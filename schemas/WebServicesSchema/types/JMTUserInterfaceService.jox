        <wsdlName>getEmailAddresses</wsdlName>
        <ReturnType type="WS_EmailAddressesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getEventRequestTypes" id="999acf44-1a0c-41df-8013-08c9e7b270e6">
        <usesRPC>default</usesRPC>
        <source>getEventRequestTypes() : WS_RequestTypesResponse webService;

/*

Purpose:			Get the Request Types allowed for the current user.

Parameters:			

Return Value:		


Date		Who		Reason
15 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
14/07/2025		naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
*/

vars
	response		: WS_RequestTypesResponse;
	completedOK		: Boolean;
	requestType		: WS_RequestType;
	
	tmpStopTable 	: CM_StopsTable;
	tmpStopTableDict : CM_StopsTableByIdDict;
	tmpToDoTask 	: CM_ToDoTaskDesc;
	tmpTaskDict 	: CM_ToDoTaskDescByCode;
	tmpRole 		: CM_SecurityRole;
	tmpTransType 	: CM_TransactionType;
	obj				: Object;
	iter			: Iterator;
	str				: String;
	dynaDict : DynaDictionary;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	//epr par 37325 22/1/16 changed to dynaDict so we could have longer strings. TO DO Tasks with max description would cause 1035 string too long
	create dynaDict transient;
	dynaDict.setMembership(CM_Object);
	dynaDict.addExternalKey(String,100,false,false);
	dynaDict.endKeys(true);
	
	// Only return those that the security role has access to
	tmpRole := app.getMySecurityRole();
	if tmpRole = null then
		app.raiseCMException(Security_role_found,
							null, 
							null);
		completedOK := true;
		return response;
	endif;

	// All transactions
	foreach tmpTransType in tmpRole.allTransactionTypesForEvents do
		//cnwmc5 - 4 MArch 2015 - PAR 33796
		if tmpTransType.trxGroup = TRANS_TYPE_GROUP_TI then
			dynaDict.putAtKey(tmpTransType.description, tmpTransType);
		endif;
	endforeach;		
	
	// Addition and removal of specific stops
	// Note: string format is used to determine whether request is for removing/clearing the stop
	// refer CMIF_EventRequestController::actionNotify();
	tmpStopTableDict := tmpRole.allStopsView;
	foreach tmpStopTable in tmpStopTableDict do
		dynaDict.putAtKey(app.eventReqFormatActivityString(app.getErrorString(AddUpper), tmpStopTable.heading), tmpStopTable);
		dynaDict.putAtKey(app.eventReqFormatActivityString(app.getErrorString(ClearUpper), tmpStopTable.heading), tmpStopTable);
	endforeach;	

	// Addition and removal of specific To Do Task
	// Note: string format is used to determine whether request is for removing/completing the task
	// refer CMIF_EventRequestController::actionNotify();	
	tmpTaskDict := tmpRole.allToDoTasksAddRemove;
	foreach tmpToDoTask in tmpTaskDict do
		dynaDict.putAtKey(app.eventReqFormatActivityString(app.getErrorString(AddUpper), tmpToDoTask.description), tmpToDoTask);
		dynaDict.putAtKey(app.eventReqFormatActivityString(app.getErrorString(ClearUpper), tmpToDoTask.description), tmpToDoTask);
	endforeach;	

	// Now create the proxy request types, returned in alphabetical order
	iter := dynaDict.createIterator();
	while iter.next(obj) do
		iter.getCurrentKeys(str);  //MTN-35226
		
		create requestType transient;
		requestType.description := str;
		response.allRequestTypes.add(requestType);
	endwhile;
	

	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog

	delete iter;
	delete dynaDict;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Get the Request Types allowed for the current user.</text>
        <wsdlName>getEventRequestTypes</wsdlName>
        <ReturnType type="WS_RequestTypesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getEventRequestTypesUpdateDel" id="0b608ee8-1026-4bb6-be60-69c57e325c7a">
        <source>getEventRequestTypesUpdateDel() : WS_RequestTypesResponse webService;

/*

Purpose:			Get the Request Types allowed for the current user.

Parameters:			

Return Value:		


Date		Who		Reason
// tfs 2708 cnwns1 26/09/16 PAR38242 POL - query on permissions
14/07/2025		naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
*/

vars
	response		: WS_RequestTypesResponse;
	completedOK		: Boolean;
	requestType		: WS_RequestType;
	
	tmpStopTable 	: CM_StopsTable;
	tmpStopTableDict : CM_StopsTableByIdDict;
	tmpToDoTask 	: CM_ToDoTaskDesc;
	tmpTaskDict 	: CM_ToDoTaskDescByCode;
	tmpRole 		: CM_SecurityRole;
	tmpTransType 	: CM_TransactionType;
	obj				: Object;
	iter			: Iterator;
	str				: String;
	dynaDict : DynaDictionary;
		passport	: CM_Passport;
	
	user		: CM_User;
	terminal	: CM_Terminal;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	//epr par 37325 22/1/16 changed to dynaDict so we could have longer strings. TO DO Tasks with max description would cause 1035 string too long
	create dynaDict transient;
	dynaDict.setMembership(CM_Object);
	dynaDict.addExternalKey(String,100,false,false);
	dynaDict.endKeys(true);
	
	// Only return those that the security role has access to
	tmpRole := app.getMySecurityRole();
	if tmpRole = null then
		app.raiseCMException(Security_role_found,
							null, 
							null);
		completedOK := true;
		return response;
	endif;

	passport := app.myPassport;
	user := passport.myUser;
	terminal := passport.myTerminal;
	
	// All transactions
	foreach tmpTransType in tmpRole.allTransactionTypesForEvents do
		//cnwmc5 - 4 MArch 2015 - PAR 33796
		if tmpTransType.trxGroup = TRANS_TYPE_GROUP_TI  then
			dynaDict.putAtKey(tmpTransType.description, tmpTransType);
		endif;
	endforeach;		
	
	// Addition and removal of specific stops
	// Note: string format is used to determine whether request is for removing/clearing the stop
	// refer CMIF_EventRequestController::actionNotify();
	tmpStopTableDict := tmpRole.allStopsView;
	foreach tmpStopTable in tmpStopTableDict where user.canUpdateStop(terminal,tmpStopTable) do
		dynaDict.putAtKey(app.eventReqFormatActivityString(app.getErrorString(AddUpper), tmpStopTable.heading), tmpStopTable);
		dynaDict.putAtKey(app.eventReqFormatActivityString(app.getErrorString(ClearUpper), tmpStopTable.heading), tmpStopTable);
	endforeach;	

	// Addition and removal of specific To Do Task
	// Note: string format is used to determine whether request is for removing/completing the task
	// refer CMIF_EventRequestController::actionNotify();	
	tmpTaskDict := tmpRole.allToDoTasksAddRemove;
	foreach tmpToDoTask in tmpTaskDict where user.canAddRemoveTodoTask(terminal,tmpToDoTask) do
		dynaDict.putAtKey(app.eventReqFormatActivityString(app.getErrorString(AddUpper), tmpToDoTask.description), tmpToDoTask);
		dynaDict.putAtKey(app.eventReqFormatActivityString(app.getErrorString(ClearUpper), tmpToDoTask.description), tmpToDoTask);
	endforeach;	

	// Now create the proxy request types, returned in alphabetical order
	iter := dynaDict.createIterator();
	while iter.next(obj) do
		iter.getCurrentKeys(str);  //MTN-35226
		
		create requestType transient;
		requestType.description := str;
		response.allRequestTypes.add(requestType);
	endwhile;
	

	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog

	delete iter;
	delete dynaDict;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <ReturnType type="WS_RequestTypesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getEventStatuses" id="7eed078e-a9e5-41d2-8f2c-4343edd9f435">
        <usesRPC>default</usesRPC>
        <source>getEventStatuses() : WS_EventStatusesResponse webService;

/*

Purpose:			Get a list of valid Event Request statuses.

Parameters:			None

Return Value:		


Date		Who		Reason
15 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	response		: WS_EventStatusesResponse;
	completedOK		: Boolean;
	eventStatus		: WS_EventStatus;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Populate response
	create eventStatus transient;
	eventStatus.description := EventRequestAnyStr;
	eventStatus.id := EventRequestStatusAny;
	response.allEventStatuses.add(eventStatus);
	
	create eventStatus transient;
	eventStatus.description := EventRequestPendingStr;
	eventStatus.id := EventRequestPending;
	response.allEventStatuses.add(eventStatus);
	
	create eventStatus transient;
	eventStatus.description := EventRequestMatchedStr;
	eventStatus.id := EventRequestMatched;
	response.allEventStatuses.add(eventStatus);
	
	create eventStatus transient;
	eventStatus.description := EventRequestActionedStr;
	eventStatus.id := EventRequestActioned;
	response.allEventStatuses.add(eventStatus);

	create eventStatus transient;
	eventStatus.description := EventRequestEmailedStr;
	eventStatus.id := EventRequestEmailed;
	response.allEventStatuses.add(eventStatus);

	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Get a list of valid Event Request statuses.</text>
        <wsdlName>getEventStatuses</wsdlName>
        <ReturnType type="WS_EventStatusesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getEventTypes" id="0929aa20-2b47-40c8-9f47-54675bae0035">
        <source>getEventTypes() : WS_EventTypeResponse webService;

/*

Purpose:			Get the Event Types available to the current user.

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	response		: WS_EventTypeResponse;
	completedOK		: Boolean;
	
	eventType		: CM_EventType;
	proxyEventType	: WS_EventType;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	foreach eventType in app.myRoot.allEventTypesByType do
		create proxyEventType transient;
		proxyEventType.setFromEventNameType(eventType.name,eventType.type.String); //27 March 2009	#cnwdz2	 PAR19281  Correct selection of event types
		response.allEventTypes.add(proxyEventType);
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Get the Event Types available to the current user.</text>
        <wsdlName>getEventTypes</wsdlName>
        <ReturnType type="WS_EventTypeResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getFilterImexForSite" id="6f4304be-23a9-47b3-ae33-7ff2a7cc1745">
        <source>getFilterImexForSite(site : Integer) : WS_IMEXStatusesResponse webService;

/*

Purpose:			Get the Imex Statuses available for the site passed in (e.g. OnSite, OffSite).

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
//04/11/2010 cnwdz2 26201
*/

vars
	response		: WS_IMEXStatusesResponse;
	completedOK		: Boolean;
	
	imexStatus		: CM_IMEXStatus;
	proxyImexStatus	: WS_IMEXStatus;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	if site &lt; 1 then
		completedOK := true;
		return response;
	endif;
	
	imexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT]; 
	if imexStatus &lt;&gt; null then
		create proxyImexStatus transient;
		proxyImexStatus.setProxyFromObject(imexStatus);
		response.allIMEXStatuses.add(proxyImexStatus);		
	endif;
	
	imexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT]; 
	if imexStatus &lt;&gt; null then
		create proxyImexStatus transient;
		proxyImexStatus.setProxyFromObject(imexStatus);
		response.allIMEXStatuses.add(proxyImexStatus);		
	endif;
	
	imexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_TRANSHIP];
	if imexStatus &lt;&gt; null then
		create proxyImexStatus transient;
		proxyImexStatus.setProxyFromObject(imexStatus);
		response.allIMEXStatuses.add(proxyImexStatus);		
	endif;
	
	if site = TI_SITE_OFFSITE or site = TI_SITE_ONSITE then
		imexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_STORAGE]; 
		if imexStatus &lt;&gt; null then
			create proxyImexStatus transient;
			proxyImexStatus.setProxyFromObject(imexStatus);
			response.allIMEXStatuses.add(proxyImexStatus);		
		endif;
	endif;
	
	imexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_REMAINONBOARD]; 
	if imexStatus &lt;&gt; null then
		create proxyImexStatus transient;
		proxyImexStatus.setProxyFromObject(imexStatus);
		response.allIMEXStatuses.add(proxyImexStatus);		
	endif;
	/*
	// Populate response - cloned from CMUI_Assistant::comboBoxIMEXStatus
	foreach imexStatus in app.myRoot.allImexStatuses do
		create proxyImexStatus transient;
		proxyImexStatus.setProxyFromObject(imexStatus);
		response.allIMEXStatuses.add(proxyImexStatus);		
	endforeach;
	*/
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Get the Imex Statuses available for the site passed in (e.g. OnSite, OffSite).</text>
        <wsdlName>getFilterImexForSite</wsdlName>
        <Parameter name="site" type="Integer"/>
        <ReturnType type="WS_IMEXStatusesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getFormDefinition" id="e88f7b1f-30af-4665-abe9-155518e9aa07">
        <usesRPC>default</usesRPC>
        <source>getFormDefinition(formRequest : String) : WS_FormDefinitionResponse webService;

/*

Purpose:			This method is designed for the JMT RIA.

Parameters:			Form name

Return Value:		Form response


Date		Who		Reason
17 Dec 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	entTableGroup	: EntTableGroup;
	entTableDef		: EntTableDef;
	entTableRow		: EntTableRow;
	dataStore		: String;
	
	formDef			: WS_FormDefinition;
	response		: WS_FormDefinitionResponse;
	userPrefs		: WS_UserPreferences;

	completedOK		: Boolean;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	create formDef transient;
	formDef.formName := formRequest;	
	response.myFormDefinition := formDef;	
	
	formDef.buildMyFormDefinition();
	
	create userPrefs transient;
	userPrefs.getPreferencesForForm(formDef);
	response.myUserPreferences := userPrefs;

	// Got to here, everything is ok
	completedOK := true;
	return response;
	
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;


end;
</source>
        <text>This method is designed for the JMT RIA.</text>
        <wsdlName>getFormDefinition</wsdlName>
        <Parameter name="formRequest" type="String"/>
        <ReturnType type="WS_FormDefinitionResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getFormLayout" id="206e5cbd-9ec7-437d-8c44-177a910ca577">
        <source>getFormLayout(formaLayoutRequest : String) : WS_FormLayoutResponse webService;

/*

Purpose:			This method is designed for the JMT RIA.

Parameters:			Form name

Return Value:		Form response


Date		Who		Reason
17 Dec 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
23 Nov 2011	cnwkpd1	PAR #28731 - fix transient leaks

*/

vars
	formDef			 : WS_FormDefinition;
	response		 : WS_FormLayoutResponse;
	//userPrefs		 : WS_UserPreferences;

	completedOK		 : Boolean;
	requestParaArray : StringArray;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create requestParaArray transient;
	formaLayoutRequest.getTokensForDelimiter("|", requestParaArray);
	if requestParaArray.size &lt;&gt; 3 then
		//rasise an error;
	endif;
	
	create formDef transient;
	formDef.formName := requestParaArray[1];		
	formDef.buildMyFormLayout(requestParaArray[2],requestParaArray[3]);
		
	// Create the response
	create response transient;
	response.formLayout := formDef.myFormLayout;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
	
epilog
	delete requestParaArray;		// PAR #28731
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;

	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;
</source>
        <text>This method is designed for the JMT RIA.</text>
        <wsdlName>getFormLayout</wsdlName>
        <Parameter name="formaLayoutRequest" type="String"/>
        <ReturnType type="WS_FormLayoutResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getFormPermissions" id="e7fcf6e4-2e0d-4efc-a844-92d63845fa2b">
        <source>getFormPermissions() : WS_FormPermissionResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#		Description
============================================================================
13 Jul 2015	cnwmc5				Initial creation
18 Sep 2019 jlgka1 	TFS 46306 	JMT - Add photos to Cargo via web apps
18 Oct 2022 navma1	ChangeRequest 53880: EUP - WMS - Damage Recording Extra Details WEB
08 Mar 2023 navlw1  ChangeRequest 53880: EUP - WMS - Repair Recording Extra Details WEB
29 Mar 2023 navlw1	ChangeRequest 55987: (Task 57161) EUP - INB/MOB - New Scanning App Permission
20 Sep 2023 navsck1 ChangeRequest 60470: EUP | Mobile DD - [FrontEnd] Work Point Selection
28 Feb 2024	navdap1	TFS 62642 Add user permission for mobile app - todo
19 Apr 2024 navmj1	TFS 63668 	Add uers permissioon for moble app - WO All - allows all apps used in WO to be displayed on landing page
09 Dec 2025 navtr3  MTN-36835 Phase 1 - Setting Permissions for viewing MTN customization UI
============================================================================*/
vars
	response				: WS_FormPermissionResponse;
	completedOK			    : Boolean;
	term					: CM_Terminal;
	formPermission			: WS_FormPermission;
	cargoEnqFormPermission	: WS_FormPermission;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers  
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	term := app.getMyTerminalDO_NOT_USE();
	
	// Special permission... Settings etc.
	create formPermission transient;
	formPermission.id := 0;
	response.allFormPermissions.add(formPermission);
	
	//07 Oct 2019	NDL	TFS 46169
	if app.getMyUser() = null or not app.getMyUser().canDo(null, Mod_WebApps) then
		app.raiseCMException1( NotLicensedToPerformAction, app.getLicenseName(Mod_WebApps), null, null );
		completedOK := true;
		return response;
	endif;
	
	if app.myCurrentUserCan(term, PmHHCargoEnquiry) then // Cargo Enquiry
		create formPermission transient;
		formPermission.id := PmHHCargoEnquiry;
		response.allFormPermissions.add(formPermission);
	endif;
	
	if app.myCurrentUserCan(term,PmHHBBDiscrepancy) then	// Cargo Discrepancy
		create formPermission transient;
		formPermission.id := PmHHBBDiscrepancy;
		response.allFormPermissions.add(formPermission);
		
		if not response.doesContain(PmHHCargoEnquiry) then
			create cargoEnqFormPermission transient;
			cargoEnqFormPermission.id := PmHHCargoEnquiry;
			response.allFormPermissions.add(cargoEnqFormPermission);
		endif;
	endif;
	
	if app.isCargoGroupEnabled then
		if app.myCurrentUserCan(term, PmHHCargoGroupMove) then // Cargo Group Move
			create formPermission transient;
			formPermission.id := PmHHCargoGroupMove;
			response.allFormPermissions.add(formPermission);
			
			if not response.doesContain(PmHHCargoEnquiry) then
				create cargoEnqFormPermission transient;
				cargoEnqFormPermission.id := PmHHCargoEnquiry;
				response.allFormPermissions.add(cargoEnqFormPermission);
			endif;
		endif;
	endif;
	if app.myCurrentUserCan(term, PmHHGrading) then // Cargo Grading
		create formPermission transient;
		formPermission.id := PmHHGrading;
		response.allFormPermissions.add(formPermission);
		
		if not response.doesContain(PmHHCargoEnquiry) then
			create cargoEnqFormPermission transient;
			cargoEnqFormPermission.id := PmHHCargoEnquiry;
			response.allFormPermissions.add(cargoEnqFormPermission);
		endif;
	endif;
	if app.myCurrentUserCan(term, PmHHCargoAltId) then // Cargo Identifier
		create formPermission transient;
		formPermission.id := PmHHCargoAltId;
		response.allFormPermissions.add(formPermission);
		
		if not response.doesContain(PmHHCargoEnquiry) then
			create cargoEnqFormPermission transient;
			cargoEnqFormPermission.id := PmHHCargoEnquiry;
			response.allFormPermissions.add(cargoEnqFormPermission);
		endif;
	endif;
	if app.myCurrentUserCan(term,PmHHBBMerge) then // Cargo Merge
		create formPermission transient;
		formPermission.id := PmHHBBMerge;
		response.allFormPermissions.add(formPermission);
		
		if not response.doesContain(PmHHCargoEnquiry) then
			create cargoEnqFormPermission transient;
			cargoEnqFormPermission.id := PmHHCargoEnquiry;
			response.allFormPermissions.add(cargoEnqFormPermission);
		endif;
	endif;
	if app.myCurrentUserCan(term,PmHHBBSplit) then // Cargo Split
		create formPermission transient;
