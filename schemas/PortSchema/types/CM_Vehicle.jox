    <JadeMethod name="setForCreate" id="90efea83-72bc-41ea-abf9-6b37fa953a11">
        <updating/>
        <source>setForCreate(pProxyVehicle:CM_Vehicle) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	unknownChassisLC : CM_TILCRow;
begin

	setForUpdate(pProxyVehicle);
	self.myTerminal := pProxyVehicle.myTerminal;
	
	create unknownChassisLC persistent;
	unknownChassisLC.setMyVehicle(self);
end;</source>
