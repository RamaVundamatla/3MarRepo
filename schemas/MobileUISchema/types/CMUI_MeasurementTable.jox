    <JadeMethod name="setMeasurementType" id="2920c012-f196-4fc7-8a87-f27c3fa9c147">
        <updating/>
        <source>setMeasurementType(_measureType : String) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/03/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars

begin
