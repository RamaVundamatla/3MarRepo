    <JadeMethod name="hasTSWClearance" id="18bce3b1-66a9-47d4-9ae2-0bda341f0b8a">
        <source>hasTSWClearance(isImport : Boolean) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 July 2018	jlgsl4	TFS 39133 - Trade Single Window - break out clearance check
31 October 2018	jlgsl4	TFS 39133 - new response codes
*/

vars
	isCleared : Boolean;
begin
	isCleared := hasNZCSClearance() or self.responseStatus = MPI_QualifiedClearance_2 or self.responseStatus = MPI_QualifiedClearance_3; // TFS 39133 16/08/18 - 31/10/18
	if not isCleared then
		isCleared := (self.responseStatus = MPI_Clearance_1 or self.responseStatus = MPI_Clearance_3// or self.responseStatus = MPI_Clearance_2 // TFS 39133 - 25/10/18 - prevent F04 clearance
		or self.responseStatus = MPI_QualifiedClearance_1) and isImport;
	endif; // to distinguish 819 clearance for TSW, NZCS_Clearance_6, from 819 for CusRes, Customs_Deliver_BreakBulk,
	return isCleared and isValidTSWMessage(); // do isValid check - most likely redundant now b/c hasNZCSClearance checks for 819...
epilog

end;</source>
        <Parameter name="isImport" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasValidTSWResponse" id="cb565aae-77ca-4f51-b9d3-05cd1946f0b3">
        <source>hasValidTSWResponse(isImport : Boolean) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 July 2018	jlgsl4	TFS 39133 - Trade Single Window - break out response check

*/

vars

begin
	return hasTSWClearance(isImport) or isToBeTSWHeld(); // TFS 39133 16/08/18
epilog

end;</source>
        <Parameter name="isImport" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="idVerify" id="4336a470-f8d2-4481-903f-3548e851fe75">
        <source>idVerify(_terminal : CM_Terminal): String;
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 23 Jul 2018	jlgsl4		TFS 39133 - Trade Single Window
// 29 Nov 2023	navpw1		TFS: 61364 (61375) - Modified to find bol on terminal by number and pack count. If the config setting is set 'Enforce Vessel Name Match for Customs EDI'
// 28 Nov 2024  navma1		MTN-19124 STWO - Uploading an EDI file 'freezes' MTN.
//30/6/2025 navsaa30 MTN-35121 CPL | TSW 819 Clearance - Clarify Error Message
// 19 Sep 2025  navvk1  MTN-35857 SNO - Add support to CUSRES for trailer cargo type

vars
	trackedItem	: CM_TrackedItem;
	message		: String;
	value		: Integer;
	voy 		: CM_Voyage;
	bolSet 		: CM_BOLSet;
	bol 		: CM_BOL;
	selectedBol : CM_BOLIn;
	bolIn		: CM_BOLIn;	// ### TFS 61364 (61375) 28Nov2023 NAVPW1
	idUpper		: String;
	valid		: Integer;
begin
	value := VALID;
	
	// ### TFS 61364 (61375) 28Nov2023 NAVPW1
	if _terminal.getConfig(EDIEnforceVeslMatchExprt).Boolean and self.billOfLading &lt;&gt; null and self.billOfLading = self.id then
		bolIn := _terminal.getBOLInByNumberPackCount(self.billOfLading, self.packCount,valid);		//navsaa30 #35121
		if bolIn &lt;&gt; null then
			value := VALID;
		else
			value := WARNING;
			if valid = 0 then
				message := "Bol not found on voyage.";
			elseif value = -1 then
				message := "Packages doesn't match cargo count on BOL.";
			endif;
		endif;
			
	// ### TFS 61364 (61375) 28Nov2023 NAVPW1
	elseif self.billOfLading &lt;&gt; null and self.billOfLading = self.id then	//28 Mar 20-17	NDL	TFS 3857
		voy := self.getMyVoyage;
		if voy = null then
			value := WARNING;
			message := "Bol Voyage not found.";
			
		else
			create bolSet transient;
			voy.getBOLInsFromNumber( bolSet, BOLType_GeneralBillOfLading, self.id, true, null );
			
			idUpper := self.id.toUpper;					//28.11.2024 navma1 #MTN-19124
			
			foreach bol in bolSet do
				if bol.number.toUpper = idUpper then	//28.11.2024 navma1 #MTN-19124
					selectedBol := bol.CM_BOLIn;	
					break;
				endif;
			endforeach;
			
			if selectedBol = null then
				value := WARNING;
				message := "Bol not found on voyage.";
				
			endif;
				
		endif;
	
	else
	
		trackedItem := _terminal.allOnsiteTIsByIdCargoType[id, self.cargoType];
		
		if self.myCargoType = null and _terminal.defaultTrailerCargoType = null then // MTN-35857 Trailer support 19/09/2025
			value := WARNING;
			message := app.getErrorString(ERR_TERM_CONFIG_DEF_TRAIL); 				 //08.01.2026 navbs1  #35857
		elseif trackedItem = null then
			value := WARNING;
			//message := self.myCargoType.description &amp; " is not onsite.";						//08.01.2026 navbs1  #35857
			message := app.getErrorString1(Not_onsite,self.myCargoType.description);			//08.01.2026 navbs1  #35857
		else
			if not trackedItem.isStopSetToBeProcessed(StopProcessEDICustomImport)
			and not trackedItem.isStopSetToBeProcessed(StopProcessEDICustomExport)
			and not self.isToBeTSWHeld() // TFS 39133 - don't need warning if TSW stop's being added
			then
				value	:=	WARNING;
				//message	:=	self.myCargoType.description &amp; " does not have relevant stop loaded.";	//08.01.2026 navbs1  #35857
				message	:=	app.getErrorString1(No_relevant_stop_loaded, self.myCargoType.description);  //08.01.2026 navbs1  #35857
			endif;
		endif;
	
	endif;
	
	return value.String &amp; message;
	
epilog

	delete bolSet;
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isCREMessage" id="873b4488-ee2b-4586-8eaa-c38d5af225b7">
        <source>isCREMessage() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Oct 2018	jlgsl4	TFS39133 - EX1 'all clear' only applies to CRE

*/

vars

begin
	return self.customsRef = Valid_TSWCREDocumentName;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCancel" id="b659af29-a55c-4ebe-95b7-7afdb916cdca">
        <source>isCancel(): Boolean;
//----------------------------------------------------------------
//	Created:	09 June 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	return self.responseStatus = Customs_Import_Cancel or
		self.responseStatus = Customs_Export_Cancel or
		self.responseStatus = Customs_Tranship_Cancel or
		self.responseStatus = MAF_ContainerCancellation or
		self.responseStatus = SEP_ContainerCancellation;// or
		//self.responseStatus = CustomsX12_Hold1H;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isForExport" id="4230f4dc-95d0-4b81-93fa-4a2db2818c47">
        <source>isForExport(): Boolean;
//----------------------------------------------------------------
//	Created:	15 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//11 Jul 2018	jlgsl4	TFS 39133 - Trade Single Window; 25/10/18 - for onship cargo

vars

begin
	return self.responseStatus = Customs_Export_Cleared or
		self.responseStatus = Customs_Export_Cancel or
		self.responseStatus = SEP_ContainerRelease or
		self.responseStatus = SEP_InspectionRequired or
		(self.hasValidTSWResponse(false) and self.isTSWExport) or // TFS 39133 25/10/18
		self.responseStatus = SEP_ContainerCancellation;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isForImport" id="720ccbb1-6607-4d71-ad82-760124351b8d">
        <source>isForImport(): Boolean;
//----------------------------------------------------------------
//	Created:	15 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//11 Jul 2018	jlgsl4	TFS 39133 - Trade Single Window; 25/10/18 - for onship cargo

vars

begin

	return self.responseStatus = Customs_Import_Cleared or
		self.responseStatus = Customs_Import_Cancel or
		self.responseStatus = MAF_ActionRequired or
		self.responseStatus = MAF_ContainerCancellation or
		self.responseStatus = CustomsX12_Hold1H or 
		self.responseStatus = CustomsX12_Hold1C or
		self.responseStatus = Polish_Customs_Cleared or
		(self.hasValidTSWResponse(true) and self.isTSWImport) or // TFS 39133 25/10/18
		self.responseStatus = CustomsX12_DispCode69;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isICRMessage" id="650d5b24-4101-40b1-bfc1-c3252175b213">
        <source>isICRMessage() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Oct 2018	jlgsl4	TFS39133 - IM1 'all clear' only applies to ICR

*/

vars

begin
	return self.customsRef = Valid_TSWICRDocumentName;
epilog

end;</source>
