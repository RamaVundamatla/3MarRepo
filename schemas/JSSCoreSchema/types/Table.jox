    <JadeMethod name="jssFindObjectRow" id="d4e31c2b-2487-416f-afe9-321be0542daa">
        <updating/>
        <source>jssFindObjectRow(pValue:Object):JadeTableRow updating;
// --------------------------------------------------------------------------------
// Created:		04 August 2001 by cnwdad1
//
// Purpose:		This method scans the receiver's rows and returns the first
//				JadeTableRow who's itemObject matches the pValue parameter.
//
// Parameters:	pValue - The object to search for.
//
// Returns:		The JadeTableRow for the (first) row with a matching object, or
//				null if the object isn't found.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowIndex		: Integer;
	startRow		: Integer;
	rowCount		: Integer;
	tableRowObj		: JadeTableRow;
	
begin
	startRow	:=	self.fixedRows + 1;
	rowCount	:=	self.rows;
	
	foreach rowIndex in startRow to rowCount do
		tableRowObj	:=	self.accessRow(rowIndex);
			
		if tableRowObj.itemObject = pValue then
			return tableRowObj;
		endif;
	endforeach;
end;</source>
