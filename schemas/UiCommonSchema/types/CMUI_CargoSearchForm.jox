    <JadeMethod name="lstColour_doUpdateValue" id="445867fa-5723-4997-8134-0bf5b9feb359">
        <controlMethod name="CMUI_FieldGeneric::doUpdateValue"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstColour_doUpdateValue(_value: Any) updating;
//
// Purpose:			
//
