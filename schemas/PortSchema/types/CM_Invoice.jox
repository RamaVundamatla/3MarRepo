Date		Who		Reason
01 April 2019	jlgndl1	Initial creation	TFS 44080 - Step back iteratively
														to find the original in the chain

*/

vars

	postedPendingInv : CM_Invoice;

begin

	if self.myPostedPendingInvoice &lt;&gt; null then
