    <JadeMethod name="setupCamsWebservice" id="cb401593-02c7-48be-9775-6062fbad2a75">
        <source>setupCamsWebservice();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/05/2024	navcs2	ChangeRequest 59188: EUP | API Search - External Webservice Monitor
14/08/2024	navcs2	Bug 65590: EUP - EWS Monitor - Free text search not working
27/09/2024	navcs2	ChangeRequest 66181
25/11/2025	navdap1	MTN-36569 CPL | Reefer Runner Integration
*/

vars
	terminals : CM_TerminalByCodeDict;
begin
	self.tblInterfaces.clear();				// 27/09/2024	navcs2	ChangeRequest 66181
	
	self.shtBasicInfo.caption := self.Interface_Cams;
	self.shtInterfaceName.caption := "Cams Protocols";
	
	create terminals transient;
	self.getTerminals(terminals);
	self.addCamsProtocols(terminals);
	
	self.txtInvoiceFO.visible := false;
	self.lblDataAction.visible := false;
	self.cmbAction.visible := false;
	self.lblCreatedBy.visible := false;
	self.txtCreatedBy.visible := false;
	self.cmbEWSNameInvoiceAPI.visible := false;
	self.lblEWSName.visible := false;
	self.lblType.visible := false;
	self.cmbType.visible := false;
	self.grpType.visible := false;
