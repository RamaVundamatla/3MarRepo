    </JadeMethod>
    <JadeMethod name="setGriddedStackHeights" id="49520d1e-315d-4412-a465-fb2a403bd8aa">
        <updating/>
        <source>setGriddedStackHeights( _proxy: CM_TerminalAreaMaster ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2020	jlgndl1	Initial creation	TFS 49984

*/

vars

	pxySet : CM_ObjectMatchCriteriaSet;
	pxyObj : CM_ObjectMatchCriteria;
	pxyTAM : CM_TerminalAreaMaster;
	pxyMaxStackHeight : CM_GriddedTAStackHeight;
	realMaxStackHeight : CM_GriddedTAStackHeight;

begin

	self.allGriddedTAStackHeights.purge();
	
	create pxySet transient;
	_proxy.allGriddedTAStackHeights.copy( pxySet );
	
	foreach pxyObj in pxySet do
		pxyMaxStackHeight :=  pxyObj.CM_GriddedTAStackHeight;
		pxyTAM := pxyMaxStackHeight.myTerminalAreaMaster;
		pxyMaxStackHeight.setMyTerminalAreaMaster( null );	// unset on thne proxy before the persistent create methods
		create realMaxStackHeight persistent;
		realMaxStackHeight.setForUpdate( pxyMaxStackHeight );
		realMaxStackHeight.setMyTerminalAreaMaster( self );
		pxyMaxStackHeight.setMyTerminalAreaMaster( pxyTAM );	// reset after
	endforeach;

epilog

	delete pxySet;

end;</source>
        <Parameter name="_proxy" type="CM_TerminalAreaMaster"/>
    </JadeMethod>
    <JadeMethod name="setID" id="c8a420ae-385f-428b-8303-a21578100e4e">
