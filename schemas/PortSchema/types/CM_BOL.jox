    <JadeMethod name="canUserAccessSelf" id="dfb30231-53f1-4723-aa56-f5a1c9208e4b">
        <source>canUserAccessSelf(_user: CM_User; _failedDAC  :CM_DataAccessController output; _passport: CM_Passport): Boolean;
//----------------------------------------------------------------
//	Created:	17 August 2005	by Jason Chapman  (cnwjc2)
//
//	Copied from canUserViewMe on ti
//
//----------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 15/10/2015   cnwma1 		PAR #36606 	Web Service Methods need to vaklidate Terminal/DataAccess on OIDs
vars
	dac	:  CM_DataAccessController;
	carr : CM_Carrier;
	consnee : CM_ConsigneeConsignor;
	consnor : CM_ConsigneeConsignor;
	root : CM_Root;
	pp : CM_Passport;
	dacDict	: CM_DataAccessCntrlByClassDict;
	
	canViewTerminal : Boolean;	//21 Jul 2016	NDL	TFS 2307
	bolTerminal : CM_BOLTerminal;	//21 Jul 2016	NDL	TFS 2307
	terminal : CM_Terminal;	//21 Jul 2016	NDL	TFS 2307

begin
	if self.myTerminal &lt;&gt; null and not self.myTerminal.canUserAccessSelf(_user, _failedDAC, _passport) then   // 15/10/2015 cnwma1	PAR #36606
		//return false;
		//21 Jul 2016	NDL	TFS 2307
		//OK we aren't allowed to see this terminal but there can be others that we might be allowed to see it from.
		canViewTerminal := false;
		foreach bolTerminal in self.allBOLTerminals do
			terminal := bolTerminal.myTerminal;
			if terminal &lt;&gt; null then
				canViewTerminal := terminal.canUserAccessSelf(_user, _failedDAC, _passport);
			endif;
			if canViewTerminal then
				break;
			endif;
		endforeach;
		if not canViewTerminal then
			return false;
		endif;
	endif;
	
	if _user &lt;&gt; null then
		dacDict := _user.allDataAccessControllers;
	else
		pp := _passport;	//Local var for speed.
		dacDict := pp.allDataAccessControllers;
	endif;

	if dacDict.isEmpty then
		return true;
	endif;

	root := app.myRoot;

	dac := dacDict[CM_Carrier.name];
	if dac &lt;&gt; null then
		carr := root.allCarriers[self.carrierCode];
		if carr = null and (not dac.includeIfNull) then
			_failedDAC := dac;
			return false;
		elseif (not dac.canAccess(carr)) then
			_failedDAC := dac;
			return false;
		endif;
	endif;

	dac := dacDict[CM_ConsigneeConsignor.name];
	if dac &lt;&gt; null then
		consnee := root.allConsigneeConsignors[self.consignee];
		if consnee = null and (not dac.includeIfNull) then
			_failedDAC := dac;
			return false;
		elseif (not dac.canAccess(consnee)) then
			_failedDAC := dac;
			return false;
		endif;
		consnor := root.allConsigneeConsignors[self.consignor];
		if consnor = null and (not dac.includeIfNull) then
			_failedDAC := dac;
			return false;
		elseif (not dac.canAccess(consnor)) then
			_failedDAC := dac;
			return false;
		endif;
	endif;

	dac := dacDict[CM_Operator.name];
	if dac &lt;&gt; null then
		if self.myOperator = null and (not dac.includeIfNull) then
			_failedDAC := dac;
			return false;
		elseif (not dac.canAccess(self.myOperator)) then
			_failedDAC := dac;
			return false;
		endif;
	endif;
	
	//31 May 2016	NDL	TFS 2022
	dac := dacDict[CM_SubTerminal.name];
	if dac &lt;&gt; null then
		if self.mySubTerminal = null and (not dac.includeIfNull) then
			_failedDAC := dac;
			return false;
		elseif (not dac.canAccess(self.mySubTerminal)) then
			_failedDAC := dac;
			return false;
		endif;
	endif;

	return true;

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
