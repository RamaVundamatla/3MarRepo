    <JadeMethod name="getSpecialStowStr" id="4cba672c-abeb-4fb2-aa22-db13e2d85fef">
        <source>getSpecialStowStr(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 November 2012	cnwndl1	Initial creation	Par 30754

*/

vars
	invalid 		: Boolean;
	commGrp			: CM_CommodityGroup;
	
begin

	if self.getAttrHazardous() then
		return app.getErrorString(HazardousAbbrev);
	elseif self.getAttrOverDimensioned() then								
		return "ODIM";
	else
		commGrp := self.getAttrCommodityGroup();
		if commGrp &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, commGrp, invalid);
			if commGrp.isSpecialStow then
				return commGrp.code;
			endif;
		endif;
	endif;
	
	return null;
	
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
