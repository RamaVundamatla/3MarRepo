    <JadeMethod name="doSave" id="f73af779-1b2a-4019-a187-96e4863e876d">
        <updating/>
        <source>doSave(): Boolean updating;

vars
	errObj			:	CM_Error;
	idx				:	Integer;
	tmpListBox		:	ListBox;
	ignoreWarnings,
	rtnValue		:	Boolean;
	proxyPortGroup	:	CM_PortGroup;
	code,
	groupDescription:	String;
	theForm 		: 	SOP_TableMaintForm;
	thePorts		:	CM_PortByCodeDict;
begin
  theForm := self.myForm; 
	code := theForm.tblInput1.getValueByName(ETRow_Code).String;
	groupDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_PortGroup transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	proxyPortGroup := theForm.myProxyObject.CM_PortGroup;
	
	create thePorts transient;
	theForm.mulSelect1.getSelected(thePorts);
	
	proxyPortGroup.setProxy(code, groupDescription, thePorts);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreatePortGroup(proxyPortGroup, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdatePortGroup(proxyPortGroup,app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return app.myPassport.trxCompletedOK;
	
epilog
	delete thePorts;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
