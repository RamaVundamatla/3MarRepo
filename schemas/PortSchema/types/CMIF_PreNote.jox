    <JadeMethod name="setFromTI" id="f87fd9d7-24f8-4bac-826a-95ded58209b1">
        <updating/>
        <source>setFromTI(_ti: CM_TrackedItem; _terminal: CM_Terminal) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
20 Nov 2007	cnwer1	Initial creation - PAR#xxxx
27 Jun 2023	navdap1	TFS 58813 EUP Instructions and other corrections
18 Jul 2023	jlirs1		TFS 59187 (59019) EUP - Manifest Processing - Container Reference Field
12 Jun 2024 navhn30	ChangeRequest 64067: CUX | Include additional fields in APIs (Free Text)
*/
vars

begin

	inheritMethod(_ti, _terminal);
	self.transportMode := _ti.getReceiptTransportModeStr;
	self.pinNo := _ti.getPinNumber;
	
	self.customsReference 		:= _ti.customsReference;
	
	//29 Jul 2013	NDL	Par 31763
	self.expectedArrivalDate	:= _ti.getExpectedArrivalDate();
	self.expectedArrivalTime	:= _ti.getExpectedArrivalTime();
	
	self.vehicle				:= _ti.vehicle;
	self.wagon					:= _ti.wagon;
	self.myWagonClass			:= _ti.getMyNotifiedWagonClass;	//12 May 2014	NDL	Par 33615
	self.destinationTerminal	:= _ti.destinationTerminal;		// TFS4322 MAP 25/5/17
	self.invoiceNumber			:= _ti.invoiceNumber;			// TFS4322 MAP 25/5/17
	self.orderNumber			:= _ti.orderNumber;				// TFS4322 MAP 26/5/17
	
	//03 May 2018	NDL	TFS 37795
	self.remarksAdditional1 := _ti.remarksAdditional1;
	self.remarksAdditional2 := _ti.remarksAdditional2;
	
	// ### TFS 57812 (58439) 15Jun2023 NAVPW1
	self.itemised := _ti.itemised;
	self.secondaryBarcodeId := _ti.secondaryBarcodeId;
	self.mySortingMethod := _ti.mySortingMethod;
	self.manifestNumber := _ti.manifestNumber;			// TFS 58813
	// ### TFS 57812 (58439) 15Jun2023 NAVPW1
	
	self.containerNumberText := _ti.getContainerNumberText();	//18 Jul 2023	jlirs1		TFS 59187 (59019) EUP
	self.shipmentNumber := _ti.shipmentNumber;					//12 Jun 2024	navhn30		TFS #64067
	if _ti.myCustomerPriority &lt;&gt; null then
		self.customerPriority := _ti.myCustomerPriority.code;	//12 Jun 2024	navhn30		TFS #64067
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
