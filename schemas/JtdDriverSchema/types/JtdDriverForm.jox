    <JadeMethod name="jtdCmdStart" id="9ecce73b-6b84-459a-a3a2-9ebd67a3dc76">
        <updating/>
        <source>jtdCmdStart(param : String) updating, protected;

begin
	if self.jtdState = JtdTrxDriverStarted then
		return;
	endif;
	
	self.jtdCmdStop(null);
	self.jtdSetState(JtdTrxDriverStarted, null);
	self.jtdWaitingOnPingAck := false;
	
	app.jtdMyContext.jtdSetTrxSelectionState(JtdContext.JtdSelectFromProlog);
	
	// start running transactions via a notification so that our
	// current call stack can unwind first
	self.causeEvent(self.JtdRunTransactionsEventNumber, true, null);
end;</source>
        <access>protected</access>
        <Parameter name="param" type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdCmdStop" id="1c7e1108-6afc-46b7-8bb4-90ae55858690">
        <updating/>
        <source>jtdCmdStop(param : String) updating, protected;

begin
	// make sure our final 'stop' ping goes out, even if we're
	// still waiting for an acknowledgement	of our last ping
	self.jtdWaitingOnPingAck := false;

	self.jtdAllMethodProfilesRun.clear;
	
	app.jtdMyContext.jtdClearTrxSelectionState;

	if self.jtdState = JtdTrxDriverStopped then
		return;
	endif;
	
	self.jtdSetState(JtdTrxDriverStopped, null);

	// send our 'stop' ping...
	self.jtdCmdPing(null);
	
	// ...and don't worry about waiting for an acknowledgement
	// because we've stopped anyway
	self.jtdWaitingOnPingAck := false;
	if app.jtdMyTransactionGenerator &lt;&gt; null and global.isValidObject(app.jtdMyTransactionGenerator) then
		app.jtdMyTransactionGenerator.stop();
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="param" type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdCmdTerminate" id="c94124f9-9eab-4530-83e9-26b9895b1a46">
        <source>jtdCmdTerminate(param : String) protected;

// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support

begin
	if app.jtdMyContext.jtdShutdownDelaySecs &gt; 0 then
		// sleep for a random period up to jtdShutdownDelayIntervalSecs
		// seconds before terminating in order to stagger application
		// shutdown a bit
		process.sleep(((app.random(app.actualTimeServer.time.milliSecond) mod// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
			app.jtdMyContext.jtdShutdownDelaySecs) + 1) * 1000);
	endif;

	terminate;
end;</source>
        <access>protected</access>
        <Parameter name="param" type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdDoTransaction" id="7d6bf93c-7888-40d2-817a-38565d876dd2">
        <updating/>
        <source>jtdDoTransaction() : Boolean protected, updating;

vars
	result, drvErrNo, userErrNo, pingInt, n : Integer;
	trxGenMthDesc : JtdTrxGenMethodDesc;
	genSecs, trxSecs : Real;
	mp : JtdMethodProfile;
	invoked : Boolean;
	jtd : JtdContext;
	time : Time;
	
begin
	jtd := app.jtdMyContext;

	// select a transaction to run
	while true do
		a_CurrentState := method.name &amp; " - about to select transaction";
		mp := jtd.jtdSelectTransaction;
		if mp &lt;&gt; null then
			// we've found a transaction method so break out
			break;
		endif;
		
		if jtd.jtdTrxSelectionState = JtdContext.JtdSelectFromProlog then
			// no prolog methods, so start selecting from the main methods
			jtd.jtdSetTrxSelectionState(JtdContext.JtdSelectFromMain);

		elseif jtd.jtdTrxSelectionState = JtdContext.JtdSelectFromMain then
			// if we're to stop when all main methods have been run at least
			// once, then as there are no main methods (mp is null), start
			// selecting from the epilog methods
			if jtd.jtdMyDriverProfile.jtdStopWhenAllRun then
				jtd.jtdSetTrxSelectionState(JtdContext.JtdSelectFromEpilog);
			else
				// there are no main methods to run, so break out (we run
				// epilogs only when jtdStopWhenAllRun is true)
				break;
			endif;

		else
			// if we're running epilog methods then break out (if we're in
			// the epilog and don't find a method then we want to break out
			// anyway, because there are no more methods to select from)
			break;
		endif;
	endwhile;
	
	if mp &lt;&gt; null then
		trxGenMthDesc := mp.jtdMyTrxGenMethodDesc;
	endif;
	
	if mp = null or trxGenMthDesc = null then
		self.jtdSetState(JtdTrxDriverStopped, "No transactions to perform");
		self.jtdCmdStop(null);
		return false;
	endif;

	pingInt := jtd.jtdAutoPingResponseInterval;

	if pingInt &gt; 0 then
		self.jtdSetState(JtdTrxDriverRunningTrx, trxGenMthDesc.jtdMethodName &amp; " [" &amp;
			(pingInt - (self.jtdMySummary.jtdGetTotalTransactions mod pingInt)).String &amp; ']');
	else
		self.jtdSetState(JtdTrxDriverRunningTrx, trxGenMthDesc.jtdMethodName);
	endif;

	invoked := false;	
	result := 0;
	drvErrNo := 0;
	userErrNo := 0;

	on Exception do self.jtdTransactionDriverExHandler(exception, drvErrNo);
//	write app.actualTime.String &amp; ' ' &amp; process.String;
	trxGenMthDesc.jtdDoTransaction(invoked, result, userErrNo);

	on Exception do null;

	genSecs := jtd.jtdGetGenerationSecs;
	trxSecs := jtd.jtdGetTransactionSecs;
	
	self.jtdSetState(JtdTrxDriverStarted, null);

	if invoked then
		self.jtdMySummary.jtdUpdateStatistics(trxGenMthDesc.jtdIsUpdateTransaction, genSecs,
			trxSecs, result, userErrNo);
		trxGenMthDesc.jtdMySummary.jtdUpdateStatistics(genSecs, trxSecs, result, userErrNo);
			
		if pingInt &gt; 0 then
			if self.jtdMySummary.jtdGetTotalTransactions mod pingInt = 0 then
				self.jtdCmdPing(null);
			endif;
		endif;
	endif;

	self.jtdRefreshWindow(false);

	// if we're to stop when all main profile entries have been run at least once,
	// check to see whether or not we've done enough
	if jtd.jtdMyDriverProfile.jtdStopWhenAllRun and
	   jtd.jtdTrxSelectionState = JtdContext.JtdSelectFromMain and
	   (not jtd.jtdLastMethodHasCallsRemaining)
	then
		if not self.jtdAllMethodProfilesRun.includes(mp) then
			self.jtdAllMethodProfilesRun.add(mp);
		endif;

		// assume that if the number of unique main methods run is at least the number
		// of available main methods, then all main methods have been run at least once
		if self.jtdAllMethodProfilesRun.size &gt;= jtd.jtdMyDriverProfile.jtdAllMethodProfiles.size then
			// if our driver profile has an epilog, we must run it before stopping
			if jtd.jtdMyDriverProfile.jtdHasEpilog then
				jtd.jtdSetTrxSelectionState(JtdContext.JtdSelectFromEpilog);
			else
				// no epilog, so stop
				self.jtdCmdStop(null);
				// tell any controllers that we've just stopped ourself
				system.causeEvent(jtd.jtdStopResponseEventNo, true, getOidStringForObject(process));
				return false;
			endif;
		endif;

	// otherwise, stop if we've just run the last epilog method
	elseif jtd.jtdTrxSelectionState = JtdContext.JtdSelectFromEpilog and
		   mp.jtdIsLastEpilogMethod and
		   (not jtd.jtdLastMethodHasCallsRemaining)
	then
		self.jtdCmdStop(null);
		// tell any controllers that we've just stopped ourself
		system.causeEvent(jtd.jtdStopResponseEventNo, true, getOidStringForObject(process));
		return false;
	endif;

	v_waitMilliSecs := 0;
//write time.String &amp; ' Start calculating timer' ;		
	// transaction delays (set from the controller app) take precedence over
	// profile delay intervals
	if jtd.jtdTrxDelay &gt; 0 then
		// wait for the specified transaction delay
		v_waitMilliSecs := jtd.jtdTrxDelay;
	else
		n := mp.jtdThinkSecs;
		if n &lt; 1 and jtd.jtdMyDriverProfile &lt;&gt; null then
			n := jtd.jtdMyDriverProfile.jtdDefaultThinkSecs;
		endif;
		if n &gt; 0 then
			// we don't have a transaction delay, but our profile does have a
			// delay interval specified (either on the method or the profile)
			if n &gt; JtdMaxThinkSeconds then
				n := JtdMaxThinkSeconds;
			endif;
//			v_waitMilliSecs := jtd.jtdPoissonRandom((n * 1000) div 2);
			if app.jtdMyGenerationHelper &lt;&gt; null and app.jtdMyGenerationHelper.repeatable then
				v_waitMilliSecs := (n * 1000);
			else
				v_waitMilliSecs := jtd.jtdPoissonRandom((n * 1000));
			endif;
			if v_waitMilliSecs &lt; 1 then
				// belts and braces: default to a 1 second delay
				v_waitMilliSecs := 1000;
			endif;
		endif;
	endif;
//write 'New calculated time ' &amp; v_waitMilliSecs.String;
	// give us a chance to process command notifications and GUI events and
	// wait for the required delay interval (which may be zero)
//	app.doWindowEvents(waitMilliSecs);
//	app.doWindowEvents(0);	
	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdGetPingResponseString" id="ce619aec-e907-4d88-a1e5-e7e2f69619fb">
        <source>jtdGetPingResponseString() : String protected;

vars
	localTotal, localAvail, thinTotal, thinAvail : Integer;
	profileName, s, localCPU, thinCPU : String;
	mthCount : Integer; // not used
	jtd : JtdContext;
	
begin
	jtd := app.jtdMyContext;
	
	jtd.jtdGetProfileNameAndMthCount(profileName, mthCount);
	
	// Semi-colons are delimiters in the notification info, so we want
	// to keep things simple and not confuse the controller with any
	// embedded semi-colons in the profile name. If the profile name
	// includes semi-colons, we'll just replace them with underscores
	// in the ping data. The name is used only for display and profile
	// names are unlikely to contain semi-colons in the first place.
	if profileName.pos(';', 1) &gt; 0 then
		profileName.replaceChar(';', '_');
	endif;

	jtd.jtdGetMachineDetails(localTotal, localAvail, thinTotal,
		thinAvail, localCPU, thinCPU);
		
	// semi-colons in the local computer name are replaced when it is
	// set on the context
	if jtd.jtdComputerNameLocal &lt;&gt; null then
		s := jtd.jtdComputerNameLocal &amp; ';' &amp; localTotal.String &amp;
			';' &amp; localAvail.String &amp; ';' &amp; localCPU &amp; ';';
	else
		s := ";0;0;;";
	endif;
	
	// semi-colons in the thin client computer name are replaced when
	// it is set on the context
	if jtd.jtdComputerNameThinClient &lt;&gt; null then
		s := s &amp; jtd.jtdComputerNameThinClient &amp; ';' &amp; thinTotal.String &amp;
			';' &amp; thinAvail.String &amp; ';' &amp; thinCPU &amp; ';';
	else
		s := s &amp; ";0;0;;";
	endif;

	return getOidStringForObject(process) &amp;
		   ';' &amp;
		   profileName &amp;
		   ';' &amp;
		   s &amp;
		   self.jtdMySummary.jtdAsString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdRefreshWindow" id="58f8c905-7c33-439d-9732-f2f0af2ddae4">
        <updating/>
        <source>jtdRefreshWindow(forceRefresh : Boolean) updating, protected;

vars
	jds : JtdDriverSummary;
	hours, mins : Integer;
	secs : Real;
	
begin
	if (not forceRefresh) and (not self.grpDetails.enabled) then
		// don't display any status information
		return;
	endif;
	
	jds := self.jtdMySummary;

	tblDetails.accessCell(3, 2).text :=
		jds.jtdTotalReadTrxSecs.jtdRoundedSeconds.String &amp; Tab &amp;
		jds.jtdGetReadTPS.roundedTo(2).String            &amp; Tab &amp;
		jds.jtdTotalReadGenSecs.jtdRoundedSeconds.String &amp; Tab &amp;
		jds.jtdGetReadGPS.roundedTo(2).String            &amp; Tab &amp;
		jds.jtdTotalReads.String                         &amp; Tab &amp;
		jds.jtdTotalReadErrs.String;

	tblDetails.accessCell(4, 2).text :=
		jds.jtdTotalUpdTrxSecs.jtdRoundedSeconds.String &amp; Tab &amp;
		jds.jtdGetUpdTPS.roundedTo(2).String            &amp; Tab &amp;
		jds.jtdTotalUpdGenSecs.jtdRoundedSeconds.String &amp; Tab &amp;
		jds.jtdGetUpdGPS.roundedTo(2).String            &amp; Tab &amp;
		jds.jtdTotalUpds.String                         &amp; Tab &amp;
		jds.jtdTotalUpdErrs.String;
	
	tblDetails.accessCell(5, 2).text :=
		jds.jtdGetTotalTrxSecs.jtdRoundedSeconds.String &amp; Tab &amp;
		jds.jtdGetTPS.roundedTo(2).String               &amp; Tab &amp;
		jds.jtdGetTotalGenSecs.jtdRoundedSeconds.String &amp; Tab &amp;
		jds.jtdGetGPS.roundedTo(2).String               &amp; Tab &amp;
		jds.jtdGetTotalTransactions.String              &amp; Tab &amp;
		jds.jtdGetTotalErrs.String;

	secs := app.jtdMyContext.jtdTotalRunSecs;
	hours := secs div 3600;

	secs := secs mod 3600;
	mins := secs div 60;
	
	secs := (secs mod 60).jtdRoundedSeconds;
	
	self.lblTotalSecs.caption := hours.String &amp; 'h ' &amp; mins.String &amp; 'm ' &amp; secs.String &amp; 's';
	
	self.lblNumDeadlocks.caption := jds.jtdTotalDeadlocks.String;
	self.lblNumLocks.caption := jds.jtdTotalLocks.String;
	self.lblNumUnhandled.caption := jds.jtdTotalUnhandledExceptions.String;
end;</source>
        <access>protected</access>
        <Parameter name="forceRefresh" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdRestoreInitialPosition" id="ec54962c-c052-4c69-9524-4ab5c041170a">
        <updating/>
        <source>jtdRestoreInitialPosition() updating, protected;

begin
	if app.jtdMyContext.jtdHasInitialFormPosition then
		self.move(app.jtdMyContext.jtdInitialFormLeft, app.jtdMyContext.jtdInitialFormTop,
			app.jtdMyContext.jtdInitialFormWidth, app.jtdMyContext.jtdInitialFormHeight);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdResumeInvalidMsgExHandler" id="2e248120-fe2f-4f61-a11f-0e241323605f">
        <source>jtdResumeInvalidMsgExHandler(exObj : Exception; errNo : Integer output) : Integer protected;

constants
	InvalidMessage = 1010;
	
begin
	errNo := exObj.errorCode;
	if errNo = InvalidMessage then
		return Ex_Resume_Next;
	endif;
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="errNo" type="Integer" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jtdRunTransactions" id="b11749f8-ca14-4e7b-9e7b-e913f1f11ccc">
        <updating/>
        <source>jtdRunTransactions() updating, protected;

vars
	result : Boolean;
	errNo : Integer;
	
begin

	// give us a chance to process command notifications and GUI events
//	app.doWindowEvents(0);
	v_stop := false;
	
	if app.stopped or self.jtdState &lt;&gt; JtdTrxDriverStarted then
		app.logMessage("Run was stopped - ignoring timerEvent");
		v_stop := true;
//		write '[' &amp; process.node.String &amp; "] Process: Stopped I. " &amp; self.jtdState.String;
		return;
	endif;

	result := false;
	errNo := 0;
	
	on Exception do self.jtdTransactionDriverExHandler(exception, errNo);

	a_CurrentState := "About to call jtdDoTransaction";
	result := self.jtdDoTransaction;
	a_CurrentState := "Exited call to jtdDoTransaction.  Result = " &amp; result.String;
	
	// if jtdDoTransaction encounters an exception that it doesn't handle,
	// our handler (armed above) will abort any current transaction and
	// resume to here, so we'll just return to an idle state

	on Exception do null;

	if (not result) or errNo &lt;&gt; 0 then 
		v_stop := true;
//		write '[' &amp; process.node.String &amp; "] Process: Stopped II.";
		return;
	endif;

	if self.jtdState &lt;&gt; JtdTrxDriverStarted then
		v_stop := true;
//		write '[' &amp; process.node.String &amp; "] Process: Stopped III.";
		return;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdSetProfileBubbleHelp" id="2192a8c6-2e45-4f7f-bb58-5e6078d707d2">
        <source>jtdSetProfileBubbleHelp() protected;

vars
	profileName : String;
	mthCount : Integer;
	
begin
	app.jtdMyContext.jtdGetProfileNameAndMthCount(profileName, mthCount);
	
	self.picIcon.bubbleHelp := "Profile: " &amp; profileName &amp; CrLf &amp;
		"Methods: " &amp; mthCount.String &amp; CrLf &amp;
		"Startup Delay: " &amp; app.jtdMyContext.jtdStartupDelaySecs.String &amp; " secs" &amp; CrLf &amp;
		"Shutdown Delay: " &amp; app.jtdMyContext.jtdShutdownDelaySecs.String &amp; " secs" &amp; CrLf &amp; CrLf &amp;
		"Driver Framework Version: " &amp; app.jtdMyContext.jtdGetVersionString;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdSetState" id="cd3c4b43-9f23-45df-9dc9-453b003de712">
        <updating/>
        <source>jtdSetState(newState : Integer; newMsg : String) updating, protected;

vars
	jtd : JtdContext;
	s : String;
	r : Real;
	
begin
	jtd := app.jtdMyContext;

	self.jtdState := newState;

	if not self.statusLine.enabled then
		// don't display any status information
		return;
	endif;
	
	s := getOidStringForObject(process) &amp; ": ";
	
	if newState = JtdTrxDriverStarted then
		s := s &amp; "Started";
		self.statusLine.backColor := LightGreen;

	elseif newState = JtdTrxDriverStopped then
		s := s &amp; "Stopped";
		self.statusLine.backColor := self.backColor;

	elseif newState = JtdTrxDriverRunningTrx then
		s := s &amp; "Running";
		self.statusLine.backColor := Yellow;

	else
		s := s &amp; "*** Unknown ***";
		self.statusLine.backColor := Red;
	endif;

	// transaction delays (set from the controller app) take precedence
	// over any profile delay intervals
	if jtd.jtdTrxDelay &gt; 0 then
		r := (jtd.jtdTrxDelay / 1000).roundedTo(2);
		if r = 1 then
			s := s &amp; " (Delay: 1 sec)";
		else
			s := s &amp; " (Delay: " &amp; r.String &amp; " secs)";
		endif;
	endif;
	
	self.caption := s;

	if newMsg = null then
		self.statusLine.caption := "Ready";
	else
		self.statusLine.caption := newMsg;
	endif;

	self.refreshNow;		
	self.statusLine.refreshNow;
end;</source>
        <access>protected</access>
        <Parameter name="newState" type="Integer"/>
        <Parameter name="newMsg" type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdSetupTable" id="fcb9198d-630c-4a30-bc31-0c30a10bdc56">
        <source>jtdSetupTable() protected;

vars
	i : Integer;
	
begin
	tblDetails.accessCell(1, 2).text := "Transactions" &amp; Tab &amp; Tab &amp;
		"Generations" &amp; Tab &amp; Tab &amp; "Transaction";
		
	tblDetails.accessCell(1, 2).mergeCells := Table.MergeCells_Merge;
	tblDetails.accessCell(1, 4).mergeCells := Table.MergeCells_Merge;
	tblDetails.accessCell(1, 6).mergeCells := Table.MergeCells_Merge;
	
	tblDetails.accessCell(2, 1).text := Tab &amp; "Secs" &amp; Tab &amp; "TPS" &amp;
		Tab &amp; "Secs" &amp; Tab &amp; "Rate" &amp; Tab &amp; "Count" &amp; Tab &amp; "Errors";

	tblDetails.accessCell(3, 1).text := "Read";
	tblDetails.accessCell(4, 1).text := "Update";
	tblDetails.accessCell(5, 1).text := "Totals";

	tblDetails.columnWidth[1] := 40;
	tblDetails.columnWidth[2] := 40;
	tblDetails.columnWidth[3] := 40;
	tblDetails.columnWidth[4] := 40;
	tblDetails.columnWidth[5] := 40;
	tblDetails.columnWidth[6] := 40;
	tblDetails.columnWidth[7] := tblDetails.clientWidth - (6 * 40) + 1;
	
	foreach i in 2 to tblDetails.columns do
		tblDetails.accessColumn(i).alignment := Table.Alignment_Center;
	endforeach;
	
	picHideTblCorner.backColor := self.backColor;
	picHideTblCorner.move(tblDetails.left, 0, tblDetails.columnWidth[1],
		(tblDetails.rowHeight[1] * 2) + tblDetails.top);
	picHideTblCorner.zOrder(1);
	
	picIcon.backColor := self.backColor;
	picIcon.top := tblDetails.top + (tblDetails.rowHeight[1] - (picIcon.height / 2)) - 2;
	picIcon.left := tblDetails.left + ((tblDetails.columnWidth[1] / 2) - (picIcon.width / 2)) - 3;
	picIcon.zOrder(1);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdTransactionDriverExHandler" id="9448857b-6a3a-428a-a9cc-126416eb7419">
        <source>jtdTransactionDriverExHandler(exObj : Exception; errNo : Integer output) : Integer protected;

vars
	pc			: ProcessStackArray;
	meth		: MethodCallDesc;
	theMethod	: Method;
	i			: Integer;
	logFile		: JadeLog;
	ts 			: TimeStamp;
begin
	ts := app.actualTimeServer;
	create logFile transient;
	logFile.fileName := "_jtd_" &amp; 
						app.computerName &amp; "_" &amp; 
						app.getInstanceIdForObject( app ).String &amp; "_" &amp; 
						ts.Date.format("yyyyMMdd") &amp; "_" &amp; 
						ts.Time.format("HHmmss") &amp; "_.log";
	logExceptionDetails( logFile, "*********************************************************************************" );
	logExceptionDetails( logFile, "************************** Start of exception details ***************************" );
	logExceptionDetails( logFile, "*********************************************************************************" );
	
	logExceptionDetails( logFile, "Error number = " &amp; exObj.errorCode.String );

	create pc transient;
	process.currentStack(pc);
    i := 3;							// exclude myself etc

	logExceptionDetails( logFile, "----------------- Call Stack Snapshot -------------------------------"  );
    while i &lt;= pc.size do
   		meth	:= pc[i];
   		theMethod := meth.method;
		if app.isValidObject(theMethod) then
			logExceptionDetails( logFile, "       " &amp; (i- 2).String &amp; " : " &amp; meth.display &amp; "  (" &amp;
								  theMethod.class.name &amp; ")" ); 
		else
			logExceptionDetails( logFile, theMethod.String &amp; " (Invalid)"  );
		endif;

		i := i + 1;
	endwhile;

	logExceptionDetails( logFile, "------------------------ End Call Stack Snapshot  -------------------------------" );
	logExceptionDetails( logFile, " " );
	logExceptionDetails( logFile, "*********************************************************************************" );
	logExceptionDetails( logFile, "******************** Finished displaying exception details **********************" );
	logExceptionDetails( logFile, "*********************************************************************************" );
	logExceptionDetails( logFile, " " );

	logFile.commitLog;

	errNo := exObj.errorCode;
	abortTransaction;
	return Ex_Resume_Next;
epilog
	delete logFile;
	if pc &lt;&gt; null then
		pc.purge();
		delete pc;	
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="errNo" type="Integer" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="8a893695-ee24-44cd-89e9-2236578cbec1">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	if self.jtdMySummary &lt;&gt; null and global.isValidObject(self.jtdMySummary) then
		delete self.jtdMySummary;
	endif;
	create self.jtdMySummary;

	self.jtdSetState(JtdTrxDriverStopped, null);
	self.jtdSetProfileBubbleHelp;

	if app.jtdMyContext.jtdHasInitialFormPosition then
		self.jtdRestoreInitialPosition;
	else
		self.top := 0;
		self.left := 0;
		app.jtdMyContext.jtdSetInitialFormPosition(self.top, self.left, self.height, self.width);
	endif;
	
	self.jtdSetupTable;
	
	self.jtdRefreshWindow(true);
	
//	if not app.jtdMyContext.jtdInitialStatusDisplayEnabled then  // jhp 20060915
		self.jtdCmdEnableStatusDisplay(false.String);
//	endif;
		
	self.jtdBeginNotifications;

	// tell any controllers that we're around
	self.jtdCmdPing(null);
	self.jtdWaitingOnPingAck := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="logExceptionDetails" id="2182ff7c-f9b0-4a69-a811-c4b1b00f570d">
        <source>logExceptionDetails( pLogFile : JadeLog input; pDetails : String ) protected;

vars

begin
	write pDetails ;
	pLogFile.info( pDetails );
end;</source>
        <access>protected</access>
        <Parameter name="pLogFile" type="JadeLog" usage="input"/>
        <Parameter name="pDetails" type="String"/>
    </JadeMethod>
