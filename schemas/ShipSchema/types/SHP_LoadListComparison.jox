			self.frmLoadListView.left := 514;
			self.frmLoadListView.top:= 10;			
		endif;
		self.txtFilters.width := self.cmbView.width;
		self.txtFilters.zOrder(1);		
		self.txtFilters.scrollBars := ScrollBar_Vertical;
		self.txtFilters.scrollVertical := true;
		self.txtFilters.readOnly := true;		
		self.txtFilters.height := 20;		
