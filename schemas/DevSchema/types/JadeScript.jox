    <JadeMethod name="mA1220" id="3c934ff2-788d-4b98-8068-283469691ece">
        <source>mA1220();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 February 2020	jlgma1	Initial creation

*/

vars
    bin  : Binary;
    file : File;
	str  : String;
	stringArr : CnBinaryArray;
	binn : Binary;
begin
    create file;
    file.kind := File.Kind_Binary;
    file.openInput('c:\temp\SPAIN.nsd');
    bin := file.readBinary(file.fileLength);
    //write bin;
	
	
	create stringArr transient;
	stringArr.add(bin);
	
	foreach binn in stringArr do
	
	 write binn.asStringJMT;
	endforeach;
    return;
epilog
delete stringArr;
    delete file;
end;</source>
    </JadeMethod>
    <JadeMethod name="mA51024" id="003c87ac-1ac2-4860-b20e-b875352d7f75">
        <source>mA51024();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2021	navma1	Initial creation

*/

vars
	timeStamp : TimeStamp;
	idx : Integer;
	a,b : String;
begin
	
	a := "mohamed";
	b := "MohameD";
	
	if a=b then
		write "true";
	else
		write "false";
	endif;
	foreach idx in 1 to 10 do
				
				timeStamp := app.actualTimeServer;		//19.11.2021 cnwma1 #
				write   "  idx : " &amp; idx.String &amp; '  TimeSamp :' &amp;'Seconds : '&amp; timeStamp.time.second.String &amp; ' MilliSecond: ' &amp;timeStamp.Time.milliSecond.String;

	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mA52159" id="712b2d9f-1726-4742-8cfc-b1c9fb9c855e">
