    <JadeMethod name="showSearcher" id="8ae27c4d-c3ff-46e0-8622-0fc1cbeb6a9b">
        <source>showSearcher(_hide : Boolean);
// -----------------------------------------------------------------------------
// Created:		21 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 31 May 2022	navtnr20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// -----------------------------------------------------------------------------

vars

begin
	self.frmToolbar.enabled := _hide;

	if _hide then
		self.frmSearcher.visible := false;
		return;
	endif;
	
	self.frmSearcher.centreHorizontallyInParent();
	self.frmSearcher.top := 100;
	
	self.frmSearcher.zOrder(1);
	self.frmSearcher.height := 400;	// 31.05.2022 navtnr20 TFS 53204
	self.frmSearcher.visible := true;

	self.mskDateFrom.setFocus();
	self.loadShippingLine();	// 31.05.2022 navtnr20 TFS 53204
	
epilog

end;</source>
        <Parameter name="_hide" type="Boolean"/>
    </JadeMethod>
