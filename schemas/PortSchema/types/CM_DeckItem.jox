    <JadeMethod name="validateDuplicateDeckItem" id="dd79ff51-0bbd-4019-9c7e-6f6829123929">
        <source>validateDuplicateDeckItem() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 April 2011	cnwer1	Initial creation CCMS 1031
28 Feb 2012	cnwrs1	Par 29186 - add decitem code to the error message
*/

vars
	realDeck: CM_Deck;
	dupDeckItem ,realSelf: CM_DeckItem;
begin
	if self.myDeck &lt;&gt; null then
	
		if self.myDeck.isTransient then
			// during a copy of a deck there is no real deck as we are creating
			realDeck := self.myDeck.pxyGetRealObject();
			if realDeck = null then
				realDeck := self.myDeck;
			endif;
		else
			realDeck := self.myDeck;
		endif;
		
		dupDeckItem:= realDeck.allDeckItems[self.code];
		
		if dupDeckItem &lt;&gt; null  and dupDeckItem &lt;&gt; self then
			realSelf:=self.pxyGetRealObject.CM_DeckItem;
			
			
			if realSelf = null or realSelf &lt;&gt; dupDeckItem then
				app.raiseCMException1(Duplicate_code_must_unique, app.getErrorString(Deck) &amp; " " &amp; app.getErrorString(Item) &amp; self.code, null, null);	// 28 Feb 2012	cnwrs1	Par 29186 
				return;
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="5239a3f2-766d-43cb-93a5-34ab407aeb0f">
        <source>validateForDelete();
/*
Date		    Who			Reason
10 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

begin
	if not self.canIBeErased() then
		app.raiseCMException1(Canno_erase_becau_cargo_colou_, self.code, null, null);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="b81c73f6-3854-48cb-bfae-0718b66f9aa9">
        <source>validateUpdate(_passport : CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	

	self.validateDuplicateDeckItem();
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
