    <JadeMethod name="setBay" id="4a894df7-07e3-47de-8bcd-8313ae6d6294">
        <updating/>
        <source>setBay(_bay: CM_BayDefn) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 May 2009	cnwer1	Initial creation

*/

vars

begin
	self.myBay:=_bay;
	self.myCellularVesselStructure:=_bay.myVesselCellular;
epilog

end;</source>
