    <JadeMethod name="doPrint" id="f5ec6ea8-9bb6-4813-be2c-2b93f8cbc659">
        <updating/>
        <source>doPrint() updating;
// ---------------------------------------------------------------------------
// Created:     29 November 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	gtpdataTable 	: CM_GenericTablePrint;
	now 			: TimeStamp;
	tmpJadeReport 	: JadeReport;
begin
	app.mousePointer := MP_HOURGLASS;
	app.printer.suppressDialog := true;
	now := self.systemToLocalTime(app.actualTimeServer());	// 10/6/16 cnwmp6 TFS 488 - Multi timezone support
	create gtpdataTable transient;
	gtpdataTable.whiteBackground := true;
	app.printer.setMargins(Print_Landscape,0,0,10,10);
	gtpdataTable.frHeader.width := app.printer.pageWidth;

	gtpdataTable.setHeaders(self.txtDisplay.text, null );
	create tmpJadeReport transient;
	tmpJadeReport.description := self.txtDisplay.text[1:60];
	
	app.printer.setReport(tmpJadeReport);
	app.printer.setHeader(gtpdataTable.frHeader);
	
	gtpdataTable.frHeader.height := 100; 
	gtpdataTable.frFooter.width := app.printer.pageWidth;
	gtpdataTable.lblTheUser.caption := app.getMyUserCode;
	gtpdataTable.lblTheDatePrinted.caption := now.String;
	gtpdataTable.useOrigTableColumnWidths := false;

	app.printer.setFooter(gtpdataTable.frFooter);
	gtpdataTable.printTable(self.tblData, true, null);
epilog
	app.printer.close;
	app.printPreview(tmpJadeReport, true);
	delete gtpdataTable;
	app.mousePointer := MP_DEFAULT;
end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="75d5183e-ba44-4d86-8d3c-777e7eeb834b">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:     21 November 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	LineSep = 5;
vars
	tmpSheetCont, 
	tmpSheetOther, 
	tmpSheetSummary		: JadeTableSheet;
	cargo 				: CM_CargoType;
	isCanceled , 
	hasContainersDetail,
	hasContainersSummary,
	hasOtherCargo		: Boolean;
begin
	self.createMonitor();	
// ### DO QUERY
	self.setQueryHdr();
	self.mnuContextTIEnquire.visible := false;
	self.mnuSendToReport.visible := false;
	self.mulCargoType.getSelected(self.myQueryHdr.allCargoTypes);
	self.mulFF.getSelected(self.myQueryHdr.allFreightForwarders);
	self.mulOperator.getSelected(self.myQueryHdr.allOperators);
	self.mulServices.getSelected(self.myQueryHdr.allServices);
	if self.timeFrom.isValid() then			// cnwdad1 04/08/2009 - PAR #20417.
		self.myQueryHdr.timeFrom := self.timeFrom.getTextAsDate();
	else
		self.myQueryHdr.timeFrom	:=	null;
	endif;
	self.myQueryHdr.timeTo := self.timeTo.getTextAsDate();
	self.myQueryHdr.myVoyage := self.cmbVoyage.listObject.CM_Voyage;
	self.myQueryHdr.isDetail := self.checkBox_Detail.value; 
	self.myQueryHdr.isSummary := self.checkBox_Summary.value;
	
	tmpSheetCont := self.tblData.accessSheet(1);
	tmpSheetCont.rows := tmpSheetCont.fixedRows;
	tmpSheetSummary := self.tblData.accessSheet(2);
	tmpSheetSummary.rows := tmpSheetSummary.fixedRows;
	tmpSheetOther := self.tblData.accessSheet(3);
	tmpSheetOther.rows := tmpSheetOther.fixedRows;

	hasContainersDetail  := false;
	hasContainersSummary := false;
	hasOtherCargo 		 := false;
	
	// Create the allDtl's and allSum's collections 
	if self.myQueryHdr.doQuery() then 
		// Display Selceted query on the txtDisplay TextBox
		self.txtDisplay.text := self.myQueryHdr.displayQuerySelection(self.timeFrom.getTextAsDate(),self.timeTo.getTextAsDate(),self.cmbVoyage.listObject.CM_Voyage);
		if self.myQueryHdr.isDetail then
			foreach cargo in  self.myQueryHdr.allCargoTypes do 
				if cargo.id = TI_CargoType_Container then 
					// Displaydata for Containers Detail
					hasContainersDetail := self.addDataToTblContainersDtl();
					// Display data for Containers Summary
					if self.myQueryHdr.isSummary then
						//if (self.myQueryHdr.totalFF = 0 or self.myQueryHdr.totalOperators = 0) then //and self.myQueryHdr.queryByVoyage then
							hasContainersSummary := self.addDataToContSumAllOpsFF();
						//elseif (self.myQueryHdr.totalFF &gt; 0 or  self.myQueryHdr.totalOperators &gt; 0) then
						//	hasContainersSummary := self.addDataToTblContainersSum();
						//endif;
					endif;
					break;
				endif;
			endforeach;
			hasOtherCargo := self.addDataToTblOtherCargo();
			// Select the appropiate sheet to display 
			if  hasOtherCargo and  (not hasContainersDetail) then
				self.tblData.topSheet :=3;
				self.tblData.sheet:=3;
			elseif hasContainersDetail then
				self.tblData.topSheet :=1;
				self.tblData.sheet:=1;
			elseif hasContainersSummary  then
				self.tblData.topSheet :=2;
				self.tblData.sheet:=2;
			endif;
		elseif  self.myQueryHdr.isSummary then
			foreach cargo in  self.myQueryHdr.allCargoTypes do 
				if cargo.id = TI_CargoType_Container then 
					// Display data for Containers Summary
					//if (self.myQueryHdr.totalFF = 0 and  self.myQueryHdr.totalOperators = 0) then //and self.myQueryHdr.queryByVoyage
						hasContainersSummary := self.addDataToContSumAllOpsFF();
					//elseif (self.myQueryHdr.totalFF &gt; 0 or  self.myQueryHdr.totalOperators &gt; 0) then
					//	hasContainersSummary := self.addDataToTblContainersSum();
					//endif;
					break;
				endif;
			endforeach;
			self.tblData.topSheet :=2;
			self.tblData.sheet:=2;
		endif;
		// ### HIDE QUERY FRAME?
		self.frmQuery.visible := (self.tblData.accessSheet(self.tblData.topSheet).rows  = self.tblData.fixedRows);
		app.mousePointer := Window.MousePointer_Default;
	else
		return;
	endif;
epilog
	self.deleteMonitor();
end;</source>
    </JadeMethod>
    <JadeMethod name="doResetSearch" id="225c9bed-68b1-479c-896e-4b083b6806b1">
        <source>doResetSearch();
// ---------------------------------------------------------------------------
// Created:     27 November 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	cargoTypeSet	 : CM_CargoTypeSet;
	date,
	actualDate		 : Date;
begin
	create cargoTypeSet transient;
	cargoTypeSet.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	inheritMethod();
	self.mulCargoType.clearSelected;
	self.mulCargoType.setSelected(cargoTypeSet);
	self.mulOperator.clearSelected;
	self.mulFF.clearSelected;
	self.mulServices.clearSelected;
	//Set date From the first day of the current month To the actual current date
	actualDate := self.systemToLocalTime(app.actualTimeServer()).Date;	// 26/4/16 cnwmp6 TFS 488 - Multi timezone support
	date.setDate(1,actualDate.month, actualDate.year);
	self.timeFrom.CMUI_DateMask.setDate(date);
	self.timeTo.CMUI_DateMask.setDate(actualDate);
	self.cmbVoyage.text := null;
epilog
	delete cargoTypeSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="67239ac6-97ea-4d03-8453-1bfcdb5f3283">
        <updating/>
        <source>doResize() updating;

vars
	tmpControl	: Control;
	tmpParent1,
	tmpParent2	: Window;
	numControls,
	i			: Integer;
	
begin
	// resize txtDisplay 
	self.txtDisplay.top := self.frmToolbar.height ;
	self.txtDisplay.width := self.width-7;
	self.txtDisplay.left := 0;
	self.splMain.top := self.txtDisplay.top + self.txtDisplay.height;
	// Then reposition or resize all the controls as necessary
	numControls := self.controlCount;
	foreach i in 1 to numControls do
		tmpControl := self.controls(i);
		tmpParent1 := tmpControl.parent;
		if CMUI_SplitContainer.hasInstance(tmpParent1) or
		   CMUI_ScrollableDrawingFrame.hasInstance(tmpParent1) or
		   CMUI_DrawingFrame.hasInstance(tmpParent1) then
		   	continue;
		endif;
		if Control.hasInstance(tmpParent1) then
			tmpParent2 := tmpParent1.Control.parent;
			if CMUI_SplitContainer.hasInstance(tmpParent2) or
			   CMUI_ScrollableDrawingFrame.hasInstance(tmpParent2) or
			   CMUI_DrawingFrame.hasInstance(tmpParent2) then
			   	continue;
			endif;
		endif;
		tmpControl.repositionAfterResize();
	endforeach;
	// Resize Query Toolbar
	self.fldQuery.top	:=	self.frmQueryToolbar.height;
end;</source>
    </JadeMethod>
