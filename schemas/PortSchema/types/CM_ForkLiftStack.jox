    <JadeMethod name="setForUpdate" id="0dd530de-36ba-4af4-8552-dd229c9d27f3">
        <updating/>
        <source>setForUpdate(_proxy :CM_ForkLiftStack) updating;
//setForUpdate(_proxy : CM_ForkLiftStack) updating;
// ---------------------------------------------------------------------------
// Created:     10 May 2001 Andrew Bishop cnwab1
//
// Purpose:     Note: No Towers only Gaps on Fork Lift Stacks
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	_proxy.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);

	//self.heightOfStack	:= _proxy.heightOfStack;
	self.setHeightOfStack( _proxy.heightOfStack );	//28 May 2012	NDL	Par 29604
	self.accessBack 	:= _proxy.accessBack;
	self.accessFront 	:= _proxy.accessFront;
	self.maxHeightFull 	:= _proxy.maxHeightFull;
	self.maxHeightMT 	:= _proxy.maxHeightMT;
	self.maxHeightPower := _proxy.maxHeightPower;
	
	self.staggerHeights.clear;
	_proxy.staggerHeights.copy(self.staggerHeights);

	inheritMethod(_proxy);

end;</source>
