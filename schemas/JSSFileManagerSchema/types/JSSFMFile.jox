    <DbClassMap file="jssfm_file_node"/>
    <PrimAttribute name="isArchive" id="acee9db9-1d72-4516-9af6-9c20b60d6d7e">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="isHidden" id="4a42c34c-f4f4-40ab-9f1d-ba6bebd0c91f">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="isReadOnly" id="ec83ed53-135b-410c-a348-4e1a6ecd2526">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="isSystemFile" id="2077657a-0d6d-47c8-ac76-2d62c8b2d3ef">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="create" id="da98e0b5-82fb-404a-a4bc-277f6b1502bd">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		02 July 2002 by cnwdad1
//
// Purpose:		Constructor to set default settings etc..
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isFile		:=	true;
	self.isFolder	:=	false;
end;</source>
    </JadeMethod>
    <JadeMethod name="getAttributes" id="d7c4991f-7abc-4f0e-9f1b-8b7ce5081719">
        <source>getAttributes(): String;
// --------------------------------------------------------------------------------
// Created:		26 June 2002 by cnwdad1
//
// Purpose:		Returns a string of the node's file system attributes.
//
// Parameters:	None
//
// Returns:		A string of file system attributes.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fileAttributes	: String;
	
begin
	if self.isArchive then		
		fileAttributes	:=	fileAttributes &amp; 'A';
	endif;

	if self.isHidden then
		fileAttributes	:=	fileAttributes &amp; 'H';
	endif;

	if self.isReadOnly then
		fileAttributes	:=	fileAttributes &amp; 'R';
	endif;

	if self.isSystemFile then
		fileAttributes	:=	fileAttributes &amp; 'S';
	endif;
epilog
	return fileAttributes;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTableDisplay" id="4a5dbb70-db24-4683-b48a-c5c7af6c5a58">
        <source>getTableDisplay(): String;
// --------------------------------------------------------------------------------
// Created:		26 June 2002 by cnwdad1
//
// Purpose:		Returns the receiver's properties formatted for display in a table
//				control on a form.
//
// Parameters:	None
//
// Returns:		The formatted string of the receiver's properties.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 17/10/2002	cnwdad1		Changed to round the file size to an integer instead of
//							a decimal to two places.
// --------------------------------------------------------------------------------
//11 Nov 2013	cnwrs1	make date time sort work
vars
	returnValue	: String;
	
begin
	returnValue	:=	"" &amp; Tab &amp;
					self.fileName &amp; Tab &amp;
//					(self.fileSize / 1024).roundedTo(2).String &amp; " " &amp; Tab &amp;
					(self.fileSize / 1024).rounded().String &amp; " " &amp; Tab &amp;
					self.lastModified.date.format("yyy-MM-dd") &amp; " " &amp; self.lastModified.time.String &amp; Tab &amp;
					self.getAttributes() &amp; Tab &amp;
					self.fileNodeFlag.String &amp; Tab &amp;
					self.pathName &amp; Tab &amp;
					self.nodeType.String &amp; Tab &amp;
					self.isUnix.String;
epilog
	return returnValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setAttributes" id="600a55b2-1776-4ff0-bf39-aad6814176c7">
        <updating/>
        <source>setAttributes(pIsArchive: Boolean; pIsHidden: Boolean; pIsReadOnly: Boolean; pIsSystemFile: Boolean) updating, protected;
// --------------------------------------------------------------------------------
// Created:		26 June 2002 by cnwdad1
//
// Purpose:		Sets the file node's attributes.
//
// Parameters:	pIsArchive - A boolean flag to indicate whether the file's Archive
//					attribute is set.
//				pIsHidden - A boolean flag to indicate whether the file's Hidden
//					attribute is set.
//				pIsReadOnly - A boolean flag to indicate whether the file's Read Only
//					attribute is set.
//				pIsSystemFile - A boolean flag to indicate whether the file's System
//					File attribute is set.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isArchive		:=	pIsArchive;
	self.isHidden		:=	pIsHidden;
	self.isReadOnly		:=	pIsReadOnly;
	self.isSystemFile	:=	pIsSystemFile;
end;</source>
        <access>protected</access>
        <Parameter name="pIsArchive" type="Boolean"/>
        <Parameter name="pIsHidden" type="Boolean"/>
        <Parameter name="pIsReadOnly" type="Boolean"/>
        <Parameter name="pIsSystemFile" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setNodeFlag" id="976a4949-4ec4-45bf-9c9e-83f6e26181fe">
        <updating/>
        <source>setNodeFlag() updating, protected;
// --------------------------------------------------------------------------------
// Created:		26 June 2002 by cnwdad1
//
// Purpose:		Updates the receiver's node type flag.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.fileNodeFlag	:=	self.NODE_FLAG_FILE;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
