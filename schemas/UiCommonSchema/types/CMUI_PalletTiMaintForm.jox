    <JadeMethod name="setReadOnly" id="00e6a5ce-5082-468a-8968-3b912b848b7e">
        <updating/>
        <source>setReadOnly()  updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2017	cnwndl1	Initial creation	TFS 3414

*/

vars

begin

	self.btnOk.enabled := not self.isReadOnly;
	self.cmbPallettType.enabled := not self.isReadOnly;
	self.chkHeatTreated.enabled := not self.isReadOnly;
	self.chkStoreOn.enabled := not self.isReadOnly;
	
	//21 Jan 2020	NDL	TFS 48246
	self.lblPalletType.enabled := not self.isReadOnly;
	self.lblHeatTreated.enabled := not self.isReadOnly;
	self.lblStoreOn.enabled := not self.isReadOnly;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d6b21d79-6c87-425d-9672-7652db1c64ea">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2017	cnwndl1	Initial creation

*/

vars
	
	handlingType : CM_HandlingType;
	handlingSubType : CM_HandlingSubType;

begin
	inheritMethod();
	
	handlingType := app.myRoot.allHandlingTypes.getAtKey(TI_HandlingType_Pallets);
	handlingType.getValidSubTypes( self.allHandlingSubTypes, true );

	self.loadCombo();
	
	self.setReadOnly();
	
	if self.myPxyBreakBulkGeneric &lt;&gt; null then
		if self.myPxyBreakBulkGeneric.myPalletDetailsTI = null then
			handlingSubType := handlingType.getDefaultSubHandlingType;
			if handlingSubType = null then	//22 Jan 2020
				self.cmbPallettType.listIndex := -1;
				self.chkHeatTreated.value := false;
				self.chkStoreOn.value := false;
			else
				self.cmbPallettType.listIndex := self.cmbPallettType.findObject( handlingSubType );
				self.chkHeatTreated.value := handlingSubType.CM_PalletType.heatTreated;
				self.chkStoreOn.value := false;
			endif;
		else
			handlingSubType := self.myPxyBreakBulkGeneric.myPalletDetailsTI.getPalletTypeObj;
			self.cmbPallettType.listIndex := self.cmbPallettType.findObject( handlingSubType );
			self.chkHeatTreated.value := self.myPxyBreakBulkGeneric.myPalletDetailsTI.heatTreated;
		//	self.chkStoreOn.value := self.myPxyBreakBulkGeneric.myPalletDetailsTI.storeOnPallets;
			self.chkStoreOn.value := true;	//20 Jan 2020
		endif;
	endif;
	
	self.clickStoreOnPallet( self.chkStoreOn.value );	//16 Jan 2020 NDL	TFS 48246

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="32e6dff4-5b13-4880-87aa-ee29aa4cb675">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 19 April 2017 09:02:38.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021938, locale);
	lblHeatTreated.translateCaption(Xlat_0021939, locale);
	lblPalletType.translateCaption(Xlat_0021940, locale);
	lblStoreOn.translateCaption(Xlat_0021941, locale);
end;</source>
    </JadeMethod>
</GUIClass>
