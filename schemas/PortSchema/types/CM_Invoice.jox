    <JadeMethod name="loadPropertyCol" id="58736e7e-8acb-425a-a3fe-4bcce505e64c">
        <source>loadPropertyCol(jvlt : Table io);
// 7 Nov 2022 navrk21 Bug 55204: MTN - Accural Type for Debtor is incorrect
vars
	str : String;

begin

	str := sequenceNum.String.padLeftBlanks(10) &amp; '  ' &amp; Tab;

	str := str &amp; getStatusDescription(self.status) &amp; Tab;
	if status = CM_Invoice.INVOICE_VOID then
		jvlt.column := 2;
		jvlt.accessMode := 1;
		jvlt.backColor := Gray;
	endif;

	str := str &amp; debtor.name &amp; Tab;
	str := str &amp; invoiceType.getInvoiceString(self) &amp; Tab;
	str := str &amp; invoiceLines.size.String.padLeftBlanks(10) &amp; '  ' &amp; Tab;
	str := str &amp; unqualifiedAudits.size.String.padLeftBlanks(10) &amp; '  ' &amp; Tab;
	str := str &amp; qualifiedAudits.size.String.padLeftBlanks(10) &amp; '  ' &amp; Tab;

	//str := str &amp; invoiceType.getAccrualTypeDescription &amp; Tab;					// 07.11.2022 navrk21 TFS 55204
	str := str &amp; invoiceType.getAccrualTypeDescDebtor(self.debtor) &amp; Tab;		// 07.11.2022 navrk21 TFS 55204
	if fromDT.isValid then
		str := str &amp; fromDT.date.userFormat($CM_YearFormat) &amp; fromDT.time.userFormat($CM_SortTime) &amp; Tab;
		str := str &amp; fromDT.String &amp; Tab;
	else
		str := str &amp; "not applicable" &amp; Tab;
		str := str &amp; "" &amp; Tab;
	endif;

	if toDT.isValid then
		str := str &amp; toDT.date.userFormat($CM_YearFormat) &amp; toDT.time.userFormat($CM_SortTime) &amp; Tab;
		str := str &amp; toDT.String &amp; Tab;
	else
		str := str &amp; "not applicable" &amp; Tab;
		str := str &amp; "" &amp; Tab;
	endif;

	if exportedCount &gt; 0 then
		str := str &amp; "Yes" &amp; Tab;
	else
		str := str &amp; "No" &amp; Tab;
	endif;

	if decfinGLYear &lt;&gt; null // AKB 02Feb2001 PAR 3869
	and decfinGLPeroid &lt;&gt; null then
		str := str &amp; decfinGLYear.String &amp; "/" &amp; decfinGLPeroid.String.padZeros(2) &amp; Tab;
	else
		str := str &amp; "" &amp; Tab;
	endif;

	//GD NFS Xpose 1128
	if self.termsOfTradeCode &lt;&gt; null then		
		str := str &amp; self.termsOfTradeCode &amp; Tab;
	else
		str := str &amp; "" &amp; Tab;
	endif;
	
	
	// CCMS 1125
	if self.invoiceType &lt;&gt; null then		
		if self.invoiceType.myFinancialPeriodEnd &lt;&gt; null then
			str := str &amp; self.invoiceType.myFinancialPeriodEnd.description &amp; Tab;
		else
			str := str &amp; "" &amp; Tab;
		
		endif;
	endif;

	jvlt.column := 1;
	jvlt.text := str;

end;</source>
        <Parameter name="jvlt" type="Table" usage="io"/>
    </JadeMethod>
    <JadeMethod name="mergeLinesToInvoice" id="ded512cf-3b45-426b-8ef9-abd82bb81f37">
        <updating/>
        <source>mergeLinesToInvoice(_controller : CMIF_InvoiceLineMerge) updating;
/*
Purpose:			

Date		Who		Reason
08 January 2024	navab1	CR 58085 TASK 61342
*/

vars
	invoice : CM_Invoice;
	invoiceLine : CM_InvoiceLine;
	status : CMIF_InvoiceStatus;
	localAgent : CM_UpdateTransactionAuditAgent;
begin
	create localAgent transient;
	create status transient;
	
	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(self, true);
	 
	foreach invoice in _controller.allInvoices do
		foreach invoiceLine in invoice.invoiceLines do
			invoiceLine.mergeLineToInvoice(self);
			if app.myPassport.hasErrors() then
				return;
			endif;
		endforeach;
	
		localAgent.audUpdateGeneric(invoice, true);
		status.newStatus := CM_Invoice.INVOICE_VOID;
		invoice.setForUpdateStatus(status, null);
		invoice.myMergeInvoice := self;

		if self.fromDT &gt; invoice.fromDT then
			self.fromDT := invoice.fromDT;
		endif;
	 
		localAgent.audUpdateGeneric(invoice, false);
	 
		// ### Concatenate the following fields into the target invoice's fields.
		if invoice.narration &lt;&gt; null then
			self.narration := self.narration &amp; CrLf &amp; CrLf &amp; invoice.narration;
		endif;
		if invoice.purchaseOrderNumber &lt;&gt; null then
			self.purchaseOrderNumber := self.purchaseOrderNumber &amp; CrLf &amp; CrLf &amp; invoice.purchaseOrderNumber;
		endif;
		if invoice.debtorReference &lt;&gt; null then
			self.debtorReference := self.debtorReference &amp; CrLf &amp; CrLf &amp; invoice.debtorReference;
		endif;
		
		if invoice.myInvoiceNote &lt;&gt; null and invoice.myInvoiceNote.note &lt;&gt; null then
			if self.myInvoiceNote &lt;&gt; null then
				self.myInvoiceNote.setNote(self.myInvoiceNote.note  &amp; CrLf &amp; CrLf &amp; invoice.myInvoiceNote.note);
			else
				self.myInvoiceNote := invoice.myInvoiceNote.cloneSelf(false);
			endif;
		endif;
		
		if app.myPassport.hasErrors() then
			return;
		endif;
	endforeach;
	 
	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(self, false);

epilog
	delete status;
	delete localAgent;
end;</source>
        <Parameter name="_controller" type="CMIF_InvoiceLineMerge"/>
    </JadeMethod>
    <JadeMethod name="myTerminal" id="7afc9fd7-0461-42d6-beb1-11415da70fc1">
        <methodInvocation>mapping</methodInvocation>
        <source>myTerminal(set: Boolean; _value: CM_Terminal io) mapping;
// ---------------------------------------------------------------------------
// Created:		July  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	if self.bank &lt;&gt; null then
		// This should be ok as the only bank which does not
		// have a terminal reference is the root one which
		// does not have invoices!
		_value := self.bank.terminal;
	endif;

end;</source>
