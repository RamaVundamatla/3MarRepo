    <JadeMethod name="cloneForTrackedItemRefs" id="4db8c259-4302-4034-bcb7-5d5015d73899">
        <updating/>
        <source>cloneForTrackedItemRefs(_ti: CM_TrackedItem; _orginalTransaction: CM_SubTerminalRelease) updating, protected;
/* ---------------------------------------------------------------------------
Created:     20 August 2009 by cnwrs2

Purpose:     CCMS 1875
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	inheritMethod(_ti, _orginalTransaction);
	
	self.mySubTerminalTo	:= _orginalTransaction.mySubTerminalTo;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_orginalTransaction" type="CM_SubTerminalRelease"/>
    </JadeMethod>
    <JadeMethod name="getCompletedTaskString" id="43064329-eee8-4908-a8f5-89f4fe8a1cd6">
        <source>getCompletedTaskString(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2014	cnwndl1	Initial creation	Par 35295

*/

vars

	str : String;

begin

	if self.mySubTerminal &lt;&gt; null then
		str := app.getErrorString( From ) &amp; " " &amp; self.mySubTerminal.code &amp; " ";
	endif;
	
	if self.mySubTerminalTo &lt;&gt; null then
		str := str &amp; "into" &amp; " " &amp; self.mySubTerminalTo.code;
	endif;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="99c01536-cccd-4f29-b385-02a14889e11b">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// Jan 2012 CCSM 1262 Transaction Enquiry
//18 Aug 2017		cnwma1	TFS #5027:POL - CAMS Transaction not being correctly processed
vars

begin
	if _attrName = ETRow_SubTermReleaseTo  or _attrName = ETRow_SubTerminalTo then // 18.8.2017 cnwma1 TFS #5027 then
		if self.mySubTerminalTo &lt;&gt; null then
			return self.mySubTerminalTo.code;
		else
			return null;
		endif;
	elseif _attrName = ETRow_SubTerminalFrom then  // 4.8.2017 cnwma1 TFS #5027
		if self.mySubTerminal &lt;&gt; null then
			return self.mySubTerminal.code;
		else
			return null;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;
end;
</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMySubTerminalTo" id="8216b9b9-175d-4ce4-a76f-e894d981f53c">
        <source>getMySubTerminalTo(): CM_SubTerminal;
// --------------------------------------------------------------------------------
// Created:		14 September 2009 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.mySubTerminalTo;
end;</source>
        <ReturnType type="CM_SubTerminal"/>
    </JadeMethod>
