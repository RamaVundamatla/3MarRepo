    </JadeMethod>
    <JadeMethod name="makeBtnVisibleIfUpdatable" id="fb722fba-e37e-42ce-a2c6-acdd78470e13">
        <source>makeBtnVisibleIfUpdatable(	_btn : CMUI_Button input;
							_forceVisible : Boolean;
							_databaseWeight : Decimal;
							_calulatedWeight : Decimal;
							_tblMeasureCntrl : CMUI_MeasurementTable
							) protected;
/*

Purpose:			

Parameters:			Eliminate the possibility of rounding causing the update buttons to be set in error

Return Value:		

Date		Who		Reason
26 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

	measurementType : CM_MeasurementType;
	convertedDisplayValue : Decimal [12,4];
	convertedStorageValue : Decimal [12,4];

begin
	
	if _forceVisible then
		_btn.visible := true;
		return;
	endif;
	
	if _calulatedWeight &lt;= 0 then
		_btn.visible := false;
		return;
	endif;

	measurementType := _tblMeasureCntrl.getMeasurementType;
	if measurementType = null then
		_btn.visible := ( _databaseWeight &lt;&gt; _calulatedWeight );
		return;
	endif;

	convertedDisplayValue := (_calulatedWeight / measurementType.conversionRate).roundedTo(measurementType.getDecimalPrecision);
	convertedStorageValue := (convertedDisplayValue * measurementType.conversionRate).roundedTo(measurementType.getDecimalPrecision);
	
	_btn.visible := ( _databaseWeight &lt;&gt; convertedStorageValue );

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_btn" type="CMUI_Button" usage="input"/>
        <Parameter name="_forceVisible" type="Boolean"/>
        <Parameter name="_databaseWeight" type="Decimal"/>
        <Parameter name="_calulatedWeight" type="Decimal"/>
        <Parameter name="_tblMeasureCntrl" type="CMUI_MeasurementTable"/>
    </JadeMethod>
