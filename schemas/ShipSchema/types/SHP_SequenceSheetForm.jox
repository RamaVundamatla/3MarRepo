    <JadeMethod name="translateForm" id="3eda89e5-9d2c-42d3-9cce-11688f40d76d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017663, locale);
	btnLocate.translateBubbleHelp(Xlat_0015561, locale);
	btnLocate.translateCaption(Xlat_0003096, locale);
	btnMoveDown.translateBubbleHelp(Xlat_0003089, locale);
	btnMoveDown.translateCaption(Xlat_0003090, locale);
	btnMoveUp.translateBubbleHelp(Xlat_0003095, locale);
	btnMoveUp.translateCaption(Xlat_0003097, locale);
	cbPrintPreview.translateCaption(Xlat_0003086, locale);
	cbPrnLidComments.translateCaption(Xlat_0006678, locale);
	lblCrane.translateCaption(Xlat_0003098, locale);
	lblJob.translateCaption(Xlat_0003099, locale);
	lblLoadLane.translateCaption(Xlat_0003091, locale);
	lblPrintSize.translateCaption(Xlat_0003088, locale);
	lblSequence.translateCaption(Xlat_0003092, locale);
	lblSide.translateCaption(Xlat_0003100, locale);
	lblVoyage.translateCaption(Xlat_0003101, locale);
	optLargeL.translateCaption(Xlat_0003103, locale);
	optLargeP.translateCaption(Xlat_0003102, locale);
	optNormal.translateCaption(Xlat_0003104, locale);
	sdfBay.translateCaption(Xlat_0003105, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateProgress" id="8e70caad-e5af-4acc-9761-3cba1fc72543">
        <updating/>
        <source>updateProgress(_cmifMonitor: CMIF_Monitor input) updating;
// ---------------------------------------------------------------------------
// Created:     18 June 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	pb				: ProgressBar;
begin
	
	//inheritMethod(_cmifMonitor);
	self.pbProgressBar.partsInJob := _cmifMonitor.partsInJob;	
	self.pbProgressBar.partsDone := _cmifMonitor.partsDone;
	self.lblModalMessage.caption := _cmifMonitor.message;
	self.lblModalInfo.caption := 'Number to print =' &amp; _cmifMonitor.partsInJob.String &amp;
								'    Number complete =' &amp; _cmifMonitor.partsDone.asStringJMT;

	self.frmModalDialog.doWindowEvents(0);
	self.btnModalOpt1.doWindowEvents(0);
	self.btnModalOpt2.doWindowEvents(0);

	_cmifMonitor.monitorReturnValue := self.modalDialogReturnValue;	

	
end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateTIWle" id="20390870-014a-47ce-9ade-1121b27e22b7">
        <updating/>
        <source>updateTIWle(_ti : CM_TrackedItem)updating;
//--------------------------------------------------
// Created:	28 January 2004 By: cnwgd1
//--------------------------------------------------
vars
	wle : CM_WorkListEntry;
	saveRow,
	rowIdx : Integer;

begin
	if (not CM_TrackedItem.hasInstance(_ti)) then
		return;
	endif;
	
	if (not self.allNotableObjects.includes(_ti)) then
		return;
	endif;
	saveRow := self.tblData.row;
	foreach wle in _ti.allWorklistEntries do
		if (not CM_VoyageWLE.hasInstance(wle)) then
			continue;
		endif;
		if self.tblData.findObjectInRow(wle, rowIdx) then
			self.doNotableRemove(wle.myTrackedItem);				
			self.tblData.removeItem(rowIdx);
			self.addWLEToTable(wle, rowIdx);
			break;
		endif;	
	endforeach;
	
	if rowIdx = saveRow then			
		if self.tblData.selectRow(saveRow, false) then
			self.tblData.row := saveRow;	
		endif;
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="userNotificationUpdate" id="d78074fb-c4cd-4b9f-8d42-2edcaadc2387">
        <updating/>
        <source>userNotificationUpdate(_event: Integer; _noteobj : CM_Object; _obj: CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	firstVisCol,
	saveRow,
	idx : Integer;
	theVJob : CM_VoyageJob;
begin
	
	if _event = EVENT_VOYAGE_BERTHING_CHANGED then
		self.handleBerthChangeNotification(_event, _obj);
		return;
	endif;
	
	if _event = VoyageJob_Delete_Event then
		if self.tblData.findObjectInRow(_obj, idx) then
			app.msgBox('A currently selected Job has been deleted.' &amp; CrLf &amp;
					'The job sequences will now be cleared for re-selection.', 'Job Deleted',
					MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		endif;
		self.doJobBuild();
		self.tblData.rows := self.tblData.fixedRows;
		self.doShowSearcherClick();		
		return;
	endif;
	
	if not CM_VoyageJob.hasInstance(_obj) then
		return;
	endif;	
	
	theVJob := _obj.CM_VoyageJob;
	
	if _event = VoyageJob_Create_Event then
		if theVJob.myJobSheet &lt;&gt; null then
			if self.cmbCrane.listObject &lt;&gt; null and (theVJob.myJobSheet.CM_VoyageJobSheet.crane.trimBlanks  = self.cmbCrane.listObject.CM_Object.IF_VoyageWorkPoint.getID) then
				self.doJobBuild();
			endif;
		endif;
		return;
	elseif _event = VoyageJob_Update_Event then
		if self.tblData.findObjectInRow(theVJob, idx) then
			firstVisCol := self.tblData.getColumnByRowName(self.dynaKey);
			if firstVisCol &gt; 0 then
				saveRow := self.tblData.row;
				self.tblData.removeItem(idx);		
				self.addJobToTable(theVJob, firstVisCol, idx);
				if saveRow = idx then
					self.tblData.selectObject(theVJob, false);
				endif;
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_noteobj" type="CM_Object"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
</GUIClass>
