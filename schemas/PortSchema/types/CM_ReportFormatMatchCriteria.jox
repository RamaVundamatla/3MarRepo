    <JadeMethod name="setForUpdate" id="69115a02-90ef-4267-b524-30f7a5df0012">
        <updating/>
        <source>setForUpdate(_proxy: CM_ReportFormatMatchCriteria) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2013	cnwndl1	Initial creation

*/

vars

begin
	
	//epr TFS 1629 PAR 37627 make sure the priority is set before terminal so we don't get 1210 exception
	inheritMethod(_proxy);
	self.reportType := _proxy.reportType;
	self.reportName := _proxy.reportName;
	self.myTerminal := _proxy.myTerminal;
	self.numCopies := _proxy.numCopies;	//11 Jan 2019	NDl	TFS 40479
	self.myPrinter := _proxy.myPrinter; //11 Jan 2019	NDl	TFS 40479
	
	

epilog

end;</source>
        <Parameter name="_proxy" type="CM_ReportFormatMatchCriteria"/>
    </JadeMethod>
