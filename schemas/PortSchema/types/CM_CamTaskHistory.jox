    <JadeMethod name="addFileDataLineEDIFACT" id="20b99a3a-7273-4d51-8060-4a6149a1baf0">
        <updating/>
        <source>addFileDataLineEDIFACT(_dataLine : String):String updating;
// 09/05/2011 	cnwcs5	CCMS SCT 2058/PAR 27460 - soft coding special characters
// 19/12/2012	cnwcs5	CCMS SFW 1294 /par 30855 - returns message
//21 Jul 2015	cnwrs1	Par 35544 - Switch Cams to camtaskhistory::rawData
//29 Sep 2015	cnwrs1	Par 35544 - Change Cams task hisoty to use JadeBytes  
constants
	SPACE = ' ';
vars
	str					:String;
	protocol			:CM_CamProtocol;			// par 27460 cnwcs5 09/05/2011
	escape, singleQuote	:Character;					// par 27460 cnwcs5 09/05/2011
//	fileDataStr : String;
begin	
	protocol	:= self.camProtocol;				// par 27460 cnwcs5 09/05/2011
	escape		:= protocol.escapeCharacter;		// par 27460 cnwcs5 09/05/2011
	singleQuote	:= protocol.segmentTerminator;		// par 27460 cnwcs5 09/05/2011
	
	// par 11782 cnwrs1 may 2006 change any ' to null in messages
	str := _dataLine.convertSpecialToAlphaEquiv(); 	//par 16227 cnwrs1 mar 2008
	str := str.stripAbove7E();
	// par 11103 were forgetting the ' at the line end
	//str.cnReplaceChar(singleQuote, null);			// par 27460 cnwcs5 09/05/2011		//cnwmc5 - 24 April 2014 - PAR 33635
	if str[str.length:str.length] = singleQuote then									//cnwmc5 - 24 April 2014 - PAR 33635
		str := str[1:str.length-1].replaceString(singleQuote, escape &amp; singleQuote);	//cnwmc5 - 24 April 2014 - PAR 33635
	else																				//cnwmc5 - 24 April 2014 - PAR 33635
		str := str.replaceString(singleQuote, escape &amp; singleQuote);					//cnwmc5 - 24 April 2014 - PAR 33635
	endif;																				//cnwmc5 - 24 April 2014 - PAR 33635
	
	str := str.trimBlanks();
	
	if str[str.length:1] = escape then			// par 27460 cnwcs5 09/05/2011
		str := str &amp; SPACE;						// par 27460 cnwcs5 09/05/2011
	endif;
	str := str &amp; singleQuote;
/*	if str.length &gt; 60 then
		// if &gt; 60 characters just output first 60
		fileDataStr := str[1:60] &amp; singleQuote;
	else
		fileDataStr := str;
	endif;
	self.fileData.add(fileDataStr);							// par 27460 cnwcs5 09/05/2011
*/
	str := str &amp; Cr;
	return str;
end;</source>
        <Parameter name="_dataLine" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
