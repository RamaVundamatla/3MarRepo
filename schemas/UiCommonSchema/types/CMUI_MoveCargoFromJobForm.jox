    <JadeMethod name="doCargoEdit" id="c27d49c3-ae40-4d02-841a-d18518d6aec9">
        <source>doCargoEdit();
// --------------------------------------------------------------------------------
// Created:		23 September 2010 by cnwjo3
//
// Purpose:		do cargo enquiry on 1 or more TIs
//
vars
	ti : CM_TrackedItem;
	tiArray : ObjectArray;
	voyageWLE : CM_VoyageWLE;
	table : CM_DataTable;
	rowIdx : Integer;
begin
	table := self.tblCargoList;
	
	create tiArray transient;
	

	foreach rowIdx in 1 to table.rows do
		if table.accessRow(rowIdx).itemObject &lt;&gt; null and table.accessRow(rowIdx).selected then
			voyageWLE := table.accessRow(rowIdx).itemObject.CM_VoyageWLE;
			if voyageWLE.myTrackedItem &lt;&gt; null then
				ti := voyageWLE.myTrackedItem;
				tiArray.add(ti);
			endif;
		endif;
	endforeach;
		
	if tiArray.size = 1 then
		self.myAssistant.showCargoEnquiryForm(ti,null,true,true);
	elseif tiArray.size &gt; 1 then
		self.myAssistant.showCargoEnquiryForTIs(ti,tiArray,null,true);
	endif;

epilog
	delete tiArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCargoEnquiry" id="d1a7da7b-430b-4f55-93b9-86878bc7aacf">
        <source>doCargoEnquiry();
// --------------------------------------------------------------------------------
// Created:		20 September 2010 by cnwjo3
//
// Purpose:		do cargo enquiry on 1 or more TIs
//
vars
	ti : CM_TrackedItem;
	tiArray : ObjectArray;
	voyageWLE : CM_VoyageWLE;
	table : CM_DataTable;
	rowIdx : Integer;
begin
	table := self.tblCargoList;
	
	create tiArray transient;
	
	if self.myAssistant = null then
		//do nothing...
	else
		foreach rowIdx in 1 to table.rows do
			if table.accessRow(rowIdx).itemObject &lt;&gt; null and table.accessRow(rowIdx).selected then
				if table.accessRow(rowIdx).itemObject.isKindOf(CM_VoyageWLE) then
					voyageWLE := table.accessRow(rowIdx).itemObject.CM_VoyageWLE;
					if voyageWLE.myTrackedItem &lt;&gt; null then
						ti := voyageWLE.myTrackedItem;
						tiArray.add(ti);
					endif;
				endif;
			endif;
		endforeach;
		
		if tiArray.size = 1 then
			self.myAssistant.showCargoEnquiry(ti);
		elseif tiArray.size &gt; 1 then
			self.myAssistant.showCargoEnquiryForTIs(ti,tiArray,null,false);
		endif;
	endif;
epilog
	delete tiArray;
end;</source>
    </JadeMethod>
