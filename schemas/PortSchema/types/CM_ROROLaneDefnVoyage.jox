    <JadeMethod name="setProxyForCreateDefaults" id="19770bf5-47ee-4ac0-8138-fac35a38e7f0">
        <updating/>
        <source>setProxyForCreateDefaults(_deckItemLayout: CM_DeckItemLayout; _gapInMetre: Decimal) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	inheritMethod(_deckItemLayout, _gapInMetre);
	
	//18/11/2011 cnwdz2 28609
	self.myVoyageStructure:=self.myDeck.CM_DeckVoyage.getROROStructure;
epilog

end;</source>
