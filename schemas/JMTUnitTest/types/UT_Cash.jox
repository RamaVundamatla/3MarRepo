    <JadeMethod name="validateSplitMerge2B" id="f8826bc1-02a6-42a5-a8fb-22454ef63ed4">
        <source>validateSplitMerge2B(_cargo, _splitCargo : CM_TrackedItem);
// tPayBreakBulkSplitMerge validate lines and payments after the second release
vars
	count	: Integer;
	cargo,
	splitCargo	: CM_TrackedItem;
	payment		: CM_CashPayment;
	line		: CM_InvoiceLine;
begin
	cargo := _cargo;
	splitCargo := _splitCargo;

	// check the original and split invoice lines and payments
	count := 0;
	foreach payment in cargo.allCashPayments do
		if payment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
			continue;
		endif;
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(payment.cashValue, 1000.Decimal, "First original cargo payment after second release");
		elseif count = 2 then
			self.assertEqualMsg(payment.cashValue, 5000.Decimal, "Second original cargo payment after second release");
		elseif count = 3 then
			self.assertEqualMsg(payment.cashValue, 1000.Decimal, "Third original cargo payment after second release");
			self.assertEqualMsg(payment.myProformaDetail.quantity, 10000.Real, "Third original cargo proforma quantity after second release");
			self.assertEqualMsg(payment.myProformaDetail.lineTotal, 1000.Decimal, "Third original cargo proforma value after second release");
		endif;
	endforeach;
	self.assertEqualMsg(count, 3, "Original cargo payments after second release");
	count := 0;
	foreach line in cargo.invoiceLines do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(line.lineTotal, 1000.Decimal, "First original invoice line after second release");
		elseif count = 2 then
			self.assertEqualMsg(line.lineTotal, 5000.Decimal, "Second original invoice line after second release");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, "Original invoice lines after second release");

	count := 0;
	foreach payment in splitCargo.allCashPayments do
		if payment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
			continue;
		endif;
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(payment.cashValue, 2000.Decimal, "First split cargo payment after second release");
		elseif count = 2 then
			self.assertEqualMsg(payment.cashValue, 2000.Decimal, "Second split cargo payment after second release");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, "Split cargo payments after second release");
	count := 0;
	foreach line in splitCargo.invoiceLines do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(line.lineTotal, 2000.Decimal, "First Split invoice line after second release");
		elseif count = 2 then
			self.assertEqualMsg(line.lineTotal, 2000.Decimal, "First Split invoice line after second release");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, "Split invoice lines after second release");

end;
</source>
