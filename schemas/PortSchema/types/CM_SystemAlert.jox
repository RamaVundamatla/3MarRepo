/*

Purpose:			


Return Value:		


Date		Who		Reason
29 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if  self.mySystemAlertType &lt;&gt; _systemAlertType then
		self.mySystemAlertType := _systemAlertType;
	endif;


epilog

end;</source>
        <Parameter name="_systemAlertType" type="CM_SystemAlertType"/>
