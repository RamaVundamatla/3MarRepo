    <JadeMethod name="tidyUpOOWCreations" id="befc0810-6617-42bf-aa08-dff36f626978">
        <updating/>
        <source>tidyUpOOWCreations() updating;
// ---------------------------------------------------------------------------
// Created:		05 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	realOOWC, twinOOWC : CM_OOWCreation;
begin
	foreach realOOWC in self.allOOWCreations do
		
		twinOOWC := realOOWC.mySplitSelf;
		if twinOOWC &lt;&gt; null then
			if realOOWC.myCraneJobSheet = twinOOWC.myCraneJobSheet then
				realOOWC.setForMerge(twinOOWC);
			endif;
		endif;

		if realOOWC.CM_OOWCreationDetail.getTotalItems() = 0 then
			if twinOOWC &lt;&gt; null then
				twinOOWC.setMySplitSelf(null);
			endif;
			delete realOOWC;
			continue;
		endif;

	endforeach;
	foreach realOOWC in self.allOOWCreations do
		twinOOWC := realOOWC.mySplitSelf;
		if twinOOWC = null then
			realOOWC.setPropertyValue(CM_OOWCreation::orderType.name,1);
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="updateBayLinks" id="f6ee1a39-b833-4090-8dbc-f665a5da1e56">
        <source>updateBayLinks();
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	realBay,previousBay:CM_Bay;
	aHold : CM_Hold;
begin
	previousBay := null;
	foreach realBay in self.allBayVoyagesByOrdinal do
		if previousBay &lt;&gt; null then
			previousBay.setMyAftBay(realBay);
		endif;
		previousBay := realBay;
	endforeach;
	if realBay &lt;&gt; null then
		realBay.setMyAftBay(null); // make sure that it does not wrap around to the front
	endif;
	// PAR 7799 make the bay types for all the aft bays the same as the forward bays
	foreach aHold in self.allHolds do
		aHold.updateBayLinks();
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateBayIDs" id="c2896108-4acc-4241-8667-a06c6a566a46">
        <source>validateBayIDs();
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theBayIds : StringArray;
	aBay : CM_Bay;
	errorBayID : String;
begin
	
	create theBayIds transient;
	
	// CHECK that the 20 and 40 bay ids are unique
	errorBayID := "";
	foreach aBay in self.allBayVoyagesByOrdinal do
		if aBay.id &lt;&gt; null then
			if not theBayIds.includes(aBay.id) then
				theBayIds.add(aBay.id);
			else
				errorBayID := aBay.id;
				break;
			endif;
		endif;
	endforeach;
	if errorBayID &lt;&gt; null then
		app.raiseCMException2(ERR_INVALID_VALUE,"20 Foot Bay ID", " Bay ID '" &amp; errorBayID &amp; "' is already is use, it must be unique", null, null);
	
	endif;
	errorBayID := "";
	foreach aBay in self.allBayVoyagesByOrdinal do
		
		if aBay.idBay40 &lt;&gt; null then
			if not theBayIds.includes(aBay.idBay40) then
				theBayIds.add(aBay.idBay40);
			elseif aBay.id = aBay.idBay40 
			and aBay.fortyFootOnly then				//JC 28/04/2004	added
				//this will be allowed				//JC 28/04/2004	added
			else
				errorBayID := aBay.idBay40;
				break;
			endif;
		endif;
	endforeach;
	if errorBayID &lt;&gt; null then
		if aBay &lt;&gt; null then
			app.raiseCMException2(ERR_INVALID_VALUE,"40 Foot Bay ID", " Bay ID '" &amp; errorBayID &amp; "' used on bay " &amp; aBay.id &amp; " is already is use, it must be unique", null, null);
		else
			app.raiseCMException2(ERR_INVALID_VALUE,"40 Foot Bay ID", " Bay ID '" &amp; errorBayID &amp; "' is already is use, it must be unique", null, null);
		endif;	
	endif;
	foreach aBay in self.allBayVoyagesByOrdinal do
		aBay.validateTierIDs();
		aBay.validateCellIDs();
		aBay.validateSlot40();
	endforeach;
epilog
	delete theBayIds;


end;</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="47fbe5e9-11b8-42c9-9d14-eccfabb56665">
        <source>validateForCreate(_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 Jan 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	
	inheritMethod(_passport);
	self.validateBayIDs();
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdateStructure" id="a33bcaf4-9cb8-4559-8f51-492454145a66">
        <source>validateForUpdateStructure(_passport : CM_Passport input;_includeStructures : Boolean);
// ---------------------------------------------------------------------------
// Created:     16 Jan 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
begin
	
	self.validateMe(_passport);
	if _includeStructures then // do not do this from Voyage Call screen
		self.validateBayIDs();
	endif;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_includeStructures" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="b8c5e2d7-7b4d-4c59-858f-6484c4fe3349">
        <source>validateMe(_passport : CM_Passport input);
//-----------------------------------------
// Created: April 2004 By: cnwgd1
//-----------------------------------------
vars
	tmpString,
	msg		: String;	
	tmpVoyage : CM_Voyage;
begin
	
	inheritMethod(_passport);
	
	tmpVoyage := self.myVoyage;

	tmpVoyage.validateForCellularStructure(_passport);
/* PAR 33644 REMOVED is OK to have LOLO and GC HIOLDS				
	if (tmpVoyage.isNonPlannedVoyage or tmpVoyage.isNonWorkedVoyage) 
	and (not self.allBayVoyagesByOrdinal.isEmpty) then
		//this is a bit strange, going from planned/worked to non-planned
		if tmpVoyage.isNonPlannedOrNotCellularRORO then		// PAR 21745 CCMS MES 1031 - We do now allow RORO/Planned voyages
			if tmpVoyage.isNonPlannedVoyage then
				msg := app.getErrorString(Non_Planned);
			endif;
			if tmpVoyage.isNonWorkedVoyage then
				if msg &lt;&gt; null then
					msg := msg &amp; "/" &amp; app.getErrorString(Non_Worked);
				else
					msg := app.getErrorString(Non_Worked);
				endif;
			endif;
			app.raiseCMException1(ERR_SHIP_STRUCTURE_EXISTS, msg, 'myShipBlockStack', null);
		endif;
	endif;
	*/
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateOOWCPhysicalOrder" id="d8501c13-1758-4cf7-b55d-e11e308fced9">
        <source>validateOOWCPhysicalOrder();
// ---------------------------------------------------------------------------
// Created:		18 September 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aJS : CM_VoyageJobSheet;
	aBay : CM_Bay;
	firstOOWC, oowc :CM_OOWCreation;
begin
	if self.myVoyage = null then
		return;
	endif;

	foreach aBay in self.allBayVoyagesByOrdinal discreteLock do
		firstOOWC := null;
		foreach oowc in self.allOOWCreations discreteLock do
			if oowc.myBay = aBay then
				if firstOOWC &lt;&gt; null then
					if not  oowc.CM_OOWCreationDetail.validateOOWCOrder(firstOOWC.CM_OOWCreationDetail) then
						app.raiseCMWarning2(Cannot_be_after,oowc.getDescription(), firstOOWC.getDescription(), null,null, self);
					endif;
				endif;
				firstOOWC := oowc;
			endif;
		endforeach;
	endforeach;	
end;</source>
    </JadeMethod>
</Class>
