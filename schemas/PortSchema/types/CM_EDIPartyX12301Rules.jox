    <JadeMethod name="create" id="fe02b96e-2c29-4b35-bd42-cea15a464699">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2015	cnwma1	Initial creation

*/

vars
	type	:CM_EDIFileType;
begin
	// set file type
	type := app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileTypeX12_301_4010, null);
	
	if type = null or type.type &lt;&gt; EDIFileTypeX12_301_4010 then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'X12 file type missing');
	endif;
	
	self.myEDIFileType	:= type;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDefaultVoyage" id="1a7d0c00-e59a-47d2-8c91-90377ef8a1f6">
        <source>getDefaultVoyage():CM_Voyage;
/*
Date		Who		Reason
// 18 Apr 2018	jlgrs1	TFS 8296 add release req and prenotes to X12 301
*/
vars
	gotException : Boolean;
	voyage : CM_Voyage;
begin
	on Exception do app.handleDeletedObject(exception, voyage, gotException);
	
	voyage := self.myDefaultVoyage;
	
	if voyage = null then
		return null;
	endif;
	
	if voyage.edition &gt;= 0 then
		return voyage;
	endif;
		
	// must have got an exception
	return null;
epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getX12301EDIDataStyle" id="a0248952-44e9-40a6-8a9d-0cde921e4569">
        <source>getX12301EDIDataStyle() : Boolean;
//
// 18 Apr 2018	jlgrs1	TFS 8296 add release req and prenotes to X12 301
//
vars

begin
	if self.prenoteN7 or
	   self.relReqY4 then
		return true;
	else
		return false;
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="d22548da-893a-431b-9e91-4d05e11ae498">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2015	cnwma1	Initial creation
// 18 Apr 2018	jlgrs1	TFS 8296 add release req and prenotes to X12 301
*/
vars
	proxy : CM_EDIPartyX12301Rules;
begin
	proxy := inheritMethod();
	
	proxy.useN1SH := self.useN1SH;
	proxy.defaultAvailabilityGrade := self.defaultAvailabilityGrade;
	proxy.defaultAvailabilityGradeReefer := self.defaultAvailabilityGradeReefer;
	proxy.defaultDeliveryReasonCode := self.defaultDeliveryReasonCode;
	proxy.defaultDeliveryReasonDesc := self.defaultDeliveryReasonDesc;
	proxy.defaultReleaseStatus := self.defaultReleaseStatus;
	proxy.defaultReleaseType := self.defaultReleaseType;
	proxy.myDefaultCarrier := self.myDefaultCarrier;
	proxy.myDefaultSubTerminal := self.myDefaultSubTerminal;
	proxy.myDefaultVoyage := self.myDefaultVoyage;
	proxy.myISOTypeForGen := self.myISOTypeForGen;
	proxy.prenoteN7 := self.prenoteN7;
	proxy.relReqY4 := self.relReqY4;

	return proxy;
epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="68e483d0-3cf1-4436-ab95-094fa4f76419">
        <updating/>
        <source>setForUpdate(_proxy: CM_EDIPartyX12301Rules) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2015	cnwma1	Initial creation
*/
// 18 Apr 2018	jlgrs1	TFS 8296 add release req and prenotes to X12 301
vars

begin
	inheritMethod(_proxy);
	
	self.useN1SH := _proxy.useN1SH;
	self.defaultAvailabilityGrade := _proxy.defaultAvailabilityGrade;
	self.defaultAvailabilityGradeReefer := _proxy.defaultAvailabilityGradeReefer;
	self.defaultDeliveryReasonCode := _proxy.defaultDeliveryReasonCode;
	self.defaultDeliveryReasonDesc := _proxy.defaultDeliveryReasonDesc;
	self.defaultReleaseStatus := _proxy.defaultReleaseStatus;
	self.defaultReleaseType := _proxy.defaultReleaseType;
	self.myDefaultCarrier := _proxy.myDefaultCarrier;
	self.myDefaultSubTerminal := _proxy.myDefaultSubTerminal;
	self.myDefaultVoyage := _proxy.myDefaultVoyage;
	self.myISOTypeForGen := _proxy.myISOTypeForGen;
	self.prenoteN7 := _proxy.prenoteN7;
	self.relReqY4 := _proxy.relReqY4;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_EDIPartyX12301Rules"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="447a64a3-06ed-49fd-8a2a-d9782a535f61">
        <updating/>
        <source>setProxy(_useN1SH, _prenoteN7, _relReqY4 : Boolean; _myISOTypeForGen : CM_ISOType; _myDefaultVoyage : CM_Voyage; 
		_myDefaultSubTerminal : CM_SubTerminal; _myDefaultCarrier : CM_Carrier; _defaultReleaseType, _defaultReleaseStatus : Integer;
		_defaultDeliveryReasonDesc : String; _defaultAvailabilityGrade, _defaultAvailabilityGradeReefer : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2015	cnwma1	Initial creation
*/
// 18 Apr 2018	jlgrs1	TFS 8296 add release req and prenotes to X12 301
vars

begin
	self.useN1SH := _useN1SH;
	self.prenoteN7 := _prenoteN7;
	self.relReqY4 := _relReqY4;
	self.defaultAvailabilityGrade := _defaultAvailabilityGrade;
	self.defaultAvailabilityGradeReefer := _defaultAvailabilityGradeReefer;
	self.defaultDeliveryReasonDesc := _defaultDeliveryReasonDesc;
	self.defaultDeliveryReasonCode := app.deliveryReasonStringToEnum (self.defaultDeliveryReasonDesc);
	self.defaultReleaseStatus := _defaultReleaseStatus;
	self.defaultReleaseType := _defaultReleaseType;
	self.myDefaultCarrier := _myDefaultCarrier;
	self.myDefaultSubTerminal := _myDefaultSubTerminal;
	self.myDefaultVoyage := _myDefaultVoyage;
	self.myISOTypeForGen := _myISOTypeForGen;
epilog

end;</source>
        <Parameter name="_useN1SH" type="Boolean"/>
        <Parameter name="_prenoteN7" type="Boolean"/>
        <Parameter name="_relReqY4" type="Boolean"/>
        <Parameter name="_myISOTypeForGen" type="CM_ISOType"/>
        <Parameter name="_myDefaultVoyage" type="CM_Voyage"/>
        <Parameter name="_myDefaultSubTerminal" type="CM_SubTerminal"/>
        <Parameter name="_myDefaultCarrier" type="CM_Carrier"/>
        <Parameter name="_defaultReleaseType" type="Integer"/>
        <Parameter name="_defaultReleaseStatus" type="Integer"/>
        <Parameter name="_defaultDeliveryReasonDesc" type="String"/>
        <Parameter name="_defaultAvailabilityGrade" type="Integer"/>
        <Parameter name="_defaultAvailabilityGradeReefer" type="Integer"/>
    </JadeMethod>
</Class>
