    <JadeMethod name="eprTestPutCargoToPreviousLocn" id="4fc1c8ac-dcb6-4c63-bd7a-eb03a93c2bfd">
        <source>eprTestPutCargoToPreviousLocn();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2022	jlier1	Initial creation

*/

vars
	request : WS_CargoLocationRequest;
	
	hhs		: JMTHandheldService;
	response : WS_Response;
begin
	
	app.initialize;
