end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="1ad6b76e-3928-4856-8232-af02fae1991a">
        <source>doQuery();
// ---------------------------------------------------------------------------
// Created:		16 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aTI : CM_TrackedItem;
	theDataLine : String;
	num, idx : Integer;
	table : CM_DataTable;
begin
	table := self.tblData;
	table.rows := table.fixedRows;
	
	foreach aTI in self.allTIs discreteLock do
		num := num + 1;
		theDataLine := aTI.getAttributeStringForDefArray(table.allTblDataEntRows);
		
		theDataLine := theDataLine.replaceString("&lt;TLREASON&gt;",self.allReasons[num]);
		
		idx := table.addItemObject(aTI, theDataLine.trimBlanks());
	
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="doRemove" id="eb913b66-d040-4f95-bae1-175d290216e3">
        <source>doRemove();
// ---------------------------------------------------------------------------
// Created:		16 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.tblData.row &gt; self.tblData.fixedRows then
	self.tblData.removeItem(self.tblData.row);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblDataContextMenu" id="0dc0c23a-e961-4634-814a-4d0533a914f4">
        <updating/>
        <source>doTblDataContextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:		16 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	xLeft 	: Real;
	yTop	: Real;
begin

	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   

	self.mnuInspect.visible := app.isAllowedToInspect();
	
	self.popupMenu(mnuContext, xLeft.Integer, yTop.Integer);

	return false;


end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="20e496f9-8f99-4314-8ffc-4616c8bb0b8c">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:		August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	xmlStr	: String;
begin
	xmlStr := inheritMethod();

	xmlStr := xmlStr &amp; self.tblData.getXmlStrForColumns(true);

	return xmlStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
