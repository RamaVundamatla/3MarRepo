    <JadeMethod name="deleteCalculationType" id="9e8122cd-6b4e-4e35-9f1d-5dab3aee4549">
        <source>deleteCalculationType(_code : String; _eraseLevel : Integer);

// 22/02/2017	cnwmh5	Change so that reads thru Quantity Maps and sets myCalculationType to null
//						Since myCalculationType is not a reference have to read each record

vars
	calcType	: CM_CalculationType;
	service		: CM_ServiceObject;
	quantityMap	: CM_QuantityMap;
begin
	calcType := self.getRoot().allCalculationTypesByCode[ _code ];
	if calcType &lt;&gt; null then
		// 22/05/2015 cnwmh5
		foreach service in calcType.allServices discreteLock do
			///app.myTrxDA.trxDeleteServiceObject(service, app.myPassport);
			self.deleteInvoiceService(service.name, NORMAL_ERASE);		// 13/09/2017 jlgmh5 - Change to use this delete
		endforeach;
		
		// 22/02/2017 cnwmh5
		beginTransaction;
		foreach quantityMap in CM_QuantityMap.instances discreteLock 
				where quantityMap.myCalculationType = calcType do
			quantityMap.setMyCalculationType(null);
		endforeach;
		commitTransaction;
		
		self.ignoreTrxWarnings(true);
		if _eraseLevel = NORMAL_ERASE then
			app.myTrxDA.trxDeleteCalculationType(calcType, app.myPassport);
		else
			app.myTrxDA.trxDeleteCalcTypeObjectForced(calcType, app.myPassport);
		endif;
		self.assertNoTrxErrorsOrWarnings();
	endif;

end;
</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="deleteCalendar" id="c81a04a4-8bec-4578-bbb6-a881ea407045">
        <source>deleteCalendar(_code : String; _dayTypeCode : String);
// CCMS 1295 free storage days
vars
	calendar	: CM_Calendar;
	dayType		: CM_DayType;
begin
	calendar := app.myRoot.allCalendars[_code];
	if calendar &lt;&gt; null then
		dayType := calendar.myDayType;
		beginTransaction;
		calendar.allTerminals.clear();
		commitTransaction;
	 	app.myTrxDA.trxDeleteCalendar(calendar, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	elseif _dayTypeCode &lt;&gt; null then
		dayType := app.myRoot.allDayTypes[_dayTypeCode];
	endif;
	if dayType &lt;&gt; null then
		app.myTrxDA.trxDeleteDayType(dayType, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;

end;
</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_dayTypeCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteCamGroup" id="10c25c64-64de-451e-b803-e53e90171f93">
        <source>deleteCamGroup(_code : String);
// cnwrs1 1 Feb 2011
vars
	camGroup : CM_CamGroup;
	protocol : CM_CamProtocol;
begin
	camGroup := self.getTerminal.camGroups[_code];
	if camGroup = null then
		return;
	endif;
	
	// 12/06/2014 cnwmh5 - delete any cam protocols that exist for this cam group
	foreach protocol in camGroup.protocols do
		self.deleteCamProtocol(protocol.code);
		self.assertNoTrxErrorsOrWarnings();
	endforeach;
	
 	app.myTrxDA.trxDeleteCamGroup(camGroup, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
end;
</source>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteCamProtocol" id="53183e2d-c673-464f-ac8d-1a409e569799">
        <source>deleteCamProtocol(_code : String);
// cnwrs1 1 Feb 2011
vars
	camProtocol : CM_CamProtocol;
begin
	camProtocol := self.getTerminal.camProtocols[_code];
	if camProtocol = null then
		return;
	endif;
	
	self.deleteCamProtocolFiles(camProtocol);

 	app.myTrxDA.trxDeleteCamProtocol(camProtocol, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
end;
</source>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteCamProtocolFiles" id="39adf4e6-7f20-4feb-9696-1bc3650db823">
        <source>deleteCamProtocolFiles(camProtocol : CM_CamProtocol);
/*

Date		Who		Reason
21 June 2016	cnwer1	Initial creation TFS

*/

vars
	camTaskHistory : CM_CamTaskHistory;
	fileObj : File;
	fileDirectory : String;
	assoc	:CM_Association;
begin
	assoc := self.getProfileSetting (UT_Profile.P_CAMS_DIRECTORY);
	if assoc &lt;&gt; null then
		fileDirectory := assoc.asString &amp; 
						'\' &amp; camProtocol.getProtocolSubDirectoryName; 
	else	
		fileDirectory := camProtocol.terminal.getConfig_FileDirectory(CamsFileDirectory).String.trimRight &amp; 
						'\' &amp; camProtocol.getProtocolSubDirectoryName; 
	endif;
	foreach camTaskHistory in camProtocol.taskHistoryByProtocolSeq discreteLock do
		if camTaskHistory.fileName &lt;&gt; null then
			create fileObj transient;
			fileObj.fileName := fileDirectory &amp; "\" &amp; camTaskHistory.fileName;
			
			if fileObj.isAvailable then
				fileObj.purge;
			endif;
			
			delete fileObj;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="camProtocol" type="CM_CamProtocol"/>
    </JadeMethod>
    <JadeMethod name="deleteCargo" id="bc4e4bfd-f316-4139-b593-6adaa0eaf2aa">
        <source>deleteCargo(id: String; _cargoType: Any) : Boolean;
//29 August 2008	cnwdw1	
//
vars
	ti: CM_TrackedItem;	
	cargoType: CM_CargoType;
begin

	if _cargoType.isKindOf(String) then
		cargoType := getRoot.getCargoTypeFromAbbrevOrDescr( _cargoType.String );
	else
		cargoType := _cargoType.CM_CargoType;
	endif;
	
	if cargoType &lt;&gt; null then
		ti := self.getTerminal.lookupTrackedItem(id, cargoType.id, TI_STATE_UNDEFINED, null, false);
		if ti = null then														// 08/05/2014 cnwmh5
			ti := self.getTerminal.lookupTrackedItem(id, cargoType.id, TI_STATE_OFFSITE, null, false);
		endif;
	endif;
	
	if ti &lt;&gt; null then 
		self.deleteTrackedItem(ti, false); // AKB added false
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="id" type="String"/>
        <Parameter name="_cargoType" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deleteCargoCheck" id="63620307-0182-4190-8518-a699b3e32a5d">
        <source>deleteCargoCheck(_cargoCheck : Any);

/*

Purpose:		

Date			Who		Reason
18/06/2015		cnwmh5	Initial creation

*/

vars

	cargoCheck						: CM_CargoCheck;
	obj								: Object;
	
	objArray						: ObjectArray;

begin

	if _cargoCheck.isKindOf(Integer) then
		cargoCheck := self.getTerminal().allCargoChecks[_cargoCheck.Integer];
	elseif _cargoCheck.isKindOf(CM_CargoCheck) then
		cargoCheck := _cargoCheck.CM_CargoCheck;
	endif;
	
	if cargoCheck = null then
		return;
	endif;
	
	create objArray transient;
	cargoCheck.allCargoCheckItems.copy(objArray);
	foreach obj in objArray do
		self.deleteCargoCheckItem(obj.CM_CargoCheckItem);
	endforeach;
	
	app.myTrxDA.trxDeleteCargoCheck(cargoCheck, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog

	delete objArray;

end;</source>
        <Parameter name="_cargoCheck" type="Any"/>
    </JadeMethod>
    <JadeMethod name="deleteCargoCheckItem" id="3ef8cffe-a3b3-46bc-9937-ca852e61a908">
        <source>deleteCargoCheckItem(_cargoCheckItem : CM_CargoCheckItem);

/*

Purpose:		

Date			Who		Reason
18/06/2015		cnwmh5	Initial creation

*/

vars

	cargoCheckItem					: CM_CargoCheckItem;

begin

	if _cargoCheckItem = null then
		return;
	endif;
	
	cargoCheckItem := _cargoCheckItem;
	
	app.myTrxDA.trxDeleteCargoCheckItem(cargoCheckItem, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog

end;</source>
        <Parameter name="_cargoCheckItem" type="CM_CargoCheckItem"/>
    </JadeMethod>
    <JadeMethod name="deleteCargoGroup" id="37b70230-5d17-436c-88e8-bb52002aa76d">
        <source>deleteCargoGroup( _id : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	cg : CM_CargoGroup;
	count : Integer;
	lastCount : Integer;
	assignedTi : CM_TrackedItem;

begin

	cg := self.getTerminal.getCargoGroupItem( _id );
	if cg &lt;&gt; null and cg.id = _id then
		while true do
			count := cg.allAssignedTrackedItems.size;
			if count = 0 then
				break;
			endif;
			if count = lastCount then
				break;
			endif;
			lastCount := count;
			assignedTi := cg.allAssignedTrackedItems.first;
			if assignedTi = null then
				break;
			endif;
			self.deleteTrackedItem(assignedTi, false);
		endwhile;
		self.deleteTrackedItem(cg, false);
	endif;

epilog

end;</source>
        <Parameter name="_id" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteCargoPhoto" id="6307b64e-be20-4eba-bb18-3e2f6645b71e">
        <source>deleteCargoPhoto(_trackedItem:CM_TrackedItem; _loadTime : TimeStamp);
//09 Nov 2009	cnwdz2
//
vars
	photo : CM_Photo;
	iter : Iterator;
	ts : TimeStamp;
begin
	iter := _trackedItem.allAttachments.createIterator();
	_trackedItem.allAttachments.startKeyGeq(CM_Attachment.Type_Photo, iter);
	while iter.next(photo) do
		if photo.type &lt;&gt; CM_Attachment.Type_Photo then
			break;
		endif;
		
		ts := photo.getLoadTimeStamp();	
		if ts = _loadTime then
			app.myTrxDA.trxDeleteCargoPhoto(photo, app.myPassport);
			self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
		endif;
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_loadTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="deleteCargoType" id="ec85cc29-bb86-4524-9e78-3730d069c3f6">
        <source>deleteCargoType(_code: String);
//06 August 2009	cnwdw1	
// 26/06/2014 		cnwmh5	Add deleting of products and deleting of Release Requests for this cargo type
// 05/02/2016		cnwkpd1	Performance changes - use keys for dictionaries by Cargo Type ID
//
vars
	cargoType		: CM_CargoType;
	mergeIter		: MergeIterator;
	terminal		: CM_Terminal;
	ti				: CM_TrackedItem;
	tilcType 		: CM_TILCType;
	voyage 			: CM_Voyage;
	product			: CM_Product;
	bulkRelease		: CM_BulkRelease;
	obj				: Object;
	tiSet			: CM_TISet;
	iter			: Iterator;
	cargoTypeId		: Integer;
	
begin
	cargoType := self.getRoot().getCargoTypeFromAbbrevOrDescr( _code );
	
	///terminal := self.getTerminal();
	
	if cargoType &lt;&gt; null then
		beginTransaction;
		cargoType.setPropertyValue(CM_CargoType::hasNoNonInversedUsages.name, true);
		commitTransaction;
		
		cargoTypeId := cargoType.id;
		
		// 07/07/2014 cnwmh5
		create tiSet transient;
		foreach terminal in app.myRoot.allTerminals do
		
			// 26/06/2014 cnwmh5 - delete bulk releases for this cargo type
			foreach bulkRelease in terminal.allBulkReleasesByCodeDate do
				foreach obj in bulkRelease.allReserveDetails do
					if obj.isKindOf(CM_ReserveSelection) and obj.CM_ReserveSelection.myCargoType = cargoType then
						self.deleteReleaseRequest(bulkRelease.code);
						break;
					endif;
				endforeach;		
			endforeach;
		
			// delete any tracked items for the cargoType
			delete mergeIter;
			create mergeIter transient;
			mergeIter.addCollection(terminal.allNotifiedTIsByCargoTypeId);
//			mergeIter.addCollection(terminal.allOffsiteTIsByCargoTypeId);
			mergeIter.addCollection(terminal.allOnsiteTIsByCargoTypeId);
			mergeIter.addCollection(terminal.allTbaTIsByCargoTypeId);
			
			mergeIter.startKeyGeq(cargoTypeId, null);
			while mergeIter.next(ti) do
				if ti.cargoType &lt;&gt; cargoTypeId then
					break;
				endif;
				//deleteTrackedItem(ti, false); // AKB added false
				if not tiSet.includes(ti) then
					tiSet.add(ti);
				endif;
			endwhile;
			
			delete iter;
			iter := terminal.allOffsiteTIsByCargoTypeId.createIterator();
			terminal.allOffsiteTIsByCargoTypeId.startKeyGeq(cargoTypeId, null, null, iter);
			while iter.next(ti) do 
				if ti.cargoType &lt;&gt; cargoTypeId then
					break;
				endif;
				if not tiSet.includes(ti) then
					tiSet.add(ti);
				endif;
			endwhile;
			
			foreach voyage in terminal.allVoyagesByCode do
				delete iter;
				iter := voyage.allOnshipTIsByCargoTypeId.createIterator;
				voyage.allOnshipTIsByCargoTypeId.startKeyGeq(cargoTypeId, null, iter);
				while iter.next(ti) do
					if ti.cargoType &lt;&gt; cargoTypeId then
						break;
					endif;
					
					if not tiSet.includes(ti) then
						tiSet.add(ti);
					endif;
				endwhile;
			endforeach;
		
		endforeach;
		terminal := self.getTerminal();	
		
		// 27/01/2015 cnwmh5
		self.deleteTrackedItemCT(tiSet, true);
		///foreach obj in tiSet do
		///	self.deleteTrackedItem(obj.CM_TrackedItem, true);
		///endforeach;		
		
		// 26/06/2014 cnwmh5 - delete products for this cargo type
		foreach product in cargoType.allProducts do
			self.deleteProduct(product, product.myOperator, cargoType);
			self.assertNoTrxErrorsOrWarnings();
		endforeach;
		
		/*
		// 26/06/2014 cnwmh5 - delete products for this cargo type
		foreach product in cargoType.allProducts do
			self.deleteProduct(product, product.myOperator, cargoType);
			self.assertNoTrxErrorsOrWarnings();
		endforeach;
		
		// delete any tracked items for the cargoType
		create mergeIter transient;
		terminal := self.getTerminal();
		mergeIter.addCollection(terminal.allNotifiedTIsByCargoTypeId);
		mergeIter.addCollection(terminal.allOffsiteTIsByCargoTypeId);
		mergeIter.addCollection(terminal.allOnsiteTIsByCargoTypeId);
		mergeIter.addCollection(terminal.allTbaTIsByCargoTypeId);
		
		while mergeIter.next(ti) do
			if ti.myCargoType = cargoType then
				deleteTrackedItem(ti, false); // AKB added false
			endif;
		endwhile;
		
		foreach voyage in terminal.allVoyagesByCode do
			while true do
				ti := voyage.allOnshipTIsByCargoTypeId.getAtKeyGeq(cargoType.id, null);
				if ti &lt;&gt; null
				and ti.cargoType = cargoType.id then
					deleteTrackedItem(ti, false); // AKB added false
				else
					break;
				endif;
			endwhile;
		endforeach;
		*/
		
		// 05/12/2012 cwnmh5
		foreach tilcType in cargoType.allTILCTypes do
			self.deleteTrailerType(tilcType);
		endforeach;
		
		self.ignoreTrxWarnings(true);
		//app.myPassport.setWarningsIgnored(true);
		app.myTrxDA.trxDeleteCargoType(cargoType, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
epilog
	delete mergeIter;
	delete tiSet;
	delete iter;
end;</source>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteCargoUpdateRequestsFor" id="4fd5616f-f07a-4bf6-baa2-7abeaf14bc40">
        <source>deleteCargoUpdateRequestsFor( _cargoType : CM_CargoType; _cargoId : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2016	cnwndl1	Initial creation	TFS 1650

*/

vars

	cargoUpdRequest : CM_EventRequestTI;
	selectedObj : CM_Object;

begin

	if _cargoType &lt;&gt; null then
		if _cargoId &lt;&gt; null then
			cargoUpdRequest := _cargoType.allEventRequestsStops.getAtKey(_cargoId);
			while cargoUpdRequest &lt;&gt; null do
				selectedObj := cargoUpdRequest;
				app.myTrxDA.trxDeleteCMObject(selectedObj, app.myPassport);
				cargoUpdRequest := null;
				cargoUpdRequest := _cargoType.allEventRequestsStops.getAtKey(_cargoId);
			endwhile;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_cargoId" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteCarrier" id="476d6987-6eee-41b3-bb93-ad43c0b1036b">
        <source>deleteCarrier(_code: String);
//09 September 2010	by cnwvu1
vars
	carrier	: CM_Carrier;
	vehicle : CM_Vehicle;
	terminal		: CM_Terminal;
	usedCarrier		: String;
begin

	carrier := self.getCarrier(_code);
	if carrier = null then
		return;
	endif;
	
	self.opts.addAssoc("DontDeleteCarrier", true);				// 20/08/2012
	foreach vehicle in carrier.vehicles do
		self.deleteVehicle(vehicle);
	endforeach;	
	
	// 03/03/2014 - cnwmh5 - Take into account if used for rail carrier on terminal
	beginTransaction;
	foreach terminal in app.myRoot.allTerminals do
		usedCarrier := terminal.getConfig(DefRailCarrier).String;
		if usedCarrier = carrier.code then
			terminal.setConfig(DefRailCarrier, null);
		endif;
	endforeach;
	commitTransaction;

 	app.myTrxDA.trxDeleteCarrier(carrier, app.myPassport);

	self.assertNoTrxErrorsOrWarnings();

end;</source>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteCheckPoint" id="34a273d7-23db-472b-91fa-048a403236f7">
        <source>deleteCheckPoint(_checkPointId : String; _harbour : HMS_Harbour);

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
22 December 2011	cnwmh5	Initial creation

*/

vars

	checkPoint				: HMS_Object;
	hookCodeHistory			: CM_HookCodeHistory;

begin

	if _harbour = null then
		return;
	endif;
	
	checkPoint := _harbour.allCheckPoints[_checkPointId].HMS_CheckPoint;
	if checkPoint &lt;&gt; null then
		
		if checkPoint.HMS_CheckPoint.myHookCode &lt;&gt; null then
			beginTransaction;
			foreach hookCodeHistory in checkPoint.HMS_CheckPoint.myHookCode.allHookCodeHistory do
				delete hookCodeHistory;		
			endforeach;
			commitTransaction;
		endif;
		
		app.myTrxDA.trxDeleteHMSObject(checkPoint, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();		
	endif;

epilog

end;</source>
        <Parameter name="_checkPointId" type="String"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="deleteCommodity" id="8eb0837e-c84e-4454-966d-4982a3c61db6">
        <source>deleteCommodity(_commodityId : String);

/*

Purpose:		Delete a Commodity	

Date			Who		Reason
29/11/2011		cnwmh5	Initial creation

*/

vars

	commodity			: CM_Commodity;
	terminal			: CM_Terminal;

begin

	commodity := app.myRoot.allCommodities[_commodityId];
	if commodity &lt;&gt; null then
	
		// remove from terminal defaults
		beginTransaction;
		foreach terminal in app.myRoot.allTerminals do
			if terminal.getConfig(DefCommodity).String = commodity.code then
				terminal.setConfig(DefCommodity, null);
			endif;
			if terminal.getConfig(DefReeferComdty).String = commodity.code then
				terminal.setConfig(DefReeferComdty, null);
			endif;
			if terminal.getConfig(DefHazCommodity).String = commodity.code then
				terminal.setConfig(DefHazCommodity, null);
			endif;
		endforeach;
		commitTransaction;
		
		app.myTrxDA.trxDeleteCommodity(commodity, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;

epilog

end;</source>
        <Parameter name="_commodityId" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteCommodityGroup" id="5bae81c7-df0c-4500-81a7-a23153560ae2">
        <source>deleteCommodityGroup(_commodityGroup : Any);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 February 2014	cnwma1	Initial creation

*/

vars

	commodityGroup 				: CM_CommodityGroup;

begin

	if _commodityGroup.isKindOf(String) then
		commodityGroup := app.myRoot.allCommodityGroups[_commodityGroup.String].CM_CommodityGroup;
	else	
		commodityGroup := _commodityGroup.CM_CommodityGroup;
	endif;
	
	if commodityGroup = null then
		return;
	endif;
	
	
	beginTransaction;
	commodityGroup.allCommodities.clear();
	commitTransaction;
	
	app.myTrxDA.trxDeleteCommodityGroup(commodityGroup, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

end;</source>
        <Parameter name="_commodityGroup" type="Any"/>
    </JadeMethod>
    <JadeMethod name="deleteConsignGroup" id="3dc39daf-f26c-4fda-9ee2-6d5587688878">
        <source>deleteConsignGroup(_consignGroup : Any);

/*

Purpose:		Delete a consign group

Date			Who		Reason
18/022013		cnwmh5	Initial creation

*/

vars

	consignGroup				: CM_ConsigneeConsignorGroup;

begin

	if _consignGroup.isKindOf(String) then
		consignGroup := app.myRoot.allConsignGroups[_consignGroup.String];
	else
		consignGroup := consignGroup.CM_ConsigneeConsignorGroup;
	endif;
	
	if consignGroup &lt;&gt; null then
		app.myTrxDA.trxDeleteConsignGroup(consignGroup, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;

epilog

end;</source>
        <Parameter name="_consignGroup" type="Any"/>
    </JadeMethod>
    <JadeMethod name="deleteConsigneeConsignor" id="63d45c67-8673-479f-8b48-478af2011f52">
        <source>deleteConsigneeConsignor( _consignoreeStr : String );

/*
Date				Who		Reason
23 February 2010	cnwrl1	Initial creation as part of PAR 21735 = CCMS 1068 (CR005) - EDI file load of Consignor/Consignee
*/
	
vars
	consigneeConsignor		: CM_ConsigneeConsignor;
	camGroup				: CM_CamGroup;
	bookingRef				: CM_BookingRef;
	
begin
	consigneeConsignor	:= app.myRoot.allConsigneeConsignors[ _consignoreeStr ];
	if consigneeConsignor = null then
		return;
	endif;
	
	// 11/06/2013 cnwmh5 - Remove from CAM Group
	beginTransaction;
	foreach camGroup in consigneeConsignor.allCamGroupsForFF do
		camGroup.allFreightForwarders.remove(consigneeConsignor);	
	endforeach;	
	commitTransaction;
	
	// 11/06/2013 cnwmh5
	beginTransaction;
	foreach bookingRef in consigneeConsignor.allBookingRefsByRef do
		bookingRef.setPropertyValue("myConsignee", null);
		bookingRef.setPropertyValue("myConsignee", null);
		bookingRef.setPropertyValue("myFreightForwarder", null);
	endforeach;
	commitTransaction;
	
	app.myTrxDA.trxDeleteConsigneeConsignor( consigneeConsignor, app.myPassport );
	self.assertTrueMsg( app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString() );
	
epilog
	
end;
</source>
        <Parameter name="_consignoreeStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteContainer" id="69c0f487-9731-447a-b448-7bc4ae0a7be5">
        <source>deleteContainer(_id: String) ;
//29 August 2008	cnwdw1	
//
vars
	ti		: CM_TrackedItem;	
begin
	while true do
		  // 13/05/2011 cnwmh5
		ti := self.getTrackedItemByCargoType(_id, 1);    
		if ti = null then
			break;
		endif;
		self.deleteTrackedItem(ti, false); // AKB added false
	endwhile;
end;
</source>
        <Parameter name="_id" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteContainerOnVoyage" id="c6d74641-13c9-406c-a3c9-c5f8bb22f075">
        <source>deleteContainerOnVoyage(_id: String; _voyageCode : String) ;
//29 August 2008	cnwdw1	
//
vars
	ti, pxyTI: CM_TrackedItem;	
	root: CM_Root;
	oid: String;
begin
	root := CM_Root.firstInstance;
	ti := self.getTerminal.lookupTrackedItem(_id, TI_CargoType_Container, TI_STATE_ONSHIP, _voyageCode, false);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, false); // AKB added false
	endif;
end;
</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteContainerRange" id="6931c65e-61df-4f19-b680-7ead2f547140">
        <source>deleteContainerRange(_start, _end :String);
// ---------------------------------------------------------------------------
// Created:     24 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	range	:CM_ContRange;
begin
	range := app.myRoot.lookupContainerRange(_start);
	
	if range = null or range.lower &lt;&gt; _start or range.upper &lt;&gt; _end then
		return;
	endif;
	
	app.myTrxDA.trxDeleteContRange (range, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings ();
epilog

end;</source>
        <Parameter name="_start" type="String"/>
        <Parameter name="_end" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteCustomsAgent" id="132429d6-ffc0-4a34-bb65-a5278c0129f5">
        <source>deleteCustomsAgent(_customAgent : Any);

/*

Purpose:		Delete a Custom Agent	

Date			Who		Reason
29/11/2011		cnwmh5	Initial creation

*/

vars

	customsAgent			: CM_CustomsAgent;

begin

	if _customAgent.isKindOf(String) then
		customsAgent := app.myRoot.allCustomsAgents[_customAgent.String];
	else
		customsAgent := _customAgent.CM_CustomsAgent;
	endif;
	
	if customsAgent &lt;&gt; null then
		app.myTrxDA.trxDeleteCustomsAgent(customsAgent, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;

epilog

end;</source>
