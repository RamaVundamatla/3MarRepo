    <JadeMethod name="startGraphTimer" id="5df9b3d6-beb0-4ff3-8040-64d8c3527aca">
        <updating/>
        <source>startGraphTimer() updating, protected;

begin
	self.stopGraphTimer;
	
	if self.graphTimerInterval &gt; 0 then
		self.beginTimer(self.graphTimerInterval, Timer_Continuous, self.GraphTimerEventNumber);
		self.graphTimerRunning := true;
	endif;
end;</source>
