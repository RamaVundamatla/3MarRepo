    <JadeMethod name="btnAdd_click" id="e5c94de5-e1d5-4441-a763-3fb1f5d5a6bb">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAdd_click(btn: Button input) updating;

begin
	app.mousePointer	:=	Busy;
	self.doPrinterAdd();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnCancel_click" id="e19c28b3-90d8-4542-947a-712c45174bef">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;

begin
	self.aIsCancelled	:=	true;
	self.unloadForm();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOk_click" id="3c6c272b-f7f4-4d13-9611-60dde9c7d9c5">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOk_click(btn: Button input) updating;

begin
	app.mousePointer	:=	Busy;
	self.aIsCancelled	:=	false;

	if self.doFormUpdate(false) then
		unloadForm();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnRemove_click" id="733309d6-6c0a-42b9-abd4-5738881d981a">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnRemove_click(btn: Button input) updating;

begin
	app.mousePointer	:=	Busy;
	self.doPrinterRemove();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="fbbc377d-4801-447a-9217-a49b449e084c">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		02 August 2000 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	printerNameArray	: StringArray;

begin
	inheritMethod();

	create printerNameArray transient;

	txtDescription.text	:=	self.aMyReport.reportDescription;
	global.cnEcGetAllPrinters(printerNameArray);
	lstPrinters.listCollection(printerNameArray, false, 0);

	if self.aAllSelectedPrinters.cnEcIsNotEmpty() then
		lstSelected.listCollection(self.aAllSelectedPrinters, false, 0);
	endif;
epilog
	delete printerNameArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="0c0de590-730c-4adc-8f1d-b922d001d190">
        <updating/>
        <source>doFormUpdate(pIsDelete: Boolean): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		02 August 2000 by cnwdad1
//
// Purpose:		Standard form update method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	printerIndex	: Integer;
	printerCount	: Integer;

begin
	if self.doValidateDetails() then
		self.aAllSelectedPrinters.clear();
		printerCount	:=	lstSelected.listCount;
	
		foreach printerIndex in 1 to printerCount do
			self.aAllSelectedPrinters.add(lstSelected.itemText[printerIndex]);
		endforeach;
	endif;
epilog
	return self.doShowError();
end;</source>
        <access>protected</access>
        <Parameter name="pIsDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPrinterAdd" id="6cb3384e-4e9b-4c56-88f8-baf617a28be8">
        <updating/>
        <source>doPrinterAdd() updating, protected;

begin
	if lstPrinters.listIndex &lt;&gt; CNEC_NULL_INDEX then
		lstPrinters.cnEcMoveSelected(lstSelected);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doPrinterRemove" id="1094b2fb-1e27-49f4-8366-48cfc1ba1bda">
        <updating/>
        <source>doPrinterRemove() updating, protected;

begin
	if lstSelected.listIndex &lt;&gt; CNEC_NULL_INDEX then
		lstSelected.cnEcMoveSelected(lstPrinters);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doValidateDetails" id="5af75586-8206-4b5f-81bd-23b47c24bfe2">
        <updating/>
        <source>doValidateDetails():Boolean updating, protected;

begin
	if lstSelected.listCount = 0 then
		self.setErrorMessage("Please select a Printer.");
		return false;
	endif;

	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="queryUnload" id="5594fd1e-1c37-4b23-b86e-b24f9cd774ed">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;

begin
	if self.aIsCancelled and self.aAllSelectedPrinters.size() &gt; 0 then
		self.aAllSelectedPrinters.clear();
	endif;

	inheritMethod(cancel, reason);
end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
</GUIClass>
