    <JadeMethod name="setupMenu" id="7b8a253b-2eee-44b5-a9f9-f8b2fc3bf43b">
        <updating/>
        <source>setupMenu() protected, updating;
/*
Date		Who		Reason
26 January 2009	cnwcp2	Initial creation
*/

vars
	passport : CM_Passport;
	term : CM_Terminal;
begin
	passport := app.myPassport;
	term := passport.myTerminal;
	
		
	self.mConnect.visible := app.myCurrentUserCan(term, PmHHReeferConnect);
	self.mReadings.visible := app.myCurrentUserCan(term, PmHHReeferReadings);
	self.mMoveCargo.visible := app.myCurrentUserCan(term, PmHHMove);
	self.mRaiseAlert.visible := app.myCurrentUserCan(term, PmHHRaiseAlert);
	
	self.isMenuItemsVisible := self.mConnect.visible or
								self.mReadings.visible or
								self.mMoveCargo.visible or
								self.mRaiseAlert.visible;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTable" id="7894651e-5ca5-44a6-8ea4-ff8af968f2f5">
        <updating/>
        <source>setupTable() updating, protected;

/*
Purpose: Set up the table of the form with the correct headings

Date		Who		Reason
22 January 2009	cnwcp2	Initial creation
*/

vars
begin

	self.tblResults.fontName := "Tahoma";
	self.tblResults.rows := 18;
	self.tblResults.columns := 2;

	self.tblResults.accessCell(1,1).text := app.getErrorString(AlternativeID);
	self.tblResults.accessCell(2,1).text := app.getErrorString(Location);
	self.tblResults.accessCell(3,1).text := app.getErrorString(Temperature);
	self.tblResults.accessCell(4,1).text := app.getErrorString(Commodity);
	self.tblResults.accessCell(5,1).text := app.getErrorString(ControlledAtmosphere);
	self.tblResults.accessCell(6,1).text := app.getErrorString(CM_O2);
	self.tblResults.accessCell(7,1).text := app.getErrorString(CM_CO2);
	self.tblResults.accessCell(8,1).text := app.getErrorString(CM_Ventilation);
	self.tblResults.accessCell(9,1).text := app.getErrorString(Connected);
	self.tblResults.accessCell(10,1).text := app.getErrorString(Disconnected);
	self.tblResults.accessCell(11,1).text := app.getErrorString(Voyage);
	self.tblResults.accessCell(12,1).text := app.getErrorString(CM_Consignor);
	self.tblResults.accessCell(13,1).text := app.getErrorString(CM_Humidity);
	self.tblResults.accessCell(14,1).text := app.getErrorString(Operator);
	self.tblResults.accessCell(15,1).text := app.getErrorString(CM_Booking_Ref);
	self.tblResults.accessCell(16,1).text := app.getErrorString(CM_Discharge_Port);
	self.tblResults.accessCell(17,1).text := app.getErrorString(AvailabilityGrade);
	self.tblResults.accessCell(18,1).text := app.getErrorString(Reefer_remarks);
	
	self.tblResults.accessRow(5).wordWrap := true;
	self.tblResults.accessRow(17).wordWrap := true;
	self.tblResults.accessRow(18).wordWrap := true;

epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="9defa8ec-50e1-418b-b5e9-5806239b4c46">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:49:32.
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023436, locale);
	mConnect.translateCaption(Xlat_0023439, locale);
	mMoveCargo.translateCaption(Xlat_0023440, locale);
	mPopupMenu.translateCaption(Xlat_0023437, locale);
	mRaiseAlert.translateCaption(Xlat_0023441, locale);
	mReadings.translateCaption(Xlat_0023438, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
