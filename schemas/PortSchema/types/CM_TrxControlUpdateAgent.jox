        <updating/>
        <source>trxUpdateEDIFileStatus(_ediFile: CM_EDIFile; _newStatus: Integer; _passport: CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	09 June 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ediFile		: CM_EDIFile;
begin

//	do not initialize activity for this action

	app.setContinueCMExceptions(false);

	ediFile := _ediFile;
	
	beginTransaction;
	
	app.myUtilityUA.utlUpdateEDIFileStatus(ediFile, _newStatus, _passport);

	app.cmsCommitTransaction(null);
	
epilog
	//should have committed by now - must be a problem
	if process.isInTransactionState then
		app.cmsAbortTransaction;
	endif;
	
end;</source>
