    <JadeMethod name="ndlx101" id="45280d0d-2951-45c5-906c-2fcc1c6ca8ec">
        <source>ndlx101();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2021	navndl1	Initial creation	TFS 51142

*/

vars

	mutex : CM_Mutex;

begin

	app.initialize();
	app.myPassport.setMyUserFromCode("SUPERUSER");

	mutex := app.myRoot.allMutexes.getAtKey( Mutex_Permissions_String, Mutex_Permissions );	
	lock(mutex, Reserve_Lock, Session_Duration, LockTimeout_Immediate);
	
	app.myRoot.inspectModal;
	
	

epilog

	self.unlock(mutex);

end;</source>
    </JadeMethod>
    <JadeMethod name="objUpgradeRequestRun" id="7b30fa3d-b094-4a28-a61d-f6efe16c6822">
        <source>objUpgradeRequestRun();
//
//	/35678 test the fixup background run code
//
constants
	Terminal1 : String = 'BISH';
vars
	terminal : CM_Terminal;
	bgpRequest : BGP_BackgroundObjectUpgradeReq;
	oufs	: CM_ObjectUpgraderFutureStorage;
begin
	app.initialize;
	terminal := app.myRoot.allTerminals[Terminal1];
	if terminal = null then
		write 'Can not find required terminal ' &amp; Terminal1;
		return;
	endif;
	oufs := CM_ObjectUpgraderFutureStorage.firstInstance;
	
	if oufs = null then
		beginTransaction;
		create oufs persistent;
		commitTransaction;
	else
		beginTransaction;
		oufs.allTrackedItems.clear();
		oufs.deleteCount := 0;
		oufs.lastRunDate := null;
		oufs.setPropertyValue("upgradeStatus", CM_ObjectUpgraderFutureStorage.STATUS_NOT_STARTED);
		commitTransaction;
	endif;
	app.myPassport.setMyTerminal(terminal);
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	app.changeLogLevel(LogDEBUG);
	create bgpRequest transient;

	bgpRequest.action();
epilog
	delete bgpRequest;
end;
</source>
    </JadeMethod>
    <JadeMethod name="omanStop" id="151112ef-0c65-42a5-91d6-6b2b285e328d">
        <source>omanStop();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2018	jlgma1	Initial creation

*/

vars
	_ti : CM_TrackedItem;
	_result : Boolean;
	spl  : CM_SpecialLift;
begin

	
	foreach spl in _ti.allSpecialLifts do
																
				if spl.code.toUpper = "SL1" then
								_result := true;
								break;
				endif;
	endforeach;
end;


</source>
    </JadeMethod>
    <JadeMethod name="pRP49923" id="b3684b05-13d5-429e-af10-a1deb050be23">
        <source>pRP49923();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2020	jlgma1	Initial creation

*/

vars
	rtq : CM_RTQueueTask;
	i : Integer;
	str : String;
begin
	rtq :=  "2832.41395".asOid.CM_RTQueueTask;
	
	if rtq &lt;&gt; null then
		beginTransaction;
		rtq.setPropertyValue("myMachine",null);
		commitTransaction;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="par28948" id="50dcfd66-74af-49d7-b8d3-c71c4a4bd768">
        <source>par28948();
// find and fix all voyages with offloaded logs which have been incorrectly stock fixed
// Feb 2012 for C3, run in 781
vars
	invalidVoyage,
	invalidTi,
	invalidTrans,
	invalidSOH	: Boolean;
	date		: Date;
	foundOffload	: Boolean;
	logDir		 :String;
	voyage	: CM_Voyage;
	ti		: CM_TrackedItem;
	trans	: CM_Transaction;
	moveTrans	: CM_Move;
	sohLocn		: CM_SOHLocation;
	file		: File;
begin
	on Exception do app.handleDeletedObject(exception, voyage, invalidVoyage);
	on Exception do app.handleDeletedObject(exception, ti, invalidTi);
	on Exception do app.handleDeletedObject(exception, trans, invalidTrans);
	on Exception do app.handleDeletedObject(exception, sohLocn, invalidSOH);
	
	create file transient;
	logDir := app.getProfileStringAppServer(app.getIniFileNameAppServer(), 'JadeLog', 'LogDirectory', 'c:\temp');
	if logDir[logDir.length:1] &lt;&gt; '/' and
	   logDir[logDir.length:1] &lt;&gt; '\' then
		logDir := logDir &amp; '\';
	endif;
	file.usePresentationFileSystem := false;
	file.openOutput(logDir &amp; 'par28948.log');
	
	beginTransaction;

	foreach voyage in CM_Voyage.instances do
		invalidVoyage := false;
		if voyage.myLogVoyageStructure = null then
			continue;
		endif;
		if invalidVoyage then
			continue;
		endif;
		foreach ti in voyage.allOffloadedTIsByCargoTypeId do
			invalidTi := false;
			if ti.myMoveCloneToTI = null or
			   ti.myCurrentSOHLocation &lt;&gt; null then
				continue;
			endif;
			if invalidTi then
				continue;
			endif;
			foundOffload := false;
			moveTrans := null;
			foreach trans in ti.allTransactions reversed do
				invalidTrans := false;
				if trans.isKindOf(CM_Offload) then
					foundOffload := true;
				endif;
				if invalidTrans then
					continue;
				endif;
				if foundOffload and
				   trans.isKindOf(CM_Move) then
					moveTrans := trans.CM_Move;
					break;
				endif;
			endforeach;
			if moveTrans &lt;&gt; null then
				if moveTrans.myStockMovementIn &lt;&gt; null and
				   moveTrans.myStockMovementIn.myStockMoveBucket &lt;&gt; null and
				   moveTrans.myStockMovementIn.myStockMoveBucket.isKindOf(CM_StockMoveLocation) then
					sohLocn := moveTrans.myStockMovementIn.myStockMoveBucket.CM_StockMoveLocation.mySOHLocation;
					if sohLocn &lt;&gt; null then
						file.writeLine(voyage.code &amp; " " &amp; voyage.myTerminal.code &amp; " Log " &amp; ti.id &amp; " to " &amp; sohLocn.getName());
						sohLocn.adjustStockOnHand(date, StkMove_MoveIn, false, ti, null, null, true);
					endif;
				endif;
			endif;
		endforeach;
	endforeach;
	commitTransaction;
epilog
	if file &lt;&gt; null then
		if file.isOpen() then
			file.close();
		endif;
		delete file;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="par28953" id="6542df7f-df41-415e-90ba-0b077a0bd1ae">
        <source>par28953();

/*

