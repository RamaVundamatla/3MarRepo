	if self.mnuDisplay.visible then
		return;
	endif;
	if self.mnuOther.visible then
		return;
	endif;
	if self.mnuCargo.visible then
		return;
	endif;

	if self.mnuGridBulkEdit.visible then
		return;
	endif;

	self.mnuGridSeperator01.visible := false;
end;</source>
