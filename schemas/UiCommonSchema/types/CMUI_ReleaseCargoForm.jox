    <JadeMethod name="btnCargoIDsearch_click" id="ba817265-ae75-48ba-8654-5e4c2e535283">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCargoIDsearch_click(btn: Button input) updating;
// -----------------------------------------------------------------------------
// Created:		10 September 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 13 Mar 2023  navma1 		ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
// 17 Apr 2023  navhl20 	ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
// -----------------------------------------------------------------------------

vars

	tis			: CM_TISet;
	rowIndex 	: Integer;
	matchingTi  : CM_TrackedItem;
	selectedTi	: CM_TrackedItem;
	filter 		: String;
	
begin

	//19 Jul 2018	NDL	TFS 38617
	if self.cmbType.getObject = null and self.myTerminal.getConfig(UseFilterForReleaseById).Boolean then	
		create tis transient;
		filter := self.txtCargoIDvalue.text.trimBlanks.toUpper;
		foreach rowIndex in 1 to self.lstCargoIDvalues.rows do
			matchingTi := self.lstCargoIDvalues.accessRow( rowIndex ).itemObject.CM_TrackedItem;
			if matchingTi = null then
				continue;
			endif;
			if filter &lt;&gt; null and matchingTi.id.pos( filter, 1 ) &lt; 1 then
				continue;
			endif;
			tis.add( matchingTi );
		endforeach;
		if tis.isEmpty then
			app.msgBox( app.getErrorString1( Nothing_found_matching, filter ), app.getErrorString(Warning), MsgBox_OK_Only );
			return;
		elseif tis.size = 1 then
			selectedTi := tis.first;
		else
			self.myAssistant.pickerWindowForBreakBulk(tis, self.myTerminal, true, selectedTi, self);
		endif;
		if selectedTi &lt;&gt; null then
			self.myTI := selectedTi;
			self.txtCargoIDvalue.text := selectedTi.id;
			self.txtCargoIDvalue.lostFocus( self.txtCargoIDvalue );
		endif;
		return;
	endif;
	
	if self.showCargoPicker(self.txtCargoIDvalue.text) then
		return;
	endif;
	
	
	if self.isGeneralCargo then
		self.myAssistant.showCargoSearchForm(self, 
											null, 
											null, 
											null, 
											null,
											self.cmbType.getObject.CM_CargoType,
											null,null,												//17.4.2023 navhl20 #55443[54991]
											null);													//13.03.2023 navma1 #56457:[56458]
	else
		self.myAssistant.showCargoSearchForm(self, self.isEmptyContainer, 
											null, 
											null, 
											self.myReserveDetail, 
											app.myRoot.allCargoTypesById[TI_CargoType_Container],  //cnwrd1 par 21162 added reserveDetail
											null,null,												//17.4.2023 navhl20 #55443[54991]
											null);													//13.03.2023 navma1 #56457:[56458]
	endif;
epilog

delete tis;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
