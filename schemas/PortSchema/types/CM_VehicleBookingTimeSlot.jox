    <JadeMethod name="getSlotTypeYACriteria" id="85d7c2d5-f0e6-4f23-ba5c-856a6f6c3394">
        <source>getSlotTypeYACriteria(_hasCarrier,
			    _hasOperator,
			    _hasCargoType,
			    _hasProduct,
			    _hasCommodity 	: Boolean output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2023 navma1  ChangeRequest 54049: EUP - VBS MTN - [9] - Linking Multiple Slots to Vehicle visit

*/

vars
	slotType 			: CM_VehicleBookingTimeSlotType;
	vbsSlotTypeCriteria : CM_VBSSlotTypeCriteria;
	hasCarrier,
	hasOperator,
	hasCargoType,
	hasProduct,
	hasCommodity		: Boolean;
	criteria 			: CM_YACriteria;
begin

	slotType := self.myVBTimeSlotType;
	
	if slotType = null then
		return;
	endif;
	
	vbsSlotTypeCriteria := slotType.myVBSSlotTypeCriteria;
	
	if vbsSlotTypeCriteria = null then
		return;
	endif;
	foreach criteria in vbsSlotTypeCriteria.allCriteria do
		if criteria.myYACriteriaType.isYATypeCarrier then				//Carrier
			_hasCarrier := true;
		elseif  criteria.myYACriteriaType.isYATypeCargoType then		//CargoType
			_hasCargoType := true;
		elseif  criteria.myYACriteriaType.isYATypeProduct then			//Product
			_hasProduct := true;
		elseif  criteria.myYACriteriaType.isYATypeCommodity then		//Commodity
			_hasCommodity := true;
		elseif  criteria.myYACriteriaType.isYATypeOperatorItem then		//Operator
			_hasOperator := true;
		endif;
	endforeach;
	
end;
</source>
        <Parameter name="_hasCarrier" type="Boolean" usage="output"/>
        <Parameter name="_hasOperator" type="Boolean" usage="output"/>
        <Parameter name="_hasCargoType" type="Boolean" usage="output"/>
        <Parameter name="_hasProduct" type="Boolean" usage="output"/>
        <Parameter name="_hasCommodity" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getStatusInteger" id="b3d84bc9-3eba-463c-a057-9238446981c1">
        <source>getStatusInteger():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Apr 2013	cnwndl1	Initial creation	Par 31393
16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	graceMins 		: Integer;
	graceTSInterval : TimeStampInterval;
	startPeriod 	: TimeStamp;
	endPeriod 		: TimeStamp;
	now 			: TimeStamp;
	timeIn 			: TimeStamp;

begin

	graceTSInterval := self.getTimeslotGraceTimeInterval( graceMins );
	now 			:= app.actualTimeServer;
	
	if graceMins &gt; 0 then
		endPeriod := self.bookingTSend + graceTSInterval;
	else
		endPeriod := self.bookingTSend;
	endif;
	
	if self.myCarrier = null then
		if now &gt; endPeriod then
			return NoLongerAvailInt;						// Expired not Booked
		else
			return AvailableNotBookedInt;					// Available Not Booked
		endif;
	endif;
	
	if graceMins &gt; 0 then
		startPeriod := self.bookingTSstart - graceTSInterval;
	else
		startPeriod := self.bookingTSstart;
	endif;
	
	if not self.isUsed then
		if now &lt; startPeriod then
			return BookedNotYetDueInt;						// Booked Not Yet Due 
		elseif now &gt; endPeriod then
			return BookedOverdueInt;						// Booked Over Due
		else
			return BookedCurrentInt;						// Booked Current 
		endif;
	
	else
		timeIn := self.myVehicleVisitRecord.timeIn;
		if timeIn &lt; startPeriod then
			return BookedArrivedEarlyInt;					// Booked Arrived Early
		elseif timeIn &gt; endPeriod then
			return BookedArrivedLateInt;					// Booked Arrived Late
		else
			return BookedArrivedOntimeInt;					// Booked Arrived On Time 
		endif;
	endif;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getStatusString" id="aa1684a7-4a09-4367-92c4-dd6222745484">
        <source>getStatusString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	status : Integer;

begin

	status := self.getStatusInteger;
	
	if status = AvailableNotBookedInt then
		return AvailableNotBooked;
	elseif status = BookedNotYetDueInt then
		return BookedNotYetDue;
	elseif status = BookedOverdueInt then
		return BookedOverdue;
	elseif status = BookedCurrentInt then
		return BookedCurrent;
	elseif status = BookedArrivedEarlyInt then
		return BookedArrivedEarly;
	elseif status = BookedArrivedLateInt then
		return BookedArrivedLate;
	elseif status = BookedArrivedOntimeInt then
		return BookedArrivedOntime;
	elseif status = NoLongerAvailInt then
		return NoLongerAvail;
	else
		return null;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStatusStringWithTS" id="ce204336-0c1a-4486-a2a3-a4569483c2db">
        <source>getStatusStringWithTS() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Mar 2025	navnk30	JIRA 34424: TPT | VBS - Change the information from "Arrived on schedule" to be more clear with the timestamp like "Arrived on schedule at 23:23 on 20th March 2025"

*/

vars
	statusStr	: String;
	vvr 		: CM_VehicleVisitRecord;
begin
	statusStr := self.getStatusString();
	
	statusStr := self.getStatusString();
	vvr := self.myVehicleVisitRecord;
	if (statusStr = BookedArrivedEarly or
		statusStr = BookedArrivedOntime or
		statusStr = BookedArrivedLate) and
		(vvr &lt;&gt; null) then
		statusStr &amp;= " at " &amp; vvr.timeIn.Time.asStringJMT() &amp;
				" on " &amp; vvr.timeIn.Date.asStringJMT();
	endif;
	
	return statusStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
