    <JadeMethod name="setFromQuickFind" id="2687a499-72f8-4ae4-accf-338fe1afa1c4">
        <updating/>
        <source>setFromQuickFind( _vvr: CM_VehicleVisitRecord; _text : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2014	cnwndl1	Initial creation	Par 33350
14/09/2016	cnwma1	TFS #2619:SPT - Road Gate loading incorrect release/prenote details when entering the Reg Code
*/

vars

begin

	if _vvr &lt;&gt; null then

		self.txtVisitNumber.text := _vvr.visitNumber;
		//self.doQuery();  // 14/09/2016 cnwma1 TFS #2619
		self.doQuery(_vvr); // 14/09/2016 cnwma1 TFS #2619
	
	endif;
	

epilog

end;</source>
