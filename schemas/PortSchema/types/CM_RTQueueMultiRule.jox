    <JadeMethod name="pxyCreateUpdateProxy" id="66187f56-2c26-401f-b608-1ed35756a4fb">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
10 February 2010	cnwer1	Initial creation
20/04/2011			cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
							trying to create the proxy
*/

vars
	pxyRTQueueMultiRule : CM_RTQueueMultiRule;
	moveMethodRule : CM_RTMoveMethodRule;
	completedOK		: Boolean;
begin
	pxyRTQueueMultiRule:= inheritMethod();

	pxyRTQueueMultiRule.myTerminal:=self.myTerminal;
	
	foreach moveMethodRule in self.allDefaultRTMoveMethodRules do
		moveMethodRule.pxyCreateUpdateProxy();
	endforeach;
	
	foreach moveMethodRule in self.allOtherRTMoveMethodRules do
		moveMethodRule.pxyCreateUpdateProxy();
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyRTQueueMultiRule;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyRTQueueMultiRule;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="740bb8fc-8b31-4f23-b16c-8a72de81cd82">
        <updating/>
        <source>setForCreate(_pxyRTQueueMultiRule : CM_RTQueueMultiRule) updating;

// Created by cnwdvb1 on 29 August 2006

vars

begin

	self.setForUpdate(_pxyRTQueueMultiRule);
	
	self.myTerminal		:= _pxyRTQueueMultiRule.myTerminal;

end;</source>
        <Parameter name="_pxyRTQueueMultiRule" type="CM_RTQueueMultiRule"/>
    </JadeMethod>
    <JadeMethod name="setForProxy" id="6a64100e-28ab-4170-b094-bed6428b2073">
        <updating/>
        <source>setForProxy( _terminal : CM_Terminal) updating;

// Created by cnwdvb1 on 29 August 2006

vars

begin

	
	self.myTerminal		:= _terminal;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="414a729a-f220-4f2d-8b12-56b632640361">
        <updating/>
        <source>setForUpdate(_pxyRTQueueMultiRule : CM_RTQueueMultiRule) updating;

// Created by cnwdvb1 on 29 August 2006

vars
	pxyRTMoveMethodRule,
	realRTMoveMethodRule : CM_RTMoveMethodRule;
	allRTMoveMethodsToDelete,
	allRTMoveMethodsToCreate : CM_RTMoveMethodRuleSet;
begin
	create allRTMoveMethodsToDelete transient;
	create allRTMoveMethodsToCreate transient;
	self.allDefaultRTMoveMethodRules.copy(allRTMoveMethodsToDelete);
	self.allOtherRTMoveMethodRules.copy(allRTMoveMethodsToDelete);
	
	foreach pxyRTMoveMethodRule in _pxyRTQueueMultiRule.allOtherRTMoveMethodRules do
		realRTMoveMethodRule:=pxyRTMoveMethodRule.pxyGetRealObject;
		if realRTMoveMethodRule &lt;&gt;  null then
			allRTMoveMethodsToDelete.removeIfPresent(realRTMoveMethodRule);
		endif;
		allRTMoveMethodsToCreate.add(pxyRTMoveMethodRule);
	endforeach;
	
	foreach pxyRTMoveMethodRule in _pxyRTQueueMultiRule.allDefaultRTMoveMethodRules do	
		realRTMoveMethodRule:=pxyRTMoveMethodRule.pxyGetRealObject;
		if realRTMoveMethodRule &lt;&gt; null then
			
			allRTMoveMethodsToDelete.removeIfPresent(realRTMoveMethodRule);
		endif;
		allRTMoveMethodsToCreate.add(pxyRTMoveMethodRule);
	endforeach;
	
	//epr par 22577 8/3/10 purge these first to avoid 1300 exception
	allRTMoveMethodsToDelete.purge;
	
	foreach pxyRTMoveMethodRule in allRTMoveMethodsToCreate do
		realRTMoveMethodRule:=pxyRTMoveMethodRule.pxyGetRealObject;
		if 	 realRTMoveMethodRule = null then
			create realRTMoveMethodRule persistent;
		endif;
		realRTMoveMethodRule.setForCreate(pxyRTMoveMethodRule,self);
	endforeach;
	
epilog
	
	delete allRTMoveMethodsToDelete;
	delete allRTMoveMethodsToCreate;
end;</source>
        <Parameter name="_pxyRTQueueMultiRule" type="CM_RTQueueMultiRule"/>
    </JadeMethod>
    <JadeMethod name="validateCreate" id="ab6b5df6-4867-450f-9680-5bf2ed4a9cc4">
        <source>validateCreate(_passport: CM_Passport input);

// Created by cnwdvb1 on 05 September 2006

vars

begin
	
	if self.myTerminal = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Null Terminal', null, null);
	endif;
	
	self.validateUpdate(_passport);

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
