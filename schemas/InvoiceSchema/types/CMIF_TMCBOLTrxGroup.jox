	form.myCurrentMapTMBOL := self.myBOLBroker.myTransMap;
	form.myCurrentMapServiceBroker := self.myBOLBroker;

epilog

end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
</Class>
