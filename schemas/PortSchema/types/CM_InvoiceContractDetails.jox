    <JadeMethod name="logDetailUsed" id="867d4b27-fc43-41a8-940f-f3e1d1f7ee26">
        <source>logDetailUsed(_rate : CM_InvoiceContractRate);
/*
Purpose:			

Date				Who		Reason
21 November 2023	navab1	BUG 61096
23 Oct 2024			navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	canLogExtra			: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	// ### TFS BUG 61096 21NOV2023 NAVAB1
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog("CONT USED - CONTRACT = " &amp; self.myInvoiceContract.contractId, LogINFO.String);
		app.invLog("CONT USED - DEBTOR = " &amp; self.myInvoiceContract.myDebtor.name, LogINFO.String);
		app.invLog("CONT USED - INV LINE = " &amp; self.myInvoiceLineType.narration, LogINFO.String);
		app.invLog("CONT USED - FROM TS = " &amp; self.fromTS.asStringJMT(),LogINFO.String);
		app.invLog("CONT USED - TO TS = " &amp; self.toTS.asStringJMT(), LogINFO.String);
		if self.myInvoiceContractCriteria &lt;&gt; null and self.myInvoiceContractCriteria.description &lt;&gt; null then
			app.invLog("CONT USED - CRITERIA = " &amp; self.myInvoiceContractCriteria.description, LogINFO.String);
		endif;
		if self.myCalculationType&lt;&gt; null then
			app.invLog("CONT USED - CALCTYPE  = " &amp; self.myCalculationType.description, LogINFO.String);
		endif;
		if self.myUnitOfMeasure&lt;&gt; null then
			app.invLog("CONT USED - UOM = " &amp; self.myUnitOfMeasure.description, LogINFO.String);
		endif;
		
		// ### TFS CR 61579 TASK 62473 13FEB2024 NAVAB1
		if _rate &lt;&gt; null
		and _rate.myCalculationType&lt;&gt; null then
			app.invLog("CONT USED - CALCTYPE  = " &amp; _rate.myCalculationType.description, LogINFO.String);
		endif;
		app.invLog("-", LogINFO.String);
		app.invLog("-", LogINFO.String);
	endif;
epilog

end;</source>
        <Parameter name="_rate" type="CM_InvoiceContractRate"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="ca7d90c4-030f-4db7-b667-822fae74f85c">
        <source>pxyCreateUpdateProxy(): SelfType;
/*
Purpose:			

Date		Who		Reason
01 December 2022	navab1	TFS CR 55623 TASK 55673
*/

vars
	proxySelf : SelfType;
begin
	proxySelf := inheritMethod();
	
	proxySelf.myCalculationType := self.myCalculationType;
	proxySelf.myInvoiceContract := self.myInvoiceContract;
	proxySelf.myInvoiceLineType := self.myInvoiceLineType;
	proxySelf.myBusinessUnit := self.myBusinessUnit;
	
	if self.myInvoiceContractCriteria &lt;&gt; null then
		proxySelf.myInvoiceContractCriteria := self.myInvoiceContractCriteria.pxyCreateUpdateProxy();
	endif;
	
	return proxySelf;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="fc4f717a-724b-44d4-8f7e-8d437acf5223">
        <updating/>
        <source>setForCreate(_proxy : SelfType) updating;
/*
Purpose:			

Date		Who		Reason
01 December 2022	navab1	TFS CR 55623 TASK 55673
08 Feb 2023	navmv20 TFS 55650 Task 55702: Jade - Contracts XML Load TRX
*/

vars

begin
	self.contractType := _proxy.contractType;
	self.criteriaPriority := _proxy.criteriaPriority;
	self.fromTS := _proxy.fromTS;
	self.toTS := _proxy.toTS;
	self.myCalculationType := _proxy.myCalculationType;
	self.myInvoiceContract := _proxy.myInvoiceContract;
	self.myInvoiceLineType := _proxy.myInvoiceLineType;
	self.myBusinessUnit := self.myInvoiceContract.myBusinessUnit;
	self.myShippingTerm := _proxy.myShippingTerm; // ### TFS CR 55644 TASK 55684 12JAN2023 NAVAB1
	self.myUnitOfMeasure := _proxy.myUnitOfMeasure; //09/02/2023 navmv20 TFS 55650 TASK 55702
	self.id := self.cnGetInstanceId(self);  // ### TFS CR 55624 TASK 55700 24JAN2023 NAVAB1
	
	
	// TFS CR 55623 TASK 55679
	if _proxy.myInvoiceContractCriteria &lt;&gt; null and _proxy.myInvoiceContractCriteria.allCriteria.isNotEmpty then
		if self.myInvoiceContractCriteria = null then
			create self.myInvoiceContractCriteria persistent;
			self.myInvoiceContractCriteria.setForCreate(_proxy.myInvoiceContractCriteria);
		else
			self.myInvoiceContractCriteria.setForUpdate(_proxy.myInvoiceContractCriteria);
		endif;
	else
		delete self.myInvoiceContractCriteria;
	endif;
	
epilog

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
