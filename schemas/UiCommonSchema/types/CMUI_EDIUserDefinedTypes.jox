    <JadeMethod name="tblFieldMap_keyDown" id="bc380099-2314-4863-afac-2ca836f02df7">
        <controlMethod name="CM_DataTable::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblFieldMap_keyDown(table: Table input; keyCode: Integer io; shift: Integer) updating;
/*

Date		Who		Reason
05 September 2016	cnwer1	Initial creation TFS

*/

vars

begin
	if self.mode &lt;&gt; MODE_VIEW then
		if keyCode = J_key_Tab then
			if table.row = table.rows and table.column = table.getLastVisibleColumn() then
				self.txtNumFields.text := (self.txtNumFields.text.Integer + 1).asStringJMT;
				self.doUpdateNumberOfFields(self.txtNumFields);
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblFieldMap_mouseUp" id="1eb9ccbd-ce83-4050-9269-474c7a14f8d1">
        <controlMethod name="CM_DataTable::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblFieldMap_mouseUp(_table: CM_DataTable input; _button: Integer; _shift: Integer; _x, _y: Real) updating;
/*
Date		Who		Reason
28 May 2013	cnwcs5	Initial Creation - par 31618
*/
vars

begin
	if _table.tag = self.TAG_RENUMBER then
		self.doRenumberRows (_table);
	endif;
epilog
	_table.tag := null;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_button" type="Integer"/>
        <Parameter name="_shift" type="Integer"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblFieldMap_queryRowMove" id="0994fa1d-8021-4fe0-b371-8f3d06933950">
        <controlMethod name="Table::queryRowMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblFieldMap_queryRowMove(_table: Table input; _rowFrom, _rowTo: Integer):Boolean updating;
/*
Date		Who		Reason
28 May 2013	cnwcs5	Initial Creation - par 31618
*/
vars

begin 
	if self.mode = self.MODE_VIEW then
		return false;
	endif;
	
	if _rowFrom &gt; _table.fixedRows and _rowTo &gt; _table.fixedRows then
		// renumber rows in mouse-up event
		_table.tag := self.TAG_RENUMBER;
		
		return true;
	endif;
epilog

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_rowFrom" type="Integer"/>
        <Parameter name="_rowTo" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
