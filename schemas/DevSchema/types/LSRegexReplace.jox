    <JadeMethod name="create" id="44636fab-6442-4f50-bff7-f871a083bc16">
        <updating/>
        <source>create(_name, _pattern, _prefixText, _suffixText : String; _ignoreCase, _explicitCapture : Boolean) updating;
/*

Purpose:			Creates a LSRegexReplace (see if we can replace without using this)

Parameters:			_pattern:		String		The pattern for the regular expression
					_prefixText:	String		The prefix for replacing text
					_suffixText:	String		The suffix for replacing text

Return Value:		

Date		Who		Reason
01 November 2021	navpw1	Initial creation TFS: 52202

*/

begin	
	self.name := _name;
	self.pattern := _pattern;
	self.prefixText := _prefixText;
	self.suffixText := _suffixText;
	
	create self.myRegexPattern transient;
	self.myRegexPattern.compile(_pattern);
	self.myRegexPattern.setIgnoreCase(_ignoreCase);
	self.myRegexPattern.setExplicitCapture(_explicitCapture);
	
	
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_pattern" type="String"/>
        <Parameter name="_prefixText" type="String"/>
        <Parameter name="_suffixText" type="String"/>
        <Parameter name="_ignoreCase" type="Boolean"/>
        <Parameter name="_explicitCapture" type="Boolean"/>
    </JadeMethod>
</Class>
