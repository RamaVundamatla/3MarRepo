    <JadeMethod name="restoreSealControlValues" id="d9d7e9b2-3538-482d-b566-b53d1177e525">
        <source>restoreSealControlValues() protected;
// 30047 restore saved seal control values after form rebuild (are cloned controls so can get rebuilt and lose their values on change of commodity etc)
vars

	indx : Integer;
	obj : Object;
	control : Control;
	sealTypeName : String;
	sealValue : String;
	
begin

	foreach sealTypeName in self.sealTypes do
		indx := indx + 1;
		sealValue := self.sealValues[indx];
		foreach obj in self.allClonedControls do
			control := obj.Control;
			if control.name = sealTypeName then
				if control.isKindOf(CMUI_FieldTextBox) then
					control.CMUI_FieldTextBox.setValue(sealValue);
				endif;
			endif;
		endforeach;
	endforeach;

epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="saveDataToProxyTrackedItem" id="abf0b11b-aca4-4148-b7d1-4c2f53527e0b">
        <source>saveDataToProxyTrackedItem(_proxyTrackedItem : CM_TrackedItem input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16/07/2009	cnwdap1	Initial creation
05/03/2014	cnwdap1	PAR #33193 CCMS DPH 2285 Added Purchase Order and Service Order fields
25/11/2015	cnwma1  PAR #36943 Shipping Reference error during extract
4/10/2016   cnwns1  TFS 2755:Time saved incorrectly - multi-timezone issue
19/05/2022	jlika1	TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
20 may 2022	navgm20 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
29 Jun 2022 navsrk20 ChangeRequest 54022: MTN - EUP Shipping Line Refactor Wmast
16 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
21 Feb 2023 navtnr20	TFS CR 55648 Task 55663: UI - Contract Id
*/

vars
	bookingRef	: CM_BookingRef;
	packTSLocal : TimeStamp;
	packTSSystem : TimeStamp;
begin
	bookingRef := self.myTerminal.getBookingReference(null, txtBookingRef.getText.trimBlanks, null);
	
	// Main Details
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_BookingReference, bookingRef);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_BookingReferenceItem, cmbBRItem.getObject);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_CargoType, cmbType.getText);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Commodity, cmbCommodity.getText);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_CargoId, txtCargoID.getText);
	if _proxyTrackedItem.isKindOf(CM_Container)  then
		_proxyTrackedItem.setAttributeFromDisplayName(ETRow_IsoType, cmbISOType.getText);
	endif;
	//_proxyTrackedItem.setAttributeFromDisplayName(ETRow_TotalWeight, txtTotalWeight.getInteger);				// PAR #31155
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_TotalWeight, tblTotalWeight.getConvertedValue);			// PAR #31155
	
	// Voyage Details
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_ImexStatus, cmbImexStatus.getText);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_VoyageCode, cmbVoyageCode.listObject);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Operator, cmbOperatorCode.listObject);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Destination, cmbDestPort.listObject);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_DischargePort, cmbDischargePort.listObject);
	if app.myPassport.myTerminal.getConfig(ShowPortOfCallTranship).Boolean then
		_proxyTrackedItem.setAttributeFromDisplayName(ETRow_MyTranshipToPort, cmbTranshipPort.listObject);
	endif;
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_AllDischargePorts, lstOptionalPorts.allSelectedObjects);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Consignor, cmbConsignor.getObject);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Consignee, cmbConsignee.getObject);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Carrier, cmbCarrier.getObject);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Stevedore, cmbStevedore.getObject); //02.10.2020 cnwma1 TFS #50112
	// Dimensions (General Cargo only)
	//_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Length, txtLength.getInteger);						// PAR #31155
	//_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Width, txtWidth.getInteger);							// PAR #31155
	//_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Height, txtHeight.getInteger);						// PAR #31155
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Length, tblLength.getConvertedValue);					// PAR #31155
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Width, tblWidth.getConvertedValue);						// PAR #31155
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Height, tblHeight.getConvertedValue);					// PAR #31155
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_WidthString, txtWidthText.getString);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_HeightString, txtHeightText.getString);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_LengthString, txtLengthText.getString);
	if _proxyTrackedItem.isKindOf(CM_BreakBulkGeneric)  then
		//_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Diameter, tblDiameter.getConvertedValue);
		//_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Grade, txtGrade.getString);
		//_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Grammage, txtGrammage.getString.Decimal);
		//_proxyTrackedItem.setAttributeFromDisplayName(ETRow_RollingLength, tblRollingLength.getConvertedValue);
		_proxyTrackedItem.CM_BreakBulkGeneric.setDiameter(tblDiameter.getConvertedValue);			// ### TFS 54021 29June2022 NAVPW1
		_proxyTrackedItem.CM_BreakBulkGeneric.setGrade(txtGrade.getString);							// ### TFS 54021 29June2022 NAVPW1
		_proxyTrackedItem.CM_BreakBulkGeneric.setGrammage(txtGrammage.getString.Decimal);			// ### TFS 54021 29June2022 NAVPW1
		_proxyTrackedItem.CM_BreakBulkGeneric.setRollingLength(tblRollingLength.getConvertedValue);	// ### TFS 54021 29June2022 NAVPW1
	endif;
	//_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Quantity, txtQuantity.getInteger);
	self.setObjectFromQuantityValue( _proxyTrackedItem );	//04 Mar 2014	NDL	Par 33596
	//_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Volume, txtVolume.getInteger);						// PAR #31155
	//_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Density, txtDensity.getInteger);						// PAR #31155
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Volume, tblVolume.getConvertedValue);					// PAR #31155
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Density, tblDensity.getConvertedValue);					// PAR #31155
	
	// Cargo Details
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Location, txtLocation.getString);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Description, txtDescription.getString);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_AlternativeId, txtAlternativeId.getString);	// general cargo only
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Mark, txtMark.getString);					// general cargo only
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_MarkNumber, txtMarkNumber.getInteger);		// general cargo only
//20 Sep 2010	NDL	Par 25608 - Seals now use soft fields...
//	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_SealNum, txtOperatorSeal.getString);
//	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_SealNumVent, txtVentSeal.getString());
//	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_SealNumShippers, txtShippersSeal.getString);
//	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_SealNumCustoms, txtCustomsSeal.getString);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_ExportReleaseNumber, txtOpExRelNbr.getString);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_CustomExportEntryNumber, txtCustomsExDel.getString);
//	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Hazard, lstHazards.allSelectedObjects);

	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_IsDirectDelivery, chkDirDel.getBoolean);	//28 Jan 2013	NDL	CCMS 1299		Par 31102
	
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_SpecialStow, cmbSpecialStow.getObject);
	//_proxyTrackedItem.setAttributeFromDisplayName(ETRow_ShippingLine, cmbShippingLine.getObject);	//20 may 2022 navgm20 TFS 53204			//29.06.2022 navsrk20 TFS 54022
	_proxyTrackedItem.setMyShippingLine(cmbShippingLine.getObject.CM_ShippingLine);			//29.06.2022 navsrk20 TFS 54022	
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_CountryOfOrigin, cmbCtryOfOrigin.getObject);	// 16.08.2022 navak20 TFS 54441
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_InvoiceContractId,cmbInvContractID.getObject);//21.02.2023 navtnr20 TFS CR 55648 Task 55663
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_SpecialLift, cmbSpecialLift.getObject);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_AvailabilityGrade, cmbMTGrade.getObject);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_PreTripDate, chkPreTrip.getDate);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_OffsiteCleaned, chkCleaned.getBoolean);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Remarks, txtRemarks.getString);
	
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_ClientRef, txtClientRef.getString); //cnwrd1 par 23337 20.5.2010
	
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_PurchaseOrder, self.txtPurchaseOrder.getString());			// PAR #33193 
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_ServiceOrder, self.txtServiceOrder.getString());			// PAR #33193 
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_ShippingReference, self.txtShippingRef.getString());       //25/11/2015 cnwma1 PAR #36943

	// Over Dimension Details (full container only)
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_OverDimension, chkIsOverDim.value);
//	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_DimensionLengthFront, txtDimLenFront.text.Integer);
//	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_DimensionLengthBack, txtDimLenRear.text.Integer);
//	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_DimensionWidthLeft, txtDimWidthLeft.text.Integer);
//	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_DimensionWidthRight, txtDimWidthRight.text.Integer);
//	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_DimensionHeight, txtDimOverHeight.text.Integer);
	
	// Reefer Details
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_AllowableTimeOffPower, txtTimeOffPower.getDecimal);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_CarriageTempC, txtCarriageTemp.getInteger);
	//_proxyTrackedItem.setAttributeFromDisplayName(ETRow_TareWeight, txtTareWeight.getBoolean);				// PAR #31155
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_TareWeight, tblTareWeight.getConvertedValue);			// PAR #31155
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_CarbonDioxide, txtCO2Percent.getDecimal);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Oxygen, txtOxygenPercent.getDecimal);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_CurtainsIn, chkCurtainsIn.getBoolean);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Humidity, txtHumidity.getDecimal);
	//_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Ventilation, txtVentilation.getDecimal);				// PAR #31155
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Ventilation, tblVentilation.getConvertedValue);			// PAR #31155
	packTSLocal.cnEcSetDateAndTime(txtPackDate.getDate(),txtPackTime.getTime());				//TFS 2755
	packTSSystem := self.localToSystemTime(packTSLocal);										//TFS 2755
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_PackDate, packTSSystem.date());			//TFS 2755
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_PackTempC, txtPackTemp.getInteger);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_PackTime, packTSSystem.time());			//TFS 2755
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_CoolingType, cmbCoolingType.getString);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_VoltageType, cmbVoltageType.getString);
	
	// Additional Details
	//_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Stops, lstStops.allSelectedObjects);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_ToDoTasks, lstToDoTasks.allSelectedObjects);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_FreightForwarder, cmbFreightFwdr.getObject);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_CustomsAgent, cmbCustomsAgent.getObject);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_HouseBOL, txtHouseBOL.getString);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_ConsignorVoyage, txtConsignVoy.getObject);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_EirNumber, txtEquipXchg.getString);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_PurchaseOrder, txtPurchaseOrder.getString);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_TransportMode, app.transModeToCode(cmbTransportMode.getString));
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_MySubTerminal, cmbSubTerminal.getObject);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_BusinessUnit, cmbBusUnit.getObject);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Attachments, chkHasAttachment.getBoolean);
	
	// ### TFS 57812 (58439) 15Jun2023 NAVPW1
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_Itemised, chkItemised.getBoolean);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_SecondaryBarcodeId, txtSecondaryBarcodeId.getString);
	_proxyTrackedItem.setAttributeFromDisplayName(ETRow_SortingMethod, cmbSortingMethod.getObject);
	// ### TFS 57812 (58439) 15Jun2023 NAVPW1
epilog

end;</source>
        <Parameter name="_proxyTrackedItem" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
