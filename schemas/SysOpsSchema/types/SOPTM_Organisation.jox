    <JadeMethod name="doAddNewEmail" id="92ba65ed-5b22-47c8-a7f3-56f1847f1f75">
        <source>doAddNewEmail(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 July 2015	cnwndl1	Initial creation	Par 36588

*/

vars

	errObj					: CM_Error;
	ignoreWarnings,rtnValue	: Boolean;
	newEmailAddress,
	proxyEmailAddress		: CM_EmailAddress2;
	lEmailAddress, lTitle	: String; 
	theForm					: SOP_TableMaintForm;
	objectArray				: CM_ObjectArray;
	
begin

	theForm := self.myForm; 

	lTitle := theForm.txtEmailName.getControl(2).text.trimWhiteSpace;
	lEmailAddress := theForm.txtName.getControl(2).text.trimWhiteSpace;

 	create proxyEmailAddress transient;
	
	proxyEmailAddress.setProxyForEmailAddress(lTitle, lEmailAddress, null);

	app.myTrxCA.trxCreateEmailAddress2(proxyEmailAddress, newEmailAddress,app.myPassport);
	
	if newEmailAddress &lt;&gt; null then
		create objectArray transient;
		theForm.mulSelect2.getSelected(objectArray);
		objectArray.add(newEmailAddress);
		theForm.mulSelect2.setAvailable(app.myRoot.allEmailAddressesByAddress, true);
		theForm.mulSelect2.setSelected(objectArray);
		
		theForm.txtEmailName.getControl(2).text := null;
		theForm.txtName.getControl(2).text := null;
	endif;

	return app.myPassport.trxCompletedOK;
	
epilog

	delete objectArray;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="ad3d32b8-66f0-4b15-884e-89e42fe7bbc8">
