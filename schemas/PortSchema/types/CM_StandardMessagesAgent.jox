<Class name="CM_StandardMessagesAgent" id="f211b56d-3458-4f31-9580-22a65fe03036">
    <superclass name="CM_Agent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <Constant name="MESSAGE_KIND_AGGATEWAY" id="3a15526a-f5aa-444c-ba43-6e0e4975aab8">
        <source>'AGGATEWAY'</source>
        <type name="String"/>
    </Constant>
    <JadeMethod name="handleStandardMessage" id="7ee2f3ed-f752-48db-9be3-ecd930c60b3c">
        <source>handleStandardMessage(_messageKind : String; _requestType : String ; _version : Real; _requestMessage : String; _resp : CMIF_StandardMessageProcResp io; _terminal : CM_Terminal);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 July 2025	navra1	Initial creation for //navra1 - MTN-34782 - 15th July 2025

*/

vars
	agMessageAgent: CM_AgGatewayMessageAgent;
begin
	if _messageKind.toUpper() = CM_StandardMessagesAgent.MESSAGE_KIND_AGGATEWAY then
		if _version = 5 then
			create agMessageAgent transient;		
		
			agMessageAgent.processAgMessage_V5(_requestType, _requestMessage,  _resp, _terminal);						
		else
			_resp.isSuccess := false;
			_resp.failureReason := "Unsupported version specified for " &amp; _messageKind;		
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Wrong version sent - " &amp; version.String, LogERROR);
		endif;
	else
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Wrong message kind - " &amp; _messageKind, LogERROR);
	//elseif _messageKind.toUpper() = CM_StandardMessagesAgent.MESSAGE_KIND_NEW_TYPE_MESSAGE then        &lt;------- for extension
	endif;
	
epilog
	delete agMessageAgent;
	
end;</source>
        <Parameter name="_messageKind" type="String"/>
        <Parameter name="_requestType" type="String"/>
        <Parameter name="_version" type="Real"/>
        <Parameter name="_requestMessage" type="String"/>
        <Parameter name="_resp" type="CMIF_StandardMessageProcResp" usage="io"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
</Class>
