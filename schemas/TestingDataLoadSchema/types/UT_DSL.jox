    <JadeMethod name="updateBookingType" id="1b47c6c7-573b-4983-a04c-b8863be6cc9a">
        <source>updateBookingType(_booking: CM_BookingRef; _stock: Boolean);
//01 September 2008	cnwdw1	 
//
vars
	pxyBooking: CM_BookingRef;
begin
	pxyBooking := app.createUpdateProxy(_booking).CM_BookingRef;
	pxyBooking.setIsStockBooking(_stock);
	
	// 29/05/2014 - cnwmh5
	if self.opts.includesKey("Voyage") then
		pxyBooking.setMyVoyage(self.opts.obj("Voyage").CM_Voyage);
	endif;
	
	// 29/05/2014 - cnwmh5
	if self.opts.includesKey("DischargePort") then
		pxyBooking.setPropertyValue("dischargePort", self.opts.str("DischargePort"));
	endif;
	
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateBookingBulkRel(pxyBooking, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog
	delete pxyBooking;
end;</source>
        <Parameter name="_booking" type="CM_BookingRef"/>
        <Parameter name="_stock" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateBoom" id="6d57d38b-cca9-4ba7-b25f-1ea9544155da">
        <source>updateBoom(_boom : CM_Boom; _description : String);

/*

Purpose:		Update the boom

Date			Who		Reason
21/03/2014		cnwmh5	Initial creation

*/

vars

	pxyBoom						: CM_Boom;
	
	loadState					: Boolean;

begin

	app.cmsBeginLoad(loadState);
	pxyBoom := _boom.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
	
	pxyBoom.setProxy(_boom.code, _description, _boom.ipAddress, _boom.portNumber, _boom.myTerminal,
						pxyBoom.getDisplayValueForChannel,	//_channel : String;	//14 Feb 2019	NDL	TFS 43403
						pxyBoom.userCode,	//_userCode : String;	//14 Feb 2019	NDL	TFS 43403
						pxyBoom.password	//_password : String	//14 Feb 2019
						);

	app.myTrxUA.trxUpdateBoom(pxyBoom, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	app.cmsEndLoad(loadState);
	
	delete pxyBoom;

end;</source>
        <Parameter name="_boom" type="CM_Boom"/>
        <Parameter name="_description" type="String"/>
    </JadeMethod>
