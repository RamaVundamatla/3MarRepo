    <JadeMethod name="isWeighBridgeWeighable" id="0985422e-47a4-4088-9147-ac975265d2fa">
        <source>isWeighBridgeWeighable(_objs: ObjectArray input; _errMess : String output): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2014	cnwndl1	Initial creation	Par 33268
08 Jan 2018	NDL	TFS 36437
*/

vars

	tiSet : CM_TISet;

begin

	if self.myTerminal= null or self.myTerminal.allWeighBridges.isEmpty then
		return false;
	endif;

	create tiSet transient;
	self.getAllOnboardTIs( tiSet );
	if tiSet.size &gt; 1 then
		return false;
	endif;
	
	if self.myPrimaryActualLocation &lt;&gt; null and self.myPrimaryActualLocation.isVehicle then	//25 Mar 2015, NDL Par 35912
	//if self.myPrimaryActualLocation.isVehicle then
		if _objs &lt;&gt; null then
				_objs.addExclusive( self.myPrimaryActualLocation.CM_VehicleController.vehicle );
				_objs.addExclusive( self );
				if not tiSet.isEmpty then
					_objs.addExclusive( tiSet.first );
				endif;
			endif;
		return true;
	endif;
	
	return false;

epilog

	delete tiSet;

end;</source>
        <Parameter name="_objs" type="ObjectArray" usage="input"/>
        <Parameter name="_errMess" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="offHireDate" id="35a0ef37-7f9a-4237-9bb7-7707df2e0638">
        <methodInvocation>mapping</methodInvocation>
        <source>offHireDate(set: Boolean; _value: Date io) mapping;
//24 November 2009	cnwml2
/**************************************************************************************
***** Changes
Date				Name		TFS#		Description
=======================================================================================
21/09/2018			jlgka1		40200		Add checking if myTiMaster is not null 
											before returning the value.
***************************************************************************************/
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	else
		if self.myTiMaster &lt;&gt; null then
			_value := self.myTiMaster.CM_TIMasterTILC.offHireDate;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Date" usage="io"/>
    </JadeMethod>
