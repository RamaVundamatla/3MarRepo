    <JadeMethod name="buildDataTable" id="8d07f4f3-d07d-4331-b13c-80fc28ad1868">
        <updating/>
        <source>buildDataTable(headings:StringArray; columnWidths:IntegerArray; userColl:Collection; update:Boolean; showHow:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		13 August 1999 by cnwdad1
//
// Purpose:		Sets up the data table column headings and widths, and also the
//				table's listCollection.
//
// Parameters:	headings (StringArray) - An array of the column headings.
//				columnWidths(IntegerArray) - An array of values representing the
//					percentage of the data table the column should occupy.
//				userColl (Collection) - The collection to be used for the listCollection.
//				update (Boolean) - Indicates whether the data table should reflect
//					any updates to the listCollection.
//				showHow (Integer) - Indicates the order of the listCollection (0 =
//					normal, 1 = reversed).
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	table		: CnEcDataTable;
	heading		: String;
	colCount	: Integer;
	colWidth	: Integer;

begin
	table	:=	self.myDataTable;

	if (headings &lt;&gt; null) then
		table.columns	:=	headings.size() + 1;
		table.rows		:=	1;
		colCount		:=	1;		// Column 1 is already used, so we need to start incrementing from 1 onwards.

		foreach heading in headings do
			colCount	:=	colCount + 1;
			table.setCellText(1, colCount, heading);
		endforeach;

		table.sizeColumnArrays();
		table.rebuildColumnHeadingArray();
		self.listCollection(userColl, update, showHow);
	endif;

	self.dataColumnWidths.clear();

	if (columnWidths &lt;&gt; null) then
		columnWidths.copy(self.dataColumnWidths);
	endif;

	self.resizeColumnWidths();
end;</source>
        <Parameter name="headings" type="StringArray"/>
        <Parameter name="columnWidths" type="IntegerArray"/>
        <Parameter name="userColl" type="Collection"/>
        <Parameter name="update" type="Boolean"/>
        <Parameter name="showHow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="buildDisplayTable" id="de678727-7653-4aac-b737-2bc1bb3373dc">
        <source>buildDisplayTable(rowValues:HugeStringArray; columnWidths:IntegerArray);
// --------------------------------------------------------------------------------
// Created:		15 August 1999 by cnwdad1
//
// Purpose:		Sets up the display table columns and widths.
//
// Parameters:	rowValues (HugeStringArray) - An array of (tab-delimited) string
//				values for the table rows.
//				columnWidths (StringArray) - An array of integer values representing
//				the percent of the table's width that the column should occupy.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowIndex	: Integer;
	maxRows		: Integer;
	rowString	: String;
	table		: CnEcDisplayTable;

begin
	if (columnWidths = null) or (columnWidths.size() = 0) then
		return;
	endif;

	table			:=	self.myDisplayTable;
	table.rows		:=	0;
	table.columns	:=	columnWidths.size();
	maxRows			:=	rowValues.size();
	rowIndex		:=	1;

	while (rowIndex &lt;= maxRows) do
		rowString	:=	null;

		if (rowValues[rowIndex] = null) then
			rowString	:=	'';
		else
			rowString	:=	rowValues[rowIndex];
		endif;

		table.addItem(rowString);
		rowIndex	:=	rowIndex + 1;
	endwhile;

	self.displayColumnWidths.clear();

	if (columnWidths &lt;&gt; null) then
		columnWidths.copy(self.displayColumnWidths);
	endif;

	self.resizeColumnWidths();
end;</source>
        <Parameter name="rowValues" type="HugeStringArray"/>
        <Parameter name="columnWidths" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="clearDisplay" id="a9490440-bb68-4c08-b3f6-d77c500f0e49">
        <source>clearDisplay();
// -----------------------------------------------------------------------------
// Created:		02 January 2002 by cnwdad1
//
// Purpose:		Clears the display details.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.myDisplayTable.rows	:=	0;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEc_MouseUp" id="deb28dbd-2552-4583-8732-a09788bcf8b7">
        <updating/>
        <source>cnEc_MouseUp(cntrl:Control input; button:Integer; shift:Integer; x:Real; y:Real) protected, updating;
// --------------------------------------------------------------------------------
// Created:		12 August 1999 by cnwdad1
//
// Purpose:		Refer to the 'Window::cnEc_MouseUp) method.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

begin
	self.dataToDisplayRatio	:=	((self.myVerticalSplitter.left / self.width) * 100).Integer;
	self.resizeTables();

	inheritMethod(cntrl, button, shift, x, y);
end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="dataToDisplayRatio" id="b0a27891-01f6-4ae3-ae08-efefc3994f2f">
        <methodInvocation>mapping</methodInvocation>
        <source>dataToDisplayRatio(set: Boolean; _value: Integer io) protected, mapping;
// --------------------------------------------------------------------------------
// Created:		12 August 1999 by cnwdad1
//
// Purpose:		Mapping method to validate the percent value of this property.
//
// Parameters:	As per standard mapping method signature.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

begin
	if (set) then
		if (_value &lt; 1) or (_value &gt; 100) then
			_value	:=	50;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
