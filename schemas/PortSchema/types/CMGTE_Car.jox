    <JadeMethod name="setForCreate" id="22b33c01-b0a6-49c7-9b17-dbc4f05084b3">
        <updating/>
        <source>setForCreate(_pxyGTEEntity: CMGTE_Receival; _realVVR: CM_VehicleVisitRecord input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16/09/2009	cnwdap1	Initial creation
12/09/2013	cnwdap1	PAR #32216 New Car attributes
*/
vars
	pxyCar		: CMGTE_Car;			// PAR #32215

begin
	inheritMethod(_pxyGTEEntity, _realVVR);
	
	pxyCar := _pxyGTEEntity.CMGTE_Car;									// PAR #32215
	//self.hasRadio			:= _pxyGTEEntity.CMGTE_Car.hasRadio;		// PAR #32215
	//self.selfPropelled	:= _pxyGTEEntity.CMGTE_Car.selfPropelled;	// PAR #32215
	self.hasRadio			:= pxyCar.hasRadio;							// PAR #32215
	self.selfPropelled		:= pxyCar.selfPropelled;					// PAR #32215
	
	self.make				:= pxyCar.make;								// PAR #32215
	self.model				:= pxyCar.model;							// PAR #32215
	self.carType			:= pxyCar.carType;							// PAR #32215
	self.year				:= pxyCar.year;								// PAR #32215
	self.trackingNumber1	:= pxyCar.trackingNumber1;					// PAR #32215
	self.trackingNumber2	:= pxyCar.trackingNumber2;					// PAR #32215
	self.docsReceived		:= pxyCar.docsReceived;						// PAR #32215
	self.docsSent			:= pxyCar.docsSent;							// PAR #32215
	self.docsCleared		:= pxyCar.docsCleared;						// PAR #32215
	self.docsReturned		:= pxyCar.docsReturned;						// PAR #32215
	self.nbrDoors			:= pxyCar.nbrDoors;							// PAR #32215
	self.isNew				:= pxyCar.isNew;							// PAR #32215
epilog

end;</source>
        <Parameter name="_pxyGTEEntity" type="CMGTE_Receival"/>
        <Parameter name="_realVVR" type="CM_VehicleVisitRecord" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="035cde80-9640-4186-b804-7cae0a0223c0">
        <updating/>
        <source>setForUpdate(_pxyGTEEntity: CMGTE_Receival; _realVVR: CM_VehicleVisitRecord) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16/09/2009	cnwdap1	Initial creation
12/09/2013	cnwdap1	PAR #32215 New Car attributes
*/
vars
	pxyCar		: CMGTE_Car;			// PAR #32215

begin
	inheritMethod(_pxyGTEEntity, _realVVR);
	
	pxyCar := _pxyGTEEntity.CMGTE_Car;									// PAR #32215
	//self.hasRadio			:= _pxyGTEEntity.CMGTE_Car.hasRadio;		// PAR #32215
	//self.selfPropelled	:= _pxyGTEEntity.CMGTE_Car.selfPropelled;	// PAR #32215
	self.hasRadio			:= pxyCar.hasRadio;							// PAR #32215
	self.selfPropelled		:= pxyCar.selfPropelled;					// PAR #32215
	
	self.make				:= pxyCar.make;								// PAR #32215
	self.model				:= pxyCar.model;							// PAR #32215
	self.carType			:= pxyCar.carType;							// PAR #32215
	self.year				:= pxyCar.year;								// PAR #32215
	self.trackingNumber1	:= pxyCar.trackingNumber1;					// PAR #32215
	self.trackingNumber2	:= pxyCar.trackingNumber2;					// PAR #32215
	self.docsReceived		:= pxyCar.docsReceived;						// PAR #32215
	self.docsSent			:= pxyCar.docsSent;							// PAR #32215
	self.docsCleared		:= pxyCar.docsCleared;						// PAR #32215
	self.docsReturned		:= pxyCar.docsReturned;						// PAR #32215
	self.nbrDoors			:= pxyCar.nbrDoors;							// PAR #32215
	self.isNew				:= pxyCar.isNew;							// PAR #32215
epilog

end;</source>
        <Parameter name="_pxyGTEEntity" type="CMGTE_Receival"/>
        <Parameter name="_realVVR" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="setPXYFromController" id="e0e54b0e-329b-4198-aa05-d38e4465ad3e">
        <updating/>
        <source>setPXYFromController(_flexi: CMIF_FlexiGateController) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16/09/2009	cnwdap1	Initial creation
12/09/2013	cnwdap1	PAR #32215 New Car attributes
*/
vars

begin
	inheritMethod(_flexi);
	
	self.hasRadio		:= _flexi.hasRadio;
	self.selfPropelled	:= _flexi.selfPropelled;
	
	self.colour				:= _flexi.colour;			// PAR #32215
	self.make				:= _flexi.make;				// PAR #32215
	self.model				:= _flexi.model;			// PAR #32215
	self.carType			:= _flexi.carType;			// PAR #32215
	self.year				:= _flexi.year;				// PAR #32215
	self.trackingNumber1	:= _flexi.trackingNumber1;	// PAR #32215
	self.trackingNumber2	:= _flexi.trackingNumber2;	// PAR #32215
	self.docsReceived		:= _flexi.docsReceived;		// PAR #32215
	self.docsSent			:= _flexi.docsSent;			// PAR #32215
	self.docsCleared		:= _flexi.docsCleared;		// PAR #32215
	self.docsReturned		:= _flexi.docsReturned;		// PAR #32215
	self.nbrDoors			:= _flexi.nbrDoors;			// PAR #32215
	self.isNew				:= _flexi.isNew;			// PAR #32215
epilog

end;</source>
        <Parameter name="_flexi" type="CMIF_FlexiGateController"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromTI" id="82a63de7-969b-47e1-bcf8-c318751f4016">
        <updating/>
        <source>setPxyFromTI(_ti: CM_Car) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/03/2010	cnwjk3	PAR 22502
12/09/2013	cnwdap1	PAR #32215 New Car attributes
*/
vars

begin
	inheritMethod(_ti);
	if _ti.hasRadio = CM_Car.HasRadio then
		self.hasRadio := true;
	else
		self.hasRadio := false;
	endif;
	
	self.selfPropelled := _ti.selfPropelled;
	
	self.make				:= _ti.make;				// PAR #32216
	self.model				:= _ti.model;				// PAR #32216
	self.carType			:= _ti.carType;				// PAR #32216
	self.year				:= _ti.year;				// PAR #32216
	self.trackingNumber1	:= _ti.trackingNumber1;		// PAR #32216
	self.trackingNumber2	:= _ti.trackingNumber2;		// PAR #32216
	self.docsReceived		:= _ti.docsReceived;		// PAR #32216
	self.docsSent			:= _ti.docsSent;			// PAR #32216
	self.docsCleared		:= _ti.docsCleared;			// PAR #32216
	self.docsReturned		:= _ti.docsReturned;		// PAR #32216
	self.nbrDoors			:= _ti.nbrDoors;			// PAR #32216
	self.isNew				:= _ti.isNew;				// PAR #32216
	self.jobType:=self.JobType_GeneralIN;
epilog

end;</source>
        <Parameter name="_ti" type="CM_Car"/>
    </JadeMethod>
</Class>
