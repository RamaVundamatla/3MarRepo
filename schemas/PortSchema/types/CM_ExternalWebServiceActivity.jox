    <JadeMethod name="getAPIEndpoint" id="18f379aa-2482-4c01-a7d1-9fb18189e71a">
        <source>getAPIEndpoint() : CM_Endpoint;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 July 2023	jlier1	Initial creation 58840

*/

vars
	pos : Integer;
	endpointDesc : String;
begin
	if self.myExtWebserviceDef = null then
		return null;
	endif;
	pos:= self.description.pos(Space,1);
	if pos &gt; 1 then
		endpointDesc:=self.description[pos+1:end];
	else
		return null;
	endif;
	return self.myExtWebserviceDef.allEndpoints[endpointDesc];
epilog

end;</source>
        <ReturnType type="CM_Endpoint"/>
    </JadeMethod>
