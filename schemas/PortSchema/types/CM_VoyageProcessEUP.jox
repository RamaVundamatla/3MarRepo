    <JadeMethod name="getNextValidStatuses" id="31da42bd-b292-4035-af32-280c7a8202e1">
        <source>getNextValidStatuses(_voyage: CM_Voyage; _nextStatuses: CM_VoyageStatusByPriority input; _includeAll: Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
16 August 2022		jlizm1	Initial creation TFS 54298 EUP - Simplified Voyage Work Order Process

*/

vars

	status, nextStatus 	: CM_VoyageStatus;
	currentStatus		: Integer;

begin
	
	if _includeAll then
		self.allStatuses.copy(_nextStatuses);
		return;
	endif;

	if _voyage &lt;&gt; null then
		currentStatus := _voyage.status;
	endif;
	
	if currentStatus = null then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_EUP_VoyReq]);
	else
		if app.myRoot.allVoyageStatuses[currentStatus] &lt;&gt; null then
			_nextStatuses.add(app.myRoot.allVoyageStatuses[currentStatus]);
		endif;
	endif;
	
	if currentStatus = Voyage_Status_EUP_VoyReq then
		_nextStatuses.add(app.myRoot.allVoyageStatuses[Voyage_Status_EUP_VoyReqSubm]);
		_nextStatuses.add(app.myRoot.allVoyageStatuses[Voyage_Status_EUP_VoyReqRej]);
		_nextStatuses.add(app.myRoot.allVoyageStatuses[Voyage_Status_EUP_Pending]);
		_nextStatuses.add(app.myRoot.allVoyageStatuses[Voyage_Status_EUP_Cancelled]);
	
	elseif currentStatus = Voyage_Status_EUP_VoyReqSubm then
		_nextStatuses.add(app.myRoot.allVoyageStatuses[Voyage_Status_EUP_VoyReqRej]);
		_nextStatuses.add(app.myRoot.allVoyageStatuses[Voyage_Status_EUP_Pending]);
		_nextStatuses.add(app.myRoot.allVoyageStatuses[Voyage_Status_EUP_Cancelled]);
	
	elseif currentStatus = Voyage_Status_EUP_VoyReqRej then
		_nextStatuses.add(app.myRoot.allVoyageStatuses[Voyage_Status_EUP_Cancelled]);
	
	elseif currentStatus &gt;= Voyage_Status_EUP_Pending then
		if currentStatus &lt;&gt; Voyage_Status_EUP_Pending then
			_nextStatuses.add(app.myRoot.allVoyageStatuses[Voyage_Status_EUP_Pending]);
		endif;
		if currentStatus &lt;&gt; Voyage_Status_EUP_Arrived then
			_nextStatuses.add(app.myRoot.allVoyageStatuses[Voyage_Status_EUP_Arrived]);
		endif;
		if currentStatus &lt;&gt; Voyage_Status_EUP_Loading then
			_nextStatuses.add(app.myRoot.allVoyageStatuses[Voyage_Status_EUP_Loading]);
		endif;
		if currentStatus &lt;&gt; Voyage_Status_EUP_Complete then
			_nextStatuses.add(app.myRoot.allVoyageStatuses[Voyage_Status_EUP_Complete]);
		endif;
		if currentStatus &lt;&gt; Voyage_Status_EUP_Closed then
			_nextStatuses.add(app.myRoot.allVoyageStatuses[Voyage_Status_EUP_Closed]);
		endif;
		if currentStatus &lt;&gt; Voyage_Status_EUP_Departed then
			_nextStatuses.add(app.myRoot.allVoyageStatuses[Voyage_Status_EUP_Departed]);
		endif;
		if currentStatus &lt;&gt; Voyage_Status_EUP_Cancelled then
			_nextStatuses.add(app.myRoot.allVoyageStatuses[Voyage_Status_EUP_Cancelled]);
		endif;
		if currentStatus &lt;&gt; Voyage_Status_EUP_Archived then
			_nextStatuses.add(app.myRoot.allVoyageStatuses[Voyage_Status_EUP_Archived]);
		endif;
		
	endif;
	
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_nextStatuses" type="CM_VoyageStatusByPriority" usage="input"/>
        <Parameter name="_includeAll" type="Boolean"/>
    </JadeMethod>
