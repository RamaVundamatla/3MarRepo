    <JadeMethod name="xGCDCStatusBarStep6" id="e4effc96-2e7b-4090-9575-d3e11275f1ed">
        <updating/>
        <source>xGCDCStatusBarStep6() updating;

/*

Purpose:		Colour code load jobs and check that the status bar is correct	

Date			Who		Reason
15/05/2013		cnwmh5	Initial creation

*/
constants

	ContainerPartialId					: String = 'UTGCDC1';

vars

	port								: CM_Port;
	cargo								: CM_TrackedItem;
	realAlloc							: CM_VoyageAllocation;

	itemsToDischarge					: StringArray;
	roroLCsHold							: CM_LCArray;
	altRoroLCs							: CM_LCArray;
	
	index								: Integer;
	isoTypeStr							: String;
	
begin

	app.writeLog("STEP 6", LogINFO);
	app.writeLog("Color Coding Load slots and creating cargo to load.  Please wait...", LogINFO);
	
	port := app.myRoot.allPorts["NZAKL"];
	self.assertNotNull(port);
	
	
	// create cargo to load
	self.tisToPlanArray.clear();
	index := 1;
	isoTypeStr := "U20G";
	while index &lt;= 2 do
		self.cargoCountId := self.cargoCountId + 1;
		cargo := self.addContainerAtLocnDisch(ContainerPartialId &amp; self.cargoCountId.padLeadingWith("0", 4), isoTypeStr, "MT", TI_IMEX_STATUS_EXPORT, self.myBlockStack.myLocationsController, port, self.myVoyage);
		self.assertNotNull(cargo);
		self.deleteStops(cargo);
		self.tisToPlanArray.add(cargo);
		isoTypeStr := "U40G";
		index := index + 1;
	endwhile;
	
	// create voyage allocations
	create roroLCsHold transient;
	create altRoroLCs transient;
	self.roroLCs.clear();
	self.getJobROROControllerByID(self.myVoyage.code, self.myDeck.code, null, "D4211082", self.roroLCs, true, 1); 
	self.getJobROROControllerByID(self.myVoyage.code, self.myDeck.code, null, "D4231082", self.roroLCs, true, 1); 
	realAlloc := self.addVoyageAllocation(self.myVoyage, port.code, "U20G", "", TI_CargoType_Container, false, false);
	self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);
	self.roroLCs.copy(roroLCsHold);
	
	
	self.roroLCs.clear();
	self.getJobROROControllerByID(self.myVoyage.code, self.myDeck.code, null, "D4211084", self.roroLCs, true, 1); 
	self.getJobROROControllerByID(self.myVoyage.code, self.myDeck.code, null, "D4210684", self.roroLCs, true, 1); 
	realAlloc := self.addVoyageAllocation(self.myVoyage, port.code, "U40G", "", TI_CargoType_Container, false, false);
	self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);
	self.roroLCs.copy(roroLCsHold);
	
	// save the details so jobs can be created
	self.roroLCs.clear();
	roroLCsHold.copy(roroLCs);

	app.writeLog("Checking Status Bar (ACTUAL) details are correct.  Please wait...", LogINFO);
	self.locationArray.clear();
	self.statusArray.clear();
	self.locationArray.add("D4339O");
	self.statusArray.add("D4339O D4339O | 2 x CONT NZLYT  U20G | UTGCDC10020, UTGCDC10021");
	self.locationArray.add("D4341O");
	self.statusArray.add("D4341O D4341O | Aft: D4340O | 1 x CONT NZLYT  U40G | UTGCDC10033");
	self.locationArray.add("D4270682");
	self.statusArray.add("D4270682 D4270682 |  Fwd: D4250682 | 4 x CONT NZLYT  U20G | UTGCDC10010, UTGCDC10011, UTGCDC10012, UTGCDC10013");
	self.locationArray.add("D4270282");
	self.statusArray.add("D4270282 D4270282 |  Fwd: D4250282 | 2 x CONT NZLYT  U20G | UTGCDC10002, UTGCDC10003");
	self.locationArray.add("D4250282");
	self.statusArray.add("D4250282 D4250282 | Aft: D4270282 | 1 x CONT NZLYT  U20G | UTGCDC10001");
	self.locationArray.add("D4250382");
	self.statusArray.add("D4250382 D4250382 | Aft: D4270382 | 2 x CONT NZLYT  U20G| 1 x CONT NZLYT  U40G | UTGCDC10008, UTGCDC10024, UTGCDC10009");
