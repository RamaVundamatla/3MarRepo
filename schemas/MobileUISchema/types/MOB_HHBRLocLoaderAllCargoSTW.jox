    <JadeMethod name="validateLoad" id="ef356505-ffac-4dab-afc9-dc0c509d19b1">
        <source>validateLoad( _ti : CM_TrackedItem; _reserveDetail : CM_ReserveDetail ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 November 2015	cnwndl1	Initial creation	Par 37153

*/

vars
	quantityLoading: Integer;
	weightLoading : Decimal[16,4];
	quantityLoaded : Integer;
	weightLoaded : Decimal[16,4];
	maxQuantityToLoad : Integer;
	maxWeightToLoad : Decimal[16,4];
	row: Integer;
	msg : String;
	reserveDetail : CM_ReserveDetail;
begin

	if _ti.canSplitTotalQuantity then
		if _ti.isBulkByQuantity then
			quantityLoading := _ti.totalQuantity;
		elseif  _ti.isBulkByWeight or _ti.isBulkByVolume then
			weightLoading := _ti.totalWeight;
		endif;
	else
		quantityLoading := 1;
	endif;
	
	quantityLoaded := self.getQuantityLoaded( weightLoaded );	//already on the truck
	maxQuantityToLoad := self.getQuantityToLoad( maxWeightToLoad );
	
	//09 Dec 2015	NDL	TFS752-12
	if _reserveDetail &lt;&gt; null then
		msg := _reserveDetail.validateWeightQuantityAdd(	quantityLoading, weightLoading, false ).trimBlanks;
		if msg &lt;&gt; null then
			self.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only, false);
			return false;
		endif;
	endif;
	
	
	
	//Relative to the WLE where potentailly multiple trucks are working one bulk release,
	// should be able to load more than the amount on the WLE on the basis that the checks above
	// will have determined that there was enough left on the reserve details of the bulk release.
	if quantityLoading &gt; 0 and maxQuantityToLoad &gt; 0 then
		if quantityLoaded &gt;= maxQuantityToLoad then
			//Already on the truck
			msg := app.getErrorString(Fully_loaded) &amp; CrLf &amp; app.getErrorString(SHP_Do_You_Want_To_Continue);
			if self.msgBox(msg, app.getErrorString(Continue), MsgBox_Yes_No, false) &lt;&gt; MsgBox_Return_Yes then
				return false;
			endif;
		elseif (quantityLoaded + quantityLoading) &gt; maxQuantityToLoad then
			if quantityLoading &gt; 0 then
				msg := app.getErrorString3(Addin_truck_will_excee_totla_w, quantityLoading.String, quantityLoaded.String, maxQuantityToLoad.String );
			else
				msg := app.getErrorString2(Addin_will_excee_total_work_li, quantityLoading.String, maxQuantityToLoad.String );
			endif;
			if self.msgBox(app.getErrorString(Fully_loaded), app.getErrorString(Continue), MsgBox_Yes_No, false) &lt;&gt; MsgBox_Return_Yes then
				return false;
			endif;
		endif;
		
	elseif weightLoading &gt; 0 and  maxWeightToLoad &gt; 0 then
		if weightLoaded &gt;= maxWeightToLoad then
			//Already on the truck
			msg := app.getErrorString(Fully_loaded);
			if self.msgBox(msg, app.getErrorString(Continue), MsgBox_Yes_No, false) &lt;&gt; MsgBox_Return_Yes then
				return false;
			endif;
		elseif (weightLoaded + weightLoading) &gt; maxWeightToLoad then
			if weightLoading &gt; 0 then
				msg := app.getErrorString3(Addin_truck_will_excee_totla_w, weightLoading.String, weightLoaded.String, maxWeightToLoad.String );
			else
				msg := app.getErrorString2(Addin_will_excee_total_work_li, weightLoading.String, maxWeightToLoad.String );
			endif;
			if self.msgBox(app.getErrorString(Fully_loaded), app.getErrorString(Continue), MsgBox_Yes_No, false) &lt;&gt; MsgBox_Return_Yes then
				return false;
			endif;
		endif;
	
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
