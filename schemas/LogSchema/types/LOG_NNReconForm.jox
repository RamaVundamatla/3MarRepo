    <JadeMethod name="initTblLocation" id="91d14dee-91b4-44f4-9d64-50dcfc4c81d5">
        <source>initTblLocation();
// ---------------------------------------------------------------------------
// Created:     04 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	entTableDef		: EntTableDef;
begin
	self.tblLocations.setTerminologyRelevant(app.myRoot.allCargoTypesById[TI_CargoType_Log], self.myTerminal);

	entTableDef := app.myController.getEntTableDef(ETDef_LocationsUsed);
	
	self.tblLocations.setTblDataEntRowsFromDef(entTableDef);
	self.tblLocations.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblLocations.autoSize := Table.AutoSize_Column;
	tblLocations.userInputEnabled := true;
	tblLocations.accessColumn(5).alignment := Table.Alignment_Right_Middle;	
	tblLocations.accessColumn(6).alignment := Table.Alignment_Right_Middle;
end;</source>
