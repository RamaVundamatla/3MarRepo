    <JadeMethod name="doAcceptSpecificTask" id="1fc2bdc3-01db-4010-aee5-26b540dd3582">
        <updating/>
        <source>doAcceptSpecificTask(_queueEntry : Object input) : Boolean updating, protected;

/*

Purpose:			Attempt to accept the passed in queue entruy's next task


Return Value:		True if successful


Date		Who		Reason
14 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	errorStr		: String;
	
begin
	if not app.myRTGuiAgent.acceptSpecificTask(_queueEntry, self, errorStr, self.aState) then
		self.showMessage(errorStr, true);
		return false;
	endif;
	
	self.updateFromState();
	return true;
	
	
epilog

end;</source>
