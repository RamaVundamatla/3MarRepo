    <JadeMethod name="setOrientation" id="d4675a72-e9d9-49fb-a61e-1750b025e9ac">
        <updating/>
        <source>setOrientation(_taViewPosition	: CM_TerminalAreaViewPosition ) updating;

/*

Purpose:		This method is invoked prior to displaying a terminal area to set the orientation of the display 

Parameters:			

Return Value:		


Date				Who		Reason
26 November 2008	consw1	Initial creation

*/

vars
	
begin
	

	if _taViewPosition = null then
		self.myDrawingFrame.setSwapXY( false, null, null );
		self.flipHorizontal	:= false;
		self.flipVertically	:= false;
		return;
	endif;
	
	
	// cnwjk3 SFW1030
	if _taViewPosition.rotation = 0 then
		self.myDrawingFrame.setSwapXY( false, null, null );
		self.flipHorizontal	:= false;
		self.flipVertically	:= false;
	elseif _taViewPosition.rotation = 90 then
		self.myDrawingFrame.setSwapXY( true, _taViewPosition.origin, self.scaleFactor );
		self.flipHorizontal	:= false;
		self.flipVertically	:= true;
	elseif _taViewPosition.rotation = 180 then
		self.myDrawingFrame.setSwapXY( false, null, null );
		self.flipHorizontal	:= true;
		self.flipVertically	:= true;
	elseif _taViewPosition.rotation = 270 then
		self.myDrawingFrame.setSwapXY( true, _taViewPosition.origin, self.scaleFactor );
		self.flipHorizontal	:= true;
		self.flipVertically	:= false;
	endif;

	
	if _taViewPosition.horizontalFlip then
		self.flipHorizontal	:= not self.flipHorizontal;
	endif;
	
	if _taViewPosition.verticalFlip then
		self.flipVertically	:= not self.flipVertically;
	endif;

	return;
epilog

end;</source>
        <Parameter name="_taViewPosition" type="CM_TerminalAreaViewPosition"/>
    </JadeMethod>
    <JadeMethod name="setRange" id="8cfbd8cc-c629-47f7-8684-f2833ba64d90">
        <updating/>
        <source>setRange( _minRow, _maxRow, _minColumn, _maxColumn : Integer ) updating;

/*

Purpose:			Set row/column range that bounds the area to be displayed.

Parameters:			Zero value indicates no boundary set.

Return Value:		


Date				Who		Reason
18 November 2008	consw1	Initial creation

*/

vars

begin
	self.minRow := _minRow;
	self.maxRow := _maxRow;
	self.minColumn := _minColumn;
	self.maxColumn := _maxColumn;

	if _maxRow = 0 then
		self.maxRow := Max_Integer;
	endif;

	if _maxColumn = 0 then
		self.maxColumn := Max_Integer;
	endif;

epilog

end;</source>
        <Parameter name="_minRow" type="Integer"/>
        <Parameter name="_maxRow" type="Integer"/>
        <Parameter name="_minColumn" type="Integer"/>
        <Parameter name="_maxColumn" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setScale" id="8443edbe-7466-47f0-8d97-b31dfdf1a412">
        <updating/>
        <source>setScale(_factor: Real; _onDeck, _underDeck: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     02 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theRowHeight,
	theColWidth		: Integer;

begin
	inheritMethod(_factor, _onDeck, _underDeck);

	if (self.amPrinting and self.printOutputStyle = self.PrintOutput_Large) then
		theRowHeight 	:= PrintScaleLargeHeight;
		theColWidth 	:= PrintScaleLargeWidth;
	else
		theRowHeight 	:= (RowHeightDefault *  _factor).Integer;
		theColWidth		:= (24 * _factor).Integer; // PAR 16415
	endif;

	// must set these BEFORE call to setAttrPositions as it uses these figures
	self.rowHeight := theRowHeight;
	self.columnWidth := theColWidth;

	self.setAttrPositions(self.displayMode);

end;</source>
        <Parameter name="_factor" type="Real"/>
        <Parameter name="_onDeck" type="Boolean"/>
        <Parameter name="_underDeck" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTICollections" id="155ce8ad-6843-4fcb-b84b-3fa6777ab8f9">
        <source>setTICollections();
// ---------------------------------------------------------------------------
// Created:     01 September 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theTI, theOSTI 	: CM_TrackedItem;
	idx, colSize 	: Integer;
	
begin
	self.allTempTIs.clear();
	self.allTIsA.clear();
	self.allTIsP.clear();
	self.allTIsQ.clear();
	self.myLocationsController.allTrackedItems.copy(self.allTIsA);
	self.myLocationsController.getAllQueuedTrackedItems(self.allTIsQ, true); // PAR 26614 switch tranship imports to tranship export item
	self.myLocationsController.getAllPlannedTrackedItems(self.allTIsP, true, true); // PAR 26614
	
	self.allTIsA.copy(self.allTempTIs);
	colSize := self.allTempTIs.size;
	
	
	// ### QUEUED
	foreach theTI in self.allTIsQ do
		//cnwjo3 par 24408
		if theTI.allQueuedFutureMoves.size = 0 then
			continue;
		endif;
	
		if not theTI.isTwenty() then
			if theTI.allQueuedFutureMoves.first.CM_FutureMoveQueued.getPrimaryLocation = self.myLocationsController then
				colSize := theTI.allQueuedFutureMoves.first.CM_FutureMoveQueued.getNumOfTIsOnBackendAsPrimary(true);
				if colSize &gt; self.allTIsA.size then
					foreach idx in 1 to colSize do
						self.allTIsA.add(self.myTrackedItem); // dummy placeholder
						self.allTempTIs.add(self.myTrackedItem); // dummy placeholder
					endforeach;
				
				endif;
			else
				colSize := theTI.allQueuedFutureMoves.first.CM_FutureMoveQueued.getNumOfTIsOnBackendAsPrimary(false);
				if colSize &gt; self.allTIsA.size then
					foreach idx in 1 to colSize do
						self.allTIsA.add(self.myTrackedItem); // dummy placeholder
						self.allTempTIs.add(self.myTrackedItem); // dummy placeholder
					endforeach;
				endif;
			
			endif;
		endif;
		if not self.allTempTIs.includes(theTI) then
			self.allTempTIs.add(theTI);
		endif;
	endforeach;
	
	// ### PLANNED
	foreach theTI in self.allTIsP do
		//cnwjo3 par 24408
		if theTI.allPlannedFutureMoves.size = 0 then
			continue;
		endif;
	
		if not theTI.isTwenty() then
			if theTI.allPlannedFutureMoves.first.CM_FutureMovePlanned.getPrimaryLocation = self.myLocationsController then
				colSize := theTI.allPlannedFutureMoves.first.CM_FutureMovePlanned.getNumOfTIsOnBackendAsPrimary(true);
				if colSize &gt; self.allTIsA.size then
					foreach idx in 1 to colSize do
						self.allTIsA.add(self.myTrackedItem); // dummy placeholder
						self.allTempTIs.add(self.myTrackedItem); // dummy placeholder
					endforeach;
				
				endif;
			else
				colSize := theTI.allPlannedFutureMoves.first.CM_FutureMovePlanned.getNumOfTIsOnBackendAsPrimary(false);
				if colSize &gt; self.allTIsA.size then
					foreach idx in 1 to colSize do
						self.allTIsA.add(self.myTrackedItem); // dummy placeholder
						self.allTempTIs.add(self.myTrackedItem); // dummy placeholder
					endforeach;
				endif;
			
			endif;
		endif;
		if not self.allTempTIs.includes(theTI) then
			self.allTempTIs.add(theTI);
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setYAMTable" id="5d6f3ad0-e790-4918-b62d-f98f4778e8a3">
