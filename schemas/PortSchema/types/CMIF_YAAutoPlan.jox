    <JadeMethod name="isAvailable_Match" id="c21a4172-b4a4-4c08-84a6-d248556cb2fa">
        <source>isAvailable_Match(_yaData: CM_YADataBoolean): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 Sep 2009	cnwkpd1	PAR #19112 - New IsAvailable YA Criteria

*/

vars

	yaData : CM_YAData;
	yaDataBoolean : CM_YADataBoolean;
	booleanValue : Boolean;

begin

	//12 Aug 2016	NDL	TFS 2527
	yaData := self.getExtraCriteriaMatchData( YACriteriaType_IsAvailable );

	if yaData &lt;&gt; null and yaData.isKindOf(CM_YADataBoolean) then
		yaDataBoolean := yaData.CM_YADataBoolean;
		if yaDataBoolean &lt;&gt; null then
			if yaDataBoolean.value =  CM_YADataBoolean.VALUE_EITHER then
				return true;
			endif;
			booleanValue := yaDataBoolean.getValueAsBoolean();
			return _yaData.doesValueMatch( booleanValue );
		endif;
	endif;
		
	return false;
	
	
epilog

end;</source>
        <Parameter name="_yaData" type="CM_YADataBoolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
