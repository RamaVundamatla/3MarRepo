    <JadeMethod name="doMnuStopClick" id="65dc2749-516c-4f47-86b1-f92a59789c26">
        <updating/>
        <source>doMnuStopClick( menuItem : MenuItem input ) updating, protected;
	
// Changed On   Changed By  Reason
// 28/01/2010	cnwrl1		PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
// 16/06/2010	cnwcs5		par 24342 - new form for maintaining stops	
vars
	lTI			: CM_TrackedItem;
begin
	// just maintains the last ti selected
	lTI := menuItem.userObject.CM_TrackedItem;
	
	self.myAssistant.showStopsForm_TI (lTI, null, app.getMyUser.canUpdateStops( self.myTerminal) );	//cnwrd1 par 29440 27.4.2012
	
	return;
	
/*	app.mousePointer	:= Busy;
	
	lTI := menuItem.userObject.CM_TrackedItem;
	if lTI = null or menuItem = self.mnuStops then
		return;
	endif;
	
	// cnwrl1 27/01/2010 PAR 21889 - start of coding
	// NOTE: This reproduces the release 7.7.3 behaviour - ie it only handles the last TrackedItem clicked on.
	create tiSet transient;
	stopsTable	:= app.myRoot.allStopsTable[ menuItem.index ];
	while true do : update_TrackedItems
		self.myAssistant.contextMenuTIsStop( stopsTable, lTI, tiSet );
		
		if app.myPassport.noErrors then
			self.clearErrorWarnings();
			return;
		endif;
		result	:= app.showErrorWarningDialog(	app.getString( EWD_Cannot_Continue, app.getString( HeadingSaved ) ),
												app.myPassport,
												ErrWarnMode_Add + ErrWarnMode_CanAckWarnings );
		if app.myPassport.noErrors and result = IDOK then
			app.myPassport.warningsAcknowledged	:= true;
			continue update_TrackedItems;
		endif;
		self.setAllErrorWarnings( app.myPassport );	// copies errors to this form and shows in err/warnings window
		return;
	endwhile update_TrackedItems; */
	// cnwrl1 27/01/2010 PAR 21889 - end of coding
	
	/* cnwrl1 28/01/2010 PAR 21889 - what it was
	lTI := menuItem.userObject.CM_TrackedItem;
	if lTI = null or menuItem = self.mnuStops then
		return;
	endif;
	
	create lStops transient;
	create tiSet transient;
	
	lStops.add(menuItem.index);
	if not lTI.isStopSet( menuItem.index ) then
		tiSet.add( lTI );
		app.myTrxCA.trxCreateStopsForTIs( tiSet, lStops, app.myPassport );
		if not app.myPassport.trxCompletedOK then
			app.showErrorWarningDialog('Grid Area Form', app.myPassport, ErrWarnMode_Add);
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
	else
		stopTable := lTI.getStopByIDAsAtDate( menuItem.index, null ).myStopsTable;
		if stopTable.requiresInfo then
			self.processStopInfo(lTI, stopTable, lStops);
		else
			app.myTrxDA.trxDeleteStops(lTI, lStops, app.myPassport);
		endif;
		if not app.myPassport.trxCompletedOK then
			app.showErrorWarningDialog(app.getErrorString(Cargo_Enquiry), app.myPassport, ErrWarnMode_Update);
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
	endif;

	menuItem.checked := not menuItem.checked;
epilog
	delete lStops;
	delete tiSet;
	mousePointer := MousePointer_Default;
end;
	cnwrl1 28/01/2010 PAR 21889 - end of what it was */
	
epilog
	
	
end;
</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuTaskAdd" id="a0f44aa1-0316-4d34-af84-62e76cf8f93e">
        <updating/>
        <source>doMnuTaskAdd(menuItem : MenuItem input) updating;

vars

	lTI	: CM_TrackedItem;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	lTI := menuItem.userObject.CM_TrackedItem;
	if lTI = null then
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTIToDoTaskAdd(lTI, menuItem.index, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Add Todo Task', app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuTaskComplete" id="a1324721-43f9-4c55-b4ba-59670cd775c7">
        <updating/>
        <source>doMnuTaskComplete(menuItem : MenuItem input) updating;

vars

	lTI	: CM_TrackedItem;
	realTiSet : CM_TISet;
	pxyTiSet : CM_TISet;
	resourceUsageProxys : CM_ResourceTypeUsageSet;
	toDoTaskDesc : CM_ToDoTaskDesc;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	lTI := menuItem.userObject.CM_TrackedItem;
	if lTI = null or menuItem = self.mnuTaskComplete then
		return;
	endif;
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescriptions[menuItem.index];
	
	create realTiSet transient;
	realTiSet.add(lTI);

	create pxyTiSet transient;

	if not self.myAssistant.doTaskProxySetForComplete( menuItem.index, pxyTiSet, lTI, realTiSet, resourceUsageProxys) = IDOK then
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(toDoTaskDesc, pxyTiSet, resourceUsageProxys, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('GridArea Form', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog

	if pxyTiSet &lt;&gt; null and not pxyTiSet.isEmpty then
		pxyTiSet.purge;
	endif;
	delete pxyTiSet;
	delete realTiSet;
	
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuTaskRemove" id="24867144-f065-4bec-b71b-40e31d2f69e6">
        <updating/>
        <source>doMnuTaskRemove(_menuItem : MenuItem input) updating;

vars

	lTI		: CM_TrackedItem;
	answer	: Integer;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	lTI := _menuItem.userObject.CM_TrackedItem;
	if lTI = null or 
	   _menuItem = self.mnuTaskRemove then
		return;
	endif;

	answer := app.msgBox(app.getErrorString(TaskRemoveConfirm), app.getErrorString(Remove_Task), MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	
	if answer = MsgBox_Return_No then
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTIToDoTaskRemove(lTI, _menuItem.index, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Remove_Task), app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doNotableAdd" id="857bc406-b084-41dd-a8f5-eba5e6c2328a">
        <source>doNotableAdd(_ti : CM_TrackedItem);

vars

begin
	if _ti = null then
		return;
	endif;
	
	if (not global.isValidObject(_ti)) then
		return;
	endif;
	
	if (not self.allNotableTIs.includes(_ti)) then
		self.allNotableTIs.add(_ti);
		beginNotification(_ti, Object_Update_Event, Response_Continuous, null);
		beginNotification(_ti, Object_Delete_Event, Response_Continuous, null);
		
	endif;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="fc86ab92-190a-4503-a74e-16d5bce25d07">
        <source>doNotableClear();

vars
	ti : CM_TrackedItem;
begin

	foreach ti in self.allNotableTIs do
		endNotification(ti, Object_Update_Event);
		endNotification(ti, Object_Delete_Event);
	endforeach;

	self.allNotableTIs.clear;

end;</source>
    </JadeMethod>
    <JadeMethod name="doOpenBOLReconForm" id="ccdbe662-5e23-40cf-ba40-3a6daf6d6d40">
        <source>doOpenBOLReconForm();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Nov 2012	cnwpjs1	Initial creation   PAR #30787

*/

vars

	form	: CMUI_ReconBOLForm;
	bol		: CM_BOL;	
begin


	if self.isBOLDetailMode() then
		if self.myCurrentBOLDetail  &lt;&gt; null then
			bol := self.myCurrentBOLDetail.myBOL;
		endif;
	else
		bol := self.myCurrentBOL;
	endif;
	
	if bol = null then
		return;
	endif;


	form := app.loadForm(CMUI_ReconBOLForm,
									self.myAssistant.class,
									false,
									false,
									false,
									self.myTerminal, null).CMUI_ReconBOLForm;
	form.setMyBOL(bol);
	form.show;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOutturnEvent" id="eee4a011-ea64-4b89-b115-9f7a930b7b06">
        <source>doOutturnEvent( _bolSet : CM_BOLSet );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 October 2017	jlgndl1	Initial creation	TFS 6940

*/

vars

	result : Integer;
	term : CM_Terminal;
	iter : Iterator;
	camProtocol : CM_CamProtocol;
	includesOneStop : Boolean;

begin

	//warning if we are about to generate OUTTURN requests with no appropriate CAMS set up.
	term := self.myTerminal;
	iter := term.camProtocols.createIterator;
	while iter.next( camProtocol ) do
		if camProtocol.protocolDesc.isOneStopXML then
			if camProtocol.allTrainEventTypes.getAtKey("Voyage BOL OUTTURN Request") &lt;&gt; null then
				includesOneStop := true;
				break;
			endif;
		endif;
	endwhile;
	
	if not includesOneStop then
		app.msgBox( app.getErrorString(Outtu_trans_requi_stop_proto_t), app.getErrorString(Warning), MsgBox_OK_Only );
		return;
	endif;

	while true do
		app.myTrxUA.trxCreateOutturns( _bolSet, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Create_outturn), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;

epilog

	delete iter;

end;</source>
        <Parameter name="_bolSet" type="CM_BOLSet"/>
    </JadeMethod>
