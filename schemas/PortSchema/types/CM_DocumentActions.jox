    <JadeMethod name="mergeExistingAppliedActions" id="750a238a-7ddb-4083-9854-4665db51372a">
        <source>mergeExistingAppliedActions( _beingMerged : CM_TrackedItem input;  // will be zombied
							_beingMergedInto : CM_TrackedItem input  // will be the result of the two
							);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2016	cnwndl1	Initial creation	TFS 3016 / 2549

*/

vars

	iter : Iterator;
	
	docStopApplied : CM_DocumentStops;
	docToDoApplied : CM_DocumentToDoTask;
	
	localDocStopsColl : CM_DocumentStopsDict;
	localDocToDosArray : CM_DocumentTasksArray;
	
	oldAmount : Real;
	docStopToDel: CM_DocumentStops;
	docToDoToDel : CM_DocumentToDoTask;

begin

	if _beingMerged = null or _beingMergedInto = null then
		return;
	endif;

	// find the items that need merging
	create localDocStopsColl transient;
	create localDocToDosArray transient;
	
	iter := self.allDocumentStopsApplied.createIterator;
	while iter.next( docStopApplied ) do
		if docStopApplied.myTrackedItem &lt;&gt; _beingMerged then
			continue;
		endif;
		// this is one we need to merge.
		localDocStopsColl.add(docStopApplied);
	endwhile;
	delete iter;
	
	iter := self.allDocumentTasksApplied.createIterator;
	while iter.next( docToDoApplied ) do
		if docToDoApplied.myTrackedItem &lt;&gt; _beingMerged then
			continue;
		endif;
		// this is one we need to merge.
		localDocToDosArray.add(docToDoApplied);
	endwhile;
	delete iter;
	
	//Find the corresponding item for the target ti and increment the amount. / create a new one if 
	// there is no existing one, ultimately delete the ones related to the zombie.
	if not localDocStopsColl.isEmpty then
		iter := localDocStopsColl.createIterator;
		while iter.next( docStopToDel ) do
			oldAmount := docStopToDel.amount;
			docStopApplied := self.allDocumentStopsApplied.getAtKey(_beingMergedInto,docStopToDel.myStopsTable);
			if docStopApplied &lt;&gt; null then
				//found one, increment it
				docStopApplied.adjustAmount( docStopApplied.amount + oldAmount );
			else
				// none found create a new one.
				self.createDocumentStopForTi( _beingMergedInto, oldAmount, docStopToDel.myStopsTable );
			endif;
		endwhile;
		delete iter;
		localDocStopsColl.purge();
	endif;
	
	if not localDocToDosArray.isEmpty then
		iter := localDocToDosArray.createIterator;
		while iter.next( docToDoToDel ) do
			oldAmount := docToDoToDel.amount;
			docToDoApplied := self.allDocumentTasksApplied.getDocTask(_beingMergedInto,docToDoToDel.toDoTaskDesc);
			if docToDoApplied &lt;&gt; null then
				docToDoApplied.adjustAmount( docToDoApplied.amount + oldAmount );
			else
				self.createDocumentTaskForTi( _beingMergedInto, oldAmount, docToDoToDel.toDoTaskDesc, docToDoToDel.remarks );
			endif;
		endwhile;
		delete iter;
		localDocToDosArray.purge();
	endif;

epilog

	delete iter;
	delete localDocStopsColl;
	delete localDocToDosArray;

end;</source>
        <Parameter name="_beingMerged" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_beingMergedInto" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="db308306-7ce3-4a5b-8e94-8be452308007">
        <updating/>
        <source>setForUpdate( _proxy : CM_DocumentActions ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2016	cnwndl1	Initial creation	TFS 2278 / 2670

*/

vars

begin

	self.setStopTablesToAdd( _proxy.allStopTablesToAdd );
	self.setTaskDescsToAdd( _proxy.allTaskDescsToAdd, _proxy.allTaskRemarkToAdd );	//05 Oct 2016	NDL	TFS 2001 / 2792

epilog

end;</source>
        <Parameter name="_proxy" type="CM_DocumentActions"/>
    </JadeMethod>
    <JadeMethod name="setNewStopsTableToApply" id="bd0f2354-149a-447c-90bc-afe2187be7a1">
        <updating/>
        <source>setNewStopsTableToApply(  _proxy : CM_DocumentActions;  _stopToApply : CM_StopsTableSet)updating;
/*
Purpose:	 // ### TFS 3283		
Date				Who			Reason
MARCH 2017		CNWAB1		Initial creation
*/

vars
	ti : CM_TrackedItem;
	docstop : CM_DocumentStops;
	stopToApply : CM_StopsTableSet;
	remarksToApply : StringArray;
	tisToApplyTo : CM_TIArray;
    amount : Real;
    stopDesc : CM_StopsTable;
 begin
	stopToApply := _stopToApply;
	create tisToApplyTo transient;

	
	// get all the tis that have already have DAs applied to them
	self.getAllTis(tisToApplyTo);
	
	
	if tisToApplyTo.isEmpty() then // this happens if cargo has been staged but there were no stops or tasks
		self.getAllTisFromDocument(tisToApplyTo);
	endif;
	
	foreach ti in tisToApplyTo discreteLock do
		if not ti.isOnSite then
			continue;
		endif;
		foreach stopDesc in  stopToApply do
			// TFS 3283 amount := self.getDocumentAmount();
			amount := ti.totalQuantity; // TFS 3283 self.getDocumentAmount();
		
			docstop := self.createDocumentStopForTi( ti, amount, stopDesc );
		endforeach;

	endforeach;
epilog
	delete stopToApply;
	delete remarksToApply;
	delete tisToApplyTo;
end;</source>
        <Parameter name="_proxy" type="CM_DocumentActions"/>
        <Parameter name="_stopToApply" type="CM_StopsTableSet"/>
    </JadeMethod>
    <JadeMethod name="setNewTaskDescsToApply" id="9eab0ecb-10b2-4eec-9085-2eb4bd25c045">
        <updating/>
        <source>setNewTaskDescsToApply(  _proxy : CM_DocumentActions; _remarksToApply : StringArray;  _taskToApply : CM_ToDoTaskDescArray)updating;
/*
Purpose:	 // ### TFS 3283		
Date				Who			Reason
MARCH 2017		CNWAB1		Initial creation
*/

vars
	index : Integer;
	ti : CM_TrackedItem;
	doctask : CM_DocumentToDoTask;
	taskToApply : CM_ToDoTaskDescArray;
	remarksToApply : StringArray;
	tisToApplyTo : CM_TIArray;
    amount : Real;
    taskDesc : CM_ToDoTaskDesc;
    remarks : String;
begin
	taskToApply := _taskToApply;
	remarksToApply := _remarksToApply;
	create tisToApplyTo transient;

	
	// get all the tis that have already have DAs applied to them
	self.getAllTis(tisToApplyTo);
	
	
	if tisToApplyTo.isEmpty() then // this happens if cargo has been staged but there were no stops or tasks
		self.getAllTisFromDocument(tisToApplyTo);
	endif;
	
	foreach ti in tisToApplyTo discreteLock do
		if not ti.isOnSite then
			continue;
		endif;
		foreach index in 1 to taskToApply.size do
			amount := ti.totalQuantity; // TFS 3283 self.getDocumentAmount();
			taskDesc := taskToApply[index];
			remarks := remarksToApply[index];
			
			doctask := self.createDocumentTaskForTi( ti, amount, taskDesc, remarks );
			endforeach;

	endforeach;
epilog
	delete taskToApply;
	delete remarksToApply;
	delete tisToApplyTo;
end;</source>
        <Parameter name="_proxy" type="CM_DocumentActions"/>
        <Parameter name="_remarksToApply" type="StringArray"/>
        <Parameter name="_taskToApply" type="CM_ToDoTaskDescArray"/>
    </JadeMethod>
    <JadeMethod name="setStopTablesToAdd" id="b8862b55-853e-420e-a88a-28f93ea1c0dd">
        <updating/>
        <source>setStopTablesToAdd( objSet : ObjectSet )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2016	cnwndl1	Initial creation	TFS 2644 / 2001

*/

vars

	obj : Object;
	stop : CM_StopsTable;
	doCheck : Boolean;
	errMess : String;

begin

	
	if self.allStopTablesToAdd.size &lt;&gt; objSet.size then
		doCheck := true;
	elseif not objSet.isEmpty then
		foreach stop in self.allStopTablesToAdd do
			if not objSet.includes( stop ) then
				//trying to change something
				doCheck := true;
				break;
			endif;
		endforeach;
	endif;
	
	if doCheck then
		if not self.validateChangeActions(true,errMess,objSet,null) then
			return;
		endif;
	endif;
	
	self.allStopTablesToAdd.clear();
	
	if objSet &lt;&gt; null then
		foreach obj in objSet do
			if CM_StopsTable.hasInstance( obj ) then
				stop := obj.CM_StopsTable;
				self.allStopTablesToAdd.add( stop );
			endif;
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="objSet" type="ObjectSet"/>
    </JadeMethod>
    <JadeMethod name="setTaskDescsToAdd" id="ebca1387-4693-45a1-879d-9bba0064d10b">
        <updating/>
        <source>setTaskDescsToAdd( objArray : ObjectArray; strArray : HugeStringArray )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2016	cnwndl1	Initial creation	TFS 2644 / 2001

*/

vars

	obj : Object;
	task : CM_ToDoTaskDesc;
	doCheck : Boolean;
	index : Integer;
	str : String;
	errMess : String;

begin

	if self.allTaskDescsToAdd.size &lt;&gt; objArray.size then	//05 Oct 2016	NDL	TFS 2001 / 2792
		doCheck := true;
	elseif not objArray.isEmpty then
		foreach task in self.allTaskDescsToAdd do
			if not objArray.includes( task ) then
				//trying to change something
				doCheck := true;
				break;
			endif;
		endforeach;
	endif;

	if doCheck then
		if not self.validateChangeActions(true,errMess,null,objArray) then
			return;
		endif;
	endif;
	
	self.allTaskDescsToAdd.clear();
	self.allTaskRemarkToAdd.clear();
	
	if objArray &lt;&gt; null and not objArray.isEmpty then
		foreach index in 1 to objArray.size do
			obj := objArray[index];
			str := null;
			if strArray.size &gt;= index then
				str := strArray[index];
			endif;
			if CM_ToDoTaskDesc.hasInstance( obj ) then
				task := obj.CM_ToDoTaskDesc;
				self.allTaskDescsToAdd.add( task );
				self.allTaskRemarkToAdd.add( str );	//05 Oct 2016	NDL	TFS 2001 / 2792
			endif;
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="objArray" type="ObjectArray"/>
        <Parameter name="strArray" type="HugeStringArray"/>
    </JadeMethod>
    <JadeMethod name="setTaskDescsToAddFromEDI" id="448254bd-0da0-44b1-a31a-d659338e0935">
        <updating/>
        <source>setTaskDescsToAddFromEDI( _cargoType : Integer; _objArray : ObjectSet input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 October 2016	cnwndl1	Initial creation	TFS 2001 / 2792

*/

vars

	obj : Object;
	ediTI : CM_EDITaskRemarkRelBookTI;
	objArray : ObjectArray;
	hugeStrArray : HugeStringArray;
	iter : Iterator;
	remark : String;
	str : String;
	
	taskDesc : CM_ToDoTaskDesc;
	selectedTaskDesc : CM_ToDoTaskDesc;
	
	cargoType : CM_CargoType;

begin

	create objArray transient;
	create hugeStrArray transient;
	
	cargoType := app.myRoot.allCargoTypesById[_cargoType];

	if _objArray &lt;&gt; null then
		iter := app.myRoot.allToDoTaskDescriptions.createIterator;
		foreach obj in _objArray do
			if obj.isKindOf(CM_EDITaskRemarkRelBookTI) then
				ediTI := obj.CM_EDITaskRemarkRelBookTI;
				str := ediTI.taskCode;
				remark := ediTI.toDoRemarks;
				if str = null then
					app.raiseCMException1(ERR_NO_TODO_TASK, "null", ETRow_TaskCode, ediTI);
					continue;
				endif;
				
				if str.isInteger() then
					selectedTaskDesc := app.myRoot.allToDoTaskDescriptions[str.Integer];
				else
					iter.reset();
					while iter.next(taskDesc) do
						if str = taskDesc.shortDescription
						then
							selectedTaskDesc := taskDesc;
							break;
						endif;
					endwhile;
				endif;
				
				if selectedTaskDesc = null then
					app.raiseCMException1(ERR_NO_TODO_TASK, str, ETRow_TaskCode, ediTI);	
					continue;
				endif;
				
				if not selectedTaskDesc.allCargoTypes.includes(cargoType) then
					if cargoType = null then
						app.raiseCMException2(TaskCargoTypeMismatch, str, null, ETRow_TaskCode, ediTI);
					else
						app.raiseCMException2(TaskCargoTypeMismatch, str, cargoType.abbreviation, ETRow_TaskCode, ediTI);
					endif;
					continue;
				endif;
				
				objArray.add(selectedTaskDesc);
				hugeStrArray.add(remark);
			
			endif;
		endforeach;
	endif;
	
	self.setTaskDescsToAdd( objArray, hugeStrArray );

epilog

	delete objArray;
	delete hugeStrArray;
	delete iter;

end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_objArray" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="splitExistingAppliedActions" id="b3d90338-d10f-48dd-8dd0-a8bb58cae8bf">
        <source>splitExistingAppliedActions(_splitSourceTi : CM_TrackedItem input;
							_splitTi : CM_TrackedItem input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2016	cnwndl1	Initial creation	TFS 3016 / 2549

*/

vars

	splitAmount : Real;
	iter : Iterator;
	
	docStopApplied : CM_DocumentStops;
	docToDoApplied : CM_DocumentToDoTask;
	
	localDocStopsColl : CM_DocumentStopsDict;
	localDocToDosArray : CM_DocumentTasksArray;
	
	oldAmount : Real;

begin

	if _splitTi = null or _splitSourceTi = null then
		return;
	endif;

	splitAmount := _splitTi.totalQuantity.max(1);
	if _splitTi.myCargoType.allowDuplicates then
		if _splitTi.myCargoType.isBulkByVolume then
			splitAmount := _splitTi.totalVolume;
		elseif _splitTi.myCargoType.isBulkByWeight then
			splitAmount := _splitTi.totalWeight;
		endif;	
	endif; 
	
	if splitAmount= 0 then
		return;
	endif;
	
	// find the items that need splitting
	create localDocStopsColl transient;
	create localDocToDosArray transient;
	
	iter := self.allDocumentStopsApplied.createIterator;
	while iter.next( docStopApplied ) do
		if docStopApplied.myTrackedItem &lt;&gt; _splitSourceTi then
			continue;
		endif;
		// this is one we need to adjust.
		localDocStopsColl.add(docStopApplied);
	endwhile;
	delete iter;
	
	iter := self.allDocumentTasksApplied.createIterator;
	while iter.next( docToDoApplied ) do
		if docToDoApplied.myTrackedItem &lt;&gt; _splitSourceTi then
			continue;
		endif;
		// this is one we need to adjust.
		localDocToDosArray.add(docToDoApplied);
	endwhile;
	delete iter;
	
	
	//adjust the existing items and create new ones for the variance.
	if not localDocStopsColl.isEmpty then
		iter := localDocStopsColl.createIterator;
		while iter.next( docStopApplied ) do
			oldAmount := docStopApplied.amount;
			if oldAmount &gt; splitAmount then
				docStopApplied.adjustAmount( oldAmount - splitAmount );
				self.createDocumentStopForTi( _splitTi, splitAmount, docStopApplied.myStopsTable );
			endif;
		endwhile;
		delete iter;
	endif;
	
	if not localDocToDosArray.isEmpty then
		iter := localDocToDosArray.createIterator;
		while iter.next( docToDoApplied ) do
			oldAmount := docToDoApplied.amount;
			if oldAmount &gt; splitAmount then
				docToDoApplied.adjustAmount( oldAmount - splitAmount );
				self.createDocumentTaskForTi( _splitTi, splitAmount, docToDoApplied.toDoTaskDesc, docToDoApplied.remarks );
			endif;
		endwhile;
		delete iter;
	endif;

epilog

	delete iter;
	delete localDocStopsColl;
	delete localDocToDosArray;

end;</source>
        <Parameter name="_splitSourceTi" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_splitTi" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateProxyFromSelf" id="dde78146-6a8a-48fe-af1e-07752e1cf3e5">
        <source>updateProxyFromSelf( _proxy : CM_DocumentActions input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2016	cnwndl1	Initial creation	TFS 2278 / 2670

*/

vars

	docStop : CM_DocumentStops;
	docTask : CM_DocumentToDoTask;
	pxyDocStop : CM_DocumentStops;
	pxyDocTask : CM_DocumentToDoTask;

begin

	self.allCompletedStopTrx.copy(_proxy.allCompletedStopTrx);
	self.allCompletedTaskTrx.copy(_proxy.allCompletedTaskTrx);
	
	foreach docStop in self.allDocumentStopsApplied discreteLock do
		create pxyDocStop transient;
		pxyDocStop.setDetails(	docStop.myTrackedItem,	//_ti : CM_TrackedItem;
								docStop.amount,	//_amount : Real;
								docStop.myStopsTable,	//_stopTable : CM_StopsTable;
								_proxy	//_docActions : CM_DocumentActions
								);
	endforeach;
	
	foreach docTask in self.allDocumentTasksApplied discreteLock do
		create pxyDocTask transient;
		pxyDocTask.setDetails(	docTask.myTrackedItem,	//_ti : CM_TrackedItem;
								docTask.amount,	//_amount : Real;
								docTask.toDoTaskDesc,	//_task : CM_ToDoTaskDesc;
								docTask.remarks,	//_toDoRemarks : String;
								_proxy	//_docActions : CM_DocumentActions
								);
	endforeach;
	
	self.allStopTablesToAdd.copy(_proxy.allStopTablesToAdd);
	self.allTaskDescsToAdd.copy(_proxy.allTaskDescsToAdd);
	self.allTaskRemarkToAdd.copy(_proxy.allTaskRemarkToAdd);

epilog

end;</source>
        <Parameter name="_proxy" type="CM_DocumentActions" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateChangeActions" id="22153984-9bed-441d-aa1e-222b66355aad">
        <source>validateChangeActions( _raiseEsc : Boolean; _errorString : String output; _stopSet : ObjectSet; _taskArray : ObjectArray ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 November 2016	cnwndl1	Initial creation	TFS 2918 / 2419
20 Dec 2016			NDL							TFS 3122/2419/2001

*/

vars

	proposedStops : CM_StopsTableByIdDict;
	proposedTasks : CM_ToDoTaskDescByCode;
	trx : CM_TITransaction;
	stopClear : CM_StopClearedDocAction;
	taskComp : CM_TaskCompleteDocAction;
	stopApplied : CM_DocumentStops;
	taskApplied : CM_DocumentToDoTask;
	retValue : Boolean;

begin

	retValue := true;
	
	if _stopSet &lt;&gt; null then
		create proposedStops transient;
		_stopSet.copy( proposedStops );
		
		foreach trx in self.allCompletedStopTrx do
			if trx.isStopClearedDocAction then
				stopClear := trx.CM_StopClearedDocAction;
				if proposedStops.getAtKey( stopClear.stopID ) = null then
					if _raiseEsc then
						app.raiseCMException1( Not_remov_alrea_been_compl_aga, stopClear.stopDescription, null, null );
					else
						_errorString := app.getErrorString1( Not_remov_alrea_been_compl_aga, stopClear.stopDescription );
					endif; 
					retValue := false;
					return retValue;
				endif;
			endif;
		endforeach;
		
		foreach stopApplied in self.allDocumentStopsApplied do
			if proposedStops.getAtKey( stopApplied.myStopsTable.id ) = null then
				if _raiseEsc then
					app.raiseCMException1( Not_remov_alrea_been_appli_car, stopApplied.myStopsTable.heading, null, null );
				else
					_errorString := app.getErrorString1( Not_remov_alrea_been_appli_car, stopApplied.myStopsTable.heading );
				endif;
				retValue := false;
				return retValue;
			endif;
		endforeach;
		
	endif; 
	
	if _taskArray &lt;&gt; null then
		create proposedTasks transient;
		_taskArray.copy( proposedTasks );
		
		foreach trx in self.allCompletedTaskTrx do
			if trx.isTaskCompleteDocAction then
				taskComp := trx.CM_TaskCompleteDocAction;
				if proposedTasks.getAtKey( taskComp.todoTaskCode ) = null then
					if _raiseEsc then
						app.raiseCMException1( Not_remov_alrea_been_compl_aga, taskComp.todoTaskDesc, null, null );
					else
						_errorString := app.getErrorString1( Not_remov_alrea_been_compl_aga, taskComp.todoTaskDesc );
					endif; 
					retValue := false;
					return retValue;
				endif;
			endif;
		endforeach;
		
		foreach taskApplied in self.allDocumentTasksApplied do
			if proposedTasks.getAtKey( taskApplied.toDoTaskDescCode ) = null then
				if _raiseEsc then
					app.raiseCMException1( Not_remov_alrea_been_appli_car, taskApplied.toDoTaskDescDesc, null, null );
				else
					_errorString := app.getErrorString1( Not_remov_alrea_been_appli_car, taskApplied.toDoTaskDescDesc );
				endif;
				retValue := false;
				return retValue;
			endif;
		endforeach;
		
	endif;
	
	return retValue;

/*	if not self.allCompletedStopTrx.isEmpty
	or not self.allCompletedTaskTrx.isEmpty
	then
		if _raiseEsc then
			app.raiseCMException(Docum_actio_selec_not_updat_on, null, null);
		else
			_errorString := app.getErrorString(Docum_actio_selec_not_updat_on);
		endif; 
		return false;
	endif;
	
	if not self.allDocumentStopsApplied.isEmpty
	or not self.allDocumentTasksApplied.isEmpty
	then
		if _raiseEsc then
			app.raiseCMException(Docum_actio_selec_not_updat_wh, null, null);
		else
			_errorString := app.getErrorString(Docum_actio_selec_not_updat_wh);
		endif; 
		return false; 
	endif;
	
	return true; */
		
epilog

	delete proposedStops;
	delete proposedTasks;

end;</source>
        <Parameter name="_raiseEsc" type="Boolean"/>
        <Parameter name="_errorString" type="String" usage="output"/>
        <Parameter name="_stopSet" type="ObjectSet"/>
        <Parameter name="_taskArray" type="ObjectArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="c8300cfd-4c1a-4ec7-9d0f-2337ae7fc35c">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 September 2016	cnwndl1	Initial creation	TFS 2647 / 2001
27 Jul 2022	navsj20	TFS 53862	EUP - WMS - Damage Recording Extra Details

*/

vars

	cargoType : CM_CargoType;
	stop : CM_StopsTable;
	task : CM_ToDoTaskDesc;
	criteria	: CM_YACriteria;
begin

	cargoType := self.getCargoType();

	foreach stop in self.allStopTablesToAdd do
		if stop.requiresInfoString &lt;&gt; null then
			app.raiseCMException1(Stop_not_valid_this_operat, stop.shortHeading, null, null);
		endif;
		if cargoType &lt;&gt; null then
			// START 27 Jul 2022	navsj20	TFS 53862
			//if not stop.allCargoTypesNew.includes( cargoType ) then	//17 Jul 2022	navsj20	TFS 53862
			if stop.myStopCriteria &lt;&gt; null then
				foreach criteria in stop.myStopCriteria.allCriteria where criteria.myYACriteriaType.type = YACriteriaType_CargoType and not criteria.myYAData.CM_YADataObjects.allObjects.includes( cargoType ) do
					app.raiseCMException2(StopCargoTypeMismatch, stop.shortHeading, cargoType.abbreviation, null, null);
				endforeach;
			endif;
			// END 27 Jul 2022	navsj20	TFS 53862
		endif;
	endforeach;
	
	if cargoType &lt;&gt; null then
		foreach task in self.allTaskDescsToAdd do
			if not task.allCargoTypes.includes( cargoType ) then
				app.raiseCMException2(TaskCargoTypeMismatch, task.shortDescription, cargoType.abbreviation, null, null);
			endif;
		endforeach;
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
