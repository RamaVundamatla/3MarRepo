    <JadeMethod name="erase" id="3972ec43-d8a8-4be6-862b-015d169e264f">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

/*

Purpose:	NOTE. The GC Defn/LC will only exst for the discharge OR the load, not both		

Parameters:			

Return Value:		


Date		Who		Reason
09 November 2011	#cnwdz2	 28634

*/

vars
	erasedLoad : Boolean;
begin

	if self.myRORORequestDischarge &lt;&gt; null then
		self.eraseRequest(self.myRORORequestDischarge);
	endif;

	if self.myRORORequestLoad &lt;&gt; null then
		self.eraseRequest(self.myRORORequestLoad);
		erasedLoad := true;
	endif;
	
	if self.hasTIs() and erasedLoad then // PAR 32732 do not erase the location if there is loaded cargo, just erase the CC
		return;
	endif;
	
 	inheritMethod(_eraseLevel);
	
	

epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="executePostMoveForOrigLocation" id="e26c1256-3a70-4252-b497-5d19af3d5234">
        <updating/>
        <source>executePostMoveForOrigLocation(control: CMIF_MoveController; _passport: CM_Passport input) updating;
/*

Date		Who		Reason
19 June 2015	cnwer1	Initial creation PAR 36305

*/

vars
	defn : CM_DeckItem;
begin
	inheritMethod(control, _passport);

	if control.moveMode = REAL_MODE then
		if self.allTrackedItems.isEmpty then
			defn := self.myGCDefn;
			defn.myLayout.hideMe(); // this will stop any moves to the LC, see CM_LC::testIsControllerAvailable
			defn.myLayout.showAllCoveredPolygons();	
		endif;
	endif;
epilog

end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="executePostMoveForToLocation" id="fa7126f6-e1ab-415e-8def-e76b18e9fb0d">
        <updating/>
        <source>executePostMoveForToLocation(control: CMIF_MoveController; _passport: CM_Passport input) updating;
/*

Date		Who		Reason
18 June 2015	cnwer1	Initial creation PAR 36305

*/

vars
	layer, newLayer : CM_DeckLayerLayout;
	defn : CM_DeckItem;
begin
	inheritMethod(control, _passport);
	
	if control.moveMode = REAL_MODE then
		defn := self.myGCDefn;
		if defn &lt;&gt; null then	
			layer := defn.myLayout.myDeckLayer;
				
			if layer &lt;&gt; null then
				if not layer.isActualCargoLayer() then
				
					if layer.myDeckLayout &lt;&gt; null then
						newLayer := layer.myDeckLayout.getGCLayer(); // The actual GC Cargo Layer
						if newLayer &lt;&gt; null then
							// Move the GC layout to the GC Layer
							defn.myLayout.setMyDeckLayer(newLayer);
							defn.CM_ROROGCDefn.setMyDeckLayerLayout(newLayer); // PAR 32732 - Move the GC defn to the GC Layer
						endif;
					endif;
				else
					defn.myLayout.setIsVisible(true);
				endif;
			endif;
		endif;
	endif;	
epilog

end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAreaInSquareMetres" id="5061045e-ba6c-4eac-8da0-ac55889087ed">
        <source>getAreaInSquareMetres(): Decimal;
/*
Purpose:			
Date		Who		Reason
18 August 2011	cnwab1	Initial creation
*/

vars
	defn : CM_DeckItem;
begin
	defn := self.getDefn();
	
	if defn = null then
		return 0;
	endif;
	
	return defn.getAreaInSquareMetres();

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
