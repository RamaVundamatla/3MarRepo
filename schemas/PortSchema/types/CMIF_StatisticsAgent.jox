    <JadeMethod name="getSpareHeight" id="17c8b2d7-183c-4125-b932-70e4a809c17c">
        <source>getSpareHeight( _lc : CM_LocationsController; _minHeight, _maxHeight : Integer ) : Integer;

/*

Purpose:  Given an LC calculate the spare height, taking into account the adjacent LCs, when the TI spans more than one, along 
          with any height restrictions placed on an LC.  For example, a 53' may fit on top of the first 2 LC's but not the third. 			

Parameters:			

Return Value:		


Date		Who		Reason
09 March 2009	cnwjk3	Initial creation

*/

vars
	primaryLC,
	nextLC : CM_LocationsController;
	usedHeight,
	tempHeight,
	maxHeight : Integer;
	theTi,
	ti	: CM_TrackedItem;
begin
	nextLC := _lc;
	
	ti := nextLC.allTrackedItems.first;
	if ti = null then
		return 0;
	endif;
	theTi := ti;	
	
	//usedHeight := nextLC.allTrackedItems.size;	
	//tempHeight := nextLC.getMaxStackingHeight();
	//tempHeight := tempHeight - usedHeight;
	
	 //cnwjo3 par 20470
	if _minHeight = _maxHeight then
		usedHeight := nextLC.allTrackedItems.size().min(_minHeight);
	else
		usedHeight := nextLC.allTrackedItems.size().max(_minHeight);	
	endif;
	
	tempHeight :=  nextLC.getMaxStackingHeight().min(_maxHeight);	
	maxHeight  := tempHeight - usedHeight;
	
	nextLC := nextLC.CM_GridController.myNextController;	
	
	while nextLC &lt;&gt; null do
		// It's important to try and grab the back-end first within the loop as we are working from 
		// left to right
		ti := nextLC.allTrackedItemOSBackEnds.first;
		usedHeight := nextLC.allTrackedItemOSBackEnds.size;
		if ti = null then
			ti := nextLC.allTrackedItems.first;
			usedHeight := nextLC.allTrackedItems.size;
		endif;
		if ti = null or (ti &lt;&gt; null and ti &lt;&gt; theTi) then
			return maxHeight;
		endif;
		
		//tempHeight := nextLC.getMaxStackingHeight();
		//tempHeight := tempHeight - usedHeight;
		//tempHeight := nextLC.getMaxStackingHeight() - usedHeight - (_maxHeight - _minHeight);
		usedHeight := nextLC.allTrackedItems.size().max(_minHeight);	
		tempHeight :=  nextLC.getMaxStackingHeight().min(_maxHeight);	
		tempHeight := tempHeight - usedHeight;
		maxHeight := maxHeight.min(tempHeight);
		nextLC := nextLC.CM_GridController.myNextController;	
	endwhile;
	return maxHeight;
epilog

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_minHeight" type="Integer"/>
        <Parameter name="_maxHeight" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSpareHeightOLD" id="1d14161d-ca65-4320-8c25-2458b4fdf343">
        <source>getSpareHeightOLD( _lc : CM_LocationsController ) : Integer;

/*

Purpose:  Given an LC calculate the spare height, taking into account the adjacent LCs, when the TI spans more than one, along 
          with any height restrictions placed on an LC.  For example, a 53' may fit on top of the first 2 LC's but not the third. 			

Parameters:			

Return Value:		


Date		Who		Reason
09 March 2009	cnwjk3	Initial creation

*/

vars
	primaryLC,
	nextLC : CM_LocationsController;
	usedHeight,
	tempHeight,
	maxHeight : Integer;
	theTi,
	ti	: CM_TrackedItem;
begin
	nextLC := _lc;
	
	ti := nextLC.allTrackedItems.first;
	if ti = null then
		return 0;
	endif;
	theTi := ti;	
	usedHeight := nextLC.allTrackedItems.size;
	tempHeight := nextLC.getMaxStackingHeight();
	tempHeight := tempHeight - usedHeight;
	maxHeight  := tempHeight;
	nextLC := nextLC.CM_GridController.myNextController;	
	
	while nextLC &lt;&gt; null do
		// It's important to try and grab the back-end first within the loop as we are working from 
		// left to right
		ti := nextLC.allTrackedItemOSBackEnds.first;
		usedHeight := nextLC.allTrackedItemOSBackEnds.size;
		if ti = null then
			ti := nextLC.allTrackedItems.first;
			usedHeight := nextLC.allTrackedItems.size;
		endif;
		if ti = null or (ti &lt;&gt; null and ti &lt;&gt; theTi) then
			return maxHeight;
		endif;
		
		tempHeight := nextLC.getMaxStackingHeight();
		tempHeight := tempHeight - usedHeight;
		maxHeight := maxHeight.min(tempHeight);
		nextLC := nextLC.CM_GridController.myNextController;	
	endwhile;
	return maxHeight;
epilog

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getUsedHeight" id="e42ae92c-611e-4770-b59e-d38958a08b7e">
        <source>getUsedHeight( _lc : CM_LocationsController ) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 March 2009	cnwjk3	Initial creation

*/

vars

begin
	return _lc.allTrackedItems.size();
epilog

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWidthOfTIForPrimaryLocation" id="5f710b58-2e5d-419b-a8b8-a1ab9105fc34">
        <source>getWidthOfTIForPrimaryLocation(_lc : CM_LocationsController) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 March 2009	cnwjk3	Initial creation

*/

vars
	ti : CM_TrackedItem;
begin
	if self.isPrimaryLocation(_lc) then
		ti := _lc.allTrackedItems.first;
		if ti &lt;&gt; null then
			return ti.getActualLength().Integer;
		endif;
	endif;
	
	return 0;
epilog

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="haveSameGridTypes" id="90535643-e92c-493b-9135-67fdb87cb424">
        <source>haveSameGridTypes( _startColumn, _endColumn : Integer; _row : CM_LCArray) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 March 2009	cnwjk3	Initial creation

*/

vars
	column 	: Integer;
	is20ft,
	is30ft,
	is40ft,
	is45ft,
	is53ft 	: Boolean;
	theLC 	: CM_LocationsController;
begin
	if _startColumn &gt; _endColumn then
		return false;
	endif;
	if _startColumn &lt; 1 or _startColumn &gt; _row.size() then
		return false;
	endif;
	if _endColumn &lt; 1 or _endColumn &gt; _row.size() then
		return false;
	endif;
	foreach column in _startColumn to _endColumn do
		theLC := _row[column];
		if column &gt; _startColumn then
			// compare the first LC's grid values
			if is20ft &lt;&gt; theLC.is20ft then
				return false;
			endif;
			if is30ft &lt;&gt; theLC.is30ft then
				return false;
			endif;
			if is40ft &lt;&gt; theLC.is40ft then
				return false;
			endif;
			if is45ft &lt;&gt; theLC.is45ft then
				return false;
			endif;
			if is53ft &lt;&gt; theLC.is53ft then
				return false;
			endif;
		else
			// Record the first LC's grid types
			is20ft := theLC.is20ft;
			is30ft := theLC.is30ft;
			is40ft := theLC.is40ft;
			is45ft := theLC.is45ft;
			is53ft := theLC.is53ft;	
		endif;
	endforeach;
	return true;
epilog

end;</source>
        <Parameter name="_startColumn" type="Integer"/>
        <Parameter name="_endColumn" type="Integer"/>
        <Parameter name="_row" type="CM_LCArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isPrimaryLocation" id="c3258bfd-42e8-4158-8913-28333210fae5">
        <source>isPrimaryLocation( _lc : CM_LocationsController ) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 March 2009	cnwjk3	Initial creation

*/

vars
	ti : CM_TrackedItem;
	invalidObject : Boolean;
begin
	if not _lc.allTrackedItems.isEmpty() then
		ti := _lc.allTrackedItems.first;
	endif;
	
	on Exception do app.handleDeletedObject(exception,ti, invalidObject);
	if ti = null then
		return false;
	else
		return ti.myPrimaryActualLocation = _lc;
	endif;
epilog

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="locationContainsStartOfTI" id="e1b64e3f-1952-444f-ad15-682fb220c61c">
