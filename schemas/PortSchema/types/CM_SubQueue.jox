    <JadeMethod name="addAllowedMachineTypeGroup" id="7819e9e6-a7af-46b6-8cd9-a87232e8cac8">
        <updating/>
        <source>addAllowedMachineTypeGroup(_machineTypeGroup : Integer) updating;

// Created by cnwdvb1 on 30 August 2006

vars

begin

	if not self.allAllowedMachineTypeGroups.includes(_machineTypeGroup) then
		self.allAllowedMachineTypeGroups.add(_machineTypeGroup);
	endif;

end;</source>
        <Parameter name="_machineTypeGroup" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="canMachineAccess" id="58f45241-c831-4fbe-822d-a8c7afebc10b">
        <source>canMachineAccess(mach: CM_Machine);

vars

	taMaster : CM_TerminalAreaMaster;
begin
	inheritMethod(mach);

	
	// CCMS 1576
	foreach taMaster in self.allMoveFromTAMasters do
		if mach.canMachineAccessTAObj(taMaster, false) = false then
			app.setContinueCMExceptions(false);
			//app.raiseCMException2(ERR_MACH_TA_ACCESS, mach.id, taMaster.id, null, null);
			app.raiseCMException3(ERR_MACH_TA_ACCESS, self.id, taMaster.id, mach.id, null, null);
			return;
		endif;
	endforeach;

	
	
	// CCMS 1576
	foreach taMaster in self.allMoveToTAMasters do
		if mach.canMachineAccessTAObj(taMaster, true) = false then
			app.setContinueCMExceptions(false);
			//app.raiseCMException2(ERR_MACH_TA_ACCESS, mach.id, taMaster.id, null, null);
			app.raiseCMException3(ERR_MACH_TA_ACCESS, self.id, taMaster.id, mach.id, null, null);		//CNWMC5 - 16/01/2013 - PAR #30874
			return;
		endif;
	endforeach;
	
	//epr 11/3/09 removed can be worked test there are no longer system defined queues this effectively always returned true since 7.7.3

end;</source>
        <Parameter name="mach" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="ccms1061_conversion" id="7b7adf8a-0c32-45ff-90eb-360a20d768ca">
        <updating/>
        <source>ccms1061_conversion(_terminalArea :CM_TerminalArea; _area :CM_AreaWithLanes)updating;
// ---------------------------------------------------------------------------
// Created:     16 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/10/2009	cnwcs5		par 21285 - reset VTA queue to non-system defined
// ---------------------------------------------------------------------------
vars

begin
	if self.myMoveFromTAMaster = _terminalArea then
		self.myMoveFromTAMaster := _area;
	endif;
	
	if self.myMoveToTAMaster = _terminalArea then
		self.myMoveToTAMaster := _area;
	endif;
	
	if self.allMoveFromTAMasters.includes (_terminalArea) then
		self.allMoveFromTAMasters.remove (_terminalArea);
		self.allMoveFromTAMasters.add (_area);
	endif;
	
	if self.allMoveToTAMasters.includes (_terminalArea) then
		self.allMoveToTAMasters.remove (_terminalArea);
		self.allMoveToTAMasters.add (_area);
	endif;
	// if this is the queue we renamed on the vta then change its name back
	if self.id = _terminalArea.id and self.id &lt;&gt; null and self.id[1] = '~' then
		self.id 				:= _area.id;
		self.isSystemDefined	:= false;	// par 21285
	endif;
		
epilog

end;</source>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_area" type="CM_AreaWithLanes"/>
    </JadeMethod>
    <JadeMethod name="changeId" id="2dea563a-6ba4-4fbd-a3e4-ab5cf4e3b435">
        <updating/>
        <source>changeId(newId: String) updating;
//Changes the id of the queue. ONLY applies to sub-queues.
//Voyage queues have an id of the voyage number,
//VoyageCraneQueues have an id of the crane.
vars
	tStr : String;
begin
	tStr := newId.trimBlanks;
	if tStr = null then
		//No ID!!! Error
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_NO_QUEUE_ID, null, null);
		return;
	endif;
	if self.myParentQueue.allSubQueuesById[tStr] &lt;&gt; null then
		//Duplicated, error!
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_QUEUE_EXISTS, tStr, null, null);
		return;
	endif;
	//queuesByOrder is not affected
	self.id := newId.trimBlanks;
end;</source>
        <Parameter name="newId" type="String"/>
    </JadeMethod>
    <JadeMethod name="combineMatchPriorities" id="6fd34b0b-ba98-417b-9386-454e7563fcbe">
        <source>combineMatchPriorities(firstMp: Integer; secondMp: Integer): Integer;

begin
	if firstMp = Match_Fail or secondMp = Match_Fail then
		return Match_Fail;
	endif;

	if isUnidirectional then
		return firstMp + secondMp + Match_Directional;
	else
		return firstMp + secondMp;
	endif;
end;</source>
        <Parameter name="firstMp" type="Integer"/>
        <Parameter name="secondMp" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="compareQueueToType" id="309ae5c5-3860-4fde-98ef-4881c5a8ffcb">
        <source>compareQueueToType(_machineTypeGroup : CM_MachineTypeGroup): Boolean;

// Created by cnwdvb1 on 15 August 2006

vars

begin
	
	// This method should only be needed for sub queues because voyage queues
	// and master queues are evaluated differently.
	
	if _machineTypeGroup = null then
		//epr CCMS 1025 found while testing
		//this will create a picup / setdown task if queue has only IMV then
		// should not be allowed
		if self.allAllowedMachineTypeGroups.size = 1 and
			self.allAllowedMachineTypeGroups.first = MACHINETYPEGRP_IMV then
			return false;
		endif;
	
		return true;
	
	elseif _machineTypeGroup.type = MACHINETYPEGRP_RTG then
		if self.allAllowedMachineTypeGroups.includes(_machineTypeGroup.type) then
			return true;
		endif;
	else
		// Allowed machines is empty and not comparing and RTG group then let it through.
		if self.allAllowedMachineTypeGroups.isEmpty() or self.allAllowedMachineTypeGroups.includes(_machineTypeGroup.type) then
			return true;
		endif;
	endif;
		
	return false;

end;</source>
        <Parameter name="_machineTypeGroup" type="CM_MachineTypeGroup"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="destroyQueue" id="dd5ffa66-1187-46da-b08f-93b7ab4dec1d">
        <updating/>
        <source>destroyQueue() updating, protected;
//Removes us from the Queue, returns our machines to the parent
//and destroys this object.
vars
	mach	: CM_Machine;
	lc 		: CM_LocationsController;
	queue	: CM_RadioTelemetryQueue;
	entry	: CM_RTQueueEntry;
	array	: CM_RTQueueEntryArray;
	
begin
	exclusiveLock(self);

	create array transient;
	self.allEntries.copy(array);
	foreach entry in array do
		entry.shiftEntry(self.myParentQueue);
	endforeach;

	foreach mach in self.allPrimaryMachines do
		self.myParentQueue.addMachine(mach);
	endforeach;

epilog
	delete array;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doesQueueOrderNeedManipulating" id="f7e10faf-7a7f-405f-b31d-56b886867207">
        <source>doesQueueOrderNeedManipulating(_machinesTA : CM_TerminalArea) : Boolean protected;
// -------------------------------------------
// Created 12 January 2005 by cnwdvb1
// -------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	invalid 		: Boolean;
	ed				: Integer;
	
begin
	// Don't know where machine is.
//	if not global.isValidObject(_machinesTA) then
	if _machinesTA = null then
		return false;
	endif;
	
	on Exception do app.handleDeletedObject(exception, _machinesTA, invalid);
	// dereference ta to check it is valid
	ed := _machinesTA.edition();
	if invalid then
		return false;
	endif;
	
	// No point searching for similar locations in 
	// uni directional as queues already have only one type of movement.
	if self.isUnidirectional then
		return false;
	endif;
	
	// Am I supposed to find next task in this area?
	
	// We look for something going back if
	// 1) The area is enabled for look for similar area.
	// 2) The from area is the same as the one the machine is in
	// 3) The from area is set to anything and the machine is not in an area specified by the to area.
	
	if self.lookForFromAreaMove then
		// DVB changed 11/08/06
		// Rethink about whether only terminalareas is enough here.
		//if self.moveFromTerminalArea = _machinesTA or (self.moveFromTerminalArea = null and self.moveToTerminalArea &lt;&gt; _machinesTA) then
		
		// PAR 16732 changed from Following 13 May 08 - as gives 6060 err in JADE 6.2, end part would have returned false since 2006
		//if self.allMoveFromTAMasters.includes(_machinesTA) or (self.allMoveFromTAMasters.isEmpty() and self.allMoveFromTAMasters &lt;&gt; _machinesTA) then
		if self.allMoveFromTAMasters.includes(_machinesTA) then
			return true;
		endif;
	endif;

	// We look for something going back if
	// 1) The area is enabled for look for similar area.
	// 2) The to area is the same as the one the machine is in
	// 3) The to area is set to anything and the machine is not in an area specified by the from area.
	
	if self.lookForToAreaMove then
		// DVB changed 11/08/06
		//if self.moveToTerminalArea = _machinesTA or (self.moveToTerminalArea = null and self.moveFromTerminalArea &lt;&gt; _machinesTA) then

		// PAR 16732 changed from Following 13 May 08 - as gives 6060 err in JADE 6.2, end part would have returned false since 2006
		//if self.allMoveToTAMasters.includes(_machinesTA) or (self.allMoveToTAMasters.isEmpty() and self.allMoveToTAMasters &lt;&gt; _machinesTA) then
		if self.allMoveToTAMasters.includes(_machinesTA) then
			return true;
		endif;
	endif;

	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_machinesTA" type="CM_TerminalArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="erase" id="4255d9f2-39b4-4a34-b3b7-a301ff9c8b00">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

vars

	queue	: CM_RadioTelemetryQueue;
		
begin
	
//	self.raiseExceptionIfQueueEntries();
	
	exclusiveLock(self);
	
	foreach queue in self.allSubQueuesById do
		queue.erase(_eraseLevel);
	endforeach;
	
	if (not self.isTransient) then
		self.destroyQueue();
	endif;
	inheritMethod(_eraseLevel);

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="evaluateMatchPriority" id="299bfe22-82b6-48da-bb79-39982a4d9b57">
        <source>evaluateMatchPriority(_arbiter: CM_RTQueueArbiter input; sourceLocn: CM_LocationsController; targetLocn: CM_LocationsController; forwardMove: Boolean): Integer;
// 22/06/2010	cnwcs5	par 24418 - use CM_LocationsController::getMyTerminalArea instead of CM_LocationsController::myTerminalArea
// 26/08/2010	cnwmh5	#25510/25512 - Add queue logging
// 29/06/2011	cnwmh5	#27179 - Change to use the arbiter's writeLoggingText
 // ### JIRA 35862 08SEP2025 NAVAB1 - _arbiter: CM_RTQueueArbiter added 'input'
vars
	sourceArea			: CM_TerminalArea;
	targetArea			: CM_TerminalArea;
	sourceAreaName, targetAreaName: String;
	srcLocnMatch		: Integer;
	targetLocnMatch		: Integer;
	preferSource	: Boolean;	
	finalPriority: Integer;
	
begin

	preferSource := _arbiter.preferSource = forwardMove;
	
	if sourceLocn &lt;&gt; null then
		sourceArea := sourceLocn.getMyTerminalArea;	// cnwcs5 22/06/2010
		
		if (not self.moveFromLocnControllers.isEmpty) and (self.moveFromLocnControllers.includesTerminalArea(sourceArea)) then
			if self.moveFromLocnControllers.includes(sourceLocn) then
				if preferSource then
					srcLocnMatch := Match_LC_High;
				else
					srcLocnMatch := Match_LC_Low;
				endif;
			endif;
		else
			if self.allMoveFromTAMasters.isEmpty() then
				srcLocnMatch := Match_Default;
			else
				if sourceArea &lt;&gt; null and self.allMoveFromTAMasters.isSimilarQueueArea(sourceLocn) then
					if preferSource then
						srcLocnMatch := Match_TA_High;
					else
						srcLocnMatch := Match_TA_Low;
					endif;
				endif;
			endif;
		endif;
	endif;

			
	if targetLocn &lt;&gt; null then
		targetArea := targetLocn.getMyTerminalArea;	// cnwcs5 22/06/2010
		
		if (not self.moveToLocnControllers.isEmpty) and (self.moveToLocnControllers.includesTerminalArea(targetArea)) then
			if moveToLocnControllers.includes(targetLocn) then
				if preferSource then
					targetLocnMatch := Match_LC_Low;
				else
					targetLocnMatch := Match_LC_High;
				endif;
			endif;
		else
			if self.allMoveToTAMasters.isEmpty() then
				targetLocnMatch := Match_Default;
			else
				if targetArea &lt;&gt; null and self.allMoveToTAMasters.isSimilarQueueArea(targetLocn) then
					if preferSource then
						targetLocnMatch := Match_TA_Low;
					else
						targetLocnMatch := Match_TA_High;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	finalPriority := combineMatchPriorities(srcLocnMatch, targetLocnMatch);
	
	if sourceArea &lt;&gt; null then
		sourceAreaName := sourceArea.id;
	endif;
	if targetArea &lt;&gt; null then
		targetAreaName := targetArea.id;
	endif;
	_arbiter.writeLoggingText(Tab &amp; 'Priority Final: ' &amp; finalPriority.String &amp;
						      ' Source: ' &amp; srcLocnMatch.String &amp; 
							  ' Target: ' &amp; targetLocnMatch.String &amp;
							  " (" &amp; sourceAreaName &amp; " =&gt; " &amp; targetAreaName &amp; ")");
		
	return finalPriority;
end;
</source>
        <Parameter name="_arbiter" type="CM_RTQueueArbiter" usage="input"/>
        <Parameter name="sourceLocn" type="CM_LocationsController"/>
        <Parameter name="targetLocn" type="CM_LocationsController"/>
        <Parameter name="forwardMove" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="evaluateMatchPriorityOld" id="f3264c15-a426-49cd-be6d-03927a743c51">
        <source>evaluateMatchPriorityOld(sourceLocn: CM_LocationsController; targetLocn: CM_LocationsController; forwardMove: Boolean): Integer;

vars
	fromArea			: CM_TerminalArea;
	toArea				: CM_TerminalArea;
	srcLocnMatch		: Integer;
	targetLocnMatch		:   Integer;
	preferSource,	
	isFromTransferArea,
	isToTransferArea	: Boolean;	
	
begin

	return 0;
	/*preferSource := (app.getMyTerminalConfig(RtQueuePriorityFromOverTo).Boolean = forwardMove);
	isFromTransferArea := (self.moveFromTerminalArea &lt;&gt; null and self.moveFromTerminalArea.isTransferArea);
	fromArea := sourceLocn.myTerminalArea;
	toArea := targetLocn.myTerminalArea;

	if not self.moveFromLocnControllers.isEmpty and not isFromTransferArea then
		if self.moveFromLocnControllers.includes(sourceLocn) then
			if preferSource then
				srcLocnMatch := Match_LC_High;
			else
				srcLocnMatch := Match_LC_Low;
			endif;
		endif;
	else
		if self.moveFromTerminalArea = null then
			srcLocnMatch := Match_Default;
		else
			if fromArea &lt;&gt; null and
			   self.moveFromTerminalArea.isSimilarQueueArea(fromArea.CM_TerminalArea) then
				if preferSource then
					srcLocnMatch := Match_TA_High;
				else
					srcLocnMatch := Match_TA_Low;
				endif;
			endif;
		endif;
	endif;

	isToTransferArea := (self.moveToTerminalArea &lt;&gt; null and self.moveToTerminalArea.isTransferArea);
	
	if not self.moveToLocnControllers.isEmpty and not isToTransferArea then
		if moveToLocnControllers.includes(targetLocn) then
			if preferSource then
				targetLocnMatch := Match_LC_Low;
			else
				targetLocnMatch := Match_LC_High;
			endif;
		endif;
	else
		if self.moveToTerminalArea = null then
			targetLocnMatch := Match_Default;
		else
			if toArea &lt;&gt; null and
			   self.moveToTerminalArea.isSimilarQueueArea(toArea.CM_TerminalArea) then
				if preferSource then
					targetLocnMatch := Match_TA_Low;
				else
					targetLocnMatch := Match_TA_High;
				endif;
			endif;
		endif;
	endif;

	return combineMatchPriorities(srcLocnMatch, targetLocnMatch);*/
end;</source>
        <Parameter name="sourceLocn" type="CM_LocationsController"/>
        <Parameter name="targetLocn" type="CM_LocationsController"/>
        <Parameter name="forwardMove" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllQueuesForMachineType" id="4d88df34-0d4c-40f9-b856-e9e558014d9f">
        <source>getAllQueuesForMachineType(_machineType: Integer; _queuesToReturn: CM_RTQueueArray io);
/*

Purpose:			


Return Value:		


Date		Who		Reason
18 October 2006	cnwer1	Initial creation - PAR#12766

*/
vars
	rtQ	:	CM_RadioTelemetryQueue;
begin

	if self.queueType = QTYPE_RTG then
		if _machineType = MACHINETYPE_RTG or _machineType = MACHINETYPE_RMG then
		//exclude those where the myMoveFromTAMaster &lt;&gt; CM_RTGLane
			_queuesToReturn.add(self);
		endif;
		
		foreach rtQ in self.allSubQueuesByOrder do
			rtQ.getAllQueuesForMachineType(_machineType,_queuesToReturn);
		endforeach;	
		
	else
		inheritMethod(_machineType, _queuesToReturn);
	endif;


epilog

end;</source>
        <Parameter name="_machineType" type="Integer"/>
        <Parameter name="_queuesToReturn" type="CM_RTQueueArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getDefaultWorkzone" id="29f74067-9e9b-45a2-ab13-a11da539fd73">
        <source>getDefaultWorkzone(	_startCol,
					_endCol : CM_RTGColumn output;
					_taMaster : CM_TerminalAreaMaster output);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 September 2009	cnwer1	Initial creation

*/

vars
	rtgArea : CM_RTGArea;
	rtgLane : CM_RTGLane;
	ta 		: CM_TerminalArea;
begin
	//check if is working a RTG queue
	if not self.queueType = QTYPE_RTG and
		not self.queueType = QTYPE_RMG then
		return;
	endif;
	
	if self.allMoveFromTAMasters.isEmpty then
		return;
	endif;
	
	if not self.allMoveFromTAMasters.first.isKindOf(CM_RTGArea) then
		return;
	endif;
	
	rtgArea:=self.allMoveFromTAMasters.first.CM_RTGArea;
	rtgLane:=rtgArea.allTerminalAreaGroups.first.CM_RTGLane;
	if rtgLane = null then
		_startCol:=rtgArea.allGridColumns.first.CM_RTGColumn;
		_endCol:=rtgArea.allGridColumns.last.CM_RTGColumn;
		_taMaster:=rtgArea;
		return;
	endif;
	
	_taMaster:=rtgLane;
	foreach ta in rtgLane.allTAsByTypeId  do
		if not self.allMoveFromTAMasters.includes(ta) then
			continue;
		endif;
		
		rtgArea:=ta.CM_RTGArea;
		if _startCol = null then
			_startCol:=rtgArea.allGridColumns.first.CM_RTGColumn;
		endif;
		_endCol:=rtgArea.allGridColumns.last.CM_RTGColumn;
	endforeach;
epilog

end;</source>
        <Parameter name="_startCol" type="CM_RTGColumn" usage="output"/>
        <Parameter name="_endCol" type="CM_RTGColumn" usage="output"/>
        <Parameter name="_taMaster" type="CM_TerminalAreaMaster" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getMatchPriority" id="36e5e9f1-871e-4643-bdb4-b8be8599be3b">
        <source>getMatchPriority(arbiter: CM_RTQueueArbiter io;
					_sourceLocation,
					_targetLocation 	: CM_LocationsController): Integer;
//If this queue matches the (source, target, enforcementLevel) criteria 
//then return true, else false.
// 26/08/2010	cnwmh5	#25510/25512 - Add queue logging
// ### JIRA 35862 08SEP2025 NAVAB1 added Tab for collapsible View
vars
	extraPriority 			: Integer;
	forwardMovePriority		: Integer;
	reverseMovePriority		: Integer;
	hasChanged				: Boolean;	
	voyage : CM_Voyage;
begin
	
	// Yard Jobs are always allowed to use a yard queue
	if not arbiter.isYardJob and not arbiter.isYardQueueAllowed(_sourceLocation, _targetLocation) then
		arbiter.writeLoggingText(Tab &amp; "Match Failed: Not Yard Job or Not Yard Queue Allowed");
		return Match_Fail;
	endif;
	
	if self.queueType = QTYPE_VOYAGEYARD then
		if not arbiter.isVoyageJob then
			arbiter.writeLoggingText(Tab &amp; "Match Failed: Only Voyage Jobs allowed in Yard Voyage queue");
			return Match_Fail;
		endif;
		if arbiter.isVoyageJob and arbiter.isYardQueueAllowed(_sourceLocation, _targetLocation) then
			if self.voyageJobType &lt;&gt; 0 then
				if arbiter.job.CM_VoyageJob.isDischarge and  self.voyageJobType &lt;&gt; VoyageJob_Discharge then
					arbiter.writeLoggingText(Tab &amp; "Match Failed: Only Voyage DISCHARGE Jobs allowed in Yard Voyage queue");
					return Match_Fail;
				endif;
				if arbiter.job.jobType = JOB_TYPE_LOAD  and  self.voyageJobType &lt;&gt; VoyageJob_Load then
					arbiter.writeLoggingText(Tab &amp; "Match Failed: Only Voyage LOAD Jobs allowed in Yard Voyage queue");
					return Match_Fail;
				endif;
			endif;
			voyage:=arbiter.job.CM_VoyageJob.myVoyage;
			if self.myVoyage &lt;&gt; null and voyage &lt;&gt; self.myVoyage then
				arbiter.writeLoggingText(Tab &amp; "Match Failed: Voyage did not match voyage defined in Yard Voyage queue");
				return Match_Fail;	
			endif;
			
			extraPriority:= Match_Default;
		endif;
	endif;
	
	if arbiter.isTargetMove and self.allAllowedMachineTypeGroups.includes(MACHINETYPEGRP_RTG) then
		arbiter.preferSource := not arbiter.preferSource;
		hasChanged := true;
	endif;

	forwardMovePriority := self.evaluateMatchPriority(arbiter, _sourceLocation, _targetLocation, true);

	if _sourceLocation = null or _targetLocation = null then
		arbiter.writeLoggingText(Tab &amp; "Priority Final: " &amp; forwardMovePriority.String &amp; " (Source or Target Location is null)");
		return forwardMovePriority + extraPriority;
	elseif isUnidirectional then
		arbiter.writeLoggingText(Tab &amp; "Priority Final: " &amp; forwardMovePriority.String &amp; " (UniDirectional)");
		return forwardMovePriority + extraPriority;
	else
		reverseMovePriority := self.evaluateMatchPriority(arbiter, _targetLocation, _sourceLocation, false);
		arbiter.writeLoggingText(Tab &amp; "Priority Final: " &amp; forwardMovePriority.max(reverseMovePriority).String &amp; " (BiDirectional)");
		return (forwardMovePriority.max(reverseMovePriority)) + extraPriority;
	endif;

epilog
	if hasChanged then
		arbiter.preferSource := not arbiter.preferSource;
	endif;
end;</source>
        <Parameter name="arbiter" type="CM_RTQueueArbiter" usage="io"/>
        <Parameter name="_sourceLocation" type="CM_LocationsController"/>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
