    <JadeMethod name="doTblDataKeyPress" id="ec5ef2d6-aede-4066-afc7-6a0fcb9a6218">
        <updating/>
        <source>doTblDataKeyPress(table: Table input; keyCode: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	if keyCode = J_key_Space then
		self.doBtnRTSClick(table);
