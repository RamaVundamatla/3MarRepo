    <JadeMethod name="resetData_37279" id="49ec2ef6-457c-4307-a515-e5ec249952ca">
        <source>resetData_37279();

constants

	VehicleID				: String = "37279";

vars

	terminal				: CM_Terminal;
	ti						: Object;
	ediFile					: CM_EDIFile;
	passportTerm			: CM_Terminal;
	release					: CM_BulkRelease;

	tisToDelete				: StringArray;
	tiSet					: CM_TISet;
	pinsStrDict				: CM_StringDict;

	trackedItemId			: String;
	ediData 				: String;			
	
begin

	
	app.initialize();
	
	create pinsStrDict transient;
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	terminal := app.myRoot.allTerminals["TT1"];
	if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
		
	// delete the vehicle
	self.deleteVehicle(VehicleID);
	self.addVehicle(VehicleID, app.myRoot.allCarriers["AAUTO"].CM_Carrier, terminal);
	
	// delete the release request
	self.deleteReleaseRequest("JLG37279ROAD001");
	self.deleteReleaseRequest("JLG37279ROAD002");
	self.deleteReleaseRequest("JLG37279ROAD003");
		
	// delete the tracked items
	create tisToDelete transient;
	tisToDelete.add("JLG37279W7UA01");
	tisToDelete.add("JLG37279W7UA02");
	tisToDelete.add("JLG37279W7UA03");
	tisToDelete.add("JLG37279W7UA04");
	tisToDelete.add("JLG37279W7UA05");
	tisToDelete.add("JLG37279W7UA06");
	tisToDelete.add("JLG37279W7UA07");
	tisToDelete.add("JLG37279W7UA08");
	tisToDelete.add("JLG37279W7UA09");
	
	create tiSet transient;
	
	foreach trackedItemId in tisToDelete do
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti := trackedItemId.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			self.deleteTrackedItem(tiSet.first, false);
		endif;	
		
	endforeach;
	
	/*
	// can't do this as doens't remove offsite cargo 
	// delete all other tracked items
	ediData := '&lt;?xml version="1.0" encoding="UTF-8"?&gt;
&lt;JMTInternalCargoOnSite 
  xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalCargoOnSite.xsd"&gt;
  &lt;AllCargoOnSite&gt;
    &lt;operationsToPerform&gt;Verify;Load To DB&lt;/operationsToPerform&gt;
    &lt;operationsToPerformStatuses&gt;EDI_STATUS_VERIFIED / EDI_STATUS_VERIFIED_WARNINGS;EDI_STATUS_DBLOADED&lt;/operationsToPerformStatuses&gt;
     &lt;CargoOnSite Terminal="TT1"&gt;
      &lt;TestCases&gt;37279&lt;/TestCases&gt;
      &lt;cargoTypeDescr&gt;Motor Vehicle&lt;/cargoTypeDescr&gt;
      &lt;id&gt;JLG37279W7UA02&lt;/id&gt;
      &lt;operatorCode&gt;MSL&lt;/operatorCode&gt;
      &lt;locationId&gt;GCVH01 CARS&lt;/locationId&gt;
      &lt;weight&gt;5000.0000&lt;/weight&gt;
      &lt;imexStatus&gt;Import&lt;/imexStatus&gt;
      &lt;commodity&gt;MCAR&lt;/commodity&gt;
      &lt;dischargePort&gt;NZLYT&lt;/dischargePort&gt;
      &lt;voyageCode&gt;MSCK000002&lt;/voyageCode&gt;
      &lt;messageMode&gt;D&lt;/messageMode&gt;
    &lt;/CargoOnSite&gt;
    &lt;CargoOnSite Terminal="TT1"&gt;
      &lt;TestCases&gt;37279&lt;/TestCases&gt;
      &lt;cargoTypeDescr&gt;Motor Vehicle&lt;/cargoTypeDescr&gt;
      &lt;id&gt;JLG37279W7UA03&lt;/id&gt;
