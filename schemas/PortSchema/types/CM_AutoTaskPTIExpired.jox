<Class name="CM_AutoTaskPTIExpired" id="1ee1f175-6e57-4987-868b-606c184fe2bb">
    <superclass name="CM_AutoTask"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Check PreTrip Inspection Expired&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <ImplicitInverseRef name="myToDoTaskDesc" id="0750d62f-3b37-47f7-a031-5f56f04eaef3">
        <embedded/>
        <type name="CM_ToDoTaskDesc"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="getEntryTableViewName" id="cc362289-6e94-45c9-9604-78a8591e7441">
        <source>getEntryTableViewName(): String;
//--------------------------------------------------------------
//Created: 05 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	return 'bgpAutoViewProcessPTIExpired';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueForRow" id="f16d0181-ad06-480d-aa19-835cafd49171">
        <source>getValueForRow(_rowName: String; _obj : Object output): Any;
//--------------------------------------------------------------
//Created: 10 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if _rowName = ETRow_ToDoTaskDesc then
		if global.isValidObject(self.myToDoTaskDesc) then
			return self.myToDoTaskDesc.code.String &amp; ' ' &amp; self.myToDoTaskDesc.CM_ToDoTaskDesc.description;
		endif;
	endif;
	
	return inheritMethod(_rowName, _obj);

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_obj" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="e0db02f3-ffd6-491b-80a7-b6e1344b150b">
        <source>pxyCreateUpdateProxy(): SelfType;

// cnwdvb1 19 June 2003 
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars

	task : CM_AutoTaskPTIExpired;
	completedOK		: Boolean;
	
begin
	
	task := inheritMethod();
	task.myToDoTaskDesc := self.myToDoTaskDesc;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return task;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete task;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="ca0b32dd-a82f-4c7c-865a-d0f631648d29">
        <updating/>
        <source>setForCreate(_pxyAutoTask: CM_AutoTaskPTIExpired) updating;
//--------------------------------------------------------------
//Created: 05 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_pxyAutoTask);
	self.requestClassName := BGP_AutoProcessExpiredPTI.name;
	self.myToDoTaskDesc := _pxyAutoTask.myToDoTaskDesc;
end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskPTIExpired"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="d5b3d472-8c8a-4bec-a779-3717df383fe4">
        <updating/>
        <source>setForUpdate(_pxyAutoTask: CM_AutoTaskPTIExpired) updating;
//--------------------------------------------------------------
//Created: 10 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_pxyAutoTask);
	self.myToDoTaskDesc := _pxyAutoTask.myToDoTaskDesc;
end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskPTIExpired"/>
    </JadeMethod>
    <JadeMethod name="setValueForRow" id="bf6623f9-307e-4796-a844-ca2b62411210">
        <updating/>
        <source>setValueForRow(_rowName: String; _value: Any) updating;
//--------------------------------------------------------------
//Created: 10 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if _rowName = ETRow_ToDoTaskDesc then
		self.myToDoTaskDesc := _value.CM_ToDoTaskDesc;
	else
		inheritMethod(_rowName, _value);
	endif;

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validate" id="d58e2b0f-b484-4417-9c02-800731664cbe">
        <source>validate();
//--------------------------------------------------------------
//Created: 10 June 2003 By: cnwgd1
//--------------------------------------------------------------
// 15/12/2014  cnwdb2	PAR 35364

vars

begin
	inheritMethod();
	if self.myToDoTaskDesc = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'To Do Task Description', ETRow_ToDoTaskDesc, null);
		app.raiseCMException(Input_required_field_ToDo, ETRow_ToDoTaskDesc, null); // cnwdb2	PAR 35364

	endif;
	
	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', ETRow_BgpAutoTerminals, null);
		app.raiseCMException(Input_required_field_terminal, ETRow_BgpAutoTerminals, null); // cnwdb2	PAR 35364


	endif;
end;</source>
    </JadeMethod>
</Class>
