    <JadeMethod name="valBOL" id="5c3d68ce-b68d-4579-9bbe-654896a4b614">
        <source>valBOL(pProxyBOL : CM_BOL input;  _headerOnly: Boolean; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 25 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	updCntrl	: CMIF_TIUpdateController;
begin
	self.raiseExceptionIfNull(pProxyBOL, 'Docket/Bill of Lading Proxy');
	pProxyBOL.raiseExceptionIfNotProxy(method);
	
	updCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, null, null);	
	pProxyBOL.validateForUpdate(updCntrl, _headerOnly, _passport);
	
epilog
	if updCntrl &lt;&gt; null then
		delete updCntrl;
	endif;
	
end;</source>
        <Parameter name="pProxyBOL" type="CM_BOL" usage="input"/>
        <Parameter name="_headerOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
