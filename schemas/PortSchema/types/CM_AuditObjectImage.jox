    <JadeMethod name="createPropertyImages" id="20e399f4-0942-4497-8410-3e6ee02ea615">
        <source>createPropertyImages( _auditText : String );

/*

Purpose:		This method will take the supplied string (delimited with the AuditStringSeparator ie ^ character)
				and create CM_AuditPropertyImage instances in the allPropertyImages collection.

Date				Who		Reason
19 May 2009			cnwrl1	Initial creation as part of PAR 19668 - CCMS 1814

*/
	
vars
	text			: String;
	propName		: String;
	propValue		: String;
	tmpSeparator	: String;
	index			: Integer;
	len				: Integer;
	propImage		: CM_AuditPropertyImage;
	
begin
	self.allPropertyImages.purge;
	
	text	:= _auditText;
	if text = null then
		return;
	endif;
	
	tmpSeparator := AuditStringSeparator;
	
	index	:= 1;
	len		:= text.length;
	
	while index &lt; len do : text_loop
		if not self.getPropertyNameAndValue( text, index, propName, propValue, tmpSeparator ) then
			continue text_loop;
		endif;
		if self.allPropertyImages[ propName ] &lt;&gt; null then
			continue text_loop;
		endif;
		create propImage transient;
		propImage.updateForCreate( propName, propValue, null, self );
	endwhile text_loop;
	
epilog
	
end;
</source>
        <Parameter name="_auditText" type="String"/>
    </JadeMethod>
    <JadeMethod name="delete" id="e8d91f9a-b02e-4360-bc97-2394facf02c0">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     12 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.allPropertyImages.size &gt; 0 then
		self.allPropertyImages.purge;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="a95fb183-992f-481f-b391-b739b36fe1e5">
        <source>getAuditText(auditText, postAuditText : String output);
// ---------------------------------------------------------------------------
// Created:     12 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	api : CM_AuditPropertyImage;
	audType : Integer;
		
begin
	auditText := null;
	postAuditText := null;

	if self.allPropertyImages.isEmpty then
		return;
	endif;	

	audType := self.auditType;
		
	foreach api in self.allPropertyImages do
		if audType = AuditCreated or audType = AuditDeleted then
			auditText := auditText &amp; api.name &amp; AuditStringSeparator &amp; 
						api.afterValue.length.String &amp; AuditStringSeparator &amp; 
						api.afterValue &amp; AuditStringSeparator;
		elseif audType = AuditUpdated then
			if api.beforeValue &lt;&gt; api.afterValue then
				auditText := auditText &amp; api.name &amp; AuditStringSeparator &amp; 
							api.beforeValue.length.String &amp; AuditStringSeparator &amp; 
							api.beforeValue &amp; AuditStringSeparator;
				postAuditText := postAuditText &amp; api.name &amp; AuditStringSeparator &amp; 
							api.afterValue.length.String &amp; AuditStringSeparator &amp; 
							api.afterValue &amp; AuditStringSeparator;
			endif;
		endif;
	endforeach;
end;</source>
        <Parameter name="auditText" type="String" usage="output"/>
        <Parameter name="postAuditText" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getCallerContextString" id="43fd78bd-4ebb-4797-9d53-abdd07eb4eaf">
        <source>getCallerContextString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 April 2019	jlgndl1	Initial creation	TFS 44140

*/

vars

	image : CM_AuditPropertyImage;

begin

	if self.allPropertyImages = null or self.allPropertyImages.isEmpty then
		return null;
	endif;

	image := self.allPropertyImages.getAtKey(CM_AuditObject.CallingFormContext);
	if image = null then
		return null;
	endif;
	
	return	image.name &amp; AuditStringSeparator &amp;  
			image.afterValue.length.String &amp; AuditStringSeparator &amp; 
			image.afterValue &amp; AuditStringSeparator;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPropertyNameAndValue" id="3408cd27-6505-4a66-8685-df605839859e">
        <source>getPropertyNameAndValue(auditText : String; fromPos : Integer io;
	propName, propValue : String output;
	_separator : String io) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     12 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 03 Apr 2009	cnwkpd1		PAR #19375 - Ensure property name returned not longer
//							than the allowable 60 characters
// ---------------------------------------------------------------------------
vars
	p, dataLen : Integer;
	
begin
	propName := null;
	propValue := null;

	if auditText = null then
		return false;
	endif;
	
	if fromPos &lt; 1 then
		fromPos := 1;
	endif;

	if fromPos &gt; auditText.length then
		return false;
	endif;

	// text format is propName:length:data:propName:length:data: etc
	p := auditText.pos(_separator, fromPos);
	if p &lt; fromPos then
		if _separator = AuditStringSeparator then
			// try with the old separator as some old data still has this
			_separator := ":";
			p := auditText.pos(_separator, fromPos);
			if p &lt; fromPos then
				_separator := AuditStringSeparator;
				fromPos:=fromPos+1;
				return false;
			endif;
		else
			return false;
		endif;
	endif;
	propName := auditText[fromPos : p - fromPos].truncatedAt(60);		// PAR #19375
	
	fromPos := p + 1;
	
	p := auditText.pos(_separator, fromPos);
	if p &lt; fromPos then
		return false;
	endif;
	dataLen := auditText[fromPos : p - 1].Integer;
	if dataLen &lt; 1 then
		return false;
	endif;

	propValue := auditText[p + 1 : dataLen];
	fromPos := p + dataLen + 2;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="auditText" type="String"/>
        <Parameter name="fromPos" type="Integer" usage="io"/>
        <Parameter name="propName" type="String" usage="output"/>
        <Parameter name="propValue" type="String" usage="output"/>
        <Parameter name="_separator" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasPropertyImages" id="8da3cf9d-e6e8-4a0b-b7bc-156594308874">
        <source>hasPropertyImages() : Boolean;
// ---------------------------------------------------------------------------
// Created:     12 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	return self.allPropertyImages.size &gt; 0;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="ab022704-c62e-47fc-a289-b51e7999a691">
        <updating/>
        <source>initialise(subj : CM_Object; type : Integer; aud : CM_AuditObject;
	auditText, postAuditText : String) updating;
// ---------------------------------------------------------------------------
// Created:     12 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	txt, propName, propValue : String;
	i, len : Integer;
	propImage : CM_AuditPropertyImage;
	tmpSeparator	: String;
	
begin
	self.allPropertyImages.purge;
	
	if subj = null then
		self.subjectOidString := "0.0";
		self.subjectIdString := null;
	else
		self.subjectOidString := getOidStringForObject(subj);
		self.subjectIdString := subj.auditIdDisplay;
	endif;
	
	self.auditType := type;
	self.myAuditObject := aud;

	txt := auditText;
	if txt = null then
		return;
	endif;


	tmpSeparator := AuditStringSeparator;
	
	i := 1;	
	len := txt.length;
	
	while i &lt; len do
		if self.getPropertyNameAndValue(txt, i, propName, propValue, tmpSeparator) then
			if self.allPropertyImages[propName] = null then
				create propImage transient;
				if type = AuditUpdated then
				
					propImage.updateForCreate(propName, propValue, null, self);
				else
					propImage.updateForCreate(propName, null, propValue, self);
				endif;
			endif;
		endif;
	endwhile;
	
	if type &lt;&gt; AuditUpdated then
		return;
	endif;

	txt := postAuditText;
	if txt = null then
		return;
	endif;
	
	i := 1;
	len := txt.length;

	while i &lt; len do
		if self.getPropertyNameAndValue(txt, i, propName, propValue, tmpSeparator) then
			propImage := self.allPropertyImages[propName];
			if propImage &lt;&gt; null then
				propImage.updateAfterValue(propValue);
			else
				create propImage transient;
				propImage.updateForCreate(propName, null, propValue, self);
			endif;
		endif;
	endwhile;
end;</source>
        <Parameter name="subj" type="CM_Object"/>
        <Parameter name="type" type="Integer"/>
        <Parameter name="aud" type="CM_AuditObject"/>
        <Parameter name="auditText" type="String"/>
        <Parameter name="postAuditText" type="String"/>
    </JadeMethod>
    <JadeMethod name="initialiseFromAudit" id="88e4c647-1442-4d24-ac31-3a1d233a1b7e">
        <updating/>
        <source>initialiseFromAudit(aud : CM_AuditObject) updating;
// ---------------------------------------------------------------------------
// Created:     12 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if aud = null then
		self.allPropertyImages.purge;
		self.auditType := 0;
		self.myAuditObject := null;
		return;
	endif;

	self.initialise(null, aud.type, aud, aud.auditText, aud.postAuditText);
	
end;</source>
        <Parameter name="aud" type="CM_AuditObject"/>
    </JadeMethod>
</Class>
