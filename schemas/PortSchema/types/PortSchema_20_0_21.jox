    <JadeMethod name="convertMeasurementPrecision" id="0b2ff6ed-aa18-422b-a9c5-e9165b54ce75">
        <source>convertMeasurementPrecision(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Nov 2022	navma1	ChangeRequest 55381: MTN - Store format's decimal precision on Measurement Type
*/

vars
	measurementType : CM_MeasurementType;
	root 		: CM_Root;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Storing decimal precision on Measurement Type ", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Storing decimal precision on Measurement Type") ;	
	endif;
	
	root := app.myRoot;
	
	beginTransaction;
	
	foreach measurementType in root.allMeasurementTypesByShortName discreteLock do
		measurementType.setFormatPrecision(measurementType.calculateFormatPrecision(measurementType.format));
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Storing decimal precision on Measurement Type complete", LogINFO);
	
	if _controller &lt;&gt; null then
		_controller.logEntry(" Storing decimal precision on Measurement Type complete") ;	
	endif;
	
	self.addScriptRun(method.name);
	
	
epilog

end;</source>
