Return Value:		

Date		Who		Reason
16 June 2025	navpw1	Initial creation

*/

vars
	scmName,
	className,
	methodName	: String;
	mth			: Method;
	txt			: String;
	
begin
	scmName		:= "JMTUnitTest";
	className	:= "UT_CargoType";
	methodName	:= "tSysCargoTypeQuantityCheck";

	mth := rootSchema.getSchema(scmName).getClass(className).getMethod(methodName);
	write mth.text;

	read txt;

	beginTransaction;
	mth.cnEcSetText(txt);
	commitTransaction;

	write mth.text;
	
end;</source>
