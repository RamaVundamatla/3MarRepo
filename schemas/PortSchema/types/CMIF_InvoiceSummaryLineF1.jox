    <JadeMethod name="getChargeByValueString" id="cb2ad1f3-0250-4019-81bd-6e23d2fe8a65">
        <source>getChargeByValueString( _invLine : CM_InvoiceLine ):String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2017	jlgndl1	Initial creation	TFS 5799

*/

vars

	calcType : CM_CalculationType;

begin

	if _invLine &lt;&gt; null then
		calcType := _invLine.getCalcType;
	endif;
	
	if calcType &lt;&gt; null then
		if calcType.calculationType = INV_CALC_TYPE_UNITY then	//if calcType.description = "Value of 1" then
			return "QTY";
		elseif calcType.calculationType = INV_CALC_TYPE_REVENUE_TONS then	//elseif calcType.description = "Revenue Tonnes" then
			return "REV";
		elseif calcType.calculationType = INV_CALC_TYPE_VOLUME then	//elseif calcType.description = "Cargo Volume" then
			return "VOL";
		endif;
	endif;
	
	return null;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_invLine" type="CM_InvoiceLine"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGroupString" id="daed3190-f21a-4ef3-be15-dfbef19143eb">
        <source>getGroupString( _ti : CM_TrackedItem; _tiTrx : CM_TITransaction ):String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 August 2017	jlgndl1	Initial creation	TFS 5799

*/

vars

	loadPort2 : String;

begin

	if _ti.getImExStatus = TI_IMEX_STATUS_TRANSHIP then
		return "TRANSHIP";
	endif;
	
	if self.operatorCode = "WWL" then
		if _ti.getImExStatus = TI_IMEX_STATUS_EXPORT then
			return "OCEANIA";
		endif;
	
		loadPort2 := _ti.loadPort[1:2];
		if loadPort2 = "AU" or loadPort2 = "NZ" then
			return "OCEANIA";
		endif;
	
	endif;
	
	if _ti.getImExStatus = TI_IMEX_STATUS_EXPORT then
		return "EXPORTS";
	endif;
	if _ti.getImExStatus = TI_IMEX_STATUS_IMPORT then
		return "IMPORTS";
	endif;
	
	return "***UNKNOWN***";

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHookString" id="b196294d-ad03-4f55-83bd-dee92494ab2c">
        <source>getHookString( _ti : CM_TrackedItem; _tiTrx : CM_TITransaction ):String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 August 2017	jlgndl1	Initial creation	TFS 5799

*/

vars

begin

	if self.myFacInvLine &lt;&gt; null then
		if self.myFacInvLine.usesGLCode('4180') then
			return "Y";
		endif;
		if self.myFacInvLine.usesGLCode('4181') then
			return "Y";
		endif;
		if self.myFacInvLine.usesGLCode('4213') then
			return "Y";
		endif;
		if self.myFacInvLine.usesGLCode('4214') then
			return "Y";
		endif;
	endif;
	
	if self.mySacInvLine &lt;&gt; null then
		if self.mySacInvLine.usesGLCode('4180') then
			return "Y";
		endif;
		if self.mySacInvLine.usesGLCode('4181') then
			return "Y";
		endif;
		if self.mySacInvLine.usesGLCode('4213') then
			return "Y";
		endif;
		if self.mySacInvLine.usesGLCode('4214') then
			return "Y";
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="String"/>
