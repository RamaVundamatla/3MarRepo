    <JadeMethod name="validateForDelete" id="7fd65d8e-ea3a-4659-a0f0-d4dcf3247820">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	
	if not self.brokers.isEmpty() then
		app.raiseCMException2(ERR_CANNOT_DELETE_BANK," Service " &amp; self.name," It is in use in the Transaction Map.",null,null);
	endif;
	
	if not self.charges.isEmpty() then
		app.raiseCMException2(ERR_CANNOT_DELETE_BANK," Service " &amp; self.name," It has charges.",null,null);
	endif;
	
end;</source>
    </JadeMethod>
