    <JadeMethod name="displaySelectorCargoItem" id="6910c390-7798-469d-9ad9-fb1ecbe476c6">
        <updating/>
        <source>displaySelectorCargoItem(_ti: CM_TrackedItem) updating;
//03 July 2015	cnwma1	PAR #36555 CCMS 2509 TFS - Multi-location selection for MTs for vessel release
vars
	theReturn	: Integer;
	msg			: String;
begin
	if _ti = null then
		return;
	endif;
	msg := app.getErrorString2(Add_cargo_to_request, _ti.id, self.myDeliveryRequest.deliveryNumber) &amp; CrLf;
	// show differences ** todo XL and complete
	if _ti.getISOType &lt;&gt; self.myDeliveryRequest.isoType then
		msg := msg &amp; "Request ISO Type is " &amp; self.myDeliveryRequest.isoType &amp; " cargo " &amp; _ti.getISOType;
	endif;
	
	theReturn := app.msgBox(msg, app.getErrorString(Cargo_ADD), MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second);
	
	if theReturn = MsgBox_Return_No then
		return;
	endif;
	
	self.myAssignedTrackedItem := _ti;
	self.txtAssignCargo.text := _ti.id;
	self.lblSrcLocn.visible := false;
	self.txtYardSource.visible :=false;  // 03/07/2015 cnwma1 PAR #36555
	self.cmbSourceLocn.visible := false;
	self.lblAssignCargo.visible := true;
	self.txtAssignCargo.visible := true;
	
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="displaySelectorGridObject" id="5c4b664c-0fc8-4df6-925f-09f7b66d7478">
        <updating/>
        <source>displaySelectorGridObject(_gridObject: CM_GridObject) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2011	cnwrd1	Initial creation
03 July 	2015	cnwma1	PAR #36555 CCMS 2509 TFS - Multi-location selection for MTs for vessel release
*/

vars
	aGO : CM_GridObject;
	aTA : CM_TerminalArea;
begin
	aGO :=_gridObject;
	if aGO &lt;&gt; null then
		aTA := aGO.getGridArea;
		
		self.allSelectedTAs.add(aTA);
		self.allSelectedTAGridObjs.add(aGO);		
		self.txtYardSource.caption := self.truncateDisplayString(self.getYardSourceText(),100);
	
		self.myAssignedTrackedItem := null;
		self.lblAssignCargo.visible := false;
		self.txtAssignCargo.visible := false;
		self.lblSrcLocn.visible := true;
		//self.cmbSourceLocn.visible := true;  	// 03/07/2015 cnwma1 PAR #36555
	endif;

epilog

end;</source>
        <Parameter name="_gridObject" type="CM_GridObject"/>
    </JadeMethod>
    <JadeMethod name="displaySelectorLocation" id="550b4a17-2b30-47cb-9b2b-c5ca9cfec1ad">
        <updating/>
        <source>displaySelectorLocation(_termArea: CM_TerminalArea) updating;
//03 July 2015	cnwma1	PAR #36555 CCMS 2509 TFS - Multi-location selection for MTs for vessel release
vars

begin
	if _termArea &lt;&gt; null then
		//cmbSourceLocn.cnEcSetObjectIndex(_termArea);            // 03/07/2015 cnwma1 PAR #36555
		self.myAssignedTrackedItem := null;
		self.lblAssignCargo.visible := false;
		self.txtAssignCargo.visible := false;
		self.lblSrcLocn.visible := true;
		self.cmbSourceLocn.visible := false;						// 03/07/2015 cnwma1 PAR #36555
		if not self.allSelectedTAs.includes(_termArea) then			// 03/07/2015 cnwma1 PAR #36555
			self.allSelectedTAs.add(_termArea);
		endif;
		self.txtYardSource.caption :=  self.truncateDisplayString(self.getYardSourceText(),100);
	endif;

end;
</source>
        <Parameter name="_termArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="doAssignTI" id="55a466af-a86d-42be-903d-ac36be038a71">
        <updating/>
        <source>doAssignTI() updating, protected;

vars

	result : Integer;
	moveController : CMIF_MoveController;
	wle		: CM_WorkListEntry;
begin

	wle := self.myCurrentWLE;
	if wle = null then
		return;
	else
		sharedLock(wle);
	endif;

	create moveController transient;
	moveController.setMyToPrimaryLocation(self.getLocationController);
	moveController.setMyWorkListEntry(wle);
	moveController.setMyTrackedItem(self.myAssignedTrackedItem);
	moveController.setMoveMode(REAL_MODE);

	while true do
		app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);	
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Assign To Release', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;
	
epilog
	if wle &lt;&gt; null then
		unlock(wle);
	endif;
	delete moveController;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="402be75b-0644-4cd0-96a7-8de1049fb0ad">
        <updating/>
        <source>doSave() updating;
//03 July 2015	cnwma1	PAR #36555 CCMS 2509 TFS - Multi-location selection for MTs for vessel release
vars
	isoGroup	: String;
	isoType		: String;
	remarks		: String;
	mask		: String;
	doorForward,
	heavy		: Boolean;
	theReturn	: Integer;
	aveGrades	: IntegerArray;
	obj			: Object;
	pxyRequest 	: CM_DeliveryRequest;
	wle			: CM_WorkListEntry;
	wleArray 		: CM_WLEArray;
begin

	if self.myDeliveryRequest = null then
		return;
	endif;
	
	//  all fields are optional except that at least one of ISO Group and ISO Type must be entered.
	//  Advanced source location has preference over combo source location.
	if self.cmbISOGroup.listObject = null and self.cmbISOType.listObject = null then
		app.msgBox(app.getErrorString(MustEnter_ISO_Type_AndOr_Group), app.getErrorString(Required_Fields), MsgBox_OK_Only + MsgBox_Information_Icon);
		self.cmbISOType.setFocus();
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	pxyRequest := app.createUpdateProxy(self.myDeliveryRequest).CM_DeliveryRequest;	
	
	create aveGrades transient;
	foreach obj in self.lstAvailGrade.allSelectedObjects do
		aveGrades.add(obj.CM_MTGrade.code);
	endforeach;
	create wleArray transient;
	
	if not self.allWLEs.isEmpty then // cnwrd1 par 31069 22.2.2013
		self.allWLEs.copy ( wleArray );
	else
		self.myDeliveryRequest.allWorkListEntries.copy (wleArray);
	endif;
	
	if self.allSelectedTAs.isEmpty()  then
	//and cmbSourceLocn.listObject &lt;&gt; null                                  // 07/07/2015 cnwma1 PAR #36555
		//self.allSelectedTAs.add(cmbSourceLocn.listObject.CM_TerminalArea);  // 07/07/2015 cnwma1 PAR #36555
		self.allSelectedTAGridObjs.add(null);
	endif;
	remarks := self.txtRemarks.text;
	mask := self.txtMask.text;
	doorForward := self.chkDoorsForward.value;
	heavy := self.chkHeavyDuty.value;
	obj := self.cmbISOGroup.listObject;
	if obj &lt;&gt; null then
		isoGroup := obj.CM_ISOTypeGroup.code;
	endif;
	obj := self.cmbISOType.listObject;
	if obj &lt;&gt; null then
		isoType := obj.CM_ISOType.code;
	endif;

	pxyRequest.setProxyAdditionalInfo(false, false, doorForward, heavy, mask, aveGrades);
	pxyRequest.setRemarks(remarks);
	pxyRequest.isoType := isoType;
	pxyRequest.setIsoGroup(isoGroup);

	while true do
		app.myTrxUA.trxUpdateRequestDetails(pxyRequest, wleArray, self.allSelectedTAs, self.allSelectedTAGridObjs, self.isBestPick, self.isFIFO, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else			
			theReturn := app.showErrorWarningDialog('Edit Request', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	
	if self.myAssignedTrackedItem &lt;&gt; null then
		self.doAssignTI();
	endif;

	self.unloadForm();
epilog
	delete pxyRequest;
	delete aveGrades;
	delete wleArray;
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="getLocationController" id="999f97e1-3776-4915-8efb-4dbcee7d6201">
        <source>getLocationController() : CM_LocationsController protected;

vars

begin
	if self.myCurrentWLE &lt;&gt; null then
		// road
		if self.myCurrentWLE.job.isKindOf(CM_RoadJob) then
			return self.myCurrentWLE.getRoadReleaseLC();
		// rail
		elseif CM_YardWLE.hasInstance(self.myCurrentWLE) and not self.myCurrentWLE.CM_YardWLE.allLocationControllers.isEmpty then
			return self.myCurrentWLE.CM_YardWLE.allLocationControllers.first;
		endif;
	endif;
	return null;

end;</source>
        <access>protected</access>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getYardSourceText" id="d7f68b5c-f6a4-41c9-bcd6-c9159ed2eb5e">
        <source>getYardSourceText() : String protected;
// show source locations and options from CMUI_SelectISOSourceMulti
vars
	ta 		: CM_TerminalArea;
	aGO		: CM_GridObject;
	sep 	: String;
	result 	: String;
	count	: Integer;
begin	

	count := 1;
	foreach ta in self.allSelectedTAs do
		if self.allSelectedTAGridObjs &lt;&gt; null and self.allSelectedTAGridObjs.size &gt;= count then
			aGO := self.allSelectedTAGridObjs[count];
		else
			aGO := null;
		endif;
			
		if aGO = null then
			result := result &amp; sep &amp; ta.id;
		else
			result := result &amp; sep &amp; ta.id &amp; '(' &amp; aGO.label &amp; ')';
		endif;
		
		sep := ', ';
		count := count +1;
	endforeach;
	
	/*if self.isBestPick and
	   result &lt;&gt; "" then
		result := result &amp; " (" &amp; app.getErrorString(Best_pick) &amp; ")";
	endif;*/
	
	return result;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="375af9ef-aaa9-42b0-b14b-b22f3ea9f698">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// populate form from selected delivery request
//03 July 2015	cnwma1	PAR #36555 CCMS 2509 TFS - Multi-location selection for MTs for vessel release
vars
	canEdit	: Boolean;
	isoType,
	str			: String;
begin
	self.isSelectorCapable := true;
	isoType := self.myDeliveryRequest.isoType.trimRight;
	if isoType = null then
		isoType := self.myDeliveryRequest.isoGroup.trimRight;
	endif;
	
	if self.myDeliveryRequest.allTerminalAreas.size &gt; 0 then			// 07/07/2015 cnwma1 PAR #36555
		self.myDeliveryRequest.allTerminalAreas.copy(self.allSelectedTAs);
		if self.myDeliveryRequest.allTerminalAreaGridObj.size &gt; 0 then			// 07/07/2015 cnwma1 PAR #36555
			self.myDeliveryRequest.allTerminalAreaGridObj.copy(self.allSelectedTAGridObjs);
		endif;
		self.txtYardSource.caption := self.truncateDisplayString(getYardSourceText(),100);
	endif;
	
	str := app.getErrorString4(DeliveryRequestInfo,
							   self.myDeliveryRequest.deliveryNumber,
							   self.myDeliveryRequest.totalRequested.String,
							   isoType,
							   self.myDeliveryRequest.consigneeCode);
	if self.myDeliveryRequest.myOriginatingBulkRelease &lt;&gt; null and 
	   self.myDeliveryRequest.myOriginatingBulkRelease.canBeHiLoCube then
		str := str	&amp; " " &amp; app.getErrorString(CanBeHiLowCube) &amp; ".";
	endif;
	self.lblRequestDesc.caption := str;
	
	self.txtRemarks.text := self.myDeliveryRequest.remarks;
	self.myAssistant.listTableMTGrade(lstAvailGrade, null, null);	
	self.myAssistant.setListTableMTGrade(self.lstAvailGrade, self.myDeliveryRequest.allAvailabilityGrades);
	self.chkDoorsForward.value := self.myDeliveryRequest.doorsForward;
	self.chkHeavyDuty.value := self.myDeliveryRequest.heavyRated;
	self.txtMask.text := self.myDeliveryRequest.getIdsAsString;
	self.myAssistant.comboBoxSourceArea2(self.cmbSourceLocn, self.myDeliveryRequest.allTerminalAreas.first, false, false);
	self.myAssistant.comboBoxISOTypeGroup(self.cmbISOGroup, app.myRoot.allISOTypeGroups[self.myDeliveryRequest.isoGroup]);
	self.cmbISOType.setObject(app.myRoot.allISOTypes[self.myDeliveryRequest.isoType.trimBlanks()]);
	// require permission to edit many of the fields
	//canEdit := app.getMyUser.canDo(self.myTerminal, PmYardEditRelReq);
	canEdit := true;
	self.cmbISOGroup.enabled := canEdit;
	self.cmbISOType.enabled := canEdit;
	self.chkHeavyDuty.enabled := canEdit;
	self.lstAvailGrade.enabled := canEdit;
	self.txtMask.enabled := canEdit;
	self.txtRemarks.enabled := canEdit;
	
	self.caption := app.getErrorString(Edit_Request) &amp; " " &amp; self.myDeliveryRequest.deliveryNumber &amp; " " &amp; self.myTerminal.code;
	
	self.cmbSourceLocn.setFocus();
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="lstAvailGrade_displayRow" id="97f840c8-fead-4773-8cad-af2dbfc3e6b4">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstAvailGrade_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;

vars
	selected	: Boolean;
begin

	selected := table.CMUI_ListTable.allSelectedObjects.includes(obj);
	return self.myAssistant.displayEntryMTGradeList(obj.CM_MTGrade, selected);

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="selectISOSource" id="b4440be9-5625-41d4-b24e-bc564ae8952d">
        <updating/>
        <source>selectISOSource()updating, protected;
// called from Advanced button to get CMUI_SelectISOSourceMulti form
//01 July 2015	cnwma1	PAR #36555 CCMS 2509 TFS - Multi-location selection for MTs for vessel release
vars
	sourceForm	: CMUI_SelectISOSourceMulti;
begin
	
	sourceForm := app.loadForm(CMUI_SelectISOSourceMulti, CMUI_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction).CMUI_SelectISOSourceMulti;
	sourceForm.centreWindow;
	sourceForm.setMyTerminal(self.myTerminal);
	// keep the sourceForm.allWLEs collection empty so that CMUI_SelectISOSourceMulti will not do the save, as it needs to be
	//  done from here
	sourceForm.myDeliveryRequest := self.myDeliveryRequest;
	sourceForm.setSelectedValues(self.allSelectedTAs,self.allSelectedTAGridObjs,  self.isFIFO, self.isBestPick); //grid objects

	sourceForm.showModal;

	if sourceForm.modalDialogReturnValue &lt;&gt; ModalDialogReturn_Default then		// Cancel button pressed
		return;
	endif;
	
	// save the result
	self.allSelectedTAs.clear();
	//sourceForm.mltTermAreas.getSelected(self.allSelectedTAs); 
	sourceForm.getAreasWithGridObjs( self.allSelectedTAs, self.allSelectedTAGridObjs);
	self.isFIFO := sourceForm.optFIFO.value;	
	self.isBestPick := sourceForm.chkBestPick.value;

	//self.txtYardSource.caption := self.getYardSourceText();   						 // 07/07/2015 cnwma1 PAR #36555
	self.txtYardSource.caption := self.truncateDisplayString(getYardSourceText(),100);   // 07/07/2015 cnwma1 PAR #36555
	
epilog
	delete sourceForm;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showSelectorForm" id="c035e472-8329-4f8d-b0ff-ec04d98002ea">
        <updating/>
        <source>showSelectorForm() updating, protected;
// called from Selector button to call the selector form pre-populated from the main screen values
vars
	heavy			: Boolean;
	str				: String;
	obj				: Object;
	assoc,
	assoc2			: CM_Association;
	theSelector		: CMUI_Selector;
	critLine		: CM_SelectorCriteriaLine;
	request : CM_Request;	//25 Jun 2015	NDL	Par 36525
	byTypeCriteria : CM_ReleaseByTypeCriteria;	//25 Jun 2015	NDL	Par 36525
	skipHeavy : Boolean;	//25 Jun 2015	NDL	Par 36525
	
begin
	
	if self.mySelectorForm &lt;&gt; null then
		theSelector := self.mySelectorForm;
	else
		theSelector := app.loadForm(CMUI_Selector, null, false, false, true, self.myTerminal, self.myMasterMenuAction).CMUI_Selector;
		if theSelector = null then
			return;
		endif;
		theSelector.myParent := self;
	endif;
	
	theSelector.myTerminal := self.myTerminal;
	theSelector.myEnquiryCollectionClass := CM_TIArray;
	theSelector.defaultSiteStr := TI_SITE_ONSITE_str;

	theSelector.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, TI_CargoType_Container];
	theSelector.disableMnuEnquiry := false;
	theSelector.enableSendCargoMenu(self.caption);
	theSelector.enableSendLocationMenu(self.caption);
	theSelector.enableSendGridObjMenu(self.caption);

	obj := self.cmbISOType.listObject;
	if obj &lt;&gt; null then
		theSelector.addDefaultPropertyLine("isoType", CM_QueryOperator.Operator_Equal, obj);
	endif;

	obj := self.cmbISOGroup.listObject;
	if obj &lt;&gt; null then
		theSelector.addDefaultPropertyLine("isoGroup", CM_QueryOperator.Operator_Equal, obj);
	endif;
	
	//25 Jun 2015	NDL	Par 36525
	if self.myCurrentWLE &lt;&gt; null then
		request := self.myCurrentWLE.myRequest;
		byTypeCriteria := request.getReserveSelectionCriteria();
		if byTypeCriteria &lt;&gt; null then
			skipHeavy := byTypeCriteria.includesCriteriaFor(YACriteriaType_HeavyDuty);
		endif;
	endif;

		//25 Jun 2015	NDL	Par 36525
	if skipHeavy then
		// will use the one we found in the extra criteria on the release 
	else
		heavy := self.chkHeavyDuty.value;
		if heavy then
			str := "Yes";
		else
			str := "No";
		endif;	
		create assoc transient;
		assoc.setValue(str);
		theSelector.addDefaultPropertyLine("isHeavyDuty", CM_QueryOperator.Operator_Equal, assoc);
	endif;

	assoc := null;
	foreach obj in self.lstAvailGrade.allSelectedObjects do
		if assoc  = null then
			create assoc transient;
		endif;
		create assoc2 transient;
		assoc2.setValue(obj.CM_MTGrade.code);
		assoc.objectArray.add(assoc2);
	endforeach;
	if assoc &lt;&gt; null then
		theSelector.addDefaultPropertyLine("availabilityGrade", CM_QueryOperator.Operator_IsOneOf, assoc);
	endif;
	
	//25 Jun 2015	NDL	Par 36525
	if byTypeCriteria &lt;&gt; null then
		theSelector.addYACriteriaToSelector( byTypeCriteria.allCriteria, CM_Container.name);
	endif;

	theSelector.show;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="92a95a6a-bf9c-46dc-978a-d62e7b8f0031">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:42:48.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016156, locale);
	btnAdvanced.translateCaption(Xlat_0023289, locale);
	btnCancel.translateCaption(Xlat_0023287, locale);
	btnSave.translateCaption(Xlat_0023288, locale);
	btnSelector.translateCaption(Xlat_0023290, locale);
	lblAssignCargo.translateCaption(Xlat_0023286, locale);
	lblAvailGrade.translateCaption(Xlat_0016162, locale);
	lblBase.translateCaption(Xlat_0016163, locale);
	lblDoors.translateCaption(Xlat_0016164, locale);
	lblHeavyDuty.translateCaption(Xlat_0016165, locale);
	lblISOGroup.translateCaption(Xlat_0016166, locale);
	lblISOType.translateCaption(Xlat_0016167, locale);
	lblMask.translateCaption(Xlat_0016168, locale);
	lblRemarks.translateCaption(Xlat_0016169, locale);
	lblSrcLocn.translateCaption(Xlat_0023291, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="truncateDisplayString" id="05c51f95-12b8-42d6-9069-b4d8997d7664">
        <source>truncateDisplayString(_text : String; _maxLen : Integer ) : String protected;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2015	cnwma1	Initial creation

*/

constants
	MaxLen = 30;
vars
	maxLen : Integer;
begin
	if _maxLen = -1 then 
		maxLen := MaxLen;
	else
		maxLen := _maxLen;
	endif;
	
	if _text.length &gt; maxLen then
		return _text[1:maxLen-1]&amp; '...';
	else
		return _text;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_text" type="String"/>
        <Parameter name="_maxLen" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
</GUIClass>
