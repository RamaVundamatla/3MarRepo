    <JadeMethod name="btnRemDate_click" id="837b8f38-7a33-456e-806d-72ae8389d65e">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnRemDate_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 October 2010	cnwndl1	Initial creation

*/

vars
	
	obj : Object;
	tempCalendarDate : CM_CalendarDate;
	
begin

	if not self.tblDayData.allSelectedObjects.isEmpty then
		foreach obj in self.tblDayData.allSelectedObjects do
			if obj.isKindOf(CM_CalendarDate) then
				tempCalendarDate := obj.CM_CalendarDate;
				if self.allTransCalendarDates.includes(tempCalendarDate) then
					self.allTransCalendarDates.remove(tempCalendarDate);
				endif;
				delete tempCalendarDate;
			endif;
		endforeach;
	endif;
	
	self.populateTblDayData();

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
