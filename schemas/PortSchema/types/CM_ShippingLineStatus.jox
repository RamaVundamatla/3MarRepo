    <JadeMethod name="validateForUpdate" id="2ac7fee0-4cb9-4cb1-9cea-070d10df8fa4">
        <source>validateForUpdate();
//08/08/2023	navkc1	CR 59580	Task 59586: Jade - CustDocs Shipping Line Status TRX
vars

