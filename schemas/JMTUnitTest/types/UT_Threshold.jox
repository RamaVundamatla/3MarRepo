    <JadeMethod name="addStopsForThresholdTest" id="898a86d5-1d78-4f9a-9bda-821e93a38e29">
        <source>addStopsForThresholdTest(): CM_StopsTable protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars
	
	selectedTypes: CM_CargoBOLTypeSet;
	stopsTable: CM_StopsTable;
	processAreas: IntegerArray;
	opts: CM_AssociationDict;
	
begin
	
	deleteStopsTable(997);

	// Create a Stop Type
	create selectedTypes transient;
	selectedTypes.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	create processAreas transient;
	processAreas.add(StopProcessCopyToChild);
	create opts transient;
	opts.addAssoc(ETRow_ProcessStopAreas, processAreas);
	opts.addAssoc( ETRow_IsMT, true );
	stopsTable := addStopsTable(997, "UT_Th", "Unit Test", selectedTypes, opts);

	return stopsTable;
	
epilog
	delete selectedTypes;
	delete processAreas;
	delete opts;
end;</source>
