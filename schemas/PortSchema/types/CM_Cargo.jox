    <JadeMethod name="mergeChargesByFactor" id="0dc8e2e3-5a2c-4e4b-a1fa-1f6ce432343d">
        <updating/>
        <source>mergeChargesByFactor(_mergeToTI 		: CM_TrackedItem) updating;
// ### JIRA 35213 27JUN2025 NAVAB1
vars
	ts						: TimeStamp;
	hasPayment				: Boolean;
	quantity,
	newQuantity		: Decimal[23, 6];
	value,
	newValue, 
	newtaxvalue, 
	taxvalue 
					: Decimal[23, 6];
	invLine,
	otherLine, matchLine				: CM_InvoiceLine;
	mergePayment,
	payment, 
	taxpayment,mergeToTaxPayment, otherPayment				: CM_CashPayment;
	proformaDetail, mergeToProformaDetail			: CM_ProformaDetails;
	ild				: CM_InvoiceLineDesc;
	oa						: ObjectArray;
	obj						: Object;
	includeTaxPayment 		: Boolean;
	now						: TimeStamp;
	theController : CMIF_InvoiceLineManual;
	terminal : CM_Terminal;
	prevContext : Integer;
begin
	now := app.actualTimeServer;
	
	// ### JIRA 34909 16MAY2025 NAVAB1
	prevContext := app.myPassport.context;	
	app.myPassport.setContext(Context_Pass_InvSplitMerge); 
	
	if _mergeToTI = self then
		return;
	endif;

	ts := app.serverTimestampAtTrxStart;
	
	terminal := self.myTerminal;
	
	// #### GET ALL THE INVOICE LINES THAT HAVE CASH PAYMENTS
	create oa transient;

	foreach invLine in self.invoiceLines do
		hasPayment := false;
		foreach payment in invLine.allCashPayments do
			if not payment.voided then
				if payment.myCarrier = null and
				   payment.myDriver = null then
					hasPayment := true;
					break;
				endif;
			endif;
		endforeach;
		if hasPayment then
			oa.add(invLine);
		elseif invLine.debtor.isCashOnlyDebtor(terminal) then
			if invLine.allCashPayments.isEmpty 
			and not self.allCashPayments.isEmpty then
				// have I got the cash payment that matches the invoice line?
				foreach payment in self.allCashPayments do
					if payment.getPaymentnvoiceLineType() = invLine.invoiceLineDesc then
						hasPayment := true;
						oa.add(invLine);
						break;
					endif;
				endforeach;
			elseif invLine.allCashPayments.isEmpty then
				hasPayment := true;
				oa.add(invLine);
			endif;
		endif;
	endforeach;

	foreach invLine in oa as CM_InvoiceLine do
		
		// #### don't split void or posted invoice lines
		if invLine.voided 
		or  (invLine.invoice &lt;&gt; null and invLine.invoice.isPosted) then		
			continue;
		endif;
		
				
		// find an invoice line to merge into, if not merged invoice lines are moved to new TI else where MergeNullRefs()
		otherLine := null; //_mergeToTI.getInvoiceLineByTypeForCash(invLine.invoiceLineDesc);
		
		foreach matchLine in _mergeToTI.invoiceLines discreteLock do 
			if matchLine.voided 
			or  (matchLine.invoice &lt;&gt; null and matchLine.invoice.isPosted) then		
				continue;
			endif;
			
			if matchLine.invoiceLineDesc = invLine.invoiceLineDesc 
			and matchLine.totalRate = invLine.totalRate
			and matchLine.taxRate = invLine.taxRate
			and matchLine.myTransactionTI = invLine.myTransactionTI then
				otherLine := matchLine;
				break;
			endif;
		
		endforeach;
		
		
		if otherLine &lt;&gt; null then
		
			// ### ADJUST INVOICE LINE
			quantity := invLine.quantity;
			quantity := quantity + otherLine.quantity;
			
			otherLine.setQuantityAndTotal(quantity);
			otherLine.setManual(true);
			otherLine.setQuantityAndTotalAmount(quantity, otherLine.lineTotal); 
	
			// Void the invoice line for the zombie TI
			invLine.setStatus(CM_InvoiceLine.STATUS_VOIDED);

			
			
			foreach otherPayment in invLine.allCashPayments do
				if otherPayment.voided or
				   otherPayment.myCashPaymentForInvoice &lt;&gt; null then //  tax payment ignore
					continue;
				endif;
				
				foreach mergePayment in otherLine.allCashPayments do
					if mergePayment.voided or
					   mergePayment.myCashPaymentForInvoice &lt;&gt; null then //  tax payment ignore
						continue;
					endif;
					
					 // ### JIRA 36345 17OCT2025 NAVAB1
					if otherPayment.isCancelled() &lt;&gt; mergePayment.isCancelled() then
						continue;
					endif;
					
					
					value := otherPayment.cashValue + mergePayment.cashValue;
					mergePayment.doAuditSplitMerge(0,mergePayment.cashValue,value,method.qualifiedName,CM_AuditCashAdjustment.REASON_MERGE);
					mergePayment.setCashValue(value);		
				endforeach;
				// Void the cash payment for the zombie TI
				otherPayment.doAuditSplitMerge(0,payment.cashValue,payment.cashValue,method.qualifiedName,CM_AuditCashAdjustment.REASON_MERGE);
				otherPayment.setStatus(CM_CashPayment.Status_Merged);
			endforeach;
			
			
			
			
			
			
			
			
		endif;
	endforeach;

	// do proforma payments now
	oa.clear();
	self.allCashPayments.copy(oa);
	/// only for current payments
	foreach payment in oa as CM_CashPayment do
		if payment.voided or
		   payment.myCashPaymentForInvoice &lt;&gt; null then // tax payment ignore
			continue;
		endif;
		proformaDetail := payment.myProformaDetail;
		
		if proformaDetail &lt;&gt; null then
			mergePayment := _mergeToTI.getCashPaymentByProformaLine(payment);
		
		elseif payment.myInvoiceLine &lt;&gt; null then
		/*
			ild := payment.myInvoiceLine.invoiceLineDesc;
		
			foreach otherPayment in _mergeToTI.allCashPayments do
				if otherPayment.voided or
				   otherPayment.myCashPaymentForInvoice &lt;&gt; null then //  tax payment ignore
					continue;
				endif;
				if otherPayment.myInvoiceLine &lt;&gt; null then
					if otherPayment.myInvoiceLine.invoiceLineDesc = ild then
						mergePayment := otherPayment;
						break;
					endif;
				endif;
			endforeach;
			*/
			continue;
		
		endif;
		
		if mergePayment = null then
			continue;
		endif;
		
		mergeToProformaDetail := mergePayment.myProformaDetail;
		

		value := payment.cashValue;			
		newValue := value + mergePayment.cashValue;
		
		if mergeToProformaDetail &lt;&gt; null then
			newQuantity := proformaDetail.quantity + mergeToProformaDetail.quantity;
			
			mergeToProformaDetail.setQuantity(newQuantity);
			value := payment.cashValue + mergePayment.cashValue;
			mergeToProformaDetail.setValue(value);
			mergePayment.doAuditSplitMerge(0,mergePayment.cashValue,value,method.qualifiedName,CM_AuditCashAdjustment.REASON_MERGE);
			mergePayment.setCashValue(value);
			proformaDetail.setValue(value);
			mergeToProformaDetail.setRemarks();
		else // invoice line will be merged above
			value := payment.cashValue + mergePayment.cashValue;
			mergePayment.doAuditSplitMerge(0,mergePayment.cashValue,value,method.qualifiedName,CM_AuditCashAdjustment.REASON_MERGE);
			mergePayment.setCashValue(value);		
		endif;

		taxpayment := payment.myCashPaymentForTax;
		mergeToTaxPayment := mergePayment.myCashPaymentForTax;
		
		includeTaxPayment := taxpayment &lt;&gt; null and mergeToTaxPayment &lt;&gt; null;
		
		if includeTaxPayment then
				taxvalue    := taxpayment.cashValue;
				newtaxvalue := (taxvalue + mergeToTaxPayment.cashValue).roundedTo(6);
				mergeToTaxPayment.setCashValue(newtaxvalue);
		endif;
			
		
		// Void the cash payment for the zombie TI
		payment.doAuditSplitMerge(0,payment.cashValue,payment.cashValue,method.qualifiedName,CM_AuditCashAdjustment.REASON_MERGE);
		payment.setStatus(CM_CashPayment.Status_Merged);
	endforeach;
	
epilog
	delete oa;
	delete theController;

	// ### JIRA 34909 16MAY2025 NAVAB1
	app.myPassport.setContext(prevContext); 

end;</source>
        <Parameter name="_mergeToTI" type="CM_TrackedItem"/>
    </JadeMethod>
