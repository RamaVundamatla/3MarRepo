    <JadeMethod name="setWagonClassOnWagonIdChg" id="f5c5b67f-d858-4520-b028-82873fc3e44c">
        <source>setWagonClassOnWagonIdChg( _fieldFrame: CMUI_FieldFrame input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2014	cnwndl1	Initial creation	Par 33615

*/

vars

	wagonId : String;
	wagonVisit : CM_Wagon;
	wagonClassId : String;
	wagonClass : CM_WagonClass;
	wagonMaster : CM_WagonMaster;

begin

	self.cmbWagonClass.enabled := self.txtWagon.enabled;

	wagonId := _fieldFrame.CMUI_FieldTextBox.getString.trimBlanks;
	if wagonId = null then
		//NO wagon entered, no need to allow entry of a wagon class
		self.cmbWagonClass.enabled := false;
		return;
	endif;
	
	wagonVisit := self.myTerminal.getCurrentWagonByID(wagonId);
	if wagonVisit &lt;&gt; null then
		//There is a current wagon on site with this id, unconditionally use its wagon class, and don't alow them to change it.
		self.cmbWagonClass.setForObject( wagonVisit.myWagonClass );
		self.cmbWagonClass.enabled := false;
		return;
	endif;
	
	wagonMaster := self.myTerminal.myRoot.allWagonMasters[wagonId];
	if wagonMaster &lt;&gt; null then
		wagonClass := wagonMaster.myWagonClass;
		if wagonClass &lt;&gt; null then
			//know about this one, it has visited previously... unconditionally use its wagon class, and don't alow them to change it.
			self.cmbWagonClass.setForObject( wagonClass );
			self.cmbWagonClass.enabled := false;
			return;
		endif;
	endif;
	
	wagonClassId := app.myRoot.getWagonClassViaHookCode( self.myTerminal, wagonId, null );
	if wagonClassId &lt;&gt; null then
		wagonClass := self.myTerminal.myRoot.allWagonClasses[wagonClassId];
		if wagonClass &lt;&gt; null then
			//Hook code says use this one... unconditionally use its wagon class, and don't alow them to change it.
			self.cmbWagonClass.setForObject( wagonClass );
			self.cmbWagonClass.enabled := false;
			return;
		endif;
	endif;
	
	wagonClassId := self.myTerminal.getConfig(DefWagonClass).String;
	if wagonClassId &lt;&gt; null then
		wagonClass := self.myTerminal.myRoot.allWagonClasses[wagonClassId];
		if wagonClass &lt;&gt; null and self.cmbWagonClass.getObject = null then
			//OK default it and let them change it if they want
			self.cmbWagonClass.setForObject( wagonClass );
		endif;
	endif;
	

epilog

end;</source>
        <Parameter name="_fieldFrame" type="CMUI_FieldFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="4dd840dd-1173-4ded-9746-4f15086d7c0d">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2009	cnwdap1	Initial creation
*/
vars
	captionString	: String;

begin
	inheritMethod();
	self.handleMenusForModalDisplay();
	
	self.initFieldsForEntDefName(ETDef_AdditionalDetails, true);
	// turn off resize, and disappear min/max buttons
	self.borderStyle	:= self.BorderStyle_Double;
	self.maxButton		:= false;
	self.minButton		:= false;
	
	// no Next button
	btnNext.visible := false;
	btnSave.left := btnNext.left;
	
	captionString := "Additional Details";
	if self.cargoId &lt;&gt; null then
		captionString := captionString &amp; " for " &amp; self.cargoId;
	endif;
	self.setCaption(captionString);
	
	if not self.isUpdatable() then
		self.enableAllControls(false);
		self.btnCancel.enabled := true;
	endif;
	
	//epr par 35955 29/4/15
	if self.myParentForm  &lt;&gt; null and self.myParentForm.isKindOf(CMUI_ReceiveCargoForm) then
		if self.myParentForm.CMUI_ReceiveCargoForm.isOnshipForm then
			self.txtHouseBOL.setMyCaption(app.getErrorString(House_BOL));
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="74bfd5a2-4b78-451d-af7c-b4970b952a1b">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 19 April 2023 09:58:03.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017250, locale);
	chkCurtainsIn.translateCaption(Xlat_0011787, locale);
	chkOverlanded.translateCaption(Xlat_0025960, locale);
	cmbBusUnit.translateCaption(Xlat_0011788, locale);
	cmbCoolingType.translateCaption(Xlat_0011789, locale);
	cmbCtryOfOrigin.translateCaption(Xlat_0025106, locale);
	cmbCustomsAgent.translateCaption(Xlat_0011790, locale);
	cmbFreightFwdr.translateCaption(Xlat_0011791, locale);
	cmbInvContractID.translateCaption(Xlat_0025797, locale);
	cmbShippingLine.translateCaption(Xlat_0024931, locale);
	cmbSpecialLift.translateCaption(Xlat_0011792, locale);
	cmbSpecialStow.translateCaption(Xlat_0011793, locale);
	cmbSubTerminal.translateCaption(Xlat_0013377, locale);
	cmbTransportMode.translateCaption(Xlat_0011794, locale);
	cmbVoltageType.translateCaption(Xlat_0011795, locale);
	cmbWagonClass.translateCaption(Xlat_0019688, locale);
	lstStops.translateCaption(Xlat_0011796, locale);
	lstToDo.translateCaption(Xlat_0011797, locale);
	txtAddRemarks1.translateCaption(Xlat_0022402, locale);
	txtAddRemarks2.translateCaption(Xlat_0022403, locale);
	txtConsignVoy.translateCaption(Xlat_0011798, locale);
	txtDescription.translateCaption(Xlat_0011799, locale);
	txtEquipXchg.translateCaption(Xlat_0011800, locale);
	txtHouseBOL.translateCaption(Xlat_0011801, locale);
	txtPurchaseOrder.translateCaption(Xlat_0011802, locale);
	txtShippingRef.translateCaption(Xlat_0021110, locale);
	txtWagon.translateCaption(Xlat_0013378, locale);
	txtWagonTrain.translateCaption(Xlat_0013379, locale);
end;</source>
