<Class name="GateDock" id="428216db-8375-4d5d-a771-cb7d700c8e04">
    <superclass name="JmtTransactionGenerator"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>
_defaultProfileName GateDock;

_defaultAutoPingInterval 10;

_defaultStatusDisplay on;

_beginDriverProfile GateDock
	_randomSelection false
	_defaultThinkSecs 2
	_stopWhenAllEntriesRun true
	_beginProlog
		_method GateDock;startup;1;0;
	_endProlog

	_method GateDock;gd002_CUN_lstTest_click;1;0;
	_method GateDock;gd004_CUN_lstTest_dblClick;1;0;
