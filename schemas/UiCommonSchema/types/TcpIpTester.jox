    <JadeMethod name="doConnectionOpen" id="511320de-c50f-44c4-a477-6c97d36510f8">
        <source>doConnectionOpen();
// -----------------------------------------------------------------------------
// Created:		25 July 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	myConnection.name := self.txtAddress.text;
	myConnection.port := self.txtPort.text.Integer;
	myConnection.open();
	self.btnTCPIPOpen.caption := 'Close';
	
end;</source>
