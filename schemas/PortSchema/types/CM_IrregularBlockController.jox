    <JadeMethod name="setupForDeckingInTA" id="70088ca8-c51d-41a6-9bd6-003288e701cd">
        <source>setupForDeckingInTA(_fromHeight, _toHeight: Integer; _deckingOptions: CM_YADeckingOptionsTA input; _yaIndex: Integer io);
/*
Purpose:	 // PAR 34890		
Date				Who			Reason
SEPTEMBER 2014		CNWAB1		Initial creation
*/
vars
	taIndex,
	intHeight		: Integer;
	yaLocnCell,
	prevYALocnCell	: CM_YALocationCell;
	shelf : CM_YardController;
begin
	if _fromHeight &lt; 1 then
		return;
	endif;

	
	if not self.isRack then
		inheritMethod(_fromHeight, _toHeight, _deckingOptions, _yaIndex);
		return;
	endif;
	
	
	//other rules may cover other heights
	foreach shelf in self.allSubLocations discreteLock do
 
		//default index
		_yaIndex			:= _yaIndex + 1;	//decking index
		taIndex				:= null;
		prevYALocnCell		:= yaLocnCell;
		shelf.allYAYardLocationCells.purge;
		intHeight := 1;
		
		create yaLocnCell persistent;
		shelf.allYAYardLocationCells.insert(intHeight, yaLocnCell);
		yaLocnCell.setForCreate(intHeight);
		_deckingOptions.allYALocationCellsIn.add(yaLocnCell);
		
	endforeach;

end;</source>
        <Parameter name="_fromHeight" type="Integer"/>
        <Parameter name="_toHeight" type="Integer"/>
        <Parameter name="_deckingOptions" type="CM_YADeckingOptionsTA" usage="input"/>
        <Parameter name="_yaIndex" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="testAutoPlanRequestYA" id="fe5f2450-cd7e-4f35-a453-bd1b9e9f4933">
        <source>testAutoPlanRequestYA(_yaAgent : CM_YAAutoplanAgent input) : Boolean;
//Request based testing only, looking for SOURCE of TI's
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 07/01/2015   cnwma1      PAR #37313 Release Requests - Yard Areas
// 29/08/2017	jlgrh7 		TFS6269	STWR - Issue - Steinweg Rotterdam - Exception Type: SystemException (1090 : Attempted access via null object reference)
// 05 Jun 2025 navma1 		MTN-34114  MTN - Performance Improvements - Remove Class::FirstInstance usage  
vars

	totalFound,
	totalWeNeed			: Integer;
	cmifRequest			: CMIF_YARequest;
	ti					: CM_TrackedItem;
	testIds				: Boolean;
	tiId				: String;
	bulkRelease			: CM_BulkRelease;
	fMove				: CM_FutureMove;
	wle					: CM_WorkListEntry;
	assignedTIs	 		: CM_TISet;
	reserveSelection	: CM_ReserveSelection;
	cT					: CM_CargoType;
begin
	

	cmifRequest := _yaAgent.myCurrentCMIFYAAutoPlan.CMIF_YARequest;
	
	if cmifRequest.totalRequested &gt; self.allTrackedItems.size then
		//Not enough here.. Quit
		_yaAgent.addLogEntry(AP_Log_YA_Default,"Insufficient objects in this area to satisfy request (need " &amp; cmifRequest.totalRequested.String &amp; ", area contains " &amp;   self.allTrackedItems.size.String &amp; ".. Skipping.", true);
		return false;
	endif;

	if cmifRequest.ids.isEmpty() then
	else
		_yaAgent.addLogEntry(AP_Log_YA_Default,"Identification masks to test on Request.", true);
		testIds := true;
	endif;

	reserveSelection := cmifRequest.myReserveSelection;						//05.06.2025 navma1 #MTN-34114
	
	if cmifRequest.isDeliveryRequest then									 //05 Apr 2016	NDL	TFS 1779
		totalWeNeed := cmifRequest.totalRequested;
		bulkRelease := cmifRequest.myDeliveryRequest.myOriginatingBulkRelease;
	elseif reserveSelection &lt;&gt; null then                 				 // 07/01/2015 cnwma1 PAR #37313 
		cT := reserveSelection.myCargoType;
		if cT &lt;&gt; null then
			if cT.id = TI_CargoType_Container then
				totalWeNeed := reserveSelection.totalRequested;
			else 
				totalWeNeed := cmifRequest.totalRequested;
			endif;
		endif;
	else
		totalWeNeed := cmifRequest.totalRequested;
	endif;
	
	//cnwrd1 par 31623 we may be working a release item that hasnt been manually assigned so we do not want to exclude non assigned ti's as we normally would 30.5.2013
	create assignedTIs transient;	
	if bulkRelease &lt;&gt; null and not bulkRelease.allTrackedItemsAssigned.isEmpty then
		bulkRelease.getAvailableAssignedTis( assignedTIs, cmifRequest.myDeliveryRequest );	//24 Apr 2020	NDL	TFS 49095  // ### TFS 52721 16NOV2022 NAVAB1
	endif;	

	foreach ti in self.allTrackedItems discreteLock do : outerLoop
		// Don't count tis that have already been used.
		if _yaAgent.myCurrentCMIFYAAutoPlan.allKeepTrackedTis.includes(ti) then
			_yaAgent.addLogEntry(AP_Log_YA_Default,'Item ' &amp; ti.id &amp; ' has already been allocated.', true);
			totalFound := totalFound + 1;
			continue;
		endif;
		
		if not ti.allQueuedFutureMoves.isEmpty() then
			foreach fMove in ti.allQueuedFutureMoves discreteLock do	//05.06.2025 navma1 #MTN-34114
				wle := fMove.myWorkListEntry;
				if wle = null then
					_yaAgent.addLogEntry(AP_Log_YA_Default,'Could not determine wle from queued move skipping..', true);
					continue outerLoop;
				elseif wle.job = _yaAgent.myCurrentJob then
					_yaAgent.addLogEntry(AP_Log_YA_Default,'Item (' &amp; ti.id &amp; ') is already queued to job, skipping ... ' &amp; wle.job.jobId, true);
					continue outerLoop;
				else
					_yaAgent.addLogEntry(AP_Log_YA_Default,'Item (' &amp; ti.id &amp; ') is queued to a different job stopping...', true);
					continue outerLoop;
				endif;
			endforeach;
		endif;
		
		if testIds then
			tiId := ti.id.trimRight;
			if cmifRequest.ids.compareIds(tiId) then
				_yaAgent.addLogEntry(AP_Log_YA_Default,"Identification Masking, " &amp; tiId  &amp; " passed mask test, testing potentially good Item..", true);
			else
				continue;
			endif;
		endif;
		
		if bulkRelease &lt;&gt; null then
			if not assignedTIs.isEmpty then //cnwrd1 par 31623 
				if (not assignedTIs.includes(ti)) then
					_yaAgent.addLogEntry(AP_Log_YA_Default,'Item ' &amp; ti.id  &amp; ' is not allocated to bulk release', true);
					// Par 11819 DVB changed 25/05/2006
					//return false;
					continue;
				endif;	
			endif;
			
			// Par 12270
			if (not ti.allBulkReleasesAssigned.isEmpty()) and (not ti.allBulkReleasesAssigned.includes(bulkRelease)) then
			//	if (not ti.allBulkReleasesAssigned.includes(bulkRelease)) then
				_yaAgent.addLogEntry(AP_Log_YA_Default,'Item ' &amp; ti.id  &amp; ' is assigned to another bulk release', true);
				// Par 11819 DVB changed 25/05/2006
				//return false;
				continue;
			endif;
		endif;
		
		if ti.testAutoPlanRequestYA(_yaAgent) then
			_yaAgent.myCurrentCMIFYAAutoPlan.allKeepTrackedTis.add(ti);
			_yaAgent.addLogEntry(AP_Log_YA_Default,'Item ' &amp; ti.id &amp; ' matched criteria.', true);
			totalFound := totalFound + 1;
		endif;
		
		if totalFound &gt;= totalWeNeed then
			_yaAgent.addLocationToAgent(self, CM_YAAutoplanAgent.Locations_Found);
			return true;
		endif;
 	endforeach; 
  	
	// TFS 3045
	if totalFound &lt;  totalWeNeed and totalFound &gt; 0 then
		_yaAgent.addLogEntry(AP_Log_YA_Default,"Insufficient items in '" &amp; self.getFullId() &amp; "' to satisfy request (need " &amp; totalWeNeed.String &amp; ", area contains " &amp;   totalFound.String &amp; ".. Skipping.", true);
	
	endif;
	
 	return false;
epilog 
	delete assignedTIs;
end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testIsControllerFullYA" id="77bb974e-c730-4e13-b65d-80be01313f9f">
        <source>testIsControllerFullYA(_yaAgent : CM_YAAutoplanAgent input) : Boolean;
/*
Purpose:	// TFS 43424		
Date				Who			Reason
FEBRUARY 2019		CNWAB1		Initial creation
*/

vars
	maxCap : Integer;
	currentCount, quantityQTotal,quantityRTotal,quantityPTotal : Integer;
	testPlannedCount : Integer;
	hasSomeCapacity : Boolean;
	totVolume, totWeight : Decimal[16,6];
begin

	if self.myTerminalArea.testIsFull() then
		_yaAgent.addLogEntry(AP_Log_YA_Default,app.getErrorString(Location_Flagged_Full), true);
		return true;
	endif;			
	
	maxCap := self.maxCapacity;
	
	if maxCap &lt;&gt; 0 then
		testPlannedCount := _yaAgent.getTestPlannedCargoCountFor( self );	

		self.getTotalsByMode(QUEUE_MODE, totVolume, totWeight, quantityQTotal);
		self.getTotalsByMode(REAL_MODE, totVolume, totWeight, quantityRTotal);
		self.getTotalsByMode(PLANNING_MODE, totVolume, totWeight, quantityPTotal);
		
		currentCount := (quantityRTotal + quantityPTotal + quantityQTotal + testPlannedCount);
		
		if currentCount &gt;= maxCap then	
			_yaAgent.addLogEntry(AP_Log_YA_Default,"Location only has capacity for " &amp; maxCap.String &amp; " it will be exceeded if this is selected as a target", true);
			return true;
		endif;
	endif;
	
	if self.testIsControllerFullTAMaxYA(_yaAgent, hasSomeCapacity) then	
		if hasSomeCapacity then
			_yaAgent.myCMIFYAAutoPlan.addLocationForSplitQ( _yaAgent.myCurrentAllocation, self);	
		endif;
		return true;
	endif;
	
	return false;			

end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testLocationYA" id="28cd5529-8327-4193-9884-8475376c1046">
        <source>testLocationYA(_yaAgent: CM_YAAutoplanAgent input; _isIn: Boolean): Boolean;
/*
Purpose:			
Date		Who		Reason
17/09/2013	cnwab1	Initial creation
11/10/2019	jlgdap1	TFS 47001 PRP Auto-plan Errors
13/05/2021	navdap1	TFS 49858 PRP Default Capacity per Location for GC Areas
*/

vars

	capacity : Integer;
	
begin

	//02 May 2014	NDL	Par 33936
	if not inheritMethod( _yaAgent, _isIn ) then
		return false;
	endif;
	
	if _isIn then										// TFS 47001
		capacity := self.getCurrentCapacity();
		
		if capacity &lt; 1 then
			//no checking
			return true;
		endif;	
		
		//if capacity &lt;= (self.allTrackedItems.size + self.allQueuedFutureMoves.size ) then										// TFS 49858
		if capacity &lt;= (self.allTrackedItems.size + self.allQueuedFutureMoves.size + self.allPlannedFutureMoves.size ) then		// TFS 49858
			return false;
		endif;
	endif;												// TFS 47001
	
	return true;

epilog

end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_isIn" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
