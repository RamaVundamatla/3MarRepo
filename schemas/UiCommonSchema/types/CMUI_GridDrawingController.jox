    <JadeMethod name="getSpaceForDifferentFonts" id="5861e828-4855-439e-a160-4755d4860e19">
        <source>getSpaceForDifferentFonts(defaultScale : Real) :Real;
//17 February 2009	cnwwc2	Initial creation
//calculate much extra space needed for different scales
vars
	space: Real;
	sf : Real;
begin

	sf := self.scaleFactor * 2;	
	
	space := (sf - defaultScale) * 2;
	
	return space;
end;</source>
