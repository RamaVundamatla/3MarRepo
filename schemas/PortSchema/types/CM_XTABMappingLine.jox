    <JadeMethod name="validateForCreate" id="f6f191a2-d245-42ea-9a7e-2abc8279b209">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     16 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	property	:CM_QueryProperty;
begin
	// mapped value is required
	if self.mappedValue = null then
		app.raiseCMException (XTAB_Mapped_Value_Reqd, null, null);
	endif;
	
	property := self.myXTABMapping.getQueryProperty;
	
	if property &lt;&gt; null then
		// we will already have ahd an error if property is null
		if property.allAllowedOperators[self.myQueryOperator.description] = null then
			app.raiseCMException2 (XTAB_InvalidOperatorForProp, self.myQueryOperator.description, property.propertyName, null, null);
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
