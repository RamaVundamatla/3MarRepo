    <JadeMethod name="convertInvoiceLineTaxDetails" id="43953052-0f4d-4aa8-8db9-5d6906be560a">
        <source>convertInvoiceLineTaxDetails(_controller : CnEcReleaseController);
/*



NOT USED. This script might have taken many hours to run in sime clients database.




*/









/*
Purpose - 	
Who - NAVAB1
Date - 02APR2024
ADO -  CR 62992 TASK 62994 
*/

vars
	iter01 : Iterator;
	theInvLine : CM_InvoiceLine;
	theInv : CM_Invoice;
