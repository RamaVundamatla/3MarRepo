    <JadeMethod name="includeObject" id="17a2fa12-3810-46e2-9233-be6a699b727b">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;

vars

begin
	
	if _obj.CM_TerminalAreaType.description = "Road Transfer Area" then
		return false;
	endif;
	
	
	if self.includeNotAvailableEntries then
		return true;
	else
		return not _obj.CM_TerminalAreaType.getIsNotAvailableForEntry;
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
