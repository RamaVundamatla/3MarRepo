    <JadeMethod name="utlCreateO2Reading" id="e7167377-4540-4e99-a600-2f3391304594">
        <source>utlCreateO2Reading(_o2Params : CMIF_O2Reading input; _passport : CM_Passport input) : CM_O2Reading;
//
// Purpose:			Record a O2 reading for a reefer cargo item and create the associated TI transaction
//
// Parameters:			CMIF parameters for creating a O2 reading / passport
//
// Return Value:		The created O2 reading object
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/12/2025	navdap1		Initial creation MTN-36569 CPL | Reefer Runner Integration
//
vars
	o2Reading : CM_O2Reading;
	realTI, proxyTI : CM_TrackedItem;
	expectedEdition : Integer;

begin
	self.initialiseActivity();
	
	proxyTI := _o2Params.myTrackedItem;
	proxyTI.raiseExceptionIfNotProxy(method);
	
	app.setContinueCMExceptions(true);
	
	proxyTI.pxyGetRealObjectAndEdition(realTI, expectedEdition);
	if realTI = null then
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TrackedItem.name, null, null);
		return null;
	endif;
	
	app.myValCA.valO2Reading(_o2Params);
	if not self.checkValidationWithPassport(_passport) then
		return null;
	endif;
	app.setContinueCMExceptions(false);
	
	self.exclusiveLock(realTI);

	if _passport.noErrors then
		_o2Params.myTrackedItem := realTI;
		create o2Reading persistent;
		o2Reading.setForCreate(_o2Params);
	endif;
	
	if _passport.noErrors then
		// raise a note
		_o2Params.myTrackedItem.causeEvent(_o2Params.myTerminal.getTerminalEvent(EVENT_TEMP_CREATE), false, o2Reading);
	endif;
	
	return o2Reading; 
	
epilog

end;</source>
        <Parameter name="_o2Params" type="CMIF_O2Reading" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_O2Reading"/>
    </JadeMethod>
