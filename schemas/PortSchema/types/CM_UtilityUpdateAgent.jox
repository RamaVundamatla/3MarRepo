    </JadeMethod>
    <JadeMethod name="utlUpdateTIFromOneStopAction" id="16976893-0022-4be9-ad19-a34679854b5b">
        <source>utlUpdateTIFromOneStopAction(_theProxyTI: CM_TrackedItem input; _theEDITI : CM_EDICustomStopTI; _ediFileType : CM_EDIFileType; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 September 2016	cnwndl1	Initial creation	TFS 2278 /2670  Special variant for One Stop Australian customs messages.
24 Sep 2018	jlgsl4	40687 - AAT - re-apply import stops if stop-add message received after 'clear'
02 Oct 2018	jlgsl4	40687 - AAT - re-apply import stops for CARST files; Pt.3 - add stop regardless of CEN
11 Feb 2019 jlggb1	42598 - One Stop Underbond Movements
*/

vars
	theRealTI		: CM_TrackedItem;
	expectedEdition : Integer;
	aTITrans		: CM_TITransaction;
	ediAction		: CM_EDIAction;
	action			: Boolean;
	txnParams		: CMIF_TITransactionController;
	aStringArray	: HugeStringArray;
	updated			: Boolean;
	actionObject	: CM_Object;
	invalid 		: Boolean;
begin
	self.initialiseActivity();

	_theProxyTI.raiseExceptionIfNotProxy(method);
	_theProxyTI.pxyGetRealObjectAndEdition(theRealTI, expectedEdition);

	if theRealTI = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "can't locate real object");
		return;
	endif;

	exclusiveLock(theRealTI);
	
	create aStringArray transient;
	create txnParams transient;
	txnParams.type 			:= TRANS_TYPE_EDIT;
	txnParams.myTrackedItem := theRealTI;
	txnParams.userId 		:= _passport.userCode;
	
	on Exception do app.handleDeletedObject(exception, actionObject, invalid);
	
	if _ediFileType.type  = EDIFileType_XMLOneStopCust then
		ediAction := _ediFileType.CM_EDIFileTypeXMLOneStopCust.getEdiAction( _theEDITI.clientRef, _theEDITI.description, theRealTI, true );
	endif;
	
	if ediAction = null or ediAction.myActionObject = null then
		return;
	endif;
		
	actionObject := ediAction.myActionObject;	// a stop or todo task
	
	if actionObject &lt;&gt; null then		
		if ediAction.actionType = EDIAction_Add and actionObject.isA(CM_StopsTable) and 
			((theRealTI.isImport and (	ediAction.keyFileSegment = EDIKeySegment_AQISHOLD or // TFS 40687 // Pt.3 8/10/18
										ediAction.keyFileSegment = EDIKeySegment_CARST or 
										ediAction.keyFileSegment = EDIKeySegment_SEAOUTR or 
										ediAction.keyFileSegment = EDIKeySegment_UBMREQR or //42598 jlggb1 11/02/2019
										ediAction.keyFileSegment = EDIKeySegment_XRAYADV))// TFS 40687 Pt.3
			or (theRealTI.isExport and (ediAction.keyFileSegment = EDIKeySegment_CTORECR or 
										ediAction.keyFileSegment = EDIKeySegment_CTOREMR))) then // TFS 40687 Pt.3
			if theRealTI.isImport then // TFS 40687 Pt.3
				theRealTI.setCustomsEntryNumber(""); // TFS 40687 - re-apply import stops by clearing CEN
			endif; // TFS 40687 Pt.3
			if not self.checkValidationWithPassport(_passport) then // TFS 40687
				return; // TFS 40687
			endif; // TFS 40687
			if actionObject.isA(CM_StopsTable) and not theRealTI.hasStopOfType(actionObject.CM_StopsTable) then // TFS 40687 Pt.3
				theRealTI.createStop(actionObject.CM_StopsTable.id, false, false, null, false, null, _passport); // TFS 40687 Pt.3
				if not self.checkValidationWithPassport(_passport) then // TFS 40687 Pt.3
					return; // TFS 40687 Pt.3
				endif; // TFS 40687 Pt.3	
			endif; // TFS 40687 Pt.3	
		else // TFS 40687
			invalid := false;
			updated := actionObject.actionTI(theRealTI, ediAction.actionType, _passport);
		endif; // TFS 40687
		if invalid then
			app.raiseUnexpectedProgramError(class.name, method.name, 'the action item has been deleted - update the EDI Action (' &amp; ediAction.name &amp; ') in SysOps');
			return;
		endif;
		
		if updated then
			// RECORD This event
			aStringArray.add("EDIAction =&gt; " &amp; ediAction.actionType &amp; " " &amp; actionObject.getEDIActionName);
		endif;
	endif;	

	on Exception do null;
	
	if not aStringArray.isEmpty then
		aTITrans := theRealTI.createTransaction(txnParams, _passport);	
		
		aTITrans.CM_Edit.fieldsValues.addStrings(aStringArray);
	endif;
	
epilog
	delete txnParams;
	delete aStringArray;	
end;</source>
        <Parameter name="_theProxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_theEDITI" type="CM_EDICustomStopTI"/>
        <Parameter name="_ediFileType" type="CM_EDIFileType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
