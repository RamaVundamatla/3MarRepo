<Class name="CM_WorkOrderAssign" id="785dc382-0bff-4e3a-81fa-24dbeef7fbf9">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="workorder"/>
    <ImplicitInverseRef name="myWorkOrder" id="cf09b410-ff97-4bc1-9ca2-370eac49ec7a">
        <embedded/>
        <type name="CM_WorkOrderTI"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="getDisplayStringForAttribute" id="340505ee-493a-447a-9b91-aa7e02ab614e">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498
08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/

vars
	lDetail : String;
	invalidWO : Boolean;
	workOrder	: CM_WorkOrderTI;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			on Exception do app.handleDeletedObject(exception, workOrder, invalidWO); 
			workOrder := self.myWorkOrder;
			if workOrder &lt;&gt; null then
				lDetail := "Assigned to " &amp; workOrder.id;
			endif;
			return lDetail;
			
		endif;
							
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="931ac1d5-e499-4d74-b071-13c27ef52e59">
        <source>getEnquiryRow(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 December 2009	cnwrd1	Initial creation
08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/
vars
	lDetail 	: String;
	lInvalidBR 	: Boolean;
	lReturn		: String;
	str 		: String;
	invalidWO	: Boolean;
	workOrder	: CM_WorkOrderTI;
begin

	on Exception do app.handleDeletedObject(exception, workOrder, invalidWO); 


	lDetail := inheritMethod();
	
	workOrder := self.myWorkOrder;
	str := "Assigned to " &amp; workOrder.id;
	return lDetail &amp; str;
	
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWOPinSpaceContainerId" id="b0d2784d-b98d-4874-8020-edec6120b1d4">
        <source>getWOPinSpaceContainerId():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 February 2019	jlgndl1	Initial creation	TFS 43543

*/

vars
	
	pinNo : String;
	id : String;
	retValue : String;

begin

	if self.myWorkOrder &lt;&gt; null then
		if self.myWorkOrder.myPinNo &lt;&gt; null then
			pinNo := self.myWorkOrder.myPinNo.pinNo;
		endif;
	endif;
	
	if self.myTrackedItem &lt;&gt; null then
		id := self.myTrackedItem.id;
	endif;
	
	retValue := pinNo &amp; " " &amp; id;
	
	return retValue.trimBlanks;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="7dae340e-6413-4994-8367-055d0740eee4">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_WorkOrderTransController; _passport: CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 December 2009	cnwrd1	Initial creation

*/

vars

begin


	self.myWorkOrder := _tiTransCntrl.myWorkOrder;
	inheritMethod(_tiTransCntrl, _passport);

epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_WorkOrderTransController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
