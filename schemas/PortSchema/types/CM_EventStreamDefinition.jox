    <JadeMethod name="setForUpdate" id="da55e79d-3e85-45a3-b145-22b44855807d">
        <updating/>
        <source>setForUpdate(_pxyEventStreamDef : CM_EventStreamDefinition) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI

*/

vars

begin

	// This method should be used only to update persistents
	self.raiseExceptionIfTransient(method);
	if not _pxyEventStreamDef.isTransient then
		self.raiseExceptionIfNotTransient(method);
		return;
	endif;
	
	self.name 		:= _pxyEventStreamDef.name;
	self.targetURL 	:= _pxyEventStreamDef.targetURL;
	self.isActive 	:= _pxyEventStreamDef.isActive;
	self.numRetries := _pxyEventStreamDef.numRetries;
	self.email 		:= _pxyEventStreamDef.email;
	self.authToken 	:= _pxyEventStreamDef.authToken;
	self.disabledTS := _pxyEventStreamDef.disabledTS;
	
	self.myEventStreamRoot := CM_PushEventsRoot.firstInstance();
	
epilog

end;</source>
        <Parameter name="_pxyEventStreamDef" type="CM_EventStreamDefinition"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="b93e3021-fbf9-4d9e-8608-131a20fdd354">
        <updating/>
        <source>setProxy(	_name 		: String;
			_targetURL 	: String;
			_isActive	: Boolean;
			_numRetries	: Integer;
			_email		: String;
			_authToken	: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI

*/

vars

begin
	// This method should be used only to update transient
	self.raiseExceptionIfNotTransient(method);
	
	self.name 		:= _name;
	self.targetURL 	:= _targetURL;
	self.isActive 	:= _isActive;
	self.numRetries := _numRetries;
	self.email 		:= _email;
	self.authToken 	:= _authToken;
	
	// disabled timestamp should only be non null when it has been
	// automatically disabled by the system, and should be removed
	// when updated
	self.disabledTS := null;
	
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_targetURL" type="String"/>
        <Parameter name="_isActive" type="Boolean"/>
        <Parameter name="_numRetries" type="Integer"/>
        <Parameter name="_email" type="String"/>
        <Parameter name="_authToken" type="String"/>
    </JadeMethod>
