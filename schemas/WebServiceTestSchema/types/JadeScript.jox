    <JadeMethod name="testMultipleWS" id="2c433a15-39dd-419b-98e6-c044881a3571">
        <source>testMultipleWS();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 June 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	endpoints		: HugeStringArray;
	endpoint		: String;
	jmt				: JMTUserInterfaceService;
	i				: Integer;
	param			: GetCurrentVersion;
	consumers		: ObjectArray;
	
begin
	create consumers transient;
	create endpoints transient;
	endpoints.add("http://web1.cnwdmast.cnw.co.nz/bin_public/jadehttp.dll?JMTWebService&amp;serviceName=JMTUserInterfaceService&amp;listName=JMTWebService");
	endpoints.add("https://web1.cnwwmast.cnw.co.nz/bin_public/jadehttp.dll?JMTWebService&amp;serviceName=JMTUserInterfaceService&amp;listName=JMTWebService");
	endpoints.add("http://web1.cnwgmast.cnw.co.nz/bin_public/jadehttp.dll?JMTWebService&amp;serviceName=JMTUserInterfaceService&amp;listName=JMTWebService");
	endpoints.add("http://web1.cnwjmast.cnw.co.nz/bin_public/jadehttp.dll?JMTWebService&amp;serviceName=JMTUserInterfaceService&amp;listName=JMTWebService");
	endpoints.add("http://web1.cnwlmast.cnw.co.nz/bin_public/jadehttp.dll?JMTWebService&amp;serviceName=JMTUserInterfaceService&amp;listName=JMTWebService");
	endpoints.add("http://web1.cnwnmast.cnw.co.nz/bin_public/jadehttp.dll?JMTWebService&amp;serviceName=JMTUserInterfaceService&amp;listName=JMTWebService");
	endpoints.add("http://web1.cnwsmast.cnw.co.nz/bin_public/jadehttp.dll?JMTWebService&amp;serviceName=JMTUserInterfaceService&amp;listName=JMTWebService");

	foreach i in 1 to endpoints.size() do
		create jmt transient;
		consumers.add(jmt);
		jmt.setEndpointURL(endpoints[i]);
		create param transient;
		write i.String &amp; Tab &amp; "Sending to " &amp; jmt.getEndpointURL();
		write jmt.getCurrentVersion(param).returnAsXMLString;
	endforeach;	
	
epilog
	delete endpoints;
	if consumers &lt;&gt; null then
		consumers.purge();
		delete consumers;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="testWebService" id="93c18435-35ef-442b-8fa5-b8428de0467b">
        <source>testWebService();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Mar 2009	cnwkpd1	RIA web site

*/

constants
	EncryptedId		= 'Encrypted Session Id=';

vars
	sess			: WebSession;
	sessions		: ObjectArray;
	iter			: Iterator;
	sessionClass	: Class;
	sessDisplay,
	sessionId		: String;
	pos				: Integer;
	
begin
	sessionClass := rootSchema.getSchema('WebServicesSchema').getClass('SWebServiceSchema');
	
	create sessions transient;
	sessionClass.allInstances(sessions, 0, true);
	
	iter := sessions.createIterator;
	
	while iter.next(sess) do
		sessDisplay := sess.display;
		pos := sessDisplay.pos(EncryptedId, 1);
		sessionId := null;
		if pos &lt;&gt; 0 then
			pos := pos + EncryptedId.length;
			sessionId := sessDisplay.scanUntil(CrLf, pos);
		endif;
			
		write sess.String &amp; Tab &amp; sess.getPropertyValue('sessionId').String &amp; Tab &amp; sessionId;
	endwhile;
	
	
	
epilog

end;</source>
    </JadeMethod>
</Class>
