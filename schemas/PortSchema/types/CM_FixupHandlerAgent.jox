    <JadeMethod name="zGetNiceName" id="fe9f92b5-ca1a-444d-888e-63ba5cf21ae9">
        <source>zGetNiceName( _meth : Method ) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05/05/2011	cnwndl1	Initial creation	Par 27438
03/04/2017	cnwdap1	TFS 3930 LNX Bulk Vessel Extract / Load
22/03/2019	jlgdap1	TFS 43952 PEL1 Manual Update of Tax Number/Tax Date
27/03/2019	jlgdi1	TFS# 43985 Added deletion of archived voyages that arrived between specified dates
23/08/2019	jlgdi1	TFS# 45939 Added - Set Payment Status of an Invoice
27/08/2019	jlgdi1	TFS# 45939 Added - Get and set Tax Number of an Invoice
08/10/2021	jlier1	TFS 51963 - removed Pelindo specific methods
*/

begin
	if _meth = null then
		return "Error - No method supplied for " &amp; method.qualifiedName;
	else	
		if _meth.name = CM_FixupHandlerAgent::doRepairShipReceivalTrans.name then
			return "Repair Tranship Ship Receival Transactions";
		elseif _meth.name = CM_FixupHandlerAgent::doRemTALocRestrictions.name then
			return "Remove Terminal Area Location Restrictions";
		elseif _meth.name = CM_FixupHandlerAgent::doRepairLostEIRNumbers.name then	//cnwas3 par 27766
			return "Recover lost EIR numbers for released cargo";
		elseif _meth.name = CM_FixupHandlerAgent::doRepairBookingPackAs.name then
			return "Repair 'Pack as' value on EDI created bookings";
		elseif _meth.name = CM_FixupHandlerAgent::doCleanUpVesselStructure.name then	// 13 Jul 2011	NDL	Par 27826
			return "Clean up orphaned 'Cellular Vessel Structure' objects";
		elseif _meth.name = CM_FixupHandlerAgent::doFindReportWriterUsage.name then		// Sep 2011 28028 CCMS 1120
			return "Show Report Writer Usage";
		elseif _meth.name = CM_FixupHandlerAgent::doRepairDpRailReleaseTrans.name then		// cnwrd1 for par 28436 &amp; 28478 17.10.2011
			return "Repair Cargo Duplicate Rail Release Transactions";			
		elseif _meth.name = CM_FixupHandlerAgent::doCargoMoveOffsite.name then		// 17 Nov 2011	NDL	Par 28686
			return "Move Cargo Items directly Offsite";			
		elseif _meth.name = CM_FixupHandlerAgent::doUpgradeVolumeTotalVolume.name then		// 14 Dec 2011	NDL	Par 28855
			return "Upgrade 'Total Volume' on historical Cargo";			
		elseif _meth.name = CM_FixupHandlerAgent::doForceDataExtract.name then		// 21 Dec 2011	28892
			return "Force Data Extract of Cargo";
		elseif _meth.name = CM_FixupHandlerAgent::doFindOnshipWithoutRelease.name then	//30 Jan 2012	NDL	Par 29034
			return "Find 'teklogix' exported 'On Ship' Cargo with no Release trx";
		elseif _meth.name = CM_FixupHandlerAgent::doFindVesselsWithBadSlots.name then	//14 Feb 2012	NDL	Par 28640 / 28975
			return "Find 'Vessel'(s) and 'Voyage'(s) that have slots with invalid 40 foot attributes";
		elseif _meth.name = CM_FixupHandlerAgent::doCreateBATs.name then	//24 Apr 2012	NDL Par 29417
			return "Bulk Creation of Terminal RFID table items for use as BATs";
		elseif _meth.name = CM_FixupHandlerAgent::doConvertPilotExemptStatus.name then	//30 Apr 2012	NDL Par 29496
			return "Convert 'Pilot Exempt' Statuses";
		elseif _meth.name = CM_FixupHandlerAgent::doSetBerthRoot.name then	//30 Apr 2012	NDL Par 29537
			return "Ensure all 'Berths' visible";
		elseif _meth.name = CM_FixupHandlerAgent::doCleanUpYACellHeights.name then	//25 May 2012	NDL Par 29604
			return "Check and Repair Gridded Block Stack cell heights";
		elseif _meth.name = CM_FixupHandlerAgent::doFindSemiQueuedCargo.name then	//30 Aug 2012	NDL	Par 30252
			return "Check and Repair Semi Queued Cargo";
		elseif _meth.name = CM_FixupHandlerAgent::doStraddleStackRowRenumber.name then //11 Oct 2012	NDL	Par 30521
			return "Check and Repair Straddle Stack Row index issues";
		elseif _meth.name = CM_FixupHandlerAgent::doRepairPortCodes.name then	//28 Nov 2012	NDL Par 30772
			return "Reset Port 3 character codes from 5 character country/port code'";
		elseif _meth.name = CM_FixupHandlerAgent::doSplitInvoice.name then //05 Dec 2012	NDL	Par 30685
			return "Split an Invoice that has a large number of Invoice Lines";
		elseif _meth.name = CM_FixupHandlerAgent::doResetQueryDefinitions.name then	//03 Apr 2013	NDL	Par 31295
			return "Reset Query Definitions";
		elseif _meth.name = CM_FixupHandlerAgent::doClearInvalidObjsFromRail.name then
			return "Cleanse Rail line invalid Wagon references.";
		elseif _meth.name = CM_FixupHandlerAgent::doCheckPrinterDefs.name then	//19 June 2013	NDL	Par 31842
			return "Check Printers defined in System Admin/Printers/Table";
		elseif _meth.name = CM_FixupHandlerAgent::doUpdateGCHolds.name then	// 21 June 2013 DJW
			return "Update GC Holds to Upper/Tween/Lower";
		elseif _meth.name = CM_FixupHandlerAgent::doPopulateCountryCodes.name then	//08 Aug 2013	NDL	32305
			return "Load/Update Country Code details";
		elseif _meth.name = CM_FixupHandlerAgent::doRepairCargoPackUnpackDates.name then	// 15/08/2013	cnjwre1	32065
			return "Repair Cargo Pack and Unpack dates";
		elseif _meth.name = CM_FixupHandlerAgent::doResetCashReceiptNumbers.name then		// 12/11/2013	cnwjre1 32972
			return "Reset Cash Receipt Numbers";
		elseif _meth.name = CM_FixupHandlerAgent::doFindDepartWagOnsiteCargo.name then		// 17/12/2013	NDL 33189
			return "Find Cargo Items on departed wagons still marked as on-site";
		elseif _meth.name = CM_FixupHandlerAgent::doRemAddCurrentTodoTasks.name then		// 28/7/2014 CCMS POE 2390 AKB
			return "Remove and Re-add all Current Todo Tasks";
		elseif _meth.name = CM_FixupHandlerAgent::doRepairReceivingDates.name then			// 13/08/2014 cnwjre1	34715
			return "Repair cleared cargo received dates";
		elseif _meth.name = CM_FixupHandlerAgent::doUpdateClassInstancesBulk.name then			// 27/11/14 cnwrd1 35165
			return "Update Objects for DSS extract";			
		elseif _meth.name = CM_FixupHandlerAgent::doSetupVehicleBookingRoot.name then			// 05 Dec 2014	NDL	Par 35342
			return "Set Base Data for Vehicle Booking Sytem";			
		elseif _meth.name = CM_FixupHandlerAgent::doWellcarConversion.name then			// 22 Dec 2014	NDL	Par 35346
			return "Wellcar Conversion";			
		elseif _meth.name = CM_FixupHandlerAgent::doFixCashPayments.name then			// 12/01/2015	cnwjre1	Pars 35443, 35464, 35373
			return "Create missing cash payments";			
		elseif _meth.name = CM_FixupHandlerAgent::doResyncSubTermAndBusUnit.name then	//11 May 2015	NDL	Par 36181
			return app.getErrorString(Resync_subter_busine_unit_carg);//"Re-Synchronise Sub-Terminal and Business Unit on Cargo";
		elseif _meth.name = CM_FixupHandlerAgent::doExtractLoad.name then		// May 2015	JRE	Par 36385
			return "Extract and Load invoicing setup data";
		elseif _meth.name = CM_FixupHandlerAgent::doListPatchedMethods.name then	//03 Dec 2015	NDL	Par 37174
			return "List methods patched into this environment after the base release was cut";
		elseif _meth.name = CM_FixupHandlerAgent::doListUsersAndRoles.name then	//08 Dec 2015	NDL
			return "List User Permissions and Roles setup";
		elseif _meth.name = CM_FixupHandlerAgent::doDeleteUnknownTrucks.name then	//07 Jan 2015	NDL	Par 37215
			return "Delete Security gate 'Unknown' trucks";
		elseif _meth.name = CM_FixupHandlerAgent::doFindYADataPatterns.name then		//10 Feb 2015	NDL	Par 37510
			return "Find Yard Allocations using '****' as a pattern";
		elseif _meth.name = CM_FixupHandlerAgent::doCleanseCashReceiptTIs.name then	//30 Mar 2016	NDL	TFS 1726
			return "Clear Deleted Cargo references from Cash Receipts";
		elseif _meth.name = CM_FixupHandlerAgent::doCheckPackedLocations.name then //10 May 2016	NDL	TFS 1969
			return "Find off-site and on-ship child cargo associated to on-site Yard Locations";
		elseif _meth.name = CM_FixupHandlerAgent::doFixSplitInvoiceLines.name then		// 21/07/2016 cnwjre1 TFS 2379
			return "Fix invoice lines from cargo split and merge";
		elseif _meth.name = CM_FixupHandlerAgent::doDeleteStateStrings.name then				// 26/07/2016 cnwdap1 C3 TFS #2211
			return "Delete State Strings with no parent and State Objects with no state data";		// 26/07/2016 cnwdap1 C3 TFS #2211
		elseif _meth.name = CM_FixupHandlerAgent::doVesselDataExtractLoad.name then		// TFS 3930
			return "Extract and Load Vessel data";										// TFS 3930
		elseif _meth.name = CM_FixupHandlerAgent::doFixVoyagePortRotations.name then		// CNWAB1 TFS 4353
			return "Fix Voyage Port Rotations";										// CNWAB1 TFS 4353
		elseif _meth.name = CM_FixupHandlerAgent::doUpdatePaymentStatusCR.name then		// CNWAB1 TFS 42401
			return "Update Cash Receipt Payment Status To 'Cancelled Manually'";										// CNWAB1 TFS 42401
		elseif _meth.name = CM_FixupHandlerAgent::doReportOnFutStorage.name then		// JLGNS1 TFS 42264
			return "Report on Incorrect Future Storage Charges";						// JLGNS1 TFS 42264	
		elseif _meth.name = CM_FixupHandlerAgent::doDeleteArchivedVoyages.name then	// TFS# 43985
			return "Delete archived voyages arrived between specified dates";
		elseif _meth.name = CM_FixupHandlerAgent::doShowLastUpdate.name then //09 May 2019	NDL
			return "Show Last Modified time for 'class' or 'method'";
		elseif _meth.name = CM_FixupHandlerAgent::doListJMTRefreshConfig.name then	//15 May 2019 jlger1 TFS 42569
			return "List configs in JMTRefreshParameters ini format";
		elseif _meth.name = CM_FixupHandlerAgent::doListRampRates.name then	//10 Jun 2019	NDL	TFS 45084
			return "List Ramp Calculation Type - rates";
		elseif _meth.name = CM_FixupHandlerAgent::doBolTrxTermPopulate.name then	//04 Nov 2019 NDL	TFS 47100
			return "Make historical BOL Transactions available for the Selector";
		elseif _meth.name = CM_FixupHandlerAgent::doRemoveZombieRefs.name then	//15 Feb 2021	NDL	TFS 50761
			return "Clean up 'Stops' for 'Merged' Cargo";
		elseif _meth.name = CM_FixupHandlerAgent::doTFS51570CleanUp.name then	//22 Jul 2021	NDL	TFS 51570
			return "Clean up Fleet File (Master record Objects) for TFS 50910 / 51570";
		elseif _meth.name = CM_FixupHandlerAgent::doTruncateEDIinfoXML.name then	//13 Sep 2021	NDL	TFS 51718
			return "Initiate a single run of the Garbage Collect '" &amp; app.getErrorString(Truncate_EDIInfo_XML) &amp; "' option";
		elseif _meth.name = CM_FixupHandlerAgent::doInvAddStoExpForOffItem.name then //13/05/2024	navkc1 CR63806 Task 63878
			return "Invoice add storage expiry detail for offsite items";
			elseif _meth.name = CM_FixupHandlerAgent::doTriggerDataExtrctFrmOids.name then // ### JIRA: MTN-36212 24Nov2025 NAVPW1
			return "Force Data Extract of Oids";
		else
			return _meth.name &amp; " [developer needs to update '" &amp;  method.qualifiedName &amp; "']";
		endif;
	endif;
end;</source>
        <Parameter name="_meth" type="Method"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="zSetMyForm" id="2b659824-ca4b-4f3e-be3e-668dc4192861">
