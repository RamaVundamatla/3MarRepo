    <JadeMethod name="setForCreateSubClasses" id="23114e38-0f47-4faa-8f68-1d1b8da85674">
        <updating/>
        <source>setForCreateSubClasses(_ti: CM_Machinery; _passport : CM_Passport input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	inheritMethod(_ti, _passport);

	self.cScDT 		:= _ti.cScDT;
	self.isoType 	:= _ti.isoType;
	self.preTripDT := _ti.preTripDT;

