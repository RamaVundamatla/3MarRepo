//	Created:	23 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	return self.myDiscrepancyEDITI;

epilog

end;</source>
        <ReturnType type="CM_EDITrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="dfc5b707-c3aa-426a-a5b1-ac89683740cd">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//----------------------------------------------------------------
//	Created:	28 July 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str,
	strReturn	: String;
	strSize		: Integer;
begin
	
	if _attrName = ETRow_VoyageCode then
		if self.myTrackedItem &lt;&gt; null then
			if self.comparisonMode = TI_IMEX_STATUS_EXPORT and //PAR25362 cnwsh3 03/09/2010
			self.myTrackedItem.isTranshipInbound() then
				return self.transhipVoyageCode;
			else
				return self.myTrackedItem.myVoyage.code;
			endif;
		endif;
	elseif _attrName = ETRow_YardLocation then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.locationId;
		endif;
	elseif _attrName = ETRow_IsTranshipItem then
		if self.myTrackedItem &lt;&gt; null then
			return app.getYesNo(self.myTrackedItem.isTranshipItem);
		endif;
	elseif _attrName = ETRow_State then
		/*
		If this is needed it needs to indicate this relative to the voyage that is being compared against
		if self.myTrackedItem &lt;&gt; null and
		   self.myTrackedItem.isTranshipItem then
		   
			if self.myTrackedItem.
			if self.myTrackedItem.isTranshipExport() then
				return "Tranship Outbound";
			elseif self.myTrackedItem.isTranshipOnInboundVoyage() then
				return "Tranship Inbound";
			endif;
		else
		*/
			return app.stateEnumToString(self.state);
		//endif;
	elseif _attrName = ETRow_ImexStatus then	//19 May 2010	NDL Par 24243
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getImExStatusString;
		endif;
	elseif _attrName = ETRow_DischargePort then //PAR25362 cnwsh3 03/09/2010
		if self.comparisonMode = TI_IMEX_STATUS_EXPORT and 	//If we are viewing loads (not discharges):
			self.myTrackedItem.isTranshipInbound() then 	//For tranship cargo, if we are viewing the outbound voyage, 
			return self.transhipDischargePort;				//we need to be able to see the tranship discharge port as opposed to the current discharge
															//port as the discharge port at this stage is the port we are currently travelling to.
		else
			return self.dischargePort;
			
		endif;
	
	endif;
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayValue" id="c46f9326-ddd0-4a7b-ab61-a96ff8cc3561">
        <source>getDisplayValue(_attrName: String): String;
//----------------------------------------------------------------
//	Created:	23 October 2003	by Jason Chapman  (cnwjc2)
// 26 Jun 2025  navbs1	Story 35185: MTN - Refactor Required to Stop Using getDisplayStringForAttribute() for Known Attributes
//----------------------------------------------------------------
vars

begin

	return self.getDisplayStringForAttribute(_attrName, false);

	
	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="976766cf-0310-46c8-815b-1dd7204507ad">
        <source>getExtraInfo(_dataCont: CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		29 June 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 11/11/2009	cnwmh5		PAR21557 - Change so that if myTrackedItem is
//							invalid doesn't cause a UE 4 to occur
// 07/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
// ---------------------------------------------------------------------------
vars
	block : CM_DataContainerBlock;
	aString : String;
	invalidObject	: Boolean;			// 11/11/2009 cnwmh5 #21557
	ti				: CM_TrackedItem;
begin
	ti := self.myTrackedItem;
	if ti &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, ti, invalidObject);		// 11/11/2009 cnwmh5 #21557
		if ti.isTranshipItem then
			aString := ti.getInfoStrTranship();
			block := _dataCont.addNewBlock;
			block.addNewItem(app.getErrorString(SHP_Tranship), DC_Warning, 1, ti);
			block.addNewItem(aString, DC_Data, 1, null);
		endif;
	endif;
	
	/*
	// 11/11/2009 cnwmh5 #21557 - replaced
	if self.myTrackedItem &lt;&gt; null
	and self.myTrackedItem.isTranshipItem then
	*/

	inheritMethod(_dataCont);

end;</source>
        <Parameter name="_dataCont" type="CM_DataContainer"/>
    </JadeMethod>
