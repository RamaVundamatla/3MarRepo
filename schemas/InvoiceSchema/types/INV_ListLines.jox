    <JadeMethod name="doMnuOOWShowBayClick" id="d39795bb-d6ef-4b9f-b8b8-7fa23fb318ae">
        <updating/>
        <source>doMnuOOWShowBayClick(menuItem: MenuItem input) updating;
// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
//  this menu item has been hijacked to be 'Show Snapshot Data' for these invoice lines
vars
	snapshot	:CM_OutputFormat_SS;
	agent		:CMIF_OutputFormatAgent_SS;
	format		:CM_OutputFormat_XTAB;
	coll		:CM_ObjectSet;
	form 		:CMUI_XTABDisplayForm;
	obj			:Object;
begin
	if self.myCurrentInvoiceLine = null then
		return;
	endif;
	snapshot := self.myCurrentInvoiceLine.mySnapShotData.mySnapshotData.myOutputFormat_SS;
	
	// create default xtab definition for selected snapshot
	create agent transient;
	format := agent.createXTABOutputFormat (snapshot, true);
	
	// create collection with selected snapshot data
	create coll transient;
	
	self.populateSnapshotCollection (coll);
	
	form := app.loadForm (CMUI_XTABDisplayForm, CMUI_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).CMUI_XTABDisplayForm;
	
	form.initialise (format, null, null, coll);
	form.myInitialSnapshot := self.myCurrentInvoiceLine.mySnapShotData;
	form.show;
epilog
	delete coll;
	delete agent;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuOverrideExtRefClick" id="3baf754f-a945-4991-88da-171c70d16160">
        <updating/>
        <source>doMnuOverrideExtRefClick(menuItem: MenuItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//08/12/2025	navkc1 JIRA 36262 ROS - 1 - External Reference updates in MTN 

*/

vars
	cmifHeader				: CMIF_InvoiceExternalRefHeader;
	allLinesToProcess,
	allLines				: CM_InvoiceLineBySeqNumDict;
	inv						: CM_Invoice;
	invLine					: CM_InvoiceLine;
	form					: INV_LinesOverrideExtReferences;
	allCMIFSummaries		: CMIF_InvoiceExtRefSummaries;
begin
	
	create cmifHeader transient;
	create allLines transient;
	create allLinesToProcess transient;
	
	self.tblData.allSelectedObjects.copy(allLines);
	
	// Get those invoice line which invoice type allows manual update external references
	foreach invLine in allLines do
		inv := invLine.invoice;
		
		if inv = null then
			app.invLog(method.getNiceName() &amp; " Invoice Line number " &amp; invLine.sequenceNum.String &amp; " has a null invoice. Skip", LogINFO.String);
			continue;
		endif;
		
		if not inv.isManUpdeExtRefAllowedForUser() then
			app.invLog(method.getNiceName() &amp; " Invoice Line number " &amp; invLine.sequenceNum.String &amp; ", Invoice number " &amp; inv.sequenceNum.String &amp; " does not allow manual edit external reference. Skip", LogINFO.String);
			continue;
		endif;
		
		allLinesToProcess.tryAdd(invLine);
	endforeach;
	
	if allLinesToProcess.isEmpty() then
		app.msgBox(app.getErrorString(NoInoivceLinesExtRefUpdAllowed), app.getErrorString(Information), MsgBox_OK_Only);
		return;
	endif;
	
	// Build summary
	cmifHeader.doBuildSummaryFromInvLines(allLinesToProcess);
	
	form := app.loadForm(INV_LinesOverrideExtReferences, INV_Assistant, false, false, false, self.getMyTerminal(), null).INV_LinesOverrideExtReferences;
	
	if form = null then
		return;
	endif;
	
	create allCMIFSummaries transient;
	
	cmifHeader.allSummaries.copy(allCMIFSummaries);
	
	// Set summary to form
	form.setMyCMIFSummary(allCMIFSummaries);
	form.myCMIFHeader := cmifHeader;
	form.showModal();

epilog

	delete allLines;
	delete allLinesToProcess;
	delete allCMIFSummaries;
end;</source>
        <Parameter name="menuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuSameInvDiffCargo" id="19bd9236-d9a2-46c1-b34f-735c01a74e9c">
        <source>doMnuSameInvDiffCargo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2023  navmv20 TFS 55304 Task 55545: UI - Invoice Line List Changes

*/

vars
	form : INV_LineCopyDiffCargoSameInv;
	rowSt,
	rowEnd,
	index : Integer;
	objSet : CM_InvoiceLineSet;
	invLine : CM_InvoiceLine;
begin
	
	rowSt := tblData.fixedRows + 1;
	rowEnd := tblData.rows;
	create objSet transient;
	foreach index in rowSt to rowEnd do
		if tblData.accessRow(index).selected then
			invLine := tblData.accessRow(index).itemObject.CM_InvoiceLine;
			if invLine.invoice &lt;&gt; self.myCurrentInvoice then
				app.msgBox(app.getErrorString(Select_lines_diff_invoices), app.getErrorString(Error),MsgBox_OK_Only);
				global.beep;
				return;
			endif;
			objSet.add(invLine);
		endif;
	endforeach;
	
	if objSet.isEmpty() then
		app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	
	form := app.loadForm(INV_LineCopyDiffCargoSameInv, 
					INV_Assistant, 
					false, 
					false,
					false, 
					self.myTerminal,
					null).INV_LineCopyDiffCargoSameInv;	
	
	if form = null then
		return;
	endif;
	form.createMyAssistant(INV_Assistant);
	form.setCurrentInvoice(self.myCurrentInvoice);
	form.setMyCurrentBank(self.myCurrentBank);
	objSet.copy(form.allSelectedInvoiceLines);
	form.showModal();
epilog
	delete objSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuSameInvSameCargo" id="0371079f-dbad-4e06-ba85-874d2893850d">
        <source>doMnuSameInvSameCargo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2023  navmv20 TFS 55304 Task 55545: UI - Invoice Line List Changes

*/

vars

	rowSt,
	rowEnd,
	index,
	theReturn	: Integer;
	objSet : CM_InvoiceLineSet;
	invLine : CM_InvoiceLine;
	controller : CMIF_InvoiceLineCopy;
begin
	
	rowSt := tblData.fixedRows + 1;
	rowEnd := tblData.rows;
	create objSet transient;
	foreach index in rowSt to rowEnd do
		if tblData.accessRow(index).selected then
			invLine := tblData.accessRow(index).itemObject.CM_InvoiceLine;
			if invLine.invoice &lt;&gt; self.myCurrentInvoice then
				app.msgBox(app.getErrorString(Select_lines_diff_invoices), app.getErrorString(Error),MsgBox_OK_Only);
				global.beep;
				return;
			endif;
			objSet.add(invLine);
		endif;
	endforeach;
	
	if app.msgBox(app.getErrorString1(Confirm_copy_inv_lines,(objSet.size()) .String),app.getErrorString(Confirmation),MsgBox_OK_Cancel) = MsgBox_Return_Cancel then
		global.beep;
		return;
	endif;
	
	create controller transient;
	objSet.copy(controller.allSelectedInvoiceLines);
	controller.setValues(false,false,false,null,null,null); 

	while true do
		app.myTrxCA.trxCopyInvoiceLine(controller,app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Invoice Line Copy", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				  theReturn = IDOK then
				  // there must have just been warnings that the user has acknoledged so ..
				  app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
			
		break;
	endwhile;

epilog
	delete controller;
	delete objSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="a4e6a0d5-2046-4d2f-a01b-a1d1250e6447">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:		23 February 2010 cnwjo3
//
// Purpose:		par 21915.  Each form should implement doNotableClear without an inheritMethod();
//
vars
	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		if anObject.isKindOf(CM_Invoice) then
			endNotification(anObject, self.myTerminal.getTerminalEvent(Event_InvoiceUpdate));
			removedNotification := removedNotification + 1;
		elseif anObject.isKindOf(CM_InvoiceLine) then
			endNotification(anObject, self.myTerminal.getTerminalEvent(Event_InvoiceLineUpdate));
			removedNotification := removedNotification + 1;
		elseif anObject.isKindOf(CM_CashPayment) then
			endNotification(anObject, self.myTerminal.getTerminalEvent(Event_CashPaymentUpdate));
			removedNotification := removedNotification + 1;
		endif;
	endforeach;

	validateNotificationRemoval(removedNotification,self.allNotableObjects.size);
	
	self.allNotableObjects.clear;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPaginatedNoteAdd" id="3cdea9b5-fec3-4068-814b-ef41dd26d9f1">
        <source>doPaginatedNoteAdd(_obj: CM_Object);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Jul 2025	navbs1	Initial creation Story MTN-35314: MTN | Pagination - Invoice Line List

*/

vars
	invoiceLine : CM_InvoiceLine;
	cashPayment : CM_CashPayment;
	
begin
		if _obj.isKindOf(CM_InvoiceLine) then
			invoiceLine := _obj.CM_InvoiceLine;		

			// setup note for this item
			self.doNotableAdd(invoiceLine);
			self.doNotableAdd(invoiceLine.invoice);
			
		elseif _obj.isKindOf(CM_CashPayment) then			
			cashPayment := _obj.CM_CashPayment;				
			self.doNotableAdd(cashPayment);			
		endif;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="doPaginatedNoteClear" id="251e1ced-1596-4bd3-bd2c-f703121d77bc">
        <source>doPaginatedNoteClear();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Aug 2025	navbs1	Initial creation Story MTN-35314: MTN | Pagination - Invoice Line List

*/

vars

begin
	self.doNotableClear();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPreQuery" id="8d7e206f-f9e1-4d4a-9d98-2d0e0e132944">
        <updating/>
        <source>doPreQuery() updating;
// ---------------------------------------------------------------------------
// Created:		28 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	self.specialQuery := false;
	self.myCurrentInvoice := null;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrintInvoice" id="fda10c12-8344-44d9-b2b2-18057c1fede4">
        <source>doPrintInvoice(preview: Boolean; _consolidate: Boolean; _oneLine: Boolean);
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	dateStr,mess, head : String;
	bank : CM_Bank;
begin
	if not global.isValidObject(self.myCurrentInvoice) then
		app.msgBox("Please select something to print.", "Print Error", MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	bank := self.myCurrentBank;

	mess := "Printing Invoice Items for Invoice " &amp; self.myCurrentInvoice.sequenceNum.String &amp; "  - " &amp; self.myCurrentInvoice.debtor.name;

	head := "Invoice Items for Invoice " &amp; self.myCurrentInvoice.sequenceNum.String &amp; "  - " &amp; self.myCurrentInvoice.debtor.name;
	
	self.doTblDataPrint(mess,head,"Invoice Items");

end;</source>
        <Parameter name="preview" type="Boolean"/>
        <Parameter name="_consolidate" type="Boolean"/>
        <Parameter name="_oneLine" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doQuery" id="d3ff930e-c6d4-4a1f-a33b-3e8478f70393">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//	
// Purpose:		
//	Populate self.allInvoiceLines from the selections made on the query form.
//	Showing the results in the table has been moved Oct 2010 to populateInvoiceTable for par 21800 to allow
//	  displaying all invoice lines from a given snapshot summary data item.
// 21/04/2016 cnwma1 PAR #37681  QNS - locking issue
//	29 Mar 2023	navmv20 Bug 57023: EUP - inconsistent search behaviour with external number
//31 Jul 2025	navbs1	Story MTN-35314: MTN | Pagination - Invoice Line List
//09 Sep 2025	navbs1 	Bug 35962: MTN | Invoice Lines Form displaying empty rows when rows are added from Selector form
// ---------------------------------------------------------------------------

vars
	bolId			: String;
	mode			: Integer;
	consignee		: CM_ConsigneeConsignor;
	voyage			: CM_Voyage;
	iter			: Iterator;
	theDebtor : CM_Debtor;
	invLine:    CM_InvoiceLine;
	theTI : CM_TrackedItem;
	aBank,bank : CM_Bank;
	lineType : CM_InvoiceLineDesc;
	invoice  : CM_Invoice; 		//29/03/2023 navmv20 Bug 57023
	theCaption : String;
	searchFor,					//29/03/2023 navmv20 Bug 57023
	invByInvoiceNum,			//29/03/2023 navmv20 Bug 57023
	invLineByNumber,			//29/03/2023 navmv20 Bug 57023
	invByInvExtNum,				//29/03/2023 navmv20 Bug 57023
	invExtNumber,				//29/03/2023 navmv20 Bug 57023
	extNum			: String;	//29/03/2023 navmv20 Bug 57023
	invoiceSet      : CM_InvoiceSet; //14/04/2023 navmv20 Bug 57023
	cashPayment     : CM_CashPayment; //14/04/2023 navmv20 Bug 57023

begin

	self.myCurrentInvoiceLine := null;
	// from par 21800 when invoice lines are displayed from snapshot data, keep using the allInvoiceLines content
	//  until an explicit query is done, for refresh and table column changes etc
	if self.specialQuery then
		self.textSearch.text := null; //03/04/2023 navmv20 Bug 57023
		self.populateInvoiceTable(true);
		return;
	endif;

	self.allInvoiceLines.clear;
	self.allCashPayments.clear();
	// 05/09/2014 cnwar2 #34862 - only clear filter on initial load, not for every query
	//self.clearTableFilter();	// 30931
	
	// ######################
	// ## LINES FOR an INVOICE 
	// ######################
	bank := self.cmbBank.listObject.CM_Bank;
	
	//29 Mar 2023 navmv20 Bug 57023 - START
	if self.cmbSearchFor.listIndex &gt; 0 then
		searchFor := self.cmbSearchFor.itemText[self.cmbSearchFor.listIndex];
	endif;
		
	invByInvoiceNum   := app.getErrorString(Invoice_invoice_number);
	invLineByNumber   := app.getErrorString(Invoice_line_number);
	invByInvExtNum    := app.getErrorString(Inv_external_number);
		
	//if self.btnQueryInvoice.value and self.textSearch.text &lt;&gt; null and self.optSearchInvoice.value then
	if self.btnQueryInvoice.value and self.textSearch.text &lt;&gt; null and searchFor = invByInvoiceNum then
	//29 Mar 2023 navmv20 Bug 57023 - END	
		if bank &lt;&gt; null then
			//self.myCurrentInvoice := bank.allInvoices[self.myTerminal,bank,self.textSearch.text.Integer]; //29/03/2023 navmv20 Bug 57023
			self.myCurrentInvoice := bank.allInvoices[self.myTerminal,bank,self.textSearch.text.Integer]; //29/03/2023 navmv20 Bug 57023
		else
			//foreach aBank in self.myTerminal.companies where aBank.isBusinessUnit  do
			foreach aBank in self.myTerminal.companies discreteLock where aBank.isBusinessUnit  do //21/04/2016 cnwma1 PAR #37681 
				//self.myCurrentInvoice :=aBank.allInvoices[self.myTerminal,aBank,self.textSearch.text.Integer]; //29/03/2023 navmv20 Bug 57023
				self.myCurrentInvoice :=aBank.allInvoices[self.myTerminal,aBank,self.textSearch.text.Integer]; //29/03/2023 navmv20 Bug 57023
				if self.myCurrentInvoice &lt;&gt; null then
					break;
				endif;
			endforeach;
		endif;
		
		if self.myCurrentInvoice &lt;&gt;  null then
			self.myCurrentInvoice.invoiceLines.copy(self.allInvoiceLines);
			self.myCurrentInvoice.allCashPayments.copy(self.allCashPayments);
			self.doNotableAdd(self.myCurrentInvoice);
			theCaption := app.getErrorString(INV_Invoice_Items_For_Invoice) &amp; self.myCurrentInvoice.sequenceNum.String &amp;'"';
		endif;
	// ######################
	// ## A LINE (PAR35397) moved the line search up because the asistant show invoice line did not work
	// ######################
	//elseif  self.btnQueryInvoice.value and  self.textSearch.text &lt;&gt; null and self.optSearchLine.value then //29/03/2023 navmv20 Bug 57023
	elseif  self.btnQueryInvoice.value and  self.textSearch.text &lt;&gt; null and searchFor = invLineByNumber then //29/03/2023 navmv20 Bug 57023
		if bank &lt;&gt; null then
			//invLine := bank.invoiceLines[self.myTerminal,bank,self.textSearch.text.Integer]; //29/03/2023 navmv20 Bug 57023
			invLine := bank.invoiceLines[self.myTerminal,bank,self.textSearch.text.Integer]; //29/03/2023 navmv20 Bug 57023

		else
			//foreach aBank in self.myTerminal.companies where aBank.isBusinessUnit  do
			foreach aBank in self.myTerminal.companies discreteLock where aBank.isBusinessUnit  do //21/04/2016 cnwma1 PAR #37681 
				//invLine := aBank.invoiceLines[self.myTerminal,aBank,self.textSearch.text.Integer]; //29/03/2023 navmv20 Bug 57023
				invLine := aBank.invoiceLines[self.myTerminal,aBank,self.textSearch.text.Integer]; //29/03/2023 navmv20 Bug 57023
				if invLine &lt;&gt; null then
					break;
				endif;
			endforeach;
		endif;
	
		if invLine &lt;&gt; null then
			self.allInvoiceLines.add(invLine);
			self.myCurrentInvoiceLine := invLine;
			self.myCurrentInvoice := invLine.invoice;
			theCaption := app.getErrorString(INV_Invoice_Item) &amp; invLine.sequenceNum.String; // &amp;'"';
		endif;
	//29/03/2023 navmv20 Bug 57023 - start
	elseif self.btnQueryInvoice.value and self.textSearch.text &lt;&gt; null and searchFor = invByInvExtNum then
		invExtNumber := self.textSearch.text.toUpper();
		self.myCurrentInvoice := null;
		create invoiceSet transient;
		if bank &lt;&gt; null then
			foreach invoice in bank.allInvoicesByExtNumber do
				if invoice.externalNumber &lt;&gt; null then
					extNum := invoice.externalNumber.toUpper;
					if extNum.cnContains(invExtNumber) then
						invoiceSet.add(invoice);
					endif;
				endif;
			endforeach;
			
		else
			foreach aBank in self.myTerminal.companies discreteLock where aBank.isBusinessUnit  do
				foreach invoice in aBank.allInvoicesByExtNumber do
					if invoice.externalNumber &lt;&gt; null then
						extNum := invoice.externalNumber.toUpper;
						if extNum.cnContains(invExtNumber) then
							invoiceSet.add(invoice);
						endif;
					endif;
				endforeach;
			endforeach;
		endif;
		
		self.allInvoiceLines.clear();
		self.allCashPayments.clear();
		foreach invoice in invoiceSet do
			foreach invLine in invoice.invoiceLines do
				self.allInvoiceLines.add(invLine);
			endforeach;
			
			foreach cashPayment in invoice.allCashPayments do
				self.allCashPayments.add(cashPayment);
			endforeach;
			doNotableAdd(invoice);
		endforeach;
		
		theCaption := app.getErrorString(INV_Invoice_Items_For_ExtNum) &amp; invExtNumber;

	//29/03/2023 navmv20 Bug 57023 - End
	// ######################
	// ## DEBTOR
	// ######################
	elseif self.cmbDebtor.listIndex &gt; 0 then
		self.textSearch.text := null; //03/04/2023 navmv20 Bug 57023
		theDebtor := self.cmbDebtor.listObject.CM_Debtor;
		if theDebtor = null then
			return;
		endif;
		
		lineType := self.cmbInvLineTypeQu.listObject.CM_InvoiceLineDesc; // PAR 34469
		
		//foreach invLine in theDebtor.invoiceLines reversed do
		foreach invLine in theDebtor.invoiceLines discreteLock,reversed do //21/04/2016 cnwma1 PAR #37681 
			if self.mode &lt;&gt;  self.Mode_MultiTerminal and invLine.getTerminal &lt;&gt; self.myTerminal then
				continue;
			endif;
			
			if lineType &lt;&gt; null and invLine.invoiceLineDesc &lt;&gt; lineType then // PAR 34469
				continue;
			endif;
			
			if bank = null or invLine.bank = bank then
				self.allInvoiceLines.add(invLine);
			endif;
			if not self.tblData.isPaginated and self.allInvoiceLines.size &gt; JadeTableRowLimit then			//04.08.2025 navbs1 #35314		//09.09.2025 navbs1 #35962
				break;
			endif;
		endforeach;
		theCaption := app.getErrorString(INV_Invoice_Items_For_Debtor) &amp; theDebtor.name; // &amp;'"';
	// ######################
	// ## INVOICE LINE TYPE  // PAR 34469
	// ######################
	elseif  self.btnQueryDebtor.value and bank &lt;&gt; null then // PAR 34469
		self.textSearch.text := null; //03/04/2023 navmv20 Bug 57023
		theDebtor := self.cmbDebtor.listObject.CM_Debtor;
		//self.btnQueryDebtor.value
		lineType := self.cmbInvLineTypeQu.listObject.CM_InvoiceLineDesc;
		
		//foreach invLine in bank.invoiceLinesByDateTime do
		foreach invLine in bank.invoiceLinesByDateTime discreteLock do  //21/04/2016 cnwma1 PAR #37681 
			if self.mode &lt;&gt;  self.Mode_MultiTerminal and invLine.getTerminal &lt;&gt; self.myTerminal then
				continue;
			endif;
			
			if lineType &lt;&gt; null and invLine.invoiceLineDesc &lt;&gt; lineType then
				continue;
			endif;
			
			self.allInvoiceLines.add(invLine);

			if not self.tblData.isPaginated and self.allInvoiceLines.size &gt; JadeTableRowLimit then			//04.08.2025 navbs1 #35314		//09.09.2025 navbs1 #35962
				break;
			endif;
		endforeach;
	
		theCaption := "Invoice Lines of type '" &amp; self.cmbInvLineTypeQu.text &amp; "'"; // app.getErrorString(INV_Invoice_Items_For_Debtor) &amp; theDebtor.name; // &amp;'"';
	// ######################
	// ## CARGO
	// ######################
	elseif self.cmbCargoID_.listIndex &gt; 0 then
		self.textSearch.text := null; //03/04/2023 navmv20 Bug 57023
		theTI := self.cmbCargoID_.listObject.CM_TrackedItem;
		if theTI = null then
			return;
		endif;
		//foreach invLine in theTI.invoiceLines do
		foreach invLine in theTI.invoiceLines discreteLock do //21/04/2016 cnwma1 PAR #37681 
			if invLine.bank = self.myCurrentBank then
				self.allInvoiceLines.add(invLine);
			endif;
		endforeach;
		if self.allInvoiceLines.size = 0 then
			return;
		endif;
		theCaption := app.getErrorString(I_Invoice_Items_For_Tracked_It) &amp; theTI.id; // &amp;'"';
	// #### BOL or consignee ################
	// 30931 search by BOL or consignee
	elseif self.cmbBOL.text &lt;&gt; null or		// 33528
		   self.cmbCnee.listObject &lt;&gt; null then
		self.textSearch.text := null; //03/04/2023 navmv20 Bug 57023
		bolId := self.cmbBOL.text.trimBlanks();
		consignee := self.cmbCnee.listObject.CM_ConsigneeConsignor;
		mode := self.cmbCargoSite_.itemData[self.cmbCargoSite_.listIndex];
		if mode = TI_SITE_ONSITE then
			iter := self.myTerminal.allOnsiteTIsByCargoTypeId.createIterator;
		elseif mode = TI_SITE_OFFSITE then
			iter := self.myTerminal.allOffsiteTIsByCargoTypeId.createIterator;
		elseif mode = TI_SITE_TBA then
			iter := self.myTerminal.allTbaTIsByCargoTypeId.createIterator;
		elseif mode = TI_SITE_ONSHIP then
			voyage := self.cmbCargoVoyage_.listObject.CM_Voyage;
			if voyage &lt;&gt; null then
				iter := voyage.allOnshipTIsByCargoTypeId.createIterator();
			endif;
		endif;
		if iter &lt;&gt; null then
			while iter.next(theTI) do
				if (bolId &lt;&gt; null and
					theTI.billOfLading = bolId) or
				   (consignee &lt;&gt; null and 
					theTI.consignee = consignee.code) then
					//foreach invLine in theTI.invoiceLines do
					foreach invLine in theTI.invoiceLines discreteLock do //21/04/2016 cnwma1 PAR #37681 
						self.allInvoiceLines.add(invLine);
					endforeach;
				endif;
			endwhile;
		endif;
	endif;
	
	//03/04/2023 navmv20 Bug 57023 - start
	if not self.btnQueryInvoice.value then
		self.textSearch.text := null;
	endif;
	//03/04/2023 navmv20 Bug 57023 - end
	self.populateInvoiceTable(true);
	self.applyColumnFilter( self.tblData );		// 05/09/2014 cnwar2 #34862 - reapply any column filters
	self.setCaption(theCaption &amp; " " &amp; self.myCurrentBank.code); // 	TFS 2682
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryAddLine" id="7a6c1558-6c8b-4ae8-8703-b6008a82d6ad">
        <updating/>
        <source>doQueryAddLine(_theInvoiceLine : CM_InvoiceLine) updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
 
//Return Value:		
 
// Date			Who		Reason
//29 Jul 2025	navbs1	Story MTN-35314: MTN | Pagination - Invoice Line List
//09 Sep 2025	navbs1 	Bug 35962: MTN | Invoice Lines Form displaying empty rows when rows are added from Selector form
// ---------------------------------------------------------------------------
vars
	theDataLine : String;
	idx : Integer;
begin
	if not self.tblData.isPaginated then 											//31.07.2025 navbs1 #35314		//09.09.2025 navbs1 #35962	
		theDataLine := _theInvoiceLine.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);	
	endif;
	//idx := self.tblData.addItem(theDataLine);										//29.07.2025 navbs1 #35314
	//self.tblData.accessRow(idx).itemObject := _theInvoiceLine;					//29.07.2025 navbs1 #35314	
	self.tblData.addItemObject(_theInvoiceLine, theDataLine);						//29.07.2025 navbs1 #35314
 
	// setup note for this item
	self.doNotableAdd(_theInvoiceLine);
	self.doNotableAdd(_theInvoiceLine.invoice);
end;</source>
        <Parameter name="_theInvoiceLine" type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="doQueryAddPayment" id="c747aa6a-eafd-4e53-bc92-7adf4a39dd5d">
        <updating/>
        <source>doQueryAddPayment(_cashPayment : CM_CashPayment) updating;
// ---------------------------------------------------------------------------
// Created:		
//
// Purpose:		
 
//Return Value:		
 
// Date			Who		Reason
//31 Jul 2025	navbs1	Story MTN-35314: MTN | Pagination - Invoice Line List
//09 Sep 2025	navbs1 	Bug 35962: MTN | Invoice Lines Form displaying empty rows when rows are added from Selector form
// ---------------------------------------------------------------------------

vars
	theDataLine : String;
	idx : Integer;
begin
	if not self.tblData.isPaginated then 									//04.08.2025 navbs1 #35314			//09.09.2025 navbs1 #35962	
		theDataLine := _cashPayment.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
	endif;
	/*idx := self.tblData.addItem(theDataLine);								//31.07.2025 navbs1 #35314
	self.tblData.accessRow(idx).itemObject := _cashPayment;*/				//31.07.2025 navbs1 #35314
	self.tblData.addItemObject(_cashPayment, theDataLine);
	
	// setup note for this item
	self.doNotableAdd(_cashPayment);

end;</source>
        <Parameter name="_cashPayment" type="CM_CashPayment"/>
    </JadeMethod>
    <JadeMethod name="doReevaluate" id="218bcd92-6c77-41f7-acbb-c77bf4991d1e">
        <updating/>
        <source>doReevaluate() updating;
// ---------------------------------------------------------------------------
// Created:		20 January 2006  By Andrew Bishop cnwab1
//
// Purpose:		CCMS 1005
//				Looging added Apr 2012 as part of CCMS 1264
// ---------------------------------------------------------------------------
/*
Date			Who		Reason
18 Oct 2024		navlw1	JIRA-33107: Invoice Logging Use Levels
*/
vars
	theReturn,num : Integer;
	obj		: Object;
	invs : CM_InvoiceLineBySeqNumDict;
	inv : CM_InvoiceLine;
	txtInv, strTxt : String;
	numEval, numMoved : Integer;
	controller : CMIF_InvoiceLineReeval;
	logger	: CMIF_Logger;

begin
	create invs transient;
	foreach obj in self.tblData.allSelectedObjects do
		if obj.isKindOf(CM_InvoiceLine) then
			invs.add(obj.CM_InvoiceLine);
		endif;
	endforeach;
	num := invs.size;
	if num = 0 then 
		app.msgBox("Please select an invoice line to re-evaluate.","Error",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	create controller transient;
	
	foreach inv in invs do
		if txtInv = null then
			txtInv := inv.sequenceNum.String;
		else
			txtInv := txtInv &amp; ", " &amp; inv.sequenceNum.String;
		endif;
		controller.allInvoiceLines.add(inv);
		
	endforeach;
	
	if num = 1 then
		if app.msgBox("Re-evaluate invoice line "  &amp; txtInv &amp; "?","Confirm Re-evaluation",MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	elseif num &lt; 10 then
		if app.msgBox("Re-evaluate invoice lines:" &amp; Cr &amp; Cr &amp; txtInv &amp; "?","Confirm Re-evaluation",MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	else
		if app.msgBox("Re-evaluate " &amp; num.String &amp; " invoice lines?","Confirm Re-evaluation",MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	endif;
	
	create logger transient;
	app.setLogger(logger);
	
	controller.reEvaluate := true; // ### TFS DEFECT 63720 24APR2024 NAVAB1
	
	while true do
		app.myTrxUA.trxUpdateInvoiceLineReeval(controller, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Invoice Line Re-evaluate", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

	numEval := controller.numEval;
	numMoved := controller.numMoved;
	
	app.invLog("** Summary **", LogINFO.String);
	if numEval = 1 then
		strTxt := "1 invoice line was re-evaluated.";
	else
		strTxt := numEval.String &amp; " invoice lines were re-evaluated.";
	endif;
	app.invLog(strTxt, LogINFO.String);
	if numMoved = 1 then
		strTxt := "1 was moved to a different invoice.";
	else
		strTxt := numMoved.String &amp; " were moved to a different invoice";
	endif;
	app.invLog(strTxt, LogINFO.String);

	self.doShowReevaluateLogging(logger);
epilog
	delete controller;	 
	delete invs;
	if logger &lt;&gt; null then
		app.setLogger(null);	// this deletes the 'logger' instance
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResetSearch" id="138e6d99-9023-48d6-ab15-1164cb235d66">
        <source>doResetSearch();
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 29 Mar 2023	navmv20 Bug 57023: EUP - inconsistent search behaviour with external number

vars

begin
	inheritMethod();

	self.cmbCargoID_.listIndex := -1;
	self.cmbCargoSite_.listIndex := 1;
	self.cmbCargoType_.listObject := app.myPassport.getDefaultCargoType();
	self.cmbCargoVoyage_.listIndex := -1;
	
	//29/03/2023 navmv20 Bug 57023 - START
	//self.optSearchLine.value := true; 
	self.cmbSearchFor.listIndex := self.cmbSearchFor.findStringExact(1,app.getErrorString(Invoice_invoice_number));
	self.textSearch.dataType := TextBox.DataType_Numeric;
	self.textSearch.maxLength := 9;
	//29/03/2023 navmv20 Bug 57023 - END

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveChangeStatus" id="4090706f-bfe7-45fb-89b0-3f21ce228bce">
        <updating/>
        <source>doSaveChangeStatus(_status : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		Set the void status on the selected invoice lines/cash payments to the entered value.
//
// ---------------------------------------------------------------------------
//23/04/2018 JLGNS1 Bug 38115: GUQ - 7206 extension-Show Parent &amp; Child items from BOL (issue 2)

vars
	theStatus : CMIF_InvoiceStatus;
	pxyInvoiceLine	: CM_InvoiceLine;
	pxyPayment	: CM_CashPayment;
	anObject : Object;
	theReturn	: Integer;
	statusDesc	: String;
	msgString 	: String;
	countPosted 	: Integer;
begin

	if self.myCurrentInvoiceLine = null and
	   self.myCurrentCashPayment = null then
		app.msgBox("Please select an Invoice Line.", "Status Change Error",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	create theStatus transient;
	
	foreach anObject in self.tblData.allSelectedObjects do
		if anObject.isKindOf(CM_InvoiceLine)  then
		//	if anObject.CM_InvoiceLine.invoice.status = CM_Invoice.INVOICE_POSTED then
			if anObject.CM_InvoiceLine.invoice.isPostedOrReversal then	//04 Sep 2017	NDL	TFS 6759
				countPosted := countPosted + 1;
			else
				pxyInvoiceLine := app.createUpdateProxy(anObject.CM_Object).CM_InvoiceLine;
				theStatus.allInvoiceLines.add(pxyInvoiceLine);
			endif;
		elseif anObject.isKindOf(CM_CashPayment)  then
			//epr par 34754 5/9/14 
			if  anObject.CM_CashPayment.myInvoice &lt;&gt; null and  anObject.CM_CashPayment.myInvoice.isPosted then
				countPosted := countPosted + 1;
			else
				pxyPayment := app.createUpdateProxy(anObject.CM_Object).CM_CashPayment;
				theStatus.allCashPayments.add(pxyPayment);
			endif;
		endif;
	endforeach;
	if countPosted &lt;&gt; 0 then
		msgString := "There are " &amp; countPosted.String &amp; " lines for posted invoices in the current selection." &amp;
					 CrLf &amp; CrLf &amp; "These will be ignored.  Do you wish to continue?";
		if app.msgBox(msgString, "Ignore invoice lines?", MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
			// TFS 2085 close the Void Reason frame, if showing
			self.tblInvProperties.clearValues;
			self.frmInvProperties.visible := false;
			return;
		endif;
	endif;
	
	if _status = CM_InvoiceLine.STATUS_NORMAL then
		statusDesc := "Normal";
	elseif _status = CM_InvoiceLine.STATUS_VOIDED then
		statusDesc := "Void";
		
	endif;
	
	if self.myTerminal.allInvoiceStatusReasons.size &gt; 0 and self.tblInvProperties.isRowVisible(ETRow_VoidReason) and self.myCurrentInvoiceLine &lt;&gt; null then // Bug 38115
		//epr par 36958
		theStatus.voidReason:= self.tblInvProperties.getValueByName(ETRow_VoidReason).asStringJMT;
		theStatus.voidReasonCode:=self.tblInvProperties.getValueByName(ETRow_VoidReasonCode).asStringJMT;
		
		if theStatus.voidReason = null then
			app.msgBox(app.getErrorString( Input_required_field_reason),app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		if theStatus.voidReasonCode = null then
			app.msgBox(app.getErrorString( Input_required_field_reasonCde),app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	endif;
	
	if app.msgBox(app.getErrorString(WARN_CHANGE_CHARGE)&amp; " Do you want to continue?",
		"Changing Invoice Line Status for " &amp; self.tblData.allSelectedObjects.size.String &amp; " line(s) " &amp; statusDesc,
		MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_No  then
		// TFS 2085 close the Void Reason frame, if showing
		self.tblInvProperties.clearValues;
		self.frmInvProperties.visible := false;
		return;
	endif;
	
	theStatus.newStatus := _status;
	
	if theStatus.allInvoiceLines.isEmpty and
	   theStatus.allCashPayments.isEmpty then
		if countPosted &lt;&gt; 0 then
			app.msgBox("No invoice lines to be updated, this could be because the invoice has been POSTED.","Invoice Has Been Posted, Nothing to Update",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			// TFS 2085 close the Void Reason frame, if showing
			self.tblInvProperties.clearValues;
			self.frmInvProperties.visible := false;
			return;
		else
			app.msgBox("No invoice lines to be updated, please select some invoice lines to update","Invoice Line Status Change",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			// TFS 2085 close the Void Reason frame, if showing
			self.tblInvProperties.clearValues;
			self.frmInvProperties.visible := false;
			return;
		
		endif;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateInvoiceStatus(theStatus,app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			// TFS 2085 close the Void Reason frame, if showing
			self.tblInvProperties.clearValues;
			self.frmInvProperties.visible := false;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(CM_Update_Invoice), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
epilog
	self.btnSearchCargo.visible := true;	//09 Mar 2020	NDL	TFS 48823
	if theStatus &lt;&gt; null then
		theStatus.allInvoiceLines.purge;
		theStatus.allCashPayments.purge;
	endif;
	delete theStatus;
end;</source>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doSelectorQuery" id="870054b5-34c8-41b8-a295-e8d761375377">
