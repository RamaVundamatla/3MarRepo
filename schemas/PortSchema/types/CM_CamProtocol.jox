    <JadeMethod name="getNextSeqNumber" id="a84bf69d-8b29-4249-8415-0bbbfd79d36e">
        <updating/>
        <source>getNextSeqNumber(_seqNumber:Integer io; _dailySeqNumber:Integer io; _status : Integer io) updating;
//
//25 May 2012	cnwrs1		Par 26914 - make cams restart after lock error
//
//25 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
//30 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
vars
	camTaskHistory : CM_CamTaskHistory;
begin
	camTaskHistory := self.taskHistoryByProtocolSeq.last;
	if camTaskHistory = null or
	   camTaskHistory.seqNumber = 0 then
		_seqNumber := 1;
		_dailySeqNumber := 1;
	else
		if camTaskHistory.status &lt;&gt; CAM_COMPLETESTATUS then
			_seqNumber := camTaskHistory.seqNumber;
			_dailySeqNumber := 1;
			_status := camTaskHistory.status;
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;camTaskHistory.fileData.size.String;
		else	
			_seqNumber := camTaskHistory.seqNumber + 1;
			if lastRunDateTime.date = camTaskHistory.startDateTime.date then
				_dailySeqNumber := camTaskHistory.dailySeqNumber + 1;
			else
				_dailySeqNumber := 1;
			endif;
		endif;
	endif;
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;camTaskHistory.String&amp;' _seqNumber='&amp;_seqNumber.String&amp;' _dailySeqNumber='&amp;_dailySeqNumber.String;
end;</source>
        <Parameter name="_seqNumber" type="Integer" usage="io"/>
        <Parameter name="_dailySeqNumber" type="Integer" usage="io"/>
        <Parameter name="_status" type="Integer" usage="io"/>
    </JadeMethod>
