        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="bnOpenSession_click" id="dcc423cc-22e9-4ad2-9c65-b4279ce78ef6">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>bnOpenSession_click(btn: Button input) updating;

vars
	offset : Integer;
	
begin
	if jjAccess &lt;&gt; null then
		postMsg("Error: session already active");
	else
		if txJournalNumber.text.Integer &lt;= 0 then
			postMsg("Error: journal number is invalid");
		elseif txJournalOffset.text.Integer &lt; 0 then
			postMsg("Error: journal offset is invalid");
		elseif txJournalPath.text.length = 0 then
			postMsg("Error: journal path is empty");
		else
			create jjAccess;
			
			offset := txJournalOffset.text.Integer;
			
			jjAccess.getJournal(txJournalPath.text,
								txJournalNumber.text.Integer,
								offset);
			
			bnOpenSession.enabled := false;
			bnCloseSession.enabled := true;
			bnNextJournal.enabled := true;
			bnLoadRemaps.enabled := true;
			bnClearRemaps.enabled := true;
			bnRegisterClass.enabled := true;
			bnClearClasses.enabled := true;
			bnFindNext.enabled := true;
			bnNextRecord.enabled := true;
			bnBeforeImage.enabled := false;
			bnAfterImage.enabled := false;
			bnDeltaObject.enabled := false;
			
			txJournalNumber.text := jjAccess.getJournalNumber().String;
			txJournalPath.text := jjAccess.getJournalPath();
			
			utcBias := jjAccess.getUTCBias;
			
			updateCurrentJournal;
		endif;
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="bnRegisterClass_click" id="69dd27d3-e2c5-45e7-b8e4-3cb388dd4012">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>bnRegisterClass_click(btn: Button input) updating;

vars
	classNumber		: Integer;
	parClassNumber	: Integer;

begin
	jjAccess.setFilterExcludes(cbExcludeClasses.value);
	
	classNumber := txRegClassNo.text.Integer;
	parClassNumber := txRegParClassNo.text.Integer;
	
	if classNumber &gt; 0 then
		if parClassNumber &gt; 0 then
			postMsg("calling registerFilterCollection(" &amp; classNumber.String &amp; "," &amp; parClassNumber.String &amp; ")");
			
			jjAccess.registerFilterCollection(classNumber, parClassNumber);
			
			postMsg("registerFilterCollection(" &amp; classNumber.String &amp; "," &amp; parClassNumber.String &amp; ") performed");
		elseif parClassNumber = 0 then
			postMsg("calling registerFilterClass(" &amp; classNumber.String &amp; ")");
			
			jjAccess.registerFilterClass(classNumber);

			postMsg("registerFilterClass(" &amp; classNumber.String &amp; ") performed");
		else
			postMsg("Error: invalid parent class number");
		endif;
	else
		postMsg("Error: invalid class number");
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cbExcludeClasses_click" id="bb01bf4c-a917-4690-b1ad-ca4b391eeabb">
        <controlMethod name="CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cbExcludeClasses_click(checkbox: CheckBox input) updating;

vars
	msg : String;
	
begin
	jjAccess.setFilterExcludes(checkbox.value);

	if cbExcludeClasses.value then
		msg := "re";
	endif;

	postMsg("Filters will exclude is " &amp; msg &amp; "set");
end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createUserTracker" id="494bcedf-6907-49f1-8727-ed60b585c7a4">
        <source>createUserTracker(userName : String; userIndex : Integer; logonTime : TimeStamp) : AuditAccessUserTracker;

/*

Purpose:			


Return Value:		


Date		Who		Reason
24 January 2005	cnwkpd1	PAR #5202 - SUTARE 1007 Timer Task

*/

vars
	userTracker		: AuditAccessUserTracker;
	
begin
	// Handle error condition
	deleteUserTracker(userIndex);
		
	create userTracker transient;
	userTracker.userIndex := userIndex;
	userTracker.userName := userName;
	userTracker.logonTime := logonTime;
	allAuditAccessUsers.add(userTracker);

	updateUserTable;
	
	return userTracker;
	

epilog

end;</source>
        <Parameter name="userName" type="String"/>
        <Parameter name="userIndex" type="Integer"/>
        <Parameter name="logonTime" type="TimeStamp"/>
        <ReturnType type="AuditAccessUserTracker"/>
    </JadeMethod>
    <JadeMethod name="deleteUserTracker" id="5df12d92-018e-4225-9616-f56ccc186f24">
        <source>deleteUserTracker(userIndex : Integer);

/*

Purpose:			


Return Value:		


Date		Who		Reason
24 January 2005	cnwkpd1	PAR #5202 - SUTARE 1007 Timer Task

*/

vars
	userTracker		: AuditAccessUserTracker;
	
begin
	userTracker := allAuditAccessUsers[userIndex];
	if userTracker &lt;&gt; null then
		allAuditAccessUsers.remove(userTracker);
		delete userTracker;
		updateUserTable;
	endif;


epilog

end;</source>
        <Parameter name="userIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNextRecord" id="ae50f984-c1c3-4a75-b9cf-d81b6d532041">
        <source>getNextRecord() : Integer;

/*

Purpose:			Get the next record (if there is one)


Return Value:		Record type, or zero if there are no more


Date		Who		Reason
24 Jan 2005	cnwkpd1	Initial creation

*/

vars
	recordType		: Integer;
	recordOffset	: Integer;
	localTimeStamp,
	timeStamp		: TimeStamp;
	serialNumber	: Decimal [12];
	transactionId	: Decimal [12];
	object			: Object;
	edition			: Integer;
	userName		: String;
	userIndex		: Integer;
	cUserName		: String;
	cUserIndex		: Integer;
	validObject		: Boolean;	
	returnVal		: Integer;
	objectType		: Integer;
	oid				: String;
	classNumber		: Integer;
	
begin
	if jjAccess.getNextRecord(recordType, 
							  objectType, 
							  recordOffset, 
							  timeStamp, 
							  serialNumber, 
							  transactionId,
							  oid,
							  classNumber,
							  edition) then
		lpType.caption:= getRecordTypeDescription(recordType) &amp; " (" &amp; recordType.String &amp; ")";
		lpOffset.caption:= recordOffset.String;
		localTimeStamp := timeStamp.utcToLocalTimeUsingBias(utcBias);
		lpTimestamp.caption:= localTimeStamp.String;
		lpSequence.caption:= serialNumber.String;
		lpTranid.caption:= transactionId.String;
		lpOid.caption:= oid &amp; ":" &amp; edition.String;

		if recordType = JadeAuditAccess.Jaa_Type_UserSignOn or recordType = JadeAuditAccess.Jaa_Type_UserSignOff then
			jjAccess.getUserData(userName, userIndex);
			lpUserName.caption:= userName;
			lpUserIndex.caption := userIndex.String;

			if recordType = JadeAuditAccess.Jaa_Type_UserSignOn then
				createUserTracker(userName, userIndex, localTimeStamp);
			else
				deleteUserTracker(userIndex);
			endif;
		
		elseif recordType = JadeAuditAccess.Jaa_Type_ChangeUser then
			jjAccess.getChangeUserData(userName, userIndex, cUserName, cUserIndex);
			
			lpUserName.caption:= userName;
			lpUserIndex.caption := userIndex.String;

			updateUserTracker(userName, userIndex);

		elseif recordType = JadeAuditAccess.Jaa_Type_BeginTransaction or 
			   recordType = JadeAuditAccess.Jaa_Type_CommitTransaction or
			   recordType = JadeAuditAccess.Jaa_Type_AbortTransaction then

			jjAccess.getUserData(userName, userIndex);
			lpUserName.caption:= userName;
			lpUserIndex.caption := userIndex.String;
			
			if recordType = JadeAuditAccess.Jaa_Type_BeginTransaction then
				updateUserTrackerTran(userIndex, transactionId);
			else
				updateUserTrackerTran(userIndex, null);
			endif;
			
		else
			lpUserName.caption:= "";
			lpUserIndex.caption := "";
		endif;
		
		returnVal := recordType;

	else
		lpType.caption:= "End Of File";
		lpOffset.caption:= "";
//		lpTimestamp.caption:= "";
		lpSequence.caption:= "";
		lpTranid.caption:= "";
		lpOid.caption:= "";
		lpUserName.caption:= "";
		lpUserIndex.caption := "";
	endif;	
	
	txDeltaObject.text := "";

	validObject := objectType = JadeAuditAccess.Jaa_Object_Object;
	bnBeforeImage.enabled := validObject and recordType = JadeAuditAccess.Jaa_Type_Update;
	bnAfterImage.enabled := validObject and (recordType = JadeAuditAccess.Jaa_Type_Update or recordType = JadeAuditAccess.Jaa_Type_Create);
	bnDeltaObject.enabled := validObject and recordType = JadeAuditAccess.Jaa_Type_Update;

	return returnVal;
	
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRecordTypeDescription" id="cbefdcdf-e325-49af-95ce-40d5bb742551">
        <final/>
        <source>getRecordTypeDescription(type : Integer) : String final;

begin
	if type = JadeAuditAccess.Jaa_Type_BeginTransaction then
		return "Begin Transaction";
	elseif type = JadeAuditAccess.Jaa_Type_CommitTransaction then
		return "Commit Transaction";
	elseif type = JadeAuditAccess.Jaa_Type_AbortTransaction then
		return "Abort Transaction";
	elseif type = JadeAuditAccess.Jaa_Type_NoAuditDiscontinuity then
		return "No Audit Discontinuity";
	elseif type = JadeAuditAccess.Jaa_Type_ReorgDiscontinuity then
		return "Structural Change Discontinuity";
	elseif type = JadeAuditAccess.Jaa_Type_Create then
		return "Create";
	elseif type = JadeAuditAccess.Jaa_Type_Delete then
		return "Delete";
	elseif type = JadeAuditAccess.Jaa_Type_Update then
		return "Update";
	elseif type = JadeAuditAccess.Jaa_Type_UserSignOn then
		return "User Sign On";
	elseif type = JadeAuditAccess.Jaa_Type_UserSignOff then
		return "User Sign Off";
	endif;
	
	return "*** Unknown type (" &amp; type.String &amp; ") ***";
 end;</source>
        <Parameter name="type" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleNextJournalException" id="a493c90d-596d-4a5e-aa71-e75db02651bc">
        <source>handleNextJournalException(exc : Exception) : Integer;

/*

Purpose:			


Return Value:		


Date		Who		Reason
25 January 2005	cnwkpd1	PAR #5174 - Programme Planning

*/

vars

begin
	app.msgBox("No more journals found", "Error", MsgBox_OK_Only);
	return Ex_Abort_Action;


epilog

end;</source>
        <Parameter name="exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="fac4a225-935d-4db2-bdb0-0565354de1fe">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

vars
	dba : JadeDatabaseAdmin;
	
begin
	create jdoDeltaObject;
	create dba transient;
//	journalNumber.text := dba.getCurrentLogNumber().String;
	txJournalNumber.text := '1';
	txJournalOffset.text := '0';
	txJournalPath.text := dba.getCurrentLogDirectory();
	txJournalNumber.text := dba.getCurrentJournalNumber.String;
	txRemapFileName.text := 'c:\temp\ClassNumbers.txt';
	
	tblUsers.clear;
	tblUsers.setCellText(1, 1,"Index" &amp; Tab &amp; "Name" &amp; Tab &amp; "Logon Time" &amp; Tab &amp; "Tran ID");
	updateUserTable;
	
epilog
	delete dba;
end;</source>
