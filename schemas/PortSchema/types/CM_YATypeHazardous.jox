    <JadeMethod name="isCMIFDataMatch" id="5a2fc986-407c-46d4-a1fc-0289aadbc2f3">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataString): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	
	return _cmifAutoPlan.isHazardous_Match(_yaData);


