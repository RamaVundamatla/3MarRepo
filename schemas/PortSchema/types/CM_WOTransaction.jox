*/


vars

begin
	
	if not self.hasCargoWorkOrderDetails  then
		return null;
	endif;
	
	if self.myWorkOrderDetail.CM_WorkOrderTIDtl.allSelectedTIs.isEmpty() then		//08.02.2023 navma1 #56457:[56458]
		return null;
	endif;
	
	return self.myWorkOrderDetail.CM_WorkOrderTIDtl.allSelectedTIs.first.cargoType;	//08.02.2023 navma1 #56457:[56458]
epilog

end;</source>
        <ReturnType type="Integer"/>
