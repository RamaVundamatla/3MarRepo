    <JadeMethod name="getLoadCCNumPlanned" id="9ddb935b-2cee-4b71-bbdc-97897c05f2d3">
        <source>getLoadCCNumPlanned() : Integer;
// ---------------------------------------------------------------------------
// Created:     26 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	slot : CM_SlotRequest;
	req : CM_VoyageRequest;
	numPln : Integer;
begin
	foreach slot in self.allSlotRequests discreteLock do
		if not slot.isLoad then
			continue;
		endif;
		
		if slot.getAttrIsBackend() then
			continue;
		endif;
		// if a load slot request has a TI associated with it then it is planned
		if slot.getTrackedItem() &lt;&gt; null then 
			numPln := numPln + 1;
		endif;
	endforeach;
	foreach req in self.allRequests discreteLock do
		if not req.isLoad then
			continue;
		endif;
		
		if req.getAttrIsBackend() then
			continue;
		endif;
		// if a load slot request has a TI associated with it then it is planned
		
		numPln := numPln + req.getNumTIsOfMode(PLANNING_MODE, false) ;
	endforeach;
	
	return numPln;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
