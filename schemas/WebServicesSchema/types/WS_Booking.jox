    <JadeMethod name="delete" id="87576e0b-69b7-4237-be19-bb4f1427ffd1">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2014	cnwmc5	Initial creation

*/

vars

begin
	self.allBookingItems.purge();
	delete self.carrier;
	delete self.consignee;
	delete self.consignor;
	delete self.customsAgent;
	delete self.destination;
	delete self.dischargePort;
	delete self.freightForwarder;
	delete self.operator;
	delete self.status;
	delete self.bulkRelease; //06/01/2026 navtr3 MTN-36695
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyDetails" id="e183f3a1-50d8-4bbe-b692-7a95efea4f45">
        <updating/>
        <source>setProxyDetails(_bookingRef: CM_BookingRef) updating, protected;
/*

Date		Who		Reason
04 Oct 2016	cnwer1	Initial creation TFS 2526
10 May 2018	cnwma1	ChangeRequest 38518: PEL1 - WP Cargo Receivals
29 Jan 2020	jlgdap1	TFS 47457 JMT Web Portal Bookings
07 May 2020	jlgdap1	TFS 49218 MTN Web Portal - Bookings - Delete option not available
02 Oct 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
08 Jan 2026 navtr3	MTN-36695 SNO - Release Empties - Thin client Webservices changes
*/

vars
	destinationPort	: CM_Port;
	dischargePort	: CM_Port;
begin
	self.bookingReference := _bookingRef.bookingReference;
	self.bookingRemarks := _bookingRef.bookingRefRemarks;

	if _bookingRef.myCarrier &lt;&gt; null then
		create self.carrier transient;
		self.carrier.setProxyFromObject(_bookingRef.myCarrier);
	endif;
	
	if _bookingRef.myStevedore &lt;&gt; null then                     //02.10.2020 cnwma1 TFS #50112
		self.stevedoreCode := _bookingRef.myStevedore.code;
	endif;
	if _bookingRef.myConsignee &lt;&gt; null then
		create self.consignee transient;
		self.consignee.setProxyFromObject(_bookingRef.myConsignee);
	endif;
	
	if _bookingRef.myConsignor &lt;&gt; null then
		create self.consignor transient;
		self.consignor.setProxyFromObject(_bookingRef.myConsignor);
	endif;
	
	if _bookingRef.getCustomsAgentObject() &lt;&gt; null then
		create self.customsAgent transient;
		self.customsAgent.setProxyFromObject(_bookingRef.getCustomsAgentObject());
	endif;
	
	if _bookingRef.destinationPort &lt;&gt; null then
		destinationPort := app.myRoot.allPorts[_bookingRef.destinationPort];
		if destinationPort &lt;&gt; null then
			create self.destination transient;
			self.destination.setProxyFromObject(destinationPort);
		endif;
	endif;
	
	if _bookingRef.dischargePort &lt;&gt; null then
		dischargePort := app.myRoot.allPorts[_bookingRef.dischargePort];
		if dischargePort &lt;&gt; null then
			create self.dischargePort transient;
			self.dischargePort.setProxyFromObject(dischargePort);
		endif;
	endif;
	
	if _bookingRef.myFreightForwarder &lt;&gt; null then
		create self.freightForwarder transient;
		self.freightForwarder.setProxyFromObject(_bookingRef.myFreightForwarder);
	endif;
	
	if _bookingRef.allReleaseRequests.first &lt;&gt; null then //navtr3 MTN-36695
		create self.bulkRelease transient;
		self.bulkRelease.setProxyFromObject(_bookingRef.allReleaseRequests.first);
	endif;
	
	self.isStockBooking := _bookingRef.isStockBookingRef;
	
	if _bookingRef.myOperator &lt;&gt; null then
		create self.operator transient;
		self.operator.setProxyFromObject(_bookingRef.myOperator);
	endif;
	
	self.packAs := _bookingRef.getPackAsString();
	self.receiveAsTranship := _bookingRef.receiveAsTranship;
	//self.releaseRequestNumber := _bookingRef.release
	self.remarks := _bookingRef.remarks;
	self.shippingReference := _bookingRef.shippingReference;
	self.transhipOriginalVoyage := _bookingRef.getMyTranshipVoyage();
	self.vesselCode := _bookingRef.vesselCode;
	self.voyageCode := _bookingRef.voyageCode;
	
	//10.5.2018 cnwma1 TFS #38518
	if _bookingRef.myVoyage &lt;&gt; null then
		self.externalVoyageCode := _bookingRef.myVoyage.voyageCodeExternal;
	endif;
	create self.status transient;
	self.status.description := app.bookingRefStatusEnumToString(_bookingRef.status);
	self.status.id := _bookingRef.status;
	
	self.isDirectDelivery := _bookingRef.directDelivery;
	
	// TFS 47457 start
	if _bookingRef.myVoyage &lt;&gt; null then
		self.voyageArrivedDT := _bookingRef.myVoyage.arrivedDT.asStringForWebInterface();
	endif;
	if app.getMyUser.canDo(_bookingRef.myTerminal, PmGteBookingRefMaint) or app.getMyUser.canDo(_bookingRef.myTerminal, PmWebBookingMaint) then
		// can we roll, split or delete this booking
		// can delete if status is pending
		// can split if status is pending or active
		// can roll if status is pending or active, and at least one onsite or prenoted cargo item
		// TFS 49218 Booking can also be deleted if it's Active
		if _bookingRef.status = BOOKING_REF_PENDING or _bookingRef.status = BOOKING_REF_ACTIVE then
			self.canDelete := true;
		endif;
		if _bookingRef.status = BOOKING_REF_PENDING or _bookingRef.status = BOOKING_REF_ACTIVE then
			self.canSplit := true;
			if _bookingRef.getPrenotedCount &lt;&gt; null or _bookingRef.getRecievedCount &lt;&gt; null then
				self.canRoll := true;
			endif;
		endif;
	endif;
	// TFS 47457 end
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_bookingRef" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromBookingRefItem" id="0a474f6a-28a0-4eb4-aee1-028089524b43">
        <updating/>
        <source>setProxyFromBookingRefItem(_bookingRefItem: CM_BookingRefItem) updating;
/*

Date		Who		Reason
04 October 2016	cnwer1	Initial creation TFS 2526

*/

vars
	wsBookingItem	: WS_BookingItem;
begin
	if _bookingRefItem = null then
		return;
	endif;
	//epr TFS 2526 4/10/16
	self.setOidDetails(_bookingRefItem.myBookingReference);
	
	self.setProxyDetails(_bookingRefItem.myBookingReference);
	
	create wsBookingItem transient;
	wsBookingItem.setProxyFromObject(_bookingRefItem);
	self.allBookingItems.add(wsBookingItem);
epilog

end;</source>
        <Parameter name="_bookingRefItem" type="CM_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="4618a275-4e45-485a-8bb7-a8674ec296d3">
        <updating/>
        <source>setProxyFromObject(_bookingRef: CM_BookingRef) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 October 2014	cnwmc5	Initial creation

*/

vars
	bookingItem 	: CM_BookingRefItem;
	wsBookingItem	: WS_BookingItem;
begin
	inheritMethod(_bookingRef);
	
	if _bookingRef.allBookingRefItems &lt;&gt; null and not _bookingRef.allBookingRefItems.isEmpty then
		foreach bookingItem in _bookingRef.allBookingRefItems do
			create wsBookingItem transient;
			wsBookingItem.setProxyFromObject(bookingItem);
			self.allBookingItems.add(wsBookingItem);
		endforeach;
	endif;
	
	//epr TFS 2526 4/10/16
	self.setProxyDetails(_bookingRef);
	
	
epilog

end;</source>
        <Parameter name="_bookingRef" type="CM_BookingRef"/>
    </JadeMethod>
</Class>
