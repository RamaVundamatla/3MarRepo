begin
	logLevel := app.logLevel;
//	app.changeLogLevel(LogTRACE);
	
	// Setup
	terminal := self.getMyTerminal();
	
	self.deleteSubTerminal(SubTerminalID);
	subTerm1 := self.addSubTerminal(SubTerminalID, SubTermType_Depot_Int);
	
	//Set the config to false
	consignor_ee_AsText := app.myRoot.getConfig(Consignor_ee_AsText).Boolean;
	isSubTerminalsOn	:= terminal.getConfig(IsSubTerminalsOn).Boolean;
	
	beginTransaction;
		app.myRoot.setConfig(Consignor_ee_AsText, false, false);
		terminal.setConfig(IsSubTerminalsOn,false);
	commitTransaction;
	
	// Cleanup
	self.deleteReleaseRequest(ReleaseRequestNumber);
	self.deleteReleaseRequest(ReleaseRequestNumber&amp;"01");
	self.deleteReleaseRequest(ReleaseRequestNumber&amp;"02");
	self.deleteCargo(ReleaseRequestNumber &amp; "-1", "CONT");
	self.deleteCargo(ReleaseRequestNumber &amp; "-2", "CONT");
	self.deleteCargo(ReleaseRequestNumber &amp; "-3", "CONT");
	self.deleteCargo(ReleaseRequestNumber &amp; "-4", "CONT");
	self.deleteCargo(ReleaseRequestNumber &amp; "-5", "CONT");
	
	self.deleteCargo(ReleaseRequestNumber &amp; "-6", "CONT");
	self.deleteCargo(ReleaseRequestNumber &amp; "-7", "CONT");
	self.deleteCargo(ReleaseRequestNumber &amp; "-8", "CONT");
	self.deleteCargo(ReleaseRequestNumber &amp; "-9", "CONT");
	self.deleteCargo(ReleaseRequestNumber &amp; "-10", "CONT");
	self.deleteCargo(ReleaseRequestNumber &amp; "-11", "CONT");
	
	self.assertNotNullMsg(terminal, "Invalid/No Terminal defined in Unit Test Profile");
	operator := app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString];
	self.assertNotNullMsg(operator, "Invalid/No Operator defined in Unit Test Profile");
	voyage := terminal.getNullVoyage();
	carrier := app.myRoot.allCarriers[self.getProfileSetting(UT_Profile.P_CARRIER).asString];
	self.assertNotNullMsg(carrier, "Invalid/No Carrier defined in Unit Test Profile");
	
	consignee := app.myRoot.allConsigneeConsignors["UTCC1"];
	if consignee = null then
		consignee := self.addConsigneeConsignor("UTCC1", "Unit test consignee/or/ff 1", true, true, true);
	endif;
	consignor := app.myRoot.allConsigneeConsignors["UTCC2"];
	if consignor = null then
		consignor := self.addConsigneeConsignor("UTCC2", "Unit test consignee/or/ff 2", true, true, true);
	endif;
	freightForwarder := app.myRoot.allConsigneeConsignors["UTCC3"];
	if freightForwarder = null then
		freightForwarder:= self.addConsigneeConsignor("UTCC3", "Unit test consignee/or/ff 3", true, true, true);
	endif;
	
	dischargePort := app.myRoot.allPorts["NZWLG"];
	self.assertNotNullMsg(dischargePort, "Port NZWLG not found");
	self.assertNotNullMsg(app.myRoot.getCargoTypeFromAbbrev("UT_BB_GC"), "UT_BB_GC Cargo Type");
	self.assertNotNullMsg(app.myRoot.getCargoTypeFromAbbrev("UTBYQ"), "UTBYQ Cargo Type");
	self.assertNotNullMsg(app.myRoot.getCargoTypeFromAbbrev("UTBYW"), "UTBYW Cargo Type");
	self.assertNotNullMsg(app.myRoot.getCargoTypeFromAbbrev("UTBYV"), "UTBYV Cargo Type");
	
	cargoType := app.myRoot.getCargoTypeFromAbbrev("COAL");
	self.assertNotNullMsg(cargoType, "COAL Cargo Type");
	self.assertNotNullMsg(cargoType.allProducts[null, "LIGNITE"], "LIGNITE Cargo Subtype for COAL");
	
	requestedDateTime.setDateTime(2024, 07, 24, 10, 58, 0, 0);
	estimatedDateTime.setDateTime(2024, 07, 26, 12, 32, 0, 0);
	
	//Create TI's for release request
	ti1 := self.createContainer(ReleaseRequestNumber &amp; "-1", "22G1", null, operator, false);
	self.assertNotNullMsg(ti1, "TI 1");
	ti2 := self.createContainer(ReleaseRequestNumber &amp; "-2", "22G1", null, operator, false);
	self.assertNotNullMsg(ti2, "TI 2");
	ti3 := self.createContainer(ReleaseRequestNumber &amp; "-3", "22G1", null, operator, false);
	self.assertNotNullMsg(ti3, "TI 3");
	ti4 := self.createContainer(ReleaseRequestNumber &amp; "-4", "22G1", null, operator, false);
	self.assertNotNullMsg(ti4, "TI 4");
	ti5 := self.createContainer(ReleaseRequestNumber &amp; "-5", "22G1", null, operator, false);
	self.assertNotNullMsg(ti5, "TI 5");
	
	ti6 := self.createContainer(ReleaseRequestNumber &amp; "-6", "22G1", null, operator, false);
	self.assertNotNullMsg(ti6, "TI 6");
	ti7 := self.createContainer(ReleaseRequestNumber &amp; "-7", "22G1", null, operator, false);
	self.assertNotNullMsg(ti7, "TI 7");
	ti8 := self.createContainer(ReleaseRequestNumber &amp; "-8", "22G1", null, operator, false);
	self.assertNotNullMsg(ti8, "TI 8");
	
	ti9 := self.createContainer(ReleaseRequestNumber &amp; "-9", "22G1", null, operator, false);
	self.assertNotNullMsg(ti9, "TI 9");
	ti10 := self.createContainer(ReleaseRequestNumber &amp; "-10", "22G1", null, operator, false);
	self.assertNotNullMsg(ti10, "TI 10");
	ti11 := self.createContainer(ReleaseRequestNumber &amp; "-11", "22G1", null, operator, false);
	self.assertNotNullMsg(ti11, "TI 11");
	
	//create the booking		//TFS 65383
	self.deleteBooking(ReleaseRequestNumber);
	self.addBookingForContainer(ReleaseRequestNumber,operator,voyage,dischargePort.code,"2200","MT");
	booking := terminal.allBookingRefsByRef[ReleaseRequestNumber];
	self.assertNotNullMsg(booking, "Booking not created");
	
	//Create release request
	create pxyReleaseRequest transient;
	pxyReleaseRequest.setProxyBasic(ReleaseRequestNumber, BR_TYPE_ROAD, false, BR_ACTIVE, terminal, operator, voyage, requestedDateTime, null);
	pxyReleaseRequest.assignTIToBulkRelease(ti1, null);
	pxyReleaseRequest.assignTIToBulkRelease(ti2, null);
	pxyReleaseRequest.assignTIToBulkRelease(ti3, null);
	pxyReleaseRequest.setSubTerminal(subTerm1);	
	app.myTrxCA.trxCreateBulkRelease(pxyReleaseRequest, realReleaseRequest, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();	
	self.assertNotNullMsg(realReleaseRequest, "Release Request");
	self.assertEqualMsg(realReleaseRequest.allTrackedItemsAssigned.size, 3, "Assigned TIs to Release Request");
	
	//Create release request
	create pxyReleaseRequest1 transient;
	pxyReleaseRequest1.setProxyBasic(ReleaseRequestNumber&amp;"01", BR_TYPE_ROAD, false, BR_ACTIVE, terminal, operator, voyage, requestedDateTime, null);
	pxyReleaseRequest1.assignTIToBulkRelease(ti6, null);
	pxyReleaseRequest1.assignTIToBulkRelease(ti7, null);
	pxyReleaseRequest1.assignTIToBulkRelease(ti8, null);
	pxyReleaseRequest1.setSubTerminal(subTerm1);	
	app.myTrxCA.trxCreateBulkRelease(pxyReleaseRequest1, realReleaseRequest1, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();	
	self.assertNotNullMsg(realReleaseRequest1, "Release Request");
	self.assertEqualMsg(realReleaseRequest1.allTrackedItemsAssigned.size, 3, "Assigned TIs to Release Request");
	
	//Create release request
	create pxyReleaseRequest2 transient;
	pxyReleaseRequest2.setProxyBasic(ReleaseRequestNumber&amp;"02", BR_TYPE_ROAD, false, BR_ACTIVE, terminal, operator, voyage, requestedDateTime, null);
	pxyReleaseRequest2.assignTIToBulkRelease(ti9, null);
	pxyReleaseRequest2.assignTIToBulkRelease(ti10, null);
	pxyReleaseRequest2.assignTIToBulkRelease(ti11, null);
	pxyReleaseRequest2.setSubTerminal(subTerm1);	
	app.myTrxCA.trxCreateBulkRelease(pxyReleaseRequest2, realReleaseRequest2, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();	
	self.assertNotNullMsg(realReleaseRequest2, "Release Request");
	self.assertEqualMsg(realReleaseRequest2.allTrackedItemsAssigned.size, 3, "Assigned TIs to Release Request");
	
	// Tests
	
	// Release Request not found
	// Assigned Cargo not found
	// ... everything else in validateRequest
	
	incomingJSONString := IncomingJSONById;
	//check the parameters
	
	//.Test 1
	// Update By-Id
	//Check all validations here
	expectFailure := true;
	create expectedErrorList transient;
	expectedErrorList.add(Input_req_release_number);
	expectedErrorList.add(Input_required_field_reqtype);
	expectedErrorList.add(Input_required_field_operator);
	expectedErrorList.add(Input_required_field_voyage);
	expectedErrorList.add(ERR_Carrier_Unknown);
	expectedErrorList.add(ERR_INVALID_CONSIGN);
	expectedErrorList.add(ERR_INVALID_FreightForwarder);
	expectedErrorList.add(Input_required_requestDT);	
	urlParams := "";
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutReleaseRequest.name, incomingJSONString, urlParams, expectFailure, expectedErrorList);
	self.opts.purge();
	
	beginTransaction;
		terminal.setConfig(IsSubTerminalsOn,true);
	commitTransaction;
	
	expectedErrorList.add(Subterminal_invalid);
	urlParams := "";
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutReleaseRequest.name, incomingJSONString, urlParams, expectFailure, expectedErrorList);
	self.opts.purge();
	
	expectedErrorList.clear();
	delete expectedErrorList;
	
	//Test 2
	//Replace with actual values
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"id": "' &amp; ReleaseRequestNumber &amp; '"', '\"id\": \""', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"requestType": "Road"', '\"requestType\": \""', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"operatorId": "' &amp; operator.code &amp; '"', '\"operatorId\": \""', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"voyageId": "********************"', '\"voyageId\": \""', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"carrierId": "' &amp; carrier.code &amp; '"', '\"carrierId\": \"(\&lt;WRONG01\&gt;)\"', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"consigneeId": "' &amp; consignee.code &amp; '"', '\"consigneeId\": \"&lt;WR\&gt;"', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"consignorId": "' &amp; consignor.code &amp; '"', '\"consignorId\": \"&lt;WR\&gt;"', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"freightForwarderId": "' &amp; freightForwarder.code &amp; '"', '\"freightForwarderId\": \"&lt;WR\&gt;"', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"subTerminalId": "' &amp; subTerm1.code &amp; '"', '\"subTerminalId\": \"&lt;WR\&gt;"', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"bookingId": "' &amp; ReleaseRequestNumber &amp; '"', '\"bookingId\": \""', false);
	expectFailure := false;
	urlParams := ReleaseRequestNumber &amp; "/1721732280";
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutReleaseRequest.name, incomingJSONString, urlParams, expectFailure, expectedErrorList);
	
	self.assertEqualMsg(realReleaseRequest.allTrackedItemsAssigned.size, 3, "Assigned TIs to Release Request");
	count := 1;
	foreach assignedTi in realReleaseRequest.allTrackedItemsAssigned do
		if count = 1 then
			self.assertEqualMsg(assignedTi, ti2, "TI 2 expected to be first assigned TI");
		elseif count = 2 then
			self.assertEqualMsg(assignedTi, ti4, "TI 4 expected to be first assigned TI");
		elseif count = 3 then
			self.assertEqualMsg(assignedTi, ti5, "TI 5 expected to be first assigned TI");
		else
			self.assertTrueMsg(false, "Unit Test not checking for assigned TIs correctly");
		endif;
		count+=1;
	endforeach;
	self.assertEqualMsg(realReleaseRequest.myOperator, operator, "Release Request Operator does not match");
	self.assertEqualMsg(realReleaseRequest.dateRequested, requestedDateTime, "Release Request Date/Time Requested does not match");
	self.assertEqualMsg(realReleaseRequest.carrierId, carrier.code, "Release Request Carrier Id does not match");
	self.assertEqualMsg(realReleaseRequest.consigneeCode, consignee.code, "Release Request Consignee Code does not match");
	self.assertEqualMsg(realReleaseRequest.consignorCode, consignor.code, "Release Request Consignor Code does not match");
	self.assertEqualMsg(realReleaseRequest.consignorVoyageCode, "Some Consignr Voy Id", "Release Request Consignor Voyage Code does not match");
	self.assertEqualMsg(realReleaseRequest.deliveryReleaseNumber, "Some Delivery Release Number", "Release Request Delivery Release Number does not match");
	self.assertEqualMsg(realReleaseRequest.myDischargePort, dischargePort, "Release Request Discharge Port does not match");
	self.assertEqualMsg(realReleaseRequest.dateEstimatedRequired, estimatedDateTime, "Release Request Estimated Required Date/Time does not match");
	self.assertEqualMsg(realReleaseRequest.freightForwarderCode, freightForwarder.code, "Release Request FreightForwarder Code does not match");
	self.assertEqualMsg(realReleaseRequest.myFreightForwarder, freightForwarder, "Release Reqyest myFreightForwarder does not match");
	self.assertTrueMsg(realReleaseRequest.fullRelease, "Release Request Full Release");
	self.assertFalseMsg(realReleaseRequest.releaseByType, "Release Request 'Release By Type' should be false");
	self.assertEqualMsg(realReleaseRequest.cargoRemarks, "Some Remarks", "Release Request Cargo Remarks does not match");
	self.assertNotNullMsg(realReleaseRequest.myBookingRefStock, "Booking reference not found");	//TFS 65383
	self.assertEqualMsg(realReleaseRequest.myBookingRefStock.bookingReference, ReleaseRequestNumber, "Booking reference not found");//TFS 65383
	
	//Test 3
	//Change release type
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"requestType": "Rail"', '\"requestType\": \"Road"', false);
	urlParams := ReleaseRequestNumber &amp; "/1721732280";
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutReleaseRequest.name, incomingJSONString, urlParams, expectFailure, expectedErrorList);
	self.assertEqualMsg(realReleaseRequest.type, BR_TYPE_RAIL, "Release type not changed");
	self.assertEqualMsg(realReleaseRequest.allTrackedItemsAssigned.size, 3, "Assigned TIs to Release Request");
	
	//Test 4
	// Update By-Type (lets see if we can really break it and change from a ById to ByType!)
	//Check all validations here
	delete expectedErrorList;
	create expectedErrorList transient;
	expectedErrorList.add(Input_req_release_number);
	expectedErrorList.add(Input_required_field_reqtype);
	expectedErrorList.add(Input_required_field_operator);
	expectedErrorList.add(Input_required_field_voyage);
	expectedErrorList.add(ERR_Carrier_Unknown);
	expectedErrorList.add(ERR_INVALID_CONSIGN);
	expectedErrorList.add(ERR_INVALID_FreightForwarder);
	expectedErrorList.add(Input_required_requestDT);
	expectedErrorList.add(Subterminal_invalid);
	
	expectFailure := true;
	incomingJSONString := IncomingJSONByType;
	urlParams := "";
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutReleaseRequest.name, incomingJSONString, urlParams, expectFailure, expectedErrorList);
	expectedErrorList.clear();	
	delete expectedErrorList;
	
	//Test 5
	//Replace with actual values
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"id": "' &amp; ReleaseRequestNumber &amp; '"', '\"id\": \""', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"requestType": "Road"', '\"requestType\": \""', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"operatorId": "' &amp; operator.code &amp; '"', '\"operatorId\": \""', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"voyageId": "********************"', '\"voyageId\": \""', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"carrierId": "' &amp; carrier.code &amp; '"', '\"carrierId\": \"(\&lt;WRONG01\&gt;)\"', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"consigneeId": "' &amp; consignee.code &amp; '"', '\"consigneeId\": \"&lt;WR\&gt;"', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"consignorId": "' &amp; consignor.code &amp; '"', '\"consignorId\": \"&lt;WR\&gt;"', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"freightForwarderId": "' &amp; freightForwarder.code &amp; '"', '\"freightForwarderId\": \"&lt;WR\&gt;"', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"subTerminalId": "' &amp; subTerm1.code &amp; '"', '\"subTerminalId\": \"&lt;WR\&gt;"', false);
		
	expectFailure := false;
	urlParams := ReleaseRequestNumber &amp; "/1721732280";
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutReleaseRequest.name, incomingJSONString, urlParams, expectFailure, expectedErrorList);
	
	self.assertEqualMsg(realReleaseRequest.allTrackedItemsAssigned.size, 0, "Assigned TIs to Release Request");
	self.assertEqualMsg(realReleaseRequest.allReserveDetails.size, 6, "Reserve Details");
	
	// None of this should have changed
	self.assertEqualMsg(realReleaseRequest.myOperator, operator, "Release Request Operator does not match");
	self.assertEqualMsg(realReleaseRequest.dateRequested, requestedDateTime, "Release Request Date/Time Requested does not match");
	self.assertEqualMsg(realReleaseRequest.carrierId, carrier.code, "Release Request Carrier Id does not match");
	self.assertEqualMsg(realReleaseRequest.consigneeCode, consignee.code, "Release Request Consignee Code does not match");
	self.assertEqualMsg(realReleaseRequest.consignorCode, consignor.code, "Release Request Consignor Code does not match");
	self.assertEqualMsg(realReleaseRequest.consignorVoyageCode, "Some Consignr Voy Id", "Release Request Consignor Voyage Code does not match");
	self.assertEqualMsg(realReleaseRequest.deliveryReleaseNumber, "Some Delivery Release Number", "Release Request Delivery Release Number does not match");
	self.assertEqualMsg(realReleaseRequest.myDischargePort, dischargePort, "Release Request Discharge Port does not match");
	self.assertEqualMsg(realReleaseRequest.dateEstimatedRequired, estimatedDateTime, "Release Request Estimated Required Date/Time does not match");
	self.assertEqualMsg(realReleaseRequest.freightForwarderCode, freightForwarder.code, "Release Request FreightForwarder Code does not match");
	self.assertEqualMsg(realReleaseRequest.myFreightForwarder, freightForwarder, "Release Reqyest myFreightForwarder does not match");
	self.assertTrueMsg(realReleaseRequest.fullRelease, "Release Request Full Release");
	self.assertTrueMsg(realReleaseRequest.releaseByType, "Release Request 'Release By Type' should be true");
	self.assertEqualMsg(realReleaseRequest.cargoRemarks, "Some Remarks", "Release Request Cargo Remarks does not match");
	
	count := 1;
	foreach reserveSelection in realReleaseRequest.allReserveDetails as CM_ReserveSelection do		// If this breaks due to CM_ReserveTIs in there, then thats good, as they shouldn't be!
		// Ordered Set, so first up we have ...
		if count = 1 then
			self.assertNotNullMsg(reserveSelection.myCargoType, "Cargo Type missing from Reserve Selection");
			self.assertEqualMsg(reserveSelection.myCargoType.abbreviation, "CONT", "Cargo Type on Reserve Selection");
			self.assertNotNullMsg(reserveSelection.myISOType, "ISO Type missing from Reserve Selection");
			self.assertEqualMsg(reserveSelection.myISOType.code, "2200", "ISO Type on Reserve Selection");
			self.assertTrueMsg(reserveSelection.clean, "Clean not set on Reserve Selection");
			self.assertEqualMsg(reserveSelection.lineNumber, 1, "Line Number not set correctly on Reserve Selection");
			self.assertEqualMsg(reserveSelection.remarks, "Some Release Detail Remarks", "Remarks not set correctly on Reserve Selection");
		elseif count = 2 then
			self.assertNotNullMsg(reserveSelection.myCargoType, "Cargo Type missing from Reserve Selection");
			self.assertEqualMsg(reserveSelection.myCargoType.abbreviation, "UT_BB_GC", "Cargo Type on Reserve Selection");
			self.assertEqualMsg(reserveSelection.quantitySelection, 10, "Quantity (Pieces) not set correctly on Reserve Selection");
			self.assertEqualMsg(reserveSelection.lineNumber, 2, "Line Number not set correctly on Reserve Selection");
		elseif count = 3 then
			self.assertNotNullMsg(reserveSelection.myCargoType, "Cargo Type missing from Reserve Selection");
			self.assertEqualMsg(reserveSelection.myCargoType.abbreviation, "UTBYQ", "Cargo Type on Reserve Selection");
			self.assertEqualMsg(reserveSelection.totalRequested, 2, "Total Requested not set correctly on Reserve Selection");
			self.assertEqualMsg(reserveSelection.lineNumber, 200, "Line Number not set correctly on Reserve Selection");
		elseif count = 4 then
			self.assertNotNullMsg(reserveSelection.myCargoType, "Cargo Type missing from Reserve Selection");
			self.assertEqualMsg(reserveSelection.myCargoType.abbreviation, "UTBYW", "Cargo Type on Reserve Selection");
			self.assertEqualMsg(reserveSelection.weightRequested, 3.1234.Decimal, "Weight Requested not set correctly on Reserve Selection");
			self.assertEqualMsg(reserveSelection.lineNumber, 3, "Line Number not set correctly on Reserve Selection");
		elseif count = 5 then
			self.assertNotNullMsg(reserveSelection.myCargoType, "Cargo Type missing from Reserve Selection");
			self.assertEqualMsg(reserveSelection.myCargoType.abbreviation, "UTBYV", "Cargo Type on Reserve Selection");
			self.assertEqualMsg(reserveSelection.weightRequested, 4.1234.Decimal, "Volume Requested not set correctly on Reserve Selection");
			self.assertEqualMsg(reserveSelection.lineNumber, 201, "Line Number not set correctly on Reserve Selection");
		elseif count = 6 then
			self.assertNotNullMsg(reserveSelection.myCargoType, "Cargo Type missing from Reserve Selection");
			self.assertEqualMsg(reserveSelection.myCargoType.abbreviation, "COAL", "Cargo Type on Reserve Selection");
			self.assertNotNullMsg(reserveSelection.myProduct, "Cargo Sub-Type missing from Reserve Selection");
			self.assertEqualMsg(reserveSelection.myProduct.code, "LIGNITE", "Cargo Sub-Type on Reserve Selection");
			self.assertEqualMsg(reserveSelection.volumeSelection, 30.1234.Decimal, "Weight Requested not set correctly on Reserve Selection");
			self.assertEqualMsg(reserveSelection.lineNumber, 100, "Line Number not set correctly on Reserve Selection");
		else
			self.assertTrueMsg(false, "Unit Test not checking for Reserve Selections correctly");
		endif;
		count += 1;
	endforeach;
	
	// Multiple Requests By Id
	//Test 6 - Update multiple requests By-Id
	//Check all validations here
	incomingJSONString	:= IncomingJSONByIdMulti;
	expectFailure := true;
	create expectedErrorList transient;
	expectedErrorList.add(Input_req_release_number);
	expectedErrorList.add(Input_required_field_reqtype);
	expectedErrorList.add(Input_required_field_operator);
	expectedErrorList.add(Input_required_field_voyage);
	expectedErrorList.add(ERR_Carrier_Unknown);
	expectedErrorList.add(ERR_INVALID_CONSIGN);
	expectedErrorList.add(ERR_INVALID_FreightForwarder);
	expectedErrorList.add(Subterminal_invalid);
	
	incomingJSONString1 := incomingJSONString;
	incomingJSONString1 := JadeRegex@replaceAll(incomingJSONString1, '"id": ""', '\"id\": \"&lt;WR1\&gt;"', false);
	incomingJSONString1 := JadeRegex@replaceAll(incomingJSONString1, '"id": ""', '\"id\": \"&lt;WR2\&gt;"', false);
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutReleaseRequest.name, incomingJSONString1, urlParams, expectFailure, expectedErrorList);
	self.opts.purge();
	expectedErrorList.clear();
	delete expectedErrorList;
	
	//Test 7 - replace with actual values
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"id": "' &amp; ReleaseRequestNumber &amp; '01"', '\"id\": \"&lt;WR1\&gt;"', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"id": "' &amp; ReleaseRequestNumber &amp; '02"', '\"id\": \"&lt;WR2\&gt;"', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"requestType": "Road"', '\"requestType\": \""', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"operatorId": "' &amp; operator.code &amp; '"', '\"operatorId\": \""', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"voyageId": "********************"', '\"voyageId\": \""', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"carrierId": "' &amp; carrier.code &amp; '"', '\"carrierId\": \"(\&lt;WRONG01\&gt;)\"', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"consigneeId": "' &amp; consignee.code &amp; '"', '\"consigneeId\": \"&lt;WR\&gt;"', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"consignorId": "' &amp; consignor.code &amp; '"', '\"consignorId\": \"&lt;WR\&gt;"', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"freightForwarderId": "' &amp; freightForwarder.code &amp; '"', '\"freightForwarderId\": \"&lt;WR\&gt;"', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"subTerminalId": "' &amp; subTerm1.code &amp; '"', '\"subTerminalId\": \"&lt;WR\&gt;"', false);
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutReleaseRequest.name, incomingJSONString, urlParams, expectFailure, expectedErrorList);

	self.assertEqualMsg(realReleaseRequest1.allReserveDetails.size, 3, "Reserve Details");
	
	self.assertEqualMsg(realReleaseRequest2.allReserveDetails.size, 3, "Reserve Details");
	
	// Test 8 - Inter-Terminal Transfer	
	
	// setup destination terminal stuff
	destTerm := self.getTerminal();
	shipCutoffError := destTerm.getConfig(ShipCutoffsShowError).Boolean;
	beginTransaction;
	destTerm.setConfig(ShipCutoffsShowError, false);
	commitTransaction;
	
	// setup source bs
	self.deleteTerminalArea("BS77");
	ta := self.addBlockStack("BS77", 50, null);
	self.assertNotNull(ta);
	
	
	// get the gate details
	gate := terminal.getDefaultGate_OUT();
	adminGate := gate.getFirstAGate_IN();
	if adminGate = null then
		laneController := adminGate.getLaneByNumber(1);
	endif;
	autoIn := true;
	autoOut := true;
	
	delreason := app.myRoot.allDeliveryReasonselReasons.first;
	delReasonID := delreason.id;
	delReason := delreason.description;	
	
	// create inter terminal config
	//self.deleteInterTermConfig(InterTermConfig);
	itc := self.addInterTermConfig(InterTermConfig,
									gate,
									laneController,
									terminal,
									ta,
									autoIn, 
									autoOut,
									destTerm,
									consignee,
									voyage.code,
									voyage,
									delReasonID,
									delReason,
									subTerm1
									);
	
	ti12 := self.addContainer("TIINTTER41", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	
	// need cargo item assigned to the release (moved to ITCBS1 should do it)
	self.move( ti12, ta);  //should allocate it to the BR
	
	realReleaseRequest3 := itc.myRelease;
	
	self.assertTrue(itc.myRelease.allTrackedItemsAssigned.includes(ti12) );
	expectFailure := false;
	incomingJSONString := IncomingJSONByIdIntTer;
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"id": "' &amp; InterTermConfig &amp; '"', '\"id\": \""', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"requestType": "Road"', '\"requestType\": \""', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"operatorId": "' &amp; operator.code &amp; '"', '\"operatorId\": \""', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"voyageId": "********************"', '\"voyageId\": \""', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"carrierId": "' &amp; carrier.code &amp; '"', '\"carrierId\": \"(\&lt;WRONG01\&gt;)\"', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"consigneeId": "' &amp; consignee.code &amp; '"', '\"consigneeId\": \"&lt;WR\&gt;"', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"consignorId": "' &amp; consignor.code &amp; '"', '\"consignorId\": \"&lt;WR\&gt;"', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"freightForwarderId": "' &amp; freightForwarder.code &amp; '"', '\"freightForwarderId\": \"&lt;WR\&gt;"', false);
	incomingJSONString := JadeRegex@replaceAll(incomingJSONString, '"subTerminalId": "' &amp; subTerm1.code &amp; '"', '\"subTerminalId\": \"&lt;WR\&gt;"', false);
	urlParams := InterTermConfig &amp; "/" &amp; itc.myRelease.dateRequested.String;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutReleaseRequest.name, incomingJSONString, urlParams, expectFailure, expectedErrorList);
	self.assertEqualMsg(realReleaseRequest3.allReserveDetails.size, 1, "Reserve Details");
	
	// None of this should have changed
	self.assertEqualMsg(realReleaseRequest3.myOperator, operator, "Release Request Operator does not match");
	self.assertEqualMsg(realReleaseRequest3.dateRequested, requestedDateTime, "Release Request Date/Time Requested does not match");
	self.assertEqualMsg(realReleaseRequest3.carrierId, carrier.code, "Release Request Carrier Id does not match");
	self.assertEqualMsg(realReleaseRequest3.consigneeCode, consignee.code, "Release Request Consignee Code does not match");
	self.assertEqualMsg(realReleaseRequest3.consignorCode, consignor.code, "Release Request Consignor Code does not match");
	self.assertEqualMsg(realReleaseRequest3.consignorVoyageCode, "Some Consignr Voy Id", "Release Request Consignor Voyage Code does not match");
	self.assertEqualMsg(realReleaseRequest3.deliveryReleaseNumber, "Some Delivery Release Number", "Release Request Delivery Release Number does not match");
	self.assertEqualMsg(realReleaseRequest3.myDischargePort, dischargePort, "Release Request Discharge Port does not match");
	self.assertEqualMsg(realReleaseRequest3.dateEstimatedRequired, estimatedDateTime, "Release Request Estimated Required Date/Time does not match");
	self.assertEqualMsg(realReleaseRequest3.freightForwarderCode, freightForwarder.code, "Release Request FreightForwarder Code does not match");
	self.assertEqualMsg(realReleaseRequest3.myFreightForwarder, freightForwarder, "Release Reqyest myFreightForwarder does not match");
	self.assertTrueMsg(realReleaseRequest3.fullRelease, "Release Request Full Release");
	self.assertTrueMsg(not realReleaseRequest3.releaseByType, "Release Request 'Release By Type' should be true");
	self.assertEqualMsg(realReleaseRequest3.cargoRemarks, "Some Remarks", "Release Request Cargo Remarks does not match");
epilog
	delete pxyReleaseRequest;
	delete pxyReleaseRequest1;
	delete pxyReleaseRequest2;
	delete expectedErrorList;
	beginTransaction;
	app.myRoot.setConfig(Consignor_ee_AsText, consignor_ee_AsText, false);
	terminal.setConfig(IsSubTerminalsOn, isSubTerminalsOn);
	terminal.setConfig(ShipCutoffsShowError, shipCutoffError);
	commitTransaction;
	app.changeLogLevel(logLevel);
end;</source>
