    <JadeMethod name="doUpdateNull" id="4dfd38a4-045b-4458-9b3a-7dfd48db443e">
        <updating/>
        <source>doUpdateNull(_anObject : Object) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 07/11/2012	cnwcs5		par 30475 - remove references to cm_LocationRestricContainer
// 24/11/2016	cnwdap1		TFS 2844 STWR Hazardous Details Enhancements
vars
	aLabRest 		: CM_LabourRestriction;
	aSBS 			: CM_SubBlockStack;
	aTermSubArea 	: CM_TerminalSubArea;
	aDoor			: CM_DoorDirectionRule;
	hazDetail		: CM_TerminalAreaHazDetails;							// TFS 2844
begin
	if _anObject &lt;&gt; null then
		if _anObject.isKindOf(CM_SubBlockStack) then
			aSBS := _anObject.CM_SubBlockStack;
			if aSBS = self.mySubBlockStack then
				self.mySubBlockStack := null;
				self.theSubBlockColour := -1;
			endif;
		elseif _anObject.isKindOf(CM_LabourRestriction) then
			aLabRest := _anObject.CM_LabourRestriction;
			
			self.allLabourRestrictions.removeInvalidObjects();
			if self.allLabourRestrictions.includes(aLabRest) then
				self.allLabourRestrictions.remove(aLabRest);
			endif;
			if self.allLabourRestrictions.size = 0 then
				self.theLabourColour := -1;
			else
				self.theLabourColour := self.allLabourRestrictions.first.colour;
			endif;
		elseif _anObject.isKindOf(CM_TerminalSubArea) then
			aTermSubArea:= _anObject.CM_TerminalSubArea;
			if not global.isValidObject(aTermSubArea) then
				self.allTerminalSubAreas.removeInvalidObjects();
			elseif self.allTerminalSubAreas.includes(aTermSubArea) then
				self.allTerminalSubAreas.remove(aTermSubArea);
			endif;
			if self.allTerminalSubAreas.size = 0 then
				self.theTermSubAreaColour := -1;
			else
				self.theTermSubAreaColour:= self.allTerminalSubAreas.first.colour;
			endif;

		elseif _anObject.isKindOf(CM_DoorDirectionRule) then
			aDoor := _anObject.CM_DoorDirectionRule;
			//if not global.isValidObject(aLabRest) then
			self.allDoorDirectionRules.removeInvalidObjects();
			if self.allDoorDirectionRules.includes(aDoor) then
				self.allDoorDirectionRules.remove(aDoor);
			endif;
			if self.allDoorDirectionRules.size = 0 then
				self.theDoorDirectionColour := -1;
			else
				self.theDoorDirectionColour := self.allDoorDirectionRules.first.colour;
			endif;
		
		elseif _anObject.isKindOf(CM_TerminalArea) and self.myLocationsController.isKindOf(CM_GridController) then
			
			self.power := self.myLocationsController.CM_GridController.power;
			self.powerDamaged := self.myLocationsController.CM_GridController.powerDamaged;
			if self.myLocationsController.isKindOf(CM_StackController) then
				self.availability := self.myLocationsController.CM_StackController.availability;
				self.usage := self.myLocationsController.CM_StackController.usage;
			endif;		
			
		elseif _anObject.isKindOf(CM_TerminalAreaHazDetailsDict) then				// TFS 2844
			hazDetail := _anObject.CM_TerminalAreaHazDetails;						// TFS 2844
			self.allHazardDetails.removeInvalidObjects();							// TFS 2844
			if self.allHazardDetails.includes(hazDetail) then						// TFS 2844
				self.allHazardDetails.remove(hazDetail);							// TFS 2844
			endif;																	// TFS 2844
			if self.allHazardDetails.size = 0 then									// TFS 2844
				self.theHazardColour := -1;											// TFS 2844
			else																	// TFS 2844
				self.theHazardColour := self.allHazardDetails.first.colour;			// TFS 2844
			endif;																	// TFS 2844
			
		endif;		
	endif;

end;</source>
        <Parameter name="_anObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="draw" id="5798e699-4b3f-4dad-8376-2bb17d5d0247">
        <updating/>
        <source>draw(pFrame: CMUI_GridAreaFrame input; _theColour, _theLineColour, _mode : Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     31 December 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/11/2012	cnwcs5		par 30475 - remove references to cm_LocationRestricContainer
// 24/11/2016	cnwdap1		TFS 2844 STWR Hazardous Details Enhancements
// ---------------------------------------------------------------------------
constants
	PicWidth = 17;
vars
	startY, endY		: Real;
	idx					: Integer;
	thePicture 			: Binary;
	iAmSelected 		: Boolean;
	theArea 			: YRD_PadArea;
begin
	theArea 	:= self.myGridArea.YRD_PadArea;
	iAmSelected := theArea.allSelectedPoints.includes(self);

	pFrame.drawWidth	:= 1;	
	self.cellHeight 	:= (self.y2 - self.y1);
	idx 				:= 1;
	startY 				:= self.getYPosFromIdx(idx);
	endY				:= startY + self.cellHeight;

	pFrame.drawFillColor := _theColour;
	
	if self.locked and theArea.editMode = true 
	and self.availability &lt;&gt; PAD_UNAVAILABLE
	and (self.usage &lt;&gt; LIGHT_TOWER_USE) and (self.usage &lt;&gt; BUILDING_USE)  then
		pFrame.drawFillStyle := Frame.DrawFillStyle_DiagonalCross	;
	else
		pFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
	endif;
	
	pFrame.drawFilledRectangle(self.x1, startY, self.x2, endY, _theLineColour); 
	
	thePicture := null;
	
	// Height Restrictions
	if _mode = YRD_PadArea.AreaMode_Height  then
		self.drawHeights(pFrame);
	// Labour, Location &amp; Sub Block Stacks
	else
		if self.usage = BUILDING_USE then
			self.drawAttribute(-1,PicTIBuilding,pFrame);
		elseif self.usage = LIGHT_TOWER_USE then
			self.drawAttribute(-1,PicTILight,pFrame);
		elseif self.availability = PAD_UNAVAILABLE and not self.power then
			self.drawAttribute(-1,PicTIUnavail,pFrame);
		elseif self.power and _mode = YRD_PadArea.AreaMode_Height  then
			self.drawAttribute(-1,PicTIPower,pFrame);
		elseif _mode = YRD_PadArea.AreaMode_Labour then // LABOUR		
				if self.allLabourRestrictions.size &lt;&gt; 0  then
					self.allLabourRestrictions.removeInvalidObjects();
					self.drawCode(self.allLabourRestrictions.getAllCodes, pFrame);
				endif;
		elseif _mode = YRD_PadArea.AreaMode_TermSubArea then 
			if self.allTerminalSubAreas.size &lt;&gt; 0  then
				self.allTerminalSubAreas.removeInvalidObjects();
				self.drawCode(self.allTerminalSubAreas.getAllCodes, pFrame);
			endif;	
		elseif _mode = YRD_PadArea.AreaMode_DoorDirection then 
			if self.allDoorDirectionRules.size &lt;&gt; 0  then
				self.allDoorDirectionRules.removeInvalidObjects();
				self.drawCode( self.allDoorDirectionRules.getAllCodes, pFrame );
			endif;	
		elseif _mode = YRD_PadArea.AreaMode_Hazardous then							// TFS 2844
			if self.allHazardDetails.size &lt;&gt; 0 then									// TFS 2844
				self.allHazardDetails.removeInvalidObjects();						// TFS 2844
				self.drawCode(self.allHazardDetails.getAllCodes, pFrame);			// TFS 2844
			endif;																	// TFS 2844
		endif;

	endif;

	if self.mySubBlockStack &lt;&gt; null and _mode = YRD_PadArea.AreaMode_SubBlock then
		theArea.addTerminalLabel((self.x1 + 1).Integer, (self.y1 + 1).Integer, self.mySubBlockStack);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="pFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_theColour" type="Integer"/>
        <Parameter name="_theLineColour" type="Integer"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawAttribute" id="812584a6-b819-4502-9465-66bea84f91ef">
        <source>drawAttribute(_theAttColour : Integer; _theAttribute : String;_theFrame: CMUI_GridAreaFrame input) ;
// ---------------------------------------------------------------------------
// Created:		09 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	theDrawingAttribute		 : CM_DrawingAttribute;
	theX,theY,theColour		 :Integer;
	origFontName,theFontName,theGFontName : String;
	origFontSize,theFontSize : Real;
	theCharacter , theGChar			 : Character;
	theGridArea				 : YRD_PadArea;
begin
	origFontName := _theFrame.drawFontName;
	origFontSize := _theFrame.drawFontSize;
	theGridArea := self.myGridArea.YRD_PadArea;
	if self.isGap and _theAttribute &lt;&gt; PicTIGap then
		theDrawingAttribute := theGridArea.mySDF.allDrawingAttributes[PicTIGap];
		if theDrawingAttribute &lt;&gt; null then
			theGChar := theDrawingAttribute.fontCharacter.Character;
			theGFontName := theDrawingAttribute.fontName;
		endif;
	endif;
	
	theDrawingAttribute := theGridArea.mySDF.allDrawingAttributes[_theAttribute];

	if theDrawingAttribute &lt;&gt; null then
		theCharacter := theDrawingAttribute.fontCharacter.Character;
		_theFrame.drawFontName := theDrawingAttribute.fontName;
//		theColour := theDrawingAttribute.colour;
//		theColour := _theFrame.drawFillColor.getInverseColour();
	else
		theCharacter := '!'.Character;
//		theColour := Red;
	endif;

	//check for gaps
	if self.isGap and _theAttribute &lt;&gt; PicTIGap  then
		theX := (self.x1 + 1).Integer;
		theY := (self.y1 + 2).Integer;
	else
		if _theAttColour = -1 then
			theX := (self.x1 + ((self.x2 - self.x1)/ 6)).Integer;
			theY := (self.y1 + ((self.y2 - self.y1)/ 2)).Integer -10;
		else
			theX := (self.x1 + ((self.x2 - self.x1)/ 1.7)).Integer;
			theY := (self.y1 + ((self.y2 - self.y1)/ 2)).Integer -10;
		endif;
	endif;
	_theFrame.drawFontSize := 11;
	_theFrame.drawTextAlign := Frame.DrawTextAlign_Left; //DrawTextAlign_Center;
	
//	if _theAttColour &lt; 0 then
//		theColour := _theAttColour;
//	endif;
	if theDrawingAttribute &lt;&gt; null then
		if theGridArea.areaMode = YRD_PadArea.AreaMode_Height then
			theColour := theDrawingAttribute.colour;
		else
			theColour := _theFrame.drawFillColor.getInverseColour();
		endif;
	else
		theColour := Red;
	endif;
	_theFrame.drawTextAt(theCharacter, theX,theY,theColour);
	if self.isGap and _theAttribute &lt;&gt; PicTIGap  then
		theX := (self.x1 + ((self.x2 - self.x1)/ 2)).Integer ;
		_theFrame.drawFontName := theGFontName;
		_theFrame.drawTextAt(theGChar, theX,theY,theColour);
	endif;
		
epilog
	_theFrame.drawFontName := origFontName;
	_theFrame.drawFontSize := origFontSize;
end;</source>
        <Parameter name="_theAttColour" type="Integer"/>
        <Parameter name="_theAttribute" type="String"/>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawCode" id="06c300d4-8ec7-4dd3-9bfb-53ebe0792abe">
        <source>drawCode(_theCode : String;_theFrame: CMUI_GridAreaFrame input) ;
// ---------------------------------------------------------------------------
// Created:		09 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	theX,theY,theColour		 :Integer;
	origFontName,theFontName : String;
	origFontSize,theFontSize : Real;
	theCharacter 			 : String;
	theGridArea				 : YRD_PadArea;
begin
	origFontName := _theFrame.drawFontName;
	origFontSize := _theFrame.drawFontSize;
	theGridArea := self.myGridArea.YRD_PadArea;
	
	theCharacter := _theCode;
	_theFrame.drawFontName := "Ariel";

	theX := (self.x1 + ((self.x2 - self.x1)/ 2)).Integer -10;
	theY := (self.y1 + ((self.y2 - self.y1)/ 2)).Integer -10;
	_theFrame.drawFontSize := 10;
	_theFrame.drawTextAlign := Frame.DrawTextAlign_Left; //DrawTextAlign_Center;
	
	theColour := _theFrame.drawFillColor.getInverseColour();
	_theFrame.drawTextAt(theCharacter, theX,theY,theColour);
		
epilog
	_theFrame.drawFontName := origFontName;
	_theFrame.drawFontSize := origFontSize;
end;</source>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawHeights" id="c8ab6955-6e09-46e4-ba0e-0e3fb3e02abc">
        <updating/>
        <source>drawHeights(pFrame: CMUI_GridAreaFrame input) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	startY,
	endY				: Real;
	thePicture : Binary;
	idx : Integer;
begin
	pFrame.drawWidth	:= 1;	
	self.cellHeight := (self.y2 - self.y1);
	idx := 1;
	startY 	:= self.getYPosFromIdx(idx);
	endY	:= startY + self.cellHeight;

	if self.availability &gt; 2 then
		
		//pFrame.drawTextAt((self.availability - 2).String, self.x1 + 15,startY + 19,Red);
		self.drawAttribute(Red - ((self.availability - 2) * 20),'picTI' &amp; (self.availability - 2).String,pFrame);
	
	endif;
	
	if self.usage = BUILDING_USE then
		self.drawAttribute(-1,PicTIBuilding,pFrame);
		
		//pFrame.drawTextAt("T", self.x1 + 10,startY + 2,drawAttr.colour);
	elseif self.usage = LIGHT_TOWER_USE then
		self.drawAttribute(-1,PicTILight,pFrame);
	elseif self.availability = PAD_UNAVAILABLE and not self.isGap() then
		self.drawAttribute(-1,PicTIUnavail,pFrame);
	elseif self.powerDamaged then
		self.drawAttribute(-1,PicTIPowerDamaged,pFrame);
	elseif self.power then
		self.drawAttribute(-1,PicTIPower,pFrame);
	elseif self.availability = PAD_AVAILABLE then
		// if I am being made available see I can find the Unavailable picture and remove it.
//write "AKB" &amp; " " &amp; class.name &amp; '::' &amp; method.name &amp; " 1. ";
//			thePicture := pFrame.form.YRD_LocationMaintForm.getPictures(LOC_Display_Unavailable);
//			self.removePicture(thePicture);
	//endif;
	elseif self.isGap() then
		self.drawAttribute(-1,PicTIGap,pFrame);
		
	endif;
		
	
end;</source>
        <Parameter name="pFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawSelf" id="98c86a5b-091b-4d35-9ec4-139115cc4c87">
        <updating/>
        <source>drawSelf(pFrame: CMUI_GridAreaFrame input) updating;
// ---------------------------------------------------------------------------
// Created:     31 December 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/11/2012	cnwcs5		par 30475 - remove references to location restrictions
// 22/11/2016	cnwdap1		TFS 2844 STWR Hazardous Details Enhancements
// 31/01/2017 cnwrh7	TFS	2207	Hazardous location shows sub area colours 
// ---------------------------------------------------------------------------
vars
	theColour, theLineColour 	: Integer;
	iAmSelected 				: Boolean;
begin

	if self.availability = PAD_UNAVAILABLE and not self.power then
		if self.myGridArea.YRD_PadArea.areaMode &lt;&gt; YRD_PadArea.AreaMode_Height then
			return;
		endif;
	endif;
	
	iAmSelected := self.myGridArea.allSelectedPoints.includes(self);

	if self.myGridArea.YRD_PadArea.areaMode = YRD_PadArea.AreaMode_Height then
		if iAmSelected then
			theColour := Yellow; //self.myGridArea.YRD_PadArea.paintColour;
			theLineColour := theColour;
		else
			theColour := White;
			theLineColour := DarkGray;
		endif;
	elseif self.myGridArea.YRD_PadArea.areaMode = YRD_PadArea.AreaMode_Labour then
		if iAmSelected then
			if self.myGridArea.editMode  then 
				theColour := Yellow;
			else
				theColour := self.myGridArea.YRD_PadArea.paintColour;
			endif;
			theLineColour := theColour;
		elseif self.myGridArea.drawingMode and self.theLabourColour &lt;&gt; -1 then
			theColour := self.theLabourColour;
			theLineColour := theColour;
		elseif self.myGridArea.editMode then
			theColour := White;
			theLineColour := DarkGray;
		elseif self.theLabourColour = -1 then
			theColour := White;
			theLineColour := DarkGray;
		else
			theColour := self.theLabourColour;
			theLineColour := theColour;
		endif;

	elseif self.myGridArea.YRD_PadArea.areaMode = YRD_PadArea.AreaMode_SubBlock then
		if iAmSelected then
			theColour := self.myGridArea.YRD_PadArea.paintColour;
			theLineColour := theColour;
		elseif self.myGridArea.drawingMode and self.theSubBlockColour &lt;&gt; -1 then
			theColour := self.theSubBlockColour;
			theLineColour := theColour;
		elseif self.myGridArea.editMode then
			theColour := White;
			theLineColour := DarkGray;
		elseif self.theSubBlockColour = -1 then
			theColour := White;
			theLineColour := DarkGray;
		else
			theColour := self.theSubBlockColour;
			theLineColour := theColour;
		endif;
	elseif self.myGridArea.YRD_PadArea.areaMode = YRD_PadArea.AreaMode_TermSubArea then
		if iAmSelected then
			theColour := self.myGridArea.YRD_PadArea.paintColour;
			theLineColour := theColour;
		elseif self.myGridArea.drawingMode and self.theTermSubAreaColour &lt;&gt; -1 then
			theColour := self.theTermSubAreaColour;
			theLineColour := theColour;
		elseif self.myGridArea.editMode then
			theColour := White;
			theLineColour := DarkGray;
		elseif self.theTermSubAreaColour = -1 then
			theColour := White;
			theLineColour := DarkGray;
		else
			theColour := self.theTermSubAreaColour;
			theLineColour := theColour;
		endif;
	elseif self.myGridArea.YRD_PadArea.areaMode = YRD_PadArea.AreaMode_DoorDirection then
		if iAmSelected then
			theColour := self.myGridArea.YRD_PadArea.paintColour;
			theLineColour := theColour;
		elseif self.myGridArea.drawingMode and self.theDoorDirectionColour &lt;&gt; -1 then
			theColour := self.theDoorDirectionColour;
			theLineColour := theColour;
		elseif self.myGridArea.editMode then
			theColour := White;
			theLineColour := DarkGray;
		elseif self.theDoorDirectionColour = -1 then
			theColour := White;
			theLineColour := DarkGray;
		else
			theColour := self.theDoorDirectionColour;
			theLineColour := theColour;
		endif;

	elseif self.myGridArea.YRD_PadArea.areaMode = YRD_PadArea.AreaMode_Hazardous then	// TFS 2844
		if iAmSelected then																// TFS 2844
			theColour := self.myGridArea.YRD_PadArea.paintColour;						// TFS 2844
			theLineColour := theColour;													// TFS 2844
		elseif self.myGridArea.drawingMode and self.theHazardColour &lt;&gt; -1 then		// TFS 2844		//TFS2207
			theColour := self.theHazardColour;										// TFS 2844
			theLineColour := theColour;													// TFS 2844
		elseif self.myGridArea.editMode then											// TFS 2844
			theColour := White;															// TFS 2844
			theLineColour := DarkGray;													// TFS 2844
		elseif self.theHazardColour = -1 then										// TFS 2844
			theColour := White;															// TFS 2844
			theLineColour := DarkGray;													// TFS 2844
		else																			// TFS 2844
			theColour := self.theHazardColour;										// TFS 2844				//TFS 2207
			theLineColour := theColour;													// TFS 2844
		endif;																			// TFS 2844
		
	else
//		write "AKB" &amp; " " &amp; class.name &amp; '::' &amp; method.name &amp; " 1. UNKNOWN AREA MODE";
		return;
	endif;

	self.draw(pFrame,theColour, theLineColour,self.myGridArea.YRD_PadArea.areaMode);

		
end;</source>
        <Parameter name="pFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isGap" id="2323a9c9-af83-41c8-b31a-1b74880f361b">
        <source>isGap(): Boolean;
// ---------------------------------------------------------------------------
// Created:		12 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	return self.myLocationsController.isKindOf(CM_GapController);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="01c7d5de-b68e-4640-a660-869b8b69c696">
        <updating/>
        <source>setForCreate(_width, _height, _row, _col : Integer; _cmGridController : CM_GridController; _yrdPadArea : YRD_PadArea; 
				_mySBS : CM_BlockStack; _myLabourRestrictions : CM_LabourRestrictionByIdDict ) updating;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//  07/11/2012	cnwcs5	par 30475 - remove references to CM_LocationRestrictionContainer
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 24/11/2016	cnwdap1	TFS 2844 STWR Hazardous Details Enhancements
// ---------------------------------------------------------------------------
vars
	dLoc : CM_DoorDirectionLocation;	
	hazDetail : CM_TerminalAreaHazDetails;					// TFS 2844
begin

	self.mySubBlockStack := _mySBS;
	
	if _mySBS = null then
		self.theSubBlockColour := -1;
	else
		self.theSubBlockColour := self.mySubBlockStack.myLayoutGraphic.drawLineColour;
	endif;
	
	_myLabourRestrictions.copy(self.allLabourRestrictions);
	
	if _myLabourRestrictions.size = 0 then
		self.theLabourColour := -1;
	else
		self.theLabourColour := _myLabourRestrictions.first.colour;
	endif;
	
	_cmGridController.allTerminalSubAreas.copy(self.allTerminalSubAreas);
	
	if _cmGridController.allTerminalSubAreas.size = 0 then 
		self.theTermSubAreaColour := -1;
	else 
		self.theTermSubAreaColour := _cmGridController.allTerminalSubAreas.first.colour;
	endif;

	foreach dLoc in _cmGridController.allDoorDirectionLocations do
		self.allDoorDirectionRules.add( dLoc.myDoorDirectionRule );
	endforeach;

	if _cmGridController.allDoorDirectionLocations.size = 0 then 
		self.theDoorDirectionColour := -1;
	else 
		self.theDoorDirectionColour := _cmGridController.allDoorDirectionLocations.first.myDoorDirectionRule.colour;
	endif;
	
	foreach hazDetail in _cmGridController.allTerminalAreaHazDetails do						// TFS 2844
		self.allHazardDetails.addNoDuplicates(hazDetail, false);							// TFS 2844
	endforeach;																				// TFS 2844
	if _cmGridController.allTerminalAreaHazDetails.size = 0 then							// TFS 2844
		self.theHazardColour := -1;															// TFS 2844
	else																					// TFS 2844
		self.theHazardColour := _cmGridController.allTerminalAreaHazDetails.first.colour;	// TFS 2844
	endif;																					// TFS 2844
	
	self.theLocationColour 		:= -1;	
	self.width 					:= _width;
	self.heightOfStack 			:= _height;
	self.myLocationsController 	:= _cmGridController;
	
	self.setForCreateSuperClass(_yrdPadArea, _row, _col);
	
	self.power 					:= _cmGridController.power;
	self.powerDamaged 			:= _cmGridController.powerDamaged;
	
	if _cmGridController.isKindOf(CM_StackController) then
		self.availability 	:= _cmGridController.CM_StackController.availability;
		self.usage 			:= _cmGridController.CM_StackController.usage;
	elseif _cmGridController.isKindOf(CM_RTGController) then
		self.availability 	:= _cmGridController.CM_RTGController.availability;
		self.usage 			:= _cmGridController.CM_RTGController.usage;
	else
		self.availability 	:= 0;
		self.usage 			:= 0;
	endif;
end;</source>
        <Parameter name="_width" type="Integer"/>
        <Parameter name="_height" type="Integer"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_cmGridController" type="CM_GridController"/>
        <Parameter name="_yrdPadArea" type="YRD_PadArea"/>
        <Parameter name="_mySBS" type="CM_BlockStack"/>
        <Parameter name="_myLabourRestrictions" type="CM_LabourRestrictionByIdDict"/>
    </JadeMethod>
    <JadeMethod name="setForCreateGCAllocRow" id="6ac11748-4e56-4240-9333-2a73fc417836">
        <updating/>
        <source>setForCreateGCAllocRow(	_width, _height, _row, _col : Integer; 
						_controller : CM_GeneralCargoAllocGroup; 
						_yardPadArea : YRD_PadArea; 
						_sbs : CM_BlockStack; 
						_labourRestrictions : CM_LabourRestrictionByIdDict	) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 30/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satelite View Screen for Flexible Terminal Areas
//
vars
	hazDetail	: CM_TerminalAreaHazDetails;

begin
	_labourRestrictions.copy(self.allLabourRestrictions);
	if _labourRestrictions.size = 0 then
		self.theLabourColour := -1;
	else
		self.theLabourColour := _labourRestrictions.first.colour;
	endif;
	
	foreach hazDetail in _controller.allTerminalAreaHazDetails do
		self.allHazardDetails.addNoDuplicates(hazDetail, false);
	endforeach;
	if _controller.allTerminalAreaHazDetails.size = 0 then
		self.theHazardColour := -1;
	else
		self.theHazardColour := _controller.allTerminalAreaHazDetails.first.colour;
	endif;
	
	self.theSubBlockColour 		:= -1;
	self.theTermSubAreaColour 	:= -1;
	self.theDoorDirectionColour := -1;
	
	self.theLocationColour 		:= -1;	
	self.width 					:= _width;
	self.heightOfStack 			:= _height;
	self.myLocationsController 	:= _controller;
	
	self.setForCreateSuperClass(_yardPadArea, _row, _col);
	
	self.power 					:= _controller.power;
	self.powerDamaged 			:= _controller.powerDamaged;
	self.availability 			:= 1;
	self.usage 					:= 1;
	
epilog

end;</source>
        <Parameter name="_width" type="Integer"/>
        <Parameter name="_height" type="Integer"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_controller" type="CM_GeneralCargoAllocGroup"/>
        <Parameter name="_yardPadArea" type="YRD_PadArea"/>
        <Parameter name="_sbs" type="CM_BlockStack"/>
        <Parameter name="_labourRestrictions" type="CM_LabourRestrictionByIdDict"/>
    </JadeMethod>
    <JadeMethod name="setForCreateIrregularArea" id="0b9b0e42-deec-41a6-9a35-7a3c4ce9fff3">
        <updating/>
        <source>setForCreateIrregularArea(_width, _height, _row, _col : Integer; _location : CM_LocationsController; _yrdPadArea : YRD_PadArea) updating;
// TFS 3422
vars
	hazDetail	: CM_TerminalAreaHazDetails;
begin
	
	foreach hazDetail in _location.allTerminalAreaHazDetails do
		self.allHazardDetails.addNoDuplicates(hazDetail, false);
	endforeach;
	if _location.allTerminalAreaHazDetails.size = 0 then
		self.theHazardColour := -1;
	else
		self.theHazardColour := _location.allTerminalAreaHazDetails.first.colour;
	endif;
	
	self.theSubBlockColour := -1;
	self.theLabourColour := -1;
	self.theTermSubAreaColour := -1;
	self.theDoorDirectionColour := -1;
	self.theLocationColour 		:= -1;	

	self.width 					:= _width;
	self.heightOfStack 			:= _height;
	self.myLocationsController 	:= _location;
	
	self.setForCreateSuperClass(_yrdPadArea, _row, _col);
	
	self.power 					:= false;
	self.powerDamaged 			:= false;
	self.availability 			:= 1;
	self.usage 					:= 1;
end;</source>
        <Parameter name="_width" type="Integer"/>
        <Parameter name="_height" type="Integer"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_yrdPadArea" type="YRD_PadArea"/>
    </JadeMethod>
    <JadeMethod name="setForCreateRoRoLane" id="f4134fe5-1cb6-4591-bc8a-e28b1b33c699">
        <updating/>
        <source>setForCreateRoRoLane(_width, _height, _row, _col : Integer; _cmGridController : CM_RoRoController; _yrdPadArea : YRD_PadArea; 
				_mySBS : CM_BlockStack; _myLabourRestrictions : CM_LabourRestrictionByIdDict ) updating;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/11/2012	cnwcs5		par 30475 - remove references to container location restrictions ((removed _myLocationRestriction parameter)
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------
vars
	dLoc 	: CM_DoorDirectionLocation; 
begin
	self.mySubBlockStack := _mySBS;
	
	if _mySBS = null then
		self.theSubBlockColour := -1;
	else
		self.theSubBlockColour := self.mySubBlockStack.myLayoutGraphic.drawLineColour;
	endif;
	
	_myLabourRestrictions.copy(self.allLabourRestrictions);
	
	if _myLabourRestrictions.size = 0 then
		self.theLabourColour := -1;
	else
		self.theLabourColour := _myLabourRestrictions.first.colour;
	endif;
	
	_cmGridController.allTerminalSubAreas.copy(self.allTerminalSubAreas);
	
	if _cmGridController.allTerminalSubAreas.size = 0 then 
		self.theTermSubAreaColour := -1;
	else 
		self.theTermSubAreaColour := _cmGridController.allTerminalSubAreas.first.colour;
	endif;

	foreach dLoc in _cmGridController.allDoorDirectionLocations do
		self.allDoorDirectionRules.add( dLoc.myDoorDirectionRule );
	endforeach;
	
	if _cmGridController.allDoorDirectionLocations.size = 0 then 
		self.theDoorDirectionColour := -1;
	else 
		self.theDoorDirectionColour := _cmGridController.allDoorDirectionLocations.first.myDoorDirectionRule.colour;
	endif;
	
	self.theLocationColour 		:= -1;	
	self.width 					:= _width;
	self.heightOfStack 			:= _height;
	self.myLocationsController 	:= _cmGridController;
	
	self.setForCreateSuperClass(_yrdPadArea, _row, _col);
	
	self.power 					:= _cmGridController.power;
	self.powerDamaged 			:= _cmGridController.powerDamaged;
	self.availability 			:= 1;
	self.usage 					:= 1;
end;</source>
        <Parameter name="_width" type="Integer"/>
        <Parameter name="_height" type="Integer"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_cmGridController" type="CM_RoRoController"/>
        <Parameter name="_yrdPadArea" type="YRD_PadArea"/>
        <Parameter name="_mySBS" type="CM_BlockStack"/>
        <Parameter name="_myLabourRestrictions" type="CM_LabourRestrictionByIdDict"/>
    </JadeMethod>
    <JadeMethod name="setForUpdatePad" id="f5fc4e3b-1f24-4b94-be92-013b5f228bcf">
        <updating/>
        <source>setForUpdatePad(_cmGridController : CM_GridController) updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 07/11/2012	cnwcs5	par 30475 - remove references to CM_LocationRestrictionContainer
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 24/11/2016	cnwdap1	TFS 2844 STWR Hazardous Details Enhancements
vars
	dLoc : CM_DoorDirectionLocation;
begin

	self.mySubBlockStack := _cmGridController.mySubBlockStack;
	
	if self.mySubBlockStack = null then
		self.theSubBlockColour := -1;
	else
		self.theSubBlockColour := self.mySubBlockStack.myLayoutGraphic.drawLineColour;
	endif;
	
	self.allLabourRestrictions.clear;
	
	_cmGridController.allLabourRestrictions.copy(self.allLabourRestrictions);
	
	if self.allLabourRestrictions.size = 0 then
		self.theLabourColour := -1;
	else
		self.theLabourColour := self.allLabourRestrictions.first.colour;
	endif;
	
	self.allTerminalSubAreas.clear;
	_cmGridController.allTerminalSubAreas.copy(self.allTerminalSubAreas);
	
	if self.allTerminalSubAreas.size = 0 then
		self.theTermSubAreaColour:= -1;
	else
		self.theTermSubAreaColour:= self.allTerminalSubAreas.first.colour;
	endif;
	
	self.theLocationColour := -1;

	self.allDoorDirectionRules.clear;
	
	foreach dLoc in _cmGridController.allDoorDirectionLocations do
		self.allDoorDirectionRules.add( dLoc.myDoorDirectionRule );
	endforeach;
	
	if self.allDoorDirectionRules.size = 0 then 
		self.theDoorDirectionColour := -1;
	else 
		self.theDoorDirectionColour := self.allDoorDirectionRules.first.colour;
	endif;

	self.allHazardDetails.clear;													// TFS 2844
	_cmGridController.allTerminalAreaHazDetails.copy(self.allHazardDetails);		// TFS 2844
	if self.allHazardDetails.size = 0 then											// TFS 2844
		self.theHazardColour := -1;													// TFS 2844
	else																			// TFS 2844
		self.theHazardColour := self.allHazardDetails.first.colour;					// TFS 2844
	endif;																			// TFS 2844
	
	self.power 			:= _cmGridController.power;
	self.powerDamaged 	:= _cmGridController.powerDamaged;
	
	if _cmGridController.isKindOf(CM_StackController) then
		self.availability 	:= _cmGridController.CM_StackController.availability;
		self.usage 			:= _cmGridController.CM_StackController.usage;
		
	elseif _cmGridController.isKindOf(CM_RTGController) then
		self.availability 	:= _cmGridController.CM_RTGController.availability;
		self.usage 			:= _cmGridController.CM_RTGController.usage;
	else
		self.availability	:= 0;
		self.usage 			:= 0;
	endif;
end;</source>
        <Parameter name="_cmGridController" type="CM_GridController"/>
    </JadeMethod>
    <JadeMethod name="setForUpdatePadGC" id="5281c4ba-a67c-4f0c-8bc4-ef5a4fe5a2ff">
        <updating/>
        <source>setForUpdatePadGC(_controller : CM_IrregularBlockController) updating;
//TFS 3422 after TFS 2844 handle General Cargo Areas as well
vars
	
begin

	self.theSubBlockColour := -1;
	self.allLabourRestrictions.clear;
	self.theLabourColour := -1;
	self.allTerminalSubAreas.clear;
	self.theTermSubAreaColour:= -1;
	self.theLocationColour := -1;

	self.allDoorDirectionRules.clear;
	self.theDoorDirectionColour := -1;

	self.allHazardDetails.clear;
	_controller.allTerminalAreaHazDetails.copy(self.allHazardDetails);
	if self.allHazardDetails.size = 0 then
		self.theHazardColour := -1;
	else
		self.theHazardColour := self.allHazardDetails.first.colour;
	endif;
	
	self.power 			:= _controller.power;
	self.powerDamaged 	:= _controller.powerDamaged;
	
	self.availability	:= 1;
	self.usage 			:= 0;
end;</source>
        <Parameter name="_controller" type="CM_IrregularBlockController"/>
    </JadeMethod>
    <JadeMethod name="setForUpdatePadGCAlloc" id="60890c85-db74-480c-a60e-cc2cde53f655">
        <updating/>
        <source>setForUpdatePadGCAlloc(_controller : CM_GeneralCargoAllocGroup) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18/05/2021	navdap1		Initial creation TFS 49899 MTN Labour on Block for New GC Areas
//
vars

begin
	self.theSubBlockColour := -1;
	self.allLabourRestrictions.clear;
	self.theLabourColour := -1;
	self.allTerminalSubAreas.clear;
	self.theTermSubAreaColour:= -1;
	self.theLocationColour := -1;
	
	_controller.allLabourRestrictions.copy(self.allLabourRestrictions);
	if self.allLabourRestrictions.isEmpty then
		self.theLabourColour := -1;
	else
		self.theLabourColour := self.allLabourRestrictions.first.colour;
	endif;
	
	self.allDoorDirectionRules.clear;
	self.theDoorDirectionColour := -1;

	self.allHazardDetails.clear;
	_controller.allTerminalAreaHazDetails.copy(self.allHazardDetails);
	if self.allHazardDetails.size = 0 then
		self.theHazardColour := -1;
	else
		self.theHazardColour := self.allHazardDetails.first.colour;
	endif;
	
	self.power 			:= _controller.power;
	self.powerDamaged 	:= _controller.powerDamaged;
	
	self.availability	:= 1;
	self.usage 			:= 0;

epilog

end;</source>
        <Parameter name="_controller" type="CM_GeneralCargoAllocGroup"/>
    </JadeMethod>
</Class>
