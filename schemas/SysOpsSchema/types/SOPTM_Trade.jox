    <JadeMethod name="setPortsOfCallChanged" id="ebf19ddf-0463-45e4-853e-fc4bab2b890c">
        <updating/>
        <source>setPortsOfCallChanged(_value : Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 September 2009	cnwer1	Initial creation

*/

vars

begin
