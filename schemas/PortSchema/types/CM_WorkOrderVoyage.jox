    <JadeMethod name="setNotApproved" id="4c65b550-67e2-43ad-ad3d-caf77a19f7d5">
        <updating/>
        <source>setNotApproved(_notApprovedBy: String; _remarks: String; _totDays: Decimal) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 October 2018		jlger1	Initial creation 41310
16 Nov    2018      cnwma1  ChangeRequest 42045: PEL1 - SAP Integration : Additional Changes - Extended
*/

vars
	woDtl   : CM_WorkOrderDtl;
	wo      : CM_WorkOrder;
	cashRec,
	pxyCashRec : CM_CashReceipt;
begin
	inheritMethod(_notApprovedBy, _remarks, _totDays);
	
	self.myVoyage.setRemarks(app.getErrorString2(Work_order_reject_because,allWoDtls.first.taskID,self.remarks),true);
	
	foreach woDtl in self.allWoDtls discreteLock do
		woDtl.CM_WorkOrderVoyageDtl.actionForNotApproved(self.myVoyage);
	endforeach;
	
	/*
		16.11.2018 cnwma1 TFS# 42045
		41022.130 Rejected Marine Service Work Order – Auto Collection
	*/	
	woDtl := allWoDtls.first.CM_WorkOrderDtl;
	wo    := woDtl.myParent;
	
	if wo.isWorkOrderForIMSR then
		/* 
			Auto Collection will be by sending WSDL 1.10
			processSAPRequest Only used to cancel Auto collection
		*/
		wo.processSAPRequest(true); 
		/*Post Pay will be by changing cash receipt payment status to Cancel*/
		if wo.allCashReceipts.isNotEmpty then
			foreach cashRec in wo.allCashReceipts do
				if cashRec.isPostPay then
					pxyCashRec := cashRec.pxyCreateUpdateProxy();
					app.myUtilityUA.utlUpdateCashRecPaymentStatus(pxyCashRec,CM_CashReceipt.CREDIT_CANCEL_APPROVED, app.myPassport);
				endif;
			endforeach;
		endif;
	endif;
epilog
	delete pxyCashRec;
end;</source>
        <Parameter name="_notApprovedBy" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_totDays" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setOperatorsForWS" id="dbe37e83-f5fe-4fc9-8c14-cca7999c6f9d">
        <updating/>
        <source>setOperatorsForWS(_voyageOp: CM_Operator; _loadOp: CM_Operator; _dischargeOp: CM_Operator) updating;
/*

Purpose:			// TFS 40029

Parameters:			

Return Value:		

Date		Who		Reason
30 August 2018	jlgab1	Initial creation

*/

vars
	wodtl : CM_WorkOrderDtl;
begin

	if self.isWorkOrderForVoyageRequest then
		wodtl := self.allWoDtls.first;
		if wodtl&lt;&gt; null then
			wodtl.setOperatorsForWS(_voyageOp, _loadOp, _dischargeOp);
		endif;
	
	endif;
epilog

end;</source>
        <Parameter name="_voyageOp" type="CM_Operator"/>
        <Parameter name="_loadOp" type="CM_Operator"/>
        <Parameter name="_dischargeOp" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="setPendingApproval" id="ee469161-adea-4df5-91cc-5e6ab98dbe29">
