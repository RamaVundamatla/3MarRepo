    <JadeMethod name="getAuditText" id="acb51684-a828-413a-a704-74449f7325f4">
        <source>getAuditText(): String;
 // par 20581 cnwrs1 sept 2009
vars
	txt	: String;
begin
	txt := inheritMethod();
	if self.myBGPManager &lt;&gt; null then
		txt := txt &amp; self.myBGPManager.getAuditText();
	endif;
	return txt;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDDSQueuedRequestsFor" id="7e0a0a44-fd42-483d-9f84-ddf92ed16628">
        <source>getDDSQueuedRequestsFor( _descr : String ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2014	cnwndl1	Initial creation	Unit Test method

*/
vars

	tmpClass	: Class;
	number		: Integer;
	className	: String;
	iter : Iterator;
	ddsReq : BGP_ExternalDBRequest;
	
begin

	foreach className in self.allRequestClassesToProcess do
		tmpClass := self.getClass(className);
		if tmpClass = null then
			continue;
		endif;
		if className = BGP_ExternalDBRequest.name then
			iter := BGP_ExternalDBRequest.instances.createIterator;
			while iter.next( ddsReq ) do
				if ddsReq.isTransient then
					continue;
				endif;
				if ddsReq.isProcessed then
					continue;
				endif;
				if ddsReq.myDataDumpExtractDef = null then
					continue;
				endif;
				if ddsReq.myDataDumpExtractDef.description = _descr then
					number := number + 1;
				endif;
			endwhile;
			delete iter;
		endif;
	endforeach;
	
	return number;

epilog
	
		delete iter;
		
end;</source>
        <Parameter name="_descr" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="31158db1-c31c-44fa-a7f9-068d08b21d54">
        <source>getDisplay() : String;

// cnwdvb1 24 October 2002 
/*

Date		Who		Reason
17 Oct 2011	cnwkpd1	PAR #28493 - 1090 exception from BGP form
	
*/

vars
	start,
	queued	: String;
	request : BGP_Request;
	invalid	: Boolean;
	
begin
	on Exception do self.xHandlerDisplay(exception);

	// PAR #28493 - need to get request to local variable and protect against it being deleted, because 
	// self.myCurrentRequest can become null at any time
	request :=  self.myCurrentRequest;
	if request &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, request, invalid);
		start := request.processingStartTime.bgpDisplay();
		on Exception do null;
	endif;

/*	PAR #28493 - old code replaced	
	if self.myCurrentRequest &lt;&gt; null and // cnwrs1 Feb 2007 got a dump with myCurrentRequest = null par 16836
	   global.isValidObject(self.myCurrentRequest) then
		if self.myCurrentRequest &lt;&gt; null then	// CCMS1150 cnwrs1 04 July 2011
			start := self.myCurrentRequest.processingStartTime.bgpDisplay();
		endif;
	endif;
*/

	if self.numQueuedRequests &lt;&gt; 0 then
		queued := self.numQueuedRequests.String;
	endif;	
	return Tab &amp; Tab &amp; Tab &amp; self.displayString &amp; Tab &amp; self.machineName &amp; Tab &amp; self.dateTimeLastStarted.bgpDisplay() &amp;  Tab &amp; queued &amp; 
	Tab &amp; start &amp; Tab &amp; self.dateTimeLastCompleted.bgpDisplay() &amp; Tab &amp; self.isRunning().asRunningStopped(self.isSetup) &amp; Tab &amp; self.isRunningSDSDisplay();// CCMS1150 cnwrs1 04 July 2011

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
