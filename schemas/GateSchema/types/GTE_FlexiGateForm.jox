        <source>resizeHeight(size : Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2009	cnwas3	Initial creation

*/
begin	
	
	self.minimumHeight := size;
	
	if self.height &lt; self.minimumHeight then
		self.height := self.minimumHeight;
	endif;
	
/*	self.minimumHeight := self.minimumHeight + size;
	
	if self.minimumHeight &lt; 688 then 
		self.minimumHeight := 688;		
	endif;
	
	if (size &gt; 0 and self.height &lt; self.minimumHeight) or (size &lt; 0 and self.height &gt; self.minimumHeight) then
		self.height := self.minimumHeight;
	endif;*/
end;</source>
