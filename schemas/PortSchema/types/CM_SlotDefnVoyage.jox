    <JadeMethod name="createSlotController" id="bdab975a-ad23-4726-810c-8f791b1ca555">
        <updating/>
        <source>createSlotController(_doTransient : Boolean) updating;
/*
------------------------------------------------------------------------
Created:			30 January 2003 by cnwdwq1
Purpose:			Creates the slot controller that relates to this slotDefnVoyage.
Parameters:		None
Returns:			Not a lot.
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	slotController : CM_SlotController;
begin
	if self.mySlotController &lt;&gt; null then
		return;
	endif;

	slotController :=  self.myBay.CM_BayVoyage.allSlotControllersByOrdinal[self.ordinalDeck,self.ordinalCell,self.ordinalTier];
	if slotController = null then
		if _doTransient then
			create slotController transient;
		else
			create slotController;
		endif;
	endif;

	slotController.setFromSlotDefnVoyage(self);
	
end;</source>
        <Parameter name="_doTransient" type="Boolean"/>
    </JadeMethod>
