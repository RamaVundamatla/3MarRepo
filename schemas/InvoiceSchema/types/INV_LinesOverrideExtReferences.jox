    <JadeMethod name="translateForm" id="ddb9f76b-eca0-4aea-81fa-458f7b601f6c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 January 2026 10:31:55.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0027140, locale);
	btnCancel.translateCaption(Xlat_0027141, locale);
	btnSave.translateCaption(Xlat_0027142, locale);
	lblExtRef1.translateCaption(Xlat_0027143, locale);
	lblExtRef2.translateCaption(Xlat_0027144, locale);
	lblExtRef3.translateCaption(Xlat_0027145, locale);
	lblExtRef4.translateCaption(Xlat_0027146, locale);
	lblInvoiceID.translateCaption(Xlat_0027147, locale);
	lblInvoiceLines.translateCaption(Xlat_0027148, locale);
	lblTotal.translateCaption(Xlat_0027149, locale);
end;</source>
    </JadeMethod>
