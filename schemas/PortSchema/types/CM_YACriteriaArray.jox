<CollClass name="CM_YACriteriaArray" id="75e57d2e-07cd-4947-b9b5-3f70a257ca54">
    <loadFactor>66</loadFactor>
    <memberType name="CM_YACriteria"/>
    <superclass name="ObjectArray"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getDisplay" id="bc84104b-5dbf-482a-a394-3af416c1d1d7">
        <source>getDisplay():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 February 2014	cnwndl1	Initial creation	Par 33439

*/

vars

	crit : CM_YACriteria;
	str : String;

begin

	foreach crit in self do
		if str &lt;&gt; null then
			str := str &amp; ", ";
		endif;
		str := str &amp; crit.getDescription();
	endforeach;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
