	file: File;
begin
	app.initialize();
	create file transient;
	file.openOutput("c:\dev\client_EDIlicense.csv");
	create ediAgent transient;
	ediAgent.init;
	ediAgent.outputAsCSV(file);
/*	
	// Get Clients
	create clients transient;
	clientLicenseDetails := DEV_LicenseEntity.getConstant(DEV_LicenseEntity.DETAILS).text;
	pos := 1;
	while (pos &gt; 0) do
		clientXML := clientLicenseDetails.cnEcGetNextTagValueOfName(DEV_LicenseClient.XMLTag_Client, pos);
		if clientXML &lt;&gt; null then
			create client transient;
			client.setFromXML(clientXML);
			clients.add(client);
		endif;
	endwhile;

	foreach client in clients do
		clientNames := clientNames &amp; "," &amp; client.name;
	endforeach;
	
	file.writeLine("Name,Value,Type,Category,Internal,Description" &amp; clientNames);
	foreach constant in currentSchema.getCategory(XLAT_Permissions).getConstants do
		create permission transient;
		permission.setFromXML(constant);
		
		if permission.permType = 0 then
			permTypeString := "0 - Terminal";
		elseif permission.permType = 1 then
			permTypeString := "1 - System";
		else
			permTypeString := "2 - License";
		endif;
		

		if permission.permType = 2 and not permission.isInternal then
			clientLicense := "";
			foreach client in clients do
				foreach licenseDtl in client.allLicenseDtls do
					if licenseDtl.type = DEV_LicenseEntity.LicenseType_System then
						if licenseDtl.canDo(permission.constValue) then
							clientLicense := clientLicense &amp; ",Yes";
						else
							clientLicense := clientLicense &amp; ",";
						endif;
					endif;
				endforeach;
			endforeach;
			file.writeLine(permission.constName
					   &amp; "," &amp; permission.constValue.String 
					   &amp; "," &amp; permTypeString
					   &amp; "," &amp; permission.category.String
					   &amp; "," &amp; permission.isInternal.String
					   &amp; "," &amp; permission.description.String
					   &amp; clientLicense
					   );
		endif;
		delete permission;
	endforeach;*/
	file.close;
epilog
//	delete permission;
//	if clients &lt;&gt; null then
//		clients.purge;
//	endif;
//	delete clients;
	delete ediAgent;
	delete file;
end;</source>
    </JadeMethod>
    <JadeMethod name="extractReportConstants" id="159a3f67-2c89-4deb-9fdf-a96147bc1e17">
        <source>extractReportConstants();
// 35754 extract CM_Report global constants with the current report descriptions
vars

	file					: File;
	constantCategory 		: ConstantCategory;
	constant				: Constant;
	pos1, pos2				: Integer;
	text 					: String;
	text1, text2			: String;
	reportName				: String;
	qryReport				: CM_QryReport;
	xmlParser 				: CnEcXmlParser;
	xmlStruct	 			: CnEcXmlStructureInstance;
	found,
	changed,
	new,
	lost				: Integer;
	
	dict				: DynaDictionary;
begin
	create dict transient;
	dict.setMembership(CM_QryReport);
	dict.addExternalKey(String, 60, false, true);
	dict.endKeys(false);
	
	foreach qryReport in CM_QryReportSystem.instances do
		if dict[qryReport.reportName] = null then
			dict.putAtKey(qryReport.reportName, qryReport);
		endif;
	endforeach;

	create file transient;
	file.usePresentationFileSystem := true;
	file.openOutput('c:\temp\PortSchema_ReportConstants.scm');
	if file.isAvailable() then
		file.purge;
	endif;

	file.writeLine('jadeVersionNumber "7.0.08";');
	file.writeLine('schemaDefinition');
	file.writeLine('PortSchema subschemaOf BaseSchema partialDefinition;');
	
	constantCategory := rootSchema.getSchema(PortSchemaName).getConstantCategory("CM_Report");
	file.writeLine('constantDefinitions');

	// constant category
	file.writeLine(Tab &amp; 'categoryDefinition ' &amp; constantCategory.name);
	
	create xmlParser transient;
	foreach constant in constantCategory.getConstants do
		delete xmlStruct;
		create xmlStruct as CnEcXmlGroupInstance transient;
		text := constant.text;
		xmlParser.parseToMsgStructure(text, xmlStruct);
		qryReport := null;
		if xmlStruct.findStructure('reportName') &lt;&gt; null then
			reportName 	:= xmlStruct.findStructure('reportName').tagData;
			qryReport := dict.getAtKey(reportName).CM_QryReport;
			if qryReport = null then
				lost := lost + 1;
			else
				found := found + 1;
			endif;
		endif;
		if qryReport &lt;&gt; null and
		   qryReport.reportDescription &lt;&gt; null then
			pos1 := text.pos("&lt;reportDescription&gt;", 1);
			if pos1 &gt; 0 then			// already a reportDescription etry
				text1 := text[1:pos1+18];
				pos2 := text.pos("&lt;/reportDescription&gt;", pos1);
				if pos2 &gt; 0 then
					text2 := text[pos2:end];
					text := text1 &amp; qryReport.reportDescription &amp; text2;
					changed := changed + 1;
				endif;
			else		// no reportDescription, add it before the end tag ...
				pos1 := text.pos("&lt;/CM_QueryReport&gt;", 1);
				if pos1 &gt; 0 then
					text1 := text[1:pos1-1];
					text := text1 &amp; "&lt;reportDescription&gt;" &amp; qryReport.reportDescription &amp; "&lt;/reportDescription&gt;" &amp; CrLf &amp; "&lt;/CM_QueryReport&gt;";
					new := new + 1;
				endif;
			endif;
		endif;
		// now write the constant definition to the scm file with the updated description
		
		file.writeLine(Tab &amp; Tab &amp; constant.name &amp; ':	' &amp; constant.type.name &amp; ' = ' &amp; constant.getSource() &amp; ';');
		file.writeLine(Tab &amp; 'documentationText');
		file.writeLine('`' &amp; text &amp; '`');
		
	endforeach;
	file.close();
	write "found=" &amp; found.String &amp; " lost=" &amp; lost.String &amp; " changed=" &amp; changed.String &amp; " new=" &amp; new.String; // only 2 'lost'
epilog
	delete file;
	delete xmlParser;
	delete xmlStruct;
	delete dict;
end;</source>
    </JadeMethod>
    <JadeMethod name="extract_CM_DrawingAttribute" id="81460b3d-f86a-4042-a21b-69844249d481">
        <source>extract_CM_DrawingAttribute();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2017	jlgma1	Initial creation
17 Oct 2017	cnwma1  TFS #7431 JMT - Refactoring - Drawing Attributes Labels

*/

vars
	drw :CM_DrawingAttribute  ;
	lFile : File;
	lbl : String;
begin
	create lFile transient;
	lFile.fileName := "C:\TEMP\CM_DrawingAttribute_DMAST2.csv";
	lFile.open;
	
	foreach drw in CM_DrawingAttribute.instances do
		lbl:= null;
		
		lbl := drw.getLabel;
		
		lFile.writeLine(drw.getOidAsString &amp;","&amp; drw.code  &amp;","&amp; drw.getLabel  &amp;","&amp; drw.label);
		
	
	endforeach;
	
	
	lFile.close;
	
	delete lFile;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="findBeginLoadEndLoadMethods" id="77da8984-3087-4a7f-86d5-955d889bde73">
        <source>findBeginLoadEndLoadMethods(_file : File io; _class : Class);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 April 2011	cnwmh5	Initial creation

*/

constants
	MaxTokens		: Integer = 4000;
	CheckReturn		: Boolean = true;
	SortRefs		: Boolean = true;

vars
	meth			: Method;
	methodsDict		: MethodNDict;
	dd				: DynaDictionary;
	iter			: Iterator;
	
	cmsBeginEndLoadVarArray	: StringArray;
	
	methodSource	: String;
	tokensSize		: Integer;
	tokens			: HugeStringArray;
	token,
	tokenPlus1,
	tokenPlus2,
	tokenPlus3,
	arrayToken		: String;
	doesCreate,
	doesReturn,
	doesDelete,
	doesDeleteInEpilog,
	appMsgBox,
	inEpilog		: Boolean;
	currentLevel,
	createLevel,
	deleteLevel		: Integer;
	
	cmsBeginLoadStr,
	cmsEndLoadEpilogStr,
	cmsEndLoadStr, 
 	cmsBeginEndLoadVars : String;
	
	beginLoadStr,
	endLoadEpilogStr,
	endLoadStr		: String;
	
	str				: String;
	
	posStart, 
	posEnd			: Integer;
	
	isOK			: Boolean;

begin
	if _class = null then
		write 'Class is null';
		return;
	endif;	
	
	write "Checking methods for cmsBeginLoad, cmsEndLoad, beginLoad and endLoad in class " &amp; _class.schema.name &amp; "::" &amp; _class.name;

	// Get all the references to the named class
	methodsDict := _class.cnGetMethods();
	iter:= methodsDict.createIterator;

	create cmsBeginEndLoadVarArray transient;	
	
	while iter.next(meth) do
		
			// don't want my search methods
			if meth.name = "mh5CheckBeginEndLoads" or meth.name = "findBeginLoadEndLoadMethods" or 
					meth.name = 'cmsBeginLoad' or meth.name = "cmsEndLoad" or meth.name = 'cmsBeginLoadOLD' or
					meth.name = 'cmsEndLoadOLD' then
				continue;
			endif;
	
			methodSource := findPossibleTransLeaksRemFlf(meth.getSource);
			methodSource.replaceChar(Cr, " ");
			methodSource.replaceChar(Lf, " ");

			// Break method source into tokens
			tokens := methodSource.getHugeTokens;
			tokensSize := tokens.size;
		
			// Add 4 tokens at the end to ensure we process them all
			tokens.add(null);
			tokens.add(null);
			tokens.add(null);
			tokens.add(null);

			appMsgBox := false;
			inEpilog := false;
			doesCreate := false;
			doesReturn := false;
			doesDelete := false;
			doesDeleteInEpilog := false;
			currentLevel := 0;
			createLevel := 0;
			deleteLevel := 0;

			token := null;
			tokenPlus1 := null;
			tokenPlus2 := null;
			tokenPlus3 := null;
			
			cmsBeginLoadStr := null;
			cmsEndLoadEpilogStr := null;
			cmsEndLoadStr := null;
			isOK := false;
			cmsBeginEndLoadVars := null;
			
			beginLoadStr := null;
			endLoadStr := null;
			endLoadEpilogStr := null;
			
			cmsBeginEndLoadVarArray.clear();

			foreach arrayToken in tokens do
				token := tokenPlus1;
				tokenPlus1 := tokenPlus2;
				tokenPlus2 := tokenPlus3;
				tokenPlus3 := arrayToken;

				if token.cnContains("cmsBeginLoad") then
					cmsBeginLoadStr := token;
					posStart := token.pos("(", 1) + 1;
					posEnd := token.pos(")", 1);
					str := token[posStart:posEnd-posStart];
					if not cmsBeginEndLoadVarArray.includes(str) then
						cmsBeginEndLoadVarArray.add(str);
					endif;
				elseif token.cnContains('cmsEndLoad') then
					if inEpilog then
						cmsEndLoadEpilogStr := token;
					else
						cmsEndLoadStr := token;
					endif;
					posStart := token.pos("(", 1) + 1;
					posEnd := token.pos(")", 1);
					str := token[posStart:posEnd-posStart];
					if not cmsBeginEndLoadVarArray.includes(str) then
						cmsBeginEndLoadVarArray.add(str);
					endif;
				elseif token = "beginLoad" then
					beginLoadStr := token;
				elseif token = "endLoad" then
					if inEpilog then
						endLoadEpilogStr := token;
					else
						endLoadStr := token;
					endif;
				elseif token = "epilog" then
					inEpilog := true;
				elseif token = "msgBox" then
					appMsgBox := true;
				endif;
			
			endforeach;
		
			// not cmsBeginLoad or beginLoad so next method
			if cmsBeginLoadStr = null and beginLoadStr = null then
				continue;
			endif;
			
			if cmsBeginLoadStr &lt;&gt; null then
				//isOK := (inEpilog and cmsEndLoadEpilogStr &lt;&gt; null and cmsBeginEndLoadVarArray.size = 1);
				if not cmsBeginEndLoadVarArray.isEmpty() then
					foreach str in cmsBeginEndLoadVarArray do
						cmsBeginEndLoadVars := cmsBeginEndLoadVars &amp; str &amp; ",";
					endforeach;
					cmsBeginEndLoadVars := cmsBeginEndLoadVars[1:cmsBeginEndLoadVars.length-1];
				endif;
			endif;
						
		//	if beginLoadStr &lt;&gt; null then
		//		isOK := (inEpilog and endLoadEpilogStr &lt;&gt; null);
		//	endif;
			
			if cmsEndLoadEpilogStr &lt;&gt; null or endLoadEpilogStr &lt;&gt; null then
				isOK := true;
			endif;
		
			
			if not appMsgBox then
				continue;
			endif;
			
			_file.writeLine(_class.schema.name &amp; "::" &amp; _class.name &amp; "::" &amp; meth.name &amp; Tab &amp; 
				_class.schema.name &amp; Tab &amp; _class.name &amp; Tab &amp; meth.name &amp; Tab &amp; (cmsBeginLoadStr &lt;&gt; null).String &amp; Tab &amp; 
				(cmsEndLoadStr &lt;&gt; null).String &amp; Tab &amp; cmsBeginEndLoadVars &amp; Tab &amp; (beginLoadStr &lt;&gt; null).String &amp; Tab &amp; 
				(endLoadStr &lt;&gt; null).String &amp; Tab &amp; (cmsEndLoadEpilogStr &lt;&gt; null or endLoadEpilogStr &lt;&gt; null).String &amp; Tab &amp; isOK.String);
			write _class.schema.name &amp; "::" &amp; _class.name &amp; "::" &amp; meth.name &amp; Tab &amp; 
				_class.schema.name &amp; Tab &amp; _class.name &amp; Tab &amp; meth.name &amp; Tab &amp; (cmsBeginLoadStr &lt;&gt; null).String &amp; Tab &amp; 
				(cmsEndLoadStr &lt;&gt; null).String &amp; Tab &amp; cmsBeginEndLoadVars &amp; Tab &amp; (beginLoadStr &lt;&gt; null).String &amp; Tab &amp; 
				(endLoadStr &lt;&gt; null).String &amp; Tab &amp; (cmsEndLoadEpilogStr &lt;&gt; null or endLoadEpilogStr &lt;&gt; null).String &amp; Tab &amp; isOK.String;
			
			delete tokens;

	endwhile;
		
	

epilog
	write "Finished checking class " &amp; _class.schema.name &amp; "::" &amp; _class.name;
	delete cmsBeginEndLoadVarArray;
	//delete methodsDict;
	delete iter;
	delete tokens;
	delete dd;
end;</source>
        <Parameter name="_file" type="File" usage="io"/>
        <Parameter name="_class" type="Class"/>
    </JadeMethod>
    <JadeMethod name="findClassesInUse" id="0d5e5ea1-4c89-4bb9-b833-7fc8c3b2102a">
        <source>findClassesInUse();

/*

Purpose:			Find all the classes in use in the current system.
					Much quicker than using the dev environment Browse Classes In Use.
					
Parameters:			None

Return Value:		Output to Tab separated txt file


Date		Who		Reason
28 May 2009	cnwkpd1	Initial creation

*/


vars
	cls				: Class;
	numClasses,
	numProcesses,
	pos,
	len,
	classNum,
	lastClassNum	: Integer;
    inuseString,
	lastSchemaName,
	lastClassName	: String;
    proc			: Process;
	file			: File;
	invalidProcess	: Boolean;
	
begin
	system._getClassAcquisitions(inuseString, 0, numClasses, numProcesses);
	
	write "numClasses=" &amp; numClasses.String;
	write "numProcesses=" &amp; numProcesses.String;
	
	create file transient;
	file.openOutput("c:\temp\inuse.txt");
	
	on Exception do app.handleDeletedObject(exception, proc, invalidProcess);
	
	pos := 1;
	len := inuseString.length();
	
	while pos &lt; len do
		classNum := inuseString.scanUntil("/", pos).Integer;
		pos := pos + 1;
		
		proc := inuseString.scanUntil(",", pos).asOid.Process;
        pos := pos + 1;
		
		if classNum &lt;&gt; lastClassNum then
			lastClassNum := classNum;
			cls := rootSchema.getClassByNumber(classNum);
			lastSchemaName := cls.schema.name;
			lastClassName := cls.name;
		endif;
		
		file.writeLine(lastSchemaName &amp; Tab &amp; lastClassName&amp; Tab &amp; classNum.String &amp; Tab &amp; proc.userCode &amp; Tab &amp; proc.node.name &amp; Tab &amp; proc.persistentApp.name);
    endwhile;

	file.close();

	
epilog
	delete file;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="findJRWReportUsage" id="d9ef3e95-36de-4658-af59-3cbed96aae38">
        <source>findJRWReportUsage();

/*

Purpose:			Find Ssytem usages of a given JRW report name

Parameters:			None

Return Value:		None


Date		Who		Reason
30 Jul 2010	cnwkpd1	PAR #25185

*/

constants
//	ReportName		= "CM_PlanWeightCmdtyOld";
	ReportName		= "NF_VESSEL_SCHEDULE_RORO_FINAL";
	
vars
	qrs				: CM_QryReportSystem;
	qru				: CM_QryReportUser;
	
begin
	foreach qrs in CM_QryReportSystem.instances do
		if qrs.jrwReportName.includes(ReportName) then
			write qrs.String &amp; Tab &amp; qrs.reportName;
		endif;
	endforeach;
	
	foreach qru in CM_QryReportUser.instances do
		if qru.jrwReportName.includes(ReportName) then
			write qru.String &amp; Tab &amp; qru.reportName;
		endif;
	endforeach;

	write "Finished";
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="findPossibleTransLeaksOneCls" id="66824da2-67ca-4f9f-95d0-09903d74f9aa">
        <source>findPossibleTransLeaksOneCls();

/*

Purpose:			This method will scan through the meta schema data looking
					for methods which create transient instances of a given class, 
					and also highlight if the instances do not appear to be being 
					deleted.
					Simply change the SchemaToCheck and ClassToCheck constants to the 
					appropriate class, and execute.


Return Value:


Date		Who		Reason
22 Aug 2002	KPD		Initial creation
05 Dec 2002	KPD		Add log errors only option

*/

constants
	SchemaToCheck	: String = "PortSchema";  //"PortSchema";
	ClassToCheck	: String = "CM_TISet";//"CM_CashPayment";// CM_TITransactionSet";//"StringArray";
	LogErrorsOnly	: Boolean = true;
	IncludeJadeScriptMethods	: Boolean = false;
	
vars
	scm				: Schema;
	localClass,
	rootClass		: Class;
	
begin
	scm := rootSchema.getSchema(SchemaToCheck);
	if scm = null then
		scm := currentSchema;
	endif;
	
	// Check class at named schema
	localClass := scm.getClass(ClassToCheck);
	if localClass &lt;&gt; null then
		findPossibleTransientLeaks(localClass, IncludeJadeScriptMethods, LogErrorsOnly, false);
	endif;
	
	// Also check at rootSchema in case it is a rootSchema class
	rootClass := rootSchema.getClass(ClassToCheck);
	if rootClass &lt;&gt; null and rootClass &lt;&gt; localClass then
		findPossibleTransientLeaks(rootClass, IncludeJadeScriptMethods, LogErrorsOnly, false);
	endif;
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="findPossibleTransLeaksRemFlf" id="e45eb50a-dbd4-40c4-ae11-0332cc003efb">
        <source>findPossibleTransLeaksRemFlf(pSource: String): String;

/*
Purpose:			To remove the fluff from a method source. Fluff is comment text and the contents of string literals.
					This is for use when checking for leaking transients.
					The purpose of this is two-fold: to reduce the number of (1) tokens to be processed, and (2) false positives
					which occur when the 'never delete a line of code' brigade comment out foreach statements and replace them
					with while statements.

Return Value:		The defluffed source.

Date				Who			Reason
14 Jun 2005			cnwjub1		Creation
02 Sep 2008	cnwkpd1	"Borrowed" code from JSMS

*/

vars
	dq, sq, sa, ss, p, p1, sz, first, eol: Integer;
	src, str: String;

begin
	src:= pSource;
	p:= 1;
	sz:= src.length;
	dq:= src.pos('"', 1);
	sq:= src.pos("'", 1);
	sa:= src.pos("/*", 1);
	ss:= src.pos("//", 1);
	while true do
		if dq &gt; 0 and dq &lt; p then
			dq:= src.pos('"', p);
		endif;
		if sq &gt; 0 and sq &lt; p then
			sq:= src.pos("'", p);
		endif;
		if sa &gt; 0 and sa &lt; p then
			sa:= src.pos("/*", p);
		endif;
		if ss &gt; 0 and ss &lt; p then
			ss:= src.pos("//", p);
		endif;
		first:= 0;
		p1:= sz + 1;
		if dq &gt; 0 then
			first:= 1;
			p1:= dq;
		endif;
		if sq &gt; 0 and sq &lt; p1 then
			first:= 2;
			p1:= sq;
		endif;
		if sa &gt; 0 and sa &lt; p1 then
			first:= 3;
			p1:= sa;
		endif;
		if ss &gt; 0 and ss &lt; p1 then
			first:= 4;
			p1:= ss;
		endif;
		if first = 1 then
			// Double quote: copy up to and including, then discard up to but not including match
			str:= str &amp; src[p:(p1-p+1)];
			p:= p1 + 1;
			if p &gt; sz then
				break;
			endif;
			dq:= src.pos('"', p);
			if dq &lt;= 0 then // No match
				break;
			endif;
			p:= dq + 1;
			str:= str &amp; '"';
		elseif first = 2 then
			// Single quote: copy up to and including, then discard up to but not including match
			str:= str &amp; src[p:(p1-p+1)];
			p:= p1 + 1;
			if p &gt; sz then
				break;
			endif;
			sq:= src.pos("'", p);
			if sq &lt;= 0 then // No match
				break;
			endif;
			p:= sq + 1;
			str:= str &amp; "'";
		elseif first = 3 then
			// Slash asterisk: copy up to but not including, then discard up to and including mate
			str:= str &amp; src[p:(p1-p)];
			p:= p1 + 2;
			if p &gt; sz then
				break;
			endif;
			sa:= src.pos("*/", p);
			if sa &lt;= 0 then // No match
				break;
			endif;
			p:= sa + 2;
		elseif first = 4 then
			// Slash slash: copy up to but not including, then discard up to but not including end of line
			str:= str &amp; src[p:(p1-p)];
			p:= p1 + 2;
			if p &gt; sz then
				break;
			endif;
			eol:= src.pos(Cr, p);
			if eol &lt;= 0 then // No end of line
				break;
			endif;
			p:= eol;
		else
			// No more: copy to end and exit
			str:= str &amp; src[p:end];
			break;
		endif;
		if p &gt; sz then
			break;
		endif;
	endwhile;
	return str;
end;</source>
        <Parameter name="pSource" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="findPossibleTransientLeaks" id="91eb7cea-1050-4fd8-9b7d-2208dac0075c">
        <source>findPossibleTransientLeaks(cls : Class; includeJadeScript, logErrorsOnly, pQuiet : Boolean);

/*

Purpose:			This method will scan through the meta schema data looking
					for methods which create transient instances of a given class,
					and also highlight if the instances do not appear to be being
					deleted.


Return Value:


Date		Who		Reason
22 Aug 2002	KPD		Initial creation
23 Aug 2002 conej1	Pass class to check as parameter
05 Dec 2002	KPD		Add code to handle iterators, and option to log errors only
18 Jul 2003	KPD		Extend code to try to detect creates nested inside loops
21 Jul 2003	KPD		Rewrite to iterate through tokens for performance
20 Jan 2004	cnwjub1	Allow to not write 'Checking class...' and 'Finished...' messages if there's no other output,
					depending on the parameter pQuiet.
					For a large method, add the local variable name to the 'skipping' message.
15 Sep 2004	KPD		Added io and output parameters to the usages that are checked
07 Jun 2005	cnwjub1	Add checks for method returning the created object - caller should delete.
14 Jun 2005	cnwjub1	Remove fluff from the source before processing it.
31 Aug 2005	cnwjub1	Sort the methods before reporting (schema, type, method, variable).
02 Sep 2008	cnwkpd1	"Borrowed" code from JSMS
08 Oct 2008	cnwkpd1	Added parameter to optionally include JadeScriptMethods
12 Mar 2010	cnwkpd1	Added check for JadeReportWriterReport
16 Mar 2015	cnwkpd1	Handle io and output parameters as "returning value"

*/

constants
	MaxTokens		: Integer = 4000;
	CheckReturn		: Boolean = true;
	SortRefs		: Boolean = true;

vars
	refs			: TypeUsageSet;
	ref				: TypeUsage;
	dd				: DynaDictionary;
	iter			: Iterator;
	msg,
	methodName,
	methodSource,
	varName			: String;
	script			: Script;
	tokensSize		: Integer;
	tokens			: HugeStringArray;
	testVarName,
	addToCollName,
	token,
	tokenMinus1,
	tokenPlus1,
	tokenPlus2,
	tokenPlus3,
	arrayToken		: String;
	checkWritten,
	doesCreate,
	doesReturn,
	doesDelete,
	doesDeleteInEpilog,
	doesAddToColl,
	doesPurgeColl,
	doesPurgeCollInEpilog,
	inEpilog		: Boolean;
	pos,
	pos1,
	currentLevel,
	createLevel,
	deleteLevel		: Integer;

begin
	if cls = null then
		return;
	endif;

	if not pQuiet then
		checkWritten:= true;
		write "Checking for local creates of class " &amp; cls.schema.name &amp; "::" &amp; cls.name;
	endif;

	// Get all the references to the named class
	refs := cls.getPropertyValue("scriptRefs").TypeUsageSet;

	if SortRefs then
		create dd transient;
		dd.setMembership(TypeUsage);
		dd.addMemberKey('schemaScript.schemaType.schema.name', false, false);
		dd.addMemberKey('schemaScript.schemaType.name', false, false);
		dd.addMemberKey('schemaScript.name', false, false);
		dd.addMemberKey('name', false, false);
		dd.endKeys(true);
		refs.copy(dd);
		iter:= dd.createIterator;
	else
		iter:= refs.createIterator;
	endif;

	// Look for all usages of this class as a local variable
	while iter.next(ref) do
		if ref.isKindOf(JadeLocalVar) or
				(ref.isKindOf(Parameter) and (ref.Parameter.usageDisplay = " io" or ref.Parameter.usageDisplay = " output")) then
			// Get details of local variable name and method source
			varName := ref.name;
			script := ref.schemaScript;
			
			if not includeJadeScript and script.schemaType.name = JadeScript.name then
				continue;
			endif;

			methodName := script.schemaType.schema.name &amp; "::" &amp; script.schemaType.name &amp; "::" &amp; script.name;

			methodSource := findPossibleTransLeaksRemFlf(script.getSource);
			methodSource.replaceChar(Cr, " ");
			methodSource.replaceChar(Lf, " ");

			// Break method source into tokens
			tokens := methodSource.getHugeTokens;
			tokensSize := tokens.size;
			
			// Skip any large methods
			if tokensSize &gt; MaxTokens then
				if not checkWritten then
					checkWritten:= true;
					write "Checking for local creates of class " &amp; cls.schema.name &amp; "::" &amp; cls.name;
				endif;
				write "     " &amp; methodName &amp; " - too big, skipping check for " &amp; ref.class.name &amp; " " &amp; varName;
				continue;
			endif;
			
			// Add 4 tokens at the end to ensure we process them all
			tokens.add(null);
			tokens.add(null);
			tokens.add(null);
			tokens.add(null);

			inEpilog := false;
			doesCreate := false;
			doesReturn := false;
			doesDelete := false;
			doesDeleteInEpilog := false;
			doesAddToColl := false;
			doesPurgeColl := false;
			doesPurgeCollInEpilog := false;
			currentLevel := 0;
			createLevel := 0;
			deleteLevel := 0;

			token := null;
			tokenMinus1 := null;
			tokenPlus1 := null;
			tokenPlus2 := null;
			tokenPlus3 := null;
			
			addToCollName := null;

			foreach arrayToken in tokens do
				tokenMinus1 := token;
				token := tokenPlus1;
				tokenPlus1 := tokenPlus2;
				tokenPlus2 := tokenPlus3;
				tokenPlus3 := arrayToken;
				
				if token = "while" or token = "foreach" then
					currentLevel := currentLevel + 1;
				elseif token = "endwhile" or token = "endforeach" then
					currentLevel := currentLevel - 1;
				elseif token = "epilog" then
					inEpilog := true;
				elseif token = "create" then
					if tokenPlus1 = varName and tokenPlus2 &lt;&gt; "persistent" and (cls.transient or tokenPlus2 = "transient") then
					// &gt;&gt;&gt;&gt;&gt; Note that this will not detect constructs like "create obj as &lt;class&gt;...".
//					if tokenPlus1 = varName and tokenPlus2 &lt;&gt; "transient" and (not cls.transient or tokenPlus2 = "persistent") then
						doesCreate := true;
						createLevel := currentLevel.max(createLevel);
					endif;
				elseif token = "delete" then
					if tokenPlus1 = varName then
						doesDelete := true;
						// Store highest indent level of any delete
						deleteLevel := currentLevel.max(deleteLevel);
						if inEpilog then
							doesDeleteInEpilog := true;
						endif;
					endif;
				elseif CheckReturn and token = "return" then
					if tokenPlus1 = varName then
						doesReturn:= true;
					endif;
				// Handle transients being added to a local collection which is then purged
				elseif token.pos(".add(", 1) &lt;&gt; 0 then
					pos := token.pos(".add(", 1) + 5;
					if token.length() &gt;= pos then
						testVarName := token[pos:end];
					else
						testVarName := tokenPlus1;
					endif;
					pos1 := 1;
					testVarName := testVarName.scanUntil(")", pos1);
					
					if testVarName = varName then
						doesAddToColl := true;
						pos := 1;
						addToCollName := token.scanUntil(".", pos);
					endif;
				elseif token = addToCollName &amp; ".purge" then
					doesPurgeColl := true;
					if inEpilog then
						doesPurgeCollInEpilog := true;
					endif;					
				// Handle cloneSelf(true)
				elseif token = varName and tokenPlus1 = "=" and tokenPlus2.pos("cloneSelf", 1) &lt;&gt; 0 and tokenPlus2.pos("true", 1) &lt;&gt; 0 then
					doesCreate := true;
					createLevel := currentLevel.max(createLevel);
				// Handle iterators specifically
				elseif token = varName and tokenPlus1 = "=" and tokenPlus2.pos("createIterator", 1) &lt;&gt; 0 then
					doesCreate := true;
					createLevel := currentLevel.max(createLevel);
				// Handle CM_Object proxy creation specifically
				elseif token = varName and tokenPlus1 = "=" and tokenPlus2.pos("pxyCreateUpdateProxy", 1) &lt;&gt; 0 then
					doesCreate := true;
					createLevel := currentLevel.max(createLevel);
				// Handle CM_Object proxy creation specifically
				elseif token = varName and tokenPlus1 = "=" and tokenPlus2.pos("app.createUpdateProxy", 1) &lt;&gt; 0 then
					doesCreate := true;
					createLevel := currentLevel.max(createLevel);
				// Special code for StringArrays returned by RootSchema getTokens method
				elseif token = varName and tokenPlus1 = "=" and tokenPlus2.pos("getTokens", 1) &lt;&gt; 0 then
					doesCreate := true;
					createLevel := currentLevel.max(createLevel);
				// Special code for JadeReportWriterReport returned by RootSchema getReport method
				elseif token = varName and tokenPlus1 = "=" and tokenPlus2.pos("getReport", 1) &lt;&gt; 0 then
					doesCreate := true;
					createLevel := currentLevel.max(createLevel);
				endif;
			endforeach;

			if doesCreate then
				msg := "     " &amp; methodName &amp; " - " &amp; ref.class.name &amp; " " &amp; varName &amp; " created";
				if not doesDelete then
					if CheckReturn and doesReturn or ref.isKindOf(Parameter) then
						msg := msg &amp; " and returned for caller to delete";
						msg[1:2] := "&gt;&gt;";
					elseif doesAddToColl then
						msg := msg &amp; " and added to collection " &amp; addToCollName;
						if not doesPurgeColl then
							msg := msg &amp; " which should be purged";
							msg[1:4] := "&gt;&gt;&gt;&gt;";
						else
							if doesPurgeCollInEpilog then
								msg := msg &amp; " which is purged in the epilog";
							else
								msg := msg &amp; " which should be purged in the epilog";
								msg[1:3] := "&gt;&gt;&gt;";
							endif;
						endif;
					else
						msg := msg &amp; " but not deleted";
						msg[1:4] := "&gt;&gt;&gt;&gt;";
					endif;
				elseif deleteLevel &lt; createLevel then
					msg := msg &amp; " in a loop, but deleted outside it";
					msg[1:4] := "&gt;&gt;&gt; ";
				else
					if doesDeleteInEpilog then
						msg := msg &amp; ", deleted in epilog";
					else
						msg := msg &amp; ", should be deleted in epilog";
						msg[1:2] := "&gt;&gt;";
					endif;
				endif;
				if msg[1] = "&gt;" or not logErrorsOnly then
					if not checkWritten then
						checkWritten:= true;
					 	write "Checking for local creates of class " &amp; cls.schema.name &amp; "::" &amp; cls.name;
					endif;
					write msg;
				endif;
			endif;

			delete tokens;

		endif;

	endwhile;

	if checkWritten then
		write "Finished checking class " &amp; cls.schema.name &amp; "::" &amp; cls.name;
	endif;

epilog
	delete iter;
	delete tokens;
	delete dd;
end;</source>
        <Parameter name="cls" type="Class"/>
        <Parameter name="includeJadeScript" type="Boolean"/>
        <Parameter name="logErrorsOnly" type="Boolean"/>
        <Parameter name="pQuiet" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findSingleClassInUse" id="f446d0f3-6184-4e1d-82cb-c3776b58f1ed">
        <source>findSingleClassInUse();

/*

Purpose:			Find the users who currently have a single class in use.
					Much quicker than using the dev environment Browse Classes In Use
					if you are only interested in one.

Parameters:			None

Return Value:		Output to interpreter window


Date		Who		Reason
28 May 2009	cnwkpd1	Initial creation

*/

constants
	SchemaName		= "GateSchema";
	ClassName 		= "GTE_FlexiGateForm";
	
vars
	scm				: Schema;
	cls				: Class;
	pos,
	len				: Integer;
	inuseString		: String;
	proc			: Process;
	invalidProcess	: Boolean;
	
begin
	scm := rootSchema.getSchema(SchemaName);
	if scm = null then
		write "Schema not found";
		return;
	endif;
	
	cls := scm.getClass(ClassName);
	if cls = null then
		write "Class not found";
		return;
	endif;
	
	write cls.name &amp; " (" &amp; cls.number.String &amp; ") in " &amp; scm.name;

	// Class method gets all inuse in &lt;proc oid&gt; comma delimted list
	cls._getAcquisitions(inuseString);
	
	pos := 1;
	len := inuseString.length();

	on Exception do app.handleDeletedObject(exception, proc, invalidProcess);
	
	while pos &lt; len do
		proc := inuseString.scanUntil(",", pos).asOid.Process;
		pos := pos + 1;
		
		write "  " &amp; proc.userCode &amp; " at " &amp; proc.node.name &amp; " (" &amp; proc.persistentApp.name &amp; " app)";
	endwhile;
	
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="findSuperMethodReferences" id="83d1c6dc-40e2-4129-b083-2a50e4637ced">
        <source>findSuperMethodReferences();

vars
	scm	: Schema;
	cls	: Class;
	meth	: Method;
	methSet : MethodSet;
begin
	scm := rootSchema.getSchema("PortSchema");
	cls := scm.getClass("CM_JRWCraneKPI");
	meth := cls.getMethod("noOutputReturned");
	write meth.qualifiedName;write " refs ";
	create methSet transient;
	meth.getSuperMethodReferences(methSet);
	foreach meth in methSet do
		write meth.qualifiedName;
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="findUpdateMethsCantAckWarnings" id="23e4105c-f605-416c-83ef-58913f4604df">
        <source>findUpdateMethsCantAckWarnings();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 July 2019	jlger1	Initial creation

*/

vars
	const : Constant;
	ps : Schema;
	fus : MethodSet;
	meth : Method;
	idx : Integer;
	 source : String;
	 startTrxPos,
	 startPos,
	 endPos : Integer;
	allBadMethods : DynaDictionary;
	iter : Iterator;
	type, 
	user,
	formName : String;
begin
	ps:=rootSchema.getSchema("UiCommonSchema");
	const :=ps.getGlobalConstant( "ErrWarnMode_CanAckWarnings");
	
	
	create allBadMethods transient;
	allBadMethods.setMembership(Method);
	allBadMethods.addExternalKey(String,30,false,false);
	allBadMethods.addExternalKey(String,30,false,false);//user
	allBadMethods.addExternalKey(String,30,false,false);
	allBadMethods.endKeys(true);
	
//write const;
	create fus transient;
	const.getMethodRefs(fus);
	//write fus.size;
	foreach meth in fus do
		if meth.getSchemaType = CMUI_ErrorWarningDialog then
			continue;
		endif;
		if meth.name = "doTransactionLoopCompleted" or
			meth.name  = "showTrxErrorDialog" then
			continue;
		endif;

		idx:=1;
		source:=meth.getSource();
		if not (source.pos("app.myTrxUA",1) &gt; 0 or source.pos("app.myTrxCA",1) &gt; 0 or source.pos("app.myTrxDA",1) &gt; 0) then
			continue;
		endif;
		
		if source.pos("while true do",1) = 0 and source.pos("while true  do",1) = 0 then
			idx:=1;	
			if source.pos("app.myPassport.setWarningsIgnored(true)",idx) = 0 then 
				allBadMethods.putAtKey( meth.getSchemaType.name,meth.getModifiedBy,"ErrWarnMode_CanAckWarnings",meth);
			endif;
			
			
		endif;
	endforeach;

	const :=ps.getGlobalConstant( "ErrWarnMode_AddUpdate");

	create fus transient;
	const.getMethodRefs(fus);

	foreach meth in fus do
		if meth.getSchemaType = CMUI_ErrorWarningDialog then
			continue;
		endif;
		idx:=1;
		source:=meth.getSource();
		startPos:=source.pos("ErrWarnMode_AddUpdate)",1);
		if  source.pos("ErrWarnMode_AddUpdate)",1) = 0 then
			continue;
		endif;

		startTrxPos:=source.pos("app.myTrxUA",1);
		if not startTrxPos &gt; 0 then
			startTrxPos:=source.pos("app.myTrxCA",1);
		endif;
		if not startTrxPos &gt; 0 then
			startTrxPos:=source.pos("app.myTrxDA",1) ;
		endif;
		
		if startTrxPos = 0 then
			continue;
		endif;
		
		startTrxPos:=startTrxPos ;
		if startTrxPos &lt; 0 then
			continue;
		endif;
		
		if source.pos("while true do",1) = 0 and source.pos("while true  do",1) = 0  then
			idx:=1;	
			if source.pos("app.myPassport.setWarningsIgnored(true)",idx) = 0 then 
				allBadMethods.putAtKey(meth.getSchemaType.name,meth.getModifiedBy,"ErrWarnMode_AddUpdate",meth);
				endPos:= meth.getSource.pos("endif",startPos);
			endif;
			
			
		endif;
	endforeach;
	

	const :=ps.getGlobalConstant( "ErrWarnMode_Add");

	create fus transient;
	const.getMethodRefs(fus);

	foreach meth in fus do
		if meth.getSchemaType = CMUI_ErrorWarningDialog then
			continue;
		endif;
		idx:=1;
		source:=meth.getSource();
		if  meth.getSource.pos("ErrWarnMode_Add)",1) = 0 then
			continue;
		endif;
		
		if not (source.pos("app.myTrxUA",1) &gt; 0 or source.pos("app.myTrxCA",1) &gt; 0 or source.pos("app.myTrxDA",1) &gt; 0) then
			continue;
		endif;
		
		if source.pos("while true do",1) = 0  and source.pos("while true  do",1) = 0 then
			idx:=1;	
			if source.pos("app.myPassport.setWarningsIgnored(true)",idx) = 0 then 
				allBadMethods.putAtKey(meth.getSchemaType.name,meth.getModifiedBy,"ErrWarnMode_Add",meth);
			endif;			
		endif;
	endforeach;

	const :=ps.getGlobalConstant( "ErrWarnMode_Update");
	create fus transient;
	const.getMethodRefs(fus);

	foreach meth in fus do
		if meth.getSchemaType = CMUI_ErrorWarningDialog then
			continue;
		endif;
		idx:=1;

		source:=meth.getSource();
		startPos:=meth.getSource.pos("ErrWarnMode_Update)",1);
		if  startPos = 0 then
			continue;
		endif;
		
		if not (source.pos("app.myTrxUA",1) &gt; 0 or source.pos("app.myTrxCA",1) &gt; 0 or source.pos("app.myTrxDA",1) &gt; 0) then
			continue;
		endif;
		
		if source.pos("while true do",1) = 0  and source.pos("while true  do",1) = 0 then
			idx:=1;	
			if source.pos("app.myPassport.setWarningsIgnored(true)",idx) = 0 then 
				allBadMethods.putAtKey(meth.getSchemaType.name,meth.getModifiedBy,"ErrWarnMode_Update",meth);

				endPos:= meth.getSource.pos("endif",startPos);
			endif;
	
		endif;

	endforeach;

	const :=ps.getGlobalConstant( "ErrWarnMode_Delete");
	create fus transient;
	const.getMethodRefs(fus);
	foreach meth in fus do
		if meth.getSchemaType = CMUI_ErrorWarningDialog then
			continue;
		endif;

		source:=meth.getSource();
		startPos:=meth.getSource.pos("ErrWarnMode_Delete)",1) ;
		if  startPos = 0 then
			continue;
		endif;
		
		if not (source.pos("app.myTrxUA",1) &gt; 0 or source.pos("app.myTrxCA",1) &gt; 0 or source.pos("app.myTrxDA",1) &gt; 0) then
			continue;
		endif;
		
		if source.pos("while true do",1) = 0 then

			if source.pos("app.myPassport.setWarningsIgnored(true)",1) = 0 then 
				allBadMethods.putAtKey(meth.getSchemaType.name, meth.getModifiedBy,"ErrWarnMode_Delete",meth);

			endif;	
			
		endif;
	endforeach;
	write "Found " &amp; allBadMethods.size.String &amp; " methods that need changing";
	iter:=allBadMethods.createIterator;
	while iter.next(meth) do
		allBadMethods.getIteratorKeys(formName,user,type,iter);
		
		write  meth.qualifiedName &amp; " " &amp; type &amp;  " " &amp; user;
	endwhile;
	
	
epilog
	delete fus;
	delete allBadMethods;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="fixMesKPI" id="bc38804b-fdba-4632-a529-607cef66bf56">
        <source>fixMesKPI();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 October 2017	jlgma1	Initial creation

*/

vars
	tit : CM_ReleaseShip;
	
	ti : CM_TrackedItem;
	
	vol : Decimal[16,4];
begin
vol := 100.0000;
	//tit := "2403.256395".asOid.CM_ReleaseShip;
	tit := "2403.256396".asOid.CM_ReleaseShip;
	
	beginTransaction;
	tit.setPropertyValue("totalVolume",vol);
	ti := tit.myTrackedItem;
	
	ti.setPropertyValue("totalVolume",vol);
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="fixupEDIDatatYpes" id="088ccf36-c3d0-41fd-b819-974c1b5d1b58">
        <source>fixupEDIDatatYpes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2023	jlirs1	Initial creation

*/

vars
	ediData : CM_EDIData;
begin
	foreach ediData in CM_EDIDataTransManifest.instances do
		if ediData.ediDataType = 0 then
			beginTransaction;
			ediData.setPropertyValue("ediDataType", EDIDataType_TransportManifest);
			commitTransaction;
		endif;
	endforeach;
	foreach ediData in CM_EDIDataGateDoc.instances do
		if ediData.ediDataType = 0 then
			beginTransaction;
			ediData.setPropertyValue("ediDataType", EDIDataType_GateDocument);
			commitTransaction;
		endif;
	endforeach;
	foreach ediData in CM_EDIDataShipManifest.instances do
		if ediData.ediDataType = 0 then
			beginTransaction;
			ediData.setPropertyValue("ediDataType", EDIDataType_ShipManifest);
			commitTransaction;
		endif;
	endforeach;
	foreach ediData in CM_EDIDataCargoOnSite.instances do
		if ediData.ediDataType = 0 then
			beginTransaction;
			ediData.setPropertyValue("ediDataType", EDIDataType_CargoOnSite);
			commitTransaction;
		endif;
	endforeach;
	foreach ediData in CM_EDIDataRequestMultiLine.instances do
		if ediData.ediDataType = 0 then
			beginTransaction;
			ediData.setPropertyValue("ediDataType", EDIDataType_RequestMultiLine);
			commitTransaction;
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="fsCheck" id="fc415737-656a-4ef1-865e-7185cb65efdc">
        <source>fsCheck();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 August 2017	jlgma1	Initial creation

*/

vars
	fa : CM_FutureStorageProcess;
	fs : CM_FutureStorage;
	ts : TimeStamp;
	date: Date;
	time :Time;
	fsDeleted,infoDeleted,invDeleted : Integer;
	ilDeleted : Integer;
	lFile        : File;
	ti : CM_TrackedItem;
	tit : CM_TITransaction;
	i : Integer;
	invLineSet : CM_ObjectSet;
	inv : CM_Invoice;
	count : Integer;
	id : String;
	site: String;
	cargotype : String;
begin
	date := "01/01/2000".Date;
	time := "00:00:00.000".Time;
	ts.setDate(date);
	ts.setTime(time);

	
	create lFile transient;
	lFile.fileName := "C:\TEMP\"&amp;"op1.csv";
	lFile.open;
	lFile.writeLine("Tracked Item" &amp;"," &amp; "InvoiceLines" &amp; "," &amp; "Location"&amp;"," &amp; "CArgoType"&amp;","&amp;"ChargeTime"&amp;"," &amp;"Created" );
	foreach fs in CM_FutureStorage.instances where  fs.chargeDateTime &lt; ts do
	id :=null;
	site := null;
	cargotype := null;
	if fs.myTrackedItem &lt;&gt; null then
		id := fs.myTrackedItem.id;
		site := fs.myTrackedItem.getStateDisplay;
		cargotype := fs.myTrackedItem.cargoTypeDescr;
	endif;
	lFile.writeLine(id &amp;"," &amp; fs.allInvoiceLines.size.String &amp; "," &amp; site&amp;"," &amp; cargotype &amp;"," &amp;fs.chargeDateTime.asStringJMT &amp;"," &amp; fs.createdTime.asStringJMT &amp;"," &amp;fs.getOidAsString.String);
	endforeach;

	lFile.close;
	delete lFile;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="gbClassList" id="cb7292ae-304a-4406-8ad2-3b9617f2a7b7">
        <source>gbClassList( aCls : Class );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2015	cnwgb1	Initial creation

*/

vars
    cls : Class;
    subs : ClassColl;
    subCls : Class;
    
begin
    create subs transient;
    if aCls &lt;&gt; null then
        cls := aCls;
    else
        cls := currentSchema.getClass( "CM_Transaction" );
    endif;
    if cls &lt;&gt; null then
        write cls.name;
        cls.getSubclasses(subs);
        if subs &lt;&gt; null then
            foreach subCls in subs do
                gbClassList(subCls);
            endforeach;
        endif;
    endif;
        
        

epilog
    delete subs;
end;</source>
        <Parameter name="aCls" type="Class"/>
    </JadeMethod>
    <JadeMethod name="gbClasses" id="18b14a84-3629-4b4d-8446-42b0e2d932be">
        <source>gbClasses();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2015	cnwgb1	Initial creation

*/

vars

begin
    self.gbClassList (null);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="gbEdiXlationTest" id="eb4d1445-ac41-4ca2-98b2-0af3e4d2ba7e">
        <source>gbEdiXlationTest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2012	cnwgb1	Initial creation

*/
vars
	operatorOid : CM_Operator;
    terminalOid : CM_Terminal;
    voyageOid : CM_Voyage;
	foreignCode : String;
	systemCode : String;
    protocol : CM_CamCODECODesc;
	foundMatch	:Boolean;
begin
	app.initialize;
    create protocol transient;
	app.writeStatement("");
	app.writeStatement("EDI XLATION TEST" );
	app.writeStatement("");
	terminalOid := app.myRoot.allTerminals["T01"];
    if terminalOid &lt;&gt; null then
        app.myPassport.setMyTerminal(terminalOid);
        operatorOid := app.myRoot.allOperators["ABC"];
        if operatorOid &lt;&gt; null then
			write ("With Vessel");
            write ("foreign code to system code (Any Direction):");
            foreignCode := "001N";
			systemCode := null;
            systemCode := operatorOid.getXlationSystemCode_VoyageEx(foreignCode, "GBGBBOAT", null, null, 0, foundMatch);
            write ("foreignCode=  "&amp;foreignCode&amp;" systemCode="&amp;systemCode&amp;" Found Match="&amp;foundMatch.asStringJMT);
            foreignCode := "001S";
			systemCode := null;
            systemCode := operatorOid.getXlationSystemCode_VoyageEx(foreignCode,"GBGBBOAT", null, null, 0, foundMatch);
            write ("foreignCode=  "&amp;foreignCode&amp;" systemCode="&amp;systemCode&amp;" Found Match="&amp;foundMatch.asStringJMT);
            write ("foreign code to system code (Outwards):");
            foreignCode := "001N";
			systemCode := null;
            systemCode := operatorOid.getXlationSystemCode_VoyageEx(foreignCode, "GBGBBOAT", null, null, 1, foundMatch);
            write ("foreignCode=  "&amp;foreignCode&amp;" systemCode="&amp;systemCode&amp;" Found Match="&amp;foundMatch.asStringJMT);
            foreignCode := "001S";
			systemCode := null;
            systemCode := operatorOid.getXlationSystemCode_VoyageEx(foreignCode, "GBGBBOAT", null, null, 1, foundMatch);
            write ("foreignCode=  "&amp;foreignCode&amp;" systemCode="&amp;systemCode&amp;" Found Match="&amp;foundMatch.asStringJMT);
            write ("foreign code to system code (Inwards):");
            foreignCode := "001N";
			systemCode := null;
            systemCode := operatorOid.getXlationSystemCode_VoyageEx(foreignCode, "GBGBBOAT", null, null, -1, foundMatch);
            write ("foreignCode=  "&amp;foreignCode&amp;" systemCode="&amp;systemCode&amp;" Found Match="&amp;foundMatch.asStringJMT);
            foreignCode := "001S";
			systemCode := null;
            systemCode := operatorOid.getXlationSystemCode_VoyageEx(foreignCode, "GBGBBOAT", null, null, -1, foundMatch);
            write ("foreignCode=  "&amp;foreignCode&amp;" systemCode="&amp;systemCode&amp;" Found Match="&amp;foundMatch.asStringJMT);
			write ("Without Vessel");
            write ("foreign code to system code (Any Direction):");
            foreignCode := "001N";
			systemCode := null;
            systemCode := operatorOid.getXlationSystemCode_VoyageEx(foreignCode, null, null, null, 0, foundMatch);
            write ("foreignCode=  "&amp;foreignCode&amp;" systemCode="&amp;systemCode&amp;" Found Match="&amp;foundMatch.asStringJMT);
            foreignCode := "001S";
			systemCode := null;
            systemCode := operatorOid.getXlationSystemCode_VoyageEx(foreignCode,null, null, null, 0, foundMatch);
            write ("foreignCode=  "&amp;foreignCode&amp;" systemCode="&amp;systemCode&amp;" Found Match="&amp;foundMatch.asStringJMT);
            write ("foreign code to system code (Outwards):");
            foreignCode := "001N";
			systemCode := null;
            systemCode := operatorOid.getXlationSystemCode_VoyageEx(foreignCode, null, null, null, 1, foundMatch);
            write ("foreignCode=  "&amp;foreignCode&amp;" systemCode="&amp;systemCode&amp;" Found Match="&amp;foundMatch.asStringJMT);
            foreignCode := "001S";
			systemCode := null;
            systemCode := operatorOid.getXlationSystemCode_VoyageEx(foreignCode, null, null, null, 1, foundMatch);
            write ("foreignCode=  "&amp;foreignCode&amp;" systemCode="&amp;systemCode&amp;" Found Match="&amp;foundMatch.asStringJMT);
            write ("foreign code to system code (Inwards):");
            foreignCode := "001N";
			systemCode := null;
            systemCode := operatorOid.getXlationSystemCode_VoyageEx(foreignCode, null, null, null, -1, foundMatch);
            write ("foreignCode=  "&amp;foreignCode&amp;" systemCode="&amp;systemCode&amp;" Found Match="&amp;foundMatch.asStringJMT);
            foreignCode := "001S";
			systemCode := null;
            systemCode := operatorOid.getXlationSystemCode_VoyageEx(foreignCode, null, null, null, -1, foundMatch);
            write ("foreignCode=  "&amp;foreignCode&amp;" systemCode="&amp;systemCode&amp;" Found Match="&amp;foundMatch.asStringJMT);
        endif;
        write ("system code to foreign code:");
        systemCode := "GBGBB001N";
        foreignCode := protocol.getXlatedForeignCode("ABC", systemCode, XLATION_TYPE_VOYAGETERMINAL, terminalOid);
        //app.writeStatement("systemCode=  "&amp;systemCode&amp;" foreignCode="&amp;foreignCode);
        write("systemCode=  "&amp;systemCode&amp;" foreignCode="&amp;foreignCode);
        systemCode := "GBGBB001S";
        foreignCode := protocol.getXlatedForeignCode("ABC", systemCode, XLATION_TYPE_VOYAGETERMINAL, terminalOid);
        write ("systemCode=  "&amp;systemCode&amp;" foreignCode="&amp;foreignCode);
        app.writeStatement("--------------- End ---------------");
    endif;
epilog
    delete protocol;
end;</source>
    </JadeMethod>
    <JadeMethod name="gbFilesTest" id="34774784-e321-4995-8695-b31f73137527">
        <source>gbFilesTest();
vars
	fileFolder,
	fileFolderDelete	: FileFolder;
	fileNode			: FileNode;
	path				: String;
	file				: File;
	msg 				: String;
    applySubFolders     : Boolean; //cnwgb1 TEMP Testing
begin
	create fileFolder transient;	
	create file transient;
    
    path := 'C:\DevelopmentEnvs';
	
	fileFolder.fileName := path;
    //fileFolder.mask := "*.BAT";
	
	if not fileFolder.isAvailable then
		write 'Unable to access file path ' &amp; path;
		return;
	endif;
	
	
	write 'Processing ' &amp; path;
	
	
	foreach fileNode in fileFolder.files do
        if fileNode.isKindOf(fileFolder.class) then
            msg := ' &lt;DIR&gt;';
        else
            msg := '';
        endif;
        write fileNode.name &amp; msg;
	endforeach;
epilog
	delete fileFolder;
	delete file;
end;</source>
    </JadeMethod>
    <JadeMethod name="generateCode" id="a28e464d-b702-4288-9d8f-f2447f05b0f0">
