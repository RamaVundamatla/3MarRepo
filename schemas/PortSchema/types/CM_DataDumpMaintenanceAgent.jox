    <JadeMethod name="xCM_Wagon" id="73817883-6614-4cd6-b7c5-9927226b7fa1">
        <updating/>
        <source>xCM_Wagon(_features : CMIF_ExternalDBFeatureSet input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2015	cnwrd1	Initial creation
02 Oct 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
*/


//25 Jun 2014	cnwrs1	Par 34470 New SQL native classes are missing edition 
vars
	xdbFeature  : CMIF_ExternalDBFeature;
begin
	
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Wagon::alternateID.name, "CM_Wagon", "alternateID", "CM_Wagon", _features); 

	
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Wagon::confirmed.name, "CM_Wagon", "confirmed", "CM_Wagon", _features); 
	
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Wagon::confirmedOutwards.name, "CM_Wagon", "confirmedOutwards", "CM_Wagon", _features); 
	
