    <JadeMethod name="setXMLForTerminalAreaLayout" id="53e534e1-2fb2-4bdb-814a-6f7d100f2c72">
        <updating/>
        <source>setXMLForTerminalAreaLayout(_theXMLString : String) updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
08 Oct 2008	cnwkpd1	PAR #18009 - Prevent transient leaks

*/

vars
	aPxyGraphic,aRealGraphic : CM_LayoutGraphic;
	theXMLTagValue : String;
	idx,pos,theColour,theX, theY : Integer;
	theLabel,thePoints : String;
	thePointsArray : PointArray;
	aPoint : Point;
	theXYStrings : StringArray;
begin
	beginTransaction;
	delete self.myLayoutGraphic;
	commitTransaction;

	create thePointsArray transient;
	pos := 1;
	while (pos &gt; 0) do
		theXMLTagValue := _theXMLString.cnEcGetNextTagValueOfName("GR",pos); 
		if theXMLTagValue = null then
			break;
		endif;
		theColour := _theXMLString.cnEcGetTagValueOfName("cl").Integer;
		theLabel := _theXMLString.cnEcGetTagValueOfName("lb");
		
		self.hideFromOverView :=  _theXMLString.cnEcGetTagValueOfName("hfo").Integer.Boolean;
		
		thePoints := _theXMLString.cnEcGetTagValueOfName("Points");

		thePoints.replaceString(",","|");
		delete theXYStrings;			// PAR #18009
		theXYStrings := thePoints.getTokens;
		
		theX := -99999;
		foreach idx in 1 to theXYStrings.size do
			if theX = -99999 then
				theX := theXYStrings[idx].Integer;
			else		
				theY := theXYStrings[idx].Integer;
			
				aPoint.set(theX, theY);
				thePointsArray.add(aPoint);
				theX := -99999;
			endif;	
		endforeach;
		

		create aPxyGraphic transient;
		aPxyGraphic.setProxy(0,0,null,theColour,0,0,0,thePointsArray,theLabel,null);
		app.myTrxCA.trxCreateLayoutGraphic(aPxyGraphic,aRealGraphic,app.myPassport);
		delete aPxyGraphic;

		beginTransaction;
		self.myLayoutGraphic := aRealGraphic;
		commitTransaction;
	endwhile;
	
epilog
	delete aPxyGraphic;
	delete thePointsArray;
	delete theXYStrings;		// PAR #18009
	
end;</source>
        <Parameter name="_theXMLString" type="String"/>
    </JadeMethod>
