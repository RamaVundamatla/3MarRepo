    <JadeMethod name="getTicketSequenceDescription" id="e2ed4de1-5eed-4811-8c8a-778004974582">
        <source>getTicketSequenceDescription() : String;
// -----------------------------------------------------------------------------
// Created:		28 June 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	first, last : String;
	retval : String;
	
begin
	if self.allTicketSequences.size &gt; 0 then
		first := self.allTicketSequences.first.fromId;
		last := self.allTicketSequences.last.toId;
		retval := first &amp; ' - ' &amp; last; 
	endif;
	return retval;
end;</source>
