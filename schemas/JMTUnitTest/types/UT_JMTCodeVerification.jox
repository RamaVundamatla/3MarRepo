/*

Purpose:		Checks called method(s) to see if ok	

Date			Who		Reason
28/06/2013		cnwmh5	Initial creation

*/

vars

	returnOK						: Boolean;

begin

	returnOK := true;
	
	


	return returnOK;

epilog

end;</source>
