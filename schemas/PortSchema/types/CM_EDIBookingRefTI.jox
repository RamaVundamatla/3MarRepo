    <JadeMethod name="setForUpdate" id="11b0ea5b-3624-40da-803b-336bc0bef446">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
//----------------------------------------------------------------
//	Created:	08 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*
JMH 28/9/09 MES1008 Add booking ref item fields so they can add items - will always be just one item per booking ref like it does now
28 May 2013	cnwrs1	Par 31596 add freight forwarder to EDI booking
02.10.2020 cnwma1 TFS #5011202 Oct 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
*/

vars
	bolType			: CM_BOLType;
begin
	inheritMethod(_proxyEDITI);
	
	self.carrierCode 		    := _proxyEDITI.carrierCode;
	self.cargoTypeDescr 		:= _proxyEDITI.cargoTypeDescr; //par 21239 cnwrs1 Oct 2009
	self.setCarbonDioxide( _proxyEDITI.getCarbonDioxide ); //par18932 cnwrs1 feb 2009
	self.commodity 				:= _proxyEDITI.commodity;
	self.commodityDescription	:= _proxyEDITI.commodityDescription;
	self.consignee 				:= _proxyEDITI.consignee;
	self.consignor 				:= _proxyEDITI.consignor;
	self.freightForwarder 		:= _proxyEDITI.freightForwarder;
	self.curtainsIn 			:= _proxyEDITI.curtainsIn;
	self.destinationPort 		:= _proxyEDITI.destinationPort;
	self.dischargePort 			:= _proxyEDITI.dischargePort;
	self.isoType 				:= _proxyEDITI.isoType;
	self.quantity 				:= _proxyEDITI.quantity;		// 03/03/2014 cnwar2 #33016
	self.productQuantity 		:= _proxyEDITI.productQuantity;	// 03/03/2014 cnwar2 #33016
	
	self.imCodes.clear;
	_proxyEDITI.imCodes.copy(self.imCodes);
	
	self.height := _proxyEDITI.height;
	self.setHumidity( _proxyEDITI.getHumidity );
	self.length := _proxyEDITI.length;
	self.setOxygen( _proxyEDITI.getOxygen );
	self.product := _proxyEDITI.product;
	self.width := _proxyEDITI.width;
	self.isStockBookingRef := _proxyEDITI.isStockBookingRef; //Anca- Nelson- CCMS 1638 28/05/2008
	self.bookingRemarks :=_proxyEDITI.bookingRemarks;//PAR 18174 to reflect the changes after saving
	self.vesselName :=_proxyEDITI.vesselName;//PAR 18174 to reflect the changes after saving
	self.customerRef :=_proxyEDITI.customerRef;//PAR 18174 to reflect the changes after saving
    self.marks :=_proxyEDITI.marks;//PAR 18174 to reflect the changes after saving
	self.releaseRequestNumber := _proxyEDITI.releaseRequestNumber;
	self.volume := _proxyEDITI.volume;
	self.weight := _proxyEDITI.weight;
	self.width := _proxyEDITI.width;
	self.length := _proxyEDITI.length;
	self.loadPort := _proxyEDITI.loadPort;
	self.number := _proxyEDITI.number;
	self.operatorCode := _proxyEDITI.operatorCode;
	self.remarks := _proxyEDITI.remarks;
	self.temperature := _proxyEDITI.temperature;
	self.vent := _proxyEDITI.vent;
	self.setRawVoyageCode( _proxyEDITI.getRawVoyageCode() );
	self.shippingRef := _proxyEDITI.shippingRef;
	self.groupCodeForEDIMultiItem	:= _proxyEDITI.groupCodeForEDIMultiItem;	//Par18495, Jan 2009
	self.ediFileIssueDateTime		:= _proxyEDITI.ediFileIssueDateTime;		//Par18495, Feb 2009
	
	// MES1008  JMH 28/9/09 Add all the book ref item fields needed
	self.density 					:= _proxyEDITI.density;
	self.markNumber 				:= _proxyEDITI.markNumber;
	self.isoTypeGroup 				:= _proxyEDITI.isoTypeGroup;
	self.productVolume 				:= _proxyEDITI.productVolume;
	self.productWeight 				:= _proxyEDITI.productWeight;
	self.generatorType				:= _proxyEDITI.generatorType;
	self.ventilationUnits			:= _proxyEDITI.ventilationUnits;
	self.stevedore                  := _proxyEDITI.stevedore;        //02.10.2020 cnwma1 TFS #50112
epilog

end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setHumidity" id="ad4bc335-2ea5-4cb6-b0ea-2e7fdfcb782f">
