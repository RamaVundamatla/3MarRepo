    <JadeMethod name="setupForRun" id="8a3b103a-ff63-427c-b9f1-06116173ca81">
        <updating/>
        <source>setupForRun(_prefix: String) updating, protected;
//18 December 2008	cnwdw1	
//
vars
	boatName, voyageName: String;	
begin
	
	voyageName := _prefix&amp;VOYAGE;
	self.logMessageNow("Run Simulation for Voyage: " &amp; voyageName);
	
	bs1 := self.getTerminalArea(BS1).CM_BlockStack;
	self.addYACatchAll(self.getProfileSetting(UT_Profile.P_YA).asString, bs1);

	bs2 := self.getTerminalArea(BS2).CM_BlockStack;

	dualGate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	pin := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_PIN).asString);
	pout := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_POUT).asString);
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	operator := getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	boatName := voyageName&amp;"V";
	deleteVoyage(voyageName);
	deleteVessel(boatName);
	vessel := addVesselLOLOholdsRORO(boatName, operator);
	
	voyage := self.getVoyage(_prefix&amp;VOYAGE);
	if voyage &lt;&gt; null then
		self.deleteVoyage(_prefix&amp;VOYAGE);
	endif;

	voyage := self.addVoyageWithConRORO(voyageName, boatName, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);

end;</source>
        <access>protected</access>
        <Parameter name="_prefix" type="String"/>
    </JadeMethod>
    <JadeMethod name="uClearAllUserDevices" id="f2354bbc-7158-43a0-9a5a-13afe28ecabb">
        <source>uClearAllUserDevices();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 June 2013	cnwmc5	Initial creation

*/

vars
	user : CM_User;
begin
	foreach user in app.myRoot.allUsers do
		if user.notificationPlatform &lt;&gt; null or user.notificationToken &lt;&gt; null then
			beginTransaction;
			user.setNotificationDetails(null, null);
			commitTransaction;
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
