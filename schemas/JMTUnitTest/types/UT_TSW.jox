	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realStopsTableInt, "Global Setup - realStopsTableInt");
	self.logMessage("Created Stops Table: Id:'" &amp; UT_IntStopId.String &amp; " Code: " &amp; UT_IntStopCode);
	
	delete pxyStopsTableTemplate;
	delete processAreasArr;
	delete setAreasArr;
