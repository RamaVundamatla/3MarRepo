	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Train::portArrivalDT.name, "CM_Train", "portArrivalDT", "CM_Train", _features); 
	
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Train::remarks.name, "CM_Train", "remarks", "CM_Train", _features); 
	
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Train::scheduleCode.name, "CM_Train", "scheduleCode", "CM_Train", _features); 
	
	create xdbFeature transient;
