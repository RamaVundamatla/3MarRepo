    <JadeMethod name="createProxy" id="ce327905-3c72-438a-82a3-5b6608f90224">
        <source>createProxy() : CM_DeliveryParty;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 January 2025	jlier1	Initial creation 33694

*/

vars

	proxyDeliveryParty,
	realDeliveryParty: CM_DeliveryParty;
	allTerminals : CM_TerminalSet;
	ediTrackedItem : CM_EDITrackedItem;
	proxyAddress : CM_Address;
	ediAddress  : CM_EDIAddressTI;
	addressToDelete : ObjectSet;
		completedOK : Boolean;			
begin
	
	if self.messageMode = self.EDI_ACTION_ADD then
		create proxyDeliveryParty transient;
	else
		realDeliveryParty:=app.myRoot.allDeliveryParties[self.code];
		if realDeliveryParty = null then
			return null;
		endif;
		proxyDeliveryParty:=realDeliveryParty.pxyCreateUpdateProxy.CM_DeliveryParty;
	endif;
		
	create allTerminals transient;
	self.getTerminals(allTerminals); 
	
	//proxy.setProxy(self.name,self.code,self.secondaryCode,self.getDriverStatusInteger,self.getMyTerminal,allCarriers,allVehicles);		// TFS 46854
	proxyDeliveryParty.setProxy(self.code,self.name,false,allTerminals);		// TFS 46854
	
	//proxy up all the addresses
	create addressToDelete transient;
	proxyDeliveryParty.allAddresses.copy(addressToDelete);
	foreach ediTrackedItem in self.myEDIData.allEDITrackedItems where ediTrackedItem.isKindOf(CM_EDIAddressTI) and ediTrackedItem.CM_EDIAddressTI.id = self.code do
		ediAddress:=ediTrackedItem.CM_EDIAddressTI;
		proxyAddress :=proxyDeliveryParty.allAddresses[ediAddress.code];
		if proxyAddress = null then
			create proxyAddress transient;
			proxyDeliveryParty.allAddresses.add(proxyAddress);
		else
			addressToDelete.remove(proxyAddress);
		endif;
		proxyAddress.setProxy(ediAddress.code,ediAddress.description,ediAddress.address1,ediAddress.address2,ediAddress.address3,ediAddress.region,ediAddress.postCode,ediAddress.countryCode,ediAddress.city,null,ediAddress.deliveryInstructions,ediAddress.isDefault,false,null);
	endforeach;
	
	addressToDelete.purge;
	
	completedOK:=true;
	return proxyDeliveryParty;
epilog
	delete allTerminals;
	delete addressToDelete;
	if not completedOK then
		delete proxyDeliveryParty;
	endif;
end;</source>
        <ReturnType type="CM_DeliveryParty"/>
    </JadeMethod>
    <JadeMethod name="getMyTIDisplayDefName" id="148102f1-4881-4259-8576-cbd898347c46">
