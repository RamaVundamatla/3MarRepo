    <JadeMethod name="notifyMachineOfNewTask" id="07a9a75d-732d-4514-96da-3fe6b3215a93">
        <source>notifyMachineOfNewTask(_queue : CM_RadioTelemetryQueue; _machine : CM_Machine; _entry : CM_RTQueueEntry) : Boolean protected;
// -------------------------------------------
// Created 24 January 2006 by cnwdvb1
// -------------------------------------------
/*

Date		Who		Reason
19 Dec 2008	cnwkpd1	PAR #18687 - Prevent error 4 exceptions when entry is invalid
24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars
	parentQueue : CM_RadioTelemetryQueue;
	mediator	: CM_RadioTelemetryMediator;
	task		: CM_RTQueueTask;
	aStr		: String;
	invalidEntry,
	invalidTask	: Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, _entry, invalidEntry);
	on Exception do app.handleDeletedObject(exception, task, invalidTask);

	// Check whether our machine is in the queues primary dict.
	if _queue.allPrimaryMachines.includes(_machine) or
		_queue.allMachines.includes(_machine) then
		
		mediator	:= self.myMediator;

		// Need an entry to go any further.
		if _entry &lt;&gt; null and not _entry.isMultiQueueEntry() then
			// Get first taskl
			task := _entry.getATaskGeneric(aStr, _machine);
			// Need a task to go any further.
			if task &lt;&gt; null then
				// As task of machine is appropriate.
				return task.queryMachineAssign(_machine, true,false,true,false,true,null);
			endif;
		endif;
		return false;
	endif;
	
	
	parentQueue := _queue.getMyParentQueue();
	
	if parentQueue &lt;&gt; null then
		// Call this method recursively on the parent.
		return self.notifyMachineOfNewTask(parentQueue, _machine, _entry);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_entry" type="CM_RTQueueEntry"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
