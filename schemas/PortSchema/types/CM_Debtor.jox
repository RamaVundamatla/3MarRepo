    <JadeMethod name="getAllOperators" id="c2f8d28e-5931-4db2-bc95-e8a1858b052e">
        <source>getAllOperators(_operDict : CM_OperatorByCodeDict input);
//--------------------------------------------------
// Created:	12 September 2003 By: cnwgd1
//--------------------------------------------------
vars
	oper : CM_Operator;
begin
	if _operDict = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _operDict passed ot method');
		return;	
	endif;

	foreach oper in self.operators do
		if (not _operDict.includesKey(oper.code)) then
			_operDict.add(oper);
		endif;
	endforeach;
end;</source>
        <Parameter name="_operDict" type="CM_OperatorByCodeDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAuditChildSubjects" id="f9364e0e-6cde-4101-a6d2-5843b6547ded">
        <source>getAuditChildSubjects(_childAuditSubjectNames: StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Nov 2025 navhl20 Story MTN-36358: Provide an audit trail for imported debtor email addresses showing before and after data

*/

vars
	addr : CM_Address;
begin
	inheritMethod(_childAuditSubjectNames);
	foreach addr in self.allAddressesByCode discreteLock do
		addr.getAuditChildSubjects(_childAuditSubjectNames);
	endforeach;
epilog

end;</source>
        <Parameter name="_childAuditSubjectNames" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="3705f31a-4031-4f91-8b43-f39aeacbd202">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Jun 2018	jlgrh7	Initial creation TFS39308 LNX - Include Debtor Maintenance in Audit Enquiry
22 Jul 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
13 may 2022	navtnr20 TFS 53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line
10 Nov 2025 navhl20 Story MTN-36358: Provide an audit trail for imported debtor email addresses showing before and after data
27 Nov 2025 navlc30 JIRA 36749 - LINX - Audits not getting created for the Debtor with Addressed created through EDI
*/

vars
	auditText,
	tmpStr			: String;
	address			: CM_Address;			
	debTerm         : CM_DebtorTerminal;
	carrier         : CM_Carrier;
	invLineTypeDeb  : CM_DebtorInvLineType;
	invTypeDeb 		: CM_DebtorInvType;
begin

	auditText[10000] 	:= '*';
	auditText 		:= null;
	auditText 		:= inheritMethod();
	
	tmpStr := null;
	tmpStr := self.decfinName;
	auditText := auditText &amp; "Account Code" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	
	
	tmpStr := self.hasReeferFlatRate.Boolean.String;
	auditText := auditText &amp; "Reefer Flat Rate" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	
	tmpStr := null;
	tmpStr := self.hasReeferDaily.String;
	auditText := auditText &amp; "Reefer Daily" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	
	tmpStr := null;
	tmpStr := self.getBillingAddressString;
	auditText := auditText &amp; "Address" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	
	//22.07.2019 cnwma1 TFS #45577
	tmpStr := null;
	if self.myParentDebtorNode &lt;&gt; null then
		tmpStr := self.myParentDebtorNode.name;
		auditText := auditText &amp; "Debtor Group" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myTermsOfTrade &lt;&gt; null then
		tmpStr := self.myTermsOfTrade.description;
		auditText := auditText &amp; "Terms" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.allAddressesByCode.isNotEmpty then
		foreach address in self.allAddressesByCode do
			tmpStr := tmpStr &amp; address.getAuditText();							//10.11.2025 navhl20 #36358
		endforeach;
		tmpStr := tmpStr.trimLeft;
		//auditText := tmpStr;													//10.11.2025 navhl20 #36358		//27.11.2025 navlc30 #36749
		auditText := auditText &amp; tmpStr;																		//27.11.2025 navlc30 #36749
	endif;
	
	tmpStr := null;
	if self.allDebtorTerminals.isNotEmpty then
		foreach debTerm in self.allDebtorTerminals do
			if not debTerm.isCashOnly then
				continue;
			endif;
			tmpStr :=tmpStr&amp; "Code:"&amp; debTerm.myTerminal.code &amp;" Is Cash Only:" &amp; debTerm.isCashOnly.getYesNo &amp; " PaymentType:" &amp; app.paymentTypeEnumToString(debTerm.paymentType) &amp; Cr ;
		endforeach;
		tmpStr := tmpStr.trimLeft;
		
		auditText:= auditText &amp;'Cash Only Configuration' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	tmpStr := self.hasBadCredit.getYesNo;
	auditText := auditText &amp; "Has Bad Credit" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	
	tmpStr := null;
	tmpStr := self.isPurchaseOrderMandatory.getYesNo;
	auditText := auditText &amp; "Is Purchase Order Mandatory" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	
	tmpStr := null;
	tmpStr := self.isZeroRatedTax.getYesNo;
	auditText := auditText &amp; "Zero Rated" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	
	tmpStr := null;
	tmpStr := self.isSuspended.getYesNo;
	auditText := auditText &amp; "Is Suspended" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	
	tmpStr := null;
	if self.allCarriers.isNotEmpty then
		foreach carrier in self.allCarriers do
			tmpStr :=tmpStr&amp; "Code:"&amp; carrier.code &amp;" Desc:" &amp; carrier.description  &amp; Cr ;
		endforeach;
		tmpStr := tmpStr.trimLeft;
		
		auditText:= auditText &amp;'Carriers' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.consignors.isNotEmpty then
		tmpStr := self.getConsignorsDesc();
		tmpStr := tmpStr.trimLeft;
		
		auditText:= auditText &amp;'Consignors' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.allCustomsAgents.isNotEmpty then	
		tmpStr := self.getCustomsAgentsDesc();
		auditText:= auditText &amp;'Custom Agents' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.allDebtorTypes.isNotEmpty then
		tmpStr := self.getDisplayFromDict(self.allDebtorTypes); 
		auditText:= auditText &amp;'Debtor Types' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.allStevedores.isNotEmpty then
		tmpStr := self.getDisplayFromDict(self.allStevedores); 
		
		auditText:= auditText &amp;'Stevedores' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;	
	//13-may-2022 navtnr20 TFS  53195 START
	if self.allShippingLines.isNotEmpty then
		tmpStr := self.getDisplayFromDict(self.allShippingLines); 
		
		auditText:= auditText &amp;'Shipping Lines' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	//13-MAY-2022 navtnr20 TFS 53195	END
	
	tmpStr := null;
	if self.operators.isNotEmpty then
		tmpStr := self.getOperatorsDesc();
		auditText:= auditText &amp;'Operators' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.allContacts.isNotEmpty then
			tmpStr := self.getDisplayFromDict(self.allContacts); 
		auditText:= auditText &amp;'Contacts' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	
	if self.allDebtorInvTypes.isNotEmpty then
		foreach invTypeDeb in self.allDebtorInvTypes do
			if invTypeDeb.myInvoiceType = null then              //19.04.2021 cnwma1 #51081
				continue;
			endif;
			if invTypeDeb.myInvoiceType.getBank() = null then   //19.04.2021 cnwma1 #51081
				continue;
			endif;
			tmpStr := tmpStr&amp; "BU:"&amp; invTypeDeb.myInvoiceType.getBank.code &amp;" ,Type:" &amp; invTypeDeb.myInvoiceType.description &amp; " ,Packages:" &amp; self.getPackagesDesc(invTypeDeb.allPackageInvoices) &amp; Cr ;
		endforeach;
	
		auditText:= auditText &amp;'Packages - Invoice Types' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	if self.allDebtorInvLineTypes.isNotEmpty then
		foreach invLineTypeDeb in self.allDebtorInvLineTypes do
			if invLineTypeDeb.myInvoiceLineType = null then
				continue;
			endif;
			tmpStr := tmpStr&amp; "BU:"&amp; invLineTypeDeb.myInvoiceLineType.getBank.code &amp;" ,Type:" &amp; invLineTypeDeb.myInvoiceLineType.narration &amp; " ,ExternalCode:" &amp; invLineTypeDeb.otherCode &amp; Cr ;
		endforeach;
	
		auditText:= auditText &amp;'Packages - Invoice Line Types' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	return auditText;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBillingAddressString" id="62a200c7-5499-470c-8219-b8d1ba04736f">
        <source>getBillingAddressString() : String;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars	
	str : String;
	addr : String;
begin
	foreach str in self.billingAddress do
		if addr = "" then
			addr := str;
		else
			addr := addr &amp; CrLf &amp; str;
		endif;
	endforeach;
	return addr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
