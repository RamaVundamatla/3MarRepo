    <JadeMethod name="checkExcel" id="9ab3edb0-5814-48be-af03-e4d132f063ae">
        <source>checkExcel() : Boolean;

/*****************************************************
	Written by	:	cnwpra1		16 July 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
