    <JadeMethod name="getLocationForVehicleMove" id="430854f7-51d5-4ebe-af09-2b4a7996f529">
        <source>getLocationForVehicleMove(_vehicle: CM_Vehicle): CM_YardController;
/*

Purpose:			

Parameters:			Has to be the interchange for a direct delivery to or from ship

Return Value:		

Date		Who		Reason
30 January 2013	cnwndl1	Initial creation	Par 31102

*/

vars

	slotRequest : CM_SlotRequest;
	theTIs: CM_TIArray;
	ti : CM_TrackedItem;
	job : CM_VoyageJob;
	lc : CM_LocationsController;

begin

	if _vehicle &lt;&gt; null then

		create theTIs transient;
	
		foreach slotRequest in self.allSlotRequestsLoad discreteLock do
			theTIs.clear();
			slotRequest.getAllUnworkedTIs( theTIs );
			foreach ti in theTIs where ti.directDelivery do
				if ti.myPrimaryActualLocation = _vehicle.locationsController then
					job := slotRequest.myJob.CM_VoyageJob;
					if job &lt;&gt; null and job.isLoadedToOperations then
						lc := job.getCraneTransAreaLC();
						if lc &lt;&gt; null then
							return lc.CM_YardController;
						endif;
					endif;
				endif;
			endforeach;
		endforeach;
		
		foreach slotRequest in self.allSlotRequestsDischarge discreteLock do
			theTIs.clear();
			slotRequest.getAllUnworkedTIs( theTIs );
			foreach ti in theTIs where ti.directDelivery do
				if ti.myPrimaryPlannedLocation = _vehicle.locationsController then
					job := slotRequest.myJob.CM_VoyageJob;
					if job &lt;&gt; null and job.isLoadedToOperations then
						lc := job.getCraneTransAreaLC();
						if lc &lt;&gt; null then
							return lc.CM_YardController;
						endif;
					endif;
				endif;
			endforeach;
		endforeach;
	
	endif;

	return inheritMethod(_vehicle);

epilog

	delete theTIs;

end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <ReturnType type="CM_YardController"/>
    </JadeMethod>
    <JadeMethod name="getLocationId" id="02c3c8ac-969a-412f-9d07-2e40acace1ec">
        <source>getLocationId(_mode : Integer; _ti : CM_TrackedItem) : String;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	str : String;
	stowId : String;

begin

	sharedLock(self.myVoyage);

	str := self.myVoyage.code.trimBlanks;
	str := str &amp; " " &amp; self.getStowageId(_ti);
	str := str.toUpper;

	return str;
epilog
	unlock(self.myVoyage);
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationSubArea" id="dfda4bed-fdfa-46dd-9a11-bd346bf10063">
        <source>getLocationSubArea(): String;
/*
Purpose:			
Date		Who		Reason
15 January 2015	cnwab1	Initial creation
*/

vars

begin
	return self.myBayVoyage.id &amp; " " &amp; tierId;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationsForSpan" id="2a642624-23fb-4953-845a-8eaf9d738a4a">
        <source>getLocationsForSpan(_vertSpan, _horzSpan, _depthSpan : Integer; _lcDict : CM_LCSet input);
/*
----------   ----------  --------------------------------------------------
Created:	22 November 2006 By cnwth2

Purpose:	return slots surrounding self that will need to be checked for 
			hazardous segregation rule violation
			
			vertical span = accross bays
			horizontal span = accross cells
			depth span = accross tiers - FOR SELF'S DECK ONLY (this may need to be smarter depending on requirments)

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
23 July 2015	NDL	Par 36568	- remove use of LC collection with 'myTerminalArea' as key, replace with LC Set
*/
vars
	segCond					: CM_SegregationCondition;
	bayVoyage				: CM_BayVoyage;
	cellularVoyStruct		: CM_CellularVoyageStructure;
	slotController			: CM_SlotController;
	
	ordinalBayIdx,
	ordinalCellIdx,
	ordinalTierIdx,
	
	probeDepthMin,
	probeHorzMin,
	probeVertMin,
	probeDepthMax,
	probeHorzMax,
	probeVertMax				: Integer;
	doLog						: Boolean;
begin
	
	cellularVoyStruct := self.myBayVoyage.myCellularVoyageStructure;
	
	//get probe perimeter values
	probeDepthMin	:= (self.ordinalTier - _depthSpan).max(1);
	if self.ordinalDeck = 2 then
		probeDepthMax	:= (self.ordinalTier + _depthSpan).min(self.myBayVoyage.allTiersOnDeck.size);
	else
		probeDepthMax	:= (self.ordinalTier + _depthSpan).min(self.myBayVoyage.allTiersUnderDeck.size);
	endif;
	
	probeHorzMin 	:= (self.ordinalCell - _horzSpan).max(1);
	probeHorzMax 	:= (self.ordinalCell + _horzSpan).min(self.myBayVoyage.getMaxCells(ShpDisplayMode_Defn)); // PAR 26760 - get all
	probeVertMin 	:= (self.myBayVoyage.ordinalBay - _vertSpan).max(1);
	probeVertMax 	:= (self.myBayVoyage.ordinalBay + _vertSpan);
	
	//doLog := app.myPassport.myActivityCapture.captureDiagnositcs;
	doLog := app.myPassport.myActivityCapture.captureDiagnositcs or app.isSpecial;	// 01/10/2010 cnwmh5 #25632
	if doLog then
		app.myPassport.myActivityCapture.logDiagnostic('GetLocationForSpan - from ' &amp; self.getFullId &amp; CrLf &amp;
													'probeHorzMin=' &amp; probeHorzMin.String &amp; ', probeHorzMax=' &amp; probeHorzMax.String &amp; CrLf &amp;
													'probeVertMin=' &amp; probeVertMin.String &amp; ', probeVertMax=' &amp; probeVertMax.String &amp; CrLf &amp; 
													'probeDepthMin=' &amp; probeDepthMin.String &amp; ', probeDepthMax=' &amp; probeDepthMax.String); 
	endif;
	foreach ordinalBayIdx in probeVertMin to probeVertMax do
		bayVoyage := cellularVoyStruct.allBayVoyagesByOrdinal[ordinalBayIdx];
		if bayVoyage = null then
			//break;
			continue;					// 01/10/2010 cnwmh5 #25632
		endif;
		
		foreach ordinalCellIdx in probeHorzMin to probeHorzMax do
			foreach ordinalTierIdx in probeDepthMin to probeDepthMax do
				slotController := bayVoyage.allSlotControllersByOrdinal[ordinalDeck,ordinalCellIdx,ordinalTierIdx];
				if slotController = null then
					continue;
				endif;
				if doLog then
					app.myPassport.myActivityCapture.logDiagnostic('Adding slotController for span :' &amp; slotController.getFullId());
				endif;
				
				if (not _lcDict.includes(slotController)) then
					_lcDict.add(slotController);
				endif;
			endforeach;
		endforeach;
	endforeach;

	
	
end;


</source>
        <Parameter name="_vertSpan" type="Integer"/>
        <Parameter name="_horzSpan" type="Integer"/>
        <Parameter name="_depthSpan" type="Integer"/>
        <Parameter name="_lcDict" type="CM_LCSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMachineRuleTerminalArea" id="4d8c5b84-2477-4d1f-a4ac-2f2e5dca0759">
        <source>getMachineRuleTerminalArea(): CM_TerminalArea;
// ---------------------------------------------------------------------------
// Created:     May 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	queueObj : CM_RadioTelemetryQueue;
	queueItem	: CM_RadioTelemetryQueue;
	term : CM_Terminal;
	job : CM_VoyageJob;
	crane : CM_Crane;
begin

	// Just incase there is a discharge and a load to this slot, we check the discharge first, and if its not complete, if its complete then check the load
	if self.mySlotRequestDischarge &lt;&gt; null then
		if not self.mySlotRequestDischarge.isComplete then
			crane := self.mySlotRequestDischarge.getCrane();
			if crane &lt;&gt; null then
				return crane.transferArea;
			endif;
		endif;
	endif;

	// if the load is here use that whatever the status
	if self.mySlotRequestLoad &lt;&gt; null then
		crane := self.mySlotRequestLoad.getCrane();
		if crane &lt;&gt; null then
			return crane.transferArea;
		endif;
	endif;

	// ### BELT AND BRACES
	if self.mySlotRequestDischarge &lt;&gt; null then
		crane := self.mySlotRequestDischarge.getCrane();
		if crane &lt;&gt; null then
			return crane.transferArea;
		endif;
	endif;

	return null;

epilog

end;</source>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
