							_newRTVehicleConfig : CM_RTVehicleConfig output;
							_allCriteria		: CMIF_Array;
							_terminal			: CM_Terminal ;
							_machineType 		: CM_MachineType;
							_machine 			: CM_Machine;
							_passport			: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 May 2010	cnwer1	Initial creation

*/

vars

begin
	self.initialiseActivity();
	
	create _newRTVehicleConfig persistent;
	_newRTVehicleConfig.setForCreate(_pxyRTVehicleConfig,_machine,_machineType,_terminal);
	
	//06 Mar 2015	NDL	Par 35816
