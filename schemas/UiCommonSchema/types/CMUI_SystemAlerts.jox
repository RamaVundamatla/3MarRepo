    <JadeMethod name="searchSelectAll" id="aef60cfe-ea9b-4503-8160-a39c0d1236de">
        <source>searchSelectAll() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2022	navvt20	53755
03 Aug 2022	navkc1	Bug 54416: CPL - System Alerts - Searcher - "Select All" option only selects all Alert Types that are visible
*/

vars

begin
	if self.lstAlertTypes.areAllRowsSelected(true) then
		self.lstAlertTypes.clearSelected;
		
		
	else
		//self.lstAlertTypes.selectAll(); 					//	03/08/2022	navkc1	#54416
		self.lstAlertTypes.setSelected(self.allAlertTypes); //	03/08/2022	navkc1	#54416
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="searcherShowHideControls" id="c87ddde2-6b75-43a8-a0e4-e131c3018021">
        <source>searcherShowHideControls(_hide : Boolean);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 November 2008	cnwjk3	PAR 18356
23 September 2016   cnwma1  TFS #2735 PAR #38253 C3 - System Alerts - Delete Button
*/

vars

begin
	self.btnPrint.enabled := _hide;
	
	if app.isSpecial() then
		self.btnExport.enabled := _hide;
	endif;
	
	self.btnShowSearcher.enabled := _hide;
	self.btnTerminal.enabled := _hide;
	self.btnSystem.enabled := _hide;
	self.btnAll.enabled := _hide;
	self.btnDisasters.enabled := _hide;
	self.btnErrors.enabled := _hide;
	self.btnWarnings.enabled := _hide;
	self.btnInfo.enabled := _hide;
	self.btnReefer.enabled := _hide;
	self.btnEditRemote.enabled := _hide;
	self.btnDelete.enabled := _hide;
	self.btnDeleteAll.enabled := _hide;
	self.btnRefresh.enabled := _hide;
	self.btnCancelBase.enabled := _hide;
	
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then  //26/09/2016  cnwma1  TFS #2735 PAR #38253 
		self.btnDelete.enabled := false;
		self.btnDeleteAll.enabled := false;
		self.btnEditRemote.enabled := false;
	endif;
end;</source>
        <Parameter name="_hide" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDisplaySystem" id="65efc515-324f-4460-ac50-22938ade69fc">
        <updating/>
        <source>setDisplaySystem() updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpTerminal	: CM_Terminal;
	isBoth		: Boolean;

begin

	self.displayType := 0;
	self.endNotificationForSubscriber(self);
	if self.btnTerminal.value then
		tmpTerminal := self.myTerminal;
		self.beginNotification(tmpTerminal, tmpTerminal.getTerminalEvent(EventTerminalAlertAdd), Response_Continuous, null);
		self.beginNotification(tmpTerminal, tmpTerminal.getTerminalEvent(EventTerminalAlertDelete), Response_Continuous, null);
		self.displayType := DISPLAY_TERMINAL;
		isBoth := true;
	endif;
	
	if self.btnSystem.value then
		self.beginNotification(app.myRoot, EventSystemAlertAdd, Response_Continuous, null);
		self.beginNotification(app.myRoot, EventSystemAlertDelete, Response_Continuous, null);
		if isBoth then
			self.displayType := DISPLAY_BOTH;
		else
			self.displayType := DISPLAY_SYSTEM;
		endif;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setQueryDefaults" id="277f0de0-ce52-447d-a124-98f96ef3209b">
        <updating/>
        <source>setQueryDefaults(_firstTime :Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     13 March 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 08/12/2010	cnwcs5	CCMS MES 1112/Par 24464 - filter by alert type
// 16/12/2010	cnwcs5	CCMS MES 1112/Par 24464 - set selected types from user window
vars
	table	:CM_EntryTable;
	coll	:CM_SystemAlertTypesByTypeDict;
begin
//	-----
//	DATE
//	-----
	table := self.tblQuery;
	
	self.queryDateTo 	:= app.actualTimeServer.date;
	self.queryDateFrom 	:= self.queryDateTo - 2;
	self.queryTimeTo 	:= '23:59:59'.Time;		// 26/09/2014 cnwar2 #33950
	self.queryTimeFrom 	:= NULL_TIME;			// 26/09/2014 cnwar2 #33950

	table.setValueByName(ETRow_DateFrom, self.queryDateFrom);
	table.setValueByName(ETRow_DateTo, self.queryDateTo);
	table.setValueByName(ETRow_TimeFrom, self.queryTimeFrom);	// 26/09/2014 cnwar2 #33950
	table.setValueByName(ETRow_TimeTo, self.queryTimeTo);		// 26/09/2014 cnwar2 #33950
//	-----------
//	ALERT TYPES
//	-----------
	coll := self.queryAlertTypes;
	
	if not _firstTime or coll.isEmpty then
		coll.clear;
		
		app.myRoot.allSystemAlertTypes.copy (coll);
	endif;
	
	self.lstAlertTypes.setSelected (coll);
	
	self.queryIncludeNullType := true;
end;</source>
        <Parameter name="_firstTime" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setQueryValues" id="57ef0569-ab1c-44fb-b213-e222bc401cea">
        <updating/>
        <source>setQueryValues() updating;
// ---------------------------------------------------------------------------
// Created:     13 March 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 08/12/2010	cnwcs5	CCMS MES 1112/Par 24464 - filter by alert type
vars
	table	:CM_EntryTable;
	coll	:CM_SystemAlertTypesByTypeDict;
begin
	table				:= self.tblQuery;
	
	self.queryDateTo 	:= table.getValueByName(ETRow_DateTo).Date;
	self.queryDateFrom 	:= table.getValueByName(ETRow_DateFrom).Date;
	self.queryTimeTo 	:= table.getValueByName(ETRow_TimeTo).Time;		// 26/09/2014 cnwar2 #33950
	self.queryTimeFrom 	:= table.getValueByName(ETRow_TimeFrom).Time;	// 26/09/2014 cnwar2 #33950

	coll := self.queryAlertTypes;
	coll.clear;
	self.lstAlertTypes.allSelectedObjects.copy (coll);
	
	if coll[EVENT_AT_General] &lt;&gt; null then
		self.queryIncludeNullType := true;
	else
		self.queryIncludeNullType := false;
	endif;
end;</source>
    </JadeMethod>
