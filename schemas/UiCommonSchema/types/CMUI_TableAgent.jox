    <JadeMethod name="formatMultiLines" id="8ed12865-3d9c-41e9-b980-aec533427ab0">
        <source>formatMultiLines();
// ---------------------------------------------------------------------------
// Created:		27 February 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	rows, cols, row, col, numLines : Integer;
	tmpText : String;
begin

	if self.myTable = null then
		return;
	endif;
	
	rows := self.myTable.rows;
	cols := self.myTable.columns;
	
	if rows &lt;1 or cols &lt; 1 then
		return;
	endif;
	
	foreach row in 1 to rows do : loopRow
		foreach col in 1 to cols do
			tmpText := self.myTable.accessCell(row,col).text;
	//		numLines := tmpText.getNumberOfACharacter(Cr);		// - dh par 14447
			numLines := tmpText.getNumberOfACharacter(Cr) + 1; // + dh par 14447 19 Nov 2007

			if numLines &gt; 1 then
				self.myTable.accessedCell.wordWrap := true;
				self.myTable.accessRow(row).height := 18 * numLines;
				continue loopRow;
			endif;
		endforeach;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="formatTable" id="a784a268-7a1b-4fbc-b603-c4900c36a382">
        <updating/>
        <source>formatTable() updating, protected;
// ---------------------------------------------------------------------------
// Created:      24 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	colWidth : Integer;
	column : Integer;

begin
	if self.useBigFont then
//		self.myTable.fontName := "Verdana";
		self.myTable.fontSize := 10;
	else
//		self.myTable.fontName := "Microsoft Sans Serif";
//		self.myTable.fontName := "Verdana";
		self.myTable.fontSize := 7;
	endif;
	
	self.myTable.columns := self.maxColumns;
	self.myTable.fixedColumns := 0;
	self.myTable.fixedRows := 0;
	
//	self.myTable.autoSize := Table.AutoSize_Column;
	self.myTable.autoSize := Table.AutoSize_Both;	//12 Aug 2015	NDL	Par 36658
	self.myTable.wordWrap := true;

	// Setup the table with columns all the same width.  Then
	// different 'widths' for columns is then specified by
	// merging columns.  This allows cells in the same column
	// to appear as if they have different widths.
//	colWidth := self.myTable.width div self.maxColumns;	
//	foreach column in 1 to self.myTable.columns do
//		self.myTable.columnWidth[column] := colWidth;
//	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="formatWarningCell" id="c2b2f1c4-3de1-402f-912b-bffea374b488">
        <source>formatWarningCell(cell : JadeTableCell input) protected;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
begin
	cell.backColor := Red;
	cell.foreColor := White;
	cell.alignment := Table.Alignment_Left_Top;
end;</source>
        <access>protected</access>
        <Parameter name="cell" type="JadeTableCell" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getNumberOfColsForBlock" id="d00d76a1-d491-4650-b293-b4693f644ed4">
        <source>getNumberOfColsForBlock(block : CM_DataContainerBlock) : Integer protected;
// ---------------------------------------------------------------------------
// Created:      04 July 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	item : CM_DataContainerItem;
	cols : Integer;

begin
	foreach item in block.allItems do
		cols := cols + self.getNumberOfColsToMerge(item);
	endforeach;		

	return cols;
end;</source>
        <access>protected</access>
        <Parameter name="block" type="CM_DataContainerBlock"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumberOfColsToMerge" id="9f8d3a60-9b8d-4f30-ad53-cbde74e9a8cd">
        <source>getNumberOfColsToMerge(item : CM_DataContainerItem) : Integer protected;
// ---------------------------------------------------------------------------
// Created:      04 July 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin
	if item.isData or item.isLabelHeader then
		// label header is the same width as the data b/c it
		// is the column header for that data
		return self.numberOfColumnsForData * item.getScaleFactor;

	elseif item.isHeader then
		return self.numberOfColumnsForHeader * item.getScaleFactor;

	elseif item.isIcon then
		return self.numberOfColumnsForIcon * item.getScaleFactor;
		
	elseif item.isLabel or item.isIconLabel or item.isMoreInfo then
		return self.numberOfColumnsForLabel * item.getScaleFactor;
		
	endif;

	return 1 * item.getScaleFactor;
end;</source>
        <access>protected</access>
        <Parameter name="item" type="CM_DataContainerItem"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="mergeColumns" id="9a383068-e06b-4780-8291-502bd47197e5">
        <source>mergeColumns(row, colsToMerge : Integer; column : Integer io) protected;
// ---------------------------------------------------------------------------
// Created:      25 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	nonMergeColumn : Integer;

begin
	if colsToMerge &lt;= 1 then
		return;
	endif;
	
	nonMergeColumn := column + colsToMerge;
	
	if nonMergeColumn &lt;= self.maxColumns then
		self.myTable.accessCell(row, nonMergeColumn).mergeCells := Table.MergeCells_NotAvailable;
	endif;
	
	self.myTable.accessCell(row, column).mergeCells := Table.MergeCells_Merge;
	
	column := nonMergeColumn - 1;
end;</source>
        <access>protected</access>
        <Parameter name="row" type="Integer"/>
        <Parameter name="colsToMerge" type="Integer"/>
        <Parameter name="column" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="mergeRemainingColumns" id="f3ea8cc7-939a-4b56-8b61-75cd0fa63beb">
        <source>mergeRemainingColumns(row, column : Integer io) protected;
// ---------------------------------------------------------------------------
// Created:      03 July 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin
	if column &gt; 1 and column &lt; self.maxColumns then
		self.mergeColumns(row, self.maxColumns, column);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="row" type="Integer" usage="io"/>
        <Parameter name="column" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="5692cd8b-8a6e-4f5a-bb13-045bc8ba6231">
        <updating/>
        <source>setForCreate(_data : CM_DataContainer;_table : CM_BaseTable;
		_maxColumns : Integer; _useBigFont : Boolean;
		_colsForData, _colsForHeader, _colsForIcon, _colsForLabel : Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:      24 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin
	self.myDataContainer := _data;
	self.myTable := _table;
	self.maxColumns := _maxColumns;
	self.useBigFont := _useBigFont;
	self.numberOfColumnsForData := _colsForData;
	self.numberOfColumnsForHeader := _colsForHeader;
	self.numberOfColumnsForIcon := _colsForIcon;
	self.numberOfColumnsForLabel := _colsForLabel;
end;</source>
        <access>protected</access>
        <Parameter name="_data" type="CM_DataContainer"/>
        <Parameter name="_table" type="CM_BaseTable"/>
        <Parameter name="_maxColumns" type="Integer"/>
