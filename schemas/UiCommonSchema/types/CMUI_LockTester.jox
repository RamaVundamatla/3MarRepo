    <JadeMethod name="doLockObject" id="2b7b4483-4952-44d5-adf4-f1e07a6d9901">
        <source>doLockObject(txtClass, txtOid : TextBox;
		cmbInstance : ComboBox;
		optExclusive : OptionButton;
		btnLock, btnUnlock : Button input;
		staLine : StatusLine input;
		lockedObjectOid : String io;
		lockKeeperStartTime : TimeStamp io) protected;

vars
	tmpOid,
	tmpClassName	: String;
	tmpClass		: Class;
	isLast			: Boolean;
	tmpLockType		: Integer;
	tmpLockObj		: Object;
	
begin

	tmpClassName := txtClass.text;
	tmpOid := txtOid.text;
	
	if tmpClassName &lt;&gt; null then	
		tmpClass := currentSchema.getClass(tmpClassName);
		if tmpClass = null then
			self.showError('Class ' &amp; tmpClassName &amp; ' not found.');
			return;
		endif;
		isLast := (cmbInstance.text = InstanceLast);
		
		if isLast then
			lockedObjectOid := tmpClass.lastInstance.getOidString;
		else
			lockedObjectOid := tmpClass.firstInstance.getOidString;
		endif;
		
	elseif tmpOid &lt;&gt; null then
		lockedObjectOid := tmpOid;
	
	else
		self.showError('You must enter a classs or an oid');
		return;
	endif;
	
	if lockedObjectOid = null then
		self.showError('The object to lock was not found');
		return;
	endif;
	
	tmpLockObj := self.getObjectForOid(lockedObjectOid);
	
	if optExclusive.value then
		tmpLockType := Exclusive_Lock;
	else
		tmpLockType := Share_Lock;
	endif;
	
	lockKeeperStartTime := app.actualTimeServer();
	app.lockKeeperNotifyStartActivity(lockKeeperStartTime, method, CM_Terminal.firstInstance, 'Lock Tester lock', app.myPassport);
	
	staLine.caption := 'Attempting to lock ' &amp; tmpLockObj.String;
	self.lock(tmpLockObj, tmpLockType, Session_Duration, 0);
	staLine.caption := 'Locked ' &amp; tmpLockObj.String;
	
	btnLock.enabled := false;
	btnUnlock.enabled := true;

end;</source>
        <access>protected</access>
        <Parameter name="txtClass" type="TextBox"/>
        <Parameter name="txtOid" type="TextBox"/>
        <Parameter name="cmbInstance" type="ComboBox"/>
        <Parameter name="optExclusive" type="OptionButton"/>
        <Parameter name="btnLock" type="Button" usage="input"/>
        <Parameter name="btnUnlock" type="Button" usage="input"/>
        <Parameter name="staLine" type="StatusLine" usage="input"/>
        <Parameter name="lockedObjectOid" type="String" usage="io"/>
        <Parameter name="lockKeeperStartTime" type="TimeStamp" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doUnlockObject" id="9c88fd4e-41eb-44cf-9182-8e6a6cd197fb">
        <source>doUnlockObject(myLockedObject : Object; lockKeeperStartTime : TimeStamp;
	staLine : StatusLine input;
	btnLock, btnUnlock : Button input;
	lockedObjectOid : String io) protected;

vars
	
begin

	if myLockedObject = null then
		self.showError('No object is currently locked');
		return;
	endif;
	
	self.unlock(myLockedObject);

	app.lockKeeperNotifyEndActivity(lockKeeperStartTime, true, app.myPassport);

	staLine.caption := 'Unlocked ' &amp; myLockedObject01.String;
	
	btnLock.enabled := true;
	btnUnlock.enabled := false;
	
	lockedObjectOid := null;

end;</source>
        <access>protected</access>
        <Parameter name="myLockedObject" type="Object"/>
        <Parameter name="lockKeeperStartTime" type="TimeStamp"/>
        <Parameter name="staLine" type="StatusLine" usage="input"/>
        <Parameter name="btnLock" type="Button" usage="input"/>
        <Parameter name="btnUnlock" type="Button" usage="input"/>
        <Parameter name="lockedObjectOid" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getObjectForOid" id="34620712-1074-42d9-9c73-bd33ed928178">
        <source>getObjectForOid(_oidStr : String) : Object protected;
// ---------------------------------------------------------------------------
// Created:     20 April 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if _oidStr = null then
		return null;
	else
		return _oidStr.asOid;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_oidStr" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="load" id="4ed80db3-2960-4ab3-b247-25696591ed5e">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

vars

begin

	on Exception do app.generalExceptionHandler(exception) global;

	self.setupForm();

end;</source>
    </JadeMethod>
    <JadeMethod name="myLockedObject01" id="3ab1c5d2-2b33-4888-8747-46f5ddcc2cdf">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>myLockedObject01(set: Boolean; _value: Object io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     13 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if set then
		app.msgBox('Cannot set this because of shared objects', 'Error', MsgBox_OK_Only);
		/*
		if _value = null then
			self.lockedObjectOid := null;
		else
			self.lockedObjectOid := _value.getOidString;
		endif;
		*/
	else
		if self.lockedObjectOid01 = null then
			_value := null;
		else
			_value := self.lockedObjectOid01.asOid;
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Object" usage="io"/>
    </JadeMethod>
