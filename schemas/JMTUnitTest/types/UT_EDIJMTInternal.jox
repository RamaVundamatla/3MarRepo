					&lt;vent&gt;-1.0000&lt;/vent&gt;
					&lt;weight&gt;21000.0000&lt;/weight&gt;
					&lt;carbonDioxide&gt;-1&lt;/carbonDioxide&gt;
					&lt;humidity&gt;-1&lt;/humidity&gt;
					&lt;oxygen&gt;-1&lt;/oxygen&gt;
					&lt;temperature&gt;-273&lt;/temperature&gt;
					&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
					&lt;commodity&gt;WINE&lt;/commodity&gt;
					&lt;commodityDescription&gt;GENL&lt;/commodityDescription&gt;
					&lt;destinationPort&gt;CNAKL&lt;/destinationPort&gt;
					&lt;dischargePort&gt;AUSYD&lt;/dischargePort&gt;
					&lt;ediTranshipPort&gt;CNAKL&lt;/ediTranshipPort&gt;
					&lt;fullOrMT&gt;F&lt;/fullOrMT&gt;
					&lt;id&gt;XNR60003312&lt;/id&gt;
					&lt;isoType&gt;2210&lt;/isoType&gt;
					&lt;loadPort&gt;AUMEL&lt;/loadPort&gt;
					&lt;locationId&gt;0010582&lt;/locationId&gt;
					&lt;messageMode&gt;D&lt;/messageMode&gt;
					&lt;operatorCode&gt;COS&lt;/operatorCode&gt;
				&lt;/BayPlan&gt;
			&lt;/AllBayPlan&gt;
		&lt;/DataBayPlan&gt;
	&lt;/AllDataBayPlan&gt;
&lt;/JMTInternalBayPlan&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	ediDataObj	:=	ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 6, "incorrect number of EDI trackedItems");
	
	
	self.ediMakeActualWithMerge(ediFileObj);
	tempStr	:= 'Make Actual failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_MADE_ACTUAL, tempStr);
	ti := self.getTrackedItem("PAR2839011");
	self.assertEqual(ti.getDischargePortDisplay.trimBlanks, "SGSIN, AUBRI, AUSYD,");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tBayPlanAction" id="9baa5328-e8cc-4051-81f7-4594c8ea0830">
        <source>tBayPlanAction();
//
//16 August 2017	jlgrs1	Initial creation
//
// 21 August 2018	jlgrs1	TFS40086 JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal
constants
	USER_DEF_NAME : String = "JMTInternalBayPlan";
	CONTAINERID1 : String = "SARG1234541";
	CONTAINERID2 : String = "SARG1234542";
	CONTAINERID3 : String = "SARG1234543";
	CONTAINERID4 : String = "SARG1234544";
	VOYAGECODE = 'VOY27418';
//	VOYAGECODETSHIP = 'VOY27418_2';
	VESSELNAME = 'SHIP27418';
//	VESSELNAMETSHIP = 'SHIP27418_2';
	OPERATORCODE = 'MSK';
	BookingId1 = 'BK27418';
//	TIID = 'MSKU27418';
//	BlockStackName	= 'BS26728';
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	voyageT : CM_Voyage;
	operator : CM_Operator;
	container : CM_Container;
	bs : CM_BlockStack;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	str : String;
	str2 : String;
begin
	passportObj := app.myPassport;
	operator := self.getOperator(OPERATORCODE);
	self.deleteVoyage(VOYAGECODE);
	voyage := self.getVoyage(VOYAGECODE);
	self.assertIsDeleted(voyage);
	self.deleteVessel(VESSELNAME);
	vessel := self.getVessel(VESSELNAME);
	self.assertIsDeleted(vessel);
	self.deleteContainer(CONTAINERID1);
	container := self.getTrackedItem(CONTAINERID1).CM_Container;
	self.assertIsDeleted(container);
	self.deleteContainer(CONTAINERID2);
	container := self.getTrackedItem(CONTAINERID2).CM_Container;
	self.assertIsDeleted(container);
	self.deleteContainer(CONTAINERID3);
	container := self.getTrackedItem(CONTAINERID3).CM_Container;
	self.assertIsDeleted(container);
	self.deleteContainer(CONTAINERID4);
	container := self.getTrackedItem(CONTAINERID4).CM_Container;
	self.assertIsDeleted(container);
	vessel := self.addVesselCellular(VESSELNAME,
										operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VOYAGECODE,
													VESSELNAME,
													OPERATORCODE,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalBayPlan xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalBayPlan.xsd"&gt;
	&lt;AllDataBayPlan&gt;
		&lt;DataBayPlan&gt;
			&lt;operatorCode/&gt;
			&lt;arriveTime/&gt;
			&lt;departTime/&gt;
			&lt;fromPort/&gt;
			&lt;shipperCode/&gt;
			&lt;toPort/&gt;
			&lt;vesselName&gt;'&amp;VESSELNAME&amp;'&lt;/vesselName&gt;
			&lt;voyageCode&gt;'&amp;VOYAGECODE&amp;'&lt;/voyageCode&gt;
			&lt;AllBayPlan&gt;
				&lt;BayPlan&gt;
					&lt;isCertifiedWeight/&gt;
					&lt;height/&gt;
					&lt;length/&gt;
					&lt;overHeight/&gt;
					&lt;overLengthBack/&gt;
					&lt;overLengthFront/&gt;
					&lt;overWidthLeft/&gt;
					&lt;overWidthRight/&gt;
					&lt;vent/&gt;
					&lt;weight/&gt;
					&lt;width/&gt;
					&lt;carbonDioxide/&gt;
					&lt;humidity/&gt;
					&lt;oxygen/&gt;
					&lt;temperature/&gt;
					&lt;bol/&gt;
					&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
					&lt;commodity/&gt;
					&lt;commodityDescription/&gt;
					&lt;description/&gt;
					&lt;destinationPort/&gt;
					&lt;dischargePort&gt;HKHKG&lt;/dischargePort&gt;
					&lt;ediTranshipPort/&gt;
					&lt;exportImport/&gt;
					&lt;fullOrMT/&gt;
					&lt;id&gt;'&amp;CONTAINERID1&amp;'&lt;/id&gt;
					&lt;isoType&gt;2210&lt;/isoType&gt;
					&lt;loadPort/&gt;
					&lt;locationId&gt;0010682&lt;/locationId&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
					&lt;operatorCode&gt;'&amp;OPERATORCODE&amp;'&lt;/operatorCode&gt;
					&lt;remarks/&gt;
					&lt;sealNum/&gt;
					&lt;transhipToPort/&gt;
					&lt;vgmAuthSignature/&gt;
					&lt;vgmCommsType/&gt;
					&lt;vgmDocumentDetails/&gt;
					&lt;vgmEDITranmission/&gt;
					&lt;vgmElectronicMail/&gt;
					&lt;vgmMail/&gt;
					&lt;vgmPhone/&gt;
					&lt;vgmTelefax/&gt;
					&lt;vgmTelephone/&gt;
					&lt;weightCertifiedName/&gt;
					&lt;weightCertifiedReference/&gt;
					&lt;vgmDeterminationDT/&gt;
					&lt;vgmDocsIssuedDT/&gt;
					&lt;dischargePorts&gt;NZAKL NZWLG AUSYD&lt;/dischargePorts&gt;
				&lt;/BayPlan&gt;
			&lt;/AllBayPlan&gt;
		&lt;/DataBayPlan&gt;
	&lt;/AllDataBayPlan&gt;
&lt;/JMTInternalBayPlan&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	
	self.ediMakeActualWithMerge(ediFileObj);
	errorMsg	:= 'Make Actual failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_MADE_ACTUAL, errorMsg);
	container := self.getTrackedItem(CONTAINERID1).CM_Container;
	self.assertNotNull(container);
	self.assertEqualMsg(container.dischargePort, "HKHKG", "wrong remarks");
	foreach str in ediDataObj.allEDITrackedItems.first.CM_EDIBayPlanTI.dischargePorts do
		str2 := str2&amp;str&amp;' ';
	endforeach;
	self.assertEqualMsg(str2, "NZAKL NZWLG AUSYD ", "incorrect discharge ports");
	container := self.getTrackedItem(CONTAINERID1).CM_Container;
	str2 := container.getDischargePortDisplay;

	self.assertEqualMsg(str2, "NZAKL, NZWLG, AUSYD, ", "incorrect discharge ports");
end;
</source>
    </JadeMethod>
    <JadeMethod name="tBillOfLadingAction" id="f1e27fb4-8145-4f1d-9691-23143a3ec3e3">
        <source>tBillOfLadingAction();
//
//28 July 2017	jlgrs1	Initial creation
//
//06 August 2018	jlgrs1	TFS 40086 JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal
// 10 Sep 2019	cnwrs1	TFS 46030
//
constants
	VoyageName = 'VOY002BOL';
	ShipName = 'Ship001';
	TestOperator = 'MSK';
	USER_DEF_NAME : String = "JMTInternalBOL";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	bol : CM_BOL;
	voyage : CM_Voyage;
	vessel : CM_Vessel;
	str : String;
	str2 : String;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(ShipName);
	vessel := self.getVessel(ShipName);
	self.assertIsDeleted(vessel);
	
	// now set up cleanly
	vessel := self.addVesselCellular(ShipName, self.getOperator(TestOperator));
	self.assertNotNullMsg(vessel, 'Add vessel failed');

	voyage	:= self.addVoyageWithContainerStructur(VoyageName,
													ShipName,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNullMsg( voyage, 'Add voyage failed' );
	voyage := self.getVoyage(VoyageName);
	self.assertNotNull(voyage);
	// turn off CertifiedWeightNeedsVGM
	self.setTerminalConfig(CertifiedWeightNeedsVGM, false);
	passportObj	:=	app.myPassport;
	ediText :=
'
&lt;?xml version="1.0"?&gt;
&lt;JMTInternalBillOfLading&gt;
	&lt;AllDataBillOfLading&gt;
		&lt;DataBillOfLading&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;action&gt;U&lt;/action&gt;
			&lt;billOfLading&gt;BOL122&lt;/billOfLading&gt;
			&lt;portCode&gt;NZPOE&lt;/portCode&gt;
			&lt;quantityOnBill&gt;5&lt;/quantityOnBill&gt;
			&lt;transportMode&gt;SHIP&lt;/transportMode&gt;
			&lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
			&lt;AllUSCustomsManifestInformation&gt;
				&lt;USCustomsManifestInformation&gt;
					&lt;quantityOnCargo&gt;12&lt;/quantityOnCargo&gt;
					&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
					&lt;description&gt;This is the description&lt;/description&gt;
					&lt;fullOrMT&gt;F&lt;/fullOrMT&gt;
					&lt;id&gt;BOL122&lt;/id&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
					&lt;marks&gt;Details remarks 01&lt;/marks&gt;
					&lt;remarksArray&gt;Remarks1;remarks2;remarks 3&lt;/remarksArray&gt;
				&lt;/USCustomsManifestInformation&gt;
			&lt;/AllUSCustomsManifestInformation&gt;
		&lt;/DataBillOfLading&gt;
	&lt;/AllDataBillOfLading&gt;
&lt;/JMTInternalBillOfLading&gt;
';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);

	foreach str in ediFileObj.ediData.allEDITrackedItems.first.CM_EDIBillOfLadingTI.remarksArray do
		str2 := str2&amp;str&amp;' ';
	endforeach;
	self.assertEqualMsg(str2, "Remarks1 remarks2 remarks 3 ", "incorrect remarks");
	
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tBooking" id="64b587e6-3859-40fa-a5ab-8d06732566e3">
        <source>tBooking();
//
// 27 Aug 2014	cnwrs1	Par 34702 - Add support for JMT XML
// 10 Sep 2019	cnwrs1	TFS 46030
//
constants
	USER_DEF_NAME : String = "JMTInternalBooking";
	VESSEL_CODE	: String = "UTXVES1";
	VOYAGE_CODE	: String = "UTXVOY1";
	CONTAINER_ID01 : String = "TEST0000001";
	CONTAINER_ID02 : String = "TEST0000002";
	CONTAINER_ID03 : String = "TEST0000003";
	BOOKING002 : String = "GB100002";
	BOOKING004 : String = "GB100004";
vars
	containerObj : CM_TrackedItem;
	vesselObj : CM_Vessel;
	voyageObj : CM_Voyage;
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	bookingRef : CM_BookingRef;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	passportObj	:=	app.myPassport;
	self.deleteContainer(CONTAINER_ID01);
	containerObj := self.getTrackedItem(CONTAINER_ID01);
	self.assertIsDeleted(containerObj);
	self.deleteContainer(CONTAINER_ID02);
	containerObj := self.getTrackedItem(CONTAINER_ID02);
	self.assertIsDeleted(containerObj);
	self.deleteContainer(CONTAINER_ID03);
	containerObj := self.getTrackedItem(CONTAINER_ID03);
	self.assertIsDeleted(containerObj);
	self.deleteBooking(BOOKING002);
	bookingRef := self.getBooking(BOOKING002);
	self.assertIsDeleted(bookingRef);
	self.deleteBooking(BOOKING004);
	bookingRef := self.getBooking(BOOKING004);
	self.assertIsDeleted(bookingRef);

	// Create the Vessel and the Voyage.
	self.deleteVessel(VESSEL_CODE);
	vesselObj	:=	self.getVessel(VESSEL_CODE);
	self.assertIsDeleted(vesselObj);
	self.deleteVoyage(VOYAGE_CODE);
	voyageObj	:=	self.getVoyage(VOYAGE_CODE);
	self.assertIsDeleted(voyageObj);
	self.createVoyageVessel(VOYAGE_CODE, VESSEL_CODE, voyageObj, vesselObj);
	self.assertNotNullMsg(vesselObj, "Add vessel failed!");
	ediText :=
'
&lt;?xml version="1.0"?&gt;
&lt;JMTInternalBooking&gt;
	&lt;AllBookingHeader&gt;
		&lt;BookingHeader&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;consignor&gt;UTCOE&lt;/consignor&gt;
			&lt;destinationPort&gt;SAJED&lt;/destinationPort&gt;
			&lt;dischargePort&gt;NZBLU&lt;/dischargePort&gt;
			&lt;id&gt;'&amp;BOOKING002&amp;'&lt;/id&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;vesselName&gt;'&amp;VESSEL_CODE&amp;'&lt;/vesselName&gt;
			&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
				&lt;AllBookingItem&gt;
					&lt;BookingItem&gt;
						&lt;weight&gt;18830.0000&lt;/weight&gt;
						&lt;number&gt;1&lt;/number&gt;
						&lt;temperature&gt;-20&lt;/temperature&gt;
						&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
						&lt;commodity&gt;FZVG&lt;/commodity&gt;
						&lt;commodityDescription&gt;FROZEN VEGETABLES&lt;/commodityDescription&gt;
						&lt;fullOrMT&gt;F&lt;/fullOrMT&gt;
						&lt;id&gt;'&amp;BOOKING002&amp;'&lt;/id&gt;
						&lt;isoType&gt;22R1&lt;/isoType&gt;
						&lt;messageMode&gt;D&lt;/messageMode&gt;
					&lt;/BookingItem&gt;
					&lt;BookingItem&gt;
						&lt;weight&gt;25840.0000&lt;/weight&gt;
						&lt;number&gt;1&lt;/number&gt;
						&lt;temperature&gt;-20&lt;/temperature&gt;
						&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
						&lt;commodity&gt;FZVG&lt;/commodity&gt;
						&lt;commodityDescription&gt;FROZEN VEGETABLES&lt;/commodityDescription&gt;
						&lt;fullOrMT&gt;F&lt;/fullOrMT&gt;
						&lt;id&gt;'&amp;BOOKING002&amp;'&lt;/id&gt;
						&lt;isoType&gt;45R1&lt;/isoType&gt;
						&lt;messageMode&gt;D&lt;/messageMode&gt;
					&lt;/BookingItem&gt;
				&lt;/AllBookingItem&gt;
			&lt;/BookingHeader&gt;
			&lt;BookingHeader&gt;
				&lt;AllBookingItem&gt;
					&lt;BookingItem&gt;
						&lt;weight&gt;18830.0000&lt;/weight&gt;
						&lt;number&gt;1&lt;/number&gt;
						&lt;temperature&gt;-20&lt;/temperature&gt;
						&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
						&lt;commodity&gt;FZVG&lt;/commodity&gt;
						&lt;commodityDescription&gt;FROZEN VEGETABLES&lt;/commodityDescription&gt;
						&lt;fullOrMT&gt;F&lt;/fullOrMT&gt;
						&lt;id&gt;'&amp;BOOKING004&amp;'&lt;/id&gt;
						&lt;isoType&gt;22R1&lt;/isoType&gt;
						&lt;messageMode&gt;D&lt;/messageMode&gt;
					&lt;/BookingItem&gt;
					&lt;BookingItem&gt;
						&lt;weight&gt;25840.0000&lt;/weight&gt;
						&lt;number&gt;1&lt;/number&gt;
						&lt;temperature&gt;-20&lt;/temperature&gt;
						&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
						&lt;commodity&gt;FZVG&lt;/commodity&gt;
						&lt;commodityDescription&gt;FROZEN VEGETABLES&lt;/commodityDescription&gt;
						&lt;fullOrMT&gt;F&lt;/fullOrMT&gt;
						&lt;id&gt;'&amp;BOOKING004&amp;'&lt;/id&gt;
						&lt;isoType&gt;45R1&lt;/isoType&gt;
						&lt;messageMode&gt;D&lt;/messageMode&gt;
					&lt;/BookingItem&gt;
				&lt;/AllBookingItem&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;consignor&gt;UTCOE&lt;/consignor&gt;
			&lt;destinationPort&gt;SAJED&lt;/destinationPort&gt;
			&lt;dischargePort&gt;NZBLU&lt;/dischargePort&gt;
			&lt;id&gt;'&amp;BOOKING004&amp;'&lt;/id&gt;
			&lt;messageMode&gt;U&lt;/messageMode&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;vesselName&gt;'&amp;VESSEL_CODE&amp;'&lt;/vesselName&gt;
			&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
		&lt;/BookingHeader&gt;
	&lt;/AllBookingHeader&gt;
&lt;/JMTInternalBooking&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write method.name&amp;" EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 6, "incorrect number of EDI trackedItems");
	bookingRef := self.getBooking(BOOKING002);
	self.assertNotNull(bookingRef);
	self.assertEqualMsg(bookingRef.allBookingRefItems.size, 2, "");
	bookingRef := self.getBooking(BOOKING002);
	self.assertNotNull(bookingRef);
	self.assertEqualMsg(bookingRef.allBookingRefItems.size, 2, "");

	ediText :=
'
&lt;?xml version="1.0"?&gt;
&lt;JMTInternalBooking&gt;
	&lt;AllBookingHeader&gt;
		&lt;BookingHeader&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;consignor&gt;UTCOE&lt;/consignor&gt;
			&lt;destinationPort&gt;SAJED&lt;/destinationPort&gt;
			&lt;dischargePort&gt;NZBLU&lt;/dischargePort&gt;
			&lt;id&gt;'&amp;BOOKING002&amp;'&lt;/id&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;vesselName&gt;'&amp;VESSEL_CODE&amp;'&lt;/vesselName&gt;
			&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
				&lt;AllBookingItem&gt;
					&lt;BookingItem&gt;
						&lt;weight&gt;18830.0000&lt;/weight&gt;
						&lt;number&gt;10&lt;/number&gt;
						&lt;temperature&gt;-20&lt;/temperature&gt;
						&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
						&lt;commodity&gt;FZVG&lt;/commodity&gt;
						&lt;commodityDescription&gt;FROZEN VEGETABLES&lt;/commodityDescription&gt;
						&lt;fullOrMT&gt;F&lt;/fullOrMT&gt;
						&lt;id&gt;'&amp;BOOKING002&amp;'&lt;/id&gt;
						&lt;isoType&gt;22R1&lt;/isoType&gt;
						&lt;messageMode&gt;D&lt;/messageMode&gt;
					&lt;/BookingItem&gt;
					&lt;BookingItem&gt;
						&lt;weight&gt;25840.0000&lt;/weight&gt;
						&lt;number&gt;1&lt;/number&gt;
						&lt;temperature&gt;-21&lt;/temperature&gt;
						&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
						&lt;commodity&gt;FZBF&lt;/commodity&gt;
						&lt;commodityDescription&gt;FROZEN VEGETABLES&lt;/commodityDescription&gt;
						&lt;fullOrMT&gt;F&lt;/fullOrMT&gt;
						&lt;id&gt;'&amp;BOOKING002&amp;'&lt;/id&gt;
						&lt;isoType&gt;45R1&lt;/isoType&gt;
						&lt;messageMode&gt;D&lt;/messageMode&gt;
					&lt;/BookingItem&gt;
				&lt;/AllBookingItem&gt;
			&lt;/BookingHeader&gt;
			&lt;BookingHeader&gt;
				&lt;AllBookingItem&gt;
					&lt;BookingItem&gt;
						&lt;weight&gt;18830.0000&lt;/weight&gt;
						&lt;number&gt;1&lt;/number&gt;
						&lt;temperature&gt;-19&lt;/temperature&gt;
						&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
						&lt;commodity&gt;FZMT&lt;/commodity&gt;
						&lt;commodityDescription&gt;FROZEN VEGETABLES&lt;/commodityDescription&gt;
						&lt;fullOrMT&gt;F&lt;/fullOrMT&gt;
						&lt;id&gt;'&amp;BOOKING004&amp;'&lt;/id&gt;
						&lt;isoType&gt;22R1&lt;/isoType&gt;
						&lt;messageMode&gt;A&lt;/messageMode&gt;
					&lt;/BookingItem&gt;
					&lt;BookingItem&gt;
						&lt;weight&gt;25840.0000&lt;/weight&gt;
						&lt;number&gt;1&lt;/number&gt;
						&lt;temperature&gt;-20&lt;/temperature&gt;
						&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
						&lt;commodity&gt;FZVG&lt;/commodity&gt;
						&lt;commodityDescription&gt;FROZEN VEGETABLES&lt;/commodityDescription&gt;
						&lt;fullOrMT&gt;F&lt;/fullOrMT&gt;
						&lt;id&gt;'&amp;BOOKING004&amp;'&lt;/id&gt;
						&lt;isoType&gt;45R1&lt;/isoType&gt;
						&lt;messageMode&gt;A&lt;/messageMode&gt;
					&lt;/BookingItem&gt;
				&lt;/AllBookingItem&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;consignor&gt;UTCOE&lt;/consignor&gt;
			&lt;destinationPort&gt;SAJED&lt;/destinationPort&gt;
			&lt;dischargePort&gt;NZBLU&lt;/dischargePort&gt;
			&lt;id&gt;'&amp;BOOKING004&amp;'&lt;/id&gt;
			&lt;messageMode&gt;D&lt;/messageMode&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;vesselName&gt;'&amp;VESSEL_CODE&amp;'&lt;/vesselName&gt;
			&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
		&lt;/BookingHeader&gt;
	&lt;/AllBookingHeader&gt;
&lt;/JMTInternalBooking&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	ediDataObj	:=	ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write method.name&amp;" EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 6, "incorrect number of EDI trackedItems");
	bookingRef := self.getBooking(BOOKING002);
	self.assertNotNull(bookingRef);
	self.assertEqualMsg(bookingRef.allBookingRefItems.size, 2, "");
	bookingRef := self.getBooking(BOOKING004);
	self.assertNull(bookingRef);
//	self.assertEqualMsg(bookingRef.allBookingRefItems.size, 2, "");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
end;
</source>
