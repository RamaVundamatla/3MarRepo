    <JadeMethod name="getShortDisplay" id="d55687de-767d-48ed-99b5-08e9f486f69c">
        <source>getShortDisplay(): String;
/*
	Created on 25 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	str : String;
	
begin
	str := inheritMethod();
	
	
	if getTemperature() &lt;&gt; NULL_TEMPERATURE then
		str := str &amp; ' (temp = ' &amp; getTempString(false) &amp; ')';
	endif;

	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
