    <JadeMethod name="trxCreateTrackedItem" id="f595eac9-f791-42e0-ac04-609ea11ed589">
        <updating/>
        <source>trxCreateTrackedItem(_proxy : CM_TrackedItem input;
					 _realTI : CM_TrackedItem output;
					_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     14 February 2001 by cnwdwq1
//
// Purpose:		Creates a persistent trackeditem
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/08/2010	cnwdad1		CCMS 1093 (PAR 24065). Added locking of CM_Terminal::allTITransactionsByEDIDateTime.
// 11 Dec 2012	cnwcs5		par 39855 / CCMS SFW 1294 - change order of collection lock to be subid order
//25 May 2024 	naviv1		TFS 64243 : CUX | POST &amp; PUT /Cargo APIs - Edit Transaction not created when customs reference data updated via API
// ---------------------------------------------------------------------------
vars
	terminal		: CM_Terminal;
	beforeEditStr,
	afterEditStr	: String;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	//th2 2/05/2007 JBL work - prevent deadlock. i.e. Make it this process that is the only one who gets to
	//upgrade to exclusive lock on the following collections (as we're about to implicitly read lock these in the 
	//validate further on)
	terminal := _proxy.myTerminal;
	
	self.exclusiveLock(terminal.allTITransactions);
	self.exclusiveLock(terminal.allTITransactionsByTypeDate);
	self.exclusiveLock(terminal.allTITransactionsByCamsTS);		// cnwdad1 23/08/2010 - CCMS 1093 (PAR #24065).
	
	if _proxy.site = TI_SITE_ONSITE or _proxy.state = TI_STATE_NORMAL then
		self.exclusiveLock(terminal.allOnsiteTIsByCargoTypeId);
		self.exclusiveLock(terminal.allOnsiteTIsByCargoTypeIdRev);
		self.exclusiveLock(terminal.allOnsiteTIsByIdCargoType);
		self.exclusiveLock(terminal.allOnsiteTIsByIdCargoTypeRev);
									   
	elseif _proxy.site = TI_SITE_OFFSITE or _proxy.state = TI_STATE_OFFSITE then
		self.exclusiveLock(terminal.allOffsiteTIsByCargoTypeId);
		self.exclusiveLock(terminal.allOffsiteTIsByCargoTypeIdRev);
		self.exclusiveLock(terminal.allOffsiteTIsByIdCargoType);
		self.exclusiveLock(terminal.allOffsiteTIsByIdCargoTypeRev);
		
	elseif _proxy.site = TI_SITE_TBA or _proxy.state = TI_STATE_TBA then
		self.exclusiveLock(terminal.allNotifiedTIsByCargoTypeId);
		self.exclusiveLock(terminal.allNotifiedTIsByCargoTypeIdRev);
		self.exclusiveLock(terminal.allNotifiedTIsByIdCargoType);
		self.exclusiveLock(terminal.allNotifiedTIsByIdCargoTypeRev);
		
	elseif _proxy.site = TI_SITE_PLACEHOLDER or _proxy.state = TI_STATE_PLACEHOLDER then	//13 Mar 2020	NDL	TFS 47004
		self.exclusiveLock(terminal.allRRPTIsByCargoTypeId);
		self.exclusiveLock(terminal.allRRPTIsByIdCargoType);
		
	endif;

	// Start the transaction
	beginTransaction;
					
					
	
	app.myUtilityCA.utlCreateTrackedItem(_proxy, _realTI, _passport);
	
	//Start - 30-May-2024 naviv1 #64243
	if _passport.hasErrors or _realTI = null then
		return;
	endif;
	
	beforeEditStr := "null";		
	afterEditStr := _realTI.getCustomsReferenceAuditString();
	if afterEditStr = null then
		afterEditStr := "null";
	endif;
	
	if _passport.noErrors and beforeEditStr &lt;&gt; afterEditStr then
		_realTI.createEditForCustomsReferences(beforeEditStr,afterEditStr,_passport); 
	endif;
	//End - 30-May-2024 naviv1 #64243
epilog
	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_proxy" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_realTI" type="CM_TrackedItem" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateTrackedItems" id="f9c470ad-ca7a-4b86-bf66-3a63f3e5ee66">
        <updating/>
        <source>trxCreateTrackedItems(_control : CMIF_TIUpdateController input;
					_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     14 February 2001 by cnwdwq1
//
// Purpose:		Creates persistent trackeditems for each transient in 
//				the control struct
// ---------------------------------------------------------------------------
vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	//-------------------------------------------------------------
	//   V A L I D A T I O N    S E C T I O N
	// Methods to validate data here
	//-------------------------------------------------------------
	app.myValCA.valTrackedItems(_control, _passport);

	// ensure any locks are cleared
	endLoad;

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;

	beginTransaction;

	self.createTrackedItems(_control, _passport);

	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;

epilog		
	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_control" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateTrackedItemsAndAttach" id="177f3482-059b-47a8-b061-bbc816ab27d8">
        <updating/>
        <source>trxCreateTrackedItemsAndAttach(_control : CMIF_TIUpdateController input;
					//_masterContainer : CM_Container input;			
					_masterTI : CM_TrackedItem input;				//+cnwml2 PAR23045
					_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     18 November 2003	cnwth2
//
// Purpose:     Need the facility to back out of TI creation if attachment fails
//			 
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 09/09/2013	cnwdap1		PAR #31196 Use deferred updates for TI updating, so creating a tranship 
//							in a Tranship works correctly and picks up the correct voyages
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	_passport.useTIDictDeferUpdate := true;							// PAR #31196
	_passport.useTITransactionDeferUpdate := true;					// PAR #31196
	
	app.myUtilityCA.utlCreateTrackedItems(_control, _passport);
	// par 18087 AER 10/10/2008
	if _passport.hasErrors then
		return;
	endif;
	
	app.myUtilityUA.utlUpdateAttachTIs(_control, _masterTI, _passport);
	
	_passport.doDeferredUpdates();									// PAR #31196
	
epilog		
	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_control" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_masterTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateTrackedItemsLCL" id="d70c6666-c7c5-4925-b8c0-0a726f87aaf6">
        <updating/>
        <source>trxCreateTrackedItemsLCL(	_intFaceArray : CMIF_TIObjectArray input;
							_location : CM_LocationsController;
							_parentCont : CM_TrackedItem;
							_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/12/2013	cnwndl1	Initial creation	Par 32854
14/19/2015	cnwdap1	PAR #36421 CCMS DPH 2383 Hazardous Materials Handling
*/

vars

	ti : CM_TrackedItem;
	moveController : CMIF_MoveController;
	item : CMIF_TIObject;
	allErrors : CM_ErrorSet;

begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	//-------------------------------------------------------------
	//   V A L I D A T I O N    S E C T I O N
	// Methods to validate data here
	//-------------------------------------------------------------
	 //we are making LCL, it must be in a container or in a location.
	 if _location = null and _parentCont = null then
		app.raiseCMException(Location_Or_Parent_Required, null, null);
		return;
	 endif;
	
	app.myValCA.valPreNotes(_intFaceArray, _passport);

	// ensure any locks are cleared
	endLoad;

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;

	beginTransaction;

	app.myUtilityCA.utlCreatePreNotes(_intFaceArray, false, _passport);
	
	if _passport.hasErrors then
		return;
	endif;
	
	foreach item in _intFaceArray do
		ti := item.CMIF_PreNote.myPersistentTrackedItem;
		if ti = null or _passport.hasErrors then
			return;
		endif;
		if _location &lt;&gt; null then
			//creating LCL in the yard
			create moveController transient;
			moveController.setMyTrackedItem(ti);
			moveController.setMyToPrimaryLocation( _location );
			moveController.isSystemMove := true;
			
			app.myPassport.clearErrorsWarnings();
			app.myPassport.setWarningsIgnored(true);
			
			app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
			
			delete moveController;
			
		elseif _parentCont &lt;&gt; null then
			//creating LCL directly in a container
			ti.setFromParent(_parentCont, _passport);
			// PAR #36421 If the LCL is hazardous, check packing it in to the parent	// PAR #36421
			// doesn't breach hazard segregation rules									// PAR #36421
			if ti.isHazardous then														// PAR #36421
				ti.setHazardLocationsForMode(REAL_MODE, false);							// PAR #36421
				create allErrors transient;												// PAR #36421
				if ti.isBreakingHazSegregation(allErrors) then							// PAR #36421
					_passport.addErrorsFromSet(allErrors);								// PAR #36421
				endif;																	// PAR #36421
				delete allErrors;														// PAR #36421
			endif;																		// PAR #36421
		endif;
	
	endforeach;
	
	if _passport.hasErrors then
		return;
	endif;
	
	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;

epilog

self.finaliseActivityWithPassport(_passport);
delete moveController;
delete allErrors;

end;</source>
        <Parameter name="_intFaceArray" type="CMIF_TIObjectArray" usage="input"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_parentCont" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
