    <JadeMethod name="loadCmbTIs" id="53ea656b-66b7-402d-8a35-9cf780591d55">
        <source>loadCmbTIs() protected;
/*
----------   ----------  --------------------------------------------------
Created:	26 March 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
14/07/2025		naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  		
----------   ----------  --------------------------------------------------
*/
vars
	product			: CM_Product;
	cmb				: CMUI_ComboBox;
	dict			: CM_TIByCargoTypeIdDict;
	iter			: Iterator;
	cargoType,
	cargoTypeKey	: Integer;
	idKey			: String;
	ti				: CM_TrackedItem;
	count			: Integer;
	maxCountExceeded : Boolean;
	
begin
	cmb := self.cmbTI;
	cmb.clear();
	cmb.sorted := false;//dict already sorted - reduce work
	cmb.addItem('');
	if self.cmbVoyage.listObject = null and
	   self.cmbCargoType.listObject = null and
	   self.cmbProduct.listObject = null then
		return;
	endif;
	
	if self.cmbCargoType.listObject &lt;&gt; null then
		cargoType := self.cmbCargoType.listObject.CM_CargoType.id;
	endif;
	
	product := self.cmbProduct.listObject.CM_Product;

	if CM_Voyage.hasInstance(self.cmbVoyage.listObject) and
	   (not self.cmbVoyage.listObject.CM_Voyage.isNullVoyage) then
		dict := self.cmbVoyage.listObject.CM_Voyage.allOnsiteTIsByCargoTypeId;
	else
		dict := self.myTerminal.allOnsiteTIsByCargoTypeId;
	endif;
	
	iter := dict.createIterator;
	dict.startKeyGeq(cargoType, null, iter);
	
	beginLoad;
	while iter.next(ti) do
		iter.getCurrentKeys(cargoTypeKey, idKey); //MTN-35226
		if cargoType &lt;&gt; null and cargoTypeKey &lt;&gt; cargoType then
			break;
		endif;
		
		count := count + 1;
		if count &gt;= 29999 then
			//jade limit for a combo - this'll happen for 
			//logs every time - possibly other cargo types too
			maxCountExceeded := true;
			break;
		endif;
		
		if (product &lt;&gt; null and ti.myProduct &lt;&gt; product) then
			continue;
		endif;
		
		cmb.itemObject[cmb.addItem(idKey)] := ti;
	endwhile;
	
	endLoad;
	
	if maxCountExceeded then
		app.msgBox('There were more than 32,000 tracked items of selected type.' &amp; CrLf &amp;
					'Only the first 32,000 have been listed', ' Maximum entries exceeded', MsgBox_Exclamation_Mark_Icon);
	endif;
	
	
epilog
	endLoad;
	delete iter;
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="7be72f88-2717-492e-9378-4829c0889e64">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//------------------------------------------------
// Created: 07 April 2006 By: cnwgd1
//------------------------------------------------
vars
	voyage			: CM_Voyage;
	ti				: CM_TrackedItem;
begin
	inheritMethod();

	self.cmbVoyage.isDisplayByVesselName := self.myTerminal.getConfig(VesselComboByName).Boolean;
	self.cmbVoyage.initialise(false);
	if CM_Voyage.hasInstance(self.myInitObject) then
		voyage := self.myInitObject.CM_Voyage;
	
	elseif CM_TrackedItem.hasInstance(self.myInitObject) then
		ti := self.myInitObject.CM_TrackedItem;
		voyage := ti.myVoyage;
		self.doSelectTI(ti);
		self.attachmentAdd(ti, false);
		
	elseif CM_BOLIn.hasInstance(self.myInitObject) then
		ti := self.myInitObject.CM_BOLIn.allTrackedItems.first;
		if ti &lt;&gt; null then
			self.doSelectTI(ti);
			foreach ti in self.myInitObject.CM_BOLIn.allTrackedItems do
				self.attachmentAdd(ti, false);
			endforeach;
		endif;
		voyage := self.myInitObject.CM_BOLIn.myVoyage;
		
	elseif CM_BOLOut.hasInstance(self.myInitObject) then
		ti := self.myInitObject.CM_BOLOut.allTrackedItems.first;
		if ti &lt;&gt; null then
			self.doSelectTI(ti);
			foreach ti in self.myInitObject.CM_BOLOut.allTrackedItems do
				self.attachmentAdd(ti,false);
			endforeach;
		endif;
		voyage := self.myInitObject.CM_BOLOut.myVoyage;
	endif;
	
	self.cmbVoyage.setObject(voyage);
	// 25096 limit carriers to road-only
	self.cmbCarrier.setTransportMode(BR_TYPE_ROAD);
	self.cmbCarrier.initialise(true);
	
	self.dateIn.setDate(self.systemToLocalTime(app.actualTimeServer()).date());		// 17/6/16 cnwmp6 TFS 488 - Multi timezone support
	self.timeIn.setTime(self.systemToLocalTime(app.actualTimeServer()).time());
	self.dateOut.setDate(self.systemToLocalTime(app.actualTimeServer()).date());	
	self.timeOut.setTime(self.systemToLocalTime(app.actualTimeServer()).time());
	
	self.loadCmbTIs();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="dc19aa4d-3cba-4a39-99c5-48685debdf60">
        <source>setControlsForAddEdit() protected;
/*
----------   ----------  --------------------------------------------------
