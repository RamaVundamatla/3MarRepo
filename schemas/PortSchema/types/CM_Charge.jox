    <JadeMethod name="setRateForContractResync" id="a358d4bd-1da1-4cef-9d12-bf240ab7b92b">
        <updating/>
        <source>setRateForContractResync(_rateAmount : Decimal) updating;
/*
Purpose:			

Date			Who		Reason
20 June 2023	navab1	CR 55653 TASK 55669
18 Oct 2024		navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	chargeQuantity : Decimal [23,4];
	canLogExtra			: Boolean;	//26.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//26.02.2025 navah1	#34141
	if self.rate = _rateAmount then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("CONT RESYNC rate unchanged still " &amp; self.rate.String , LogINFO.String);
		endif;
		return;
	endif;
	
	chargeQuantity := self.total / self.rate;
	if canLogExtra then	//26.02.2025 navah1	#34141
		app.invLog("CONT RESYNC rate changed from " &amp; self.rate.String &amp; " to " &amp; _rateAmount.String &amp; " using quantity " &amp; chargeQuantity.String , LogINFO.String);
	endif;
	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(self, true);	
	self.rate := _rateAmount;
	self.total := chargeQuantity * _rateAmount;
	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(self, false);	
epilog

end;</source>
        <Parameter name="_rateAmount" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setRateForMinMax" id="aa53a531-6257-4d08-aca3-f45cdaa41dc5">
