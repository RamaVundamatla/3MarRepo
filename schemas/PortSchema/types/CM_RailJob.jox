/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	navhl20	ChangeRequest 57714:[57764] EUP - Delivery Dispatch – Gate
12 Oct 2023 navhl20 Bug 60863: EUP - Delivery Dispatch Remedial [1]
31 Jan 2023 navhl20 ChangeRequest 62166: EUP | 53729 - Delivery Dispatch Screen - outstanding issues
*/

vars
	wagon : CM_Wagon;
begin
	wagon := self.getMyWagon();
	if wagon = null then							//12.10.2023 navhl20 #60863				
		wagon := self.getWagonFromTrain();
	endif;
	if wagon = null then							//31.01.2023 navhl20 #62166
		wagon := self.getWagonFromWle();
	endif;
	if wagon &lt;&gt; null then
		return wagon.getReceiptTimeStamp.asStringJMT;
	endif;
	return null;
epilog

end;</source>
