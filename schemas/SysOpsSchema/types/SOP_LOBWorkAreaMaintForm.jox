<GUIClass name="SOP_LOBWorkAreaMaintForm" id="17d57c7b-1b6a-43d9-af86-75664ca80ab7">
    <superclass name="SOP_WorkAreaMaintForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="doLoadSubObjects" id="770053c4-0630-4e77-9dbf-ec2b813a87ab">
        <source>doLoadSubObjects(_ta: CM_TerminalArea): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Dec 2014	cnwndl1	Initial creation	Par 35295
25 Jun 2020	jlgdap1	TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
*/

vars

	iter : Iterator;
	lc : CM_LocationsController;

begin

	if _ta.myLabourWorkArea &lt;&gt; null then
		return true;
	else
		if _ta.isGeneralCargoAllocArea then													// TFS 49453
			iter := _ta.CM_GeneralCargoAllocRowArea.allRowControllersById.createIterator;	// TFS 49453
		else																				// TFS 49453
			iter := _ta.allLocationsControllers.createIterator;
		endif;																				// TFS 49453
		while iter.next( lc ) do
			if lc.myLabourWorkArea &lt;&gt; null then
				return true;
				break;
			endif;
		endwhile;
		delete iter;
	endif;
	
	return false;

epilog

	delete iter;

end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="334860ba-bfbb-4915-a3cc-a3f0ef585f8b">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

	pxyLabourWorkArea : CM_LabourWorkArea;
	load : Boolean;
	warningsResult : Integer;
	realLabourWorkArea : CM_LabourWorkArea;

begin

	if self.myCurrentWorkArea &lt;&gt; null then
		app.cmsBeginLoad( load );
		pxyLabourWorkArea := self.myCurrentWorkArea.CM_LabourWorkArea.pxyCreateUpdateProxy();
	else
		create pxyLabourWorkArea transient;
	endif;
	
	pxyLabourWorkArea.setProxy(	self.txtCode.text.trimBlanks,	//_code : String;
								self.txtDescription.text.trimBlanks,	//_description : String;
								self.chkAvailable.value,	//_notAvailable : Boolean;
								self.allSelectedObjects,	//_allSelectedObjects : ObjectSet;
								self.myTerminal	//_myTerminal : CM_Terminal
								);
								
	while true do
	
		if self.myCurrentWorkArea &lt;&gt; null then
			app.myTrxUA.trxUpdateLabourWorkArea(pxyLabourWorkArea, app.myPassport);
		else
			app.myTrxCA.trxCreateLabourWorkArea(pxyLabourWorkArea, realLabourWorkArea, app.myPassport);
			self.myCurrentWorkArea := realLabourWorkArea;
		endif;
		
		if app.myPassport.trxCompletedOK then
			return true;
		else
			warningsResult := app.showErrorWarningDialog(pxyLabourWorkArea.code, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if warningsResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
			else
				self.clearErrorWarnings();
				return false;
			endif;
		endif;
		
	endwhile;

epilog

	delete pxyLabourWorkArea;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getColourLegendLines" id="cba614bc-42b3-47b4-9de9-453c9577b132">
        <source>getColourLegendLines(colLegend: CMUI_ColourLegend input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 January 2015	cnwndl1	Initial creation

*/

vars

	areaString : String;

begin

	inheritMethod( colLegend );
	
	areaString := app.getErrorString(Work_area);
	
	colLegend.addLegendItem( app.getErrorString1(Item_selected_current, areaString), self.tblAreas.foreColor, self.Colour_SelectedInCurrent, null, false);
	colLegend.addLegendItem( app.getErrorString1(Item_child_items_select_curren, areaString),  self.tblAreas.foreColor, self.Colour_ChildItemsIncluded, null, false);
	colLegend.addLegendItem( app.getErrorString1(Item_inclu_curre_withi_anoth_a, areaString), self.tblAreas.foreColor, self.Colour_IncludedInCurrent, null, false);
	colLegend.addLegendItem( app.getErrorString1(Item_included_another, areaString), self.tblAreas.foreColor, self.Colour_IncludedInAnother, null, false);
	
epilog

end;</source>
        <Parameter name="colLegend" type="CMUI_ColourLegend" usage="input"/>
    </JadeMethod>
    <JadeMethod name="locationAlreadyUsed" id="76302af2-cf98-4a0f-82bb-cf1e251c2ce9">
        <source>locationAlreadyUsed(_location: CM_Object): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 November 2014	cnwndl1	Initial creation	Par 35295

*/

vars

begin

	if _location.isKindOf(CM_LocationsController) then
		return _location.CM_LocationsController.isInAnyLOBExcluding( self.myCurrentWorkArea.CM_LabourWorkArea );
	elseif _location.isKindOf(CM_GridObject) then
		return _location.CM_GridObject.isInAnyLOBExcluding( self.myCurrentWorkArea.CM_LabourWorkArea );
	elseif _location.isKindOf(CM_TerminalArea) then
		return _location.CM_TerminalArea.isInAnyLOBExcluding( self.myCurrentWorkArea.CM_LabourWorkArea );
	else
		return inheritMethod(_location);
	endif;

epilog

end;</source>
        <Parameter name="_location" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="24893021-b163-4bc6-8414-0960affbf03b">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 January 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020215, locale);
end;</source>
    </JadeMethod>
</GUIClass>
