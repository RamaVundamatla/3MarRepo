    <JadeMethod name="setProxyFromObject" id="b16b5491-01e8-449c-9d23-bb5fd8dfef0e">
        <updating/>
        <source>setProxyFromObject(_object: CM_EventRequestNotification) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2008	cnwkao1	Initial creation

*/

vars

begin
	inheritMethod(_object);
	//epr TFS 47319 31/10/19
	self.description:=_object.getUpdateDetails;
	self.type :=_object.typeString;
	//self.event			:= _object.getActivityDisplayString();//_object.eventName; //apparently this matches CM_TransactionType::description
	create self.event transient;
	event.description := _object.getActivityDisplayString();
	
epilog

end;</source>
        <Parameter name="_object" type="CM_EventRequestNotification"/>
