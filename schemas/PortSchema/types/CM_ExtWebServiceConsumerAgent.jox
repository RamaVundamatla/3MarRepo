        <source>doLogStatisticsInfo(_statistics : String) protected;
/*

Purpose:			Do any required logging/actions based on the information in the passed in
					Web Service statistics result

Parameters:			String value from getLastStatistics call

Return Value:		None

Date		Who		Reason
11 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

begin
	// Parse the XML and log input and output
	app.writeLog(method.qualifiedName &amp; " " &amp; _statistics, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	
epilog

end;</source>
