    <JadeMethod name="txtDateFrom_change" id="f9fcedae-49c6-4a36-b27e-88d1491efe07">
        <controlMethod name="JadeEditMask::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtDateFrom_change(editMask: JadeEditMask input) updating;

vars

begin
	if self.txtDateFrom.getDate() &lt;&gt; null and
	   self.txtDateTo.getDate() &lt;&gt; null and
	   self.txtDateFrom.getDate &lt; self.txtDateTo.getDate() then
		self.btnExtract.enabled := true;
	else
		self.btnExtract.enabled := false;
	endif;
end;</source>
        <Parameter name="editMask" type="JadeEditMask" usage="input"/>
    </JadeMethod>
