    <JadeMethod name="trxMoveVehicle" id="f66b14f0-18e5-4974-86f5-ad174e6c4055">
        <updating/>
        <source>trxMoveVehicle(_vehicle   : CM_Vehicle input;
				_location : CM_YardController input;
				_passport : CM_Passport input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
16 Aug 2006	cnwer1	Initial creation - PAR#xxxx
24 Oct 2024 navma1  MTN-33191 MTN - Enable Deferred Event When using Gate Checker 
*/
vars

begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	
	_passport.useEventDeferUpdate := true;			//24.10.2024 navma1   MTN-33191				
	
	beginTransaction;

	app.myUtilityUA.utlMoveVehicle(_vehicle,_location, _passport);

	if _passport.noErrors then				
		_passport.doDeferredUpdates();				//24.10.2024 navma1   MTN-33191	
	endif;

epilog	
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle" usage="input"/>
        <Parameter name="_location" type="CM_YardController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxMoveWagons" id="74a85ad1-3ea6-473d-946c-5f18688e6132">
        <updating/>
        <source>trxMoveWagons(control : CMIF_WagonMoveController input; _passport : CM_Passport input) updating;

/*

Purpose:			Performs move of wagons for trains / rail areas

Parameters:			

Return Value:		


Date		Who		Reason
28 May 2009	consw1	PAR 19710 - SFW1067 Rail Simplifications
13 May 2025	navbs1	Bug MTN-34762: MTN - Add Deferred Updates Rail Operation

*/

vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	beginTransaction;
	
	_passport.useEventDeferUpdate := true;				//13.05.2025 navbs1 #34762

	if control.myTargetRailLine &lt;&gt; null then
		reserveLock(control.myTargetRailLine);
	endif;
	if control.myTargetTrain &lt;&gt; null then
		reserveLock(control.myTargetTrain);
	endif;

	app.myUtilityUA.utlMoveWagons(control, _passport);
	
	if _passport.noErrors then 
		_passport.doDeferredUpdates();					//13.05.2025 navbs1 #34762
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="control" type="CMIF_WagonMoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxMultiCargoSplit" id="0a6f50a2-597d-4e65-a1f1-192ea2a77ef6">
        <updating/>
        <source>trxMultiCargoSplit(	_sourceTi : CM_Cargo input;
					_allTiIdsToCreate : StringArray;
					_quantityArray : IntegerArray;
					_weightArray : DecimalArray;
					_voyageArray : CM_VoyageArray;
					_disPort : String;
					_specialStow : String;
					_bolStr : String;
					_passport : CM_Passport input
					) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 June 2020	jlgndl1	Initial creation	TFS 49401

*/

vars

	index : Integer;
	size : Integer;
	
	newId : String; 
	newTi : CM_Cargo;
	quantity : Integer;
	weight : Decimal[14,4];
	voyage : CM_Voyage;
	
	originalBol : CM_BOLIn;
	createVoyageBol : Boolean;
	voyBol : CM_BOL;
	allNewBOLDtlProxies : CM_ObjectArrayActual;
	proxy : CM_Object;
	pxyBOL: CM_BOL;
	newBOL: CM_BOL;
	pxyTi : CM_TrackedItem;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	//If the original TI has a BOL, and the user has choesn to associate the new ti(s) with the same BOL number on the new voyage(s)
	// we may need to create the new bol(s) too.
	originalBol := _sourceTi.myReceivalBOL;
	if originalBol &lt;&gt; null and originalBol.number = _bolStr then
		createVoyageBol := true;
	endif;
	
	app.setContinueCMExceptions(false);
	
	beginTransaction;
	
	size := _allTiIdsToCreate.size;
	foreach index in 1 to size do
	
		newId := _allTiIdsToCreate[index];
		if not _quantityArray.isEmpty then
			quantity := _quantityArray[index];
		else
			weight := _weightArray[index];
		endif;
		// Spilt off the new cargo item
		app.myUtilityUA.utlSplitBreakBulkToNewID( 	_sourceTi,	//_sourceTi : CM_Cargo input;
													newId,	//_newId : String; 
													newTi,	//_newTi : CM_Cargo output; 
													quantity,	//_quantity : Integer;
													weight,	//_weight : Decimal;
													null,	//_operator : CM_Operator; 
													false,	//_includeStops : Boolean;
													false,	//_includeToDo : Boolean;
													false,	//_includeDamage : Boolean;
													false,	//_includeHaz : Boolean;
													null,
													_passport	//_passport : CM_Passport input
													);
													
		if _passport.hasErrors then
			break;
		endif;
		
		if newTi = null then
			continue;
		endif;
		
		//create the BOL on the voyage if we need to.
		voyage := _voyageArray[index];	
		if createVoyageBol then
			voyBol := voyage.allBOLInByTypeStatusNumDT.getFirstWithNumber( _bolStr );
			if voyBol = null then
				create pxyBOL as CM_BOLIn transient;
				pxyBOL.CM_BOLIn.pxySetFromBOLIn( originalBol, voyage );
				create allNewBOLDtlProxies transient;
				app.setServerTimestampAtTrxStart(null);  // otherwise we get duplicated keys. // ### TFS 52639 21Mar2022 NAVPW1
				app.myUtilityCA.utlCreateBOL( pxyBOL, _passport, null, voyBol, allNewBOLDtlProxies);
				delete allNewBOLDtlProxies;
				delete pxyBOL;
			
				if _passport.hasErrors then
					break;
				endif;
			endif;
		endif;
		
		//Update the newly split off item with its new attributes
		pxyTi := newTi.pxyCreateUpdateProxy();
		
		pxyTi.setMyVoyage( voyage, _passport );
		pxyTi.setDischargePort( _disPort );
		pxyTi.setSpecialStow( _specialStow );
		pxyTi.setBOL( _bolStr );
		
		app.myUtilityUA.utlUpdateTrackedItem( pxyTi, null, TI_UPDMODE_NORMAL, null, null, null, app.myPassport );
		
		delete pxyTi;
							
		if _passport.hasErrors then
			break;
		endif;
	
	endforeach;

epilog

	self.finaliseActivityWithPassport(_passport);
	
	if allNewBOLDtlProxies &lt;&gt; null then
		//these proxies have not been committed yet so if there was an exception then need to remove proxy link
		foreach proxy in allNewBOLDtlProxies do
			app.myProxyManager.deleteProxyLink(proxy);
		endforeach;
		
		delete allNewBOLDtlProxies;
	endif;
	delete pxyBOL;
	delete pxyTi;
	
end;</source>
        <Parameter name="_sourceTi" type="CM_Cargo" usage="input"/>
        <Parameter name="_allTiIdsToCreate" type="StringArray"/>
        <Parameter name="_quantityArray" type="IntegerArray"/>
        <Parameter name="_weightArray" type="DecimalArray"/>
        <Parameter name="_voyageArray" type="CM_VoyageArray"/>
        <Parameter name="_disPort" type="String"/>
        <Parameter name="_specialStow" type="String"/>
        <Parameter name="_bolStr" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxOOWRejection" id="717c96cc-4eaf-424a-a3eb-e212c05fdcdf">
        <updating/>
        <source>trxOOWRejection(	_workOrder : CM_WorkOrder input;
					_remark : CM_PredefinedRemark;
					_lengthOfTime : Decimal;
					_passport : CM_Passport input
					) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/04/2018	jlgndl1	Initial creation	TFS 37928
23/04/2018	jlgdap1	TFS 38215 PEL1 OOW Confirmation Changes
18/10/2018	cnwer1	TFS 41310 
*/

vars


begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
		
	beginTransaction;

	app.myUtilityUA.utlOOWRejection(  _workOrder,  _remark, _lengthOfTime, _passport );
	
epilog

	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_workOrder" type="CM_WorkOrder" usage="input"/>
        <Parameter name="_remark" type="CM_PredefinedRemark"/>
        <Parameter name="_lengthOfTime" type="Decimal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxPackToDoCompleteSubTerm" id="c0563d7b-20e1-4024-8ffa-60666b624d96">
        <updating/>
        <source>trxPackToDoCompleteSubTerm(	_theMoveController : CMIF_MoveController input; _noCharge : Boolean;
							_thePackTIs, _theUnpackTIs : CM_TIArray;
							_unpackFromRelease : Boolean;
							_theProxyParentTI : CM_TrackedItem io;
							_tasksToAdd, _tasksToComplete : IntegerArray;
							_resourceUsageProxies : CM_ResourceTypeUsageSet input;
							_passport : CM_Passport input	) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/07/2015	cnwdap1		Initial creation PAR #36484 Combine all trx updates from MOB_PackBookingDetailForm
//							in to one trx
// 30/11/2015	cnwdap1		PAR #37217 Assign TI to the appropriate bulk release (cut-down version of what happens
//							in Pack/Unpack screen because we don't have to deal with any children here)
// 15/12/2015	cnwdap1		PAR #37303 Rejig update of TI to avoid getting repeated warnings
//
vars
	realTI					: CM_TrackedItem;
	transactionController	: CMIF_TITransactionController;
	txnControllerDict 		: CMIF_TITxnContrlrByTypeDTDict;
	resources 				: CM_ResourceTypeUsageSet;
	tiSet 					: CM_TISet;
	toDoTask 				: Integer;
	toDoTaskDesc 			: CM_ToDoTaskDesc;
	obj 					: CM_Object;
	resource 				: CM_ResourceType;
	resourceUsage 			: CM_ResourceTypeUsage;
	bulkRelease				: CM_BulkRelease;					// PAR #37217
	tiUpdateCntrlr			: CMIF_TIUpdateController;		// PAR #37303

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
	
	realTI := _theProxyParentTI.pxyGetRealObject();
	
	create transactionController transient;
	create txnControllerDict transient;
	create resources transient;
	
	beginTransaction;
	
	// pack / unpack to update the TI as if it has had children packed in to it
	app.myUtilityUA.utlUpdatePackUnpack(_theMoveController,
										_noCharge,
										_thePackTIs,
										_theUnpackTIs,
										_unpackFromRelease,
										_theProxyParentTI,
										TI_UPDMODE_NORMAL,
										_passport);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	// now sort out releases and the tracked item - this isn't done in utlUpdatePackUnpack because				// PAR #37217
	// that just looks for packing releases																		// PAR #37217
	bulkRelease := _theProxyParentTI.allBulkReleasesAssigned.getAtKeyGeq(BR_TYPE_ROAD, null, null, null);		// PAR #37217
	if bulkRelease = null then																					// PAR #37217
		bulkRelease := _theProxyParentTI.allBulkReleasesReleased.getAtKeyGeq(BR_TYPE_ROAD, null, null, null);	// PAR #37217
	endif;																										// PAR #37217
	if bulkRelease &lt;&gt; null then																					// PAR #37217
		bulkRelease.addTIReleased(realTI, CM_ReserveDetail.PackType_Parent);									// PAR #37217
	endif;																										// PAR #37217
	realTI.setBulkReleaseReleased(bulkRelease, null, null);														// PAR #37217
	realTI.setReleasedDT(app.actualTimeServer);																	// PAR #37217
	
	//complete the WLE and Work Order detail
	app.myUtilityUA.utlUpdateTIPackComplete(_theProxyParentTI, realTI, _passport);

	if _passport.hasErrors() then
		return;
	endif;

	transactionController.myTrackedItem := realTI;
	transactionController.myOtherTrackedItem := null;
	transactionController.noCharge := false;
	transactionController.type := TRANS_TYPE_PackComplete;
	
	txnControllerDict.add(transactionController);

	if _passport.hasErrors() then
		return;
	endif;
	
	// refresh the proxy
	delete _theProxyParentTI;
	_theProxyParentTI := app.createUpdateProxy(realTI).CM_TrackedItem;
	
	//update the container and create the Pack Complete transaction
	//app.myUtilityUA.utlUpdateTrackedItem(_theProxyParentTI, null, TI_UPDMODE_NORMAL, txnControllerDict, null, null, _passport);	// PAR #37303
	tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);			// PAR #37303
	txnControllerDict.copy(tiUpdateCntrlr.allTITxnControllers);											// PAR #37303
	realTI.setForUpdate(_theProxyParentTI, tiUpdateCntrlr, null, true, _passport);						// PAR #37303
	if realTI.myTerminal.getConfig(AutoCreateCusCarBOL).Boolean and CM_Car.hasInstance(realTI) then		// PAR #37303
		app.myUtilityUA.utlUpdateBOLInCusCar(realTI.CM_Car, _passport);									// PAR #37303
	endif;																								// PAR #37303
	
	if _passport.hasErrors() then
		return;
	endif;
	
	// Set any unpack complete stops 
	realTI.setStopsToBeApplied(StopApplyPackComplete, true, _passport);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	// and update the contents status
	realTI.updateContentsStatus;
	
	// refresh the proxy
	delete _theProxyParentTI;
	_theProxyParentTI := app.createUpdateProxy(realTI).CM_TrackedItem;
	
	create tiSet transient;
	tiSet.add(_theProxyParentTI);
	
	// add tasks
	foreach toDoTask in _tasksToAdd do
		toDoTaskDesc := app.myRoot.allToDoTaskDescriptions[toDoTask];
		if toDoTaskDesc = null then
			continue;
		endif;
		
		// check if we have any resources for this to do task
		resources.clear;
		foreach obj in toDoTaskDesc.allResourceTypes discreteLock do
			resource := obj.CM_ResourceType;
			foreach resourceUsage in _resourceUsageProxies where resourceUsage.myResourceType = resource do
				resources.add(resourceUsage);
			endforeach;
		endforeach;
		
		app.myUtilityUA.utlUpdateTIToDoTasksWarehouse(toDoTaskDesc, tiSet, STATUS_TODO, resources, _passport);
	endforeach;
	
	// complete tasks
	foreach toDoTask in _tasksToComplete do
		toDoTaskDesc := app.myRoot.allToDoTaskDescriptions[toDoTask];
		if toDoTaskDesc = null then
			continue;
		endif;
		
		// check if we have any resources for this to do task
		resources.clear;
		foreach obj in toDoTaskDesc.allResourceTypes discreteLock do
			resource := obj.CM_ResourceType;
			foreach resourceUsage in _resourceUsageProxies where resourceUsage.myResourceType = resource do
				resources.add(resourceUsage);
			endforeach;
		endforeach;
		
		app.myUtilityUA.utlUpdateTIToDoTasksWarehouse(toDoTaskDesc, tiSet, STATUS_COMPLETE, resources, _passport);
	endforeach;
	
	if _passport.noErrors() then
		_passport.doDeferredUpdates();
	endif;
	
epilog
	delete transactionController;
	delete txnControllerDict;
	delete resources;
	delete tiSet;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_theMoveController" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_noCharge" type="Boolean"/>
        <Parameter name="_thePackTIs" type="CM_TIArray"/>
        <Parameter name="_theUnpackTIs" type="CM_TIArray"/>
        <Parameter name="_unpackFromRelease" type="Boolean"/>
        <Parameter name="_theProxyParentTI" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_tasksToAdd" type="IntegerArray"/>
        <Parameter name="_tasksToComplete" type="IntegerArray"/>
        <Parameter name="_resourceUsageProxies" type="CM_ResourceTypeUsageSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxPackageBulk" id="7d63ee44-7b86-4e1f-9060-f35442414f5f">
        <updating/>
        <source>trxPackageBulk(	_sourceTi : CM_Bulk input;
				_newTiIds : StringArray;
				_quantityPerId : Integer;
				_itemNettWeight : Decimal;
				_cargoType : CM_CargoType;
				_product : CM_Product;
				_operator : CM_Operator;
				_pkgingWeight : Decimal;
				_lc : CM_LocationsController;
				_passport : CM_Passport input
				) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2014	cnwndl1	Initial creation

*/

vars

	tiId : String;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	
	app.myValUA.valPackageBulk(	_sourceTi,	//_sourceTi : CM_Bulk;
								_newTiIds,	//_newTiIds : StringArray;
								_quantityPerId,	//_quantityPerId : Integer;
								_itemNettWeight,	// _itemNettWeight : Decimal;
								_cargoType,	//_cargoType : CM_CargoType;
								_product,	//_product : CM_Product;
								_operator,	//_operator : CM_Operator;
								_lc,	//_lc : CM_LocationsController
								_passport	//_passport : CM_Passport input
								);
											
	if _passport.hasErrors then
		return;
	endif;

	beginTransaction;
	
	foreach tiId in _newTiIds do

		if _passport.hasErrors then
			break;
		endif;
		
		app.myUtilityUA.utlPackageBulk( _sourceTi,	//_sourceTi : CM_Bulk;
										tiId,	//_newTiId : String;
										_quantityPerId,	//_quantity : Integer;
										_itemNettWeight,	// _itemNettWeight : Decimal;
										_pkgingWeight,	// _pkgingWeight : Decimal;
										_cargoType,	//_cargoType : CargoType;
										_product,	//_product : CM_Product;
										_operator,	//_operator : CM_Operator;
										_lc,	//_lc : CM_LocationsController
										_passport	//_passport : CM_Passport input
										);
	
	endforeach;

epilog

	self.finaliseActivityWithPassport(_passport);

end;</source>
