        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setPrimaryQueueName" id="b96604f9-de79-4ce0-8e3d-69e6b6f8f2c6">
        <updating/>
        <source>setPrimaryQueueName(_name : String) updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
12 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars

begin
	if self.primaryQueueName &lt;&gt; _name then
		self.primaryQueueName := _name;
	endif;
	

epilog

end;</source>
        <Parameter name="_name" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="260ad862-0a4c-450b-a279-3a21d904ae12">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			Standard form setup


Return Value:		None


Date		Who		Reason
11 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

begin
	inheritMethod();
	
	// Initialise form controls
	self.doApplyScreenColors();
	self.tableQueuesInitialize();
	
	// And load the table of available queues
	self.doLoadAvailableQueues();
	
	self.lblQueueName.caption := self.primaryQueueName;
	
	self.btnOk.enabled := false;
	
	
epilog
	self.modalResult := self.MB_MODAL_CANCEL;
	app.mousePointer := Idle;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tableQueuesInitialize" id="17a2c839-1c23-4808-8c4e-af21405b3d89">
        <source>tableQueuesInitialize() protected;

/*

Purpose:			Setup the Queue table and load it


Return Value:		None


Date		Who		Reason
11 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	tableObj		: Table;
	columnObj		: JadeTableColumn;
	rowObj			: JadeTableRow;
	numCols,
	i				: Integer;
	
begin
	tableObj					:= self.tblQueues;
	
	tableObj.rows				:= 1;
	tableObj.columns			:= 3;
	tableObj.fixedColumns		:= 0;
	tableObj.fixedRows			:= 1;
		
	tableObj.partialTextIndication	:=	true;

	columnObj					:= tableObj.accessColumn(1);
	columnObj.widthPercent		:= 30;
	
	columnObj					:= tableObj.accessColumn(2);
	columnObj.widthPercent		:= 35;
		
	columnObj					:= tableObj.accessColumn(3);
	columnObj.widthPercent		:= 35;

	tableObj.backColor			:= tableObj.parent.backColor;
	tableObj.gridLines			:= false;
	tableObj.defaultRowHeight	:= 60;
	
	tableObj.readOnly			:= false;
	
	rowObj						:= tableObj.accessRow(1);
	rowObj.fontBold				:= true;
	
	tableObj.setCellText(1, 1, "Queue" &amp; Tab &amp; "Number of Entries" &amp; Tab &amp; "Number of Machines");

	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
