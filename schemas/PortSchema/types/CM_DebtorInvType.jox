        <source>validateForUpdate();
// 20 September 2011	cnwjre1	CCMS 2120 Electronic Invoicing
begin
	if self.myDebtor = null then
	 //	app.raiseCMException1(REQUIRED_FIELD, "Debtor", null, null);
		app.raiseCMException(Input_required_field_debtor, null, null); // cnwdb2	PAR 35364
	endif;
	if self.myInvoiceType = null then
	// 	app.raiseCMException1(REQUIRED_FIELD, "Invoice type", null, null);
