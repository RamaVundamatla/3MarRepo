    <JadeMethod name="processReefers" id="79ebad23-ca00-4dbf-9e14-93ff98bf8e2e">
        <source>processReefers();

vars
	contRange: CM_ContRange;
	isoType: CM_ISOType;
	index: Integer;
	theUser: CM_User;
	vehicle: CM_Vehicle;
	opCode, voyCode, disCode, destCode, comCode: StringArray;
	skipCount, vehCount : Integer;
	trackedItem: CM_TrackedItem;
	contRangeUsedArray: ObjectArray;
begin
	create opCode  transient;
	create voyCode transient;
	create disCode transient;
	create destCode transient;
	create contRangeUsedArray transient;
	create comCode transient;
	opCode.add("MSK");
	voyCode.add("JBL100N");
	disCode.add("USPHL");
	destCode.add("USPHL");
	comCode.add("CHEZ");
	opCode.add("MSK");
	voyCode.add("JBL100N");
	disCode.add("USPHL");
	destCode.add("USPHL");
	comCode.add("FZFD");
	opCode.add("MSK");
	voyCode.add("JBL100N");
	disCode.add("USPHL");
	destCode.add("USPHL");
	comCode.add("FZFD");
	opCode.add("MSK");
	voyCode.add("JBL100N");
	disCode.add("USPHL");
	destCode.add("USPHL");
	comCode.add("FZBU");
	opCode.add("MSK");
	voyCode.add("JBL100N");
	disCode.add("USSAV");
	destCode.add("USSAV");
	comCode.add("FZPY");
	opCode.add("MSK");
	voyCode.add("JBL100N");
	disCode.add("USSAV");
	destCode.add("USSAV");
	comCode.add("FZBU");
	opCode.add("MSK");
	voyCode.add("JBL100N");
	disCode.add("USSAV");
	destCode.add("USSAV");
	comCode.add("FZIC");
	app.initialize;
	on Exception do handleException(exception);
	app.setPassBackExceptions(true, true);
//	app.setPassBackExceptions(false, false);
//	theUser := CM_Terminal.firstInstance.users["SUPERUSER"];
	if theUser = null then
		theUser := CM_Root.firstInstance.allUsers["SUPERUSER"];
	endif;
	app.myPassport.setMyUser(theUser);
	app.myPassport.setMyTerminal(CM_Terminal.firstInstance);
	app.myPassport.warningsAcknowledged	:= true;
	app.myPassport.setIsBackgroundWarningsIgnored(true);

	foreach contRange in app.myRoot.allContainerRanges do
		isoType := app.myRoot.allISOTypes[contRange.isoType];
		if isoType = null then
			continue;
		endif;
		if not isoType.isIntegral() then
			continue;
		endif;
		if contRangeUsedArray.includes(contRange) then
			continue;
		endif;
		skipCount := skipCount + 1;	
		trackedItem := app.getMyTerminalDO_NOT_USE.allOnsiteTIsByIdCargoType[contRange.lower, TI_CargoType_Container];
		if trackedItem &lt;&gt; null then
			continue;
		endif;
		foreach vehicle in app.getMyTerminalDO_NOT_USE().vehicles do
			vehCount := vehCount + 1;
			if vehCount &lt; skipCount then
				continue;
			endif;
			break;
		endforeach;
		if isoType.isIntegral() then
			index := index + 1;
			if index &gt; opCode.size then
				break;
			endif;
			contRangeUsedArray.add(contRange);
			self.processGroupOfContainers(contRange, vehicle.regNumber, opCode[index], voyCode[index], disCode[index], destCode[index], comCode[index]);
write(contRange.lower&amp;' '&amp;vehicle.regNumber&amp;' '&amp;opCode[index]&amp;' '&amp;voyCode[index]);
		endif;
	endforeach;
write index.String&amp;' '&amp;skipCount.String;
end;</source>
    </JadeMethod>
    <JadeMethod name="processRoadExit" id="c5421100-9ca5-4249-bb28-3c90322c521d">
        <source>processRoadExit();

/*

Date		Who		Reason
16 Feb 2024	navnk30	ChangeRequest 62414: EUP | Retrospective Operations - [54177.050] - Road Exit
*/

vars
	roadJob: CM_RoadJob;
	theUser: CM_User;
	error: CM_Error;
	jobArray: ObjectArray;
	obj: Object;
begin
	app.initialize;
	app.myPassport.setMyTerminal(CM_Terminal.firstInstance);
	if theUser = null then
		theUser := CM_Root.firstInstance.allUsers["SUPERUSER"];
	endif;
	app.myPassport.setMyUser(theUser);
	app.myPassport.warningsAcknowledged	:= true;

	create jobArray transient;
	foreach obj in CM_RoadJob.instances do
		jobArray.add(obj);
	endforeach;
	foreach obj in jobArray do
		roadJob := obj.CM_RoadJob;
		if roadJob.status = JOB_COMPLETE then
			//app.myTrxDA.trxRoadExit(roadJob, app.myPassport);			//16.02.2024 navnk30 #62414
			app.myTrxDA.trxRoadExit(roadJob, null, app.myPassport);		//16.02.2024 navnk30 #62414
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
	write class.name&amp;'::'&amp;method.name&amp;' '&amp;roadJob.String&amp;" OK";
	//							break;
			else
				foreach error in app.myPassport.allWarnings do
					write class.name&amp;'::'&amp;method.name&amp;' '&amp;roadJob.String&amp;" WARNING: "&amp;error.text;
				endforeach;
				foreach error in app.myPassport.allErrors do
					write class.name&amp;'::'&amp;method.name&amp;' '&amp;roadJob.String&amp;" ERROR: "&amp;error.text;
				endforeach;
				if app.myPassport.noErrors then
	//					   		result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
	//							app.myPassport.warningsAcknowledged	:= true;
	//								continue;
				else
	//								break;
				endif;
			endif;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="processVoyageWithContainers" id="0b48c473-1c14-434d-8581-e244c052003d">
        <source>processVoyageWithContainers();
//--------------------------------------------------
// Created:	18 January 2006 By: cnwgd1
//--------------------------------------------------
vars
	rtnValue 	: Boolean;
	term		: CM_Terminal;
	realTI,
	pxyTI		: CM_TrackedItem;
	err			: CM_Error;
	tmpCode,
	tmpDesc,
	tmpStr,
	str			: String;
	voyage	: CM_Voyage;
	passport	: CM_Passport;
	bayIdx		 	: Integer;
	root 		: CM_Root;
	tmpPort		: CM_Port;
	tmpCommodity: CM_Commodity;
	tmpCargoType: CM_CargoType;
	tmpMoveController : CMIF_MoveController;
	slotIdx : Integer;
	bayVoyage : CM_BayVoyage;
	slot : CM_SlotController;
	port : CM_Port;
	ports : CM_PortSet;
	loadPortIdx : Integer;
	loadPortCode : String;
	dischargePortIdx : Integer;
	dischargePortCode : String;
	lastTier : Integer;
	portCodeArray : StringArray;
	tiId : String;
	prefix : String;
	number, prefixIdx : Integer;
	prefixCodeArray : StringArray;
	contRange : CM_ContRange;
begin
	
	app.initialize();
	on Exception do handleException(exception);
	app.setPassBackExceptions(true, true);
	passport := app.myPassport;
	term := CM_Terminal.firstInstance;
	passport.setMyTerminal(term);
	passport.setMyUserFromCode("SUPERUSER");	
	
	create tmpMoveController transient;	
	root := app.myRoot;
	bayIdx := 0;	

	tmpCode := "EMMA0000";
	voyage := term.lookupVoyage(tmpCode, null, false);
	if voyage = null then
		write "Voyage not found.";
		return;
	endif;
	if not voyage.allOnshipTIsByCargoTypeId.isEmpty then
		beginTransaction;
		foreach realTI in voyage.allOnshipTIsByCargoTypeId do
			realTI.erase(NORMAL_ERASE);
			bayIdx := bayIdx + 1;
			if bayIdx mod 100 = 0 then
				commitTransaction;
				beginTransaction;
			endif;
		endforeach;
		commitTransaction;
		realTI := null;
	endif;
//return;
	create ports transient;
	create portCodeArray transient;
	voyage.myShippingLine.getAllDischargePorts(ports);
	foreach port in ports do
		portCodeArray.add(port.code);
	endforeach;
	create prefixCodeArray transient;
	prefixCodeArray.add("RUSS");
	prefixCodeArray.add("RUZZ");
	prefixCodeArray.add("REZZ");
	prefix := "RUSS";
	prefixIdx := 1;
	foreach bayVoyage in voyage.myCellularVoyageStructure.allBayVoyagesById do
		bayIdx := bayIdx + 1;
		lastTier := 0;
		foreach slot in bayVoyage.allSlotControllersByOrdinal do
			if slot.mySlotDefnVoyage.unavailable then
				continue;
			endif;
			if lastTier &lt;&gt; slot.ordinalCell then
				dischargePortIdx := dischargePortIdx + 1;
				if dischargePortIdx &gt; portCodeArray.size then
					dischargePortIdx := 1;
				endif;
				dischargePortCode := portCodeArray[dischargePortIdx];
			endif;
			slotIdx := slotIdx + 1;
			if slotIdx mod 7 = 0 then
				loadPortIdx := loadPortIdx + 1;
				if loadPortIdx &gt; portCodeArray.size then
					loadPortIdx := 1;
				endif;
				loadPortCode := portCodeArray[loadPortIdx];
			endif;
			create pxyTI as CM_Container transient;
			tiId := null;
			while tiId = null do
				tiId := self.getNextValidContainerId(prefix, number);
				if tiId = null then
					prefixIdx := prefixIdx + 1;
					if prefixIdx &gt; prefixCodeArray.size then
						write "run out of container prefixes";
						return;
					endif;
					prefix := prefixCodeArray[prefixIdx];
				endif;
			endwhile;
			pxyTI.setPropertyValue(CM_TrackedItem::cargoType.name, TI_CargoType_Container);
			pxyTI.setPropertyValue(CM_TrackedItem::operatorCode.name, "MSK");
			pxyTI.setPropertyValue(CM_TrackedItem::id.name, tiId);
			pxyTI.setPropertyValue(CM_Container::isoType.name, "2230");
			pxyTI.setPropertyValue(CM_TrackedItem::loadPort.name, loadPortCode);
			pxyTI.setPropertyValue(CM_TrackedItem::dischargePort.name, dischargePortCode);
			pxyTI.setPropertyValue(CM_TrackedItem::destinationPort.name, dischargePortCode);
			pxyTI.setPropertyValue(CM_TrackedItem::commodity.name, "GENL");
			//pxyTI.setPropertyValue(CM_TrackedItem::weight.name, 22000);						//-cnwml2 MSL CCMS 1017
			pxyTI.setPropertyValue(CM_TrackedItem::totalWeight.name, 22000);					//+cnwml2 MSL CCMS 1017
			pxyTI.setPropertyValue(CM_TrackedItem::companyOid.name, term.companies["DFBU"]);
			pxyTI.setPropertyValue(CM_Container::availabilityGrade.name, 12);
	
			pxyTI.setMyVoyage(voyage, passport);		
			app.myTrxCA.trxCreateTrackedItem(pxyTI, realTI, passport);
			if passport.hasErrorsOrWarnings then
				passport.inspect;
				return;
			endif;
			tmpMoveController.isForcedMove 	:= true;
			tmpMoveController.isSystemMove 	:= true;
			tmpMoveController.setMoveMode(REAL_MODE);
			tmpMoveController.setMyTrackedItem(realTI);
			tmpMoveController.setMyToPrimaryLocation(slot);
			app.myTrxUA.trxMoveTrackedItem(tmpMoveController, app.myPassport);
			if passport.hasErrorsOrWarnings then
				passport.inspect;
				return;
			endif;
			lastTier := slot.ordinalCell; 
		endforeach;
//		break; //only do 1 bay
	endforeach;
	write 'Finished.';
epilog
	delete tmpMoveController;
	delete ports;
	delete portCodeArray;
	delete prefixCodeArray;
end;
</source>
    </JadeMethod>
    <JadeMethod name="processVoyageWithContsFromFile" id="2fc1c67e-2530-4562-ad06-4749ba4f3be9">
        <source>processVoyageWithContsFromFile();
//--------------------------------------------------
// Created:	18 January 2006 By: cnwgd1
//--------------------------------------------------
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
vars
	tmpFile		: File;
	array 		: HugeStringArray;
	line 		: String;
	rtnValue 	: Boolean;
	lineNo		: Integer;
	term		: CM_Terminal;
	realTI,
	pxyTI		: CM_TrackedItem;
	err			: CM_Error;
	tmpCode,
	tmpDesc,
	tmpStr,
	str			: String;
	voyage	: CM_Voyage;
	passport	: CM_Passport;
	control		: CMIF_TIUpdateController;
	pos		 	: Integer;
	root 		: CM_Root;
	tmpPort		: CM_Port;
	tmpCommodity: CM_Commodity;
	tmpCargoType: CM_CargoType;
	tmpMoveController : CMIF_MoveController;
	vehicle,
	blockStack : CM_LocationsController;
	pxyProduct, realProduct : CM_Product;
	tiSet : CM_TISet;
begin
	
	app.initialize();
	passport := app.myPassport;
	term := CM_Terminal.firstInstance;
	passport.setMyTerminal(term);
	passport.setMyUserFromCode("SUPERUSER");	
	
	create tiSet transient;
	create array transient;
	create tmpFile transient;
	tmpFile.kind 		:= File.Kind_Unknown_Text; // 3/3/16  cnwns1 PAR 36286 unicode version
	tmpFile.mode 		:= File.Mode_Input;
	tmpFile.shareMode 	:= File.Share_Read;
	tmpFile.fileName 	:= "D:\cnwdmast\EMMA.csv";
	if (not tmpFile.isAvailable) then 
		write 'File not available';
		return;
	endif;

	tmpFile.open();	
	root := app.myRoot;
	pos := 1;	

	control := app.createTIUpdateControl(TI_UPDMODE_NORMAL, "SUPERUSER", null);	
	write 'Loading file...';
	
	while (not tmpFile.endOfFile) do
		pos := 1;	
		array.clear;
		line := tmpFile.readLine();

		lineNo := lineNo + 1;
		if lineNo = 1 then
			continue;
		endif;
		line.parseCSV(array);

		tmpStr := array[14]; //get id		
		if tmpStr = null then
			continue;
		endif;
		tmpStr.trimBlankCharacters();
		
		term.lookupAllTIsOfIdCargoType(tmpStr, TI_CargoType_Container, tiSet, false, false, null);

		beginTransaction;
		tiSet.purge;
		commitTransaction;

		foreach realTI in tiSet do
			if realTI.id = tmpStr then
				control.allPersistentTIs.add(realTI);
			endif;
		endforeach;
		
		create pxyTI as CM_Container transient;
		control.allTransientTIs.add(pxyTI);
		pxyTI.setPropertyValue(CM_TrackedItem::id.name, tmpStr);		
		
		tmpStr := array[1];
		tmpCode := tmpStr[1:25];
		voyage := term.lookupVoyage(tmpCode, null, false);
		if voyage = null then
			write "Voyage not found.";
			return;
		endif;

		tmpStr := array[3];
		pxyTI.setPropertyValue(CM_TrackedItem::operatorCode.name, tmpStr[1:3]);
		tmpStr := array[3];
		pxyTI.setPropertyValue(CM_TrackedItem::id.name, tmpStr[1:11]);
		tmpStr := array[4];		
		pxyTI.setPropertyValue(CM_Container::isoType.name, tmpStr[1:4]);
		tmpStr := array[5];		
		pxyTI.setPropertyValue(CM_TrackedItem::loadPort.name, tmpStr[1:5]);
		tmpStr := array[6];		
		pxyTI.setPropertyValue(CM_TrackedItem::dischargePort.name, tmpStr[1:5]);
		tmpStr := array[7];		
		pxyTI.setPropertyValue(CM_TrackedItem::destinationPort.name, tmpStr[1:5]);
		tmpStr := array[8];		
		pxyTI.setPropertyValue(CM_TrackedItem::commodity.name, tmpStr[1:5]);
		tmpStr := array[8];		
		//pxyTI.setPropertyValue(CM_TrackedItem::weight.name, tmpStr.Integer);					//-cnwml2 MSL CCMS 1017
		pxyTI.setPropertyValue(CM_TrackedItem::totalWeight.name, tmpStr.Integer);				//+cnwml2 MSL CCMS 1017

		pxyTI.setMyVoyage(voyage, passport);		

	endwhile;

	write 'Creating new cargo... ' &amp; control.allTransientTIs.size.String;
	
	app.myTrxCA.trxCreateTrackedItems(control, passport);
	
	if passport.hasErrorsOrWarnings then
		passport.inspect;
		return;
	endif;
	
	write 'Number of cargo items created - ' &amp; control.allPersistentTIs.size.String;
	if control.allPersistentTIs.isEmpty then
		return;
	endif;

	app.doWindowEvents(10000);
	create tmpMoveController transient;	
	tmpMoveController.isForcedMove 	:= true;
	tmpMoveController.isSystemMove 	:= true;
	tmpMoveController.setMoveMode(REAL_MODE);
	tmpMoveController.setMyTrackedItem(control.allPersistentTIs.first);
	tmpMoveController.setAllOtherTrackedItems(control.allPersistentTIs);
	tmpMoveController.allOtherTrackedItems.remove(tmpMoveController.myTrackedItem);
	vehicle := CM_VehicleController.firstInstance;
	tmpMoveController.setMyToPrimaryLocation(vehicle);
	tmpMoveController.setPropertyValue('myToTerminal', term);
	
	//move to vehicle
	write 'Moving to vehicle... ' &amp; control.allPersistentTIs.size.String;	
	app.myTrxUA.trxMoveTrackedItem(tmpMoveController, app.myPassport);

	//now to yard
	blockStack := CM_SubBlockStack.lastInstance.myLocationsController;
	tmpMoveController.setMyToPrimaryLocation(blockStack);
	
	write 'Moving items to yard location - ' &amp; blockStack.getFullId();
	app.myTrxUA.trxMoveTrackedItem(tmpMoveController, app.myPassport);
		
	write 'Finished reading from file - ' &amp; lineNo.String &amp; ' items';


epilog
	if tmpFile.isAvailable then
		tmpFile.close;
	endif;
	delete tmpMoveController;
	control.allTransientTIs.purge;
	delete array;
	delete tmpFile;
	delete control;
	delete pxyProduct;
	delete tiSet;
end;

</source>
    </JadeMethod>
