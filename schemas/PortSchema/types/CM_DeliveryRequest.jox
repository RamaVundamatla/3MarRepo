    <JadeMethod name="getRemainingAmountForJob" id="ef791ea9-1c6f-4ecd-9133-01983233356a">
        <source>getRemainingAmountForJob(_job : CM_Job) : String;
/*

Date		Who		Reason
15 September 2015	cnwer1	Initial creation PAR 36908

*/

vars
	amount : String;
	wle 	: CM_WorkListEntry;
	invalid : Boolean;
	amountWeight 	: Decimal[14,4];
	amountQuantity : Integer;
begin
	
	on Exception do app.handleDeletedObject( exception, wle, invalid );
	foreach wle in self.allWorkListEntries do
		invalid := false;
		if wle.status = WLE_COMPLETED then
			continue;
		endif;
		if invalid then
			continue;
		endif;
		if  wle.job &lt;&gt; _job then
			continue;
		endif;
		if self.myCargoType &lt;&gt; null and self.myCargoType.isBulkMulti then
			amountWeight:=amountWeight + wle.weight;
		else
			amountQuantity:= amountQuantity + wle.quantity.max(1);
		endif;
	endforeach;
	
	if amountWeight &gt; 0 then
		return self.myCargoType.getBulkTrackByDisplayForWeight(amountWeight,self.getDensityFromCargoType,true);
		
	else
		return amountQuantity.asStringJMT;
	endif;
	
	
epilog
	
end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRemainingTotalRequested" id="c88e420c-f44f-4d7d-b018-d2f38e7c241e">
        <source>getRemainingTotalRequested():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 April 2014	cnwndl1	Initial creation

*/

vars

	remTotRequested : Integer;
	wle : CM_WorkListEntry;
	invalid : Boolean;

begin

	remTotRequested:= self.totalRequested;

	if remTotRequested &lt;= 0 then
		remTotRequested := 0;
		return remTotRequested;
	endif;
	
	on Exception do app.handleDeletedObject( exception, wle, invalid );
	
	foreach wle in self.allWorkListEntries do
		invalid := false;
		if wle.status &lt;&gt; WLE_COMPLETED then
			continue;
		endif;
		if invalid then
			continue;
		endif;
		remTotRequested := remTotRequested - wle.quantity;
	endforeach;
	
	if remTotRequested &lt;= 0 then
		remTotRequested := 0;
	endif;
	
	return remTotRequested;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRemainingWeightRequested" id="15b539ab-b362-4164-9661-fa70557e9f36">
        <source>getRemainingWeightRequested():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 April 2014	cnwndl1	Initial creation

*/

vars

	remWeightRequested : Decimal[16,4];
	wle : CM_WorkListEntry;
	invalid : Boolean;

begin

	remWeightRequested:= self.weightRequested;

	if remWeightRequested &lt;= 0 then
		remWeightRequested := 0;
		return remWeightRequested;
	endif;
	
	on Exception do app.handleDeletedObject( exception, wle, invalid );
	
	foreach wle in self.allWorkListEntries do
		invalid := false;
		if wle.status &lt;&gt; WLE_COMPLETED then
			continue;
		endif;
		if invalid then
			continue;
		endif;
		remWeightRequested := remWeightRequested - wle.weight;
	endforeach;
	
	if remWeightRequested &lt;= 0 then
		remWeightRequested := 0;
	endif;
	
	return remWeightRequested;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getRequestDetailByAttribute" id="c8c78e81-5ef2-4e89-bf5a-b7c1312492c3">
