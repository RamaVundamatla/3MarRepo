	appGrid.dblClick(appGrid);	
end;</source>
        <Parameter name="table" type="CnEcAppGridTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dragDrop" id="761ccd4a-ebad-4438-b1d2-324af8404631">
        <updating/>
        <source>dragDrop(table: CnEcAppGridTable input; win: Window input; x: Real; y: Real) updating;

vars

begin
	if table = appGrid.gridTable then
        appGrid.appLabel := null;
		appGrid.dragDrop(appGrid, win, x, y);
	endif;
end;</source>
        <Parameter name="table" type="CnEcAppGridTable" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="dragOver" id="9499baf5-2006-45cd-820a-23296466107d">
        <updating/>
        <source>dragOver(table: CnEcAppGridTable input; win: Window input; x: Real; y: Real; state: Integer) updating;

vars

begin
	if table = appGrid.gridTable then
		appGrid.dragOver(appGrid, win, x, y, state);
	else
		appGrid.appInfo.visible := false;
		appGrid.dragOver(appGrid, win, x - appGrid.gridPlane.left, y - appGrid.gridPlane.top, state);
	endif;
end;</source>
        <Parameter name="table" type="CnEcAppGridTable" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="c980b2f3-bc07-49c7-9f9b-24281f7aea6c">
        <updating/>
        <source>mouseDown(table: CnEcAppGridTable input; button: Integer; shift: Integer; x: Real; y: Real) updating;

vars

begin
	// If in print preview mode ...
	if app.printer.printPreview then
		// ...disable event handling
		return;
	endif;
	appGrid.appLabel := null;
	appGrid.deselectAll();
	appGrid.changeType := appGrid.ChangeType_NoChange;
	appGrid.appInfo.visible := false;
	
	if table = appGrid.gridTable then
		appGrid.mouseDown(appGrid, button, shift, x, y);
	else
		appGrid.mouseDown(appGrid, button, shift, x - appGrid.gridPlane.left, y - appGrid.gridPlane.top);
	endif;
end;</source>
        <Parameter name="table" type="CnEcAppGridTable" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="5aa871a6-5dc2-4244-bbfe-1231ce7e3a7c">
        <updating/>
        <source>mouseUp(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;

vars

begin
	// If in print preview mode ...
	if app.printer.printPreview then
		// ...disable event handling
		return;
	endif;
	if table = appGrid.gridTable then
		appGrid.mouseUp(appGrid, button, shift, x, y);
	else
		appGrid.mouseUp(appGrid, button, shift, x - appGrid.gridPlane.left, y - appGrid.gridPlane.top);
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="scrolled" id="c4361a82-cf53-4806-b566-710a03997e9d">
        <updating/>
        <source>scrolled(table: CnEcAppGridTable input; scrollBar: Integer) updating;

vars
	int : Integer;

begin
	inheritMethod(table, scrollBar);
	
	if scrollBar = Window.ScrollBar_Vertical then
		int := appGrid.appGridTable.topRow - appGrid.topRow;
	else
		int := appGrid.appGridTable.leftColumn - appGrid.leftColumn;
	endif;
	
	appGrid.scrollAppLabels();
	appGrid.scrollDirection := int;
	appGrid.scrolled(appGrid, scrollBar);
	appGrid.scrollDirection := 0;	
end;</source>
        <Parameter name="table" type="CnEcAppGridTable" usage="input"/>
        <Parameter name="scrollBar" type="Integer"/>
    </JadeMethod>
