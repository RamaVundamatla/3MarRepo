    <JadeMethod name="tblDataToDo_updateTS" id="54f349fb-234a-4519-a6f1-d79517160a3f">
        <controlMethod name="MB_TasksTable::updateTS"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDataToDo_updateTS(_taskCode: Integer; _timeStamp: TimeStamp):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		02 February 2006 by cnwdad1
//
// Purpose:		Updates the completed timestamp on the specified To-Do Task.
//
// Parameters:	_taskCode - The unique To-Do Task code.
//				_timeStamp - The timestamp to set on the Task.
//
// Returns:		True if the update was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return doUpdateToDoTaskTs(_taskCode, _timeStamp);
end;</source>
