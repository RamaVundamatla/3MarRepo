<Class name="CM_EDIFileTypeCSVTranship" id="989d5c4d-cef6-4c4b-8bca-c1fa14f82c25">
    <superclass name="CM_EDIFileTypeCSV"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="create" id="88d70651-d50b-4863-b651-022fd9d0628c">
        <updating/>
        <source>create() updating;

vars

begin
	self.name	:= "Transhipment";
	self.type	:= EDIFileType_CSVTranship;
end;</source>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="0ead7f51-7810-4328-8575-a1ff2c88fe1e">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType, _fileTypeCode: Integer io); // cnwrs1 Par 24207 ccms 1117 11 May 2010

vars

begin
	_ediDataClass := CM_EDIDataTranship;
	_dataType := EDIDataType_Tranship;
end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_dataType" type="Integer" usage="io"/>
        <Parameter name="_fileTypeCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getMyOperator" id="49c968fd-0bb7-4ccf-8e26-0191360bb57b">
        <source>getMyOperator(): CM_Operator;

vars

begin
	return app.myRoot.allOperators["MSK"];
end;</source>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="1b681530-4ee6-46c8-bedf-c6b958cebc07">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) updating, protected;
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - commodity xlations
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	infoTI			: StringArray;
	numMsgs			: Integer;
	msgCount		: Integer;
	int 			: Integer;
	message			: String;
	tranship		: CM_EDITranshipTI;
	passport 		: CM_Passport;
	terminal		: CM_Terminal;
	ediDataTranship : CM_EDIDataTranship;
	operator  		: CM_Operator;
	comdtyString	: String;
	isoTypeString 	: String;
//	binaryLine		: Binary;
	foundMatch		: Boolean;
	theLines : HugeStringArray;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	passport := app.myPassport;	
	terminal := passport.myTerminal;
	operator := self.getMyOperator();
	
	ediDataTranship := _ediFile.ediData.CM_EDIDataTranship;
	create infoTI transient;
	create theLines transient;
	self.rawDataToHSA(_ediFile, theLines);
	numMsgs	:= theLines.size;
	foreach message in theLines do
		msgCount	:=	msgCount + 1;
		
		progressInt := app.actualTimeServer() - progressTS;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if passport.myCMIFMonitor &lt;&gt; null  and (progressInt.getMilliseconds &gt;= ProgressBarRefresh) then
			passport.myCMIFMonitor.updateProgressWithCaption("Processing File Data", numMsgs, msgCount, "Loading EDI file Step 3 of 3.");
			progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		int := int + 1;
		
		self.getTIInfo(message, infoTI);
	
		if not app.checkDigitContainerId(infoTI[1]) then
			continue;
		endif;
		
		create tranship persistent;
		tranship.setForCreateNew(ediDataTranship);
		tranship.setId(infoTI[1]);
		tranship.setBookingRef(infoTI[2]);
		isoTypeString:=infoTI[5]; //par 13088 cnwrs1 dec 2006
		if isoTypeString &lt;&gt; null then
			isoTypeString:= operator.getXlationSystemCode(isoTypeString, XLATION_TYPE_ISOTYPE_BYOP, foundMatch);
		endif;
		tranship.setIsoType(isoTypeString);
		tranship.setDischargePort(infoTI[6]); //par 13088 cnwrs1 dec 2006
		tranship.setDestinationPort(infoTI[7]); //par 13088 cnwrs1 dec 2006
		
		comdtyString:=infoTI[8]; //par 13088 cnwrs1 dec 2006
		tranship.setWeight(infoTI[9].Integer); //par 13088 cnwrs1 dec 2006
		tranship.setTemperature(infoTI[10].Real); //par 13088 cnwrs1 dec 2006
		
		// par 31259 - do commodity xlation after we have set temperature.
		if comdtyString &lt;&gt; null then
			comdtyString := operator.getXlationSystemCode_Commodity(comdtyString, foundMatch, tranship.temperature);
		endif;
		tranship.setCommodity(comdtyString);
	endforeach;
epilog
	delete theLines;
	delete infoTI;
end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
</Class>
