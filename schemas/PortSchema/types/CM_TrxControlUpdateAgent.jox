    <JadeMethod name="trxUpdateWagonsConfirmOut" id="3ad0084d-6c0e-4bd6-9034-c0d8dc26ed15">
        <updating/>
        <source>trxUpdateWagonsConfirmOut(	_moveController : CMIF_WagonMoveController; 	
							_wagonArray 	: CM_WagonArray input; 
							_confirm 		: Boolean;
							_passport 		: CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Aug 2009	cnwndl1	Initial creation
25 Oct 2024 navma1 MTN-33231 MTN - Enable Deferred Updates For Train and Wagon Events 
*/

vars
	wagon : CM_Wagon;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	_passport.useEventDeferUpdate := true;				//25.10.2024 navma1 #MTN-33231
	
	beginTransaction;

	foreach wagon in _wagonArray do
		app.myUtilityUA.utlUpdateWagonConfirmOut( _moveController, wagon, _confirm, _passport);
		if _passport.hasErrors then
			break;
		endif;
	endforeach;
	
	if _passport.noErrors then				//25.10.2024 navma1 #MTN-33231
		_passport.doDeferredUpdates();
	endif;

epilog

	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_moveController" type="CMIF_WagonMoveController"/>
        <Parameter name="_wagonArray" type="CM_WagonArray" usage="input"/>
        <Parameter name="_confirm" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateWagonsFromCMIFs" id="59acac1f-570d-47c3-b478-e59a8e66e792">
        <updating/>
        <source>trxUpdateWagonsFromCMIFs(	_wagonControllers : CMIF_Array input;
							_passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	cmifObj : CMIF_Object;
	wagonController : CMIF_WagonUpdateController;
	
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	
	foreach cmifObj in _wagonControllers do
	
		wagonController := cmifObj.CMIF_WagonUpdateController;
		
		app.myUtilityUA.utlUpdateWagonFromCMIF(wagonController, false, true, _passport);
	
		if _passport.hasErrors then
			return;
		endif;
	
	endforeach;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_wagonControllers" type="CMIF_Array" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
