    <JadeMethod name="setTIComplete" id="9ad203e8-c53b-44d2-8900-0242f28a9e53">
        <updating/>
        <source>setTIComplete(_theTI: CM_TrackedItem;_todoTaskDesc : CM_ToDoTaskDesc) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Aug 2018	jlgndl1	Initial creation	TFS 40216
10 Sep 2021 navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
15 Mar 2023 navhl20 ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
*/

constants

	Separator = " - ";
vars

	voyage 		  	 : CM_Voyage;
	term 		  	 : CM_Terminal;
	cargoTypeDesc  	 : String;
	now 		  	 : TimeStamp;
	localTS 	  	 : TimeStamp;
	user 		  	 : CM_User;
	emailEntity   	 : CM_EmailEntity;
	alertDescription : String;
	toAddress 		 : String;
	fromAddress 	 : String;
	subject 		 : String;
	body 			 : String;

begin

	inheritMethod(_theTI,_todoTaskDesc);					//27.03.2023 navma1 #56614:[56615]
	
	voyage 	:= _theTI.myVoyage;
	term 	:= _theTI.myTerminal;
	user 	:= self.getMyParent.myEnteredByUser;
	
	if term = null or voyage = null or user = null then
		return;
	endif;
	
	/* 10.09.2021 navma1 #51002
	if voyage.myVoyageProcess = null or voyage.myVoyageProcess.isDefaultProcessJMT then
		return;
	endif;
	*/
	emailEntity := user.myEmailEntity;
	
	if emailEntity = null then
		return;
	endif;
	
	toAddress 	:= emailEntity.getEmailAddress().trimBlanks;
	fromAddress := term.getConfig(CamsEmailAddress).String;	//28 Aug 2018	NDL	TFS 40199 - moved up and tested
	
	if toAddress = null or fromAddress = null then
		return;
	endif;
	
	cargoTypeDesc    := _theTI.cargoTypeDescr;
	now			  	 := app.actualTimeAppServer;
	localTS 	  	 := now.systemToLocalTimeUsingObject(term);	
	alertDescription := app.getErrorString1( CT_Task_completed, cargoTypeDesc );
	
	//subject := _theTI.id &amp; " " &amp; alertDescription &amp; Separator &amp; self.myToDoTaskDesc.description;												//15.3.2023 navhl20	#56614[56615]
	subject := _theTI.id &amp; " " &amp; alertDescription &amp; Separator &amp; self.allToDoTasksDescs.listString(Comma,CM_ToDoTaskDesc::description.name);		//15.3.2023 navhl20	#56614[56615]
	
	body := app.getErrorString( Terminal )    &amp; Separator &amp; term.name &amp; CrLf
			&amp; cargoTypeDesc 			      &amp; Separator &amp; _theTI.id &amp; CrLf
			//&amp; app.getErrorString( Task )      &amp; Separator &amp; self.myToDoTaskDesc.description &amp; CrLf											//15.3.2023 navhl20	#56614[56615]
			&amp; app.getErrorString( Task )      &amp; Separator &amp; self.allToDoTasksDescs.listString(Comma,CM_ToDoTaskDesc::description.name) &amp; CrLf	//15.3.2023 navhl20	#56614[56615]
			&amp; app.getErrorString( Completed ) &amp; Separator &amp; localTS.asStringJMT;
	
	app.myTrxCA.trxCreateEmailSendRequest(	alertDescription,		//_alertDescription : String;
											toAddress,				//_toAddress : String;
											fromAddress,			//_fromAddress : String;
											null,					//_ccAddresses : String;
											null,					//_bccAddresses : String;
											subject,				//_sendSubject : String;
											body,					//_sendMessage : String;
											null,					//_allAttachedFilePaths : HugeStringArray;
											null,					//_allFileData : CM_FileDataStorageHdrSet input;
											null,					//_blob : Binary;
											null,					//_blobFileName : String;
											EmailSource_WorkOrder,	//_sourceOfEmail : Integer;
											null,					//_updateCallbackObj : Object;
											app.myPassport			//_passport : CM_Passport input
											);
epilog

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_todoTaskDesc" type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="setToDoDetails" id="313c0963-c7ed-4e21-b7c3-3ab572bf6986">
        <updating/>
        <source>setToDoDetails(_remark : String; _priority : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Jul 2024 navhl20	ChangeRequest 65468: EUP -  VAS Mobile App - Enable Remarks for ToDo Tasks on Cargo Work Orders

*/

vars

begin
	self.remarks 	:= _remark;
	self.priority	:= _priority;
epilog

end;</source>
