<Class name="HMS_BerthPreferenceVoyageData" id="824db4ae-2954-43b6-a4b2-145635d0c7de">
    <superclass name="HMS_BerthPreference"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="harbour"/>
    <ExplicitInverseRef name="myVoyageData" id="00516e53-1e14-42d5-afda-f3d965487b20">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="HMS_VoyageData"/>
        <access>readonly</access>
        <Inverse name="HMS_VoyageData::allBerthPreferencesArray"/>
        <Inverse name="HMS_VoyageData::allBerthPreferencesByName"/>
    </ExplicitInverseRef>
    <JadeMethod name="pxyCreateUpdateProxy" id="015343b9-d83b-43bd-9827-43f9542d4ce0">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------
// Created:	24 August 2004 By: cnwgd1
//--------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy : SelfType;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="0fce3846-c882-4457-aa61-4345441f0bdb">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	24 August 2004 By: cnwgd1
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
//--------------------------------------------------
vars
	tmpPref,
	realPref,
	existingPref : HMS_BerthPreference;
	tmpBerthArray : HMS_BerthPrefArray;
begin
	inheritMethod(_passport);
	if _passport.hasErrors() then
		return;
	endif;
	if self.myVoyageData = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Voyage', ETRow_Voyage,  null);
		app.raiseCMException(Input_required_field_voyage, ETRow_Voyage,  null); // cnwdb2	PAR 35364
		return;
	endif;		
	//---------------------------------------------------------------------------
	// Check for duplicates
	//---------------------------------------------------------------------------
	if self.isTransient then		
		realPref := self.pxyGetRealObject();
	endif;
	tmpBerthArray := self.myVoyageData.allBerthPreferencesArray;
	foreach tmpPref in tmpBerthArray do
		if tmpPref = self then
			continue;
		endif;
		if tmpPref = realPref then
			continue;
		endif;		
		if tmpPref.isTransient then
			existingPref := tmpPref.pxyGetRealObject();
		endif;
		if existingPref &lt;&gt; null then
			if existingPref = realPref then
				continue;
			endif;
		endif;
		
		if tmpPref.berthName = self.berthName then
			//app.raiseCMException2(DuplicateItem, 'Berth Preference', self.berthName, ETRow_MyBerth, null); //14.06.2022 navds20 53760
			// Berth Preference already exists for %1 : Berth_prefere_already_exists
			app.raiseCMException1(Berth_prefere_already_exists, self.berthName, ETRow_MyBerth, null); //14.06.2022 navds20 53760
			return;		
		endif;
	endforeach;

	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
