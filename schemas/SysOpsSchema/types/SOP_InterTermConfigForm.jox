    <JadeMethod name="handleViewMode" id="d3d4f474-ca4a-4905-ba87-f255ed042ab2">
        <updating/>
        <source>handleViewMode(_viewing : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	conkc1	Initial creation

*/

vars

begin
	if _viewing = true then
		//lblReleaseMask.width       := grpReleaseDetail.width;
		//lblReleaseMask.height      := grpReleaseDetail.height;
		lblReleaseMask.width       := self.clientWidth;
		lblReleaseMask.height      := self.btnAdd.top - self.grpSource.top;
	else
		lblReleaseMask.width       := 1;
		lblReleaseMask.height      := 1;
	endif;
	self.btnAddDest.enabled        := not _viewing;
	self.btnEditDest.enabled       := not _viewing; 
	self.btnDeleteDest.enabled     := not _viewing;

epilog

end;</source>
        <Parameter name="_viewing" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resetForm" id="df7d8e64-020c-4225-ac2a-1798f2ef7425">
        <updating/>
        <source>resetForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
01 February 2010	conkc1	Initial creation

*/
vars

	terminalObj      : CM_Terminal;
	interTermConfig  : CM_InterTerminalConfig;
	index            : Integer;
	
begin
	
	terminalObj	:=	self.myTerminal;

	self.clearAll;
	btnEdit.enabled    := false;
	btnDelete.enabled  := false;
	btnAdd.enabled     := true;

	self.cmbConfigName.clear;
	foreach interTermConfig in terminalObj.allInterTerminalConfigs do
		index := self.cmbConfigName.addItem(interTermConfig.configName);
		self.cmbConfigName.itemObject[index] := interTermConfig;
	endforeach;

	self.disableControls;	

	if self.cmbConfigName.listCount = 0 then
		self.clearAll;
		self.setupForAdd;
		setupFormWithObject(Mode_Add);
		self.vMode := Mode_Add;
		self.handleViewMode(false);
		tbxConfigName.setFocus;
	endif;
	
	if self.myInterTerminalConfig &lt;&gt; null then
		self.cmbConfigName.listIndex := self.cmbConfigName.findObject(self.myInterTerminalConfig);
		self.cmbConfigName.click(self.cmbConfigName);
		self.handleViewMode(true);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetMyReferences" id="ff0d6a33-5ff4-4c93-95d2-db16afd168ee">
