    <JadeMethod name="getCargoType" id="73fbc34a-eb9f-4a68-ad63-d34e71fdcd5d">
        <source>getCargoType(): CM_CargoType;
/*
----------   ----------  --------------------------------------------------
Created:	30 May 2007 By cnwth2

Purpose:	

Changed On   	Changed By  Reason
25 Mar 2024  	navma1		ChangeRequest 63141: MTN - Code Refactor to improve finding matching cargo items using reserve details
28 Oct 2025		jlizm1		MTN 36255 Rotabox Assign Release To Vessel
----------   ----------  --------------------------------------------------
*/
vars
	invalid   : Boolean;
	product   : CM_Product;
	cargoType : CM_CargoType;
begin
	on Exception do app.handleDeletedObject(exception, self.myProduct, invalid); 
	//epr par 34406 25/6/14
	
	if self.myCargoType &lt;&gt; null and self.myCargoType.isContainer then
		// rotatable containers can have a product, but want to show them as containers
		return self.myCargoType;
	endif;
	
	product := self.myProduct;						//25.03.2024 navma1 #63141
	
	if product &lt;&gt; null then
		cargoType := product.myCargoType;			//25.03.2024 navma1 #63141
		if cargoType &lt;&gt; null then
			return cargoType; 
		endif;
	endif;
	if invalid then
		return null;
	endif;
	return self.myCargoType;

end;</source>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="getCargoTypeID" id="1cbdedd4-e61b-4b9f-89d3-ee27f5110654">
