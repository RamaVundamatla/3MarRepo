    <JadeMethod name="setCustDocFromTI" id="c1be1cfd-52f5-4011-b870-f0dd852621d2">
        <updating/>
        <source>setCustDocFromTI(_ti: CM_TrackedItem) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 12SEP2023
ADO - CR 59942 TASK 59943 

20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query
*/

vars
	custDocDetail : CM_CustomDocumentDetail;
	custDoc : CM_CustomDocument;
	stop : CM_Stops;

begin
	if _ti = null then
		return;
	endif;
	
	stop := _ti.getStop(self.stopID);
	if stop &lt;&gt; null then
		custDocDetail := stop.myCustomDocumentDetlAppliedBy;
		if custDocDetail &lt;&gt; null then
			custDoc := custDocDetail.getCustomDocumentHeader();
			if custDoc &lt;&gt; null then
				self.custDocCode := custDoc.code;
				self.custDocSequence := custDoc.sequence.String;
				if custDoc.myCustomLicense &lt;&gt; null then
					self.custDocLicense := custDoc.myCustomLicense.code;
				endif;
				self.custDocType := custDoc.myCustomDocumentType.code &amp; " " &amp; CM_CustomDocumentType@getDirectStrFromInt(custDoc.direction);
				
				//20/09/2023	navkc1	CR 60426 Task 60570
				if custDoc.myCustomsAgent &lt;&gt; null then
					self.custDocAgentCode := custDoc.myCustomsAgent.code;
				endif;
				
				if custDoc.myHSCode &lt;&gt; null then
					self.custDocHSCode := custDoc.myHSCode.id;
				endif;
				
				self.custDocDateTime := custDoc.dateTime;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="56bd0dde-0db9-4b3d-8347-6c18a1434b3a">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl( _tiTransCntrl : CMIF_TITransactionController; _passport : CM_Passport input ) updating;
//--------------------------------------------------
// Created:	20 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.eventRequestEnteredDT := _tiTransCntrl.eventRequestEnteredDT;
	self.isEventRequestStop := _tiTransCntrl.isEventRequest;
	self.remarks := _tiTransCntrl.remarks;
	self.systemGenerated := _tiTransCntrl.systemGenerated; //par19702 cnwrs1 May 2009
//	self.setStop(_tiTransCntrl.myStop);	// cnwrl1 01/09/2010 PAR 23697 - what it was
	if not app.isInProformaMode and not self.isStopAddDocAction then
		self.setStop( _tiTransCntrl );
	endif;
	
	if _passport.allTransMessages.size &gt;= TRXMSG_CEDO_VOYAGE_CHANGE then
		self.voyageChange := _passport.allTransMessages[TRXMSG_CEDO_VOYAGE_CHANGE];
	endif;
	
	inheritMethod( _tiTransCntrl, _passport );
	
	//05 Nov 2012	NDL	Par 30557
	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.isPreNote() then
		self.noCharge := true; // TFS 3844 prenotes are not charged for anything see CM_Bank::createCharge
	endif;
	
end;
</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyStop" id="22d62f17-b099-4851-b841-ab04a849de9f">
        <updating/>
        <source>setMyStop( _value : CM_Stops ) updating;

/*
Date				Who		Reason
01 September 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
begin

	if self.myStop &lt;&gt; _value then
		self.myStop	:= _value;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_value" type="CM_Stops"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="18aa1f05-1ffd-459e-880e-754dfc922902">
        <updating/>
        <source>setMyTrackedItem(pTI: CM_TrackedItem; _tiTransCntrl: CMIF_TITransactionController ) updating;
//----------------------------------------------------------------
//	Created:	20 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(pTI, _tiTransCntrl);

	self.onShip := pTI.site = TI_SITE_ONSHIP;

	self.setCustDocFromTI(self.myTrackedItem); // ### TFS CR 59942 TASK 59943 12SEP2023 NAVAB1
	
end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
    </JadeMethod>
    <JadeMethod name="setStop" id="9d88aa14-5f88-43aa-af8a-2cba64c96208">
        <updating/>
        <source>setStop( _tiTransCntrl : CMIF_TITransactionController ) updating, protected;
// setStop(_aStop: CM_Stops) updating, protected;	// cnwrl1 01/09/2010 PAR 23697 - what it was
//----------------------------------------------------------------
//	Created:	15 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	stop		: CM_Stops;
	realStop	: CM_Stops;
	stopsTable	: CM_StopsTable;
	
begin
	/* cnwrl1 01/09/2010 PAR 23697 - what it was
	stop := _aStop;
	
	if stop = null then
		self.stopDescription := "";
		self.stopID := null;
	else
		stopTable := stop.myStopsTable;
		if stopTable &lt;&gt; null then
			self.stopDescription := stopTable.heading;
		else
			self.stopDescription := "Stop " &amp; stop.id.String;
		endif;
		self.stopID := stop.id;
	endif;
	
	self.myStop := stop;
	cnwrl1 01/09/2010 PAR 23697 - end of what it was */
	
	// cnwrl1 01/09/2010 PAR 23697 - start of replacement coding
	// the stop and stopsTable have already been validated!
	stop					:= _tiTransCntrl.myStop;
	stopsTable				:= stop.myStopsTable;
	self.stopDescription	:= stopsTable.heading;
	self.stopID				:= stopsTable.id;
	
	if stop.isTransient then
		realStop		:= stop.pxyGetRealObject().CM_Stops;
		if realStop = null and _tiTransCntrl.myTrackedItem &lt;&gt; null then
			realStop	:= _tiTransCntrl.myTrackedItem.getStop( self.stopID );
		endif;
		self.setMyStop( realStop );
	else
		self.setMyStop( stop );
	endif;
	// cnwrl1 01/09/2010 PAR 23697 - end of coding
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
    </JadeMethod>
    <JadeMethod name="validateCMIF_TITransCntrl" id="7e4139df-1722-4c95-9c62-4fc9ca531287">
        <source>validateCMIF_TITransCntrl( _tiTransCntrl : CMIF_TITransactionController ) : Boolean;
//--------------------------------------------------
// Created:	31 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
//	return inheritMethod(_tiTransCntrl);	// cnwrl1 01/09/2010 PAR 23697 - what it was
	
	if not app.isInProformaMode then
	// cnwrl1 01/09/2010 PAR 23697 - start of replacement coding
		if _tiTransCntrl.myStop = null and not self.isStopAddDocAction then
		//	app.raiseCMException1( REQUIRED_FIELD, 'myStop', null, null );
			app.raiseCMException(Input_required_field_myStop, null, null ); // cnwdb2	PAR 35364
		elseif not self.isStopAddDocAction and  _tiTransCntrl.myStop.myStopsTable = null then
		//	app.raiseCMException1( REQUIRED_FIELD, 'myStopTable', null, null );
			app.raiseCMException(Input_required_field_myStopTab, null, null ); // cnwdb2	PAR 35364
		endif;
	endif;
	
		return inheritMethod( _tiTransCntrl );
	
	// cnwrl1 01/09/2010 PAR 23697 - end of coding
	
end;
</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
