    <JadeMethod name="bypassTokens" id="266157ee-df03-435e-9193-b2e59accd75e">
        <updating/>
        <source>bypassTokens(numberToBypass : Integer; _data : String io; _pos : Integer io) updating;

vars
	token : String;
	count : Integer;
begin
	foreach count in 1 to numberToBypass do
		token := _data.getToken(_pos);
	endforeach;
	
	return;
end;</source>
        <Parameter name="numberToBypass" type="Integer"/>
        <Parameter name="_data" type="String" usage="io"/>
        <Parameter name="_pos" type="Integer" usage="io"/>
    </JadeMethod>
