    <DbClassMap file="_usergui"/>
    <JadeMethod name="create" id="d4a88c1e-dc6c-4749-8ae5-b222bc68f49e">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
    self.borderStyle	:= BorderStyle_Single;
    self.alignment		:= Alignment_Center_Middle;
end;</source>
    </JadeMethod>
    <JadeMethod name="setMaximumFontSize" id="0ea1c66f-842f-439a-896c-01fef97cc3e4">
        <updating/>
        <source>setMaximumFontSize() updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Will set the font size of the receiver to its maximum (within
//				limits), which can continue to accomodate the current caption.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	MINIMUM_FONT_SIZE	: Integer = 6;
	STEP_SIZE			: Integer = -1;
    PIXELS_PER_POINT	: Real = 96 / 72;

vars
	maximumFontSize		: Integer;

begin
	maximumFontSize := (self.clientHeight() / PIXELS_PER_POINT).Integer;
	
	foreach self.fontSize in maximumFontSize to MINIMUM_FONT_SIZE step STEP_SIZE do
		if self.getTextHeight(self.caption) &lt; self.clientHeight() then
			break;
		endif;
	endforeach;		

	foreach self.fontSize in self.fontSize to MINIMUM_FONT_SIZE step STEP_SIZE do
		if self.getTextExtent(self.caption) &lt; self.clientWidth() then
			break;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
