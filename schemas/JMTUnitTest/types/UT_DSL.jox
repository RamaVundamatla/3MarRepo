    <JadeMethod name="ediVerifyErrors" id="48362289-a583-455a-92e8-7929f41bed36">
        <source>ediVerifyErrors(_ediText, _userDefinedName, _fileName: String; _ediFileType: Integer): CM_EDIFile protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2025	navsck1	Initial creation

*/

vars
	
	ediFile 	: CM_EDIFile;	
	tempStr		: String;
	
begin
	
	ediFile := self.ediLoadFileName(_ediText, _ediFileType, _userDefinedName, _fileName);		
	self.assertNotNull(ediFile);
	
	self.ediVerify(ediFile);
	tempStr	:= 'EdiFile verify status should be failed instead of verified';
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr);
	return ediFile;

epilog	
	
end;</source>
