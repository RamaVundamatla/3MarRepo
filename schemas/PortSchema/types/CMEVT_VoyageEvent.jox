    <JadeMethod name="matchesShift" id="2728fe29-b788-44af-9c93-a8dc94da61f2">
        <source>matchesShift(_shift: CM_Shift input): Boolean;
/*
Purpose:			
Date		Who		Reason
08 February 2017	cnwab1	Initial creation
*/

vars

begin
	if _shift = null then
		return inheritMethod(_shift);
	endif;
	
	if self.shiftCode &lt;&gt; null and _shift.code &lt;&gt; self.shiftCode then
		return false;
	endif;
	
	return _shift.startDateTime = self.shiftStart and _shift.endDateTime = self.shiftEnd;
epilog

end;</source>
        <Parameter name="_shift" type="CM_Shift" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="533b8440-ceaa-473e-a3f1-735f80bfc5f8">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Date		Who		Reason
10/12/2014	cnwer1	Initial creation PAR
20/04/2017	cnwdap1	TFS 4174 LNX Additional Information in Voyage Events
*/

vars
	proxy : SelfType;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	
	if proxy &lt;&gt; null then
		proxy.myVoyage 	:= self.myVoyage;
		proxy.shiftCode := self.shiftCode; // TFS 3217
		proxy.shiftStart := self.shiftStart; // TFS 3217
		proxy.shiftEnd := self.shiftEnd; // TFS 3217
		
		proxy.myJob := self.myJob;						// TFS 4174
		proxy.myJobSheet := self.myJobSheet;			// TFS 4174
	endif;
	
	//24 Aug 2018	NDL	TFS 40309
	proxy.myVoyageDelay := self.myVoyageDelay;
	
	completedOK := true;			
	return proxy;
epilog
	if not completedOK then			
		delete proxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
