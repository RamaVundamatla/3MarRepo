    <JadeMethod name="setMaxNumIcons" id="cbbb1820-415d-4334-92cf-b7a6eb8828dc">
        <updating/>
        <source>setMaxNumIcons( _ti : CM_TrackedItem) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2010	cnwjk3	PAR 23760

*/

vars
	tiLen : Real;
begin
	if _ti.isKindOf(CM_Container) then
		return;	// Containers work ok as they are
	endif;

	tiLen := _ti.getLengthInMetres();
	
	// Try to work out how many icons we can fit based on the current scale factor and length of TI
	if self.scaleFactor = 0.5 then
		self.attrMaxNum := 1;
	elseif self.scaleFactor = 0.75 then
		self.attrMaxNum := 1;
	elseif self.scaleFactor = ScaleFactor_1 then
		if tiLen &lt;= 7 then
			self.attrMaxNum := 0;
		elseif tiLen &lt;= 9 then
			self.attrMaxNum := 5;		
		endif;
	elseif self.scaleFactor = ScaleFactor_1_5 then
		if tiLen &lt;= 5 then
			self.attrMaxNum := 0;
		elseif tiLen &lt;= 6 then
			self.attrMaxNum := 2;
		elseif tiLen &lt;= 9 then
			self.attrMaxNum := 5;		
		endif;
	elseif self.scaleFactor = ScaleFactor_2 then
		if tiLen &lt;= 5 then
			self.attrMaxNum := 0;
		elseif tiLen &lt;= 6 then
			self.attrMaxNum := 3;
		elseif tiLen &lt;= 9 then
			self.attrMaxNum := 6;		
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setTICollections" id="d3c9fc43-389e-4545-944e-0c6be1491a53">
        <source>setTICollections();
// ---------------------------------------------------------------------------
// Created:     01 September 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theTI : CM_TrackedItem;
begin
	self.allTempTIs.clear();
	self.allTIsA.clear();
	self.allTIsP.clear();
	self.allTIsQ.clear();
	self.myLocationsController.allTrackedItems.copy(self.allTIsA);
	self.myLocationsController.getAllQueuedTrackedItems(self.allTIsQ, true);
	self.myLocationsController.getAllPlannedTrackedItems(self.allTIsP, true, false);
	
	self.allTIsA.copy(self.allTempTIs);
	foreach theTI in self.allTIsQ do
		if not self.allTempTIs.includes(theTI) then
			self.allTempTIs.add(theTI);
		endif;
	endforeach;
	foreach theTI in self.allTIsP do
		if not self.allTempTIs.includes(theTI) then
			self.allTempTIs.add(theTI);
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setTmpPointArrayXYs" id="7a309640-ab51-4ad6-9fad-6a6a43fe4f5f">
        <source>setTmpPointArrayXYs(_x1, _y1,_x2, _y2 : Integer);
// ---------------------------------------------------------------------------
// Created:		30 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpPoint : Point;
begin
		self.tmpPointArray.clear;
		tmpPoint.set(_x1.Integer,_y1.Integer);
		self.tmpPointArray.add(tmpPoint);
		tmpPoint.set(_x2.Integer,_y1.Integer);
		self.tmpPointArray.add(tmpPoint);
		tmpPoint.set(_x2.Integer,_y2.Integer);
		self.tmpPointArray.add(tmpPoint);
		tmpPoint.set(_x1.Integer,_y2.Integer);
		self.tmpPointArray.add(tmpPoint);
		tmpPoint.set(_x1.Integer,_y1.Integer);
		self.tmpPointArray.add(tmpPoint);
end;</source>
