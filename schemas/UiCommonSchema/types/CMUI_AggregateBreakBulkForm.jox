    <JadeMethod name="validate" id="f30aa846-b38e-402a-8c30-8686056a3abc">
        <source>validate( _allTisToAggregate : CM_TISet input; _location : CM_LocationsController output; _operator : CM_Operator output ):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk

*/

vars

	index : Integer;
	msg : String;
	jadeRow : JadeTableRow;
	ti : CM_TrackedItem;
	bulkItem : CM_TrackedItem;
	cargoType : CM_CargoType;
	prod : CM_Product;
	foundHeight : Integer;
	id : String;
	itemPackagingWeightKgs : Decimal [16,4];
	testDensity : Decimal [16,4];
	descr : String;

begin

	_operator := self.myTrackedItem.myOperator;

	foreach index in 1 to self.tblRange.rows do
		jadeRow := self.tblRange.accessRow(index);
		if jadeRow.selected then
			ti := jadeRow.itemObject.CM_TrackedItem;
			if ti &lt;&gt; null then
				_allTisToAggregate.add(ti);
			endif;
		endif;
	endforeach;

	if _allTisToAggregate.isEmpty then
		msg := app.getErrorString(CMUI_Nothing_Selected);
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
		return false;
	endif;
	
	itemPackagingWeightKgs := self.tblPkgingWeight.getConvertedValue();
	foreach ti in _allTisToAggregate do
		if itemPackagingWeightKgs &gt; ti.totalWeight then
			msg := app.getErrorString1(Packa_weigh_not_great_than_tot, ti.id);
			app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
			return false;
		endif;
	endforeach;
	
	bulkItem := self.cmbIDs.listObject.CM_TrackedItem;
	if bulkItem &lt;&gt; null then
		if ( not bulkItem.isBulkByVolume ) and ( not bulkItem.isBulkByWeight ) then
			msg := app.getErrorString(Selec_exist_item_aggre_break_b);
			app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
			return false;
		endif;
		_location := bulkItem.myPrimaryActualLocation;
		
		if bulkItem.getDensity &lt;&gt; self.myTrackedItem.getDensity then
			msg := app.getErrorString2(Densi_value_cargo_items_must_m,  bulkItem.id &amp; " (" &amp; bulkItem.getDensity.asStringJMT &amp; ")", self.myTrackedItem.id &amp; " (" &amp; self.myTrackedItem.getDensity.asStringJMT &amp; ")" );
			app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
			return false;
		endif;
		
	else
		id := self.cmbIDs.text.trimBlanks.toUpper;
		if id = null then
			msg := app.getErrorString(Must_enter_choos_exist_item_ag);
			app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
			return false;
		endif;
		cargoType := self.cmbNewCargoType.listObject.CM_CargoType;
		if cargoType = null then
			msg := app.getErrorString(Select_cargo_type_continu);
			app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
			return false;
		else
			if cargoType.mySystemProductType &lt;&gt; null and cargoType.mySystemProductType.myDensityDec &lt;&gt; null then		// ### TFS 52193 22Nov2021 NAVPW1
				testDensity := cargoType.mySystemProductType.myDensityDec.getRawValue.Decimal;							// ### TFS 52193 22Nov2021 NAVPW1
				descr := cargoType.description;
			endif;
		endif;
		if cargoType.hasProductTypes then
			prod := self.cmbNewSubCargo.listObject.CM_Product;
			if prod = null then
				msg := app.getErrorString(Please_select_cargo_type_conti);
				app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
				return false;
			endif;
			if prod.myDensityDec &lt;&gt; null then							// ### TFS 52193 22Nov2021 NAVPW1
				testDensity := prod.myDensityDec.getRawValue.Decimal;	// ### TFS 52193 22Nov2021 NAVPW1
				descr := cargoType.description &amp;  "/" &amp; prod.description;
			endif;
		endif;
		
		if self.myTrackedItem.isBulkByVolume and testDensity &lt;&gt; self.myTrackedItem.getDensity then
			msg := app.getErrorString2(Densi_value_cargo_type_cargo_i, descr &amp; " (" &amp; testDensity.asStringJMT &amp; ")", self.myTrackedItem.id &amp; " (" &amp; self.myTrackedItem.getDensity.asStringJMT &amp; ")");
			app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
			return false;
		endif;
		
		if self.txtNewLocation.text &lt;&gt; null then
			self.myTerminal.findLocationFromString( self.txtNewLocation.text.trimBlanks, true, _location, foundHeight );
		endif;
		if _location = null then
			msg := app.getErrorString(Location_NotFound);
			app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
			return false;
		endif;
		foreach ti in _location.allTrackedItems do
			if ti.id &lt;&gt; id then
				continue;
			endif;
			if ti.myOperator &lt;&gt; _operator then
				continue;
			endif;
			if ti.myCargoType &lt;&gt; cargoType then
				continue;
			endif;
			if prod &lt;&gt; null and ti.myProduct &lt;&gt; prod then
				continue;
			endif;
			bulkItem := ti;
			break;
		endforeach;
		if bulkItem &lt;&gt; null then
			index := self.cmbIDs.findObject( bulkItem );
			if index &gt; 0 then
				self.cmbIDs.listIndex := index;
			endif;
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_allTisToAggregate" type="CM_TISet" usage="input"/>
        <Parameter name="_location" type="CM_LocationsController" usage="output"/>
        <Parameter name="_operator" type="CM_Operator" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
