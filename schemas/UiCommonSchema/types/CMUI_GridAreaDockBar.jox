    <JadeMethod name="setScrolledCallbackMethod" id="2694b205-45da-4c01-a518-dcf6aa93bf16">
        <source>setScrolledCallbackMethod(_methodName : String);
// ---------------------------------------------------------------------------
// Created:     24 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if self.myScrollableFrame = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'self.myScrollableFrame = null');
		return;
	endif;
	
	self.myScrollableFrame.scrolledCallbackMethod := _methodName;

end;</source>
        <Parameter name="_methodName" type="String"/>
    </JadeMethod>
