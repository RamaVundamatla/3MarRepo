<GUIClass name="MOB_CEScanMoveForm" id="785a7be9-7d57-41ef-a591-ec9a33f78330">
    <superclass name="MOB_CEScanLoadForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="addTIToTable" id="5b7d2eec-8ea9-4dc5-b212-f14705474dcc">
        <updating/>
        <source>addTIToTable(_tbl: CM_MobTable io; _item: CMIF_TIGenCargo) updating;
/*
	Created on 15 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	inheritMethod(_tbl, _item);
	if _item &lt;&gt; null then
		_tbl.accessCell(2,2).itemObject := _item.myNewLocation;
	endif;
end;</source>
        <Parameter name="_tbl" type="CM_MobTable" usage="io"/>
        <Parameter name="_item" type="CMIF_TIGenCargo"/>
    </JadeMethod>
    <JadeMethod name="findTIForCMIF" id="68fb189a-4d33-43e4-8928-5031c3cb019e">
        <source>findTIForCMIF(_id : String; _action : Integer output): CM_TrackedItem;
/*
/*
	Created on 07 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	ti : CM_TrackedItem;
begin
	ti := self.myMobileDataAgent.findOnsiteCargoByID(_id);
	if ti &lt;&gt; null then
		_action :=  CMIF_TIGenCargo.Action_Move;
	endif;
	return ti;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_action" type="Integer" usage="output"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getItemDisplay" id="f08be294-3d0d-48c6-b564-98bbe28621cf">
        <source>getItemDisplay(_cmifItem: CMIF_TIGenCargo): String;
/*
	Created on 21 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	item 			: CM_TrackedItem;
	cmifRec 		: CMIF_Receival;
	id, 
	booking,
	location,
	oldLocation : String;
begin
	item 	:= _cmifItem.myTrackedItem;
	cmifRec := _cmifItem.myCMIFReceival;
	if item &lt;&gt; null then
		id := item.id;
		booking := item.bookingReference;
		oldLocation := item.locationId;
	elseif cmifRec &lt;&gt; null then
		id := cmifRec.id;
		booking := "";
	endif;
	if _cmifItem.myNewLocation &lt;&gt; null then
		location := _cmifItem.myNewLocation.getFullId;
	endif;
	return id &amp; Tab &amp; location &amp; Tab &amp; booking &amp; Tab &amp; oldLocation;
end;</source>
        <Parameter name="_cmifItem" type="CMIF_TIGenCargo"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTableSettings" id="ecb8fa2f-fee9-4786-acc0-0a686cb6e52b">
        <source>getTableSettings(_columns: Integer output; _header: String output);
/*
	Created on 21 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
begin
	_columns := 4;
	_header := app.getErrorString(Cargo_ID) &amp; Tab &amp; app.getErrorString(NewLocation) &amp; Tab &amp; app.getErrorString(Order) &amp; '#' &amp; Tab &amp; app.getErrorString(Old_Location);
end;</source>
        <Parameter name="_columns" type="Integer" usage="output"/>
        <Parameter name="_header" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleF10Key" id="f2f4e348-0723-4a13-ab5c-2337bb6b1bba">
        <source>handleF10Key();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/04/2013	cnwdap1	Initial creation PAR #31378 CCMS PNL 2247 F10 key to enquire on bookings
*/
vars
	ti				: CM_TrackedItem;
	bookingRef 		: CM_BookingRef;
	desc			: String;
	invalidObject	: Boolean;
	form			: MOB_CEBookingRefForm;
	newItem			: Boolean;

begin
	on Exception do app.handleDeletedObject(exception, bookingRef, invalidObject);
	
	ti := self.getTrackedItemForRow(newItem);
	if ti = null then
		return;
	endif;
	if ti.myBookingRef = null then
		app.msgBox(app.getErrorString(Cargo_Item_No_Order_Number), "", MsgBox_OK_Only);
		return;
	endif;
	bookingRef := ti.myBookingRef;
	
	// check for deleted object
	desc := bookingRef.description;
	if invalidObject then
		return;
	endif;
	
	create form transient;
	form.setBookingRef(bookingRef);
	form.btn_Details.enabled := false;
	form.show;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadTable" id="3e80c9e8-7ecb-40a6-91b9-b25f2e3b8860">
        <updating/>
        <source>loadTable(tbl: CM_MobTable io) updating;
/*
	Created on 22 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	inheritMethod(tbl);
	self.txt_OrderCount.text := self.getLoadCountAsString;
end;</source>
        <Parameter name="tbl" type="CM_MobTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a8db163a-71e5-4d25-aa68-7de2fe3ad00b">
        <updating/>
        <source>setupForm() updating, protected;
/*
	Created on 21 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	ioc : CMIF_InOutCommon;
begin
	inheritMethod();
	
	self.lbl_Truck.caption := app.getErrorString(Moving_cargo_items);
	self.lbl_TruckNo.caption := '';
	self.btn_TruckDone.visible := false;
	self.loadCount := 0;
	self.txt_OrderCount.text := self.getLoadCountAsString;
	self.lbl_OrderCount.caption := app.getErrorString(TransType_5) &amp; ":";
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupItemTable" id="683cb296-a383-47be-8a98-14484d147b19">
        <source>setupItemTable(tbl: CM_MobTable input);
/*
	Created on 21 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	col : JadeTableColumn;
begin
	inheritMethod(tbl);
	col := tbl.accessColumn(2);
	col.enabled := true;
	col.inputType := tbl.InputType_TextBox;
end;</source>
        <Parameter name="tbl" type="CM_MobTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="2bbd2f82-8d38-4724-9f0e-3979aa6c5a8d">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018474, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="validateCargoID" id="a28ccd71-1949-4ad2-839c-38d1e61913d9">
        <source>validateCargoID(_id : String) : Boolean protected;
//01 July 2008	cnwdw1	PAR 17308
// If this is a valid cargo id return true, otherwise false
vars
	ti: CM_TrackedItem;
begin
	if _id = null then
		return false;
	endif;
	
	ti := self.myMobileDataAgent.findOnsiteCargoByID(_id);
	if ti &lt;&gt; null and ti.isChild then
		app.msgBox(app.getErrorString(ERR_NON_CHILD_OP), '', MsgBox_OK_Only);
		return false;
	endif;
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
