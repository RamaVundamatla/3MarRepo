    <JadeMethod name="loadCmbReleaseRequest" id="f34cce8e-acf1-4071-940a-f3db2d6d8bec">
        <source>loadCmbReleaseRequest() protected;
/*
----------   ----------  --------------------------------------------------
Created:	14 November 2006 By cnwth2

Purpose:	

Date		Who		Reason
02 Jun 2010	cnwkpd1	PAR #21919 - Speed up form load
// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 07/06/24		jlier1 TFS 64530 - performance improvements
*/

vars
	cmb					: CMUI_ComboBox;
	defaultRelease,
	release				: CM_BulkRelease;
	dict				: CM_BulkReleaseByTypeStCodeDict;
	iter				: Iterator;
	typeKey,
	statusKey			: Integer;
	codeKey				: String;
	dateReqKey			: TimeStamp;
	
begin
	cmb := self.cmbReleaseNo;
	cmb.clear();
	cmb.sorted := false;
		
	dict := self.myTerminal.allBulkReleaseByTypeByStByCd;
	iter := dict.createIterator;
	
	dict.startKeyGeq(BR_TYPE_RAIL,BR_PENDING,null,null, iter);
	
	dateReqKey := app.actualTimeServer();// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	while iter.next(release) do
		iter.getCurrentKeys(typeKey, statusKey, codeKey, dateReqKey);
		
		if typeKey &lt;&gt; BR_TYPE_RAIL or statusKey &gt; BR_ACTIVE then		// PAR #21919
			break;
		endif;
		
//		if statusKey &lt;&gt; BR_PENDING and statusKey &lt;&gt; BR_ACTIVE then
//			continue;
//		endif;
				
		cmb.itemObject[cmb.addItem(self.myAssistant.displayEntryBulkRelease(release))] := release;		
	endwhile;
	
	cmb.listIndex := cmb.findObject(defaultRelease);
	
	
epilog
	delete iter;
	
end;


</source>
        <access>protected</access>
    </JadeMethod>
