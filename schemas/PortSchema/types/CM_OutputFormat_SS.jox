    <JadeMethod name="getDefaultFunctionForProperty" id="8b406578-ab83-44d1-bcc7-1c8854111fe7">
        <source>getDefaultFunctionForProperty(_property :String):Integer;
// ---------------------------------------------------------------------------
// Created:     17 December 2009 by cnwcs5
// Purpose:     CCMS 1023 - snapshot summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	field	:CM_XTABField;
begin
	foreach field in self.allFields do
		if field.propertyName &lt;&gt; _property then
			continue;
		endif;
		return field.function;
	endforeach;
	app.raiseUnexpectedProgramError (self.class.name, method.name, 'Method called for invalid property &amp; (' &amp; _property &amp; ')');
epilog

end;</source>
        <Parameter name="_property" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFieldProperties" id="d8213fd1-887d-4885-9fcc-b95c0277b991">
        <source>getFieldProperties( _queryProperties : CM_QueryPropertyArray input );
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
07 December 2009	cnwndl1	Initial creation		CCMS 1023
15/12/2009			cnwcs5	Changed parameter type from io to input
							Check not adding same property to coll twice
*/
vars
	element : CM_XTABElement;
	prop : CM_QueryProperty;
begin
	_queryProperties.clear();
	
	foreach element in self.allFields do
		prop := element.getQueryProperty();
		if prop &lt;&gt; null and 
			not _queryProperties.includes (prop) then	// cnwcs5 15/12/2009
			_queryProperties.add(prop);
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_queryProperties" type="CM_QueryPropertyArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getFunctionsForProperty" id="a4f6a83c-0b02-417f-bcf1-f4123fbcd504">
        <source>getFunctionsForProperty(_property :String; _coll :IntegerArray input);
// ---------------------------------------------------------------------------
// Created:     15 December 2009 by cnwcs5
// Purpose:     CCMS 1023 - snapshot summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	field		:CM_XTABField;
	function	:Integer;
begin
	foreach field in self.allFields do
		if field.propertyName &lt;&gt; _property then
			continue;
		endif;
		
		function := field.function;

		if not _coll.includes (function) then
			_coll.add (function);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_property" type="String"/>
        <Parameter name="_coll" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getGroupingProperties" id="e8af492f-4b7b-4ef7-b006-d2c26b3d4913">
        <source>getGroupingProperties( _queryProperties : CM_QueryPropertyArray input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 December 2009	cnwndl1	Initial creation		CCMS 1023
14/12/2009			cnwcs5	Change parameter usage from io to input
*/

vars

	element : CM_XTABElement;
	prop : CM_QueryProperty;
	
begin

	_queryProperties.clear();
	
	foreach element in self.allGroupings do
		prop := element.getQueryProperty();
		if prop &lt;&gt; null then
			_queryProperties.add(prop);
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_queryProperties" type="CM_QueryPropertyArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="hasSnapShotProperties" id="9816b6c5-fe0b-4c96-aa60-eb419fb2f591">
        <source>hasSnapShotProperties() : Boolean;
// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
// return true if tracked item type and at least one query property has non-zero allocationAttribute
vars
	result	: Boolean;
	element : CM_XTABElement;
	prop : CM_QueryProperty;
begin
	if self.type = CM_QueryDefinition.TrackedItem_Query_Type then
		foreach element in self.allGroupings do
			prop := element.getQueryProperty();
			if prop &lt;&gt; null and
			   prop.allocationAttribute &lt;&gt; 0 then
				result := true;
				break;
			endif;
		endforeach;
	endif;
	
	return result;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasSummaryDefinitions" id="4aa88042-0f15-48b1-bee4-fb7b89c3a06f">
