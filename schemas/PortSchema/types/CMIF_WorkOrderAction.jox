    </CompAttribute>
    <ImplicitInverseRef name="allRBTObjects" id="a1327618-ce59-4a51-a1f2-b2c0ece5da85">
        <memberTypeInverse/>
        <type name="CM_WorkOrderRequestByTypeArray"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myWorkOrderDtl" id="2403cb6b-95bc-4fad-9d32-307d0cb18c75">
        <embedded/>
        <type name="CM_WorkOrderDtl"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myWorkOrderSchedule" id="00f2d129-e5dd-4ef0-be85-f052e6f3fdd5">
        <embedded/>
