    <JadeMethod name="getDisplayStringForAttribute" id="c8a1f3b3-f28e-4f95-804e-28a5508e545e">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2012	cnwndl1	Initial creation	Par 29496

*/

vars

begin

	if _attrName = ETRow_MyHarbour then
		if self.myHarbour &lt;&gt; null then
			return self.myHarbour.description;
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_Vessel then
		if self.myVessel &lt;&gt; null then
			return self.myVessel.getDisplayDetails(false); //epr par 30240 24/10/12
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_ValidatedBy then
		if self.myValidatedBy &lt;&gt; null then
			return self.myValidatedBy.description;
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_DateCertified then
		if self.certifiedDate.isValid then
			return self.certifiedDate.asStringJMT;
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_DateCertificateExpires then
		if self.expiryDate.isValid then
			return self.expiryDate.asStringJMT;
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_Revalidate then
		if self.revalidationDate.isValid then
			return self.revalidationDate.asStringJMT;
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_Dim_LengthOverall then
		if self.myVessel &lt;&gt; null then
			return self.myVessel.getDisplayStringForAttribute(ETRow_LengthOverall,false);
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_Dim_GrossRegTonnes then
		if self.myVessel &lt;&gt; null then
			return self.myVessel.getDisplayStringForAttribute(ETRow_GrossRegTonnes,false);
		else
			return null;
		endif;
	
	else
		return inheritMethod(_attrName, _short);
		
	endif;


epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
