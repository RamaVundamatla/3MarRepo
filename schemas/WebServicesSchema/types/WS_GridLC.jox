    <JadeMethod name="delete" id="26209e92-bdf2-4275-93bc-265844cd388b">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2017	jlger1	Initial creation 7521

*/

vars

begin

	self.allPdTIs.purge;
	self.allQdTIs.purge;
	self.allTIs.purge;
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="ac38f6db-3d3f-4433-9602-2179f1bab3cb">
        <updating/>
        <source>setProxyFromObject(_object: Object) updating;
// ---------------------------------------------------------------------------
// Created:     28 March 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpLC : CM_GridController;
	tmpTI : CM_TrackedItem;
	ws_TI : WS_TrackedItem;
	stackMax, numTI : Integer;
	tis: CM_TIArray;
begin
	inheritMethod(_object);

	tmpLC := _object.CM_GridController;
	stackMax := tmpLC.myTerminalArea.CM_GridArea.heightOfStack;
	
	self.offset := tmpLC.offsetFlexi;
	self.colCode := tmpLC.myGridColumn.label;
	self.isPrimaryForA := tmpLC.isPrimaryForMode(REAL_MODE);
	self.code := tmpLC.getFullId();
	
	// ### ACTUAL TIs
	foreach tmpTI in tmpLC.allTrackedItems discreteLock do
		numTI := numTI + 1;
		create ws_TI transient;
		ws_TI.setProxyFromObject(tmpTI);
		self.allTIs.add(ws_TI);
	endforeach;

	
	// ### QUEUED TIs
	create tis transient;
	tmpLC.getAllQueuedTrackedItems(tis,true);
	foreach tmpTI in tis discreteLock do
		if numTI &gt;= stackMax then
			break;
		endif;
		
		numTI := numTI + 1;
		create ws_TI transient;
		ws_TI.setProxyFromObject(tmpTI);
		self.allQdTIs.add(ws_TI);
	endforeach;

	// ### PLANNED TIs
	tmpLC.getAllPlannedTrackedItems(tis,true,false);
	foreach tmpTI in tis discreteLock do
		if numTI &gt;= stackMax then
			break;
		endif;
		
		numTI := numTI + 1;
		create ws_TI transient;
		ws_TI.setProxyFromObject(tmpTI);
		self.allPdTIs.add(ws_TI);
	endforeach;
	
	
epilog
	delete tis;
end;</source>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
</Class>
