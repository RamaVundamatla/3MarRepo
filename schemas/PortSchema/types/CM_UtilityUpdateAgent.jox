    <JadeMethod name="utlUpdateTimeSlot" id="f78901db-b234-4662-83b9-a0bd29d9fe81">
        <updating/>
        <source>utlUpdateTimeSlot(pProxyTimeSlot : CM_TimeSlotEntity input; _passport : CM_Passport input; isStandard : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     04 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realTimeSlot	: CM_TimeSlotEntity;
	expectedEdition	: Integer;
	
begin

	self.initialiseActivity();

	pProxyTimeSlot.raiseExceptionIfNotProxy(method);
	pProxyTimeSlot.pxyGetRealObjectAndEdition(realTimeSlot, expectedEdition);
	
	if realTimeSlot = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TimeSlotEntity.name, null, null);
		return;
	endif;

	app.setContinueCMExceptions(true);
	
	app.myValUA.valTimeSlot(realTimeSlot, _passport, isStandard);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
		
	exclusiveLock(realTimeSlot);

	if _passport.noErrors and realTimeSlot.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Time Slot Maintenance', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTimeSlot, true);
	endif;
	
	if _passport.noErrors then
		if isStandard then
			realTimeSlot.CM_TimeSlotStd.setForUpdate(pProxyTimeSlot.CM_TimeSlotStd);
		else
			realTimeSlot.CM_TimeSlot.setForUpdate(pProxyTimeSlot.CM_TimeSlot);
		endif;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTimeSlot, false);
	endif;

end;</source>
        <Parameter name="pProxyTimeSlot" type="CM_TimeSlotEntity" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="isStandard" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateToDoRequestStatus" id="efd0465c-6849-4d5b-b479-480b4f9cebac">
        <updating/>
        <source>utlUpdateToDoRequestStatus(_request:CM_Request input; _newStatus:Integer; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31 Mar 2025  navma1 		MTN-34387 MTN - Removing Unnecessary Audits
// ---------------------------------------------------------------------------
vars
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValUA.valToDoRequestStatus(_request, _newStatus);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(_request);

	if _passport.noErrors then
		_request.changeToDoTasksStatus(_newStatus, _passport);
	endif;

	if _passport.noErrors then
		if _request.myJob &lt;&gt; null then // AKB2002JULY
			app.myUtilityUA.utlUpdateJobStatus(_request.myJob, _passport);
		endif;
	endif;
	
end;</source>
        <Parameter name="_request" type="CM_Request" usage="input"/>
        <Parameter name="_newStatus" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
