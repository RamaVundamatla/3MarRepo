    <JadeMethod name="doResize" id="d777f1f3-5711-4f76-8afb-afb4119874ad">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

begin

	inheritMethod();
	
	self.grpEventDetail.left := 1;
	self.grpEvents.left := 1;
	
	self.grpEventDetail.top := self.frmToolbar.top + self.frmToolbar.height + 2;
	self.grpEvents.top := self.grpEventDetail.top + self.grpEventDetail.height;
	self.grpEvents.height := ( (self.height - self.grpEvents.top ) - 35 );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectEvent" id="ed139e44-9b42-4b8f-92b3-ee592e05ccde">
        <updating/>
        <source>doSelectEvent( _event : CM_EventTransaction ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

begin

	if _event = null then
		self.clearEditControls();
	else
		if _event.canBeDeleted then
			self.btnEditEvent.enabled := true;
			self.btnDelete.enabled := true;
		else
			self.btnEditEvent.enabled := false;
			self.btnDelete.enabled := false;
		endif;
		self.tblEvents.selectMode := Table.SelectMode_CurrentRow;
		
		self.cmbEventType.listIndex := self.cmbEventType.findObject( _event.myEventType );
		self.cmbEventType.enabled := false;
		self.txtDate.setDate(_event.dateTime.Date);
		self.txtTime.setTime(_event.dateTime.Time);
		self.setupCmbCharge( not _event.noCharge );
		if not _event.allInvoiceLines.isEmpty() then //cnwas3 begin
			self.btnInvoiceLine.enabled := true;
		else
			self.btnInvoiceLine.enabled := false;
		endif;										//cnwas3 end
	endif;
	
epilog

end;</source>
        <Parameter name="_event" type="CM_EventTransaction"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="ee398f39-4cfe-4906-bffe-0ae41d4efc27">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars
	xmlStr	: String;
begin

	xmlStr := inheritMethod();
	
	xmlStr := xmlStr &amp; self.tblEvents.getXmlStrForColumns(true);
	return xmlStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="13808520-4915-4b8e-882d-ef1da211374a">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars
	tmpTypeStr	: String;
begin
	inheritMethod(_userWindow);
	
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(ETDef_SysEventData);
	self.xmlStrTblEvents := tmpTypeStr.trimCharacters(CrLf);

epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initTblEvents" id="f55f20bc-177b-46ba-9948-a78d69855fce">
        <source>initTblEvents() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	entTableDef		: EntTableDef;
	
begin

	entTableDef := app.myController.getEntTableDef(ETDef_SysEventData);
	//self.tblEvents.setTblDataEntRowsFromView(entTableDef, null);
	
	if self.xmlStrTblEvents.trimBlanks &lt;&gt; null then
		self.tblEvents.setTblDataEntRowsFromXML(entTableDef, self.xmlStrTblEvents);
	else
		self.tblEvents.setTblDataEntRowsFromDef(entTableDef);
	endif;
	
	self.loadTblEvents();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
