    <JadeMethod name="initTerminalApp" id="cd5f7a14-7bdd-4f7a-a43e-7a11be6cec23">
        <updating/>
        <source>initTerminalApp() updating;
// ---------------------------------------------------------------------------
// Created:     30 July 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
18 Aug 2008	cnwkpd1	PAR #17740 - Remove skins from JMT Terminal application
23 Sep 2008	cnwkpd1	PAR #18009 - Allow ini file control of transient check
29 Sep 2008	cnwdad1	PAR #18019 - User Preferences now determine whether to use skins.
07 Feb 2012	cnwkpd1	PAR #28381 - Update JSM version info correctly in managed environments
07 Sep 2012	cnwkpd1	PAR #30306 - New graphics and application branding
27 May 2014	cnwkpd1	PAR #34210 - CCMS SFW 1350 - Online Documentation
23 November 2018    jlgrh7    Initial creation TFS41429
*/
vars
	userWindow	: CM_UserWindow;
	
begin
	executeWhen JMTDevelopmentEnvironment;
		if process.isPW and process.sendMsg("_isBeingDebugged").Boolean then
			if app.checkUnitTestRunnerRunning() then
				app.msgBox("Unit Tests are currently running, unable to start in Debug mode", "ERROR", MsgBox_OK_Only + MsgBoxCustom_Icon_Stop);
				terminate;
			endif;
		endif;
	endExecuteWhen;
	
	app.mousePointer := Window.MousePointer_HourGlass;
	app.niceName := "Master Terminal";
	app.setupAppVersion();		// PAR #28381
	app.cnActivateKarmaControl(Cn_Fat_Client, null, null);
	
	on Exception do app.generalExceptionHandler(exception) global;
	on UserInterfaceException do app.xHandlerUI(exception) global;
	on Exception do app.handleNoDefaultPrinter(exception, true) global;	//19 Nov 2013	NDL	Par 32138 / 33003
	on Exception do app.handleLocaleException(exception, true) global;		//+TFS41429
	on Exception do app.handleFormLoss(exception) global;	//16 Dec 2019	NDL	TFS 48010 - Handle a user closing the windows in teh background that we rely on.
//	app.myCnCntrl.setCheckTransientsOnShutDown(false);	- removed PAR #18009

	self.initialize();

	app.passBackAllExceptions		:=	false;	//app.isDevelopmentSystem;
	app.passBackJadeExceptionsOnly	:=	app.isDevelopmentSystem;

	app.handleIt();
	
	//self.logLevel := LogWARN;	//22 Nov 2019	NDL	TFS 47053 Part of 'initialize'
//	self.initLogFile();	//rs may 2005 CCMS10137

//app.fontName := null;

	//app.setApplicationSkinByName('Jmaster2006');
//	app.setApplicationSkinByName('JMTxpx2006');			// PAR #17740

	if not app.doLogin() then
		app.writeLog('Login failed - terminating', LogFATAL);	//26 Nov 2019	NDL	TFS 47053
		terminate;
	endif;
	
// cnwdad1 29/09/2008 - PAR #18019.
	if self.getMyUser().getUseAppSkins() then
		//app.setApplicationSkinByName('JMTxpx2006');
		app.setApplicationSkinByName(self.getMyUser().getUseAppSkinName());	//cnwmc5 - PAR 31051
	endif;
	
	app.mdiFrame	:=	CMUI_SuperAppForm2;
	create app.mainForm as CMUI_SuperAppForm2;

	userWindow	:=	self.getUserWindow(CMUI_SuperAppForm2.name, false);

	if userWindow &lt;&gt; null then
		app.userSavedWindowSettings	:=	true;
		app.mainForm.CMUI_SuperAppForm2.initFromUserWindow(userWindow);
		app.userSavedWindowSettings	:=	false;
	else	
		app.mainForm.height	:=	720;
		app.mainForm.width	:=	1010;

		// create the user window to save data in on exit
		userWindow	:=	self.getUserWindow(CMUI_SuperAppForm2.name, true);
	endif;
	
	//15 Jun 2012	NDL	Par 29508
	if self.useDisableWindowsGhosting() then
		call disableWindowsGhosting(); // Call of External Function in "user32"
	endif;
	
	self.handleHelpFormatChange();			// PAR #34210
	
	create self.myMessageForm;
	app.mainForm.show();
epilog
	app.mousePointer	:=	Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="initTroubleShooterApp" id="519c49ac-f8dd-4db0-9001-febc9d1e4eac">
        <updating/>
        <source>initTroubleShooterApp() updating;
// ---------------------------------------------------------------------------
// Created:     06 August 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 07 Feb 2012		cnwkpd1			PAR #28381 - Update JSM version info correctly in managed environments
// ---------------------------------------------------------------------------

vars

begin
	app.mousePointer := Window.MousePointer_HourGlass;
	app.niceName := "Trouble Resolution";
	app.setupAppVersion();			// PAR #28381
	app.cnActivateKarmaControl(Cn_Fat_Client, null, null);

	self.initialize();

	app.passBackAllExceptions := false;	//app.isDevelopmentSystem;
	app.passBackJadeExceptionsOnly := true;

	on Exception do app.generalExceptionHandler(exception) global;
	
	//self.logLevel := LogWARN;	//22 Nov 2019	NDL	TFS 47053 Part of 'initialize'

	if not app.doLogin() then
		terminate;
	endif;
	self.myPassport.setMyTerminal(CM_Terminal.firstInstance);
	
	// Extra stuff here not in UiCommonSchema
	//app.createMyController(CMUI_Controller);

	app.mainForm := app.loadForm(CMUI_TroubleQuery, CMUI_Assistant, false, false, false, app.getMyTerminalDO_NOT_USE(), null).CMUI_TroubleQuery;
	
	// If user fails security we don't want to show a null form.
	if app.mainForm &lt;&gt; null then
		app.mainForm.show;
	endif;
	
epilog
	app.mousePointer := Window.MousePointer_Default;


end;</source>
    </JadeMethod>
    <JadeMethod name="initWithSavedSettings" id="f5cb0c76-d311-466b-a765-e2ad3d04a75c">
        <updating/>
        <source>initWithSavedSettings() updating;
/* ---------------------------------------------------------------------------
Created:     09 May 2001 by cnwrs2

Purpose:     
Changes

Date		Name	TFS#		Description
============================================================================
11/09/2008	concms1	par 17903 
					ccms 1741 	Welcome form - interim version
14/01/2015	cnwkpd1				Extended locks on allUserWindowsForStartup
20/09/2019 	jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
============================================================================*/
vars
	frmClass	: Class;
	form		: Form;
	userWindow	: CM_UserWindow;
	userTerm	: CM_UserTerminal;
	user		: CM_User;
	mdiForm		: CMUI_SuperAppForm2;			
	winName		: String;
	menuUserItem	: CM_MenuUserItem;
	count		: Integer;
	tmpUserWin	: CM_UserWindowForStartup;
			
begin
	// need to set height / width / position of MDI Frame
	// need to possibly save if toolbar hidden or no
	// need to save animation
	// need to save "Save Settings On Exit"
	
	user := app.getMyUser();
	if user = null then
		return;
	endif;

// now done in CMUI_SuperAppForm2.handlePostShow
//	self.toolbarHidden 		:= user.getStateData(ConfigGrp_Gate, UserToolbarHidden).Boolean;
//	self.saveSettingsOnExit := user.getStateData(ConfigGrp_Gate, UserSaveSettingsOnExit).Boolean;
	
	if app.mainForm.isKindOf(CMUI_SuperAppForm2) then
		mdiForm := app.mainForm.CMUI_SuperAppForm2;
		mdiForm.useAnimation 	:= user.getStateData(ConfigGrp_Gate, UserAnimation).Boolean;
	endif;

	self.userSavedWindowSettings := true;

//write 'START';
//write '';
//app.outputProcessStack();
//write '';

//write user.allUserWindowsForStartup.size();
	foreach tmpUserWin in user.allUserWindowsForStartup discreteLock do
//write tmpUserWin.windowClassName;
		menuUserItem := tmpUserWin.myMenuUserItem;
		if menuUserItem = null then
			continue;
		endif;
		menuUserItem.CM_MenuUserDtl.doDblClick(tmpUserWin);
	endforeach;
	
	if user.hasWelcomeForm and user.getShowWelcomeScreen then	// par 17903
		// we need to display the welcome form for this user	
		app.showWelcomeForm;									// par 17903
	endif;														// par 17903
	
epilog
	self.userSavedWindowSettings := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="initWithSavedSettingsLock" id="1816c3b6-66ce-45eb-8ce5-98a13b875e47">
        <updating/>
        <source>initWithSavedSettingsLock(_newUser, _lockUser : CM_User) updating;
/*
----------   ----------  --------------------------------------------------
Created:	08 January 2007 By cnwmo1

Purpose:	

Changed On	Changed By	Reason
	
----------	----------	--------------------------------------------------
14/01/2015	cnwkpd1		Extended locks on allUserWindowsForStartup

*/
vars
frmClass	: Class;
	form		: Form;
	userWindow	: CM_UserWindow;
	userTerm	: CM_UserTerminal;
	user		: CM_User;
	mdiForm		: CMUI_SuperAppForm2;			
	winName		: String;
	menuUserItem	: CM_MenuUserItem;
	count		: Integer;
	tmpUserWin	: CM_UserWindowForStartup;
	sameUser	: Boolean;
	issuedWarning	: Boolean;		
begin
	// need to set height / width / position of MDI Frame
	// need to possibly save if toolbar hidden or no
	// need to save animation
	// need to save "Save Settings On Exit"
	
	//user := app.getMyUser();
	user := _newUser;
	if _lockUser = user then
		sameUser := true;
	endif;

// now done in CMUI_SuperAppForm2.handlePostShow
//	self.toolbarHidden 		:= user.getStateData(ConfigGrp_Gate, UserToolbarHidden).Boolean;
//	self.saveSettingsOnExit := user.getStateData(ConfigGrp_Gate, UserSaveSettingsOnExit).Boolean;
	
	if app.mainForm.isKindOf(CMUI_SuperAppForm2) then
		mdiForm := app.mainForm.CMUI_SuperAppForm2;
		mdiForm.useAnimation 	:= user.getStateData(ConfigGrp_Gate, UserAnimation).Boolean;
	endif;

	self.userSavedWindowSettings := true;

//write 'START';
//write '';
//app.outputProcessStack();
//write '';

//write user.allUserWindowsForStartup.size();
	foreach tmpUserWin in _lockUser.allUserWindowsForStartup discreteLock do
//write tmpUserWin.windowClassName;
		menuUserItem := tmpUserWin.myMenuUserItem;
		if menuUserItem = null then
			continue;
		endif;
		
		if (sameUser or app.myCurrentUserCan(menuUserItem.myTerminal, menuUserItem.myMenuItem.constantValue)) then
			menuUserItem.CM_MenuUserDtl.doDblClick(tmpUserWin);
		else
			if not issuedWarning then 
				app.msgBox(app.getErrorString(WARNING_LOCK_ACCESS), "Security Warning", MsgBox_Stop_Icon);
				issuedWarning := true;
			endif;
		endif;
	endforeach;
	
	if not sameUser and (not _lockUser.getStateData(ConfigGrp_Gate, UserSaveSettingsOnExit).Boolean) then
		// This will clear settings if lock user doesn't want to remember open windows. This is because
		// we are saving these regardlessly for a locked session.
		self.doSaveSettingsOnExit(_lockUser, false);
	endif;
	
epilog
	self.userSavedWindowSettings := false;
end;
</source>
        <Parameter name="_newUser" type="CM_User"/>
        <Parameter name="_lockUser" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="initialiseViewController" id="143965d0-017f-4f92-947a-9007be382d54">
        <updating/>
