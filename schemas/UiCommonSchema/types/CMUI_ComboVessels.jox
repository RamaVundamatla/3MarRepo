<GUIClass name="CMUI_ComboVessels" id="5ef74eba-72b9-4674-8475-28faefc684cb">
    <superclass name="CMUI_ComboBoxObject"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <PrimAttribute name="checkCanCreateVoyages" id="1b8eaba6-d139-458a-b1d5-d74af220184e">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="isDisplayByName" id="e28abe47-d5b3-4702-9f67-23ace9fa2bca">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <JadeMethod name="displayEntry" id="832e3ae5-d8cf-41d8-a48b-c127aecd5751">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>displayEntry(combobox: ComboBox input; pVessel : CM_Vessel; lstIndex: Integer): String updating;
//-----------------------------------------
// Created: 07 September 2005 By: cnwgd1
//-----------------------------------------
vars
	failedDAC	: CM_DataAccessController;

begin
	if pVessel = null then
		return null;
	endif;

	if self.checkCanCreateVoyages then
		// Only display if voyages can be created for the vessel	
		if (not pVessel.canCreateVoyages) then
			return null;
		endif;	
	endif;

	if not pVessel.canUserAccessSelf(null, failedDAC, app.myPassport) then
		return null;
	endif;

	if self.isDisplayByName then
		return pVessel.name &amp;  " - (" &amp; pVessel.code &amp; ")" ;
	else
		return pVessel.code &amp; Tab &amp; pVessel.name;		
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="pVessel" type="CM_Vessel"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="5c92033f-64ec-4dc2-927c-9f94099d47a3">
        <source>getCollectionJMT(): Collection protected;
//--------------------------------------------------
// Created:	07 September 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	return app.myRoot.allVessels;

end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
