    <JadeMethod name="createLaneController" id="eb906d25-98a2-473d-a11b-ddc2ab76eac5">
        <updating/>
        <source>createLaneController() updating;
/*
Purpose:			
Date				Who			Reason
DECEMBER 2011		CNWAB1		Initial creation
*/

vars

begin
	if self.myLanePositionController &lt;&gt; null then
		return;
	endif;
	
	if self.isTransient then 
		create self.myLanePositionController transient;
	else
		create self.myLanePositionController persistent;
	endif;
	self.myLanePositionController.setFromROROLaneDefn();
epilog

end;</source>
    </JadeMethod>
