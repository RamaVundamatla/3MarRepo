<CollClass name="CM_CodesByCodeDict" id="d7063c45-14d1-413a-b959-274578afcc86">
    <memberType name="CM_Code"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <MemberKey>
        <property name="CM_Code::code"/>
    </MemberKey>
    <JadeMethod name="getEntriesAsString" id="f2887ff0-34d7-43e8-9bf2-7519b2d7502f">
        <source>getEntriesAsString() : String;
/*
Purpose:			TFS 2942
Date				Who			Reason
DEC 2016		CNWAB1		Initial creation
*/

vars
	theCode : CM_Code;
	theCodeString,
	theString : String;
	iter01 : Iterator;
	invalidCode : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, theCode, invalidCode);
	
	iter01 := self.createIterator;
	while iter01.next(theCode) do
		theCodeString:=theCode.code;
		if invalidCode then
			invalidCode:=false;
			continue;
		endif;
		theString := theString &amp; theCodeString &amp; ",";
	endwhile;
	theString := theString[1 : theString.length - 1];
	
	return theString;
	
epilog
	delete iter01;	
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
