    <JadeMethod name="unload" id="a7735032-1e65-407b-a9f9-d90fb914d425">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

vars

begin
	// proxy is deleted by a successful save but not by a cancel.  Is transient so isValidObject test is OK for performance
	if global.isValidObject(self.myProxyDebtorNode) then
		delete self.myProxyDebtorNode;
	endif;
	//delete self.allSelectedCustomsAgents;
	//delete self.allSelectedDebtorTypes;
	inheritMethod();
end;
</source>
    </JadeMethod>
