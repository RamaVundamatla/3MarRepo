    <JadeMethod name="doTblDataDragDrop" id="7806ce90-ffd2-4ab0-ba87-a770a0e8a05f">
        <updating/>
        <source>doTblDataDragDrop(table: Table input; win: Window input; x: Real; y: Real) updating;
/*

Purpose:			


Return Value:		


Date			Who		Reason
10 Augt 2007	cnwer1	Initial creation - PAR#xxxx
08 Apr 2008		cnwyl1	Par 16446 and 16441 
01 Nov 2012 	PJS		PAr #30631
*/
vars
	theRow, indexJob, indexTarget , moveIndex, maxSize: Integer;
	targetObj, selectedObj : Object;
	crane : CM_Crane;
	jobSheet : CM_JobSheet;
	theJob : CM_VoyageJob;
	selectedObjs : ObjectArray;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin


	theRow := table.CM_DataTable.getRowFromY(y);
	
	if theRow = null then 
		return;
	endif;
	
	//changed by cnwyl1 for par 16446 and par 16441
	if not self.fldMain.topSheet.userObject.isKindOf(CM_Crane) then
		return;
	endif;
	crane := self.fldMain.topSheet.userObject.CM_Crane;
	jobSheet:=self.myCurrentVoyage.allJobSheets[crane.id];
	maxSize := jobSheet.allJobsByOrder.size();	
	
	if (theRow - self.tblData.fixedRows) &gt; maxSize then
		theRow := maxSize + self.tblData.fixedRows;
	endif;
		
	targetObj := table.accessRow(theRow).itemObject;	
	indexTarget:=jobSheet.allJobsByOrder.indexOf(targetObj.CM_Job);
	create selectedObjs transient;
	self.tblData.allSelectedObjects.copy(selectedObjs);
	foreach selectedObj in selectedObjs do
		theJob:=selectedObj.CM_VoyageJob;
		indexJob:= jobSheet.allJobsByOrder.indexOf(theJob);
		moveIndex:=indexTarget - indexJob;
		if indexJob &gt; 0 then
	
			//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxUA.trxShiftJobInJobSheet(theJob, app.myPassport, (moveIndex));
			
				if app.myPassport.trxCompletedOK then
					break;
				else
					theResult := app.showErrorWarningDialog(app.getErrorString(Order_Of_Work), app.myPassport, ErrWarnMode_Update);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				return;
				
			endwhile;

			if indexTarget &lt;= 0 then
				indexTarget := 1;
			endif;
			
			//epr TFS 830 job move handled by notes 21/3/17
		endif;
	endforeach;


epilog
	delete selectedObjs;
	self.dragMode:=Window.DragMode_None;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doTblDataMouseMove" id="e28860bb-30b9-4cca-ad4f-b628a602ea9d">
        <updating/>
        <source>doTblDataMouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     11 October 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(table, button, shift, x, y);
	self.tblData.mouseMoveForDragSelect(table, button, shift, x, y);
	if self.fldMain.topSheet &lt;&gt; null and self.fldMain.topSheet.userObject.isKindOf(CM_Crane) then
		if button = Window.MouseButton_Left 
			and app.dragDetected(x, y, self.origXPos, self.origYPos) then
			if y &gt; 20 then
				if self.origYPos &gt; 20 then // ### PAR 9949 may be doing a column resize!
					self.dragMode := DragMode_Drag;
					if self.myCurrentJob &lt;&gt; null then  // cnwrd1 30.7.08 whilst fixing par #17631
						if self.myCurrentJob.status = JOB_UNACTIONED then
							self.dragCursor := self.picJobUnactCur.picture;
						elseif	self.myCurrentJob.status = JOB_COMPLETE then
							self.dragCursor := self.picJobCompCur.picture;
						elseif	self.myCurrentJob.status = JOB_PART_COMPLETE then
							self.dragCursor := self.picJobPartComCur.picture;
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doTblDataMouseUp" id="24b9220d-fcf8-4627-a279-ec9024e5a6e4">
        <updating/>
        <source>doTblDataMouseUp(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		08 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// 02 Nov 2012		PJS	PAR #30631
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(table);
	self.staStatusBar.caption := app.getErrorString(Selected_With_Colon)&amp; " " &amp; self.tblData.allSelectedObjects.size.asStringJMT;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblDataRowColChange" id="1cef8ae9-33c2-411c-9bbe-e5d480d71b34">
        <updating/>
        <source>doTblDataRowColChange(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anObject	: Object;
	aJob		: CM_VoyageJob;
	row			: Integer;
	ct			: TimeStamp;
	invalid		: Boolean;
begin

	row := table.row;
	self.myCurrentJob := null;
	
	anObject :=  table.accessRow(row).itemObject;

	if JadeTableRow.hasInstance(anObject) then
		//this is a remarks row - the job row is above
		anObject :=  table.accessRow(row-1).itemObject;
	endif;
							
	//cnwjo3 par 23520
	if anObject &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception,anObject,invalid);
		ct := anObject.creationTime;
	endif;
	
	if invalid then
		return;
	endif;

	if CM_VoyageJob.hasInstance(anObject) then
		aJob := anObject.CM_VoyageJob;
		self.myCurrentJob := aJob;
	elseif CMIF_JobTITotals.hasInstance(anObject) then
		aJob := anObject.CMIF_JobTITotals.myJob;
		self.myCurrentJob := aJob;
	endif;

	inheritMethod(table);
	self.updateMoveButtons(aJob);

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
