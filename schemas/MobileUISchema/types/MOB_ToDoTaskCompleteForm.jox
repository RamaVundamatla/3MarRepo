    <JadeMethod name="addUsageToTblResources" id="40e2e656-c8c5-4354-82af-5fef9e0d76e9">
        <source>addUsageToTblResources(_usage : CM_ResourceTypeUsage) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/03/2015	cnwdap1		Initial creation PAR #35895 CCMS PNL 2461
//
vars
	str 	: String;
	index 	: Integer;
	
begin
	str := _usage.myResourceType.description &amp; Tab &amp; _usage.quantity.String &amp; Tab &amp; _usage.myResourceType.unitDescription &amp; Tab &amp; _usage.noCharge.getYes &amp; Tab &amp; _usage.remarks &amp; Tab &amp; _usage.getStatusString;
	index := self.tbl_Resources.addItem(str);
	self.tbl_Resources.accessRow(index).itemObject := _usage;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_usage" type="CM_ResourceTypeUsage"/>
    </JadeMethod>
