    <Constant name="JSS_ENCRYPTBASEDATE" id="456532b4-1e41-470b-b135-1d6a930001aa">
        <source>'26MAY1998'.Date</source>
        <type name="Date"/>
    </Constant>
    <Constant name="JSS_ENCRYPTBASETIME" id="86a6853f-6d99-4b7a-8710-4a85b4a35647">
        <source>'00:00:00:00'.Time</source>
        <type name="Time"/>
    </Constant>
    <Constant name="JSS_MILLISECONDS_IN_DAY" id="2cfbc631-bf41-480a-8087-072d6fa4f398">
        <source>86400000</source>
