    <JadeMethod name="getContainerTotals" id="25054225-5a0e-4ebf-ba18-31140d8b03c0">
        <source>getContainerTotals(_table : Table; _contTotalsRow : Integer; _totals : StringArray input) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 29/01/2015	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voage Rationalisation
//
vars
	idx : Integer;
	table : Table;

begin
	table := _table;
	foreach idx in 2 to _table.columns do
		_totals.atPut(idx, table.accessCell(_contTotalsRow, idx).text);
	endforeach;
epilog

end;</source>
        <access>protected</access>
