    <JadeMethod name="moveCriteriaLine" id="9ec71f88-c99e-48e3-a4b8-9b33a344ca83">
        <updating/>
        <source>moveCriteriaLine( _up : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 September 2019	jlgndl1	Initial creation	TFS 45891

*/

vars

	
	tblSheet : JadeTableSheet;
	criteriaLine : CM_SelectorCriteriaLine;
	rowIndex : Integer;

begin

	tblSheet := self.tblCriteria.accessSheet(self.tblCriteria.topSheet);
	if tblSheet = null or tblSheet.row = 0 then
		return;
	endif;
	
	criteriaLine := tblSheet.accessRow(tblSheet.row).itemObject.CM_SelectorCriteriaLine;
	if criteriaLine = null or not tblSheet.accessRow(tblSheet.row).selected then
		return;
	endif;
	
	rowIndex := tblSheet.row;
	tblSheet.removeItem( tblSheet.row );
	
	if _up then
		rowIndex := rowIndex - 1;
	else
		rowIndex := rowIndex + 1;
	endif;
	
	tblSheet.addItemAt( criteriaLine.getDescriptionString, rowIndex );
	tblSheet.accessRow( rowIndex ).itemObject := criteriaLine;
	
//	if criteriaLine.isUnavailableAtRunTime then
//		tblSheet.accessRow( rowIndex ).backColor := self.ROW_COLOUR_UNAVAILABLE;
//	else
		tblSheet.accessRow( rowIndex ).backColor := criteriaLine.getPerformanceColour;
//	endif;
	
	tblSheet.accessRow( rowIndex ).selected := true;
	tblSheet.row := rowIndex;	

epilog

	self.evaluateUpDown();

end;</source>
        <Parameter name="_up" type="Boolean"/>
    </JadeMethod>
