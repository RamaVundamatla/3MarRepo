Date		Who		Reason
19 September 2013	cnwndl1	Initial creation	Par 32479

*/

vars

begin

	self.myTrackedItem := _ti;
	self.myWorkListEntry := _wle;
	
	self.setLBLQuantityCaption();

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
