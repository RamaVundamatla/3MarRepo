<CollClass name="CM_VoyageJobSet" id="4c348fef-7fa8-413c-bd0e-ea6a8802cc7a">
    <memberType name="CM_VoyageJob"/>
    <superclass name="CM_ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="operatn"/>
    <JadeMethod name="getTotalRequests" id="65f6322e-b203-49e9-b2b2-6dc6238ed379">
        <source>getTotalRequests(_nonPlnOnly : Boolean) : Integer;
// ---------------------------------------------------------------------------
// Created:		30 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aJ : CM_Job;
	idx : Integer;
	aReq : CM_Request;

begin
	foreach aJ in self do
		// ##### NON PLANNED ONLY
		if _nonPlnOnly then 
			foreach aReq in aJ.allRequests discreteLock do : reqLoop
				if aReq.isKindOf(CM_SlotRequest) then
					
					if not aReq.hasTIsOfMode(PLANNING_MODE) then
						idx := idx + aReq.allWorkListEntries.size;
					endif;
				else
					idx := idx + aReq.allWorkListEntries.size;
				endif;
			endforeach;
		// ##### EVERYTHING
		else
			idx := idx + aJ.allRequests.size;
		endif;
	endforeach;
	
	return idx;
end;</source>
        <Parameter name="_nonPlnOnly" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</CollClass>
