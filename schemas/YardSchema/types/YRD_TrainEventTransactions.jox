/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	event : CM_EventTransaction;

begin

	event := self.tblEvents.accessRow(self.tblEvents.row).itemObject.CM_EventTransaction;	
	
	/*if event = null then
		self.clearEditControls();
	else
		if event.isKindOf(CMEVT_TrainUserEvent) then
			self.btnEditEvent.enabled := true;
			self.btnDelete.enabled := true;
			self.setControlsForAddEdit( event );
