    <JadeMethod name="doFilter" id="f1265bad-5e9d-4a45-9f93-85d059a7007a">
        <source>doFilter() protected;
// only keep rows whose descriptions match
vars
	rowIndex		: Integer;
	col,
	fixedRows,
	rows			: Integer;
	description		: String;
	filterText		: String;
	table			: CM_DataTable;
begin
	table := self.tblTasksAdd;
	col := table.getColumnByRowName (ETRow_Description);
	fixedRows := table.fixedRows;
	rows := table.rows;
	// make all visible
	foreach rowIndex in fixedRows to rows do
		table.accessRow( rowIndex ).visible := true;
	endforeach;
	// hide rows that don't match
	filterText := self.txtFilter.text.toUpper.trimBlanks;
	if filterText &lt;&gt; null then
		foreach rowIndex in fixedRows to rows do
			description := table.accessCell(rowIndex, col).text.toUpper;
			if description.pos(filterText, 1) &lt; 1 then
				table.accessRow( rowIndex ).visible := false;
			endif;
		endforeach;
	endif;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doInstructions" id="4efe5242-3e0a-4122-bb39-d5d7e348e7bd">
        <source>doInstructions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions

*/

vars
	obj  : CM_Object;
begin
	obj := self.tblTasksAdd.accessRow(self.tblTasksAdd.row).itemObject.CM_Object;
	if obj &lt;&gt; null then
		self.btnInstruction.enabled := true;
	else	
		self.btnInstruction.enabled := false;
	endif;

epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="doQueryUnload" id="7cdaa7b9-2b73-4d57-8c5b-58d91bab2be6">
        <source>doQueryUnload(_cancel: Integer io; _reason: Integer) protected;

vars

begin
	if self.isFormChanged then
		if not self.confirmCancel (app.getErrorString (The_Current_Item)) then
			_cancel := 1;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cancel" type="Integer" usage="io"/>
        <Parameter name="_reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="f5b3300a-a079-4173-8ac7-d0d9bb6ed9f5">
        <updating/>
        <source>doResize() updating;

vars

begin
	inheritMethod();

	frmMain.height := self.clientHeight - frmMain.top - (self.clientHeight - btnSave.top) - 10;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="f05f40c4-204b-4c84-bce6-256776d02c3f">
        <updating/>
        <source>doSave() : Boolean updating, protected;
/*

Purpose:			
task add, complete and remove for multiple cargo items and multiple to do tasks,also remarks maintenance
Parameters:			

Return Value:		

Date		 Who	  Reason
12 Dec 2022  navcs2   ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen
27 Dec 2022  navds21  ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources
05/04/2023	 navcs2	Bug 57455: EUP - Todo Tasks Completed without adding Mandatory resources

*/ 
vars
	row					: Integer;
	rows				: Integer;
	count				: Integer;
	index				: Integer;
	result				: Integer;
	msg					: String;
	remarks				: String;
	allRemarks			: HugeStringArray;
	task				: CM_ToDoTask;
	taskArray			: CM_ToDoTaskArray;
	taskDesc			: CM_ToDoTaskDesc;
	taskDescArray		: CM_ToDoTaskDescArray;
	resourceUsageProxys : CM_ResourceTypeUsageSet;
	action				: Boolean;
	ti					: CM_TrackedItem;
	tiSet				: CM_TISet;	
	pxyTiSet			: CM_TISet;
	gotException		: Boolean;
	passport			: CM_Passport;
	table				: CM_DataTable;
	size				: Integer;
	object				: CM_Object;
	objectSet			: CM_ObjectSet;
	objectStr			: String;
begin
	app.mousePointer	:= Busy;
	passport 			:= app.myPassport;
	
	on Exception do app.handleDeletedObject (exception, ti, gotException);
	create tiSet transient;
	foreach ti in self.allTrackedItems do
		tiSet.add(ti);
	endforeach;
	
	create taskArray transient;
	create taskDescArray transient;
	create allRemarks transient;
	
	table	:= self.tblTasksAdd;
	rows 	:= table.rows;
	row		:= table.fixedRows;
	
	// for remarks the objects are ToDoTasks, for all else are ToDoTaskDesc
	if self.mode = CM_ContainerEnqForm.TASK_MODE_REMARKS then
		while row &lt; rows do
			row 	:= row + 1;
			task := table.accessRow(row).itemObject.CM_ToDoTask;
			remarks := table.getCellValueByName (ETRow_Remarks, row);
			taskArray.add(task);
			allRemarks.add(remarks);
			count := count + 1;
		endwhile;
	else
		// get the selected tasks
		while row &lt; rows do
			row 	:= row + 1;
			if self.mode = CM_ContainerEnqForm.TASK_MODE_ADD then
				remarks := table.getCellValueByName (ETRow_Remarks, row);
			endif;
			action 	:= (table.getCellValueByName (ETRow_Add, row) = 1.String);
			
			if action then
				taskDesc := table.accessRow(row).itemObject.CM_ToDoTaskDesc;
				taskDescArray.add(taskDesc);
				allRemarks.add(remarks);
				count := count + 1;
			endif;
		endwhile;
	endif;
	
	if count = 0 then
		return true;
	endif;
	if self.mode = CM_ContainerEnqForm.TASK_MODE_ADD then
		msg := "Tasks Added";
		index := 1;
		foreach taskDesc in taskDescArray do
			remarks := allRemarks[index];
			index := index + 1;
			while true do
				app.myTrxUA.trxUpdateTIToDoTaskBulkAdd(taskDesc, remarks, tiSet, app.myPassport);
				if app.myPassport.trxCompletedOK then
					self.clearErrorWarnings();
					break;
				else
					result := app.showErrorWarningDialog('Add Todo Task', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
					result = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
					self.setAllErrorWarnings(app.myPassport);
				endif;
				break;
			endwhile;
		endforeach;
		
	elseif self.mode = CM_ContainerEnqForm.TASK_MODE_COMPLETE then
		msg := "Tasks Completed";
		create pxyTiSet transient;
		foreach taskDesc in taskDescArray do
			pxyTiSet.purge();
			if resourceUsageProxys &lt;&gt; null then
				resourceUsageProxys.purge();
			endif;
			app.mousePointer	:= Idle;
			if not self.myAssistant.doTaskProxySetForComplete( taskDesc.code, pxyTiSet, ti, tiSet, resourceUsageProxys) = IDOK then
				return false;
			endif;
			app.mousePointer	:= Busy;
			//perform the updating
			while true do
				app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(taskDesc, pxyTiSet, resourceUsageProxys, app.myPassport);
				if app.myPassport.trxCompletedOK then
					self.clearErrorWarnings();
					break;
				else
					result := app.showErrorWarningDialog(app.getString(Complete_TDTask), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
					result = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
					
					self.setAllErrorWarnings(app.myPassport);
					return false;	//27/12/2022 navds21 TFS #54349[54262]
				endif;
				break;
			endwhile;
		endforeach;
	elseif self.mode = CM_ContainerEnqForm.TASK_MODE_REMOVE then
		result := app.msgBox('Are you sure you want to remove these tasks from ' &amp; tiSet.size.String &amp; ' item(s)?', 
			app.getErrorString(Remove_Task), MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	
		if result = MsgBox_Return_No then
			return false;
		endif;
		msg := "Tasks Removed";

		foreach taskDesc in taskDescArray do
			while true do
				app.myTrxUA.trxUpdateTIToDoTaskRemBulk(taskDesc, tiSet, app.myPassport);
				if app.myPassport.trxCompletedOK then
					self.clearErrorWarnings();
					break;
				else
					result := app.showErrorWarningDialog('Remove Todo Task', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
					result = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
					self.setAllErrorWarnings(app.myPassport);
				endif;
				break;
			endwhile;
		endforeach;
	
	elseif self.mode = CM_ContainerEnqForm.TASK_MODE_REMARKS then
		msg := "Task Remarks";
		index := 1;
		foreach task in taskArray do
			remarks := allRemarks[index];
			index := index + 1;
			while true do
				app.myTrxUA.trxUpdateTaskRemarks(remarks, task, app.myPassport);
				if app.myPassport.trxCompletedOK then
					self.clearErrorWarnings();
					break;
				else
					result := app.showErrorWarningDialog('Todo Task Remarks', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
					result = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
					self.setAllErrorWarnings(app.myPassport);
				endif;
				break;
			endwhile;
		endforeach;
	
	/**
	** 12/12/2022	navcs2	#56691:[56120]
	**/
	elseif self.mode = self.TODO_TASK then 
		msg := "Tasks Completed";
		create objectSet transient;
		
		foreach taskDesc in taskDescArray do

			foreach task in self.allToDoTasks where task.toDoTaskDesc = taskDesc do 
				if resourceUsageProxys &lt;&gt; null then
					resourceUsageProxys.purge();
				endif;
				app.mousePointer	:= Idle;
				if task.isKindOf(CM_TrainToDoTask) then
					object 	  := task.CM_TrainToDoTask.myTrainToDo;
					objectStr := object.CM_Train.code;							//05/04/2023	navcs2	Bug 57455
				elseif task.isKindOf(CM_WagonToDoTask) then
					object := task.CM_WagonToDoTask.myWagonToDo;
					objectStr := object.CM_Wagon.id;							//05/04/2023	navcs2	Bug 57455
				elseif task.isKindOf(CM_VBSToDoTask) then
					object := task.CM_VBSToDoTask.myVBSToDo;
					objectStr := object.CM_VehicleBookingTimeSlot.id;			//05/04/2023	navcs2	Bug 57455
				elseif task.isKindOf(CM_NonOpsToDoTask) then
					object := task.CM_NonOpsToDoTask.myDebtorToDo;
					objectStr := object.CM_Debtor.name;							//05/04/2023	navcs2	Bug 57455
				elseif task.isKindOf(CM_VoyageToDoTask) then
					object := task.CM_VoyageToDoTask.myVoyageToDo;		
					objectStr := object.CM_Voyage.code;							//05/04/2023	navcs2	Bug 57455
				elseif task.isKindOf(CM_VehicleVisitRecordToDoTask) then
					object := task.CM_VehicleVisitRecordToDoTask.myVVRToDo;
					objectStr := object.CM_VehicleVisitRecord.visitNumber;
				endif;
				if not self.myAssistant.doToDoTaskProxySetForComplete( taskDesc.code, task, resourceUsageProxys, objectStr) = IDOK then		//05/04/2023	navcs2	Bug 57455
					return false;
				endif;
				app.mousePointer	:= Busy;
				
				objectSet.addNoDuplicates(object, false);
				self.allToDoTasks.removeIfPresent(task);
				app.myTrxUA.trxUpdateVasToDoTaskComplete(object, taskDesc.code, app.myPassport, resourceUsageProxys, self.myWodtl);
				
				// 04/04/2023 navcs2 Bug 57455 Changes start
				if app.myPassport.trxCompletedOK then
					self.clearErrorWarnings();
				else
					result := app.showErrorWarningDialog(app.getString(Complete_TDTask), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
					result = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
					
					self.setAllErrorWarnings(app.myPassport);
					return false;	
				endif;
				// 04/04/2023 navcs2 Bug 57455 Changes end
			endforeach; 
		endforeach;
		app.msgBox(count.String &amp; " To Do Tasks for " &amp; objectSet.size.String &amp; " item(s).", msg, 0);
		return true;
	endif;
	/**
	** 12/12/2022	navcs2 #56691:[56120]
	**/
	
	if not self.mode = CM_ContainerEnqForm.TASK_MODE_REMARKS and
	   self.ackTodoStop then
		app.msgBox(count.String &amp; " To Do Tasks for " &amp; tiSet.size.String &amp; " item(s).", msg, 0);
	endif;
	
	return true;
	
epilog	
	delete tiSet;
	if pxyTiSet &lt;&gt; null then
		pxyTiSet.purge;
	endif;
	delete objectSet;
	delete pxyTiSet;
	delete allRemarks;
	delete taskArray;
	delete taskDescArray;
	if resourceUsageProxys &lt;&gt; null then
		resourceUsageProxys.purge;
		delete resourceUsageProxys;
	endif;
	app.mousePointer	:= Idle;
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSysNotify" id="59cd05cc-08ec-4f4f-bb19-3b0e07a3c039">
        <updating/>
        <source>doSysNotify(_event: Integer; _object: Object; _tag: Integer) updating, protected;

vars
	gotException	:Boolean;
begin
	if _event = Object_Delete_Event then
		// display message and close form
		self.unloadFormWithMessage;
		
	elseif _event = Object_Update_Event then
		on Exception do app.handleDeletedObject(exception, _object, gotException);

		_object.edition;	// will cause exception
		
		if gotException then
			self.doSysNotify (Object_Delete_Event, _object, _tag);
			return;
		endif;
		
		// reload form without message
		self.resetFirstChangeFlag;
		self.loadTasks (self.getCurrentObject);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_tag" type="Integer"/>
    </JadeMethod>
