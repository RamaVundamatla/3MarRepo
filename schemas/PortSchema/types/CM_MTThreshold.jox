    <JadeMethod name="validateMe" id="915d820f-536e-4534-842c-eae036bd6c81">
        <source>validateMe();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2011	cnwndl1	Initial creation	Par 27731
06 Sep 2019	jlgdi1	46124 Include sub terminal
*/

vars

	thresh : CM_MTThreshold;
	realMe : CM_MTThreshold;

begin

	inheritMethod();

	thresh := self.myTerminal.allMTThresholds.getThresholdFor(	self.myOperator,	//_operator : CM_Operator;
																self.myISOTypeGroup,	//_isoTypeGroup : CM_ISOTypeGroup;
																self.myMTGrade	//_grade : CM_MTGrade
																);
	if self.isTransient then
		realMe := self.pxyGetRealObject;
	endif;
	if realMe = null then
		realMe := self;
	endif;
	
	if thresh &lt;&gt; null and thresh &lt;&gt; realMe then
		app.raiseCMException(MTThreshold_exists, null, null);
	endif;
	
	thresh := null;
	thresh := self.myTerminal.allMTThresholds.getAtKey( self.processingPriority );
	if thresh &lt;&gt; null and thresh &lt;&gt; realMe then
		app.raiseCMException1(MTThreshold_same_priority, self.processingPriority.String, null, null);
	endif;
	
epilog
	
end;</source>
    </JadeMethod>
</Class>
