    <JadeMethod name="addProcessedTi" id="8ab28ca8-87ab-4e37-aa02-42af442a44d9">
        <source>addProcessedTi( _ti : CM_TrackedItem ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 September 2015	cnwndl1	Initial creation	Par 36338
07 Sep 2020 NDL	TFS 49789
*/

vars

begin

	if self.allProcessedTis.includes( _ti ) then
		return false;
	endif;
	
	if _ti.isTransient then	//14 Aug 2020 NDL	TFS 49789
		return false;
	endif;

	self.allProcessedTis.add( _ti );
	self.updateObjectEdition(self);	//03 Oct 2018	NDL	TFS 39186
	
	return true;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cargoIdsInclude" id="19181ea2-d6b8-4501-9ae1-01e996911476">
        <source>cargoIdsInclude( _str : String ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 September 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	obj : Object;

begin

	obj := self.allCargoIdsDict.getAtKey( _str );
	
	return obj &lt;&gt; null;

epilog

end;</source>
        <Parameter name="_str" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="convertNotifiedCargoGroups" id="d17199c5-de97-4a77-8f53-eb7137b3aa13">
        <updating/>
        <source>convertNotifiedCargoGroups():Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 October 2018	jlgndl1	Initial creation	TFS 39186
12 Nov 2019	NDl	TFS 47298
*/

vars

	ncgsToDelete : ObjectArray;
	ncg : CM_NotifiedCargoGroup;
	cg : CM_CargoGroup;

begin

	if self.allNotifiedCargoGroupByIdDict.isEmpty then
		return true;
	endif;
	
	create ncgsToDelete transient;
	
	foreach ncg in self.allNotifiedCargoGroupByIdDict do
		cg := ncg.getMatchingCargoGroup();
		if cg = null then
			cg := ncg.createCargoGroup( ncg.id, app.myPassport );
		endif;
		if cg = null then
			continue;
		endif;
		if cg.getMyCargoGroupAssignment &lt;&gt; null then
			// clearly not the right one, leave it alone.
			continue;
		endif;
		if ncg.isSelectable &lt;&gt; self.isSelectable then
			// bad existing data - this is one of the STW new rules.
			continue;
		endif;
		cg.upgradeFromNCG( ncg );
		if app.myPassport.hasErrors then
			return false;
		endif;
		ncgsToDelete.add( ncg );
		
	endforeach;
	
	if ncgsToDelete &lt;&gt; null and not ncgsToDelete.isEmpty then
		ncgsToDelete.purge();
	endif;
	
	if app.myPassport.hasErrors then
		return false;
	endif;
	
	return true;

epilog

	delete ncgsToDelete;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="122c832c-c89e-40ec-9da8-ba9a78ae23ba">
