    <ExplicitInverseRef name="allTrackedItems" id="4c66e43e-d9ed-45a4-be55-46861ae6133f">
        <transientToPersistentAllowed/>
        <type name="CM_TISet"/>
        <access>readonly</access>
        <text>
This holds all the trackeditems associated with this docket including
inter-terminal transfer clones and dissassembled logs.

IMPORTANT: this can hold ti's in other terminals!

For the ti's that are in a specific terminal refer to the 
collection CM_BOLTerminal.

Only manual this end for update proxy.</text>
        <Inverse name="CM_TrackedItem::allBOLsByDateTime"/>
        <Inverse name="CM_TrackedItem::myReceivalBOL"/>
        <Inverse name="CM_TrackedItem::myReleaseBOL"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="allTrackedItemsOrig" id="a554a63a-1fa9-45ab-ae29-8095cfbe2559">
        <transientToPersistentAllowed/>
        <type name="CM_TIByCargoTypeIdDict"/>
        <access>readonly</access>
        <text>
This collection holds the tracked items that were originally brought in on
this bol.  It does NOT hold dissassembled logs, inter-terminal transfer clones.

Only man/auto at this end for transients - should be auto at this end</text>
        <Inverse name="CM_TrackedItem::myReceivalBOLOrig"/>
    </ExplicitInverseRef>
