    <JadeMethod name="getWLEForTI" id="b33b2e98-df35-4249-9293-07a0811b034b">
        <source>getWLEForTI(_theTI : CM_TrackedItem) : CM_WorkListEntry;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
// ---------------------------------------------------------------------------

vars
	aWLE,foundWLE : CM_WorkListEntry;
begin

	foreach aWLE in self.allWorkListEntries discreteLock do	//06.03.2025 navma1 #MTN-34179
		if aWLE.myTrackedItem = _theTI then
			foundWLE := aWLE;
			break;
		endif;
	endforeach;
	
	return foundWLE;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getWLEQuantity" id="67c4583d-18be-4466-9b13-40aee3214352">
        <source>getWLEQuantity() : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2013	cnwer1	Initial creation CCMS DPH 2274
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	wleQuantity : Integer;
	wle : CM_WorkListEntry;
begin

	//epr par 34406
	if  self.isBulkMultiReleaseByType then 
		return 0;
	endif;
	
	foreach wle in self.allWorkListEntries discreteLock do	//06.03.2025 navma1 #MTN-34179
		if wle.myTrackedItem &lt;&gt; null and wle.myTrackedItem.myCargoType.isBulkMulti then
			continue;
		endif;
		wleQuantity:= wleQuantity + wle.quantity.max(1);
	
	endforeach;
	
	return wleQuantity;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWLEQuantityExceptWLE" id="d760cd54-0fb2-4c4b-87d1-373dccd4bdf0">
