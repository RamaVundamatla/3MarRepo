    <JadeMethod name="clearCriteriaValues" id="49400779-3476-4ca4-8950-f1f4d4906ba6">
        <updating/>
        <source>clearCriteriaValues() updating;
// on an add, show the criteria controls but with null values
vars
	criteriaCtrl	: CMUI_YACriteriaCntl;
	i				: Integer;

begin
	while true do
		i := i + 1;
		criteriaCtrl := self.frmCriteria.getControl(i);
		if criteriaCtrl = null then
			break;
		endif;
		if criteriaCtrl.visible then	
			criteriaCtrl.txtCriteriaValue.text := null;
			criteriaCtrl.txtCriteriaValue.tag := null;		// 12/07/2011 cnwmh5 #27772
			criteriaCtrl.enabled := true;
		endif;
	endwhile;

end;
</source>
    </JadeMethod>
    <JadeMethod name="clearMappingDetails" id="75deabe2-2d73-4755-be49-3ac6203ac420">
        <updating/>
        <source>clearMappingDetails() updating;
// clear and enable the current mapping details
vars

begin
	self.cmbInvoiceLine.listIndex := -1;
	self.cmbQtyAttribute.listIndex := -1;
	// but if only one entry, select it
	if self.cmbQtyAttribute.listCount = 1 then
		self.cmbQtyAttribute.listIndex := 1;
	endif;
	self.cmbQtyAttribute.enabled := true;
	self.txtQtyStart.text := "";
	self.txtQtyStart.enabled := true;
	self.txtQtyEnd.text := "";
	self.txtQtyEnd.enabled := true;
	self.chkMax.value := false;
	self.chkMax.enabled := true;
	self.chkQtyZero.value := false;
	self.chkQtyZero.enabled := true;
	self.optMapTypeSingle.value := true;
end;
</source>
    </JadeMethod>
    <JadeMethod name="create" id="5b66b1d3-99a6-4bc3-bd1d-0eda583edbcf">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2019	jlgndl1	Initial creation	TFS 43153

*/

vars

begin

	self.permissionView  := PmAdmTransactionmapView;
	self.permissionMaint := PmAdmTransactionmapMaint;
	
	self.helpFileName := HelpFile_Invoicing;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="deleteInvoiceAllocation" id="ac653132-1014-4ad0-bad8-5903d6cd0274">
        <updating/>
        <source>deleteInvoiceAllocation() : Boolean updating;

// 08/12/2014 cnwdb2 PAR 35364

vars
	result 					: Integer;
begin	
	if self.myYardAllocation = null or
	   self.myQuantityRangeMap = null or
	   self.myInvoiceLineDesc = null then
		return false;
	endif;
	
//	if app.msgBox(app.getErrorString2(CONF_DELETE,"this mapping", null), app.getErrorString(Confirm_Delete), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
	if app.msgBox(app.getErrorString(Sure_want_delete), app.getErrorString(Confirm_Delete), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then //cnwdb2	PAR 35364
		return false;
	endif;

	while true do
		app.myTrxDA.trxDeleteInvoiceAllocation(self.myYardAllocation.CM_InvoiceAllocation, self.myQuantityRangeMap, self.myInvoiceLineDesc, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.hasRemoved := true;
			self.myQuantityRangeMap := null;
			self.myInvoiceLineDesc := null;
			self.myYardAllocation := null;
			self.populateTable(false);
			self.hasRemoved := false;
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Voyage_load_colour_coding), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);
		endif;
		
		break;
	endwhile;	

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doClear" id="bc702466-1c08-444f-a9c6-00114f9fbcd4">
        <updating/>
        <source>doClear() updating;
// New button click, clear out the mapping data (but not criteria) in preparation for an add, set the btnAdd button caption to Add
//	enable Next, disable Remove
vars

begin
	self.btnAdd.caption := app.getErrorString(AmpersandAdd);
	self.btnAdd.enabled := true;
	self.btnAdd.left := self.btnNext.left - 61;
	self.btnNext.visible := true;
	self.btnNext.caption := app.getErrorString(AmpersandNext);
	self.btnRemove.enabled := false;
	self.enableCriteriaControls();
	self.clearMappingDetails();
end;
</source>
    </JadeMethod>
    <JadeMethod name="doNext" id="310a69d3-9c69-424e-b66d-3aa5e4f85f9d">
        <updating/>
