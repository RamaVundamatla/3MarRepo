    <JadeMethod name="getWagonStr" id="968df108-5cf5-4e33-bf43-42caa4a587e3">
        <source>getWagonStr() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability

*/

vars
	returnStr,
	str		: String;
	woDtl	: CM_WorkOrderDtl;
	wagon	: CM_Wagon;
	wagons	: CM_WagonSet;
begin
	
	create wagons transient; //16/01/2025	navkc1 JIRA Bug MTN-33804
	
	foreach woDtl in self.allWoDtls discreteLock do
		woDtl.getWagons(wagons);
		
		/* //16/01/2025	navkc1 JIRA Bug MTN-33804
		str := woDtl.getWagonsStr();
		
		if str = null then
			continue;
		endif;
		
		if returnStr = null then
			returnStr := str;
		else
			if returnStr.pos(str, 1) &gt; null then
				continue;
			else
				returnStr &amp;= Comma &amp; str;
			endif;
		endif;
		*/
	endforeach;
	
	//16/01/2025	navkc1 JIRA Bug MTN-33804
	foreach wagon in wagons do
		str := wagon.id;
		
		if str = null then
			continue;
		endif;
		
		returnStr.addStringToList(str, Comma); 
	endforeach;
	
	return returnStr;
epilog
	delete wagons; //16/01/2025	navkc1 JIRA Bug MTN-33804
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
