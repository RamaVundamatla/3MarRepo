    <JadeMethod name="isLinkedRequest" id="bdd0bd8b-4908-42ee-8e84-2ff367878c3e">
        <source>isLinkedRequest(_isLoad: Boolean): Boolean;
/*
Purpose:			
Date		Who		Reason
16 April 2012	cnwab1	Initial creation
*/

vars

begin

	if _isLoad then
		if self.myRORORequestLoad &lt;&gt; null then
			return self.myRORORequestLoad.isLinked();
		endif;
	else
		if self.myRORORequestDischarge  &lt;&gt; null then
			return self.myRORORequestDischarge.isLinked();
		endif;
	
	endif;
	
	return false;

epilog

end;</source>
