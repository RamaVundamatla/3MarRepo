    <JadeMethod name="doBtnSelectAreaShow" id="809794dd-194c-4098-b235-777a248cda0b">
        <updating/>
        <source>doBtnSelectAreaShow() updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	idx, max : Integer;
	railAreaColl : ObjectSet;
	
begin

	if self.tblTrains.allSelectedObjects.isEmpty and self.lstSelectAreas.selectedCount = 0 then
		self.showAreaSelectorEnable(false);
		return;
	endif;

	if self.tblTrains.allSelectedObjects.isEmpty then
		create railAreaColl transient;
		max := self.lstSelectAreas.listCount;
		foreach idx in 1 to max where self.lstSelectAreas.itemSelected[idx] do
			railAreaColl.add( self.lstSelectAreas.itemObject[idx] );
		endforeach;	
		self.setDisplayedObject( railAreaColl );
	else
		self.setDisplayedObject( self.tblTrains.allSelectedObjects );
	endif;

	self.myAssistant.comboBoxTrain(self.cmbTrain, self.myFilterTrain, false, self.isDisplayedRailAreas, false);

	self.doRefresh();

	self.showAreaSelectorEnable(false);

epilog
	delete railAreaColl;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnToolBarBubbleHelp" id="0d845c76-472e-45ef-a532-0cb4a4f9de05">
        <source>doBtnToolBarBubbleHelp(pButtonIndex : Integer) : String;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lBubbleHelp : String;
begin

	if pButtonIndex = VIEW_VOYAGE then
		lBubbleHelp := app.getErrorString(Show_voyage_colours); //"Show By Voyage Colours";
	elseif pButtonIndex = VIEW_COMMODITY then
		lBubbleHelp := app.getErrorString(Show_commodity_colours); //"Show By Commodity Colours";
	elseif pButtonIndex = VIEW_CONSIGNEE then
		lBubbleHelp := app.getErrorString(Show_consignee_colours); //"Show By Consignee Colours";
	elseif pButtonIndex = VIEW_DISPORT then
		lBubbleHelp := app.getErrorString(Show_dischar_port_colours); //"Show By Discharge Port Colours";
	elseif pButtonIndex = VIEW_ISOGROUP then
		lBubbleHelp := app.getErrorString(Show_group_colours); //"Show By ISO Group Colours";
	elseif pButtonIndex = VIEW_OPERATOR then
		lBubbleHelp := app.getErrorString(Show_operator_colours); //"Show By Operator Colours";
	elseif pButtonIndex = VIEW_STATUS then
		lBubbleHelp := app.getErrorString(Show_status_colours); //"Show By Status Colours";
	elseif pButtonIndex = VIEW_TEMPERATURE then
		lBubbleHelp := app.getErrorString(Show_temperatur_colours); //"Show By Temperature Colours";
	elseif pButtonIndex = VIEW_LEFT_TOP then
		lBubbleHelp := app.getErrorString(Left_area); //"Go to top left of area";
	elseif pButtonIndex = VIEW_RIGHT_TOP then
		lBubbleHelp := app.getErrorString(Right_area); //"Go to top right of area";
	elseif pButtonIndex = VIEW_LEFT_BOTTOM then
		lBubbleHelp := app.getErrorString(Bottom_left_area); //"Go to bottom left of area";
	elseif pButtonIndex = VIEW_RIGHT_BOTTOM then
		lBubbleHelp := app.getErrorString(Bottom_right_area); //"Go to bottom right of area";
	endif;	

	return lBubbleHelp;
end;</source>
        <Parameter name="pButtonIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doBtnToolBarLoadButtons" id="1c91e505-93b9-432c-9aa3-70d0a9361eb7">
        <source>doBtnToolBarLoadButtons();
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	LWidth = 20;
vars
	lControl : Control;
	lLeft,lSpaceIndex : Integer;
	root		: CM_Root;
	lPicture, lPictureDown : Picture;
begin

/*	root := app.myRoot;
	lSpaceIndex := self.frmToolBar.SpaceIndex;
	if self.frmToolBar.myButton.getControl(1) &lt;&gt; null then
		return;
	endif;
	//				lPicture := tmpRoot.getSystemConfig(PicHasTLs).Binary;

	self.frmToolBar.myButton.visible := false;
	self.frmToolBar.offSet := 1;
	self.frmToolBar.myParent := self;

	create lPicture transient;
	create lPictureDown transient;
	
	lPicture.picture := root.getConfig(PicVoyageUp).Binary;
	lPictureDown.picture := root.getConfig(PicVoyageDown).Binary;
	self.frmToolBar.addButton(lPicture, lPictureDown,VIEW_VOYAGE, self.doBtnToolBarBubbleHelp(VIEW_VOYAGE));
	
	lPicture.picture := root.getConfig(PicCommodityUp).Binary;
	lPictureDown.picture := root.getConfig(PicCommodityDown).Binary;
	self.frmToolBar.addButton(lPicture,lPictureDown,VIEW_COMMODITY, self.doBtnToolBarBubbleHelp(VIEW_COMMODITY));
	
	lPicture.picture := root.getConfig(PicConsigneeUp).Binary;
	lPictureDown.picture := root.getConfig(PicConsigneeDown).Binary;
	self.frmToolBar.addButton(lPicture, lPictureDown,VIEW_CONSIGNEE, self.doBtnToolBarBubbleHelp(VIEW_CONSIGNEE));

	lPicture.picture := root.getConfig(PicDisPortUp).Binary;
	lPictureDown.picture := root.getConfig(PicDisPortDown).Binary;
	self.frmToolBar.addButton(lPicture, lPictureDown,VIEW_DISPORT, self.doBtnToolBarBubbleHelp(VIEW_DISPORT));

	lPicture.picture := root.getConfig(PicISOUp).Binary;
	lPictureDown.picture := root.getConfig(PicISODown).Binary;
	self.frmToolBar.addButton(lPicture, lPictureDown,VIEW_ISOGROUP, self.doBtnToolBarBubbleHelp(VIEW_ISOGROUP));

	lPicture.picture := root.getConfig(PicOperatorUp).Binary;
	lPictureDown.picture := root.getConfig(PicOperatorDown).Binary;
	self.frmToolBar.addButton(lPicture, lPictureDown,VIEW_OPERATOR, self.doBtnToolBarBubbleHelp(VIEW_OPERATOR));

	lPicture.picture := root.getConfig(PicStatusUp).Binary;
	lPictureDown.picture := root.getConfig(PicStatusDown).Binary;
	self.frmToolBar.addButton(lPicture, lPictureDown,VIEW_STATUS, self.doBtnToolBarBubbleHelp(VIEW_STATUS));

	lPicture.picture := root.getConfig(PicTempUp).Binary;
	lPictureDown.picture := root.getConfig(PicTempDown).Binary;
	self.frmToolBar.addButton(lPicture, lPictureDown,VIEW_TEMPERATURE, self.doBtnToolBarBubbleHelp(VIEW_TEMPERATURE));

	lPicture.picture := root.getConfig(PicToolBarSpace).Binary;
	lPictureDown.picture := lPicture.picture;
	self.frmToolBar.addButton(lPicture, lPictureDown,lSpaceIndex, null);
	lSpaceIndex := lSpaceIndex + 1;

	lPicture.picture := root.getConfig(PicArrowLTUp).Binary;
	lPictureDown.picture := root.getConfig(PicArrowLTDown).Binary;
	self.frmToolBar.addButton(lPicture, lPictureDown,VIEW_LEFT_TOP, self.doBtnToolBarBubbleHelp(VIEW_LEFT_TOP));

	lPicture.picture := root.getConfig(PicArrowRTUp).Binary;
	lPictureDown.picture := root.getConfig(PicArrowRTDown).Binary;
	self.frmToolBar.addButton(lPicture, lPictureDown,VIEW_RIGHT_TOP, self.doBtnToolBarBubbleHelp(VIEW_RIGHT_TOP));

	lPicture.picture := root.getConfig(PicArrowLBUp).Binary;
	lPictureDown.picture := root.getConfig(PicArrowLBDown).Binary;
	self.frmToolBar.addButton(lPicture, lPictureDown,VIEW_LEFT_BOTTOM, self.doBtnToolBarBubbleHelp(VIEW_LEFT_BOTTOM));

	lPicture.picture := root.getConfig(PicArrowRBUp).Binary;
	lPictureDown.picture := root.getConfig(PicArrowRBDown).Binary;
	self.frmToolBar.addButton(lPicture, lPictureDown,VIEW_RIGHT_BOTTOM, self.doBtnToolBarBubbleHelp(VIEW_RIGHT_BOTTOM));

	// sgp 4 August 2003 : Multi-select button not relevant here
//	lPicture.picture := root.getConfig(PicToolBarSpace).Binary;
//	lPictureDown.picture := lPicture.picture;
//	self.frmToolBar.addButton(lPicture, lPictureDown,lSpaceIndex, null);
//	lSpaceIndex := lSpaceIndex + 1;

//	lPicture.picture := root.getConfig(PicMultiSelectUp).Binary;
//	lPictureDown.picture := root.getConfig(PicMultiSelectDown).Binary;
//	self.frmToolBar.addButton(lPicture, lPictureDown,VIEW_MULTI_SELECT, self.doBtnToolBarBubbleHelp(VIEW_MULTI_SELECT));
epilog
	delete	lPicture;
	delete lPictureDown;*/

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnToolBarMouseUp" id="b7f812d4-3e7b-451b-88ce-1721df43c1f5">
        <updating/>
        <source>doBtnToolBarMouseUp(jadeMask: JadeMask input) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars

begin
/*
	if jadeMask.index &lt;= VIEW_TEMPERATURE then
		self.frmModeStatusBar.myFrameCaption.caption := self.mySDF.setViewMode(jadeMask.index);
		if (not self.mySDF.allGridAreasByRowColumn.isEmpty) then
			self.mySDF.drawSelf();
		endif;
		if not self.frmColLegendTIs.displayViewModeCodes(self.mySDF.viewMode, self.mySDF.myDrawingAttrController) then
			self.frmColLegendTIs.doChangeViewMode(jadeMask.index);
		endif;
	endif;
	
	if jadeMask.index = VIEW_LEFT_TOP 
	or jadeMask.index = VIEW_RIGHT_TOP 
	or jadeMask.index = VIEW_LEFT_BOTTOM 
	or jadeMask.index = VIEW_RIGHT_BOTTOM then
		self.doScrollToCorners(jadeMask.index);
	endif;	
*/
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBuildAttachCaption" id="94f062d6-6cc2-4f98-bd7e-2e28b5d7a8c4">
        <updating/>
        <source>doBuildAttachCaption(_theTI : CM_TrackedItem; _theAction : Integer io) : String updating, protected;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theContainer : CM_Container;
	theCOU, theCaption : String;
	
begin
	if _theTI &lt;&gt; null then
		if _theTI.isKindOf(CM_Container) then
			theContainer := _theTI.CM_Container;
			if theContainer.isPortHole then
				theCOU := theContainer.couId.trimBlanks;
				if theCOU.trimBlanks = null then
					theCOU := "COU";
				endif;
				if theContainer.hasCOU then
					_theAction := ACTION_DISCONNECT;
					theCaption := theContainer.id &amp; " " &amp; app.getErrorString(Detach_from) &amp; " " &amp;  theCOU ; //" Detach From " &amp; theCOU ;
				else
					_theAction := ACTION_CONNECT;
					theCaption := theContainer.id &amp; " " &amp; app.getErrorString(Attach_TOOOO) &amp; " " &amp; theCOU; //" Attach To " &amp; theCOU;
				endif;
			endif;
		endif;				
	endif;

	return theCaption;
end;</source>
        <access>protected</access>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theAction" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doBuildMenuCargo" id="683904f1-ba26-4c4f-85b7-9c9e77f6f884">
        <updating/>
        <source>doBuildMenuCargo(ti : CM_TrackedItem input) protected, updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/06/2010	cnwcs5		par 24342 - new form for maintaining stops
// ---------------------------------------------------------------------------
vars
	theAction : Integer;
	menuItemSwapCaption : String;
	useTaskForm : Boolean;

begin

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	self.mnuCargo.visible := true;
	self.mnuCargoEnquiry.userObject := ti;
	self.mnuCargoEnquiry.caption := app.getErrorString(CMUI_Enquiry) &amp; ti.id ;

	self.mnuCargoEdit.userObject := ti;
	self.mnuCargoEdit.caption := app.getErrorString(CMUI_Edit) &amp; ti.id;
	self.mnuCargoEdit.visible := true;

	if ti.isKindOf(CM_TILC) then
		if ti.CM_TILC.myGenerator = null then
			self.mnuCargoAttachGenSet.visible := true;
			self.mnuCargoAttachGenSet.userObject := ti;
		else
			self.mnuCargoDetachGenSet.visible := true;
			self.mnuCargoDetachGenSet.userObject := ti;
		endif;
	endif;

	self.mnuCargoMoveIt.visible := true;
	self.mnuCargoMoveIt.userObject := ti;

	self.mnuCargoTestAP.visible := true;
	self.mnuCargoTestAP.userObject := ti;
	self.mnuCargoTestAP.caption := app.getErrorString(YRDTestAutoPlan) &amp; ti.id &amp; "...";
	
	self.mnuCargoAP.visible := true;
	//epr par 36069 6/5/15
	if self.isMultiSelect then	
		self.mnuCargoAP.caption := app.getErrorString(Auto_queue_selected_item);
	else
		self.mnuCargoAP.caption := app.getErrorString1(Auto_queue,  ti.id);
	endif;
	//12 Aug 2009	NDL	CCMS 1094
	if self.allowCargoPositionSwap( menuItemSwapCaption ) then
		self.mnuCargoPositionSwap.caption := menuItemSwapCaption;
		self.mnuCargoPositionSwap.visible := true;
	else
		self.mnuCargoPositionSwap.visible := false;
	endif;

	self.doBuildUnplanMenu(self.mnuCargoUnplan,self.mnuCargoUnqueue, ti);

	//07 Oct 2015	NDL	Par 37011
	useTaskForm := self.myTerminal.getConfig(UseTaskFormCount).Boolean;
	if useTaskForm then
		self.mnuCargoTaskAdd.visible := true;
		self.mnuCargoTaskComplete.visible := true;
		self.mnuCargoTaskRemove.visible := true;
		self.mnuCargoTaskRemarks.visible := true;
		
		self.mnuTaskAdd.visible := false;
		self.mnuTaskComplete.visible := false;
		self.mnuTaskAdd.userObject := null;
		self.mnuTaskComplete.userObject := null;
	else
		self.mnuCargoTaskAdd.visible := false;
		self.mnuCargoTaskComplete.visible := false;
		self.mnuCargoTaskRemove.visible := false;
		self.mnuCargoTaskRemarks.visible := false;
		
		self.mnuTaskAdd.visible := true;
		self.mnuTaskComplete.visible := true;
		self.mnuTaskAdd.userObject := ti;
		self.mnuTaskComplete.userObject := ti;
	endif;
	
//	self.mnuTaskAdd.visible := true;
//	self.mnuTaskComplete.visible := true;
	self.mnuStops.visible := true;
//	self.mnuTaskAdd.userObject := ti;
//	self.mnuTaskComplete.userObject := ti;
	self.mnuStops.userObject := ti;
	
	self.doBuildMnuTasksAdd(ti);	
	self.doBuildMnuTasksComplete(ti);	
	self.doBuildMnuTasksRemove(ti);	
	// par 24342 - self.doBuildMnuStops(ti);	
	
	//epr par 32261 19/8/13
	self.myAssistant.menuSetGradeBuild(self.mnuCargoSetGrade,self.mnuSetGradeSub,ti);
	
	
	if not ti.isKindOf(CM_Container) then
		return;
	endif;

	self.mnuCargoAttach.caption := self.doBuildAttachCaption(ti,theAction);
	if ti.CM_Container.hasCOU then
		self.mnuCargoAttach.visible := true;
		self.mnuCargoAttach.userObject := ti;
	endif;
	if ti.CM_Container.isPortHole then // isPortHole is designed for attaching COU
		self.mnuCargoAttach.visible := true;
		self.mnuCargoAttach.userObject := ti;
	endif;

	if ti.CM_Container.isReefer then
		if ti.CM_Container.getGenerator = null then
			self.mnuCargoAttachGenSet.visible := true;
			self.mnuCargoAttachGenSet.userObject := ti;
		else
			self.mnuCargoDetachGenSet.visible := true;
			self.mnuCargoDetachGenSet.userObject := ti;
		endif;
	endif;

	self.mnuCargoLCL.visible := true;
	self.mnuCargoLCL.userObject := ti;
	self.mnuCargoLCL.caption := app.getErrorString(CMUI_Pack_Unpack) &amp; ti.id;
	
	self.mnuCargoRemarks.visible := true;
	self.mnuCargoRemarks.userObject := ti;
	self.mnuCargoRemarks.caption := app.getErrorString(Remarks_GC) &amp; ti.id;
	
	
end;</source>
        <access>protected</access>
        <Parameter name="ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBuildMenuNullWagon" id="e249a6b7-f425-4a99-88a4-0a9b503ebe7b">
        <updating/>
        <source>doBuildMenuNullWagon(frame:Frame input;_x, _y : Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theRow, theEnd, idx : Integer;
	theX, theY : Real;
	foundPoint,
	tmpPoint	: CMUI_GridPoint;
	tmpRow		: CMUI_GridRow;
	theRailLine : CM_RailLine;		
	lCaption	: String;
	mnuChild, mnuChildSub	: MenuItem;
	theWagon : CM_Wagon;
	mnuIndex 	: Integer;
	allWagonClasses, theMenuObjects : ObjectArray;
	aWagonClass : CM_WagonClass;
	anObject : Object;
	theWagonArea: YRD_WagonArea;
	
begin
	// clear out any objects created in the wagon menus
	self.doClearTransientObjects();

	self.mnuWagonConfirm.visible := false;

	foreach idx in 1 to  50  do
		mnuChild := mnuWagonConfirm.getMenuItem(idx); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
	endforeach;

	if frame = null or not frame.isKindOf(CMUI_GridAreaFrame) then
		return;
	endif;
	
	if frame.CMUI_GridAreaFrame.myGridArea = null 
	or	not frame.CMUI_GridAreaFrame.myGridArea.isKindOf(YRD_WagonArea) then
		return;
	endif;

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	theWagonArea := frame.CMUI_GridAreaFrame.myGridArea.YRD_WagonArea;
	theRailLine := theWagonArea.myRailLine;
	
	if theRailLine = null then
		return;
	endif;

	// WAGON NEW ADD, via maintenance form

	self.mnuWagonConfirm.visible := true;
	self.mnuWagonConfirm.userObject := theRailLine;
	self.mnuWagonConfirm.caption := app.getErrorString(Confirm_wagon_TOOO) &amp; " " &amp; theRailLine.getIdString() &amp; '...'; //"Confirm Wagon To " &amp; theRailLine.getIdString &amp; '...';
	
	theEnd := theRailLine.maximumWagons;
	if theEnd &gt; 50 then
		theEnd := 50;
	endif;
	
	foreach idx in 1 to  theEnd  do
		mnuChild := mnuWagonConfirm.getMenuItem(idx); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
	endforeach;
	
	foreach idx in 1 to  theEnd  do

		theWagon := null;
		if theRailLine.allWagons.size &gt;= idx then
			theWagon := theRailLine.allWagons[idx];
		endif;
		
		if theWagon &lt;&gt; null and theWagon.confirmed then
			continue;
		endif;
		
		lCaption := app.getErrorString(Position_TRAIN) &amp; " " &amp; idx.String ; // "Position " &amp; idx.String ;
		mnuChild := mnuWagonConfirm.getMenuItem(idx); // check if the menu is already cloned
		if mnuChild = null then
			mnuChild := mnuWagonConfirm.loadSubMenu(idx); // Clone menu
		endif;
		mnuChild.caption := lCaption;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := idx.String;
		mnuChild.userObject := theRailLine;
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doBuildMenuWagon" id="d91511f0-b18c-4856-822c-8e7ca7eeee5b">
        <source>doBuildMenuWagon(_defaultWagon : CM_Wagon) protected;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idStr : String;
	train : CM_Train;
	wagon : CM_Wagon;
	wagonColl : CM_WagonSet;
	
begin
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	create wagonColl transient;
	self.getSelectedWagons( wagonColl, _defaultWagon );
	
	if wagonColl.isEmpty then
		return;
	elseif wagonColl.size = 1 then
		wagon := wagonColl.first;
		idStr := wagon.id;
	else
		idStr := app.getErrorString(Selected_wagons);	
	endif;

	self.mnuWagonEnquiry.caption := app.getErrorString(CMUI_Enquiry) &amp; idStr  &amp; '...';
	self.mnuWagonEnquiry.visible := true;
	self.mnuWagonEnquiry.userObject := wagon;

	if wagon &lt;&gt; null and wagon.hasMasterCargoRestriction() and not wagon.confirmed then
		self.mnuWagonCC.visible := false; //Don't let them add colour coding yet, or it will be overridden when confirming in
	else
		self.mnuWagonCC.caption := app.getErrorString(COLOUR_CODE) &amp; idStr &amp; '...' ;
		self.mnuWagonCC.visible := true;
		self.mnuWagonCC.userObject := wagon;
	endif;
	
	// 24 July 2009	NDL
	self.mnuInTransitNO.caption := app.getErrorString(Set_Not_In_Transit) &amp; idStr;
	self.mnuInTransitNO.visible := true;
	self.mnuInTransitNO.userObject := wagon;
	// 24 July 2009	NDL
	//self.mnuInTransit.caption := app.getErrorString(Set_In_Transit) &amp; idStr;
	self.mnuInTransit.caption := app.getErrorString1(Set_in_transit, idStr);
	self.mnuInTransit.visible := true;
	self.mnuInTransit.userObject := wagon;
	//27 July 2009	NDL
	if wagon &lt;&gt; null and wagon.hasMasterCargoRestriction() and not wagon.confirmed then
		self.mnuRemColour.visible := false; //Don't let them add colour coding yet, or it will be overridden when confirming in
	else
		self.mnuRemColour.caption := app.getErrorString1(Remove_colour_code, idStr);
		self.mnuRemColour.visible := true;
		self.mnuRemColour.userObject := wagon;
	endif;

	if wagon &lt;&gt; null then
		self.mnuWagonEdit.caption := app.getErrorString(CMUI_Edit) &amp; idStr &amp; '...';
		self.mnuWagonEdit.visible := true;
		self.mnuWagonEdit.userObject := wagon;
		
		// 24 July 2009	NDL
		if wagon.isInTransit then
			self.mnuInTransit.visible := false;
		else
			self.mnuInTransitNO.visible := false;
		endif;
		//27 July 2009	NDL
		self.mnuRemColour.visible := wagon.getRailAllocation &lt;&gt; null;
	
		self.mnuConfirmWagonOut.visible := false;
		self.mnuUnconfirmWagonOut.visible := false;
		if app.getMyTerminalConfigDO_NOT_USE(UseOutwardRailConfirm).Boolean then
			if wagon &lt;&gt; null and wagon.confirmed then
				if wagon.confirmedOutwards then
					self.mnuUnconfirmWagonOut.visible := true;
					self.mnuUnconfirmWagonOut.userObject := wagon;
				else
					self.mnuConfirmWagonOut.visible := true;
					self.mnuConfirmWagonOut.userObject := wagon;
				endif;
			endif;
		endif;
		
	endif;
	
	self.mnuWagonMaster.visible := ( wagon &lt;&gt; null and wagon.myWagonMaster &lt;&gt; null );	//07 Feb 2014	NDL	Par 33439
	if self.mnuWagonMaster.visible then
		self.mnuWagonMaster.enabled := app.getMyUser.canDo( wagon.myTerminal, PmWagonCargoRestrict );
		self.mnuWagonMaster.userObject := wagon.myWagonMaster;
	endif;
	
	//  Train Enquiry
	
	self.mnuTrainEnquiry.visible := true;
	self.mnuTrainEnquiry.userObject := null;		
	
	foreach wagon in wagonColl do
		if wagon &lt;&gt; null then
			if self.outwardsTrain then
				train := wagon.myTrainOutwards;
			else
				train := wagon.myTrainInwards;
			endif;
		endif;
		if self.mnuTrainEnquiry.userObject = null then
			self.mnuTrainEnquiry.userObject := train;
		elseif self.mnuTrainEnquiry.userObject &lt;&gt; train and train &lt;&gt; null then
			self.mnuTrainEnquiry.userObject := null;		
			break;
		endif;
	endforeach;
		
end;</source>
        <access>protected</access>
        <Parameter name="_defaultWagon" type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="doBuildMenuWgnBody" id="1e3c19d6-078b-4b19-b19a-654f1c3bb526">
        <source>doBuildMenuWgnBody(wagonBody : YRD_WagonBody) protected;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	wgnController : CM_WagonController;
	
begin
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	wgnController := wagonBody.myLocationsController.CM_WagonController;
	
	self.mnuTwistUp.checked := false;
	self.mnuTwistLocked.checked := false;
	self.mnuTwistAvail.checked := false;
	self.mnuTwistNA.checked := false;

	if wgnController.twistlocksAreUp then
		self.mnuTwistUp.checked := true;
	elseif wgnController.hasTwistlocks then
		self.mnuTwistLocked.checked := true;
	elseif wgnController.isAvailable then
		self.mnuTwistAvail.checked := true;
	else
		self.mnuTwistNA.checked := true;
	endif;

	self.mnuWagonTwistlock.visible := true;
	self.mnuWagonTwistlock.userObject := wagonBody;
	
	
end;</source>
        <access>protected</access>
        <Parameter name="wagonBody" type="YRD_WagonBody"/>
    </JadeMethod>
    <JadeMethod name="doBuildMenuZoom" id="cfffafd3-644b-4f2a-b3f4-d188a442a1d3">
        <source>doBuildMenuZoom() protected;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	idx	: Decimal[3,1];
	lFactor : Real;
	lIndex : Integer;
	lCaption : String;
	mnuChild : MenuItem;
	gridArea : CMUI_GridArea;
	
begin
	self.mnuZoomSub.visible := true;
	
	gridArea := self.myCurrentSDF.allGridAreasByRowColumn.first;
	if gridArea = null then
		self.mnuZoomSub.visible := false;
		return;
	endif;

	lFactor := gridArea.scaleXFactor;
	
	foreach idx in 1 to 4 step 0.5 do

		//lCaption := "View At " &amp; idx.String &amp; " Scale" ;
		lCaption := app.getErrorString1(View_scale_ZOOM, idx.String);
		lIndex := (idx * 2).Integer;
		mnuChild := mnuZoomSub.getMenuItem(lIndex); // check if the menu is already cloned
		if mnuChild = null then
			mnuChild := mnuZoomSub.loadSubMenu(lIndex); // Clone menu
		endif;
		mnuChild.caption := lCaption;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := idx.String;
		if lFactor = idx then
			mnuChild.checked := true;
		else
			mnuChild.checked := false;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBuildMnuTasksAdd" id="844554ae-e2b5-48a7-ba04-da7c2c5d672b">
        <updating/>
        <source>doBuildMnuTasksAdd(_theTI : CM_TrackedItem input) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	dynaDict	: DynaDictionary;
	obj			: Object;
	taskDesc	: CM_ToDoTaskDesc;
	mnuChild,mnuMaster	: MenuItem;
	taskDict		: CM_ToDoTaskDescByCode;
	useTaskForm : Boolean;
	
begin

	//07 Oct 2015	NDL	Par 37011
	useTaskForm := self.myTerminal.getConfig(UseTaskFormCount).Boolean;
	if useTaskForm then
		self.mnuTaskAdd.visible := false;
		return;
	endif;
	
	create taskDict transient;
	app.myPassport.myUser.getToDoTasksAddRemoveForTerm(self.myTerminal, taskDict);
	if taskDict.isEmpty then
		// no permission to add any tasks
		self.mnuTaskAdd.visible := false;
		return;
	endif;

	// ##############################################
	// Build up menu of ToDo Tasks that can be set
	mnuMaster := self.mnuTaskAdd;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.caption := app.getErrorString(Tasks_ADDDDdd); //"Add Tasks";
	self.mnuTaskAddSub.visible := true;

	// 36868 sort menu items by sortKey then description, so that if there is no sort key or it is not unique then the description becomes the main sort field
	create dynaDict transient;
	dynaDict.setMembership(CM_ToDoTaskDesc);
	dynaDict.addMemberKey("sortKey", false, true);
	dynaDict.addMemberKey("description", false, true);
	dynaDict.endKeys(true);
	
	foreach taskDesc in taskDict do
		dynaDict.add(taskDesc);
	endforeach;

	foreach obj in dynaDict do
		taskDesc := obj.CM_ToDoTaskDesc;
		// Always delete the tasks to complete menu
		mnuChild := mnuTaskComplete.getMenuItem(taskDesc.code); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
		mnuChild := mnuTaskRemove.getMenuItem(taskDesc.code); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;

		if taskDesc.description = null then 
			continue;
		endif;
		
		// DVB added to screen for cargo type.
		if not taskDesc.isAvailableForCargoType(_theTI.cargoType) then
			continue;
		endif;
		
		if not taskDesc.isValidForGenSet( _theTI ) then
			mnuChild := mnuMaster.getMenuItem(taskDesc.code); // check if the menu is already cloned
			if mnuChild &lt;&gt; null then
				delete mnuChild;
			endif;
			continue;
		endif;

		// add each todo task type into the add menu
		mnuChild := mnuMaster.getMenuItem(taskDesc.code); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
		self.mnuTaskAddSub.visible := false;
		mnuChild := mnuMaster.loadSubMenu(taskDesc.code); // Clone menu
		mnuChild.caption := taskDesc.description;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := taskDesc.description;
		mnuChild.userObject := _theTI;
	endforeach;

epilog
	delete taskDict;
	delete dynaDict;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuTasksComplete" id="b964b1fd-48cb-4109-8af4-aab1606f1b13">
        <updating/>
        <source>doBuildMnuTasksComplete(_theTI : CM_TrackedItem input) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	task	: CM_ToDoTask;
	taskDesc	: CM_ToDoTaskDesc;
	idx	: Decimal[3,1];
	lFactor : Real;
	lIndex,lMoveMode : Integer;
	lCaption	: String;
	mnuChild,mnuMaster	: MenuItem;
	mnuIndex 	: Integer;
	lPicture : Picture;
	root : CM_Root;
	taskDict		: CM_ToDoTaskDescByCode;
	useTaskForm : Boolean;

begin

	//07 Oct 2015	NDL	Par 37011
	useTaskForm := self.myTerminal.getConfig(UseTaskFormCount).Boolean;
	if useTaskForm then
		self.mnuTaskComplete.visible := false;
		return;
	endif;

	taskDict := app.myPassport.myUser.getToDoTasksCompleteForTerm(self.myTerminal);
	if taskDict.isEmpty then
		// no permission to complete any tasks
		self.mnuTaskComplete.visible := false;
		return;
	endif;

	// ##############################################
	// Build up menu of ToDo Tasks that have been set, but are uncomplete
	mnuMaster := self.mnuTaskComplete;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.caption := app.getErrorString(Complete_tasksSS); //"Complete Tasks";
	self.mnuTaskCompleteSub.visible := true;
	self.mnuTaskCompleteSub.caption := app.getErrorString(Tasks_NOOoo); //"No Tasks";
	
	foreach task in _theTI.allToDoTasksToDo do
	
		// Hide the todo tasks inthe add menu that we already have to do
		mnuChild := self.mnuTaskAdd.getMenuItem(task.toDoTaskDescCode); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			mnuChild.visible := false;
		endif;
		
		if (not taskDict.includes(task.toDoTaskDesc)) then
			// user does not have permission to complete this task
			continue;
		endif;
		
		if task.toDoTaskDesc.isForGenSetAttachDetach() then	// Attach / detach generator cannot be completed manually
			continue;
		endif;

		// create a list of the todo tasks that we have to do
		mnuChild := mnuMaster.getMenuItem(task.toDoTaskDescCode); // check if the menu is already cloned
		// always delete as this is different for each TI
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
		self.mnuTaskCompleteSub.visible := false;
		mnuChild := mnuMaster.loadSubMenu(task.toDoTaskDescCode); // Clone menu
		mnuChild.caption := task.toDoTaskDescDesc;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := task.toDoTaskDescDesc;
		mnuChild.userObject := _theTI;
	endforeach;

	
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuTasksRemove" id="937a5904-313c-40a1-b256-08fa39151260">
        <updating/>
        <source>doBuildMnuTasksRemove(_theTI : CM_TrackedItem input) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	task	: CM_ToDoTask;
	taskDesc	: CM_ToDoTaskDesc;
	idx	: Decimal[3,1];
	lFactor : Real;
	lIndex,lMoveMode : Integer;
	lCaption	: String;
	mnuChild,mnuMaster	: MenuItem;
	mnuIndex 	: Integer;
	lPicture : Picture;
	root : CM_Root;
	taskDict		: CM_ToDoTaskDescByCode;
	useTaskForm : Boolean;

begin

	//07 Oct 2015	NDL	Par 37011
	useTaskForm := self.myTerminal.getConfig(UseTaskFormCount).Boolean;
	if useTaskForm then
		self.mnuTaskRemove.visible := false;
		return;
	endif;

	create taskDict transient;
	app.myPassport.myUser.getToDoTasksAddRemoveForTerm(self.myTerminal, taskDict);
	if taskDict.isEmpty then
		// no permission to remove any tasks
		self.mnuTaskRemove.visible := false;
		return;
	endif;

	// ##############################################
	// Build up menu of ToDo Tasks that have been set, but are uncomplete
	mnuMaster := self.mnuTaskRemove;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.caption := app.getErrorString(Remove_tasksSS); //"Remove Tasks";
	self.mnuTaskRemoveSub.visible := true;
	self.mnuTaskRemoveSub.caption := app.getErrorString(Tasks_NOOoo); //"No Tasks";
	
	foreach task in _theTI.allToDoTasksToDo do
	
		// Hide the todo tasks inthe add menu that we already have to do
		mnuChild := self.mnuTaskAdd.getMenuItem(task.toDoTaskDescCode); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			mnuChild.visible := false;
		endif;
		
		if (not taskDict.includes(task.toDoTaskDesc)) then
			// user does not have permission to add/remove this task
			continue;
		endif;
		
		// create a list of the todo tasks that we have to do
		mnuChild := mnuMaster.getMenuItem(task.toDoTaskDescCode); // check if the menu is already cloned
		// always delete as this is different for each TI
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
		self.mnuTaskRemoveSub.visible := false;
		mnuChild := mnuMaster.loadSubMenu(task.toDoTaskDescCode); // Clone menu
		mnuChild.caption := task.toDoTaskDescDesc;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := task.toDoTaskDescDesc;
		mnuChild.userObject := _theTI;
	endforeach;
epilog
	delete taskDict;
	
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuZoom" id="bdf674ee-bbad-4f59-9f3f-2c160d50f34d">
        <source>doBuildMnuZoom();
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------

vars

	idx	: Decimal[3,1];
	lFactor : Real;
	lIndex : Integer;
	lCaption : String;
	mnuChild : MenuItem;
	mnuIndex : Integer;
	gridArea : CMUI_GridArea;
	
begin
	self.mnuGridAreaContext.enabled := true;
	
	gridArea := self.myCurrentSDF.allGridAreasByRowColumn.first;
	if gridArea = null then
		self.mnuZoomSub.visible := false;
		return;
	endif;

	lFactor := gridArea.scaleXFactor;
	
	foreach idx in 1 to 4 step 0.5 do

		//lCaption := "View At " &amp; idx.String &amp; " Scale" ;
		lCaption := app.getErrorString1(View_scale_ZOOM, idx.String);
		lIndex := (idx * 2).Integer;
		mnuChild := mnuZoomSub.getMenuItem(lIndex); // check if the menu is already cloned
		if mnuChild = null then
			mnuChild := mnuZoomSub.loadSubMenu(lIndex); // Clone menu
		endif;
		mnuChild.caption := lCaption;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := idx.String;
		if lFactor = idx then
			mnuChild.checked := true;
		else
			mnuChild.checked := false;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildQueryLists" id="15996c55-71d7-429a-acc5-9dc0cfda27ca">
        <source>doBuildQueryLists();
// ---------------------------------------------------------------------------
// Created:     May 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
	iter : Iterator;
	terminalArea : CM_TerminalArea;
	theFrame : CMUI_MoveableFrame;
	train : CM_Train;
	theDataLine : String;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	
	//  Trains

	self.tblTrains.rows := self.tblTrains.fixedRows;
	foreach train in self.myTerminal.allTrainsOnTerminal do
		if train.isNullTrain() 
		or train.isDeparted() then	// 26/01/2012 cnwar2 #28704
			continue;
		endif;
		theDataLine := train.getAttributeStringForDefArray(self.tblTrains.allTblDataEntRows);
		idx := self.tblTrains.addItem(theDataLine);
		self.tblTrains.accessRow(idx).itemObject := train;

	endforeach;

	//  Rail Areas

	self.lstSelectAreas.clear();
	
	iter := self.myTerminal.allTerminalAreasByTypeId.createIterator();
	self.myTerminal.allTerminalAreasByTypeId.startKeyGeq(TA_TYPE_RAILWAY_TRACK, null, iter);

	while iter.next(terminalArea) do
		if iter.getCurrentKey(1).Integer &lt;&gt; TA_TYPE_RAILWAY_TRACK then
			break;
		endif;
		idx := self.lstSelectAreas.addItem(terminalArea.id);
		self.lstSelectAreas.itemObject[idx] := terminalArea;
	endwhile;

epilog
	delete iter;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCargoPositionSwap" id="e2c48d1d-30c3-4d8d-a906-8bad7937fdfd">
        <updating/>
        <source>doCargoPositionSwap(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2009	cnwndl1	Initial creation

*/

vars

	selectedCargo : CM_TIArray;
	result : Integer;
	
begin
	
	create selectedCargo transient;
	self.mySDF.getAllSelectedTIs( selectedCargo );
	
	self.myAssistant.YRD_Assistant.doCargoPositionSwap( null, selectedCargo );
	
	if app.myPassport.trxCompletedOK then
		return;
	else
		result := app.showErrorWarningDialog(app.getErrorString(Cargo_swap), app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
		if app.myPassport.noErrors and result = IDOK then
			// there must have just been warnings that the user has acknowledged so ..
			app.myPassport.warningsAcknowledged	:= true;
			app.myPassport.setWarningsIgnored(true);
			self.clearErrorWarnings();
			return;
		endif;
	endif;

epilog

	delete selectedCargo;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doClearTransientObjects" id="e1317229-bc87-44c5-97d6-a70fca2ce188">
        <source>doClearTransientObjects();
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	anObject : Object;
begin
	foreach anObject in self.allTransientObjects do
		if global.isValidObject(anObject) then
			delete anObject;
		endif;
	endforeach;
	self.allTransientObjects.clear;
end;</source>
    </JadeMethod>
    <JadeMethod name="doClonedMenuClickSpecial" id="7c88d5e0-4e8a-4467-98e3-cc1d6992f206">
        <updating/>
        <source>doClonedMenuClickSpecial(menuItem: MenuItem input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 October 2015	cnwndl1	Initial creation	Par 37011

*/

vars

	obj	: Object;
	ti : CM_TrackedItem;
	realTiSet : CM_TISet;
	taskFormName : String;
	taskFormNameLength : Integer;
	passedAction : Integer;
	selectedCargo : CM_TIArray;

begin
	
	taskFormName := CMUI_TasksForm.name;
	taskFormNameLength := taskFormName.length;
	if menuItem.helpKeyword.length &gt; taskFormNameLength and menuItem.helpKeyword[1:taskFormNameLength] = taskFormName then
		passedAction := menuItem.helpKeyword[taskFormNameLength + 2:1].Integer;
		create realTiSet transient;
		create selectedCargo transient;
		self.mySDF.getAllSelectedTIs( selectedCargo );
		if not selectedCargo.isEmpty then
			selectedCargo.copy(realTiSet);
		endif;
		ti  := self.myCurrentTrackedItem;
		if ti = null and realTiSet.isEmpty then
			return;
		endif;
		self.myAssistant.showTasksForm (ti, realTiSet, true, passedAction );
		return;
	endif;

	inheritMethod(menuItem);

epilog

	delete realTiSet;
	delete selectedCargo;

end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
