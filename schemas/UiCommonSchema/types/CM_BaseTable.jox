    <JadeMethod name="setLastColumnMaxWidth" id="c10a64f4-32ba-4949-901a-5bcd720d3d91">
        <updating/>
        <source>setLastColumnMaxWidth()  updating;
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	numCols,
	idx, 
	lastColWidth,
	totColWidth, 
	lastVisibleCol		: Integer;
	tmpSheet			: JadeTableSheet;
begin
	tmpSheet := self.accessSheet(self.topSheet); 
	numCols := tmpSheet.columns;

	if numCols = 0 then
		return;
	endif;

	foreach idx in 1 to numCols do
		if tmpSheet.accessColumn(idx).visible then
			lastVisibleCol 	:= idx;
			lastColWidth 	:= self.accessedColumn.width;
			totColWidth 	:= totColWidth + lastColWidth;
		endif;
	endforeach;
			
	if lastVisibleCol = 0 then
		// no visible columns
		return;
	endif;

	if totColWidth &lt; self.width then
		// need to stretch last column to width
		tmpSheet.accessColumn(lastVisibleCol).width := ((self.width - 1 - 2 - totColWidth) + lastColWidth).Integer;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setMargins" id="95cbe930-1525-4e65-bee3-9e4eaf4d7c93">
