    <JadeMethod name="validateForUpdate" id="cae93982-5fce-4487-bc2f-18aef85900f7">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2023 navtnr20	TFS CR 57983 Task 57984: EUP - INCO Terms TRX Layer

*/

vars
	existingInvoiceDebtorTerm ,
	realInvoiceDebtorTerm     : CM_InvoiceINCOTerm;
	contract : CM_InvoiceContract;
begin
	if self.code = null then
        app.raiseCMException(Input_required_field_code, null, self);
    endif;
	
	if self.description = null then
		app.raiseCMException(Input_required_field_desc, null ,self);
	endif;
	if self.myBusinessUnit = null then
		app.raiseCMException(Input_required_field_BusUnit, null ,self);
	endif;
	realInvoiceDebtorTerm	:= self.pxyGetRealObject();
	
	existingInvoiceDebtorTerm := self.myBusinessUnit.allInvoiceINCOTerms[self.code];
	if existingInvoiceDebtorTerm &lt;&gt; null
	and existingInvoiceDebtorTerm &lt;&gt; realInvoiceDebtorTerm then
		app.raiseCMException1(Incoi_categ_inco_term_alrea_ex, self.code, null, null); 
	endif;	
epilog

end;</source>
    </JadeMethod>
</Class>
