    <JadeMethod name="getOrderTimesForMoveType" id="7a24729f-ca98-4a68-82f2-015a6bea0a57">
        <source>getOrderTimesForMoveType(_moveType : String; _fromBerth, _toBerth : HMS_Berth; _timePilot, _timeTugs, _timeLines : Integer output);
//--------------------------------------------------
// Created:	23 February 2005 By: cnwgd1
//--------------------------------------------------
vars

begin

	// Returns initialise value for 'MARINE SERVICES ORDER TIMES'
	if _moveType = HMSMovementTypeArrival then
		if self.defaultOrderTimesArrive.size &gt; 2 then
			_timeLines := self.defaultOrderTimesArrive[1];
			_timePilot := self.defaultOrderTimesArrive[2];
			_timeTugs := self.defaultOrderTimesArrive[3];
		endif;
	
	elseif _moveType = HMSMovementTypeShift then
		
		if _fromBerth &lt;&gt; null
		and _toBerth &lt;&gt; null then
			if _fromBerth.noMarineServices = true and 
				_toBerth.noMarineServices = false then
				if self.defaultOrderTimesArrive.size &gt; 2 then
					_timeLines := self.defaultOrderTimesArrive[1]; //Eg Anchorage to port
					_timePilot := self.defaultOrderTimesArrive[2];	//Treat as arrival
					_timeTugs := self.defaultOrderTimesArrive[3];
				endif;
			elseif _fromBerth.noMarineServices = false and 
				_toBerth.noMarineServices = true then
				if self.defaultOrderTimesDepart.size &gt; 2 then
					_timeLines := self.defaultOrderTimesDepart[1];	//Eg port to anchorage
					_timePilot := self.defaultOrderTimesDepart[2];//Treat as departure
					_timeTugs := self.defaultOrderTimesDepart[3];
				endif;
			elseif defaultOrderTimesShift.size &gt; 1 then
				_timeLines := self.defaultOrderTimesShift[1];
				_timeTugs := self.defaultOrderTimesShift[2];
			endif;
		elseif defaultOrderTimesShift.size &gt; 1 then
			_timeLines := self.defaultOrderTimesShift[1];
			_timeTugs := self.defaultOrderTimesShift[2];
		endif;
	
	elseif _moveType = HMSMovementTypeDeparture then
		if self.defaultOrderTimesDepart.size &gt; 2 then
			_timeLines := self.defaultOrderTimesDepart[1];
			_timePilot := self.defaultOrderTimesDepart[2];
			_timeTugs := self.defaultOrderTimesDepart[3];
		endif;
	endif;
end;</source>
        <Parameter name="_moveType" type="String"/>
        <Parameter name="_fromBerth" type="HMS_Berth"/>
        <Parameter name="_toBerth" type="HMS_Berth"/>
        <Parameter name="_timePilot" type="Integer" usage="output"/>
        <Parameter name="_timeTugs" type="Integer" usage="output"/>
        <Parameter name="_timeLines" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getShipEnterLeaveStatus" id="b889b507-108a-481a-8901-d4a1f89912f5">
        <source>getShipEnterLeaveStatus(regionFrom, regionTo : HMS_HarbourRegion io; movement : HMS_VoyageMovement):String;

/*

Date		Who		Reason
30 Mar 2008	cnwkpd1	PAR #16367 - Change to use reworked HMS_VoyageMovement::getVoyageMovementPrevious

*/

vars
 	fromBerth:		HMS_Berth;
 	toBerth:		HMS_Berth;
 	movePrev:		HMS_VoyageMovement;
 	movementType: 	String;

begin
	// This method determines whether a ship is entering or leaving the 
	// harbour on this movement and which regions it is travelling to/from
	if movement = null then
		return null;
	endif;
	
	movePrev := movement.getVoyageMovementPrevious;			// PAR #16367
	if movePrev&lt;&gt;null then
		// either a shift or a departure movement
		fromBerth := movePrev.getMyBerth;
		toBerth := movement.getMyBerth;
	else
		// arrival movement
		fromBerth := null;
		toBerth := movement.getMyBerth;
	endif;

	// Determine whether a ship is entering the harbour
	// ie. moving from a logical wharf to a nonlogical wharf
	if fromBerth&lt;&gt;null and toBerth&lt;&gt;null then
		if fromBerth.isLogicalBerth() and  (not toBerth.isLogicalBerth()) then
			// Ship is entering the harbour
			movementType := HMSMovementTypeEntering;
		elseif (not fromBerth.isLogicalBerth()) and toBerth.isLogicalBerth() then
			// Ship is leaving the harbour
			movementType := HMSMovementTypeLeaving;
		endif;
		regionFrom := fromBerth.myHarbourRegion;
		regionTo := toBerth.myHarbourRegion;
	elseif fromBerth &lt;&gt; null and toBerth = null then
		if (not fromBerth.isLogicalBerth()) then
			// Ship is leaving the harbour
			movementType := HMSMovementTypeLeaving;
		endif;
		regionFrom := fromBerth.myHarbourRegion;
		if self.defaultDepartBerth &lt;&gt; null then
			regionTo := self.defaultDepartBerth.myHarbourRegion;
		endif;
	elseif fromBerth = null and toBerth &lt;&gt; null then
		if (not toBerth.isLogicalBerth()) then
			// Ship is entering the harbour
			movementType := HMSMovementTypeEntering;
		endif;
		if self.defaultDepartBerth &lt;&gt; null then
			regionFrom := self.defaultDepartBerth.myHarbourRegion;
		endif;
		regionTo := toBerth.myHarbourRegion;
	endif;

	return movementType;		

end;</source>
        <Parameter name="regionFrom" type="HMS_HarbourRegion" usage="io"/>
        <Parameter name="regionTo" type="HMS_HarbourRegion" usage="io"/>
        <Parameter name="movement" type="HMS_VoyageMovement"/>
        <ReturnType type="String"/>
    </JadeMethod>
