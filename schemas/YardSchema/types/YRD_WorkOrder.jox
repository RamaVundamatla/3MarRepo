    <JadeMethod name="buildOptBtnsRelease" id="cf6a6d05-64e1-4422-855c-6d6e33dc5dc4">
        <updating/>
        <source>buildOptBtnsRelease() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/03/2023	navcs2	ChangeRequest 55440:[54990]: EUP - Release Cargo Work Order - Enhancement

*/

vars
	pxyWodRelease : CM_WodRelease;
begin
	if self.myPxyTask &lt;&gt; null then
		pxyWodRelease := self.myPxyTask.CM_WodRelease;
	else
		return;
	endif;
	
	if pxyWodRelease.myBookingRef &lt;&gt; null then
		self.optBtnRelease.value := false;
		self.optBtnBooking.value := true;
		self.optBtnBooking_click(self.optBtnBooking);
	else
		self.optBtnRelease.value := true;
		self.optBtnBooking.value := false;
		self.optBtnRelease_click(self.optBtnRelease);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildTblChildItems" id="dd8a53a5-7a97-48f2-9515-0f528d09ee5c">
        <source>buildTblChildItems();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
19 Apr 2022	navcs2	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
10 Jul 2023	navma1	ChangeRequest 54550: EUP | Delivery Dispatch Screen - Pack Operation
06 Jun 2024 navlc30 Bug 64240: MTN - Cargo Work Order New Screen slow when many cargo items
24 Jul 2025 navhn30 MTN-35315: MTN | Pagination - Work Order Maintenance
*/

vars
	entTableDef : EntTableDef;
	tbl			: CM_DataTable;
	xmlStr		: String;
	form		: CM_BaseForm;
begin
	
	entTableDef := app.myController.getEntTableDef(ETDef_CargoEnqDefaultData);	
	tbl			:= self.tblChildItems;
	
	xmlStr := self.enquiryTypeDef_Cargo;

	if xmlStr &lt;&gt; null then
		self.tblChildItems.setTblDataEntRowsFromXML(entTableDef, xmlStr);	
	else	
		tbl.setTblDataEntRowsFromDef(entTableDef);
	endif;
	
	tbl.setMyDataClass(CM_TrackedItem);
	tbl.fixedColumns    := 0;
	tbl.fixedRows 	    := 1;
	tbl.selectMode 		:= CM_DataTable.SelectMode_FixedRow;
	tbl.selectionType   := CM_DataTable.SelectionType_Row;
	tbl.multiSelect 	:= CM_BaseTable.MultiSelect_Simple;	
	self.setColorsForTable(tbl);
	
	if self.myPxyTask &lt;&gt; null and self.myPxyTask.isKindOf(CM_WodPack) then
		form := self;																						//06.06.2024 navlc30 #64240																																																												
		//tbl.getDataAndDisplayRowsMultith(self.myPxyTask.CM_WodPack.allPackingTIs, true, form, true);	
		tbl.getDataAndDisplayRowsPaginat(Table.DisplayCollection_Forward, null, self.myPxyTask.CM_WodPack.allPackingTIs, true); //24.07.2025	navhn30  MTN-35315
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildTxtEntitiesList" id="86537cdc-8c80-4fb2-a4dd-57d2e4e01185">
        <source>buildTxtEntitiesList();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Apr 2022	navcs2	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
10 Oct 2023	navcs2	ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Sceen
24 Jan 2023	navma1 	ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTIabortTransaction;
*/

vars
	ti					:	CM_TrackedItem;
	strChild, 
	strParentItems, 
	strChildItems		:	String;
	taskType			: Integer;
begin
	
	if self.myPxyTask &lt;&gt; null then
		taskType := self.myPxyTask.detailType;			//24.01.2023 navma1 #56141 Task#56147
	endif;
	
	if self.workOrderType = WorkOrderMode_Cargo then
		if self.myPxyWorkOrder &lt;&gt; null then
			strParentItems := self.myPxyWorkOrder.CM_WorkOrderTI.allTIs.listString(Comma,CM_TrackedItem::id.name);
			
			if self.myPxyTask &lt;&gt; null and taskType = WO_TASK_PACK then
				strChild 		:= CrLf &amp; "Child Items: " &amp;CrLf;
				strChildItems   := self.myPxyTask.CM_WodPack.allPackingTIs.listString(Comma,CM_TrackedItem::id.name);
			endif;
		endif;
		
	// 10/01/2023 navcs2 56840:[54265]
	elseif self.workOrderType = WorkOrderMode_ToDo then
		if self.myPxyTask &lt;&gt; null then
			if taskType = WO_TASK_ToDo_NONOPS then
				self.grpCargo.caption 	:= "Debtors";
				strParentItems 			:= self.myPxyTask.CM_WodToDoNonOperational.allDebtors.listString(Comma,CM_Debtor::code.name);
			elseif taskType = WO_TASK_ToDo_TRAIN then
				self.grpCargo.caption 	:= "Trains";
				strParentItems 			:= self.myPxyTask.CM_WodToDoTrain.allTrains.listString(Comma,CM_Train::code.name);
			elseif taskType = WO_TASK_ToDo_TRUCK then
				self.grpCargo.caption 	:= "Trucks";
				strParentItems 			:= self.myPxyTask.CM_WodToDoVehicleVisit.allVehicleVisits.listString(Comma,CM_VehicleVisitRecord::jobNumber.name);
			elseif taskType = WO_TASK_ToDo_WAGON then
				self.grpCargo.caption 	:= "Wagons";
				strParentItems 			:= self.myPxyTask.CM_WodToDoWagon.allWagons.listString(Comma,CM_Wagon::id.name);
			elseif taskType = WO_TASK_ToDo_VBS then
				self.grpCargo.caption 	:= "Vehicle Bookings";
				strParentItems 		    := self.myPxyTask.CM_WodToDoVBS.allVBSSlots.listString(Comma,CM_VehicleBookingTimeSlot::id.name);
			elseif taskType = WO_TASK_ToDo_VOYAGE then
				self.grpCargo.caption   := "Voyages";
				strParentItems 			:= self.myPxyTask.CM_WodToDoVoyage.allVoyages.listString(Comma,CM_Voyage::code.name);
			endif;
		else
			self.grpCargo.caption := "Entities";
		endif;
	endif;
	
	self.txtCargoList.text := strParentItems &amp; strChild &amp; strChildItems;
	// 10/01/2023 navcs2 #56840:[54265]
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildWOToDoList" id="2f04d6d1-e9d4-4dc5-b8ca-449a6faea94f">
        <source>buildWOToDoList(_wodtl : CM_WodToDo);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Mar 2023	navhl20	ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
12 Jul 2023 navma1	Bug 59070: EUP - VAS Cargo Work Order Allowing Cargo group ToDo Tasks
14 May 2024 navbs1  Bug 64102: Cannot add todo task if there are multiple todo work order tasks
22 May 2025	navbs1	ChangeRequest 34819: MTN - Filtered Group Box Changes
*/

vars
	task		 : CM_ToDoTaskDesc;
	idx,cnt		 : Integer;
	ti			 : CM_TrackedItem;
	allTodoTasks : CM_ToDoTaskDescByCode;
	toDoGrp      : Integer;
begin

	if not self.shtToDoTasks.visible   then
		return;
	endif;
	
	ti   := self.myPxyTask.CM_WorkOrderTIDtl.allSelectedTIs.first;
	
	if ti &lt;&gt; null then
	
		if ti.isKindOf(CM_CargoGroup)then														//12.07.2023 navma1 #59070
			toDoGrp := TODO_TYPE_GROUP_CARGOGROUP;
		else
			toDoGrp := TODO_TYPE_GROUP_TI;
		endif;
		
		create allTodoTasks transient;
		foreach task in app.myRoot.allToDoTaskDescriptions where task.type =  toDoGrp  do      //12.07.2023 navma1 #59070
			if task.isAvailableForCargoType( ti.cargoType ) then
				allTodoTasks.add(task);
			endif;
		endforeach;
	endif;
	
	self.mulToDoTasks.setVisibleButtons(false,false,false);										//22.05.2025 navbs1 #34819
	self.mulToDoTasks.setupControl( "Tasks", allTodoTasks, YRD_TaskJobTasks::getTaskDescription.name );
	
	self.mulToDoTasks.myAvailableListBox.sorted := true;
	self.mulToDoTasks.mySelectedListBox.sorted  := true;
	self.mulToDoTasks.setSelected( null );
	self.mulToDoTasks.cnEcResizeContents();	
	
	if self.myPxyTask &lt;&gt; null  then
		if  self.myPxyTask.isKindOf(CM_WodToDo) then
			cnt := self.myPxyTask.CM_WodToDo.allToDoTasksDescs.size;
		endif; 
		
		if cnt &gt; 0 then
			self.mulToDoTasks.setSelected(  self.myPxyTask.CM_WodToDo.allToDoTasksDescs );
			self.shtToDoTasks.caption := 'ToDo Tasks [' &amp; cnt.String &amp;']';
		endif;
	else
		self.shtToDoTasks.caption := 'ToDo Tasks';
	endif;
	self.hideVASControl();		//14.05.2024 navbs1 #64102
epilog
	delete allTodoTasks;
end;</source>
        <Parameter name="_wodtl" type="CM_WodToDo"/>
    </JadeMethod>
    <JadeMethod name="canMaintainTasks" id="f7ef04ba-6f84-434d-b4bd-965976a678b7">
        <source>canMaintainTasks(_status : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		 Reason
17 Mar 2022 navma1 	 ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
12/07/2022	navcs2	 ChangeRequest 53932: MTN - Jobs Changes
28/07/2022	navcs2	 Bug 54309: MTN - Voyage Work Orders - Unable to add a task for the Voyage Work Orders
03/08/2022	navcs2	 Bug 54309: MTN - Voyage Work Orders - Unable to add a task for the Voyage Work Orders
05 Aug 2022 navtnr20 Bug 54347: MTN - Voyage Work Orders - When selecting any task the voyage gets disappeared
06 Mar 2023 navma1   ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
*/

vars
	tasksCount : Integer;
begin
	
	if self.myPxyWorkOrder &lt;&gt; null then
		tasksCount := self.myPxyWorkOrder.allWoDtls.size;
	endif;
		
	//if self.workOrderType = WorkOrderMode_Cargo then					//16.05.2022 navma1 #52351
		if _status = WO_STATUS_USERENTRY or  _status = WO_STATUS_PENDING then
			self.btnTaskAdd.enabled 	 := true;
			self.btnTaskDelete.enabled   := tasksCount &gt;= 1;  // 12/07/2022	navcs2 53932
			self.btnTaskDown.enabled	 := tasksCount &gt;1;
			self.btnTaskUp.enabled 	 	 := tasksCount &gt;1;
		endif;
		
		if self.isUseYardJobs = false then
			self.btnTaskAdd.enabled 	 := tasksCount &lt; 1;
			self.btnTaskDelete.enabled   := not self.isApproved and tasksCount &gt;= 1; // 12/07/2022	navcs2 53932 //06.03.2023 navma1 #56457:[56458]
			self.btnTaskDown.enabled	 := tasksCount &gt;1; 
			self.btnTaskUp.enabled 	 	 := tasksCount &gt;1;
		endif;
		
		// 03/08/2022	navcs2	Bug 54309
		if self.workOrderType = WorkOrderMode_Voyage then   
			if self.workOrderMode = self.MODE_UPDATE then   //05-08-2022 navtnr20 54347
				self.btnTaskDelete.enabled   := false;		//05-08-2022 navtnr20 54347
			endif;											//05-08-2022 navtnr20 54347
			if cmbVoyageDetails.getCurrentItemObject.isKindOf(CM_Voyage) then
				self.btnTaskAdd.enabled 	 := tasksCount &lt; 1;
			else
				self.btnTaskAdd.enabled 	 := false;
			endif;
		endif;
	//endif;
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="chkSendEmail_change" id="9515b0bb-ad8e-4f62-a10f-2c6827227931">
        <controlMethod name="CheckBox::change"/>
