    <JadeMethod name="autoSelectSourceArea" id="138965ef-183e-45a0-a6a1-8a060f19b4b7">
        <updating/>
        <source>autoSelectSourceArea()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Apr 2018	jlgndl1	Initial creation	TFS 38083

*/

vars

	reserveDetail : CM_ReserveDetail;
	firstStagingLC : CM_LocationsController;
	autoSelectedStageArea : CM_LocationsController;

begin

	self.stwRuleNum := 0;
	if self.applyTwelveStwRules then
		
		if self.myBulkRelease &lt;&gt; null then
		
			self.myMobileGenericAgent.getCargoStagingDispRuleSTW(	self.myBulkRelease,	//_bulkRelease : CM_BulkRelease;
																	self.getReserveSelection,	//_selectedResDetail : CM_ReserveDetail;
																	autoSelectedStageArea,	//autoSelectedStageArea : CM_LocationsController output;
																	self.stwRuleNum	//_stwRuleNum : Integer output
																	);
		
			
			if autoSelectedStageArea &lt;&gt; null then
				self.cmbSourceArea.listIndex := self.cmbSourceArea.findObject( autoSelectedStageArea );
			endif;
			if self.cmbSourceArea.listIndex &lt; 1 then
				self.cmbSourceArea.listIndex := 1;
			endif;
			
		endif;
	
	else  
		if self.cmbRelItems.listIndex &gt; 0 then
			reserveDetail := self.cmbRelItems.listObject.CM_ReserveDetail;
			if reserveDetail &lt;&gt; null then
				if self.cmbSourceArea.listIndex &gt; 0 and self.cmbSourceArea.listCount &gt; 0 then
					firstStagingLC := self.cmbSourceArea.listObject.CM_LocationsController;
				endif;
				if firstStagingLC = null then
					//nothing selected yet, see if we can find it.
					reserveDetail.getTotalStaged(null, firstStagingLC, null);
					if firstStagingLC &lt;&gt; null then
						self.cmbSourceArea.listIndex := self.cmbSourceArea.findObject( firstStagingLC );
						if self.cmbSourceArea.listIndex &lt; 1 then
							self.cmbSourceArea.listIndex := 1;
						endif;
					endif;
				endif;
			endif;
		endif;
	
	endif;

epilog

end;</source>
    </JadeMethod>
