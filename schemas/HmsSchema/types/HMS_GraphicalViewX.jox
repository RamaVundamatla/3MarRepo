    <JadeMethod name="loadDataForFirstTime" id="c03875f1-afbe-4c71-8840-e8bff119c66f">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//--------------------------------------------------
// Created:	28 April 2004 By: cnwgd1
//--------------------------------------------------
vars
	topPos	: Real;
	
begin
/*process.profilerStop();
process.profilerReport('d:\cnwdmast\activateForm.log');
process.profilerStart();*/

	inheritMethod();
	self.buildMap();
	
	topPos					:=	self.frmMarksToolbar.height;
	self.txtRemarks.top		:=	topPos;
	self.tblExtraInfo.top	:=	topPos;
	self.tblMeterMarks.top	:=	topPos;
	self.tblSearch.top		:=	topPos;
//process.profilerStop();
end;</source>
