    <JadeMethod name="isOKToProceed" id="86f9adbd-685d-4725-acc0-3653ffa2165d">
        <updating/>
        <source>isOKToProceed(pControllerObj:CnEcReleaseController; pCurrentRelease:String):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     12 August 2002 by cnwrs2
//
// Purpose:     Can be overridden to do any pre-checking to determine if the
//				system can be upgraded or not (e.g. check if existing version
//				can be upgraded to this version, check state of data allows
//				upgrade, etc)
//
// Parameters:  pControllerObj - A reference to the Release Controller object.
//				pCurrentRelease - The current release version.
//
// Returns:     True if the release can proceed, otherwise false.  This method
//				will always return true.  To override this, the method should
//				be reimplemented on a Release Upgrader subclass.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	return true;
end;</source>
        <Parameter name="pControllerObj" type="CnEcReleaseController"/>
        <Parameter name="pCurrentRelease" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processPatchRelease" id="bff83f69-adf5-49ed-bc47-708a9da27300">
        <updating/>
        <source>processPatchRelease(pPatchNumber : String; pControllerObj : CnEcReleaseController) updating;
// ---------------------------------------------------------------------------
// Created:     10 July 2001 by cnwrs2
//
// Purpose:     Reimplement this method on the release upgrader subclass for
//				any processing that must be executed after the standard
//				processing.
//
// Parameters:  pPatchNumber - the patch number being processed.
//				pControllerObj - A reference to the release controller object.
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
end;</source>
        <Parameter name="pPatchNumber" type="String"/>
        <Parameter name="pControllerObj" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="processRelease" id="91f3c27a-6783-4fca-94ba-5fd88b4b3b9e">
        <updating/>
        <source>processRelease(pControllerObj : CnEcReleaseController) updating;
// ---------------------------------------------------------------------------
// Created:     10 July 2001 by cnwrs2
//
// Purpose:     Process the developer's release methods.
//
// Parameters:  pControllerObj - A reference to the release controller object.
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	pControllerObj.logEntry('&gt;&gt;&gt; Starting processing of specificPreStandard &lt;&lt;&lt;');
	self.specificPreStandard(pControllerObj);

	pControllerObj.logEntry('&gt;&gt;&gt; Starting processing of standardRelease &lt;&lt;&lt;');
	self.standardRelease(pControllerObj);

	pControllerObj.logEntry('&gt;&gt;&gt; Starting processing of specificPostStandard &lt;&lt;&lt;');
	self.specificPostStandard(pControllerObj);

	pControllerObj.logEntry('&gt;&gt;&gt; Release processing complete &lt;&lt;&lt;');
end;</source>
        <Parameter name="pControllerObj" type="CnEcReleaseController"/>
    </JadeMethod>
