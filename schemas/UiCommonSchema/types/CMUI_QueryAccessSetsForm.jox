    <JadeMethod name="doBaseFormCancel" id="ddce7c9a-297b-428a-ad5c-df351ca6aefb">
        <updating/>
        <source>doBaseFormCancel() updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 April 2008		cnwvu1	
// ---------------------------------------------------------------------------

vars
	querySet,
	pxyQuerySet: CM_SelectorQueryAccess;
	
begin

	self.mousePointer := Window.MousePointer_HourGlass;
	
	inheritMethod();
	
	self.setMode( self.Mode_View );
	self.clickCmbQuerySet();
	
epilog
	querySet := self.cmbQuerySet.myObject.CM_SelectorQueryAccess;
	if querySet &lt;&gt; null then
		pxyQuerySet := app.myProxyManager.getProxyObject(querySet).CM_SelectorQueryAccess;
		if pxyQuerySet &lt;&gt; null then
			delete pxyQuerySet;
		endif;
	endif;

	self.mousePointer := Window.MousePointer_Default;
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="0efd190b-494d-4c1c-bd6a-59027bb68b5e">
        <updating/>
        <source>doBaseFormSave() updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 April 2008		cnwvu1	
// ---------------------------------------------------------------------------

vars
	pxyQuerySet,
	realQuerySet,
	newQuerySet	: CM_SelectorQueryAccess;
	queryColl	: CM_MenuUserQueryArray;
	result		: Integer;
	
begin

	inheritMethod();
	
	self.mousePointer := Window.MousePointer_HourGlass;
	self.modalDialogShow(null, 'Cancel', null, null, self.caption, "Saving...");
	
	if self.mode = self.Mode_Insert then
		// Create a proxy
		create pxyQuerySet transient;
		
	elseif self.mode = self.Mode_Update then
		realQuerySet := cmbQuerySet.myObject.CM_SelectorQueryAccess;
		if realQuerySet = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'realQuerySet = null');
			return;
		endif;
		pxyQuerySet := app.myProxyManager.getProxyObject(realQuerySet).CM_SelectorQueryAccess;
		if pxyQuerySet  = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy has not been found');
			return;	
		endif;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unexpected form.mode=' &amp; self.mode.String);
		return;
	endif;	
	
	create queryColl transient;
	pxyQuerySet.setForProxy(self.txtQuerySet.text);
	self.mulSelectQueries.getSelected(queryColl);
	
	while true do
		if self.mode = Mode_Insert then
			app.myTrxCA.trxCreateSelectorQueryAccess(pxyQuerySet, newQuerySet, queryColl, app.myPassport);
			if app.myPassport.trxCompletedOK then
				self.cmbQuerySet.setObject(newQuerySet);
			endif;
		else
			app.myTrxUA.trxUpdateSelectorQueryAccess(pxyQuerySet, newQuerySet, queryColl, app.myPassport);
		endif;

		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Sub Area', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

	self.setMode(self.Mode_View);	// sysnotify doesn't work for Update or Insert Mode

epilog
	self.frmModalDialog.visible := false;
	if queryColl &lt;&gt; null then
		delete queryColl;
	endif;
	
	if app.myPassport.trxCompletedOK then
		delete pxyQuerySet;
	endif;
	
	self.mousePointer := Window.MousePointer_Default;

	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDelete" id="8a6cf741-d186-45d1-ab8e-f97610536bc5">
        <updating/>
        <source>doDelete() updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 April 2008		cnwvu1	
// ---------------------------------------------------------------------------

vars
	querySet,
	pxyQuerySet	: CM_Object;
	msgStr		: String;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	
begin

	querySet := self.cmbQuerySet.myObject.CM_Object;
	if querySet = null then
		return;
	endif;
	
	msgStr := app.getErrorString2(ConfirmDelete, null, querySet.CM_SelectorQueryAccess.description );
	if not app.msgBox(msgStr, 'Confirm Deletion', MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_Yes 
	then
		return;
	endif;

	self.mousePointer := Window.MousePointer_HourGlass;
	self.modalDialogShow(null, 'Cancel', null, null, querySet.CM_SelectorQueryAccess.description ,"Removing...");
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteCMObject(querySet, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Query Access Set', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;	

epilog
	self.frmModalDialog.visible := false;
	self.mousePointer := Window.MousePointer_Default;
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doEdit" id="69b0fe9e-a3f0-4138-8a30-13e74c74035c">
        <updating/>
        <source>doEdit() updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 April 2008		cnwvu1	
// ---------------------------------------------------------------------------

vars
	pxyQuerySet : CM_SelectorQueryAccess;
	
begin
	
	if self.cmbQuerySet.myObject.CM_Object = null then	// not allowing for one user to edit in 2 places
		return;
	endif;

	self.mousePointer := Window.MousePointer_HourGlass;

	pxyQuerySet := app.createUpdateProxy(self.cmbQuerySet.myObject.CM_Object).CM_SelectorQueryAccess;

epilog

	if  pxyQuerySet &lt;&gt; null then
		self.setMode(self.Mode_Update);
	endif;

	self.mousePointer := Window.MousePointer_Default;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getMultiSelectQueryForQuerySet" id="97d43496-af6b-4a1c-a22e-96e3e8abbd73">
        <source>getMultiSelectQueryForQuerySet(_querySet : CM_SelectorQueryAccess);
// ---------------------------------------------------------------------------
// Created:     11 April 2008		cnwvu1	
// ---------------------------------------------------------------------------

vars
	rootQuery	: CM_MenuRootQuery;
					
begin

	rootQuery := app.myRoot.myQueryMenuRoot;
	self.mulSelectQueries.setAvailable(rootQuery.allMenuUserItemsWithAMenuItem, true);	//if false, the selected would be as default for the new querySet
	
	if _querySet &lt;&gt; null then	// when creating a new querySet
		self.mulSelectQueries.setSelected(_querySet.allSelectedQueries);	//if false, the selected would be as default for the new querySet
	endif;

end;
</source>
        <Parameter name="_querySet" type="CM_SelectorQueryAccess"/>
    </JadeMethod>
    <JadeMethod name="initMultiSelect" id="6d12abaa-cec8-4386-8396-d1a3983d3bd0">
        <source>initMultiSelect() protected;
// ---------------------------------------------------------------------------
// Created:     10 April 2008		cnwvu1	
// ---------------------------------------------------------------------------

vars
	tmpMulSel : CMUI_MultiSelectGroupBox;

begin

	tmpMulSel := self.mulSelectQueries;
	tmpMulSel.availableHeading := 'Available Queries';
	tmpMulSel.selectedHeading := 'Selected Queries';
	tmpMulSel.formDisplayEntryMethodName := 'displayMultiSelect'; 
	tmpMulSel.myBaseForm := self;
	tmpMulSel.myAvailableListBox.sorted := true;		
	tmpMulSel.mySelectedListBox.sorted := false;
	tmpMulSel.mySelectedListBox.allowDragDrop := true;	
	tmpMulSel.displayOrderBtns(true, true);
	tmpMulSel.multiSelect := ListBox.MultiSelect_Extended;
	//tmpMulSel.multiSelect := ListBox.MultiSelect_Simple;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="8ba3f623-3dbf-444a-9c8e-809ed0800847">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 April 2008		cnwvu1	
// ---------------------------------------------------------------------------
//20 Jan 2017	cnwrs1	TFS 3137 - resize the form when show captions is on
vars
	querySet	: CM_SelectorQueryAccess;
	showCaptions : Boolean;
begin
	if self.frmToolbar.showCaptions then
		showCaptions := self.frmToolbar.showCaptions;
		self.frmToolbar.showCaptions := false;
		self.toolbarShowCaptions(showCaptions);
	endif;
	inheritMethod();
	
	if not app.myRoot.allSelectorQueriesAccesByDesc.isEmpty() then

		querySet := app.myRoot.allSelectorQueriesAccesByDesc.first;
		self.cmbQuerySet.setObject(querySet);

		getMultiSelectQueryForQuerySet(querySet);		// preparing mulSelectQueries box
		
	endif;
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMode" id="9d9026c0-6549-4aa7-aeac-93bb19f01aa0">
        <updating/>
        <source>setMode( _mode : Integer ) updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 April 2008		cnwvu1	
//27/06/2016    cnwma1 PAR37981 TFS2209 PEN - Can not not edit or create Query Access sets
// ---------------------------------------------------------------------------

vars

begin

	self.mode := _mode;

	self.cmbQuerySet.enabled	:= false;
	self.btnAdd.enabled			:= false;
	self.btnEdit.enabled		:= false;
	self.btnSaveBase.enabled	:= false;
	self.btnDelete.enabled		:= false;
	self.btnCancelBase.enabled	:= false;
	self.mulSelectQueries.readOnly	:= true;
	
	if _mode = self.Mode_View then
		if app.myRoot.allSelectorQueriesAccesByDesc.isEmpty() then
			self.btnEdit.enabled		:= false;
			self.btnDelete.enabled		:= false;
			self.cmbQuerySet.enabled	:= false;
		else
			self.btnEdit.enabled		:= true;
			self.btnDelete.enabled		:= true;
			self.cmbQuerySet.enabled	:= true;
		endif;
		
		self.btnAdd.enabled				:= true;
		self.btnSaveBase.enabled		:= false;
		self.btnCancelBase.enabled		:= false;
		self.mulSelectQueries.readOnly	:= true;
		self.cmbQuerySet.visible		:= true;
		self.txtQuerySet.visible		:= false;
		
	elseif (_mode = self.Mode_Insert) or (_mode = self.Mode_Update) then
		if _mode = self.Mode_Insert then
			self.cmbQuerySet.enabled	:= true;
			self.txtQuerySet.text		:= null;
		else
			self.cmbQuerySet.enabled	:= false;
			self.txtQuerySet.text				:= self.cmbQuerySet.text;
		endif;
		
		self.btnAdd.enabled					:= false;
		self.btnEdit.enabled				:= false;
		self.btnSaveBase.enabled			:= true;
		self.btnDelete.enabled				:= false;
		self.btnCancelBase.enabled			:= true;
		
		//if app.myCurrentUserCan(self.myTerminal, PmAdmSelectorMaint) then  //27/06/2016 cnwma1 PAR #37981 TFS#2209
		if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then  //27/06/2016 cnwma1 PAR #37981 TFS#2209 
			self.mulSelectQueries.readOnly	:= false;
		endif;
		
		self.cmbQuerySet.visible			:= false;
		self.txtQuerySet.visible			:= true;
		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Wrong parameter for the method');
	
	endif;


end;
</source>
        <access>protected</access>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setObjectForCmbQerySet" id="c71e124e-3527-4cfa-b06b-d769924e9f00">
        <source>setObjectForCmbQerySet( _querySet : CM_SelectorQueryAccess );
// ---------------------------------------------------------------------------
// Created:     15 April 2008		cnwvu1	
// ---------------------------------------------------------------------------

vars

begin

	self.cmbQuerySet.setObject(_querySet);
	if _querySet = null then
		self.mulSelectQueries.multiClear();
	else
		self.getMultiSelectQueryForQuerySet(_querySet);
	endif;

end;
</source>
        <Parameter name="_querySet" type="CM_SelectorQueryAccess"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="b7a97ce5-25f9-4c66-89b5-48129d32c769">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     10 April 2008		cnwvu1	
// ---------------------------------------------------------------------------

vars

begin
	
	inheritMethod();
	
	//self.showToolbar	:= true;
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.caption			:= 'Query Access Sets';
	
	self.cmbQuerySet.top := 45; // ### TFS 50421 17SEP2021 NAVAB1
	self.txtQuerySet.top := self.cmbQuerySet.top-1;
	self.txtQuerySet.width := self.cmbQuerySet.width;
	self.txtQuerySet.left := self.cmbQuerySet.left;
	
	self.initMultiSelect();
	self.setMode( self.Mode_View );

	self.beginClassNotification(CM_SelectorQueryAccess, false, Any_System_Event, Response_Continuous, null);
	self.beginClassNotification(CM_MenuUserQuery, false, Any_System_Event, Response_Continuous, null);

	// TFS 2101 CNWAB1
	if not app.myCurrentUserCan(null, self.permissionMaint) then
		self.btnEdit.enabled := false;
		self.btnAdd.enabled := false;
		self.btnDelete.enabled := false;
	endif;

end;
</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="0bf032f5-cc6b-4845-9dbd-55981cc4f2cf">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     15 April 2008		cnwvu1	
// ---------------------------------------------------------------------------

vars
	querySet,
	currentQuerySet,
	pxyQuerySet: CM_SelectorQueryAccess;
	queriesColl		: CM_SelectorQueriesAccessByDesc;
//	rootQuery		: CM_MenuRootQuery;
	
begin
	
	if self.mode &lt;&gt; self.Mode_View then
		if not (self.mode = self.Mode_Update and eventType = Object_Delete_Event) then
			return;	// do nothing in view mode (except for one case)
		endif;
	endif;

	if theObject.isKindOf(CM_MenuUserQuery) then
		if eventType = Object_Delete_Event or eventType = Object_Create_Event then
			self.clickCmbQuerySet();
		endif;
		return;
	endif;
	
	if not theObject.isKindOf(CM_SelectorQueryAccess) then
		return;	// we are only intereseted in CM_MenuUserQuery and CM_SelectorQueryAccess
	endif;
	
	querySet		:= theObject.CM_SelectorQueryAccess;
	currentQuerySet	:= self.cmbQuerySet.myObject.CM_SelectorQueryAccess;
	queriesColl		:= app.myRoot.allSelectorQueriesAccesByDesc;
	
	if eventType = Object_Update_Event then
		if querySet = currentQuerySet then
			self.setObjectForCmbQerySet(querySet);
		endif;
		
	elseif eventType = Object_Delete_Event then
		if self.mode = self.Mode_Update then
			if currentQuerySet = querySet then
				app.msgBox(app.getErrorString1(ObjectDeletedByOtherUser, self.caption), 'Warning', MsgBox_OK_Only);
				pxyQuerySet := app.myProxyManager.getProxyObject(querySet).CM_SelectorQueryAccess;
				if pxyQuerySet &lt;&gt; null then
					delete pxyQuerySet;
				endif;
				self.setObjectForCmbQerySet(queriesColl.first());	// when queriesColl.first = null - it cleares the screen
				self.setMode(self.Mode_View); // re-enable buttons, they were disabled when queriesColl.size = 0
			endif;
		elseif self.mode = self.Mode_View then
			self.setObjectForCmbQerySet(queriesColl.first);	// when queriesColl.first = null - it cleares the screen
			self.setMode(self.Mode_View); // re-enable buttons, they were disabled when queriesColl.size = 0
		endif;
		
	elseif eventType = Object_Create_Event then
		if currentQuerySet = null then
			self.setObjectForCmbQerySet(querySet);
			self.setMode(self.Mode_View); // re-enable buttons, they were disabled when queriesColl.size = 0
		endif;
	endif;


end;
</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="toolbarShowCaptions" id="f4b346d2-f90f-4270-a020-13696d662150">
        <updating/>
        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;
//
//20 Jan 2017	cnwrs1	TFS 3137 - resize the form when show captions is on
//
vars
	currentHeight : Real;
	newHeight : Real;
	heightDiff : Real;
begin
	currentHeight := self.frmToolbar.height;
	inheritMethod(_showCaptions);
	newHeight := self.frmToolbar.height;
	heightDiff := newHeight - currentHeight;
	self.txtQuerySet.top := self.txtQuerySet.top + heightDiff;
	self.cmbQuerySet.top := self.cmbQuerySet.top + heightDiff;
	self.mulSelectQueries.top := self.mulSelectQueries.top + heightDiff;
	self.mulSelectQueries.height := self.mulSelectQueries.height - heightDiff;
	self.doResize();
end;
</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="6d61d476-588e-4ed7-91e6-d97d7bddc294">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:42:07.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017444, locale);
	btnAdd.translateBubbleHelp(Xlat_0007955, locale);
	btnAdd.translateCaption(Xlat_0007956, locale);
	btnDelete.translateBubbleHelp(Xlat_0007957, locale);
	btnDelete.translateCaption(Xlat_0007958, locale);
	btnEdit.translateBubbleHelp(Xlat_0007959, locale);
	btnEdit.translateCaption(Xlat_0007960, locale);
	lblSet.translateCaption(Xlat_0007961, locale);
//	shtColumns.translateCaption(Xlat_0023284, locale);
end;</source>
    </JadeMethod>
