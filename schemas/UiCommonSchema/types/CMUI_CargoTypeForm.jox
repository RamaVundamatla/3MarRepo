    <JadeMethod name="btnProductsForm_mouseDown" id="6f5dfadb-57c0-4ddd-b287-f822868b827c">
        <controlMethod name="Button::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnProductsForm_mouseDown(btn: Button input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10 June 2021	navdap1		Initial creation TFS 
//
vars

begin
	if app.isSpecial and shift.bitAnd(1) &lt;&gt; 0 then
		self.myAssistant.showGraphicCommandForm(null, 2);
		return;
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
