        <source>getDamageProxy(_isNewPxy : Boolean output) : CM_WagonMaster;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2009	cnwer1	Initial creation

*/

vars
	pxyWagonMaster : CM_WagonMaster;
begin
	if self.isTransient then
		return self;
	endif;
	
	pxyWagonMaster:=self.pxyGetProxyObject();
	
	if pxyWagonMaster &lt;&gt; null then	//28 Apr 2010	NDL	Par 23788
		return pxyWagonMaster;
	elseif pxyWagonMaster = null then
		_isNewPxy:=true;
		return app.createUpdateProxy(self).CM_WagonMaster;
