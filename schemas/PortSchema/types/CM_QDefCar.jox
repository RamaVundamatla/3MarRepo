    <JadeMethod name="createProperties" id="a4d06aa0-e40e-44a2-a819-acc2f827aff3">
        <source>createProperties();
//15 December 2009	cnwml2
//
// Chanegd On	By			Reason
// ----------	--------	---------------------------------------------------
// 19/08/2013	cnwdap1		PAR #32215 CCMS DPH 2290 New Car Attributes

vars
	tmpProp : CM_QueryProperty;
begin
	inheritMethod();
	
	create tmpProp as CM_QIntegerProperty persistent;
	tmpProp.set('Has Radio', CM_Car::hasRadio.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanProperty persistent;
	tmpProp.set('Is Self Propelled', CM_Car::selfPropelled.name, self.className);
	tmpProp.allocationAttribute := YACriteriaType_IsSelfPropelled;	//17 Jun 2015	NDL	Par 36338
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrVehicleMakeProperty persistent;								// PAR #32215
	tmpProp.set('Vehicle Make', CM_Car::make.name, self.className);							// PAR #32215
	tmpProp.allocationAttribute := YACriteriaType_VehicleMake;	//17 Jun 2015	NDL	Par 36338
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);													// PAR #32215
																							// PAR #32215
	create tmpProp as CM_QStrVehicleModelProperty persistent;								// PAR #32215
	tmpProp.set('Vehicle Model', CM_Car::model.name, self.className);						// PAR #32215
	tmpProp.allocationAttribute := YACriteriaType_VehicleModel;	//17 Jun 2015	NDL	Par 36338
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);													// PAR #32215
																							// PAR #32215
	create tmpProp as CM_QStrVehicleTypeProperty persistent;								// PAR #32215
	tmpProp.set('Vehicle Type', CM_Car::carType.name, self.className);						// PAR #32215
	tmpProp.allocationAttribute := YACriteriaType_VehicleType;	//17 Jun 2015	NDL	Par 36338
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);													// PAR #32215
																							// PAR #32215
	create tmpProp as CM_QIntegerProperty persistent;										// PAR #32215
	tmpProp.set('Year of Manufacture', CM_Car::year.name, self.className);					// PAR #32215
	tmpProp.allocationAttribute := YACriteriaType_VehicleYear;	//17 Jun 2015	NDL	Par 36338
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);													// PAR #32215
																							// PAR #32215
	create tmpProp as CM_QStringProperty persistent;										// PAR #32215
	tmpProp.set('Military Tracking Nbr', CM_Car::trackingNumber1.name, self.className);		// PAR #32215
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);													// PAR #32215
																							// PAR #32215
	create tmpProp as CM_QStringProperty persistent;										// PAR #32215
	tmpProp.set('US Customs Clearance Nbr', CM_Car::trackingNumber2.name, self.className);	// PAR #32215
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);													// PAR #32215
																							// PAR #32215
	create tmpProp as CM_QDateProperty persistent;											// PAR #32215
	tmpProp.set('Titles Received', CM_Car::docsReceived.name, self.className);				// PAR #32215
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);													// PAR #32215
																							// PAR #32215
	create tmpProp as CM_QDateProperty persistent;											// PAR #32215
	tmpProp.set('Titles Sent to Customs', CM_Car::docsSent.name, self.className);			// PAR #32215
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);													// PAR #32215
																							// PAR #32215
	create tmpProp as CM_QDateProperty persistent;											// PAR #32215
	tmpProp.set('Titles Returned from Customs', CM_Car::docsCleared.name, self.className);	// PAR #32215
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);													// PAR #32215
																							// PAR #32215
	create tmpProp as CM_QDateProperty persistent;											// PAR #32215
	tmpProp.set('Titles Mailed to Client', CM_Car::docsReturned.name, self.className);		// PAR #32215
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);													// PAR #32215
																							// PAR #32215
	create tmpProp as CM_QIntegerProperty persistent;										// PAR #32215
	tmpProp.set('Number of Doors', CM_Car::nbrDoors.name, self.className);					// PAR #32215
	tmpProp.allocationAttribute := YACriteriaType_VehicleNbrDoors;	//17 Jun 2015	NDL	Par 36338
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);													// PAR #32215
																							// PAR #32215
	create tmpProp as CM_QBooleanProperty persistent;										// PAR #32215
	tmpProp.set('New Vehicle', CM_Car::isNew.name, self.className);							// PAR #32215
	tmpProp.allocationAttribute := YACriteriaType_IsNewVehicle;	//17 Jun 2015	NDL	Par 36338
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);													// PAR #32215

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getSelectorVisibleColumns" id="8cbca6a7-bfd7-427d-9468-82e5cf995642">
        <source>getSelectorVisibleColumns(_sa: StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2024	jlier1	Initial creation TFS 64054

*/

vars
	qProp	: CM_QueryProperty;
begin
	_sa.clear();

	inheritMethod(_sa);
	
	qProp := self.allQueryProperties[CM_TrackedItem::cargoType.name]; //cargo type
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;

	//operator 
	qProp := self.allQueryProperties[CM_Car::make.name]; 
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	
	qProp := self.allQueryProperties[CM_Car::model.name]; 
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;

	//operator 
	qProp := self.allQueryProperties[CM_TrackedItem::operatorCode.name]; 
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	
	//location
	qProp := self.allQueryProperties[CM_TrackedItem::locationId.name]; 
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;

epilog

end;</source>
        <Parameter name="_sa" type="StringArray" usage="input"/>
    </JadeMethod>
</Class>
