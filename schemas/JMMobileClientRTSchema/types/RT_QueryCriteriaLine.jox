<GUIClass name="RT_QueryCriteriaLine" id="bfa78137-18a2-491d-b717-715069e110d2">
    <superclass name="BaseControl"/>
    <transient/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="_usergui"/>
    <ExplicitInverseRef name="myForm" id="ebd636f7-a10f-4478-8ae1-e06d4fa78a38">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="RadioTelemetryMainForm"/>
        <access>readonly</access>
        <Inverse name="RadioTelemetryMainForm::aAllQueryCriteriaLines"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myLblCriteria" id="5f05643c-2dc9-44cb-9dd9-024a0fc59fb4">
        <kind>parent</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="Label_QueryCriteria"/>
        <access>readonly</access>
        <Inverse name="Label_QueryCriteria::myQueryCriteriaLine"/>
    </ExplicitInverseRef>
    <JadeMethod name="createControlsForTheForm" id="b605a6b8-4755-40d6-b957-51a367b88c12">
        <updating/>
        <source>createControlsForTheForm( _lblCriteriaCaption, _searchValueA, _searchValueB : String; _optBtnValue : Boolean; _slip : Real ) updating;
// -------------------------------------------
// Created 07 may 2008 by cnwvu1
// -------------------------------------------

vars
	clonedLabel		: Label_QueryCriteria;
	numb			: Integer;
	exampleLbl		: Label_QueryCriteria;

begin

	if self.myForm.aAllQueryCriteriaLines.isEmpty then
		return;
	endif;
	
	if self.myForm.aAllQueryCriteriaLines.size = 1 then

		// creating the first criteria line - using controls on a form
		self.myLblCriteria			:= self.myForm.lblCriteria1;
		// default searching values for captions
		self.myLblCriteria.caption	:= _lblCriteriaCaption;
	
	else
		
		// cloning controls for the other criteria lines
		numb := self.myForm.aAllQueryCriteriaLines.size;

		// cloning lblCriteria i
		exampleLbl			:= self.myForm.lblCriteria1;
		clonedLabel			:= exampleLbl.cloneSelf( true );
		clonedLabel.setForCreate(	self.myForm,
									exampleLbl.name.String[ 1 : exampleLbl.name.length()-1 ] &amp; numb.String,
									_lblCriteriaCaption,
									exampleLbl.parent.Control,
									exampleLbl.top + _slip );
		self.myLblCriteria	:= clonedLabel;
		
	endif;

end;
</source>
        <Parameter name="_lblCriteriaCaption" type="String"/>
        <Parameter name="_searchValueA" type="String"/>
        <Parameter name="_searchValueB" type="String"/>
        <Parameter name="_optBtnValue" type="Boolean"/>
        <Parameter name="_slip" type="Real"/>
    </JadeMethod>
    <JadeMethod name="deleteClone" id="a0df7a96-7fae-4ec4-906e-96c3bbc3480f">
        <updating/>
        <source>deleteClone() updating;
// -------------------------------------------
// Created 07 may 2008 by cnwvu1
// -------------------------------------------
vars
	criteriaLine : RT_QueryCriteriaLine;

begin

	criteriaLine := myForm.aAllQueryCriteriaLines.first;
	
	if criteriaLine = null then
		return;
	endif;
	
	if criteriaLine = self then
	
		// hiding controls on the form
		self.myLblCriteria.visible		:= false; 
		//breaking reference and saving the buttons on a form as example for cloning
		self.myLblCriteria		:= null; 
		
	endif;
	
	delete self;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="getDtoDefinitionFromRT" id="1faf73da-aa3b-4a54-bf39-2548eee98033">
        <source>getDtoDefinitionFromRT(	_queryOperatorOid, _propClassName, _propName : String output;
						_searchValueA, _searchValueB : String output; _searchValueBoolean : Boolean output );
// -----------------------------------------------------------------------------------------------
// Created 07 may 2008 by cnwvu1
// -----------------------------------------------------------------------------------------------

vars

begin


end;
</source>
        <Parameter name="_queryOperatorOid" type="String" usage="output"/>
        <Parameter name="_propClassName" type="String" usage="output"/>
        <Parameter name="_propName" type="String" usage="output"/>
        <Parameter name="_searchValueA" type="String" usage="output"/>
        <Parameter name="_searchValueB" type="String" usage="output"/>
        <Parameter name="_searchValueBoolean" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="d6502913-9c83-4a1e-b23e-2758c447260d">
        <updating/>
        <source>setForCreate( _form : RadioTelemetryMainForm; 
				_propClassName, _propName, _queryOperatorOid : String;
				_lblCriteriaCaption, _searchValueA, _searchValueB : String; 
				_optBtnValue : Boolean;
				_slip : Real; _tabIndex : Integer ) updating;
// -----------------------------------------------------------------------
// Created 07 may 2008 by cnwvu1
// -----------------------------------------------------------------------

vars
	
begin

	self.myForm	:= _form;
	
	
	// creating the other criteria lines - cloning controls for the form
	self.createControlsForTheForm( _lblCriteriaCaption, _searchValueA, _searchValueB, _optBtnValue, _slip );

	self.myLblCriteria.visible		:= true;
	
end;
</source>
        <Parameter name="_form" type="RadioTelemetryMainForm"/>
        <Parameter name="_propClassName" type="String"/>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_queryOperatorOid" type="String"/>
        <Parameter name="_lblCriteriaCaption" type="String"/>
        <Parameter name="_searchValueA" type="String"/>
        <Parameter name="_searchValueB" type="String"/>
        <Parameter name="_optBtnValue" type="Boolean"/>
        <Parameter name="_slip" type="Real"/>
        <Parameter name="_tabIndex" type="Integer"/>
    </JadeMethod>
