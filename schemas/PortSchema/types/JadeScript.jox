    <JadeMethod name="diFutureStorage" id="84646946-2ff6-4cb5-9a03-d5efe6bf9928">
        <source>diFutureStorage();
/*
Purpose: 48221 STWO - Problem specifying period for monthly invoicing
		 Has been observed that the invoice generated for the 1st day of the month is included in the Previous month
		 ex. Invoice for the month of Dec 2019, an Invoice Jan 1, 2020 is included
		 
Parameters:			

Return Value:		

Date		Who		TFS		Reason
21 January 2020	jlgdi1				Initial creation
21 June 2023 navmv20 CR 58373 Task 58381: Jade - Future Storage Additional Days
*/

vars
	terminal : CM_Terminal;
	operator : CM_Operator;
	cargo : CM_BreakBulkGeneric;
	tranTS : TimeStamp;
	tranDate : Date;
	now : Date;
	tran : CM_TITransaction;
	expiry : Date;
	storageDetail : CM_StorageDetail;
begin
	now := app.actualTimeServer().date();
	
	// back-date transactions to previous month, so we can 
	tranDate := "2019-12-04".Date;
	tranTS.setDate(tranDate);
	
	//cargo := "4949.2707658".asOid.CM_BreakBulkGeneric;
	//cargo := "4949.2707671".asOid.CM_BreakBulkGeneric;
	//cargo := "4949.2707672".asOid.CM_BreakBulkGeneric;
	cargo := "4949.2707673".asOid.CM_BreakBulkGeneric;
	
	foreach tran in cargo.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		if not tran.isDeleted() then 
			beginTransaction;
			tran.setPropertyValue("dateTime", tranTS);
			commitTransaction;
		endif;
	endforeach;
	
	beginTransaction;
	cargo.setReceivedDT(tranTS);
	cargo.setPropertyValue("moveDT", tranTS);
	expiry := tranTS.addDays(10).Date;
	//cargo.setFutureStorageExpiry(expiry);
	//cargo.plannedDT.setDate(expiry)
	//cargo.setFutureStorageAnniversary(expiry,storageDetail);		//05.10.2022 navma1 #52967 //21/06/2023 navmv20 CR 58373 Task 58381
	cargo.setFutureStorageAnniversary(expiry,storageDetail,false); //21/06/2023 navmv20 CR 58373 Task 58381
	commitTransaction;	
end;</source>
    </JadeMethod>
    <JadeMethod name="diGetUnInitFormTypePermission" id="df1e1c88-a8d0-44df-b132-459033f2bca4">
        <source>diGetUnInitFormTypePermission();
/*

Purpose: Show all the list of constant permissions with 'formType' attribute equal to zero (not set).
         Meaning not define as View nor Maint

Parameters:			

Return Value:		

Date		Who		Reason
13 September 2019	jlgdi1	Initial creation

*/

constants
	PERMTYPE_SPECIAL : Integer = 2;
	
vars
	permAgent : CM_PermissionAgent;
	permObj : CM_PermissionObject;
	count : Integer;
	identified : Boolean;
	niether : String;
	otherMaintPermissions : IntegerArray;
	otherViewPermissions : IntegerArray;
	identifiedCount : Integer;
	unidentifiedCount : Integer;
	
begin
	create otherMaintPermissions transient;
	create otherViewPermissions transient;
	
	self.diOtherMaintPermissionList(otherMaintPermissions);
	self.diOtherViewPermissionList(otherViewPermissions);

	create permAgent transient;
	permAgent.populatePermissionDict(true, false, 0);
	
	foreach permObj in permAgent.allPermissionsByName do
		if permObj.permType = PERMTYPE_SPECIAL then
			continue;
		endif;
				
		// Meaning permission hasn't been updated by the script nor PermissionApp
		if permObj.formType = 0 then
			write permObj.constName &amp; CrLf;
			
			if (permObj.constName.pos("View", 1) &gt; 0) or (permObj.description.pos("View", 1) &gt; 0) then
				identified := true;
				
			elseif (permObj.constName.pos("Maint", 1) &gt; 0) or (permObj.description.pos("Maint", 1) &gt; 0) then
				identified := true;
				
			elseif otherMaintPermissions.includes( permObj.constValue ) then
				identified := true;
				
			elseif otherViewPermissions.includes( permObj.constValue ) then
				identified := true;
				
			else
				identified := false;
				niether := niether &amp; permObj.constName &amp; CrLf;
			endif;
			
			if identified then
				identifiedCount := identifiedCount + 1;
			else
				unidentifiedCount := unidentifiedCount + 1;
			endif;
		endif;
	endforeach;
		
	write "Total Identified : " &amp; identifiedCount.String;
	write "Total Unidentified : " &amp; unidentifiedCount.String;

	if niether.length &gt; 0 then
		write niether;
	endif;
	
epilog
	delete permAgent;
	delete otherMaintPermissions;
	delete otherViewPermissions;
end;</source>
    </JadeMethod>
    <JadeMethod name="diHookVoyageBU" id="707a032a-72f8-4fc2-875e-0d2f2f404298">
        <source>diHookVoyageBU();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		TFS		Reason
11 February 2020	jlgdi1				Initial creation
*/

//getVoyageBusUnit(_term : CM_Terminal; _voyage : CM_Voyage) : CM_Bank;

vars
	_term : CM_Terminal; 
	_voyage : CM_Voyage;

	port, portBefore1, portBefore2, portAfter1, portAfter2 : CM_Port;
	indexOfHere,  indexBefore1, indexBefore2, indexAfter1, indexAfter2, numPorts: Integer;
	isDomesticPorts		: Boolean;
	thisPort 			: String;
	reference 			: Integer;
	voyageBusUnit		: String;
	isDomesticCountry	: Boolean;
	vesselCountryFlag	: String;
	isDomesticCargo		: Boolean;
	loadCountry			: String;
	dischargeCountry	: String;
	wo					: CM_WorkOrder;
	woVoyage			: CM_WorkOrderVoyage;
//	wodVoyageRequest	: CM_WodVoyageRequest
	wodVoyageCargoReq	: CM_WorkOrderDtl;
	wodCargoRequest		: CM_WodCargoRequest;
	
	hookLink : CM_HookLink;
	
begin
	_term := "2351.36".asOid.CM_Terminal; // T02
	_term := "2351.39".asOid.CM_Terminal; // JBL
	
	//hookLink := app.myRoot.allHookLinks[HookType_VoyageBusUnit, _term];
	
	//return;
	
	_voyage := "4480.1547570".asOid.CM_Voyage;

	
	
	
	reference := HookType_VoyageBusUnit; // here to provide some sort of reference....
										 // doesn't do anything, just makes it easier to find.
										
	thisPort 			:= _term.getConfig(PortDestCode).String;//"IDMLH";
	port 				:= app.myRoot.allPorts[thisPort]; //Here	
	
	
	//For any requests that comes after the cargo request, we don't care about the business unit
	if (_voyage.status &gt; 105 and _voyage.status &lt; 201) or (_voyage.status &gt; 205) then
		if _voyage.myDischargeCompany &lt;&gt; null then  //17.11.2018 cnwma1 Bug #42066
			app.msgBox(_voyage.myDischargeCompany.code, "", 0);
			return;
			//return _term.companies[_voyage.myDischargeCompany.code];
		endif;
	endif;
	
	
	if _voyage.myVessel &lt;&gt; null then                 //17.11.2018 cnwma1 Bug #42066
		if _voyage.myVessel.myHMSVesselData &lt;&gt; null then
			vesselCountryFlag 	:= _voyage.myVessel.myHMSVesselData.countryCode;
		endif;
	endif;
	
	if port &lt;&gt; null then	
		// BY COUNTRY FLAG	
		if vesselCountryFlag &lt;&gt; null then
			if vesselCountryFlag = port.countryCode then
				isDomesticCountry := true;
			else //if country flag is not Indonesian then it's an International vessel
				voyageBusUnit := "INT";
				app.msgBox(voyageBusUnit, "", 0);
				return;
				//return _term.companies[voyageBusUnit]; //As soon as we know it's INT, get out of here.
			endif;
		else //if country flag is not specified then it's an International vessel
			voyageBusUnit := "INT";
			app.msgBox(voyageBusUnit, "", 0);
			return;
			//return _term.companies[voyageBusUnit]; 
			
		endif;
	
		// BY PREVIOUS AND NEXT PORTS
		// Note: This code does not cater for voyages that visits less than 5 ports!
		isDomesticPorts	:= false;
		numPorts 		:= _voyage.allPorts.size;
		indexOfHere 	:= _voyage.allPorts.indexOf(port);
		
		if indexOfHere &gt; 0 then
			indexBefore1	:= indexOfHere - 1;
			indexBefore2 	:= indexOfHere - 2;
			indexAfter1 	:= indexOfHere + 1;
			indexAfter2		:= indexOfHere + 2;
	
			if indexBefore1 &gt; 0 and indexBefore1 &lt;= numPorts then
				portBefore1 := _voyage.allPorts[indexBefore1];
			endif;
			if indexBefore2 &gt; 0 and indexBefore2 &lt;= numPorts then
				portBefore2 := _voyage.allPorts[indexBefore2];
			endif;
			if indexAfter1 &gt; 0 and indexAfter1 &lt;= numPorts then
				portAfter1 := _voyage.allPorts[indexAfter1];
			endif;
			if indexAfter2 &gt; 0 and indexAfter2 &lt;= numPorts then
				portAfter2 := _voyage.allPorts[indexAfter2];
			endif;
		endif;
		
		if portBefore1 &lt;&gt; null then
			if portBefore1.countryCode = port.countryCode then // SAME COUNTRY AS HERE
				isDomesticPorts := true;
				if portBefore2 &lt;&gt; null then
					if portBefore2.countryCode &lt;&gt; port.countryCode then // DIFFERENT COUNTRY FROM HERE
						isDomesticPorts := false;
					endif;
				endif;
			endif;
		else // WE ARE THE FIRST PORT
			isDomesticPorts := true;
		endif;
		
		if isDomesticPorts then
			if portAfter1 &lt;&gt; null then
				if portAfter1.countryCode &lt;&gt; port.countryCode then // DIFFERENT COUNTRY FROM HERE
					isDomesticPorts := false;
				endif;
			endif;
			if portAfter2 &lt;&gt; null then
				if portAfter2.countryCode &lt;&gt; port.countryCode then // DIFFERENT COUNTRY FROM HERE
					isDomesticPorts := false;
				endif;
			endif;
		endif;
	else
		voyageBusUnit := "DFBU"; //This is a catch all
	endif;
	
	
	//Checking to see if the load/discharge country is International
	if _voyage.status = 105 or _voyage.status = 205 then // 105 = Cargo requested. 205 = Cargo requested for INAPORTNET voyage
		foreach wo in _voyage.allWorkOrders where wo.isKindOf(CM_WorkOrderVoyage) do		
			foreach wodVoyageCargoReq in wo.allWoDtls where wodVoyageCargoReq.isKindOf(CM_WodVoyageCargoRequest) do
				foreach wodCargoRequest in wodVoyageCargoReq.CM_WodVoyageCargoRequest.allCargoDetails do
					loadCountry := wodCargoRequest.loadPort[1:2];
					dischargeCountry := wodCargoRequest.dischargePort[1:2];
	
					if loadCountry = "ID" and dischargeCountry = "ID" then
						isDomesticCargo := true;
					else
						voyageBusUnit := "INT";
						app.msgBox(voyageBusUnit, "", 0);
						return;
						//return _term.companies[voyageBusUnit]; //As soon as it's INT, get out of here.
					endif;
				endforeach;
			endforeach;		
		endforeach;
	//For any requests made before the cargo request, 
	//we don't care about the cargo's influence on Business Unit
	elseif _voyage.status &lt; 105 or (_voyage.status &gt; 200 and _voyage.status &lt; 205) then 		
		isDomesticCargo := true;
	endif;
	
	if isDomesticCountry and isDomesticPorts and isDomesticCargo then
		voyageBusUnit := "DOM";
	else // Must be international
		voyageBusUnit := "INT";
	endif;

	app.msgBox(voyageBusUnit , "", 0);
	return;
	//return _term.companies[voyageBusUnit];
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="diInvoiceCoverTimeStampTrans" id="47ba84db-78e0-4840-8431-4153e2c40f8f">
        <source>diInvoiceCoverTimeStampTrans();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		TFS		Reason
24 January 2020	jlgdi1				Initial creation
*/

vars
	invoice : CM_Invoice;
	datetime : TimeStamp;
	trans : CM_FutureStorage;
	above:  Boolean;
	below:  Boolean;
	theToDate : TimeStamp;
	
begin
	datetime := "01/01/2020 00:01:00".TimeStamp;	
	create trans transient;
	trans.updateDateTime(datetime);
	app.msgBox("Transaction date is " &amp; datetime.asStringJMT, "", 0);
	
	create invoice transient;
	invoice.fromDT := "01/12/2019 00:00:00".TimeStamp;
	invoice.toDT := "31/12/2019 23:59:00".TimeStamp;
	
	
	app.msgBox("Test if inside the date range " &amp; invoice.fromDT.asStringJMT &amp; " - " &amp; invoice.toDT.asStringJMT, "", 0);
	
	if not invoice.fromDT.isValid then
		above := false;
	elseif invoice.fromDT &lt;= datetime then
		above := true;
	endif;
	app.msgBox("Above is " &amp; above.asStringJMT, "", 0);
	
	if not invoice.toDT.isValid then
		below := false;
	elseif invoice.toDT &gt;= datetime then
		below := true;
	endif;
	app.msgBox("Below is " &amp; below.asStringJMT, "", 0);
	
	if not below then
		theToDate.setDate(invoice.toDT.date + 1);
		theToDate.setTime(invoice.toDT.time);
		app.msgBox("NEW TODATE is " &amp; theToDate.asStringJMT, "", 0);
		if theToDate &gt;= trans.dateTime then
			below := true;
			app.msgBox("Below is " &amp; below.asStringJMT, "", 0);
		endif;		
	endif;
	
	if above and below then 
		app.msgBox("Covered!","",0);
	endif;
	
	/*
	if invoice.coversTimeStampTransaction(trans) then 
		app.msgBox("In range","",0);
	endif;
	*/
	
epilog
	delete invoice;
	delete trans;
end;</source>
    </JadeMethod>
    <JadeMethod name="diInvoiceCoverTimeStampTrans2" id="8fb48670-9616-45a7-958c-7fa0797afa9a">
        <source>diInvoiceCoverTimeStampTrans2();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		TFS		Reason
24 January 2020	jlgdi1				Initial creation
*/

vars 
	param:          CMIF_InvoiceSelection;
	invoices:       CM_InvoiceBySeqNumDict;
	invoice,inv:        CM_Invoice;
	
	debtor : CM_Debtor;
	invoiceType : CM_InvoiceDesc;
	paymentType : Integer;
	_invLineType : CM_InvoiceLineDesc;
	tran: CM_TITransaction;
	
	theToDate : TimeStamp;
	
begin
	debtor := "2206.63356".asOid.CM_Debtor;	//  "DI Cash Debtor"
	invoiceType := "2735.282494".asOid.CM_InvoiceDesc;		//  "Storage  Liner MAFI"
	
	_invLineType := "2222.1562029".asOid.CM_InvoiceLineDesc;	// "Future Storage"
	paymentType := _invLineType.getPaymentType(debtor);
	
	//app.msgBox("Payment Type is " &amp; paymentType.asStringJMT, "",0);
	
	create invoices transient;
	create param transient;
	
	param.debtor := debtor;
	param.paymentType := paymentType;
	param.status := CM_Invoice.INVOICE_OPEN;
	param.checkManual := true;
	param.isManual := false;
	param.companyCode := debtor.code;
	
	tran := "12579.292382".asOid.CM_FutureStorage;
	
	invoiceType.initialiseSelectionParameter(param, tran, null, null, null, null);
	
	debtor.getOpenInvoices(invoices, param);
	
	app.msgBox("Transaction date is " &amp; tran.dateTime.asStringJMT,"",0);
	
	if invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then	
		app.msgBox("Invoice is accrual type", "", 0);
	endif;
	
	/*
	theToDate.setDate(toDT.date + 1);
	theToDate.setTime(toDT.time);
	if theToDate &gt;= datetime then
		below := true;
	endif;	
	*/
	
	foreach invoice in invoices do				
		app.msgBox("Testing Invoice Sequence Num " &amp; invoice.sequenceNum.asStringJMT &amp; " Invoice cover dates " &amp; invoice.fromDT.asStringJMT &amp; " - " &amp; invoice.toDT.asStringJMT, "", 0);
		
		//app.msgBox("Is Invoice "&amp; invoice.sequenceNum.asStringJMT &amp;" Date FROM " &amp; invoice.fromDT.asStringJMT &amp; " valid ? " &amp; invoice.fromDT.isValid().asStringJMT, "", 0);
		//app.msgBox("Is Invoice "&amp; invoice.sequenceNum.asStringJMT &amp;" Date TO "  &amp; invoice.toDT.asStringJMT &amp;  " valid ? " &amp; invoice.toDT.isValid().asStringJMT, "", 0);
		
		if invoice.coversTimeStampTransaction(tran) then
				app.msgBox("Transaction date is " &amp; tran.dateTime.asStringJMT &amp; 
								   " MATCHED with Invoice " &amp; invoice.sequenceNum.asStringJMT &amp; 
								   " [" &amp; invoice.fromDT.asStringJMT &amp; " - " &amp; invoice.toDT.asStringJMT &amp; "]", "", 0);
				break;
		endif;
	endforeach;
	
epilog
	delete param;
	delete invoices;
end;</source>
    </JadeMethod>
