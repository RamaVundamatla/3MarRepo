    <JadeMethod name="createProperties" id="b3521820-91fd-4e3e-b198-a0dce6b1c718">
        <source>createProperties();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2023	navlw1	tfs 53902 : EUP - VBS MTN - [6] - Selector Query and JRW
30 May 2023	navlw1	ChangeRequest 53902: EUP - VBS MTN - [6] - Selector Query and JRW - Part2
25 Aug 2023 navhl20 Bug 60056: FR | 53429 - VBS Selector issues
18 Jun 2024 jlizm1	TFS 63908 Allow duplicate driver names
*/

vars
	tmpProp		: CM_QueryProperty;
begin
	inheritMethod();
	
	create tmpProp as CM_QStringProperty persistent;
	tmpProp.set('External Code', CM_VehicleBookingTimeSlot::externalReference.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple);
	tmpProp.needToUpperCase := true;
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringProperty persistent;
	tmpProp.set('Id', CM_VehicleBookingTimeSlot::id.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple);
	tmpProp.needToUpperCase := true;
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringProperty persistent;
	tmpProp.set('Remarks', CM_VehicleBookingTimeSlot::remarks.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple);
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanProperty persistent;
	tmpProp.set('Kiosk Check', CM_VehicleBookingTimeSlot::kioskCheck.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple);
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanProperty persistent;
	tmpProp.set('Pre Gate In Check', CM_VehicleBookingTimeSlot::preGateInCheck.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple);
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanProperty persistent;
	tmpProp.set('Pre Gate Out Check', CM_VehicleBookingTimeSlot::preGateOutCheck.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple);
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanProperty persistent;
	tmpProp.set('Include Delivery', CM_VehicleBookingTimeSlot::includesDelivery.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple);
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanProperty persistent;
	tmpProp.set('Include Pickup', CM_VehicleBookingTimeSlot::includesPickUp.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple);
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Cargo Id', CM_VehicleBookingTimeSlot::getVehicleBookingCargoList.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple);
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Booking Id', CM_VehicleBookingTimeSlot::getBookingRefIdsAsString.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple);
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Release Id', CM_VehicleBookingTimeSlot::getReleaseIdsAsString.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple);
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrVbsStatusMethod persistent;
	tmpProp.set('Status', CM_VehicleBookingTimeSlot::getStatusString.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple);
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrVbsTypeMethod persistent;
	tmpProp.set('Slot Type Description', CM_VehicleBookingTimeSlot::getSlotTypeDescription.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple);
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Vehicle Visit Number', CM_VehicleBookingTimeSlot::getVehicleVisitNumber.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple);
	self.allQueryProperties.add(tmpProp);
		
	create tmpProp as CM_QDateProperty persistent;
	tmpProp.set('Start Date', CM_VehicleBookingTimeSlot::bookingTSstart.name, self.className);			//25.8.2023 navhl20 #60056	
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple);
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QDateProperty persistent;														//25.8.2023 navhl20 #60056
	tmpProp.set('End Date', CM_VehicleBookingTimeSlot::bookingTSend.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple);
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrSubCarrierMethod persistent;
	tmpProp.set('Sub Carrier', CM_VehicleBookingTimeSlot::getSubCarrierCode.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrRecvRelCarrierMethod persistent;
	tmpProp.set('Carrier', CM_VehicleBookingTimeSlot::getCarrierCode.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrDriverMethod persistent;
	tmpProp.set('Driver', CM_VehicleBookingTimeSlot::getDriverCode.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );
	self.allQueryProperties.add(tmpProp);
	
		
	create tmpProp as CM_QStrVehicleRegMethod persistent;
	tmpProp.set('Vehicle Reg Num', CM_VehicleBookingTimeSlot::getVehicleString.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );
	self.allQueryProperties.add(tmpProp);
	
	//jlier1 TFS 58839 6/7/23 
	create tmpProp as CM_QBooleanMethod persistent;
	tmpProp.set('Sent Load NA', CM_VehicleBookingTimeSlot::getSentLoadNotification.name,self.className);
	tmpProp.setPerformanceRating(CM_QueryProperty.Simple);
	self.allQueryProperties.add(tmpProp);
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getSelectorVisibleColumns" id="8630de4b-96a6-4892-8e05-c8e470266d65">
        <source>getSelectorVisibleColumns(_sa: StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2023	navlw1	Initial Initial creation tfs 53902 : EUP - VBS MTN - [6] - Selector Query and JRW

*/

vars
	qProp	: CM_QueryProperty;
begin
	inheritMethod(_sa);
	
	qProp := self.allQueryProperties[CM_VehicleBookingTimeSlot::externalReference.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	
	qProp := self.allQueryProperties[CM_VehicleBookingTimeSlot::getSlotTypeDescription.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	
	qProp := self.allQueryProperties[CM_VehicleBookingTimeSlot::getBookingRefIdsAsString.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	
epilog

end;</source>
        <Parameter name="_sa" type="StringArray" usage="input"/>
    </JadeMethod>
</Class>
