/*
Purpose:			
Date		Who		Reason
05 May 2015	cnwab1	Initial creation
07 Mar 2016	cnwdap1	PAR #37739 Disable the comments text box unless we're in Edit mode
*/

vars
 
	invoiceForm : INV_CashCollectionComments;

begin
	
	create invoiceForm transient;

	
	invoiceForm.setParentForm(self);
	invoiceForm.strComments := self.cashComments;
	invoiceForm.createMyAssistant(INV_Assistant);
	invoiceForm.setMyTerminal(self.myTerminal);
	invoiceForm.txtComments.enabled := self.btnSave.visible;			// PAR #37739
	if invoiceForm.showModal() = IDOK then
		self.cashComments := invoiceForm.strComments;
	endif;

epilog

end;</source>
