    <JadeMethod name="closeForm" id="efcd5a5a-d24d-48f9-b111-02c4cca27000">
        <updating/>
        <source>closeForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 August 2022	navpw1	Initial creation

*/

vars
	type,
	remaining : Integer;
	
begin
	if self.getTimerStatus(self.Timer_Refresh, type, remaining) then
		self.endTimer(self.Timer_Refresh);
	else
		self.endTimer(self.Timer_Refresh);
	endif;

end;</source>
        <access>protected</access>
