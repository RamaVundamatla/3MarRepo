    <JadeMethod name="initYorkServerApp" id="73c4d01c-213c-4296-b652-432fea45ca66">
        <updating/>
        <source>initYorkServerApp() updating;
// ---------------------------------------------------------------------------
// Created:     06 December 2000 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	app.mousePointer := Window.MousePointer_HourGlass;
	app.niceName := "York Server Operations";
	app.cnActivateKarmaControl(Cn_Fat_Client, null, null);

	self.initialize();
	app.handleIt();
	
	app.passBackAllExceptions := false;
	app.passBackJadeExceptionsOnly := true;

	on Exception do app.generalExceptionHandler(exception) global;
	
	//self.logLevel := LogWARN;	//22 Nov 2019	NDL	TFS 47053 Part of 'initialize'
	
//	self.initLogFile();	//rs may 2005 CCMS10137
//	self.autoLogon;
	if not app.doLogin() then
		terminate;
	endif;

//	if app.theConfig.refconConfig = null then
//		beginTransaction;
//		create app.theConfig.refconConfig;
//		app.theConfig.refconConfig.refconServerName := "127.0.0.1";
//		app.theConfig.refconConfig.refconServerPort := 65001;		
//		commitTransaction;
//	endif;

//	app.mdiFrame := Yrk_RefConSimulatorForm;
//	create app.mainForm as Yrk_RefConSimulatorForm;
	app.createMyController(CMUI_Controller);
	
	app.mainForm := app.loadForm(Yrk_RefConSimulatorForm, CMUI_Assistant, false, false, false, app.getMyTerminalDO_NOT_USE(), null).Yrk_RefConSimulatorForm;
	
	// If user fails security we don't want to show a null form.
	if app.mainForm &lt;&gt; null then
		app.mainForm.show;
	endif;
	
epilog
	app.mousePointer := Window.MousePointer_Default;
	
//	app.mainForm.height := 720;
//	app.mainForm.width := 1010;
//	app.mainForm.show;
		
end;</source>
    </JadeMethod>
    <JadeMethod name="timeOfAct" id="396a6719-5867-4121-8873-b90987ed202c">
        <source>timeOfAct(_time: TimeStamp):String;
//
//	returns time in york UTC message format
//
vars
	timeUTC : TimeStamp;
	message: String;
begin
	timeUTC := _time.localToUTCTime();
	message := timeUTC.date.format("yyyyMMdd") &amp; timeUTC.time.format("HHmmss");
	//message := _time.date.format("yyyyMMdd")&amp;_time.time.format("HHmmss");
	return message;
end;</source>
        <Parameter name="_time" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="timeOfActLMT" id="42aefe09-7650-4147-8062-9f50d63cbd17">
        <source>timeOfActLMT(_time: TimeStamp):String;
//
//	returns time in york LMT message format
//
vars
	timeLMT : TimeStamp;
	message: String;
begin
	timeLMT := _time;
	message := timeLMT.date.format("yyyyMMdd") &amp; timeLMT.time.format("HHmmss");
	//message := _time.date.format("yyyyMMdd")&amp;_time.time.format("HHmmss");
	return message;
end;</source>
        <Parameter name="_time" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
