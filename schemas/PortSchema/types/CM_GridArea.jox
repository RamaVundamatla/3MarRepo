    <JadeMethod name="set30ftControllers" id="f91963db-d182-43a2-ae97-5f7ee9b5a8d5">
        <source>set30ftControllers(_gridLCDict : CM_RTGControllerBySeqRowCol input);
/*
----------   ----------  --------------------------------------------------
Created:	May 2008 Andrew Bishop

Purpose:	Sets the is30ft and 30ftOffest properties of the controllers passed in 
			and potential ANY RELATED CONTROLLERS that aren't passed in on the same
			row (they must be in lots of 3 - see offsets)

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
 // PAR 16415 CCMS 1029
*/
vars
	
	gridLC			: CM_GridController;
	row,
	column				: Integer;
		gridRow : CM_GridRow;
begin
	//reset attributes incase they were previously 30ft, but a different offset!
//PAR 18682	foreach gridLC in _gridLCDict do
	foreach gridRow in self.allGridRows  discreteLock do // PAR 18682
		foreach gridLC in gridRow.allControllersByColumn do // PAR 18682
			gridLC.setIs30ft(false);
			gridLC.setOffset30ft(null);
		endforeach;
	endforeach;
	
	
	foreach gridLC in _gridLCDict do
		if  gridLC.is30ft then
			continue;//already been set in finding anothers matching 8 below
		endif;
		
		row := gridLC.myGridRow.row;
		column := gridLC.myGridColumn.column;
		
		self.set30Controller(row, column, CM_LocationsController.Offset30_1, _gridLCDict);
		self.set30Controller(row, column + 1, CM_LocationsController.Offset30_2, _gridLCDict);
		self.set30Controller(row, column + 2, CM_LocationsController.Offset30_3, _gridLCDict);
		
	endforeach;


	
end;


</source>
        <Parameter name="_gridLCDict" type="CM_RTGControllerBySeqRowCol" usage="input"/>
    </JadeMethod>
