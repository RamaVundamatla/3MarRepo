    <JadeMethod name="doPointArrayAdd" id="718d653d-5b93-4c23-9df5-cfb58c14c682">
        <source>doPointArrayAdd(_theColour : Integer;_floodFill : Boolean; _fillStyle : Integer; _drawWidth : Integer; _fillColour : Integer; _graphic: CM_LayoutGraphic);
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Purpose:		The graphic object stores all the lines in one point array, in our drawing control we need each shape in its ow object so in here we split them up
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theFirstPoint, aPoint : Point;
	idx : Integer;
	aGL : CM_LayoutGraphic;
begin
	
	aGL := _graphic;


	self.allPointGraphics.add(aGL);
	self.allLineColours.add(_theColour);

	self.allLineStyles.add(Frame.DrawStyle_Solid);
	self.allFloodFill.add(_floodFill);
	self.allFillStyles.add(_fillStyle);
	self.allFillColours.add(_fillColour);

	self.allDrawWidths.add(_drawWidth);
	if aGL.isKindOf(CM_DeckItemLayout) then
		self.allTexts.add(aGL.CM_DeckItemLayout.code);
	endif;
epilog
end;</source>
        <Parameter name="_theColour" type="Integer"/>
        <Parameter name="_floodFill" type="Boolean"/>
        <Parameter name="_fillStyle" type="Integer"/>
        <Parameter name="_drawWidth" type="Integer"/>
        <Parameter name="_fillColour" type="Integer"/>
        <Parameter name="_graphic" type="CM_LayoutGraphic"/>
    </JadeMethod>
    <JadeMethod name="doPointArrayAddFromProxy" id="1e55479f-a0e9-4f2d-93cc-647dd7f58c5c">
        <source>doPointArrayAddFromProxy(_pxyRORO : CM_ROROGraphic);


// ### PROTOTYPE




// ---------------------------------------------------------------------------
// Created:     January 2011 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin
	self.allPointGraphics.add(_pxyRORO);
	self.allLineColours.add(_pxyRORO.drawLineColour);
	self.allLineStyles.add(Frame.DrawStyle_Solid);

	self.allFloodFill.add(true);
	self.allFillStyles.add(_pxyRORO.drawFillStyle);
	self.allFillColours.add(_pxyRORO.drawFillColor);

	self.allDrawWidths.add(_pxyRORO.drawWidth);
	self.allTexts.add(_pxyRORO.label);
epilog
	
end;</source>
        <Parameter name="_pxyRORO" type="CM_ROROGraphic"/>
    </JadeMethod>
    <JadeMethod name="doRemoveGraphic" id="8b097252-38f3-4a6e-98e1-179ba14e84cb">
        <source>doRemoveGraphic(_layout : CM_DeckItemLayout);
/*
Purpose:			
Date		Who		Reason
24 August 2011	cnwab1	Initial creation
*/

vars
	idx : Integer;
begin
	if self.allPointGraphics.includes(_layout) then
		idx := self.allPointGraphics.indexOf(_layout);
		
		self.allPointGraphics.removeAt(idx);
		
		self.allLineColours.removeAt(idx);
		self.allLineStyles.removeAt(idx);
		self.allFloodFill.removeAt(idx);
		self.allFillStyles.removeAt(idx);
		self.allFillColours.removeAt(idx);
		self.allDrawWidths.removeAt(idx);
		self.allTexts.removeAt(idx);
		
	endif;
epilog

end;</source>
        <Parameter name="_layout" type="CM_DeckItemLayout"/>
    </JadeMethod>
    <JadeMethod name="doRemovePoint" id="2cb00e66-c819-4b73-9a65-f5d03e9bffd4">
        <updating/>
        <source>doRemovePoint(_thePoint : Point) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	thePointArray : PointArray;
	thePoint, theAdjoiningPoint, theNewPoint : Point;
	thePointIndex, theAdjoiningPointIndex : Integer;
	x1,x2,y1,y2,x3,y3 : Integer;
begin
	if self.theGraphic = null then
		app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " self.theGraphic is Null returning....");
		return;
	endif;
	
	
	self.theGraphic.doRemovePoint(_thePoint);
	/*
	thePointArray := self.theGraphic.pointsPolygon;
	thePointIndex := thePointArray.indexOf(_thePoint);
	
	if thePointIndex &gt; 0 and thePointIndex &lt;= thePointArray.size then
		thePointArray.removeAt(thePointIndex);
	else
		app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " Point not found, cannot remove ");
		return;
	endif;
	*/
	self.dataChanged := true;
	
end;</source>
        <Parameter name="_thePoint" type="Point"/>
    </JadeMethod>
    <JadeMethod name="dragDrop" id="a3213fad-cce8-4545-affa-c7e05079a027">
        <controlMethod name="Frame::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>dragDrop(frame: Frame input; win: Window input; x: Real; y: Real) updating, clientExecution;
/*
Purpose:			
Date		Who		Reason
16 September 2011	cnwab1	Initial creation
*/

vars

begin
	inheritMethod(frame, win, x, y);
	
	if not self.isForPlanning() then
		return;
	endif;
	
	
	self.doFrameMouseDragDrop(frame, win, x, y);
epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="dragOver" id="dccd865e-575c-4e51-8851-f8fba258bc34">
        <updating/>
        <source>dragOver(frame: Frame input; win: Window input; x: Real; y: Real; state: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(frame, win, x, y, state);
	self.doFrameMouseDragOver(frame, win, x, y, state);

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawAPolygon" id="2e0db3a7-2db0-459c-b7d4-8026673944b8">
        <updating/>
        <source>drawAPolygon(_thePointArray : PointArray;_doFloodFill : Boolean;_colour : Integer; _drawWidth : Integer; _fillColor : Integer; _scale : Decimal; _text : String) updating;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	KnobWidth = 3;
vars
	tmpGraphic : CM_Graphic;
	thePoint, the1stPoint,fromPoint, toPoint : Point;
	idx,x1,x2,y1,y2 : Integer;
	maxX,maxY,minX,minY, pointMarkerColour,pointerX, textX, textY : Integer;
	theColour : Integer;
	theObject : Object;
	thePointArray : PointArray;
	theFirstPoint, doFloodFill : Boolean;
	rArray : RealArray;
	textWidth, polyWidth, polyHeight, checkWidth : Real;
	lastItem : CM_DeckItemLayout;
begin
	if _thePointArray.isEmpty then
		return;
	endif;
	doFloodFill := _doFloodFill;
	self.drawWidth := _drawWidth;
	self.drawFillColor := _fillColor;
	
	create rArray transient;
	_thePointArray.populateRealArray(rArray, _scale);		
	if doFloodFill then
		self.drawFilledPolygon(rArray,_colour);
	else
	
		self.drawPolygon(rArray,_colour);
	endif;
	if self.showText and _text &lt;&gt; null then

		self.getExtremePoints(CM_Graphic.Position_Left, CM_Graphic.Position_Top, _thePointArray, textX, textY);
		textX := (textX * _scale).Integer + 2 ;
		textY := (textY  * _scale).Integer + 2;
		self.drawFontSize := 6;
		
		if self.drawFillStyle = Frame.DrawFillStyle_Transparent then
			theColour := Black;
		elseif  self.drawFillStyle =Frame.DrawFillStyle_Solid then
			theColour := self.drawFillColor.getInverseColour();
		else
			theColour := Black;
		endif;
		self.drawTextRotation := 0;
		self.drawTextCharRotation := 0;
		
		if rArray.size &gt;= 4 then
			textWidth := self.getTextExtent(_text)  - 10;
			polyWidth := rArray[3] - rArray[1];
			polyHeight :=  rArray[rArray.size-2] - rArray[2];
			
			
			if self.modeView = ShpDisplayMode_Defn then
				checkWidth := polyWidth.max(polyHeight);
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; " " &amp; _text &amp; ' textWidth: ' &amp; textWidth.String &amp; " polyWidth: " &amp; polyWidth.String &amp; " X2: " &amp; rArray[4].String &amp; " X1: " &amp; rArray[1].String);
				self.drawFontSize := 20;
				while self.drawTextWidth(_text) + 6 &gt; (checkWidth) do
					self.drawFontSize := self.drawFontSize - 1;
					if self.drawFontSize &lt; 7 then
						break;
					endif;
				endwhile;

			endif;
			
			// PAR 28400 dmast only, show the location ID as large as possible
			if polyHeight &gt; polyWidth then
				self.drawTextRotation := 270;
				self.drawTextCharRotation := 270;
				self.drawTextAlign := Frame.DrawTextAlign_Left;
				textX := (textX + polyWidth - 2).Integer ; //epr par 32929 7/11/13
			endif;
		endif;
		self.drawTextAt(_text,textX, textY, theColour);
	endif;
	
	if self.mode = Mode_DisplayOnly 
	or self.mode = Mode_Work
	or self.dragCursor = self.picCursorMove 
	or (self.mode = self.Mode_PolyMove  and idx = 4) 
	or (self.modeView = ShpDisplayMode_Defn 
	//PAR 28920 or self.modeView = ShpDisplayMode_Actual 
	or self.modeView = ShpDisplayMode_Proposed // PAR 28990
	or self.modeView = ShpDisplayMode_ColCodeDisch ) then // in this mode we only draw the knob on the 3rd point
		return; // no knobs
	endif;

	// PAR 29989
	if self.modeView = ShpDisplayMode_Actual then
		if not self.allPointGraphics.isEmpty() then
			lastItem := self.allPointGraphics.last().CM_DeckItemLayout;
			if lastItem &lt;&gt; null  then
				if not lastItem.isGCDefnLayout() then
					return; // no knobs
				endif;
			endif;
		endif;
	endif;
	
	if self.modeView = ShpDisplayMode_ColCodeLoad then
		tmpGraphic := self.getGraphicObject(_thePointArray[1]);
		if tmpGraphic &lt;&gt; null  then
			if not tmpGraphic.isGCDefnLayout() then
				return;
			endif;
		else
			return;
		endif;
	endif;
	
	// ##################
	// draw a dot on the 'corners'
	// ##################

	fromPoint := _thePointArray[1];
	the1stPoint := fromPoint;
	foreach idx in 2 to _thePointArray.size do
		toPoint := _thePointArray[idx];
		x1 := ((fromPoint.x).Integer * _scale).Integer;
		y1 := ((fromPoint.y).Integer * _scale).Integer;
		x2 := ((toPoint.x).Integer * _scale).Integer;
		y2 := ((toPoint.y).Integer * _scale).Integer;
		
//		if self.mode &lt;&gt; Mode_DisplayOnly 
//		and self.mode &lt;&gt; Mode_Work
//		and self.dragCursor &lt;&gt; self.picCursorMove then
//			if self.mode &lt;&gt; self.Mode_PolyMove 
//			or (self.mode = self.Mode_PolyMove  and idx = 4) then // in this mode we only draw the knob on the 3rd point
				if self.isForRORO() then
					if toPoint = self.dragLastPoint then
						pointMarkerColour := Blue; // 28008
					else
						pointMarkerColour := Red;
					endif;
				else
					pointMarkerColour := Black;
				endif;
				self.drawFillStyle := Frame.DrawFillStyle_Solid;
				self.drawFillColor := pointMarkerColour;
				self.drawFilledRectangle(x1 - KnobWidth,y1 - KnobWidth,x1 + KnobWidth,y1 + KnobWidth,pointMarkerColour);
				self.drawFillColor := _fillColor;

//			endif;
//		endif;
		
		if the1stPoint.x = toPoint.x and the1stPoint.y = toPoint.y then
			if idx &lt; _thePointArray.size then
				fromPoint := _thePointArray[idx + 1];
				the1stPoint := fromPoint;
			endif;
		else
			fromPoint := toPoint;
		endif;
	endforeach;

epilog
	delete rArray;
end;</source>
        <Parameter name="_thePointArray" type="PointArray"/>
        <Parameter name="_doFloodFill" type="Boolean"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_drawWidth" type="Integer"/>
        <Parameter name="_fillColor" type="Integer"/>
        <Parameter name="_scale" type="Decimal"/>
        <Parameter name="_text" type="String"/>
    </JadeMethod>
    <JadeMethod name="drawAllPolygons" id="cb367d75-e1cd-48cd-95a6-b8822eb60509">
        <updating/>
        <source>drawAllPolygons(_colour : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	thePoint, the1stPoint,fromPoint, toPoint : Point;
	idx,x1,x2,y1,y2, textX, textY : Integer;
	maxX,maxY,minX,minY, pointMarkerColour,pointerX : Integer;
	theColour : Integer;
	theObject : Object;
	theText : String;
	theFirstPoint, doFloodFill : Boolean;
	aGraphic : CM_LayoutGraphic;
	rArray : RealArray;
	scale : Decimal[12,2];
	deckItemLayout : CM_DeckItemLayout;
begin
	self.autoRedraw := true;
	scale := self.scaleFactor;
	if scale &lt;= 0 then
		scale := 1;
	endif;
		
self.endBatchDrawing();
self.beginBatchDrawing();

//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1.scale: ' &amp; scale.String &amp; " self.form: " &amp; self.form.String);	
	create rArray transient;
	pointerX := 0;
	foreach theObject in self.allPointGraphics do
		pointerX := pointerX + 1;

		if pointerX &gt; self.allFloodFill.size then
			break;
		endif;
		if theObject = null then
			continue;
		endif;
		aGraphic := theObject.CM_LayoutGraphic;
		if aGraphic.pointsPolygon.size = 0 then
			continue;
		endif;
		doFloodFill := self.allFloodFill[pointerX];

		if self.showColour then
			// we are not always run from a scrollable drawing frame
			if self.mySDF &lt;&gt; null and ( _colour = self.mySDF.backColor) then
				theColour := _colour;
			else
				theColour := self.allLineColours[pointerX];
			endif;
		else
			theColour:=Black;
		endif;

		if pointerX &lt;= self.allFillStyles.size then
			self.drawFillStyle := self.allFillStyles[pointerX];
			//epr par 27626 25/5/2011 if solid fill make it transparent
			if not self.showColour and  self.drawFillStyle =Frame.DrawFillStyle_Solid  then		
				self.drawFillStyle :=  Frame.DrawFillStyle_Transparent;
			endif;

		else
			self.drawFillStyle :=  Frame.DrawFillStyle_Transparent;
		endif;
		
		if pointerX &lt;= self.allDrawWidths.size then
			self.drawWidth := self.allDrawWidths[pointerX];
		else
			self.drawWidth :=  1;
		endif;
	
		if self.showColour then
			if pointerX &lt;= self.allFillColours.size then
				self.drawFillColor := self.allFillColours[pointerX];
			else
				self.drawFillColor :=  theColour;
			endif;
		else
			self.drawFillColor := Black;
		endif;
		
		if pointerX &lt;= self.allDrawWidths.size then
			self.drawStyle := self.allLineStyles[pointerX];
		else
			self.drawStyle :=  Frame.DrawStyle_Solid;
		endif;
		
		if self.showText then
			theText := self.allTexts[pointerX];
		else
			theText := null;
		endif;
		

		self.drawAPolygon(aGraphic.pointsPolygon,doFloodFill,theColour, self.drawWidth, self.drawFillColor, scale, theText);

		if theObject.isKindOf(CM_DeckItemLayout) then // PAR 29324
			deckItemLayout := theObject.CM_DeckItemLayout;
			// PAR 28880 Is the rotation master, draw a red dot.
			if deckItemLayout.myDeckItem &lt;&gt; null and deckItemLayout.myDeckItem.isLocnContainer() then
				if not deckItemLayout.myDeckItem.CM_ROROLocnDefn.allPlannedRotatedLocnDefns.isEmpty() then
					self.drawFillColor := Red;
					self.drawFillStyle := Frame.DrawFillStyle_Solid;
					x1 := deckItemLayout.myPolygonPixels[4].x;
					y1 := deckItemLayout.myPolygonPixels[4].y;
					//epr par 32658 14/10/13 needed to scale proberly
					self.drawEllipse((x1+2)*scale, (y1-2)*scale, (x1+10)*scale, (y1-10)*scale,Red);
				endif;
			endif;
		endif;
	endforeach;
	// we are not always run from a scrollable drawing frame
	if self.mySDF &lt;&gt; null then
		self.mySDF.repositionAfterResize();
	endif;
epilog	
		
	self.endBatchDrawing();
	
	delete rArray;
end;</source>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
