vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportSilentExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 10, _passport);
	
	beginTransaction;
	app.myUtilityUA.utlUpdateTICEDO(_theProxyTI, _theCEDONumber, null, _required, _passport);
	// now delete the stop in the same transaction cnwrs1 dec 2006
	app.myUtilityDA.utlDeleteStops(_theProxyTI, _theStops, _passport);
	
epilog	
	self.finaliseActivityWithPassport(_passport);
	
end;</source>
