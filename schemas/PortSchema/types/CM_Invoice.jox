    <JadeMethod name="getExternalInvoiceNumber" id="ee3be465-d011-4a64-9011-77e2b2c49df2">
        <source>getExternalInvoiceNumber() : String;
// 31905	cnwjre1	Jun 2013	Milaha posted invoices are to have an external (posted to Oracle financials) number with the posted year and a unique sequence within this
//		re-use existing unused exportCurrencyCode to hold this.  In the future may add a property for this use.
//		TFS 1849 - Searching via external number
vars

	invNumber	: String;
	
begin

	invNumber := self.getExternalInvoiceNumberRaw;
	if invNumber = null then
		invNumber := self.getExternalInvoiceNumberCalc;
	endif;
	
	return invNumber;
	
epilog

end;

</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExternalInvoiceNumberCalc" id="8aec658a-c8c9-4716-afc5-20f262ec6725">
        <source>getExternalInvoiceNumberCalc():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2016	cnwndl1	Initial creation	TFS 1849

*/

vars

	finIOClass : CM_ExtFinanceIO;
	
begin

	finIOClass := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	return finIOClass.getExternalInvoiceNumber(self);
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
