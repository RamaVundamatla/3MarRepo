    <JadeMethod name="includeCriteria" id="0f1cd9d6-da8d-4770-90b7-071383f3cca7">
        <source>includeCriteria(_critType : CM_YACriteriaType) : Boolean;
/*
Purpose:	Two types of allocation billing, ones uses nearly all cargo attributes, the inventory uses only 10-15		

Date		Who		Reason
27MAY2021	NAVAB1	TFS 51219
*/


vars

begin
	if self.myTranMap &lt;&gt; null then // Invoice Cargo Allocations
		if not _critType.isForInvoicingAllocations() then
			return false;
		endif;
	
	elseif self.myTranMapInvent &lt;&gt; null then // Inventory Allocations
		if not _critType.isForInventoryAlllocation() then
			return false;
		endif;
		
	
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_critType" type="CM_YACriteriaType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateCriteria" id="9b6dbe39-3eb6-4296-a234-fdea68f9f3d7">
        <updating/>
        <source>populateCriteria() updating;
/*
Purpose:			
Date		Who		Reason
12 March 2015	cnwab1	Initial creation
*/

vars
	imex : CM_IMEXStatus;
	criteriaType: CM_YACriteriaType;
	opCriteria: CM_YACriteriaArray;
	criteria, proxyCriteria: CM_YACriteria;
	allCriteria				: CMIF_Array;
	tmpObjectSet			: ObjectSet;
	transientObj			: CMIF_YACriteriaPriority;
	localAssistant : CMUI_Assistant;
	caption : String;
	config : CM_InvoiceAllocationConfig;
begin
	self.allOperationalCriteria.purge();
	self.allTemplateCriteria.purge();

		create opCriteria transient;
		
		// ### TFS 51219 03JUN2021 NAVAB1
		if self.myTranMap &lt;&gt; null then
			config := self.myTranMap.myInvoiceAllocationConfig;		
		elseif self.myTranMapInvent &lt;&gt; null then
			config := self.myTranMapInvent.myInvoiceAllocationConfig;		
		endif;
		
		
		if config &lt;&gt; null then
		
			if config.allOpCriteria.isEmpty then
				app.msgBox(app.getErrorString(Please_voyage_config_color_cod), app.getErrorString(Problem), MsgBox_OK_Only);
				localAssistant := self.myAssistant;
				self.unloadForm();
			else
				foreach criteriaType in config.allOpCriteria do
					if self.myYardAllocation &lt;&gt; null then
						criteria := self.myYardAllocation.getCriteriaOfTypeValue(criteriaType.type);
					else
						//epr par 19078 19/3/09
						if allCriteria &lt;&gt; null and allCriteria.size &gt; 0 then
							criteria:=self.getCriteriaOfTypeFromTI(allCriteria,criteriaType.type);
						endif;
					endif;
					create proxyCriteria transient;
					if criteria = null then
						proxyCriteria.setProxy(criteriaType, "", "");			
					else
						proxyCriteria.setProxy(criteria.myYACriteriaType, criteria.myYAData.getDataValue(), criteria.code);
						opCriteria.add(criteria);
					endif;
					self.allOperationalCriteria.add( proxyCriteria.getTransient());
				endforeach;
			endif;
		endif;
	
		
		if self.myYardAllocation &lt;&gt; null then
			foreach criteria in self.myYardAllocation.allCriteria do
				if not opCriteria.includes(criteria) and criteria.myYACriteriaType.type &lt;&gt; YACriteriaType_ImexStatus then
				//if criteria.myYACriteriaType.type &lt;&gt; YACriteriaType_ImexStatus then
					create proxyCriteria transient;
					proxyCriteria.setProxy(criteria.myYACriteriaType, criteria.myYAData.getDataValue(), criteria.code);
					self.allTemplateCriteria.add( proxyCriteria.getTransient() );
				endif;
			endforeach; 
		else
			// PAR 19421 no extra template criteria are defaulted
		endif;
		self.populateCriteriaFrames(false);
	
epilog
	if allCriteria &lt;&gt; null then
		allCriteria.purge();
		delete allCriteria;
	endif;
	if tmpObjectSet &lt;&gt; null then
		delete tmpObjectSet;
	endif;
	delete opCriteria;
end;</source>
    </JadeMethod>
