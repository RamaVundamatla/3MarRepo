<Class name="WS_NLovResponse" id="909ec692-d565-4686-bd52-c6d862260537">
    <superclass name="WS_NAPIResponse"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <Constant name="CoolingTypeEnum" id="18675516-4e54-495a-8e8a-a55aa2e22151">
        <source>"coolingTypeEnum"</source>
        <type name="String"/>
    </Constant>
    <Constant name="VentUnitEnum" id="e08f1d61-a666-464d-841f-c2b1db783f80">
        <source>"ventUnitEnum"</source>
        <type name="String"/>
    </Constant>
    <Constant name="VoltageTypeEnum" id="23c37227-7ae2-45a7-95af-f8e7bf8aa42b">
        <source>"voltageTypeEnum"</source>
        <type name="String"/>
    </Constant>
    <ImplicitInverseRef name="content" id="bc420117-97e0-4274-98ff-baf8aa8fd96c">
        <memberTypeInverse/>
        <type name="WS_NLovArray"/>
    </ImplicitInverseRef>
    <JadeMethod name="createContent" id="220f1f17-f3e5-4feb-a416-7b745ce9e0f4">
        <updating/>
        <source>createContent(_lovKey, _searchStr : String) : Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 23/10/2020	jlgdap1		Initial creation TFS 49227 Navis API - nReefer API
//
vars
	lov : WS_NLov;
	measure : CM_MeasurementType;

begin
	if _lovKey = self.VentUnitEnum then
		foreach measure in app.myRoot.allMeasurementTypesByShortName discreteLock where measure.measurementType = Type_Displacement do
			if _searchStr = null or measure.shortName.cnContains(_searchStr) then
				create lov transient;
				lov.lovLabel := measure.shortName;
				lov.lovValue := measure.shortName;
				self.content.add(lov);
			endif;
		endforeach;
		
		return true;
	
	elseif _lovKey = self.CoolingTypeEnum then
		if _searchStr = null or ContainerAirCooledStr.cnContains(_searchStr) then
			create lov transient;
			lov.lovLabel := ContainerAirCooledStr;
			lov.lovValue := ContainerAirCooledStr;
			self.content.add(lov);
		endif;
		if _searchStr = null or ContainerWaterCooledStr.cnContains(_searchStr) then
			create lov transient;
			lov.lovLabel := ContainerWaterCooledStr;
			lov.lovValue := ContainerWaterCooledStr;
			self.content.add(lov);
		endif;
		
		return true;
	
	elseif _lovKey = self.VoltageTypeEnum then
		if _searchStr = null or ContainerDualVoltStr.cnContains(_searchStr) then
			create lov transient;
			lov.lovLabel := ContainerDualVoltStr;
			lov.lovValue := ContainerDualVoltStr;
			self.content.add(lov);
		endif;
		if _searchStr = null or ContainerSingleVoltStr.cnContains(_searchStr) then
			create lov transient;
			lov.lovLabel := ContainerSingleVoltStr;
			lov.lovValue := ContainerSingleVoltStr;
			self.content.add(lov);
		endif;
		
		return true;
	
	endif;
	
	return false;
	
epilog

end;</source>
        <Parameter name="_lovKey" type="String"/>
        <Parameter name="_searchStr" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getResponseCode" id="2a50fc9f-104f-42e8-9120-cfd86f2bcb46">
        <source>getResponseCode(): Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 23/10/2020	jlgdap1		Initial creation TFS 49227 Navis API - nReefer API
//
vars

begin
	return HttpResponseOK;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
