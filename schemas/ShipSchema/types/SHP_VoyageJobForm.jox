    <JadeMethod name="setTableForJobType" id="f3b4dcaf-b5e5-493c-8fdd-936e9170b964">
        <updating/>
        <source>setTableForJobType(combobox: ComboBox input) updating;
//----------------------------------------------------------------
//	Created:	01 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	jobType	: CM_JobType;
begin

	self.tblJobEdit.setValueByControlName(combobox.name, combobox.text);

	jobType := self.cmbJobType.listObject.CM_JobType;
	
	if jobType &lt;&gt; null then
		self.tblJobEdit.setValueByName(ETRow_TimeToComplete,jobType.estimatedTimeToCompleteMins);	
	endif;
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="75ade7be-695b-4796-b2b1-c9de5029c5a2">
        <updating/>
        <source>showThumbnailData(obj: CM_Object) updating;
//--------------------------------------------------------------
//Created: 23 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	job			: CM_VoyageJob;
begin

	job := obj.CM_VoyageJob;

	self.setNavigatorHeading(job.jobId);

	self.tblJobEdit.setTableFromCM_Object(job,null);
	
	
	if job.myDeck &lt;&gt; null then
		self.tblJobEdit.showRowByName(ETRow_DeckId,false);
		self.tblJobEdit.hideRowByName(ETRow_BayId,false);
	else
		self.tblJobEdit.showRowByName(ETRow_BayId,false);
		self.tblJobEdit.hideRowByName(ETRow_DeckId,false);
	endif;
	
	
	if job.isKindOf(CM_VoyageHatchLidJob) and job.myDeck = null then
		self.tblJobEdit.showRowByName(ETRow_TheHatchLids,false);
	else
		self.tblJobEdit.hideRowByName(ETRow_TheHatchLids,false);
	endif;
	
	//epr par 33070 30/12/13
	if job.isDischarge then
		self.tblJobEdit.hideRowByName(ETRow_LoadOutOfSequence,false);
	else
		self.tblJobEdit.showRowByName(ETRow_LoadOutOfSequence,false);
	endif;
epilog
	
	
end;</source>
        <Parameter name="obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="showWithObject" id="52b7e297-b465-40f8-93ee-daa4a44ea4df">
        <updating/>
        <source>showWithObject(pObj: CM_Object; _thumbnailOnly: Boolean; _doEdit: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	
	inheritMethod(pObj, _thumbnailOnly, _doEdit);

	if pObj.isKindOf(CM_VoyageJob) then
		self.filterVoyage := pObj.CM_VoyageJob.myVoyage;
		self.doCombosBuildForFilterVoyage();
	endif;
end;</source>
        <Parameter name="pObj" type="CM_Object"/>
        <Parameter name="_thumbnailOnly" type="Boolean"/>
        <Parameter name="_doEdit" type="Boolean"/>
    </JadeMethod>
