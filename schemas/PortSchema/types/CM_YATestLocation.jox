<Class name="CM_YATestLocation" id="cfa50499-1e82-4c0d-8f9f-1a9536050dd5">
    <superclass name="CM_YardAllocationItem"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>
	Transient class used during "Test Auto Planning"
	to record the locations used by the test auto plan run
	so that single locations are not 're-used'
	for multiple cargo items in a single test run.</text>
    <DbClassMap file="cmtrans"/>
    <PrimAttribute name="endOffset" id="56eb991d-251f-445d-af8f-70a0b516b2bb">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myLocation" id="c6c49607-76e4-47b7-ae0d-83461d302112">
        <embedded/>
        <type name="CM_LocationsController"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTrackedItem" id="46d872f2-30d7-4648-a872-28f4e53652e0">
        <embedded/>
        <type name="CM_TrackedItem"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myYardLocation" id="89198feb-e522-4136-95cb-6b4b17f1a8f2">
        <embedded/>
        <type name="CM_YardController"/>
        <text>NOT USED ANYMORE PLEASE USE myLocation </text>
    </ImplicitInverseRef>
    <PrimAttribute name="startOffset" id="a6333e35-60c8-46be-ae93-7504e1a81e6d">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="getTestCount" id="5a6c90dc-47c8-4c4a-a8ea-3bde3172777f">
        <source>getTestCount() : Integer;
/*

Purpose:			TFS 43424

Parameters:			

Return Value:		

Date		Who		Reason
15 February 2019	jlgab1	Initial creation
20 Oct 2022		jlier1  TFS 54675 20/10/22 - can autoplan to a trailer location which is not a yard location
*/

vars

begin

	if self.myLocation.isShelf() then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.totalQuantity;
		endif;
	elseif self.myLocation.isKindOf(CM_IrregularBlockController) then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.totalQuantity;
		endif;
	endif;

	return 1;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
