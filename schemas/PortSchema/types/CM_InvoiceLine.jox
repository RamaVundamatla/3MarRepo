    <JadeMethod name="isEventBlockUnit" id="e46c2bad-bf5f-4a66-a495-f69eb1be974c">
        <source>isEventBlockUnit( _theUnit : Integer) : Boolean;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 22 August 2022
TFS#		: 54420
Function	:

*** Changes ***
Date			Name		TFS#		Description
23/08/2022		jlika1		TFS 54897 	MTN - Days being charged is incorrect
****************************************************/

vars

begin
	if (_theUnit = INV_CALC_TYPE_EVENT_TIME_DAYS or
		_theUnit = INV_CALC_TYPE_EVENT_TIME_HOURS or
		_theUnit = INV_CALC_TYPE_EVENT_TIME_MINUT or 
		_theUnit = INV_CALC_TYPE_EVENT_DAYS_FULL)  then
		
		return true;
	endif;
	
	return false;
epilog

end;</source>
