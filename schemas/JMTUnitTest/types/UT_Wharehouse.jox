    <DbClassMap file="unitTest"/>
    <JadeMethod name="addCargoLocation" id="161f71f7-39b3-40bf-bb42-99e4a68b168b">
        <source>addCargoLocation(_cargoType : String; _id : String; _imex : Integer; _vol : Integer; _weight : Integer; _lc : CM_LocationsController);
/*
Purpose:			
Date		Who		Reason
20 September 2013	NAVAB1	Initial creation
*/

vars
	operator : CM_Operator;
	ct : CM_CargoType;
	ti : CM_TrackedItem;
begin
	self.opts.addAssoc(UTTI_IMEX, _imex);
	self.opts.addAssoc(UTTI_Volume, _vol);
	self.opts.addAssoc(UTTI_TotalWeight, _weight);


	ct := self.getCargoType(_cargoType);
	ti := self.addCargoOpts(_id, null,null, operator, ct.id);	
	
	self.move(ti, _lc);

epilog

end;</source>
        <Parameter name="_cargoType" type="String"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_imex" type="Integer"/>
        <Parameter name="_vol" type="Integer"/>
        <Parameter name="_weight" type="Integer"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
