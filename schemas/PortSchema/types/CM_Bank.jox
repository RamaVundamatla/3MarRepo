    <JadeMethod name="getInvoiceLineDescForBOL" id="36298e8c-dd15-4232-a8ac-c0f771ecc851">
        <updating/>
        <source>getInvoiceLineDescForBOL(_aSBController : CMIF_ServiceBroker input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Nov 2019	jlgndl1	Initial creation	TFS 47100
10 Oct 2022 navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
18 Oct 2024 navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars

	sb 			    : CM_BOLServiceBroker;
	theTransaction  : CM_BOLTransaction;
	theBank 		: CM_Bank;
	theTM 			: CM_TranMapBOL;
	canLogExtra	    : Boolean;
begin
	canLogExtra	   := app.canLogExtraDetail();				//10.10.2022 navma1 #52967 
	theTransaction := _aSBController.myBOLTransaction;
	
	theBank := _aSBController.myBank;
	if theBank = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(Input_required_field_EvtInvBnk,   method.name, null, null); 
		return;
	endif;
	
	theTM := theBank.myCurrentTranMapBOL;
	if theTM = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(Input_required_field_evtInvNCT,  method.name, null, null); 
		return;
	endif;
	
	if canLogExtra then										//10.10.2022 navma1 #52967
		app.invLog("BOL transaction map '" &amp; theTM.name &amp; "'", LogINFO.String);
	endif;

	sb := theTM.getServiceBroker(theTransaction);
	if sb = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_TRANSACTION_MAP, null, "SB. BOL TRANSACTION TYPE  for '" &amp; theTransaction.getTypeString() &amp; "'", null, null);
		return ;
	endif;	
	
	sb.getInvoiceLineDesc(_aSBController);

end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceLineDescForCargo" id="4f7f744a-ef2f-4fec-844d-681f7b02e51f">
        <updating/>
        <source>getInvoiceLineDescForCargo(_aSBController : CMIF_ServiceBroker input) updating;
// go through the transaction map matching the transaction attributes to find one or more invoice line descriptions to create invoice lines from
// CCMS DPH 2278 for cargo marked as future storage, use the invoice line description on the free storage future storage mapping
//		(uses terminal area groups to get billing by cargo location), for future storage transaction only.
//Date			Who		Reason
//05 Oct 2022 	navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
//18 Oct 2024 	navlw1	JIRA-33107: Invoice Logging Use Levels
vars
	prodGroupMap 	  : CM_ProductGroupMap;
	productMap 		  : CM_ProductMap;
	tmpTIServiceMap   : CM_TIServiceMap;
	tmpIMEXServiceMap : CM_ImexServiceMap;
	tmpContentsMap 	  : CM_ContentsMap;
	commodityMap	  : CM_CommodityMap;
	tmpServiceBroker  : CM_ServiceBroker;
	theTransaction 	  : CM_TITransaction;
	tiID, 
	tiClass, 
	tiIMEX 			  : String;
	theTI 			  : CM_TrackedItem;
	storageDetail	  : CM_StorageDetail;
	futureMapping	  : CM_FutureStorageMapping;
	termArea		  : CM_TerminalArea;
	expiryDate		  : Date;
	canLogExtra		  : Boolean;
	termAreaID		  : String;
begin
	
	canLogExtra :=	app.canLogExtraDetail();				//10.10.2022 navma1 #52967
	
	if _aSBController = null then
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _aSBController');
		return;	
	endif;
	
	theTransaction := _aSBController.myTransaction;
	if theTransaction = null then
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _aSBController.myTransaction');
		return;	
	endif;

	theTI := theTransaction.myTrackedItem;
	if theTI = null then
		if canLogExtra then									//10.10.2022 navma1 #52967
			app.invLog("Transaction has no cargo", LogTRACE.String);
		endif;
		return;
	endif;

	// CCMS DPH 2278 if the cargo has a future storage expiry date set, and the cargo matches a free storage detail with future mapping,
	//	get the invoice line description from that mapping, instead of from the transaction map.  ONLY for CM_FutureStorage.
	if theTransaction.isKindOf(CM_FutureStorage) then
		if expiryDate &lt;&gt; null then
			// ### JIRA 33015 03OCT2024 NAVAB1
			if canLogExtra then
				app.invLog("Future Storage Transaction Mapping...", LogTRACE.String);
			endif;
			
			storageDetail := theTI.getMatchingFreeStorageDetail( theTransaction );	//13 Nov 2019	NDL TFS 47344 - to take trx parameter
			if storageDetail &lt;&gt; null then
				termArea := theTransaction.CM_FutureStorage.getMyTerminalArea;		//13 Nov 2019	NDL TFS 47344 - use the terminal area from the trx
				if termArea = null then
					termArea := theTI.myTerminalArea;
					if termArea &lt;&gt; null then
						termAreaID := termArea.id;
					endif;
				endif;
				
				// ### JIRA 33015 03OCT2024 NAVAB1
				if canLogExtra then
					app.invLog("Future Storage Transaction Mapping - MATCHED storage detail " &amp; storageDetail.description, LogTRACE.String);
				endif;
				foreach futureMapping in storageDetail.allFutureStorageMappings do
					if futureMapping.myStorageGroup.includesArea(termArea) then
	
						if canLogExtra then									//10.10.2022 navma1 #52967
							app.invLog("Found free storage detail " &amp; storageDetail.getDisplayForLogging(), LogTRACE.String);
							app.invLog(" for terminal area group " &amp; futureMapping.myStorageGroup.description, LogTRACE.String);
						endif;
						
						futureMapping.myQuantityMap.getInvoiceLineDesc(_aSBController);		
						return;
					endif;
				endforeach;
				// ### JIRA 33015 03OCT2024 NAVAB1
				if canLogExtra then
					app.invLog("Future Storage Transaction Mapping - FAILED - no matching terminal area group for " &amp; termAreaID, LogTRACE.String);
				endif;
				return;
			else
				// ### JIRA 33015 03OCT2024 NAVAB1
				if canLogExtra then
					app.invLog("Future Storage Transaction Mapping - FAILED - no matching storage detail...", LogTRACE.String);
				endif;
				return;
			endif;
		endif;
	endif;
	
	tiID := theTI.id;
	tiClass := theTI.class.name;
	// TFS 37994 tiIMEX := theTransaction.getImExStatusStringDesc(true);
	tiIMEX := theTransaction.getImExStatusDescForMapping(true); // TFS 37994 DLR and SOB are part of IMEX for tran map, so this method returns DLR or SOB is neccesary.

	// AKB 12Mar2001 - exceptions added PAR 1477
	tmpTIServiceMap := self.getTIServiceMap(theTI);
	if tmpTIServiceMap = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_TRANSACTION_MAP, tiID, "CARGO TYPE for " &amp; tiClass, null, null);
		return;
	endif;
	
	if canLogExtra then									//10.10.2022 navma1 #52967
		// TFS 37994
		app.invLog("Transaction's IMEX =  " &amp; tiIMEX, LogTRACE.String);
	endif;

	prodGroupMap := tmpTIServiceMap.getProductGroupMap(theTI);
	if prodGroupMap &lt;&gt; null then
		productMap := prodGroupMap.getProductMap(theTI);
	endif;
	if productMap &lt;&gt; null then
		tmpIMEXServiceMap := productMap.getImexServiceMapTran(theTransaction);
	endif;
	if tmpIMEXServiceMap = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_TRANSACTION_MAP, tiID, "IMEX STATUS for " &amp; tiClass, null, null);
		return;	
	endif;	
	
	tmpContentsMap := tmpIMEXServiceMap.getContentsMapFromTransaction(theTransaction);

	if tmpContentsMap = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_TRANSACTION_MAP, tiID, "CONTENTS STATUS  for " &amp; tiClass &amp;"/"&amp; tiIMEX, null, null);
		return;
	endif;	
	
	commodityMap := tmpContentsMap.getCommodityMapTrans(theTransaction);
	if commodityMap = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_TRANSACTION_MAP, tiID, "COMMODITY  for " &amp; tiClass &amp;"/"&amp; tiIMEX &amp; "/" &amp; tmpContentsMap.contentsName &amp; "/" &amp; theTransaction.commodity, null, null);
		return;
	endif;	

	tmpServiceBroker := commodityMap.getServiceBroker(theTransaction);
	if tmpServiceBroker = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_TRANSACTION_MAP, tiID, "TRANSACTION TYPE  for " &amp; tiClass &amp;"/"&amp; tiIMEX &amp; "/" &amp; tmpContentsMap.contentsName &amp; "/" &amp; theTransaction.commodity &amp; "/" &amp; theTransaction.class.name, null, null);
		return;
	endif;	
	
	tmpServiceBroker.getInvoiceLineDesc(_aSBController);
	_aSBController.myServiceBroker := tmpServiceBroker;
	
end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceLineDescForEvent" id="49d292a4-f568-489a-853b-a90a23e8d348">
        <updating/>
        <source>getInvoiceLineDescForEvent(_aSBController : CMIF_ServiceBroker input) updating;
// 10 Oct 2022  navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
// 15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
// 18 Oct 2024 	navlw1	JIRA-33107: Invoice Logging Use Levels
vars
	sb				: CM_EventServiceBroker;
	theTransaction  : CM_EventTransaction;
	theEvent 		: CM_EventType;
	theBank 		: CM_Bank;
	theTM 			: CM_TranMapEvent;
	canLogExtra	    : Boolean;
begin
	canLogExtra	   := app.canLogExtraDetail();				//10.10.2022 navma1 #52967
	theTransaction := _aSBController.myEventTransaction;
	theEvent 	   := theTransaction.myEventType;
	
	if theEvent = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(Input_required_field_eventInv,  method.name, null, null);
		return ;
	endif;
	
	theBank := _aSBController.myBank;
	if theBank = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(Input_required_field_EvtInvBnk,   method.name, null, null); // cnwdb2	PAR 35364
		return ;
	endif;
	
	theTM := theBank.myCurrentTranMapEvent;
	if theTM = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(Input_required_field_evtInvNCT,  method.name, null, null); // cnwdb2	PAR 35364
		return ;
	endif;
	
	if canLogExtra then							//10.10.2022 navma1 #52967
		app.invLog("Event transaction map " &amp; theTM.name, LogTRACE.String);
	endif;

	sb := theTM.getServiceBroker(theTransaction);
	if sb = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_TRANSACTION_MAP, null, "SB. EVENT TRANSACTION TYPE  for '" &amp; theEvent.description &amp; "'", null, null);
		return ;
	endif;	
	
	sb.getInvoiceLineDesc(_aSBController);
	// 15/05/2023	navkc1	CR 57927 Task 54268
	_aSBController.myServiceBroker := sb;
end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceLineDescForInventory" id="5359a134-3a68-481d-9a3a-f67c457bae59">
        <source>getInvoiceLineDescForInventory(_aSBController : CMIF_ServiceBroker input);
/*
Purpose:			

Date		Who		Reason
31MAY2021	NAVAB1	TFS 51219
05 Oct 2022	navma1  Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
18 Oct 2024 navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars
	theTransaction   : CMEVT_LocationActivity;
	theTI 			 : CM_TrackedItem;
	cmifAutoPlan     : CMIF_YAInvInventoryAllocation;
	alloc 			 : CM_YardAllocation;
	tmpServiceBroker : CM_ServiceBroker;
	iter 			 : Iterator;
	canLogExtra		 : Boolean;
begin

	if self.myCurrentTranMapInventory = null then
		return;
	endif;
	
	canLogExtra	   := app.canLogExtraDetail();					//05.10.2022 navma1 #52967
	theTransaction := _aSBController.myInventoryEvent;
	if theTransaction = null then
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _aSBController.myInventoryEvent');
		return;	
	endif;

	theTI := theTransaction.myTrackedItem;
	if theTI = null then
		if canLogExtra then							//10.10.2022 navma1 #52967
			app.invLog("Inventory Event has no cargo", LogTRACE.String);
		endif;
	endif;

	if canLogExtra then							//10.10.2022 navma1 #52967
		app.invLog("Inventory invoice allocation map " &amp; self.myCurrentTranMapInventory.name, LogTRACE.String);
	endif;

	create cmifAutoPlan as CMIF_YAInvInventoryAllocation transient;
	cmifAutoPlan.attachTI(theTI);
	cmifAutoPlan.myLocationEvent := theTransaction;
	
	// These are descending - highest priority first
	foreach alloc in self.myCurrentTranMapInventory.allInvoiceAllocByPriority do
		if not alloc.CM_InvoiceInventoryAllocation.doesTIMatchMe(cmifAutoPlan, true) then
			continue;
		endif;
		if canLogExtra then							//10.10.2022 navma1 #52967
			app.invLog("Inventory invoice allocation " &amp; alloc.description &amp; " priority "&amp; alloc.priorityValue.String, LogINFO.String);
		endif;
		tmpServiceBroker := alloc.CM_InvoiceInventoryAllocation.myServiceBroker;
		tmpServiceBroker.getInvoiceLineDesc(_aSBController);
		_aSBController.myServiceBroker := tmpServiceBroker;
		return;
	endforeach;
	
	if canLogExtra then							//10.10.2022 navma1 #52967
		app.invLog("Inventory invoice allocation NO YAs FOUND", LogINFO.String);
	endif;

epilog
	delete cmifAutoPlan;
	delete iter;

end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceLineDescForTIAlloc" id="d4c418f2-9b72-4dc6-bc96-5acb8c5f01e2">
        <source>getInvoiceLineDescForTIAlloc(_aSBController : CMIF_ServiceBroker input);
/*
Purpose:			
Date		Who		Reason
24 Mar 2015	cnwab1	Initial creation
08 May 2017	cnwkpd1	TFS 4023 - EDI Ship Manifest performance issue
30 May 2017	cnwkpd1	TFS #4542 - Invoicing performance changes
30 Sep 2022 navvt20	ChangeRequest 54844: MTN - Invoice Allocation Logging
05 Oct 2022 navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
25 Jun 2024 jlier1	TFS 64775
18 Oct 2024 navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars
	theTransaction   : CM_TITransaction;
	theTI			 : CM_TrackedItem;
	cmifAutoPlan 	 : CMIF_YAInvCargoAllocation;
	alloc 			 : CM_YardAllocation;
	tmpServiceBroker : CM_ServiceBroker;
	iter 			 : Iterator;
	trxTypeKey 		 : Integer;
	priorityKey		 : Real;
	transMap		 : CM_TranMapCargoAllocation;
	canLogExtra		 : Boolean;
begin
	
	transMap	   := self.myCurrentTranMapCargoAlloc;		//05.10.2022 navma1 #52967
	
	if transMap = null then									//05.10.2022 navma1 #52967
		return;
	endif;
	
	canLogExtra	   := app.canLogExtraDetail();			    //05.10.2022 navma1 #52967
	theTransaction := _aSBController.myTransaction;
	
	if theTransaction = null then
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _aSBController.myTransaction');
		return;	
	endif;

	theTI := theTransaction.myTrackedItem;
	if theTI = null then
		if canLogExtra then							//10.10.2022 navma1 #52967
			app.invLog("Transaction has no cargo", LogTRACE.String);
		endif;
		return;
	endif;

	if canLogExtra then										//05.10.2022 navma1 #52967
		app.invLog("Cargo invoice allocation map " &amp; transMap.name, LogTRACE.String);
	endif;

	create cmifAutoPlan as CMIF_YAInvCargoAllocation transient;
	cmifAutoPlan.attachTI(theTI);
	cmifAutoPlan.myTransaction := theTransaction;
	cmifAutoPlan.myResourceTypeUsage:=_aSBController.myResourceTypeUsage; //25 Jun 2024 jlier1  TFS 64775
	if canLogExtra and _aSBController.myResourceTypeUsage &lt;&gt; null then
		app.invLog("Transaction has resource type " &amp; _aSBController.myResourceTypeUsage.displayLine, LogTRACE.String);
	endif;
	
	// TFS #4542 - Use dictionary by Transaction type and Priority
	iter := transMap.allInvoiceAllocByTranType.createIterator();									//05.10.2022 navma1 #52967
	transMap.allInvoiceAllocByTranType.startKeyGeq(theTransaction.type, Max_Integer64, iter);		//05.10.2022 navma1 #52967
	
	while iter.next(alloc) do
		iter.getCurrentKeys(trxTypeKey, priorityKey);
		if trxTypeKey &lt;&gt; theTransaction.type then
			break;
		endif;
	
		// TFS 4023 - Change call to not log all, and remove reading of allocation logging, as
		// it was not being used
		if not alloc.CM_InvoiceCargoAllocation.doesTIMatchMe(cmifAutoPlan, true) then
			continue;
		endif;
		
		if canLogExtra then		//05.10.2022 navma1 #52967
			app.invLog("Cargo invoice allocation " &amp; alloc.description, LogTRACE.String);
		endif;
		tmpServiceBroker := alloc.CM_InvoiceCargoAllocation.myServiceBroker;
		tmpServiceBroker.getInvoiceLineDesc(_aSBController);
		_aSBController.myServiceBroker := tmpServiceBroker;
		return;
	
	endwhile;

	if canLogExtra then							//10.10.2022 navma1 #52967
		// 29 Sept 2022 navvt20 TFS 54844
		app.invLog("No allocation exists - " &amp; theTransaction.typeString, LogTRACE.String);
	endif;
epilog
	delete cmifAutoPlan;
	delete iter;
end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceLineDescForVTMIS" id="a8602ce0-84d4-43bc-a85f-9e830e4162cc">
        <updating/>
        <source>getInvoiceLineDescForVTMIS(_aSBController : CMIF_ServiceBroker input; _message : String io) updating;

// 15/12/2014  cnwdb2	PAR 35364
// 10 Oct 2022 navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details\
// 18 Oct 2024 navlw1	JIRA-33107: Invoice Logging Use Levels
vars
	sb				: CM_ResourceServiceBroker;
	theTransaction  : HMS_VTMISTransaction;
	theResource 	: HMS_ResourceUsed;
	theBank 		: CM_Bank;
	theTM 			: CM_TranMapVoyage;
	canLogExtra		: Boolean;
begin
	canLogExtra		:= app.canLogExtraDetail();							//10.10.2022 navma1 #52967
	theTransaction  := _aSBController.myVTMISTransaction;
	theResource     := theTransaction.myResourceUsed;
	
	if theResource = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException(Input_required_field_vtmsIRU, null, null); // cnwdb2	PAR 35364
		return ;
	endif;
	
	theBank := _aSBController.myBank;
	if theBank = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException(Input_required_field_vtmisIBU, null, null); // cnwdb2	PAR 35364
		return ;
	endif;
	
	theTM := theBank.myCurrentTranMapVoyage;
	if theTM = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException(Input_required_field_vtmisINCT, null, null); // cnwdb2	PAR 35364
		return ;
	endif;
	if canLogExtra then							//10.10.2022 navma1 #52967
		app.invLog("Voyage transaction map " &amp; theTM.name, LogTRACE.String);
	endif;

	sb := theTM.getServiceBroker(theTransaction);
	if sb = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_TRANSACTION_MAP, null, "SB. VTMIS TRANSACTION TYPE  for '" &amp; theResource.description &amp; "'", null, null);
		return ;
	endif;	

	sb.getInvoiceLineDesc(_aSBController);
end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker" usage="input"/>
        <Parameter name="_message" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceLineDescForWO" id="1d6cf430-f10a-4bed-a42e-2108145c1280">
        <updating/>
        <source>getInvoiceLineDescForWO(_aSBController : CMIF_ServiceBroker input) updating;
/*
Purpose:	TFS 39237		
Date				Who			Reason
JUNE 2018			CNWAB1		Initial creation
10 Oct 2022			navma1  	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
15/05/2023			navkc1		CR 57927 Task 54268 - Transaction Map
18 Oct 2024 		navlw1		JIRA-33107: Invoice Logging Use Levels
*/

vars
	sb				: CM_WorkOrderServiceBroker;
	theTransaction	: CM_WOTransaction;
	theBank 		: CM_Bank;
	theTM 			: CM_TranMapWorkOrder;
	canLogExtra	    : Boolean;
begin
	canLogExtra	   := app.canLogExtraDetail();								//10.10.2022 navma1 #52967
	theTransaction := _aSBController.myTransactionWO ;
	
	theBank := _aSBController.myBank;
	if theBank = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(Input_required_field_EvtInvBnk,   method.name, null, null); 

		return ;
	endif;
	
	theTM := theBank.myCurrentTranMapWorkOrder;
	if theTM = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(Input_required_field_evtInvNCT,  method.name, null, null); 
		return ;
	endif;
	if canLogExtra then							   //10.10.2022 navma1 #52967
		app.invLog("Work Order transaction map " &amp; theTM.name, LogTRACE.String);
	endif;
	
	sb := theTM.getServiceBroker(theTransaction);
	if sb = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_TRANSACTION_MAP, null, "SB. WORK ORDER TRANSACTION TYPE  for '" &amp; theTransaction.getTranTypeString() &amp; "'", null, null);
		return ;
	endif;	
	
	sb.getInvoiceLineDesc(_aSBController);
	// 15/05/2023	navkc1	CR 57927 Task 54268
	_aSBController.myServiceBroker := sb;
end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceLineDescForXaction" id="8f7afe21-40dd-43c8-b56f-6ab2ae8c3aa1">
        <source>getInvoiceLineDescForXaction(_aSBController : CMIF_ServiceBroker input);
vars
	prodGroupMap : CM_ProductGroupMap;
	productMap : CM_ProductMap;
	tmpTIServiceMap : CM_TIServiceMap;
	tmpIMEXServiceMap : CM_ImexServiceMap;
	tmpContentsMap : CM_ContentsMap;
	commodityMap : CM_CommodityMap;
	tmpServiceBroker : CM_ServiceBroker;
	ti : CM_TrackedItem;     
	tmpInvLineDescription : CM_InvoiceLineDesc; //AKB PAR 1477
	tmpStr : String; //AKB PAR 1477
	theTransaction : CM_TITransaction;
begin

	if _aSBController = null then
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _aSBController');
		return;	
	endif;
		
	theTransaction := _aSBController.myTransaction;
	
	
	if theTransaction = null then
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _aSBController.myTransaction');
		return;	
	endif;
	
	ti := theTransaction.myTrackedItem;
	// AKB 12Mar2001 - Exception added PAR 1477
	if ti = null then
		app.setContinueCMExceptions(false);
	//	app.raiseCMException1(REQUIRED_FIELD, 'cargo item', null, null);
		app.raiseCMException(Input_required_field_cargoItem, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	tmpStr := ti.getImExStatusStringDesc(true); // get IMEX meaning PAR 1477

	tmpTIServiceMap := self.getTIServiceMap(ti);
	// AKB 12Mar2001 - Exception added PAR 1477
	if tmpTIServiceMap = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_TRANSACTION_MAP, ti.id, "CARGO TYPE for " &amp; ti.class.name, null, null);
		return;
	endif;

	prodGroupMap := tmpTIServiceMap.getProductGroupMap(ti);
	if prodGroupMap &lt;&gt; null then
		productMap := prodGroupMap.getProductMap(ti);
	endif;
	if productMap &lt;&gt; null then
		tmpIMEXServiceMap := productMap.getImexServiceMap(ti);
	endif;
	// AKB 12Mar2001 - Exception added PAR 1477
	if tmpIMEXServiceMap = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_TRANSACTION_MAP, ti.id, "IMEX STATUS for " &amp; ti.class.name, null, null);
		return;	
	endif;	
	
	// ### PAR 13113 - bodge for OTAGO. Contents status may change during actual updating, if any, of TI. 
	//							DeferredUpdates means that new contents status on TI makes invoicing wrong. 
	//							The transaction always has the old value so use that
	if app.myRoot.isClientPortOtago 
	and theTransaction.type = TRANS_TYPE_STORAGE then
		tmpContentsMap := tmpIMEXServiceMap.getContentsMapFromTransaction(theTransaction);
	
	else
		tmpContentsMap := tmpIMEXServiceMap.getContentsMap(ti);
	endif;
	// AKB 12Mar2001 - Exception added PAR 1477
	if tmpContentsMap = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_TRANSACTION_MAP, ti.id, "CONTENTS STATUS  for " &amp; ti.class.name &amp;"/"&amp; tmpStr, null, null);
		return;
	endif;	
	
	commodityMap := tmpContentsMap.getCommodityMap(ti);
	// AKB 12Mar2001 - Exception added PAR 1477
	if commodityMap = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_TRANSACTION_MAP, ti.id, "COMMODITY  for " &amp; ti.class.name &amp;"/"&amp; tmpStr &amp; "/" &amp; tmpContentsMap.contentsName &amp; "/" &amp; ti.commodity, null, null);
		return;
	endif;	

	tmpServiceBroker := commodityMap.getServiceBroker(theTransaction);
	// AKB 12Mar2001 - Exception added PAR 1477
	if tmpServiceBroker = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_TRANSACTION_MAP, ti.id, "TRANSACTION TYPE  for " &amp; ti.class.name &amp;"/"&amp; tmpStr &amp; "/" &amp; tmpContentsMap.contentsName &amp; "/" &amp; ti.commodity &amp; "/" &amp; theTransaction.class.name, null, null);
		return;
	endif;	
	
	tmpServiceBroker.getInvoiceLineDesc(_aSBController);
	_aSBController.myServiceBroker := tmpServiceBroker;
/*
	// AKB 12Mar2001 - Exception added PAR 1477
	if tmpInvLineDescription = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_TRANSACTION_MAP, ti.id, "INVOICE LINE for " &amp; ti.class.name &amp;"/"&amp; tmpStr &amp; "/" &amp; tmpContentsMap.contentsName &amp; "/" &amp; ti.commodity &amp; "/" &amp; theTransaction.class.name, null, null);
		return;
	endif;	
*/
	
end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getInvoices" id="ce5f450e-25ed-48dc-acfb-ff0cb91feff3">
        <source>getInvoices(param: CMIF_InvoiceSelection;  invoices: CM_InvoiceBySeqNumDict input);
// get all invoices which match the parameter value - debtor, invoice status, invoice type or voyage
//  if no parameters, return all invoices.
//Date				Who			Reason
//13 Sep 2022		navpw1		TFS: 54565 - EUP - Inv Config - Invoice Surcharges
//30 May  2025 navrv30 MTN 34789 MTN | Query by BOL option doesn't return results for BOL-generated invoices
vars
	iter			: Iterator;
	inv				: CM_Invoice;
	keyValue		: Any;
	keyPropertyName	: String;
	voyage			: CM_Voyage;
	term			: CM_Terminal;
	bolObj			: CM_BOL;
begin
	invoices.clear;
	
	if param = null then
		self.allInvoices.copy(invoices);
		return;
	endif;
	
	if param.companyCode &lt;&gt; null and param.companyCode &lt;&gt; code then
		return;
	endif;
	
	if param.bolNumber &lt;&gt; null then			//30 May  2025 navrv30 MTN 34789
		term := self.getMyTerminal();
		if terminal &lt;&gt; null then
			bolObj := terminal.allBOLsReceivedByTypeNumberDT.getAtKeyGeq(BOLType_GeneralBillOfLading, param.bolNumber, null);
		endif;
		if bolObj = null then
			return;
		endif;
		iter := bolObj.allInvoices.createIterator;
		keyValue := bolObj;
		keyPropertyName := "myBOL";
	// ### TFS 54565 (54384) 24Aug2022 NAVPW1
	elseif param.debtor &lt;&gt; null and param.hasinvDebtorSeparation() then
		iter := self.invoicesByDebtor.createIterator;
		keyValue := param.debtor;
		keyPropertyName := "debtor";
		self.invoicesByDebtor.startKeyGeq(param.debtor, iter);
		
	// ### TFS 54565 (54384) 24Aug2022 NAVPW1
		
	elseif param.debtor &lt;&gt; null then
		iter := self.invoicesByDebtor.createIterator;
		keyValue := param.debtor;
		keyPropertyName := "debtor";
		self.invoicesByDebtor.startKeyGeq(param.debtor, iter);
	elseif param.status &lt;&gt; CM_Invoice.INVOICE_ALL_STATUS then
		iter := self.invoicesByStatus.createIterator;
		keyValue := param.status;
		keyPropertyName := "status";
		self.invoicesByStatus.startKeyGeq(param.status, iter);
	elseif param.invoiceTypeNumber &gt; 0 then
		iter := self.invoicesByType.createIterator;
		keyValue := self.invoiceTypes[param.invoiceTypeNumber];
		keyPropertyName := "invoiceType";
		self.invoicesByType.startKeyGeq(keyValue.CM_InvoiceDesc, iter);
	// ### TFS 51219 25MAY2021 NAVAB1
	elseif param.invoiceKey = CM_InvoiceDesc.Key_VoyageGroup // invoice grouped by voyage group
	and param.voyageGroupCode &lt;&gt; null then
		iter := self.allInvoicesByVoyageGroupCode.createIterator;
		keyValue := param.voyageGroupCode;
		keyPropertyName := CM_Invoice::voyageGroupCode.name;
	elseif param.voyageCode &lt;&gt; null then
	/* WAS // ### TFS 51219 25MAY2021 NAVAB1
		foreach term in app.myRoot.allTerminals do
			voyage := term.lookupVoyage(param.voyageCode, null, true);
			
			if voyage &lt;&gt; null then
				break;
			endif;
		endforeach;
		NOW */
		term := self.getMyTerminal();
		voyage := term.lookupVoyage(param.voyageCode, null, true);
		
		if voyage = null then
			return;
		endif;
		iter := voyage.allInvoices.createIterator;
		keyValue := param.voyageCode;
		keyPropertyName := CM_Invoice::voyageCode.name;		
	else
		self.allInvoices.copy(invoices);
		return;
	endif;
	
	while iter.next(inv) do
		if inv.getPropertyValue(keyPropertyName) &lt;&gt; keyValue then
			break;
		endif;
		if inv.isMatch(param) then
			invoices.add(inv);
		endif;
	endwhile;
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="param" type="CMIF_InvoiceSelection"/>
        <Parameter name="invoices" type="CM_InvoiceBySeqNumDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getLastInvoiceForStatus" id="7dadd523-c3dc-43ba-8db2-a2ddf51b2b05">
        <source>getLastInvoiceForStatus(_param : CMIF_InvoiceSelection input) : CM_Invoice protected;
// prototype for 31890
vars

	theInvoice	: CM_Invoice;
	iter 		: Iterator;
	tmpStatus	: Integer;
begin
	tmpStatus := _param.status;
	
	iter := self.invoicesByStatus.createIterator();
	self.invoicesByStatus.startKeyLss(tmpStatus + 1, iter);
	while iter.back(theInvoice) do

		if theInvoice.status &lt;&gt; tmpStatus then
			break;
		endif;
		
		if not theInvoice.isMatch(_param) then
			continue;
		endif;
				
		return theInvoice;
	endwhile;
	
	return null;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_param" type="CMIF_InvoiceSelection" usage="input"/>
        <ReturnType type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="getMailingAddressString" id="6acd1e2c-44ca-4eaa-8516-6236abc7b794">
        <source>getMailingAddressString() : String;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aStr : String;
	idx, endIdx : Integer;
begin
	if self.mailingAddress = null then
		return null;
	endif;
	if self.mailingAddress.isEmpty then
		return null;
	endif;
	
	endIdx := self.mailingAddress.size;
	foreach idx in 1 to endIdx do
		aStr := aStr &amp; self.mailingAddress[idx] &amp; CrLf;
	endforeach;
	
	return aStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMatchingInvoice" id="54fb3cdb-a44f-48d0-b3aa-e77209944e00">
        <updating/>
        <source>getMatchingInvoice(invoiceType: CM_InvoiceDesc; _invLineType : CM_InvoiceLineDesc; tran: CM_TITransaction; debtor: CM_Debtor; _forcedStatusOpen : Boolean): CM_Invoice updating;
//
// Changed On	By			Reason
// ----------	--------	------------------------------------------------
// 16/09/2015	cnwdap1		PAR #36909 CCMS ADP 2537 New bol number parameter for invoiceType.initialiseSelectionParameter
// 30/01/2020   cnwma1		Bug 48416: ADP - Invoice lines not going to expected cash invoice
vars
	param         	   : CMIF_InvoiceSelection;
	invoices	 	   : CM_InvoiceBySeqNumDict;
	invoice,
	backupInvoice 	   : CM_Invoice;
	cashInvoice   	   : CM_Invoice;
	retInvoice    	   : CM_Invoice;
	paymentType        : Integer;
	
begin

	//09 Oct 2018	NDL	TFS 42181
	
	if debtor &lt;&gt; null then
		paymentType := debtor.getDefaultPaymentType( self.terminal );
	else
		paymentType := 0;
	endif;
	if _invLineType &lt;&gt; null and debtor &lt;&gt; null then
		paymentType := _invLineType.getPaymentType(debtor);
	endif;

	// for PELINDO we need to put the charges on the configured invoice type.
	//	if not self.isUsingPelindo1Process() then
	if self.isUsingDefaultProcessJMT() then	//23 Jul 2018	NDL	TFS 39882
		
		/*
		30.01.2020 cnwma1 #48416
		// TFS 48127 - only do this if cash is configured to have 1 cash invoice for the cargo item
		// If configured for 1 cash invoice per cash receipt do not do this.
		if not self.terminal.getConfig(CashInvoiceEveryReceipt).Boolean then
			// 33885 if a cash-only debtor and the cargo has cash payments and the payment receipt has a cash invoice, 
			// use this one to keep all the charges together
			if debtor &lt;&gt; null and
			   debtor.isCashOnlyDebtor(self.terminal) then
				if tran &lt;&gt; null and
				   tran.myTrackedItem &lt;&gt; null then
					cashInvoice := tran.myTrackedItem.getCashInvoice();
					if cashInvoice &lt;&gt; null then
						return cashInvoice;
					endif;
				endif;
			endif;
		endif;
		*/
		
		// 30.01.2020 cnwma1 #48416
		if tran &lt;&gt; null and tran.myTrackedItem &lt;&gt; null then
			cashInvoice := tran.myTrackedItem.getCashInvoiceForMode(false,self,_invLineType,debtor,tran);
			if cashInvoice &lt;&gt; null then
				return cashInvoice;
			endif;
		endif;
		
	endif;

	create invoices transient;
	
	create param transient;
	param.debtor       := debtor;
	param.paymentType  := paymentType;												// 09 Oct 2018	NDL	TFS 42181
	param.status       := invoiceType.getStatusForNewInvoice( _forcedStatusOpen );  // PAR 17895  status is either open or suspense
	param.checkManual  := true;                                                     // set options so it doesn't match manual invoices
	param.isManual     := false;
	param.companyCode  := self.code;
	invoiceType.initialiseSelectionParameter(param, tran, null, null, null, null);		// PAR #36909
	
	// get all non-manual invoices for the required status
	if debtor &lt;&gt; null then
		debtor.getOpenInvoices(invoices, param);
	else
		self.getInvoices(param, invoices);
	endif;

	//if invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then
	if invoiceType.hasDebtorSeparationAccrual(debtor) or invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then	// ### TFS 54565 (54384) 06Oct2022 NAVPW1
		foreach invoice in invoices do
			// check start and end datetime
			if invoice.coversTimeStampTransaction(tran) then
				retInvoice := invoice;
				break;
			else
				// set backup invoice to one with earliest fromDT consistent with toDT &gt;= tran.dateTime
				if backupInvoice = null then
					if (invoice.toDT.isValid and invoice.toDT &gt;= tran.dateTime) or 
						not invoice.toDT.isValid then
						backupInvoice := invoice;
					endif;
				else
					if invoice.isEarlierThan(backupInvoice) then
						backupInvoice := invoice;
					endif;
				endif;
			endif;
		endforeach;
		if retInvoice = null and backupInvoice &lt;&gt; null then
			// check the pending and posted invoices to see if there is one covering
			// this transaction datetime.
			if closedInvoiceCoveringTSExists(param, tran.dateTime) then
				retInvoice := backupInvoice;
			endif;
		endif;
	else
		// Accrual type = CM_InvoiceDesc.Accrue_Until_Manually_Closed
		// there should only be a maximum of one open at a time.
		if invoices.size &gt; 1 then
			// need an audit object here!
			retInvoice := invoices.last;
		else
			retInvoice := invoices.first;
		endif;
		if retInvoice &lt;&gt; null then
			if tran &lt;&gt; null and ( not retInvoice.fromDT.isValid or retInvoice.fromDT &gt; tran.dateTime ) then	//05 Mar 2013	NDL	Par 30901
				retInvoice.fromDT := tran.dateTime;
			endif;
		endif;
	endif;

	return retInvoice;
epilog
	delete param;
	delete invoices;
end;</source>
        <Parameter name="invoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="_invLineType" type="CM_InvoiceLineDesc"/>
        <Parameter name="tran" type="CM_TITransaction"/>
        <Parameter name="debtor" type="CM_Debtor"/>
        <Parameter name="_forcedStatusOpen" type="Boolean"/>
        <ReturnType type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="getMatchingInvoiceBOL" id="f85d92b3-df90-456c-b127-5f72d92d22d4">
        <updating/>
        <source>getMatchingInvoiceBOL(	_invoiceType		: CM_InvoiceDesc;
						_invLineType	: CM_InvoiceLineDesc;
						_tran			: CM_BOLTransaction;
						_debtor			: CM_Debtor
						) : CM_Invoice updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2019	jlgndl1	Initial creation	TFS 47100
13 September 2022	navpw1	TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges
30 May  2025 navrv30 MTN 34789 MTN | Query by BOL option doesn't return results for BOL-generated invoices
*/

vars
	param			: CMIF_InvoiceSelection;
	invoices		: CM_InvoiceBySeqNumDict;
	invoice			: CM_Invoice;
	backupInvoice	: CM_Invoice;
	retInvoice		: CM_Invoice;
	voy				: CM_Voyage;
	paymentType		: Integer;
	debtorSep 		: CM_InvTypeDebtorSeparation;
	
begin
	if _debtor &lt;&gt; null then
		paymentType := _debtor.getDefaultPaymentType( self.terminal );
	else
		paymentType := 0;
	endif;
	if _invLineType &lt;&gt; null and _debtor &lt;&gt; null then
		paymentType := _invLineType.getPaymentType(_debtor);
	endif;
	debtorSep := _invoiceType.getDebtorSeparation(_debtor);
	create param transient;
	
	param.debtor := _debtor;
	param.status := CM_Invoice.INVOICE_OPEN;
	param.checkManual := true;
	param.isManual := false;
	param.companyCode := self.code;
	voy := _tran.getMyVoyageObject();
	if voy &lt;&gt; null then
		param.voyageCode := voy.code;
	endif;
	param.invoiceTypeNumber := _invoiceType.number;	// PAR 10149
	param.myInvoiceType := _invoiceType;			// ### TFS 54565 (54384) 31Aug2022 NAVPW1
	param.paymentType := paymentType;				//17 Oct 2018	NDL	TFS 41446
	if _invoiceType.isBOLSpecificSeparation(debtorSep) then  //30 May  2025 navrv30 MTN 34789
		param.bolNumber := _tran.myBOL.number;
	endif;
	create invoices transient;
	
	self.getInvoices(param, invoices);
	
	//if _invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then
	if _invoiceType.hasDebtorSeparationAccrual(_debtor) or _invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then	// ### TFS 54565 (54384) 06Oct2022 NAVPW1
		foreach invoice in invoices do
			// check start and end datetime
			if invoice.coversTimeStamp( _tran.dateTime ) then
				retInvoice := invoice;
				break;
			else
				// set backup invoice to one with earliest fromDT consistent with toDT &gt;= tran.dateTime
				if backupInvoice = null then
					if (invoice.toDT.isValid and invoice.toDT &gt;= _tran.dateTime) or 
						not invoice.toDT.isValid then
						backupInvoice := invoice;
					endif;
				else
					if invoice.isEarlierThan(backupInvoice) then
						backupInvoice := invoice;
					endif;
				endif;
			endif;
		endforeach;
		if retInvoice = null and backupInvoice &lt;&gt; null then
			// check the pending and posted invoices to see if there is one covering
			// this transaction datetime.
			if closedInvoiceCoveringTSExists(param, _tran.dateTime) then
				retInvoice := backupInvoice;
			endif;
		endif;
	else
		// Accrual type = CM_InvoiceDesc.Accrue_Until_Manually_Closed
		// there should only be a maximum of one open at a time.
		if invoices.size &gt; 1 then
			// need an audit object here!
			retInvoice := invoices.last;
		else
			retInvoice := invoices.first;
		endif;
		if retInvoice &lt;&gt; null then
			if not retInvoice.fromDT.isValid or retInvoice.fromDT &gt; _tran.dateTime then
				retInvoice.fromDT := _tran.dateTime;
			endif;
		endif;
	endif;
	
	return retInvoice;
	
epilog
	delete param;
	delete invoices;
	
end;</source>
        <Parameter name="_invoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="_invLineType" type="CM_InvoiceLineDesc"/>
        <Parameter name="_tran" type="CM_BOLTransaction"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <ReturnType type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="getMatchingInvoiceEvent" id="630dbe0a-9859-4ca5-aa0e-0d6a0a75aa31">
        <updating/>
        <source>getMatchingInvoiceEvent(_invoiceType: CM_InvoiceDesc; _invLineType : CM_InvoiceLineDesc; _tran: CM_EventTransaction; _debtor: CM_Debtor): CM_Invoice updating;
/*
Purpose:	TFS 39237		
Date				Who			Reason
JUNE 2018			CNWAB1		Initial creation
13 September 2022	navpw1		TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges
*/

vars
	param			: CMIF_InvoiceSelection;
	invoices		: CM_InvoiceBySeqNumDict;
	invoice			: CM_Invoice;
	backupInvoice	: CM_Invoice;
	retInvoice		: CM_Invoice;
	voy				: CM_Voyage;
	paymentType		: Integer;	//17 Oct 2018	NDL	TFS 41446
	
begin
	//17 Oct 2018	NDL	TFS 41446
	if _tran.isVoyageEvent and _tran.CMEVT_VoyageEvent.getVoyage &lt;&gt; null then
		paymentType := _tran.CMEVT_VoyageEvent.getVoyage.paymentType;
	else
		if _debtor &lt;&gt; null then
			paymentType := _debtor.getDefaultPaymentType( self.terminal );
		else
			paymentType := 0;
		endif;
		if _invLineType &lt;&gt; null and _debtor &lt;&gt; null then
			paymentType := _invLineType.getPaymentType(_debtor);
		endif;
	endif;
	
	create param transient;
	
	param.debtor := _debtor;
	param.status := CM_Invoice.INVOICE_OPEN;
	param.checkManual := true;
	param.isManual := false;
	param.companyCode := self.code;
	voy := _tran.getVoyage();
	if voy &lt;&gt; null then
		param.voyageCode := voy.code;
	endif;
	param.invoiceTypeNumber := _invoiceType.number;	// PAR 10149
	param.myInvoiceType := _invoiceType; 			// ### TFS 54565 (54384) 31Aug2022 NAVPW1
	param.paymentType := paymentType;				//17 Oct 2018	NDL	TFS 41446
	
	param.voyageGroupCode := _tran.getVoyageGroupCode(); // ### TFS 51219 28MAY2021 NAVAB1
	param.invoiceKey := _invoiceType.invoiceKey; // ### TFS 51219 28MAY2021 NAVAB1
	
	create invoices transient;
	
	self.getInvoices(param, invoices);
	
	//if _invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then
	if _invoiceType.hasDebtorSeparationAccrual(_debtor) or _invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then	// ### TFS 54565 (54384) 06Oct2022 NAVPW1
		foreach invoice in invoices do
			// check start and end datetime
			if invoice.coversTimeStampEvent(_tran) then
				retInvoice := invoice;
				break;
			else
				// set backup invoice to one with earliest fromDT consistent with toDT &gt;= tran.dateTime
				if backupInvoice = null then
					if (invoice.toDT.isValid and invoice.toDT &gt;= _tran.dateTime) or 
						not invoice.toDT.isValid then
						backupInvoice := invoice;
					endif;
				else
					if invoice.isEarlierThan(backupInvoice) then
						backupInvoice := invoice;
					endif;
				endif;
			endif;
		endforeach;
		if retInvoice = null and backupInvoice &lt;&gt; null then
			// check the pending and posted invoices to see if there is one covering
			// this transaction datetime.
			if closedInvoiceCoveringTSExists(param, _tran.dateTime) then
				retInvoice := backupInvoice;
			endif;
		endif;
	else
		// Accrual type = CM_InvoiceDesc.Accrue_Until_Manually_Closed
		// there should only be a maximum of one open at a time.
		if invoices.size &gt; 1 then
			// need an audit object here!
			retInvoice := invoices.last;
		else
			retInvoice := invoices.first;
		endif;
		if retInvoice &lt;&gt; null then
			if not retInvoice.fromDT.isValid or retInvoice.fromDT &gt; _tran.dateTime then
				retInvoice.fromDT := _tran.dateTime;
			endif;
		endif;
	endif;
	
	return retInvoice;
	
epilog
	delete param;
	delete invoices;
	
end;</source>
        <Parameter name="_invoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="_invLineType" type="CM_InvoiceLineDesc"/>
        <Parameter name="_tran" type="CM_EventTransaction"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <ReturnType type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="getMatchingInvoiceSnapshot" id="4840af9a-18c0-4604-82c0-b0da18779a56">
        <updating/>
        <source>getMatchingInvoiceSnapshot(invoiceType: CM_InvoiceDesc; _invLineType : CM_InvoiceLineDesc; _dateTime : TimeStamp; debtor: CM_Debtor; _forcedStatusOpen : Boolean): CM_Invoice updating;
// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
//
// Changed On	By			Reason
// ----------	--------	------------------------------------------------
// 16/09/2015	cnwdap1		PAR #36909 CCMS ADP 2537 New bol number parameter for invoiceType.initialiseSelectionParameter
vars
	param:          CMIF_InvoiceSelection;
	invoices:       CM_InvoiceBySeqNumDict;
	tmpInvoices:    CM_InvoiceBySeqNumDict;
	invoice:        CM_Invoice;
	backupInvoice:  CM_Invoice;
	retInvoice:     CM_Invoice;
	paymentType : Integer; //17 Oct 2018	NDL	TFS 41446
begin

	//17 Oct 2018	NDL	TFS 41446
	if debtor &lt;&gt; null then
		paymentType := debtor.getDefaultPaymentType( self.terminal );
	else
		paymentType := 0;
	endif;
	if _invLineType &lt;&gt; null and debtor &lt;&gt; null then
		paymentType := _invLineType.getPaymentType(debtor);
	endif;
	
	
	create invoices transient;
	
	create param transient;
	param.debtor := debtor;
	param.status := invoiceType.getStatusForNewInvoice( _forcedStatusOpen );
	
	param.checkManual := true;
	param.isManual := false;
	param.companyCode := self.code;
	//invoiceType.initialiseSelectionParameter(param, null, false, null, null);			//PAR #36909
	invoiceType.initialiseSelectionParameter(param, null, false, null, null, null);		//PAR #36909
	
	param.paymentType := paymentType;	//17 Oct 2018	NDL	TFS 41446
	
	if debtor &lt;&gt; null then
		debtor.getOpenInvoices(invoices, param);
	else
		getInvoices(param, invoices);
	endif;

	//if invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then
	if invoiceType.hasDebtorSeparationAccrual(debtor) or invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then	// ### TFS 54565 (54384) 06Oct2022 NAVPW1
		foreach invoice in invoices do
			// check start and end datetime
			if invoice.coversTimeStamp(_dateTime) then
				retInvoice := invoice;
				break;
			else
				// set backup invoice to one with earliest fromDT consistent with toDT &gt;= tran.dateTime
				if backupInvoice = null then
					if (invoice.toDT.isValid and invoice.toDT &gt;= _dateTime) or 
						not invoice.toDT.isValid then
						backupInvoice := invoice;
					endif;
				else
					if invoice.isEarlierThan(backupInvoice) then
						backupInvoice := invoice;
					endif;
				endif;
			endif;
		endforeach;
		if retInvoice = null and backupInvoice &lt;&gt; null then
			// check the pending and posted invoices to see if there is one covering
			// this transaction datetime.
			if closedInvoiceCoveringTSExists(param, _dateTime) then
				retInvoice := backupInvoice;
			endif;
		endif;
	else
		// Accrual type = CM_InvoiceDesc.Accrue_Until_Manually_Closed
		// there should only be a maximum of one open at a time.
		if invoices.size &gt; 1 then
			// need an audit object here!
			retInvoice := invoices.last;
		else
			retInvoice := invoices.first;
		endif;
		if retInvoice &lt;&gt; null then
			if not retInvoice.fromDT.isValid or retInvoice.fromDT &gt; _dateTime then
				retInvoice.fromDT := _dateTime;
			endif;
		endif;
	endif;

	return retInvoice;
epilog
	delete param;
	delete invoices;
end;</source>
        <Parameter name="invoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="_invLineType" type="CM_InvoiceLineDesc"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="debtor" type="CM_Debtor"/>
        <Parameter name="_forcedStatusOpen" type="Boolean"/>
        <ReturnType type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="getMatchingInvoiceVTMIS" id="2671c030-8510-42fb-bed5-cbea4794ad78">
        <updating/>
        <source>getMatchingInvoiceVTMIS(_invoiceType: CM_InvoiceDesc; _invLineType : CM_InvoiceLineDesc; _tran: HMS_VTMISTransaction; _debtor: CM_Debtor): CM_Invoice updating;
/*
Purpose:			
Date				Who			Reason
13 May 2005			CNWAB1		Initial creation
13 September 2022	navpw1		TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges
*/

vars
	param			: CMIF_InvoiceSelection;
	invoices		: CM_InvoiceBySeqNumDict;
	invoice			: CM_Invoice;
	backupInvoice	: CM_Invoice;
	retInvoice		: CM_Invoice;
	
begin
	create param transient;
	
	param.debtor := _debtor;
	param.status := CM_Invoice.INVOICE_OPEN;
	param.checkManual := true;
	param.isManual := false;
	param.companyCode := self.code;
	// 34744 for monthly invoices don't filter by voyage
	if not _invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then
		param.voyageCode := _tran.myVoyage.code;
	endif;
	param.invoiceTypeNumber := _invoiceType.number;	// PAR 10149
	param.myInvoiceType := _invoiceType;			// ### TFS 54565 (54384) 31Aug2022 NAVPW1
	
	//09 Oct 2018	NDL	TFS 42181
	if _tran.myVoyage &lt;&gt; null then
		param.paymentType := _tran.myVoyage.paymentType;	
	endif;
	
	create invoices transient;
	
	self.getInvoices(param, invoices);
	
	//if _invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then
	if _invoiceType.hasDebtorSeparationAccrual(_debtor) or _invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then	// ### TFS 54565 (54384) 06Oct2022 NAVPW1
		foreach invoice in invoices do
			// check start and end datetime
			if invoice.coversTimeStampVTMIS(_tran) then
				retInvoice := invoice;
				break;
			else
				// set backup invoice to one with earliest fromDT consistent with toDT &gt;= tran.dateTime
				if backupInvoice = null then
					if (invoice.toDT.isValid and invoice.toDT &gt;= _tran.transactionDT) or 
						not invoice.toDT.isValid then
						backupInvoice := invoice;
					endif;
				else
					if invoice.isEarlierThan(backupInvoice) then
						backupInvoice := invoice;
					endif;
				endif;
			endif;
		endforeach;
		if retInvoice = null and backupInvoice &lt;&gt; null then
			// check the pending and posted invoices to see if there is one covering
			// this transaction datetime.
			if self.closedInvoiceCoveringTSExists(param, _tran.transactionDT) then
				retInvoice := backupInvoice;
			endif;
		endif;
	else
		// Accrual type = CM_InvoiceDesc.Accrue_Until_Manually_Closed
		// there should only be a maximum of one open at a time.
		if invoices.size &gt; 1 then
			// need an audit object here!
			retInvoice := invoices.last;
		else
			retInvoice := invoices.first;
		endif;
		if retInvoice &lt;&gt; null then
			if not retInvoice.fromDT.isValid or retInvoice.fromDT &gt; _tran.transactionDT then
				retInvoice.fromDT := _tran.transactionDT;
			endif;
		endif;
	endif;
	
	return retInvoice;
	
epilog
	delete param;
	delete invoices;
	
end;</source>
        <Parameter name="_invoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="_invLineType" type="CM_InvoiceLineDesc"/>
        <Parameter name="_tran" type="HMS_VTMISTransaction"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <ReturnType type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="getMatchingInvoiceWO" id="e2afcf5b-e6c5-4a0e-88de-df3e786c93f2">
        <updating/>
        <source>getMatchingInvoiceWO(_invoiceType: CM_InvoiceDesc; _invLineType : CM_InvoiceLineDesc; _tran: CM_WOTransaction; _debtor: CM_Debtor): CM_Invoice updating;
/*
Purpose:	TFS 39237		
Date				Who			Reason
JUNE 2018			CNWAB1		Initial creation
13 September 2022	navpw1		TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges
*/

vars
	param			: CMIF_InvoiceSelection;
	invoices		: CM_InvoiceBySeqNumDict;
	invoice			: CM_Invoice;
	backupInvoice	: CM_Invoice;
	retInvoice		: CM_Invoice;
	voy				: CM_Voyage;
	wo				: CM_WorkOrder;
	paymentType		: Integer;	//17 Oct 2018	NDL	TFS 41446
	
begin
	// TFS 39518
	wo := _tran.myWorkOrder;
	if wo &lt;&gt; null 
	and not wo.allInvoices.isEmpty() then
		retInvoice := wo.allInvoices.first;
		if retInvoice.status = CM_Invoice.INVOICE_OPEN then
			return retInvoice;
		endif;
	endif;
	
	//17 Oct 2018	NDL	TFS 41446
	if wo &lt;&gt; null and wo.isVoyageWorkOrder and wo.CM_WorkOrderVoyage.getMyVoyageObject &lt;&gt; null then
		paymentType := wo.CM_WorkOrderVoyage.getMyVoyageObject.paymentType;
	else
		if _debtor &lt;&gt; null then
			paymentType := _debtor.getDefaultPaymentType( self.terminal );
		else
			paymentType := 0;
		endif;
		if _invLineType &lt;&gt; null and _debtor &lt;&gt; null then
			paymentType := _invLineType.getPaymentType(_debtor);
		endif;
	endif;
	
	create param transient;
	
	param.debtor := _debtor;
	param.status := CM_Invoice.INVOICE_OPEN;
	param.checkManual := true;
	param.isManual := false;
	param.companyCode := self.code;
	voy := _tran.getMyVoyageObject();
	if voy &lt;&gt; null then
		param.voyageCode := voy.code;
	endif;
	param.invoiceTypeNumber := _invoiceType.number;	// PAR 10149
	param.myInvoiceType := _invoiceType;			// ### TFS 54565 (54384) 31Aug2022 NAVPW1
	param.paymentType := paymentType;				//17 Oct 2018	NDL	TFS 41446
	
	create invoices transient;
	
	self.getInvoices(param, invoices);
	
	//if _invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then
	if _invoiceType.hasDebtorSeparationAccrual(_debtor) or _invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then	// ### TFS 54565 (54384) 06Oct2022 NAVPW1
		foreach invoice in invoices do
			// TFS 39518 one invoice per work order
			if invoice.myWorkOrder &lt;&gt; null 
			and invoice.myWorkOrder &lt;&gt; wo then
				continue;
			endif;
			// check start and end datetime
			if invoice.coversTimeStampWO(_tran) then
				retInvoice := invoice;
				break;
			else
				// set backup invoice to one with earliest fromDT consistent with toDT &gt;= tran.dateTime
				if backupInvoice = null then
					if (invoice.toDT.isValid and invoice.toDT &gt;= _tran.dateTime) or 
						not invoice.toDT.isValid then
						backupInvoice := invoice;
					endif;
				else
					if invoice.isEarlierThan(backupInvoice) then
						backupInvoice := invoice;
					endif;
				endif;
			endif;
		endforeach;
		if retInvoice = null and backupInvoice &lt;&gt; null then
			// check the pending and posted invoices to see if there is one covering
			// this transaction datetime.
			if closedInvoiceCoveringTSExists(param, _tran.dateTime) then
				retInvoice := backupInvoice;
			endif;
		endif;
	else
		// Accrual type = CM_InvoiceDesc.Accrue_Until_Manually_Closed
		// there should only be a maximum of one open at a time.
		if invoices.size &gt; 1 then
			// need an audit object here!
			retInvoice := invoices.last;
		else
			retInvoice := invoices.first;
		endif;
		if retInvoice &lt;&gt; null then
			if not retInvoice.fromDT.isValid or retInvoice.fromDT &gt; _tran.dateTime then
				retInvoice.fromDT := _tran.dateTime;
			endif;
		endif;
	endif;
	
	return retInvoice;
	
epilog
	delete param;
	delete invoices;
	
end;</source>
        <Parameter name="_invoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="_invLineType" type="CM_InvoiceLineDesc"/>
        <Parameter name="_tran" type="CM_WOTransaction"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <ReturnType type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="getMatchingInvoiceX" id="2e469960-180f-4bcd-9abc-2e2d160227d0">
        <updating/>
        <source>getMatchingInvoiceX(invoiceType: CM_InvoiceDesc; tran: CM_TITransaction; debtor: CM_Debtor; _forcedStatusOpen : Boolean): CM_Invoice updating;
// copy of getMatchingInvoice without any updating code, for 31890 as the 'old' code for comparison
//
// Changed On	By			Reason
// ----------	--------	------------------------------------------------
// 16/09/2015	cnwdap1		PAR #36909 CCMS ADP 2537 New bol number parameter for invoiceType.initialiseSelectionParameter
vars
	param:          CMIF_InvoiceSelection;
	invoices:       CM_InvoiceBySeqNumDict;
	tmpInvoices:    CM_InvoiceBySeqNumDict;
	invoice:        CM_Invoice;
	backupInvoice:  CM_Invoice;
	retInvoice:     CM_Invoice;
begin

	// DVB changed to use debtor collection instead of bank
	// Par 11096
	create invoices transient;
	
	create param transient;
	param.debtor := debtor;
//	param.status := CM_Invoice.INVOICE_OPEN;
	param.status := invoiceType.getStatusForNewInvoice( _forcedStatusOpen ); // PAR 17895
	
	param.checkManual := true;
	param.isManual := false;
	param.companyCode := self.code;
	//invoiceType.initialiseSelectionParameter(param, tran, null, null, null);			// PAR #36909
	invoiceType.initialiseSelectionParameter(param, tran, null, null, null, null);		// PAR #36909
	
	if debtor &lt;&gt; null then
		debtor.getOpenInvoices(invoices, param);
	else
		self.getInvoices(param, invoices);
	endif;

	if invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then
		foreach invoice in invoices do
			// check start and end datetime
			if invoice.coversTimeStampTransaction(tran) then
				retInvoice := invoice;
				break;
			else
				// set backup invoice to one with earliest fromDT consistent with toDT &gt;= tran.dateTime
				if backupInvoice = null then
					if (invoice.toDT.isValid and invoice.toDT &gt;= tran.dateTime) or 
						not invoice.toDT.isValid then
						backupInvoice := invoice;
					endif;
				else
					if invoice.isEarlierThan(backupInvoice) then
						backupInvoice := invoice;
					endif;
				endif;
			endif;
		endforeach;
		if retInvoice = null and backupInvoice &lt;&gt; null then
			// check the pending and posted invoices to see if there is one covering
			// this transaction datetime.
			if closedInvoiceCoveringTSExists(param, tran.dateTime) then
				retInvoice := backupInvoice;
			endif;
		endif;
	else
		// Accrual type = CM_InvoiceDesc.Accrue_Until_Manually_Closed
		// there should only be a maximum of one open at a time.
		if invoices.size &gt; 1 then
			// need an audit object here!
			retInvoice := invoices.last;
		else
			retInvoice := invoices.first;
		endif;
	endif;

	return retInvoice;
epilog
	delete param;
	delete invoices;
end;</source>
        <Parameter name="invoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="tran" type="CM_TITransaction"/>
        <Parameter name="debtor" type="CM_Debtor"/>
        <Parameter name="_forcedStatusOpen" type="Boolean"/>
        <ReturnType type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="getMatchingInvoiceY" id="5e9769a9-49d1-4909-aece-a1d551ba6afc">
        <updating/>
        <source>getMatchingInvoiceY(invoiceType: CM_InvoiceDesc; tran: CM_TITransaction; debtor: CM_Debtor; _forcedStatusOpen : Boolean): CM_Invoice updating;
// copy of getMatchingInvoice for 31890 to test proprosed new code
//
// Changed On	By			Reason
// ----------	--------	------------------------------------------------
// 16/09/2015	cnwdap1		PAR #36909 CCMS ADP 2537 New bol number parameter for invoiceType.initialiseSelectionParameter
vars
	param:          CMIF_InvoiceSelection;
	invoices:       CM_InvoiceBySeqNumDict;
	invoice:        CM_Invoice;
	backupInvoice:  CM_Invoice;
	retInvoice:     CM_Invoice;
begin

	create invoices transient;
	
	create param transient;
	param.debtor := debtor;
	param.status := invoiceType.getStatusForNewInvoice( _forcedStatusOpen );
	
	param.checkManual := true;
	param.isManual := false;
	param.companyCode := self.code;
	//invoiceType.initialiseSelectionParameter(param, tran, null, null, null);			// PAR #36909
	invoiceType.initialiseSelectionParameter(param, tran, null, null, null, null);		// PAR #36909
	
	if invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then
		if debtor &lt;&gt; null then
			debtor.getOpenInvoices(invoices, param);
		else
			self.getInvoices(param, invoices);
		endif;
		foreach invoice in invoices do
			// check start and end datetime
			if invoice.coversTimeStampTransaction(tran) then
				retInvoice := invoice;
				break;
			else
				// set backup invoice to one with earliest fromDT consistent with toDT &gt;= tran.dateTime
				if backupInvoice = null then
					if (invoice.toDT.isValid and invoice.toDT &gt;= tran.dateTime) or 
						not invoice.toDT.isValid then
						backupInvoice := invoice;
					endif;
				else
					if invoice.isEarlierThan(backupInvoice) then
						backupInvoice := invoice;
					endif;
				endif;
			endif;
		endforeach;
		if retInvoice = null and backupInvoice &lt;&gt; null then
			// check the pending and posted invoices to see if there is one covering
			// this transaction datetime.
			if closedInvoiceCoveringTSExists(param, tran.dateTime) then
				retInvoice := backupInvoice;
			endif;
		endif;
	else
		// Accrual type = CM_InvoiceDesc.Accrue_Until_Manually_Closed
		// there should only be a maximum of one open at a time.
		// NEW CODE
		if debtor &lt;&gt; null then
			retInvoice := debtor.getLastInvoiceForStatus(param);
		else
			retInvoice := self.getLastInvoiceForStatus(param);
		endif;
	endif;

	return retInvoice;
epilog
	delete param;
	delete invoices;
end;</source>
        <Parameter name="invoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="tran" type="CM_TITransaction"/>
        <Parameter name="debtor" type="CM_Debtor"/>
        <Parameter name="_forcedStatusOpen" type="Boolean"/>
        <ReturnType type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="getMsgString" id="6c12b091-e4c3-4f9b-8dda-feb56d8f42b3">
        <source>getMsgString(errNo : Integer; sub1:String; sub2: String; append :String) : String;

begin
	if sub1 = null then
		return app.getErrorString(errNo);
	elseif sub1 &lt;&gt; null and sub2 = null then
		return app.getErrorString1(errNo, sub1);
	elseif sub1 &lt;&gt; null and sub2 &lt;&gt; null then
		return app.getErrorString2(errNo, sub1, sub2);
	else
		return null;
	endif;
end;</source>
        <Parameter name="errNo" type="Integer"/>
        <Parameter name="sub1" type="String"/>
        <Parameter name="sub2" type="String"/>
        <Parameter name="append" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyAutoIdGenerator" id="8028cc67-ebff-4a5f-b3a6-d079152815a1">
        <source>getMyAutoIdGenerator(_class : Class) : CM_AutoIdGenerator;
/*

Purpose:			
		This method returns the Auto ID Generator based on the Class 
Parameters:			

Return Value:		

Date				Who		Reason
30 December 2022	navkc1	Initial creation TFS CR 55300 TASK 55526
11 September 2024	jlizm1	Initial creation TFS 65953 NSW Dynamics Integration - Auto Generate ID

*/

vars
	keyType		: Integer;
	
begin
	
	if _class = CM_AutoInvoiceExtNumberGen then
		keyType := CM_AutoIdGenerator.InvExtNumberType;
	elseif _class = CM_AutoCreditExtNumberGen then
		keyType := CM_AutoIdGenerator.CrdExtNumberType;
	elseif _class = CM_AutoIdCrdInvExtNumberGen then
		keyType := CM_AutoIdGenerator.CrdInvExtNumberType;
	endif;
	
	return self.allAutoIdGenerators[keyType];
	
epilog

end;</source>
