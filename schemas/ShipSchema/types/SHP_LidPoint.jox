    <JadeMethod name="amPrinting" id="01a3326e-e9e8-4a65-9fc9-6737293cd705">
        <source>amPrinting() : Boolean;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
//	return self.myGridArea.mySDF.amPrinting;
	return self.myGridArea.SHP_BayArea.amPrinting();

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawSelf" id="263095c9-19f1-4144-b7e6-aba2f781b8c6">
        <updating/>
        <source>drawSelf(pFrame: CMUI_GridAreaFrame input) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theX1, theX2, theY1, theY2 : Integer;
	aRow : CMUI_GridRow;
	isLastRowHL : Boolean;
begin
	if self.cellODStart &lt;&gt; null then
		if self.startsMidCell then
			theX1 := self.cellODStart.x1.Integer + ((self.cellODStart.x2.Integer - self.cellODStart.x1.Integer) / 2).Integer;
		else
			theX1 := self.cellODStart.x1.Integer;
		endif;
	else
		theX1 := self.x1.Integer;	
	endif;

	if self.cellODEnd &lt;&gt; null then
		if self.endsMidCell then
			theX2 := self.cellODEnd.x1.Integer + ((self.cellODEnd.x2.Integer - self.cellODEnd.x1.Integer) / 2).Integer;
		else
			theX2 := self.cellODEnd.x2.Integer;
		endif;
	else
		theX2 := self.x2.Integer;	
	endif;

	theY1 := self.y1.Integer;
	if self.amPrinting then
		theY2 := theY1 + 5;
	else
		theY2 := self.y2.Integer;
	endif;
/*
	if self.myGridArea.scaleXFactor = 1.5 then	
		theY1 := self.y1.Integer + 15;
		theY2 := self.y1.Integer + 25;
	else
		theY1 := self.y1.Integer + 10;
		theY2 := self.y1.Integer + 20;
	endif;
*/	
	if self.myGridArea.allSelectedPoints.includes(self) then
		if self.myGridArea.SHP_BayArea.myForm &lt;&gt; null and self.myHatchLid &lt;&gt; null then
			if self.myGridArea.SHP_BayArea.myForm.class.getMethod("doBuildComboTableBays") &lt;&gt; null then
				self.myGridArea.SHP_BayArea.myForm.sendMsgWithParams("doBuildComboTableBays",self.myHatchLid.allBays);
			endif;
		endif;
		pFrame.drawFillColor := Yellow;
	else
		pFrame.drawFillColor := White;
	endif;
	pFrame.drawFilledRectangle(theX1, theY1, theX2, theY2,Black);


	if self.endsMidCell then
		pFrame.drawFillColor := Red;
		pFrame.drawFilledRectangle(theX2 - 5, theY1, theX2, theY2,Red);
	endif;
	if self.startsMidCell then
		pFrame.drawFillColor := Red;
		pFrame.drawFilledRectangle(theX1, theY1, theX1 + 5, theY2,Red);
	endif;
end;</source>
        <Parameter name="pFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoForPoint" id="8f8be2ae-6ced-4b4e-8995-3e6914639167">
        <source>getExtraInfoForPoint(x: Real; y: Real; _dataContainer : CM_DataContainer) : Object;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 June 2003 sgp			Use CM_DataContainer to hold data
// ---------------------------------------------------------------------------
vars
	block : CM_DataContainerBlock;

begin
	if self.myHatchLid &lt;&gt; null then
		self.myHatchLid.getExtraInfo(_dataContainer);
	endif;
	if app.isDevelopmentSystem then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Lid Point", DC_Label, 1, self);
		block.addNewItem(self.String, DC_Data, 1, self);
	endif;
	
	return self.myHatchLid;
end;

/*getExtraInfo(x: Real; y: Real; _theStringArray: HugeStringArray input; _theObjectArray: ObjectArray input) : Object;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theTI	: CM_TrackedItem;
	rtnStr	: StringArray;
	tmpYPos	: Real;
	numTIs,
	idx		: Integer;
	aString : String;
begin
	if self.myHatchLid &lt;&gt; null then
		self.myHatchLid.getExtraInfo(_theStringArray,_theObjectArray );
	endif;
	return self.myHatchLid;
end;
*/</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="306fa962-4006-44f0-bb56-ecf8f11b2d97">
        <updating/>
        <source>setForCreate( _col,_row : Integer; _bayArea : SHP_BayArea;
				_odStart, _odEnd,_udStart, _udEnd :SHP_BayColumn;
				_startsMid, _endMid : Boolean; _theLid : CM_HatchLid;_theBayColumn : CMUI_GridColumn) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	 
	 self.startsMidCell := _startsMid;
	self.endsMidCell :=  _endMid;
	self.cellODStart :=_odStart;
	self.cellODEnd := _odEnd;
	self.cellUDStart := _udStart;
	self.cellUDEnd := _udEnd;
	
	self.myHatchLid := _theLid;
	self.myLocationsController := null;
	self.setForCreateSuperClass(_bayArea, _row, _col);

end;</source>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_bayArea" type="SHP_BayArea"/>
        <Parameter name="_odStart" type="SHP_BayColumn"/>
        <Parameter name="_odEnd" type="SHP_BayColumn"/>
        <Parameter name="_udStart" type="SHP_BayColumn"/>
        <Parameter name="_udEnd" type="SHP_BayColumn"/>
        <Parameter name="_startsMid" type="Boolean"/>
        <Parameter name="_endMid" type="Boolean"/>
        <Parameter name="_theLid" type="CM_HatchLid"/>
        <Parameter name="_theBayColumn" type="CMUI_GridColumn"/>
    </JadeMethod>
