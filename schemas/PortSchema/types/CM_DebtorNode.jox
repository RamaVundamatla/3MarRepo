    <JadeMethod name="getChildren" id="0b046f6c-9a65-4699-9de7-1bdcc0b75adf">
        <source>getChildren(_children : CM_DebtorNodeByNameDict input; _level : Integer io);
// ---------------------------------------------------------------------------
// Created:     July 2009 by cnwjre1
//
// Purpose:     Par 24052, get all child debtors and groups
// ---------------------------------------------------------------------------
vars
	dn	: CM_DebtorNode;
begin
	if _level &gt; 1 then
		_children.add(self);
	endif;
	foreach dn in self.allChildDebtorNodes do
		_level := _level + 1;
		dn.getChildren(_children, _level);
	endforeach;

end;</source>
        <Parameter name="_children" type="CM_DebtorNodeByNameDict" usage="input"/>
        <Parameter name="_level" type="Integer" usage="io"/>
    </JadeMethod>
