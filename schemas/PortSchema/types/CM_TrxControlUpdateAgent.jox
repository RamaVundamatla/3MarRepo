    <JadeMethod name="trxIncrementInvoicesExported" id="bdfac5ba-6e6e-4595-8621-4116e76e690b">
        <updating/>
        <source>trxIncrementInvoicesExported(_invoices : CM_InvoiceSet input;_ignoreVoided : Boolean  ;_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2022	jlier1	Initial creation 53286

*/

vars
	invoice : CM_Invoice;
begin
	// Always initialize the activity first.
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers.
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction.
	beginTransaction;
	
	foreach invoice in _invoices discreteLock do
		
		app.myUtilityUA.utlIncrementInvoiceExportCount(invoice,_ignoreVoided, _passport);
	endforeach;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_invoices" type="CM_InvoiceSet" usage="input"/>
        <Parameter name="_ignoreVoided" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
