	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), "Merged OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 5, "Merged OnsiteTi1 should have 5 invoice line");
	invLine := onsiteTi1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, "Merged OnsiteTi1 has no first invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  LineName, "Merged OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = 230.4, "Merged OnsiteTi1 has wrong invoice line total - 2.2SA is " &amp; invLine.lineTotal.String);
	
	invLine := onsiteTi1.invoiceLines.last;
	self.assertTrueMsg(invLine &lt;&gt; null, "Merged OnsiteTi1 has no last invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  LineName3, "Merged OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = 50.0, "Merged OnsiteTi1 has wrong invoice line total - 2.3DDSA is " &amp; invLine.lineTotal.String);
	
	
	

	self.assertTrueMsg(onsiteTi1.allCashPayments.isNotEmpty(), "Merged OnsiteTi1 should have cash payments");
	self.assertTrueMsg(onsiteTi1.allCashPayments.size = 12, "Merged OnsiteTi1 should have 12 cash payments");
	cashPay := onsiteTi1.allCashPayments.first;
	self.assertTrueMsg(cashPay &lt;&gt; null, "Merged OnsiteTi1 has nocashPay");
	self.assertTrueMsg(cashPay.cashValue = 230.4, "Merged OnsiteTi1 has wrong cash value - 2.2SABB is " &amp; cashPay.cashValue.String);
	self.assertTrueMsg(cashPay.myInvoiceLine &lt;&gt; null, "Merged OnsiteTi1 has no invoice line - 2.2SABB" );
	self.assertTrueMsg(cashReceipt1 &lt;&gt; null, "Merged OnsiteTi1 has no cashReceipt1");
	self.assertTrueMsg(cashReceipt1.cashValue = 660.800000, "Merged OnsiteTi1 has wrong cash value - 2.2SACC is " &amp; cashReceipt1.cashValue.String);
	
	
	idx := 1;
	foreach cashPay in cashReceipt1.allCashPayments discreteLock do
		if idx.isOneOf(1,2,4,5,6,7,8,9,10,11, 12) then // SHIP RECEIVE and  TO DO TASK
			if idx.isOneOf(1) then // SHIP RECEIVE
				self.assertTrueMsg(cashPay.myInvoiceLine &lt;&gt; null, idx.String &amp; " Cash Pay has no invoice line");
				self.assertTrueMsg(cashPay.myInvoiceLine.totalAmount = cashPay.cashValue, "cash payment value &lt;&gt; invoice line");
				self.assertTrueMsg(cashPay.myInvoiceLine.invoiceLineDesc = invLineType1 ,  idx.String &amp; " line type sbe invLineType1");
