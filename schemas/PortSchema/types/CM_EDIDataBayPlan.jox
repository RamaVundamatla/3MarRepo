    <JadeMethod name="isFortyBackEnd" id="06d2da26-7240-4812-b1b9-75689b76042e">
        <source>isFortyBackEnd(_ti:CM_TrackedItem; _bayPlanType:Integer):Boolean;
// ---------------------------------------------------------------------------
// Created:		23 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	isBackEnd : Boolean;
    location : CM_LocationsController;
    slotController : CM_SlotController;
begin
	isBackEnd := false;
    if _bayPlanType = PROPOSED_BAYPLANS then
    	location := _ti.getPrimaryLocation(PLANNING_MODE);
    else
    	location := _ti.getPrimaryLocation(REAL_MODE);
    endif;
    if location &lt;&gt; null and
       location.isKindOf(CM_SlotController) then
	    slotController := location.CM_SlotController;
		if _ti.isKindOf(CM_Container) then    	
	    	if _ti.CM_Container.is40 and
	    	  slotController.isFortyBack then
	    		isBackEnd := true;
	    	endif;
	    endif;
    endif;
	return isBackEnd;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_bayPlanType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadCusCarBOls" id="1623d580-79ab-40b4-b014-44bc6302bbf3">
        <updating/>
        <source>loadCusCarBOls(_mergeCargo : Boolean; _control : CMIF_TIUpdateController input) updating;
//
//21 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors take 3

//
vars
	ti		: CM_TrackedItem;
	found	: Boolean;
	object	: Object;
//	retVal	: Integer;
begin
	
	if _control.myVoyage.allOnshipTIsByCargoTypeId.isNotEmpty then
		//merge and delete not viable options at this stage.  Warn and return - JC
//		app.msgBox('The current voyage already has cargo loaded.', 'ERROR', MsgBox_Question_Mark_Icon + MsgBox_OK_Only);
		//-------------------
//		return;
		//-------------------		
//		retVal := app.msgBox('Do you want to delete all existing cargo(Yes) or merge(No)', 'WARNING', MsgBox_Question_Mark_Icon + MsgBox_Yes_No_Cancel);
//		if retVal = MsgBox_Return_Cancel then
	//		beginTransaction;
	//		self.setStatus(CM_EDIFile.EDI_STATUS_LOADED);
	//		commitTransaction;
//			app.raiseCMException1(VB_USER_CANCELED_TRANS, '', '', null);
//			return;
//		endif;
//		if retVal = MsgBox_Return_Yes then
		if not _mergeCargo then
			beginTransaction;
			foreach ti in _control.myVoyage.allOnshipTIsByCargoTypeId do
				if not ti.isChild() then //cnwrs1 dec 2006 not allow to erase children only parents
					ti.erase(NORMAL_ERASE);
				endif;
			endforeach;
			commitTransaction;		
		endif;
	endif;
	
	app.myTrxCA.trxCreateEDIBOLInCusCar(_control, self, false, app.myPassport);
	if not app.myPassport.trxCompletedOK then
		return;
	endif;
	
end;</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_control" type="CMIF_TIUpdateController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadDB" id="f36d723f-7639-446c-a497-25a6706f991a">
        <updating/>
        <source>loadDB(_mergeCargo : Boolean; _passport: CM_Passport input) updating;
// cnwdvb1 21 February 2003 

// 04/09/2012	cnwcs5	par 30064 - don't use proxy for ediData.  Use _passport instead of local variable
//21 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors take 3
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 06 Mar 2018	jlgrs1	TFS 37484 - QNS Allow DB Loading of Bay Plan files
vars
	cmifEDIBayPlan : CMIF_EDIBayPlan;
	voyage : CM_Voyage;
	tmpStatus : Integer;
	partialDBLoad : Boolean;
begin	
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
	
	partialDBLoad := self.getMyTerminal.getConfig(EdiBayPlanAllowPartial).Boolean;
	if self.ediFileCode = EDIFileType_CusCar or self.ediFileCode = EDIFileType_WWLCar then
		self.loadDBCusCar(_mergeCargo, _passport);
		return;
	endif;
	voyage := self.getMyTerminal().lookupVoyage(self.voyageCode, null, false);
	if not partialDBLoad or 
	   voyage.isHOLDSorSHIP then
		self.loadDBNonPartial(_mergeCargo, _passport);
	else
		create cmifEDIBayPlan transient;
		cmifEDIBayPlan.voyageCode := self.voyageCode;
		cmifEDIBayPlan.myEDIData := self;
		cmifEDIBayPlan.processEDITIs(); //cnwrs1 par 26223 10 nov 2010
		tmpStatus := self.getStatusFromEDITrackedItems(false);
		
		if tmpStatus &lt;&gt; 0 then
			app.myTrxUA.trxSetEDIDataStatusAfterVerify(self, tmpStatus);	// par 27392 cnwrs1 14 Apr 2011
		endif;
	endif;
epilog
	delete cmifEDIBayPlan;
end;</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadDBCusCar" id="06409fbc-6fe2-4814-8fed-35dce15276c1">
        <updating/>
        <source>loadDBCusCar(_mergeCargo : Boolean; _passport: CM_Passport input) updating;

//  cmwrs1 June 2006 par 11961 ccms 1022
/* Changes

Date		Name	TFS#		Description
============================================================================
08 Oct 2015	cnwrs1	Par 36863 	Make EDI consistant times when refreshing progress bar
13 May 2016	cnwns1	TFS 488 	Multi Timezone Support
02 Oct 2019 jlgka1 	TFS 45332 	PEL1 - STWR - Better Forms and Interfaces for EDI Module
20 Oct 2020 jlgmd1	TFS 50204	Refactor progress updates to superclass method
============================================================================*/
vars
	poxyContainer,newContainer	: CM_TrackedItem;
	ediTI						: CM_EDITrackedItem;
	updCntrl					: CMIF_TIUpdateController;
	ignoreWarnings, rtnValue	: Boolean;
	tiSet						: CM_TISet;
	terminal					: CM_Terminal;
	voyage						: CM_Voyage;
	updateMon					: Boolean;
	passport					: CM_Passport;
	done, todo					: Integer;
	progressTS 					: TimeStamp;
begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
	
	progressTS := app.actualTimeServer();		// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	app.setContinueCMExceptions(false);
	
	create tiSet transient;
	terminal := self.getMyTerminal();
	if terminal = null then
		app.raiseCMException1(Err_InvalidTerminal, 'null', null, null);
		return;
	endif;
	
	voyage := terminal.lookupVoyage(self.voyageCode, null, false);
	if voyage = null then
		app.raiseCMException1(ERR_INVALID_VOYAGE, self.voyageCode, null, null);
		return;
	endif;
	
// PAR 33644	if voyage.isNonPlannedVoyage and	voyage.myShipBlockStack = null then
	if not voyage.structureIncludesLOLO and voyage.myShipBlockStack = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Non-planned voyage without a ship block stack controller.');
		return;
	endif;
	
	passport := _passport;
	
	// reinstaled for PAR12508 cnwrs1 Sept 2006	
	todo := self.allEDITrackedItems.size;
	done := null;
	self.updateProgress(progressTS, "Initializing Bay Plan...", todo, done, true, _passport);
	
	foreach ediTI in self.allEDITrackedItems do
		done := done + 1;
		self.updateProgress(progressTS, "Initializing Bay Plan...", todo, done, false, _passport);
		
		poxyContainer := terminal.createTI(ediTI.myCargoType, true);
		ediTI.CM_EDIBayPlanTI.setProxy(poxyContainer, null, passport);
		tiSet.add(poxyContainer);
	endforeach;
	
	self.updateProgress(progressTS, "Initializing Bay Plan...", todo, done, true, _passport);
	
	if tiSet.isEmpty then
		app.writeLog(class.name &amp; " " &amp; method.name &amp;  " no TI's found to load", LogINFO);
		return;
	endif;

	updCntrl := app.createTIUpdateControl(TI_UPDMODE_BAYPLAN, null, null);
	updCntrl.setMyUserObject(self);
	updCntrl.setMyTransientTIs(tiSet);
	updCntrl.myVoyage := voyage;
	updCntrl.comment := self.getDescription();
	passport.warningsAcknowledged := true;
//  cmwrs1 June 2006 par 11961 ccms 1022
//	if self.ediFileCode = EDIFileType_CusCar then
		self.loadCusCarBOls(_mergeCargo, updCntrl);
//	else
//		app.myTrxCA.trxCreateEDIBayPlanCusCar(updCntrl, passport);
//	endif;			
	
	if passport.noErrors then
//		app.myTrxUA.trxSetEDIDataStatus(self, CM_EDIFile.EDI_STATUS_DBLOADED); //ccms1845
//		beginTransaction;
//		status := CM_EDIFile.EDI_STATUS_DBLOADED;
//		app.cmsCommitTransaction(_passport);
		//let planning know a new EDI is available
		if voyage &lt;&gt; null then
			voyage.causeEvent(terminal.getTerminalEvent(Voyage_NewEDI_Event), true, null);
		endif;
	endif;

epilog
	delete updCntrl;
	delete tiSet;
end;</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadDBNonPartial" id="59659d68-7740-4a26-ae67-6bb6b3c92aba">
        <updating/>
        <source>loadDBNonPartial(_mergeCargo : Boolean; _passport: CM_Passport input) updating;
// cnwdvb1 21 February 2003 
/* Changes

Date		Name	TFS#		Description
============================================================================
04 Sep 2012	cnwcs5	par 30064 - don't use proxy for ediData.  Use _passport instead of local variable
21 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors take 3
08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
07 Mar 2018	jlgrs1	TFS 37484 - QNS Allow DB Loading of Bay Plan files
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
20 Oct 2020 jlgmd1	TFS 50204	Refactor progress updates to superclass method
============================================================================*/

vars
	poxyContainer, ti	: CM_TrackedItem;
	ediTI				: CM_EDITrackedItem;
	updCntrl			: CMIF_TIUpdateController;
	tiSet				: CM_TISet;
	terminal			: CM_Terminal;
	voyage				: CM_Voyage;
	done, todo			: Integer;
	tmpTIDict			: CM_TIByCargoTypeIdDict;
	portHere			: String;
	progressTS			: TimeStamp;
begin
	progressTS := app.actualTimeServer();				// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
//  cmwrs1 June 2006 par 11961 ccms 1022
	if self.ediFileCode = EDIFileType_CusCar or self.ediFileCode = EDIFileType_WWLCar then
		self.loadDBCusCar(_mergeCargo, _passport);
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	create tiSet transient;
	
	terminal := self.getMyTerminal();
	
	if terminal = null then
		app.raiseCMException1(Err_InvalidTerminal, 'null', null, null);
		return;
	endif;
	
	voyage := terminal.lookupVoyage(self.voyageCode, null, false);
	
	if voyage = null then
		app.raiseCMException1(ERR_INVALID_VOYAGE, self.voyageCode, null, null);
		return;
	endif;
	
// PAR 33644	if voyage.isNonPlannedVoyage and voyage.myShipBlockStack = null then
	if not voyage.structureIncludesLOLO and voyage.myShipBlockStack = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Non-planned voyage without a ship block stack controller.');
		return;
	endif;
//  cmwrs1 June 2006 par 11961 ccms 1022
	portHere := terminal.getConfig(PortDestCode).String;

// PAR 33644	if voyage.isNonPlannedVoyage 
	if voyage.isHOLDSorSHIP() // PAR 33644
	and voyage.allOnshipTIsByCargoTypeId.isNotEmpty then
		if not _mergeCargo then
			tmpTIDict := voyage.allOnshipTIsByCargoTypeId;
			beginTransaction;
			foreach ti in tmpTIDict do
				// par 15488 dont allow the edi file to be loaded if there is our export cargo on the voyage
				if ti.getImExStatus() = TI_IMEX_STATUS_EXPORT or ti.loadPort = portHere then
					app.raiseCMException1(ERR_INVALID_VOYAGE, self.voyageCode, null, null);
					return;
				endif;
				ti.erase(NORMAL_ERASE);
			endforeach;
			commitTransaction;		
		endif;
	endif;
	
	todo 		:= self.allEDITrackedItems.size;
	done		:= null;
	self.updateProgress(progressTS, "Initializing Bay Plan...", todo, done, true, _passport);
	
	foreach ediTI in self.allEDITrackedItems do
		done := done + 1;
		self.updateProgress(progressTS, "Initializing Bay Plan...", todo, done, false, _passport);
		
		poxyContainer := terminal.createTI(ediTI.myCargoType, true);
		
		ediTI.CM_EDIBayPlanTI.setProxy(poxyContainer, null, _passport);
		tiSet.add(poxyContainer);
		
		//  cmwrs1 June 2006 par 11961 ccms 1022
		if _mergeCargo then
			ti := voyage.allOnshipTIsByCargoTypeId[poxyContainer.cargoType, poxyContainer.id];
			if ti &lt;&gt; null then
				// par 15488 dont allow the edi file to be loaded if there is our export cargo on the voyage
				if ti.getImExStatus() = TI_IMEX_STATUS_EXPORT or ti.loadPort = portHere then
					app.raiseCMException1(ERR_INVALID_VOYAGE, self.voyageCode, null, null);
					return;
				endif;
				beginTransaction;
				ti.erase(NORMAL_ERASE);
				commitTransaction;
			endif;
		endif;
	endforeach;
	
	self.updateProgress(progressTS, "Initializing Bay Plan...", todo, done, true, _passport);
	
	if tiSet.isEmpty then
		app.writeLog(class.name &amp; " " &amp; method.name &amp;  " no TI's found to load", LogINFO);
		return;
	endif;

	updCntrl := app.createTIUpdateControl(TI_UPDMODE_BAYPLAN, null, null);
	
	updCntrl.setMyUserObject(self);
	updCntrl.setMyTransientTIs(tiSet);
	
	updCntrl.myVoyage 	:= voyage;
	updCntrl.comment 	:= self.getDescription();
	
	_passport.warningsAcknowledged := true;
	// par 30064 - don't use CM_EDIData proxy.  it serves no useful purpose
	app.myTrxCA.trxCreateEDIBayPlan(self, null, updCntrl, false, true, _passport); 	// par 30064 Sep 2012	//ccms 1845
	
	if _passport.noErrors then
		
		//epr par 37287 19/2/16 cargo notification requests were done on cargo create this caused problems for milaha
		// now its done on the baplie load and for milaha does the process stops edi automatically
		if self.status = CM_EDIFile.EDI_STATUS_DBLOADED and app.myRoot.isClientMilaha then
			app.myTrxUA.trxProcessStopsEDIOnShip(voyage, _passport);
		endif;
		
		if voyage &lt;&gt; null then
			voyage.causeEvent(terminal.getTerminalEvent(Voyage_NewEDI_Event), true, null);
		endif;
	endif;
epilog
	delete updCntrl;
	delete tiSet;
end;</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processTIs" id="9c15b94b-0020-45ef-bc03-76d6cf0f197e">
        <updating/>
        <source>processTIs(_trackedItem : CM_TrackedItem; _type : Integer) updating;
// This method takes TI's from CMS and converts data to EDI TIs
// used to extract data from CMS

// need to shift this to CM_TrackedItem and subclasses  ::setEDITIFromSelf(), or something

// 14/07/2010	cnwdap1	PAR #25021 review use of isImport/isExport for tranships
// 02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
// 31/05/2012	cnwcs5	CCMS SFW 1284 - EDI BGP Split - use setStatus instead of status := 
// 10 Sep 2014	cnwrs1	CCMS 2381
// 20 May 2016	cnwdap1	TFS #1881 BAPLIE/EDI VGM Updates
// 07 Jul 2017	cnwdap1	TFS 4492 SNO VERMAS Changes
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 03 Apr 2020  cnwma1  Bug 48976: SNO - Discharge Port of T/S Cargo in Outbound Proposed BAPLIE  
// 22 Jan 2021	jlgdap1	TFS 50553 Handling of Nested Child Cargo in BAPLIE EQA Segment
vars
	realTI			: CM_TrackedItem;
	ediTrackedItem	: CM_EDIBayPlanTI;
	commodity		: CM_Commodity;
    slotController 	: CM_SlotController;
	tmpReeferInfo,    
    bayId, 
	portCode 		: String;
	lVolume			: Real;
	tiLoc			: CM_LocationsController;
	imCodes			: StringArray;
	vgmDetails 		: CM_VGMDetails;			// TFS 4492
	child			: CM_TrackedItem;		// TFS 50553
	childEDITI		: CM_EDIBayPlanTI;		// TFS 50553
begin
	
	realTI := _trackedItem;
	if realTI = null then
		return;
	endif;
	
	if realTI.cargoType = TI_CargoType_LCL or	//don't process LCL individually
	   realTI.myParent &lt;&gt; null then				//PAR7955	or any attached item
		return;
	endif;
		
	create ediTrackedItem persistent;
	ediTrackedItem.setForCreateNew(self);

	ediTrackedItem.setCargoType(realTI.cargoType);
	
	ediTrackedItem.setId(realTI.id);
	ediTrackedItem.commodity := realTI.commodity;
	commodity := app.myRoot.allCommodities[realTI.commodity];
	if commodity &lt;&gt; null then
		ediTrackedItem.commodityDescription := commodity.description;
	endif;
	
	ediTrackedItem.destinationPort	:= realTI.destinationPort;
	ediTrackedItem.dischargePort	:= realTI.dischargePort;
	//03.04.2020 cnwma1 #48976
	if self.ediDataType = EDIDataType_BayPlan then
		if self.myEDIFile &lt;&gt; null  and self.myEDIFile.myEDIFileType &lt;&gt; null then
			if self.myEDIFile.myEDIFileType.type = EDIFileType_Baplie22 then
				if realTI.isTranshipItem          					 and
				   realTI.myVoyage = realTI.myVoyageTranshipImport   and 
				   realTI.myTranshipDetail &lt;&gt; null then
					ediTrackedItem.dischargePort	:= realTI.myTranshipDetail.dischargePort;
				endif;
			endif;
		endif;
	endif;
	
	ediTrackedItem.ediTranshipPort	:= realTI.ediTranshipPort;
	ediTrackedItem.isoType			:= realTI.getISOType;
	ediTrackedItem.loadPort			:= realTI.loadPort;
	ediTrackedItem.companyCode		:= realTI.companyCode;

    //setup bay position
	if _type = ACTUAL_BAYPLANS then
		if realTI.myPrimaryActualLocation = null then
			ediTrackedItem.locationId := realTI.locationId.reverse[1:6].reverse;	   
		else
			ediTrackedItem.locationId := realTI.myPrimaryActualLocation.getStowageId(realTI);	   
		endif;
	else
		ediTrackedItem.locationId := realTI.getProposedStowageID();	 
		if ediTrackedItem.locationId = null then
			ediTrackedItem.locationId := realTI.plannedLocnId;
		endif;
	endif;
	
	if ediTrackedItem.locationId.length = 6 then
		ediTrackedItem.locationId := "0" &amp; ediTrackedItem.locationId;
	endif;

	if realTI.isKindOf(CM_Container) then
		if realTI.CM_Container.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
			ediTrackedItem.fullOrMT := "E";
		else
			ediTrackedItem.fullOrMT := "F";
		endif;

		ediTrackedItem.temperature := realTI.CM_Container.getTemperature;
		
		tmpReeferInfo := realTI.CM_Container.getReeferInfo();
	else
		//otherwise BBLK has temp of zero
		ediTrackedItem.temperature := NULL_TEMPERATURE;
	endif;

	if realTI.isExport or realTI.isTranshipOutbound then		// PAR #25021
		ediTrackedItem.exportImport := "E";
	elseif realTI.isImport or realTI.isTranshipInbound then		// PAR #25021
		ediTrackedItem.exportImport := "I";
	elseif realTI.isRehandle then
		ediTrackedItem.exportImport := "R";
	elseif realTI.isSOB then
		ediTrackedItem.exportImport := "R";
	else
		ediTrackedItem.exportImport := "";

	endif;
	
	ediTrackedItem.operatorCode := realTI.operatorCode;
	
	// CCMS 1320 combine reefer info (cooling and voltage type) with remarks
	if tmpReeferInfo &lt;&gt; null then
		ediTrackedItem.remarks := tmpReeferInfo &amp; ' ' &amp; realTI.remarks;
	else
		ediTrackedItem.remarks := realTI.remarks;
	endif;
	
	ediTrackedItem.weight 		:= realTI.totalWeight;
	ediTrackedItem.width 		:= realTI.width.Integer; //cnwrd1 ccms 1060 fix
	ediTrackedItem.length 		:= realTI.length;
	ediTrackedItem.height 		:= realTI.height;

	create imCodes transient;
	ediTrackedItem.processTIHazards(realTI.allTIHazards, imCodes);
	imCodes.copy(ediTrackedItem.imCodes);
	delete imCodes;
		
	//do something with cubicMetres
	if realTI.getMyTotalVolume &gt; 0 and (realTI.cargoType &lt;&gt; TI_CargoType_Container) then	//BBLK
		//test if dimensions result in valid volume
		lVolume := (realTI.width/100) * (realTI.length/100) * (realTI.height/100);  //in cubic metres
		if lVolume &gt; 0 then
			//leave as is		
		else
			//don't have the dimensions to generate m3, guestimate from cubicMetres
			ediTrackedItem.validateVolume(realTI.getMyTotalVolume);
		endif;
	endif;
	ediTrackedItem.rawEDIData := realTI.rawEDIData;
	ediTrackedItem.bol := realTI.billOfLading;
	
	//28 Mar 2012	NDL	Par 28827
	if realTI.isOverDimensions then
		if realTI.cargoType = TI_CargoType_Container then
			ediTrackedItem.overHeight	:= realTI.CM_Container.overHeight;
			ediTrackedItem.overLengthBack := realTI.CM_Container.overLengthRear;
			ediTrackedItem.overLengthFront := realTI.CM_Container.overLengthFront;
			ediTrackedItem.overWidthLeft := realTI.CM_Container.overWidthLeft;
			ediTrackedItem.overWidthRight := realTI.CM_Container.overWidthRight;
		endif;
	endif;
	ediTrackedItem.setHumidity( realTI.getHumidity );
	ediTrackedItem.setCarbonDioxide( realTI.getCarbonDioxide );
	ediTrackedItem.setOxygen( realTI.getOxygen );
	ediTrackedItem.vent := realTI.getVentilation;
	
	ediTrackedItem.isCertifiedWeight := realTI.isWeightCertified;						// TFS #1881
	ediTrackedItem.weightCertifiedName := realTI.weightCertifiedName;					// TFS #1881
	ediTrackedItem.weightCertifiedReference := realTI.weightCertifiedReference;			// TFS #1881
	
	if realTI.isKindOf(CM_Container) then											// TFS 4492
		if realTI.CM_Container.myVGMDetails &lt;&gt; null then							// TFS 4492
			vgmDetails := realTI.CM_Container.myVGMDetails;							// TFS 4492
			ediTrackedItem.vgmAuthSignature := vgmDetails.vgmAuthSignature;			// TFS 4492
			ediTrackedItem.vgmCommsType := vgmDetails.vgmCommsType;					// TFS 4492
			ediTrackedItem.vgmDeterminationDT := vgmDetails.vgmDeterminationDT;		// TFS 4492
			ediTrackedItem.vgmDocsIssuedDT := vgmDetails.vgmDocsIssuedDT;			// TFS 4492
			ediTrackedItem.vgmDocumentDetails := vgmDetails.vgmDocumentDetails;		// TFS 4492
			ediTrackedItem.vgmEDITransmission := vgmDetails.vgmEDITransmission;		// TFS 4492
			ediTrackedItem.vgmElectronicMail := vgmDetails.vgmElectronicMail;		// TFS 4492
			ediTrackedItem.vgmMail := vgmDetails.vgmMail;							// TFS 4492
			ediTrackedItem.vgmPhone := vgmDetails.vgmPhone;							// TFS 4492
			ediTrackedItem.vgmTelefax := vgmDetails.vgmTelefax;						// TFS 4492
			ediTrackedItem.vgmTelephone := vgmDetails.vgmTelephone;					// TFS 4492
		endif;																		// TFS 4492
	endif;																			// TFS 4492
			
	// TFS 50553 create child cargo EDI TIs for flat rack children of flat racks
	// All we need is the ID
	if realTI.isFlat and not realTI.allChildren.isEmpty then
		foreach child in realTI.allChildren where child.isFlat do
			create childEDITI persistent;
			childEDITI.id := child.id;
			childEDITI.myParent := ediTrackedItem;
		endforeach;
	endif;
	// TFS 50553 end
	
	self.setStatus (CM_EDIFile.EDI_STATUS_LOADED);	// CCMS SFW 1284 - MAY 2012
	
epilog
	delete imCodes;									//  04/02/2014 cnwmh5
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="removeOthers" id="d6b075ee-b513-43c5-abfe-d75d13b4f805">
        <source>removeOthers();
// CCms 1156
// remove all the tracked Items whose destination is not ourselves.

/*

Date		Who		Reason
05/05/2010	cnwcs5	par 23580 - enhanced EDI form
						Changed this method so it can be called from a TRX/UTL method (i.e. in transaction state)
12 Oct 2016	cnwkpd1	TFS 2815 - JADE 7.1.08 causeEvent changes

*/						

vars
	portDestCode	: String;
	ediData			: CM_EDIData;
	ediTI			: CM_EDITrackedItem;
	objectArray		: ObjectArray;
	object			: Object;
begin
	// Hmmm this should be trx'd
	// put all edi TIs that are not for 'our' port into a collection
	create objectArray transient;
	
	portDestCode := self.getMyTerminal().getConfig(PortDestCode).String;
	
	foreach ediTI in self.allEDITrackedItems do
		if ediTI.CM_EDIBayPlanTI.dischargePort &lt;&gt; portDestCode then
			// add to temporary collection
			objectArray.add(ediTI);
		endif;
	endforeach;
	
/*	par 23580 - removed following block of code and replaced it with a purge
	beginTransaction;	
	foreach object in objectArray do
		//self.ediTrackedItems.remove(object.CM_EDIBayPlanTI);  now parent/childed up
		object.CM_EDIBayPlanTI.setMyEDIData(null);
		delete object;
	endforeach;
	commitTransaction;
*/ 
	objectArray.purge;	// par 23580
	// the receiver has not really been updated but we want the GUI to reflect this update
//	self.causeEvent(Object_Update_Event, true, self);
	self.updateObjectEdition(self);

epilog
	delete objectArray;		
end;</source>
    </JadeMethod>
