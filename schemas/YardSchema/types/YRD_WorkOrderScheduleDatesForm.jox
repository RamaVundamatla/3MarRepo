    <JadeMethod name="getDateTimes" id="6c629ce7-0d20-4ee4-be8f-6de7774b78c4">
        <source>getDateTimes( _dateTimes : TimeStampArray input );
// -----------------------------------------------------------------------------
// Created:		14 August 2009 by consw1
//
// Purpose:		Get results
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	time : Time;
	ts : TimeStamp;
	
begin
	ts.setDate( self.dtStartDate.getDate() );
	
	while ts.date &lt;= self.dtEndDate.getDate() do
	
	
	//	foreach time in self.allTimes do
		if self.tmTime.getTime &lt;&gt; null then 
			ts.setTime( self.tmTime.getTime );
		else
			ts.setTime( null);
		endif;
		
		if not _dateTimes.includes( ts ) then
			_dateTimes.add( ts );
		endif;
		//endforeach;
		
		ts.setDate( ts.date + 1 );
	endwhile;
	
epilog

end;</source>
        <Parameter name="_dateTimes" type="TimeStampArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="set" id="a7f48c22-5841-47db-b2f2-4c00c124682d">
        <updating/>
        <source>set(_workOrder : CM_WorkOrder) updating;
// -----------------------------------------------------------------------------
// Created:		14 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//29 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
// -----------------------------------------------------------------------------

vars
	today : TimeStamp;
	woRequiredByDT : TimeStamp;
begin
	today := app.actualTimeServer();

	if _workOrder.startAtDT.date &gt; today.date() then
		self.minStartDate := self.systemToLocalTime(_workOrder.startAtDT).date;
	else
		self.minStartDate := self.systemToLocalTime(today).date();
	endif;
	
	self.dtStartDate.setDate( self.minStartDate );
	woRequiredByDT := self.systemToLocalTime(_workOrder.requiredByDT);
	
	if woRequiredByDT.date &gt; self.minStartDate then
		self.dtEndDate.setDate( woRequiredByDT.date );
	else
		self.dtEndDate.setDate( self.minStartDate );
	endif;

epilog

end;</source>
        <Parameter name="_workOrder" type="CM_WorkOrder"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="196945d3-0dc4-460b-9027-7f26b1436fe6">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0012860, locale);
	btnAdd.translateCaption(Xlat_0014720, locale);
	btnAddNext.translateCaption(Xlat_0013891, locale);
	btnDelete.translateCaption(Xlat_0014721, locale);
	btnEndDate.translateCaption(Xlat_0013892, locale);
	btnStartDate.translateCaption(Xlat_0013893, locale);
	lblEndDate.translateCaption(Xlat_0012863, locale);
	lblStartDate.translateCaption(Xlat_0012864, locale);
	lblTimes.translateCaption(Xlat_0012865, locale);
end;</source>
    </JadeMethod>
</GUIClass>
