    </JadeMethod>
    <JadeMethod name="setProxyForShipNotice" id="1e7accf0-ea76-4686-b370-fa4feaed4592">
        <updating/>
        <source>setProxyForShipNotice(_sendRecvMessage:String; _webServiceDefinition : CM_ExternalWebServiceDef; _terminal : CM_Terminal; _responseCode : Integer io; _response : String io) updating;			//navra1 - MTN-35875- 5th Sep 2025-1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2025	navra1	Initial creation for //navra1 - MTN-34782 - 15th July 2025

*/

vars

begin
	self.createdUser := app.getMyUserCode();
	self.created := app.actualTimeServer();
	self.myRoot := app.myRoot;
	self.myTerminal := _terminal;
	self.interfaceName := ExternalWebServiceAgGateway;
	self.sendRecvMessage := _sendRecvMessage;
	self.myExtWebserviceDef:=_webServiceDefinition;
	self.description := CM_EWSActivityAgGateway.DIRECTION_SEND &amp; "-" &amp; CM_EWSActivityAgGateway.MESSAGE_TYPE_SHIPNOTICE;
	self.direction := CM_EWSActivityAgGateway.DIRECTION_SEND;	
	self.messageType := CM_EWSActivityAgGateway.MESSAGE_TYPE_SHIPNOTICE;
	self.response := _response;									//navra1 - MTN-35875- 5th Sep 2025-1
	self.responseCode := _responseCode;							//navra1 - MTN-35875- 5th Sep 2025-1
epilog

end;</source>
        <Parameter name="_sendRecvMessage" type="String"/>
        <Parameter name="_webServiceDefinition" type="CM_ExternalWebServiceDef"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_responseCode" type="Integer" usage="io"/>
        <Parameter name="_response" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="tryResendMessage" id="847f096d-e0e5-4050-a529-9e00a95d5276">
        <source>tryResendMessage();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2025	navra1	Initial creation
05 Sep 2025 navnk30 JIRA 35707: 4 - YARA | Create a new web service definition to use to send out AG Gateway messages

*/

vars
	wsAgent	: CM_AgGatewayConsumerWSAgent;
	response						: String;
	maxRetries,
	responseCode					: Integer;
	agGatewayEWSDef					: CM_AgGatewayServiceDef;
	updatePxy						: CM_EWSActivityAgGateway;
	realAct 						: CM_EWSActivityAgGateway;
begin
	
	agGatewayEWSDef := self.myExtWebserviceDef.CM_AgGatewayServiceDef;
	create wsAgent as CM_AgGatewayConsumerWSAgent;
	wsAgent.setupFromWebServiceDefinition(agGatewayEWSDef);
	wsAgent.setMyTerminal(self.myTerminal);
	
	maxRetries := 3;	
	
	while maxRetries &gt; 0 do	
		//navra1 - MTN-36074 - 17th Sep 2025 - start
		updatePxy := app.createUpdateProxy(self).CM_EWSActivityAgGateway;
		
		if self.messageType = CM_EWSActivityAgGateway.MESSAGE_TYPE_SHIPNOTICE then
			response := wsAgent.doSendHTTPRequest(agGatewayEWSDef.getShipNoticeEndPointStr(), JadeHTTPConnection.Verb_POST, wsAgent.getAdditionalHeadersForHTTP(), self.sendRecvMessage, responseCode);	//05SEP2025 navnk30 JIRA-35707
			updatePxy.setProxyForShipNotice(self.sendRecvMessage, self.myExtWebserviceDef, self.myTerminal, responseCode, response);
		elseif self.messageType = CM_EWSActivityAgGateway.MESSAGE_TYPE_ORDERRESPONSE then
			response := wsAgent.doSendHTTPRequest(agGatewayEWSDef.getOrderRespEndPointStr(), JadeHTTPConnection.Verb_POST, wsAgent.getAdditionalHeadersForHTTP(), self.sendRecvMessage, responseCode);	//05SEP2025 navnk30 JIRA-35707
			updatePxy.setProxyForOrderResponse(self.sendRecvMessage, self.myExtWebserviceDef, self.myTerminal, responseCode, response);
		endif;
		
		//update the existing activity's response and response code
		realAct := app.myTrxCA.trxCreateEWSActivityHistory(updatePxy, app.myPassport).CM_EWSActivityAgGateway;	
		//navra1 - MTN-36074 - 17th Sep 2025 - end
		
		if responseCode = 200 then
			break;
		endif;
		maxRetries -= 1;		
		
		delete updatePxy;	//navra1 - MTN-36074 - 17th Sep 2025
	endwhile;	
epilog
	
end;</source>
    </JadeMethod>
</Class>
