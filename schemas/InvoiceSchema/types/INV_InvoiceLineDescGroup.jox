	self.msgLines.backColor := self.backColor;
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="6e0c81ad-ec7c-46dd-a352-7ee3f9711f99">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theLine : CM_InvoiceLineDescGroup;
	thesheet	: CMUI_Sheet;
begin
	inheritMethod();
	
	theLine := self.myCurrentObject.CM_InvoiceLineDescGroup;

	self.setupAvailableLines(theLine);

	if self.mode = self.Mode_Add then
		self.msgLines.setSelected(null);
	else
		self.msgLines.setSelected(theLine.lineDescriptions);
	endif;
	self.fldEntDetail.visible := true;
	self.populateEntDetailTable();
	self.tblEntDetail.setFocus;
	self.tblEntDetail.goToRowByName(ETRow_Description);
	self.fldEntDetail.initSheetBackColors();
end;</source>
