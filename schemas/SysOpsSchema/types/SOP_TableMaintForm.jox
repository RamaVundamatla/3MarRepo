    <JadeMethod name="loadChars" id="793704af-3a12-4a5e-bd2c-e77fd48b243d">
        <source>loadChars(_theFont : String);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 13/05/2015	cnwdap1		Initial creation PAR #36206 TFS 324/334 Graphical Representation of Hazard Class and Special Stow
//
vars
	idx : Integer;
	
begin
	if _theFont = null then
		return;
	endif;
	self.cmbChar.clear();
	self.cmbChar.sorted := false;
	self.cmbChar.fontName := _theFont;
	self.cmbChar.fontSize := 16;
	foreach idx in 1 to 255 do
		self.cmbChar.addItem(idx.Character);
	endforeach;
epilog

end;</source>
        <Parameter name="_theFont" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadCmbCategoryContext" id="0e0add3c-ba42-44eb-853e-92a173379ec7">
        <source>loadCmbCategoryContext(_context : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		 Reason
30/11/2022  navmv20      TFS CR 55299 Task 55519: UI - New File Category Maintenance UI
02 Jan 2023 navtnr20 	TFS CR 56058 Task 56059: Jade - Contracts - New File Category
28/07/2023	navkc1	Bug 59320: EUP - COO - File Category Context
*/

vars
	cmb : CMUI_ComboBox;
begin
	cmb := self.cmbCategoryContext;
	cmb.clear;
	cmb.sorted := true;// ### TFS CR 56094 TASK 59618 08AUG2023 NAVAB1
	cmb.addItem(FileCategoryContext_WrkOrdrStr);
	cmb.addItem(FileCategoryContext_VoyageStr);
	cmb.addItem(FileCategoryContext_CrgoTypStr);              
	cmb.addItem(FileCategoryContext_InvoiceStr);  
	cmb.addItem(FileCategoryContext_ContrctStr);//navtnr20 02-01-2023 TFS 56059
	cmb.addItem(FileCategoryContext_OwnrChgStr); //28/07/2023	navkc1	Bug 59320
	cmb.addItem(FileCategoryContext_CustDocStr); //28/07/2023	navkc1	Bug 59320
 // ### TFS CR 55299 TASK 55985 28DEC2022 NAVAB1	cmb.addItem(FileCategoryContext_OtherStr);       
	
	cmb.listIndex := cmb.findString(1,app.getContextTextIntToStr(_context));
epilog

