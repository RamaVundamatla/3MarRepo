    <JadeMethod name="isRunningOnCE" id="c568b69e-42cb-4b62-9c65-b05eb105757e">
        <source>isRunningOnCE(): Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
29 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
constants
	WindowsCE = 19; //this is an educated guess here node hasn't been updated with the Windows CE constant
vars
	osPlatform,
	osArchitecture: Integer;
	osVersion : String;
begin
	osPlatform	:=	process.getOSPlatform(osVersion, osArchitecture);
	
	//if osPlatform.bitAnd(Node.OSWindows) &lt;&gt; 0 then
		if osPlatform = Node.OSWindowsMobile then
			return true;
		endif;
//	endif;

	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="msgBox" id="1b3a44fe-1129-48dd-a07b-d1156eb55aec">
        <source>msgBox(msg: String; title: String; flags: Integer): Integer;
// --------------------------------------------------------------------------------
// Created:		24 January 2006 by cnwdad1
//
// Purpose:		Re-implementation of app.msgBox.
//
//				If the 'flags' parameter value is positive, then the normal
//				app.msgBox will be presented.
//
// Parameters:	Refer to the "msgBox" method in the JADE Online Help.
//
// Returns:		Refer to the "msgBox" method in the JADE Online Help.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 13/02/2006	cnwdad1		Changed so that the foreground/background colors are not
//							reset to the user colors.
// --------------------------------------------------------------------------------
vars
	msgboxFormObj	: MB_MsgBoxForm;
	hhMsgboxFormObj : MB_HHMsgBoxForm;
begin

//return inheritMethod(msg, title, flags);
	if app.name = "JMTVehicleMountedLogon" or app.name = "JMTHandHeldLogon" or app.name = "JMTVehicleMountedWithDevice" then // self.myHandHeldGuiAgent &lt;&gt; null or self.myVehicleMountedLogonGUIAgent &lt;&gt; null then
		//return self.msgBoxHandHeld(msg, title, flags);
		//return inheritMethod(msg, title, flags);
		create hhMsgboxFormObj transient;
		hhMsgboxFormObj.setMessage(msg, title, flags);
		
		return hhMsgboxFormObj.showModal();
		
	endif;
	
	create msgboxFormObj transient;
	msgboxFormObj.setMessage(msg, title, flags);
	
	return msgboxFormObj.showModal();
end;</source>
        <Parameter name="msg" type="String"/>
        <Parameter name="title" type="String"/>
        <Parameter name="flags" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="myHandHeldGuiAgent" id="43cf9e6a-f632-43a9-ac65-ccbeadc8342a">
        <methodInvocation>mapping</methodInvocation>
        <source>myHandHeldGuiAgent(set: Boolean; _value: HandHeldGuiAgent io) mapping;
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if set then
		// set code here
	else
		if self.myHandHeldGateGuiAgent &lt;&gt; null then
			_value := self.myHandHeldGateGuiAgent;
		elseif self.myHandHeldRailGuiAgent &lt;&gt; null then
			_value := self.myHandHeldRailGuiAgent;
		elseif self.myVehicleMountedRTGGuiAgent &lt;&gt; null then
			_value := self.myVehicleMountedRTGGuiAgent;
		elseif self.myVehicleMountedIMVGuiAgent &lt;&gt; null then
			_value := self.myVehicleMountedIMVGuiAgent;
		elseif self.myHandHeldShipLanderGuiAgent &lt;&gt; null then
			_value := self.myHandHeldShipLanderGuiAgent;
		elseif self.myVehicleMountedRailGuiAgent &lt;&gt; null then
			_value := self.myVehicleMountedRailGuiAgent;
		elseif self.myVehicleMountedSTRADGuiAgent &lt;&gt; null then
			_value := self.myVehicleMountedSTRADGuiAgent;
		elseif self.myTwistLockReaderGUIAgent &lt;&gt; null then
			_value:=self.myTwistLockReaderGUIAgent;
		// ### this must be last!!!!
		elseif self.myHandHeldLogonGuiAgent &lt;&gt; null then
			_value := self.myHandHeldLogonGuiAgent;
		endif;
	endif;



end;


</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="HandHeldGuiAgent" usage="io"/>
    </JadeMethod>
    <JadeMethod name="myLogonGuiAgent" id="7a4ffef8-12a2-4a4a-b9d5-6d611d34fbd7">
