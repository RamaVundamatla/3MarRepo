    <JadeMethod name="btnClientBinBrows_click" id="017120a7-d05c-4ac0-8865-dd5800e56241">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClientBinBrows_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		07 July 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.statusMsg("Browsing for JADE Binaries path...");
	self.getFilePathName("JADE Binaries Path", txtClientPathBin.text);
epilog
	self.statusMsg(null);
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnClientIniBrows_click" id="d9ed5839-445c-42f8-8525-a08b3427c62d">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClientIniBrows_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		07 July 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fileOpen	: CMDFileOpen;

begin
	self.statusMsg("Browsing for JADE Initialization File path...");
//	self.getFilePathName("JADE INI File Path", txtClientPathBin.text);

	create fileOpen;
	fileOpen.allowMultiSelect	:=	false;
	fileOpen.defaultExt			:=	".ini";
	fileOpen.fileMustExist		:=	true;
//	fileOpen.filter				:=	"Initialization File (*.ini)|*.ini|All files (*.*)|*.*";
//	fileOpen.filterIndex		:=	1;
	fileOpen.cnEcSetFilters(true, 1, CNEC_FILE_FILTER_INI);

	if fileOpen.open = 0 then
		txtClientPathIni.text	:=	fileOpen.fileName;
	endif;
epilog
	delete fileOpen;
	self.statusMsg(null);
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnClientKillCl_click" id="f0bf06ba-eef4-4478-91f3-dac137194e23">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClientKillCl_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		13 June 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.statusMsg("Killing remote Web Test Clients...");
	global.causeEvent(CNEC_WEBTEST_CLIENT_CLOSE, true, 0);
epilog
	self.statusMsg(null);
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnClientKillSl_click" id="01e3befa-50f6-45fe-979c-5dca8a381cdf">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClientKillSl_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		16 June 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.statusMsg("Killing remote Web Test Slaves...");
	global.causeEvent(CNEC_WEBTEST_SLAVE_CLOSE, true, 0);
epilog
	self.statusMsg(null);
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnClientSpawn_click" id="81bf96bd-863c-400f-af58-3cb84e91e666">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClientSpawn_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		13 June 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	copiesToSpawn	: Integer;
	isThinClient	: Boolean;
	appServerPort	: String;
	binariesPath	: String;
	iniFilePath		: String;
	remoteAppInfo	: Binary;

begin
	self.statusMsg("Spawning remote Web Test Slaves...");

	copiesToSpawn	:=	txtClientCopies.text.trimBlanks.Integer;
	isThinClient	:=	chkClientIsThin.value;
	appServerPort	:=	txtClientAppSPort.text.trimBlanks;
	binariesPath	:=	txtClientPathBin.text.trimBlanks;
	iniFilePath		:=	txtClientPathIni.text.trimBlanks;

	if copiesToSpawn = 0 then
		app.msgBox("Please enter the number of Remote App copies you wish to spawn.", "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;
	elseif isThinClient and appServerPort = null then
		app.msgBox("Please enter the Application Server Port number for the Remote App.", "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;
	elseif not isThinClient then
		if binariesPath = null then
			app.msgBox("Please enter the Binaries Path for the Remote App.", "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
			return;
		elseif iniFilePath = null then
			app.msgBox("Please enter the Initialization File Path for the Remote App.", "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
			return;
		endif;
	endif;

	if isThinClient then
		remoteAppInfo	:=	self.getSpawnInfoThin(copiesToSpawn, appServerPort);
		global.causeEvent(CNEC_WEBTEST_SLAVE_SPAWN_THIN, true, remoteAppInfo);
	else
		remoteAppInfo	:=	self.getSpawnInfoFat(copiesToSpawn, binariesPath, iniFilePath);
		global.causeEvent(CNEC_WEBTEST_SLAVE_SPAWN_FAT, true, remoteAppInfo);
	endif;
epilog
	self.statusMsg(null);
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnClientStart_click" id="fbdd35be-b284-4dc8-9391-b01c0146aa5a">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClientStart_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		13 June 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	webTestName	: String;

begin
	self.statusMsg("Starting remote Web Tests...");

	if lstClientTest.listIndex &lt;&gt; CNEC_NULL_INDEX then
		webTestName	:=	lstClientTest.text;
		global.causeEvent(CNEC_WEBTEST_TEST_START, true, webTestName);
	endif;
epilog
	self.statusMsg(null);
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnClientStop_click" id="05a21292-da40-4135-8737-d8a7ddcc2910">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClientStop_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		13 June 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.statusMsg("Stopping remote Web Tests...");
	global.causeEvent(CNEC_WEBTEST_TEST_STOP, true, 0);
epilog
	self.statusMsg(null);
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnClose_click" id="d6dfdd61-287a-427d-b5d8-5a1c43145533">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
