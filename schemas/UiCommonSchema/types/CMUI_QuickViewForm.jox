    <JadeMethod name="cmbCode_displayEntry" id="b8d9dc11-b296-45a0-a584-58c64f4860b4">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCode_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
// ---------------------------------------------------------------------------
// Created:     27 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if obj.isKindOf(CM_Commodity) then
		return self.myAssistant.displayEntryCommodity(obj.CM_Commodity);
	elseif obj.isKindOf(CM_ISOType) then
		return obj.CM_ISOType.code;
	endif;
	
	return null;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="0525f972-d923-49a1-8076-fd55ee6253ba">
        <updating/>
        <source>doResize() updating;
//--------------------------------------------------------------
//Created: 25 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpLeft,
	tmpTop	: Integer;
begin

	if self.width &lt; 250 then
		self.width := 250;
	endif;
	tmpTop 	:= (self.height - 35 - btnClose.height).Integer;
	tmpLeft := (self.width - WinRightMargin - btnClose.width).Integer;
	self.btnClose.move(tmpLeft, tmpTop, btnClose.width, btnClose.height);
	self.btnSave.move(btnClose.left - HorizontalSpacing - btnClose.width, tmpTop, btnSave.width, btnSave.height);
	
	self.lblCode.move(WinLeftMargin, WinTopMargin, lblCode.width, lblCode.height);
	self.cmbCode.move(lblCode.left + lblCode.width + HorizontalSpacing, WinTopMargin, cmbCode.width, cmbCode.height);

	self.tblView.height := (self.height - btnClose.height - 65 - cmbCode.height);
	self.tblView.width := (self.width - 25);
	self.tblView.top := (cmbCode.top + WinTopMargin + cmbCode.height);
	self.tblView.left := (WinLeftMargin);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowTI" id="9ee6db3a-afd8-40fd-b952-916eef0fdd54">
        <updating/>
        <source>doShowTI(_theTI : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lController : CM_LocationsController;
	lString : String;
	idx : Integer;
	aStop : CM_Stops;
	allStops	: CM_StopsByIdDict;
	
begin
	self.tblView.rows := 0;
	self.tblView.columns := 2;
	self.tblView.backColor := White;
	self.tblView.accessColumn(1).backColor := Black;
	self.tblView.accessColumn(1).foreColor := White;
	
	idx := self.tblView.addItem("ID" &amp; Tab &amp; _theTI.id); // &amp; "(" &amp; _theTI.String &amp; ")");
	self.tblView.accessRow(idx).itemObject := _theTI;
	
	lController := _theTI.getPrimaryLocation(REAL_MODE);
	if lController &lt;&gt; null then
		self.tblView.addItem("Real Location" &amp; Tab &amp; lController.myTerminalArea.id &amp; " " &amp; lController.getID);
	endif;
	lController := _theTI.getPrimaryLocation(QUEUE_MODE);
	if lController &lt;&gt; null then
		self.tblView.addItem("Queued Location" &amp; Tab &amp; lController.myTerminalArea.id &amp; " " &amp; lController.getID);
	endif;
	lController := _theTI.getPrimaryLocation(PLANNING_MODE);
	if lController &lt;&gt; null then
		self.tblView.addItem("Planned Location" &amp; Tab &amp; lController.myTerminalArea.id &amp; " " &amp; lController.getID);
	endif;
	self.tblView.addItem("Requires Power" &amp; Tab &amp; _theTI.isAttributeTrue(TI_Attrib_RequiresPower).String);
	if  _theTI.jobRailReceive &lt;&gt; null then
		self.tblView.addItem("Job Rail Receive" &amp; Tab &amp; _theTI.jobRailReceive.jobId);
	endif;
	if  _theTI.jobRailRelease &lt;&gt; null then
		self.tblView.addItem("Job Rail Release" &amp; Tab &amp; _theTI.jobRailRelease.jobId);
	endif;
	
	if _theTI.hasStops then
		lString := "Has Stops - ";
//		foreach aStop in _theTI.getAllStops() do		// cnwrl1 15/12/2009 PAR 21889 - what it was
		create allStops transient;
		_theTI.getAllActiveStops( allStops );
		foreach aStop in allStops do
			if aStop.canBeViewed(app.myPassport) then
				lString := lString &amp; aStop.myStopsTable.heading &amp; " ";
			endif;
		endforeach;
		self.tblView.addItem("Stops" &amp; Tab &amp; lString);
	endif;
	if _theTI.allToDoTasksToDo.size &lt;&gt; 0 then
		self.tblView.addItem("ToDo" &amp; Tab &amp; "Has Some");
	endif;
	
epilog
	delete allStops;
	
end;
</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doShowTIs" id="1022d9c8-3865-4903-a8c6-1eb12fbb882e">
        <source>doShowTIs(_theTIArray : CM_TIArray) ;
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	lString : String;
	idx : Integer;
	lTI : CM_TrackedItem;
begin
	self.tblView.rows := 0;
	self.tblView.columns := 2;
	self.tblView.backColor := White;
	self.tblView.accessColumn(1).backColor := Black;
	self.tblView.accessColumn(1).foreColor := White;
	
	foreach lTI in _theTIArray do
		idx := self.tblView.addItem("ID" &amp; Tab &amp; lTI.id &amp; " (" &amp; lTI.String &amp; ")");
		self.tblView.accessRow(idx).itemObject := lTI;
	endforeach;


end;</source>
        <Parameter name="_theTIArray" type="CM_TIArray"/>
    </JadeMethod>
    <JadeMethod name="doShowThumbnail" id="79e322f8-0467-4096-a6c9-bf23e8425aa7">
        <source>doShowThumbnail(obj : Object);
// ---------------------------------------------------------------------------
// Created:     27 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	tblView.clear;
	tblView.rows := 0;
	
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
