<Class name="CMIF_VesselLabels" id="64c2d9e4-fc47-4a40-9481-6f83440daa4c">
    <superclass name="CMIF_Object"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>Used in the getOrdinals calls on either a Vessel or Bay
to extract ordinals based on labels passed in.
Use this to locate a particular position on the vessel
eg. a particular bay, cell, tier or slot leave the other fields blank</text>
    <PrimAttribute name="bay" id="d884de72-aae9-441a-b9c5-4c89ae221eec">
        <length>3</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="cell" id="ba9ce4ac-d187-4149-b299-3caf3ec47f26">
        <length>3</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="onDeck" id="9e4906b6-cc34-466d-9854-0261f78eadd5">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="secondary" id="3dbd9f57-6cb6-4b68-885a-f78c0aa5f47e">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="tier" id="07f85e2d-03fa-4524-acab-c12444167775">
        <length>3</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
</Class>
