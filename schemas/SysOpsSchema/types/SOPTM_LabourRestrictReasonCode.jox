    <JadeMethod name="doSave" id="aeff385e-dfec-49f5-b260-185fc9c6c331">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     25 May 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	errObj:CM_Error;
	idx:Integer;
	tmpListBox:ListBox;
	ignoreWarnings,rtnValue:Boolean;
	pxyLabourRestrictionReasonCode:CM_LabourRestrictionReasonCode;
	lCode,lDescription:String;
	notAvailForEntry	: Boolean;
	theForm : SOP_TableMaintForm;
begin

  	theForm := self.myForm; 
	lCode := theForm.tblInput1.getValueByName(ETRow_Code).String;
	lDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;
	notAvailForEntry := theForm.tblInput1.getValueByName(ETRow_NotAvailableForEntry).Boolean;

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_LabourRestrictionReasonCode transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	pxyLabourRestrictionReasonCode := theForm.myProxyObject.CM_LabourRestrictionReasonCode;
	pxyLabourRestrictionReasonCode.setProxy(lCode, lDescription, notAvailForEntry);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateLRReasonCode(pxyLabourRestrictionReasonCode, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateLRReasonCode(pxyLabourRestrictionReasonCode, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
