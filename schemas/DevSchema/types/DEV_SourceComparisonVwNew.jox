    <JadeMethod name="loadMissingClasses" id="b46c6f6f-3662-468a-b362-cf6f76a90b27">
        <source>loadMissingClasses(_report : DEV_SourceCompareReport; _userCode : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation
30 Jul 2025			navah1	Story 34749: MTN - Source Compare - Add counts to List Boxes and Heading Labels
*/

vars
	schema 			: DEV_Schema;
	class 			: DEV_Class;
	attribute 		: DEV_Attribute;
	constant 		: DEV_ClassConstant;
	reference 		: DEV_Reference;
	addedSchema,
	addedClass,
	addedAttributes,
	addedConstants,
	addedReferences : Boolean;
	systemSchema	: Schema;
	systemClass		: Class;
	systemReference : Reference;
	classCount,						//30.07.2025 navah1 #34749 - Start
	attributeCount,					 
	referenceCount,					 
	constantCount,					  
	total,							 
	classIndex,						 
	schemaIndex,					 
	attributeIndex,					 
	referenceIndex,					 
	constantIndex	: Integer;		//30.07.2025 navah1 #34749 - End
begin
	foreach schema in _report.allSchemas do
		addedSchema := false;
		systemSchema := rootSchema.getSchema(schema.name);
		classCount := 0; //30.07.2025 navah1 #34749
		foreach class in schema.allClasses do
			addedClass := false;
			addedAttributes := false;
			addedConstants := false;
			addedReferences := false;
			systemClass := systemSchema.getClass(class.name);
			attributeCount := 0; //30.07.2025 navah1 #34749
			referenceCount := 0; //30.07.2025 navah1 #34749
			constantCount := 0;  //30.07.2025 navah1 #34749
			
			if not self.chkShowResolved.value and class.resolvedBy &lt;&gt; null then
				continue;
			endif;
			
			if class.reason &lt;&gt; DEV_SourceCompareReportAgent.Object_Link then
				if _userCode &lt;&gt; null and class.modifiedBy &lt;&gt; _userCode then 
					continue;
				endif;
				
				if not addedSchema then
					self.qlbClassData.addItem(schema.name);
					self.qlbClassData.itemObject[self.qlbClassData.newIndex] := schema;
					self.qlbClassData.itemLevel[self.qlbClassData.newIndex] := 1;
					self.qlbClassData.itemExpanded[self.qlbClassData.newIndex] := false;
					addedSchema := true;
					schemaIndex := self.qlbClassData.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				if class.reason = DEV_SourceCompareReportAgent.Object_Missing then
					self.qlbClassData.addItem(class.name &amp; " - Missing");
				elseif class.reason = DEV_SourceCompareReportAgent.Object_Different then
					self.qlbClassData.addItem(class.name &amp; " - Different");
				endif;
				
				if class.resolvedBy &lt;&gt; null then
					self.qlbClassData.itemForeColor[self.qlbClassData.newIndex] := Gray;
				else
					self.qlbClassData.itemForeColor[self.qlbClassData.newIndex] := Window.Color_WindowText;
				endif;
				
				self.qlbClassData.itemObject[self.qlbClassData.newIndex] := class;
				self.qlbClassData.itemLevel[self.qlbClassData.newIndex] := 2;
				self.qlbClassData.itemExpanded[self.qlbClassData.newIndex] := false;
				addedClass := true;
				classIndex := self.qlbClassData.newIndex; //30.07.2025 navah1 #34749
			endif;
			
			foreach attribute in class.allAttributes do
				if not self.chkShowResolved.value and attribute.resolvedBy &lt;&gt; null then
					continue;
				endif;
				
				if _userCode &lt;&gt; null and attribute.modifiedBy &lt;&gt; _userCode then 
					continue;
				endif;
				
				if not addedSchema then
					self.qlbClassData.addItem(schema.name);
					self.qlbClassData.itemObject[self.qlbClassData.newIndex] := schema;
					self.qlbClassData.itemLevel[self.qlbClassData.newIndex] := 1;
					self.qlbClassData.itemExpanded[self.qlbClassData.newIndex] := false;
					addedSchema := true;
					schemaIndex := self.qlbClassData.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				if not addedClass then
					self.qlbClassData.addItem(class.name);
					self.qlbClassData.itemObject[self.qlbClassData.newIndex] := class;
					self.qlbClassData.itemLevel[self.qlbClassData.newIndex] := 2;
					self.qlbClassData.itemExpanded[self.qlbClassData.newIndex] := false;
					addedClass := true; 
					classIndex := self.qlbClassData.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				if not addedAttributes then
					self.qlbClassData.addItem("--Attributes--");
					self.qlbClassData.itemObject[self.qlbClassData.newIndex] := null;
					self.qlbClassData.itemLevel[self.qlbClassData.newIndex] := 3;
					self.qlbClassData.itemExpanded[self.qlbClassData.newIndex] := false;
					addedAttributes := true;
					attributeIndex := self.qlbClassData.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				if attribute.reason = DEV_SourceCompareReportAgent.Object_Missing then
					self.qlbClassData.addItem(attribute.name &amp; " - Missing");
				else
					self.qlbClassData.addItem(attribute.name &amp; " - Different");
				endif;
				
				if attribute.resolvedBy &lt;&gt; null then
					self.qlbClassData.itemForeColor[self.qlbClassData.newIndex] := Gray;
				else
					self.qlbClassData.itemForeColor[self.qlbClassData.newIndex] := Window.Color_WindowText;
				endif;
				
				self.qlbClassData.itemObject[self.qlbClassData.newIndex] := attribute;
				self.qlbClassData.itemLevel[self.qlbClassData.newIndex] := 4;
				self.qlbClassData.itemExpanded[self.qlbClassData.newIndex] := false;
				attributeCount += 1; //30.07.2025 navah1 #34749
			endforeach;
			
			foreach constant in class.allConstants do
				if not self.chkShowResolved.value and constant.resolvedBy &lt;&gt; null then
					continue;
				endif;
				
				if _userCode &lt;&gt; null and constant.modifiedBy &lt;&gt; _userCode then 
					continue;
				endif;
				
				if not addedSchema then
					self.qlbClassData.addItem(schema.name);
					self.qlbClassData.itemObject[self.qlbClassData.newIndex] := schema;
					self.qlbClassData.itemLevel[self.qlbClassData.newIndex] := 1;
					self.qlbClassData.itemExpanded[self.qlbClassData.newIndex] := false;
					addedSchema := true;
					schemaIndex := self.qlbClassData.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				if not addedClass then
					self.qlbClassData.addItem(class.name);
					self.qlbClassData.itemObject[self.qlbClassData.newIndex] := class;
					self.qlbClassData.itemLevel[self.qlbClassData.newIndex] := 2;
					self.qlbClassData.itemExpanded[self.qlbClassData.newIndex] := false;
					addedClass := true;
					classIndex := self.qlbClassData.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				if not addedConstants then
					self.qlbClassData.addItem("--Constants--");
					self.qlbClassData.itemObject[self.qlbClassData.newIndex] := null;
					self.qlbClassData.itemLevel[self.qlbClassData.newIndex] := 3;
					self.qlbClassData.itemExpanded[self.qlbClassData.newIndex] := false;
					addedConstants := true;
					constantIndex := self.qlbClassData.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				if constant.reason = DEV_SourceCompareReportAgent.Object_Missing then
					self.qlbClassData.addItem(constant.name &amp; " - Missing");
				else
					self.qlbClassData.addItem(constant.name &amp; " - Different");
				endif;
				
				if constant.resolvedBy &lt;&gt; null then
					self.qlbClassData.itemForeColor[self.qlbClassData.newIndex] := Gray;
				else
					self.qlbClassData.itemForeColor[self.qlbClassData.newIndex] := Window.Color_WindowText;
				endif;
				
				self.qlbClassData.itemObject[self.qlbClassData.newIndex] := constant;
				self.qlbClassData.itemLevel[self.qlbClassData.newIndex] := 4;
				self.qlbClassData.itemExpanded[self.qlbClassData.newIndex] := false;
				constantCount += 1; //30.07.2025 navah1 #34749
			endforeach;
			
			foreach reference in class.allReferences do
				if not self.chkShowResolved.value and reference.resolvedBy &lt;&gt; null then
					continue;
				endif;
				
				systemReference := systemClass.getProperty(reference.name).Reference;
				
				if (_userCode = null or _userCode &lt;&gt; null and reference.modifiedBy &lt;&gt; _userCode) and (systemReference = null or (systemReference &lt;&gt; null and systemReference.getModifiedByJMT &lt;&gt; _userCode)) then 
					continue;
				endif;
				
				if not addedSchema then
					self.qlbClassData.addItem(schema.name);
					self.qlbClassData.itemObject[self.qlbClassData.newIndex] := schema;
					self.qlbClassData.itemLevel[self.qlbClassData.newIndex] := 1;
					self.qlbClassData.itemExpanded[self.qlbClassData.newIndex] := false;
					addedSchema := true;
					schemaIndex := self.qlbClassData.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				if not addedClass then
					self.qlbClassData.addItem(class.name);
					self.qlbClassData.itemObject[self.qlbClassData.newIndex] := class;
					self.qlbClassData.itemLevel[self.qlbClassData.newIndex] := 2;
					self.qlbClassData.itemExpanded[self.qlbClassData.newIndex] := false;
					addedClass := true;
					classIndex := self.qlbClassData.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				if not addedReferences then
					self.qlbClassData.addItem("--References--");
					self.qlbClassData.itemObject[self.qlbClassData.newIndex] := null;
					self.qlbClassData.itemLevel[self.qlbClassData.newIndex] := 3;
					self.qlbClassData.itemExpanded[self.qlbClassData.newIndex] := false;
					addedReferences := true;
					referenceIndex := self.qlbClassData.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				if reference.reason = DEV_SourceCompareReportAgent.Object_Missing then
					self.qlbClassData.addItem(reference.name &amp; " - Missing");
				else
					self.qlbClassData.addItem(reference.name &amp; " - Different");
				endif;
				
				if reference.resolvedBy &lt;&gt; null then
					self.qlbClassData.itemForeColor[self.qlbClassData.newIndex] := Gray;
				else
					self.qlbClassData.itemForeColor[self.qlbClassData.newIndex] := Window.Color_WindowText;
				endif;
				
				self.qlbClassData.itemObject[self.qlbClassData.newIndex] := reference;
				self.qlbClassData.itemLevel[self.qlbClassData.newIndex] := 4;
				self.qlbClassData.itemExpanded[self.qlbClassData.newIndex] := false;
				referenceCount += 1; //30.07.2025 navah1 #34749
			endforeach;
			
			if attributeCount &gt; 0 then //30.07.2025 navah1 #34749 
				self.qlbClassData.itemText[attributeIndex] := app.getErrorString2(LabelWithValue, "--Attributes--", attributeCount.String);
			endif;
			
			if constantCount &gt; 0 then //30.07.2025 navah1 #34749 
				self.qlbClassData.itemText[constantIndex] := app.getErrorString2(LabelWithValue, "--Constants--", constantCount.String); 
			endif;
			
			if referenceCount &gt; 0 then //30.07.2025 navah1 #34749 
				self.qlbClassData.itemText[referenceIndex] := app.getErrorString2(LabelWithValue, "--References--", referenceCount.String);
			endif;
			
			total := referenceCount + constantCount + attributeCount; //30.07.2025 navah1 #34749
			if total &gt; 0 then //30.07.2025 navah1 #34749
				self.qlbClassData.itemText[classIndex] := app.getErrorString2(LabelWithValue, class.name, total.String);
				classCount += total;
			endif;
		endforeach; 
		
		if classCount &gt; 0 then //30.07.2025 navah1 #34749
			self.qlbClassData.itemText[schemaIndex] := app.getErrorString2(LabelWithValue, schema.name, classCount.String);
		endif;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_report" type="DEV_SourceCompareReport"/>
        <Parameter name="_userCode" type="String"/>
