    <JadeMethod name="showThumbnail" id="882fea15-b73e-4e01-a86d-b4be378184b3">
        <updating/>
        <source>showThumbnail(_status: CM_VoyageStatus) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
// 16/03/2018	jlgdap1		TFS 37540 PEL1 Voyage Statuses Pelindo 1
//
vars
	form : SOP_TableMaintForm;

begin
	form := self.myForm;
	form.tblInput1.clearValues();
	
	form.tblInput1.setValueByName(ETRow_Description, _status.description);
	form.tblInput1.setValueByName(ETRow_ReportToRun, _status.reportToRun);	//05 Jun 2018	NDL	TFS 38905
	form.tblInput1.setValueByName(ETRow_VoyageProcess, _status.myProcess.description);
	form.tblInput1.setValueByName(ETRow_AutoApplyStatus, _status.autoApplyStatus);
	if form.mode = form.Mode_View then
		form.tblInput1.setValueByName(ETRow_EmailOptions, _status.getDisplayStringForAttribute(ETRow_EmailOptions, false));
		form.tblInput1.setValueByName(ETRow_VoyageEvents, _status.getDisplayStringForAttribute(ETRow_VoyageEvents, false));
		form.tblInput1.setValueByName(ETRow_HmsResourcesEst, _status.getDisplayStringForAttribute(ETRow_HmsResourcesEst, false));
		form.tblInput1.setValueByName(ETRow_HmsResourcesApp, _status.getDisplayStringForAttribute(ETRow_HmsResourcesApp, false));	//01 Aug 2018	NDL	TFS 39900
	else
		form.tblInput1.setValueByName(ETRow_EmailOptions, app.getErrorString(Dbl_Click_To_Add_Update));
		form.tblInput1.setValueByName(ETRow_VoyageEvents, app.getErrorString(Dbl_Click_To_Add_Update));
		form.tblInput1.setValueByName(ETRow_HmsResourcesEst, app.getErrorString(Dbl_Click_To_Add_Update));
		form.tblInput1.setValueByName(ETRow_HmsResourcesApp, app.getErrorString(Dbl_Click_To_Add_Update));	//01 Aug 2018	NDL	TFS 39900
	endif;
	
	if form.myCurrentObject.CM_VoyageStatus.usesHMSResources then	// TFS 37540
		form.tblInput1.showRowByName(ETRow_HmsResourcesEst, false);
		form.tblInput1.showRowByName(ETRow_HmsResourcesApp, false);	//01 Aug 2018	NDL	TFS 39900
	else
		form.tblInput1.hideRowByName(ETRow_HmsResourcesEst, false);
		form.tblInput1.hideRowByName(ETRow_HmsResourcesApp, false);	//01 Aug 2018	NDL	TFS 39900
	endif;
	//epr TFS 51963 11/10/21
	if form.myCurrentObject.CM_VoyageStatus.isInvoiceGenerated then
		form.tblInput1.showRowByName(ETRow_AutoApplyStatus, false);	
	else
		form.tblInput1.hideRowByName(ETRow_AutoApplyStatus, false);
	endif;
	
	
	form.tblInput1.disableRowByName(ETRow_VoyageProcess);
epilog

end;</source>
        <Parameter name="_status" type="CM_VoyageStatus"/>
    </JadeMethod>
</Class>
