    <JadeMethod name="tblDrivers_dblClick" id="d10e4128-6797-445e-925c-7cfa12771268">
        <controlMethod name="Table::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDrivers_dblClick(table: Table input) updating;

begin
	if table.row &gt; table.fixedRows and
	   table.row &lt;= table.rows and
	   table.selectedCount &gt; 0
	then
		self.doSelectProfile;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblDrivers_mouseDown" id="b6f813f0-366d-4b28-bb85-7a55a4944f1b">
        <controlMethod name="Table::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDrivers_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;

vars
	r, c, errNo, i : Integer;
	errTxt : String;
	obj : Object;
	
begin
	self.mySelectedCmdTarget := null;
	
	table.clearAllSelected;
	
	if not table.getCellFromPosition(x, y, r, c) then
		return;
	endif;

	if r &lt; 1 or r &lt;= table.fixedRows or r &gt; table.rows then
		return;
	endif;
	table.row := r;

	foreach i in table.columns to 1 step -1 do
		table.column := i;
		table.selected := true;
	endforeach;

	obj := table.accessCell(r, 1).itemObject;
	if obj = null or (not DriverDescriptor.hasInstance(obj)) then
		return;
	endif;

	errNo := 0;
	on Exception do app.resumeNextExHandler(exception, errNo, errTxt);

	self.mySelectedCmdTarget := obj.DriverDescriptor.getCommandTarget;

	if errNo &lt;&gt; 0 then
		self.mySelectedCmdTarget := null;
		return;
	endif;

	if button = Window.MouseButton_Right then
		self.popupMenu(self.mnuDrvPop, (table.left + x).Integer, (table.top + y).Integer);
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblDrivers_paint" id="332f0041-54e5-415e-a971-480eb7daa4d0">
        <controlMethod name="Table::paint"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDrivers_paint(table: Table input) updating;

begin
	self.tblDrivers.drawLine(0, 0, self.clientWidth, 0, Black);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblStats_contextMenu" id="b3f54893-cd08-4cd6-b97d-9ecd047b4fb6">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblStats_contextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

begin
	self.popupMenu(self.mnuStats, (cntrl.left + x).Integer, (cntrl.top + y).Integer);
	return true;
end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
