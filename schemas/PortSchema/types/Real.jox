    <JadeMethod name="isBetween" id="6c1494af-a4c9-42e2-b43d-0443902ebfc6">
        <source>isBetween(_min:Real; _max:Real):Boolean;
// --------------------------------------------------------------------------------
// Created:		17 November 2010
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is within
//				a range of real numbers.
//
// Parameters:	_min - The minimum range value.
//				_max - The maximum range value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//				cnwdad1		Initial creation.
// --------------------------------------------------------------------------------
begin
	//29/12/2010 cnwdz2	26686
	if _min &lt;= _max then
		if self &gt;= _min and self &lt;= _max then
			return true;
		endif;
	elseif _min &gt; _max then
		if self &gt;= _max and self &lt;= _min then
			return true;
		endif;
	endif;
	
	return false;
end;</source>
        <Parameter name="_min" type="Real"/>
        <Parameter name="_max" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidTemp" id="c442f3f7-4ad0-44ae-bb64-af45b55a8a12">
        <source>isValidTemp() : Boolean;
// ---------------------------------------------------------------------------
// Created:     05 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	temp	: Real;
	
begin

	temp := self * 10;
	temp := temp - temp.Integer;
	temp := temp.abs;
	
	if temp &lt; 0.001 then
		return true;
	endif;

	return false;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jMTRoundedTo" id="62dd65be-a782-427a-9a07-df375c9190e4">
        <source>jMTRoundedTo(_decimalPlaces : Integer) : Real;
// from 20598 invoice rounding, not all nn.nn5 Real values round up correctly - adding .0001 seems to always do the trick
vars

begin
	return (self + 0.0001).roundedTo(_decimalPlaces);
end;
</source>
        <Parameter name="_decimalPlaces" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
