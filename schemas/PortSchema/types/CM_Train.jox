    <JadeMethod name="setForCreate" id="c8c301d0-b06a-4b96-954b-6c604dc02589">
        <updating/>
        <source>setForCreate(_pxyTrain : CM_Train; _trainArrivalEvent, _trainDepartEvent : CMEVT_TrainTransaction output) updating;
/*
----------   ----------  --------------------------------------------------
Created:	06 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
//16 Dec 2013	cnwrs1	Par 33035 - add CamsDateTime to CM_EventTransaction
*/
vars

begin

	self.setForUpdate(_pxyTrain, _trainArrivalEvent, _trainDepartEvent);
	
	self.myTerminal := _pxyTrain.myTerminal;
	self.myTerminalDeparted := _pxyTrain.myTerminalDeparted;

	
	
	if app.myPassport.isOpsViewEnabled(self.myTerminal) then // ### TFS 51855 05JAN2022 NAVAB1
		self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_TRAIN, self); // ### TFS 51855 05JAN2022 NAVAB1
	endif;

	create self.myJobSheet;
end;


</source>
        <Parameter name="_pxyTrain" type="CM_Train"/>
        <Parameter name="_trainArrivalEvent" type="CMEVT_TrainTransaction" usage="output"/>
        <Parameter name="_trainDepartEvent" type="CMEVT_TrainTransaction" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="2187f8ec-a7a5-42e9-8bab-0fcf72aad764">
        <updating/>
        <source>setForUpdate(_pxyTrain : CM_Train; _trainArrivalEvent, _trainDepartEvent : CMEVT_TrainTransaction output) updating;
/*
----------   ----------  --------------------------------------------------
Created:	06 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
16 Dec 2013	cnwrs1		 Par 33035 - add CamsDateTime to CM_EventTransaction
02 Oct 2020 cnwma1 		 ChangeRequest 50112: ASPA - GCI Stevedores
*/
vars
	wag 		   : CM_Wagon;
	arrivalChanged : Boolean;
	wagControl 	   : CMIF_WagonMoveController;
	oldExchangeCompleteTS : TimeStamp;
	trainTrx : CMEVT_TrainTransaction;
	isUpdate : Boolean;
begin
	isUpdate := _pxyTrain.pxyGetRealObject() &lt;&gt; null; // ### TFS 51855 06JAN2022 NAVAB1
	
	self.code					:= _pxyTrain.code;
	self.description			:= _pxyTrain.description;
	
	if self.arrivalDT &lt;&gt; _pxyTrain.arrivalDT then	// 02 Nov 2009	NDL Par 21519
		if _pxyTrain.arrivalDT &lt;&gt; null then	// 02 Nov 2009	NDL Par 21519
			_trainArrivalEvent := self.createTransaction(EVT_TrainArrive, _pxyTrain.arrivalDT, null,null,null);	// 02 Nov 2009	NDL Par 21519 // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		endif;
		self.arrivalDT := _pxyTrain.arrivalDT;

		// PAR 26564 This wagon was inward on train A but is being edited to be outward on train B.
		 // 				Train B has a jobsheet of release jobs, the jobs need to be moved to the rail area job sheet so that they can be worked.
		if self.myJobSheet &lt;&gt; null // train job sheet is only used for planning release jobs
		and not self.myJobSheet.allJobsByOrder.isEmpty() then // still has release jobs
			foreach wag in self.allWagonsByOrderOutward discreteLock do
				if wag.confirmed then // INWARD
					create wagControl transient; 
					wagControl.myTargetRailLine := wag.myRailLine;
					wagControl.allWagons.add(wag);
					wagControl.autoSetEffectiveTimeStamp();	//26 Feb 2021	NDL	TFS 50837
					self.moveOutwardJobsToRail(wagControl, app.myPassport);
				endif;
			endforeach;
		endif;
	endif;
	
	if self.departureDT &lt;&gt; _pxyTrain.departureDT then	// 02 Nov 2009	NDL Par 21519
		if _pxyTrain.departureDT &lt;&gt; null then	// 02 Nov 2009	NDL Par 21519
			_trainDepartEvent := self.createTransaction(EVT_TrainDepart, _pxyTrain.departureDT, null,null,null);	// 02 Nov 2009	NDL Par 21519 // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		endif;
		self.departureDT := _pxyTrain.departureDT;
	endif;
	
	self.myOriginPort			:= _pxyTrain.myOriginPort;
	self.myDestinationPort		:= _pxyTrain.myDestinationPort;
	self.status					:= _pxyTrain.status;			  //navsp1 16MAY2022 TFS#53619
	
	//double check of integrity to prevent orphanage of train
	if _pxyTrain.myTerminal = null and _pxyTrain.myTerminalDeparted = null then
		//app.raiseUnexpectedProgramError(class.name, method.name, 'No terminal reference set.'); //- cnwmd1, CCMS 1067, Par 19710
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(Terminal_reference_set)); //+ cnwmd1, CCMS 1067, Par 19710
	endif;
	
	//cnwrd1 par 19710 20.5.09 -  ccms 1067
	
	self.colour 		:= _pxyTrain.colour;
	self.maxHeight		:= _pxyTrain.maxHeight;
	self.maxWidth		:= _pxyTrain.maxWidth;
	self.maxWeight		:= _pxyTrain.maxWeight;
	self.noEmptyWagons := _pxyTrain.noEmptyWagons; // PAR 23176
	self.scheduleCode	:= _pxyTrain.scheduleCode;
	self.portArrivalDT	:= _pxyTrain.portArrivalDT;
	self.shunterInDT	:= _pxyTrain.shunterInDT;
	self.shunterOutDT	:= _pxyTrain.shunterOutDT;
	self.myCarrier		:= _pxyTrain.myCarrier;
	self.myTrackClearance := _pxyTrain.myTrackClearance;	// NDL 26 Jun 2009	CCMS 1067
	
	//+ 26/05/2009, cnwmd1, CCMS 1067, Par 19710
	self.scheduledArrivalDT		:= _pxyTrain.scheduledArrivalDT;
	self.scheduledDepartureDT	:= _pxyTrain.scheduledDepartureDT;
	self.cargoExchangeStartTS	:= _pxyTrain.cargoExchangeStartTS;
	oldExchangeCompleteTS := self.cargoExchangeEndTS;
	self.cargoExchangeEndTS		:= _pxyTrain.cargoExchangeEndTS;
	if (not self.cargoExchangeEndTS.isValid) then	//31 May 2021	NDL	TFS 51243
		self.cargoExchangeEndTS := null;
	endif;
	self.remarks				:= _pxyTrain.remarks;

	//+cnwml2 PAR23715 SFW CCMS1131
	self.sealCheckReceival := _pxyTrain.sealCheckReceival;
	self.sealCheckRelease := _pxyTrain.sealCheckRelease;
	
	self.myStevedoreReceive		:= _pxyTrain.myStevedoreReceive;  //02.10.2020 cnwma1 TFS #50112
	self.myStevedoreRelease		:= _pxyTrain.myStevedoreRelease;  //02.10.2020 cnwma1 TFS #50112
	
	//14 May 2021	NDL	TFS 51199
	trainTrx := self.allTransactions.getFirstOfType(EVT_TrainExchangeCompleted).CMEVT_TrainTransaction;
	if trainTrx = null and self.cargoExchangeEndTS.Date.isValid then
		trainTrx := self.createTransaction(EVT_TrainExchangeCompleted, self.cargoExchangeEndTS, null,null,null); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	elseif trainTrx &lt;&gt; null and oldExchangeCompleteTS &lt;&gt; self.cargoExchangeEndTS then
		if self.cargoExchangeEndTS &lt;&gt; null then
			trainTrx.updateDateTimeUser( self.cargoExchangeEndTS, app.myPassport.userCode );
		endif;
	endif;
	
	
	if isUpdate
	and app.myPassport.isOpsViewEnabled(self.myTerminal) then // ### TFS 51855 05JAN2022 NAVAB1
		self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_TRAIN, self); // ### TFS 51855 05JAN2022 NAVAB1
	endif;

epilog
	delete wagControl;
	end;
</source>
        <Parameter name="_pxyTrain" type="CM_Train"/>
        <Parameter name="_trainArrivalEvent" type="CMEVT_TrainTransaction" usage="output"/>
        <Parameter name="_trainDepartEvent" type="CMEVT_TrainTransaction" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="86416833-33ea-4ab1-856f-be2c081c693a">
        <updating/>
        <source>setProxy(_code,
		_description 			: String;
		_arrivalDT,
		_depatureDT				: TimeStamp;
		_originPort,
		_destPort				: CM_Port;
		_terminal				: CM_Terminal;
		_colour					: Integer;
		_status					: Integer;
		_maxHeight				: Decimal;
		_maxWidth				: Decimal;
		_maxWeight				: Integer;
		_scheduleCode			: String;
		_portArrivalDT			: TimeStamp;
		_shunterInDT			: TimeStamp;
		_shunterOutDT			: TimeStamp;
		_myCarrier				: CM_Carrier;
		_scheduledArrivalDT		: TimeStamp;
		_scheduledDepartureDT	: TimeStamp;
		_cargoExchangeStartTS	: TimeStamp;
		_cargoExchangeEndTS		: TimeStamp;
		_remarks				: String;
		_myTrackClearance		: CM_TrackClearance;
		_noEmptyWagons 			: Boolean;
		_stevedoreReceive       : CM_Stevedore;
		_stevedoreRelease       : CM_Stevedore
		) updating;
/*
----------   ----------  --------------------------------------------------
Created:	06 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
cnwrd1 					 par 19710 20.5.09 -  ccms 1067
02 Oct 2020 cnwma1 		 ChangeRequest 50112: ASPA - GCI Stevedores
----------   ----------  --------------------------------------------------
*/
vars
	realMe : CM_Train;
begin
	self.code				:= _code;
	self.description		:= _description;
	
	self.arrivalDT			:= _arrivalDT;
	self.departureDT		:= _depatureDT;
	self.myOriginPort		:= _originPort;
	self.myDestinationPort	:= _destPort;
	self.status				:= _status;	//navsp1 17MAY2022 TFS#53619
	realMe := self.pxyGetRealObject();
	if realMe &lt;&gt; null then // if update then LEAVE ALONE
		self.myTerminal := realMe.myTerminal;
		self.myTerminalDeparted := realMe.myTerminalDeparted;
	else	 // Creating so only set  not arrived
		self.myTerminal := _terminal;
		self.myTerminalDeparted := null;
	endif;
	
	//cnwrd1 par 19710 20.5.09 -  ccms 1067

	self.colour 		  := _colour;
	self.maxHeight		  := _maxHeight;
	self.maxWidth	 	  := _maxWidth;
	self.maxWeight		  := _maxWeight;
	self.scheduleCode	  := _scheduleCode;
	self.portArrivalDT	  := _portArrivalDT;
	self.shunterInDT  	  := _shunterInDT;
	self.shunterOutDT	  := _shunterOutDT;
	self.myCarrier		  := _myCarrier;
	self.myTrackClearance := _myTrackClearance;	// 26 Jun 2009	NDL	CCMS 1067
	self.noEmptyWagons    := _noEmptyWagons; // PAR 23176
	
	//+ 26/05/2009, cnwmd1, CCMS 1067, Par 19710
	self.scheduledArrivalDT		:= _scheduledArrivalDT;
	self.scheduledDepartureDT	:= _scheduledDepartureDT;
	self.cargoExchangeStartTS	:= _cargoExchangeStartTS;
	self.cargoExchangeEndTS		:= _cargoExchangeEndTS;
	self.remarks				:= _remarks;
	self.myStevedoreReceive     := _stevedoreReceive;      //02.10.2020 cnwma1 TFS #50112
	self.myStevedoreRelease     := _stevedoreRelease;      //02.10.2020 cnwma1 TFS #50112
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_arrivalDT" type="TimeStamp"/>
        <Parameter name="_depatureDT" type="TimeStamp"/>
        <Parameter name="_originPort" type="CM_Port"/>
        <Parameter name="_destPort" type="CM_Port"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_maxHeight" type="Decimal"/>
        <Parameter name="_maxWidth" type="Decimal"/>
        <Parameter name="_maxWeight" type="Integer"/>
        <Parameter name="_scheduleCode" type="String"/>
        <Parameter name="_portArrivalDT" type="TimeStamp"/>
        <Parameter name="_shunterInDT" type="TimeStamp"/>
        <Parameter name="_shunterOutDT" type="TimeStamp"/>
        <Parameter name="_myCarrier" type="CM_Carrier"/>
        <Parameter name="_scheduledArrivalDT" type="TimeStamp"/>
        <Parameter name="_scheduledDepartureDT" type="TimeStamp"/>
        <Parameter name="_cargoExchangeStartTS" type="TimeStamp"/>
        <Parameter name="_cargoExchangeEndTS" type="TimeStamp"/>
