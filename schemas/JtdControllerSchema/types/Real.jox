<PrimType name="Real">
    <JadeMethod name="asTimeStringFromSeconds" id="3f9c87c4-a684-41b8-bfb0-874c2110721e">
        <source>asTimeStringFromSeconds() : String;

vars
	hours, mins : Integer;
	secs : Real;
	
begin
	secs := self;
	
	hours := secs div 3600;
	secs := secs mod 3600;

	mins := secs div 60;
	
	secs := (secs mod 60).roundedSeconds;
	
	return hours.String &amp; 'h ' &amp; mins.String &amp; 'm ' &amp; secs.String &amp; 's';
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="roundedSeconds" id="968fdf6f-1168-4716-bae3-ca2b5ae3ff4b">
        <source>roundedSeconds() : Real;

begin
	if self &lt; 0 then
		return self.roundedTo(1);
	endif;
	
	if self &lt; 1000 then
		return self.roundedTo(2);
	endif;
	
	if self &lt; 10000 then
		return self.roundedTo(1);
	endif;
	
	return self.roundedTo(0);
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
</PrimType>
