    <JadeMethod name="utlUpdateFutureStorageDays" id="24f9f479-74f2-4d88-b300-730d84fa4172">
        <updating/>
        <source>utlUpdateFutureStorageDays(_ti 			   		 : CM_TrackedItem input;
					  _additionalStorageDays : Integer;
					  _changeReason          : String;
					  _passport 			 : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2023 navmv20 CR 58373 Task 58381: Jade - Future Storage Additional Days
20 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
*/

vars
	newTITransaction	: CM_TITransaction;
	ti 					: CM_TrackedItem;
	plannedDTOld,
	plannedDTNew,
	plannedDT           : TimeStamp;
	tiTrxDetails 		: String;
	freeStorageExpiry 	: Date;
	storageDetail       : CM_StorageDetail;
	additionalDays,
	additionalDaysOld   : Integer;
	editTransaction     : CM_Edit;
	storageExp : CM_StorageExpiryDetail;
begin
	self.initialiseActivity();
	
	if _ti = null then
		app.raiseCMException2(MethodWithNullParam, method.name, app.getErrorString(Container), null, null);
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	app.myValUA.valFutureStorageDays(_ti,_additionalStorageDays);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	plannedDTNew := null;
	plannedDT := null;
	plannedDTOld := null;
	
	if _ti.isFutureStorage(storageDetail) 
	and _ti.isOnSite() then
		plannedDTOld.setDate(_ti.getFutureStorageAnniversary());
			
		if plannedDTOld = null then
			freeStorageExpiry := _ti.getFreeStorageExpiryDate();
			_ti.setFutureStorageAnniversary(freeStorageExpiry,storageDetail,false);
		endif;
					
		plannedDT := plannedDTOld.cnEcAddDays(_additionalStorageDays);
		_ti.setFutureStorageAnniversary(plannedDT.date,storageDetail,true);
		_ti.createFutureStorageBGPActor(_ti.getFutureStorageAnniversary(), null, true,storageDetail, false);
			
		plannedDTNew.setDate(_ti.getFutureStorageAnniversary());
			
		tiTrxDetails := app.formatForEditTransaction(app.getErrorString(Future_storage_anniversar),
														 plannedDTOld.asStringJMT(),
														 plannedDTNew.asStringJMT())&amp; " ( " &amp; _additionalStorageDays.String &amp; " " &amp; app.getErrorString(Additi_future_storag_days_adde)&amp;" ) " ;
		editTransaction :=app.createEditTransaction(_ti, tiTrxDetails, null, app.myPassport);			//20.02.2024 navhl20 #62525
		tiTrxDetails:=app.formatForEditTransaction(app.getErrorString(Change_reason)," ",_changeReason);
		editTransaction.fieldsValues.add(tiTrxDetails);
		
		// CR 58373 Task 58381 - NAVAB1 25OCT2023
		storageExp := _ti.getStorageExpiryDetail();
		if storageExp &lt;&gt; null then
			storageExp.setFutureStorageAdditionalDtls(_additionalStorageDays,_changeReason);
			storageExp.updateObjectEdition(_ti); //21/01/2025	navkc1 JIRA Bug MTN-33812
		endif;
	endif;
		
	_passport.doDeferredUpdates();
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_additionalStorageDays" type="Integer"/>
        <Parameter name="_changeReason" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateGCAllocGroupLabel" id="fe5e250b-2b14-405a-8ba5-5e0da10c4b3b">
        <updating/>
        <source>utlUpdateGCAllocGroupLabel(_gcAllocGroup : CM_GeneralCargoAllocGroup input; _label : String; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	terminal : CM_Terminal;

begin
	self.initialiseActivity();
	
	if _gcAllocGroup = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Terminal Area is null');
		return;
	endif;
	if _gcAllocGroup.isTransient then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Terminal Area is transient');
		return;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_gcAllocGroup.myTerminalArea, true);
	endif;
	
	if _passport.noErrors then
		_gcAllocGroup.updateRangeLabel(_label);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_gcAllocGroup.myTerminalArea, false);
		// tell the Satellite View Screen to redraw itself to show the label
		terminal := _gcAllocGroup.myTerminalArea.myTerminal;
		_gcAllocGroup.myTerminalArea.causeEvent(terminal.getTerminalEvent(Event_TerminalAreaUpdate), false, _gcAllocGroup.myTerminalArea);
	endif;

epilog

end;</source>
        <Parameter name="_gcAllocGroup" type="CM_GeneralCargoAllocGroup" usage="input"/>
        <Parameter name="_label" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateGCAllocTAFromYA" id="e828bf3b-9974-458c-b862-a91430bd5147">
        <source>utlUpdateGCAllocTAFromYA(_terminalArea : CM_TerminalArea; _yardAllocation : CM_YardAllocation; _tis : CM_TIArray; _newGroups : StringArray; _passport : CM_Passport input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
// 16/07/2020	jlgdap1		TFS 49783 ASPA Graphical Display
// 10/12/2020	jlgdap1		TFS 50110 ASPA General Cargo Allocation Row - Label
//								New parameters, fix up group labels, moving of TIs and new group boundaries
// 18/06/2021	navdap1		TFS 51094 MTN GC Row YA Creation Crash
//
vars
	gcArea, pxyGCArea : CM_GeneralCargoAllocRowArea;
	str : String;
	allControllers, allControllersInYAs, allControllersNotInYAs : CM_LCByIdExtKeyDict;
	ya : CM_YardAllocation;
	block : CM_YABlock;
	lc, lastLC : CM_LocationsController;
	groupsById : CM_RowControllerByIdNoDupsDict;
	rc : CM_RowController;
	aNewGroup : CM_GeneralCargoAllocGroup;
	groupIDs, newGroups, newColumns : StringArray;
	groupsMatch : Boolean;
	iter : Iterator;
	dupLC : CM_LocationsController;
	sorter : CnEcSorter;					// TFS 50110
	
begin
	gcArea := _terminalArea.CM_GeneralCargoAllocRowArea;
	
	// We have a new or changed yard allocation associated with a General Cargo Allocation area
	// See if we need to change any divisions between columns in the terminal area
	// Yard allocations in General Cargo Allocation areas can't overlap each other.
	// So if the blocks in all the allocations over this area match the columns in the area, nothing needs to be done
	// e.g. Terminal Area has 10 columns labelled 01,02,03...10
	// Current groups in this area are 01-04, 05-07, 08-10
	// The terminal area has 3 yard allocations over it
	// The yard controllers for the yard allocations are 01,02,03,04 then 05,06,07 then 08,09,10
	// In this case we wouldn't have to do anything, because the groups match the yard allocation areas
	
	// Get all the terminal area's location controllers (columns)
	create allControllers transient;
	create allControllersInYAs transient;
	create allControllersNotInYAs transient;
	create groupIDs transient;
	create groupsById transient;	
	gcArea.getAllLocationsControllersById(allControllers);
	
	// Get all the controllers (columns) included in yard allocations
	// And the group IDs that would match these allocations
	foreach ya in gcArea.allYardAllocations do
		foreach block in ya.allYABlocksIn where block.myTerminalArea = gcArea do
			// TFS 49783 Check for range overlaps
			foreach dupLC in block.allYardControllers do
				if allControllersInYAs.includesObject(dupLC) then
					app.raiseCMException(YAM_Msg_OverlapingRanges, null, null);
					return;
				endif;
			endforeach;
			// TFS 49783
			block.allYardControllers.copy(allControllersInYAs);
			if block.allYardControllers.size = 1 then
				//groupIDs.add(block.allYardControllers.first.ident);
				create aNewGroup transient;
				aNewGroup.setDetails(block.allYardControllers.first.ident, null);
				groupsById.add(aNewGroup);
			elseif block.allYardControllers.size &gt; 1 then
				//groupIDs.add(block.allYardControllers.first.ident &amp; Hyphen &amp; block.allYardControllers.last.ident);
				create aNewGroup transient;
				aNewGroup.setDetails(block.allYardControllers.first.ident &amp; Hyphen &amp; block.allYardControllers.last.ident, null);
				groupsById.add(aNewGroup);
			endif;
		endforeach;
	endforeach;
	foreach rc in groupsById do
		aNewGroup := rc.CM_GeneralCargoAllocGroup;
		groupIDs.add(aNewGroup.id);
	endforeach;
	
	// Get any controllers that aren't covered by yard allocations
	foreach lc in allControllers do
		if not allControllersInYAs.includesObject(lc) then
			allControllersNotInYAs.add(lc);
			// and add the existing groups these lcs are in to the array of current groups	// TFS 50110
			if not groupIDs.includes(lc.CM_GeneralCargoAllocController.myGroup.id) then		// TFS 50110
				groupIDs.add(lc.CM_GeneralCargoAllocController.myGroup.id);					// TFS 50110
			endif;																			// TFS 50110
		endif;
	endforeach;
	
	// sort the current and new group labels by first column								// TFS 50110
	create sorter transient;																// TFS 50110
	sorter.setSortType(CnEcSorter.AS_STRING, false);										// TFS 50110
	groupIDs.doSort(sorter);																// TFS 50110
	
	// See if the group IDs from yard allocations match the current groups in the terminal area
	groupsMatch := true;
	// does every group id still match
	foreach str in groupIDs do
		if gcArea.allRowControllersById[str] = null then
			groupsMatch := false;
		endif;
	endforeach;
	if groupsMatch then
		// Nothing to do - the groups of columns from all yard allocations still matches the groups defined in the area
		return;
	endif;
	
	// Now need to build the new groups, based on the yard allocations and columns that aren't in yard allocations
	// Use the collections of columns in YAs and columns not in YAs to derive the new group boundaries,
	// but also need to take account of current group boundaries
	// TFS 51094 completely rewrite and simplify this bit
	create newGroups transient;
	foreach lc in allControllers do
		// if this column is in a YA and the last one wasn't, this is the start of a new group
		if allControllersInYAs.includesObject(lc) and lastLC &lt;&gt; null and allControllersNotInYAs.includesObject(lastLC) then
			newGroups.add(lc.ident);
		endif;
		// if this column isn't in a YA and the last one was, this is also the start of a new group
		if allControllersNotInYAs.includesObject(lc) then 
			if lastLC &lt;&gt; null and allControllersInYAs.includesObject(lastLC) then
				newGroups.add(lc.ident);
			else
				// is this column the start of an existing group?
				if gcArea.allRowControllersById[lc.CM_GeneralCargoAllocController.myGroup.id] &lt;&gt; null 
				and lc = lc.CM_GeneralCargoAllocController.myGroup.CM_GeneralCargoAllocGroup.allLocations.first 
				and not newGroups.includes(lc.ident) then
					newGroups.add(lc.ident);
				endif;
			endif;
		endif;
		lastLC := lc;
	endforeach;
	// if the first lc is in the newGroups array, remove it - can't have a group boundary before the first column!
	lc := allControllers.first;
	if newGroups.includes(lc.ident) then
		newGroups.remove(lc.ident);
	endif;
	// TFS 51094 end
	
	str := gcArea.getDisplayStringForAttribute(ETRow_ColumnLabels, false);
	create newColumns transient;
	str.convertToDelimitedArray(Comma, newColumns);
	
	// Now we can build a proxy terminal area based on the columns and dividers
	pxyGCArea := gcArea.pxyCreateUpdateProxy;
	pxyGCArea.createProxyLCsAndGroups(newColumns, newGroups);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(gcArea, true);
	endif;
	
	// And finally do the update
	//gcArea.setForUpdate(pxyGCArea);								// TFS 50110
	gcArea.setForUpdateAllocArea(pxyGCArea, _tis, _newGroups);		// TFS 50110
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(gcArea, false);
	endif;
	
epilog
	delete allControllers;
	delete allControllersInYAs;
	delete allControllersNotInYAs;
	delete newGroups;
	groupsById.purge;
	delete groupsById;
	delete newColumns;
	delete pxyGCArea;
	delete iter;
	delete sorter;				// TFS 50110
	delete groupIDs; //07 Apr 2021	NDL	TFS 49912 - transient leak
end;</source>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_yardAllocation" type="CM_YardAllocation"/>
        <Parameter name="_tis" type="CM_TIArray"/>
        <Parameter name="_newGroups" type="StringArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateGCHoldLocnDefn" id="b6deddbe-d627-4636-851e-68d48875928a">
        <updating/>
        <source>utlUpdateGCHoldLocnDefn( _proxy : CM_GCHoldLocationDefn input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2013	cnwndl1	Initial creation	Par 31965

*/

vars
	real : CM_GCHoldLocationDefn;
	expectedEdition : Integer;

begin

	self.initialiseActivity();


	app.setContinueCMExceptions(true);
	app.myValUA.valGCHoldLocnDefn(_proxy);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	_proxy.pxyGetRealObjectAndEdition(real, expectedEdition);
	
	if real = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_GCHoldLocationDefn.name, null, null);
		return;
	endif;

	exclusiveLock(real);

	if _passport.noErrors and real.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'GCHoldLocationDefn', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(real, true);
	endif;
	
	if _passport.noErrors then
		real.setForUpdate( _proxy );
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(real, false);
	endif;

end;</source>
        <Parameter name="_proxy" type="CM_GCHoldLocationDefn" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateGLCode" id="f6ddbefa-d385-4454-b891-49d757e4767f">
        <source>utlUpdateGLCode(pProxyGLCode : CM_GLCode; 	_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	cancelSave		: Boolean;
	realGLCode	: CM_GLCode;
	expectedEdition	: Integer;
	
begin

	self.initialiseActivity();

	pProxyGLCode.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyGLCode.pxyGetRealObjectAndEdition(realGLCode, expectedEdition);
	
	if realGLCode = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_GLCode.name, null, null);
		return;
	endif;

	app.myValUA.valGLCode(realGLCode, pProxyGLCode);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realGLCode);

	if _passport.noErrors and realGLCode.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Cargo Type', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realGLCode, true);
	endif;
	
	if _passport.noErrors then
		realGLCode.setForUpdate(pProxyGLCode);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realGLCode, false);
	endif;

end;</source>
        <Parameter name="pProxyGLCode" type="CM_GLCode"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateGTERelRemoveToDo" id="7c2a959e-5292-460e-b5aa-f8e1561c7ece">
        <updating/>
        <source>utlUpdateGTERelRemoveToDo(_pxyGTE : CMGTE_Receival input;_taskDesc: CM_ToDoTaskDesc;_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2018	jlgns1	Initial creation
28/11/2018   	JLGNS1	ChangeRequest 39691: SNO- VGM Gate Process
*/

//
// ---------------------------------------------------------------------------
vars
	realGTE		: CMGTE_Receival;	
begin

	self.initialiseActivity();
		
	// do validation
		
	self.raiseExceptionIfNull(_pxyGTE, 'GTE Receival');

	_pxyGTE.allToDoTasks.removeIfPresent(_taskDesc);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	realGTE := self.getRealObjectAndEditionCheck(_pxyGTE, 'GTE Receival', _passport).CMGTE_Receival;

	if _passport.noErrors then
		// do updates
		realGTE.setForUpdate(_pxyGTE,_pxyGTE.myVehicleVisitRecord);
	endif;

	

end;</source>
        <Parameter name="_pxyGTE" type="CMGTE_Receival" usage="input"/>
        <Parameter name="_taskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateGate" id="a861e947-b78c-470e-a5fa-d0267c9d1c50">
        <source>utlUpdateGate(_proxy :CM_Gate; _passport :CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     15 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gate			: CM_Gate;
	expectedEdition : Integer;
	lanesChanged	: Boolean;
begin
	self.initialiseActivity();
	
	_proxy.raiseExceptionIfNotProxy(method);
	
	_proxy.pxyGetRealObjectAndEdition(gate, expectedEdition);
		
	if gate = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Gate.name, null, null);
		return;
	endif;

	if expectedEdition &lt; 1 then
		app.raiseCMException2(ExpectedEditionInvalid, expectedEdition.String, method.name, null, null);
		return;
	endif;

	app.setContinueCMExceptions(true);
	app.myValUA.valCM_Object(_proxy, _passport); 

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	exclusiveLock(gate);

	if _passport.noErrors then
		if expectedEdition &lt;&gt; gate.edition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, CM_Gate.name, null, null);
			return;
		endif;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(gate, true);
	endif;
	
	// determine whether we need to do a causeEvent to notify application of changes to lanes
	lanesChanged := _proxy.pxyHaveGateLanesChanged;
	
	if _passport.noErrors then
		gate.setForUpdate(_proxy);
	
		if _passport.noErrors then
			// if any notifications are required they go here
		endif; 
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(gate, false);
		
		if lanesChanged then
			gate.causeEvent(gate.myTerminal.getTerminalEvent(Event_GateLane_Change), false, gate);
		endif;
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_GATE_UPDATE), false, gate);
	endif;	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_Gate"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateGateLaneControllers" id="6a24c654-5c37-4dc4-ac6b-d12e5e83f7c6">
        <source>utlUpdateGateLaneControllers(	_pxyVTA  : CM_VehicleTransferArea input;
								_allGateLaneControllers : CM_GateLaneControllerArray;
								_passport : CM_Passport input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
02 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	pNewGateLaneController,
	realGateLaneController,
	glc : CM_GateLaneController;
	edition : Integer;
	realVTA	: CM_VehicleTransferArea;
	glcDeleteSet : CM_GateLaneControllerArray;
	cannotDeleteNum : Integer;
	laneChanged : Boolean; //cnwgb1 23 May 2008 PAR 16483
	sendNote : Boolean; //cnwgb1 20 May 2008 PAR 16483
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	_pxyVTA.pxyGetRealObjectAndEdition(realVTA, edition);

	if realVTA = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_VehicleTransferArea.name, null, null);
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	if realVTA.allGateLaneControllers.size  &gt; _allGateLaneControllers.size	then
	// delete the last one
		cannotDeleteNum:=0;
		create glcDeleteSet transient;
		foreach glc in realVTA.allGateLaneControllers reversed do
			if realVTA.allGateLaneControllers.size = (_allGateLaneControllers.size + glcDeleteSet.size + cannotDeleteNum) then
				break;
			else
				if glc.allVehicleMachines.size &gt; 0 then 	
					app.raiseCMWarning2(ObjectStillHasEntries, "Gate Lane " &amp; glc.ident, "Vehicles", null, null, glc);
					cannotDeleteNum:=cannotDeleteNum + 1;
					continue;
				endif;
				glcDeleteSet.add(glc);
			endif;				
		endforeach;	
	endif;
	
	sendNote := true; // cnwgb1 23 May 2008 PAR 16483 modified...
	foreach pNewGateLaneController in _allGateLaneControllers do
		realGateLaneController:=null;
		pNewGateLaneController.pxyGetRealObjectAndEdition(realGateLaneController,edition);
		if realGateLaneController = null then
			create realGateLaneController persistent;
			realGateLaneController.setForCreate(pNewGateLaneController,realVTA);
			laneChanged := true;
		else
			laneChanged := realGateLaneController.isDirectionDifferent( pNewGateLaneController );
			realGateLaneController.setForUpdate(pNewGateLaneController,realVTA);
		endif;
		if laneChanged and sendNote then
			realVTA.causeEvent(realGateLaneController.myTerminal.getTerminalEvent(Event_GateLane_Change), false, realVTA);
			sendNote := false;
		endif;
	endforeach; // ...cnwgb1 23 May 2008 PAR 16483 modified
	


epilog
	if glcDeleteSet &lt;&gt; null then
		glcDeleteSet.purge;
		delete glcDeleteSet;
	endif;
end;</source>
        <Parameter name="_pxyVTA" type="CM_VehicleTransferArea" usage="input"/>
        <Parameter name="_allGateLaneControllers" type="CM_GateLaneControllerArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateGateLaneDirection" id="d4c529f9-fce7-44a4-b6ef-e37e88075ca8">
        <source>utlUpdateGateLaneDirection(_proxy : CM_LaneController; 	needToSendNote : Boolean io; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:	18 May 2008 By Graeme Black cnwgb1 PAR 16483
// ---------------------------------------------------------------------------
vars
	edition : Integer;
	lane 	: CM_LaneController;
	changed : Boolean;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	_proxy.pxyGetRealObjectAndEdition(lane, edition);

	if lane = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, _proxy.class.name, null, null); return;
	endif;
	
	changed := lane.updateLaneDirection( _proxy );
	
	if changed and needToSendNote then
		lane.myTerminalArea.causeEvent(lane.myTerminal.getTerminalEvent(Event_GateLane_Change), false, lane.myTerminalArea);
		needToSendNote := false;
	endif;
	app.setContinueCMExceptions(false);

end;</source>
        <Parameter name="_proxy" type="CM_LaneController"/>
        <Parameter name="needToSendNote" type="Boolean" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateGateScanRecord" id="dfbd81b8-33f6-40d8-871c-92d57ecec3ab">
        <source>utlUpdateGateScanRecord(_pxyGateScanRecord: CM_GenericGateScanRecord; _passport: CM_Passport input);
/*

Purpose:			Utility to update an existing GateScan Record from the Proxy object passed in

Parameters:			_pxyGateScanRecord	CM_GenericGateScanRecord	The proxy object to update the real object from
					_passport			CM_Passport					Passport to use for our Trx that holds errors and other useful data

Return Value:		NONE

Date		Who		Reason
17 February 2022	navpw1	Initial creation TFS: 52773

*/

vars
	cancelSave			: Boolean;
	realGateScanRecord	: CM_GenericGateScanRecord;
	expectedEdition		: Integer;
	
begin
	self.initialiseActivity();

	_pxyGateScanRecord.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyGateScanRecord.pxyGetRealObjectAndEdition(realGateScanRecord, expectedEdition);
	
	if realGateScanRecord = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_GenericGateScanRecord.name, null, null);
		return;
	endif;

	app.myValUA.valGateScanRecord(realGateScanRecord, _pxyGateScanRecord);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realGateScanRecord);

	if _passport.noErrors and realGateScanRecord.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Gate Scan Record', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realGateScanRecord, true);
	endif;
	
	if _passport.noErrors then
		realGateScanRecord.setForUpdate(_pxyGateScanRecord);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realGateScanRecord, false);
	endif;
	
	// ### TFS 54311 18Oct2022 NAVPW1
	if _passport.noErrors then
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_GATESCAN_UPDATE), false, realGateScanRecord);
	endif;
	// ### TFS 54311 18Oct2022 NAVPW1
	
end;</source>
        <Parameter name="_pxyGateScanRecord" type="CM_GenericGateScanRecord"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateGenGCController" id="c00e5830-deb7-4958-85d9-3ab685d6f417">
        <updating/>
        <source>utlUpdateGenGCController( _proxy : CM_GeneralCargoController input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 July 2013	cnwndl1	Initial creation	Par 31965

*/

vars
