    <JadeMethod name="utlUpdateVVSBooking" id="e2a41d4b-7e83-4252-9f50-bc35a1648e8d">
        <updating/>
        <source>utlUpdateVVSBooking(_proxy : CM_VehicleBookingTimeSlot; _deliveryIds, _pickupIds : StringArray; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Apr 2013	cnwndl1	Initial creation	Par 31393
10 Sep 2021	navdap1	TFS 51248 SNO Truck Appointment and Pre-Notes - new signature
*/

vars
	realVBooking 	: CM_VehicleBookingTimeSlot;
	expectedEdition : Integer;
	ti : CM_TrackedItem;
	vvr : CM_VehicleVisitRecord;
	alertDetails : String;
	
begin

	self.initialiseActivity();

	_proxy.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxy.pxyGetRealObjectAndEdition(realVBooking, expectedEdition);
	
	if realVBooking = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_VehicleBookingTimeSlot.name, null, null);
		return;
	endif;

	//app.myValUA.valVehicleBooking(realVBooking, _proxy);							// TFS 51248
	app.myValUA.valVehicleBooking(realVBooking, _proxy, _deliveryIds, _pickupIds);	// TFS 51248
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realVBooking);

	if _passport.noErrors and realVBooking.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(Vehicle_schedul_booking_slot), null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realVBooking, true);
	endif;
	
	if _passport.noErrors then
		alertDetails := realVBooking.getAlertDetail( _proxy );
		realVBooking.setForUpdate(_proxy);
	endif;
	
	if _passport.noErrors then
		vvr := realVBooking.myVehicleVisitRecord;
		if vvr &lt;&gt; null then
			foreach ti in vvr.allReceivedTrackedItems do
				ti.setVehicleBookingTimeslot( realVBooking );
			endforeach;
		endif;
	endif;

	if _passport.noErrors then
		realVBooking.raiseAlert( alertDetails );
		self.myUpdateAuditAgent.audUpdateGeneric(realVBooking, false);
	endif;

end;</source>
        <Parameter name="_proxy" type="CM_VehicleBookingTimeSlot"/>
        <Parameter name="_deliveryIds" type="StringArray"/>
        <Parameter name="_pickupIds" type="StringArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
