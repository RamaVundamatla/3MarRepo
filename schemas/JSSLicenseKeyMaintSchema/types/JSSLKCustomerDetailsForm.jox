    <ImplicitInverseRef name="aMyCustomer" id="643a701e-c3ca-4a97-a3c5-ffa705f48e7f">
        <embedded/>
        <type name="JSSLKCustomer"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="btnCancel" id="db01ffc8-b2b2-4300-84f7-ec4fb3f5c813">
        <embedded/>
        <type name="JadeMask"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="btnOk" id="79b5254e-3862-4bb0-8407-7451277bc104">
        <embedded/>
        <type name="JadeMask"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblName" id="d1ee092f-0444-4377-95c9-c53b6d98ffce">
        <embedded/>
        <type name="Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="txtName" id="2bb263aa-78d5-4e62-ab8a-db662eb340e0">
        <embedded/>
        <type name="TextBox"/>
    </ImplicitInverseRef>
    <JadeMethod name="btnCancel_click" id="1c3ad356-4e19-4ee2-9dae-a4b7acdb3eb4">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	unloadForm();
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOk_click" id="f662a471-7734-462f-a084-d3bca8fb9152">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOk_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	if self.doFormUpdate(false) then
		unloadForm();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFormInitialize" id="189105da-baf3-482e-b6ca-d40ace71718d">
        <updating/>
        <source>doFormInitialize() updating, protected;
// --------------------------------------------------------------------------------
// Created:		22 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theCustomer	: JSSLKCustomer;
	
begin
	inheritMethod();
	
	theCustomer	:=	self.aMyCustomer;
	
	if theCustomer = null then
		txtName.text	:=	null;
	else
		txtName.text	:=	theCustomer.customerName;
		
		self.resynchObjectAndSetEdition(theCustomer);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="0b7794af-0a38-4ffb-aa69-bf6148c59cfc">
        <updating/>
        <source>doFormUpdate(pIsDelete: Boolean): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		22 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theCustomer		: JSSLKCustomer;
	customerName	: String;
	
begin
	theCustomer		:=	self.aMyCustomer;
	customerName	:=	txtName.text.trimBlanks();
	
	if theCustomer = null then
		app.myTA.trxCreateCustomer(customerName, app.myRoot, theCustomer);
	else
		app.myTA.trxUpdateCustomer(theCustomer, self.aObjectEdition, customerName, app.myRoot);
	endif;
	
	return inheritMethod(pIsDelete);
end;</source>
        <access>protected</access>
        <Parameter name="pIsDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCustomer" id="edcfbc9d-c187-4897-9232-5da8117c03ec">
        <updating/>
        <source>setCustomer(pTheCustomer:JSSLKCustomer) updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2003 by cnwdad1
//
// Purpose:		Sets a reference to the specified Customer object on the form.
//
// Parameters:	pTheCustomer - The reference to the customer object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMyCustomer	:=	pTheCustomer;
end;</source>
        <Parameter name="pTheCustomer" type="JSSLKCustomer"/>
    </JadeMethod>
</GUIClass>
