    <JadeMethod name="getAuditChildSubjects" id="60510340-4ba2-4311-913d-7f9177a060da">
        <source>getAuditChildSubjects(_childAuditSubjectNames: StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 February 2019	jlger1	Initial creation 43546

*/

vars

	cargoDetails : CM_WodCargoRequest;
	marineDetail : CM_WodMarineServiceDetail;
begin
	inheritMethod(_childAuditSubjectNames);
	
	foreach cargoDetails in self.allWodCargoRequests discreteLock do
		cargoDetails.getAuditChildSubjects(_childAuditSubjectNames);	
	endforeach;
	
	foreach marineDetail in self.allMarineServiceDetails discreteLock do
		marineDetail.getAuditChildSubjects(_childAuditSubjectNames);	
	endforeach;
epilog

end;</source>
        <Parameter name="_childAuditSubjectNames" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="0a4a8b12-6767-4727-96e9-740445d02e8c">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 February 2019	jlger1	Initial creation 43546

*/

vars

	auditText : String;
	cargoDetails : CM_WodCargoRequest;
	marineDetail : CM_WodMarineServiceDetail;
begin
	auditText:= inheritMethod();
	
	foreach cargoDetails in self.allWodCargoRequests discreteLock do
		auditText:= auditText &amp; cargoDetails.getAuditText;	
	endforeach;
	
	foreach marineDetail in self.allMarineServiceDetails discreteLock do
		auditText:= auditText &amp; marineDetail.getAuditText;	
	endforeach;
	
	return auditText;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBerthForPaymentType" id="91c98e5a-9165-43bc-bb73-371c0427c93b">
        <source>getBerthForPaymentType(): HMS_Berth;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2018	jlgndl1	Initial creation	TFS 41281

*/

vars

	voyage : CM_Voyage;
	imsr : CM_WodMarineServicesInitial;
	berth : HMS_Berth;

begin

	//26 Mar 2019	NDL	TFS 43976 - New rules, have to use the IMSR berth for ALL shifts
	voyage := self.getMyVoyageObject;
	if voyage &lt;&gt; null then
		imsr := voyage.getWorkOrderForIMSR();
		if imsr &lt;&gt; null then
			berth := imsr.getBerthForPaymentType;
			if berth &lt;&gt; null then
				return berth;
			endif;
		endif;
	endif;
/*	if self.myFromBerth &lt;&gt; null then
		return self.myFromBerth;
	endif;
	
	if self.myHMSVoyageMovement &lt;&gt; null then
		return self.myHMSVoyageMovement.getMyBerth;
	endif; */
	
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
