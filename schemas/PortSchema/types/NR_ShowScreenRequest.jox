<Class name="NR_ShowScreenRequest" id="2af1a425-42c0-469e-9401-b1bea37c16a4">
    <superclass name="NR_NodeRequest"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="nodereq"/>
    <PrimAttribute name="appName" id="7fba2763-6a02-436f-bd56-5a9c395dbf73">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="currentDateTime" id="25fa5f56-b3bc-4857-9a36-1702d60decb5">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="screenShot" id="2a24aafa-5c9c-4697-b308-7ba861f7dcff">
        <type name="Binary"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="userName" id="dbcc0ff1-e756-4511-921b-df99fffaf962">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="actionOnTargetNode" id="1b20abe5-6a1b-4966-b7e6-0a3e5a54c751">
        <updating/>
        <source>actionOnTargetNode() updating;
// ---------------------------------------------------------------------------
// Created:     30 March 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
22 Feb 2010	cnwkpd1	PAR #21603 - Change to use Window::createPictureAsType to
					reduce size of binary.  
21 Jan 2011	cnwkpd1	Also re work so that screen image is not requested in transaction state

*/

vars
	tmpAppType	: Character;
	tmpForm		: Form;
	tmpControl	: Control;
	screenImage	: Binary;
	
begin

//	process.persistentApp.name
	tmpAppType := app.applicationType;
	
	if tmpAppType &lt;&gt; Application.ApplicationType_GUI then
		beginTransaction;
		self.setCurrentDetails();
		commitTransaction;
		return;
	endif;
	
	// PAR #21603 - changed to get the screen image when not in transaction state
	tmpControl := app.activeControl;
	
	if tmpControl &lt;&gt; null then
		
		tmpForm := tmpControl.form;
	
		if tmpForm.mdiChild = Form.MdiChild_IsMdi and
		   app.mainForm &lt;&gt; null then
			// if mdi child then we will take the whole screen
			tmpForm := null;
		endif;
	endif;
	
	if tmpForm = null then
		tmpForm := app.mainForm;
	endif;
	
	if tmpForm &lt;&gt; null then
		// only use colour bits = 8 to avoid no memory for buffers error when
		// picture is too large
		screenImage := tmpForm.createPictureAsType(true, true, 8, Window.PictureType_Png); // PAR #21603
		//self.screenShot := tmpForm.createPicture(true, true, 8);
	endif;
	
	beginTransaction;

	self.setCurrentDetails();
		
	if screenImage = null then
		self.logEntry('Form not found - cannot get picture for application ' &amp; app.niceName);
	else
		self.screenShot := screenImage;
	endif;
	
	commitTransaction;

	
epilog
	if process.isInTransactionState then
		commitTransaction;
	endif;
	self.causeEvent(NR_NodeRequestCompleteEvent, true, self);
	
end;</source>
    </JadeMethod>
