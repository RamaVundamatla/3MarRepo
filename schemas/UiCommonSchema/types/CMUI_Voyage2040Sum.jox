<GUIClass name="CMUI_Voyage2040Sum" id="f3be2ccc-f1f3-459d-ac32-874adca2d4ba">
    <superclass name="CMUI_VoyageWeightSummary"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="addTotalsRow" id="5540000c-c4d7-4d7e-ab96-1a2fed712844">
        <source>addTotalsRow() protected;
// ---------------------------------------------------------------------------
// Created:     10 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	
	weightTotal		: Decimal[12,1];
	countTotal,
	numRows,
	numColumns,
	row,
	totalNumRow,
	totalWeightRow,
	column			: Integer;
	tbl				: Table;
	
begin
	tbl := self.tblReport;
	
	numRows := tbl.rows;
	numColumns := tbl.columns;
	totalNumRow := tbl.addItem('ZZZTotal' &amp; Tab &amp; 'Total');
	tbl.accessRow(totalNumRow).fontBold := true;
	tbl.accessedRow.alignment := tbl.Alignment_Right_Middle;
	tbl.accessedRow.fontSize := 10;
	
	totalWeightRow := tbl.addItem('ZZZTotalWeight' &amp; Tab &amp; '');
	tbl.accessRow(totalWeightRow).fontBold := true;
	tbl.accessedRow.fontSize := 10;
	tbl.accessedRow.alignment := tbl.Alignment_Right_Middle;
	tbl.accessedRow.fontItalic := true;	
	
	foreach column in 3 to numColumns do
		countTotal := 0;
		weightTotal := 0;
		foreach row in 4 to numRows step 2 do
			countTotal := countTotal + tbl.getCellText(row, column).Integer;
			weightTotal := weightTotal + tbl.getCellText(row + 1, column).Decimal;
		endforeach;
		
		if countTotal &lt;&gt; 0 then
			tbl.setCellText(totalNumRow, column, countTotal.String);
			tbl.setCellText(totalWeightRow, column, weightTotal.String);
		endif;
		
	endforeach;

	tbl.accessColumn(1).visible := false;//column 1 is just for sorting = hide it
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateTable" id="971442bf-f71b-4b3e-b72b-8623a0926e00">
        <source>populateTable() protected;
// ---------------------------------------------------------------------------
// Created:     07 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	voySummary				: CMIF_VoyageSummary;
	tbl						: Table;
	weightEmpty20, weightEmpty40, weightEmptyTotal,
	weightReefer20, weightReefer40, weightReeferTotal,
	weightGeneral20, weightGeneral40, weightGeneralTotal,
	weightTotal							 : Decimal[12,1];
	
	numEmpty20,	numEmpty40, totalEmpty,
	numReefer20, numReefer40, totalReefer,
	numGeneral20, numGeneral40, totalGeneral,
	total,
	foundRow,
	foundWeightRow,
	numRows,
	row,
	column,
	rightAlignment					: Integer;
	iter							: Iterator;
	summaryDict						: CMIF_VoyageSummaryByValueDict;
	str,
	previousKey1,
	previousKey2					: String;

begin
	
	summaryDict := self.myJRWVoyageSummary.allVoyageSummaryObjects;

	tbl := self.tblReport;
	rightAlignment := tbl.Alignment_Right_Middle;
	//setup column and rows headings////////////////
	tbl.rows := 3;
	tbl.fixedRows := 3;
	tbl.columns := 2;
	tbl.fixedColumns := 2;
	tbl.sortColumn[1] := 1;
	tbl.sortAsc[1] := true;
	/////////////////////////////////////////////////
	
	iter := summaryDict.createIterator;
	
	while iter.next(voySummary) do : objLoop
		if previousKey1 &lt;&gt; voySummary.keyValue1 then
			column := tbl.columns;
			tbl.columns := column + 10;
			column := column + 1;	
			
			if voySummary.keyValue1 = CMQF_VoyageSummary.TOTALS_ID then
				tbl.accessCell(1, column).text := 'Total';
			else
				tbl.accessCell(1, column).text := voySummary.keyValue1;				
			endif;
			tbl.accessedCell.mergeCells := Table.MergeCells_Merge;
			tbl.accessedCell.alignment := Table.Alignment_Center;
			tbl.accessedCell.fontBold := true;
			
			tbl.accessCell(2, column).text := 'Mty' &amp; Tab &amp; Tab &amp; Tab &amp; 
												'Gen' &amp; Tab &amp; Tab &amp; Tab &amp;
												'Ref';
			
			tbl.accessCell(2, column).mergeCells := Table.MergeCells_Merge;
			tbl.accessCell(2, column).alignment := Table.Alignment_Center;
			
			tbl.accessCell(2, column + 3).mergeCells := Table.MergeCells_Merge;
			tbl.accessCell(2, column + 3).alignment := Table.Alignment_Center;
			
			tbl.accessCell(2, column + 6).mergeCells := Table.MergeCells_Merge;
			tbl.accessCell(2, column + 6).alignment := Table.Alignment_Center;
			
			tbl.accessCell(3, column).text 		:= "20'";
			tbl.accessCell(3, column + 1).text 	:= "40'";
			tbl.accessCell(3, column + 2).text 	:= "All";
			
			tbl.accessCell(3, column + 3).text 	:= "20'";
			tbl.accessCell(3, column + 4).text 	:= "40'";
			tbl.accessCell(3, column + 5).text 	:= "All";
			
			tbl.accessCell(3, column + 6).text 	:= "20'";
			tbl.accessCell(3, column + 7).text 	:= "40'";
			tbl.accessCell(3, column + 8).text 	:= "All";
			
			tbl.accessCell(3, column + 9).text 	:= "Total";
			
		endif;
		
		previousKey1 := voySummary.keyValue1;
		
		numRows := tbl.rows;
		foundRow := - 1;
		foundWeightRow := -1;
		foreach row in 3 to numRows do : rowLoop
			if tbl.accessCell(row, 1).text.trimBlanks = voySummary.keyValue2.trimBlanks then
				foundRow := row;
				foundWeightRow := row + 1;
				break rowLoop;
			endif;
		endforeach;
		
		if foundRow = - 1 then
			foundRow := tbl.addItem(voySummary.keyValue2);
			tbl.accessCell(foundRow, 2).text := voySummary.keyValue2;//column 1 is hidden for sorting
			tbl.accessedCell.fontBold := true;
			tbl.accessRow(foundRow).alignment := tbl.Alignment_Right_Middle;
			
			foundWeightRow := tbl.addItem(voySummary.keyValue2 &amp; 'ZZZ' &amp; Tab &amp; '');//keep alpha order
			tbl.accessRow(foundWeightRow).alignment := tbl.Alignment_Right_Middle;
			tbl.accessedRow.fontBold := true;
			tbl.accessedRow.fontItalic := true;			
		endif;
		
		weightEmpty20 := (voySummary.weight20Empty / 1000).roundedTo(1);
		weightEmpty40 := (voySummary.weight40Empty / 1000).roundedTo(1);
		weightEmptyTotal := weightEmpty20 + weightEmpty40;
		numEmpty20 := voySummary.num20ftEmpty;
		numEmpty40 := voySummary.num40ftEmpty;
		totalEmpty := numEmpty20 + numEmpty40;
		
		weightGeneral20 := (voySummary.weight20General / 1000).roundedTo(1);
		weightGeneral40 := (voySummary.weight40General / 1000).roundedTo(1);
		weightGeneralTotal := weightGeneral20 + weightGeneral40;
		numGeneral20 := voySummary.num20ftGeneral;
		numGeneral40 := voySummary.num40ftGeneral;
		totalGeneral := numGeneral20 + numGeneral40;
		
		weightReefer20 := (voySummary.weight20Reefer / 1000).roundedTo(1);
		weightReefer40 := (voySummary.weight40Reefer / 1000).roundedTo(1);
		weightReeferTotal := weightReefer20 + weightReefer40;
		numReefer20 := voySummary.num20ftReefer;
		numReefer40 := voySummary.num40ftReefer;
		totalReefer := numReefer20 + numReefer40;
		
		weightTotal := weightEmptyTotal + weightGeneralTotal + weightReeferTotal;
		total := totalEmpty + totalGeneral + totalReefer;
		
		//////////////EMPTIES////////////////
		if numEmpty20 &lt;&gt; null then
			tbl.accessCell(foundRow, column).text := numEmpty20.String;
			tbl.accessedCell.alignment := rightAlignment;
			tbl.accessCell(foundWeightRow, column).text := weightEmpty20.String;
			tbl.accessedCell.alignment := rightAlignment;
			tbl.accessedCell.fontBold := true;
			tbl.accessedCell.fontItalic := true;
		endif;
		
		if numEmpty40 &lt;&gt; null then
			tbl.accessCell(foundRow, column + 1).text := numEmpty40.String;
			tbl.accessCell(foundWeightRow, column + 1).text := weightEmpty40.String;
		endif;
		
		if totalEmpty &lt;&gt; null then
			tbl.accessCell(foundRow, column + 2).text := totalEmpty.String;
			tbl.accessCell(foundWeightRow, column + 2).text := weightEmptyTotal.String;
		endif;
		////////////GENERAL////////////////////////
		if numGeneral20 &lt;&gt; null then
			tbl.accessCell(foundRow, column + 3).text := numGeneral20.String;
			tbl.accessCell(foundWeightRow, column + 3).text := weightGeneral20.String;
		endif;
		
		if numGeneral40 &lt;&gt; null then
			tbl.accessCell(foundRow, column + 4).text := numGeneral40.String;
			tbl.accessCell(foundWeightRow, column + 4).text := weightGeneral40.String;
		endif;
		
		if totalGeneral &lt;&gt; null then
			tbl.accessCell(foundRow, column + 5).text := totalGeneral.String;
			tbl.accessCell(foundWeightRow, column + 5).text := weightGeneralTotal.String;
		endif;
		////////////REEFERS///////////////////////
		if numReefer20 &lt;&gt; null then
			tbl.accessCell(foundRow, column + 6).text := numReefer20.String;
			tbl.accessCell(foundWeightRow, column + 6).text := weightReefer20.String;
		endif;
		
		if numReefer40 &lt;&gt; null then
			tbl.accessCell(foundRow, column + 7).text := numReefer40.String;
			tbl.accessCell(foundWeightRow, column + 7).text := weightReefer40.String;
		endif;
		
		if totalReefer &lt;&gt; null then
			tbl.accessCell(foundRow, column + 8).text := totalReefer.String;
			tbl.accessCell(foundWeightRow, column + 8).text := weightReeferTotal.String;
		endif;
		
		////Total column///////////////////////////////
		if total &lt;&gt; null then
			tbl.accessCell(foundRow, column + 9).text := total.String;
			tbl.accessedCell.fontSize := 10;
			
			tbl.accessCell(foundWeightRow, column + 9).text := weightTotal.String;
			tbl.accessedCell.fontSize := 10;
		endif;
		///////////////////////////////////////////
	endwhile;
	
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setNoDataDisplay" id="09655271-616f-4d5d-bb41-60fa02c6534e">
        <source>setNoDataDisplay();
// -------------------------------------------
// Created 23 September 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	
	self.lblNoData.caption := 'No Data To Display For Voyage 20/40 Summary';



end;</source>
    </JadeMethod>
    <JadeMethod name="setupHeader" id="dde96ecc-c3dd-498f-bc09-aea1ffe2e8b4">
        <source>setupHeader() protected;
// ---------------------------------------------------------------------------
// Created:     07 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
constants
	Gap = 5;
vars

begin
	self.frmHeader.height := 145;
	self.lblPage.top := self.lblPrinted.top;
	self.lblHeading3_1.top := self.lblPrinted.top;
	self.lblHeading3_1.left := self.lblHeading3_1.left - Gap;
	
	self.lblTerminalName.visible := false;
	self.lblReportId.visible := false;
	self.lblPrinted.top := self.picPortLogo.top + self.picPortLogo.height + Gap;
	self.lblPrinted.left := self.lblPrinted.left - 10;
	self.lblPrintedDtl.top := self.lblPrinted.top;
	self.lblPrintedDtl.left := self.lblPrintedDtl.left - 10;
	self.lblPrintTime.top := self.lblPrinted.top;
	self.lblPrintTime.left := self.lblPrintTime.left - 15;
	
	self.picJadeLogo.picture := app.getPicLogoProduct;
	self.picPortLogo.picture := app.getPicLogoPort;
	self.picJadeLogo.visible := true;
	self.picPortLogo.visible := true;
	self.picJadeLogo.zOrder(1);
	self.picPortLogo.zOrder(1);
	
	self.lblHeading1.caption := self.myJRWVoyageSummary.myVoyage.code &amp; ' - ' &amp; 
						self.myJRWVoyageSummary.myVoyage.vesselName.trimBlanks &amp; ' - Container 20/40 Summary';
	self.lblHeading1.alignment := self.lblHeading2.Alignment_Center_Middle;
	self.lblHeading1.top := 10;
	self.lblHeading1.height := 20;
	self.lblHeading1.fontSize := 12;
	self.lblHeading1.fontBold := true;
	
	self.lblHeading2.caption := self.myJRWVoyageSummary.orderedByHeading1 &amp; 
								' by ' &amp; self.myJRWVoyageSummary.orderedByHeading2 &amp; ' - ' &amp; 
								self.myJRWVoyageSummary.modeDescription;
	
	self.lblHeading2.alignment := self.lblHeading2.Alignment_Center_Middle;
	self.lblHeading2.top := 40;
	self.lblHeading2.height := 20;
	self.lblHeading2.fontSize := 12;
	self.lblHeading2.fontBold := true;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTable" id="8156fe6b-8d25-4c75-826a-272497060974">
        <source>setupTable() protected;
// ---------------------------------------------------------------------------
// Created:     21 July 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod();
	self.tblReport.fontSize := 10;

end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
