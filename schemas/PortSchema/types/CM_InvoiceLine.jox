    </JadeMethod>
    <JadeMethod name="getTaxAmountProformaForVoyage" id="c436b1e0-fa4c-4344-bca9-6657ee97c0be">
        <source>getTaxAmountProformaForVoyage(_workOrder : CM_WorkOrder) : Real;
/*

Purpose:		// TFS 45953  removing old cash code and attributes in DMAST only noticed use of work order to get tax (for PELs)	

Parameters:			

Return Value:		

Date		Who		Reason
22 October 2019	jlgab1	Initial creation

*/

vars
	lineTax : Real;
	charge : CM_Charge;
begin
	lineTax := 0; 
	foreach charge in self.charges do
		lineTax := lineTax + charge.getTaxAmountProformaForVoyage(_workOrder);
	endforeach;

	return lineTax;
epilog

end;</source>
        <Parameter name="_workOrder" type="CM_WorkOrder"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTaxAmountsAsString" id="5dd7d2a9-f431-4cfa-b0f0-c5a9ba1d9480">
        <source>getTaxAmountsAsString(_useQuotes : Boolean) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Nov 2018	jlgsl4	TFS 41230 - ADP - Invoice export
03 May 2023 navmv20 Bug 57664: EUP - Copy function does not include overridden rates
*/

vars
	taxAmounts : DecimalArray;
	amt : Decimal[23,2]; //03/05/2023 navmv20 Bug 57664
	list : String;		 //03/05/2023 navmv20 Bug 57664
begin
	create taxAmounts transient;
	self.getTaxAmountsForCharges(taxAmounts);
	//03/05/2023 navmv20 Bug 57664 - START
	//return self.convertDecimalArrayToCSV(taxAmounts, _useQuotes);
	foreach amt in taxAmounts do
		/*
		if list.pos(amt.String,1) = 0 then
			if list = null then
				list := amt.String;
			else
				list := list &amp; ", " &amp; amt.String;
			endif;
		endif;
		*/
		
		list.addStringToList(amt.String, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
	endforeach;
	return list;
	//03/05/2023 navmv20 Bug 57664 - END
epilog
	delete taxAmounts;
end;</source>
        <Parameter name="_useQuotes" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTaxAmountsForCharges" id="00ee528e-98dd-414b-9d75-c762fc378cb9">
        <source>getTaxAmountsForCharges(_taxAmount : DecimalArray io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Nov 2018	jlgsl4	TFS 41230 - ADP - Invoice export

*/

vars
	charge : CM_Charge;
begin
	_taxAmount.clear();
	foreach charge in self.charges do
		_taxAmount.add(charge.getTaxAmountForCharge());
	endforeach;
epilog

end;</source>
        <Parameter name="_taxAmount" type="DecimalArray" usage="io"/>
