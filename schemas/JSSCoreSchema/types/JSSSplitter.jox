    <JadeMethod name="jssfmMouseUp" id="2e4489cc-f5df-4d7c-a999-a232bd7fd3af">
        <updating/>
        <source>jssfmMouseUp(wndw: Window input; button: Integer; shift: Integer; x: Real; y: Real) updating, protected;

// Called by the splitter bar when the user mouse action is complete

vars

begin
	// Calculate and set the new ratio, and resize the child controls
	if isSplitHorizontal then
		leftToRightRatio := (self.myHorizontalSplitter.top / self.clientHeight() * 100).Integer;
	else
		leftToRightRatio := (self.myVerticalSplitter.left / self.clientWidth() * 100).Integer;
	endif;
	
	self.resizeChildrenAndSplitter();

	// Invoke any form logic required after the move
	self.splitterMove(self);

//	inheritMethod(wndw, button, shift, x, y);
end;</source>
        <access>protected</access>
        <Parameter name="wndw" type="Window" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="leftToRightRatio" id="ad4f30d1-a1b0-446e-bf58-d730acae656f">
