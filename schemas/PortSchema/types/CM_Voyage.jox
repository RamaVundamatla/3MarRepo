    <JadeMethod name="getDepartureDT" id="554e6e14-5cd9-45b3-98fe-f2855d5fe796">
        <source>getDepartureDT() : TimeStamp;
/*
----------   ----------  --------------------------------------------------
Created:	03 August 2007 By cnwth2

Purpose:	Used in JRW - don't delete

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	hmsMovement			: HMS_Movement;
	hmsVoyageData			: HMS_VoyageData;
begin
	if self.myHMSVoyageData = null then
		return self.departedDT; // PAR 25719
	endif;
	hmsMovement := self.myHMSVoyageData.getMovementForMoveType(HMSMovementTypeDeparture);
	
	if hmsMovement = null then
		return self.departedDT; // TFS 42872 null;
	endif;
	
	return hmsMovement.occursOnDTNEW;

end;


</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDepartureDTLocalTZ" id="513fe10a-0189-451e-84c3-bac2bd748bf0">
        <source>getDepartureDTLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2016	cnwns1	Initial creation
// 07 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	hmsMovement			: HMS_Movement;
	hmsVoyageData			: HMS_VoyageData;
begin
	if self.myHMSVoyageData = null then
		return self.systemToLocalTime(self.departedDT); // PAR 25719
	endif;
	hmsMovement := self.myHMSVoyageData.getMovementForMoveType(HMSMovementTypeDeparture);
	
	if hmsMovement = null then
		return null;
	endif;
	
	return self.systemToLocalTime(hmsMovement.occursOnDTNEW);

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
