    <JadeMethod name="clearSheets" id="6bbc1795-4680-4b7b-9573-f923dd944699">
        <source>clearSheets();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Apr 2022	navcs2	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
02 Aug 2022	navcs2  Bug 54238: MTN - Work Order Maintenance - Task Details Section Does Not Always Show Correctly
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
05 Jul 2023 navma1  Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
*/

vars

begin

	/*
	Sheets
	*/
	self.shtBlank.visible 			 := false;
	self.shtMove.visible 			 := false;
	self.shtPack.visible 			 := false;
	self.shtReceive.visible 		 := false;
	self.shtRelExtension.visible 	 := false;
	self.shtRelease.visible 		 := false;
	self.shtToDo.visible 			 := false;
	self.shtToDoTasks.visible 		 := false;
	self.shtUnPack.visible 			 := false;
	self.shtNullVoyage.visible 		 := false;				 //navcs2 54238 02/08/2022
	self.shtTimeChange.visible   	 := false;
	self.shtWaterRequest.visible 	 := false;
	self.shtExtension.visible 	 	 := false;
	self.shtHMSCancel.visible	 	 := false;
	self.shtBillingAdj.visible	 	 := false;
	self.shtMarineI.visible		 	 :=	false;
	self.shtVoyageNewRequest.visible := false;
	self.shtMarineD.visible			 := false;
	self.shtPermit.visible			 := false;
	self.shtShift.visible			 := false;
	self.shtCargoRequest.visible	 := false;
	self.shtFinancial.visible 		 := false;
	self.shtVoyageResources.visible	 := false;
	
	/*
	Buttons
	*/
	self.btnMaintainBooking.visible := false;				//06.7.2023 navhl20 #58952
	self.btnCreateCargo.visible 		  := false;
	
	self.tblChildItems.visible 			  := false;
	self.grpPackItems.visible 			  := false;
	
	
	
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="cmbBerthCR_displayEntry" id="812348c5-f59d-4556-ac2b-3e3a8e915834">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBerthCR_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 April 2022	navhl20	Initial creation    TFS 52351

*/

vars
	berth : HMS_Berth;

begin
	if obj = null then
		return null;
	endif;
	berth := obj.HMS_Berth;
	return berth.code &amp; Tab &amp; berth.description;
epilog

end;</source>
