    <JadeMethod name="trxCreateBGPAPIRequestForVBS" id="3f0f3ccc-0924-4837-86c6-1d9d0dc82310">
        <updating/>
        <source>trxCreateBGPAPIRequestForVBS(_allVehicleBookings : CM_VehicleBookingTimeSlotById input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason 
30 June 2023	jlier1	Initial creation 58839

*/

vars
	pxyBGPRequest : BGP_APIWSRequest;
	bgpRequest	: BGP_ExternalWSRequest;
	vbs : CM_VehicleBookingTimeSlot;
begin
// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	if _allVehicleBookings = null or _allVehicleBookings.isEmpty then
		//nothing to do
		return ;
	endif;
		
	beginTransaction;

	foreach vbs in _allVehicleBookings discreteLock do
		if not vbs.canSendLoadNotification then
			continue;
		endif;
	
		delete pxyBGPRequest;
		create pxyBGPRequest transient;
		pxyBGPRequest.setDetails(null, null,vbs,vbs.myTerminal, BGP_APIWSRequest.Type_LoadNotification);		
	
		app.myUtilityCA.utlCreateBGPRequestExtWS(pxyBGPRequest,bgpRequest,_passport);
		
		if app.myPassport.hasErrors then
			break;
		endif;
	endforeach;

epilog
	self.finaliseActivityWithPassport(_passport);
	delete pxyBGPRequest;
end;</source>
        <Parameter name="_allVehicleBookings" type="CM_VehicleBookingTimeSlotById" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
