    <JadeMethod name="trxCreateBOL" id="30424c99-3da5-4d8d-b2d9-e0a777ca0503">
        <updating/>
        <source>trxCreateBOL(	_pxyBOL: CM_BOL input; 
				_newBOL : CM_BOL output;
				_context : Object; //06 Nov 2019	NDL	TFS 47100
				_passport : CM_Passport input) updating;
//
// 02 Dec 2018	jlgrs1	TFS 42276 STWR Make EDI MultiThreaded Stage 7
//

vars
	allNewBOLDtlProxies : CM_ObjectArrayActual;
	proxy : CM_Object;
begin
// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;

	create allNewBOLDtlProxies transient;
	beginTransaction;

	app.myUtilityCA.utlCreateBOL(_pxyBOL, _passport, _context, _newBOL, allNewBOLDtlProxies);

	if _passport.noErrors then
		app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(_newBOL);
	endif;
	
	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;
epilog

	self.finaliseActivityWithPassport(_passport);

	if allNewBOLDtlProxies &lt;&gt; null then
		//these proxies have not been committed yet so if there was an exception then need to remove proxy link
		foreach proxy in allNewBOLDtlProxies do
			app.myProxyManager.deleteProxyLink(proxy);
		endforeach;
		
		delete allNewBOLDtlProxies;
	endif;

end;</source>
        <Parameter name="_pxyBOL" type="CM_BOL" usage="input"/>
        <Parameter name="_newBOL" type="CM_BOL" usage="output"/>
        <Parameter name="_context" type="Object"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
