    <JadeMethod name="initQueryFrame" id="176957c2-0e62-49f4-baa3-ae4eff4f1e96">
        <source>initQueryFrame() protected;
// ---------------------------------------------------------------------------
// Created:     05 September 2003	cnwth2
//
// Purpose:     
//	
// 02 Nov 2012	PJS			PAR #30631 - Voyage Rationalisation		 
// ----------   ----------  --------------------------------------------------
vars

begin
