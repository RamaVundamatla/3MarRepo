    <JadeMethod name="getEmailAddressForUser" id="0c727096-acc1-478b-b208-1f301b7e05c9">
        <source>getEmailAddressForUser(_address : String;
					  _user : CM_User) : CM_EmailAddress2;

/*

Purpose:			Get the first Email Address with the matching address that the passed in
					User can see

Parameters:			Email Address to match on, and User

Return Value:		Matching Email Address, if there is one


Date		Who		Reason
27 Jan 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	iter			: Iterator;
	address			: String;
	emailAddress	: CM_EmailAddress2;
	
begin
	address := _address.trimBlanks.toLower();
	iter := self.allEmailAddressesByAddress.createIterator();
	self.allEmailAddressesByAddress.startKeyGeq(address, iter);
	
	while iter.next(emailAddress) do
		if emailAddress.emailAddress &lt;&gt; address then
			break;
		endif;
		
		// 33797 using email addresses for packages needs to be able to see all users, added null _user test
		if _user = null then
			return emailAddress;
		elseif emailAddress.allUsersWhoCanSeeMe.includes(_user) then
			return emailAddress;
		endif;
	endwhile;
	
	return null;
	
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_address" type="String"/>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="CM_EmailAddress2"/>
    </JadeMethod>
    <JadeMethod name="getEmailAddresses" id="0515db9a-4c33-4857-8510-5803d33efe29">
        <source>getEmailAddresses(tmpCol : ObjectSet input; _groups : Boolean);
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
27 Jan 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
					Tidy up of email address code

*/

vars
	anEMail 		: CM_EmailEntity;
	
begin
	foreach anEMail in app.myRoot.allEmailEntities discreteLock do
		if _groups = anEMail.isEmailGroup then
			tmpCol.add(anEMail);
		endif;
	endforeach;

end;</source>
        <Parameter name="tmpCol" type="ObjectSet" usage="input"/>
        <Parameter name="_groups" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getEmailEntity" id="0d092f73-c736-4bb6-b34e-ec065b180117">
        <source>getEmailEntity(_emailEntName: String): CM_EmailEntity;
//----------------------------------------------------------------
//	Created:	26 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	emlEnt : CM_EmailEntity;
begin
	//check for user then group
	emlEnt := self.allEmailEntities[Email_Address,_emailEntName];
	
	if emlEnt = null then
		emlEnt := self.allEmailEntities[Email_Group,_emailEntName];
	endif;
	
	return emlEnt;

end;</source>
        <Parameter name="_emailEntName" type="String"/>
        <ReturnType type="CM_EmailEntity"/>
    </JadeMethod>
