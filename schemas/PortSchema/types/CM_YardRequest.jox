    <JadeMethod name="setCouGenRemarks" id="8192617b-01af-486f-a9e9-3f56249d26af">
        <source>setCouGenRemarks() : String protected;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lString : String;
begin

	lString := self.remarks;
	if lString = null then
		if self.needCOU then
			lString := lString &amp; " - " &amp; self.COU_REQD &amp; ".";
		endif;
		if self.needGenerator then
			lString := lString &amp; " - " &amp; self.GEN_REQD &amp; ".";
		endif;
	else
		if not self.needCOU then
			lString.replaceString(" - " &amp; self.COU_REQD  &amp; ".","");
		endif;
		if not self.needGenerator then
			lString.replaceString(" - " &amp; self.GEN_REQD &amp; ".","");
		endif;
		if self.needCOU then
			lString := lString &amp; " - " &amp; self.COU_REQD &amp; ".";
		endif;
		if self.needGenerator then
			lString := lString &amp; " - " &amp; self.GEN_REQD &amp; ".";
		endif;
	endif;		
	return lString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setDeliveryNumber" id="119bcd30-3813-4603-8ad7-19e18024f205">
        <updating/>
        <source>setDeliveryNumber(_value : String) updating;
// ---------------------------------------------------------------------------
// Created:     15 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theBulkRelease	: CM_BulkRelease;
	term : CM_Terminal;
begin

	self.deliveryNumber := _value.trimRight;

	term := self.myTerminal;
	
	// 03/11/2010 cnwmh5 #26400 - Start
	///theBulkRelease := term.getBulkReleaseFromCode(self.deliveryNumber);
	if term &lt;&gt; null then					
		if self.myReserveDetail &lt;&gt; null then		// 03/12/2010 cnwmh5 #26400
			theBulkRelease := self.myReserveDetail.myReserveHeader;
		else
			theBulkRelease := term.getBulkReleaseFromCode(self.deliveryNumber);
		endif;
	endif;
	// 03/11/2010 cnwmh5 #26400 - End
	
	self.setMyOriginatingBulkRelease(theBulkRelease);
	
end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
