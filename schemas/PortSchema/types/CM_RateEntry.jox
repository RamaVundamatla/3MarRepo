    <JadeMethod name="doAuditRateHistory" id="ce69c20b-e3e7-400d-b58a-080b13e4efd8">
        <updating/>
        <source>doAuditRateHistory(_newCosts : DecimalArray; pNewCost : Decimal; pNewStartTime : TimeStamp; _newExpiryTime : TimeStamp; _newIgnoreEntry : Boolean;
					pRate : CM_RateEntry; pDeleted : Boolean; _status : Integer) updating;
//----------------------------------------------
//Created: 9 October 2001 By: cnwgd1
// May 2010	23582 add expiry date and ignore options
//----------------------------------------------
vars
	auditRateChg	: CM_FinAuditRateHistory;
	now				: TimeStamp;
	rate			: CM_RateEntry;
	oldCPU, newCPU : Real;
	idx : Integer;
begin
	
	if pRate = null then
		return;
	endif;
	
	if _newCosts = null and
	  (not pDeleted) then	//par 10907 cnwrs1 mer 2006
		return;
	endif;
	
	if (not pDeleted) then		//No change so don't do audit	
		if pRate.startTimestamp = pNewStartTime and
		   pRate.expiryTimestamp = _newExpiryTime and
		   pRate.ignoreThisEntry = _newIgnoreEntry then
			if _newCosts.isEmpty then
				if pRate.getRawCostPerUnit = pNewCost then
					return;
				endif;
			else
				if _newCosts.membersSame(pRate.allCostPerUnits) then
					return;
				endif;
			endif;
		endif;
	endif;

	if _newCosts = null 
	or _newCosts.isEmpty //par 10907 cnwrs1 mer 2006
	or pRate.allCostPerUnits.isEmpty then
		self.doAuditRateHistoryCreate(pNewCost, pNewStartTime, _newExpiryTime, _newIgnoreEntry, pRate.getRawCostPerUnit, pRate.startTimestamp, pRate.expiryTimestamp, pRate.ignoreThisEntry, pDeleted, pRate, _status);
	else
		foreach oldCPU in pRate.allCostPerUnits do		
			idx := idx + 1;
			//epr par 11969
			if idx &gt; _newCosts.size then
				break;
			endif;
			
			newCPU := _newCosts[idx];
			if (newCPU &lt;&gt; oldCPU) 
			or (pNewStartTime &lt;&gt; pRate.startTimestamp)		// PAR 16503
			or (_newExpiryTime &lt;&gt; pRate.expiryTimestamp)
		    or (_newIgnoreEntry &lt;&gt; pRate.ignoreThisEntry) then
				self.doAuditRateHistoryCreate(newCPU, pNewStartTime, _newExpiryTime, _newIgnoreEntry, oldCPU, pRate.startTimestamp, pRate.expiryTimestamp, pRate. ignoreThisEntry, pDeleted, pRate, _status);
			endif;
		endforeach;
	endif;

end;</source>
        <Parameter name="_newCosts" type="DecimalArray"/>
        <Parameter name="pNewCost" type="Decimal"/>
        <Parameter name="pNewStartTime" type="TimeStamp"/>
        <Parameter name="_newExpiryTime" type="TimeStamp"/>
        <Parameter name="_newIgnoreEntry" type="Boolean"/>
        <Parameter name="pRate" type="CM_RateEntry"/>
        <Parameter name="pDeleted" type="Boolean"/>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doAuditRateHistoryCreate" id="c403419c-bbb5-47a8-8537-f563593fc15e">
        <updating/>
        <source>doAuditRateHistoryCreate(_newCost : Decimal; _newStartTime : TimeStamp; _newExpiryTime : TimeStamp; _newIgnoreEntry : Boolean; _oldCost : Decimal; _oldStartTime : TimeStamp; 
						 _oldExpiryTime : TimeStamp; _oldIgnoreEntry : Boolean; pDeleted : Boolean; _auditedObject : CM_RateEntry; _status : Integer) protected, updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		JMH Invoice changes 
//	23582	May 2010	cnwjre1	added expiry date and ignore options
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
12 Oct 2016	cnwkpd1	TFS 2815 - JADE 7.1.08 causeEvent changes
	
*/

vars
	auditRateChg	: CM_FinAuditRateHistory;

begin
	create auditRateChg persistent;
	auditRateChg.auditedFOs.clear;
	auditRateChg.unauditedFOs.clear;
	auditRateChg.sequenceNum := app.getNextInvoiceSeqNumOnRootBank(SN_AUDIT); // PAR 15036
	auditRateChg.userId := app.getMyUserCode;
	auditRateChg.dateTime := app.actualTimeServer;
	auditRateChg.isDeleted := false;	
	auditRateChg.status := _status;
	
	if (not pDeleted) then
		auditRateChg.previousCost := _oldCost;
		auditRateChg.newCost := _newCost;
		auditRateChg.previousStartTime := _oldStartTime;
		auditRateChg.newStartTime := _newStartTime;
		auditRateChg.previousExpiryTime := _oldExpiryTime;
		auditRateChg.newExpiryTime := _newExpiryTime;
		auditRateChg.previousIgnoreEntry := _oldIgnoreEntry;
		auditRateChg.newIgnoreEntry := _newIgnoreEntry;
		auditRateChg.myRateEntry := _auditedObject;
	else 
		auditRateChg.isDeleted := true;
		auditRateChg.previousCost := _oldCost;
		auditRateChg.previousStartTime := _oldStartTime;
		auditRateChg.previousExpiryTime := _oldExpiryTime;
		auditRateChg.previousIgnoreEntry := _oldIgnoreEntry;
	endif;
	auditRateChg.auditedFOs.add(self);

//	self.causeEvent(Object_Update_Event, false, null);
	self.updateObjectEdition(self);
			
end;</source>
        <access>protected</access>
        <Parameter name="_newCost" type="Decimal"/>
        <Parameter name="_newStartTime" type="TimeStamp"/>
        <Parameter name="_newExpiryTime" type="TimeStamp"/>
        <Parameter name="_newIgnoreEntry" type="Boolean"/>
        <Parameter name="_oldCost" type="Decimal"/>
        <Parameter name="_oldStartTime" type="TimeStamp"/>
        <Parameter name="_oldExpiryTime" type="TimeStamp"/>
        <Parameter name="_oldIgnoreEntry" type="Boolean"/>
        <Parameter name="pDeleted" type="Boolean"/>
        <Parameter name="_auditedObject" type="CM_RateEntry"/>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="erase" id="18282340-c26b-4662-b617-8075c8424952">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.rate.doAuditRateHistory(null, null, null, null, null, self, true, CM_FinAuditRateHistory.Status_Delete);	

	inheritMethod(_eraseLevel);

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="extractAsCSV" id="976b2f09-628b-4aab-843c-09c9126fcd9c">
        <source>extractAsCSV(_debtorNode : CM_DebtorNode input; _service : CM_Service input; _rateEntryDetails : HugeStringArray io);

/*

Purpose:		Extract the record for CSV	

Date			Who		Reason
17/10/2012 		cnwmh5	Initial creation

*/

vars
	
	extractLine							: CnStringArray;
	costPerUnitLabels					: StringArray;

	iter								: Iterator;
	
	debtorCode							: String;
	debtorName							: String;
	derivedDebtorCode					: String;
	serviceName							: String;
	effectiveDate						: String;
	effectiveTime						: String;
	expiryDate							: String;
	expiryTime							: String;
	glCode								: String;
	
	ts									: TimeStamp;
	isOverRidingValue					: Boolean;
	
	costPerUnitLabel					: String;
	index								: Integer;
	
	debtorGroup							: String;

	calculationType : CM_CalculationType;	//29 Jun 2018	NDL	TFS 39338
	calcType : Integer;	//29 Jun 2018	NDL	TFS 39338
	subTerm : CM_SubTerminal;	//29 Jun 2018	NDL	TFS 39338
	tidalClass : HMS_TidalClass;	//29 Jun 2018	NDL	TFS 39338
begin

	if _debtorNode.isKindOf(CM_Debtor) then
		debtorCode			:=	_debtorNode.CM_Debtor.decfinName;
		derivedDebtorCode	:=	debtorCode;
		
		debtorGroup := 'D';
	else
		debtorGroup := 'G';
		
		if _debtorNode.myParentDebtorNode &lt;&gt; null then
			derivedDebtorCode	:=	_debtorNode.myParentDebtorNode.name;
		endif;
	endif;
	
	debtorName	:=	_debtorNode.name;
		
	isOverRidingValue	:=	self.rate.CM_DebtorRate.debtorNode = _debtorNode;
	serviceName			:=	_service.name.removeCrLfs();											
	effectiveDate		:=	self.startTimestamp.date.String;
	effectiveTime		:=	self.startTimestamp.time.String;
	expiryDate			:=	self.expiryTimestamp.date.String;
	expiryTime			:=	self.expiryTimestamp.time.String;
	
	if _service.genLCode &lt;&gt; null then
		glCode	:=	_service.genLCode.code.String;
	endif;
	
	//29 Jun 2018	NDL	TFS 39338
	calculationType := _service.myCalculationType;
	if calculationType&lt;&gt; null then
		calcType := calculationType.calculationType;
	endif;
	

	create costPerUnitLabels transient;
	self.getCostPerUnitLabels(costPerUnitLabels);
	
	index	:=	1;
	iter	:=	costPerUnitLabels.createIterator();
	
	while iter.next(costPerUnitLabel) do	
		//epr par 11969 		
		create extractLine transient;
		extractLine[10]	:=	null;			
		extractLine[1]	:=	debtorGroup;	// debtorCode;		// change to be row type = D for Debtor, G for Group
		extractLine[2]	:=	debtorName;
		extractLine[3]	:=	derivedDebtorCode;
		extractLine[4]	:=	isOverRidingValue.getYesNo;
		extractLine[5]	:=	serviceName;
		extractLine[6]	:=	effectiveDate;
		extractLine[7]	:=	effectiveTime;
		extractLine[8]	:=	expiryDate;
		extractLine[9]	:=	expiryTime;
		
		if costPerUnitLabel = serviceName then
			extractLine[10]	:=	null;
		else
			extractLine[10]	:=	costPerUnitLabel;	// Non-null will indicate a multi-line rate.
		endif;
		
		if calcType = INV_CALC_TYPE_DAYSINCE_SUBTERM then	//29 Jun 2018	NDL	TFS 39338
			subTerm := self.getMyTerminal.allSubTerminals.getMatchingDesc( costPerUnitLabel );
			extractLine[11] :=	self.getCPUforObject( subTerm ).String;
			
		elseif calcType = INV_CALC_TYPE_TIDAL_CLASS then	//29 Jun 2018	NDL	TFS 39338
			tidalClass := app.myRoot.allTidalClasses.getMatchingDesc( costPerUnitLabel );
			extractLine[11] :=	self.getCPUforObject( tidalClass ).String;
			
		else
			if self.allCostPerUnits.size &lt; index then 
				extractLine[11]	:=	"0";
			else
				extractLine[11]	:=	self.allCostPerUnits[index].String;						
			endif;
		endif;
		
		extractLine[12]	:=	glCode;	
		extractLine[13]	:=	self.adjustmentToBase.Real.String;	
		extractLine[14]	:=	self.percentageOfBase.Real.String;	
	 
		_rateEntryDetails.add(extractLine.asCSV(true));	
		delete extractLine;
		index := index + 1;
	endwhile;
	
	delete iter;			

epilog

	delete iter;
	delete extractLine;
	delete costPerUnitLabels;

end;</source>
        <Parameter name="_debtorNode" type="CM_DebtorNode" usage="input"/>
        <Parameter name="_service" type="CM_Service" usage="input"/>
        <Parameter name="_rateEntryDetails" type="HugeStringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllTimeStampRangesForEntry" id="f65564f5-03c4-49ab-b4ee-93704d52f005">
        <source>getAllTimeStampRangesForEntry( 	_startTsArray : TimeStampArray input;
								_endTsArray : TimeStampArray input
								);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2012	cnwndl1	Initial creation	Par 30375
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	now : TimeStamp;
	startTs : TimeStamp;
	endTs : TimeStamp;
	rateEntries : CM_RateEntryByStartTsDict;
	baseRateEntry : CM_RateEntry;

begin

	now := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	create rateEntries transient;
	self.rate.getBaseRateEntriesFrom( self.startTimestamp, self.expiryTimestamp, rateEntries );
	
	if self.expiryTimestamp.date.isValid then
		endTs := self.expiryTimestamp;
	else
		endTs := now;
	endif;
	foreach baseRateEntry in rateEntries reversed do
		if baseRateEntry.expiryTimestamp.date.isValid and baseRateEntry.expiryTimestamp &lt; endTs then
			// add the gap
			_startTsArray.add(baseRateEntry.expiryTimestamp);
			_endTsArray.add(endTs);
			endTs := baseRateEntry.expiryTimestamp.cnEcAddMinutes( - 1 );
		endif;
		if baseRateEntry.startTimestamp &lt; self.startTimestamp then
			startTs := self.startTimestamp;
		else
			startTs := baseRateEntry.startTimestamp;
		endif;
		_startTsArray.add(startTs);
		_endTsArray.add(endTs);
		endTs := startTs.cnEcAddMinutes( - 1 );
	endforeach;
	
epilog

	delete rateEntries;

end;</source>
        <Parameter name="_startTsArray" type="TimeStampArray" usage="input"/>
        <Parameter name="_endTsArray" type="TimeStampArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getBank" id="4d2e4439-cdad-42a0-8a5e-40b48ab41109">
