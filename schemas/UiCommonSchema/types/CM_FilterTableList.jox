<GUIClass name="CM_FilterTableList" id="4753ad36-e3e8-475e-bf0a-44680c98cf28">
    <superclass name="CMUI_ListTable"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <JadeMethod name="click" id="12215a7c-ebb9-410c-b255-d0a1412b4a52">
        <controlMethod name="CMUI_ListTable::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2015	cnwndl1	Initial creation

*/

vars

	filterTable : CM_FilterTable;

begin

	if self.parent.isKindOf( CMUI_FilterTableFrame ) then
		filterTable := self.parent.CMUI_FilterTableFrame.myFilterTable;
		if filterTable &lt;&gt; null then
			if self = filterTable.lstFilterProxy then
				filterTable.lstFilterProxy_click( self );
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
