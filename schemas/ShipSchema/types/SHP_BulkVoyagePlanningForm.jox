    <JadeMethod name="btnViewOps_click" id="dd194b68-ddd2-470d-9910-c28c37b46ed7">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnViewOps_click(btn: Button input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02 September 2015	cnwdap1		Initial creation PAR #
//
vars
	theTable : CM_DataTable;

begin
	if (not self.toolbarClickPreProcessing(VIEW_BAYVIEW)) then
		return;
	endif;

	app.mousePointer := MousePointer_HourGlass;
	self.switchDisplayMode(ShpDisplayMode_Ops, true);

	theTable := self.tblGridAreaInfo;
	theTable.borderStyle := Frame.BorderStyle_None;
	theTable.scrollBars:=Table.ScrollBars_Both;
	theTable.rows :=0;// 12;
	theTable.columns := 1;
	theTable.fixedColumns := 0;
	theTable.fixedRows := 0;
	theTable.selectMode := Table.SelectMode_CurrentRow;
	self.showTableStatsColumnLabels();
	theTable.accessRow(StatsTableRowLabel).fontBold := true;
	theTable.accessColumn(1).backColor := self.colorHeadingColumn;
	theTable.accessRow(StatsTableRowLabel).backColor := self.colorHeadingColumn;
	theTable.fitColumnWidth(1,5);
	self.showTableStats();	// 28/7/16 cnwmp6 TFS 1601
	theTable.fixedRows := 1; // TFS 4133

epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
