    <JadeMethod name="includeCargoType" id="7873a376-4fd7-4416-9da8-3ca3d2b40255">
        <source>includeCargoType(_cargoType :Integer; _trx : CM_Transaction; _camAgent : CM_CamControllerAgent; _logExcluded : Boolean) : Boolean;
/*
Date		Who		Reason
27/06/2012	cnwcs5	Initial creation - par 29601
*/
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
// 15 May 2014	cnwrs1	Par 34159 - include Chassis in Codeco
// 04 Aug 2014	cnwrs1	par 34882 - correct log exclusion message
// 19 May 2017	cnwrs1	TFS 4259 _ Penn Seaboard implimentation
vars
	result : Boolean;
	tmpCargoType : CM_CargoType;
	cargoType  : CM_CargoType;
	str : String;
	int : Integer;
begin
	result := self.allRegisteredCargoTypes.includes(_cargoType);
	if not result then
		tmpCargoType := app.myRoot.allCargoTypesById[_cargoType];
		foreach int in self.allRegisteredCargoTypes do
			cargoType := app.myRoot.allCargoTypesById[int]; 
			if tmpCargoType.isChildTypeOf(cargoType) then
				result := true;
				break;
			endif;
		endforeach;
	endif;
	if not result and _logExcluded then
//		tmpCargoType := app.myRoot.allCargoTypesById[_cargoType];
		if tmpCargoType = null then
			str := _cargoType.String;
		else
			str := tmpCargoType.description;
		endif;
		_camAgent.logReasonForExclusion (_trx, 'Cargo type '&amp;str&amp;' is not a Selected Cargo Type');
	endif;
	
	return result;
epilog

end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_trx" type="CM_Transaction"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <Parameter name="_logExcluded" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="incrementTSForContext" id="a8ed8e26-75c7-4778-975c-f02f87f881a1">
        <source>incrementTSForContext( _contextObj : CM_Object; _ts : TimeStamp io );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2018	jlgndl1	Initial creation	TFS 37406

*/

vars

begin

	if not self.singleContainerPerUNB then
		return;
	endif;
	
	if _contextObj = null then
		return;
	endif;
	
	if _contextObj.isKindOf( CM_CamMessage ) then
		if _contextObj.CM_CamMessage.activity = CODECO_GATEIN then
			_ts := _ts.addMinutes( 1 );
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_contextObj" type="CM_Object"/>
        <Parameter name="_ts" type="TimeStamp" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isCAMGroupMatch" id="59a915e6-c8dc-46ae-8ddc-8482145a4981">
        <source>isCAMGroupMatch( _trx :CM_TITransaction; _camAgent : CM_CamControllerAgent; _logExcluded :Boolean ) : Boolean;
/*	
	Purpose:		Determine whether to process transaction based on operator and freight forwarder
					specified on _camGroup
	Parameters:		ti	- ti 
	Return Value:	true if ti values match cam group values for operator and freight forwarder	
					false otherwise

Date			Who		Reason
26 June 2008	concms1	Par 17268 CAMs message by freight forwarder
02/04/2009		cnwrl1	CCMS 1819 EDI messaging needs the ability to send CAMS for operators that slot share
17/07/2012		cnwcs5	par 29601 log excluded transactions
18 Jul 2012	    cnwrs1	CCMS 1269 CAMS remove CM_CamTask
4 June 2014     cnwgb1  PAR 34285 Null Voyage false Positive. I rewrote the method
16/04/2020		jlgdap1	TFS 49125 SNO COARRI Issue
*/
vars
	ti			:CM_TrackedItem;	// par 29601 July 2012
	camGroup	:CM_CamGroup;		// par 29601 July 2012
	tiOp, 
	voyageOp	:String;			// par 29601 July 2012
begin
	ti 			:= _trx.myTrackedItem;	// par 29601 July 2012
	camGroup	:= self.camGroup;		// par 29601 July 2012
	
	// First filter out the situation where the Cam Group has a Freight Forwarder Restriction
	if camGroup.allFreightForwarders.size &gt; 0 and not camGroup.allFreightForwarders.includes (ti.myFreightForwarder) then
		if _logExcluded then
			_camAgent.logReasonForExclusion (_trx, 'Cargo Freight Forwarder (' &amp; ti.freightForwarderCode &amp; ') does not match CAM Group Freight Forwarders');
		endif;
		return false;
	endif;
    

	if self.useTiOperator then
		tiOp	:= ti.operatorCode;
		
		// If there is a cargo operator and it's in the cam group list
        if tiOp &lt;&gt; null and camGroup.operators[ tiOp ] &lt;&gt; null then
            return true;
		endif;
    endif;

    if self.useVoyageOperator then
        if ti.myVoyage.myOperator &lt;&gt; null then
			voyageOp	:= ti.myVoyage.myOperator.code;
		endif;
		// TFS 49125 if the cam protocol "Include Tranship Imports for Voyage Operator" is true,
		// and the ti is a tranship, use the import voyage operator
		app.writeLog(method.qualifiedName &amp; Tab &amp; "_trx type is " &amp; _trx.type.String &amp; " class is " &amp; _trx.class.name, LogINFO);
		if self.getTranshipImportsVoyageOp and ti.isTranshipItem and not _trx.isReleaseType then
			if ti.myVoyageTranshipImport &lt;&gt; null then
				voyageOp := ti.myVoyageTranshipImport.myOperator.code;
			endif;
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Switched voyage operator to " &amp; voyageOp, LogINFO);
		endif;
		// TFS 49125 end
		
		// If there is a voyage operator and it's in the cam group list. (Never match the null voyage!)
        if voyageOp &lt;&gt; null and camGroup.operators[ voyageOp ] &lt;&gt; null then
            return true;
		endif;
	endif;

	if _logExcluded then
        if self.useVoyageOperator and self.useTiOperator then
			_camAgent.logReasonForExclusion (_trx, 'Neither Cargo Operator (' &amp; tiOp &amp; ') or Voyage Operator (' &amp; voyageOp &amp; ') match CAM Group Operators');
        elseif self.useVoyageOperator then
			_camAgent.logReasonForExclusion (_trx, 'Voyage Operator (' &amp; voyageOp &amp; ') does not match CAM Group Operators');
        else
			_camAgent.logReasonForExclusion (_trx, 'Cargo Operator (' &amp; tiOp &amp; ') does not match CAM Group Operators');
        endif;
    endif;

    return false;
    
epilog

end;</source>
        <Parameter name="_trx" type="CM_TITransaction"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <Parameter name="_logExcluded" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCAMGroupMatchEvent" id="22ea8d6d-e5cf-4f95-8b56-575fe8a00cdf">
        <source>isCAMGroupMatchEvent(_trx :CM_EventTransaction; _ti : CM_TrackedItem; _camAgent : CM_CamControllerAgent; _logExcluded :Boolean) : Boolean;
//
//20 Apr 2016	cnwrs1	Par 37788 TFS 1875 Came Events does not check cam group operators nor cargotype list
//16 Apr 2020	jlgdap1	TFS 49125 SNO COARRI Issue
//
vars
	tiOp : String;
	camGroup : CM_CamGroup;
	voyageOp : String;
begin
	camGroup := self.camGroup;
	if self.useTiOperator then
		tiOp := _ti.operatorCode;
		// If there is a cargo operator and it's in the cam group list
        if tiOp &lt;&gt; null and camGroup.operators[tiOp] &lt;&gt; null then
            return true;
		endif;
    endif;

    if self.useVoyageOperator then
        if _ti.myVoyage.myOperator &lt;&gt; null then
			voyageOp := _ti.myVoyage.myOperator.code;
		endif;
		// TFS 49125 if this is a voyage departure event, and the cam protocol "Include Tranship Imports for Voyage Operator" is true,
		// and the ti is a tranship, use the import voyage operator
		if _trx.type = EVT_VoyageDeparture and _trx.getMyVoyageObject = _ti.myVoyageTranshipImport then
			if self.getTranshipImportsVoyageOp and _ti.isTranshipItem then
				voyageOp := _ti.myVoyageTranshipImport.myOperator.code;
				app.writeLog(method.qualifiedName &amp; Tab &amp; "Switched voyage operator to " &amp; voyageOp, LogDEBUG);
			endif;
		endif;
		// TFS 49125 end
		
		// If there is a voyage operator and it's in the cam group list. (Never match the null voyage!)
        if voyageOp &lt;&gt; null and camGroup.operators[voyageOp] &lt;&gt; null then
            return true;
		endif;
	endif;

	if _logExcluded then
        if self.useVoyageOperator and self.useTiOperator then
			_camAgent.logReasonForExclusion(_trx, 'Neither Cargo Operator (' &amp; tiOp &amp; ') or Voyage Operator (' &amp; voyageOp &amp; ') match CAM Group Operators');
        elseif self.useVoyageOperator then
			_camAgent.logReasonForExclusion(_trx, 'Voyage Operator (' &amp; voyageOp &amp; ') does not match CAM Group Operators');
        else
			_camAgent.logReasonForExclusion(_trx, 'Cargo Operator (' &amp; tiOp &amp; ') does not match CAM Group Operators');
        endif;
    endif;

    return false;

end;
</source>
        <Parameter name="_trx" type="CM_EventTransaction"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <Parameter name="_logExcluded" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
