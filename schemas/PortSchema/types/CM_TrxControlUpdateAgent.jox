    <JadeMethod name="trxUpdateAssignOutwardRail" id="584b4ca1-b0f8-4a5f-a7ae-123fc859626f">
        <updating/>
        <source>trxUpdateAssignOutwardRail(_cmif_bps :  ObjectArray; _targetIORake : CM_RailJSInOutRake; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*
01 Aug 2024 navlc30 Bug 65063: FR | 53891 - Mobile App changes for Delivery Dispatch (FR issues)
12 Sep 2024 navlc30 Bug 65971: When we assign bulk releases to a wagon to create rail jobs, the first warehouse and the number of warehouse locations are not updated.

*/
vars
	cmifBuildPriority : CMIF_BuildPriority;
	anObject : Object;
	targetType : Integer;
	tmpRailJob : CM_RailJob;
	tmpReq : CM_Request;
	tmpRes : CM_ReserveDetail;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	targetType := _targetIORake.inOut.outwards;

	app.setContinueCMExceptions(true);
		
	beginTransaction;
	foreach anObject in _cmif_bps do
		cmifBuildPriority := anObject.CMIF_BuildPriority;
		app.myUtilityUA.utlBuildPriorityRailOps(cmifBuildPriority, _passport);

		foreach tmpRes in cmifBuildPriority.allReservesToProcess do
			tmpReq := tmpRes.getRequest();	//SFW1035
			if tmpReq = null then
				continue;
			endif;
			tmpRailJob := tmpReq.myJob.CM_RailJob;
			if tmpRailJob = null then
				continue;
			endif;
			//tmpRailJob.setJobPlannedLocation();				//01.08.2024 navlc30 #65063
			tmpRailJob.setJobPlannedLocation(true); //26/08/2024	navkc1 CR 63588 Task 63589		//16.09.2024 navlc30 #65971			
			app.myUtilityUA.utlUpdateJobRailOps(tmpRailJob, _targetIORake, true, targetType, _passport);
			if _passport.hasErrors() then
				return;
			endif;

		endforeach;
	endforeach;

epilog	
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_cmif_bps" type="ObjectArray"/>
        <Parameter name="_targetIORake" type="CM_RailJSInOutRake"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateAssignOutwardTrain" id="18f9dcb7-28e5-4b6c-90c8-9e1da899db2b">
        <updating/>
        <source>trxUpdateAssignOutwardTrain(_cmif_bps :  ObjectArray; _train : CM_Train input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 17/02/2023		navdap1			TFS 56580 EUP EDI for Assigning Releases to Wagons
//	12 Sep 2024 	navlc30 		Bug 65971: When we assign bulk releases to a wagon to create rail jobs, the first warehouse and the number of warehouse locations are not updated.
// ---------------------------------------------------------------------------

vars
	cmifBuildPriority : CMIF_BuildPriority;
	anObject : Object;
	targetType : Integer;
	tmpRailJob : CM_RailJob;
	tmpReq : CM_Request;
	tmpRes : CM_ReserveDetail;
	checkReq : CM_Request;				// TFS 56580
	requestsProcessed : CM_ObjectSet;	// TFS 56580
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	
	create requestsProcessed transient;		// TFS 56580
	
	beginTransaction;
	foreach anObject in _cmif_bps do
		cmifBuildPriority := anObject.CMIF_BuildPriority;
		app.myUtilityUA.utlBuildPriorityRailOps(cmifBuildPriority, _passport);

		foreach tmpRes in cmifBuildPriority.allReservesToProcess do			
			// TFS 56580 start
			//tmpReq := tmpRes.getRequest();	//SFW1035
			foreach checkReq in tmpRes.allRequests do
				if requestsProcessed.includes(checkReq) then
					continue;
				endif;
				tmpReq := checkReq;
				break;
			endforeach;
			// TFS 56580 start			
			//tmpReq := cmifBuildPriority.allCMIFRequests.first().myNewRequest;			
			// TFS 56580 end
			// TFS 56580 end
			if tmpReq = null then
				continue;
			endif;
			tmpRailJob := tmpReq.myJob.CM_RailJob;
			if tmpRailJob = null then
				continue;
			endif;
			tmpRailJob.setJobPlannedLocation(true);		//16.09.2024 navlc30 #65971			
			app.myUtilityUA.utlUpdateJobTrains(tmpRailJob, _train, true,  _passport);
			requestsProcessed.add(tmpReq);			// TFS 56580
		endforeach;
	endforeach;

epilog	
	delete requestsProcessed;						// TFS 56580
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_cmif_bps" type="ObjectArray"/>
        <Parameter name="_train" type="CM_Train" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
