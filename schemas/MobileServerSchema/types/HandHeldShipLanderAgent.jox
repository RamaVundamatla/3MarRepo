    <JadeMethod name="init" id="5e9539df-73f2-4466-b54e-781dc5ead2fb">
        <updating/>
        <source>init() updating;
// ---------------------------------------------------------------------------
// Created:		20 October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.myCraneLaneLC_AFT := null;
	self.myCraneLaneLC_FWD := null;
	self.myMachine := null;
	self.myRTQTask_AFT := null;
	self.myRTQTask_FWD := null;
	self.myTI_AFT := null;
	self.myTI_FWD := null;
	self.myVoyageJob_AFT := null;
	self.myVoyageJob_FWD := null;
end;</source>
