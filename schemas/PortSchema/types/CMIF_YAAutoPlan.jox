        <source>isForDirectDelivery():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2013	cnwndl1	Initial creation	Par 31102

*/

vars

	invalidObj : Boolean;

begin

	if self.myTrackedItem &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, self.myTrackedItem, invalidObj );
		return self.myTrackedItem.directDelivery;
	endif;
	
	return false;

epilog

end;</source>
