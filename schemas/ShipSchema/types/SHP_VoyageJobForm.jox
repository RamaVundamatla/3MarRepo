    <JadeMethod name="doComboHatchLidsBuild" id="6c452125-7cd1-4d24-8d2b-ef15630e6027">
        <source>doComboHatchLidsBuild();
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	aBay : CM_Bay;
	aVoyage : CM_Voyage;
	idx : Integer;
	aLid : CM_HatchLid;
begin
	self.cmbHatchLids.rows := 0;
	self.cmbHatchLids.setSelected(null);
	
	if self.cmbBayId.listObject = null then
		return;
	endif;
	
	if self.cmbJobType.listObject &lt;&gt; null then
		if not self.cmbJobType.listObject.CM_JobType.isHatchType then
			return;
		endif;
	endif;
	aBay := self.cmbBayId.listObject.CM_Bay;
	aVoyage := self.filterVoyage;
	
	foreach aLid in aBay.allHatchLids do
		idx := self.cmbHatchLids.addItemObject(aLid.getDescription(aBay),aLid);
	endforeach;
	self.cmbHatchLids.setSelected(null);


end;</source>
    </JadeMethod>
    <JadeMethod name="doComboJobIdBuild" id="93ba0ced-dc1d-4c8b-9f67-639da1a4d11a">
        <source>doComboJobIdBuild();
//--------------------------------------------------------------
//Created: 23 April 2003 By: cnwgd1
//23/08/2016 cnwma1 TFS #2557:SPT - Missing Planned Location on Sequence Sheets- Issue not fixed from previous TFS
//--------------------------------------------------------------
vars
	idx : Integer;
	job : CM_Job;
	voyJobs : CM_JobSet;
begin
	self.cmbJobId.clear();
	self.tblSearch.setValueByControlName(self.cmbJobId.name, null);
	if self.filterVoyage = null then
		return;
	endif;

	voyJobs := self.filterVoyage.allVoyageJobs;
	//foreach job in voyJobs do                                               //23/08/2016 cnwma1 TFS# 2557
	foreach job in voyJobs where not job.isKindOf(CM_VoyageROROJob) do         //23/08/2016 cnwma1 TFS# 2557
		if self.filterStatus = FILTER_STATUS_NULL or job.status = self.filterStatus then
			idx := self.cmbJobId.addItem(job.jobId);
			self.cmbJobId.itemObject[idx] := job;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doComboStatusBuild" id="3b7e4f14-1ac2-4948-ad03-680c69e4971b">
        <source>doComboStatusBuild() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 July 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	self.cmbStatus.addItem(null);
	self.cmbStatus.addItem(app.jobStatusEnumToString(JOB_UNACTIONED));
	self.cmbStatus.addItem(app.jobStatusEnumToString(JOB_PART_COMPLETE));
	self.cmbStatus.addItem(app.jobStatusEnumToString(JOB_COMPLETE));

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
