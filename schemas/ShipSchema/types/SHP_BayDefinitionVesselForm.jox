    <JadeMethod name="doLoadTblCellLimits" id="10e3f0ff-96cc-431a-a194-a72bf8a04ad2">
        <source>doLoadTblCellLimits():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 July 2010	cnwndl1	Initial creation		Par 25127	/ CCMS 1140

*/

vars

	theBay : CM_Bay;
	aCellDef : CM_CellDefn;
	aTierDef : CM_TierDefn;
	numCols : Integer;
	tableHeight : Integer;
	editMode : Boolean;
	
	index : Integer;
	rowData : String;
	
begin

	theBay := self.myCurrentBay;
	if theBay = null then
		numCols := 0;
		editMode := false;
		self.shtBayCellLimit.caption := app.getErrorString1(BayDimensions, null);
	else
		numCols := theBay.allCellsOnDeckByOrdinal.size;
		editMode := theBay.isTransient;
		self.shtBayCellLimit.caption := app.getErrorString1(BayDimensions, theBay.id);
	endif;

	// set up the 'On Deck' table
	self.tblOnCellDims.clear();
	self.tblOnCellDims.clearAllSelected();
	self.tblOnCellDims.fixedRows := 1;
	self.tblOnCellDims.fixedColumns := 1;
	self.tblOnCellDims.columns := numCols + 1;
	self.tblOnCellDims.rows := 4;
	tableHeight := (self.tblOnCellDims.accessRow(1).height * 5) + 4;	// 4 real rows plus room for a scroll bar if required
	
	self.tblOnCellDims.move( 	2,
								20,
								self.shtBayCellLimit.width - 10,
								tableHeight );
								
	self.tblOnCellDims.setCellText(1,1,app.getErrorString(On_deck_cells) );
	self.tblOnCellDims.setCellText(2,1,app.getErrorString(OnDeck20CellMaxPileTons) );
	self.tblOnCellDims.setCellText(3,1,app.getErrorString(OnDeck40CellPileTons) );
	self.tblOnCellDims.setCellText(4,1,app.getErrorString(OnDeckCellMaxHeightMetres) );
	
	if theBay &lt;&gt; null then
		// add the 'On deck' data.
		index := 1;
		foreach aCellDef in theBay.allCellsOnDeckByOrdinal do
			index := index + 1;
			// headings
			self.tblOnCellDims.setCellText(1,index,aCellDef.id.trimBlanks);
			self.tblOnCellDims.accessColumn(index).itemObject := aCellDef;
			self.tblOnCellDims.accessCell(1,index).alignment := Table.Alignment_Center_Middle;
			//real data
			self.tblOnCellDims.accessColumn(index).alignment := Table.Alignment_Right_Middle;
			self.tblOnCellDims.setCellText(2,index,aCellDef.maxPileWeight20.asStringJMT);
			self.tblOnCellDims.setCellText(3,index,aCellDef.maxPileWeight40.asStringJMT);
			self.tblOnCellDims.setCellText(4,index,aCellDef.maxHeight.asStringJMTWithPrecision(2,false));
			if editMode then	// in edit mode, allow input.
				// allow Integers only
				self.tblOnCellDims.decimals := 0;
				self.tblOnCellDims.accessCell(2,index).inputType := Table.InputType_TextNumeric;
				self.tblOnCellDims.accessCell(3,index).inputType := Table.InputType_TextNumeric;
				// must be decimal in this one
				self.tblOnCellDims.decimals := 2;
				self.tblOnCellDims.accessCell(4,index).inputType := Table.InputType_TextNumeric;
			endif;
		endforeach;

	endif;

	// set up the 'Under Deck' table
	self.tblUnderCellDim.clear();
	self.tblUnderCellDim.clearAllSelected();
	self.tblUnderCellDim.fixedRows := 1;
	self.tblUnderCellDim.fixedColumns := 1;
	if theBay &lt;&gt; null then
		numCols := theBay.allCellsUnderDeckByOrdinal.size;
	endif;
	self.tblUnderCellDim.columns := numCols + 1;
	self.tblUnderCellDim.rows := 4;
	tableHeight := (self.tblUnderCellDim.accessRow(1).height * 5) + 4;
	
	self.tblUnderCellDim.move( self.tblOnCellDims.left,
								self.tblOnCellDims.top + self.tblOnCellDims.height + 50,
								self.tblOnCellDims.width,
								tableHeight );
								
	self.tblUnderCellDim.setCellText(1,1,app.getErrorString(Under_deck_cells) );
	self.tblUnderCellDim.setCellText(2,1,app.getErrorString(UnderDeck20CellMaxPileTons) );
	self.tblUnderCellDim.setCellText(3,1,app.getErrorString(UnderDeck40CellPileTons) );
	self.tblUnderCellDim.setCellText(4,1,app.getErrorString(UnderDeckCellMaxHeightMetres) );
	
	if theBay &lt;&gt; null then
		// add the 'Under deck' data.
		index := 1;
		foreach aCellDef in theBay.allCellsUnderDeckByOrdinal do
			index := index + 1;
			self.tblUnderCellDim.setCellText(1,index,aCellDef.id.trimBlanks);
			self.tblUnderCellDim.accessColumn(index).itemObject := aCellDef;
			self.tblUnderCellDim.accessCell(1,index).alignment := Table.Alignment_Center_Middle;
			
			self.tblUnderCellDim.accessColumn(index).alignment := Table.Alignment_Right_Middle;
			self.tblUnderCellDim.setCellText(2,index,aCellDef.maxPileWeight20.asStringJMT);
			self.tblUnderCellDim.setCellText(3,index,aCellDef.maxPileWeight40.asStringJMT);
			self.tblUnderCellDim.setCellText(4,index,aCellDef.maxHeight.asStringJMTWithPrecision(2,false));
			if editMode then
				self.tblUnderCellDim.decimals := 0;
				self.tblUnderCellDim.accessCell(2,index).inputType := Table.InputType_TextNumeric;
				self.tblUnderCellDim.accessCell(3,index).inputType := Table.InputType_TextNumeric;
				self.tblUnderCellDim.decimals := 2;
				self.tblUnderCellDim.accessCell(4,index).inputType := Table.InputType_TextNumeric;
			endif;
		endforeach;
		
	endif;
	
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPrintBay" id="80754475-56fd-435d-8b25-32139c4fc7fb">
        <updating/>
        <source>doPrintBay() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	bayFrame,bayFrameUD : CMUI_GridAreaFrame;
	pxyJadeReport	: JadeReport;
	header, theType, theCode :String;
	theLeft : Real;
	bckClr : Integer;
	cvs : CM_CellularVesselStructure;
begin
	if self.myCurrentBay = null then
		app.msgBox("Please select a bay from the list.", "Select Bay", MsgBox_Information_Icon+MsgBox_OK_Only);
		return;
	endif;
	theCode := "Print"; // PAR 22952
	if self.myCurrentCellularVessel &lt;&gt; null then
		theType := "Vessel";
		if self.myCurrentCellularVessel.myVessel &lt;&gt; null then // PAR 22952
			theCode := self.myCurrentCellularVessel.myVessel.name.trimBlanks;
		elseif self.myProxyCellularVessel &lt;&gt; null then // PAR 22952
			cvs := self.myProxyCellularVessel.pxyGetRealObject().CM_CellularVesselStructure; // PAR 22952
			if cvs &lt;&gt; null and cvs.myVessel &lt;&gt; null then // PAR 22952
				theCode := cvs.myVessel.name.trimBlanks; // PAR 22952
			endif;
		endif;
	endif;	
	header := theType &amp; " : " &amp; theCode &amp;  ". Bay Definition, Bay " &amp; self.myCurrentBay.id;
	
	// PAR 22952
	self.lblReport_1.width := 200;
	self.lblReport.left := self.lblReport_1.left + self.lblReport_1.width + 10;
	
	self.doPrintOutTable(null, header,true,false, true, true);

// ####################################

	if app.msgBox("Print The Layout For " &amp; self.myCurrentBay.id &amp; "?","Confirm Bay Layout Print",MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
		create pxyJadeReport transient;
		app.printer.setReport(pxyJadeReport);
		app.printer.newPage();
//		app.printer.setHeader(header);
		app.printer.setFooter(null);
		app.printer.setPrintPosition(50);
//		theReport.printLine("");

		theLeft := self.mySDF.myHLabels.left;
		self.mySDF.myHLabels.left := 0;
		app.printer.print(self.mySDF.myHLabels);
		self.mySDF.myHLabels.left := theLeft;
		
		bayFrame := self.frmGridArea.getControl(ONDECK);
		if bayFrame &lt;&gt; null then
			bckClr := bayFrame.backColor;
			bayFrame.backColor := White;
			app.printer.print(bayFrame);
			bayFrame.backColor := bckClr;
		endif;
	
		bayFrameUD := self.frmGridArea.getControl(UNDERDECK);
		if bayFrameUD &lt;&gt; null then
			bckClr := bayFrameUD.backColor;
			bayFrameUD.backColor := White;
			bayFrameUD.height := bayFrameUD.myGridArea.allGridRows.last.y2 + 100;
			app.printer.print(bayFrameUD);
			bayFrameUD.backColor := bckClr;
		endif;	
	
		// print the legend
		theLeft := self.frmLegend.left;
		self.frmLegend.left := 10;
		self.frmLegend.width := 400;
		self.frmLegend.borderStyle := Frame.BorderStyle_None;
		app.printer.print(self.frmLegend);
		self.frmLegend.left := theLeft;

		app.printer.close();
		app.printPreview(pxyJadeReport, true);
	endif;

epilog
	self.lblReport_1.caption := null;
	self.lblReport.caption := null;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="8226e3bc-f455-4545-a2f1-a6af3ca53599">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02/03/2021	navmd1		TFS 49052 MACS3 Vessel Library API
// 03/11/2022   navds21     ChangeRequest 55184: MTN - Hide MACS3 and NSD Vessel Definition imports
// ---------------------------------------------------------------------------

vars
	aW,aH ,	tmpTop : Real;
begin
	inheritMethod();
	tmpTop := (self.frmToolbar.height+VerticalSpacing);
	self.lblVessel.top := tmpTop;
	self.cmbVessel.top := tmpTop;
	self.cmbBayList.top := tmpTop;
	self.lblBayList.top := tmpTop;
	tmpTop := (tmpTop+VerticalSpacing+cmbVessel.height);
	self.fldVessel.top := tmpTop;

	self.fldVessel.height := self.clientHeight - self.fldVessel.top;
	
	self.frmToolBarBay.top := 0;
	self.frmToolBarBay.left := 1;
	self.frmToolBarLayout.top := 0;
	self.frmToolBarLayout.left := 1;
	//Start 03.11.2022 navds21 TFS 55184
	if not (app.isSpecial or app.myPassport.myUser.isSuperUser) then
		self.grpWizard.top := self.grpMACS3.top;
		self.grpWizard.height := 530;
	endif;
	//End 03.11.2022 navds21 TFS 55184
	// #################################
	// BAY LAYOUT TOOLBAR
	self.splLayout.move(1,self.frmToolBarLayout.clientHeight+2 ,self.shtBayLayout.width, self.shtBayLayout.height - (self.frmToolBarLayout.clientHeight).Integer);
	self.splLayout.cnEcResizeContents();	

	self.mySDF.myHScroll.move(0, self.mySDF.height - self.mySDF.ScrollBarWidth - 2, self.mySDF.width - self.mySDF.ScrollBarWidth, self.mySDF.ScrollBarWidth);
	self.mySDF.myVScroll.move(self.mySDF.width - self.mySDF.ScrollBarWidth , 0, self.mySDF.ScrollBarWidth, self.mySDF.height);
	
	if self.mySDF.allGridAreasByRowColumn.isEmpty then
		aW :=self.mySDF.width;
		aH := self.mySDF.height;
	else
		aW := self.mySDF.getWidthOfAllFrames();
		aH := self.mySDF.getHeightOfAllFrames() + 70;
	endif;
	self.mySDF.resizeDrawingFrame(aW,aH);
	self.mySDF.repositionScrollBars();
	self.grpBayDetails.centreVerticallyInParent();
	self.grpBayDetails.centreHorizontallyInParent();

	self.grpVesselDetails.centreVerticallyInParent();
	self.grpVesselDetails.centreHorizontallyInParent();	
	
	self.tblOnCellDims.width := self.shtBayCellLimit.width - 10;	//29 July 2010	NDL	Par 25127	/ CCMS 1140
	self.tblUnderCellDim.width := self.shtBayCellLimit.width - 10;	//29 July 2010	NDL	Par 25127	/ CCMS 1140
	
	self.grpStructure.centreVerticallyInParent();	// TFS 49052
	self.grpStructure.centreHorizontallyInParent(); // TFS 49052
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="cf7d20ab-089f-4862-9cff-7e8e0bc3400a">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	theRealVessel	: CM_CellularVesselStructure;
	rtnValue		: Boolean;
	result			: Integer;
	conflictManager : CMIF_HMS_ConflictsManager;

begin
	
	//Check we have valid bay ids first as the labels are being processed on the form to populate controls.
	if not self.validateTierCellLabels('Physical Bay Order', self.txtBayOrder.text) then
		app.msgBox("The Physical Bay Order is invalid. Labels must be a 2 character number." &amp; CrLf &amp; "(e.g. 01 03 05....)", "Invalid Physical Bay Order", MsgBox_OK_Only);
		self.txtBayOrder.setFocus;
		return false;
	endif;
	app.mousePointer := Window.MousePointer_HourGlass;

	if self.mode &lt;&gt; self.Mode_Update
	or self.viewModeOnly then
		return false;
	endif;
	
	if self.myProxyCellularVessel = null then
		return false;
	endif;
	
	theRealVessel := self.myProxyCellularVessel.pxyGetRealObject();				

	self.doSetProxyVesselCellular(self.myProxyCellularVessel);

	while true do
		
		app.myTrxUA.trxUpdateVesselStructure(self.myProxyCellularVessel, app.myPassport);
		//process.debug;
		if app.myPassport.trxCompletedOK then
			self.myCurrentCellularVessel := self.myProxyCellularVessel.pxyGetRealObject.CM_CellularVesselStructure;
			delete self.myProxyCellularVessel;
			break;
		else
			
			result := app.showErrorWarningDialog('Vessel Definition', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
		endif;
		return false;
	endwhile;
	
	self.anythingChanged := false;	
	self.anythingChangedBay := false;

	if conflictManager &lt;&gt; null then
		if (not conflictManager.allCMIFConflicts.isEmpty) then
			if app.msgBox('There are Voyages with conflicts in the system. Do you want to view the "Conflict Report" now?', 'View Conflict Report', MsgBox_Exclamation_Mark_Icon + MsgBox_Yes_No + MsgBox_Default_Second) = MsgBox_Return_Yes then
				self.myAssistant.showConflictsReport(conflictManager, self.myTerminal, self.myTerminal.myHarbour);
			else
				delete conflictManager;			
			endif;
		else
			delete conflictManager;
		endif;
	endif;
		
	global.beep;
	rtnValue := true;
	return rtnValue;

epilog
	self.frmModalDialog.visible := false;
	self.btnBaySeqBay.caption := self.CAPTION_BTN_SEQNUM;
	self.btnBaySeqBay.bubbleHelp := self.BUBBLE_SEQNUM;
	self.frmToolBarBay.positionToolbarControls();
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveWizard" id="cd8c1562-6deb-4c18-afda-767384aba311">
        <updating/>
        <source>doSaveWizard() updating;
// ---------------------------------------------------------------------------
// Created:		22 May 2008 By Andrew Bishop cnwab1
//
// Purpose:		 // PAR 17912
//
// ---------------------------------------------------------------------------
vars
	pxyVessel : CM_CellularVesselStructure;
	result : Integer;
	aBay : CM_BayDefn;
	tmpTxt : TextBox;
begin
	tmpTxt := self.validateWizardData();
	if tmpTxt &lt;&gt; null then
		global.beep;
		tmpTxt.setFocus();
		return;
	endif;


	pxyVessel := app.createUpdateProxy(self.myCurrentCellularVessel).CM_CellularVesselStructure;
	
	pxyVessel.setProxyCellularVessel(null,true,true,false, 0); // PAR 32286
	pxyVessel.createProxyBaysFromString(self.txtWBayOrder.text.trimBlanks());
	
	foreach aBay in pxyVessel.allBaysByOrdinal do
		aBay.setProxyCellsODFromLabels(txtWOnDeckCells.text,true);
		aBay.setProxyCellsUDFromLabels(self.txtWUnderDeckCel.text,null,false);
		aBay.setProxyTiersODFromLabels(self.txtWOnDeckTier.text,false);
		aBay.setProxyTiersUDFromLabels(self.txtWUnderDeckTr.text,false);
	endforeach;
	
	
	
	while true do
		
		app.myTrxUA.trxUpdateVesselStructure(pxyVessel, app.myPassport);
		if app.myPassport.trxCompletedOK then
			
			global.beep;
			
			// PAR 18145
			app.msgBox("The creation of the bay definitions for '" &amp; self.myCurrentCellularVessel.myVessel.code &amp; "' has been Successful!","Vessel Structure",MsgBox_Information_Icon);
			self.frmWizard.visible := false;
			//self.cmbVessel.click(self.cmbVessel);
			break;
		else
			
			result := app.showErrorWarningDialog('Vessel Definition Wizard', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return;
	endwhile;
	

epilog
	delete pxyVessel;
	app.mousePointer := Window.MousePointer_Default;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSetAllSlots40" id="0ffa7ce8-87bf-4be6-8611-5905f6ec8806">
        <source>doSetAllSlots40();
//----------------------------------------------------------------
//	Created:	29 June 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	proxyVessel : CM_CellularVesselStructure;
	bay			: CM_Bay;	
begin
	if self.myProxyCellularVessel = null then
		return;
	endif;

	app.mousePointer := Window.MousePointer_HourGlass;
	proxyVessel := self.myProxyCellularVessel;
	
	foreach bay in proxyVessel.allBays40ByLabel do
		bay.setProxyBaySlots40();
	endforeach;
	global.beep;
epilog
	app.mousePointer := Window.MousePointer_Default;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSetProxyAttributesFromGUI" id="2ba9c4a5-d223-4450-b88d-01008f3138b4">
        <updating/>
        <source>doSetProxyAttributesFromGUI() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		Sets the Proxy copy of the Bay and Cell and Slots with the onscreen attributes
//
// Parameters:	None
//
// Returns:		Nothing
//
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//       AKB    21MAY2008     PAR 16415 CCMS 1029 30,45,53s
// ---------------------------------------------------------------------------

vars
	aColumn : CMUI_GridColumn;
	bayFrame,bayFrameUD : CMUI_GridAreaFrame;
	aPoint : CMUI_GridPoint;
	bayPoint : SHP_BayPoint;
	theString : CM_String;
	bayArea : SHP_BayArea;
begin
	if self.myCurrentBay = null then
		return;
	endif;
	app.mousePointer := Window.MousePointer_HourGlass;
	
	// #################################
	// Ondeck Cell Alignment
	bayFrame := self.frmGridArea.getControl(ONDECK);
	if bayFrame &lt;&gt; null then
		foreach aColumn in bayFrame.myGridArea.allGridColumns do
			aColumn.SHP_BayColumn.myCell.setAlignment(aColumn.SHP_BayColumn.allignment);
		endforeach;
		foreach aPoint in bayFrame.myGridArea.SHP_BayAreaAboveDeck.allGridPoints do
			if aPoint.isKindOf(SHP_BayPoint) then
				bayPoint := aPoint.SHP_BayPoint;
				bayPoint.mySlotDefn.setAttributes(bayPoint.bayDefnThirtyFoot, bayPoint.bayDefnFiftyThreeFoot, bayPoint.bayDefnFortyFive ,bayPoint.bayDefnFortyFoot, bayPoint.bayDefnPowered,bayPoint.bayDefnReefer,
									bayPoint.bayDefnWaterCooled,bayPoint.bayDefnUnavailable,bayPoint.bayDefnDoorDirection20,
									bayPoint.bayDefnDoorDirection20,bayPoint.bayDefnMotorDirection20,bayPoint.bayDefnMotorDirection40,bayPoint.bayDefnMtOnly, bayPoint.bayDefnHeavy, bayPoint.bayDefnVoltage);
			endif;
			//_fortyFront,_power,_reefer,_watercooled,_unavailable,_doors20Aft,_doors40Aft,_mtOnly,_motor20Aft,_motor40Aft
		endforeach;
	endif;
	// #################################
	// Underdeck Cell Alignment
	bayFrame := self.frmGridArea.getControl(UNDERDECK);
	if bayFrame &lt;&gt; null then
		foreach aColumn in bayFrame.myGridArea.allGridColumns do
			aColumn.SHP_BayColumn.myCell.setAlignment(aColumn.SHP_BayColumn.allignment);
		endforeach;
		foreach aPoint in bayFrame.myGridArea.SHP_BayAreaBelowDeck.allGridPoints do
			bayPoint := aPoint.SHP_BayPoint;

			bayPoint.mySlotDefn.setAttributes(bayPoint.bayDefnThirtyFoot, bayPoint.bayDefnFiftyThreeFoot,bayPoint.bayDefnFortyFive,bayPoint.bayDefnFortyFoot, bayPoint.bayDefnPowered,bayPoint.bayDefnReefer,
									bayPoint.bayDefnWaterCooled,bayPoint.bayDefnUnavailable,bayPoint.bayDefnDoorDirection20,
									bayPoint.bayDefnDoorDirection20,bayPoint.bayDefnMotorDirection20,bayPoint.bayDefnMotorDirection40,bayPoint.bayDefnMtOnly, bayPoint.bayDefnHeavy, bayPoint.bayDefnVoltage);

			//_fortyFront,_power,_reefer,_watercooled,_unavailable,_doors20Aft,_doors40Aft,_mtOnly,_motor20Aft,_motor40Aft
		endforeach;
	endif;

	bayFrame := self.frmGridArea.getControl(ONDECK);
	if bayFrame &lt;&gt; null then
		bayFrame.myGridArea.drawSelf();
	endif;
	self.currentBayEdition := self.myCurrentBay.edition;


	// ########################
	// DRAW THE LEGEND
	// merge the attributes used on the 2 frames into the top frames and print the legend
	bayFrameUD := self.frmGridArea.getControl(UNDERDECK);
	if bayFrame &lt;&gt; null then
		if bayFrameUD &lt;&gt; null then
			
			foreach theString in bayFrameUD.myGridArea.SHP_BayArea.allAttributesUsed do
				if not global.isValidObject(theString) then
					continue;
				endif;
				if bayFrame.myGridArea.SHP_BayArea.allAttributesUsed[theString.string] = null then
					bayFrame.myGridArea.SHP_BayArea.allAttributesUsed.add(theString);
				endif;
			endforeach;
		endif;	
		bayFrame.myGridArea.SHP_BayArea.displayAttributeLegend(self.frmLegend);
	endif;
	if self.anythingChanged then
		self.anythingChangedBay := true;
	endif;
	self.anythingChanged := false;
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSetProxyBay" id="9c1a593c-ef14-45e6-9087-d1d1f6e895a9">
        <updating/>
        <source>doSetProxyBay(theProxyBay : CM_Bay input) : Boolean updating;
/* ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
01 Sep 2014		cnwer1		PAr 34819 1310 exceptions
// ---------------------------------------------------------------------------*/

vars
	theIdBay40,theClonedFromBay,theLashFromTier,theUnlashFromTier,theRemarks, theMaxNumHighCubesIfFull:String;
	theOrdinalBay,theBayType,theMaxPileWeight20IB,theMaxPileWeight20OB,
	theMaxPileWeight40IB,theMaxPileWeight40OB,theMaxPileWeightUD,theNumOfPlugs,theOrdinalHold :Integer;
	theAthwartships,theFortyFootBay,theFortyFootOnly,theFortyFiveFootBay,theFortyFiveFootOnly,theUseCellTierODSequencing,theUseCellTierUDSequencing:Boolean;
	theUseCellTierODSequencing40,theUseCellTierUDSequencing40, theTLOD, theTLUD:Boolean;
	osCrane : Integer;
	aProxyHold : CM_Hold;
	theNextBay : CM_Bay; //Defn;
	allOtherBays : CM_BayArray;
	result : Boolean;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	result:=true;
	// #############################################
	// set the proxy BAY DEFINITION
	
	
	theIdBay40 := self.txt40FootBayID.text;
	theLashFromTier := self.cmbLashFrom.text;
	theUnlashFromTier := self.cmbUnlashFrom.text;
	theRemarks := self.txtRemarks.text;
	theOrdinalBay := theProxyBay.ordinalBay;
	theBayType := self.cmbBayType.listIndex - 1;
	theMaxPileWeight20IB := self.txtMaxPileWt20IB.text.Integer * 1000;
	theMaxPileWeight20OB := self.txtMaxPileWt20OB.text.Integer * 1000;
	theMaxPileWeight40IB := self.txtMaxPileWt40IB.text.Integer * 1000;
	theMaxPileWeight40OB := self.txtMaxPileWt40OB.text.Integer * 1000;
	theMaxPileWeightUD := self.txtMaxPileWtUD.text.Integer * 1000;
	theNumOfPlugs := self.txtNumOfPlugs.text.Integer;
//	theOrdinalHold := self.txtOrdinalHold).Integer;
	theTLOD := self.ckbTwinLiftOD.value;
	theTLUD := self.ckbTwinLiftUD.value;
	theAthwartships := self.ckbAthwartships.value;
	theAthwartships := self.ckbAthwartships.value;
	theFortyFootBay := self.ckbFortyFootBay.value;
	theFortyFootOnly := self.ckbFortyFootOnly.value;
	theFortyFiveFootBay := self.ckbForty5FootBay.value;
	theFortyFiveFootOnly := self.ckbForty5FtOnly.value;
	theMaxNumHighCubesIfFull := self.txtUDCellsHiCub.text;

	theUseCellTierODSequencing := (self.cmbDirOn.listIndex = 1); // PAR 8824 AKB2004AUGUST
	theUseCellTierUDSequencing := (self.cmbDirUnder.listIndex = 1); // PAR 8824 AKB2004AUGUST
	
	theUseCellTierODSequencing40 := (self.cmbDirOn40.listIndex = 1); // PAR 8824 AKB2004AUGUST
	theUseCellTierUDSequencing40 := (self.cmbDirUnder40.listIndex = 1); // PAR 8824 AKB2004AUGUST
	if self.cmbOnShipCrane.listIndex = -1 then
		osCrane := 0;
	else
		osCrane := self.cmbOnShipCrane.itemData[self.cmbOnShipCrane.listIndex];
	endif;
	aProxyHold := null;
	if self.cmbHolds.listIndex &gt; 0 then
		aProxyHold := self.cmbHolds.itemObject[self.cmbHolds.listIndex].CM_Hold;
	elseif self.cmbHolds.listCount &gt; 0 then
		aProxyHold := self.cmbHolds.itemObject[1].CM_Hold;
	endif;

	if self.myCurrentCellularVessel &lt;&gt; null then
		theProxyBay.CM_BayDefn.setProxyBay(theProxyBay.id,theIdBay40,theClonedFromBay,theLashFromTier,theUnlashFromTier,theRemarks,
							theOrdinalBay,theBayType,theMaxPileWeight20IB,theMaxPileWeight20OB,
							theMaxPileWeight40IB,theMaxPileWeight40OB,theMaxPileWeightUD,theNumOfPlugs,theOrdinalHold,
							theAthwartships,theFortyFootBay,theFortyFootOnly,theUseCellTierODSequencing,theUseCellTierUDSequencing,
							theUseCellTierODSequencing40,theUseCellTierUDSequencing40,theTLOD,theTLUD,
							self.myCurrentCellularVessel,aProxyHold,osCrane,theFortyFiveFootBay,theFortyFiveFootOnly);
	endif;
	
	
	
	// #############################################
	// set the proxy CELL DEFINITIONS
	//epr par 34819 when changing a bay's cell/tier make sure those changes are always reflected in the other bays in the hold
	//epr par 34518 25/11/14
	if theProxyBay &lt;&gt; null then
		
		create allOtherBays transient;
		foreach theNextBay in theProxyBay.myHold.allBays do
			if theNextBay &lt;&gt; theProxyBay then
				allOtherBays.add(theNextBay);
				theNextBay.setBayType(theBayType);
			endif;
		endforeach;
		
		if not theProxyBay.setProxyCellsODFromLabels(self.txtOnDeckCells.text,true) then
			result:= false;
		endif;
		if not theProxyBay.setProxyCellsUDFromLabels(self.txtUnderDeckCell.text,self.txtUDCellsHiCub.text,true) then
			result:= false;
		endif;
		if not theProxyBay.setProxyTiersODFromLabels(self.txtOnDeckTier.text,true) then
			result:= false;
		endif;
		if not theProxyBay.setProxyTiersUDFromLabels(self.txtUnderDeckTier.text,true) then
			result:= false;
		endif;
		
		if self.mode = Mode_Update then
			foreach theNextBay in allOtherBays  discreteLock do
				if theNextBay.getAllCellsOnDeck().trimBlanks &lt;&gt; self.txtOnDeckCells.text.trimBlanks then
					theNextBay.setProxyCellsODFromLabels(self.txtOnDeckCells.text,false);		
				endif;
				if theNextBay.getAllCellsUnderDeck().trimBlanks &lt;&gt; self.txtUnderDeckCell.text.trimBlanks then
					theNextBay.setProxyCellsUDFromLabels(self.txtUnderDeckCell.text,null,false);
				endif;
				if theNextBay.getAllTiersOnDeck().trimBlanks &lt;&gt;  self.txtOnDeckTier.text.trimBlanks then
					theNextBay.setProxyTiersODFromLabels(self.txtOnDeckTier.text,false);
				endif;
				if theNextBay.getAllTiersUnderDeck().trimBlanks &lt;&gt; self.txtUnderDeckTier.text.trimBlanks then
					theNextBay.setProxyTiersUDFromLabels(self.txtUnderDeckTier.text,false);
				endif;
			endforeach;
		endif;
	endif;
	
	return result;
epilog
	
	delete allOtherBays;
	app.mousePointer := Window.MousePointer_Default;
	
end;</source>
        <Parameter name="theProxyBay" type="CM_Bay" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSetProxyVesselCellular" id="076061dc-196a-46cd-a132-cb4b392cdcfa">
        <source>doSetProxyVesselCellular(_pxyVessel : CM_CellularVesselStructure input);
//--------------------------------------------------------------
//Created: June 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpBridgeAfterBay 			: String; 		
	tmpUse40Id,
	tmpUseBayCellTierNumbering : Boolean;
	changes : Boolean;
	tmpNumSlots : Integer;
begin
	
	if _pxyVessel = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy Vessel is null.');
		return;
	endif;
	
	self.doUpdateDeckCellProxies( self.tblOnCellDims, self.tblUnderCellDim, changes );	//19 Oct 2010	NDL	Par 26058
	
	self.doBuildProxyHoldList(self.txtNumHolds.text.Integer);

	tmpBridgeAfterBay := self.cmbBridgeAftBay.text;
	tmpUse40Id := self.ckb40BayIds.value;
	tmpNumSlots := self.txtTEUTotal.text.Integer; // PAR 32286
	
	tmpUseBayCellTierNumbering := self.cmbStowageNumber.text = Vessel_Stowage_Type_BCT_Text;
	
	_pxyVessel.setProxyCellularVessel(tmpBridgeAfterBay, tmpUse40Id, tmpUseBayCellTierNumbering, self.ckbISOHalfHeight.value, tmpNumSlots); // PAR 32286


end;</source>
        <Parameter name="_pxyVessel" type="CM_CellularVesselStructure" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doValidateCellTierLabels" id="3889e31b-3c2c-4359-803a-d10660d38eae">
        <source>doValidateCellTierLabels(	_newLabels : String;
							_messageLabel : String;
							_oldLabels : String) : Boolean;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	aLabel, oldLabels : String;
	theLabels,theoldLabels, tmpLabels : StringArray;
	idx,theReturn : Integer;
	bayID : String;
	newLabelSize, oldLabelSize : Integer;
begin
	
	if self.myCurrentBay &lt;&gt; null then
		bayID := self.myCurrentBay.id;
	else
		bayID := "";
	endif;
	aLabel := _newLabels;
	aLabel.replaceString(" ","|");
	theLabels := aLabel.getTokens;
	idx := 0;
	oldLabels := _oldLabels;
	oldLabels.replaceString(" ","|");
	theoldLabels := oldLabels.getTokens;

	newLabelSize := theLabels.size;
	oldLabelSize := theoldLabels.size;
	
	//epr par 34819 removed validation for adding more than one bay at a time - this now works without errors

	// ### CHECK FOR DUPLICATES
	create tmpLabels transient;
	foreach aLabel in theLabels do
		if aLabel.trimBlanks = null then
			continue;
		endif;
		
		// PAR 16323 &amp; 17208
		if aLabel.length()  &gt; 2 then
			app.msgBox(app.getErrorString2(Bay_ID_too_long,_messageLabel,aLabel ), _messageLabel &amp; " ID Problem", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
		idx := idx + 1;

		if tmpLabels.includes(aLabel.trimBlanks) then
			app.msgBox("Duplicate " &amp; _messageLabel &amp; " IDs Are Not Allowed!" &amp; Cr  &amp; _messageLabel &amp; "ID " &amp; aLabel &amp; " Is Duplicated." &amp; Cr &amp; 
							"Please re-edit " &amp; _messageLabel &amp; " IDs For Bay " &amp; bayID,
							_messageLabel &amp; " ID Duplication",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return false;
		else
			tmpLabels.add(aLabel.trimBlanks);
		endif;
	endforeach;


	// ## CONFIRM CHANGES
	if oldLabelSize &gt; newLabelSize
	or (_newLabels &lt;&gt; oldLabels and oldLabels &lt;&gt; null)  then
		theReturn := app.msgBox("Are You Sure That You Want To Change " &amp; _messageLabel &amp; "s From Bay " &amp; bayID &amp; "?",_messageLabel &amp; " Delete",MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		return (theReturn = MsgBox_Return_Yes);
	endif;
	
	return true;
epilog
	delete theLabels;
	delete tmpLabels;
	delete theoldLabels;

end;</source>
        <Parameter name="_newLabels" type="String"/>
        <Parameter name="_messageLabel" type="String"/>
        <Parameter name="_oldLabels" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doValidateTierLabels" id="ad8d8cc3-8c8a-4b20-b4d3-5e1228c3dd1a">
        <source>doValidateTierLabels(_newLabels : String; _ondeck : Boolean) : Boolean;
// ---------------------------------------------------------------------------
// Created:     July 2008 ANDREW BISHOP
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 29JUL2008		CNWAB1			PAR 17603
// ---------------------------------------------------------------------------

vars

	aLabel : String;
	theLabels : StringArray;
	bayID : String;
begin
	if self.myCurrentBay &lt;&gt; null then
		bayID := self.myCurrentBay.id;
	else
		bayID := "";
	endif;
	aLabel := _newLabels;
	aLabel.replaceString(" ","|");
	theLabels := aLabel.getTokens;	

	foreach aLabel in theLabels do
		if aLabel.trimBlanks = null then
			continue;
		endif;
		if _ondeck then
			if aLabel.isInteger() then
				if aLabel.Integer &lt; 50 then
					app.msgBox("WARNING. On deck tier labels for bay " &amp; bayID &amp;  " may be wrong." &amp; Cr 
							&amp; "They should be '84 86 88 90 92' etc. not '" &amp; _newLabels &amp; "'." &amp; Cr &amp; Cr
							&amp; "Have you mixed up your on deck and under deck tier Labels?", "On-deck Tier ID Problem", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
					return false;
				endif;
			endif;
		else
			if aLabel.isInteger() then
				if aLabel.Integer &gt; 50 then
					app.msgBox("WARNING. Under deck tier labels for bay " &amp; bayID &amp;  " may be wrong." &amp; Cr 
							&amp; "They should be '06 08 10 12 14' etc. not '" &amp; _newLabels &amp; "'." &amp; Cr &amp; Cr
							&amp; "Have you mixed up your on deck and under deck tier Labels?", "Under-deck Tier ID Problem", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
					return false;
				endif;
			endif;
		endif;
	endforeach;

	return true;
epilog
	delete theLabels;

end;</source>
        <Parameter name="_newLabels" type="String"/>
        <Parameter name="_ondeck" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doWBayOrderLostFocus" id="63a57731-0676-4f8e-947a-0e774d266b41">
        <source>doWBayOrderLostFocus();
// ---------------------------------------------------------------------------
// Created:     18 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// // PAR 17912
// ---------------------------------------------------------------------------

vars
	hyphen, comma : Integer;
	allBays, bays, tmp : String;
	holdOrd, bayID, bayID1, bayID2 : Integer;
begin
	bays := self.txtWBayOrder.text;
	tmp := bays;
	
	tmp.replaceChar("-", " ");
	if not self.validateBayLabelsWizard(tmp, true) then
		app.msgBox("Physical Bay Order can only have numbered bay IDs with space and comma separators", "Physical Bay Order Problem", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon); // PAR 18147
		self.txtWBayOrder.setFocus();
		return;
	endif;
	
	hyphen := bays.pos("-", 1);
	comma := bays.pos(",", 1);

	if hyphen &gt; 0 and comma &lt;= 0 then
		bayID1 := bays[1:hyphen-1].Integer;
		bayID2 := bays[hyphen+1:end].Integer;
		
		foreach bayID in bayID1 to bayID2 do
			if bayID mod(2) &lt;&gt; 0 then
				holdOrd := holdOrd + 1;
				if allBays = null then
					allBays := allBays &amp; bayID.padLeadingWith("0",2);
				else
					if holdOrd mod(2) &lt;&gt; 0 then
						allBays := allBays &amp; "," &amp; bayID.padLeadingWith("0",2);
					else
						allBays := allBays &amp; " " &amp; bayID.padLeadingWith("0",2);
					endif;
				endif;
			endif;
		endforeach;
		bays := allBays;
	endif;

	self.txtWBayOrder.text := bays;


end;</source>
    </JadeMethod>
    <JadeMethod name="doWCellOrderLostFocus" id="f540920b-4531-47e1-9c28-b405fdafad6d">
        <source>doWCellOrderLostFocus(_text : TextBox input);
// ---------------------------------------------------------------------------
// Created:     18 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// // PAR 17912
//TFS 6904 jgns1 19/9/17 POL - Missing 00 value on the LOLO vessel definition wizard
// ---------------------------------------------------------------------------

vars
	hyphen, comma : Integer;
	allBays, ids, tmp, even, odd, mess : String;
	holdOrd, bayID, bayID1, bayID2, bayID3 : Integer;
begin
	ids := _text.text;
	tmp := ids;
	// PAR 18214
	mess := "Cell IDs can only be numeric IDs with space and comma separators." &amp;  // PAR 18147
						Cr &amp; "Cell IDs must be 2 characters in length." &amp; Cr &amp; "Alternatively a range can be entered with a hyphen.";
						
	tmp.replaceChar("-", " ");
	if not self.validateBayLabelsWizard(tmp, true) then
		app.msgBox(mess, "Cell ID Problem", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		_text.setFocus();
		return;
	endif;
	hyphen := ids.pos("-", 1);
	comma := ids.pos(",", 1);

	if hyphen &gt; 0 and comma &lt;= 0 then
		// PAR 18214
		if hyphen = ids.length then
			app.msgBox(mess, "Cell ID Problem", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			_text.setFocus();
			return;
		endif;
	endif;
	

	if hyphen &gt; 0 and comma &lt;= 0 then
		bayID2 := ids[1:hyphen-1].Integer;
		bayID1 := ids[hyphen+1:end].Integer;
		bayID3 := 0;						//TFS 6904
		
		foreach bayID in bayID3 to bayID2 do
			if bayID mod(2) = 0 then
				even := bayID.padLeadingWith("0",2) &amp; " "  &amp; even;
			else
				odd := odd &amp; bayID.padLeadingWith("0",2) &amp; " " ;
			endif;
		endforeach;
		ids := even &amp; odd;
	endif;

	_text.text := ids;


end;</source>
        <Parameter name="_text" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doWTierOrderLostFocus" id="0b7face7-393e-4f5a-8558-1c8490484c5e">
        <source>doWTierOrderLostFocus(_text : TextBox input);
// ---------------------------------------------------------------------------
// Created:     18 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// // PAR 17912
// ---------------------------------------------------------------------------

vars
	hyphen, comma : Integer;
	allBays, ids, tmp, mess : String;
	holdOrd, bayID, bayID1, bayID2 : Integer;
begin
	ids := _text.text;
	tmp := ids;
	
	// PAR 18214
	mess := "Tier IDs can only be numeric IDs with space and comma separators." &amp;  // PAR 18147
						Cr &amp; "Tier IDs must be 2 characters in length." &amp; Cr &amp; "Alternatively a range can be entered with a hyphen.";
	
	tmp.replaceChar("-", " ");
	if not self.validateBayLabelsWizard(tmp, true) then
		app.msgBox(mess, "Tier ID Problem", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		_text.setFocus();
		return;
	endif;
	
	hyphen := ids.pos("-", 1);
	comma := ids.pos(",", 1);
	
	// PAR 18214
	if hyphen &gt; 0 and comma &lt;= 0 then
		if hyphen = ids.length then
			app.msgBox(mess, "Tier ID Problem", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			_text.setFocus();
			return;
		endif;
	endif;

	if hyphen &gt; 0 and comma &lt;= 0 then
		bayID1 := ids[1:hyphen-1].Integer;
		bayID2 := ids[hyphen+1:end].Integer;
		
		foreach bayID in bayID1 to bayID2 do
			if bayID mod(2) = 0 then
				allBays := allBays &amp; bayID.padLeadingWith("0",2) &amp; " " ;
			endif;
		endforeach;
		ids := allBays;
	endif;

	_text.text := ids;


end;</source>
        <Parameter name="_text" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="fldVessel_querySheetChg" id="7bbec150-6ba3-41e1-8d4d-12a9e8618d31">
