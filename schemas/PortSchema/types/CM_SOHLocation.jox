    <JadeMethod name="adjustStockOnHand" id="76f9d489-8716-452a-ae23-39ce6a82f482">
        <updating/>
        <source>adjustStockOnHand(_date : Date; _type : Integer; _moveOut : Boolean; 
			_ti : CM_TrackedItem; _tiUpdCntrl : CMIF_TIUpdateController;
			_txn : CM_TITransaction input; _adjustParents : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     13 May 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	//if _tiUpdCntrl = null then
	//	app.raiseUnexpectedProgramError(class.name, method.name, 'Null _tiUpdCntrl');
	//	return;
	//endif;
	
	self.adjustStock(_date, _type, _moveOut, _ti, _tiUpdCntrl, _txn);
	
	if _moveOut then
//		self.allTrackedItems.safeRemove(_ti);
		if self.allTrackedItems.includes(_ti) then
			self.allTrackedItems.remove(_ti);
		endif;
		if self.allTrackedItemsByReceivalBOL.includes(_ti) then
			self.allTrackedItemsByReceivalBOL.remove(_ti);
		endif;
	else
		if (not self.allTrackedItems.includes(_ti)) then
			self.allTrackedItems.add(_ti);
		endif;
		if (not self.allTrackedItemsByReceivalBOL.includes(_ti)) then
			self.allTrackedItemsByReceivalBOL.add(_ti);
		endif;
	endif;
	
	if not self.isTransient then	//20 Jan 2014	NDL	Par 33264
		//15 Jan 2014	NDL	Par 33264
		self.updateObjectEdition(self);
	endif;

end;</source>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_moveOut" type="Boolean"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiUpdCntrl" type="CMIF_TIUpdateController"/>
        <Parameter name="_txn" type="CM_TITransaction" usage="input"/>
        <Parameter name="_adjustParents" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="adjustStockOnHand_docketCorect" id="30eab340-ff51-43bd-a910-782f3a9706e5">
        <updating/>
        <source>adjustStockOnHand_docketCorect( _ts : TimeStamp; _type : Integer; _moveOut : Boolean;
								_quantity: Integer; _weightKgs : Decimal; _volume, _sedMean : Decimal;
								_ti : CM_TrackedItem; _txn : CM_TITransaction input; _newBucket : CM_StockMoveBucket output;
								_stockForLocationChanged : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		11 March 2008 By: cnwvu1
//
// Parameters:	_moveOut = true removes stockMovement (_type) from _trn
//				_moveout = false adds stockMovement (_type) to the _trn
//				_stockForLocationChanged := true, when stock is corrected for location changed,
//					for Product change, this should be false  
// ---------------------------------------------------------------------------

vars
	moveTransFromRoadToLocn2	: CM_Move; 
	moveTransFromLocn1ToLocn2	: CM_TITransaction;

begin

	self.adjustStock_docketCorrection( _ts, _type, _moveOut, _quantity, _weightKgs, _volume, _sedMean, _ti, _txn, _newBucket );
	
//	if _stockOnHandToBeChanged then	it seems we don't need this check.
		// when changing product, we have to correct and stockOnHand. 
		//if log has been removed from terminal, stockOnHand will be reversed and corrected by following movement finally
		if _moveOut then
		
			//#24377 .When log has more Move transactions, then its current SOH location should keep this log - don't remove. 15/10/2010
			if self.allTrackedItems.includes(_ti) and
			   self.myLocationsController.CM_LogController = _ti.myPrimaryActualLocation.CM_LogController then	//the log can be already moved to the current location by a MOVE transaction
				_ti.CM_Log.getTransMovedForDocketCorrect( moveTransFromRoadToLocn2, moveTransFromLocn1ToLocn2);
				if moveTransFromLocn1ToLocn2 &lt;&gt; null and _stockForLocationChanged then	// the log has already been moved somewhere by MOVE transaction before Docket Correction
					return;	// In this case we quit thus avoiding the log removal from its current SOH location. #24377
				endif;
			endif;
		
			if self.allTrackedItems.includes(_ti) then
				self.allTrackedItems.remove(_ti);
			endif;
			if self.allTrackedItemsByReceivalBOL.includes(_ti) then
				self.allTrackedItemsByReceivalBOL.remove(_ti);
			endif;
			
		else
		
			if _ti.state = TI_STATE_DELETED then	//When log is rejected or disassembled, don't change it's location. #24462 09/07/2010
				return;	
			endif;
			
			if _ti.myCurrentSOHLocation = null then
				if (not self.allTrackedItems.includes(_ti)) then
					self.allTrackedItems.add(_ti);
				endif;
				if (not self.allTrackedItemsByReceivalBOL.includes(_ti)) then
					self.allTrackedItemsByReceivalBOL.add(_ti);
				endif;
			endif;
		endif;
//	endif;

	if not self.isTransient then	//20 Jan 2014	NDL	Par 33264
		//15 Jan 2014	NDL	Par 33264
		self.updateObjectEdition(self);
	endif;

end;
</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_moveOut" type="Boolean"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weightKgs" type="Decimal"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_sedMean" type="Decimal"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_txn" type="CM_TITransaction" usage="input"/>
        <Parameter name="_newBucket" type="CM_StockMoveBucket" usage="output"/>
        <Parameter name="_stockForLocationChanged" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="allReceivalBOLs" id="3aa29a83-95eb-4bbf-9c03-8baa0e252fdb">
        <methodInvocation>mapping</methodInvocation>
        <source>allReceivalBOLs(set: Boolean; _value: CM_BOLSet io) mapping;
// -----------------------------------------------------------------------------
// Created:		01 July 2002 by cnwka1
//
// Purpose:		This method is by the report writter to give a virtual collection
//				of BOLs. Don't delete until you have looked a the JRW!
//
//				Thw way things stand right now this causes a leak!!!
// Parameters:	
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	iter : Iterator;
	lastBOL, currentBOL	: CM_BOLIn;
	ti : CM_TrackedItem;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);	
		return;
	endif;
	
	if _value = null then

		create _value transient;
	endif;
	
	iter := self.allTrackedItemsByReceivalBOL.createIterator();

	lastBOL := null;
	while iter.next(ti) do

		self.allTrackedItemsByReceivalBOL.getIteratorKeys(currentBOL, iter);

		if currentBOL &lt;&gt; lastBOL and not _value.includes(currentBOL) then 
		
			_value.add(currentBOL);
			lastBOL := currentBOL;
		endif;
	endwhile;
epilog 
	delete iter;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_BOLSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="averageVolume" id="043932a7-cf60-42dd-95ef-a34f8c8654cd">
        <methodInvocation>mapping</methodInvocation>
        <source>averageVolume(set: Boolean; _value: Real io) mapping;
// ---------------------------------------------------------------------------
// Created:     18 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	if self.myExtension &lt;&gt; null and
	   self.myExtension.isKindOf(CM_SOHLocationExtLog) then
		_value := self.myExtension.CM_SOHLocationExtLog.averageVolume;
	elseif self.currentQuantity &lt;&gt; 0 then
		_value := (self.currentVolume / self.currentQuantity).roundedTo(3);
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="calAllocatedAmount" id="33d51150-ca05-427c-ad38-bf46a17aad15">
        <source>calAllocatedAmount() : Real;
//--------------------------------------------------------------
//Created: 26 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	quantity : Real;
	allocation	: CM_StockOrderAllocation;
begin

	foreach allocation in self.allStockOrderAllocations do
		if allocation.isKindOf(CM_StockOrderSummaryAlloc) then
			quantity := (quantity + allocation.allocQuantity);
		/*elseif allocation.CM_StockOrderLineAlloc.myStockOrderSummaryAlloc = null then
			quantity := (quantity + allocation.allocQuantity);*/
		endif;
	endforeach;

	return quantity;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="calAllocatedAmountToLines" id="b91fe6a5-ce43-47f0-a895-098eca22c093">
        <source>calAllocatedAmountToLines() : Real;
//--------------------------------------------------------------
//Created: 6 July 2004 By: cnwgd1
//--------------------------------------------------------------
vars
	quantity : Real;
	allocation	: CM_StockOrderAllocation;
begin

	foreach allocation in self.allStockOrderAllocations where (not allocation.isKindOf(CM_StockOrderSummaryAlloc)) do
		quantity := (quantity + allocation.allocQuantity);
	endforeach;

	return quantity;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="calAllocatedForSummary" id="7c152ece-602f-40d1-8972-4319e316078b">
        <source>calAllocatedForSummary(_summaryAlloc : CM_StockOrderSummaryAlloc) : Real;
//--------------------------------------------------------------
//Created: 26 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	quantity : Real;
	allocation	: CM_StockOrderAllocation;
begin
	
	if _summaryAlloc = null then
		return quantity;
	endif;
	
	foreach allocation in self.allStockOrderAllocations do
		if allocation &lt;&gt; _summaryAlloc then
			if allocation.myStockOrderHeader = _summaryAlloc.myStockOrderHeader then
				quantity := (quantity + allocation.allocQuantity);
			endif;
		endif;
	endforeach;
	
	return quantity;
end;</source>
        <Parameter name="_summaryAlloc" type="CM_StockOrderSummaryAlloc"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="calAvailableVolume" id="b5b42db2-39a6-4336-b86b-faf94b2fd2b0">
        <source>calAvailableVolume() : Real;
//-----------------------------------------
// Created: July 2004 By: cnwgd1
//-----------------------------------------
vars
	allocVol,
	availVol : Real;
begin

	allocVol := self.calAllocatedAmount();
	availVol := (self.currentVolume - allocVol);

	if availVol &lt; 0 then
		availVol := 0;
	endif;
	
	return availVol;

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="calAvailableVolumeForStkOrder" id="5ebd3531-7e27-461f-aeb8-aa703f0e97a8">
        <source>calAvailableVolumeForStkOrder(_stkOrderLine : CM_StockOrderProductLine; _afterAllocated : Boolean) : Real;
//-----------------------------------------
// Created: July 2004 By: cnwgd1
//-----------------------------------------
vars
	allocObj	: CM_StockOrderAllocation;
	tmpVol,
	lineVol,
	summVol,
	availVol	: Real;
	qtyType		: Integer;
begin

	availVol := self.calAvailableVolume();

	if _stkOrderLine = null then
		return availVol;
	endif;
	
	qtyType := CM_StockOrderSummaryAlloc.AllocType_Quantity;
	
	foreach allocObj in self.allStockOrderAllocations do
		if CM_StockOrderSummaryAlloc.hasInstance(allocObj) then
			summVol := summVol + allocObj.allocQuantity;
		elseif allocObj.allocType &lt;&gt; qtyType then
			//all or remaining is allocated
			if _afterAllocated then
				continue;
			else
				return 0;
			endif;
		else
			lineVol := lineVol + allocObj.allocQuantity;
		endif;
	endforeach;

	return availVol + (summVol-lineVol);

end;</source>
        <Parameter name="_stkOrderLine" type="CM_StockOrderProductLine"/>
        <Parameter name="_afterAllocated" type="Boolean"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="calRemainingAllocAmount" id="1090fd9a-ddd3-4f72-b704-4047259afae5">
        <source>calRemainingAllocAmount(_alloc : CM_StockOrderAllocation) : Decimal;
// ---------------------------------------------------------------------------
// Created:     07 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	allocQty	: Decimal[16,4];
	tmpAlloc	: CM_StockOrderAllocation;
begin

	foreach tmpAlloc in self.allStockOrderAllocations do
		// Each Line allocation has a summary allocation
		// If line is updated the summary gets updated as well
		// So therefore only total up the summaries 
		if CM_StockOrderLineAlloc.hasInstance(tmpAlloc) then
			continue;
		endif;

		if tmpAlloc &lt;&gt; _alloc then
			allocQty := allocQty + tmpAlloc.allocQuantity;
		endif;
	endforeach;

	if (self.currentVolume - allocQty) &gt; 0 then
		return (self.currentVolume - allocQty);
	else
		return 0;
	endif;
	
end;</source>
        <Parameter name="_alloc" type="CM_StockOrderAllocation"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="calculateResiduePiecesVolume" id="af2c869a-101a-4401-aebd-adea43b46fa0">
        <source>calculateResiduePiecesVolume(_residuePieces : Integer output; _residueVolume : Real output);
//--------------------------------------------------------------
//Created: 29 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
	if self.myExtension &lt;&gt; null then
		self.myExtension.calculateResiduePiecesVolume(_residuePieces, _residueVolume);
	endif;
end;</source>
        <Parameter name="_residuePieces" type="Integer" usage="output"/>
        <Parameter name="_residueVolume" type="Real" usage="output"/>
    </JadeMethod>
    <JadeMethod name="canAllocateToOrder" id="f1676aa6-6b3e-4bdb-ad11-f7d355bfb666">
        <source>canAllocateToOrder(_alloc : CM_StockOrderAllocation; _isSplit : Boolean; _newType : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     07 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------
vars
	realAlloc,
	tmpAlloc	: CM_StockOrderAllocation;
begin

	if _alloc &lt;&gt; null then
		if _alloc.isTransient then
			realAlloc := _alloc.pxyGetRealObject();
		else
			realAlloc := _alloc;
		endif;			
		if realAlloc &lt;&gt; null and self.allStockOrderAllocations.includes(realAlloc) then
			//They may be changing the type which is valid
			/*if realAlloc.allocType = _newType then
				return true;
			elseif _newType = _alloc.AllocType_Quantity then
				return true;
			endif;*/
			return true;
		endif;
	endif;

	if _isSplit then
		//spreading the summary across order lines.
		return true;
	endif;

	foreach tmpAlloc in self.allStockOrderAllocations do
		
		if realAlloc = tmpAlloc then
			continue;
		endif; 
		if tmpAlloc.allocType = tmpAlloc.AllocType_All or
		   tmpAlloc.allocType = tmpAlloc.AllocType_Remaining then
		   	return false;
		endif;
	endforeach;

	if self.allStockOrderAllocations.isEmpty then
		return true;
	//elseif _newType = tmpAlloc.AllocType_All then
	//or _newType = tmpAlloc.AllocType_Remaining then
		//return false;
	endif;
	
	return true;

end;</source>
        <Parameter name="_alloc" type="CM_StockOrderAllocation"/>
        <Parameter name="_isSplit" type="Boolean"/>
        <Parameter name="_newType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserAccessSelf" id="c2cebbc5-05ee-4c33-bb29-ec6f17edc3cd">
        <source>canUserAccessSelf(_user : CM_User; _failedDAC  :CM_DataAccessController output; _passport: CM_Passport): Boolean;
// ---------------------------------------------------------------------------
// Created:     04 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	dac			: CM_DataAccessController;
	dacDict		: CM_DataAccessCntrlByClassDict;
	consignee 	: CM_ConsigneeConsignor;
	location	: CM_LocationsController;
	logLot		: CM_LogLot;
	rtnValue	: Boolean;

begin
	if self.myOperator &lt;&gt; null then
		rtnValue := self.myOperator.canUserAccessSelf(_user, _failedDAC,_passport);
		if not rtnValue then
			return false;
		endif;
	endif;
	
	if _user &lt;&gt; null then
		dacDict := _user.allDataAccessControllers;
	else
		dacDict := _passport.allDataAccessControllers;
	endif;
	if dacDict.isEmpty then
		return true;
	endif;

	// 31/01/2011 cnwar2 #26581 - check consignee/consignor dac
	location := self.myLocationsController;
	if location.isKindOf(CM_LogVoyageController) then
		logLot := location.CM_LogVoyageController.myLogLot;
		if logLot &lt;&gt; null then
			consignee := logLot.myConsignee;
		endif;
	endif;
	
	dac := dacDict[CM_ConsigneeConsignor.name];
	if dac &lt;&gt; null then
		
		if consignee = null and (not dac.includeIfNull) then
			_failedDAC := dac;
			return false;
		elseif (not dac.canAccess(consignee)) then
			_failedDAC := dac;
			return false;
		endif;
	endif;

	return inheritMethod(_user, _failedDAC, _passport);

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="currentVolume" id="ba79044d-fbae-48ea-8dfd-f05fd9c8df09">
        <methodInvocation>mapping</methodInvocation>
        <source>currentVolume(set : Boolean; _value : Decimal io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2016	cnwmc5	Initial creation		PAR 37536

*/

vars
	soh : CM_StockOrderAllocation;
begin
	if set then
		foreach soh in self.allStockOrderAllocations do
			if soh.allocType = soh.AllocType_All or soh.allocType = soh.AllocType_Remaining then
				self.updateObjectEdition(soh);
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="fixupStockOnHand" id="c3aa5254-428b-43d4-a2ca-326b54a8d727">
        <updating/>
        <source>fixupStockOnHand(_passport : CM_Passport input; _comment :String; _parent : Object; _cmifMonitor : CMIF_Monitor input)updating;
//--------------------------------------------------------------
//Created: 29 October 2002 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------
// 29/03/2016	cnwdap1		PAR #35843 Make monitor time-based rather than object based
vars
	saveMsg,
	tmpMsg		: String;
	ti			: CM_TrackedItem;
	lcTIArray 	: CM_TIArray;
	date		: Date;
	tmpMove		: CM_StockMoveBucket;	
	sohTxn		: CM_SOHTransaction;
	sohVol,
	actualVol 	: Decimal[16,4];
	sohQty, 
	actualQty	: Integer;
	sohWgt,		
	actualWgt	: Decimal[14,4];
	tmpPartsDone,
	tmpPartsInJob : Integer;
	tmpSOHLocation		: CM_SOHLocation;
	lastUpdated	: Decimal [20];						// PAR #35843
	
begin
	exclusiveLock(self);
	lcTIArray 	:= self.myLocationsController.allTrackedItems;
	date 		:= app.serverTimestampAtTrxStart.date;
	//updCntrl 	:= app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);

	tmpPartsInJob 	:= (self.numTIs + lcTIArray.size);
	
	if _cmifMonitor &lt;&gt; null then
		saveMsg := _cmifMonitor.message;
		tmpMsg 	:= _cmifMonitor.message &amp; ' ' &amp; self.myProduct.code;
	endif;
	
	if self.myExtension &lt;&gt; null then
		self.myExtension.fixupStockOnHand(_passport);
	endif;

	//Check SOH TIs are actually in the location
	foreach ti in self.allTrackedItems do
		tmpPartsDone := tmpPartsDone + 1;
		//if tmpPartsDone mod 100 = 0 then																// PAR #35843
		if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then		// PAR #35843
			if _cmifMonitor &lt;&gt; null and (not _cmifMonitor.updateProgress(tmpMsg, tmpPartsInJob, tmpPartsDone)) then
				return;
			endif;			
			lastUpdated := app.relativeMachineTime;														// PAR #35843
		endif;		
		if lcTIArray.includes(ti) then
			// This TI is in the location so leave in this collection
			continue;
		endif;
		// 28948 Jan 2012 don't fixup inter-terminal transfers
		if (ti.myMoveCloneToTI &lt;&gt; null or ti.myMoveCloneFromTI &lt;&gt; null) and
		   ti.myCurrentSOHLocation = self then
			continue;
		endif;
		
		// This means that this ti is in the wrong CM_SOHLocation (i.e. ti.myCurrentSOHLocation is wrong)

		app.writeLog('Fixup SOH for (' &amp; self.getID &amp; ') removing ' &amp; ti.id, LogINFO);		

		// create the fixup soh-transaction
		sohTxn := self.createTransaction(TRANS_TYPE_SOH_FIXUP, _passport, _comment, _parent);
		if (not _passport.noErrors) then
			return;
		endif;
		// the following moves this ti out of the self.allTrackedItems collection
		self.adjustStockOnHand(date, StkMove_MoveOut, true, ti, null, null, true);
		sohTxn.setValuesPostUpdate(null);

		
		// See if we can move the TI into the correct CM_SOHLocation collection
		if ti.myPrimaryActualLocation &lt;&gt; null and
		   ti.myPrimaryActualLocation.isStockControlled then
		   
			tmpSOHLocation := ti.myPrimaryActualLocation.getSOHLocationForProduct(ti.myProduct);
			if tmpSOHLocation &lt;&gt; null then
				// move the ti into this CM_SOHLocation
				sohTxn := tmpSOHLocation.createTransaction(TRANS_TYPE_SOH_FIXUP, _passport, _comment, _parent);
				if (not _passport.noErrors) then
					return;
				endif;	
				tmpSOHLocation.adjustStockOnHand(date, StkMove_MoveIn, false, ti, null, null, true);
				sohTxn.setValuesPostUpdate(null);
				app.writeLog('Fixup SOH for (' &amp; ti.myCurrentSOHLocation.getID &amp; ') adding ' &amp; ti.id, LogINFO);				
			endif;
		endif;
		
		
	endforeach;

	if _cmifMonitor &lt;&gt; null and (not _cmifMonitor.updateProgress(tmpMsg, tmpPartsInJob, tmpPartsDone)) then
		return;
	endif;

	// Check that all the TI's that are in the location are in this CM_SOHLocation if appropriate
	foreach ti in lcTIArray do
		tmpPartsDone := tmpPartsDone + 1;
		//if tmpPartsDone mod 50 = 0 then																// PAR #35843
		if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then		// PAR #35843
			if _cmifMonitor &lt;&gt; null and (not _cmifMonitor.updateProgress(tmpMsg, tmpPartsInJob, tmpPartsDone)) then
				return;
			endif;			
			lastUpdated := app.relativeMachineTime;														// PAR #35843
		endif;
		//Only interested in TIs with same product code as self(SOH)
		if ti.myProduct &lt;&gt; self.myProduct then
			continue;
		endif;
		//TI has the same product code, check self knows about it	
		if self.allTrackedItems.includes(ti) then
			continue;
		endif;
		
		// Move TI out of the incorrect CM_SOHLocation that it is in
		if ti.myCurrentSOHLocation &lt;&gt; null then
			app.writeLog('Fixup SOH for (' &amp; ti.myCurrentSOHLocation.getID &amp; ') removing ' &amp; ti.id, LogINFO);				
			sohTxn := ti.myCurrentSOHLocation.createTransaction(TRANS_TYPE_SOH_FIXUP, _passport, _comment, _parent);
			if (not _passport.noErrors) then
				return;
			endif;	
			ti.myCurrentSOHLocation.adjustStockOnHand(date, StkMove_MoveOut, true, ti, null, null, true);
			sohTxn.setValuesPostUpdate(null);
		endif;
		
		// move the ti into this CM_SOHLocation
		sohTxn := self.createTransaction(TRANS_TYPE_SOH_FIXUP, _passport, _comment, _parent);
		if (not _passport.noErrors) then
			return;
		endif;	
		self.adjustStockOnHand(date, StkMove_MoveIn, false, ti, null, null, true);
		sohTxn.setValuesPostUpdate(null);
		
		app.writeLog('Fixup SOH for (' &amp; self.getID &amp; ') adding ' &amp; ti.id, LogINFO);				

	endforeach;

	if _cmifMonitor &lt;&gt; null and (not _cmifMonitor.updateProgress(tmpMsg, tmpPartsInJob, tmpPartsDone)) then
		return;
	endif;	
	
	//Get actual TI accumulated values (qty, vol, weight) for comparison
	
// changed as no. of Ti's being returned, not total quantity of items in the TI's //HJG 10/01/2005
	//	actualQty := self.allTrackedItems.size();
	actualQty := self.getTotalQuantityActual(); 
	actualVol := self.getTotalVolumeActual();
	actualWgt := self.getTotalWeightActual();
	
	sohQty 		:= -(self.currentQuantity - actualQty);
	sohVol 		:= -(self.currentVolume - actualVol);	
	sohWgt		:= -(self.currentWeightKgs - actualWgt);
	
	//compare actual values to self
	if self.currentQuantity &lt;&gt; actualQty or
	   self.currentVolume &lt;&gt; actualVol or
	   self.currentWeightKgs &lt;&gt; actualWgt then

		app.writeLog('Fixup SOH for (' &amp; self.getID &amp; ') ' &amp; actualQty.String &amp;
					', ' &amp; actualVol.String &amp; ', ' &amp; actualWgt.String, LogINFO);

		tmpMove := self.allStockMovementsByDate[date];
		if tmpMove = null then
			create tmpMove as self.getStockMovementClass() persistent;
			tmpMove.init(date, self.currentQuantity, self.currentWeightKgs, self.currentVolume, self);
		endif;	
		sohTxn := self.createTransaction(TRANS_TYPE_SOH_FIXUP, _passport, _comment, _parent);
		if (not _passport.noErrors) then
			return;
		endif;
		//Update current values with actual values	
		self.currentQuantity	:= actualQty;
		self.currentVolume		:= actualVol;
		self.currentWeightKgs	:= actualWgt;
		tmpMove.addFixup(StkMove_Fixup, sohQty, sohWgt, sohVol);				
		sohTxn.setValuesPostUpdate(null);
	endif;
	
	if _cmifMonitor &lt;&gt; null then
		_cmifMonitor.message := saveMsg;
	endif;
	
	if not self.isTransient then	//20 Jan 2014	NDL	Par 33264
		//15 Jan 2014	NDL	Par 33264
		if self.myExtension &lt;&gt; null then
			self.updateObjectEdition( self.myExtension );
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_parent" type="Object"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllAssignedVoyageCodes" id="4faf6ef6-5c6f-4e71-9ad6-171e4e8fbb52">
        <source>getAllAssignedVoyageCodes() : String;
//--------------------------------------------------------------
//Created: 26 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	strArray	: StringArray;
	rtnStr,
	str 		: String;
	voy			: CM_Voyage;
	allocation	: CM_StockOrderAllocation;
begin

	create strArray transient;
	foreach allocation in self.allStockOrderAllocations do
		if allocation.myStockOrderHeader = null then
			continue;
		endif;
		voy := allocation.myStockOrderHeader.myVoyage;
		if voy = null then
			continue;
		endif;		
		if (not strArray.includes(voy.code)) then
			strArray.add(voy.code);
		endif;
	endforeach;
	
	foreach str in strArray do
		if rtnStr = null then
			rtnStr := str;
		else
			rtnStr := str &amp; '; ' &amp; rtnStr;
		endif;
	endforeach;
	
	return rtnStr;
epilog
	delete strArray;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllResidueTIs" id="67f75c3b-d912-41e4-a5b7-4b9c3bb6b9fa">
        <source>getAllResidueTIs(_tiSet : CM_TISet input);
//--------------------------------------------------------------
//Created: 29 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	ti : CM_TrackedItem;
begin
	
	if _tiSet = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null CM_TISet passed to method. Contact Developer.');
		return;
	endif;
	
	foreach ti in self.allTrackedItems do
		if (not ti.isOnShip) then
			_tiSet.add(ti);
		endif;
	endforeach;
end;</source>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllocAmtForDetail" id="1af530db-7df7-4d87-b692-1ccb552523e8">
        <source>getAllocAmtForDetail(_order : CM_StockOrderLine) : Decimal;
//--------------------------------------------------------------
//Created: 24 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	rtnValue	: Decimal[16,4];
	allocation 	: CM_StockOrderAllocation;
begin
	foreach allocation in self.allStockOrderAllocations do
		if allocation.myParent = _order then
			rtnValue := allocation.allocQuantity;
			break;
		endif;
	endforeach;
	return rtnValue;
end;</source>
        <Parameter name="_order" type="CM_StockOrderLine"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getAllocQtyForOrderLine" id="30486f7c-21fc-4315-b76b-ad01afd63b09">
        <source>getAllocQtyForOrderLine(_stockOrderObj : CM_StockOrderObject) : Real;
// ---------------------------------------------------------------------------
// Created:     02 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	allocObj	: CM_StockOrderAllocation;
	allocQty	: Real;
	lastCol,
	numRows		: Integer;
		
begin

	allocQty := 0;
	if _stockOrderObj &lt;&gt; null then
		foreach allocObj in self.allStockOrderAllocations do
			if allocObj.myParent = _stockOrderObj then
				allocQty := allocQty + allocObj.allocQuantity;
			endif;
		endforeach;
	endif;
	
	return allocQty;

end;</source>
        <Parameter name="_stockOrderObj" type="CM_StockOrderObject"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getAllocTypeStringForOrderLine" id="0e5a5480-dd09-4559-bec5-590614cb80a9">
        <source>getAllocTypeStringForOrderLine(_stockOrderObj : CM_StockOrderObject) : String;
//will return 'Quantity' if not found
vars
	allocObj	: CM_StockOrderAllocation;
	allocTypeStr	: String;
begin

	allocTypeStr := CM_StockOrderAllocation.AllocTypeStr_Quantity;

	if _stockOrderObj = null then
		return allocTypeStr;
	endif;
	
	foreach allocObj in self.allStockOrderAllocations do
		if allocObj.myParent = _stockOrderObj then
			return allocObj.allocTypeString;
		endif;
	endforeach;
	
	return allocTypeStr;

end;</source>
        <Parameter name="_stockOrderObj" type="CM_StockOrderObject"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllocatedLotAndSummaryIDs" id="d2e50a64-1734-455c-ba1e-c5a2e28596f6">
        <source>getAllocatedLotAndSummaryIDs(_lotIDs, _summaryID : String output);
//-----------------------------------------
// Created: December 2004 By: cnwgd1
//-----------------------------------------
vars
	allocationSet			: CM_StockOrderAllocationSet;
	stockOrderAllocation	: CM_StockOrderAllocation;
	lineAllocation			: CM_StockOrderLineAlloc;
	tmpSummary				: CM_StockOrderSummaryAlloc;
	strLength				: Integer;
begin
	allocationSet := self.allStockOrderAllocations;
	
	foreach stockOrderAllocation in allocationSet do
		if CM_StockOrderLineAlloc.hasInstance(stockOrderAllocation) then
			lineAllocation := stockOrderAllocation.CM_StockOrderLineAlloc;
			if CM_LogStockOrderLine.hasInstance(lineAllocation.myStockOrderLine) then
				_lotIDs := _lotIDs &amp; lineAllocation.myStockOrderLine.CM_LogStockOrderLine.lotNo &amp; ', ';
			endif;
		elseif CM_StockOrderSummaryAlloc.hasInstance(stockOrderAllocation) then
			tmpSummary := stockOrderAllocation.CM_StockOrderSummaryAlloc;
			_summaryID := _summaryID &amp; tmpSummary.getOrderID() &amp; ', ';
		endif;
	endforeach;

	strLength := _lotIDs.length;

	if strLength &gt; 1
	and _lotIDs[strLength -1 : strLength] = ', ' then
		_lotIDs := _lotIDs[1 : strLength -2];
	endif;

	strLength := _summaryID.length;

	if strLength &gt; 1
	and _summaryID[strLength -1 : strLength] = ', ' then
		_summaryID := _summaryID[1 : strLength -2];
	endif;	
	
end;</source>
        <Parameter name="_lotIDs" type="String" usage="output"/>
        <Parameter name="_summaryID" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getAllocatedLotIDs" id="7c234096-343f-4b75-9d79-b6df86df26de">
        <source>getAllocatedLotIDs() : String;
// ---------------------------------------------------------------------------
// Created:     26 March 2004	cnwth2
//
// Purpose:     For CCMS 1056 - used in reporting and not referenced - **DO NOT DELETE**
//			 	Returns a delimeted string of allocated lot IDs where lot allocations exist
//				of the type that have that info (summaries don't)
// ----------   ----------  --------------------------------------------------
vars
	allocationSet			: CM_StockOrderAllocationSet;
	stockOrderAllocation	: CM_StockOrderAllocation;
	lineAllocation			: CM_StockOrderLineAlloc;
	str						: String;
	strLength				: Integer;
begin
	allocationSet := self.allStockOrderAllocations;
	
	foreach stockOrderAllocation in allocationSet do
		if CM_StockOrderLineAlloc.hasInstance(stockOrderAllocation) then
			lineAllocation := stockOrderAllocation.CM_StockOrderLineAlloc;
			if CM_LogStockOrderLine.hasInstance(lineAllocation.myStockOrderLine) then
				str := str &amp; lineAllocation.myStockOrderLine.CM_LogStockOrderLine.lotNo &amp; ', ';
			endif;
		endif;
	endforeach;

	strLength := str.length;
	//PAR 9237
	if strLength &gt; 1
	and str[strLength -1 : strLength] = ', ' then	//&lt;&lt;now  was line below
//	if str[strLength -2 : strLength] = ', ' then
		str := str[1 : strLength -2];
	endif;
	
	return str;	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllocatedVoyageCode" id="18273746-d8a1-4451-bfe9-254427f17c79">
        <source>getAllocatedVoyageCode() : String;
// ---------------------------------------------------------------------------
// Created:     26 March 2004	cnwth2
//
// Purpose:     For CCMS 1056 - used in reporting and not referenced - **DO NOT DELETE**
//			 	Returns voyage code of first stock order header found for the product location
// ----------   ----------  --------------------------------------------------
vars
	stockOrderAllocation	: CM_StockOrderAllocation;
begin

	stockOrderAllocation := self.allStockOrderAllocations.first;
	if stockOrderAllocation = null then
		return null;
	endif;
	
	if stockOrderAllocation.myStockOrderHeader.myVoyage = null then
		return null;
	endif;
	
	return 	stockOrderAllocation.myStockOrderHeader.myVoyage.code;	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCargoBOLType" id="2b19ed0d-64d9-43ef-b712-6f0773fddcfc">
        <source>getCargoBOLType() : CM_CargoBOLType;
//--------------------------------------------------------------
//Created: 06 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	cargoType : CM_CargoBOLType;
begin
	if self.myProduct.isKindOf(CM_ProductLog) then
		cargoType := app.myRoot.getCargoBOLTypeForId(TI_CargoType_Log);
	endif;
	return cargoType;
end;</source>
        <ReturnType type="CM_CargoBOLType"/>
    </JadeMethod>
    <JadeMethod name="getDetailForRemoteQuery" id="7c80ae9a-291c-4cc1-96c0-b731bf3ca9a7">
        <source>getDetailForRemoteQuery() : String;

vars

	response,
	location	: String;

begin

	if self.myLocationsController &lt;&gt; null then
		response := self.myLocationsController.myTerminalArea.getID().trimBlanks() &amp; ',' &amp; self.myLocationsController.getID().trimBlanks();
	endif;
	// DVB cbanged 10/09/03 to not use jasVolumeString as in includes commas.
	response := response &amp; ','  &amp; self.myProduct.getDetailForRemoteQuery() &amp; self.currentVolume.roundedTo(3).String &amp; ',' &amp; 
	self.getTotalWeight.String &amp; ',' &amp; self.getNumberOfTrackedItems.String;

	return response;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="c09ade17-c7ad-46dc-b0f4-486a8f644e9a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------------------
//Created: 12 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	str : String;
begin

	if _attrName = ETRow_RowId or
		_attrName = ETRow_Pieces or
		_attrName = ETRow_NumItems or
		_attrName = ETRow_Lot or		
		_attrName = ETRow_Hatch or
		_attrName = ETRow_Place then		
		if self.myLocationsController &lt;&gt; null then							
			return self.myLocationsController.getDisplayStringForAttribute(_attrName, _short);
		endif;
	elseif _attrName = ETRow_CurrentVolume or
       _attrName = ETRow_Volume then
		return self.currentVolume.jasVolumeString; 
	elseif _attrName = ETRow_Specifications or 
			_attrName = ETRow_Length or
			_attrName = ETRow_AverageSED or
			_attrName = ETRow_OldestFellDate or
			_attrName = ETRow_AverageVolume or		 			
			_attrName = ETRow_Date then
			if self.myExtension &lt;&gt; null then
				return self.myExtension.getDisplayStringForAttribute(_attrName, _short);
			else
				return null;
			endif;
	elseif _attrName = ETRow_Opt or _attrName = ETRow_Filler then 
		return 'false';
	elseif _attrName = ETRow_AvailableVolume then
		return self.calAvailableVolume.jasVolumeString;

	elseif _attrName = ETRow_AllocQuantity or
		 _attrName = ETRow_AllocVolume then
		return self.calAllocatedAmount().jasVolumeString;
		
	elseif _attrName = ETRow_AllocTypeString then
		if not self.canAllocateToOrder(null, false, null) then
			return 'All/Remaining';
		else
			return 'Quantity';						
		endif;
	elseif _attrName = ETRow_MyOperator
	or _attrName = ETRow_OperatorCode
	or _attrName = ETRow_Supplier then
		if self.myProduct &lt;&gt; null then
			return self.myProduct.getDisplayStringForAttribute(_attrName, _short);
		else
			return null;
		endif;
	elseif _attrName = ETRow_CheckColumn or
		_attrName = ETRow_ResiduePieceCount or
		_attrName = ETRow_ResidueVolume then
		return null;
	elseif _attrName = ETRow_AssignedVoyages then
		return self.getAllAssignedVoyageCodes();		
	endif;
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtensionClass" id="86aaf28b-4f14-41fa-8a84-41237a0ac9da">
        <source>getExtensionClass(): Class;
// ---------------------------------------------------------------------------
// Created:     24 May 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.myLocationsController = null then
		return null;
	endif;

	return self.myLocationsController.getSOHExtensionClass();

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoLogVoyOps" id="5e43dd5b-caee-4ca4-89c0-8010cc156d99">
        <source>getExtraInfoLogVoyOps(_array : HugeStringArray input);
//--------------------------------------------------------------
//Created: 25 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	allocSum,
	allocDtl	: CM_StockOrderAllocation;
	orderLine	: CM_StockOrderLine;
	str			: String;
	tmpVoyage   : CM_Voyage;
begin

	_array.add("Number of Items" &amp; Tab &amp; self.numTIs.String);		
	_array.add("Current Volume" &amp; Tab &amp; self.currentVolume.jasVolumeString);		

	if self.myExtension &lt;&gt; null then
		self.myExtension.getExtraInfoOLD(_array);
	endif;

	if (not self.allStockOrderAllocations.isEmpty) then
		str := 'Allocated to:' &amp; Tab;
		foreach allocSum in self.allStockOrderAllocations where allocSum.isKindOf(CM_StockOrderSummaryAlloc) do
			if allocSum.myStockOrderHeader = null then
				continue;
			endif;
			tmpVoyage := allocSum.myStockOrderHeader.myVoyage;
			if tmpVoyage = null then
				continue;
			endif;
			
//			str := str &amp; tmpVoyage.code &amp; '  (' &amp; allocSum.getAllocQuantityDisplayStr() &amp; ')';
			str := str &amp; allocSum.CM_StockOrderSummaryAlloc.getOrderID &amp; '  (' &amp; allocSum.getAllocQuantityDisplayStr() &amp; ')';
			
			_array.add(str);
			str := Tab &amp; Tab;
			
//			foreach allocDtl in self.allStockOrderAllocations where allocDtl.isKindOf(CM_StockOrderLineAlloc) do
			foreach allocDtl in allocSum.CM_StockOrderSummaryAlloc.allStockOrderLineAllocations do
				if allocDtl.myStockOrderHeader = null then
					continue;
				endif;
				if allocDtl.myStockOrderHeader.myVoyage &lt;&gt; tmpVoyage then
					continue;
				endif;
				
				orderLine := allocDtl.CM_StockOrderLineAlloc.myStockOrderLine;
				
				if CM_LogStockOrderLine.hasInstance(orderLine) then
					str := str &amp; '    Lot: ' &amp; orderLine.CM_LogStockOrderLine.lotNo 
							&amp; '  (' &amp; allocDtl.getAllocQuantityDisplayStr &amp; ')';
					_array.add(str);
					str := Tab &amp; Tab;
				endif;
			endforeach;
		endforeach;
	endif;
		
end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getID" id="a7f27277-8b09-4586-aa2f-6a7a5a1273eb">
        <source>getID(): String;
//--------------------------------------------------------------
//Created: 16 December 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	return self.myLocationsController.getID();

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getName" id="732333c3-95c6-4e6e-add3-f3897e5cce57">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:     22 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str	: String;
	
begin

	if self.myLocationsController &lt;&gt; null then
		str := self.myLocationsController.getID;
	endif;
	
	if self.myProduct &lt;&gt; null then
		str := str &amp; '-' &amp; self.myProduct.code;
	endif;

	return str &amp; '(' &amp; inheritMethod() &amp; ')';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNumberOfBOLIns" id="f024741c-69b7-46ce-bd7b-b41f792dd08d">
        <source>getNumberOfBOLIns() : Integer;
// -----------------------------------------------------------------------------
// Created:		02 July 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	iter : Iterator;
	cnt : Integer;
	lastBOL, currentBOL	: CM_BOLIn;
	ti : CM_TrackedItem;
begin
	iter := self.allTrackedItemsByReceivalBOL.createIterator();
	lastBOL := null;
	while iter.next(ti) do
		self.allTrackedItemsByReceivalBOL.getIteratorKeys(currentBOL, iter);
		if currentBOL &lt;&gt; lastBOL then
			cnt := cnt + 1;
			lastBOL := currentBOL;
		endif;
	endwhile;
	return cnt;
epilog 
	delete iter;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
