<Class name="VehicleMountedLogonAgent">
    <JadeMethod name="findFormsForUser" id="c6c0252f-3a83-44f7-a963-16b11560a0cc">
        <source>findFormsForUser(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 April 2010	cnwer1	Initial creation

*/

vars

begin
	app.myMobileAgent.allAvailableForms.clear();		//cnwmc5 - 4 April 2014 - PAR 33890

	//epr par 33147 6/12/13
	if self.myMachine &lt;&gt; null then
		if self.myMachine.getMachineType.allFaultQuestions.size &gt; 0 then
			app.myMobileAgent.allAvailableForms.add(MOB_VehicleMountedPreStart);
			return true;
		endif;
	endif;
	
	if app.myMobileAgent.allAvailableForms.size = 0 then
		if self.myMachine &lt;&gt; null and self.myMachine.machineLiftType = MULTI_LIFT then
			app.myMobileAgent.allAvailableForms.add(MOB_VehicleMountedWarehouse);
		else
			app.myMobileAgent.allAvailableForms.add(MOB_VehicleMountedForm);
		endif;
	endif;

	app.myVMAgent.user:=self.user;

	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
