    <JadeMethod name="showTableForTemplate" id="ee72a501-e86d-4df6-989d-8c9c914ee406">
        <updating/>
        <source>showTableForTemplate(_userReport : CM_MenuUserReport) updating, protected;
// ---------------------------------------------------------------------------
// Created:     07 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 27 Oct 2016	cnwrs1	TFS 2797 printer not displaying
// 30 Oct 2025  navah1  MTN-36162: NSWP | Handle Existing Date Parameters Stored and Ensure Legacy Report Support
// 16 Jan 2026  navah1	MTN-36669: PEN | Report Generation - SFTP Reports	 
vars
	filterDef		: CMQF_FilterReports;
	entRow			: EntTableRow;
	rowStr			: String;
	printerDef		: CM_PrinterDef;
	foundPrinterDef : CM_PrinterDef;
	row				: Integer;
	//terminal		: CM_Terminal;
	bgpRequest		: BGP_ReportRequest;
	qryParam			: CM_QueryReportParam;
    reportTemplate  : CM_ReportTemplate;
    reportRequest   : BGP_ReportRequest;
begin

	bgpRequest := _userReport.getBGPReportRequest();
	if bgpRequest = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null report request');
		return;
	endif;
	filterDef := bgpRequest.myFilter;
	
	if filterDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "The report request's filter is null");
		return;
	endif;	
	
	self.tblParameter.userInputEnabled := false;
	
	//cnwmc5 - 11 March 2016 - PAR 37496 - moved to showTableForReport because of new calling order..
	/*self.myReportAgent.allTerminals.clear();
	self.tblTerminals.allSelectedObjects.clear();
	filterDef.allTerminals.copy(self.myReportAgent.allTerminals);
	
	foreach row in 1 to self.tblTerminals.rows do
		terminal := self.tblTerminals.accessRow(row).itemObject.CM_Terminal;
		
		if terminal = null then
			continue;
		endif;
		
		if filterDef.allTerminals.includes(terminal) then
			self.tblTerminals.accessCell(row, 1).text := 1.String;
			self.tblTerminals.allSelectedObjects.add(terminal);
		else
			self.tblTerminals.accessCell(row, 1).text := 0.String;
		endif;
	endforeach;*/
	
	//epr par 36434 18/6/15
	foreach qryParam in filterDef.allQueryReportParams do
		row:=self.tblParameter.getRowByName(qryParam.paramName);
		if row &gt; 0 then
			//30.10.2025 navah1 #36162 Start
			//self.tblParameter.accessCell(row,CM_EntryTable.ColumnValue).text:=qryParam.getParamValue.asStringJMT;
			if qryParam.type = Date.number then  
				self.tblParameter.accessCell(row,CM_EntryTable.ColumnValue).text:=qryParam.getTemplateDate();
			else 
				self.tblParameter.accessCell(row,CM_EntryTable.ColumnValue).text:=qryParam.getParamValue.asStringJMT;
			endif; 
			//30.10.2025 navah1 #36162 End
		endif;
	endforeach;
	
	self.cmbFormat.text := self.myReportAgent.getFormatDescriptionForType(bgpRequest.outputDestination);
	self.tblPrintOptions.setValueByName(ETRow_FormatOption, self.cmbFormat.text);
	// TFS2797 cnwrs1
	foreach printerDef in app.myRoot.allPrinterDefsByLogicalName do
		if printerDef.physicalPrinterName = bgpRequest.printerName then
			foundPrinterDef := printerDef;
			break;
		endif;
	endforeach;
	if foundPrinterDef &lt;&gt; null then
		self.cmbPrinter.text := foundPrinterDef.logicalPrinterName;
		self.tblPrintOptions.setValueByName(ETRow_ChoosePrinter, self.cmbPrinter.text);
	endif;
	
	self.cmbProcess.text := self.PROCESS_BACKGROUND;

	self.tblPrintOptions.setValueByName(ETRow_ProcessOption, self.PROCESS_BACKGROUND);
	self.tblPrintOptions.setValueByName(ETRow_TemplateName, _userReport.name);
	self.tblPrintOptions.setValueByName(ETRow_TemplateDescription, _userReport.description);
	self.tblPrintOptions.setValueByName(ETRow_ServerFilePath, _userReport.networkFilepath);
	
    reportTemplate := _userReport.myReportTemplate;                                                 //MTN-36668
    if reportTemplate &lt;&gt; null then                                                                  //MTN-36668
        reportRequest := reportTemplate.myReportRequest;                                            //MTN-36668
        if reportRequest &lt;&gt; null and reportRequest.outputType = BGP_ReportRequest.FTP_SFTP then     //MTN-36668
            self.setFormatOption(reportRequest);                                                    //MTN-36668
            if reportTemplate.myFTPEntity &lt;&gt; null then                                              //MTN-36668
				self.cmbFTPEntity.text := reportTemplate.myFTPEntity.id;							//16.01.2026 navah1 #MTN-36669
                self.tblPrintOptions.setValueByName(ETRow_FTPEntity, reportTemplate.myFTPEntity.id);//MTN-36668
                //self.tblPrintOptions.setValueByControlName(self.cmbFormat.name, reportTemplate.myFTPEntity.id);
            endif;                                                                                  //MTN-36668
        endif;                                                                                      //MTN-36668
    endif;                                                                                          //MTN-36668
end;</source>
        <access>protected</access>
        <Parameter name="_userReport" type="CM_MenuUserReport"/>
    </JadeMethod>
    <JadeMethod name="showTemplateUserMaint" id="6035fb2f-1988-46e3-978f-ed39a3d4b500">
        <updating/>
        <source>showTemplateUserMaint() protected, updating;
// -------------------------------------------
// Created 13 December 2004 by cnwdvb1
// -------------------------------------------
vars

	reportTemplate	: CM_ReportTemplate;
	user			: CM_User;
	objArray		: ObjectArray;
	menuItem		: CM_MenuUserItem;
	failedDAC  :CM_DataAccessController;

begin

	if not global.isValidObject(self.myMenuEntity) then
		return;
	endif;
	
	reportTemplate := self.myMenuEntity.CM_MenuUserReport.myReportTemplate;
	
	create objArray transient;
	
	if reportTemplate = null then
		self.multiGrpEdit.setSelected(objArray);
		self.multiGrpOutput.setSelected(objArray);
		self.cmbUserRunAs.listObject := null;
		self.isUserCmbEnabled := false;
		return;
	endif;
	
	if reportTemplate.myUserToRunAs.canUserAccessSelf(null, failedDAC, app.myPassport) then
		self.cmbUserRunAs.listObject := reportTemplate.myUserToRunAs;
		self.isUserCmbEnabled := true;
	else
		self.cmbUserRunAs.listObject := null;
//	self.cmbUserRunAs.text := 'Access Denied';	// cnwrl1 11/11/2009 PAR 19951 - what it was
		self.cmbUserRunAs.text := app.getString( Access_Denied );
		self.isUserCmbEnabled := false;
	endif;
	
	
	foreach user in reportTemplate.allUsersToGetOutput do
		if self.allTemplateUsersOutput.includes(user) then
			objArray.add(user);
		endif;
	endforeach;
	
	self.multiGrpOutput.setSelected(objArray);
	
	objArray.clear();
	foreach menuItem in reportTemplate.allMenuUserReports do
		user := menuItem.CM_MenuUserReport.getMyUser();
		if user &lt;&gt; null and self.allTemplateUsersEdit.includes(user) then
			objArray.add(user);
		endif;
	endforeach;
	
	self.multiGrpEdit.setSelected(objArray);
	
epilog

	delete objArray;



end;</source>
        <access>protected</access>
    </JadeMethod>
