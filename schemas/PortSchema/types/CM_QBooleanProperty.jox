    <JadeMethod name="setComboValues" id="91695655-2aa1-4775-8af1-aaf063070120">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     05 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	
begin	
	_combo.clear();
	_combo.addItem( true.getYesNo() );		// Par 17266 - changing true and false to Yes and No
	_combo.addItem( false.getYesNo() );
//	_combo.addItem( app.getErrorString(NotApplicable) );	//23 Mar 2015	NDL	Par 35886


	if CM_QueryBooleanOperator.hasInstance(_queryOperator) then
		//_combo.text := _queryOperator.CM_QueryBooleanOperator.searchValue.String;
	//	if  _queryOperator.CM_QueryBooleanOperator.notApplicable then	//23 Mar 2015	NDL	Par 35886
	//		_combo.text := app.getErrorString(NotApplicable);
	//	else
		if _queryOperator.CM_QueryBooleanOperator.searchValue then
			_combo.text := true.getYesNo();
		else
			_combo.text := false.getYesNo();
		endif;
	endif;
	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="b8757e74-e85c-4875-9c4e-06bfbd2412ba">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     July 2008		cnwvu1	
// ---------------------------------------------------------------------------
vars

begin
	//23 Mar 2015	NDL	Par 35886
	if _value.String = app.getErrorString(NotApplicable) then
		return _value.String;
	endif;
	
	if _value.isKindOf(Integer) then	//25 Jun 2015	NDL	Par 36525
		if _value.Integer = 3 then
			return app.getErrorString(NotApplicable);
		elseif _value.Integer = 1 then
			return true.getYes();
		else
			return false.getYes();
		endif;
	endif;

	// Par 17266 - changing true and false to Yes and No
	return _value.Boolean.getYesNo();

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="e25ad93b-d6a4-472a-931d-05a8130940eb">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     July 2008		cnwvu1	
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
06 Oct 2008	cnwkpd1	PAR #18099 - Correct Selector query processing

*/

vars

begin
	//23 Mar 2015	NDL	Par 35886
	if _value.String = app.getErrorString(NotApplicable) then
		return _value;
	endif;
	if _value.isKindOf(Integer) then	//25 Jun 2015	NDL	Par 36525
		if _value.Integer = 3 then
			return app.getErrorString(NotApplicable);
		elseif _value.Integer = 1 then
			return true.getYes();
		else
			return false.getYes();
		endif;
	endif;
	
	return _value.String = true.getYes();

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="2e4d49bf-f7b3-40da-9fe5-200446483db8">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 06/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars

begin
	if _value.isKindOf(Boolean) then
		return _value.asStringJMT;
	elseif _value.isKindOf(String) and _value.String = "true" then
		return true;
	elseif _value.isKindOf(String) and _value.String = "false" then
		return false;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
