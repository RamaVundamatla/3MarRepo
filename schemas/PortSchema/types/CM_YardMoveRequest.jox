    <JadeMethod name="getSourceLocationID" id="8a704f30-dce4-4a1e-8e5b-528b26c42f6f">
        <source>getSourceLocationID() : String;
// -----------------------------------------------------------------------------
// Created:		24 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 24/07/2009	consw1		SFW1075 - To Do Task Scheduling
// -----------------------------------------------------------------------------

vars

begin
	if self.mySourceLocation = null then
		return null;
	endif;
	
	return self.mySourceLocation.getFullId();	// 23098 handle source being a gridded area
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSourceTA" id="8621894b-b6fb-416a-b8a3-7627cc6af597">
        <source>getSourceTA(): CM_TerminalArea;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2010	cnwer1	Initial creation

*/

vars

begin
	if self.mySourceLocation = null then
		return null;
	endif;
	
	return self.mySourceLocation.myTerminalArea;

epilog

end;</source>
