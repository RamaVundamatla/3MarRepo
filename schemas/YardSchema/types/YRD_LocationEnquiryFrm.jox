    <JadeMethod name="buildCargoMenuXtra" id="86f5f32b-cade-4ff6-a55c-e26dfdca082c">
        <updating/>
        <source>buildCargoMenuXtra(_cargoMenu : MenuItem input) : MenuItem updating;
//----------------------------------------------------------------
//	Created:	August 2005	by Russell Sargent  (cnwrs1)
//----------------------------------------------------------------

vars
	tmpMenu : MenuItem;

begin
	//epr TFS 47132 17/12/19
	if self.myCurrentObject = null or not self.myCurrentObject.isKindOf(CM_TrackedItem) then
		return null;
	endif;
	
	self.mnuCargoEdit.visible := true;
	tmpMenu := self.zCloneMenu(_cargoMenu, self.mnuCargoEdit, true); 
	self.mnuCargoEnquiry.visible := true;
	tmpMenu := self.zCloneMenu(_cargoMenu, self.mnuCargoEnquiry, true); 
	self.mnuRemarks.visible := true;
	tmpMenu := self.zCloneMenu(_cargoMenu, self.mnuRemarks, true); 
	return tmpMenu;	
end;</source>
        <Parameter name="_cargoMenu" type="MenuItem" usage="input"/>
        <ReturnType type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="create" id="7191cb70-4d34-49bf-880d-44496dd109d4">
