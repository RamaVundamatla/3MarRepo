    <JadeMethod name="getCargoId" id="83bdfb5f-6511-48a8-a52e-4f3278ebf991">
        <source>getCargoId(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin
	return self.cargoId;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="65b767a8-d0dd-47b1-89f0-49e643cccb54">
        <source>getDescription(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	str : String;

begin

	if self.proformaDesc &lt;&gt; null then
		str := self.proformaDesc.removeCrLfs();
		if str.length &gt; 70 then
			str := str[1:67] &amp; "...";
		endif;
	endif;
	
	if str = null then
		str := self.cargoId;
	endif;

	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDriverName" id="1ea5ce84-8991-454f-a10f-1a80b085116f">
        <source>getDriverName(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	if self.driver.trimBlanks &lt;&gt; null then
		return self.driver;
	endif;
	
	return app.getErrorString(Unknown);

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
