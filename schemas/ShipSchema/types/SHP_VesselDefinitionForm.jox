        <updating/>
        <source>btnBayDefinition_click(btn: Button input) updating;
//--------------------------------------------------
// Created:	07 September 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.myCurrentVessel &lt;&gt; null then
		self.myAssistant.showVesselBayDefinForm(self.myCurrentVessel.myCellularVesselStructure, self.myMasterMenuAction, false);
	else
		self.myAssistant.showVesselBayDefinForm(null, self.myMasterMenuAction, false);
	endif;					
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnChangeBitmap_click" id="5fa484f2-8a0f-4e58-a1af-d98f3859d487">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnChangeBitmap_click(btn: Button input) updating;
//--------------------------------------------------
// Created:	06 September 2005 By: cnwgd1
//--------------------------------------------------
vars
	fileOpenDialog	: CMDFileOpen;
	fileName		: String;
	result : Integer;
	
begin
	create fileOpenDialog;
	
	result := fileOpenDialog.open;
	if result = 0 then
		fileName	:=	fileOpenDialog.fileName;
		
		if app.checkPictureFile(fileName) &lt;&gt; PictureType_None then
			picVesselBitmap.picture	:=	app.loadPicture(fileName);
		endif;
		
	else
		//clicked cancel
		if picVesselBitmap.picture &lt;&gt; null then
			if app.msgBox(app.getErrorString(Would_like_clear_vessel_image), app.getErrorString(Clear_existing_image), MsgBox_Yes_No + MsgBox_Default_Second ) = MsgBox_Return_Yes then
				picVesselBitmap.picture	:= null;
			endif;
		endif;
		
	endif;
	
	self.btnExtractImage.enabled	:=	self.picVesselBitmap.picture &lt;&gt; null;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
