    <JadeMethod name="updateProgress" id="bd6ca121-5f94-4b2e-9889-dfccf25a9013">
        <updating/>
        <source>updateProgress(_cmifMonitor : CMIF_Monitor) updating;
// ---------------------------------------------------------------------------
// Created:     20 May 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if self.frmModalDialog.visible then
		self.modalDialogUpdateInfo(_cmifMonitor.message);
		self.pbProgressBar.partsInJob := _cmifMonitor.partsInJob;
		self.pbProgressBar.partsDone  := _cmifMonitor.partsDone;
		self.pbProgressBar.doWindowEvents(0);
	endif;

end;




</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor"/>
    </JadeMethod>
</GUIClass>
