//			str := str &amp; '&lt;ShipDepartTime&gt;&lt;/ShipDepartTime&gt;' &amp; CrLf;	//_departTime
//			str := str &amp; '&lt;VoyageNo&gt;&lt;/VoyageNo&gt;' &amp; CrLf;
//			str := str &amp; '&lt;VesselName&gt;&lt;/VesselName&gt;' &amp; CrLf;
//			str := str &amp; '&lt;ShipOperator&gt;&lt;/ShipOperator&gt;' &amp; CrLf;
//		str := str &amp; '&lt;/TransportDetail&gt;' &amp; CrLf;
	str := str &amp; '&lt;/TransportDetails&gt;' &amp; CrLf;
	
	return str;
end;</source>
        <access>protected</access>
        <Parameter name="_departTime" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
