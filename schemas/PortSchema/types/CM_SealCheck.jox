    <JadeMethod name="getDisplayStringForAttribute" id="0837f2bf-e14b-4a2d-b84e-a3347eb0e9c6">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// Jan 2011 CCMS 1262 Transaction Enquiry
//2/10/2019		JLGNS1		ChangeRequest 45790: JMT - Refactor - Seal Transactions
vars
	detail : CM_SealCheckDetail;
begin

	if _attrName = 	ETRow_SealCheck then
		return self.getSealCheckDetails();
		
	elseif _attrName = ETRow_Type then
		detail := self.allSealCheckDetails.first;
		if detail &lt;&gt; null then
			if detail.sealCheckType = SEAL_CHECK_RECORDED then
				return "Seal Recorded";
			endif;
		endif;
	endif;
	
	return inheritMethod(_attrName, _short);
	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getImexString" id="a2219f75-6b49-4409-80f1-2bec752fe0f0">
        <source>getImexString():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2010	cnwndl1	Initial creation

*/

vars
	
	imex : CM_IMEXStatus;
	
begin


	if self.imExStatus &gt; 0 then
		imex := app.myRoot.allImexStatuses[self.imExStatus];
		if imex &lt;&gt; null then
			return imex.description;
		else
			return "Unknown";
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
