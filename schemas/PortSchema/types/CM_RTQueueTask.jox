    <JadeMethod name="getMultiDirectorUltimateTarget" id="352b5616-f20e-464c-af05-c446c0a89006">
        <source>getMultiDirectorUltimateTarget() : CM_LocationsController;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 November 2010	cnwrd1	Initial creation
//cnwrd1 par 25681 18.11.2010 multi machine director moves
*/

vars
	targetLC : CM_LocationsController;
begin

	// need to find the last entry's director task and return its target location.
	if not self.isMultiMachineDirector() then
		return null;
	endif;
	
	targetLC:= self.myEntry.getMultiDirectorUltimateTarget();
	if targetLC = null then
		targetLC:= self.myEntry.getUltimateTargetLocation;
	endif;
	
	return targetLC;
epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
