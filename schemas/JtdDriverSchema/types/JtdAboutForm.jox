    <JadeMethod name="btnClose_click" id="997d7871-a861-4c4e-9048-dcc97199c5a5">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClose_click(btn: Button input) updating;

begin
	self.unloadForm;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lblWebSite_click" id="77713974-cdad-4a25-b664-88e47f0658fe">
        <controlMethod name="Label::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lblWebSite_click(label: Label input) updating;

vars
	result : Integer;

begin
	if app.isUnicode then
		result := call jtdShellExecuteW(self.hwnd, "open", "http://www.discoverjade.com", null, null, 1);
	else
		result := call jtdShellExecuteA(self.hwnd, "open", "http://www.discoverjade.com", null, null, 1);
	endif;
	
	if result &lt;= 32 then
		app.msgBox("Error opening browser to http://www.discoverjade.com" &amp; CrLf &amp; CrLf &amp;
			"Windows error code: " &amp; result.String, "Error Opening Browser",
			MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	endif;
end;</source>
        <Parameter name="label" type="Label" usage="input"/>
    </JadeMethod>
    <JadeMethod name="load" id="aee88e57-77b8-4f44-9bb2-a7d2f23bcd2b">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	self.lblVersion.caption := app.jtdMyContext.jtdGetVersionString;
	self.centreWindow;
end;</source>
    </JadeMethod>
