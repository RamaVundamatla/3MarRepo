    <JadeMethod name="selectCargoInvoiceLine" id="98c8bb16-7060-43dc-a3d7-29332eef1fdb">
        <updating/>
        <source>selectCargoInvoiceLine() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

	invLine : CM_InvoiceLine;
	cashPayment : CM_CashPayment;

begin

	self.tblInvLineCashP.rows := self.tblInvLineCashP.fixedRows;
	self.tblInvLineCashP.allSelectedObjects.clear();
	
	invLine := self.tblCargoInvL.allSelectedObjects.first.CM_InvoiceLine;
	self.myCurrentInvoiceLine := invLine;
	
	if invLine = null then
		return;
	endif;
	
	foreach cashPayment in invLine.allCashPayments discreteLock do
		if cashPayment.myCashPaymentForInvoice &lt;&gt; null then // tax payment ignore
			continue;
		endif;
		self.tblInvLineCashP.addObject( cashPayment );
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="selectReleasedCargoItem" id="61cb4aa0-8dd6-42a7-a9f2-de7bd08be075">
        <updating/>
        <source>selectReleasedCargoItem() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

	ti : CM_TrackedItem;

begin

	ti := self.tblRelCargo.allSelectedObjects.first.CM_TrackedItem;
	self.myCurrentTrackedItem := ti;
	
	self.populateTblUnassCashP( ti );	
	self.populateTblCargoInvL( ti );	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="d6056457-0f7d-4023-8226-1327362d2907">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2019	jlgndl1	Initial creation

*/

vars

	selectedTi : CM_TrackedItem;
	selectedInvLine : CM_InvoiceLine;
	allSelectedAssigned : CM_CashPaymentSet;
	allSelectedUnassigned : CM_CashPaymentSet;
	
	selectedRowIndex : Integer;
	cashPayment : CM_CashPayment;
	
begin

	//Get details of what we have selected in each table.
	selectedTi := self.myCurrentTrackedItem;
	selectedInvLine := self.myCurrentInvoiceLine;
	
	create allSelectedAssigned transient;
	self.tblInvLineCashP.allSelectedObjects.copy(allSelectedAssigned);
	
	create allSelectedUnassigned transient;
	self.tblUnassCashP.allSelectedObjects.copy(allSelectedUnassigned);
	
	// Refresh the table and re-select based on what we captured above
	if _theTable = self.tblRelCargo then
		if self.tblRelCargo.rows &gt; self.tblRelCargo.fixedRows and self.lastFindButton &lt;&gt; null then
			self.doBtnFind( self.lastFindButton ); // refreshes the data using the last find.
		endif;
		self.reselectReleasedCargo( selectedTi, selectedInvLine, allSelectedAssigned, allSelectedUnassigned ); // reselects all selected objects
	
	elseif _theTable = self.tblUnassCashP then	
		self.populateTblUnassCashP( self.myCurrentTrackedItem );
		self.reselectUnassignedCashPs( allSelectedUnassigned );
	
	elseif _theTable = self.tblCargoInvL then 
		self.populateTblCargoInvL( self.myCurrentTrackedItem );
		self.reselectCargoInvLines(	selectedInvLine, allSelectedAssigned );
	
	elseif _theTable = self.tblInvLineCashP then 
		self.selectCargoInvoiceLine();
		self.reselectInvLineCashPas( allSelectedAssigned );
		
	endif;
		
epilog

	delete allSelectedAssigned;
	delete allSelectedUnassigned;

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="5491848d-1439-49f6-8a1f-6a253f9157e6">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

begin

	inheritMethod();
	
	self.populateCmbVoyage();
	self.populateCmbCargoType();
	self.initialiseTables();
	
	self.enableButtons();
	
	self.showFrmManual( false );
	
	beginClassNotification( CM_CashPayment, false, Any_System_Event, Response_Continuous, 0 );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showFrmManual" id="f8dc09b5-f2f9-4a12-911c-74ceeaa51791">
        <source>showFrmManual( _show : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

begin

	if _show then
		self.populateFrmManual();
	endif;
	
	self.dkcMain.enabled := not _show;
	self.frmManual.visible := _show;
	
	if _show then
		self.frmManual.zOrder(1);
	endif;
		
epilog

end;</source>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
