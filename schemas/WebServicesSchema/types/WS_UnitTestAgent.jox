        <source>wsRESTPostFindCargo(_loginString: String; json: String; _response: String io; expectErrors: Boolean; _queryParamString : String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Mar 2024	navhn30		Initial creation TFS 56853 CUX | POST /findCargo - EDBIC 190 - Cargo Details Query Tk62914 GolCrit 01*

*/

vars
