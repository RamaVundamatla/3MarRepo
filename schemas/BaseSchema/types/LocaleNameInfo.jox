<Class name="LocaleNameInfo">
    <JadeMethod name="cnEcCopyInfo" id="03c65cf1-ec48-4722-970c-4196c743d917">
        <updating/>
        <source>cnEcCopyInfo(pLocaleNameInfoObj : LocaleNameInfo) updating;
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		Copies all property values from the specified LocaleNameInfo
//				object to the receiver.
//
// Parameters:	pLocaleNameInfoObj - The object to copy the property values from.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.abbreviatedCountryName	:=	pLocaleNameInfoObj.abbreviatedCountryName;
	self.abbreviatedLangName	:=	pLocaleNameInfoObj.abbreviatedLangName;
	self.countryCode			:=	pLocaleNameInfoObj.countryCode;
	self.englishCountryName		:=	pLocaleNameInfoObj.englishCountryName;
	self.englishLangName		:=	pLocaleNameInfoObj.englishLangName;
	self.languageId				:=	pLocaleNameInfoObj.languageId;
	self.localeId				:=	pLocaleNameInfoObj.localeId;
	self.localizedCountryName	:=	pLocaleNameInfoObj.localizedCountryName;
	self.localizedLangName		:=	pLocaleNameInfoObj.localizedLangName;
	self.nativeCountryName		:=	pLocaleNameInfoObj.nativeCountryName;
	self.nativeLangName			:=	pLocaleNameInfoObj.nativeLangName;
end;</source>
        <Parameter name="pLocaleNameInfoObj" type="LocaleNameInfo"/>
    </JadeMethod>
</Class>
