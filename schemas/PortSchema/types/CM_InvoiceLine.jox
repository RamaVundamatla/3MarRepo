    <JadeMethod name="adjustForSplitByAmount" id="c9b2f63b-1f63-4f57-ae71-9b37eb195484">
        <updating/>
        <source>adjustForSplitByAmount( _invAdjustmentAmount : Decimal; _payAdjustmentAmount : Decimal) updating;

/*

Purpose:			 // TFS 7311

Parameters:			

Return Value:		


Date		Who		Reason
06 October 2017	jlgab1	Initial creation
//02/02/2018	jlgns1	Bug 36580: ADP - Tax for Cash Module Part 3
//8/08/2018 	JLGNS1	Bug 39772: PKT - Decimal Precision Error
// ### JIRA 34909 16MAY2025 NAVAB1 changed all the REALS to decimals
*/

vars
	quantity  : Decimal[23, 6];
//	totpay, newTotal : Decimal[16, 6];
//	factor :  Decimal[14, 12]; 
	roundDecimalOpt : Integer;
	payment, taxPayment, lastPayment		: CM_CashPayment;
	totpay, newCashValue, totalCashPayment : Decimal[23, 6];	//11 May 2018	NDL	TFS 38528
	factor :  Decimal[23, 12]; 	//11 May 2018	NDL	TFS 38528	// Bug 39772 
	terminal : CM_Terminal;
begin
	// ### JIRA 34982 28MAY2025 NAVAB1 do same rounding for cash payment as invoice line
	terminal := self.myTerminal;
	if terminal &lt;&gt; null then
		roundDecimalOpt := terminal.getConfig(InvoiceRoundLineTotal).Integer;
	endif;

	// ### ADJUST THE INVOICE LINE BY THE AMOUNT
	quantity := self.quantity;
	quantity := quantity + _invAdjustmentAmount; // INCREASE by ADJUSTMENT
	self.setQuantityAndTotal(quantity);
	self.setManual(true);
	self.setQuantityAndTotalAmount(quantity, self.lineTotal); // ### JIRA 34909 22MAY2025 NAVAB1
	
	// ### GET THE TOTAL OF ALL PAYMENTS ON THIS LINE
	foreach payment in self.allCashPayments do
		if payment.voided then
			continue;
		endif;
		totpay := totpay + payment.cashValue;
	endforeach;
	
	// ### WORK OUT THE PERCENTAGE FACTOR TO IN CREASE BY
	// ### e.g. totpay = $100. _payAdjustmentAmount = $20. factor = 1.20%
	factor := 1;
	if totpay &lt;&gt; 0 then
		factor := (_payAdjustmentAmount / totpay) + 1;
	endif;
	
	 // ### JIRA 34982 12JUN2025 NAVAB1
	lastPayment := self.allCashPayments.last;
	
	foreach payment in self.allCashPayments do
		if payment.voided then
			continue;
		endif;
		
		// ### JIRA 34982 12JUN2025 NAVAB1 do same rounding for cash payment as invoice line
		if payment = lastPayment then
			newCashValue := self.lineTotal - totalCashPayment;
			if roundDecimalOpt &lt;&gt; CMIF_ConfigTerminal.InvLineRound_Value_NoRound then
				newCashValue := newCashValue.roundedTo(roundDecimalOpt);  
			endif;
			payment.doAuditSplitMerge(factor,payment.cashValue,newCashValue,method.qualifiedName,CM_AuditCashAdjustment.REASON_TRANSFER);
			payment.setCashValue(newCashValue);
		else
			newCashValue := payment.cashValue * factor; // INCREASE by ADJUSTMENT
			payment.doAuditSplitMerge(factor,payment.cashValue,newCashValue,method.qualifiedName,CM_AuditCashAdjustment.REASON_TRANSFER);		//Bug 36580	
			payment.setCashValue(newCashValue);
			totalCashPayment := totalCashPayment + newCashValue; // ### JIRA 34909 21MAY2025 NAVAB1
		endif;
		// TFS 8275
		taxPayment := payment.myCashPaymentForTax;
		if taxPayment &lt;&gt; null then
			newCashValue := taxPayment.cashValue * factor; // INCREASE by ADJUSTMENT
			taxPayment.setCashValue(newCashValue);
		
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_invAdjustmentAmount" type="Decimal"/>
        <Parameter name="_payAdjustmentAmount" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="adjustForSplitByFactor" id="9ebe3baa-98a5-4526-aac7-28e6cbf8ee15">
        <updating/>
        <source>adjustForSplitByFactor( _factor : Decimal;  _invAdjustmentAmount : Decimal output;  
									_payAdjustmentAmount : Decimal output; _taxAdjustmentAmount : Decimal output; _includeTax : Boolean output) updating;

/*

Purpose:			 // TFS 7311

Parameters:			

Return Value:		


Date		Who		Reason
06 October 2017	jlgab1	Initial creation
//02/02/2018	jlgns1	Bug 36580: ADP - Tax for Cash Module Part 3
//8/08/2018 	JLGNS1	Bug 39772: PKT - Decimal Precision Error
// ### JIRA 34909 16MAY2025 NAVAB1 changed all the REALS to decimals. Plus getting slight difference in CM_InvoiceLine.lineTotal and CM_CashPayment.cashValue in the decimal part which can lead to rounding up and there being a difference
//														This is becaus ethe invoic eline adjusts the quantity by the factor then uses the rate to get the line total whereas the cash payment just adjusts the cash value.
//														So basically now adjust the line total as before, but now set the cash value to the line total
*/

vars
	quantity : Decimal[23,6];
	payAdjustmentAmount : Decimal[23,6];
//	newTotal : Decimal[16, 6];
//	factor :  Decimal[14, 12]; 
	
	payment, taxPayment, lastPayment		: CM_CashPayment;
	newCashValue, newLineTotal, totalCashPayment, totalTaxPayment : Decimal[23, 6];	//11 May 2018	NDL	TFS 38528
	factor :  Decimal[23, 12];	//11 May 2018	NDL	TFS 38528// Bug 39772 
	terminal : CM_Terminal;
	roundDecimalOpt : Integer;
begin
	// ### JIRA 34982 28MAY2025 NAVAB1 do same rounding for cash payment as invoice line
	terminal := self.myTerminal;
	if terminal &lt;&gt; null then
		roundDecimalOpt := terminal.getConfig(InvoiceRoundLineTotal).Integer;
	endif;

	factor := _factor; // EG 0.10%
	_includeTax := false;
	// ### ADJUST INVOICE LINE
	quantity := self.quantity;
	_invAdjustmentAmount := (quantity * factor).roundedTo(6);
	quantity := quantity - _invAdjustmentAmount; // REDUCE by ADJUSTMENT
	
	self.setQuantityAndTotal(quantity);
	self.setManual(true);
	self.setQuantityAndTotalAmount(quantity, self.lineTotal); // ### JIRA 34909 22MAY2025 NAVAB1
	self.setTotalAndTaxForResync();  // ### JIRA 35213 01JUL2025 NAVAB1

	 // ### JIRA 34909 21MAY2025 NAVAB1
	lastPayment := self.allCashPayments.last;
	
	foreach payment in self.allCashPayments do
		if payment.voided then
			continue;
		endif;
		
		 // ### JIRA 35593 30JUL2025 NAVAB1
		if payment.isCancelled() then
			continue;
		endif;
		
		if payment = lastPayment then
			// ### JIRA 34982 28MAY2025 NAVAB1 do same rounding for cash payment as invoice line
			newCashValue := self.lineTotal - totalCashPayment;
			if roundDecimalOpt &lt;&gt; CMIF_ConfigTerminal.InvLineRound_Value_NoRound then
				newCashValue := newCashValue.roundedTo(roundDecimalOpt);  
			endif;
			
			_payAdjustmentAmount  := _payAdjustmentAmount + (payment.cashValue -  newCashValue);
			payment.setCashValue(newCashValue);
			
			taxPayment := payment.myCashPaymentForTax;
			if taxPayment &lt;&gt; null then
				_includeTax := true;
				payment.setCashValue(newCashValue);
			endif;
		else
			newCashValue := payment.cashValue;
			 // ### JIRA 34982 28MAY2025 NAVAB1 do same rounding for cash payment as invoice line
			payAdjustmentAmount := (newCashValue * factor); //.roundedTo(6);
			if roundDecimalOpt &lt;&gt; CMIF_ConfigTerminal.InvLineRound_Value_NoRound then
				payAdjustmentAmount := payAdjustmentAmount.roundedTo(roundDecimalOpt);  
			endif;
			
			_payAdjustmentAmount := _payAdjustmentAmount + payAdjustmentAmount; // TOTAL THE PAY ADJUSTMENT TO PASS BACK
			newCashValue := newCashValue - payAdjustmentAmount; // REDUCE by ADJUSTMENT
			payment.doAuditSplitMerge(1 - factor,payment.cashValue,newCashValue, method.qualifiedName,CM_AuditCashAdjustment.REASON_SPLIT_ORIGINAL);		//Bug 36580
			payment.setCashValue(newCashValue);
			totalCashPayment := totalCashPayment + newCashValue; // ### JIRA 34909 21MAY2025 NAVAB1
			
		endif;
		// TFS 8275
		taxPayment := payment.myCashPaymentForTax;
		if taxPayment &lt;&gt; null then
			_includeTax := true;
			newCashValue := taxPayment.cashValue;
			// ### JIRA 34982 28MAY2025 NAVAB1 do same rounding for cash payment as invoice line
			payAdjustmentAmount := (newCashValue * factor); //.roundedTo(6);
			if roundDecimalOpt &lt;&gt; CMIF_ConfigTerminal.InvLineRound_Value_NoRound then
				payAdjustmentAmount := payAdjustmentAmount.roundedTo(roundDecimalOpt);  
			endif;
			
			
			
			_taxAdjustmentAmount := _taxAdjustmentAmount + payAdjustmentAmount; // TOTAL THE TAX ADJUSTMENT TO PASS BACK
			newCashValue := newCashValue - payAdjustmentAmount; // REDUCE by ADJUSTMENT
			taxPayment.setCashValue(newCashValue);
			totalTaxPayment := totalTaxPayment + newCashValue; // ### JIRA 34909 21MAY2025 NAVAB1
			
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_factor" type="Decimal"/>
        <Parameter name="_invAdjustmentAmount" type="Decimal" usage="output"/>
        <Parameter name="_payAdjustmentAmount" type="Decimal" usage="output"/>
        <Parameter name="_taxAdjustmentAmount" type="Decimal" usage="output"/>
        <Parameter name="_includeTax" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="adjustQuantityForRange" id="5aa6a455-e855-48a8-8445-292a779e4c71">
        <source>adjustQuantityForRange(_value : Real) : Real;
// ---------------------------------------------------------------------------
// Created:		12 October 2007 By Andrew Bishop cnwab1
//				revised July 2010 for 24160 after unit tests written
// Purpose:		
//
// ---------------------------------------------------------------------------
// Date				Who		Reason
// 23 Oct 2024		navlw1	JIRA-33107: Invoice Logging Use Levels
// 25 Feb 2025		navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
//
vars
	lower, upper, adjusted, previousAmount, value : Real;
	adjustment : Integer;
	calcType : CM_CalculationType;
	lastRange : Boolean;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	// if there is a value in these then the Quantity Map was 'Escalating'
	if self.quantityRangeEnd = 0 and self.quantityRangeStart = 0 then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " not escalating, returning _value=" &amp; _value.String, LogINFO.String);
		endif;
		return _value;
	endif;
	
	if self.quantityRangeZero then
		if  (_value &gt;= self.quantityRangeEnd) then
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " quantityRangeZero, returning ZERO from _value=" &amp; _value.String, LogINFO.String);
			endif;
			return 0; // !!!!!!!!
		else
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " quantityRangeZero, returning _value=" &amp; _value.String, LogINFO.String);
			endif;
			return _value;
		endif;
		
	endif;
	
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog(method.qualifiedName &amp; " _value=" &amp; _value.String &amp; " qtyRangeStart=" &amp; self.quantityRangeStart.String &amp; " qtyRangeEnd=" &amp; self.quantityRangeEnd.String, LogINFO.String);
	endif;
	// PAR 24160 from here - Aug 2013 the getPreviousLinkedAmount call was at the start but is not needed until here - moved down for efficiency
	if self.isStorageByDays() then
		previousAmount := self.getPreviousLinkedAmount();
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " is storage by days, prev linked amount=" &amp; previousAmount.String, LogINFO.String);
		endif;
	endif;
	if previousAmount &gt; 0 then
		if (_value + previousAmount) &gt; self.quantityRangeEnd then
			upper := self.quantityRangeEnd;
			lower := previousAmount;
			if previousAmount &lt; self.quantityRangeStart then
				lower := self.quantityRangeStart;
				adjustment := 1;
			endif;
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " 1: upper=" &amp; upper.String &amp; " lower=" &amp; lower.String &amp; " adjustment=" &amp; adjustment.String, LogTRACE.String);
			endif;
		else
			adjustment := 0;
			upper := (_value + previousAmount - adjustment);
			lower := self.quantityRangeStart;
			// handle being in the last quantity range
			if previousAmount &gt; lower then
				lower := previousAmount;
			endif;
			if self.quantityRangeStart &gt; 0 and 
			   previousAmount &lt; self.quantityRangeStart then
				adjustment := 1;
			endif;
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " 2: upper=" &amp; upper.String &amp; " lower=" &amp; lower.String &amp; " adjustment=" &amp; adjustment.String, LogTRACE.String);
			endif;
		endif;
	// PAR 24160 to here
	else
		if _value &gt; self.quantityRangeEnd then
			upper := self.quantityRangeEnd;
		else
			upper := _value;
			lastRange := true;
		endif;
		if self.quantityRangeStart &gt; 0 then
			adjustment := 1;
		endif;
		lower := self.quantityRangeStart;
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " 3: upper=" &amp; upper.String &amp; " lower=" &amp; lower.String &amp; " adjustment=" &amp; adjustment.String, LogTRACE.String);
		endif;
	endif;
	
	adjusted := (upper - lower) + adjustment;
	
	// TFS 38113
	if not self.isCalcTypeSame4MeQuantityRange() then
		// If the quantity range is for DAYS, and the range is not the last range, then the ADJUSTED is for that range of days only, i.e. no weight or volume or TEU is in ADJUSTED
		if self.quantityRangeCalc = INV_CALC_TYPE_DAYS_SINCE_RECVL 
		or self.quantityRangeCalc = INV_CALC_TYPE_DAYS_ONSITE_AT then
			if lastRange then
				// The 'adjusted' value for the last range will include the weight/volume etc.
				// So need to get the days and make adjusted just the days, so that below we can use the weight, volume etc in the calculation.
				// get number of days from the quantity range calc type
				value := self.quantityCARGObyType(self.quantityRangeCalc, false);
				adjusted := (value - lower) + adjustment;
			endif;
		
			calcType := self.invoiceLineDesc.myCalculationType;
		
			if calcType.calculationType = INV_CALC_TYPE_DAYS_WEIGHT then
				adjusted := adjusted * self.trackedItemWeight;
			elseif calcType.calculationType = INV_CALC_TYPE_DAYS_VOLUME then
				adjusted := adjusted * self.trackedItemVolume;
			elseif calcType.calculationType = INV_CALC_TYPE_DAYSINCE_REC_TEU then
				adjusted := adjusted * self.trackedItemTEU();
			elseif calcType.calculationType = INV_CALC_TYPE_DAYSINCE_REC_RT and self.myTransactionTI &lt;&gt; null then	//08 May 2018	NDL	TFS 38525
				adjusted := adjusted * self.myTransactionTI.getRTvalue;
			endif;
			
		endif;
	endif;
	
	
	// from 37687 if quantity calc from CM_QuantityMap is wrong for escalatig storage, can get extra invoice line types such that the value here becomes negative
	//  log and return 0 in this case.
	if adjusted &lt; 0 then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " adjusted is NEGATIVE " &amp; adjusted.String, LogTRACE.String);
		endif;
		adjusted := 0;
	endif;
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog(method.qualifiedName &amp; " returning adjusted=" &amp; adjusted.String, LogTRACE.String);
	endif;
	return adjusted;
end;</source>
        <Parameter name="_value" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
