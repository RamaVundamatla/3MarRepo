        <source>cmbCarrier_lostFocus(combobox: ComboBox input) updating;
// -------------------------------------------
// Created 15 September 2004 by cnwdvb1
//15/01/2015   cnwma1		 PAR #35462 Carrier Drop-down Fields	
// -------------------------------------------
vars
		tbl			: CM_EntryTable;
begin

	//self.tblMasterEnt.setValueByControlName(combobox.name, combobox.text);
	
	if not CM_EntryTable.hasInstance(combobox.parent) then
		return;
	endif;

	tbl := combobox.parent.CM_EntryTable;
	
	if combobox.listObject &lt;&gt; null then
		tbl.setValueByControlName(combobox.name, combobox.listObject.CM_Carrier.code);
	else
		tbl.setValueByControlName(combobox.name, null);
	endif;
	

end;



