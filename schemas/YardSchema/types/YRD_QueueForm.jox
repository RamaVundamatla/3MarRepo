    <JadeMethod name="moveQueue" id="b646ad5b-655d-47fb-aec2-6a595db5ce32">
        <updating/>
        <source>moveQueue(pFrom : Object; pTo : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     05 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpNum	: Integer;
	fromObj,
	toObj	: CM_Object;
	ok		: Boolean;
	targetQueue : CM_RadioTelemetryQueue;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin

//	if pFrom = pTo then
//		return;
//	endif;
	
	app.mousePointer := MousePointer_HourGlass;

	tmpNum := lstQueues.listCount;
//	if pFrom &lt;= 0 or pTo &lt;= 0 or pFrom &gt; tmpNum or pTo &gt; tmpNum then
	if pTo &lt;= 0 or pTo &gt; tmpNum then
		app.raiseUnexpectedProgramError(class.name, method.name, 'From/To outside valid limits');
		return;
	endif;

	fromObj := pFrom.CM_Object;
	toObj	:= lstQueues.itemObject[pTo].CM_Object;
	if toObj.isKindOf(CM_RTQueueEntry) then
		targetQueue := toObj.CM_RTQueueEntry.myQueue;
	elseif toObj.isKindOf(CM_RadioTelemetryQueue) then
		targetQueue :=toObj.CM_RadioTelemetryQueue;
	endif;
	
	
	if fromObj.isKindOf(CM_RadioTelemetryQueue) then
		if toObj.isKindOf(CM_RTQueueEntry) then
			toObj := toObj.CM_RTQueueEntry.myQueue;
		endif;
	elseif fromObj.isKindOf(CM_RTQueueEntry) then
		self.deselectRTQueueEntry( fromObj );	//17 July 2014	NDL	Par 25646
	endif;
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		if fromObj.isKindOf(CM_RadioTelemetryQueue) then
			app.myTrxUA.trxUpdateQueuePosition(fromObj.CM_RadioTelemetryQueue, toObj.CM_RadioTelemetryQueue,app.myPassport);		
		elseif fromObj.isKindOf(CM_RTQueueEntry) then
			app.myTrxUA.trxUpdateQueueEntryPosition(fromObj.CM_RTQueueEntry, toObj, app.myPassport);
		endif;
	
		if app.myPassport.trxCompletedOK then
			self.showQueueThumbnail(targetQueue);
			break;
		else
			theResult := app.showErrorWarningDialog('Task Status', app.myPassport, ErrWarnMode_Add);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;

epilog
	app.mousePointer := MousePointer_Default;	
end;</source>
        <Parameter name="pFrom" type="Object"/>
        <Parameter name="pTo" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="moveQueueMulti" id="cdb89293-0617-43fd-ba63-90e505dbfa38">
        <updating/>
        <source>moveQueueMulti( _lObj : Object; _newIndex : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 July 2014	cnwndl1	Initial creation	Par 25646

*/

vars
	targetIndex,
	index : Integer;
	obj : Object;
	targetRTQueueEntry : Object;
	entry : CM_RTQueueEntry;
	localArray : CM_RTQueueEntryArray;
	 
begin
	
	
	targetRTQueueEntry:=self.lstQueues.itemObject[_newIndex];
	
	if _lObj.isKindOf(CM_RTQueueEntry) then
		create localArray transient;
		if not self.allSelectedRTQEntries.isEmpty then
			self.allSelectedRTQEntries.copy( localArray );
		endif;
		if not localArray.includes( _lObj.CM_RTQueueEntry ) then
			localArray.add( _lObj.CM_RTQueueEntry );
		endif;
		foreach index in 1 to localArray.size do
			entry := localArray[index];
			if targetRTQueueEntry &lt;&gt; null then
				targetIndex:=self.lstQueues.findObject(targetRTQueueEntry);
			else
				targetIndex:=_newIndex;
			endif;
				
			self.moveQueue(entry, targetIndex);
		endforeach;
		self.allSelectedRTQEntries.clear();
		return;
	endif;

	self.moveQueue(_lObj, _newIndex);

epilog

	delete localArray;


end;</source>
        <Parameter name="_lObj" type="Object"/>
        <Parameter name="_newIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="openWithSavedSettings" id="eaa76a79-5f90-490b-8671-78c7dd4fee2c">
        <updating/>
        <source>openWithSavedSettings(): Boolean updating;
/*

Purpose:			Default the 'Hide Sub Queue Tasks' checkbox to true for PRP

Parameters:			

Return Value:		

Date			Who		Reason
24 August 2020	jlgmd1	Initial creation TFS 49961 PRP - Hide Sub Queue Tasks

*/

vars
	userWindow	: CM_UserWindow;
	hideTasks	: String;
begin
	//
	// Only required for patch 021, should default to 'false' for the next release
	//
	/*if app.getMyUser &lt;&gt; null then
		userWindow := self.myUserWindow;
		if userWindow = null then
			userWindow := app.getUserWindow(self.name, false);
		endif;
	endif;
	
	if userWindow &lt;&gt; null then
		hideTasks := userWindow.xmlInfo.cnEcGetTagValueOfName(XMLTag_HideSubTasks);
	endif;
	
	if hideTasks = "" then
		self.chkHideSubQTasks.value := true;
	endif;*/

	return inheritMethod();
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="readBroadcastMessage" id="f19301f4-dde1-4a9d-a70f-38b9adc1d3fd">
        <source>readBroadcastMessage() : String protected;
/*

Date		Who		Reason
11 December 2013	cnwer1	Initial creation PAR 33141

*/

vars
	inputBox : CMUI_InputBox;
begin
	create inputBox transient;
	
	inputBox.init(	app.getErrorString( Message ),null,
					'', 30, TextBox.DataType_AlphaNumeric, TextBox.Case_None, false, false);
	
	inputBox.myTerminal := self.myTerminal;
	inputBox.showModal;
	
	if inputBox.modalResult &lt;&gt; IDOK then
		return '';
	endif;
	
	return inputBox.txtInput.text.String;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="saveQueueExpandedState" id="0f9d5eec-5cfa-4b53-928a-988dcee59b85">
        <source>saveQueueExpandedState() protected;

vars

	idx,
	localListCount	: Integer;
	object			: Object;

begin

	self.allQueuesExpandedState.clear();
	localListCount := self.lstQueues.listCount;
	foreach idx in 1 to localListCount do
		object := self.lstQueues.itemObject[idx];
		if object &lt;&gt; null then
			if object.isKindOf(CM_RadioTelemetryQueue) then 
				if self.lstQueues.itemExpanded[idx] then
					self.allQueuesExpandedState.add(object.CM_RadioTelemetryQueue);
				endif;
			endif;
		endif;
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="selectRTQueueEntry" id="9e421fdd-940a-4787-b92c-3e0d189d2ef5">
        <source>selectRTQueueEntry( entry : CM_RTQueueEntry );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 July 2014	cnwndl1	Initial creation	Par 25646

*/

vars

begin
	if entry &lt;&gt; null and not self.allSelectedRTQEntries.includes( entry ) then
		self.allSelectedRTQEntries.add( entry );
	endif;

epilog

end;</source>
        <Parameter name="entry" type="CM_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="c6741d0f-6020-40ef-8d0b-52b9755258a4">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     30 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpBackColor	: Integer;

begin
	inheritMethod(_colorControl);

	tmpBackColor	:= self.backColor;
	
	self.lstQueues.backColor	:= self.colorControlBack;
	
	self.splitter1.backColor	:= tmpBackColor;
	self.splitter2.backColor	:= tmpBackColor;
	
	self.setColorsForTable(self.tblMachines);
	self.setColorsForTable(self.tblQEntries);
	
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setMachineStatusMenu" id="f671d562-3e2c-4c17-8175-a938ddfcb629">
        <source>setMachineStatusMenu();

// cnwdvb1 27 March 2003 

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01/02/2019	jlgmd1		TFS #43007 - Remove Teklogix
//
// ---------------------------------------------------------------------------

vars
	subMenu : MenuItem;
	machine	: CM_Machine;
	qSize, idx : Integer;
	cq : CM_VoyageCraneQueue;
	theProcess : Process;
	itsInterface : CM_ITSInterfaceDefinition;
	errMsg : String;	//08 Jan 2018	NDL	36437
begin
	self.mnuMachineMove1.userObject := null;
	self.mnuMachineMove1.caption  := null;
	self.mnuMachineMove2.userObject := null;
	self.mnuMachineMove2.caption  := null;
	self.mnuRemQdMach.visible:=false;
	self.mnuMachCargoOnboard.enabled:=false;
	self.mnuWeighMachine.enabled := false;
	//cnwjo3 this is incorrect.  submenus can be more than 10.  need something like 1 to self.mnuMachineMove2.subMenuCount or while self.mnuMachineMove2.hasSubMenus
	// par 27787 June 2011 cnwjre1 delete more sub-menus - note 100 is still an arbitrary limit - also added the break;
	foreach idx in 1 to 100 do
		subMenu := self.mnuMachineMove2.getMenuItem(idx);
		if subMenu &lt;&gt; null then
			delete subMenu;
		else
			break;
		endif;
	endforeach;
	self.mnuMachineMove1.visible := false;
	self.mnuMachineMove2.visible := false;
	
	self.getCurrentMachine(machine);
	if machine &lt;&gt; null then
		if machine.machineStatus = STATUS_OFFLINE then
			self.mnuMachineOnline.caption := 'Restore Machine Online';
		else
			self.mnuMachineOnline.caption := 'Set Machine Offline';
		endif;
		
		if machine.myNextPrimaryQueue &lt;&gt; null then
			self.mnuRemQdMach.visible:=true;
		endif;
		
		//13 Mar 2014	NDL	- Can weigh machine or machine with 1 tracked item.
		if machine.isWeighBridgeWeighable(null,errMsg) then
			self.mnuWeighMachine.enabled := true;
			self.mnuWeighMachine.userObject := machine;
		endif;
		
		self.mnuMachCargoOnboard.enabled:= machine.myMachineController.allTrackedItems.size &gt; 0;
		
		// #############################
		// PAR 20474
		// #############################
		if machine.myPrimaryQueue.isCraneQueue() then

			
			
			qSize := machine.myPrimaryQueue.CM_VoyageCraneQueue.crane.allCraneQueues.size;
			if qSize &gt; 1 then
				if qSize = 2 then
					foreach cq in machine.myPrimaryQueue.CM_VoyageCraneQueue.crane.allCraneQueues discreteLock do
						if cq &lt;&gt; machine.myPrimaryQueue then
							break;
						endif;
					endforeach;
					self.mnuMachineMove1.caption := app.getErrorString2(Move_selecte_machine_from, machine.myPrimaryQueue.CM_VoyageCraneQueue.id, cq.id);
					self.mnuMachineMove1.userObject := cq;
					self.mnuMachineMove1.visible := true;
				else
					self.mnuMachineMove2.caption := app.getErrorString2(Move_selecte_machine_from, machine.myPrimaryQueue.CM_VoyageCraneQueue.id, null);
					idx := 0;
					foreach cq in machine.myPrimaryQueue.CM_VoyageCraneQueue.crane.allCraneQueues discreteLock do
						if cq = machine.myPrimaryQueue then
							continue;
						endif;
						idx := idx + 1;
						subMenu := self.mnuMachineMove2.loadSubMenu(idx);
						subMenu.caption := cq.id;
						subMenu.visible := true;
						subMenu.userObject := cq;
					endforeach;
					self.mnuMachineMove2.visible := true;
				endif;
				

			endif;
		endif;
		
		//08/01/2010 cnwdz2 par21593
		itsInterface := machine.myITSInterfaceLoggedOn;
		if itsInterface &lt;&gt; null then
			if not self.mnuViewMessage.caption.endsWith(itsInterface.name) then
				self.mnuViewMessage.caption := self.mnuViewMessage.caption &amp; " " &amp; itsInterface.name;
			endif;
			self.mnuViewMessage.visible := true;
		else
			self.mnuViewMessage.visible := false;
		endif;
	endif;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuMachineLoginAs.visible := false;
		self.mnuMachLoginAsGdansk.visible := false;							
		self.mnuMachineDebugLogin.visible := false;
		self.mnuMachinePosQueue.visible := false;
		self.mnuMachinePosTask.visible := false;
		self.mnuMachineResetSession.visible := false;
		self.mnuMachineDetails.visible := false;
		self.mnuWeigh.visible := false;
		self.mnuWeighMachine.visible := false;
		self.mnuMachineMove2.visible := false;
		self.mnuQueueBroadcastMsg.visible := false;
		self.mnuTaskStatusRestore.visible := false;
		self.mnuMachineOnline.visible := false;
		self.mnuMachineMove1.visible := false;
		self.mnuMachineMessage.visible := false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setMachineStatusPic" id="f92e52f5-9fb1-47d4-ada1-2c055983dca8">
        <source>setMachineStatusPic(_machine : CM_Machine; _row : Integer) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 Aug 2011	cnwdz2	PAR #27747 - For each type of Machine, there will be a unique Icon displayed, 
					based solely on the "working" state of the machine
29 Aug 2011	cnwkpd1	PAR #27747 - Additional machine types added

*/

vars
	cell 			: JadeTableCell;
	offLine 		: Binary;
	idle 			: Binary;
	active 			: Binary;
	machineType 	: Integer;
	
begin
	cell := self.tblMachines.accessCell(_row, 1);
	
	machineType := _machine.machineType;
	
	if machineType = MACHINETYPE_STRADDLE then
		offLine		:= picStraddleOff.picture;
		idle		:= picStraddleIdle.picture;
		active		:= picStraddleActiv.picture;
	elseif machineType = MACHINETYPE_FORK_LIFT then
		offLine		:= picForkliftOff.picture;
		idle		:= picForkliftIdle.picture;
		active		:= picForkliftActiv.picture;
	elseif machineType = MACHINETYPE_RMG then
		offLine		:= picRMGOff.picture;
		idle		:= picRMGIdle.picture;
		active		:= picRMGActive.picture;
	elseif machineType = MACHINETYPE_IMV then
		offLine		:= picIMVOff.picture;
		idle		:= picIMVIdle.picture;
		active		:= picIMVActive.picture;
	elseif machineType = MACHINETYPE_PORTAINER_CRANE then
		offLine		:= picPCraneOff.picture;
		idle		:= picPCraneIdle.picture;
		active		:= picPCraneActive.picture;
	elseif machineType = MACHINETYPE_SIDE_LOADER then
		offLine		:= picSLOff.picture;
		idle		:= picSLIdle.picture;
		active		:= picSLActive.picture;
	elseif machineType = MACHINETYPE_TOP_LIFT then
		offLine		:= picTLOff.picture;
		idle		:= picTLIdle.picture;
		active		:= picTLActive.picture;
	elseif machineType = MACHINETYPE_RTG then 
		offLine		:= picRTGOff.picture;
		idle		:= picRTGIdle.picture;
		active		:= picRTGActive.picture;
	else
		offLine		:= picForkliftOff.picture;
		idle		:= picForkliftIdle.picture;
		active		:= picForkliftActiv.picture;
	endif;
	
	if _machine.machineStatus = STATUS_OFFLINE then
		cell.picture := offLine;
	elseif _machine.currentQueueTask = null then
		cell.picture := idle;
	else
		cell.picture := active;
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMachineStatusPicPrimaryQ" id="ddb0d81c-c697-470b-bb84-95dcbbbf03d8">
        <source>setMachineStatusPicPrimaryQ(_machine : CM_Machine; _row : Integer; _isInPrimary : Boolean; _queue : CM_RadioTelemetryQueue);
// --------------------------------------------------------------------------------
// Created:		05 November 2010 by cnwjo3
//
// Purpose:		alot of duplication in showMachinesForQueue.  Have moved code out of there into this method.
//				this method deals with only the primary queue machines.  NOT ~XX machines!
//				par 25669
//
vars
	cell : JadeTableCell;
begin
/*
	cell := self.tblMachines.accessCell(_row, 1);
	
//if app.cnwkpd1_IsUser then
//	self.tblMachines.accessRow(_row).height := 20;
//	picStraddleOff.picture := app.loadPicture("c:\temp\forklifticons\loggedoff.png");
//	picStraddle.picture := app.loadPicture("c:\temp\forklifticons\loggedon.png");
//	picStraddleGreen.picture := app.loadPicture("c:\temp\forklifticons\working.png");
//endif;
	
		if _machine.machineType = MACHINETYPE_STRADDLE then
			if _isInPrimary or _queue.isKindOf(CM_MasterQueue)  then
				if _machine.machineStatus = STATUS_OFFLINE then
					cell.picture := picStraddleOff.picture;
				else
					if _machine.currentQueueTask = null then
						cell.picture := picStraddleIdle.picture;
					else
						cell.picture := picStraddleActiv.picture;
					endif;
				endif;
			else
				if _machine.machineStatus = STATUS_OFFLINE then
					cell.picture := picStraddleOff.picture;
				else
					//cell.picture := picStraddleGrey.picture;
					cell.picture := picStraddleIdle.picture;	 //06 Dec 2010	NDL	Par 26450
				endif;
			endif;
		elseif _machine.machineType = MACHINETYPE_PORTAINER_CRANE then
			if _machine.machineStatus = STATUS_OFFLINE then
				cell.picture := picCraneOff.picture;
			else
				cell.picture := picCrane.picture;
			endif;
		elseif _machine.machineType = MACHINETYPE_FORK_LIFT then
			if _isInPrimary  or _queue.isKindOf(CM_MasterQueue)  then 
				if _machine.machineStatus = STATUS_OFFLINE then
					cell.picture := picForkliftOff.picture;
				else
					if _machine.currentQueueTask = null then
						cell.picture := picForkliftIdle.picture;
					else
						cell.picture := picForkliftActiv.picture;
					endif;
				endif;
			else
				if _machine.machineStatus = STATUS_OFFLINE then
					cell.picture := picForkliftOff.picture;
				else
					cell.picture := picForkliftIdle.picture;
				endif;
			endif;
		elseif _machine.machineType = MACHINETYPE_RTG or _machine.machineType = MACHINETYPE_RMG  then
			if _isInPrimary  or _queue.isKindOf(CM_MasterQueue)  then 
				if _machine.machineStatus = STATUS_OFFLINE then
					cell.picture := picRTGOff.picture;
				else
					if _machine.currentQueueTask = null then
						cell.picture := picRTGIdle.picture;
					else
						cell.picture := picRTGActive.picture;
					endif;
				endif;
			else
				if _machine.machineStatus = STATUS_OFFLINE then
					cell.picture := picRTGOff.picture;
				else
					//cell.picture := picRTGGrey.picture;
					cell.picture := picRTGIdle.picture;
				endif;
			endif;
		elseif _machine.machineType = MACHINETYPE_IMV then
			if _isInPrimary  or _queue.isKindOf(CM_MasterQueue)  then 
				if _machine.machineStatus = STATUS_OFFLINE then
					cell.picture := picIMVOff.picture;
				else
					if _machine.currentQueueTask = null then
						cell.picture := picIMVIdle.picture;
					else
						cell.picture := picIMVActive.picture;
					endif;
				endif;
			else
				if _machine.machineStatus = STATUS_OFFLINE then
					cell.picture := picIMVOff.picture;
					//cell.picture := picIMVOffGrey.picture;
				else
					cell.picture := picIMVIdle.picture;
				endif;
			endif;
		else
			if _isInPrimary or _queue.isKindOf(CM_MasterQueue) then
				if _machine.machineStatus = STATUS_OFFLINE then
					cell.picture := picForkliftOff.picture;
				else
					if _machine.currentQueueTask = null then
						cell.picture := picForkliftIdle.picture;
					else
						cell.picture := picForkliftActiv.picture;
					endif;
				endif;
			else
				if _machine.machineStatus = STATUS_OFFLINE then
					cell.picture := picForkliftOff.picture;
				else
					cell.picture := picForkliftIdle.picture;
				endif;
			endif;
		endif;
		*/
end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_isInPrimary" type="Boolean"/>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue"/>
