<Class name="CM_TCPIPShared" id="46e251d0-90e2-4eaf-be0e-7733932b152d">
    <superclass name="CM_TCPIPAgent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="jmtxml"/>
    <Constant name="BindEvent" id="f7e722be-b775-43b7-b254-fc4358dadf98">
        <source>66000</source>
        <type name="Integer"/>
    </Constant>
    <PrimAttribute name="loggingLevel" id="7d540005-19ec-4d86-b5dd-79598f823447">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myWorkerClass" id="76f14dbc-e2c0-45b8-94e7-857e049aac6f">
        <embedded/>
        <type name="Class"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="bindConnection" id="a71837dd-316b-487b-b4da-eed80cf32e6d">
        <updating/>
        <source>bindConnection(_tcp : TcpIpConnection) updating;
// -----------------------------------------------------------------------------
// Created:		05 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin

	beginTransientTransaction;
	self.myTCPConnection := _tcp;
	commitTransientTransaction;	
	self.causeEvent(BindEvent, true, null);

end;</source>
        <Parameter name="_tcp" type="TcpIpConnection"/>
    </JadeMethod>
    <JadeMethod name="clearConnection" id="c76378d2-c8ad-4b45-aa5c-f63e81c871bd">
        <updating/>
        <source>clearConnection() updating;

vars

begin

	beginTransientTransaction;
	self.myTCPConnection := null;
	commitTransientTransaction;

end;</source>
    </JadeMethod>
    <JadeMethod name="finish" id="80b4235e-467c-4f8b-a7eb-183acf9aa650">
        <updating/>
        <source>finish() updating;

vars

begin
	
	// Do nothing.
end;</source>
    </JadeMethod>
    <JadeMethod name="init" id="2ef1bd46-d6e4-4882-8ef4-ccb7a056eba5">
        <updating/>
        <source>init() updating;

vars

begin

	self.beginNotification(self, self.ProcessTerminate, Response_Continuous, 0);
	self.beginNotification(self, self.BindEvent, Response_Continuous, 0);
end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="36bca589-4c84-4244-ad2d-601162ae7735">
        <updating/>
        <source>setForCreate(_controller : BGP_XMLListenController) updating;

// cnwdvb1 12 November 2002 

vars

	con : Constant;

begin

	self.loggingLevel 	:= _controller.loggingLevel;
	self.myWorkerClass := app.findWorkerClass(_controller.workerClass);
	if  self.myWorkerClass.getSuperclass &lt;&gt; CM_TCPIPAgentWorker then
		app.raiseCMException(InvalidTcpipClass, null, null);
	endif;

end;</source>
        <Parameter name="_controller" type="BGP_XMLListenController"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="9e6ce4a4-c860-430e-8156-64e584e1b4bd">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// -----------------------------------------------------------------------------
// Created:		05 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin

	if eventType = self.BindEvent and theObject = self then
		app.myXMLWorker.startReading();
	endif;		
	
	inheritMethod(eventType, theObject, eventTag, userInfo);
	
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
