vars

begin

	self.validateMe();


end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="c83704e4-d03f-42ab-afbb-020efaca33ba">
        <source>validateMe() protected;
// -------------------------------------------
// Created 27 October 2004 by cnwdvb1
//13/06/2022 navds20 TFS 53760 DuplicateItem not Translatable
// -------------------------------------------
vars

	mtGradeCode,
	realCode	: CM_Code;
	isUpdate,
	errorMsg	: Boolean;

begin

	realCode := self.pxyGetRealObject();
	
	if realCode &lt;&gt; null then
		isUpdate := true;
	endif;
	foreach mtGradeCode in self.myCodeGroup.allCodes do
		if (mtGradeCode.CM_MTGradeCode.myMTGrade = self.myMTGrade or mtGradeCode.code = self.code) then
			if isUpdate then
				if realCode &lt;&gt; mtGradeCode then
					errorMsg := true;
					break;
				endif;
			else
				errorMsg := true;
				break;
			endif;
		endif;
	endforeach;
	
	if errorMsg then
		//app.raiseCMException2(DuplicateItem, 'Availability Code ' &amp; mtGradeCode.code, 'Availability Group ' &amp; mtGradeCode.CM_MTGradeCode.myMTGrade.code.String, null, null); //13.06.2022 navds20 53760
		// Availability Code %1 already exists for Availability Group %2 : Avail_code_alrea_exist_avail_g
		app.raiseCMException2(Avail_code_alrea_exist_avail_g, mtGradeCode.code,  mtGradeCode.CM_MTGradeCode.myMTGrade.code.String, null, null); //13.06.2022 navds20 53760
		return;
	endif;
	inheritMethod();


end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
