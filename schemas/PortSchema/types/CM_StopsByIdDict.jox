<CollClass name="CM_StopsByIdDict" id="9370168a-e95d-4747-b089-aa81fe5ea5a9">
    <memberType name="CM_Stops"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="misc"/>
    <MemberKey>
        <property name="CM_Stops::id"/>
    </MemberKey>
    <JadeMethod name="auditIdDisplay" id="ca632689-43e2-4ccb-ae64-11fc98885e78">
        <source>auditIdDisplay() : String;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	stop	: CM_Stops;
	rtnStr	: String;
begin

	foreach stop in self do
		if rtnStr = null then
			rtnStr := stop.auditId();
		else
			rtnStr := rtnStr &amp; '::' &amp; stop.auditId();
		endif;
	endforeach;

	return rtnStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
