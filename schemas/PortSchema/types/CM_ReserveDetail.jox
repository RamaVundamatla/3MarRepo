    <JadeMethod name="getTrainsUsed" id="df8859d7-fdf1-4834-8c22-6e144be6525a">
        <source>getTrainsUsed() : String;
// ---------------------------------------------------------------------------
// Created:     13 October 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//// PAR 25980
// ---------------------------------------------------------------------------

vars
	req : CM_Request;
	tmpStr : String;
	train : CM_Train;
	objs : CM_TrainSet;
	obj : Object;
begin
	create objs transient;
	foreach req in self.allDeliveryRequests discreteLock do
		train := req.getTrain();
		if train &lt;&gt; null then
			objs.addNoDuplicates(train, false);
		endif;
	endforeach;
	
	foreach train in objs discreteLock do
		if tmpStr = null then
			tmpStr := train.code;
		else
			tmpStr := tmpStr &amp; ", " &amp; train.code;
		endif;
	endforeach;
	return tmpStr &amp; " ";
epilog
	delete objs;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUnactionedAssignedRequest" id="df0c74b4-1323-4897-9e37-16195f7807d6">
