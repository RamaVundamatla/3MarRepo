    <JadeMethod name="translateForm" id="e219ed3a-aa20-4dd8-99f1-2798daeac064">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 18 July 2024 01:54:09.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017455, locale);
	btnAdd.translateCaption(Xlat_0014600, locale);
	btnCancel.translateCaption(Xlat_0014601, locale);
	btnDelete.translateCaption(Xlat_0014602, locale);
	btnSave.translateCaption(Xlat_0014603, locale);
	btnUpdate.translateCaption(Xlat_0014604, locale);
	chkHeatTreated.translateCaption(Xlat_0021991, locale);
	chkNoCharge.translateCaption(Xlat_0013486, locale);
	chkStoreOnP.translateCaption(Xlat_0021992, locale);
	chkVoid.translateCaption(Xlat_0013487, locale);
	grpResource.translateCaption(Xlat_0013488, locale);
	lblFromDateTime.translateCaption(Xlat_0020970, locale);
	lblPallet.translateCaption(Xlat_0021993, locale);
	lblRemarks.translateCaption(Xlat_0013489, locale);
	lblToDateTime.translateCaption(Xlat_0020971, locale);
	lblToDo.translateCaption(Xlat_0013490, locale);
	lblUnits.translateCaption(Xlat_0013491, locale);
	mnuColumnOrganizer.translateCaption(Xlat_0026923, locale);
	mnuResourceUsage.translateCaption(Xlat_0026924, locale);
end;</source>
    </JadeMethod>
</GUIClass>
