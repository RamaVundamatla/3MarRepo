    </PrimAttribute>
    <JadeMethod name="initializeForActivity" id="1b01f7a7-4452-42cf-a7fe-9ef1f742bb00">
        <updating/>
        <source>initializeForActivity(_any: Any; _ewsOpsView: CM_EWSActivityOpsview) updating;
/*
Purpose:			

Date		Who		Reason
03 December 2021	navab1	TFS 51853
*/

vars
	ti : CM_TrackedItem;
begin
	inheritMethod(_any, _ewsOpsView);
	
	
	self.tableName		:= self.Ref_equipment;
	
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		self.gkey		:= self.generateFullGKey(_any, "");
		return;
	endif;
	
	
	ti := _any.CM_TrackedItem;
	
	ti.initializeForActivity(_ewsOpsView, self);


epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
    </JadeMethod>
</Class>
