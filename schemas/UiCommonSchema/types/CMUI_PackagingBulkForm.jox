    <JadeMethod name="translateForm" id="61c1ee74-2d66-4998-8971-224a686119b3">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 02 May 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019659, locale);
	lblAmountPerItem.translateCaption(Xlat_0019660, locale);
	lblAmountToProc.translateCaption(Xlat_0019661, locale);
	lblCargoSubType.translateCaption(Xlat_0019662, locale);
	lblExistingCargo.translateCaption(Xlat_0019663, locale);
	lblINewItems.translateCaption(Xlat_0019664, locale);
	lblId.translateCaption(Xlat_0019665, locale);
	lblIdSuffix.translateCaption(Xlat_0019666, locale);
	lblNewCargoType.translateCaption(Xlat_0019667, locale);
	lblNewLocation.translateCaption(Xlat_0019668, locale);
	lblOperator.translateCaption(Xlat_0019669, locale);
	lblPkgingWeight.translateCaption(Xlat_0019670, locale);
	optBreakBulk.translateCaption(Xlat_0019671, locale);
	optPieceBBB.translateCaption(Xlat_0019672, locale);
end;</source>
    </JadeMethod>
