    <JadeMethod name="updateJob" id="f33af583-b851-4d9a-ba9b-814317712c7f">
        <updating/>
        <source>updateJob(_job : CM_VoyageHoldJob) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/02/2017	cnwdap1		Initial creation TFS 3220 Voyage Operations Enhancements
//
vars

begin
	// is it the current job?
	if _job = self.myCurrentJob then
		//app.msgBox(app.getErrorString1(Viewed_Object_Updated, app.getErrorString(Job)), app.getErrorString(Updated), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		self.loadJobDetails(_job);
	else
		if self.cmbJob.findObject(_job) = null then
			self.cmbJob.addItemObject(_job.id, _job);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_job" type="CM_VoyageHoldJob"/>
    </JadeMethod>
    <JadeMethod name="updateTI" id="90e2ea83-39f3-48c2-88c6-4cbe53ccde14">
        <updating/>
        <source>updateTI(_ti : CM_TrackedItem io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
13 September 2019		jlgzm1	Initial creation TFS 42872 Direct Release Between HOLD Voyages and Rail

*/

vars
	voyage 			: CM_Voyage;
	invalidObject 	: Boolean;
	wle 			: CM_WorkListEntry;
begin
	on Exception do app.handleDeletedObject( exception, _ti, invalidObject );
	
	voyage := _ti.myVoyage;
	if invalidObject then
		return;
	endif;
	
	if voyage &lt;&gt; self.myCurrentVoyage then
		return;
	endif;
	
	foreach wle in _ti.allWorklistEntries where wle.job &lt;&gt; null and wle.job = self.myCurrentJob do
		self.updateWLE(wle);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateWLE" id="5fbfb50e-6ddd-4e6d-9c09-2a03efa724c6">
        <updating/>
        <source>updateWLE(_wle : CM_WorkListEntry io) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
// 22/08/2019	jlgzm1		TFS 42872 Direct Release Between HOLD Voyages and Rail
//
vars
	voyage : CM_Voyage;
	invalidObject : Boolean;

begin
	on Exception do app.handleDeletedObject( exception, _wle, invalidObject );
	
	//voyage := _wle.getMyVoyageObject;
	if _wle &lt;&gt; null and _wle.job &lt;&gt; null then	// TFS 42872
		voyage := _wle.job.getMyVoyageObject;	// TFS 42872
	endif;

	if not self.allDisplayedWLEs.includes(_wle) then
		// we haven't currently got this one displayed.
		if (voyage = self.myCurrentVoyage or _wle.myTrackedItem.myVoyageTranshipExport = self.myCurrentVoyage ) and not invalidObject then  // epr par 33148 31/3/14
			// but potentially it should be
			self.updateWLEMove(_wle);
		else
			// not one we are interested in anyway
			return;
		endif;
	else
		if (voyage &lt;&gt;  self.myCurrentVoyage and ( _wle.myTrackedItem.myVoyageTranshipExport &lt;&gt; self.myCurrentVoyage) )   or  invalidObject then // epr par 33148 31/3/14
			// voyage is different, or its been deleted, get rid of it from our tables
			self.removeWLE(_wle);
		else
			// just update it in situ.
			self.updateWLEMove(_wle);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateWLEMove" id="179d3f11-5100-4ecf-8685-8fdf5afdd07a">
        <updating/>
        <source>updateWLEMove(_wle : CM_WorkListEntry io) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
//
vars
	idx : Integer;

begin
	if self.tblJobDetails.findObjectInRow(_wle, idx) then
		self.tblJobDetails.accessCell(idx, 1).text := _wle.getAttributeStringForDefArray(self.tblJobDetails.allTblDataEntRows);
		self.doColourTableRow(_wle, self.myCurrentJob, idx);
	endif;
epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="io"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="55632fa4-d362-4f09-90b3-3525c894ff03">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
// 22/08/2019	jlgzm1		TFS 42872 Direct Release Between HOLD Voyages and Rail 
// 24/02/2024	navcs2 		MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	event 	: Integer;
	wle 	: CM_WorkListEntry;
begin
	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	if userInfo &lt;&gt; null and userInfo.isKindOf(CM_WorkListEntry) then	// TFS 42872
		if event = WLE_Update_Event then
			wle := userInfo.CM_WorkListEntry;
			self.updateWLE(wle);
		elseif event = WLE_Create_Event then	// TFS 42872
			wle := userInfo.CM_WorkListEntry;	// TFS 42872
			self.addWLE(wle);					// TFS 42872
		elseif event = WLE_Delete_Event then	// TFS 42872
			wle := userInfo.CM_WorkListEntry;	// TFS 42872
			self.handleDeletedWLE(wle);			// TFS 42872
		endif;
	endif;

	// handle deletes first
	if eventType = Object_Delete_Event then
		// must be the prenote table or the onship table
		if theObject.isKindOf(CM_WorkListEntry) then
			self.handleDeletedWLE(theObject.CM_WorkListEntry);
		elseif theObject.isKindOf(CM_VoyageHoldJob) then
			self.handleDeletedJob(theObject.CM_VoyageHoldJob);
		endif;
		return;
	endif;
	
	if theObject &lt;&gt; null then
		if theObject.isKindOf(CM_WorkListEntry) then
			wle := theObject.CM_WorkListEntry;
			self.updateWLE(wle);
		elseif theObject.isKindOf(CM_VoyageHoldJob) then
			self.updateJob(theObject.CM_VoyageHoldJob);
		endif;
	endif;
epilog
	
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
