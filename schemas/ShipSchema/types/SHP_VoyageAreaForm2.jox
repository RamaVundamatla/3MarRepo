    <JadeMethod name="showCargoSelector" id="a73ab5b5-a882-4c0a-911e-6306c6210a28">
        <updating/>
        <source>showCargoSelector(_theRequest : CM_SlotRequest) updating;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theForm : SHP_SelectWLE;
	theRequest : CM_SlotRequest;
	theSlotController : CM_SlotController;
	theTIs : CM_TIArray;
begin

	app.mousePointer := Window.MousePointer_HourGlass;
	theRequest := _theRequest;
	if theRequest.isLoad then
		return;
	endif;
	theSlotController := theRequest.mySlotController;
	
	theForm := app.getForm(SHP_SelectWLE.name).SHP_SelectWLE;
	if theForm = null then
		create theForm as SHP_SelectWLE;
	endif;
	theForm.myTerminal := self.myTerminal;
	theForm.myCurrentVoyage := self.myCurrentVoyage;
	theForm.myCurrentRequest := theRequest;
	theForm.initGroupBox();
	//theForm.myVoyageAreaForm := self;
	theForm.msgCargo.setAvailable(theSlotController.allTrackedItemsById,true);
	
	create theTIs transient;
	theRequest.getAllTrackedItems(theTIs);
	theForm.msgCargo.setSelected(theTIs);
	theForm.showModal();
epilog
	delete theTIs;
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="_theRequest" type="CM_SlotRequest"/>
    </JadeMethod>
    <JadeMethod name="showExtraAttributesDisplay" id="27ec70c3-d45a-48dc-918b-a651997885ea">
        <updating/>
        <source>showExtraAttributesDisplay(_theTIIndex: Integer; _theAttributeArray: CMUI_GridAttributesArray input;
		_dataContainer : CM_DataContainer) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		This has been sub classed so that we can delete the transient objects used to show the icons
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_theTIIndex, _theAttributeArray, _dataContainer);
epilog
	if _theAttributeArray &lt;&gt; null then
		_theAttributeArray.purge;
	endif;
end;</source>
        <Parameter name="_theTIIndex" type="Integer"/>
        <Parameter name="_theAttributeArray" type="CMUI_GridAttributesArray" usage="input"/>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="showHatchLidJobFrame" id="9978989c-7c90-4ff8-b4e0-6c9201dd7cab">
        <source>showHatchLidJobFrame(_top : Integer; _left : Integer);
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theTop , theLeft, idx : Integer;
	aJobType : CM_JobType;
begin
	if self.frmHatchLidJob.visible then
		return;
	endif;
	
	if _top = 0 then
		theTop := (self.frmToolbar2.top +  self.frmToolbar2.height + 1).Integer;
		theLeft := 1;
	else
		theTop := _top;
		theLeft := _left;
	endif;
	self.txtJobHatchNum.text := self.cmbJob.text.trimBlanks.toUpper;
	
	self.cmbHatchLidRemrk.clear;
	self.cmbHatchLidRemrk.style := ComboBox.Style_DropDown;
	self.cmbHatchLidRemrk.listCollection(app.myRoot.allPreDefinedRemarks, false, 0);	
	
	self.cmbHatchLidType.clear;
	self.cmbHatchLidType.listCollection(app.myRoot.allJobTypes, false, 0);	
	self.txtJobHatchNum.text := null;
	self.lblHatchLidLbl.transparent := true;	
	self.frmHatchLidJob.visible := true;

	self.frmHatchLidJob.zOrder(1);
	self.frmHatchLidJob.top := theTop;
	self.frmHatchLidJob.left := theLeft;
	self.txtJobHatchNum.setFocus();
end;</source>
