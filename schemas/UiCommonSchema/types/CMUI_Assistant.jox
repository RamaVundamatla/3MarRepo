    <JadeMethod name="comboBoxPlanningState" id="f03b3661-5b83-4301-bc4d-66679fdb4185">
        <source>comboBoxPlanningState(_tbl : CM_EntryTable input; _attrName : String);
// ---------------------------------------------------------------------------
// Created:     31 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	baseScm 			: Schema;
	category 			: ConstantCategory;
	const 				: Constant;
	constDict			: ConstantNDict;
	str					: String;

begin
	baseScm := rootSchema.getSchema(PortSchemaName);
	category := baseScm.getCategory(TIPlanningState);
	constDict := category.getConstants();

	foreach const in constDict do
		str := str &amp; app.planningStateEnumToString(const.valueAsInteger) &amp; Tab;	
	endforeach;

	_tbl.setComboValues(_tbl.getRow(_attrName), str);

end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_attrName" type="String"/>
    </JadeMethod>
