	self.assertNotNullMsg(ti5, "Failed to creatt TI5");
	self.editIMEXStatus(ti5, TI_IMEX_STATUS_IMPORT, true);
	
	// Set Customs Agent and Customs Entry Number to all cargo
	beginTransaction;
	ti1.setCustomsAgent(customagent);
	ti1.setCustomsEntryNumber(CEN);
	ti2.setCustomsAgent(customagent);
	ti2.setCustomsEntryNumber(CEN);
	ti3.setCustomsAgent(customagent);
	ti3.setCustomsEntryNumber(CEN);
	ti4.setCustomsAgent(customagent);
	ti4.setCustomsEntryNumber(CEN);
	ti5.setCustomsAgent(customagent);
	ti5.setCustomsEntryNumber(CEN);
	commitTransaction;
	
