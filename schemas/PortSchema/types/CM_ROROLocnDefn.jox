    <JadeMethod name="getEDITypeCode" id="1f5fc66a-5fc9-46bd-b6ea-0bf4f28a3a1c">
        <source>getEDITypeCode(): Character;
//
// 16 Jan 2012	cnwrs1 MSL CCMS 1009 Par29024
//
vars

begin

	if self.isOOTLLocn then				// 09/08/2010 cnwmh5 #30077
		return 'S';
	endif;

	return 'G';
end;
