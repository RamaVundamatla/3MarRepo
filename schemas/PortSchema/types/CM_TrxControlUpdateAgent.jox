    <JadeMethod name="trxUpdateWorkOrderTasks" id="54903dfb-45fd-4ea0-a73e-d57b10e69f76">
        <updating/>
        <source>trxUpdateWorkOrderTasks(_pxyWorkOrder : CM_WorkOrder input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2009	cnwmd1	Initial creation

*/
vars
	pxyWorkOrderDtl, newRealWorkOrderDtl : CM_WorkOrderDtl;
	realWorkOrder : CM_WorkOrder;
	voyageProformaTrxAction  : CMIF_TrxActionWOProforma;
	workOrdersToDelete : ObjectSet;
	trxAA : CM_UpdateTransactionAuditAgent;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	realWorkOrder := app.myProxyManager.getRealObject(_pxyWorkOrder).CM_WorkOrder;

	if _pxyWorkOrder.allWoDtls.isEmpty then // need some tasks! //cnwrd1 par 25332 6.8.2010
		app.raiseCMException(Work_order_no_tasks, null, null);
		return;
	endif;
	
	
	create trxAA transient;
	trxAA.audUpdateGeneric(realWorkOrder, true);
	
	beginTransaction;

	create workOrdersToDelete transient;
	realWorkOrder.allWoDtls.copy(workOrdersToDelete); 
	
	foreach pxyWorkOrderDtl in _pxyWorkOrder.allWoDtls do
		if app.myProxyManager.getRealObject(pxyWorkOrderDtl) = null then
			app.myUtilityCA.utlCreateWorkOrderTask(pxyWorkOrderDtl, newRealWorkOrderDtl, realWorkOrder, _passport);
		else
			workOrdersToDelete.remove(pxyWorkOrderDtl.pxyGetRealObject);
			app.myUtilityUA.utlUpdateWorkOrderTask(pxyWorkOrderDtl, _passport);
		endif;
		
		if _passport.hasErrors() then
			return;
		endif;
		
	endforeach;

	if _passport.hasErrors() then
		return;
	endif;
	
	workOrdersToDelete.purge;
	
	if not app.isInProformaMode then
			
			//epr 20/6/18 TFS 39166
			create voyageProformaTrxAction transient;
			voyageProformaTrxAction.setMyWorkOrder(realWorkOrder,CM_TrxControlAgent.Trx_Update);
			_passport.addTrxPostAction(voyageProformaTrxAction);
			
	endif;

	app.myUtilityUA.utlUpdateWorkOrderTaskPosition(_pxyWorkOrder, _passport);
	
	if _passport.noErrors then
		trxAA.audUpdateGeneric(realWorkOrder, false);
	endif;
epilog
	delete trxAA;
	delete workOrdersToDelete;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WorkOrder" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateWorkOrderTransport" id="f4695d25-3674-4b12-b24a-165f3d4d2c11">
        <updating/>
        <source>trxUpdateWorkOrderTransport(_pxyworkOrder 		: CM_WorkOrder input;
							_pxyWorkOrderDtl	: CM_WorkOrderDtl input;
							_transport			: CM_Object;
							_newTransport 		: String; 
							_newId				: String;
							_newTIsArr			: ObjectArray;
							_terminal			: CM_Terminal;
							_passport		 	: CM_Passport input;
							_quantityIfWle		: Integer)updating;
/*

Purpose:			

Parameters:			_newTIsArr		ObjectArray	Contains tis unless we are dealing with release by ype release requests then it holds wles
					_quantityIfWle	Integer		Added as a way to split wles. The parent screen that calls this trx only allows you to select one WLE to do this to

Return Value:		NONE

Date		Who		Reason
10 May 2023 navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes
30 Aug 2023 navhl20 Bug 60135: MTN - Error 1090 when using Transport Mode Change
13 Dec 2023 naviv1	ChangeRequest 61543: EUP - Transport  Mode Change should create a new Work Order 
21 Dec 2023 navhl20 Bug 61861: EUP | Work Order Transport Mode change - issues 
04 Jan 2024 navlc30 ChangeRequest 59997: EUP | Work Order Transport Mode change - Rail Receive
05 Jan 2023 navhl20 Defect 61920: EUP - The Work Order Status for the "Receive Road WO" remains "Part Complete" despite changing the transport mode for all remaining items to "Ship."
10 Jan 2023 navhl20 Defect 62018: EUP - Ship job got created when changing the transport mode from Road to Ship with the Approved status.
30 Jan 2024	navpw1	TFS: 59411 (61855) - Added new output work order for change of transport. Added code for Road -&gt; Ship Change of transport.
30 Jan 2024 navlc30 Bug 62217: MTN - 1090 exception when changing the transport mode from Rail to Ship
13 Feb 2024	navpw1	TFS: 59411 (62272) - Added support for release by type to split and create a new release request for the new work order and work order detail
13 Feb 2024	navpw1	TFS: 59411 (61867) - Added support for changing transport mode from road to rail for Cargo Releases
07 Mar 2024	navpw1	TFS: 62777 (62778) - Added support for not creating a work order if all tis are selected and the work order has not been actioned
02 Apr 2024	navpw1	TFS: 62777 (63186) - Added a boolean for hasAllTisSelected to show whether all ti's have been selected.
											Added allTisSelected set to hold all of the tis as ti's can be in one or more collections. This is more accurate
15 Apr 2024	navpw1	TFS: 63647 (63670) - Refactored releaseByType boolean and some release request assigning to remove dedundant code. 
											Added code which checks whether or not the entire wle has been selected or not for a release by type.
22 Apr 2024 navpw	TFS: 63666 (63761) - Added currentWodtl to remove bug whereby wodtl is reassigned and removed
10 Dec 2024	navhl20 Bug MTN-33557: EUP | Change of Transport Mode for Release by Type not working for multiple Release Lines
15/07/2025	navcs2	MTN-35210 Add Deferred Updates for WO Transaction During Transport Manifest and Call-Off Loading to Reduce Deadlocks

*/

constants
	CreateBooking			: Integer = 1;
	CreateBol				: Integer = 2;
	CreateReleaseRequest	: Integer = 3;
	
vars
	booking 			: CM_BookingRef;
	bol					: CM_BOL;
	currentWodtl,
	wodtl,
	oldWod				: CM_WorkOrderTIDtl;
	workOrder			: CM_WorkOrderTI;
	realWorkOrder   	: CM_WorkOrder; 	//13.12.2023 naviv1 #61543 
	proxyWorkOrder 		: CM_WorkOrder;
	emails          	: CM_EmailEntityByTypeNameDict;
	now,requiredByDT	: TimeStamp;
	woActionIF 			: CMIF_WorkOrderAction;
	realJob				: CM_Job;
	wod 				: CM_WorkOrderDtl;
	ti					: CM_TrackedItem;
	action				: Boolean;
	wodType         	: Integer;
	createBooking,
	createBol,
	isUseYardJobs,
   	createNewWoDtl,
	hasJobsActioned,
	hasAllTisSelected,
	releaseByType		: Boolean;
	allTisSelected		: CM_TISet;
	entityToCreate		: Integer;
	releaseRequest,
	wodReleaseRequest	: CM_BulkRelease;
	wodReserveDetail	: CM_ReserveDetail;
	train				: CM_Train;
	voyage				: CM_Voyage;
	pxyWorkOrderDtlTi	: CM_WorkOrderTIDtl;
	bookingItem			: CM_BookingRefItem;
	reserveDetail		: CM_ReserveDetail;
	bolDtl				: CM_BOLDtl;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Set to use deffered updates
	_passport.useWOTransactionDeferUpdate := true;							// 15/07/2025	navcs2	MTN-35210
	_passport.useTITransactionDeferUpdate := true;							// 15/07/2025	navcs2	MTN-35210

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	// ### TFS 62777 (62778) 07Mar2024 NAVPW1
	if _transport.isKindOf(CM_Train) then
		train := _transport.CM_Train;
		
	elseif _transport.isKindOf(CM_Voyage) then
		voyage := _transport.CM_Voyage;
		
	endif;
	// ### TFS 62777 (62778) 07Mar2024 NAVPW1
	
	// ### TFS 63647 (63670) 15Apr2024 NAVPW1
	if _pxyWorkOrderDtl.isWodRelease then
		wodReleaseRequest	:= _pxyWorkOrderDtl.CM_WodRelease.myReleaseRequest;
		wodReserveDetail	:= _pxyWorkOrderDtl.CM_WodRelease.myReserveDetail;
		
	endif;
	
	if wodReleaseRequest &lt;&gt; null then
		releaseByType := wodReleaseRequest.releaseByType;
		
	endif;
	// ### TFS 63647 (63670) 15Apr2024 NAVPW1
	
	// ### TFS 63647 (63670) 17Apr2024 NAVPW1
	pxyWorkOrderDtlTi	:= _pxyWorkOrderDtl.CM_WorkOrderTIDtl;
	hasJobsActioned		:= pxyWorkOrderDtlTi.allJobs.hasJobsActioned();
	
	if pxyWorkOrderDtlTi.isWodRelease and releaseByType then
		hasAllTisSelected := wodReserveDetail.totalRequested = _quantityIfWle;	
	else
		create allTisSelected transient;
		pxyWorkOrderDtlTi.allActionedTIs.copyNoDups(allTisSelected);
		pxyWorkOrderDtlTi.allAvailableTIs.copyNoDups(allTisSelected);
		pxyWorkOrderDtlTi.allCompleteTIs.copyNoDups(allTisSelected);
		pxyWorkOrderDtlTi.allSelectedTIs.copyNoDups(allTisSelected);
		
		hasAllTisSelected := _newTIsArr.size = allTisSelected.size;
		
	endif;
	
	if _pxyworkOrder.taskStatus.isOneOf(WO_STATUS_USERENTRY, WO_STATUS_APPROVED, WO_STATUS_ACTIONED, WO_STATUS_PARTCOMPLETE) and 
		(hasJobsActioned or not hasAllTisSelected) then
		createNewWoDtl := true; //Saves a new if statement indent below
	endif;
	// ### TFS 63647 (63670) 17Apr2024 NAVPW1
	beginTransaction;
	
	/*
		1- Stage
		Convert Booking to Bill of Lading or 
		Convert Bill of Lading to Booking 
	*/
	action := app.myPassport.warningsAcknowledged; 										//13.12.2023 naviv1 #61543 
	
	if _pxyWorkOrderDtl.isWodReceive then
		wodType := WO_TASK_RECEIVE;
	elseif _pxyWorkOrderDtl.isWodRelease then
		wodType := WO_TASK_RELEASE;
	endif;
	
	if wodType = WO_TASK_RECEIVE then
		if _newTransport = TI_TRANSMODE_ROAD_STR or _newTransport = TI_TRANSMODE_RAIL_STR then												//04.01.2024 navlc30 #59997
			createBooking  := true;
		elseif _newTransport = TI_TRANSMODE_SHIP_STR then
			createBol  := true;
		endif;
	else
		if _newTransport = TI_TRANSMODE_SHIP_STR and 
			wodReleaseRequest &lt;&gt; null and releaseByType
		then
			entityToCreate := CreateReleaseRequest;	//Creates a release by type release request if transport mode is ship and release by type release request
			
		elseif _newTransport = TI_TRANSMODE_SHIP_STR then
			createBooking := true; //Creates export booking if transport mode is ship
			
		elseif _newTransport = TI_TRANSMODE_ROAD_STR or _newTransport = TI_TRANSMODE_RAIL_STR then
			entityToCreate := CreateReleaseRequest;	//Creates a release request if transport mode is rail
			
		endif;
	endif;
	
	if entityToCreate = CreateReleaseRequest then
		app.myUtilityUA.utlConvertWOTransportToRelease(releaseRequest, _pxyWorkOrderDtl, _newId, _newTransport, _transport, _newTIsArr, _terminal, _passport, _quantityIfWle);
	elseif createBooking then
		app.myUtilityUA.utlConvertWOTransportToBook(booking, _pxyWorkOrderDtl, _newId, _newTransport, _transport, _newTIsArr, _terminal, _passport);			//30.01.2024 navlc30 #62217
	elseif createBol then
		app.myUtilityUA.utlConvertWOTransportToBol(bol, _pxyWorkOrderDtl, _newId, _newTransport, _transport, _newTIsArr, _terminal, _passport);					//30.01.2024 navlc30 #62217
	endif;
	
	/*
		2- Stage
		Create New Work Order Details
		Only if work order status is UserEntry, Approved, Or Action and no wles or jobs have been created and we selected all the tis.
	*/
	
	// ### TFS 62777 (62778) 07Mar2024 NAVPW1
	//pxyWorkOrderDtlTi	:= _pxyWorkOrderDtl.CM_WorkOrderTIDtl;
	//hasJobsActioned		:= pxyWorkOrderDtlTi.allJobs.hasJobsActioned();
	
	// ### TFS 63647 (63670) 15Apr2024 NAVPW1
	//if pxyWorkOrderDtlTi.isWodRelease and releaseByType then
	//	hasAllTisSelected := wodReserveDetail.totalRequested = _quantityIfWle;
	// ### TFS 63647 (63670) 15Apr2024 NAVPW1	
	/*else
		create allTisSelected transient;
		pxyWorkOrderDtlTi.allActionedTIs.copyNoDups(allTisSelected);
		pxyWorkOrderDtlTi.allAvailableTIs.copyNoDups(allTisSelected);
		pxyWorkOrderDtlTi.allCompleteTIs.copyNoDups(allTisSelected);
		pxyWorkOrderDtlTi.allSelectedTIs.copyNoDups(allTisSelected);
		
		hasAllTisSelected := _newTIsArr.size = allTisSelected.size;
		
	endif;*/
	
	//if _pxyworkOrder.taskStatus.isOneOf(WO_STATUS_USERENTRY, WO_STATUS_APPROVED, WO_STATUS_ACTIONED, WO_STATUS_PARTCOMPLETE) and (hasJobsActioned or not hasAllTisSelected) then
	//	createNewWoDtl := true; //Saves a new if statement indent below
	//endif;
	// ### TFS 62777 (62778) 07Mar2024 NAVPW1
	
	//if not _passport.hasErrors then 													//30.8.2023 navhl20 #60135
	//if not _passport.hasErrorsOrWarnings or action then								// 13.12.2023 naviv1 #61543
	if (not _passport.hasErrorsOrWarnings or action) and createNewWoDtl then			// ### TFS 62777 (62778) 07Mar2024 NAVPW1
		if _pxyWorkOrderDtl.isWodReceive then
			create wodtl as CM_WodReceive transient;
		elseif _pxyWorkOrderDtl.isWodRelease then
			create wodtl as CM_WodRelease transient;
		endif;
		
		if _newTransport = TI_TRANSMODE_ROAD_STR then
			app.myUtilityUA.utlUpdateWOTransportToRoad(_pxyworkOrder,
													  _pxyWorkOrderDtl,
													  wodtl,
													  _transport,
													  booking, 
													  releaseRequest,	// ### TFS 59411 (61868) 19Feb2024 NAVPW1 - Added for CM_WodRelease
													  _newTIsArr,
													  _passport);
		elseif _newTransport = TI_TRANSMODE_SHIP_STR then
			app.myUtilityUA.utlUpdateWOTransportToShip(_pxyworkOrder,
													  _pxyWorkOrderDtl,
													  wodtl,
													  _transport,
													  bol,
													  booking,			// ### TFS 59411 (61855) 26Jan2024 NAVPW1 - Added for CM_WodRelease
													  releaseRequest,	// ### TFS 59411 (62272) 13Feb2024 NAVPW1 - Added for CM_WodRelease
													  _newTIsArr,
													  _passport);
		elseif _newTransport = TI_TRANSMODE_RAIL_STR then																				//04.01.2024 navlc30 #59997
			app.myUtilityUA.utlUpdateWOTransportToRail(_pxyworkOrder,
													  _pxyWorkOrderDtl,
													  wodtl,
													  _transport,
													  booking,
													  releaseRequest,	// ### TFS 59411 (61867) 16Feb2024 NAVPW1 - Added for CM_WodRelease
													  _newTIsArr,
													  _passport);
		endif;
		if _passport.noErrors and (_pxyworkOrder.taskStatus = WO_STATUS_APPROVED or			// 13.12.2023 naviv1 #61543
		_pxyworkOrder.taskStatus = WO_STATUS_PARTCOMPLETE) then								//21.11.2023 navhl20 #61861
			workOrder := app.myProxyManager.getRealObject(_pxyworkOrder).CM_WorkOrderTI;		
			foreach ti in wodtl.allSelectedTIs do
				if workOrder.allTIs.includes(ti) then
					workOrder.allTIs.remove(ti);
				endif;
			endforeach;
		endif;
	endif;
	
	/*
		3- Stage
		Create New Work Order 
	*/
	//if not _passport.hasErrorsOrWarnings or action then  				// 13.12.2023 naviv1 #61543	
	if (not _passport.hasErrorsOrWarnings or action) and createNewWoDtl then				// ### TFS 62777 (62778) 07Mar2024 NAVPW1
		now := app.actualTimeServer;
		if _pxyworkOrder.requiredByDT &lt;&gt; null then 
			requiredByDT := _pxyworkOrder.requiredByDT;
		else
			requiredByDT := now;
		endif;
		create proxyWorkOrder as CM_WorkOrderTI transient;
		create emails transient;
		proxyWorkOrder.setProxy(	
				emails,
				null,
				false, 								//_emailNotification
				now, 								//_enteredByDT
				app.getMyUser(), 					//_enteredByUser 
				'',									//_approvedBy
				app.getMyUser().myOrganisation, 	// _myOrganisation
				app.myPassport.myTerminal, 			//_myTerminal
				null,  								//_remarks
				requiredByDT,						//_requiredByDT
				null, 								//_startAtDT
				WO_STATUS_USERENTRY					//_taskStatus    
				);
		proxyWorkOrder.setProxyWorkOrderTask(wodtl, requiredByDT, null, false,null, null);													
		app.myUtilityCA.utlCreateWorkOrder(proxyWorkOrder,realWorkOrder, _passport);
	endif;
	
	/*
		4 - Stage
		 Approve and Action newly created work order
	*/
	
	if realWorkOrder &lt;&gt; null and not _passport.hasErrorsOrWarnings or action then	// 13.12.2023 naviv1 #61543
		
		if (_pxyworkOrder.taskStatus = WO_STATUS_APPROVED or 						//13.12.2023 naviv1 #61543
			_pxyworkOrder.taskStatus = WO_STATUS_PARTCOMPLETE) and 
			createNewWoDtl															// ### TFS 62777 (62778) 07Mar2024 NAVPW1
		then						//21.11.2023 navhl20 #61861
			realWorkOrder.CM_WorkOrderTI.setTaskStatus(WO_STATUS_APPROVED);
			
			if _pxyWorkOrderDtl.status = WO_STATUS_ACTIONED or _pxyWorkOrderDtl.status = WO_STATUS_PARTCOMPLETE then				//10.01.2023 navhl20 #62018
				isUseYardJobs := realWorkOrder.myTerminal.getConfig(UseYardJobsCargoWO).Boolean;
				foreach wod in realWorkOrder.allWoDtls do
					create woActionIF transient;
					woActionIF.myWorkOrderDtl 		:= wod;
					if wod.isKindOf(CM_WorkOrderTIDtl) then
						woActionIF.numberFromKnownCargo := wod.CM_WorkOrderTIDtl.allAvailableTIs.size;
					endif;
					woActionIF.useYardJobs			:= isUseYardJobs ;
					app.myUtilityUA.utlWorkOrderAction(woActionIF,realJob,null,_passport);	
					delete woActionIF;																													//18.12.2024 navhl20 #33557
				endforeach;
			endif;
		endif;
		
		/*
			5 - Stage
			Update Old WorkOrder
		*/
		//if _pxyWorkOrderDtl.CM_WodReceive.allSelectedTIs.isEmpty() and _pxyworkOrder.allWoDtls.includes(_pxyWorkOrderDtl) then						//05.9.2023 navhl20 #60135
		if _pxyWorkOrderDtl.isWodReceive and _pxyWorkOrderDtl.CM_WodReceive.allSelectedTIs.isEmpty() and _pxyworkOrder.allWoDtls.includes(_pxyWorkOrderDtl) then	// ### TFS 59411 (61855) 30Jan2024 NAVPW1
			_pxyworkOrder.allWoDtls.remove(_pxyWorkOrderDtl);
		endif;
		
		// ### TFS 59411 (62272) 13Feb2024 NAVPW1
		foreach currentWodtl in _pxyworkOrder.allWoDtls as CM_WorkOrderTIDtl do
			if currentWodtl.isWodRelease and 
				currentWodtl.CM_WodRelease.myReleaseRequest &lt;&gt; null and 
				currentWodtl.CM_WodRelease.myReleaseRequest.releaseByType and 
				currentWodtl.totalActioned &lt;&gt; currentWodtl.allActionedTIs.size
			then
				currentWodtl.setTotalActioned(currentWodtl.allActionedTIs.size);
			endif;
			
		endforeach;
		// ### TFS 59411 (62272) 13Feb2024 NAVPW1
		
		if not _passport.hasErrors then 													//30.8.2023 navhl20 #60135
			app.myUtilityUA.utlUpdateWorkOrder(_pxyworkOrder, true, _passport);
		endif;
		
		/*
			5- Stage
			Split the Job and Work List Entry 
		*/
		if createNewWoDtl then	// ### TFS 62777 (62778) 07Mar2024 NAVPW1
			// ### TFS 59411 (61855) 30Jan2024 NAVPW1 - Removed/Changed type casting below
			if not _passport.hasErrors  and (_pxyworkOrder.allWoDtls.last.status = WO_STATUS_ACTIONED																//30.8.2023 navhl20 #60135
				or _pxyworkOrder.allWoDtls.last.status = WO_STATUS_PARTCOMPLETE)
			then																																					//21.11.2023 navhl20 #61861								
				app.myUtilityUA.utlSplitWOTransportJobs(_pxyWorkOrderDtl.CM_WorkOrderTIDtl, realWorkOrder.allWoDtls.last.CM_WorkOrderTIDtl, _terminal, _passport);	// 13.12.2023 naviv1 #61543
			endif;
		endif;					// ### TFS 62777 (62778) 07Mar2024 NAVPW1
		
		/*
			//05.01.2023 navhl20 #61920
			6- Stage
			Complete old workorder if the job and work order detail completed
		*/
		if createNewWoDtl and _passport.noErrors then
			oldWod := app.myProxyManager.getRealObject(_pxyWorkOrderDtl).CM_WorkOrderTIDtl;
			if _terminal.isUseYardJobsForCargoWo and oldWod.isAllJobsWithStatus(JOB_COMPLETE) then
				oldWod.completeMe();
			endif;
		endif;
	endif;
	
	// ### TFS 62777 (62778) 07Mar2024 NAVPW1
	/*
		5- Update Old Work Order
		If we did not create a new work order
	*/
	if not createNewWoDtl then	//Update existing one
		if _pxyWorkOrderDtl.isWodRelease then
			if booking &lt;&gt; null then
				bookingItem := booking.allBookingRefItems.first;
			endif;
			
			if releaseRequest &lt;&gt; null then
				reserveDetail := releaseRequest.allReserveDetails.first;
			endif;
			
			_pxyWorkOrderDtl.CM_WodRelease.setProxyWodRelease(releaseRequest,
								app.transportModeStringToENum(_newTransport),											
								voyage,
								train,
								booking,
								bookingItem,
								reserveDetail);
		elseif _pxyWorkOrderDtl.isWodReceive then
			if bol &lt;&gt; null then
				bolDtl := bol.allBOLDtls.first;
			endif;
			
			if booking &lt;&gt; null then
				bookingItem := booking.allBookingRefItems.first;
			endif;
			
			_pxyWorkOrderDtl.CM_WodReceive.setProxyWodReceival(booking,
							bookingItem,
							bol,
							bolDtl,
							null,
							voyage,
							app.transportModeStringToENum(_newTransport));
			
		endif;
		
		if not _passport.hasErrors then
			app.myUtilityUA.utlUpdateWorkOrder(_pxyworkOrder, true, _passport);
		endif;
		
		if not _passport.hasErrors and not createNewWoDtl and _pxyWorkOrderDtl.status = WO_STATUS_ACTIONED and _pxyWorkOrderDtl.isWodRelease then		//11.12.2024 navhl20 #33557
			currentWodtl := app.myProxyManager.getRealObject(_pxyWorkOrderDtl).CM_WorkOrderTIDtl;
			currentWodtl.setStatus(WO_STATUS_APPROVED);
			create woActionIF transient;
			woActionIF.myWorkOrderDtl 		:= currentWodtl;
			if currentWodtl.isKindOf(CM_WorkOrderTIDtl) then
				woActionIF.numberFromKnownCargo := currentWodtl.CM_WorkOrderTIDtl.allAvailableTIs.size;
			endif;
			woActionIF.useYardJobs			:= isUseYardJobs ;
			app.myUtilityUA.utlWorkOrderAction(woActionIF,realJob,null,_passport);
			foreach oldWod in currentWodtl.myParent.allWoDtls as CM_WodRelease do
				if oldWod &lt;&gt; currentWodtl then
					releaseRequest := oldWod.CM_WodRelease.myReleaseRequest;
					foreach reserveDetail in releaseRequest.allReserveDetails where reserveDetail &lt;&gt; oldWod.CM_WodRelease.myReserveDetail do
						delete reserveDetail;
					endforeach;
				endif;
			endforeach;
			app.myProxyManager.clearAllProxies();
		endif;
	endif;
	// ### TFS 62777 (62778) 07Mar2024 NAVPW1
	
epilog
	if _passport.noErrors() then				// 15/07/2025	navcs2	MTN-35210
		_passport.doDeferredUpdates();			// 15/07/2025	navcs2	MTN-35210															
	endif;										// 15/07/2025	navcs2	MTN-35210
	
	delete wodtl;
	delete emails;
	if woActionIF &lt;&gt; null then																															//18.12.2024 navhl20 #33557
		delete woActionIF;
	endif;
	delete proxyWorkOrder;
	delete allTisSelected;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyworkOrder" type="CM_WorkOrder" usage="input"/>
        <Parameter name="_pxyWorkOrderDtl" type="CM_WorkOrderDtl" usage="input"/>
        <Parameter name="_transport" type="CM_Object"/>
        <Parameter name="_newTransport" type="String"/>
        <Parameter name="_newId" type="String"/>
        <Parameter name="_newTIsArr" type="ObjectArray"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_quantityIfWle" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateWorkPoint" id="b5af78df-002b-403e-8446-37ad7ff8bf04">
