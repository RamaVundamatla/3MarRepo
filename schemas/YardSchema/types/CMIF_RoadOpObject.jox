    <JadeMethod name="setTableRowColour" id="35f67282-ffa4-46dd-a014-3955807000c0">
        <source>setTableRowColour(_obj : CM_Object; _row: Integer);
/*

Purpose:			


Return Value:		


Date			Who		Reason
15 August 2006	cnwer1	Initial creation - PAR#xxxx
25 August 2009	cnwcs5	ccms 1061 - road ops form changes
*/
vars
	table					: CM_DataTable;
	isSelected, isReceipt 	: Boolean;
	foreColour,	backColour,
	col						: Integer;	
	commodity				: CM_Commodity;
	wle 					: CM_WorkListEntry;
	colElapsed : Integer;
	cell : JadeTableCell;
	term : CM_Terminal;
	maxElapsedMins : Integer;
	int : Integer;
	tableRow : JadeTableRow;
begin
	if _obj = null then
		return;
	endif;

	// set default foreground and background colours
	foreColour := Black;
	backColour := White;

	table	:= self.myDataTable;
	
	if _obj.isKindOf(CM_WorkListEntry) then
		wle := _obj.CM_WorkListEntry;
		
		if wle.job &lt;&gt; null and wle.job.jobType = BOLType_Log then
			foreColour := Black;
			backColour := app.mainForm.getSystemColor(Window.Color_Window);
		else
			wle.getRowColour(foreColour, backColour);	
		endif;	
	endif;
	
	table.accessRow(_row).backColor := backColour;
	table.accessRow(_row).foreColor := foreColour;	
	
	if backColour = Red then
		table.accessRow(_row).fontBold := true;	
	else		
		table.accessRow(_row).fontBold := false;		
	endif;
	
	// Radio telemetry 
	col := table.getColumnByRowName(ETRow_RadioTelemetry);
	
	if col &gt; 0 then
		self.displayWLEsShowRT(_row, col);
	endif;	

	// Gate lane - centre contents
	col := table.getColumnByRowName(ETRow_GateLane);
	
	if col &gt; 0 then
		table.accessCell(_row, col).alignment := Table.Alignment_Center_Middle;
	endif;
	
	if self.getBoldPowerChecked and wle &lt;&gt; null and wle.myTrackedItem &lt;&gt; null and wle.status &lt;&gt; WLE_COMPLETED then
		if wle.myTrackedItem.commodity &lt;&gt; null then	
			commodity := app.myRoot.allCommodities[wle.myTrackedItem.commodity].CM_Commodity;
			if commodity.requiresPower then 
			
				// 03/09/2014 cnwar2 #34651 - make whole row bold not just commodity cell
				table.accessRow(_row).foreColor := Blue;
				table.accessRow(_row).fontBold 	:= true;	
				/*col :=	table.getColumnByRowName(ETRow_Commodity);	
				if col &lt;&gt; 0 then			
					table.accessCell(_row, col).foreColor	:= Blue;	   			
					table.accessCell(_row, col).fontBold 	:= true;					   	
				endif;*/
			endif;
		endif;
	endif;
	
	//05 Sep 2012	NDL	Par 29717
	colElapsed := self.myDataTable.getColumnByRowName(ETRow_ElapsedTime);
	if colElapsed &gt; 0 then
		term := self.getTerminal;
		if term &lt;&gt; null then
			//epr TFS 7828 24/11/17
			maxElapsedMins := self.myRoadOpController.maxElapsedMins;	
			
			if maxElapsedMins &gt; 0 then
				cell:=self.myDataTable.accessCell(_row, colElapsed);
				if cell.text &lt;&gt; null then
					int := cell.text.Integer;
					if int &gt; maxElapsedMins then
						tableRow := self.myDataTable.accessRow(_row);
						cell.fontBold := true;
						if tableRow.backColor = Red then
							cell.foreColor := White;
						else
							cell.foreColor := Red;
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;


epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTableRowColour_Lanes" id="ae2cd785-0435-4bbc-9001-9bd1a71bd8a7">
        <source>setTableRowColour_Lanes(_obj :Object; _row :Integer) protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2009 by cnwcs5:1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	table	:CM_DataTable;
	vehicle	:CM_Vehicle;
	lane	:CM_LaneController;
begin
	table := self.myDataTable;
	
	if (_obj.isKindOf(CM_Vehicle)) then
		vehicle := _obj.CM_Vehicle;
	
		if vehicle.myPrimaryActualLocation.isKindOf(CM_LaneController) then
			lane := vehicle.myPrimaryActualLocation.CM_LaneController;
		endif;
		
	elseif (_obj.isKindOf(CM_LaneController)) then
		lane := _obj.CM_LaneController;
	endif;

	if lane &lt;&gt; null and lane.CM_LaneController.laneDirection &lt;&gt; lane.CM_LaneController.vehicleDirection then
		table.accessRow(_row).fontBold	:= true;	
		table.accessRow(_row).backColor := Red;
		table.accessRow(_row).foreColor := White;	
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupBoldPowerOption" id="458d1f97-35d1-4402-bb13-aae808931304">
        <source>setupBoldPowerOption(_menu :MenuItem input);
// ---------------------------------------------------------------------------
// Created:     15 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	i 		: Integer;
	obj		: Object;
	menu 	: MenuItem;
begin
	if _menu = null then
		return;
	endif;
	
	foreach obj in self.allMenuItems do
		menu := obj.MenuItem;
		
		if menu.name = _menu.name and menu.userObject = self then
			// we already have it
			return;
		endif;
	endforeach;
	
	self.myRoadOpController.setNumberOfMenuItems(self.myRoadOpController.numberOfMenuItems+1);
	
	menu			:= _menu.loadMenu(self.myRoadOpController.numberOfMenuItems);
	menu.visible	:= true;
	menu.userObject	:= self;
	
	menu.setEventMapping(MenuItem::click.name,YRD_RoadOperationsForm::mBoldPower_click.name);
	
	self.allMenuItems.add(menu);
epilog

end;</source>
        <Parameter name="_menu" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupDataTable" id="c03c6fb1-e050-4937-a3ab-851a3c10394a">
        <source>setupDataTable();

vars
	terminal 	: CM_Terminal;
	table		: CM_DataTable;
	view 		: String;
begin
	terminal 	:= self.getTerminal();
	table 		:= self.myDataTable;
	
	table.userInputEnabled 	:= false;
	table.multiSelect 		:= CM_DataTable.MultiSelect_None;
	table.selectMode 		:= Table.SelectMode_CurrentRow;
	table.selectionType 	:= CM_DataTable.SelectionType_Row;	
	table.fixedColumns		:= self.getFixedColumns;
	
	table.setTerminologyRelevant(null,terminal);
	
	//If there is no user window then we sort by dwell time
	table.zAddSortColumn(self.getSortColumn, self.sortColumnDescending);

	view := self.getDataTableView();
	
	// we will be grouping by terminaAreaOid
	table.CM_GroupingTable.setTblDataEntRowsFromView_Grp(self.getEntTableDef(),view, ETRow_TerminalAreaOid);
	
	table.leftColumn := 1;//has no idea how but was being set to 2
	table.selectMode := Table.SelectMode_FixedRow;
end;</source>
    </JadeMethod>
