*/
vars

begin
	return AppName_TwistLockReader;


epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLogName" id="d1d0611f-3315-494d-8332-bbaa91d15028">
        <source>getLogName(): String protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
20 July 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	fileName : String;
	
begin
	fileName := self.getAppName;
	if self.myMachine &lt;&gt; null then
		fileName := fileName &amp; "_" &amp; self.myMachine.id;
	endif;

	return fileName;


epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initializeConnection" id="f84da667-e155-4205-bf27-fad0880872c4">
        <updating/>
        <source>initializeConnection(	terminalCode,
						deviceCode : String)
						 : Boolean updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
28 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	serialConnectionDetails : CM_WinCEJadeSerialDetails;
	serverPath : String;
begin
	
	on ConnectionException do connectionExceptionHandler(exception) global;
	//self.writeLog(method.name &amp; " - server bin = " &amp; app.getJadeInstallDirAppServer);
	create self.myWinCESerialPort as JadeSerialPort transient;

	myTerminal := app.myRoot.allTerminals[terminalCode];
	if self.myTerminal = null then
		self.writeLog(method.name &amp; ' - Terminal is null');
		return false;
	endif;
	app.myPassport.setMyTerminal(self.myTerminal);
	
	self.myRTDevice:=self.myTerminal.radioTelemetry.allRTDevices[deviceCode];
	if self.myRTDevice = null then
		self.writeLog(method.name &amp; " - RT Device is null");
		return false;
	endif;
	if self.myRTDevice.isKindOf(CM_RTDeviceVehicleMount) then
		self.setMyMachine(self.myRTDevice.CM_RTDeviceVehicleMount.myMachine);
	else
		self.writeLog(method.name &amp; " - RT Device is invalid type");
		return false;
	endif;
	
	if self.myRTDevice.useSerialConnection = false then
		self.writeLog(method.name &amp; " - RT Devices does not use a serial connection");
		return false;	
	endif;
	
	serialConnectionDetails:=self.myRTDevice.CM_RTDeviceVehicleMount.myWinCESerialDetails;
	if serialConnectionDetails = null then
		self.writeLog(method.name &amp; " - RT Devices serial connection details are null");
		return false;	
	endif;
	
	self.myWinCESerialPort.JadeSerialPort.usePresentationClient:=true;
	self.myWinCESerialPort.name:=serialConnectionDetails.portName;
	self.myWinCESerialPort.timeout:=serialConnectionDetails.timeout;
	self.myWinCESerialPort.JadeSerialPort.speedBps := serialConnectionDetails.speedBps;
	self.myWinCESerialPort.JadeSerialPort.dataBits := serialConnectionDetails.dataBits;
	self.myWinCESerialPort.JadeSerialPort.parity := serialConnectionDetails.parity;
	self.myWinCESerialPort.JadeSerialPort.stopBits :=serialConnectionDetails.stopBits;
	self.myWinCESerialPort.JadeSerialPort.flowControl := serialConnectionDetails.flowControl;
	
	self.writeLog(serialConnectionDetails.portName &amp; " " &amp; serialConnectionDetails.timeout.String &amp; " " &amp; serialConnectionDetails.speedBps.String &amp; " " &amp; serialConnectionDetails.dataBits.String &amp; " " &amp; serialConnectionDetails.parity.String
					&amp; " " &amp; serialConnectionDetails.stopBits.String &amp; "  "&amp;serialConnectionDetails.flowControl.String );
	return true;
epilog

end;</source>
        <Parameter name="terminalCode" type="String"/>
        <Parameter name="deviceCode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyMachine" id="1f616d48-bdfd-4396-9189-edebf0140279">
        <updating/>
        <source>setMyMachine(_machine : CM_Machine) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	if self.myMachine &lt;&gt; _machine then
		self.myMachine:=_machine;
	endif;

epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="startNotes" id="dfb56449-ef3c-4928-81ee-083b9d446251">
        <source>startNotes();
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.beginNotification(self.myMachine, EVENT_TWISTLOCK_READ ,Response_Continuous , null);	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="userNotification" id="0d60302e-1644-4235-bd0c-0106be46dfb8">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	
begin
	if eventType = EVENT_TWISTLOCK_READ then
		self.doRead();
	endif;

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="xmlExceptionHandler" id="d0aaab8b-a3b2-43a9-a3b5-5869237da93e">
        <source>xmlExceptionHandler(exObj: JadeXMLException): Integer;
/*

Purpose:			


Return Value:		


Date		Who		Reason
11 May 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.myMachine.causeEvent(EVENT_TWISTLOCK_RESPONSE,true,null);
	return inheritMethod(exObj);


epilog

end;</source>
        <Parameter name="exObj" type="JadeXMLException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
