    <JadeMethod name="doSaveProjections" id="f7b0144d-2377-4eb9-aef8-5080e9a1804b">
        <updating/>
        <source>doSaveProjections() updating;
// ---------------------------------------------------------------------------
// Created:     08 March 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	allocs : CM_YardAllocationSet;
	obj : CM_YardAllocation;
	pxyAlloc, voyAlloc, updatePxy : CM_VoyageAllocation;
	idx , stRow, endRow, proj20, selectedCol, theReturn : Integer;
begin
	create allocs transient; // PAR 23405

	selectedCol := self.tblCCAllocation.getColumnByRowName(ETRow_Projected);
	if selectedCol &lt;= 0 then
		return;
	endif;

	// ### SET PROJECTIONS ON PROXY
	stRow := self.tblCCAllocation.fixedRows + 1;
	endRow := self.tblCCAllocation.rows;
	
	foreach idx in stRow to endRow do
		voyAlloc := self.tblCCAllocation.accessRow(idx).itemObject.CM_VoyageAllocation;
		if voyAlloc &lt;&gt; null then
			pxyAlloc := voyAlloc.pxyGetProxyObject();
			if pxyAlloc = null then
				pxyAlloc := app.createUpdateProxy(voyAlloc).CM_VoyageAllocation;
			else
				updatePxy := pxyAlloc; // This is created by the 'linked' voyage allocation attribute screen
			endif;
			if pxyAlloc &lt;&gt; null then
				proj20 := self.tblCCAllocation.accessCell(idx,selectedCol).text.Integer;
				pxyAlloc.setProxyProjectedValues(proj20,0,0,0,0,0);
				allocs.add(pxyAlloc);
			endif;
		endif;
	endforeach;
	
	// ### UPDATE PROJECTIONS
	while true do
		app.myTrxUA.trxUpdateVoyageAllocNumbers(allocs, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Allocation Projections", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

epilog
	foreach obj in allocs  discreteLock do
		if obj = updatePxy then
			continue;
		endif;
		delete obj;
	endforeach;
	delete allocs;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSetCaption" id="d6976683-7e17-48f7-8994-51dc3c930ddc">
