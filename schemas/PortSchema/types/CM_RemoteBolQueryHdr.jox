<Class name="CM_RemoteBolQueryHdr" id="6334c4b8-b574-4608-9aa8-4ce5907cb717">
    <superclass name="CM_RemoteDataHdr"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Docket Query&lt;/display&gt;</text>
    <DbClassMap file="remoteDataProcessing"/>
    <CompAttribute name="allBols" id="d015aeac-1289-43b3-a63c-9ee2683e76a4">
        <type name="StringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <PrimAttribute name="tagAttributes" id="48d25775-50cf-4bf1-9d1e-f99d70ff3042">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getBolQueryResponse" id="80f0d032-d538-42b2-9e96-7b1a9b5b2727">
        <source>getBolQueryResponse(_error : Integer output; _errorTxt : String output) : String protected;
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars

	bolId			: String;
	item			: CM_BOLIn;
	myTerminal		: CM_Terminal;
	theResponse		: String;
	tiType,
	class			: String;
	bolConstant		: Integer;
	isFound			: Boolean;
	iter			: Iterator;
	errStr			: String;
	ti				: CM_TrackedItem;
	coll			: Collection;
	obj				: Any;

begin

	self.getAttributes(self.tagAttributes, class, tiType);
	bolConstant :=  getBolConstant(class);
	if bolConstant = 0 then
		_error := Err_InvalidClass;
		_errorTxt := app.getErrorString1(Err_InvalidClass, class);
		return null;
	endif;
	
	if tiType &lt;&gt; Type_BOL then
		_error := Err_InvalidType;
		_errorTxt := app.getErrorString1(Err_InvalidType, tiType);
		return null;
	endif; 

	if self.allBols.size &gt; 0 then
		theResponse := 
		self.formatAsXMLPrefix(XML_BDY) &amp; 
		self.formatAsXMLPrefix(XML_BOLQRYRSP);
		myTerminal := app.myPassport.myTerminal;
		if myTerminal = null then
			_error 		:= Err_InvalidTerminal;
			_errorTxt	:= app.getErrorString1(Err_InvalidTerminal, self.terminal);
			return null;
		endif;
		iter := myTerminal.allBOLsReceivedByTypeNumberDT.createIterator();
		foreach bolId in self.allBols do
			myTerminal.allBOLsReceivedByTypeNumberDT.startKeyGeq(bolConstant, bolId, null, iter);
			while iter.next(item) do
				if item.number &lt;&gt; bolId then
					errStr := errStr &amp; ', ' &amp; bolId;
				else
					theResponse := theResponse &amp; '&lt;' &amp; XML_BOL &amp; ' class=' &amp; class &amp; '&gt;' &amp; CrLf;
					theResponse := theResponse &amp; self.formatAsXML(XML_BOLHDR, item.getDetailForRemoteQuery(self.theVersion));
					theResponse := theResponse &amp; 
					'&lt;' &amp; XML_TIDTLS &amp; ' class=' &amp; class &amp; ' type="FULL"' &amp; '&gt;' &amp; CrLf;
					coll := item.getTICollectionForTerminal(myTerminal);
					foreach obj in coll do
						ti := obj.CM_TrackedItem;
						
						theResponse := theResponse &amp; self.formatAsXML(XML_TI, ti.getDetailForRemoteQuery(Type_Full, self.theVersion));
					endforeach;
					theResponse := theResponse &amp; self.formatAsXMLSuffix(XML_TIDTLS) &amp; self.formatAsXMLSuffix(XML_BOL);
					isFound := true;
				endif;
				break;
			endwhile;
		endforeach;

		if errStr.length &gt; 2 then
			// We have not found tracked item(s).
			_error := Err_BOLNotFound;
			_errorTxt := app.getErrorString1(Err_BOLNotFound, null) &amp; errStr[3 : end];
		endif;
	endif;	
	if isFound then
		return theResponse &amp; self.formatAsXMLSuffix(XML_BOLQRYRSP) &amp; self.formatAsXMLSuffix(XML_BDY);
	endif;
	return null;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_error" type="Integer" usage="output"/>
        <Parameter name="_errorTxt" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMessageResponseType" id="c9c886e8-fa28-4df6-88c8-76dfc12a0c7f">
        <source>getMessageResponseType(): String;

vars

begin
	return CM_RemoteDataManager.BOLQUERYRSP;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processExternal" id="4fdcb20e-e3ec-4110-a58a-b3c7542264f0">
        <updating/>
        <source>processExternal(_parseAgent: CM_RemoteParseAgent io): String updating;

vars

	err			: Integer;
	errTxt		: String;
	response	: String;
	headerCast	: CM_RemoteDataHdr;

begin

	response := inheritMethod(_parseAgent);
	if response = null then
		if _parseAgent.createBOLQueryDetail(self) then
			response := self.getBolQueryResponse(err, errTxt);
			return self.doBuildMessage(self.xmlResponse(err, errTxt) &amp; response);
		endif;
		response := app.getErrorString1(Err_XML, 'bol item query');
		return self.doBuildMessage(self.xmlResponse(Err_XML , response));
	endif;
	headerCast := self;
	return self.doBuildMessage(xmlDefaultResponse(headerCast, Err_XML , response));
			
end;</source>
        <Parameter name="_parseAgent" type="CM_RemoteParseAgent" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyForBolQueryHdr" id="37bd9744-ab14-42e0-8baa-a28ef2212c0c">
        <updating/>
        <source>setProxyForBolQueryHdr(_tagAttributes : String; _allBols : StringArray) updating;

vars

begin

	self.raiseExceptionIfNotTransient(method);
	self.tagAttributes := _tagAttributes;
	_allBols.copy(self.allBols);

end;</source>
        <Parameter name="_tagAttributes" type="String"/>
        <Parameter name="_allBols" type="StringArray"/>
    </JadeMethod>
</Class>
