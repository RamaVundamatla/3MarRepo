    <JadeMethod name="rel22024_tfs36332" id="58dbd712-98d4-4d11-bd36-4ec585700954">
        <source>rel22024_tfs36332();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20/10/2025	navkc1	MTN JIRA 36332

*/

vars
	agent 				: EntTableAgent;
	array 				: StringArray;
	
	translationAgent 	: CM_TranslationAgent;
begin
	app.initialize();

	create agent transient;
	create array transient;
	agent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;
	
	array.add("ETRow_CargoTypeCodeForCntnt");
