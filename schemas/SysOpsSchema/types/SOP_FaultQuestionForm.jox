    <JadeMethod name="doBaseFormSave" id="995d89c9-c5c3-4a35-ab67-44627c7e75a9">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
05 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	rtnValue : Boolean;
begin
	rtnValue:=self.doSave();
	
epilog
	if rtnValue then
		self.unloadForm;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="fdeea7da-697d-4e3f-8e14-efe322fd42c5">
        <updating/>
        <source>doSave() : Boolean updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
11 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	failureCondition : String;
	faultType : CM_FaultType;
	rtnValue : Boolean;
	result : Integer;
begin
	if self.myProxyFaultQuestion = null then	
		create self.myProxyFaultQuestion  transient;
	endif;
	if self.cmbFaultType.listIndex &gt; 0 then
		faultType:=self.cmbFaultType.itemObject[self.cmbFaultType.listIndex].CM_FaultType;
	endif;
	if self.cmbFailure.listIndex &gt; 0 then
		failureCondition:= self.cmbFailure.itemText[self.cmbFailure.listIndex];
	endif;
	self.myProxyFaultQuestion.setProxy(self.txtQuestion.text,faultType,failureCondition);

	while true do
		if self.myFaultQuestion = null then	
			app.myTrxCA.trxCreateFaultQuestion(self.myProxyFaultQuestion,self.myMachineType, self.myFaultQuestion, app.myPassport);
			rtnValue	:=	app.myPassport.trxCompletedOK;
			
		else
			app.myTrxUA.trxUpdateFaultQuestion(self.myProxyFaultQuestion, app.myPassport);
			rtnValue	:=	app.myPassport.trxCompletedOK;
		endif;
			
		if (not rtnValue) then
			result := app.showErrorWarningDialog('Fault Questions', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			//we had a cancelled update - refresh data
			if self.myFaultQuestion &lt;&gt; null then
				
				self.myProxyFaultQuestion := app.createUpdateProxy(self.myFaultQuestion).CM_FaultQuestion;
			endif;
			return false;
		else
			self.clearErrorWarnings();
		endif;
		break;
	endwhile;
	
	return rtnValue;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveNext" id="d949c835-d6d1-43cb-8433-3cccbefd65fe">
        <updating/>
        <source>doSaveNext() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
11 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	rtnValue : Boolean;
begin
	rtnValue:=doSave;
	if rtnValue then
		self.init(self.myMachineType,null);
		self.setupForm;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="init" id="6c25d335-ca2b-4966-8eb2-d404f69b6825">
        <updating/>
        <source>init(	_machineType : CM_MachineType;
		_faultQuestion : CM_FaultQuestion ) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
06 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	self.myMachineType:=_machineType;
	self.myFaultQuestion:=_faultQuestion;
	if _faultQuestion &lt;&gt; null then
		btnNext.visible := false;
	
  		self.myProxyFaultQuestion := app.createUpdateProxy(_faultQuestion).CM_FaultQuestion;
	else
		if self.myProxyFaultQuestion &lt;&gt; null then
			delete self.myProxyFaultQuestion;
		endif;
		
	endif;
epilog

end;</source>
        <Parameter name="_machineType" type="CM_MachineType"/>
        <Parameter name="_faultQuestion" type="CM_FaultQuestion"/>
    </JadeMethod>
