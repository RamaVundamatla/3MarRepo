    <JadeMethod name="getTIForModeStackHeight" id="a3100ed8-7b26-4020-b399-f60c46dde6be">
        <source>getTIForModeStackHeight(_anLC : CM_LocationsController; _mode : Integer;  _y : Integer) : CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:		06 September 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	key1, key2 : Point;
	tmpY1, tmpY2, tmpIDX, tmpHeight, stackHght : Integer;
	theTI : CM_TrackedItem;
begin
	if self.allGridObjects.findObjectInDictGetXY(_anLC, key1, key2) then
		stackHght := self.getHeightOfStack;	// PAR 21532 CCMS SFW 1025
		tmpY1 := key1.y;
		tmpY2 := key2.y;
		tmpIDX := (_y - tmpY1).Integer; // frame Y relective to rectangle
		tmpHeight := tmpY2 - tmpY1;
		tmpHeight := (tmpHeight / stackHght).Integer;
		tmpIDX := (tmpIDX /tmpHeight).roundedUp;
		tmpIDX := (stackHght - tmpIDX) + 1;
		if tmpIDX &gt; 0 then
			theTI := _anLC.getTIAtIndex(_mode,tmpIDX);
		endif;
	endif;
	return theTI;
end;</source>
        <Parameter name="_anLC" type="CM_LocationsController"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getTIsForLCs" id="74c30d61-0f63-4f96-aa29-6e4ed2e0a62c">
        <source>getTIsForLCs(_tiDict : CM_TIByIdDict input);
// ---------------------------------------------------------------------------
// Created:		19 September 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	anObj : Object;
	anLC : CM_LocationsController;
	aTI : CM_TrackedItem;
begin
	if _tiDict = null then
		return;
	endif;
	
	foreach anObj in self.allSelectedObjects do
		if anObj.isKindOf(CM_LocationsController) then
			anLC := anObj.CM_LocationsController;
			foreach aTI in anLC.allTrackedItemsById discreteLock do
				_tiDict.addNoDuplicates(aTI, false);
			endforeach;
		elseif anObj.isKindOf(CM_TrackedItem) then
				_tiDict.addNoDuplicates(anObj.CM_TrackedItem, false);
		
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_tiDict" type="CM_TIByIdDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getViewMode" id="e7f2ee1a-aefb-4b22-959f-e2d7a43c3f7c">
        <source>getViewMode() : Integer ;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 April 2009	cnwjk3	PAR 19329

*/

vars
	theForm 	: Form; 
begin
	theForm := self.getForm();
	if theForm.isKindOf(YRD_GridAreasOverviewForm) then
		return theForm.YRD_GridAreasOverviewForm.getValidYardGridAreaViewMode(self.viewMode);
	else
		return self.viewMode;
	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getXPosForColumn" id="b05381cd-8bac-4b7b-b74b-3ba8611a7228">
        <source>getXPosForColumn(_column : CM_GridColumn) : Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 December 2010	cnwer1	Initial creation

*/

vars
	tmpTA : CM_GridArea;
	xPos1,xPos2	: Real;
	tmpCol  : CM_GridColumn; 
	theColWidth : Real;
begin
	xPos1 := self.LABELGAP ;
	xPos2:=xPos1;
	tmpTA:=_column.myGridArea;
	if self.flipHorizontal then
		foreach tmpCol in tmpTA.allGridColumns reversed   do 
			
			xPos1:=xPos2+ self.columnSpacing;
			theColWidth	 := self.ColumnWidth * self.scaleFactor;
			if tmpCol.hasGap then
				theColWidth := self.getGapDrawWidth(tmpCol);
			endif;
			xPos2:=xPos1+ theColWidth;
			if tmpCol = _column then
				break;
			endif;
		endforeach;
	else
		foreach tmpCol in tmpTA.allGridColumns  do
			xPos1:=xPos2+ self.columnSpacing;
			theColWidth	 := self.ColumnWidth * self.scaleFactor;
			if tmpCol.hasGap then
				theColWidth := self.getGapDrawWidth(tmpCol);
			endif;
			xPos2:=xPos1+ theColWidth;
			if tmpCol = _column then
				break;
			endif;
		endforeach;
	endif;	
	
	return xPos1.Integer ;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_column" type="CM_GridColumn"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getYardAllocationPoints" id="4c9725cc-ce3f-4ce9-87f7-cfa9c5be6968">
        <source>getYardAllocationPoints(_drawing : Boolean);
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin

	if _drawing then
		self.myDrawingFrame.myOverlayDrawingFrame.getYardAllocationPointsForTA(self.myTerminalArea.CM_GridArea);
		self.myDrawingFrame.myOverlayViewingFrame.setObjects(self.myDrawingFrame.myOverlayDrawingFrame.allObjects);
	else
		self.myDrawingFrame.myOverlayViewingFrame.getYardAllocationPointsForTA(self.myTerminalArea.CM_GridArea);
		self.myDrawingFrame.myOverlayDrawingFrame.setObjects(self.myDrawingFrame.myOverlayViewingFrame.allObjects);
	
	endif;
	
	self.drawYardAllocations(_drawing);

end;</source>
        <Parameter name="_drawing" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="gridObjectsGetAtKeyForPut" id="1bbcc7f8-bfd0-4820-899b-10f3fdfd0842">
        <source>gridObjectsGetAtKeyForPut( _x1, _y1, _x2, _y2 : Integer ) : Object;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
26 November 2008	consw1	Initial creation

*/

vars

begin
	if self.myDrawingFrame &lt;&gt; null and		// PAR 21532 CCMS SFW 1025
	   self.myDrawingFrame.swapXY then
		return self.allGridObjects.getAtKey(	_y1 + self.myDrawingFrame.swapYadjustment, _x1 + self.myDrawingFrame.swapXadjustment, 
												_y2 + self.myDrawingFrame.swapYadjustment, _x2 + self.myDrawingFrame.swapXadjustment 	);
	endif;

	return self.allGridObjects.getAtKey( _x1, _y1, _x2, _y2 );

epilog

end;</source>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="gridObjectsPutAtKey" id="52ad3d0b-28ac-45a0-8642-a7bf6738dcf2">
        <source>gridObjectsPutAtKey( _x1, _y1, _x2, _y2 : Integer; _obj : Object );

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
26 November 2008	consw1	Initial creation

*/

vars
	obj : Object;														// cnwmc5 - 20 May 2016 - TFS 2006
	x1 : Integer;														// cnwmc5 - 20 May 2016 - TFS 2006
begin
	x1 := _x1;															// cnwmc5 - 20 May 2016 - TFS 2006
	obj := self.gridObjectsGetAtKeyForPut(_x1, _y1, _x2, _y2);			// cnwmc5 - 20 May 2016 - TFS 2006
	while obj &lt;&gt; null do												// cnwmc5 - 20 May 2016 - TFS 2006
		x1 := x1 + 1;													// cnwmc5 - 20 May 2016 - TFS 2006
		obj := self.gridObjectsGetAtKeyForPut(x1, _y1, _x2, _y2);		// cnwmc5 - 20 May 2016 - TFS 2006
	endwhile;															// cnwmc5 - 20 May 2016 - TFS 2006	
	
	if self.myDrawingFrame &lt;&gt; null and		// PAR 21532 CCMS SFW 1025
	   self.myDrawingFrame.swapXY then
		self.allGridObjects.putAtKey( 	_y1 + self.myDrawingFrame.swapYadjustment, x1 + self.myDrawingFrame.swapXadjustment, 			// cnwmc5 - 20 May 2016 - TFS 2006
										_y2 + self.myDrawingFrame.swapYadjustment, _x2 + self.myDrawingFrame.swapXadjustment, _obj );
	else
		self.allGridObjects.putAtKey( x1, _y1, _x2, _y2, _obj );		// cnwmc5 - 20 May 2016 - TFS 2006			
	endif;

epilog

end;</source>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="gridObjectsRemove" id="0d8b8327-64dc-454f-924e-67d46f66dc5e">
        <source>gridObjectsRemove( _x1, _y1, _x2, _y2 : Integer );

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
26 November 2008	consw1	Initial creation

*/

vars

begin
	if self.myDrawingFrame.swapXY then
		self.allGridObjects.removeObjectsInDict( _y1 + self.myDrawingFrame.swapYadjustment, _x1 + self.myDrawingFrame.swapXadjustment, 
												 _y2 + self.myDrawingFrame.swapYadjustment, _x2 + self.myDrawingFrame.swapXadjustment );
	else
		self.allGridObjects.removeObjectsInDict( _x1, _y1, _x2, _y2 );
	endif;

epilog

end;</source>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleLabelFrameDblClick" id="c7241465-c714-494c-acc7-032e7caa942e">
        <updating/>
        <source>handleLabelFrameDblClick(frame: CMUI_ScrollableLabelsFrame input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	TopTextMargin	: Integer = 10;
	LeftTextMargin	: Integer = 5;

	TopMargin		: Integer = 10;
	BottomMargin	: Integer = 10;
	LeftMargin		: Integer = 10;
	RightMargin		: Integer = 10;
	RowSpacing		: Integer = 10;

	RowHeight		: Integer = 12;
	ColWidth		: Integer = 24;

vars
	tmpDrawingController	: YRD_ContainerDrawingController;
	maxX,
	maxY	: Integer;
	tmpTA	: CM_GridArea;
	tmpRow	: CM_GridRow;
	tmpCol	: CM_GridColumn;
	tmpLC	: CM_GridController;
	rowIdx, tmpRowIdx,
	colIdx,rowNum,colNum	: Integer;
	tmpX, tmpY,
	theRowHeight,
	theColWidth,
	yPos1, yPos2,
	xPos1, xPos2	: Integer;	
	tmpCaption	: String;
	tmpFrame	: CMUI_Frame;	//YRD_ContainerDrawingFrame;
	cellHeight, cellIdx, cellY1, cellY2 : Integer;
	
	frameButton, frameShift : Integer;
begin
/* SFW1030	
	tmpTA := self.myTerminalArea.CM_GridArea;
	if tmpTA = null then
		return;
	endif;
	
	if tmpTA.type &lt;&gt; TA_TYPE_STRADDLE_STACK then
		return;
	endif;
	
	frameButton := frame.origButton;
	
	if frameButton &lt;&gt; Window.MouseButton_Left then
		return ;
	endif;
	
	frameShift := frame.origShift;

	 self.getDeckingRowHeight(frame);	
	
	if (not frameShift.isControlKeyPressed and not frameShift.isAltKeyPressed and not frameShift.isShiftKeyPressed) then // no ctrl, shift or alt
		if not (self.myDockBar.isForOverview and self.myDockBar.isForTrailers) then
			self.myYardGridAreaForm.showDeckingFrame(0);
		endif;
	elseif (frameShift.isControlKeyPressed and not frameShift.isAltKeyPressed and not frameShift.isShiftKeyPressed) then // control only
		if not (self.myDockBar.isForOverview and self.myDockBar.isForTrailers) then
			self.myYardGridAreaForm.reverseDeckingForRow(self.myCurrentDeckingRow);
		endif;
	endif;
*/	
end;</source>
        <Parameter name="frame" type="CMUI_ScrollableLabelsFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="handleLabelFrameDragOver" id="b96a706a-36ef-4eb9-816d-0dc5990d89bf">
        <updating/>
        <source>handleLabelFrameDragOver(frame: CMUI_ScrollableLabelsFrame input; win: Window input; x: Real; y: Real; state: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

constants
	TopTextMargin	: Integer = 10;
	LeftTextMargin	: Integer = 5;

	TopMargin		: Integer = 10;
	BottomMargin	: Integer = 10;
	LeftMargin		: Integer = 10;
	RightMargin		: Integer = 10;
	RowSpacing		: Integer = 10;

	RowHeight		: Integer = 12;
	ColWidth		: Integer = 24;

vars
	tmpDrawingController	: YRD_ContainerDrawingController;
	maxX,
	maxY	: Integer;
	tmpTA	: CM_GridArea;
	tmpRow	: CM_GridRow;
	tmpCol	: CM_GridColumn;
	tmpLC	: CM_GridController;
	rowIdx,
	colIdx,rowNum,colNum	: Integer;
	tmpX, tmpY,
	theRowHeight,
	theColWidth,
	yPos1, yPos2,
	xPos1, xPos2	: Integer;	
	tmpCaption	: String;
	tmpFrame	: CMUI_Frame;	//YRD_ContainerDrawingFrame;

	origX, origY, nowX, nowY : Integer;
begin
	
	if not self.myDrawingFrame.myOverlayDrawingFrame.visible then
		return;
	endif;

/*	
	if state = Frame.DragOver_Enter then
		self.enteredTS := now;
		self.leaveTS := null;
		return;
	endif;
	if state = Frame.DragOver_Leave then
		self.leaveTS := now;
		self.enteredTS := null;
		return;
	endif;
*/

	tmpTA := self.myTerminalArea.CM_GridArea;
	if tmpTA = null then
		return;
	endif;

	colNum := tmpTA.allGridColumns.size;
	rowNum := tmpTA.allGridRows.size;
	theColWidth	 := (ColWidth * self.scaleFactor).Integer;
	theRowHeight := (RowHeight * self.getHeightOfStack * self.scaleFactor).Integer;	// PAR 21532 CCMS SFW 1025

	if frame = self.myHLabels then
//		write "HORIZ&gt; X:" &amp; x.String &amp; " Y: " &amp; y.String;
		yPos1 := self.LABELGAP;
		yPos2 := (rowNum * theRowHeight).Integer + self.LABELGAP + ((rowNum - 1) * RowSpacing).Integer;
		
		xPos2 := self.LABELGAP - 1;
		foreach colIdx in 1 to colNum do
			xPos1 :=  xPos2;
			xPos2 := xPos1 + theColWidth + self.columnSpacing;
			
			if frame.origX &gt;= xPos1 and frame.origX &lt;= xPos2 then
				origX := xPos1;
				break;
			endif;
		endforeach;

		xPos2 := self.LABELGAP - 1;
		foreach colIdx in 1 to colNum do
			xPos1 :=  xPos2;
			xPos2 := xPos1 + theColWidth + self.columnSpacing;
			
			if x &gt;= xPos1 and x &lt;= xPos2 then
				nowX := xPos2;
				break;
			endif;
		endforeach;
		self.myDrawingFrame.myOverlayDrawingFrame.doSelectColumnRow(origX,yPos1 ,nowX,yPos2 ,false,false);
		
	elseif frame = self.myVLabels then
	endif;
/*		
			self.drawAllFrames();		

	self.drawStyle := Frame.DrawStyle_Dot;
	self.drawWidth := 2;
	self.drawFillStyle := Frame.DrawFillStyle_DiagonalCross;
	self.drawFillColor := Red;
	self.drawFilledRectangle(self.origXPos, self.origYPos,self.lastMouseX, self.lastMouseY, Red);

		
	endif;
*/
end;</source>
        <Parameter name="frame" type="CMUI_ScrollableLabelsFrame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleLabelFrameMouseDown" id="bad5695f-3490-49a1-a2d4-b37d2e1af59e">
        <updating/>
        <source>handleLabelFrameMouseDown(frame: CMUI_ScrollableLabelsFrame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
begin
	if self.myYardGridAreaForm &lt;&gt; null then
		if not shift.isControlKeyPressed 
		and not shift.isShiftKeyPressed
		and not shift.isAltKeyPressed then
			self.myDrawingFrame.myOverlayDrawingFrame.allPoints.clear;
		endif;
		self.myYardGridAreaForm.setMyCurrentDrawingController(self, true);
	endif;



end;</source>
        <Parameter name="frame" type="CMUI_ScrollableLabelsFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="handleLabelFrameMouseMove" id="8e767b1a-fd00-4f2c-afbe-4dd4caaf0cde">
        <updating/>
        <source>handleLabelFrameMouseMove(frame: CMUI_ScrollableLabelsFrame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	return; // do later
	
	
	if self.myDrawingFrame.myOverlayDrawingFrame.visible then
		if button = Window.MouseButton_Left 
		and frame.dragMode &lt;&gt; CMUI_ScrollableLabelsFrame.DragMode_Drag
		and app.dragDetected(x, y, frame.origX, frame.origY) then
			frame.dragMode := CMUI_ScrollableLabelsFrame.DragMode_Drag;
			app.isDragging := true;
		endif;
	endif;

end;</source>
        <Parameter name="frame" type="CMUI_ScrollableLabelsFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="handleLabelFrameMouseUp" id="bee2b19b-c1b9-475c-8061-d69084a5b7a1">
        <updating/>
        <source>handleLabelFrameMouseUp(frame: CMUI_ScrollableLabelsFrame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	TopTextMargin	: Integer = 10;
	LeftTextMargin	: Integer = 5;

	TopMargin		: Integer = 10;
	BottomMargin	: Integer = 10;
	LeftMargin		: Integer = 10;
	RightMargin		: Integer = 10;
	RowSpacing		: Integer = 10;

	RowHeight		: Integer = 12;
	ColWidth		: Integer = 24;

vars
	tmpTA	: CM_GridArea;
	rowIdx,
	colIdx,rowNum,colNum	: Integer;
	theRowHeight,
	theColWidth,
	yPos1, yPos2,
	xPos1, xPos2	: Integer;	
begin
	
	tmpTA := self.myTerminalArea.CM_GridArea;
	if tmpTA = null then
		return;
	endif;
	
	if not self.myDrawingFrame.myOverlayDrawingFrame.visible then // PAR 10525 
		self.showRowColumnInfo((frame = self.myHLabels),x,y,true);
	
//		if (tmpTA.type = TA_TYPE_STRADDLE_STACK or tmpTA.type = TA_TYPE_RTG)	//SFW1030	
//		and self.myYardGridAreaForm.frmDeckingOrder.visible then
//			self.getDeckingRowHeight(frame);
//			self.myYardGridAreaForm.showDeckingFrame(0);
//		endif;
	else

		colNum := tmpTA.allGridColumns.size;
		rowNum := tmpTA.allGridRows.size;
		theColWidth	 := (ColWidth * self.scaleFactor).Integer;
		theRowHeight := (RowHeight * self.getHeightOfStack * self.scaleFactor).Integer;	// PAR 21532 CCMS SFW 1025
	
		if frame = self.myHLabels then
			yPos1 := self.LABELGAP;
			yPos2 := (rowNum * theRowHeight).Integer + self.LABELGAP + ((rowNum - 1) * RowSpacing).Integer;
			xPos2 := self.LABELGAP - 1;
			foreach colIdx in 1 to colNum do
				xPos1 :=  xPos2;
				xPos2 := xPos1 + theColWidth + self.columnSpacing;
				
				if x &gt;= xPos1 and x &lt;= xPos2 then
	//				tmpTA.allGridColumns[colIdx].inspect;
					self.myDrawingFrame.myOverlayDrawingFrame.doSelectColumnRow(xPos1,yPos1,xPos2,yPos2, true,false);
				endif;
				
			endforeach;
		elseif frame = self.myVLabels then
			xPos1 := self.LABELGAP;
			xPos2 := (colNum * theColWidth).Integer + self.LABELGAP + ((colNum - 1) * self.columnSpacing).Integer;
			yPos2 := self.LABELGAP - 1;
			foreach rowIdx in 1 to rowNum do
				yPos1 :=  yPos2;
				yPos2 := yPos1 + theRowHeight + RowSpacing;
				
				if y &gt;= yPos1 and y &lt;= yPos2 then
	//				tmpTA.allGridRows[rowIdx].inspect;
					yPos2 := yPos2 - RowSpacing;
					self.myDrawingFrame.myOverlayDrawingFrame.doSelectColumnRow(xPos1,yPos1,xPos2,yPos2 + 1,true,false);
				endif;
				
			endforeach;
				
		endif;
	endif;	
end;</source>
        <Parameter name="frame" type="CMUI_ScrollableLabelsFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="handleResize" id="125e4517-267a-4cc1-a2a1-2f124254a034">
        <source>handleResize();
// ---------------------------------------------------------------------------
// Created:		08 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.myDrawingFrame.handleResize();
end;</source>
    </JadeMethod>
    <JadeMethod name="hasGotItemAtHeight" id="446f1f2f-af10-4a85-8a5e-e7aed345d6ea">
        <source>hasGotItemAtHeight(_idx : Integer; _chkCurrentMode : Boolean) : Boolean;
// ---------------------------------------------------------------------------
// Created:     23 July 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 23JUL08			CNWAB1			Check for any Qd  items backends have already been drawn
// ---------------------------------------------------------------------------

vars

	startY,endX,
	endY, startX, tmpDiff	: Real;
	theFMLetter : String;
	theMode	, size	: Integer;
	isFMA40,
	isFMQ40,
	isFMP40		: Boolean;
	ti			: CM_TrackedItem;	
	tmpLC : CM_LocationsController;
	numActualTIs,  numQdTIs, numPdTIs, fmIndex : Integer;
begin
	tmpLC := self.myLocationsController;
	
	if tmpLC = null then
		return false;
	endif;

	if _chkCurrentMode and tmpLC.allTrackedItems.size &gt;= _idx then
		return true;
	endif;
	
	// ## PAR 23195 use this collection as this now contains the TIs the we are drawing A, Q and Ps
	size := self.allTempTIs.size;
	if size &gt;= _idx then
		return true;
	endif;
	
/*		PAR 23195
		size := tmpLC.allTrackedItems.size; // REAL
		if size &gt;= _idx then
			return true;
		endif;
		tmpLC.getAllQueuedTrackedItems(self.allTrackedItems, true, false);
		size := size + self.allTrackedItems.size; // QUEUED
		if size &gt;= _idx then
			return true;
		endif;
		tmpLC.getAllPlannedTrackedItems(self.allTrackedItems, true, false);
		size := size + self.allTrackedItems.size; //PLANNED
		if size &gt;= _idx then
			return true;
		endif;
	*/
	return false;
epilog

end;</source>
        <Parameter name="_idx" type="Integer"/>
        <Parameter name="_chkCurrentMode" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeAttribute" id="d0115187-e80a-492d-9bce-b2d3345e8854">
        <source>includeAttribute(_attrStr : String io): Boolean protected;
// ---------------------------------------------------------------------------
// Created:     03 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if _attrStr[1:12] = PicTIPlanned then
		if self.displayMode = DISPLAY_MODE_PLAN then
			if _attrStr.length &gt; 12 then
				if _attrStr[13:end].Integer = 1 then
					return false;
				endif;
			else
				return false;
			endif;
		endif;
	elseif _attrStr = PicTIQueued and
	   self.displayMode = DISPLAY_MODE_QUEUE then
		return false;
	endif;

	return inheritMethod(_attrStr);

end;</source>
        <access>protected</access>
        <Parameter name="_attrStr" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="init" id="cf10c410-f301-4abe-962b-9b96c794a35a">
        <updating/>
        <source>init(_terminalArea : CM_TerminalAreaMaster; _rows : CM_ObjectArray) updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 18/06/2020	jlgdap1		TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
vars
	yalloc : CM_YardAllocation;
	aRow : CM_GridRow;
begin
	self.myTerminalArea := _terminalArea;
	self.drawFromNote := false;
	self.setIgnoreSkin();
	if self.createHighlighter() then
		create self.myHighlighter;
	endif;

	if self.myTerminalArea &lt;&gt; null then
	
		self.myTerminal := self.myTerminalArea.myTerminal;
		self.yardGridAreaTranshipMark := self.myTerminal.getConfig(YardGridAreaTranshipMark).String;
		self.myDrawingAttrController.allYardAllocations.clear;
		
		if self.myTerminalArea.isKindOf(CM_GridArea) then
			// CCMS 1013
			//foreach yalloc in self.myTerminalArea.allYardAllocations discreteLock where yalloc.isDisabled = false do
			foreach yalloc in self.myTerminalArea.CM_GridArea.allYardAllocations discreteLock where not (yalloc.isDisabled or not yalloc.includeInYardDisplays()) do
				self.myDrawingAttrController.allYardAllocations.addNoDuplicates(yalloc,false);
			endforeach;
			self.heightOfStack	:= self.myTerminalArea.CM_GridArea.getHeightOfStack();
		elseif self.myTerminalArea.isKindOf(CM_RTGLane) then
			//self.heightOfStack := self.myTerminalArea.CM_RTGLane.getHeightOfStack();	// cnwdad1 13/03/2009 - Caused 1086 exception.
			self.heightOfStack := self.myTerminalArea.getHeightOfStack();
		else
		self.heightOfStack := 1;
		endif;
	else
		self.myTerminal := self.myDrawingFrame.form.CM_BaseForm.myTerminal;
	endif;
	
	 
	if self.myTerminal &lt;&gt; null then
		self.configAutoPlanUseAllocations := true;										//SFW1030 30/10/2008
		self.noteTAMove	:= self.myTerminal.getTerminalEvent(EVENT_TI_MOVE);
		//self.noteTALocationUpdate	:= self.myTerminal.getTerminalEvent(Event_TALocation_Update);			//-cnwml2 PAR21465
		self.noteTALocationCreate	:= self.myTerminal.getTerminalEvent(Event_TALocation_Create);
		self.noteTALocationDelete	:= self.myTerminal.getTerminalEvent(Event_TALocation_Delete);
		
		self.noteTAYardAllocationCreate	:= self.myTerminal.getTerminalEvent(Event_YardAllocationCreate);
		self.noteTAYardAllocationUpdate	:= self.myTerminal.getTerminalEvent(Event_YardAllocationUpdate);
		self.noteTAYardAllocationDelete	:= self.myTerminal.getTerminalEvent(Event_YardAllocationDelete);
		self.beginNotification(self.myTerminal, self.noteTAYardAllocationCreate, Response_Continuous, null);
		self.beginNotification(self.myTerminal, self.noteTAYardAllocationDelete, Response_Continuous, null);
		self.beginNotification(self.myTerminal, self.noteTAYardAllocationUpdate, Response_Continuous, null);
	
		self.noteTIUpdate := self.myTerminal.getTerminalEvent(TI_UPDATE_EVENT);
	
		self.noteTAReverseDecking	:= self.myTerminal.getTerminalEvent(EVENT_DECKING_CHANGE);
		
		self.noteTAUpdate := self.myTerminal.getTerminalEvent(Event_TerminalAreaUpdate);				// TFS 49453
	
	endif;

//	self.allLCsByOID.purge;
	self.allOIDSbyOIDString.purge;
	self.setIgnoreSkin();
	self.initColours();
end;</source>
        <Parameter name="_terminalArea" type="CM_TerminalAreaMaster"/>
        <Parameter name="_rows" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="initALL" id="d6dca4af-12c9-4581-a62d-e4c91b0481f1">
        <updating/>
        <source>initALL(_rows : CM_ObjectArray) updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed By	On			Reason
// ----------	--------	--------------------------------------------------
// 19/06/2020	jlgdap1		TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
vars
	yalloc : CM_YardAllocation;
	aRow : CM_GridRow;
	aTA : CM_TerminalArea;
begin
	self.drawFromNote := false;
	self.setIgnoreSkin();
	if self.createHighlighter() then
		create self.myHighlighter;
	endif;

	// ###
	self.myDrawingAttrController.allYardAllocations.clear;
	foreach aTA in self.allTerminalAreas do
		
		if  aTA.isKindOf(CM_GridArea) then
			foreach yalloc in aTA.CM_GridArea.allYardAllocations discreteLock where not (yalloc.isDisabled or not yalloc.includeInYardDisplays()) do
				self.myDrawingAttrController.allYardAllocations.addNoDuplicates(yalloc,false);
			endforeach;
			self.heightOfStack := aTA.CM_GridArea.getHeightOfStack();
		endif;
		
	endforeach;
	
	// ###
	self.myTerminal := self.myDrawingFrame.form.CM_BaseForm.myTerminal;
	 
	if self.myTerminal &lt;&gt; null then
		self.configAutoPlanUseAllocations := true;													//SFW1030 30/10/2008
		self.noteTAMove	:= self.myTerminal.getTerminalEvent(EVENT_TI_MOVE);
	//	self.noteTALocationUpdate	:= self.myTerminal.getTerminalEvent(Event_TALocation_Update);	//-cnwml2 PAR21465
		self.noteTALocationCreate	:= self.myTerminal.getTerminalEvent(Event_TALocation_Create);
		self.noteTALocationDelete	:= self.myTerminal.getTerminalEvent(Event_TALocation_Delete);
		
		self.noteTAYardAllocationCreate	:= self.myTerminal.getTerminalEvent(Event_YardAllocationCreate);
		self.noteTAYardAllocationUpdate	:= self.myTerminal.getTerminalEvent(Event_YardAllocationUpdate);
		self.noteTAYardAllocationDelete	:= self.myTerminal.getTerminalEvent(Event_YardAllocationDelete);
		self.beginNotification(self.myTerminal, self.noteTAYardAllocationCreate, Response_Continuous, null);
		self.beginNotification(self.myTerminal, self.noteTAYardAllocationDelete, Response_Continuous, null);
		self.beginNotification(self.myTerminal, self.noteTAYardAllocationUpdate, Response_Continuous, null);
	
		self.noteTIUpdate := self.myTerminal.getTerminalEvent(TI_UPDATE_EVENT);
	
		self.noteTAReverseDecking	:= self.myTerminal.getTerminalEvent(EVENT_DECKING_CHANGE);
		self.noteTAUpdate := self.myTerminal.getTerminalEvent(Event_TerminalAreaUpdate);				// TFS 49453
		
	endif;

	self.allOIDSbyOIDString.purge;
	self.initColours();
end;</source>
        <Parameter name="_rows" type="CM_ObjectArray"/>
    </JadeMethod>
