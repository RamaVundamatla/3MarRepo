    <JadeMethod name="isAllJobsWithStatus" id="fb69eecd-5db1-42f0-adc9-6008ff1a0f2a">
        <source>isAllJobsWithStatus(_jobStatus : Integer) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Apr 2023 navma1  ChangeRequest 55440:[54990] EUP - Release Cargo Work Order - Enhancement

*/

vars
	job :CM_Job;
begin
	foreach job in self.allJobs do
			if job.status &lt;&gt; _jobStatus  then
