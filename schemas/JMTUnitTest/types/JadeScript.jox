    <JadeMethod name="lwDeleteOperators" id="0e1e4485-d230-45a3-8052-3aa0921f869b">
        <source>lwDeleteOperators();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
29 January 2024	navlw1	delete operators that have been created multiple times

*/

vars
	dsl 		: UT_DSL;
	operator 	: CM_Operator;
begin
	app.initialize;
	create dsl as UT_DSL transient;
	dsl.setActiveProfileMDHONLY();
	foreach operator in app.myRoot.allOperators do 
		if operator.code &lt;&gt; "7C97" and operator.description = "TFS53854EUP" then
			dsl.deleteOperator(operator.code);
		endif;
	endforeach;
epilog
	delete dsl;
end;</source>
    </JadeMethod>
    <JadeMethod name="mdhBuildRunDetailsFromEmails" id="d64033ff-5c93-43fa-bf3a-67b56a82429f">
        <source>mdhBuildRunDetailsFromEmails();

/*

Purpose:		COnvert the email details to data	

Date			Who		Reason
25/07/2013		cnwmh5	Initial creation

*/

vars

	fileFolder					: FileFolder;
	fileNode					: FileNode;

	allFiles					: FileNodeArray;
	
	systemsToRunFor				: StringArray;
	
	systemID					: String;
	regenerate					: Boolean;
	
begin

	app.initialize();
	
	regenerate := true;
	if regenerate then
		beginTransaction;
		UM_UnitTestClassMethod.instances.purge;
		UM_UnitTestResult.instances.purge();
		UM_UnitTestRun.instances.purge();
		commitTransaction;
	endif;
	
	create allFiles transient;
	
	// setup the systems to run for
	create systemsToRunFor transient;
	systemsToRunFor.add(CM_Version.VERSION);
	
	foreach systemID in systemsToRunFor do
	
		// check that the folder exists
		delete fileFolder;
		create fileFolder transient;
		fileFolder.fileName := "c:\JMTUnitTestResults\" &amp; systemID &amp; "\Email_Files";
		if not fileFolder.isValidPathName(fileFolder.fileName) or not fileFolder.isAvailable() then
			write "Unable to find directory (" &amp; fileFolder.fileName &amp; ")";
			continue;
		endif;
	
		// get the files in the directory
		allFiles := fileFolder.files();
	
		foreach fileNode in allFiles do
		
			// don't care about directory's
			if not fileNode.isKindOf(File) then
				continue;
			endif;
			
			// don't want anything that doesn't have an exension of eml.
			if fileNode.fileName[fileNode.fileName.length - 3: end] &lt;&gt; ".eml" then
				continue;
			endif;
			
			// process the data
			self.processEmailData(fileNode.fileName, null);
			
		endforeach;
	
	endforeach;
	
epilog

	delete systemsToRunFor;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhCM_TIRequestInvalidTI" id="88595d90-1e1d-4ebb-a888-9bb9b3bb4673">
        <source>mdhCM_TIRequestInvalidTI();

/*

Purpose:		

Date			Who		Reason
07/05/2014		cnwmh5	Initial creation

*/

vars

	tiRequest					: CM_TIRequest;

begin

	foreach tiRequest in CM_TIRequest.instances do
	
		if tiRequest.creationTime.date &lt;&gt; "06/05/2014".Date then
			continue;
		endif;
	
		//if tiRequest &lt;&gt; null and not global.isValidObject(tiRequest.trackedItem) then
		
			if tiRequest.myJob &lt;&gt; null and tiRequest.myJob.getMyTerminal().code = "UT" then
				write tiRequest.identity.String &amp; Tab &amp; tiRequest.creationTime.String &amp; Tab &amp; 
					tiRequest.myJob.String &amp; Tab &amp; tiRequest.myJob.id &amp; Tab &amp; 
					tiRequest.myJob.getMyTerminal().code &amp; Tab &amp; global.isValidObject(tiRequest.trackedItem).String;
			endif;
			if tiRequest.bulkRelease &lt;&gt; null and tiRequest.bulkRelease.myTerminal.code = "UT" then
				write tiRequest.identity.String &amp; Tab &amp; tiRequest.creationTime.String &amp; Tab &amp; 
					tiRequest.bulkRelease.String &amp; Tab &amp; tiRequest.bulkRelease.code &amp; Tab &amp; 
					tiRequest.bulkRelease.myTerminal.code &amp; Tab &amp; global.isValidObject(tiRequest.trackedItem).String;
			endif;
		//endif;
	
	endforeach;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhChangedSinceLastCut" id="2fac4139-af08-457d-86c8-9c4a73b77410">
        <source>mdhChangedSinceLastCut();

/*

Purpose:			

Date			Who		Reason
18/11/2015		cnwmh5	Initial creation

*/

vars

	root						: UM_Root;
	classMethod					: UM_UnitTestClassMethod;
	result						: UM_UnitTestResult;
	file						: File;
			
	dynaDict					: DynaDictionary;
	detailsArray				: StringArray512;
	tokens						: HugeStringArray;
	
	iter						: Iterator;

	lastCutTS					: TimeStamp;
	resultStr					: String;
	line						: String;
	pos							: Integer;
	detailsStr					: String;
	pos2						: Integer;
	index						: Integer;
	tempDate					: Date;
	tempLine					: String;
	tempLineStart				: String;
	tempLineEnd					: String;
	dateStr						: String;
		
begin

	root := UM_Root.firstInstance;
	if root = null then
		app.msgBox("Unable to find instance of UM_Root.  Exiting Jadescript...", "UM_Root Error", 
			MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;

	create dynaDict transient;
	dynaDict.setMembership(StringArray512);
	dynaDict.addExternalKey(String, 300, false, true);					// Class method user date time
	dynaDict.endKeys(true);
	
	create tokens transient;
	
	lastCutTS.setDate("22/10/2015".Date);
	lastCutTS.setTime("15:32:00".Time);
	
	classMethod := root.allRunnableUTClassesMethods["UT_Verification_Admin", "vCheckChangedMethCalledByUT"];
	if classMethod = null then
		app.msgBox("Unable to find instance of UT_Verification_Admin::vCheckChangedMethCalledByUT.  Exiting Jadescript...", 
			"UT_Verification_Admin::vCheckChangedMethCalledByUT Error", MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	iter := classMethod.allUnitTestResults.createIterator;
	while iter.next(result) do
		if result.myTestRun.startTS.date &lt; lastCutTS.date or 
				(result.myTestRun.startTS.date = lastCutTS.date and 
				result.myTestRun.startTS.time &lt; lastCutTS.time) then
			break;
		endif;
		
		detailsStr := null;
		
		resultStr := result.details.uncompressToString().trimBlanks();
		if resultStr = null then
			continue;
		endif;
		
		pos := 1;
		while true do
			line := resultStr.cnEcGetNextLine(pos);
			if pos = 0 then
				break;
			endif;
			
			// if this found don't care
			if line.cnContains("The following changed methods ARE called by an Automated Test:") then
				break;
			endif;
			
			if line.cnContains("The following changed methods ARE NOT called by an Automated Test:") or line = null then
				continue;
			endif;
			
			detailsStr := line;
			if detailsStr.length = 0 then
				continue;
			endif;
		
			pos2 := 1;
			detailsStr.scanUntil(" ", pos2);
			line := detailsStr[pos2 + 1:end];
			
			// reformat the date
			tokens.clear();
			line.getTokensForDelimiterHuge(" ", tokens);
			tempDate := (tokens[4] &amp; " " &amp; tokens[5] &amp; " " &amp; tokens[6][1:tokens[6].length-1]).Date;
			
			create detailsArray transient;
			detailsArray.add(tokens[1] &amp; " " &amp; tokens[2] &amp; " " &amp; tokens[3] &amp; " " &amp; 
				tempDate.format("dd/MM/yyyy") &amp; " " &amp; tokens[tokens.size]);
			dynaDict.putAtKey(line, detailsArray);
			
		endwhile;
		
	endwhile;
	
	create file transient;
	file.fileName := "c:\temp\ChangedSinceLastCut.csv";
	if file.isAvailable() then
		file.purge();
	endif;
	file.writeLine("class,method,changed by,date,time");
	
	delete iter;
	iter := dynaDict.createIterator;
	while iter.next(detailsArray) do
	
		dynaDict.getIteratorKeys(line, iter);
		
		tokens.clear();
		detailsStr := null;
		detailsArray[1].getTokensForDelimiterHuge(" ", tokens);
				
		foreach index in 1 to tokens.size step 1 do
			if index &gt; 1 then 
				detailsStr := detailsStr &amp; ",";
			endif;
			detailsStr := detailsStr &amp; tokens[index];
		endforeach;
		file.writeLine(detailsStr);
	
	endwhile;
	
epilog

	delete iter;
	delete dynaDict;
	delete tokens;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="mdhChangedSinceLastCutAll" id="45d0f9a7-e502-41c4-b03a-b3ec7430ecff">
        <source>mdhChangedSinceLastCutAll();

/*

Purpose:			

Date			Who		Reason
23/11/2015		cnwmh5	Initial creation

*/

vars

	schema						: Schema;
	type						: Type;
	meth						: Method;
	meth2						: Method;
	usage						: UM_MethodPropertyUsage;
	unitTestResult 				: UM_UnitTestResult;
	file						: File;
	
	methodsToCheckDict			: DynaDictionary;

	schemaColl					: SchemaColl;
	schemasToRemoveArray		: StringArray;
	classColl					: ClassColl;
	methDict					: MethodNDict;
	typeColl					: TypeColl;
	notFoundArray				: HugeStringArray;
	foundArray					: HugeStringArray;
	
	iter						: Iterator;
	iterMeth					: Iterator;
	
	tempStr						: String;
	ts							: TimeStamp;
	className					: String;
	methodName					: String;
	level						: Integer;
	methodClassName				: String;
	methodMethodName			: String;
	usedByFormUnitTest			: Character;
	unitTestsUsedBy				: String;
	result						: String;
	methStartTS					: TimeStamp;
	methEndTS					: TimeStamp;
	elapsedTime					: TimeStampInterval;
	str							: String;
	
begin

	result := "FAIL";
	
	methStartTS := app.cnGetServerTime();

	create schemaColl transient;
	
	create schemasToRemoveArray transient;
	schemasToRemoveArray.add("JRWInterfaceSchema");
	schemasToRemoveArray.add("JMTUnitTest");
	schemasToRemoveArray.add("PortDumpLoadSchema");
	schemasToRemoveArray.add("PortTestSchema");
	schemasToRemoveArray.add("DevSchema");
	schemasToRemoveArray.add("ExcelPackEvaluation");
	schemasToRemoveArray.add("HotFixesCommonSchema");
	schemasToRemoveArray.add("Patterns");
	schemasToRemoveArray.add("TestProduct");
	schemasToRemoveArray.add("YorkServer");
	schemasToRemoveArray.add("JtdCommonSchema");
	schemasToRemoveArray.add("JtdDriverSchema");
	
	create methodsToCheckDict transient;
	methodsToCheckDict.setMembership(Method);
	methodsToCheckDict.addExternalKey(String, 50, false, false);						// Class Name
	methodsToCheckDict.addExternalKey(String, 50, false, false);						// Method Name
	methodsToCheckDict.endKeys(false);
	
	create usage transient;
	create notFoundArray transient;
	create foundArray transient;

	// set the ts so can work out if changed in the valid period
	//ts := app.cnGetServerTime();
	//ts := ts.addDays(-1);	
	ts.setDate("22/10/2015".Date);
	ts.setTime("15:32:00".Time);
	
	schema := rootSchema.getSchema("PortSchema");
	if schema = null then
		write "Unable to find Schema PortSchema.  Exiting JadeScript...";
		return;
	endif;
	schemaColl.add(schema);
	schema.allSubschemas(schemaColl);
	
	// get the methods that we need to check
	foreach schema in schemaColl do
		if schemasToRemoveArray.includes(schema.name) then
			continue;
		endif;
		
		// get the classes and primatives to check
		delete typeColl;
		delete classColl;
		typeColl := schema.allPrimitives();
		classColl := schema.allClasses();
		classColl.copy(typeColl);
		
		foreach type in typeColl do
			if type.schema.name &lt;&gt; schema.name then
				continue;
			endif;
			
			if type.name = "JadeScript" then				// 20/082015 cnwmh5 - don't need to check JadeScript
				continue;
			endif;
			
			methDict := type.cnGetMethods();
			
			foreach meth in methDict do
				if meth.getSchema() &lt;&gt; schema or meth.cnGetModifiedTimeStamp() &lt; ts then
					continue;
				endif;
				if not methodsToCheckDict.includesKey(meth.getSchemaType().name, meth.name) then
					methodsToCheckDict.putAtKey(meth.getSchemaType().name, meth.name, meth);		
				endif;
			endforeach;
			
		endforeach;

	endforeach;
	
	
	create file transient;
	file.fileName := "c:\temp\ChangedSinceLastCutAll.csv";
	if file.isAvailable() then
		file.purge();
	endif;
	file.writeLine("schema,class,method,changed by,date,time");
	
	delete iter;
	iter := methodsToCheckDict.createIterator;
	while iter.next(meth) do
	
		methodsToCheckDict.getIteratorKeys(methodClassName, methodMethodName, iter);
		
		//tokens.clear();
		//detailsStr := null;
		//detailsArray[1].getTokensForDelimiterHuge(" ", tokens);
				
		//foreach index in 1 to tokens.size step 1 do
		//	if index &gt; 1 then 
		//		detailsStr := detailsStr &amp; ",";
		//	endif;
		//	detailsStr := detailsStr &amp; tokens[index];
		///endforeach;
		//file.writeLine(detailsStr);
		file.writeLine(meth.getSchemaType().schema.name &amp; ',' &amp;
			methodClassName &amp; "," &amp; methodMethodName &amp; ',' &amp; 
			meth.cnGetModifierName().String &amp; ',' &amp; 
			meth.cnGetModifiedTimeStamp().date.format("dd/MM/yyyy") &amp; "," &amp; 
			meth.cnGetModifiedTimeStamp().time.String);
	
	endwhile;
	
	
	/*
	// check these methods
	iter := methodsToCheckDict.createIterator;
	while iter.next(meth) do
	
		methodsToCheckDict.getIteratorKeys(className, methodName, iter);
		
		level := 1;
		usage.clearCollections(true);
		usage.setCurrentMethod(meth);
		usage.addMethodToList(meth, level, true);
	
		unitTestsUsedBy := null;
		delete iterMeth;
		iterMeth := usage.tempDictionary.createIterator;
		while iterMeth.next(meth2) do
			usage.tempDictionary.getIteratorKeys(className, methodName, methodClassName, methodMethodName, usedByFormUnitTest, iterMeth);
			if usedByFormUnitTest = "U" then
				if unitTestsUsedBy &lt;&gt; null then
					unitTestsUsedBy := unitTestsUsedBy &amp; ", ";
				endif;
				unitTestsUsedBy := unitTestsUsedBy &amp; meth2.getSchemaType().name &amp; "::" &amp; meth2.name;
			endif;
		endwhile;
		
		if unitTestsUsedBy = null then
			app.writeLog(meth.String &amp; Tab &amp; meth.getSchemaType().name &amp; Tab &amp; meth.name &amp; Tab &amp; 
				meth.cnGetModifierName() &amp; Tab &amp; meth.cnGetModifiedTimeStamp().String, LogAlways);
			///write meth.String &amp; Tab &amp; meth.getSchemaType().name &amp; Tab &amp; meth.name &amp; Tab &amp; 
			///		meth.cnGetModifierName() &amp; Tab &amp; meth.cnGetModifiedTimeStamp().String;
			notFoundArray.add(meth.String &amp; Tab &amp; meth.getSchemaType().name &amp; Tab &amp; meth.name &amp; Tab &amp; 
					meth.cnGetModifierName() &amp; Tab &amp; meth.cnGetModifiedTimeStamp().String);
		else
			app.writeLog(meth.String &amp; Tab &amp; meth.getSchemaType().name &amp; Tab &amp; meth.name &amp; Tab &amp; 
				meth.cnGetModifierName() &amp; Tab &amp; meth.cnGetModifiedTimeStamp().String &amp; CrLf &amp;
				unitTestsUsedBy, LogAlways);
			foundArray.add(meth.String &amp; Tab &amp; meth.getSchemaType().name &amp; Tab &amp; meth.name &amp; Tab &amp; 
					meth.cnGetModifierName() &amp; Tab &amp; meth.cnGetModifiedTimeStamp().String);
		endif;
		
	endwhile;
	
	if not notFoundArray.isEmpty() then
		tempStr	:=  CrLf &amp; "The following changed methods ARE NOT called by an Automated Test:" &amp; CrLf;
		foreach str in notFoundArray do
			tempStr := tempStr &amp; CrLf &amp; str;
		endforeach;
	else
		result := "PASS";
	endif;
	
	// 27/07/2015 cnwmh5
	if not foundArray.isEmpty() then
		tempStr	:=  tempStr &amp; CrLf &amp; CrLf &amp; "The following changed methods ARE called by an Automated Test:" &amp; CrLf;
		foreach str in foundArray do
			tempStr := tempStr &amp; CrLf &amp; str;
		endforeach;	
	endif;
	
	// create a unit test record
	beginTransaction;
	create unitTestResult persistent;			
	
	methEndTS := app.cnGetServerTime();
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;
	
	tempStr := tempStr.replaceString(Tab, " ");
	
	unitTestResult.updateDetails(method.getSchemaType().name, method.name, (elapsedTime.getMilliseconds/1000).String, 
		"", app.getUTAdminUserCode(), result, tempStr, methStartTS, _unitTestRun);
	unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
	commitTransaction;
	*/
	
epilog

	delete schemaColl;
	delete methodsToCheckDict;
	delete classColl;
	delete typeColl;
	delete iter;
	delete iterMeth;
	delete usage;
	delete notFoundArray;
	delete foundArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="mdhChangedSinceSpecifiedDate" id="715b1328-8843-4aaa-a991-d8226681e88a">
        <source>mdhChangedSinceSpecifiedDate();

/*

Purpose:		Get the changed details from a specified date	

Date			Who		Reason
06/09/2016		cnwmh5	Initial creation

*/
constants

	DifferencesTag				: String = "Differences";
	SchemasTag					: String = "Schemas";
	ClassesTag					: String = "Classes";
	ConstantsTag				: String = "Constants";
	PropertiesTag				: String = "Properties";
	MethodsTag					: String = "Methods";
	SourceTag					: String = "Source";
	ChangedDateTag				: String = "ChangedDate";
	ChangedTimeTag				: String = "ChangedTime";
	ChangedByTag				: String = "ChangedBy";
	GlobalsTag					: String = "Globals";

vars

	schema						: Schema;
	meth						: Method;
	klass						: Class;
	obj							: Object;
	type						: Type;
	prop						: Property;
	constant					: Constant;
	fileFolder					: FileFolder;
	file						: File;
	globalConst					: GlobalConstant;
	
	xmlDoc						: JadeXMLDocument;
	elementDifferences			: JadeXMLElement;
	elementSchemas				: JadeXMLElement;
	elementSchema				: JadeXMLElement;
	elementClasses				: JadeXMLElement;
	elementClass				: JadeXMLElement;
	elementConstants			: JadeXMLElement;
	elementMethods				: JadeXMLElement;
	elementProperties			: JadeXMLElement;	
	elementMethod				: JadeXMLElement;
	elementProperty				: JadeXMLElement;
	elementConstant				: JadeXMLElement;
	element						: JadeXMLElement;
	elementGlobals				: JadeXMLElement;
	elementCategories			: JadeXMLElement;
	
	classMethWithDiff			: DynaDictionary;
	globalConstWithDiff			: DynaDictionary;
	
	schemaColl					: SchemaColl;
	classColl					: ClassColl;
	methDict					: MethodNDict;
	typeColl					: TypeColl;
	constDict					: ConstantNDict;
	propertyColl				: PropertyColl;
	
	iter						: Iterator;
	
	tsToCheckFrom				: TimeStamp;
	schemaName					: String;
	methodConstName				: String;
	className					: String;
	currentClassName			: String;
	currentSchemaName			: String;
	objType						: String;
	currentObjType				: String;
	source						: String;
	changedTS					: TimeStamp;
	changedBy					: String;
	constType					: String;
	constText					: String;
	constDefinition				: String;
	categoryName				: String;
	currentCategoryName			: String;
	globalConstName				: String;
	version						: String;

begin

	// setup timestamp to check from
	tsToCheckFrom.setDate("30/07/2015".Date);
	tsToCheckFrom.setTime("00:00:00".Time);
	
	create xmlDoc transient;
	elementDifferences := xmlDoc.addElement(DifferencesTag);
	elementGlobals := elementDifferences.addElement(GlobalsTag);
	elementSchemas := elementDifferences.addElement(SchemasTag);
	
	create fileFolder transient;
	fileFolder.usePresentationFileSystem := true;
	fileFolder.fileName := "C:\temp\CheckSource";
	if not fileFolder.isAvailable() then
		fileFolder.make();
	endif;
	
	version := CM_Version.VERSION;
	version := version.replaceString(".", "");
	
	create file transient;
	file.fileName := fileFolder.fileName &amp; "\" &amp; version &amp; "SourceChanges.xml";
	if file.isAvailable() then
		file.purge();
	endif;
	
	// get the global constant differences
	create globalConstWithDiff transient;
	globalConstWithDiff.setMembership(Object);
	globalConstWithDiff.addExternalKey(String, 64, false, false);						// Category Name
	globalConstWithDiff.addExternalKey(String, 64, false, false);						// Constant Name
	globalConstWithDiff.endKeys(false);
	
	foreach globalConst in GlobalConstant.instances discreteLock do
		if globalConst.cnGetModifiedTimeStamp() &lt; tsToCheckFrom then
			continue;
		endif;
		categoryName := globalConst.getCategory().name;
		if not globalConstWithDiff.includesKey(categoryName, globalConst.name) then
			globalConstWithDiff.putAtKey(categoryName, globalConst.name, globalConst);		
		endif;
	endforeach;
	
	delete iter;
	iter := globalConstWithDiff.createIterator;
	while iter.next(globalConst) do
	
		changedBy := globalConst.cnGetModifierName();
		changedTS := globalConst.cnGetModifiedTimeStamp();
		constType := globalConst.getType().name;
		constDefinition := globalConst.getSource();
		constText := globalConst.text;
		
		globalConstWithDiff.getIteratorKeys(categoryName, globalConstName, iter);
				
		if currentCategoryName &lt;&gt; categoryName then
			elementCategories := elementGlobals.addElement(categoryName);
			currentCategoryName := categoryName;		
		endif;
		
		elementConstant := elementCategories.addElement(globalConstName);
		element := elementConstant.addElement(ChangedDateTag);
		element.setText(changedTS.date.format("dd/MM/yyyy"));
		element := elementConstant.addElement(ChangedTimeTag);
		element.setText(changedTS.time.String);
		element := elementConstant.addElement(ChangedByTag);
		element.setText(changedBy);
		element := elementConstant.addElement("Type");
		element.setText(constType);
		element := elementConstant.addElement("Definition");
		element.setText(constDefinition);
		element := elementConstant.addElement("Text");
		element.addCDATA(constText);
		
	endwhile;
	
	// Get the changed class details
	create classMethWithDiff transient;
	classMethWithDiff.setMembership(Object);
	classMethWithDiff.addExternalKey(String, 64, false, false);						// Schema Name
	classMethWithDiff.addExternalKey(String, 64, false, false);						// Class Name
	classMethWithDiff.addExternalKey(String, 64, false, false);						// Method / Constant / Primative Name
	classMethWithDiff.endKeys(false);

	// get all schemas from Root Schema down
	create schemaColl transient;
	rootSchema.allSubschemas(schemaColl);
	
	foreach schema in schemaColl do
	
		if schema.name[1:4] = "Jade" then
			continue;
		endif;
	
		delete typeColl;
		delete classColl;
		typeColl := schema.allPrimitives();
		classColl := schema.allClasses();
		classColl.copy(typeColl);
		
		foreach type in typeColl do
			if type.schema.name &lt;&gt; schema.name then
				continue;
			endif;
			
			// get the changed methods
			methDict := type.cnGetMethods();
			foreach meth in methDict do
				if meth.getSchema() &lt;&gt; schema or meth.cnGetModifiedTimeStamp() &lt; tsToCheckFrom then
					continue;
				endif;
				if not classMethWithDiff.includesKey(meth.getSchema().name, meth.getSchemaType().name, meth.name) then
					classMethWithDiff.putAtKey(meth.getSchema().name, meth.getSchemaType().name, meth.name, meth);		
				endif;
			endforeach;
			
			// class constants
			delete constDict;
			create constDict transient;
			type.getConstants(constDict);
			foreach constant in constDict do
				if constant.cnGetModifiedTimeStamp() &lt; tsToCheckFrom then
					continue;
				endif;
				if not classMethWithDiff.includesKey(meth.getSchema().name, meth.getSchemaType().name, constant.name) then
					classMethWithDiff.putAtKey(meth.getSchema().name, meth.getSchemaType().name, constant.name, constant);		
				endif;
			endforeach;
			
			// class properties
			delete propertyColl;
			propertyColl := type.Class.allProperties;
			foreach prop in propertyColl do
				
				if prop.cnGetModifiedTimeStamp() &lt; tsToCheckFrom then
					continue;
				endif;
				
				if not classMethWithDiff.includesKey(meth.getSchema().name, meth.getSchemaType().name, prop.name) then
					classMethWithDiff.putAtKey(meth.getSchema().name, meth.getSchemaType().name, prop.name, prop);	
				endif;
				
			endforeach;
			
		endforeach;
		
	endforeach;
	
	delete iter;
	iter := classMethWithDiff.createIterator;
	while iter.next(obj) do
	
		constant := null;
		meth := null;
		prop := null;
		if obj.isKindOf(Constant) then
			constant := obj.Constant;
			changedBy := constant.cnGetModifierName();
			changedTS := constant.cnGetModifiedTimeStamp();
			constType := constant.getType().name;
			constDefinition := constant.getSource();
			constText := constant.text;
		elseif obj.isKindOf(Method) then
			meth := obj.Method;
			source := meth.getSource();
			changedBy := meth.cnGetModifierName();
			changedTS := meth.cnGetModifiedTimeStamp();
		else
			prop := obj.Property;
			changedBy := prop.cnGetModifierName();
			changedTS := prop.cnGetModifiedTimeStamp();
		endif;
	
		classMethWithDiff.getIteratorKeys(schemaName, className, methodConstName, iter);
				
		if currentSchemaName &lt;&gt; schemaName then
			elementSchema := elementSchemas.addElement(schemaName);
			elementClasses := elementSchema.addElement(ClassesTag);
			currentSchemaName := schemaName;		
		endif;
		
		if currentClassName &lt;&gt; className then
			elementClass := elementClasses.addElement(className);
			elementConstants := elementClass.addElement(ConstantsTag);
			elementProperties := elementClass.addElement(PropertiesTag);
			elementMethods := elementClass.addElement(MethodsTag);
			currentClassName := className;
		endif;
		
		if meth &lt;&gt; null then
			elementMethod := elementMethods.addElement(meth.name);
			element := elementMethod.addElement(ChangedDateTag);
			element.setText(changedTS.date.format("dd/MM/yyyy"));
			element := elementMethod.addElement(ChangedTimeTag);
			element.setText(changedTS.time.String);
			element := elementMethod.addElement(ChangedByTag);
			element.setText(changedBy);
			element := elementMethod.addElement(SourceTag);
			element.addCDATA(source);
		elseif constant &lt;&gt; null then
			elementConstant := elementConstants.addElement(constant.name);
			element := elementConstant.addElement(ChangedDateTag);
			element.setText(changedTS.date.format("dd/MM/yyyy"));
			element := elementConstant.addElement(ChangedTimeTag);
			element.setText(changedTS.time.String);
			element := elementConstant.addElement(ChangedByTag);
			element.setText(changedBy);
			element := elementConstant.addElement("Type");
			element.setText(constType);
			element := elementConstant.addElement("Definition");
			element.setText(constDefinition);
			element := elementConstant.addElement("Text");
			element.addCDATA(constText);
		else
			elementProperty := elementProperties.addElement(prop.name);
			element := elementProperty.addElement(ChangedDateTag);
			element.setText(changedTS.date.format("dd/MM/yyyy"));
			element := elementProperty.addElement(ChangedTimeTag);
			element.setText(changedTS.time.String);
			element := elementProperty.addElement(ChangedByTag);
			element.setText(changedBy);
		endif;
		
	endwhile;
		
	xmlDoc.writeToFile(file.fileName);
	

epilog

	schemaColl.clear();
	delete schemaColl;

	delete classColl;
	delete typeColl;
	///delete methDict;
	delete classMethWithDiff;
	delete iter;
	delete constDict;
	delete xmlDoc;
	
	delete file;
	delete fileFolder;
	delete propertyColl;
	
	delete globalConstWithDiff;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="mdhCheckForStackDumps" id="2fce322e-c4ed-4aa3-a308-5c4de5b52710">
        <source>mdhCheckForStackDumps();

/*

Purpose:		

Date			Who		Reason
17 February 2017	cnwmh5	Initial creation

*/

vars

	verAdmin 					: UT_Verification_Admin;
		
	userSummaryDict				: CM_AssociationDict;
	
	startTS						: TimeStamp;
	endTS						: TimeStamp;

begin

	app.initialize();
	
	startTS := app.actualTimeAppServer();
	startTS.setTime("01:00:00".Time);
	endTS := app.actualTimeAppServer();
	endTS.setTime("06:05:00".Time);
	
	create verAdmin transient;
	create userSummaryDict transient;
	userSummaryDict.clear();
	verAdmin.sendMsgWithIOParams("vCheckForStackDumps_MDH", startTS, endTS, userSummaryDict);

epilog

	delete userSummaryDict;
	delete verAdmin;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhCheckNonASCIIConvert" id="b876710a-7ff9-482b-9a11-b0d5272318b4">
        <updating/>
        <source>mdhCheckNonASCIIConvert() updating;
/*

Purpose:		Find the non ASCII character which is trying to be emailed	

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2019	jlgmh5:1	Initial creation
17 Oct 2025	navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2

*/

vars

	testRun						: UM_UnitTestRun;
	testResult					: UM_UnitTestResult;
	
	mergeIter					: MergeIterator;
	
	resultStr					: String;
	linePtr						: Integer;

begin

	app.initialize;
	
	testRun := UM_UnitTestRun.lastInstance;
	
	create mergeIter transient;
	mergeIter.addCollection(testRun.allFailed);
	mergeIter.addCollection(testRun.allPassed);
	mergeIter.addCollection(testRun.allIgnored);

	beginTransaction;
	while mergeIter.next(testResult) do
	
		resultStr := testResult.details.uncompressToString().trimBlanks();
		//write resultStr;
		
		
		testResult.updateDetails(testResult.myClassMethod.className, testResult.myClassMethod.methodName, testResult.elapsedTime, 
			testResult.emailedTo, testResult.ownerName, testResult.getResultDetails(testResult.result).String, resultStr, testResult.methodRunStartTS, testResult.myTestRun, null);		//17.10.2025 navbs1  #34979
		
		
		resultStr := testResult.details.uncompressToString().trimBlanks();
		write resultStr;
		
		/*
		linePtr			:=	1;

        while linePtr &lt;= resultStr.length do
        	if resultStr[linePtr].Character.Integer &gt; 127 or resultStr[linePtr].Character.Integer = null then
	    		//raiseValidationException(Err_Non_ASCII_Character, className &amp; " The message contains a non-ASCII character in the following line (" &amp; line &amp; ")");//V4
				write testResult.String &amp; Tab &amp; "linePtr: " &amp; linePtr.String &amp; Tab &amp; testResult.myClassMethod.className &amp; Tab &amp; 
					testResult.myClassMethod.methodName &amp; CrLf &amp; resultStr &amp; CrLf &amp; CrLf;
        	endif;
        	linePtr		:=	linePtr + 1;
        endwhile;
		*/
		
	endwhile;
	commitTransaction;

epilog
	
	delete mergeIter;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhCheckStripNONASCIIWorks" id="a3605e51-cd69-43aa-8012-541ac06d959c">
        <source>mdhCheckStripNONASCIIWorks();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2019	jlgmh5:1	Initial creation

*/

vars

	testResult					: UM_UnitTestResult;
	
	resultStr					: String;
	tempStr						: String;
	
begin

	app.initialize();

	testResult := "12254.2576162".asObject().UM_UnitTestResult;
	if testResult = null then
		return;
	endif;
	
	resultStr := testResult.details.uncompressToString().trimBlanks();
	
	write 'BEFORE' &amp; CrLf &amp; resultStr &amp; CrLf;
	
	tempStr := testResult.stripNONASCIICharacters(resultStr);
	
	write 'AFTER' &amp; CrLf &amp; tempStr &amp; CrLf;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhCheckTrx1stLine" id="156aee6c-4716-413b-99b2-fe3c18ab22f3">
        <source>mdhCheckTrx1stLine();

/*

Purpose:		Check for trxs methods have initialise as the first line of code	

Date			Who		Reason
11/10/2012		cnwmh5	Initial creation

*/

vars

	schema							: Schema;
	klass							: Class;
	meth							: Method;
	
	classes							: ClassColl;
	methodsDict						: MethodNDict;
	methodsToIgnore					: StringArray;
	
	initActWithPassport				: StringArray;
	
	beginFound						: Boolean;
	lineCount						: Integer;
	linePos							: Integer;
	posSlash						: Integer;
	line 							: String;
	initialiseFound					: Boolean;
	returnFound						: Boolean;
	epilogFound						: Boolean;

begin

	app.initialize();

	// get the schema
	schema := rootSchema.getSchema("PortSchema");
	///self.assertNotNullMsg(schema, "Unable to find schema (PortSchema)");
	if schema = null then
		write 'Unable to find schema (PortSchema)';
		return;
	endif;
		
	// get the class
	klass := schema.getClass("CM_TrxControlAgent");
	//self.assertNotNullMsg(klass, "Unable to find class (CM_TrxControlAgent)");
	if klass = null then
		write "Unable to find class (CM_TrxControlAgent)";
	endif;
	
	create initActWithPassport transient;
	create methodsToIgnore transient;
	///*
	methodsToIgnore.add("trxImportCustomsAgent");
	methodsToIgnore.add("trxImportDebtorNode");
	methodsToIgnore.add("trxImportServiceObject");
	methodsToIgnore.add("trxImportShippingAgent");
	methodsToIgnore.add("trxLoadErrMsgsGlbConstsExtUser");
	methodsToIgnore.add("trxLoadErrMsgsFromGlbConsts");
	methodsToIgnore.add("trxMoveTrackedItemAssignToJobU");
	methodsToIgnore.add("trxSetupCams");
	methodsToIgnore.add("trxUpdateMovePlan");
	methodsToIgnore.add("trxUpdateSlotRequestAttribute");
	methodsToIgnore.add("trxUpdateSlotRequestLoadCC");
	methodsToIgnore.add("trxMoveTIsAUTOAssignToJob");
	methodsToIgnore.add("trxUpdateYALastBlock");
	methodsToIgnore.add("trxUpdateYAGroupLastBlock");
	methodsToIgnore.add("trxCreateProformaInvoiceLines");
	//*/
	//methodsToIgnore.add("trxUpdateBOL");
	
	// get the classes to check
	create classes transient;
	klass.allLocalSubclasses(classes);
	
	// read through the classes
	foreach klass in classes do
		
		// get the methods
		methodsDict := klass.cnGetMethods();
			
		// process the methods
		foreach meth in methodsDict do
		
			// don't care about it if the method name doesn't start with trx
			if meth.name[1:3] &lt;&gt; "trx" then
				continue;
			endif;
		
			// check to see if there are any methods to ignore
			if methodsToIgnore.includes(meth.name) then
			//if not methodsToIgnore.includes(meth.name) then								/// testing only
				continue;
			endif;		
		
			beginFound := false;
			initialiseFound := false;
			returnFound := false;
			epilogFound := false;
			lineCount := 0;
			linePos := 1;
			while linePos &gt; 0 do
				line := meth.getSource.cnEcGetNextLine(linePos);
				if not beginFound then
					// haven't found the begin code yet so check to see if we have and update
					// variables accordingly
					if line[1:5] = "begin" then
						beginFound := true;
					endif;
					continue;
				else
					// found begin code so now start checking what the first line of code is
					// don't care about blank lines
					line.cnReplaceString(Tab, "");
					if line.trimBlanks = null then
						continue;
					endif;
					// if we hit the epilog then don't care either
					if line.cnContains("epilog") then
						linePos := -1;
						epilogFound := true;
						continue;
					endif;
					// don't care if its this comment
					if line.cnContains("// Always initialize the activity first") then
						continue;
					endif;
					// check to see if there is any code before the comment
					posSlash := line.pos("//", 1);
					if posSlash &gt; 0 and line[1:posSlash-1] = null then
						continue;
					endif;
					// check to see if the line contains initialiseActivityWithPassport(_passport, method)
					line.cnReplaceString(" ", "");
					if line.cnContains("initialiseActivityWithPassport(") or line.cnContains(".initialiseTransaction") then
						lineCount := lineCount + 1;
						linePos := -1;
						initialiseFound := true;
						continue;
					endif;
					// allowable 
					if line.cnContains("thePassport:=_passport") or line.cnContains("theRoot:=app.myRoot") or line.cnContains("passport:=_passport") or 
							line.cnContains("passport:=app.myPassport") or line.cnContains("_passport:=app.createPassport()") then
						continue;
					endif;
					if line.cnContains("return") and not initialiseFound then
						returnFound := true;
						linePos := -1;
						continue;
					endif;
					
					lineCount := lineCount + 1;
					
				endif;
			endwhile;
			
			if epilogFound then
				continue;
			endif;
			
			//if (returnFound and not initialiseFound) then
		//		continue;
		//	endif;
			
			// check to see what lineCount is.  If &gt; 1 then put into array
			if lineCount = 1 then
				continue;
			endif;
			initActWithPassport.add(klass.name &amp; " :: " &amp; meth.name);
			
		endforeach;
		
	endforeach;

	// check to see if anything failed
	//self.assertNullMsg(initActWithPassport, CrLf &amp; "The following trx method(s) do not have self.initialiseActivityWithPassport(_passport, method); as the first line of code: " &amp; CrLf &amp;
	//		initActWithPassport.concatenate(CrLf));
	
	
	// check to see if anything failed.
	if not initActWithPassport.isEmpty() then
		//app.writeLog(CrLf &amp; "The following trx method(s) do not have self.initialiseActivityWithPassport(_passport, method); as the first line of code: " &amp; CrLf &amp;
		//	initActWithPassport.concatenate(CrLf), LogAlways);
		write CrLf &amp; "The following trx method(s) do not have initialiseActivityWithPassport(_passport, method) as the first line of code: " &amp; CrLf &amp;
			initActWithPassport.concatenate(CrLf);
		//self.assertEqual(initActWithPassport.size, 0);
		return;
	endif;
	
epilog

	delete classes;
	delete initActWithPassport;
	delete methodsToIgnore;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="mdhCheckingStops" id="aa21bcd5-83dc-468a-b883-28122c7ef43a">
        <source>mdhCheckingStops();

/*

Purpose:		

Date			Who		Reason
17 November 2014	cnwmh5	Initial creation

*/

vars

	stop				: CM_Stops;
	
	oidStr				: String;
	pos					: Integer;
	
begin

	foreach stop in CM_Stops.instances discreteLock do
	
		oidStr := stop.getOidAsString();
		
		pos := oidStr.reversePos(".");
		if pos = 0 then
			continue;
		endif;
		
		oidStr := oidStr[pos+1:end].trimBlanks();
		write stop.String &amp; Tab &amp; oidStr &amp; Tab &amp; stop.creationTime.date.format("dd/MM/yyyy") &amp; Tab &amp; stop.creationTime.time.String;
		
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhClearClassMethodSearchDtls" id="b5346c57-7569-4fe1-8acb-fee249c37a17">
        <source>mdhClearClassMethodSearchDtls();

/*

Purpose:		

Date			Who		Reason
12 June 2015	cnwmh5	Initial creation

*/

vars

	root				: UM_Root;
	obj					: Object;
	
	count				: Integer;

begin

	app.initialize();

	root := UM_Root.firstInstance;
	if root = null then
		return;
	endif;
	
	beginTransaction;
	foreach obj in root.allClassMethodsUsedBy do
		delete obj;
		count := count + 1;
		if count = 50000 then
			commitTransaction;
			beginTransaction;
			count := 0;
		endif;
	endforeach;
	
	if count &gt; 0 then
		commitTransaction;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhConvertEmailTrxDetails" id="d8f9d6e6-f5be-4eee-a48e-6a15e022dbce">
        <source>mdhConvertEmailTrxDetails();

/*

Purpose:		

Date			Who		Reason
06/01/2014		cnwmh5	Initial creation

*/

vars

	inFile							: File;
	outFile							: File;

	line							: String;
	//firstTime						: String;
	trxName							: String;
	trxType							: String;
	
	
begin

	create inFile transient;
	inFile.kind := File.Kind_Unknown_Text;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	inFile.fileName := "c:\temp\trx details.txt";
	
	create outFile transient;
	outFile.mode := File.Mode_Output;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	outFile.fileName := "c:\temp\trxDetails.csv";
	if outFile.isAvailable then
		outFile.purge();
	endif;
	outFile.writeLine('Class/Method,Class,Method,trxType');
	
	//firstTime := true;
	
	while not inFile.endOfFile do
	
		line := inFile.readLine();
		
		if line = null or line.cnContains("Count:") then
			continue;
		elseif line.cnContains("Summary of Trx") then
			trxName := line["Summary of Trx ".length:end].trimBlanks();
			//write trxName;
			continue;
		elseif line.cnContains("Trxs:") then
			trxType := line[1:line.pos("Trxs:", 1) - 1].trimBlanks();
			//write trxType;
			continue;
		endif;
		//write Tab &amp; Tab &amp; line;
		outFile.writeLine(trxName &amp; "::" &amp; line.trimBlanks() &amp; "," &amp; trxName &amp; "," &amp; line.trimBlanks() &amp; "," &amp; trxType);
	
	endwhile;

	inFile.close();
	outFile.close();	
	
epilog

	delete inFile;
	delete outFile;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhConvertFailsFileToUNL" id="fbd33c17-cf34-4127-9abc-bb88d17b74b8">
        <source>mdhConvertFailsFileToUNL();

/*

Purpose:	Convert the fails taken from the email to a unl file so can be loaded
			into GUI

Date		Who		Reason
24/06/2014	cnwmh5	Initial creation

*/

vars

	file						: File;
	outFile						: File;
	openDialog 					: CMDFileOpen;
	
	tokens						: StringArray;
	
	line						: String;
	className					: String;
	methodName					: String;
	pos							: Integer;
	foundTRF					: Boolean;
	countEqual					: Integer;

begin

	create openDialog transient;
	openDialog.filter := 'txt Files| *.txt|eml Email| *eml';
	openDialog.initDir := "c:\temp\";
	openDialog.filterIndex := 1;
	
	if openDialog.open() = 0 then
		create file transient;
		file.kind := File.Kind_Unknown_Text;	// 25/2/16 cnwmp6 PAR 36286 unicode version
		file.fileName := openDialog.fileName;
		create outFile transient;		
		outFile.mode := File.Mode_Output; // 4/3/16  cnwns1 PAR 36286 unicode version
		outFile.fileName := openDialog.fileName[1:openDialog.fileName.length-3] &amp; "unl";
	endif;
	
	if file = null then
		return;
	endif;
	
	if outFile = null then
		return;
	endif;	
	
	create tokens transient;
	
	foundTRF := false;
	countEqual := 0;
	
	while not file.endOfFile do
	
		line := file.readLine();
		
		if not foundTRF then
			if line.cnContains("Test Runner Failures") then
				foundTRF := true;
			endif;
			continue;
		endif;
		
		if line.cnContains("====================") then
			countEqual := countEqual + 1;
			if countEqual = 2 then
				break;
			endif;
			continue;
		endif;
				
		tokens.clear();
		line.getTokensForDelimiter(" ", tokens);
		
		pos := tokens[2].pos("::", 1);
		className := tokens[2][1:pos-1];
		methodName := tokens[2][pos+2:end];
		
		outFile.writeLine("Method " &amp; className &amp; " " &amp; methodName);
	
	endwhile;
	
	file.close;
	outFile.close;
	
epilog

	delete file;
	delete openDialog;
	delete tokens;
	delete outFile;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="mdhConvertToNewCleanUpDetails" id="81904f76-ab32-41b2-89b5-f10e9396030a">
        <source>mdhConvertToNewCleanUpDetails();

/*

Purpose:		Convert existing CleanUp Details to new classes

Date			Who		Reason
11/06/2015		cnwmh5	Initial creation

*/

vars

	oldCleanUpDetails				: UM_CleanUpResultsDetails;
	cleanUpDetails					: UM_CleanUpDetails;
	root							: UM_Root;
	
	count							: Integer;
	mapFileName						: String;
	taskDescription 				: String;
	
	
begin

	
	count := 0;
	beginTransaction;
	foreach oldCleanUpDetails in UM_CleanUpResultsDetails.instances discreteLock do
		
		if oldCleanUpDetails.taskDescription = "Posted" then
			taskDescription := UM_CleanUpDetails.TaskDescriptionPostInvoice;
		elseif oldCleanUpDetails.taskDescription = "Posted - Error" then
			taskDescription := UM_CleanUpDetails.TaskDescriptionPostInvoiceErr;
		elseif oldCleanUpDetails.taskDescription = "Delete" then
			taskDescription := UM_CleanUpDetails.TaskDescriptionDeleteCMLookup;		
		else	
			continue;
		endif;
		
		create cleanUpDetails persistent;
		cleanUpDetails.updateDetails(oldCleanUpDetails.startTS, oldCleanUpDetails.endTS, oldCleanUpDetails.numberDone, taskDescription, null);
		
	endforeach;
	commitTransaction;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhDeleteAutomatedRunDetails" id="32365bf8-f8de-42f4-8e95-cf9c052a32bf">
        <source>mdhDeleteAutomatedRunDetails();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 February 2020	jlgmh5	Initial creation

*/

vars

	testRun						: UM_UnitTestRun;
	testResult					: UM_UnitTestResult;
	
	mergeIter					: MergeIterator;
	
	tsToCheck					: TimeStamp;

begin

	app.initialize();
	
	tsToCheck.setDate("25/02/2020".Date);
	tsToCheck.setTime("07:00:00".Time);
	
	beginTransaction;
	foreach testRun in UM_UnitTestRun.instances reversed, discreteLock do
	
		if testRun.startTS &lt; tsToCheck then
			break;
		endif;
		
		write "Deleting Unit Test Run: " &amp; testRun.String &amp; Tab &amp; testRun.startTS.String;
		
		delete mergeIter;
		create mergeIter transient;
		mergeIter.addCollection(testRun.allFailed);
		mergeIter.addCollection(testRun.allIgnored);
		mergeIter.addCollection(testRun.allPassed);
		
		while mergeIter.next(testResult) do
			delete testResult;		
		endwhile;
		
		delete testRun;
	
	endforeach;
	commitTransaction;

epilog

	delete mergeIter;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhDeleteMultipleTruck" id="d93ba00f-e3f4-42e1-9ee7-72ac38dedc04">
        <source>mdhDeleteMultipleTruck();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2011	cnwmh5	Initial creation

*/

vars

	terminal		: CM_Terminal;
	vehicle			: CM_Vehicle;
	utdsl			: UT_DSL;
	job				: CM_Job;
	vvr 			: CM_VehicleVisitRecord;

	dontDelete		: StringArray;

begin

	app.initialize;

	
	
	terminal := app.myRoot.allTerminals["T02"];
	if terminal = null then
		write 'unable to find terminal';
		return;
	endif;
	
	create dontDelete transient;
	dontDelete.add("YYY12R2");
	dontDelete.add("YYY12R3");
	
	create utdsl as UT_DSL transient;
	
	foreach vehicle in terminal.vehicles do
		if dontDelete.includes(vehicle.regNumber) then
			continue;
		endif;
		if vehicle.regNumber &lt;&gt; "PTN002A" then
			continue;
		endif;
		write vehicle.String &amp; Tab &amp; vehicle.regNumber;	
		
		//if _reg.isKindOf(String) then
		//	vehicle := terminal.vehicles[_reg.String, ""];
		//else
		//	vehicle := _reg.CM_Vehicle;
		//endif;
		///*
		if vehicle &lt;&gt; null then
			foreach job in vehicle.allRoadJobs do
				utdsl.deleteJob(job);
			endforeach;
			
			foreach vvr in vehicle.visitRecords do
				utdsl.deleteVVR(vvr);
			endforeach;
			
			//self.ignoreTrxWarnings(true);
			//app.myPassport.setWarningsIgnored(true);
			app.myTrxDA.trxDeleteVehicle(vehicle, app.myPassport); 
			//assertNoTrxErrorsOrWarnings();
		endif;
		//*/
		break;
	endforeach;

epilog

	delete utdsl;
	delete dontDelete;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhDeleteReleaseRequests" id="8292d717-d46c-45a6-8d13-cf6500393a0a">
        <source>mdhDeleteReleaseRequests();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2014	cnwmh5	Initial creation

*/

vars

	file					: File;
	dsl						: UT_DSL;
	
	line					: String;

begin

	app.initialize();

	create file transient;
	file.kind := File.Kind_Unknown_Text;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	file.fileName := "c:\temp\DeleteReleaseRequests1.txt";
	
	create dsl transient;
	dsl.setActiveProfileMDHONLY();
	
	while not file.endOfFile do
	
		line := file.readLine();
		if line = null then
			continue;
		endif;
		
		dsl.deleteReleaseRequest(line);
	
	endwhile;
	file.close();

epilog

	delete file;
	delete dsl;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhDeleteTIsViaFile" id="3db11e91-0eb5-46df-9bd1-e20cb27c4c81">
        <source>mdhDeleteTIsViaFile();

/*

Purpose:		

Date			Who		Reason
14 August 2014	cnwmh5	Initial creation

*/

vars

	dsl 					: UT_DSL;
	file					: File;
	ti						: CM_TrackedItem;
	
	tiSet					: CM_TISet;
	tisWithWarnings			: CM_TISet;
	tokensArray				: StringArray;
	
	line					: String;
	count					: Integer;
	
begin

	app.initialize();

	create dsl transient;
	dsl.setActiveProfileMDHONLY();
	
	create tokensArray transient;
	create tiSet transient;
	
	create file transient;
	file.kind := File.Kind_Unknown_Text;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	file.fileName := "c:\temp\tisToDelete.csv";
	file.readLine();
	
	while not file.endOfFile do
	
		line := file.readLine();
		
		tokensArray.clear();
		line.getTokensForDelimiter(",", tokensArray);
		
		if tokensArray.size &lt; 3 then
			continue;
		endif;
		
		ti := dsl.getTrackedItem(tokensArray[2]);
		if ti &lt;&gt; null then
			tiSet.add(ti);
			count := count + 1;
		endif;
		
	
	endwhile;		
	write 'Count: ' &amp; count.String;
	write 'tiSet.size: ' &amp; tiSet.size.String;
	
	write "Deleting tracked items.  Please wait...";
	dsl.deleteTrackedItems(tiSet, tisWithWarnings);
	
	
epilog

	delete dsl;
	delete file;
	delete tokensArray;
	delete tiSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="mdhDeleteTrackedItem" id="84bd9895-682d-427b-922b-4f602a36527b">
        <source>mdhDeleteTrackedItem();

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
22 May 2013	cnwmh5	Initial creation

*/
constants

	TrackedItemId				: String = "YARD1112";

vars

	ti							: CM_TrackedItem;
	dsl							: UT_DSL;
	
	index						: Integer;

begin

	app.initialize();

	index := 221;
	
	create dsl as UT_DSL transient;
	
	dsl.setActiveProfileMDHONLY();
	
	while index &lt;= 420 do
	
		ti := dsl.getTrackedItem(TrackedItemId &amp; index.String);
		if ti &lt;&gt; null then
			dsl.deleteTrackedItem(ti, false);
		endif;
		
		index := index + 1;
		//break;
	
	endwhile;


epilog

	delete dsl;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhDeleteUnitTestRuns" id="4a100ce8-199f-447e-8c5a-8bade21423c4">
        <source>mdhDeleteUnitTestRuns();

/*

Purpose:		Delete unit test runs up to ???

Date			Who		Reason
29/06/2015		cnwmh5	Initial creation

*/

vars

	testRun						: UM_UnitTestRun;
	root						: UM_Root;
	obj							: Object;
	classMethod					: UM_UnitTestClassMethod;
	
	iter						: Iterator;

	endTS						: TimeStamp;
	upToDate					: String;

begin

	app.initialize();
	
	root := UM_Root.firstInstance;
	if root = null then
		return;
	endif;
	
	while true do
	
		upToDate := "31/12/2999";
	
		read upToDate;
	
		if upToDate = null then
			return;
		endif;
		
		if not upToDate.Date.isValid() then
			continue;
		endif;
	
		endTS.setDate(upToDate.Date);
		endTS.setTime("23:59:59".Time);
	
		break;
	
	endwhile;

	
	iter := root.allUnitTestRuns.createIterator;
	while iter.next(testRun) do
	
		beginTransaction;
		if testRun.startTS &gt;= endTS then
			commitTransaction;
			break;
		endif;
	
		foreach obj in testRun.allFailed do
			delete obj;
		endforeach;
	
		foreach obj in testRun.allIgnored do
			delete obj;
		endforeach;
		
		foreach obj in testRun.allPassed do
			delete obj;
		endforeach;
	
		delete testRun;
		commitTransaction;
	
	endwhile;
	
	delete iter;
	beginTransaction;
	iter := root.allClassMethodsUsedBy.createIterator;
	while iter.next(classMethod) do
		if classMethod.allUnitTestResults.isEmpty() then
			delete classMethod;
		endif;
	endwhile;
	commitTransaction;
	
epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhFails0212" id="db82e638-0494-4674-a888-18824510e944">
        <source>mdhFails0212();

/*

Purpose:		

Date			Who		Reason
02 December 2015	cnwmh5	Initial creation

*/

vars

	terminal					: CM_Terminal;
	voyage						: CM_Voyage;
	ti							: CM_TrackedItem;
	
	mergeIter					: MergeIterator;
	
	tempTS						: TimeStamp;
	tempStr						: String;
	pos							: Integer;

begin

	app.initialize();

	terminal := app.myRoot.allTerminals["UT"];
	if terminal = null then
		app.msgBox("Unable to find UT Terminal.  Exiting JadeScript...", "Terminal Error", MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;

	tempTS := app.cnGetServerTime();
	tempTS.setTime("09:55:00".Time);

	create mergeIter transient;

	mergeIter.addCollection(terminal.allNotifiedTIsByIdCargoType);
	mergeIter.addCollection(terminal.allOnsiteTIsByIdCargoType);
	
	foreach voyage in terminal.allVoyagesArchived do
		mergeIter.addCollection(voyage.allOnshipTIsByIdCargoType);
	endforeach;
	
	foreach voyage in terminal.allVoyagesByCode do
		//if not voyage.allOnshipTIsByIdCargoType.isEmpty() then
			mergeIter.addCollection(voyage.allOnshipTIsByIdCargoType);
		//endif;
	endforeach;

	
	while mergeIter.back(ti) do
	
		if ti.mySubTerminal &lt;&gt; null then
			continue;
		endif;
		
		if ti.creationTime.date &lt; "30/11/2015".Date then
			continue;
		endif;
		
		tempStr := ti.remarks;
		pos := 1;
		pos := tempStr.pos("Created by unit test", pos);
		if pos &gt; 0 then
			tempStr := tempStr[pos:end];
			tempStr := tempStr.replaceString(CrLf, " "); 
		else	
			tempStr := null;
		endif;
		
		write ti.String &amp; Tab &amp; ti.id &amp; Tab &amp; ti.creationTime.date.format("dd/MM/yyyy") &amp; Tab &amp; 
			ti.creationTime.time.String &amp; Tab &amp; ti.hasChildren.String &amp; Tab &amp; tempStr;
	
	endwhile;
	
	
	
epilog

	delete mergeIter;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhFindAllTIsCreatedAfter" id="c052054d-24db-4f0a-b464-9830801d4f54">
        <source>mdhFindAllTIsCreatedAfter();

/*

Purpose:			

Date			Who		Reason
28 August 2015	cnwmh5	Initial creation

*/

vars

	root 							: UM_Root;
	classMethod						: UM_UnitTestClassMethod;
	unitTestResult					: UM_UnitTestResult;
	nextTrackedItemToStartAt		: CM_TrackedItem;
	ti								: CM_TrackedItem;
	objToDelete						: UM_ObjectsToDelete;
	schema							: Schema;
	klass							: Class;
	startAtClass					: Class;
	prop							: Property;
	propObjValue					: Object;
	obj								: Object;
	newTerm							: CM_Terminal;
	newOperator						: CM_Operator;
	cou								: CM_ClipOnUnit;
	passport						: CM_Passport;
	file							: File;

	classes							: ClassColl;
	tiSet							: CM_TISet;
	nullRefsDelObjArray				: StringArray;
	properties						: PropertyColl;
	objsToDeleteArray				: ObjectArray;
	
	iterClass						: Iterator;
	iterTI							: Iterator;
	iterProp						: Iterator;
	
	tempStr							: String;
	pos								: Integer;
	startSize 						: Integer;
	totNoToCheck					: Integer;
	noToCheck						: Integer;
	noToDelete						: Integer;
	isInvalidObject					: Boolean;
	timeToTest						: TimeStamp;
	invalidObj						: Boolean;
	remarks							: String;
	
begin
	
	on Exception do app.handleDeletedObject(exception, obj, invalidObj);
	
	root := UM_Root.firstInstance;
	if root = null then
		return;
	endif;
	
	schema := rootSchema.getSchema("PortSchema");
	if schema = null then
		return;
	endif;
	
	klass := schema.getClass("CM_TrackedItem");
	if klass = null then
		return;
	endif;
	
	timeToTest := app.cnGetServerTime();
	tempStr := timeToTest.date.year.padLeadingWith("0",2) &amp; timeToTest.date.month.padLeadingWith("0",2) &amp; 
		timeToTest.date.day.padLeadingWith("0",2) &amp; "_" &amp; timeToTest.time.hour.padLeadingWith("0",2) &amp; 
		timeToTest.time.minute.padLeadingWith("0",2) &amp; timeToTest.time.second.padLeadingWith("0",2);
	//timeToTest.setDate("09/08/2015".Date);
	//timeToTest.setTime("02:30:00".Time);
	timeToTest := timeToTest.addDays(-1);
	timeToTest.setTime("20:00:00".Time);
	//timeToTest.setTime("11:53:00".Time);

	create file transient;
	file.fileName := "c:\temp\CurrentTIs_" &amp; tempStr &amp;".csv";
	tempStr := null;	
	if file.isAvailable() then
		file.purge();
	endif;
	file.writeLine("TI,ID,Date,Time,Has Created,remarks");
	
	// get all the tracked item classes
	create classes transient;
	classes.add(klass);
	klass.allLocalSubclasses(classes);
	
	iterClass := classes.createIterator;
	while iterClass.next(klass) do 
	
		// no instances so go to next class
		if klass.instances.isEmpty() then
			continue;
		endif;
	
		delete tiSet;
		create tiSet transient;
		klass.instances.copy(tiSet);
		
		delete iterTI;
		iterTI := tiSet.createIterator;
		while iterTI.back(obj) do
		
			if obj.creationTime &lt; timeToTest then
				break;
			endif;
			
			ti := obj.CM_TrackedItem;
			remarks := ti.remarks;
			remarks := remarks.replaceString(",", " ");
			remarks := remarks.replaceString(CrLf, " ");
			write ti.String &amp; Tab &amp; ti.id &amp; Tab &amp; ti.creationTime.date.format("dd/MM/yyyy") &amp; Tab &amp; 
				ti.creationTime.time.String &amp; Tab &amp; (remarks &lt;&gt; null).String &amp; Tab &amp; remarks;		
			file.writeLine(ti.String &amp; "," &amp; ti.id &amp; "," &amp; ti.creationTime.date.format("dd/MM/yyyy") &amp; "," &amp; 
				ti.creationTime.time.String &amp; "," &amp; (remarks.cnContains("Created by unit test").String &amp; "," &amp; remarks));
		
		endwhile;	
	
	endwhile;


epilog

	delete classes;
	delete iterClass;
	delete iterTI;
	delete tiSet;
	delete nullRefsDelObjArray;
	delete properties;
	delete iterProp;
	delete objsToDeleteArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="mdhFindChangedFormConstants" id="7210c6d7-595a-4382-b14c-82eca1f34a77">
        <source>mdhFindChangedFormConstants();

/*

Purpose:		

Date			Who		Reason
21 September 2015	cnwmh5	Initial creation

*/
constants

	DELIM						: String = ",";
	
vars

	formCaption					: XLAT_FormCaption;
	file						: File;
	
	allMethodRefs				: MethodSet;
	
	iter						: Iterator;

	startDate					: Date;
	newConstant					: Boolean;
	count						: Integer;
	defaultMessage				: String;

begin

	startDate := "30/07/2015".Date;
	
	create file transient;
	file.fileName := "c:\temp\FormConstantDetails.csv";
	if file.isAvailable() then
		file.purge();
	endif;
	
	create allMethodRefs transient;
	
	iter := XLAT_FormCaption.instances.createIterator;
	while iter.next(formCaption) do
	
		// check if newly created constant
		newConstant := false;
		if formCaption.creationTime.date &gt; startDate then
			newConstant := true;
		endif;
	
		// dont require if not references
		allMethodRefs.clear();
		formCaption.myGlobalConstant.getMethodRefs(allMethodRefs);
		if allMethodRefs.isEmpty() then
			continue;
		endif;		
		
		defaultMessage := formCaption.vDefaultMessage.replaceString(CrLf, "^^^");
		
		if not newConstant then
			continue;
		endif;
		
		count := count + 1;
		
		write formCaption.createdTime.date.String &amp; Tab &amp; formCaption.createdTime.time.String &amp; Tab &amp;
			newConstant.String &amp; Tab &amp; formCaption.vFormClass &amp; Tab &amp; formCaption.vConstantName &amp; Tab &amp; 
			formCaption.number.String &amp; Tab &amp; formCaption.vControlName &amp; Tab &amp; formCaption.vControlProperty &amp; Tab &amp; 
			formCaption.vDefaultMessage;
		file.writeLine(formCaption.createdTime.date.String &amp; DELIM &amp; formCaption.createdTime.time.String &amp; DELIM &amp;
			newConstant.String &amp; DELIM &amp; formCaption.vFormClass &amp; DELIM &amp; formCaption.vConstantName &amp; DELIM &amp; 
			formCaption.number.String &amp; DELIM &amp; formCaption.vControlName &amp; DELIM &amp; formCaption.vControlProperty &amp; DELIM &amp; 
			formCaption.vDefaultMessage);
	
	endwhile;
	file.close();
	write "count: " &amp; count.String;

epilog

	delete file;
	delete allMethodRefs;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhFindNonASCIICharacter" id="6e9ed3ce-16db-4ee6-98a4-761d3ee7ddcc">
        <source>mdhFindNonASCIICharacter();
/*

Purpose:		Find the non ASCII character which is trying to be emailed	

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2019	jlgmh5:1	Initial creation

*/

vars

	testRun						: UM_UnitTestRun;
	testResult					: UM_UnitTestResult;
	
	mergeIter					: MergeIterator;
	
	resultStr					: String;
	linePtr						: Integer;

begin

	app.initialize;
	
	testRun := UM_UnitTestRun.lastInstance;
	
	create mergeIter transient;
	mergeIter.addCollection(testRun.allFailed);
	mergeIter.addCollection(testRun.allPassed);
	mergeIter.addCollection(testRun.allIgnored);

	while mergeIter.next(testResult) do
	
		resultStr := testResult.details.uncompressToString().trimBlanks();
		
		linePtr			:=	1;

        while linePtr &lt;= resultStr.length do
        	if resultStr[linePtr].Character.Integer &gt; 127 or resultStr[linePtr].Character.Integer = null then
	    		//raiseValidationException(Err_Non_ASCII_Character, className &amp; " The message contains a non-ASCII character in the following line (" &amp; line &amp; ")");//V4
				write testResult.String &amp; Tab &amp; "linePtr: " &amp; linePtr.String &amp; Tab &amp; testResult.myClassMethod.className &amp; Tab &amp; 
					testResult.myClassMethod.methodName &amp; CrLf &amp; resultStr &amp; CrLf &amp; CrLf;
        	endif;
        	linePtr		:=	linePtr + 1;
        endwhile;
	
	endwhile;

epilog
	
	delete mergeIter;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhFindTrxNoAssert" id="293d4e0a-7f81-4912-9a4f-1dda221e21a3">
        <source>mdhFindTrxNoAssert();

/*

Purpose:			

Date			Who		Reason
31 October 2012	cnwmh5	Initial creation

*/

vars

	klass				: Class;
	meth				: Method;
	
	classes				: ClassColl;
	methodsDict			: MethodNDict;
	
	tokens				: StringArray512;
	missingOwnerArray	: StringArray;
	
	methodSource		: String;
	line				: String;
	token				: String;
	linePos 			: Integer;
	found				: Boolean;
	count 				: Integer;
	lineCount			: Integer;
	trxFound 			: Boolean;
	getNextNumLines		: Integer;
	idx					: Integer;
	tempLine			: String;
	
begin

	create tokens transient;
	create missingOwnerArray transient;

	// get UT_DSL class
	klass := currentSchema.getClass("UT_DSL");
	//self.assertNotNull(klass);
	if klass = null then
		return;
	endif;
	
	// create classes
	create classes transient;
	classes.add(klass);
	klass.allLocalSubclasses(classes);
	
	create tokens transient;
	
	count := 0;
	foreach klass in classes do
	
		methodsDict := klass.cnGetMethods();
		
		foreach meth in methodsDict do
	
			methodSource := meth.getSource();
			methodSource.replaceChar(Tab, " ");
			if not methodSource.cnContains(".trx") then
				continue;
			endif;
	
			lineCount := 0;
			linePos := 1;
			while linePos &gt; 0 do
				
				lineCount := lineCount + 1;
				
				line :=  methodSource.cnEcGetNextLine(linePos);
							
				if not line.cnContains('.trx') then
					continue;
				endif;
				
				// check to see if commented out line
				if line.trimBlanks()[1:2] = "//" then
					continue;
				endif;	
				
				// don't require if trxCmopletedOK
				if line.cnContains(".trxCompletedOK") then
					continue;
				endif;				
				
				if line.cnContains('trxType.trxType') then
					continue;
				endif;
				
				tempLine := klass.name &amp; Tab &amp; meth.name &amp; Tab &amp; lineCount.String &amp; Tab &amp; line;
				
				getNextNumLines := 2;
				idx := 1;
				while idx &lt;= getNextNumLines do
					lineCount := lineCount + 1;
					line := methodSource.cnEcGetNextLine(linePos);
					if linePos = 0 then
						break;
					endif;
					// ignore blank lines
					if line.trimBlanks() = null then
						continue;
					endif;
					// ignore comments
					if line.trimBlanks()[1:2] = "//" then
						continue;
					endif;
					if line.cnContains("assertNoTrxErrorsOrWarnings") then
						tempLine := null;
						break;
					endif;
					if line.cnContains(".trxCompletedOK") then
						tempLine := null;
						break;
					endif;
					//if tempLine &lt;&gt; null then
					//	write tempLine;
					//	tempLine := null;
					//endif;
					//write klass.name &amp; Tab &amp; meth.name &amp; Tab &amp; lineCount.String &amp; Tab &amp; line;
					idx := idx + 1;
				endwhile;
				
				if tempLine &lt;&gt; null then
					write tempLine;
				endif;
				
			endwhile;
			
			
			
			count := count + 1;
	
		endforeach;
			
	endforeach;
		
	//write 'count: ' &amp; count.String;	
	
epilog

	delete classes;
	delete tokens;
	delete missingOwnerArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="mdhFixRoadOps79731Error" id="8f8d4628-ae65-4e15-aa3a-516fcc09eeb7">
        <source>mdhFixRoadOps79731Error();

/*

Purpose:		Fix 79731 Road Ops Error

Date			Who		Reason
03/03/2014		cnwmh5	Initial creation

*/

vars

	deliveryRequest					: CM_DeliveryRequest;
	tiRequest						: CM_TIRequest;

	deliveryRequestSet				: CM_DeliveryRequestSet;
	
	count							: Integer;
	
begin

	create deliveryRequestSet transient;
	CM_YardDeliveryRequest.instances.copyNoDups(deliveryRequestSet);
	CM_DeliveryRequest.instances.copyNoDups(deliveryRequestSet);
	
	beginTransaction;
	foreach deliveryRequest in deliveryRequestSet do
		if deliveryRequest.myCargoType &lt;&gt; null and not global.isValidObject(deliveryRequest.myCargoType) then
			count := count + 1;
			write deliveryRequest.identity &amp; Tab &amp; deliveryRequest.myCargoType.String &amp; Tab &amp; global.isValidObject(deliveryRequest.myCargoType).String;
			deliveryRequest.setPropertyValue("myCargoType", null);
		endif;
	endforeach;
	commitTransaction;
	write 'Count: ' &amp; count.String;
	
	beginTransaction;
	foreach tiRequest in CM_TIRequest.instances do
		if not global.isValidObject(tiRequest.trackedItem) then
			tiRequest.setPropertyValue("trackedItem", null);
		endif;	
	endforeach;
	commitTransaction;
	
epilog

	delete deliveryRequestSet;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhGetAllCreatedTIDetails" id="7b664933-c3a7-4b15-b632-d5a52f2560f0">
        <source>mdhGetAllCreatedTIDetails();

/*

Purpose:		

Date			Who		Reason
21 November 2014	cnwmh5	Initial creation

*/

vars

	terminal					: CM_Terminal;
	dsl							: UT_DSL;
	voyage						: CM_Voyage;
	ti							: CM_TrackedItem;
	file						: File;

	mergeIterVoyage				: MergeIterator;
	mergeIterTI					: MergeIterator;
	iter						: Iterator;

	ts							: TimeStamp;
	extraDataValue				: String;
	
begin

	app.initialize();

	create dsl transient;
	dsl.setActiveProfileMDHONLY();	
	
	terminal := dsl.getTerminal();
	if terminal = null then
		write "Unable to get Terminal.  Exiting JadeScript.";
		return;
	endif;
	
	create file transient;
	file.fileName := "c:\temp\createdTrackedItemDetails.csv";
	if file.isAvailable() then
		file.purge();
	endif;
	file.writeLine("Oid,ID,Voy Code,Voy Desc,Unit Test,Date,Time,Location");
	
	create mergeIterTI transient;
	mergeIterTI.addCollection(terminal.allNotifiedTIsByIdCargoType);
	mergeIterTI.addCollection(terminal.allOnsiteTIsByIdCargoType);
	
	create mergeIterVoyage transient;
	mergeIterVoyage.addCollection(terminal.allVoyagesArchived);
	mergeIterVoyage.addCollection(terminal.allVoyagesByCode);
	
	while mergeIterVoyage.next(voyage) do
		mergeIterTI.addCollection(voyage.allOnshipTIsByIdCargoType);
	endwhile;
	
	while mergeIterTI.next(ti) do
		global.getExtraData(ti.allExtraData, "createdByUnitTest", extraDataValue);
		write ti.String &amp; Tab &amp; ti.id &amp; Tab &amp; ti.myVoyage.code &amp; Tab &amp; ti.myVoyage.description &amp; Tab &amp; 
			extraDataValue &amp; Tab &amp; ti.creationTime.date.format("dd/MM/yyyy") &amp; Tab &amp; 
			ti.creationTime.time.String &amp; Tab &amp; ti.getPrimaryLocationId(REAL_MODE);		
		file.writeLine(ti.String &amp; "," &amp; ti.id &amp; "," &amp; ti.myVoyage.code &amp; "," &amp; ti.myVoyage.description &amp; "," &amp; 
			extraDataValue &amp; "," &amp; ti.creationTime.date.format("dd/MM/yyyy") &amp; "," &amp; 
			ti.creationTime.time.String &amp; "," &amp; ti.getPrimaryLocationId(REAL_MODE));
	endwhile;
	
	ts := null;
	iter := terminal.allOffsiteTIsByIdCargoType.createIterator;
	while iter.next(ti) do
		global.getExtraData(ti.allExtraData, "createdByUnitTest", extraDataValue);
		write ti.String &amp; Tab &amp; ti.id &amp; Tab &amp; ti.myVoyage.code &amp; Tab &amp; ti.myVoyage.description &amp; Tab &amp; 
			extraDataValue &amp; Tab &amp; ti.creationTime.date.format("dd/MM/yyyy") &amp; Tab &amp; 
			ti.creationTime.time.String &amp; Tab &amp; ti.getPrimaryLocationId(REAL_MODE);		
		file.writeLine(ti.String &amp; "," &amp; ti.id &amp; "," &amp; ti.myVoyage.code &amp; "," &amp; ti.myVoyage.description &amp; "," &amp; 
			extraDataValue &amp; "," &amp; ti.creationTime.date.format("dd/MM/yyyy") &amp; "," &amp; 
			ti.creationTime.time.String &amp; "," &amp; ti.getPrimaryLocationId(REAL_MODE));
	endwhile;

epilog

	delete dsl;
	delete mergeIterVoyage;
	delete mergeIterTI;
	delete iter;
	delete file;
end;</source>
    </JadeMethod>
    <JadeMethod name="mdhGetClassMethodResults" id="778da223-b419-4a23-b4c3-07863eb9bdb1">
        <source>mdhGetClassMethodResults();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 September 2013	cnwmh5	Initial creation

*/

vars

	classMethod				: UM_UnitTestClassMethod;
	result					: UM_UnitTestResult;

	root					: UM_Root;

begin

	root := UM_Root.firstInstance;
	if root = null then
		return;
	endif;

	classMethod := root.allRunnableUTClassesMethods["UT_AutoPlanOut", "tReleaseToDoTasks"];
	if classMethod = null then
		return;
	endif;
	
	//write classMethod.String &amp; Tab &amp; classMethod.className &amp; Tab &amp; classMethod.methodName &amp; Tab &amp; classMethod.getFailingFor("22/08/2013".Date).String;
	
	
	
	
	foreach result in classMethod.allUnitTestResults do
		write result.String &amp; Tab &amp; result.myTestRun.startTS.String &amp; Tab &amp; result.myTestRun.endTS.String &amp; Tab &amp; 
			result.methodRunStartTS.String &amp; Tab &amp; result.getResultDetails(result.result).String &amp; Tab &amp; 
			result.elapsedTime.String;  // &amp; result.getFailingFor("01/09/2013".Date).String;
	endforeach;
	


	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhGetConfigTypes" id="f696e21f-ad16-4bef-8a8c-5d75e25f8f4a">
        <source>mdhGetConfigTypes();

/*

Purpose:		

Date			Who		Reason
19 December 2014	cnwmh5	Initial creation

*/

vars

	file						: File;
	terminal					: CM_Terminal;
	stateObject					: CM_StateObject;
	stateData					: CM_StateData;

begin

	app.initialize();

	create file transient;
	file.fileName := "c:\temp\DumpedStateTypes.csv";
	if file.isAvailable() then
		file.purge;
	endif;
	
	terminal := app.myRoot.allTerminals["UT"];
	if terminal = null then
		write 'Unable to find terminal UT.  Exiting Jadescript.';
		return;
	endif;
	
	foreach stateObject in terminal.getAllStateData() do
		foreach stateData in stateObject.allStateData do
			file.writeLine('Terminal,' &amp; stateData.key &amp; "," &amp; stateData.getNiceClassName());
		endforeach;
	endforeach;
	
	foreach stateObject in app.myRoot.getAllStateData() do
		foreach stateData in stateObject.allStateData do
			file.writeLine('System,' &amp; stateData.key &amp; "," &amp; stateData.getNiceClassName());
		endforeach;
	endforeach;
	
epilog

	delete file;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhGetLastXLATExceptionNumber" id="e8fb5f5d-b3cd-43dd-9dec-0251e3ba5094">
        <source>mdhGetLastXLATExceptionNumber();

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
18 July 2012	cnwmh5	Initial creation

*/

vars
	number : Integer;
	constant : Constant;
begin
	foreach constant in rootSchema.getSchema(PortSchemaName).getCategory("XLAT_Exceptions").getConstants discreteLock do
		number := number.max(constant.getPropertyValue("source").Integer);
	endforeach;
	write number;
end;
</source>
    </JadeMethod>
    <JadeMethod name="mdhGetMethodsUsedByUnitTests" id="30eaa3af-6363-48c2-b688-94b1ffcb3f68">
        <source>mdhGetMethodsUsedByUnitTests();

/*

Purpose:		

Date			Who		Reason
27 July 2015	cnwmh5	Initial creation

*/
constants
	Capitals				: String = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
vars

	klass				: Class;
	meth				: Method;
	file				: File;
	
	classes				: ClassColl;
	methodsDict			: MethodNDict;
	
	tokens				: StringArray512;
	missingOwnerArray	: StringArray;
	
	methodSource		: String;
	line				: String;
	token				: String;
	linePos 			: Integer;
	found				: Boolean;
	pos2				: Integer;
	creationTS			: TimeStamp;
	modifiedTS			: TimeStamp;
	createdBy			: String;
	lastModifiedBy		: String;
	
begin

	create tokens transient;
	create missingOwnerArray transient;
	
	create file transient;
	file.fileName := "c:\temp\AutomatedTestMethCreateMod.csv";
	if file.isAvailable() then
		file.purge();
	endif;
	file.writeLine("Method Oid,Class,Method,Has Changed,Create Date,Create Time,Created By,Mod Date, Mod Time,Mod by");

	// get UT_DSL class
	klass := currentSchema.getClass("UT_DSL");
	if klass = null then
		return;
	endif;
	
	// create classes
	create classes transient;
	classes.add(klass);
	klass.allLocalSubclasses(classes);
	
	foreach klass in classes do
	
		methodsDict := klass.cnGetMethods();
		
		foreach meth in methodsDict where meth.isRunnableUnitTestMethod() or 
				(meth.name[1:1] = "v" and Capitals.pos(meth.name[2:1], 1) &gt; 0) do
		
			found := false;
			createdBy := null;
			linePos := 1;
			meth.getSource.cnEcGetNextLine(linePos);
			while linePos &gt; 0 do : haveFoundOwner
				line :=  meth.getSource.cnEcGetNextLine(linePos);
				if (line[1:9] = 'constants' and line.trimBlanks().length = 9) or 		
						(line[1:4] = "vars" and line.trimBlanks().length = 4) then
					break;
				endif;
				line.replaceChar(Tab, ' ');
				tokens.clear;
				line.getTokensForDelimiter(" ", tokens);
				foreach token in tokens do
					if token.toUpper().cnContains("CNW") then
						found := true;
						createdBy := token.toUpper();
						break haveFoundOwner;
					endif;
				endforeach;
			endwhile;
	
			creationTS := meth.creationTime;
			modifiedTS := meth.cnGetModifiedTimeStamp();
			lastModifiedBy := meth.cnGetModifierName().toUpper();			
	
			write meth.String &amp; Tab &amp; meth.getSchemaType().name &amp; Tab &amp; meth.name &amp; Tab &amp; (creationTS.date &lt;&gt; modifiedTS.date).String &amp; Tab &amp;
				creationTS.date.format("dd/MM/yyyy") &amp; Tab &amp; creationTS.time.String &amp; Tab &amp; createdBy &amp; Tab &amp; 
				modifiedTS.date.format("dd/MM/yyyy") &amp; Tab &amp; modifiedTS.time.String &amp; Tab &amp; 
				lastModifiedBy;
			file.writeLine(meth.String &amp; "," &amp; meth.getSchemaType().name &amp; "," &amp; meth.name &amp; "," &amp; (creationTS.date &lt;&gt; modifiedTS.date).String &amp; "," &amp;
				creationTS.date.format("dd/MM/yyyy") &amp; "," &amp; creationTS.time.String &amp; "," &amp; createdBy &amp; "," &amp; 
				modifiedTS.date.format("dd/MM/yyyy") &amp; "," &amp; modifiedTS.time.String &amp; "," &amp; 
				lastModifiedBy);
			
		endforeach;
	
	endforeach;
		
	
	
epilog

	delete classes;
	delete tokens;
	delete missingOwnerArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="mdhGetTestDetails" id="f37a4613-a513-439a-aaae-9ed7a890b02d">
        <source>mdhGetTestDetails();

/*

Purpose:		Get the Test Details (Fails / Pass) for the specified unit test

Date			Who		Reason
21/07/2014		cnwmh5	Initial creation

*/
constants

	DELIM							: String = ",";
	
vars

	classMethod						: UM_UnitTestClassMethod;
	testResult						: UM_UnitTestResult;
	file							: File;

	envName 						: String;
	passFail						: String;
	detailsStr						: String;

begin

	// get the system name
	envName := CM_Version.VERSION;

	create file transient;
	file.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version
	file.fileName := "c:\temp\UT_DSS_tBasicChangeTracker_Results.csv";
	file.mode := File.Mode_Append;
	if envName = "8.3.2" and file.isAvailable() then
		file.purge();
	endif;
	file.writeLine("System, RunDate, RunTime, Fail/Pass, Details");
	
	foreach classMethod in UM_UnitTestClassMethod.instances do
		if classMethod.className &lt;&gt; "UT_DSS" or classMethod.methodName &lt;&gt; "tBasicChangeTracker" then
			continue;
		endif;
		write classMethod.String &amp; Tab &amp; classMethod.className &amp; Tab &amp; classMethod.methodName;	
		
		foreach testResult in classMethod.allUnitTestResults do
			
			if testResult.hasPassed() then
				passFail := "PASS";
			else
				passFail := "FAIL";
			endif;
			
			detailsStr := testResult.details.uncompressToString().trimBlanks();
			detailsStr := detailsStr.replaceString(Cr, "^&amp;");
			detailsStr := detailsStr.replaceString(Lf, "^&amp;");
			detailsStr := detailsStr.replaceString("^&amp;^&amp;", " ");
			
			file.writeLine(envName &amp; DELIM &amp; testResult.methodRunStartTS.date.String &amp; DELIM &amp; 
				testResult.methodRunStartTS.time.String &amp; DELIM &amp; passFail &amp; DELIM &amp; 
				detailsStr);
			
		endforeach;
		
	endforeach;
	
	
epilog

	delete file;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhHandleDeletedObject" id="1a4a1485-937e-478d-a594-3844cad3bd05">
        <source>mdhHandleDeletedObject(_exc : Exception; _obj : Object; _invalidObject : Boolean io) : Integer;

/*

Purpose:			General exception handler to deal with invalid object references.  Needs to be
					armed with a specific object reference to be checked.


Return Value:		Standard Exception return codes, and _invalidObject set to true if
					the specified object reference caused the exception.


Date		Who		Reason
18 Mar 2008	cnwkpd1	PAR #16195 - Allow generic handling of invalid objects
03 Jun 2008	cnwkpd1	PAR #16718 - handle exclusive collection exceptions as well, as there are
					situations where an exclusive collection on the object we are interested in
					will be the error object in the exception
21 May 2009	cnwkpd1	Change to use new JADE Object::getOwnerForObject method
04 Feb 2011	cnwkpd1	PAR #27142 - Added code to handle null _obj, to protect against incorrect
					arming and therefore invalid resume for standard objects (with no owner)
					
*/

constants
	ObjectNotFound	= 4;
	ObjectDeleted	= 1072;
	InvalidClass	= 1046;
	
vars
	returnVal		: Integer;
	
begin
	returnVal := Ex_Pass_Back;
	
	// PAR #27142 - if the handler has been armed for a local variable that has not yet been
	// initialised when the exception occurs, then it is not for us, so just pass back immediately
	if _obj = null then				
		return returnVal;
	endif;
	
	if _exc.errorCode = ObjectNotFound or _exc.errorCode = ObjectDeleted or _exc.errorCode = InvalidClass then
		//if _exc.errorObject = _obj or self.getOwnerForObject(_exc.errorObject) = _obj then
			// Set _invalidObject, and resume in the calling method, which will then
			// interrogate excOccurred, to identify an invalid/deleted object
			_invalidObject := true;
			if _exc.resumable then
				returnVal := Ex_Resume_Next;
			endif;
		//endif;
	endif;


epilog
	return returnVal;
	
end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_invalidObject" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="mdhImportExistingDetails" id="a13274a0-8fc4-4733-8fd2-617c2a2d0142">
        <source>mdhImportExistingDetails();

/*

Purpose:		

Date			Who		Reason
19 November 2013	cnwmh5	Initial creation

*/
constants
	DelimComma						: String = ",";
vars

	file						: File;
	cleanUpDetails				: UM_CleanUpResultsDetails;
	root						: UM_Root;
	
	lineArray					: StringArray512;
		
	systemId					: String;
	firstTime					: Boolean;
	line						: String;	
	startTS						: TimeStamp;
	endTS						: TimeStamp;
	
begin

	root := UM_Root.firstInstance.UM_Root;
	if root = null then
		return;
	endif;
	
	beginTransaction;
	root.allCleanUpResultsDetails.clear();
	UM_CleanUpResultsDetails.instances.purge();
	commitTransaction;


	systemId := CM_Version.VERSION;
	systemId := systemId.replaceString(".", "");

	create file transient;
	file.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version	
	file.fileName := "C:\temp\" &amp; systemId &amp; "CleanUp_Result_Details.csv";
	write 'fileName: ' &amp; file.fileName;
	
	create lineArray transient;
	firstTime := true;
	beginTransaction;
	while not file.endOfFile do
	
		line := file.readLine();
		if firstTime then
			firstTime := false;
			continue;
		endif;
		
		lineArray.clear();
		line.getTokensForDelimiter(DelimComma, lineArray);
		
		startTS.setDate(lineArray[2].Date);
		startTS.setTime(lineArray[3].Time);
		endTS.setDate(startTS.date);
		endTS.setTime(lineArray[4].Time);
		
		create cleanUpDetails persistent;
		cleanUpDetails.createRecord(startTS, endTS, lineArray[5].Integer, lineArray[6], lineArray[7].Decimal, lineArray[8].Decimal);
	
		write startTS.String &amp; Tab &amp; endTS.String &amp; Tab &amp; lineArray[5].Integer.String &amp; Tab &amp; lineArray[6] &amp; Tab &amp; 
			lineArray[7].Decimal.String &amp; Tab &amp; lineArray[8].Decimal.String;
	
	endwhile;
	commitTransaction;

	file.close();

epilog

	delete file;
	delete lineArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhIterateDynaDict60052" id="424ee2e9-d0e7-4fab-92fc-f62822e55887">
        <source>mdhIterateDynaDict60052();

/*

Purpose:			

Date			Who		Reason
23 July 2013	cnwmh5	Initial creation

*/

vars

	dict					: DynaDictionary;
	obj						: Object;
	jdo						: JadeDynamicObject;
	file					: File;
		
	invalidObj				: Boolean;
	count					: Integer;
	checked					: Boolean;

	failedResults 			: Binary;
	passedResults			: Binary;
	passed					: Boolean;
	
	startTimeStamp 			: TimeStamp;
	runTimeStamp 			: TimeStamp;
	lastPassedDate 			: Date;
	
	resultDetails			: String;
	
begin

	on Exception do self.mdhHandleDeletedObject(exception, dict, invalidObj);

	create file transient;
	file.fileName := "c:\temp\DynaDictDetails.txt";
	if file.isAvailable then
		file.purge();
	endif;
	
	beginTransaction;
	foreach dict in DynaDictionary.instances discreteLock do
	
		//write dict.String;
		invalidObj := false;
		checked := false;
		foreach obj in dict do
			
			if not checked and not invalidObj then
				/*
				if obj.isKindOf(JadeDynamicObject) then
					jdo := obj.JadeDynamicObject;
					
					startTimeStamp := jdo.getPropertyValue("startTimeStamp").TimeStamp;
					runTimeStamp := jdo.getPropertyValue("runTimeStamp").TimeStamp;
					lastPassedDate := jdo.getPropertyValue('lastPassedDate').Date;
					
					resultDetails := null;
					passed := false;
					failedResults := jdo.getPropertyValue('failedResults').Binary;
					if failedResults &lt;&gt; null then
						resultDetails := failedResults.uncompressToStringJMT();
					endif;
					passedResults := jdo.getPropertyValue('passedResults').Binary;
					if passedResults &lt;&gt; null then
						resultDetails := passedResults.uncompressToStringJMT();
						passed := true;
					endif;		
					resultDetails.replaceString(Cr, "");
					resultDetails.replaceString(Lf, " ");
					write dict.String &amp; Tab &amp; dict.creationTime.String &amp; Tab &amp; obj.String &amp; Tab &amp; startTimeStamp.String &amp; Tab &amp; 
						runTimeStamp.String &amp; Tab &amp; lastPassedDate.String &amp; Tab &amp; passed.String &amp; Tab &amp; 
						resultDetails;
				else
					file.writeLine(dict.String &amp; Tab &amp; obj.String);
				endif;
				*/
				checked := true;
			
			endif;
		endforeach;
		
		if invalidObj then
			dict.inspect();
			
			count := count + 1;
			write dict.String &amp; Tab &amp; dict.creationTime.String &amp; Tab &amp; "***Invalid***";
			file.writeLine(dict.String &amp; Tab &amp; dict.creationTime.String &amp; Tab &amp; "***Invalid***");
//			dict._zap();
//			delete dict;
		endif;
	
	endforeach;
	file.close();
	commitTransaction;

	write 'Count: ' &amp; count.String;
	
epilog

	delete file;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhMethodCreateChanged" id="b0e63caf-2243-483d-90ed-da5b644f395b">
        <source>mdhMethodCreateChanged();

/*

Purpose:		Methods changed in the last ? days

Date			Who		Reason
16/05/2014		cnwmh5	Initial creation

*/

vars

	klass						: Class;
	meth						: Method;
	file						: File;
	
	classes						: ClassColl;
	methodsDict					: MethodNDict;
	tokens						: StringArray512;
	
	found						: Boolean;
	linePos						: Integer;
	line						: String;
	token						: String;
	cnwPos						: Integer;
	userName					: String;
	indexOf						: Integer;
	noDays						: Integer;
	dateToCheck					: Date;
	modifiedTS					: TimeStamp;
	daysStr						: String;
	
	startDate					: Date;
	endDate						: Date;

begin

	
	//dateToCheck.setDate(03,01,2018);
	startDate.setDate(02, 01, 2018);
	endDate.setDate(03, 01, 2018);

	create file transient;
	file.fileName := "c:\temp\UnitTestChangesLastNoDays.csv";
	if file.isAvailable() then
		file.purge();
	endif;
	file.writeLine("Class,Method,Owner,Date,Time");

	// get UT_DSL class
	klass := currentSchema.getClass("UT_DSL");
	if klass = null then
		return;
	endif;
	
	// create classes
	create classes transient;
	classes.add(klass);
	klass.allLocalSubclasses(classes);
	
	create tokens transient;
	foreach klass in classes do
	
		methodsDict := klass.cnGetMethods();
		
		foreach meth in methodsDict  do
			
			modifiedTS := meth.cnGetModifiedTimeStamp();
			
			if modifiedTS.date &gt;= startDate and modifiedTS.date &lt;= endDate then
				file.writeLine(meth.schemaType.name &amp; "," &amp; meth.name &amp; "," &amp; meth.cnGetModifierName() &amp; "," &amp;
					modifiedTS.date.String &amp; "," &amp; modifiedTS.time.String);
				write meth.schemaType.name &amp; "," &amp; meth.name &amp; "," &amp; meth.cnGetModifierName() &amp; "," &amp;
					modifiedTS.date.String &amp; "," &amp; modifiedTS.time.String;
			endif;
			
		endforeach;
		
	endforeach;
	file.close();

epilog

	delete file;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhMethodsChangedInLastNoDays" id="eaaedbde-32d0-4bec-92d0-e1ff6a95b5ae">
        <source>mdhMethodsChangedInLastNoDays();

/*

Purpose:		Methods changed in the last ? days

Date			Who		Reason
16/05/2014		cnwmh5	Initial creation

*/

vars

	klass						: Class;
	meth						: Method;
	file						: File;
	
	classes						: ClassColl;
	methodsDict					: MethodNDict;
	tokens						: StringArray512;
	
	found						: Boolean;
	linePos						: Integer;
	line						: String;
	token						: String;
	cnwPos						: Integer;
	userName					: String;
	indexOf						: Integer;
	noDays						: Integer;
	dateToCheck					: Date;
	modifiedTS					: TimeStamp;
	daysStr						: String;

begin

	daysStr := "0";
	while true do
		read daysStr;
		if daysStr = null then
			return;
		endif;
		if daysStr.isInteger() then
			noDays := daysStr.Integer;
			break;
		endif;
	endwhile;

	
	dateToCheck := dateToCheck.addDays(-noDays);

	create file transient;
	file.fileName := "c:\temp\UnitTestChangesLastNoDays.csv";
	if file.isAvailable() then
		file.purge();
	endif;
	file.writeLine("Class,Method,Owner,Date,Time");

	// get UT_DSL class
	klass := currentSchema.getClass("UT_DSL");
	if klass = null then
		return;
	endif;
	
	// create classes
	create classes transient;
	classes.add(klass);
	klass.allLocalSubclasses(classes);
	
	create tokens transient;
	foreach klass in classes do
	
		methodsDict := klass.cnGetMethods();
		
		foreach meth in methodsDict  do
			
			modifiedTS := meth.cnGetModifiedTimeStamp();
			
			if modifiedTS.date &gt;= dateToCheck then
				file.writeLine(meth.schemaType.name &amp; "," &amp; meth.name &amp; "," &amp; meth.cnGetModifierName() &amp; "," &amp;
					modifiedTS.date.String &amp; "," &amp; modifiedTS.time.String);
			endif;
			
		endforeach;
		
	endforeach;
	file.close();

epilog

	delete file;

end;</source>
    </JadeMethod>
