    <JadeMethod name="setProxyFromObject" id="5fd3e12b-e51a-4248-a48e-5e50a9abe5c0">
        <updating/>
        <source>setProxyFromObject(error : CM_Error) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2020	jlgrr1	Initial creation

*/

vars

begin

	self.timestamp := "";
	self.level	:= NavisAPI_ErrorLevel_SEVERE;
	self.message := error.text;
	self.status := HttpResponseClientError;
	self.error := error.errorCode.String;	
	
epilog

end;</source>
        <Parameter name="error" type="CM_Error"/>
    </JadeMethod>
