    <JadeMethod name="createGTEOut" id="eff19fee-f28f-416a-b81b-0974cc4cc673">
        <source>createGTEOut( _ti : CM_Container; _vvr : CM_VehicleVisitRecord io ) : CMGTE_Entity protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2012	cnwndl1	Initial creation

*/

vars

	controller : CMIF_FlexiGateController;
	pxyGateEntity, gateEntity: CMGTE_Entity;
	release: CM_BulkRelease;
	releaseType : Integer;
	releaseByType : Boolean;
	subTerm : CM_SubTerminal;

begin

	// Create the GTE Entity and add to VVR
	create controller transient;
	create pxyGateEntity as CMGTE_Release transient;
	controller.myTerminal := _ti.myTerminal;
	if _ti.isEmpty then
		controller.jobType := CMGTE_Entity.JobType_EmptyOUT;   // MT
	else
		controller.jobType := CMGTE_Entity.JobType_FullOUT;   // full
	endif;
	controller.numItems := 1;
	controller.id := _ti.id;
	controller.isoTypeCode := _ti.isoType;
	controller.operatorCode := _ti.operatorCode;
	controller.consigneeCode	:= _ti.consignee;
	controller.cargoType := TI_CargoType_Container;
	controller.myVehicleVisitRecord := _vvr;
	controller.yardLocationTxt :=  _ti.myPrimaryActualLocation.getFullId;
	
	releaseType := null;
	release := self.addReleaseById(_ti.id, BR_TYPE_ROAD, _ti);
	
	if release &lt;&gt; null then 
		controller.myBulkRelease := release;
		controller.myReserveDetail := release.allReserveDetails.first;
		controller.deliveryReason	:= release.deliveryReasonDescr;
		
		if controller.myReserveDetail &lt;&gt; null then
			controller.isoTypeCode := controller.myReserveDetail.getISOTypeCode;
			controller.isoGroup := controller.myReserveDetail.getISOGroupCode;
			controller.operatorCode := controller.myReserveDetail.getOperatorCode;
			if release.myVoyage &lt;&gt; null then
				controller.voyageCode := release.myVoyage.code;
			endif;
			if controller.myReserveDetail.isKindOf(CM_ReserveSelection) then
				controller.myReserveDetail.CM_ReserveSelection.allTerminalAreas.copy(controller.allSourceTAs);
				controller.billOfLading := controller.myReserveDetail.getBOLNumber;
			endif;
		endif;
		
		controller.mtOnly := not release.fullRelease;
		releaseType := release.type;
		releaseByType := release.releaseByType;
	endif;
	
	if app.isSubTerminalsOn(self.getTerminal) then
		subTerm := self.getTerminal.getDefaultSubTerminal(	CM_SubTerminal.Type_BulkRelease,
															releaseType,
															0,
															null,
															false);
		if subTerm &lt;&gt; null then
			controller.subTerminalCode := subTerm.code;
		endif;
	endif;

	pxyGateEntity.setPXYFromController(controller); 
	
	pxyGateEntity.CMGTE_Release.setIsReleaseById(true);

	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateInOutFlexiGateEntity(_vvr, pxyGateEntity, gateEntity, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	return gateEntity;
	
epilog

	delete pxyGateEntity;
	delete controller;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_Container"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="io"/>
        <ReturnType type="CMGTE_Entity"/>
    </JadeMethod>
    <JadeMethod name="createGTEOutBBlk" id="da6ddcd2-98bd-4717-86fc-f9927a91fa89">
        <source>createGTEOutBBlk( _ti : CM_Cargo; _vvr : CM_VehicleVisitRecord io; _amount : Integer ) : CMGTE_Entity protected;
/*
Purpose - 	
Who - NAVAB1
Date - 02MAY2025
ADO - JIRA 34760
*/


vars

	controller : CMIF_FlexiGateController;
	pxyGateEntity, gateEntity: CMGTE_Entity;
	release: CM_BulkRelease;
	releaseType : Integer;
	releaseByType : Boolean;
	subTerm : CM_SubTerminal;

begin

	// Create the GTE Entity and add to VVR
	create controller transient;
	create pxyGateEntity as CMGTE_Release transient;
	controller.myTerminal := _ti.myTerminal;
	controller.jobType := CMGTE_Entity.JobType_GeneralOUT;

	controller.numItems := _amount;
	controller.id := _ti.id;
	controller.myTrackedItem := _ti;
	//controller.isoTypeCode := _ti.isoType;
	controller.operatorCode := _ti.operatorCode;
	controller.consigneeCode	:= _ti.consignee;
	controller.cargoType := _ti.cargoType;
	controller.myVehicleVisitRecord := _vvr;
	controller.yardLocationTxt :=  _ti.myPrimaryActualLocation.getFullId;
	
	releaseType := null;
	self.opts.purge();
	self.opts.addAssoc("TotalRequested",_amount); // Release 1000

	release := self.addReleaseById(_ti.id, BR_TYPE_ROAD, _ti);
	
	if release &lt;&gt; null then 
		controller.myBulkRelease := release;
		controller.myReserveDetail := release.allReserveDetails.first;
		controller.deliveryReason	:= release.deliveryReasonDescr;
		
		if controller.myReserveDetail &lt;&gt; null then
			controller.isoTypeCode := controller.myReserveDetail.getISOTypeCode;
			controller.isoGroup := controller.myReserveDetail.getISOGroupCode;
			controller.operatorCode := controller.myReserveDetail.getOperatorCode;
			if release.myVoyage &lt;&gt; null then
				controller.voyageCode := release.myVoyage.code;
			endif;
			if controller.myReserveDetail.isKindOf(CM_ReserveSelection) then
				controller.myReserveDetail.CM_ReserveSelection.allTerminalAreas.copy(controller.allSourceTAs);
				controller.billOfLading := controller.myReserveDetail.getBOLNumber;
			endif;
		endif;
		
		controller.mtOnly := not release.fullRelease;
		releaseType := release.type;
		releaseByType := release.releaseByType;
	endif;
	
	if app.isSubTerminalsOn(self.getTerminal) then
		subTerm := self.getTerminal.getDefaultSubTerminal(	CM_SubTerminal.Type_BulkRelease,
															releaseType,
															0,
															null,
															false);
		if subTerm &lt;&gt; null then
			controller.subTerminalCode := subTerm.code;
		endif;
	endif;

	pxyGateEntity.setPXYFromController(controller); 
	
	pxyGateEntity.CMGTE_Release.setIsReleaseById(true);

	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateInOutFlexiGateEntity(_vvr, pxyGateEntity, gateEntity, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	return gateEntity;
	
epilog

	delete pxyGateEntity;
	delete controller;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_Cargo"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="io"/>
        <Parameter name="_amount" type="Integer"/>
        <ReturnType type="CMGTE_Entity"/>
    </JadeMethod>
    <JadeMethod name="createMoreCargoForCash" id="90647e9e-d307-4345-b970-041cd46a58a9">
        <updating/>
        <source>createMoreCargoForCash(_extraMoves : Boolean; _connectReefers : Boolean) protected, updating;
// cnwjre1
/*	
	Create cargo for cash module testing, in nominated terminal for nominated voyage and cargo operator
	with known transactions and existing charges.
*/
vars
	terminalId	: String;
	bolId		: String;
	terminal	: CM_Terminal;
	passTerm	: CM_Terminal;
	appBank		: CM_Bank;
	bs 			: CM_TerminalArea;
	operator	: CM_Operator;
	ti			: CM_TrackedItem;
	containers	: CM_TISet;
	voyage : CM_Voyage;
	tran : CM_TITransaction;
	tranTS : TimeStamp;
	tranDate : Date;
	now : Date;

begin
	now := app.actualTimeServer().date();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	// save app/passport attributes for current terminal
	passTerm := app.myPassport.myTerminal;
	appBank := self.myBank;

	terminalId := "JT1";
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminalId);
	terminal := self.getTerminal();
	app.myPassport.setPropertyValue("myTerminal", terminal);
	self.myBank := terminal.getDefaultCompanyBank();
	
	operator := self.getOperator("PON");
	
	voyage := self.createTargetVesselVoyage(terminal, "JMT CASH", "JCASH001", operator);
	
	self.myOperator := operator;
	create containers transient;
	
	//self.createCashCargo(voyage, 0, containers);		// don't back-date the transactions yet
	self.createCashCargo2(voyage, 0, containers);		// don't back-date the transactions yet
	
	// update the billOfLading and voyage
	beginTransaction;
	foreach ti in containers do
		if ti.id[1:5] = "GENU2" then
			bolId := "CASHBOL001";
		elseif ti.id[1:5] = "GENU4" then
			bolId := "CASHBOL002";
		elseif ti.id = "MTMU" then
			bolId := "CASHBOL003";
		elseif ti.id[1:5] = "REEF2" then
			bolId := "CASHBOL004";
		else
			bolId := "CASHBOL005";
		endif;
		ti.setPropertyValue("billOfLading", bolId);
		ti.setMyVoyage(voyage, app.myPassport);
	endforeach;
	commitTransaction;
	
	// optionally move all cargo around to get an extra charge
	if _extraMoves then
		self.opts.addAssoc("Terminal", terminalId);
		bs := self.getTerminal.allTerminalAreas.getAtKeyGeq("BS3");

		foreach ti in containers do
			self.move(ti, bs);
		endforeach;
	endif;
	
	tranDate := now - 10;
	tranTS.setDate(tranDate);
	// back-date transactions 10 days to get storage charges
	foreach ti in containers do
		foreach tran in ti.allTransactions do
			tranTS.setDate(tranDate);
			tranTS.setTime(tran.dateTime.time);
		
			beginTransaction;
			tran.setPropertyValue("dateTime", tranTS);
			commitTransaction;
		endforeach;
		// back-date received and move dates for reefer connection
		beginTransaction;
		ti.setReceivedDT(tranTS);
		ti.setPropertyValue("moveDT", tranTS);
		commitTransaction;
	endforeach;

	// optionally connect all reefers for reefer daily charge - do after back-dating transactions so it works
	if _connectReefers then
		foreach ti in containers do
			if ti.isReefer then
				self.updateTIConnection(ti, false, true, tranTS, null);
			endif;
		endforeach;
	endif;
	
epilog
	delete containers;
	// restore app/passport current terminal attributes
	app.myPassport.setPropertyValue("myTerminal", passTerm);
	self.myBank := appBank;
	self.myOperator := null;
end;</source>
        <access>protected</access>
        <Parameter name="_extraMoves" type="Boolean"/>
        <Parameter name="_connectReefers" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createPartialReceiptCargo" id="7fa4c427-b57b-4293-8b26-86b369888410">
        <updating/>
        <source>createPartialReceiptCargo(_cargoColl : CM_TISet input) : CM_Voyage protected, updating;
// cnwjre1
/*	
	Create cargo for partial receipt unit tests with known transactions and existing charges.
	Revised May 2014 for simpler cargo creation
*/
constants
	MaxCargo = 6;
vars
	baseDate,
	now		: Date;
	count	: Integer;
	debtorName	: String;
	cargoId		: String;
	cargoIds	: StringArray;
	bs : CM_TerminalArea;
	operator	: CM_Operator;
	debtor		: CM_Debtor;
	proxyDebtor		: CM_Debtor;
	debtorNode	: CM_DebtorNode;
	debtorNodeController	: CMIF_DebtorNode;
	ti			: CM_TrackedItem;
	trans		: CM_TITransaction;
	voyage : CM_Voyage;

begin

	// use an operator with a known non-cash debtor
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	debtorName := "UT_Debtor1";
	debtor := app.myRoot.myRootCompany.debtorNodes[debtorName].CM_Debtor;
	if debtor = null then
		create debtorNodeController transient;
		create proxyDebtor transient;
		self.setDebtorNodeController1(debtorName, debtorNodeController, proxyDebtor);
		app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		debtor := debtorNode.CM_Debtor;
	endif;

	beginTransaction;
		operator.setPropertyValue(CM_Operator::debtor.name, debtor);
	commitTransaction;
	self.myOperator := operator;

	// use a specific transaction map, 2 free days
	self.tranMapLoadCashPartial();
	
	voyage := self.createVesselVoyageCash("JMT STAR", "JSTAR001", operator.code);
	self.assertTrueMsg(voyage &lt;&gt; null, "Voyage JSTAR001 not created...");
	
	// ids with valid check digits
	create cargoIds transient;
	self.getCargoIds(cargoIds);
	foreach cargoId in cargoIds do
		count := count + 1;
		if count &gt; MaxCargo then
			break;
		endif;
		self.deleteContainer(cargoId);
	endforeach;
	count := 0;
	foreach cargoId in cargoIds do
		count := count + 1;
		if count &gt; MaxCargo then
			break;
		endif;
		ti := self.addOnsiteCargoForId(cargoId, true, 6);
		beginTransaction;
		ti.setMyVoyage(voyage, app.myPassport);
		foreach trans in ti.allTransactions do
			trans.setPropertyValue("voyage", voyage);
			trans.setPropertyValue("voyageCode", voyage.code);
			trans.setPropertyValue("myVoyageRelivant", voyage);
		endforeach;
		commitTransaction;
		_cargoColl.add(ti);
	endforeach;
	
	return voyage;
epilog
	delete cargoIds;
end;</source>
        <access>protected</access>
        <Parameter name="_cargoColl" type="CM_TISet" usage="input"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createProformaAgent2" id="fc63215f-d10e-4379-bd05-a518283e7835">
        <source>createProformaAgent2(_effective : TimeStamp; _shipReleaseDate : Date; _ti : CM_TrackedItem) : CM_CashInvoiceProformaAgent protected;
/*

Purpose:			Create an return a pro

Parameters:			

Return Value:		


Date		Who		Reason
22/10/2013	cnwjre1	Cash testing

*/

vars
	bank		: CM_Bank;
	agent 	    : CM_CashInvoiceProformaAgent;
	effectiveDT : TimeStamp;

begin

	create agent transient;
	bank := self.getTerminal.getDefaultCompanyBank();
	effectiveDT := _effective;
	app.myPassport.clearErrorsWarnings;
	agent.init( bank, _ti, effectiveDT.date, false );
	agent.setReleaseDate(_shipReleaseDate);
	agent.createProformaInvLines( null, false, false );		// no consolidation, no extra lines
	agent.getCurrentInvLines();							    // existing invoice lines from transactions
	
	return agent;
epilog
	
	app.allReportObjectSet.purge();		// used as temporary invoice storage
end;</source>
