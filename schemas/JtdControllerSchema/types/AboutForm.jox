    <JadeMethod name="btnClose_click" id="61b2885e-e047-44eb-b2e6-296c12449148">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClose_click(btn: Button input) updating;

begin
	self.unloadForm;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="load" id="f957d9f5-8154-4c06-acc0-175715c60ee9">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	if app.name = "JtdControllerApp" then
		self.caption := "About Driver Controller";
		self.lblAppName.caption := "Driver Controller";
	else
		self.caption := "About Driver Profile Editor";
		self.lblAppName.caption := "Driver Profile Editor";
	endif;
		
	self.lblVersion.caption := app.getVersionString;
	self.lblJadeVersion.caption := app.getSystemVersion;

	self.centreWindow;
end;</source>
    </JadeMethod>
