    <JadeMethod name="scaleDimensions" id="490ab4d9-e1c4-4470-a931-e88ad7c8583e">
        <updating/>
        <source>scaleDimensions(_scale : Real) updating;
/*
Date		    Who			Reason
14 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/


vars
	
begin
	
	
	self.interLocnSlotsHeight := (self.interLocnSlotsHeight * _scale).Integer;
	self.locnDefnHeight := (self.locnDefnHeight * _scale).Integer;
	self.locnDefnWidth := (self.locnDefnWidth * _scale).Integer;
	
	self.interSlotsHeight := (self.interSlotsHeight * _scale).Integer;
	self.interLocnSlotsWidth := (self.interLocnSlotsWidth * _scale).Integer;
	
	self.slotHeight := (self.slotHeight * _scale).Integer;
	self.slotWidth := (self.slotWidth * _scale).Integer;
	
	
epilog

end;</source>
        <Parameter name="_scale" type="Real"/>
    </JadeMethod>
    <JadeMethod name="selectObjectsForJob" id="75923589-3d0c-4220-8abf-dfb2b2a1e379">
        <updating/>
        <source>selectObjectsForJob(_job : CM_VoyageJob; _inLoadMode, _clearFirst : Boolean) updating;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

vars
	tmpHatchLidJob	: CM_VoyageHatchLidJob;
	tmpHatchLid		: CM_HatchLid;
	tmpRequest		: CM_Request;
	tmpSlotRequest	: CM_RORORequest;
	tmpLC			: CM_LocationsController;
	tmpSlot			: CM_VoyageROROController;
	tmpTI			: CM_TrackedItem;
	tmpBay			: CM_Bay;
	tmpFrame		: SHP_BayDrawingFrame;
begin

	app.mousePointer := Window.MousePointer_HourGlass;

	beginLoad;

	if _clearFirst then
		self.clearAllSelectedObjects();
	endif;
	
	if _job.isKindOf(CM_VoyageDeckJob) then
		foreach tmpRequest in _job.allRequests do
			if (not CM_RORORequest.hasInstance(tmpRequest)) then
				continue;
			endif;
			tmpSlotRequest := tmpRequest.CM_RORORequest;
			if _inLoadMode then
				if tmpSlotRequest.isDischarge then
					continue;
				endif;
			else
				if tmpSlotRequest.isLoad then
					continue;
				endif;
			endif;
			if tmpSlotRequest.myLayout = null then
				continue;
			endif;
			self.selectObject(tmpSlotRequest.myROROController, self.mySideViewFrame,true);
		endforeach;
		
	endif;

epilog
	endLoad;
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="_job" type="CM_VoyageJob"/>
        <Parameter name="_inLoadMode" type="Boolean"/>
        <Parameter name="_clearFirst" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDrawStyleAndColors" id="47ce899e-5daa-445f-a7b4-0f32f224154c">
        <updating/>
        <source>setDrawStyleAndColors(_objectToDraw : Object; _frame : SHP_ROROScrollingFrame input; _drawFillColor : Integer io;
		_outerColourUpper, _outerColourLower : Integer output) updating, protected;
/*
Date		    Who			Reason
14 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/
//15 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed 
vars
	slotDefn : CM_ROROSlotDefnVoyage;
	theTI : CM_TrackedItem;
begin

	_frame.drawFillStyle := Frame.DrawFillStyle_Solid;
	_frame.drawStyle := Frame.DrawStyle_Solid;
	_frame.drawWidth := 2;
	
	
	if self.allSelectedObjects.includes(_objectToDraw) or self.allSelectedObjectsAlt.includes(_objectToDraw) then
		_outerColourLower := White;
		_outerColourUpper := DarkGray;
	else
		_outerColourLower := DarkGray;
		_outerColourUpper := White;
	endif;
	//self.drawFillColor := _drawFillColor;
	_frame.drawFillColor := _drawFillColor;
	if _objectToDraw.isKindOf(CM_ROROLocnDefn) then

	endif;
	// ### SET FILL STYLE FOR MODE
	if _objectToDraw.isKindOf(CM_ROROSlotController) then
		slotDefn := _objectToDraw.CM_ROROSlotController.mySlotDefn;		
	
		if self.modeView = ShpDisplayMode_ColCodeLoad then
			if slotDefn.mySlotController.myRORORequestLoad &lt;&gt; null then
				_frame.drawFillStyle := Frame.DrawFillStyle_Solid;
			else
				slotDefn.mySlotController.getTIs(self.allTempTIs, REAL_MODE, true);
				theTI := self.allTempTIs.first();
				if theTI &lt;&gt; null then
					if slotDefn.mySlotController.myRORORequestDischarge = null then // PAR 29050 
						_frame.drawFillStyle := Frame.DrawFillStyle_Solid; // PAR 29050 Frame.DrawFillStyle_DiagonalCross; // RoB
						_frame.drawFillColor := White; // PAR 29050
					else
						_frame.drawFillStyle := Frame.DrawFillStyle_Solid;
					endif;
				else
					_frame.drawFillStyle := Frame.DrawFillStyle_Solid; // DEFAULT
				endif;
			endif;
		elseif self.modeView = ShpDisplayMode_ColCodeDisch then
			if slotDefn.mySlotController.myRORORequestDischarge &lt;&gt; null then
				_frame.drawFillStyle := Frame.DrawFillStyle_Solid;
			else
				slotDefn.mySlotController.getROB(self.allTempTIs, true, false); // PAR 29050 //15 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
				theTI := self.allTempTIs.first();
				if theTI &lt;&gt; null then
// PAR 29050					if slotDefn.mySlotController.myRORORequestLoad &lt;&gt; null then
//	 PAR 29050					_frame.drawFillStyle := Frame.DrawFillStyle_DiagonalCross;
//	 PAR 29050				else
						if self.modeViewSub = ShpDisplayModeSub_Colour then
							_frame.drawFillStyle := Frame.DrawFillStyle_Solid; // PAR 29050 DrawFillStyle_DiagonalCross;
							_frame.drawFillColor := White; // PAR 29050
						else
							_frame.drawFillStyle := Frame.DrawFillStyle_Solid;
						endif;
	//				endif;
				else
					_frame.drawFillStyle := Frame.DrawFillStyle_Solid; // DEFAULT
				endif;
			endif;
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_objectToDraw" type="Object"/>
        <Parameter name="_frame" type="SHP_ROROScrollingFrame" usage="input"/>
        <Parameter name="_drawFillColor" type="Integer" usage="io"/>
        <Parameter name="_outerColourUpper" type="Integer" usage="output"/>
        <Parameter name="_outerColourLower" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setFromLocnDefn" id="a3a42845-1084-464d-8489-f3aaae659eaf">
        <updating/>
        <source>setFromLocnDefn(_locnDefn : CM_ROROLocnDefnVoyage; x1, y1, x2, y2 : Real) updating;
/*
Date		    Who			Reason
12 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars	
	
begin

	if _locnDefn = null then		
		return;
	endif;

	self.x1	:= x1;
	self.y1	:= y1;
	self.x2	:= x2;
	self.y2	:= y2;

	self.myCurrentROROLocnDefn := _locnDefn;
	
	self.myCurrentObject := _locnDefn;
	
end;</source>
        <Parameter name="_locnDefn" type="CM_ROROLocnDefnVoyage"/>
        <Parameter name="x1" type="Real"/>
        <Parameter name="y1" type="Real"/>
        <Parameter name="x2" type="Real"/>
        <Parameter name="y2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setFromSlotDefn" id="13391749-2678-4897-af2e-00b875bb254d">
        <updating/>
        <source>setFromSlotDefn(_slotDefn : CM_ROROSlotDefnVoyage; x1, y1, x2, y2 : Real) updating;
/*
Date		    Who			Reason
12 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	
	tmpSlot	: CM_ROROSlotController;

begin

	if _slotDefn = null then		
		return;
	endif;

	self.x1	:= x1;
	self.y1	:= y1;
	self.x2	:= x2;
	self.y2	:= y2;

	self.myCurrentROROSlotDefn := _slotDefn;	
	
	tmpSlot := _slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
	
	self.myCurrentObject := tmpSlot;
	
end;</source>
        <Parameter name="_slotDefn" type="CM_ROROSlotDefnVoyage"/>
        <Parameter name="x1" type="Real"/>
        <Parameter name="y1" type="Real"/>
        <Parameter name="x2" type="Real"/>
        <Parameter name="y2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setupDimensions" id="d13bf907-8297-4562-b587-7890d5d313c6">
        <updating/>
        <source>setupDimensions() updating;
/*
Date		    Who			Reason
15 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	tmpVessel : CM_Vessel;
	allStateData : CM_StateDataDict;
	locnGap, locnLength, locnWidth : Decimal[12,2];
begin
		
		
	tmpVessel := self.myVessel;
	
	if tmpVessel  &lt;&gt; null then
		allStateData:= tmpVessel.allStateData;
		if allStateData = null or allStateData.size = 0 then
			allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
		endif;
	else
		allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
	endif;
	
	global.getExtraData(allStateData,RoRoLocationGap,locnGap);
	global.getExtraData(allStateData,RoRoLocationWidth,locnWidth);
	global.getExtraData(allStateData,RoRoLocationLength,locnLength);
	if locnGap = 0 then	//cnwas3 par 28382
		locnGap := 0.1;
	endif;
	if locnWidth = 0 then
		locnWidth := 3;
	endif;
	if locnLength = 0 then
		locnLength := 6;
	endif;
	
	self.interLocnSlotsHeight := (locnGap * ROROStructurePixelsPerMetre * 2).Integer; //without * 2 it looks way to cramped. while this is usefull in the planning overviews of the entire bay, for the purpose of this screen,we need to take a better closer look at the selected location defns/slot defns
	self.locnDefnHeight := (locnWidth * ROROStructurePixelsPerMetre).Integer;	
	self.locnDefnWidth := (locnLength * ROROStructurePixelsPerMetre).Integer;
	
	self.interSlotsHeight := (self.interLocnSlotsHeight/2).Integer;
	self.interLocnSlotsWidth := self.interLocnSlotsHeight * 2;
	
	self.slotHeight := (self.locnDefnHeight).Integer;
	self.slotWidth := self.locnDefnWidth;
	
	self.scaleDimensions(1);
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="slotHeight" id="a01467f8-b7a3-4052-8627-2cdffb9e81a2">
