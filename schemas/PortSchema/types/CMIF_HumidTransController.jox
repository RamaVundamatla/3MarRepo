    <ImplicitInverseRef name="myHumidReading" id="4c9bdeb4-ae44-4d66-b7dd-848b39743cb9">
        <embedded/>
        <type name="CM_HumidReading"/>
    </ImplicitInverseRef>
    <JadeMethod name="setFromTransaction" id="4db1c732-90f6-479b-8a40-553dd5264e18">
