    <JadeMethod name="resetRTMoveMethod" id="b4784bb5-1a23-4eb0-ae98-a8c917e5c8b2">
        <source>resetRTMoveMethod(pConstant : Constant; _passport : CM_Passport input);

// Created by cnwdvb1 on 28 August 2006



vars

	rtMoveMethod		: CM_RTMoveMethod;
	str					: String;
	type				: Integer;
	
begin

	if pConstant.valueAsInteger &gt; RTMoveMethod_Max then
	   	return;
	endif;

	//epr par 21619
	if pConstant.valueAsInteger = RTMoveMethod_Max and pConstant.text = null then
		return;
	endif;
		
	type := pConstant.valueAsInteger;
	rtMoveMethod := self.allRTMoveMethods[type];
	str := pConstant.text;
	if str = null then
		return;
	endif;
	
	beginTransaction;
	if  rtMoveMethod =  null then
		create rtMoveMethod persistent;
	endif;
	
	rtMoveMethod.setFromXML(type, str, self);
	commitTransaction;

	

end;</source>
        <Parameter name="pConstant" type="Constant"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
