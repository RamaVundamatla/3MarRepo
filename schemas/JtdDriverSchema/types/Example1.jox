        <updating/>
        <source>e022_YGAF_table_click():Integer updating;

vars
	table:Table;
begin
	myCM_ContainerEnqForm.tblEdit1.mouseUp(myCM_ContainerEnqForm.tblEdit1, 1, 0, 201, 129);
	app.doWindowEvents(shortPause);
	if app.isValidObject(myCM_ContainerEnqForm) then
		myCM_ContainerEnqForm.unloadForm;  // 14:16:57
	endif;
	myCM_ContainerEnqForm:=null;
	table:=app.atcgGetAddedControl(myYRD_GridAreasForm, 'table;CM_ColourLegendTable;0;-91;0;0;|frmColLegendTIs;CMUI_ColourLegendFrame;0;-91;0;0;|dkbColorLegend;CMUI_JadeDockBar;0;-469;0;0;|').Table;
	table.row:=5;
	table.column:=1;
	table.clearAllSelected();
	table.accessCell(5,1).selected:=true;
	table.rowColumnChg(table);
	table:=app.atcgGetAddedControl(myYRD_GridAreasForm, 'table;CM_ColourLegendTable;0;-91;0;0;|frmColLegendTIs;CMUI_ColourLegendFrame;0;-91;0;0;|dkbColorLegend;CMUI_JadeDockBar;0;-469;0;0;|').Table;
	table.mouseDown(table, 1, 0, 30, 74);
	app.doWindowEvents(shortPause);
	table:=app.atcgGetAddedControl(myYRD_GridAreasForm, 'table;CM_ColourLegendTable;0;-91;0;0;|frmColLegendTIs;CMUI_ColourLegendFrame;0;-91;0;0;|dkbColorLegend;CMUI_JadeDockBar;0;-469;0;0;|').Table;
	table.mouseUp(table, 1, 0, 30, 74);
	app.doWindowEvents(shortPause);
	table:=app.atcgGetAddedControl(myYRD_GridAreasForm, 'table;CM_ColourLegendTable;0;-91;0;0;|frmColLegendTIs;CMUI_ColourLegendFrame;0;-91;0;0;|dkbColorLegend;CMUI_JadeDockBar;0;-469;0;0;|').Table;
	app.doWindowEvents(shortPause);
	table.row:=5;
	table.column:=1;
	table.click(table);  // 14:16:59
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
