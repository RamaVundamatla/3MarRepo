    <JadeMethod name="setBalances" id="95c1f7e6-2ed8-49a8-9430-c46c7167d961">
        <updating/>
        <source>setBalances() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 Jul 2012	cnwndl1	Initial creation
25 Jul 2019	jlgsl4	TFS 44274 - Cash Credit
16 Oct 2019 cnwma1	ChangeRequest 46984: JMT - Refactor Cash Credit UI and Tax
*/

vars
	unCreditPayments	: Decimal[23,6];
begin

	self.creditTotal        := 0;
	self.creditPrevCreated  := 0;
	unCreditPayments        := self.getUnCreditTotal();
	self.creditTotal 		:= self.creditTotal + unCreditPayments;
	
	
	if self.tblCharges.rows &gt; 1 then
		self.setTableCreditTotal(true);
	endif;
	lblCreditAvailableValue.caption      := self.creditTotal.roundedTo(2).asCurrencyJMT;


epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDefaultCargoDebtorDetails" id="82b4fa06-6877-4705-9d43-604b3e511786">
        <updating/>
        <source>setDefaultCargoDebtorDetails() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 Jul 2012	cnwndl1	Initial creation	Par 29968
18 Sep 2019	cnwma1	Bug 46582: Cash Credit are not being accounted for correctly
*/

vars

begin

	self.setMyDebtor(null);
	self.tblCharges.rows := self.tblCharges.fixedRows;
	self.setBalances();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setEstimatedCharges" id="03560d63-4ae5-4388-977b-032dac41dfb0">
        <updating/>
        <source>setEstimatedCharges() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Oct 2019 cnwma1 ChangeRequest 46984: JMT - Refactor Cash Credit UI and Tax
08 Jan 2020 cnwma1 Bug 48211: JMT - 4 x Issues relating to cash credit totals.
*/

vars
	valueOnPayment,
	valueOnPaymentTax,
	creditOnPayment,
	creditOnPaymentTax,
	cashOnPaymentPrevCredit			: Decimal[23,6];
	table							: CM_DataTable;
	cashPayment						: CM_CashPayment;
	ti              				: CM_TrackedItem;
	row 							: Integer;
	obj              				: Object;
	allTIOnCashPayment, 
	allTIOnPrevCredit,
	allCashPayment,
	allCashPaymnetNonTI,
	allCashPaymentPrevCredit,
	allCashPaymentPrevCreditNonTI,
	allInvoiceLines					: ObjectArray;
begin
	
	self.resetForm();
	table := self.tblCharges;
	
	create allCashPayment  	             transient;
	create allCashPaymnetNonTI  	     transient;
	create allCashPaymentPrevCredit      transient;
	create allTIOnCashPayment            transient;
	create allTIOnPrevCredit             transient;
	create allCashPaymentPrevCreditNonTI transient;
	create allInvoiceLines               transient;
	
	self.myCashReceipt.populateCashReceiptDetails(allCashPayment,
										allCashPaymnetNonTI,
										allCashPaymentPrevCredit,
										allCashPaymentPrevCreditNonTI,
										allTIOnCashPayment,
										allTIOnPrevCredit,
										allInvoiceLines);
										
	
	if not allCashPayment.isEmpty then
		foreach  obj in allTIOnCashPayment discreteLock do 
			ti := obj.CM_TrackedItem;
			self.addRowCargo(ti,true);
			foreach obj in allCashPayment discreteLock do 
				
				if ti &lt;&gt; obj.CM_CashPayment.myTrackedItem then
					continue;
				endif;
				table.rows := table.rows + 1;	
				table.row  := table.rows;
				row		   := table.rows;
				
				self.addRowPayment(obj.CM_CashPayment,row,true);
				
			endforeach;
		endforeach;
		
		if table.rows &gt; 0 then
			self.addRowPaymentCreditTotal(self.getUnCreditTotal(),true);
		endif;
		self.btnSave.visible	:= true;
	endif;
	
	
	if allCashPaymnetNonTI.isNotEmpty then
		self.addRowSepartor(null);
		foreach obj in allCashPaymnetNonTI discreteLock do
		
			table.rows := table.rows + 1;	
			table.row  := table.rows;
			row		   := table.rows;
			self.addRowPayment(obj.CM_CashPayment,row,true);
		endforeach;
	endif;

	self.setBalances();
	
	/* Later will be used  to display previous Credits on Payment*/
	
	if allCashPaymentPrevCredit.isNotEmpty then
		self.addRowSepartor("Previous Credits");
		valueOnPaymentTax       := 0;
		creditOnPaymentTax      := 0;
		foreach  obj in allTIOnPrevCredit discreteLock do 
			ti := obj.CM_TrackedItem;
			self.addRowCargo(ti,false);
			foreach obj in allCashPaymentPrevCredit discreteLock do 
				
				cashPayment		  := obj.CM_CashPayment;
				valueOnPayment    := cashPayment.cashValue;
				creditOnPayment   := cashPayment.getCreditedAmount;
				
				valueOnPaymentTax  := 0;   //08.01.2020 cnwma1 #48211
				creditOnPaymentTax := 0;   //08.01.2020 cnwma1 #48211
				if cashPayment.hasTax then
					valueOnPaymentTax  := cashPayment.myCashPaymentForTax.cashValue;
					creditOnPaymentTax := cashPayment.myCashPaymentForTax.getCreditedAmount;
				endif;  
				
				if ti &lt;&gt; obj.CM_CashPayment.myTrackedItem then
					continue;
				endif;
				
				table.rows := table.rows + 1;	
				table.row  := table.rows;
				row		   := table.rows;
				 cashOnPaymentPrevCredit	 := cashOnPaymentPrevCredit +( valueOnPayment + valueOnPaymentTax) +(creditOnPayment + creditOnPaymentTax);
				self.addRowPayment(obj.CM_CashPayment,row,false);
			endforeach;
		endforeach;
		

	if allCashPaymentPrevCreditNonTI.isNotEmpty then
		self.addRowSepartor(null);
		valueOnPaymentTax       := 0;
		creditOnPaymentTax      := 0;
		foreach obj in allCashPaymentPrevCreditNonTI discreteLock do
			
			cashPayment		  := obj.CM_CashPayment;
			valueOnPayment    := cashPayment.cashValue;
			creditOnPayment   := cashPayment.getCreditedAmount;
			
			valueOnPaymentTax  := 0;   //08.01.2020 cnwma1 #48211
			creditOnPaymentTax := 0;   //08.01.2020 cnwma1 #48211
			if cashPayment.hasTax then
				valueOnPaymentTax  := cashPayment.myCashPaymentForTax.cashValue;
				creditOnPaymentTax := cashPayment.myCashPaymentForTax.getCreditedAmount;
			endif; 
				
			table.rows := table.rows + 1;	
			table.row  := table.rows;
			row		   := table.rows;
			cashOnPaymentPrevCredit	 := cashOnPaymentPrevCredit +( valueOnPayment + valueOnPaymentTax) +(creditOnPayment + creditOnPaymentTax);
			self.addRowPayment(obj.CM_CashPayment,row,false);
		endforeach;
	endif;
	
	
	
	self.creditPrevCreated  := cashOnPaymentPrevCredit;
		
	if table.rows &gt; 0 then
			self.addRowPaymentCreditTotal(self.creditPrevCreated,false);
		endif;
		
	endif;
	
epilog
	delete allCashPayment ;
	delete allCashPaymnetNonTI ;
	delete allCashPaymentPrevCredit;
	delete allTIOnCashPayment ;
	delete allTIOnPrevCredit ;
	delete allCashPaymentPrevCreditNonTI;
	delete allInvoiceLines;
end;</source>
    </JadeMethod>
