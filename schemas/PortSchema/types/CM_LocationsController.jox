    <JadeMethod name="isMixedRowForView" id="4543d601-0669-47c4-8ac6-59a99eedc3d9">
        <source>isMixedRowForView(pView : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:      11 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
20 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens
					Remove server execution, add cargo type

*/

begin
	if pView = VIEW_OPERATOR and self.hasMixedOperators then
		return true;
	endif;
	
	if pView = VIEW_VOYAGE and self.hasMixedVoyages then
		return true;
	endif;
	
	if pView = VIEW_LOG_GRADE and self.hasMixedLogGrades then
		return true;
	endif;

	if pView = VIEW_CARGO_TYPE and self.hasMixedCargoTypes() then
		return true;
	endif;

	return false;
end;</source>
        <Parameter name="pView" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
