    <JadeMethod name="handleUiException" id="9dd09934-49ad-449c-a4be-2ac94a0f845c">
        <source>handleUiException(_exObj : Exception; _hadException : Boolean output) : Integer protected;
// 36236 detect an item level error and rebuild the lstJobs if found 
begin

	if _exObj.errorCode = 14022 then
		_hadException := true;
		return Ex_Resume_Next;
	endif;

	return Ex_Pass_Back;

end;</source>
