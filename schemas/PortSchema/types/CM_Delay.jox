    <JadeMethod name="createAssociatedEvent" id="b7bceb28-277f-4d3e-88ca-44ddc43e61fe">
        <updating/>
        <source>createAssociatedEvent()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2018	jlgndl1	Initial creation	TFS 40309

*/

vars


begin

	if self.myDelayType.myEventTypeToCreate &lt;&gt; null then
	
		create self.myVoyageEvent;
		self.myVoyageEvent.setDetails(	self.myDelayType.myEventTypeToCreate,	//_eventType: CM_EventType;
							self.startDT,	//_dateTime: TimeStamp;
							self.myTerminal,	//_terminal: CM_Terminal;
							app.getMyUserCode,	//_userCode: String;
							false,	//_noCharge: Boolean;
							1	//_amount: Decimal
							);
							
		self.myVoyageEvent.setEndDataTime( true, self.estEndDT );
		self.myVoyageEvent.setMyVoyage( self.myVoyage );
		if remarks.trimBlanks = null then	//05 Nov 2018 	NDL	TFS 41711
			self.myVoyageEvent.setRemarks( app.getErrorString(Created_from_delay) );
		else
			self.myVoyageEvent.setRemarks( self.remarks.trimBlanks &amp; CrLf &amp; app.getErrorString(Created_from_delay) );
		endif;
		self.myVoyageEvent.setNumMoves( 1 );
		self.myVoyageEvent.setMyVoyageDelay( self );

	endif; 

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createMachineHistory" id="c0d19e01-c15d-47ce-ac23-e02c866cbeff">
        <source>createMachineHistory(_event :CM_EventTransaction)protected;
// ---------------------------------------------------------------------------
// Created:     31 March 2011 by cnwcs5
// Purpose:     Create machine history entry for a delay
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	machine	:CM_Machine;
begin
	machine	:= self.myMachine;
	
	if machine = null then
		// nothing to do
		return;
	endif;
		
	if _event = self.myEventStart then		
		machine.addDelayStartHistory (_event.CMEVT_DelayStart);
	elseif _event = self.myEventEnd then
		machine.addDelayEndHistory (_event.CMEVT_DelayEnd);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_event" type="CM_EventTransaction"/>
    </JadeMethod>
