    <JadeMethod name="getDamageSeverity" id="b323af5e-0a4f-4398-8913-c1253bf1a29b">
        <source>getDamageSeverity() : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20/10/2022 navak20 ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars

begin
	if self.myDamagesInstance &lt;&gt; null then
		return self.myDamagesInstance.getSeverityLevel();
	else
		return self.severity;// ### TFS 55267 02NOV2022 NAVAB1
	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="4215636d-70aa-4b1b-98ba-a798c4d71015">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 02 May 2019
TFS#		: 44287
Function	:

*** Changes ***
Date			Name		TFS#		Description
// 19/10/2022 navak20 ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
****************************************************/

begin
	if _attrName = ETRow_Details then
		if self.deleted then
			return self.getDeletedDetails();
		else
			//return self.damagePositionCode &amp; " " &amp; self.damageCode &amp; "(" &amp; self.severity.String &amp; ") (x" &amp; self.quantity.String &amp; ")";	// 19.10.2022 navak20 TFS 53862
			return self.damagePositionCode &amp; " " &amp; self.damageCode &amp; "(" &amp; self.getDamageSeverity().String &amp; ") (x" &amp; self.quantity.String &amp; ")";	// 19.10.2022 navak20 TFS 53862
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
