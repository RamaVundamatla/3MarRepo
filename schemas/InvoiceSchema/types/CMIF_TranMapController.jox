    <JadeMethod name="setEnableObjects" id="edce57d8-4d41-454d-8297-79b30730ea1a">
        <source>setEnableObjects(form : INV_TransactionMap io);
//09/02/2017 cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time
// 15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
vars

begin

	form.menuTMVnew.visible := false; // &lt;&lt;&lt; MAIN VTMIS NEW 
	form.menuTMVnew.enabled := true; // &lt;&lt;&lt; MAIN VTMIS NEW 
	form.menuTMVmap.enabled := false;
	form.menuTMVmap.visible := true;
	form.menuTMVresource.visible := false;
	form.menuTMVDebtor.enabled := false;
	form.menuTMVDebtor.visible := false;
	form.menuTMVQtyRange.visible := false;
	form.menuSItemPropUpdate.visible := false; //03/04/2025	navkc1 JIRA Bug MTN-34244
	form.menuTMAnew.visible := false; // &lt;&lt;&lt; CARGO ALLOC NEW 
	form.menuTMEnew.visible := false; // &lt;&lt;&lt; MAIN EVENT NEW 
	form.menuTMEnew.enabled := true; // &lt;&lt;&lt; MAIN EVENT NEW 
	form.menuTMEmap.visible := false;
	form.menuTMEevent.visible := false;
	form.menuTMEdebtor.visible := false;
	form.menuTMEQtyRange.visible := false;
	
	//03/04/2025	navkc1 JIRA Bug MTN-34244
	if form.myCurrentMapTMCargoAllocation &lt;&gt; null or form.myCurrentMapTMInventory &lt;&gt; null then
		form.menuSItemPropUpdate.visible := true;
	endif;
	
	// 15/05/2023	navkc1	CR 57927 Task 54268
	form.menuTMETransType.visible := false;
	form.menuTMEResourceType.visible := false;
	
	form.menuTMWOTransType.visible := false;
	form.menuTMWOResourceType.visible := false;
	
	// TFS 39236
	form.menuTMWOnew.visible := false; // &lt;&lt;&lt; MAIN WO NEW 
	form.menuTMWOnew.enabled := true; // &lt;&lt;&lt; MAIN WO NEW 
	form.menuTMWOmap.visible := false;
	form.menuTMWorkOrder.visible := false;
	form.menuTMWOdebtor.visible := false;
	form.menuTMWOQtyRange.visible := false;
	
	//01 Nov 2019	NDL	TFS 47100
	form.menuTMBOLnew.visible := false; // &lt;&lt;&lt; MAIN BOL NEW 
	form.menuTMBOLnew.enabled := true; // &lt;&lt;&lt; MAIN BOL NEW 
	form.menuTMBOLmap.visible := false;
	form.menuTMBOLTrx.visible := false;
	form.menuTMBOLdebtor.visible := false;
	form.menuTMBOLQtyRange.visible := false;
	
	
	form.menuTMSnew.visible := false;	// snap shot summary main new
	form.menuTMSnew.enabled := true;
	form.menuTMSmap.visible := false;
	form.menuTMSinv.visible := false;
	
	form.menuSItemNew.visible := false; // &lt;&lt;&lt; MAIN CARGO NEW 
	form.menuSItemNew.enabled := true; // &lt;&lt;&lt; MAIN CARGO NEW 
	form.btnNew.enabled := false;
	form.menuSINewDebtor.visible := false;
	form.menuMappingNewTMap.visible := false;
	form.menuSINewContainer.visible := false;
	form.menuSINewProductGroup.visible := false;
	form.menuSINewProduct.visible := false;
	form.menuSINewQTYRange.visible := false;
	form.menuSINewImExStatus.visible := false;
	form.mnuCopy.visible := false;
	form.btnCopy.enabled := false;
	form.mnuReplace.visible := false;
	form.btnReplace.enabled := false;
	form.menuSINewContentStatus.visible := false;
	form.menuSINewCommodity.visible := false;
	form.menuSINewTranType.visible := false;
	form.menuMapNewTranMove.visible := false;
	form.menuMapNewTranStandard.visible := false;
	form.mnuResourceType.visible := false;
	form.mnuSItemUpdate.visible := false;

	form.menuMappingSetActive.visible := false;
	form.mnuTMExport.visible := false;
	form.btnExtractCSV.enabled := false;
	form.mnuTSExport.visible := false;	// 23659

	form.menuSItemDelete.visible := false;
	form.btnDelete.enabled := false;

	form.menuSItemProperties.visible := false;
	form.btnProperties.enabled := false;

	form.btnPrint.enabled := false;
	
	form.menuSINewSubQTY.visible :=false;  		//09/02/2017 cnwma1 TFS #2901
	form.menuSINewSubQTYRange.visible :=false;  //09/02/2017 cnwma1 TFS #2901

end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
