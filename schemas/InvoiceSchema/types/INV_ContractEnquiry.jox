    <JadeMethod name="setupForm" id="da6e6b68-1d95-425a-b633-3d189438a5e6">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			

Date		Who		Reason
13DEC2022	NAVAB1	TFS CR 55645 TASK 55662
16 October 2023	navmv20	Bug 60893: FR - 54089 - Invoice Contract screens - Modal mode
07 November 2023	navrv30 Bug 58391: EUP - Audits for Invoice Copy
21 Aug 2024	navnk30	Bug 65602: FR - 54089 - Invoice Contract - permissions
14 Oct 2024 navlc30 JIRA 19508 UI - Contract Enquiry extra tables for results
*/

vars

begin
	inheritMethod();

	if self.myCurrentBank = null then
		self.myCurrentBank := self.myTerminal.getDefaultCompanyBank();
	endif;
	
	self.setNavigatorHeading(self.caption);
	self.setCaption("Invoice Contracts Enquiry " &amp; self.myCurrentBank.code );
	self.getXMLSettingsForSetup();
	
	self.doCmbBUBuild(self.cmbBusinessUnit);
	self.doMsgDebtorBuild();
	self.doMsgServicesBuild();
	self.doMsgLineTypeBuild();
	
	create self.myFilterCriteria transient;
	
	self.initTblData();
	self.initTblContractDetails(ETDef_ContractDetails);			//14.10.2024 navlc30 #19508
	self.initTblContractRate(ETDef_ContractRate);				//14.10.2024 navlc30 #19508	
	self.tblDetails.visible := false;							//14.10.2024 navlc30 #19508
	self.tblRates.visible := false;								//14.10.2024 navlc30 #19508

	self.setBusinessUnit();

	self.doBtnClearClick();
	
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnNew.enabled := false;
		self.btnRemove.enabled := false;
		self.btnUpdate.enabled := false;
		self.btnCopy.enabled := false;
		self.btnLoadCSV.enabled := false;
		//self.btnAudit.enabled := false;   //11/07/2023 navrv30 #58391 //21.08.2024 navnk30 #65602
		self.btnBulkUpdate.enabled := false;	//21.08.2024 navnk30 #65602
	endif;
	
	self.zOrder(0); //16/10/2023	navmv20	Bug 60893
	
	self.frmTableFilter.setupControl(self.tblData, null); //05/06/2024	navkc1 CR 63736 Task 63770
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showChooseFormatForm" id="a4fa838b-209b-4c59-9f56-73c5b7c0ed18">
        <source>showChooseFormatForm(_mode : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 January 2023	navmv20	TFS 55650 Task 55701: Jade - Contracts XML Extract TRX

*/

vars
	frm : INV_ChooseFormat;
begin
	
	frm := app.loadForm(INV_ChooseFormat, 
					INV_Assistant, 
					false, 
					false,
					false, 
					self.myTerminal,
					null).INV_ChooseFormat;	
	
	if frm = null then
		return;
	endif;
	
	frm.myParent := self;
	frm.initCollection();
	frm.mode := _mode;
	if self.cmbBusinessUnit.listObject.isKindOf(CM_Bank) then
		frm.selectedBank := self.cmbBusinessUnit.listObject.CM_Bank;
	endif;
	frm.createMyAssistant(INV_Assistant);
	frm.centreOverParent(0);
	frm.showModal();
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
