    <JadeMethod name="doDeleteSeletedTIs" id="0e8423ed-0654-4cd7-8c11-e4f4fa8a7876">
        <source>doDeleteSeletedTIs();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 November 2012	cnwrd1	Initial creation

*/

vars

	aTI 		: CM_TrackedItem;
	lstCnt		: Integer;
	cnt			: Integer;
begin

	lstCnt := self.tblSelectedItems.rows;
	while cnt &lt; lstCnt do
		cnt := cnt+1;			
		
		if self.tblSelectedItems.accessRow(cnt).selected then
			aTI :=  self.tblSelectedItems.accessRow(cnt).itemObject.CM_TrackedItem;				
			self.tblSelectedItems.removeItem(cnt);
			self.allSelectedCargo.remove(aTI);
			lstCnt := lstCnt-1;
			cnt := cnt -1;
		endif;	
	endwhile;
	
	//self.lblInfo.caption := app.getErrorString1(Selected_cargo_count,self.allSelectedCargo.size.asStringJMT());

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuColumnOrganiserClick" id="0393b482-72ff-4350-9a3d-26ca881568a3">
        <source>doMnuColumnOrganiserClick(menuItem : MenuItem);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2012	cnwrd1	Initial creation

*/


//19 February 2010	cnwml2
//+cnwml2 PAR21663

vars
	tbl : CM_DataTable;
begin
	tbl := menuItem.userObject.CM_DataTable;
	
	if tbl = self.tblResults then
		self.tblResults.showColumnOrganiserFrm(self.myTerminal, null);
	elseif tbl = self.tblSelectedItems then
		self.tblSelectedItems.showColumnOrganiserFrm(self.myTerminal,null);
	endif;

epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem"/>
    </JadeMethod>
