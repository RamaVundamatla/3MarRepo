    <JadeMethod name="doSheetCaption" id="9cac5034-d6da-4742-8cd5-f40ffbfd7545">
        <source>doSheetCaption(_sheet : CMUI_Sheet input; _table : CM_DataTable);
/*
Purpose:			

Date		Who		Reason
03 March 2023	navab1	TFS CR 56806 TASK 56807
08 Feb 2024 jlier1 TFS 62363
*/

vars
	size, selected : Integer;
	table : CM_DataTable;
	message : String;
begin
	table := self.tblAllCargoTop;
	size := _table.rows - _table.fixedRows;
	selected := _table.allSelectedObjects.size;
	message := app.getErrorString2(XofY, selected.String, size.String );

	if _sheet = self.shtAllCargo then
		_sheet.caption := app.getFormCaptionsString(Xlat_0025777) &amp; " " &amp; message;
	elseif _sheet = self.shtHazardous then
		_sheet.caption := app.getFormCaptionsString(Xlat_0025778) &amp; " " &amp; message;
	elseif _sheet = self.shtMAFI then
		_sheet.caption := app.getFormCaptionsString(Xlat_0025779) &amp; " " &amp; message;
	elseif _sheet = self.shtBookingList then
		_sheet.caption := app.getFormCaptionsString(Xlat_0025780) &amp; " " &amp; message;
	elseif _sheet = self.shtReefers then
		_sheet.caption := app.getFormCaptionsString(Xlat_0025781) &amp; " " &amp; message;
	elseif _sheet = self.shtTrailers then
		_sheet.caption := app.getFormCaptionsString(Xlat_0025783) &amp; " " &amp; message;
		
	endif;
epilog

end;</source>
        <Parameter name="_sheet" type="CMUI_Sheet" usage="input"/>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="doSheetCaptions" id="50f0f9b0-f4c9-4bc7-9372-e153b47d8b00">
        <source>doSheetCaptions();
/*
Purpose:			

Date		Who		Reason
10 March 2023	navab1	TFS CR 56806 TASK 56807
08 Feb 2024 jlier1 TFS 62363
*/

vars

begin
	
	self.doSheetCaption(self.shtAllCargo, self.tblAllCargoTop);
	self.doSheetCaption(self.shtHazardous, self.tblHazardousTop);
	self.doSheetCaption(self.shtMAFI, self.tblMAFITop);
	self.doSheetCaption(self.shtBookingList, self.tblBookingTop);
	self.doSheetCaption(self.shtReefers, self.tblReefersTop);
	self.doSheetCaption(self.shtTrailers, self.tblTrailersTop);


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTableContext" id="0d6bc126-f192-4ab5-90a5-07edb7148ca0">
        <updating/>
        <source>doTableContext(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*
Purpose:			

Date		Who		Reason
01MAR2023	NAVAB1	CR 56806 TASK 56807 
*/

vars
	xLeft 	: Real;
	yTop	: Real;
	obj	 	: CM_Object;
	loadTo  : CM_LocationsController;
begin

	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);
	self.mnuContext.userObject := cntrl;	
	self.mnuContext.visible := false; // do not show on main menu
	

	self.popupMenu(self.mnuContext, xLeft.Integer, yTop.Integer);

	return false;
end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTableDblClick" id="46e09c20-c385-40e7-8bba-6395d080d3c3">
        <updating/>
        <source>doTableDblClick(table: Table input) updating;
/*
Purpose:			

Date				Who		Reason
01MAR2023			NAVAB1	CR 56806 TASK 56807 
12 December 2023	jlizm1	TFS 61665 Display RTL Reason
*/

vars
	ti : CM_TrackedItem;
	dataTable : CM_DataTable;
	colIdx : Integer;
	reason : String;
begin
	ti := self.myCurrentTrackedItem;
	dataTable := table.CM_DataTable;
	
	if table.row = table.fixedRows then
		if table.sortColumn[1] &gt; 0 then
			table.accessCell(1,table.sortColumn[1]).fontBold := false;
		endif;

		dataTable.resortTableByColumn(table.column);
		table.accessCell(1,table.column).fontBold := true;
		self.colourTableRows( dataTable );
		
	elseif table.row &gt; table.fixedRows then
		colIdx := dataTable.getColumnByRowName(ETRow_ReadyToLoad);
		if colIdx &gt; 0 and table.column = colIdx then
			if not ti.evaluateReadyToLoadReason(reason) then
				app.msgBox(reason, app.getErrorString(Not_RTL_reason), MB_OKONLY);
			endif;
			return;
		endif;
		
		self.myAssistant.showCargoEnquiryForm(ti, self.myMasterMenuAction, true, false);
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUnqueueSelected" id="01cf6c58-328e-4c7e-8a44-3ba5ddd4a33c">
        <updating/>
        <source>doUnqueueSelected(_table : CM_DataTable) updating;
/*
Purpose:			

Date		Who		Reason
01MAR2023	NAVAB1	CR 56806 TASK 56807 
*/

vars
	table : CM_DataTable;
	obj : Object;
	ti : CM_TrackedItem;
	count : Integer;
	tiSet : CM_TISet;

begin
	create tiSet transient;
	table := _table;
	
	foreach obj in table.allSelectedObjects do
		if CM_TrackedItem.hasInstance( obj ) then
			ti := obj.CM_TrackedItem;
			if not ti.isQueued then
				continue;
			endif;
			tiSet.addNoDuplicates( ti, false );
		endif;
	endforeach;
	
	foreach ti in tiSet do
		self.doUnqueueTI( ti );
	endforeach;

epilog
	delete tiSet;
end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="doUnqueueTI" id="2e2f03ef-87dc-4984-882d-42eccb2e14fd">
        <updating/>
        <source>doUnqueueTI(_theTI : CM_TrackedItem input) updating;
/*
Purpose:			

Date		Who		Reason
01MAR2023	NAVAB1	CR 56806 TASK 56807 
*/

vars
	idx : Integer;
	lTI	: CM_TrackedItem;
	aStr : String;
	lResult : Integer;
	lMoveControl : CMIF_MoveController;
	lTransferArea : CM_TerminalArea;
	lQEntry : CM_RTQueueEntry;
	result	: Integer;

begin
	mousePointer := MousePointer_HourGlass;	
	
	if _theTI = null then
		app.msgBox(app.getErrorString(Please_Select_A_Tracked_Item),app.getErrorString(Problem), MsgBox_OK_Only +MsgBox_Information_Icon);
		return;
	endif;
	
	create lMoveControl transient;
	lMoveControl.setMoveMode(QUEUE_MODE);
	lMoveControl.setMyTrackedItem(_theTI);
	lMoveControl.setMyWorkListEntry(_theTI.allWorklistEntries.last);
	
	if lMoveControl.myWorkListEntry &lt;&gt; null and lMoveControl.myWorkListEntry.myFutureMove = null then
		lMoveControl.setMyWorkListEntry(null);
	endif;
	
	while true do
		app.myTrxUA.trxUpdateMoveTIUndo(lMoveControl, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(CMUI_Unqueue), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog 
	if lMoveControl &lt;&gt; null then
		delete lMoveControl;
	endif;
	mousePointer := MousePointer_Default;	

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="excludeMAFI" id="7ccf76d2-f5cf-42b7-bf9e-7b2536610445">
        <source>excludeMAFI(_mafi : CM_TILC) : Boolean;
/*

Purpose:			MAFIs may not necessarily follow the standard order of operations so
					this method performs additional checks specific to MAFIs

Parameters:			

Return Value:		

Date				Who		Reason
06 August 2024		jlizm1	Initial creation TFS 65494 Discharged MAFI not showing for reload with new cargo

*/

vars
	onboardTIs 	: CM_TISet;
	ti 			: CM_TrackedItem;
	
begin
	if _mafi = null then
		return true;
	endif;

	create onboardTIs transient;
	_mafi.getAllOnboardTIs(onboardTIs);
	
	if _mafi.isOnSite and _mafi.hasBeenReceivedFromVoyage(self.myCurrentVoyage) then
		foreach ti in onboardTIs do
			if ti.hasBeenReceivedFromVoyage(self.myCurrentVoyage) then
				return true;
			endif;
			
			return false;
		endforeach;
	endif;

	return false;
	
epilog
	delete onboardTIs;

end;</source>
        <Parameter name="_mafi" type="CM_TILC"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
