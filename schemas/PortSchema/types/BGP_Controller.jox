    <JadeMethod name="numQueuedRequests" id="137f0726-445a-4a6f-a52b-a9d0f4a36f73">
        <methodInvocation>mapping</methodInvocation>
        <source>numQueuedRequests(set: Boolean; _value: Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:     01 May 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29 Nov 2011	cnwkpd1		PAR #28753 - Performance issues in BGP form
// ---------------------------------------------------------------------------
vars
	tmpClass	: Class;
	number		: Integer;
	className	: String;
	
begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;

	foreach className in self.allRequestClassesToProcess do
		tmpClass := self.getClass(className);
		if tmpClass = null then
			app.raiseCMException1(Err_InvalidClass, className, null, null);
		endif;
//		number := number + tmpClass.instances.size;
		number := number + tmpClass.countPersistentInstances();		// PAR #28753
	endforeach;
	_value := number;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processRequest" id="edd1b044-eb35-4803-aca6-ff2a03000091">
        <updating/>
        <source>processRequest(_request : BGP_Request io) : Boolean protected, updating;
//
//18 Apr 2012	cnwrs1	Par 29441 - getting code 4's when trying to stop and clear the system
//26 June 2012	cnwrs1	Par 29858 - BGP Request not being deleted after an exception
//17 Aug 2012	cnwrs1	Par 30159 - getting 1400 exceptions
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
//10 Dec 2015	cnwkpd1	PAR #37286 - 1400 exceptions after multiple exceptions
// 03 Oct 2016	cnwrs1	TFS 2756 PAR38267 allow Cams to run per terminal
// 12 Jan 2018	jlgkpd1	TFS 36632 - Add extra call to heartbeat for JSM monitoring

vars
	lockRequest		: BGP_Request;
	requestStr		: String;
	stillRunning		: Boolean;	// name changed as it was the same name as a method isRunning()
	invalidProcess : Boolean;
	str : String;
	actionFinished : Boolean;
	msg : String;
	locked,
	isInvalid : Boolean;
	hadException : Boolean;
	result : Boolean;
	option,
	timeRemaining : Integer;
	
begin
	on Exception do app.handleDeletedObject(exception, _request, isInvalid);	 //18 Apr 2012 29441
	
	hadException 	:= true;	//26 June 2012	cnwrs1 par 29858
	result 			:= true;

	app.writeLog(class.name&amp;'::'&amp;method.name, LogTRACE);

	app.sendHeartbeatIfRequired();		// 12/01/2017 Additional call to deal with multiple queued request notifications
	
	// 29200 replacement code
	if not app.isSDSSecondaryDB and self.myCurrentRequest &lt;&gt; null then
		msg := self.name &amp; ' previous run appears to have not completed, continuing with current request.';
		
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053	
	endif;
	
	//27 Oct 2018 jlger1 tfs 41625 -  have tasks for each terminal
	if self.getMyTerminal &lt;&gt; null and _request.myTerminal &lt;&gt; null and self.getMyTerminal &lt;&gt; _request.myTerminal then
		hadException := false;
		result := false;
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' wrong terminal cont='&amp;self.getMyTerminal.code&amp;' req='&amp;_request.myTerminal.code&amp;' '&amp;_request.String, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		return result;
		
	endif;
	
	// This is used to hold reference in lock table.
	lockRequest := _request;
	locked 		:= self.tryLock(_request, Exclusive_Lock, Session_Duration, LockTimeout_Immediate);
	
	if isInvalid or not locked then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;' request locked or invalid', LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		_request 		:= null;
		lockRequest 	:= null;
		hadException 	:= false;	//17 Aug 2012	cnwrs1
		result 			:= false;
		return result;
	endif;
	
	if _request.isProcessed then
		self.unlock(_request);
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;' request '&amp;_request.String&amp;' has been processed so will be deleted.', LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		app.myTrxUA.trxUpdateBGPControllerSDSTerm(self, false);					//17 Aug 2012	cnwrs1
		app.myTrxDA.trxDeleteBGPRequest(null, _request, true, app.myPassport);	//17 Aug 2012	cnwrs1
		
		_request 		:= null;
		lockRequest 	:= null;
		hadException 	:= false;	//17 Aug 2012	cnwrs1
		result 			:= false;
		
		return result;
	endif;
	
	stillRunning := true;
	
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;' trxUpdateBGPControllerPre '&amp;_request.String, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	app.myTrxUA.trxUpdateBGPControllerPre(self, app.actualTimeServer, _request, app.myPassport);
	
	if not _request.isASyncProcess then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' trxUpdateBGPControllerPre '&amp;_request.String, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		app.myTrxUA.trxUpdateBGPRequest(_request, true,0 , null, app.myPassport);
	endif;	
	
	requestStr 	:= _request.class.name;
	msg 		:= 'Started processing BGP Request ' &amp; requestStr &amp; ' ' &amp; _request.String &amp; ' ' &amp; _request.createdTime.String;
	
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	actionFinished := _request.action();
	
	if actionFinished then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' action finished', LogINFO);	//25 Nov 2019	NDL	TFS 47053
		app.myTrxUA.trxUpdateBGPControllerSDSTerm(self, false);
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Delete request' &amp; _request.String, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		app.myTrxDA.trxDeleteBGPRequest(null, _request, true, app.myPassport);
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Request ' &amp; _request.String &amp; ' deleted', LogINFO);	//25 Nov 2019	NDL	TFS 47053
	endif;
	
	hadException := false;	//26 June 2012	cnwrs1 par 29858
epilog
	if hadException then	//26 June 2012	cnwrs1 par 29858
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Exception has occured', LogINFO);	//25 Nov 2019	NDL	TFS 47053
		// PAR #37286 - Added check to see if timer is already active for prior exception
		if not self.getTimerStatus(DeleteBGPRequest_Event_Tag, option, timeRemaining) then
			self.beginTimer(0, Timer_OneShot, DeleteBGPRequest_Event_Tag);
		endif;
	endif;
	
	if stillRunning and actionFinished then
		app.myTrxUA.trxUpdateBGPControllerPost(self, app.myPassport);
		
		msg := 'Completed processing BGP Request ' &amp; requestStr;
		
		app.writeLog(self.getUserCode&amp;' '&amp;app.name&amp;' '&amp;msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
	endif;
	
	if lockRequest &lt;&gt; null then
		// Clean up lock table.
		self.unlock(lockRequest);
		result := true;
	else
		result := false;
	endif;
	self.causeEvent(BGP_Object.BGP_DisplayUpdate, false, null);	//26 June 2012	cnwrs1 par 29899
	return result;
end;</source>
        <access>protected</access>
        <Parameter name="_request" type="BGP_Request" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="serverMethodAbortedHandler" id="b0295cf6-ab09-4ea6-a86a-2efc365f8f9e">
        <source>serverMethodAbortedHandler(exObj : Exception) : Integer protected;
// handle 1242 exception in timer when closing down
constants
	ServerMethodAborted = 1242;
	
vars

begin
	abortTransaction;
	
	if exObj.errorCode = ServerMethodAborted then
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;
end;
</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
