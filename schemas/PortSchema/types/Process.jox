    <JadeMethod name="isNavnk30" id="112b617e-c76c-4318-b57f-30f8d9d0f6c2">
        <source>isNavnk30() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Nov 2023	navnk30	Initial creation

*/

vars
	user	: CM_User;
begin
	executeWhen JMTDevelopmentEnvironment;
	
	// JMT
	if app.myPassport &lt;&gt; null then
		user := app.myPassport.myUser;
		
		if user &lt;&gt; null 
		and (user.code.toUpper = "NAVNK30") then
			return true;
		endif;
	endif;
		
	// PatchCreatorApp
	if process.getComputerName().toUpper = "NAVNK30" and
		(currentSchema.name = "DevSchema" or
			currentSchema.superschema.name = "DevSchema") then
		return true;
	endif;
	
	// EntTableMaintApp
	if self.userInfo = "EntTableMaintApp" and
		self.userCode.toUpper.startsWith__("NAVNK30") then
		return true;
	endif;
	
	endExecuteWhen; 
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isPW" id="23843a45-83d9-4ea1-9705-c350223b833b">
        <source>isPW() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2022	navpw1	Initial creation

*/

vars
	user : CM_User;
	
begin

	executeWhen JMTDevelopmentEnvironment;
	
	// JMT
	if app.myPassport &lt;&gt; null then
		user := app.myPassport.myUser;
		
		if user &lt;&gt; null and (user.code = "NAVPW1" or user.code = "Phillip.Wells") and user.userName = "Phillip Wells" then
			return true;
		elseif process.userCode.toUpper.cnContains("NAVPW1") or process.userCode.toUpper.cnContains("PHILLIP.WELLS") then
			return true;
		endif;
		
		return false;
		
	elseif process.userCode.toUpper.cnContains("NAVPW1") or process.userCode.toUpper.cnContains("PHILLIP.WELLS") then
		return true;
		
	endif;
	
	endExecuteWhen;
	
	return false;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isRam" id="e9223b3f-ebd8-44ff-b06b-fd668d69ee59">
        <source>isRam() : Boolean;

vars
	meCode : String;
begin
	meCode := self.userCode;
	
	return meCode[1:6].toUpper() = "NAVRA1" or process.isJLGAB1() or (meCode.toUpper().pos("RAM",1) &gt; 0);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
