        <updating/>
        <source>btnEventTrans_click(btn: Button input) updating;
/*

Date		Who		Reason
11/12/2014	cnwer1	Initial creation PAR
20/04/2017	cnwdap1	TFS 4174 Additional Information in Voyage Events
*/

vars
	vvr : CM_VehicleVisitRecord;
begin
	if self.myCurrentVehicle &lt;&gt; null then
		vvr:=self.myCurrentVehicle.getCurrentVisit;
		if vvr &lt;&gt; null then
			//self.myAssistant.showEventTransactions(vvr, null);				// TFS 4174
			self.myAssistant.showEventTransactions(vvr, null, null, null);		// TFS 4174
		endif;
			
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
