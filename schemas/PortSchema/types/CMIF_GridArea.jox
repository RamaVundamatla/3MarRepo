    <JadeMethod name="getNextColLabelNum" id="9a97e4a1-94d5-4f4c-9c45-bf3141ad34f2">
        <source>getNextColLabelNum(_currentColNum : String io);
/*
----------   ----------  --------------------------------------------------
Created:	25 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	checkKey : String;
	newColNum : String;
	lastChanceIndex : Integer;
begin
	if _currentColNum  = null then
		if self.decrementColNums then
			_currentColNum:=((self.incrementColNumBy * self.numColumns) + (self.startNumColumn -self.incrementColNumBy)).String;
		else
			_currentColNum:= self.startNumColumn.String;
		endif;
	else
		if self.decrementColNums then
			_currentColNum := (_currentColNum.Integer - self.incrementColNumBy).String;
		else
			_currentColNum := (_currentColNum.Integer + self.incrementColNumBy).String;	
		endif;
	endif;
	
	// Generally the code above works well, but if a user has changed the default values of
	// the labels, you can't be sure what values they have used or whether they are descending or ascending in a pattern.
	// If a user  tries to extend an  existing Straddle stack, there is no way of knowing whether an existing
	// 'default' value has already been used without actually checking.
	// 19 July 2010	NDL	Par 24425
	if self.myPxyGridArea &lt;&gt; null then
		checkKey := _currentColNum.padLeadingZeros(self.labelLengthCol); // the value we will use by default.
		if self.myPxyGridArea.allGridColumnsByLabel.getAtKey(checkKey) &lt;&gt; null then
			// its already used, get the first available unused number.
			foreach lastChanceIndex in 1 to self.numColumns do
				//30 May 2012	NDL	Par 28380
				if self.myPxyGridArea.use40ftIds then
					checkKey := ( (lastChanceIndex  * 2 ) - 1 ).String.padLeadingZeros(self.labelLengthCol);
				else
					checkKey := lastChanceIndex.String.padLeadingZeros(self.labelLengthCol);
				endif;
				if self.myPxyGridArea.allGridColumnsByLabel.getAtKey(checkKey) = null then
					_currentColNum := checkKey;
					return;
				endif;
			endforeach;
		endif;
	endif; 
	
	_currentColNum := _currentColNum.padLeadingZeros(self.labelLengthCol);
	
end;</source>
        <Parameter name="_currentColNum" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getNextRowLabelNum" id="c4210619-4044-4da7-9afc-eb698065dbad">
        <source>getNextRowLabelNum(_currentRowNum : String io);
/*
----------   ----------  --------------------------------------------------
Created:	25 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
13 July 2022	navsrk20	ChangeRequest 53760: MTN - DuplicateItem not Translatable
----------   ----------  --------------------------------------------------
*/
vars

begin
	if _currentRowNum  = null then
		_currentRowNum:= self.startNumRow.String;
	else
		if self.decrementRowNums then
			_currentRowNum := (_currentRowNum.Integer - self.incrementRowNumBy).String;
		else
			_currentRowNum := (_currentRowNum.Integer + self.incrementRowNumBy).String;
		endif;
	endif;
//	_currentRowNum := _currentRowNum.padLeadingZeros(self.numRows.String.length);
	
	// PAR 13499 - avoiding label duplicates
	_currentRowNum := _currentRowNum.padLeadingZeros(2/*self.labelLengthRow*/);  //always 2 digits
	
	while self.myPxyGridArea.allGridRowsByLabel.includesKey(_currentRowNum) do
		if self.decrementRowNums then
			_currentRowNum := (_currentRowNum.Integer - 1).String;
			if _currentRowNum &lt;= '0' then
				//app.raiseCMException(DuplicateItem, 'The row label should be positive', null);
				//The row label should be positive : Label_should_positive
				app.raiseCMException(Label_should_positive, null, null);		//13.07.2022 navsrk20 TFS 53760
			endif;
		else
			_currentRowNum := (_currentRowNum.Integer + 1).String;
			if _currentRowNum.Integer &gt;= 100 then
				app.raiseCMException(LabelsMustBeUnique, 'There are no available labels.', null);
			endif;
		endif;
		_currentRowNum := _currentRowNum.padLeadingZeros(2);
	endwhile;
	
end;</source>
        <Parameter name="_currentRowNum" type="String" usage="io"/>
    </JadeMethod>
