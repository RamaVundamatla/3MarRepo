    <JadeMethod name="setupCarrierCombo" id="3ce1031d-a23a-4409-b1d3-8d77d45af5e1">
        <source>setupCarrierCombo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	carrier : CM_Carrier;
	driver : CM_DriverDetails;
	vehicle : CM_Vehicle;

begin

	self.cmbCarrier.clear();
	
	if self.myVehicleBooking &lt;&gt; null then
		carrier := self.myVehicleBooking.myCarrier;
		driver := self.myVehicleBooking.myDriver;
		vehicle := self.myVehicleBooking.myVehicle;
	endif;
	
	self.myAssistant.comboBoxCarrierRoad( self.cmbCarrier, carrier );
	
	self.setupDriverCombo( carrier, driver );
	
	self.setupVehicleCombo( driver, vehicle );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupDriverCombo" id="483e2db4-8ef1-426c-b5d7-d4440e8ae670">
        <source>setupDriverCombo( _carrier : CM_Carrier; _driver : CM_DriverDetails );
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
08 April 2013		cnwndl1	Initial creation	Par 31393
18 June 2024		jlizm1	TFS 63908 Allow duplicate driver names

*/

vars

	iter : Iterator;
	driver : CM_DriverDetails;
	allowDups : Boolean;
	driverStr : String;

begin

	if _carrier = null then
	
		self.cmbDriver.enabled := false;
	
	else
	
		self.cmbDriver.clear();
		self.cmbDriver.enabled := true;
	
		allowDups	:= self.myTerminal.getConfig(AllowDupDriverNames).Boolean;
		iter := _carrier.allDrivers.createIterator;
		while iter.next( driver ) do
			if driver.myTerminal &lt;&gt; self.myTerminal then
				continue;
			endif;
			
			if allowDups then
				driverStr := driver.code &amp; Space &amp; driver.name;
			else
				driverStr := driver.name;
			endif;
			
			self.cmbDriver.itemObject[self.cmbDriver.addItem(driverStr)] := driver;
		endwhile;
		delete iter;
		
		if _driver &lt;&gt; null then
			self.cmbDriver.listIndex := self.cmbDriver.findObject(_driver);
		endif;
		
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_driver" type="CM_DriverDetails"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="054e292b-c401-4c26-8b63-4285069f3ad4">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation	Par 31393
// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	bookingRef : CM_BookingRef;
	bulkRel : CM_BulkRelease;
	localBookingTSstart : TimeStamp;
	localBookingTSend : TimeStamp;
begin
	
	inheritMethod();
	
	self.setupCarrierCombo();
	self.populateCmbTSType();
	
	if self.myVehicleBooking &lt;&gt; null then
		localBookingTSstart := self.systemToLocalTime(self.myVehicleBooking.bookingTSstart);	// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		localBookingTSend	:= self.systemToLocalTime(self.myVehicleBooking.bookingTSend);		// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
		self.txtDateStart.setDate(localBookingTSstart.Date );									// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.txtTimeStart.setTime(localBookingTSstart.Time );									// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.txtDateEnd.setDate(localBookingTSend.Date );										// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.txtTimeEnd.setTime(localBookingTSend.Time );										// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.txtRemarks.text := self.myVehicleBooking.remarks;
		self.chkDeliver.value := self.myVehicleBooking.includesDelivery;
		self.chkPickUp.value := self.myVehicleBooking.includesPickUp;
		self.txtIdsDeliver.text := self.myVehicleBooking.getDeliveryIds(CrLf);
		self.txtIdsPickUp.text := self.myVehicleBooking.getPickUpIds(CrLf);
		if self.myVehicleBooking.myVBTimeSlotType &lt;&gt; null then	//20 Oct 2014	NDL	Par 35008
			self.cmbTSType.listIndex := self.cmbTSType.findObject( self.myVehicleBooking.myVBTimeSlotType );
		else
			self.cmbTSType.listIndex := -1;
		endif;
		//20 Oct 2014	NDL	Par 35008
		self.lblIDValue.caption := self.myVehicleBooking.id;
		
		self.txtCargoBookId.text := null;
		if self.myVehicleBooking.allBookingRefs &lt;&gt; null and not self.myVehicleBooking.allBookingRefs.isEmpty  then
			foreach bookingRef in self.myVehicleBooking.allBookingRefs do
				if self.txtCargoBookId.text = null then
					self.txtCargoBookId.text := bookingRef.bookingReference;
				else
					self.txtCargoBookId.text := self.txtCargoBookId.text &amp; " " &amp; bookingRef.bookingReference;
				endif;
			endforeach;
		endif;
		self.txtCargoRelId.text := null;
		if self.myVehicleBooking.allBulkReleases &lt;&gt; null and not self.myVehicleBooking.allBulkReleases.isEmpty then
			foreach bulkRel in self.myVehicleBooking.allBulkReleases do
				if self.txtCargoRelId.text = null then
					self.txtCargoRelId.text := bulkRel.code;
				else
					self.txtCargoRelId.text := self.txtCargoRelId.text &amp; " " &amp; bulkRel.code;
				endif;
			endforeach;
		endif;
		
		self.txtDateStart.enabled := false;
		self.txtTimeStart.enabled := false;
		self.txtDateEnd.enabled := false;
		self.txtTimeEnd.enabled := false;
		self.cmbTSType.enabled := false;
			
	//	if self.myVehicleBooking.isUsed then
		if self.myVehicleBooking.isUsed or self.myVehicleBooking.isExpired then	//14 May 2015	NDL	Par 36234
			self.txtRemarks.enabled := false;
			self.cmbDriver.enabled := false;
			self.cmbCarrier.enabled := false;
			self.cmbVehicle.enabled := false;
			self.btnSave.enabled := false;
			self.chkDeliver.enabled := false;
			self.chkPickUp.enabled := false;
			self.txtIdsDeliver.enabled := false;
			self.txtIdsPickUp.enabled := false;
			self.txtCargoBookId.enabled := false;
			self.txtCargoRelId.enabled := false;
		endif;
		
	else
	
		self.lblIDValue.caption := null;	//20 Oct 2014	NDL	Par 35008
		
		if self.passedInStartTS = null then
			self.passedInStartTS :=  self.systemToLocalTime(app.actualTimeServer);// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			self.passedInEndTS := passedInStartTS.cnEcAddMinutes(5);
		endif;
		
		self.txtDateStart.setDate( self.passedInStartTS.Date );
		self.txtTimeStart.setTime( self.passedInStartTS.Time );
		self.txtDateEnd.setDate( self.passedInEndTS.Date );
		self.txtTimeEnd.setTime( self.passedInEndTS.Time );
		self.txtRemarks.text := null;
		self.chkDeliver.value := false;
		self.chkPickUp.value := false;
		self.txtIdsDeliver.text := null;
		self.txtIdsPickUp.text := null;
		self.cmbTSType.listIndex := -1;	//20 Oct 2014	NDL	Par 35008
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupVehicleCombo" id="b0e2a8a7-faa6-439f-8e85-02a5f5cb4143">
        <source>setupVehicleCombo( _driver : CM_DriverDetails; _vehicle : CM_Vehicle );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	vehicle : CM_Vehicle;
	iter : Iterator;

begin

	if _driver = null then
	
		self.cmbVehicle.enabled := false;
		
	else
	
		self.cmbVehicle.enabled := true;
		self.cmbVehicle.clear();
		
		self.cmbVehicle.addItem( app.getErrorString(AnyString) );
		iter := _driver.allVehicleMachines.createIterator;
		while iter.next( vehicle ) do
			self.cmbVehicle.itemObject[self.cmbVehicle.addItem( vehicle.regNumber )] := vehicle;
		endwhile;
		delete iter;
		
		if _vehicle &lt;&gt; null then
			self.cmbVehicle.listIndex := self.cmbVehicle.findObject(_vehicle);
		endif;
		
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="_driver" type="CM_DriverDetails"/>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="c58d7000-1de6-4145-a8f5-427464cd5c01">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 21 October 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018931, locale);
	btnCancel.translateCaption(Xlat_0018932, locale);
	btnSave.translateCaption(Xlat_0018933, locale);
	chkDeliver.translateCaption(Xlat_0019041, locale);
	chkPickUp.translateCaption(Xlat_0019042, locale);
	lblCargoBookId.translateCaption(Xlat_0019970, locale);
	lblCargoRelId.translateCaption(Xlat_0019971, locale);
	lblCarrier.translateCaption(Xlat_0018934, locale);
	lblDriver.translateCaption(Xlat_0018935, locale);
	lblEndDate.translateCaption(Xlat_0018936, locale);
	lblEndTime.translateCaption(Xlat_0018937, locale);
	lblID.translateCaption(Xlat_0019972, locale);
	lblRemarks.translateCaption(Xlat_0018938, locale);
	lblStartDate.translateCaption(Xlat_0018939, locale);
	lblStartTime.translateCaption(Xlat_0018940, locale);
	lblTSType.translateCaption(Xlat_0019973, locale);
	lblVehicle.translateCaption(Xlat_0018941, locale);
end;</source>
    </JadeMethod>
