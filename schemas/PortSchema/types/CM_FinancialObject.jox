    <JadeMethod name="getLastStatusChangeAudit" id="18d7ea17-5f93-48e7-8a9e-e5d575e84bb5">
        <source>getLastStatusChangeAudit() : CM_Audit;
/*

Date		Who		Reason
01 October 2015	cnwer1	Initial creation PAR 36958

*/

vars
	audit : CM_Audit;
begin
	
	foreach audit in self.qualifiedAudits  reversed do
		if audit.isKindOf(CM_FinAuditInvStatusChanged) or audit.isKindOf(CM_AuditLineStatusChanged) then
		//if audit.statusChangeReasonCode &lt;&gt; null then
				return audit;
		//	endif;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_Audit"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="48865576-9e82-4558-adf6-f0478c184234">
        <source>getMyTerminal(): CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2016	cnwkpd1	TFS 488 - Multi Timezone Support


*/

vars
	bank		: CM_Bank;

begin
	bank := self.getBank();
	if bank &lt;&gt; null then
		return bank.getMyTerminal();
	else	
		return null;
	endif;

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
