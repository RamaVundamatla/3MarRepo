    <JadeMethod name="validateStorageTransactions13" id="832f6fbc-4423-4443-8610-13527f06adec">
        <source>validateStorageTransactions13(_ti : CM_TrackedItem);
// Created:     Mar 2011
// par 27193 invoice line quantity changes after transaction map quantity range changes
vars
	transCount,
	invCount	: Integer;
	trans	: CM_TITransaction;
	invLine	: CM_InvoiceLine;
begin
	foreach trans in _ti.allTransactions do
		if trans.isKindOf(CM_Storage) then
			transCount := transCount + 1;
			invCount := 0;
			foreach invLine in trans.allInvoiceLines do
				invCount := invCount + 1;
				if invCount = 1 then
					self.assertEqualMsg(invLine.quantity, 4.Real, "Cargo 1 inv 1 quantity");
					self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStore1", "Cargo 1 inv 1 ILD");
					self.assertEqualMsg(invLine.quantityRangeStart, 0.Real, "Cargo 1 inv 1 qrs");
					self.assertEqualMsg(invLine.quantityRangeEnd, 4.Real, "Cargo 1 inv 1 qre");
				elseif invCount = 2 then
					self.assertEqualMsg(invLine.quantity, 4.Real, "Cargo 1 inv 2 quantity");
					self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStore2", "Cargo 1 inv 2 ILD");
					self.assertEqualMsg(invLine.quantityRangeStart, 5.Real, "Cargo 1 inv 2 qrs");
					self.assertEqualMsg(invLine.quantityRangeEnd, 8.Real, "Cargo 1 inv 2 qre");
				elseif invCount = 3 then
					self.assertEqualMsg(invLine.quantity, 4.Real, "Cargo 1 inv 3 quantity");
					self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStore3", "Cargo 1 inv 3 ILD");
					self.assertEqualMsg(invLine.quantityRangeStart, 9.Real, "Cargo 1 inv 3 qrs");
					self.assertEqualMsg(invLine.quantityRangeEnd, 12.Real, "Cargo 1 inv 3 qre");
				elseif invCount = 4 then
					self.assertEqualMsg(invLine.quantity, 10.Real, "Cargo 1 inv 4 quantity");
					self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStore4", "Cargo 1 inv 4 ILD");
					self.assertEqualMsg(invLine.quantityRangeStart, 13.Real, "Cargo 1 inv 4 qrs");
					self.assertEqualMsg(invLine.quantityRangeEnd, 99999999.Real, "Cargo 1 inv 4 qre");
				endif;
			endforeach;
			self.assertEqualMsg(invCount, 4, "Storage invoice lines");
		endif;
	endforeach;
	self.assertEqualMsg(transCount, 1, "Storage transactions");
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateStorageTransactions14" id="801cfd34-7a22-418c-81d0-c68ac0f80dbd">
        <source>validateStorageTransactions14(_ti : CM_TrackedItem);
// Created:     Feb 2010 by cnwjre1
// Escalating storage, no linked storage transactions, charged storage days are working not calendar
// Get two storage transactions, first is no-charge, second has 3 invoice lines
// Expected results revised after TFS 3588 fixes
vars
	transCount,
	invCount	: Integer;
	trans	: CM_TITransaction;
	invLine	: CM_InvoiceLine;
begin
	foreach trans in _ti.allTransactions do
		if trans.isKindOf(CM_Storage) then
			transCount := transCount + 1;
			invCount := 0;
			foreach invLine in trans.allInvoiceLines do
				invCount := invCount + 1;
				if invCount = 1 then
					self.assertEqualMsg(invLine.quantity, 5.Real, "Cargo 1 inv 2 quantity");
					self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStore1", "Cargo 1 inv 1 ILD");
				elseif invCount = 2 then
					self.assertEqualMsg(invLine.quantity, 4.Real, "Cargo 1 inv 3 quantity");
					self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStore2", "Cargo 1 inv 2 ILD");
				elseif invCount = 3 then
					self.assertEqualMsg(invLine.quantity, 1.Real, "Cargo 1 inv 3 quantity");
					self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStore3", "Cargo 1 inv 3 ILD");
				endif;
			endforeach;
			if transCount = 1 then
				self.assertEqualMsg(invCount, 0,"Storage 1 invoice lines");
			elseif transCount = 2 then
				self.assertEqualMsg(invCount, 3,"Storage 2 invoice lines");
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(transCount, 2, "Storage transactions");
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateStorageTransactions2" id="a126a7e7-868c-472f-99d2-dc18a250f7f6">
