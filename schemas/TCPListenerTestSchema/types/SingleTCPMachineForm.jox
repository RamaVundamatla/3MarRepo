    <JadeMethod name="processTCPResponse" id="8c2d9940-a1d2-4ef6-a72b-69c02df6fb64">
        <source>processTCPResponse(_response: String);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 February 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift

*/

vars
	questionCount,
	pos				: Integer;
	containerId		: String;
	responseArray	: StringArray;
	hasErrors		: Boolean;
	craneId			: String;
	
	eachResponse : String;
begin
	inheritMethod(_response);
	
	create responseArray transient;
	/*
	write  method.qualifiedName &amp; "_response is &gt;&gt;"&amp;_response;
	_response.csvToStringArray(responseArray);
	foreach eachResponse in responseArray do
		write method.qualifiedName  &amp; "eachResponse is &gt;&gt;" &amp; eachResponse;
	endforeach;
	*/
	hasErrors := responseArray.isEmpty or responseArray[1] = "2";
		
	if self.currentOperation = Operation_Logon then
		pos := _response.reversePos("0,,");
		if pos &lt;&gt; 0 then
			pos := pos + 3;
			questionCount := _response.scanUntil(",", pos).Integer;
			self.txtNumFaults.text := questionCount.String;
		else
			self.txtNumFaults.text := 0.String;
		endif;
	
	elseif self.currentOperation = Operation_ValidateMove or self.currentOperation = Operation_ValidateDischarge then	//30 Mar 2011	NDL	Par 27290
		pos := 1;
		containerId := _response.reverse.scanUntil(',', pos).trimBlanks.reverse;
		if containerId &lt;&gt; null then
			self.myValidateTextBox.text := containerId;
		endif;
	
	elseif self.currentOperation = Operation_NextJob then
		if not hasErrors then
			self.txtContainer1.text := null;
			self.txtContainer2.text := null;

			if responseArray.size &gt;= 4 then
				self.txtContainer1.text := responseArray[4];
			endif;
			if responseArray.size &gt;= 6 then
				self.txtContainer2.text := responseArray[6];
			endif;
		endif;
		
	elseif self.currentOperation = Operation_SetDown then
		if not hasErrors then
			self.txtContainer1.text := null;
			self.txtContainer2.text := null;
		endif;
	
	elseif self.currentOperation = Operation_Reject then
		if not hasErrors then
			self.txtContainer1.text := null;
			self.txtContainer2.text := null;
		endif;
		
	elseif self.currentOperation = Operation_ValidateCraneQueue then	//30 Mar 2011	NDL	Par 27290
	// nothing to do.
		/*	if not hasErrors then
			pos := 1;
			craneId := _response.reverse.scanUntil(',', pos).trimBlanks.reverse;
		endif; */
		
	endif;
		

epilog
	delete responseArray;
	
end;</source>
        <Parameter name="_response" type="String"/>
    </JadeMethod>
    <JadeMethod name="sendTCPMessage" id="75b0e1b5-f230-4088-936b-739ee2388a60">
        <updating/>
        <source>sendTCPMessage(_tcpPayload: TCPMessagePayload): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 February 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift

*/

vars

begin
	self.currentOperation := _tcpPayload.operationName;
	
	return inheritMethod(_tcpPayload);

	
epilog

end;</source>
        <Parameter name="_tcpPayload" type="TCPMessagePayload"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
