    <JadeMethod name="isContainer" id="6ddcc7bd-c651-4528-b7d0-f35e0d30aa97">
        <source>isContainer(): Boolean protected;
// --------------------------------------------------------------------------------
// Created:		05 May 2009 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myCargoType = null then
		return false;
	else
		return (self.myCargoType.id = TI_CargoType_Container);
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isReceipt" id="4a777627-cbd4-4721-8f8f-45b4c0ea2cbb">
        <methodInvocation>mapping</methodInvocation>
        <source>isReceipt(set : Boolean; _value : Boolean io) mapping;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 26 July 2007
//
//----------------------------------------------------------------------

vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	_value := self.myWorkListEntry.isReceipt;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processWorkEntry" id="e2c01426-dfc9-40f2-b3cf-128eac02e5bd">
        <updating/>
        <source>processWorkEntry(_roadJob : CM_RoadJob; _passport : CM_Passport input) updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 03 August 2007
//
//----------------------------------------------------------------------

vars
	lc : CM_LocationsController;
begin
	if self.validateForUpdate(_passport) then
		if self.isReceipt then
			lc := self.myLocationController;
		else
			lc := _roadJob.myVehicle.locationsController;
		endif;
		if not self.isReceipt then
			//THE RECEIVALS ARE ALREADY IN THE RIGHT COLLECTION AT THIS POINT.  WE ARE UPDATING RELEASE TYPES
			self.myWorkListEntry.assignTIandBOL(self.myTrackedItem, null);
		endif;
		if self.myTrackedItem &lt;&gt; null then // PAR 16188
			//self.myTrackedItem.moveToLocation(lc, _roadJob, self.myWorkListEntry, null, REAL_MODE, false, true, false, false, false,  false, null,null, _passport);		// TFS 2651
			self.myTrackedItem.moveToLocation(lc, _roadJob, self.myWorkListEntry, null, REAL_MODE, false, true, false, false, false, false, null, null, null, null, _roadJob.myVehicleVisit, _passport);	// TFS 2651
		endif;
		self.myWorkListEntry.rebuildStatus();
	endif;
epilog

end;</source>
        <Parameter name="_roadJob" type="CM_RoadJob"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="set" id="417ce0dc-12ab-4d8b-9d64-ffea16ee5f9d">
        <updating/>
        <source>set(_tiCode : String; _locationTarget : String; _cargoType : CM_CargoType; _wle : CM_WorkListEntry; _ti : CM_TrackedItem; _terminal : CM_Terminal ) updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 26 July 2007
//
//----------------------------------------------------------------------

vars

begin
	self.locationString := _locationTarget;
	self.trackedItemCode := _tiCode;
	self.myCargoType := _cargoType;
	self.myWorkListEntry := _wle;
	self.myTrackedItem := _ti;
	self.myTerminal := _terminal;
epilog

end;</source>
        <Parameter name="_tiCode" type="String"/>
        <Parameter name="_locationTarget" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="538a3404-6382-4aa9-974a-3d8f81e84177">
        <updating/>
        <source>validateForUpdate(_passport: CM_Passport input): Boolean updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 29 July 2007
//
//----------------------------------------------------------------------

vars

begin
	//inheritMethod(_passport);
	if self.isReceipt then
		if self.myWorkListEntry &lt;&gt; null then															// cnwjk3 ccms 1071 25/02/10
			if self.myWorkListEntry.myRequest.isReceivalType then										// cnwjk3 ccms 1071 25/02/10
				if self.myWorkListEntry.status &lt;&gt; WLE_COMPLETED then									// cnwjk3 ccms 1071 25/02/10
					app.raiseCMException1(WLE_GCMustBeComplete, self.myWorkListEntry.id, null, null);	// cnwjk3 ccms 1071 25/02/10
					return false;																		// cnwjk3 ccms 1071 25/02/10
				endif;																					// cnwjk3 ccms 1071 25/02/10
			endif;																						// cnwjk3 ccms 1071 25/02/10
		endif;																							// cnwjk3 ccms 1071 25/02/10
		
		if self.validateLocationString(_passport) then
			return true;
		endif;
	else
		if self.validateTrackedItemCode() then
			return true;
		endif;
	endif;
	
	
	return false;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateLocationString" id="7b496f88-e992-42f1-9c0e-04db04ef0bfa">
        <updating/>
        <source>validateLocationString(_passport : CM_Passport input) : Boolean updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 26 July 2007
//
//----------------------------------------------------------------------

vars
	locationController : CM_LocationsController;
	locationHeight : Integer;
	foundLocation : Boolean;
begin
	self.myTerminal.findLocationFromString(self.locationString, false, locationController, locationHeight);
	if locationController = null then
		app.raiseCMException1(ERR_INVALID_LOCN, self.locationString, null, null);
		foundLocation := false;
	else
		self.myLocationController := locationController;
		foundLocation := true;
	endif;
	
	return foundLocation;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateTrackedItemCode" id="ba7b6351-546e-4866-b7ef-afa7a65c9ec5">
        <updating/>
        <source>validateTrackedItemCode() : Boolean updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 26 July 2007
//
//----------------------------------------------------------------------

vars
	cargoType : Integer;
	trackedItem : CM_TrackedItem;
	foundTrackedItem : Boolean;
begin
	//We may already have the ti at this point.
	if self.myTrackedItem &lt;&gt; null and not self.isTrackedItemChecked then
		return true;
	endif;
	
	if self.myCargoType &lt;&gt; null then
		cargoType := self.myCargoType.id;
	endif;
	
	trackedItem := self.myTerminal.lookupTrackedItem(self.trackedItemCode, cargoType, TI_STATE_NORMAL, null, false);
	
	if trackedItem = null then
		app.raiseCMException1(ERR_CARGO_NOT_FOUND, self.trackedItemCode, null, trackedItem);
		foundTrackedItem := false;
	else
	
		self.myWorkListEntry.validateForAssignTI(trackedItem);	//15 Nov 2011	NDL	Par 28367
	
		self.isTrackedItemChecked := true;
		self.myTrackedItem := trackedItem;
		self.myWorkListEntry.setMyTrackedItem(trackedItem);
		foundTrackedItem := true;
		
	endif;
	
	return foundTrackedItem;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
