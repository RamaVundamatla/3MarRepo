    <JadeMethod name="getNumOfTIsOnBackendAsPrimary" id="af1fcbcd-3536-400c-8946-205a9ba76571">
        <source>getNumOfTIsOnBackendAsPrimary(_last : Boolean): Integer;
// ---------------------------------------------------------------------------
// Created:     18 March 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lc : CM_LocationsController;
	tmpTI : CM_TrackedItem;
begin
	if self.allLocationsControllers.size &gt; 1 then
		if _last then
			lc := self.allLocationsControllers.last;
		else
			lc := self.allLocationsControllers.first;
		endif;
		if lc.allTrackedItems.size &gt; 0 then
			tmpTI :=  lc.allTrackedItems[1];
			if tmpTI.myPrimaryActualLocation = lc then
				return lc.allTrackedItems.size ;
			endif;
		endif;
	endif;
	
	return 0;
epilog

end;</source>
        <Parameter name="_last" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPrimaryLocation" id="46e778e4-1293-4753-b941-303c2eabc838">
        <source>getPrimaryLocation(): CM_LocationsController;
/*
------------------------------------------------------------------------
Created:			27 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars

	firstLocation : CM_LocationsController;
	invalidObject : Boolean;

begin

	//return self.allLocationsControllers.first;

	if self.allLocationsControllers = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, self.allLocationsControllers, invalidObject );
	firstLocation := self.allLocationsControllers.first();
	
	return firstLocation;
	
	

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getPrimaryLocationId" id="80e3aec8-500e-463c-8626-12d27e8ffbc8">
        <source>getPrimaryLocationId(): String;
// ---------------------------------------------------------------------------
// Created:     04 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 05/04/2016	cnwdap1		PAR #37738 Special ID code for wellcar wagons
// 11/11/2024	navdap1		MTN-18897 EUP | FR 53485 EUP - Warehouse Yard Allocation
// ---------------------------------------------------------------------------
vars
	lc	: CM_LocationsController;
	id 	: String;												// PAR #37738
begin
	
	if self.allLocationsControllers.isEmpty then
		return null;
	endif;
	
	lc := self.allLocationsControllers.first;

	if lc = null then
		return null;
	endif;
	
	if lc.isWagonInUPSPFormat(self.myTrackedItem, id) then		// PAR #37738
		return id;												// PAR #37738
	endif;														// PAR #37738
	
	// MTN-18897
	if self.isMoveToFullGCArea then
		if lc.myTerminalArea &lt;&gt; null then
			return lc.myTerminalArea.id;
		endif;
	endif;
	// MTN-18897 end
	
//	return lc.getFullIdForTIForMode(QUEUE_MODE);
	return lc.getFullIdAndLevel( self.myTrackedItem, QUEUE_MODE, true );	//01 Feb 2018	NDL	TFS 36848
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getQueueEntries" id="67e9f9e9-761b-4fb1-a99b-4ab9e35e770b">
        <source>getQueueEntries(_rtQueueEntrySet : CM_RTQueueEntrySet input);
// --------------------------------------------------------------
// Created:		24 August 2007 By cnwvu1
// --------------------------------------------------------------

vars

	queueEntry : CM_RTQueueEntry;

begin

	foreach queueEntry in self.allRTQueueEntries do
		if not _rtQueueEntrySet.includes(queueEntry) then
			_rtQueueEntrySet.add(queueEntry);
		endif;
	endforeach;

end;
</source>
        <Parameter name="_rtQueueEntrySet" type="CM_RTQueueEntrySet" usage="input"/>
    </JadeMethod>
