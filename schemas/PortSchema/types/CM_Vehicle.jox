    <JadeMethod name="carrierCode" id="15a78344-2a88-4e55-8486-abd9b5c8ba0d">
        <methodInvocation>mapping</methodInvocation>
        <source>carrierCode(_set: Boolean; _value: String io) mapping;

vars

begin
	if _set then 
		app.raiseSetVirtualError(class.name, method.name);
