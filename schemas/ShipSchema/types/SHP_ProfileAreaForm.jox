    <JadeMethod name="btnSaveWebCam_click" id="ca058543-0b84-4885-a141-6a08214584c3">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSaveWebCam_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		19 October 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars


	aPicture : Binary;
	aTerm : CM_Terminal;
	tmpFileSave 		: CMDFileSave;
	fileName			: String;
begin
	on FileException do fileExceptionHandler(exception, 'webcam');
	
	app.mousePointer := Window.MousePointer_HourGlass;
	
	aTerm := CM_Terminal.firstInstance;
	if aTerm = null then
		return;
	endif;

	aPicture :=  aTerm.getConfig(PicWebCamPicture01).Binary;
	if aPicture &lt;&gt; null then
	
		create tmpFileSave;
		tmpFileSave.filter := "JMT Webcam Image (*.jpg)";//|(*.bmp)|*.bmp|(*.tif)|*.tif|(*.tga)|*.tga|(*.png)|*.png";
		tmpFileSave.initDir := 'C:\Temp';
		tmpFileSave.fileName := "webcam.jpg";
		if tmpFileSave.open = 0 then
			aPicture.writeSlobToFile(tmpFileSave.fileName);
		else
			return;
		endif;	
	endif;
	
	global.beep;
epilog
	app.mousePointer := Window.MousePointer_Default;
	if tmpFileSave &lt;&gt; null then
		delete tmpFileSave;
	endif;	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
