    <JadeMethod name="locateMachine" id="e9adc4f0-b31c-4600-9ad7-eda40b1e5575">
        <source>locateMachine(mach	:	CM_Machine)	:	CM_RadioTelemetryQueue;
//Finds a machine in the queue
vars
	subQueue	:	CM_RadioTelemetryQueue;
	foundQueue	:	CM_RadioTelemetryQueue;
begin
	if mach = null then
		return null;
	endif;
	if self.allPrimaryMachines.includes(mach) then
		return self;
	endif;
	if mach.isKindOf(CM_Crane) then
		if self.allPrimaryCranes.includes(mach) then
			return self;
		endif;
	endif;
	foreach subQueue in self.allSubQueuesById do
		foundQueue := subQueue.locateMachine(mach);
		if foundQueue &lt;&gt; null then
			return foundQueue;
		endif;
	endforeach;
end;</source>
        <Parameter name="mach" type="CM_Machine"/>
        <ReturnType type="CM_RadioTelemetryQueue"/>
    </JadeMethod>
    <JadeMethod name="locateTaskForTI" id="45b4d018-675f-4b39-a0f6-c83dee08122a">
        <source>locateTaskForTI(tiToSearch	:	CM_TrackedItem; _taskType : Integer) : CM_RTQueueTask;
//Called on a Queue, searches for, and returns the current 1st task.
vars
	entry	:	CM_RTQueueEntry;
	task	:	CM_RTQueueTask;
begin
	if self.allEntries.isEmpty then
		return null;
	endif;
	foreach entry in self.allEntries discreteLock do
		task := entry.locateTaskForTI(tiToSearch,_taskType);
		if task &lt;&gt; null then
			return task;
		endif;
	endforeach;
	return null;
end;</source>
        <Parameter name="tiToSearch" type="CM_TrackedItem"/>
        <Parameter name="_taskType" type="Integer"/>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="locateTaskForTIDownQueues" id="9309b4ef-512e-41ba-bd3c-f558fe0b3aee">
        <source>locateTaskForTIDownQueues(tiToSearch	:	CM_TrackedItem; _taskType : Integer ) : CM_RTQueueTask;

vars
	queue	:	CM_RadioTelemetryQueue;
	task	:	CM_RTQueueTask;
begin
	task := self.locateTaskForTI(tiToSearch, _taskType);
	if task &lt;&gt; null then
		return task;
	endif;
	foreach queue in self.allSubQueuesById discreteLock do
		task := queue.locateTaskForTI(tiToSearch, _taskType);
		if task &lt;&gt; null then
			return task;
		endif;
	endforeach;
	return null;
end;</source>
        <Parameter name="tiToSearch" type="CM_TrackedItem"/>
        <Parameter name="_taskType" type="Integer"/>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="moveSubQueue" id="7912f8b8-d354-44cb-81d2-4dd50cd0bbe0">
        <source>moveSubQueue(pQueue : CM_RadioTelemetryQueue; pPos : Integer);
// ---------------------------------------------------------------------------
// Created:     08 October 2001 by cnwrs2
//
// Purpose:     Moves a queue to the allSubQueuesByOrder array
//
// Parameters:  The queue to move
//				The positon in the allSubQueuesByOrder array to move to
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pPos = 0 or pPos &gt; self.allSubQueuesByOrder.size then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(MovingQueueToInvalidPosition, pQueue.id, pPos.String, null, null);
		return;
	endif;
	
	self.allSubQueuesByOrder.remove(pQueue);
	self.allSubQueuesByOrder.insert(pPos, pQueue);

end;</source>
        <Parameter name="pQueue" type="CM_RadioTelemetryQueue"/>
        <Parameter name="pPos" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="orderQueueEntriesByPriority" id="432c4307-fae1-4ef8-a62d-260b632eebb3">
        <source>orderQueueEntriesByPriority(_allQueueEntriesOrdered : CM_RTQueueEntryArray input; _machinesTA : CM_TerminalArea) : Boolean protected;
// -------------------------------------------
// Created 12 January 2005 by cnwdvb1
// -------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars

	iter					: Iterator;
	entry					: CM_RTQueueEntry;
	ti						: CM_TrackedItem;
	pLC						: CM_LocationsController;
	ta						: CM_TerminalArea;
	sameLocationEntryArray,	
	otherEntryArray			: CM_RTQueueEntryArray;

begin
	
	_allQueueEntriesOrdered.clear();
	if _machinesTA = null then
		return false;
	endif;
	
	// Create sorting arrays.
	create sameLocationEntryArray transient;
	create otherEntryArray transient;
	
	iter := self.allEntries.createIterator();
	
	while iter.next(entry) do
		if not tryLock(entry, Reserve_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
			//Locked by someone else.. continue
			continue;
		endif;
				
		ti := entry.myWorkListEntry.myTrackedItem;
		// Do we have a tracked item to check?
		if ti &lt;&gt; null then
			pLC := ti.getPrimaryLocation(REAL_MODE);
			// Do we know where it is?
			if pLC &lt;&gt; null then
				//cnwjo3 par 24180
				ta := pLC.getMyTerminalArea;			
				
				// Is it in the same place as the machine?
				if ta &lt;&gt; null then
					if ta = _machinesTA then
						// The system will attempt to allocate these entries first.
						sameLocationEntryArray.add(entry);
						unlock(entry);
						continue;
					endif;
				endif;
			endif;
		endif;
		// Just chuck in the normal array.
		otherEntryArray.add(entry);
		unlock(entry);
	endwhile;
	
	// Nothing. No point in wasting any more time.
	if sameLocationEntryArray.isEmpty then
		return false;
	endif;
	
	// Out they go.
	sameLocationEntryArray.copy(_allQueueEntriesOrdered);
	otherEntryArray.copy(_allQueueEntriesOrdered);
	
	return true;
	

epilog

	delete otherEntryArray;
	delete sameLocationEntryArray;
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_allQueueEntriesOrdered" type="CM_RTQueueEntryArray" usage="input"/>
        <Parameter name="_machinesTA" type="CM_TerminalArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="persistCriteria" id="a42d4d42-a5e7-452c-b623-58d01cb3a5af">
        <updating/>
        <source>persistCriteria(_allTransientCriteriaObj : CMIF_Array; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 October 2025		jlizm1	Initial creation TFS 59551 Kiosk Additional Question

*/

vars
	criteriaObj		: CM_YACriteria;
	cmifObject		: CMIF_Object;
	transientObj	: CMIF_YACriteriaPriority;
	proxyObj		: CM_YACriteriaPriority;
	realCPObj		: CM_YACriteriaPriority;
	isCreateDone	: Boolean;
	isDeleteDone	: Boolean;
	isUpdateDone	: Boolean;
	term 			: CM_Terminal;

begin

	foreach criteriaObj in self.allCriteria reversed do
		criteriaObj.setPriorityValue(criteriaObj.priorityValue * -1);
	endforeach;
	
	isCreateDone	:= false;
	isDeleteDone	:= false;
	isUpdateDone	:= false;
	
	foreach cmifObject in _allTransientCriteriaObj do
		transientObj	:= cmifObject.CMIF_YACriteriaPriority;
		proxyObj		:= transientObj.myProxy;
		realCPObj		:= transientObj.myCriteriaPriority;
		proxyObj.CM_YARTQueueCriteria.setMyQueue(self);
		
		// Do "New" first, because the "changed" flag can be set if a new Criteria
		// is changed after it is added, but before it is saved to the database
		if transientObj.isNew then
			app.myUtilityCA.utlCreateYACriteriaPriority(proxyObj, realCPObj, _passport);
			isCreateDone := true;
			
		elseif transientObj.isChanged then
			app.myUtilityUA.utlUpdateYACriteriaPriority(realCPObj, proxyObj, _passport);
			isUpdateDone := true;
			
		elseif transientObj.isDeleted then
			app.myUtilityDA.utlDeleteYACriteriaPriority(realCPObj, _passport);
			isDeleteDone := true;
			
		else
			// The Criteria/Priority has not been touched, however, we still need to update it,
			// because all priority values have been made negative as they all need to be 
			// resequenced for new or deleted Criteria
			app.myUtilityUA.utlUpdateYACriteriaPriority(realCPObj, proxyObj, _passport);
		endif;
	endforeach;
	
	self.recalculateCriteriaPriorities();
	
	self.validateCriteria();
	
	if isCreateDone or isUpdateDone or isDeleteDone then
		term := self.getMyTerminal;
		if term &lt;&gt; null then
			self.causeEvent(term.getTerminalEvent(EVENT_YA_CP_UPDATE), false, process);
		endif;
	endif;

end;</source>
        <Parameter name="_allTransientCriteriaObj" type="CMIF_Array"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="58726820-b671-4eb1-9a64-699978a5c676">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------
// Created:	30 October 2003 By: cnwgd1
//--------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy : SelfType;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	proxy.myParentQueue := self.myParentQueue;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="raiseExceptionIfQueueEntries" id="27715baf-8d1c-4753-9328-133b56e5c29c">
        <source>raiseExceptionIfQueueEntries() protected;
// ---------------------------------------------------------------------------
// Created:     08 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	exclusiveLock(self);

	if self.allEntries.size &lt;&gt; 0 then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_QUEUE_ENTRIES, id, self.allEntries.size.String, null, null);
		return;	
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="recalculateCriteriaPriorities" id="887e78cb-577f-401b-873e-ec72a6d1900a">
        <source>recalculateCriteriaPriorities();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 October 2025		jlizm1	Initial creation MTN 35861 RTQueue configuration - cargo attribute criteria

*/

vars
	criteriaObj			: CM_YACriteria;
	allCriteriaSetObj	: CM_YACriteriaSet;
	
begin
	create allCriteriaSetObj transient;
	self.allCriteria.copy(allCriteriaSetObj);
	
	foreach criteriaObj in allCriteriaSetObj do
		criteriaObj.calculatePriority();
	endforeach;
	
epilog
	delete allCriteriaSetObj;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="releaseMachine" id="bfff3fa6-bdec-4b66-a20e-79f703ff7001">
        <updating/>
        <source>releaseMachine(mach	:	CM_Machine input) : Boolean updating;
//Asks machine if its ok to leave Queue
vars

begin

	// DVB CCMS 1330
	if not mach.checkCanRemoveFromQueue(self) then // PAR 22224 added SELF
		return false;
	endif;
	mach.removeFromQueue(self);
	
	return true;

end;</source>
        <Parameter name="mach" type="CM_Machine" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeQueueEntry" id="bea8d3cb-ffcc-4786-bc1e-80c78bf5d14e">
        <source>removeQueueEntry(pEntry : CM_RTQueueEntry input);
// ---------------------------------------------------------------------------
// Created:     10 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29 Jul 2013	cnwkpd1		PAR #32107 - performance change 
// ---------------------------------------------------------------------------
vars

	terminal	: CM_Terminal;
	ti			: CM_TrackedItem;

begin

	exclusiveLock(self);
	exclusiveLock(self.allEntries);

	// PAR #32107 - change check to the other end for performance 
	if pEntry.myQueue = self then
//	if self.allEntries.includes(pEntry) then
		
		// DVB changed 14/08/06
		ti := pEntry.getTrackedItem();
		if ti &lt;&gt; null then
			if ti.allQueues.includes(self) then
				ti.removeFromQueue(pEntry);// PAR 25307 11/8/10 allQueues.remove(self);
			endif;
		endif;
		self.allEntries.remove(pEntry); //epr par 25495 19/8/10
		
		terminal := self.getMyTerminal();
		if terminal &lt;&gt; null then
			app.myEventManager.createSingleObjInfoNoteEvt(self,terminal.getTerminalEvent(Event_Delete_Queue_Entry),pEntry);
		endif;
	endif;
end;</source>
        <Parameter name="pEntry" type="CM_RTQueueEntry" usage="input"/>
    </JadeMethod>
