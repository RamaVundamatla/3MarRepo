    <JadeMethod name="updateLogLot" id="b8367808-e42a-41c0-b296-1e719034ece8">
        <updating/>
        <source>updateLogLot(_lot : CM_LogLot; _event : Integer)updating;
//--------------------------------------------------------------
//Created: 14 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	idx : Integer;
begin
	
	if self.filterVoyage = null then
		// No voyage selected so nothing to update
		return;
	endif;

	if _event = LogLot_Delete_Event then
		idx := cmbLot.findObject(_lot);
		// findObject returns -1 if not found
		if idx &gt; -1 then
			if self.filterLot = _lot then
				self.filterLot := null;
			endif;	
			cmbLot.gotFocus(cmbLot); // Save the original value
			self.myAssistant.LOG_Assistant.comboBoxLogVoyageLots(cmbLot, self.filterVoyage, self.filterLot);
			cmbLot.lostFocus(cmbLot);	
		endif;
		return;
	endif;

//	if self.filterVoyage &lt;&gt; _lot.myLogVoyage then
	if self.filterVoyage &lt;&gt; _lot.myLogVoyageStructure.myVoyage then	
	   	// Lot is not associated with voyage selected.
		return;
	endif;
	
	if _event = LogLot_Create_Event or
	   _event = LogLot_Update_Event then
   		cmbLot.gotFocus(cmbLot);
		self.myAssistant.LOG_Assistant.comboBoxLogVoyageLots(cmbLot, self.filterVoyage, self.filterLot);
		cmbLot.lostFocus(cmbLot);
	endif;
end;</source>
        <Parameter name="_lot" type="CM_LogLot"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateStockOrderAlloc" id="71396de8-ac7d-40e5-beaf-92937701453a">
        <updating/>
        <source>updateStockOrderAlloc(_stockOrderAlloc : CM_StockOrderAllocation; _event : Integer)updating;
//--------------------------------------------------------------
//Created: 14 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	idx 		: Integer;
	tmpVoyage	: CM_Voyage;
	logAssist	: LOG_Assistant;
begin
	
	if self.filterVoyage = null then
		// No voyage selected so nothing to update
		return;
	endif;

	logAssist := self.myAssistant.LOG_Assistant;
	
	if _event = StockOrderAlloc_Delete_Event then
		// Reload the locations
		self.cmbLocations.gotFocus(self.cmbLocations);
		logAssist.comboBoxAssignedLocations(self.cmbLocations, self.filterVoyage, null);
		if self.filterLogLocation &lt;&gt; null and
		   logAssist.allLotAssignedLocations.includes(self.filterLogLocation) then	
  			 self.cmbLocations.listObject := self.filterLogLocation;	
		endif;
		cmbLocations.lostFocus(cmbLocations);	
		return;
	endif;
		
	tmpVoyage := _stockOrderAlloc.myStockOrderHeader.myVoyage;
	
	if self.filterVoyage &lt;&gt; tmpVoyage then
		return;
	endif;
	
	if _event = StockOrderAlloc_Create_Event or
	   _event = StockOrderAlloc_Update_Event then 
		logAssist.comboBoxAssignedLocations(self.cmbLocations, self.filterVoyage, self.filterLogLocation);
		if self.filterLogLocation &lt;&gt; null and
		   (not logAssist.allLotAssignedLocations.includes(self.filterLogLocation)) then
		   	// Location has changed, update combo with new location
			 self.cmbLocations.listObject := _stockOrderAlloc.myLocationsController;
			 self.cmbLocations.lostFocus(cmbLocations);
		endif;
		
	endif;
end;</source>
        <Parameter name="_stockOrderAlloc" type="CM_StockOrderAllocation"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateVoyage" id="eeafb294-33cc-4e41-8688-fa0e90252eaa">
        <updating/>
        <source>updateVoyage(_voyage : CM_Voyage; _event : Integer)updating;
//--------------------------------------------------------------
//Created: 14 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	idx : Integer;
begin

	if _event = Voyage_Delete_Event then
		if self.filterVoyage = _voyage then
			self.filterVoyage := null;
			self.cmbVoyage.gotFocus(self.cmbVoyage);
			self.myAssistant.comboBoxVoyageCode(self.cmbVoyage, self.filterVoyage, false, true);
			self.cmbVoyage.lostFocus(self.cmbVoyage);
		endif;
		return;
	endif;

	// Cannot do this check on Voyage_Delete_Event as _voyage would be invalid.
//	if (not _voyage.isKindOf(CM_LogVoyage)) then
//		return;
//	endif;
	if _voyage.myLogVoyageStructure = null then 
		return;
	endif;	
	
	if _event = Voyage_Create_Event then
		self.myAssistant.comboBoxVoyageCode(self.cmbVoyage, filterVoyage, false, true);
	endif;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateVoyageOperator" id="3244bf11-4f65-44b9-8dab-afd07791d426">
        <updating/>
        <source>updateVoyageOperator(_voyOper : CM_VoyageOperator; _event : Integer)updating;
//--------------------------------------------------------------
//Created: 14 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	idx 		: Integer;
	tmpVoyOper	: CM_VoyageOperator;
begin
	
	if self.filterVoyage = null then
		// No voyage selected so nothing to update
		return;
	endif;

	if _event = VoyageOperator_Delete_Event then
		idx := cmbSupplier.findObject(_voyOper);
		// findObject returns -1 if not found
		if idx &gt; -1 then
			self.cmbSupplier.gotFocus(self.cmbSupplier);
			if cmbSupplier.listObject &lt;&gt; null and cmbSupplier.listObject &lt;&gt; _voyOper then
				tmpVoyOper := cmbSupplier.listObject.CM_VoyageOperator;
			endif;
			self.myAssistant.LOG_Assistant.comboBoxVoyageOperator(self.cmbSupplier, tmpVoyOper, filterVoyage);
			self.cmbSupplier.lostFocus(self.cmbSupplier);
		endif;
		return;
	endif;

	if self.filterVoyage &lt;&gt; _voyOper.myVoyage then
	   	// Not associated with voyage selected.
		return;
	endif;
	
	if _event = VoyageOperator_Create_Event then
		if cmbSupplier.listObject &lt;&gt; null then
			tmpVoyOper := cmbSupplier.listObject.CM_VoyageOperator;
		endif;	
		self.cmbSupplier.gotFocus(self.cmbSupplier);		
		self.myAssistant.LOG_Assistant.comboBoxVoyageOperator(self.cmbSupplier, tmpVoyOper, filterVoyage);
		self.cmbSupplier.lostFocus(self.cmbSupplier);					
	endif;
end;</source>
        <Parameter name="_voyOper" type="CM_VoyageOperator"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="cf3c45d8-f607-4f8c-8680-40c90a66df9d">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//--------------------------------------------------------------
//Created: 14 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	event : Integer;
begin

	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	
	if event = Voyage_Create_Event or
	   event = Voyage_Update_Event or 
	   event = Voyage_Delete_Event then
		self.updateVoyage(userInfo.CM_Voyage, event);
	endif;

	if self.filterVoyage = null then
		// No voyage selected
		return;
	endif;	
	 
	if event = VoyageOperator_Create_Event or 
	  event = VoyageOperator_Update_Event or 
	  event = VoyageOperator_Delete_Event then
		self.updateVoyageOperator(userInfo.CM_VoyageOperator, event);
		
	elseif event = LogLot_Create_Event or 
	  event = LogLot_Update_Event or 
	  event = LogLot_Delete_Event then
		self.updateLogLot(userInfo.CM_LogLot, event);
	
	elseif event = StockOrderAlloc_Create_Event or 
		event = StockOrderAlloc_Update_Event or 
		event = StockOrderAlloc_Delete_Event then
		self.updateStockOrderAlloc(userInfo.CM_StockOrderAllocation, event);
			
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validate" id="f723da13-fba6-4ad3-b8ff-c62ff31c80c7">
        <source>validate();
//--------------------------------------------------------------
//Created: 12 June 2002 By: cnwgd1
//--------------------------------------------------------------
//Validation is also done on the BOL at creation time.
//This may be a double up but from the GUI point of view it saves a lot of unnecessary processing.
// 10/12/2014  cnwdb2	PAR 35364

vars
	quantity : Integer;
	tmpStr,
	docketNumber : String;
begin

	docketNumber := self.tblHeaderDtls.getValueByName(ETRow_DocketNumber).String;
	quantity := self.tblHeaderDtls.getValueByName(ETRow_Quantity).Integer;

	if docketNumber = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Docket No.', ETRow_DocketNumber, null);	
		app.raiseCMException(Input_required_field_docketFld, ETRow_DocketNumber, null);	// cnwdb2	PAR 35364


	endif;	
	if quantity &lt;= 0 then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Quantity', ETRow_Quantity, null);	
		app.raiseCMException(Input_required_field_quantity, ETRow_Quantity, null);	// cnwdb2	PAR 35364		
	endif;

	if self.optLoadOutItem.value then
		if self.allLogIds.size &lt;&gt; quantity then
			app.raiseCMException2(InvalidQuantity, 'Log Ids to load ', quantity.String, null, null);	
		endif;
		
	elseif self.optLocnDtlsLogs.value then
		if self.allTrackedItems.size &lt;&gt; quantity then
			app.raiseCMException2(InvalidQuantity, 'Log Ids to load ', quantity.String, null, null);	
		endif;		
	endif;
	
	if self.filterOperator = null then
		tmpStr := app.getTerminologyAlternate(null, self.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Supplier');
	//	app.raiseCMException1(REQUIRED_FIELD, tmpStr, ETRow_Supplier, null);
		app.raiseCMException1(Input_required_field_Required, tmpStr, ETRow_Supplier, null); // cnwdb2	PAR 35364
		return;	
	endif;
	
	if self.transportMode = TI_TRANSMODE_SHIP then			
		self.validateForVoyage(docketNumber);
	elseif self.transportMode = TI_TRANSMODE_ROAD then
		self.validateForRoad(docketNumber);					
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForRoad" id="ce985c1e-f792-4b8c-ba5f-a9e67f1c1414">
        <source>validateForRoad(docketNumber : String);
//--------------------------------------------------------------
//Created: 12 June 2002 By: cnwgd1
//--------------------------------------------------------------
//Validation is also done on the BOL at creation time.
//This may be a double up but from the GUI point of view it saves a lot of unnecessary processing.
// 10/12/2014  cnwdb2	PAR 35364

constants 
	MsgStr = "in the Database. These entries must be unique.";
vars
	bol : CM_BOL;
	now	: TimeStamp;
	opTerm	: CM_OperatorTerminal;
begin
	now := app.actualTimeServer();	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support

	if self.transportMode &lt;&gt; TI_TRANSMODE_ROAD then			
		return;
	endif;

	if docketNumber &lt;&gt; null then
		opTerm := self.filterOperator.getOperatorTerminal(self.myTerminal, false);
		if opTerm &lt;&gt; null then
			bol := opTerm.allBOLByTypeNumber.getAtKey(BOLType_Log, docketNumber, now);
			if bol &lt;&gt; null and
			   bol.isKindOf(CM_BOLOut) and
			   bol.CM_BOLOut.myTerminalIfUnmatched = null then
				app.raiseCMException3(ERR_DUPLICATED_LABEL, 'Docket', docketNumber, MsgStr, null, null);	
			endif;
		endif;
	else
	//	app.raiseCMException1(REQUIRED_FIELD, 'Docket No.', null, null);	
		app.raiseCMException(Input_required_field_docketFld, null, null);	// cnwdb2	PAR 35364


		

	endif;

end;</source>
        <Parameter name="docketNumber" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForVoyage" id="0d19177d-e9fc-48b5-b0ab-8d3cb1d196c7">
        <source>validateForVoyage(docketNumber : String);
//--------------------------------------------------------------
//Created: 12 June 2002 By: cnwgd1
//--------------------------------------------------------------
//Validation is also done on the BOL at creation time.
//This may be a double up but from the GUI point of view it saves a lot of unnecessary processing.
constants 
	MsgStr = "in the Database. These entries must be unique.";
vars
	hatch, quantity: Integer;
	place, lot, uom : String;
	bol : CM_BOL;	
begin

	if self.transportMode &lt;&gt; TI_TRANSMODE_SHIP then			
		return;
	endif;

	lot	:= self.tblHeaderDtls.getValueByName(ETRow_Lot).String;	
	hatch := self.tblHeaderDtls.getValueByName(ETRow_Hatch).Integer;
	place := self.tblHeaderDtls.getValueByName(ETRow_Place).String;
	uom := self.tblHeaderDtls.getValueByName(ETRow_UnitOfMeasure).String;
		
	if hatch = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Hatch', null, null);	
		app.raiseCMException(Input_required_field_hatch, null, null);	

	endif;
	if place = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Place', null, null);	
		app.raiseCMException(Input_required_field_place, null, null);	
	endif;
	if uom = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Unit of Measure', ETRow_UnitOfMeasure, null);	
		app.raiseCMException(Input_required_field_unitOfMes, ETRow_UnitOfMeasure, null);	
	endif;		

	if self.filterProductCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Log Specifications', null, null);	
		app.raiseCMException(Input_required_field_logSpecs, null, null);	
		
		
		
		
	endif;
				
	if self.filterLot = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Lot No.', null, null);	
		app.raiseCMException(Input_required_field_lotNo, null, null);	// cnwdb2	PAR 35364

	endif;							
	if self.filterVoyage = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Voyage', null, null);	
		app.raiseCMException(Input_required_field_voyage, null, null); // cnwdb2	PAR 35364
	endif;	
	
	if self.filterStevedore = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Stevedore', null, null);	
		app.raiseCMException(Input_required_field_stevedore, null, null);	
		
	elseif docketNumber &lt;&gt; null then
		bol := self.filterStevedore.allBOLOutByNumberVoyage[docketNumber, self.filterVoyage];
		if bol &lt;&gt; null then
			app.raiseCMException3(ERR_DUPLICATED_LABEL, 'Docket', docketNumber, MsgStr, null, null);	

		endif;
	else
	//	app.raiseCMException1(REQUIRED_FIELD, 'Docket No.', null, null);	
		app.raiseCMException(Input_required_field_docketFld, null, null); // cnwdb2	PAR 35364
	endif;
end;</source>
        <Parameter name="docketNumber" type="String"/>
    </JadeMethod>
