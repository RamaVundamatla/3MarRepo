    <JadeMethod name="setProxy" id="d3ff5615-98eb-49d1-b640-65000cd1c773">
        <updating/>
        <source>setProxy(pName: Integer; pDescription: String)  updating;
//-----------------------------------------
//
// Created : by CNWAER1 
//-----------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);

	self.id 			:= pName.Integer;
	self.description 	:= pDescription[1:30].trimBlanks;
	self.myRoot 		:= app.myRoot;
end;</source>
        <Parameter name="pName" type="Integer"/>
        <Parameter name="pDescription" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="7668c8cf-87f9-4be5-9d57-2365dc55160b">
        <source>validateForCreate();
//-----------------------------------------
//
// Created : by CNWAER1 
//-----------------------------------------
vars

begin

	if app.myRoot.allDeliveryReasonselReasons[self.id] &lt;&gt; null then 
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.id.String, null, null);
	endif;

	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="c19797ef-7735-4943-83f3-47c5e382c261">
        <source>validateForUpdate();
//-----------------------------------------
//
// Created : by CNWAER1 
//-----------------------------------------
vars

begin
	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="0fb4b41a-1c1e-421c-a09c-8d565dc3a184">
        <source>validateMe() protected;
//-----------------------------------------
//
// Created : by CNWAER1 
//-----------------------------------------
vars

begin

	if self.id = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Delivery Release Reason ID', null, null);
		app.raiseCMException(Input_required_field_delRelId, null, null); 
		
	endif;
	if self.description.trimBlanks = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Delivery Release Reason Description', null, null);
		app.raiseCMException(Input_required_field_delRelDes, null, null); // cnwdb2	PAR 35364


	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
