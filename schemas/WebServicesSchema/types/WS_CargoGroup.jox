    <JadeMethod name="setProxyFromObject" id="24ad4cdf-7250-482e-8285-1f6f003aa79f">
        <updating/>
        <source>setProxyFromObject(_object: CM_CargoGroup) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Aug 2021	jlier1	Initial creation 51683
19 Jan 2023	navak20 Task 55838: New Rest end point to return cargo group detail
23 Mar 2023 navpw1	Defect: 57198: Added special stow field
22 Aug 2023 navma1	Bug 59932: EUP | Cargo Group -Special stow missing in group overview - FR 53422 | Ticket 59683
12 Sep 2023 navlc30 Bug 59886: EUP | Cargo Group - Quantity not showing total quantity of cargo - FR 53422 | Ticket 59683
14 Sep 2023 navlc30 Bug 59889: EUP | Cargo Group - special stow should be grouped by description instead of true/false - FR 53422 | Ticket 59683
12 Jan 2024 navbk1  CR  62005:  FR | 53422 - Cargo Group overview in Mobile Apps (part II)
26 Feb 2024 navbk1  Bug 62607: EUP - Group Overview showing "Multiple" for Mark Number when only one Mark Number exists
*/

constants
	STRING_MULTIPLE : String = "Multiple";

vars
	lc 			   : CM_LocationsController;
	measureType    : CM_MeasurementType;
	cargoType      : CM_CargoType;
	cargoSubType   : CM_Product;	
	ti 			   : CM_TrackedItem;	
    countPrenoted,
	countOffSite, 
	countOnShip	   : Integer;	
	iter		   : Iterator;
	specialStow	   : CM_SpecialStow;
	specialStowtr  : String;
begin
	inheritMethod(_object);
	if _object.myCargoType &lt;&gt; null then
		self.description:= _object.myCargoType.abbreviation &amp; " " &amp; _object.operatorCode;
	else
		self.description:=  _object.operatorCode;
	endif;
	
	
	measureType := app.getDefaultMeasurementForType(Type_Weight);
	if measureType &lt;&gt; null then
		self.weightUnit:=measureType.shortName ;
		self.minWeight :=  app.convertMeasurementForDisplay(self.weightUnit, _object.minWeight);
		if self.minWeight = "" then
			self.minWeight:=_object.minWeight.asStringWeightJMT;
		endif;
		self.maxWeight :=  app.convertMeasurementForDisplay(self.weightUnit, _object.maxWeight); 
		if self.maxWeight = "" then
			self.maxWeight:=_object.maxWeight.asStringWeightJMT;
		endif;
		self.totalWeight:= app.convertMeasurementForDisplay(self.weightUnit, _object.totalWeight); 
		if self.totalWeight = "" then
			self.totalWeight:=_object.totalWeight.asStringWeightJMT;
		endif;
	else
		self.minWeight   := _object.minWeight.asStringWeightJMT;
		self.maxWeight   := _object.maxWeight.asStringWeightJMT;
		self.totalWeight := _object.totalWeight.asStringWeightJMT;
	endif;
	self.id					 :=  _object.id;
	self.count				 := _object.totalQuantity;
	self.preAssignedCount	 := _object.allPreAssignedCargoIdsDict.size;
	self.isComplete			 := _object.isComplete;
	self.actualLocationsDesc := _object.getAllLocations( null );
	self.plannedLocationDesc := _object.getDefaultLocation;
	self.scannedCount		 := _object.getScannedCount();
	self.toScanCount 		 := _object.getPreAssignedToScan( null );
	self.isPreAssigned		 :=_object.allPreAssignedCargoIdsDict.size &gt; 0;
	
	
	// ### TFS 57198 23Mar2023 NAVPW1
	//not the cargo type of the cargo group but of the assigned cargo
	cargoType :=  _object.getCargoGroupCargoType();
	if cargoType &lt;&gt; null then
		self.cargoTypeId	:= cargoType.id.asStringJMT;
		self.cargoTypeDesc	:= cargoType.abbreviation;
	endif;
	
	//not the cargo type of the cargo group but of the assigned cargo
	cargoSubType := _object.getCargoGroupCargoSubType();
	if cargoSubType &lt;&gt; null then
		self.cargoSubTypeDesc := cargoSubType.description;
	endif;
	
	//not the cargo type of the cargo group but of the assigned cargo
	self.voyageCode			 := _object.getCargoGroupVoyage();
	self.vesselName			 := _object.getCargoGroupVessel();
	self.dischargePortDesc   := _object.getCargoGroupDischargePortDesc();
	self.destinationPortDesc := _object.getCargoGroupDestPortDesc();
	self.commodityDesc 		 := _object.getCargoGroupCommodity();
	self.operatorDesc 		 := _object.getCargoGroupOperator();
	self.imexStatusDesc 	 := _object.getCargoGroupImexStatusDesc();
	self.voyageArrivalDate   := _object.getCargoGroupVoyageArrDate();              //12.1.2024 navbk1 #62005
	self.markNumbers		 := _object.getMarkNumber();						   //26.2.2024 navbk1 #62607
	/*
	22.08.2023 navma1 #59932
	*/
	specialStowtr := _object.getCargoGroupSpecialStow();
	
	if specialStowtr = STRING_MULTIPLE then											//14.9.2023 navlc30 #59889
		self.hasSpecialStow  := true;
		self.specialStowCode := STRING_MULTIPLE;
		self.specialStowDesc := STRING_MULTIPLE;
	elseif specialStowtr &lt;&gt; null then												//14.9.2023 navlc30 #59889
		specialStow := app.myRoot.allSpecialStows[specialStowtr];
		if specialStow &lt;&gt; null then
			self.hasSpecialStow  := true;
			self.specialStowCode := specialStow.code;
			self.specialStowDesc := specialStow.description;
		endif;
	endif;

	self.totalQuantity := _object.totalQuantity.String;
	self.totalVolume   := _object.totalVolume.String;
	
	iter := _object.allAssignedTrackedItems.createIterator;
	
	while iter.next(ti) do
		//jlier1 TFS 59948 13/10/23
		/*
		//26.2.2024 navbk1 #62607
		if ti.markNumber &lt;&gt; null then
			self.markNumbers:=self.markNumbers.appendCommaSeparatedValue(ti.markNumber, false);
		endif; */
		if ti.state &lt;&gt; TI_STATE_NOTIFIED and ti.state &lt;&gt; TI_STATE_OFFSITE and ti.state &lt;&gt; TI_STATE_ONSHIP then
            continue;
        endif;
        if ti.state = TI_STATE_NOTIFIED then
            countPrenoted += ti.totalQuantity;									//12.9.2023 navlc30 #59886
		elseif ti.state = TI_STATE_ONSHIP then
			countOnShip   += ti.totalQuantity;									//12.9.2023 navlc30 #59886
		elseif ti.state = TI_STATE_OFFSITE then
			countOffSite  += ti.totalQuantity;									//12.9.2023 navlc30 #59886
        endif;
		
	endwhile;
	
	// ### TFS 57198 23Mar2023 NAVPW1
	self.amountOffSite  := countOffSite;
	self.amountOnShip   := countOnShip;
	self.amountPrenoted := countPrenoted;
	// ### TFS 57198 23Mar2023 NAVPW1
	
	//End 19.01.2023 navak20 TFS 55838
	lc:= _object.getLastOnsiteLocation;
	if lc &lt;&gt; null then
		self.lastOnsteLocationDesc:=lc.getFullId;
	endif;
	self.remarks:=_object.remarks;
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_object" type="CM_CargoGroup"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromObject" id="a2f1783f-d16e-4794-9546-16147b6b2570">
        <updating/>
        <source>setPxyFromObject(_object: CM_CargoGroup; _mode: String; _entity : Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Feb 2024 navhl20 ChangeRequest 62406:[62534] EUP | Scanning App Cargo Group Overview Changes
28 Mar 2024 navbk1  Bug 63193: EUP | Scanning App Cargo Group Overview Changes
03 May 2024 navbk1  Bug 63811: EUP | Scanning App Cargo Group Overview Changes - Part 2
18 Apr 2025	navhl20 Bug MTN-34624: EUP | 53856 - Scanning App - further issues
*/

constants
	STRING_MULTIPLE : String = "Multiple";

vars
	lc 			   : CM_LocationsController;
	measureType    : CM_MeasurementType;
	cargoType      : CM_CargoType;
	cargoSubType   : CM_Product;	
	ti 			   : CM_TrackedItem;	
    countPrenoted,
	countOffSite, 
	countOnShip	   : Integer;	
	iter		   : Iterator;
	specialStow	   : CM_SpecialStow;
	specialStowtr  : String;
begin
	self.setProxyFromObject(_object);
	if _object.myCargoType &lt;&gt; null then
		self.description:= _object.myCargoType.abbreviation &amp; " " &amp; _object.operatorCode;
	else
		self.description:=  _object.operatorCode;
	endif;
	
	
	measureType := app.getDefaultMeasurementForType(Type_Weight);
	if measureType &lt;&gt; null then
		self.weightUnit:=measureType.shortName ;
		self.minWeight :=  app.convertMeasurementForDisplay(self.weightUnit, _object.minWeight);
		if self.minWeight = "" then
			self.minWeight:=_object.minWeight.asStringWeightJMT;
		endif;
		self.maxWeight :=  app.convertMeasurementForDisplay(self.weightUnit, _object.maxWeight); 
		if self.maxWeight = "" then
			self.maxWeight:=_object.maxWeight.asStringWeightJMT;
		endif;
		/*
		//18.04.2025 navhl20 #34624
		self.totalWeight:= app.convertMeasurementForDisplay(self.weightUnit, _object.totalWeight); 
		if self.totalWeight = "" then
			self.totalWeight:=_object.totalWeight.asStringWeightJMT;
		endif;*/
	else
		self.minWeight   := _object.minWeight.asStringWeightJMT;
		self.maxWeight   := _object.maxWeight.asStringWeightJMT;
		//self.totalWeight := _object.totalWeight.asStringWeightJMT;				//18.04.2025 navhl20 #34624
	endif;
	self.id					 :=  _object.id;
	self.count				 := _object.totalQuantity;
	self.preAssignedCount	 := _object.allPreAssignedCargoIdsDict.size;
	/*
	//28.03.2024 navbk1 #63193
	self.isComplete			 := _object.isComplete;									
	*/
	self.actualLocationsDesc := _object.getOnsiteLocations( null );					//18.04.2025 navhl20 #34624
	self.plannedLocationDesc := _object.getPlannedLocation();
	self.scannedCount		 := _object.getCargoCount(true,_mode,_entity);			//03.05.2024 navbk1 #63811
	self.totalWeight 		 := _object.getTotalWeightScanned(_mode, _entity);		//18.04.2025 navhl20 #34624
	self.toScanCount		 := _object.getCargoCount(false,_mode, _entity);		//03.05.2024 navbk1 #63811
	self.isPreAssigned		 :=_object.allPreAssignedCargoIdsDict.size &gt; 0;
	self.isComplete			 := self.toScanCount = 0;								//28.03.2024 navbk1 #63193
	
	//not the cargo type of the cargo group but of the assigned cargo
	cargoType :=  _object.getCargoGroupCargoType();
	if cargoType &lt;&gt; null then
		self.cargoTypeId	:= cargoType.id.asStringJMT;
		self.cargoTypeDesc	:= cargoType.abbreviation;
	endif;
	
	//not the cargo type of the cargo group but of the assigned cargo
	cargoSubType := _object.getCargoGroupCargoSubType();
	if cargoSubType &lt;&gt; null then
		self.cargoSubTypeDesc := cargoSubType.description;
	endif;
	
	//not the cargo type of the cargo group but of the assigned cargo
	self.voyageCode			 := _object.getCargoGroupVoyage();
	self.vesselName			 := _object.getCargoGroupVessel();
	self.dischargePortDesc   := _object.getCargoGroupDischargePortDesc();
	self.destinationPortDesc := _object.getCargoGroupDestPortDesc();
	self.commodityDesc 		 := _object.getCargoGroupCommodity();
	self.operatorDesc 		 := _object.getCargoGroupOperator();
	self.imexStatusDesc 	 := _object.getCargoGroupImexStatusDesc();
	self.voyageArrivalDate   := _object.getCargoGroupVoyageArrDate();
	self.markNumbers		 := _object.getMarkNumber();
	
	specialStowtr := _object.getCargoGroupSpecialStow();
	
	if specialStowtr = STRING_MULTIPLE then
		self.hasSpecialStow  := true;
		self.specialStowCode := STRING_MULTIPLE;
		self.specialStowDesc := STRING_MULTIPLE;
	elseif specialStowtr &lt;&gt; null then
		specialStow := app.myRoot.allSpecialStows[specialStowtr];
		if specialStow &lt;&gt; null then
			self.hasSpecialStow  := true;
			self.specialStowCode := specialStow.code;
			self.specialStowDesc := specialStow.description;
		endif;
	endif;

	self.totalQuantity := _object.totalQuantity.String;
	self.totalVolume   := _object.totalVolume.String;
	
	iter := _object.allAssignedTrackedItems.createIterator;
	
	while iter.next(ti) do
		if ti.state &lt;&gt; TI_STATE_NOTIFIED and ti.state &lt;&gt; TI_STATE_OFFSITE and ti.state &lt;&gt; TI_STATE_ONSHIP then
            continue;
        endif;
        if ti.state = TI_STATE_NOTIFIED then
            countPrenoted += ti.totalQuantity;
		elseif ti.state = TI_STATE_ONSHIP then
			countOnShip   += ti.totalQuantity;
		elseif ti.state = TI_STATE_OFFSITE then
			countOffSite  += ti.totalQuantity;
        endif;
		
	endwhile;
	
	self.amountOffSite  := countOffSite;
	self.amountOnShip   := countOnShip;
	self.amountPrenoted := countPrenoted;
	
	lc:= _object.getLastOnsiteLocation;
	if lc &lt;&gt; null then
		self.lastOnsteLocationDesc:=lc.getFullId;
	endif;
	self.remarks:=_object.remarks;
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_object" type="CM_CargoGroup"/>
        <Parameter name="_mode" type="String"/>
        <Parameter name="_entity" type="Object"/>
    </JadeMethod>
</Class>
