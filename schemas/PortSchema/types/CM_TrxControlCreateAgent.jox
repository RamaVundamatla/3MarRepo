    <JadeMethod name="trxCreateTransactionType" id="6e17dd96-f4cb-4d37-872d-5dc8b199cc5b">
        <updating/>
        <source>trxCreateTransactionType(	pProxyObj : CM_TransactionType input;
							pNewObj : CM_TransactionType output;
							_passport : CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		25 November 2005 by cnwdad1
//
// Purpose:		Creates the persistent object.
//
// Parameters:	pProxyObj - A reference to the proxy object.
//				pNewObj - A reference (output) to the new object.
//				_passport - A reference to the user passwport object.
//
// Returns:		A reference to the new object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do self.agtPassportExHandler(exception, _passport);
	on LockException do self.agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	// Start the transaction
	beginTransaction;

	// Perform the operation
	app.myValCA.valTransactionType(pProxyObj, false);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create pNewObj persistent;
	pNewObj.setForCreate(pProxyObj);
	
	if _passport.noErrors then
		app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(pNewObj);
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="pProxyObj" type="CM_TransactionType" usage="input"/>
        <Parameter name="pNewObj" type="CM_TransactionType" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
