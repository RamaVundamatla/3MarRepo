19 February 2010	cnwjk3	Initial creation

*/

vars

begin
	return not self.allTrackedItems.isEmpty();
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="7cd00b90-92e8-41c8-b979-31fffa2b12d5">
        <source>pxyCreateUpdateProxy(): SelfType;

// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxyReceivalInfo : CM_ReceivalInfo;
	completedOK		: Boolean;
begin
	pxyReceivalInfo := inheritMethod();
	pxyReceivalInfo.myBooking := self.myBooking;
	pxyReceivalInfo.myBookingItem := self.myBookingItem;
	pxyReceivalInfo.myCargoType := self.myCargoType;
	pxyReceivalInfo.myCargoSubtype := self.myCargoSubtype;
	pxyReceivalInfo.commodity := self.commodity;
	pxyReceivalInfo.quantity := self.quantity;
	pxyReceivalInfo.setParent(self.getParent);
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyReceivalInfo;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyReceivalInfo;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
