    <JadeMethod name="getCargoToBeScanned" id="be8638cf-7f5f-45de-b7a1-6c887ff95596">
        <source>getCargoToBeScanned( _strArray : StringArray input; _mode : String; _oid : String ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Feb 2024 navhl20 ChangeRequest 62406:[62535] EUP | Scanning App Cargo Group Overview Changes
26 Feb 2024 navhl20 Bug 62614: EUP - Cargo Scanning - Internal Server error when clicking on search icon
12 Aug 2024 navbk1  Bug 65344: FR | 53856 - New Scanning App - Cargo Group Overview - Cargo groups not found

*/

vars
	strArr	: StringArray;
	ti,
	childTi : CM_TrackedItem;
	cargoId	: String;
	vehicle	: CM_Vehicle;
	wagon	: CM_Wagon;
	voyage	: CM_Voyage;
	wo		: CM_WorkOrderTI;
begin
	if _mode = "ship" then
		voyage	:= app.myPassport.getObjectOfTypeFromOid(_oid, CM_Voyage).CM_Voyage;
	elseif _mode = "road" then
		vehicle := app.myPassport.getObjectOfTypeFromOid(_oid, CM_Vehicle).CM_Vehicle;
	elseif _mode = "rail" then
		wagon 	:= app.myPassport.getObjectOfTypeFromOid(_oid, CM_Wagon).CM_Wagon;
	elseif _mode = "unpack" then
		wo 		:= app.myPassport.getObjectOfTypeFromOid(_oid, CM_WorkOrderTI).CM_WorkOrderTI;
	endif;
	
	create strArr transient;
	foreach ti in self.allAssignedTrackedItems do
		if _mode = "ship" then
			if voyage &lt;&gt; null and ti.state = TI_STATE_ONSHIP and not ti.receivedDT.isValid() 				//26.02.2024 navhl20 #62614
			and ti.imexStatus &lt;&gt; TI_IMEX_STATUS_REMAINONBOARD and ti.myVoyage = voyage and not strArr.includes(ti.id) then
				strArr.add(ti.id);
			endif;
		elseif _mode = "road" then
			if vehicle &lt;&gt; null and ti.isOnVehicle(vehicle) and not strArr.includes(ti.id) then				//26.02.2024 navhl20 #62614
				strArr.add(ti.id);
			endif;
		elseif _mode = "rail" then
			if wagon &lt;&gt; null and ti.isOnWagon and ti.wagon = wagon.id and not strArr.includes(ti.id) then	//26.02.2024 navhl20 #62614
				strArr.add(ti.id);
			endif;
		elseif _mode = "unpack" then
			//START 12.08.2024 navbk1 #65344
			if wo &lt;&gt; null and wo.allTIs.includes(ti.getParent()) and not strArr.includes(ti.id) then
				strArr.add(ti.id);
			endif;
			/*if wo &lt;&gt; null and wo.allTIs.includes(ti) and ti.allChildren.isNotEmpty() then					//26.02.2024 navhl20 #62614
				foreach childTi in ti.allChildren do
					if not strArr.includes(childTi.id) then
						strArr.add(childTi.id);
					endif;
				endforeach;
			endif;*/
			//END 12.08.2024 navbk1 #65344
		endif;
	endforeach;
	
	if strArr.isNotEmpty then
		foreach cargoId in strArr do
			_strArray.add( cargoId );
		endforeach;
		return 1;
	endif;
	
	return 0;
epilog
	delete strArr;
end;</source>
        <Parameter name="_strArray" type="StringArray" usage="input"/>
        <Parameter name="_mode" type="String"/>
        <Parameter name="_oid" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDefaultLocation" id="ea214dbd-c8fd-4eab-aead-3fa6a61cb963">
        <source>getDefaultLocation():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	ncg : CM_NotifiedCargoGroup;

begin

	if self.defaultLocation &lt;&gt; null then
		return self.defaultLocation;
	else
		ncg := self.getMyNotifiedGroup;
		if ncg &lt;&gt; null then
			return ncg.defaultLocation;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDefaultTargetLocation" id="f82a89bd-5b52-42ef-92a4-b2fe56b45dc4">
        <source>getDefaultTargetLocation( _ti : CM_TrackedItem ) : String;
/*

Purpose:			

Parameters:			Find the location of the last cargo item added that is still on-site

Return Value:		

Date		Who		Reason
17 September 2015	cnwndl1	Initial creation	Par 36906

*/

vars

	iter : Iterator;
	trx : CM_TITransaction;
	trxTi : CM_TrackedItem;
	lastLocation : CM_LocationsController;

begin

	iter := self.allTransactions.createIterator;
	while iter.back( trx ) do
		if trx.type &lt;&gt; TRANS_TYPE_GRP_ASSIGN then
			continue;
		endif;
		trxTi := trx.CM_GroupAssign.getOtherTrackedItem;
		if trxTi = null or trxTi = _ti or ( not trxTi.isOnSite ) then
			continue;
		endif;
		if trxTi.isNotified or trxTi.myPrimaryActualLocation = null then	//15 Feb 2016	NDL	Par 37544
			continue;
		endif;
		if not self.allAssignedTrackedItems.includes(trxTi) then
			//no longer associated with Cargo group
			continue;
		endif;
		if trxTi.myPrimaryActualLocation = _ti.myPrimaryActualLocation then
			continue;
		endif;
		//Ok we got one that is still on site and still in the Cargo Group
		return trxTi.myPrimaryActualLocation.getFullId;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDetailForTIAndSite" id="33de35f9-0a78-4515-ae97-6d09da8dfb9d">
        <source>getDetailForTIAndSite(_ti: CM_TrackedItem input; _site: Integer) : CM_CargoGroupDetail;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 April 2023	navmd1	Initial creation TFS 56062 Fix Cargo Group Detail headers not updating correctly

*/

vars
	cgDetail	: CM_CargoGroupDetail;
begin
	foreach cgDetail in self.allCargoGroupDetails where cgDetail.site = _site do
		if cgDetail.allAssignedTrackedItems.includes(_ti) then
			return cgDetail;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_site" type="Integer"/>
        <ReturnType type="CM_CargoGroupDetail"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="c0bb814d-78a5-4d6c-87bc-94e44a7d6e73">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2015	cnwndl1	Initial creation	Par 36338
// 05 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 21 Apr 2022 navhl20 TFS 53352 EUP - Voyage External Reference Field Usability - UI
//09-06-2022	navtnr20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// 22 Jun 2022	navsrk20	Bug 53887: EUP - Items Cargo Type to be shown instead of Cargo Group Type
//05 July 2023 navmv20 CR 58410 Task 58414: UI - Cargo Review - Grouping Table
24 July 2023 navmv20 CR 58239 Task 58240: UI - New COO columns
30/11/2023	navkc1 ChangeRequest 58254 Task 61099: UI - Ownership Change Approved
*/

vars

	realCG 		: CM_CargoGroup;
	ti 			: CM_TrackedItem;
	ct 			: CM_CargoType;
	prod 		: CM_Product;
	shipLine	: CM_ShippingLine;
	cm : CM_Commodity;
begin
	
	ti := self.allAssignedTrackedItems.first;      //21 Apr 2022 navhl20 TFS 53352
	
	if _attrName = ETRow_LocationArea
	or _attrName = ETRow_LocationSubArea
	or _attrName = ETRow_Lot
	or _attrName = ETRow_Hatch
	or _attrName = ETRow_Place
	or _attrName = ETRow_MyPlannedLocation
	or _attrName = ETRow_PlannedLocn
	or _attrName = ETRow_PlannedLocnId
	or _attrName = ETRow_QueuedLocnId
	or _attrName = ETRow_MyPrimaryQueuedLocation
	or _attrName = ETRow_PlannedLocnFull
	or _attrName = ETRow_LocationIdFull
	or _attrName = ETRow_TargetLocation
	or _attrName = ETRow_TranshipPlannedLocation
	or _attrName = ETRow_TranshipActualLocation
	or _attrName = ETRow_TerminalSubArea
	or _attrName = ETRow_VoyageArea
	or _attrName = ETRow_ShippingLineCode
	then
		return null;

	// ### TFS CR 59942 TASK 59943 06SEP2023 NAVAB1 - from here
	elseif _attrName = ETRow_CargoSubtypeCode then
		prod := self.getCargoGroupCargoSubType();
		if prod &lt;&gt; null then
			return prod.code;
		endif;
	elseif _attrName = ETRow_Location then	 // ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1
		return self.getCargoGroupDetailLocations();
	elseif _attrName = ETRow_Site then	 // ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1
		return self.getCargoGroupDetailSites();
	elseif _attrName = ETRow_ImexStatus 
	or _attrName = ETRow_IMEXStatus then	
		return self.getCargoGroupImexStatusDesc(); 
	elseif _attrName = ETRow_Voyage then	
		return self.getCargoGroupVoyage();
	elseif	_attrName = ETRow_CargoSubtypeDescr then
		prod := self.getCargoGroupCargoSubType();
		if prod &lt;&gt; null then
			return prod.description;
		endif;
	elseif _attrName = ETRow_CommodityDesc then
		return self.getCargoGroupCommodity(); 
	elseif _attrName = ETRow_Commodity 
	or _attrName = ETRow_CommodityCode then
		cm := self.getCargoGroupCommodityObj();
		if cm &lt;&gt; null then
			return cm.code;
		endif;
	elseif _attrName = ETRow_CargoTypeCode then
		ct := self.getCargoGroupCargoType();
		if ct &lt;&gt; null then
			return ct.abbreviation;
		endif;
	elseif _attrName = ETRow_CargoTypeDescription then
		ct := self.getCargoGroupCargoType();
		if ct &lt;&gt; null then
			return ct.description;
		endif;
	elseif _attrName = ETRow_CargoTypeCodeForCntnt then //02/10/2025	navkc1 JIRA 36151 AAT | RotaBox ISO Type and New Attributes - JADE
		ct := self.getCGCargoTypeForContents();
		
		if ct &lt;&gt; null then
			return ct.abbreviation;
		endif;
		
		return null;
		
	elseif _attrName = ETRow_CargoTypeForCntnt then //02/10/2025	navkc1 JIRA 36151 AAT | RotaBox ISO Type and New Attributes - JADE
		ct := self.getCGCargoTypeForContents();
		
		if ct &lt;&gt; null then
			return ct.description;
		endif;
		
		return null;
	elseif _attrName = ETRow_CargoSubTypeCodeForCntnt then //02/10/2025	navkc1 JIRA 36151 AAT | RotaBox ISO Type and New Attributes - JADE
		prod := self.getCGCargoSubTypeForContents();
		
		if prod &lt;&gt; null then
			return prod.code;
		endif;
		
		return null;
	elseif _attrName = ETRow_CargoSubTypeForCntnt then //02/10/2025	navkc1 JIRA 36151 AAT | RotaBox ISO Type and New Attributes - JADE
		prod := self.getCGCargoSubTypeForContents();
		
		if prod &lt;&gt; null then
			return prod.description;
		endif;
		
		return null;
	elseif	_attrName	= ETRow_VesselCode then
		return self.getCargoGroupVessel();
	elseif	_attrName	= ETRow_CustomsStatus then 
		return self.getCargoGroupCustomStatus();
	elseif	_attrName	= ETRow_CountryOfOriginRgnCode then
		return self.getCargoGroupOriginRegionCode();
	elseif	_attrName	= ETRow_CountryOfOriginRegion then
		return self.getCargoGroupOriginRegionDesc();
	elseif	_attrName	= ETRow_CountryOfDestRegion then 
		return self.getCargoGroupDestRegionDesc();
	elseif	_attrName	= ETRow_CountryOfDestRegionCode then
		return self.getCargoGroupDestRegionCode();
	// ### TFS CR 59942 TASK 59943 06SEP2023 NAVAB1 - to here
		
	elseif _attrName = ETRow_AssignedCargo then
		if self.isTransient then
			realCG := self.pxyGetRealObject();
			if realCG &lt;&gt; null then
				return realCG.getAssignedAsDelimString(CrLf); 
			else
				return null;
			endif;
		else
			return self.getAssignedAsDelimString(CrLf); 
		endif;
	
	elseif _attrName = ETRow_NumOnsiteCargo then
		return self.onSiteAssignedCount().asStringJMT;
		
	elseif _attrName = ETRow_NumPreNotified then	//15 Feb 2016	NDL	Par 37544
		return self.prenotifiedAssignedCount().asStringJMT;
	
	elseif _attrName = ETRow_NumReleased then	//15 Feb 2016	NDL	Par 37544
		return self.releasedAssignedCount().asStringJMT;
	
	elseif _attrName = ETRow_LastItemReleased then
		return self.systemToLocalTime(self.releasedDT).asStringJMT;// 05 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	elseif _attrName = ETRow_GroupCargoSubType or _attrName = ETRow_CargoCargoSubType then
		prod := self.getCargoGroupCargoSubType();	//30 July 2018	NDL	TFS 39186
		if prod &lt;&gt; null then
			return prod.description;
		endif;
		return null;
		
	elseif _attrName = ETRow_GroupCargoType or _attrName = ETRow_CargoCargoType or _attrName = ETRow_CargoType then		//22.06.2022 navsrk20 TFS 53887
		ct := self.getCargoGroupCargoType();
		if ct &lt;&gt; null then
			return ct.description;
		endif;
		return null;
		
	elseif _attrName = ETRow_GroupLocation then
		return self.getGroupLocation();					//10 June 2024 navrv30 Task 64477 CR 64475
	elseif _attrName = ETRow_AssignedCargoHasStops then	//21 Sep 2015	NDL	Par 36338
		return self.assignedCargoHasStops.getYesNo();
	
	elseif _attrName = ETRow_AssignedCargoHasTasks then	//21 Sep 2015	NDL	Par 36338
		return self.getHasTasks.getYesNo();             //10 June 2024 navrv30 Task 64477 CR 64475
	elseif _attrName = ETRow_IsOverlanded then	//10 June 2024 navrv30 Task 64477 CR 64475
		return self.getHasOverlanded.getYesNo();             
	elseif _attrName = ETRow_IsShortlanded then	//10 June 2024 navrv30 Task 64477 CR 64475
		return self.getHasShortlanded.getYesNo();
		
	elseif _attrName = ETRow_DefaultLocation then	//01 Oct 2018	NDL	TFS 39186
	//	return self.defaultLocation;
		return self.getDefaultLocation;	//13 Nov 2019	NDL	TFS 47298
	
	elseif _attrName = ETRow_CargoGroupAssignId then	//01 Oct 2018	NDL	TFS 39186
		if self.getMyCargoGroupAssignment &lt;&gt; null then
			return self.getMyCargoGroupAssignment.id;
		endif;
		return null;
	
	elseif _attrName = ETRow_CargoGroupAssignType then	//01 Oct 2018	NDL	TFS 39186	
		if self.isPreAssigned then
			return app.getErrorString(Preassigned);
		elseif self.isSelectable then
			return app.getErrorString(Selectable);
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_CargoGroupId then	//01 Oct 2018	NDL	TFS 39186
		return self.id;
		
	elseif _attrName = ETRow_IsCompleted then	//01 Oct 2018	NDL	TFS 39186
		return self.complete.asStringJMT;
	
	elseif _attrName = ETRow_ScannedCount then	//01 Oct 2018	NDL	TFS 39186
		return self.getScannedCount.asStringJMT;
		
	//Start 21 Apr 2022 navhl20 TFS 53352
	elseif _attrName = ETRow_ExternalRef then
		if ti &lt;&gt; null then
			return ti.myVoyage.externalRef;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_ExternalCode then
		if ti &lt;&gt; null then
			return ti.myVoyage.voyageCodeExternal;
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_VesselName then
		if ti &lt;&gt; null then
			return ti.myVoyage.vesselName;
		else
			return null;
		endif;
	//End 21 Apr 2022 navhl20 TFS 53352
	 elseif _attrName = ETRow_ShippingLine then // 18-may-2022 -navtnr20 53204
		if ti &lt;&gt; null then
			//TFS#53362 navsp1 20Jun2022
			if self.myTerminal.getConfig(ComboByNameAgent).Boolean then  
				shipLine := ti.myShippingLine;	// 14.07.2022 navsrk20 53195
				if shipLine &lt;&gt; null then
					return shipLine.description;
				endif;
			endif;
			return ti.getShippingLineCode();	// 14.07.2022 navsrk20 53195
		else
			return null;
		endif;
	elseif _attrName = ETRow_Reservations then //05/07/2023 navmv20 CR 58410 Task 58414
		return self.getReservations(); //05/07/2023 navmv20 CR 58410 Task 58414
	//24/07/2023 navmv20 CR 58239 Task 58240 - start
	elseif _attrName = ETRow_COONumber then
		return self.getCOONumber();
	elseif _attrName = ETRow_COODateTime then
		return self.getCOODate();
	elseif _attrName = ETRow_COOINCODesc then
		return self.getCOOIncotermDesc();
	elseif _attrName = ETRow_COOINCOCode then
		return self.getCOOIncotermCode();
	elseif _attrName = ETRow_OperatorPreviousDesc then
		return self.getCOOOperatorOldDesc();
	elseif _attrName = ETRow_OperatorPreviousCode then
		return self.getCOOOperatorOldCode();
	elseif _attrName = ETRow_OperatorReceiveDesc then
		return self.getCOOOperatorOrigDesc();
	elseif _attrName = ETRow_OperatorReceiveCode then
		return self.getCOOOperatorOrigCode();
	elseif _attrName = ETRow_OperatorStorageDesc then
		return self.getCOOOperatorStorageDesc();
	elseif _attrName = ETRow_OperatorStorageCode then
		return self.getCOOOperatorStorageCode();
	elseif _attrName = ETRow_FreeDaysOperatorOld then
		return self.getCOOOperatorOldFreeDays();
	elseif _attrName = ETRow_FreeDaysOperatorNew then
		return self.getCOOFreeDays();
	elseif _attrName = ETRow_FreeDaysAdditional then
		return self.getCOOFreeDaysAdditional();
	elseif _attrName = ETRow_OperatorNewCode then
		return self.getCOOOperatorNewCode();
	elseif _attrName = ETRow_OperatorNewDesc then
		return self.getCOOOperatorNewDesc();
	//24/07/2023 navmv20 CR 58239 Task 58240 - end
	elseif _attrName = ETRow_MyOperator then
		return self.getAllOperatorsCode(); //30/11/2023	navkc1 ChangeRequest 58254 Task 61099
	endif;

	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGrammage" id="eae7b058-4cc9-46b3-bfb4-83919b091b32">
        <source>getGrammage(): Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
24 June 2024	navlw1	ChangeRequest 61729: EUP | Goods Receipt Technical Debt - Remove code setting item level grammage

*/

vars
	grammage,
 	tiGrammage	: Decimal[23,2];
	ti 			: CM_TrackedItem;
begin
	grammage := null;
	foreach ti in self.allAssignedTrackedItems discreteLock do
		tiGrammage := ti.getGrammage();
		
		if grammage = null then
			grammage := tiGrammage;
		endif;
		// set the grammage if they match or return null if they do not
		if grammage = tiGrammage then
			grammage := tiGrammage;
		else
			return null;
		endif;
	endforeach;
	
	return grammage;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getGroupLocation" id="280cf925-392a-4b6b-8888-99670514ce6d">
        <source>getGroupLocation() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 June 2024 navrv30 Task 64477 CR 64475: Jade - New Cargo Group Details II
24/03/2025	navkc1 JIRA Story MTN-34256: MTN | Cargo Group Details for non Euroports Clients
*/

vars
	cgd : CM_CargoGroupDetail;
	locForGroup,
	retStr, valueStr : String;
	ti	: CM_TrackedItem;
	
begin
	//24/03/2025	navkc1 JIRA Story MTN-34256
	if self.allCargoGroupDetails.isEmpty() then
		foreach ti in self.allAssignedTrackedItems discreteLock do
			locForGroup := ti.getLocationForGroup();
			if locForGroup &lt;&gt; null then
				retStr.addStringToList(ti.getLocationForGroup(), ", ");
			endif;
		endforeach;
	else
		foreach cgd in self.allCargoGroupDetails discreteLock do
			valueStr := cgd.locationForGroup;
			/*
			if valueStr &lt;&gt; null then
				if retStr.pos(valueStr, 1) = 0 then
					if retStr = null then
						retStr := valueStr;
					else
						retStr := retStr &amp; ", " &amp; valueStr;
					endif;
				endif;
			endif;	
			*/
			
			retStr.addStringToList(valueStr, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
		endforeach;
	endif;
	
	return retStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHSCodeObject" id="a9d3dee1-d0bd-40e9-a528-50fe8497f633">
        <source>getHSCodeObject(): CM_HarmonizedSystem;
/*
Purpose:			

Date		Who		Reason
01 September 2023	navab1	CR 59942 TASK 59943 
*/

vars
	ti : CM_TrackedItem;
begin
	ti := self.allAssignedTrackedItems.first;
	
	if ti &lt;&gt; null then
		return ti.myHSCode;
	endif;

	return null;
epilog

end;</source>
        <ReturnType type="CM_HarmonizedSystem"/>
    </JadeMethod>
    <JadeMethod name="getHasOverlanded" id="b0e90c17-e26c-4014-99a8-bf1b6e0ec946">
        <source>getHasOverlanded() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 June 2024 navrv30 Task 64477 CR 64475: Jade - New Cargo Group Details II
24/03/2025	navkc1 JIRA Story MTN-34256: MTN | Cargo Group Details for non Euroports Clients
*/

vars
	cgDtl : CM_CargoGroupDetail;
	ti : CM_TrackedItem; 
begin
	//24/03/2025	navkc1 JIRA Story MTN-34256
	if self.allCargoGroupDetails.isEmpty() then
		foreach ti in self.allAssignedTrackedItems discreteLock do
			if ti.isOverlanded() then
				return true;
			endif;
		endforeach;
	else
		foreach cgDtl in self.allCargoGroupDetails discreteLock do
			if cgDtl.hasOverlanded then
				return true;
			endif;		
		endforeach;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
