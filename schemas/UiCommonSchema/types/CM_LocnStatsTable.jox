    <JadeMethod name="addItemGridColumnAt" id="d9e68a10-ee13-4ed3-95ff-4e34b804a619">
        <updating/>
        <source>addItemGridColumnAt(_gridColObj : CM_GridColumn; _addAtIndex : Integer):Integer updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 March 2012	cnwndl1	Initial creation	Par 29350

*/

vars

	tableRowLabel	: String;
	rowString	: String;
	tableRowIndex	: Integer;
	tableColumnIndex : Integer;
	tableRowObj : JadeTableRow;
	tableCellObj : JadeTableCell;
	tempLocationStats : CM_LocationStatistics;
	tempCreated : Boolean;
	
begin
	
	tableRowLabel	:=	_gridColObj.getLabel();
	
	if tableRowLabel = null then
		return 0;
	endif;
	
	if _gridColObj.myLocationStatistics = null then
		_gridColObj.buildLocationStatsTranisent(tempLocationStats);
		tempCreated := true;
	else
		tempLocationStats := _gridColObj.myLocationStatistics;
	endif;
	
	if tempLocationStats = null then
		rowString	:=	Tab &amp; tableRowLabel;
	else
		rowString	:=	tempLocationStats.getAttributeStringForDefArray(self.allTblDataEntRows);
	endif;
	
	if _addAtIndex &gt; 0 then
		self.addItemObjectAt(_gridColObj, rowString, _addAtIndex);
		tableRowIndex	:=	_addAtIndex;
	else
		tableRowIndex	:=	self.addItemObject(_gridColObj, rowString);
	endif;
	
	tableRowObj :=	self.accessRow(tableRowIndex);
	tableRowObj.height :=	18;
	self.colourAddedRow(tableRowIndex, self.myForm.CM_BaseForm.colorRow1, self.myForm.CM_BaseForm.colorRow2);
	
	if tempCreated and tempLocationStats &lt;&gt; null then
		tableColumnIndex :=	self.getColumnByRowName(ETRow_Code);
		tableCellObj :=	self.accessCell(tableRowIndex, tableColumnIndex);
		tableCellObj.text :=	"   " &amp; tableRowLabel;
	endif;
	
	return tableRowIndex;
	
epilog

	if tempCreated then
		delete tempLocationStats;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_gridColObj" type="CM_GridColumn"/>
        <Parameter name="_addAtIndex" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addItemGridRowAt" id="8f3dec14-3be6-412f-b561-671daa9c77c1">
        <updating/>
        <source>addItemGridRowAt(_gridRowObj:CM_GridRow; _row:Integer):Integer updating, protected;
// --------------------------------------------------------------------------------
// Created:		07 November 2008 by cnwdad1
//
// Purpose:		Adds the specified Grid Row to the receiver at the specified row.
//
// Parameters:	_gridRowObj - A reference to the Grid Row to add to the table.
//				_row - The row at which to add the Grid Area.
//
// Returns:		The index of the new row.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 05/03/2009	cnwdad1		Change to use a method to get the row label (which strips
//							out extraneous characters), and if the label is null,
//							then don't add the row.
// --------------------------------------------------------------------------------
vars
	rowLabel	: String;
	rowString	: String;
	rowPointer	: Integer;
	colPointer	: Integer;
	rowObj		: JadeTableRow;
	cellObj		: JadeTableCell;	
begin
	
	rowLabel	:=	_gridRowObj.getLabel();
	
	if rowLabel = null then
		return 0;
	endif;
	
	if _gridRowObj.myLocationStatistics = null then
		rowString	:=	Tab &amp; rowLabel;
	else
//		rowString	:=	Tab &amp; _gridRowObj.row.String &amp; ', ' &amp; _gridRowObj.label &amp;
//						Tab &amp; _gridRowObj.myLocationStatistics.getDelimitedStats(Tab);
		rowString	:=	_gridRowObj.myLocationStatistics.getAttributeStringForDefArray(self.allTblDataEntRows);
	endif;
	
	if _row &gt; 0 then
		self.addItemObjectAt(_gridRowObj, rowString, _row);
		rowPointer	:=	_row;
	else
		rowPointer	:=	self.addItemObject(_gridRowObj, rowString);
	endif;
	
	rowObj				:=	self.accessRow(rowPointer);
	rowObj.height		:=	18;
	self.colourAddedRow(rowPointer, self.myForm.CM_BaseForm.colorRow1, self.myForm.CM_BaseForm.colorRow2);
	colPointer			:=	self.getColumnByRowName(ETRow_Code);
	cellObj				:=	self.accessCell(rowPointer, colPointer);
	cellObj.text		:=	"   " &amp; cellObj.text;
	
	return rowPointer;
end;</source>
        <access>protected</access>
        <Parameter name="_gridRowObj" type="CM_GridRow"/>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addItemRoRoControllerAt" id="ee975f69-6eba-4add-913a-7d9c3a7543b4">
        <updating/>
        <source>addItemRoRoControllerAt(_roroObj:CM_RoRoController; _row:Integer):Integer updating, protected;
// --------------------------------------------------------------------------------
// Created:		25 January 2010 by cnwjo3
//
// Purpose:		Add subrow under RoroLaneArea for more details information on lanes
//
vars
	rowLabel	: String;
	rowString	: String;
	rowPointer	: Integer;
	colPointer	: Integer;
	rowObj		: JadeTableRow;
	cellObj		: JadeTableCell;
	tempLocationStats : CM_LocationStatistics;
begin
	rowLabel	:=	_roroObj.id.String;
	
	if rowLabel = null then
		return 0;
	endif;

	_roroObj.buildLocationStatsTranisent(tempLocationStats);
	
	rowString	:=	tempLocationStats.getAttributeStringForDefArray(self.allTblDataEntRows);
	
	if _row &gt; 0 then
		self.addItemObjectAt(_roroObj, rowString, _row);
		rowPointer	:=	_row;
	else
		rowPointer	:=	self.addItemObject(_roroObj, rowString);
	endif;
	
	rowObj				:=	self.accessRow(rowPointer);
	rowObj.height		:=	18;
	self.colourAddedRow(rowPointer, self.myForm.CM_BaseForm.colorRow1, self.myForm.CM_BaseForm.colorRow2);
	colPointer			:=	self.getColumnByRowName(ETRow_Code);
	cellObj				:=	self.accessCell(rowPointer, colPointer);
	cellObj.text		:=	"   " &amp; cellObj.text;
	
	return rowPointer;
epilog
	delete tempLocationStats;
end;</source>
        <access>protected</access>
        <Parameter name="_roroObj" type="CM_RoRoController"/>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addItemTermAreaAt" id="8fec87b8-1a6b-411c-b70c-ba58a44aae87">
        <updating/>
        <source>addItemTermAreaAt(_terminalAreaObj:CM_TerminalArea; _row:Integer):Integer updating, protected;
// --------------------------------------------------------------------------------
// Created:		07 November 2008 by cnwdad1
//
// Purpose:		Adds the specified Terminal Area to the receiver at the specified row.
//
// Parameters:	_terminalAreaObj - A reference to the Terminal Area to add to the table.
//				_row - The row at which to add the Terminal Area.
//
// Returns:		The index of the new row.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowString	: String;
	rowPointer	: Integer;
	colPointer	: Integer;
	rowObj		: JadeTableRow;
	cellObj		: JadeTableCell;
	gridRow		: Integer;
	gridAreaObj	: CM_GridArea;
	gridRowObj	: CM_GridRow;
	
	roroLaneObj	: CM_RoRoController;  //CCMS 1018
	roro		: CM_RoRoLaneArea;
	gridColObj	: CM_GridColumn;
begin
	if _terminalAreaObj.myLocationStatistics = null then
		rowString	:=	Tab &amp; _terminalAreaObj.id;
	else
//		rowString	:=	Tab &amp; _terminalAreaObj.id &amp;
//						Tab &amp; _terminalAreaObj.myLocationStatistics.getDelimitedStats(Tab);
		rowString	:=	_terminalAreaObj.myLocationStatistics.getAttributeStringForDefArray(self.allTblDataEntRows);
	endif;
	
	if _row &gt; 0 then
		self.addItemObjectAt(_terminalAreaObj, rowString, _row);
		rowPointer	:=	_row;
	else
		rowPointer	:=	self.addItemObject(_terminalAreaObj, rowString);
	endif;
	
	rowObj				:=	self.accessRow(rowPointer);
	rowObj.height		:=	18;
	rowObj.backColor	:=	self.myForm.CM_BaseForm.colorHeadingColumn;
	colPointer			:=	self.getColumnByRowName(ETRow_Code);
	cellObj				:=	self.accessCell(rowPointer, colPointer);
	cellObj.text		:= cellObj.text;
	
	self.setExpanded(rowPointer, self.NoRows);
	
	if _terminalAreaObj.isKindOf(CM_ForkLiftStack) then	//28 Mar 2012	NDL	Par 29350
		// apparently these are shown by Column not by Row!
		gridAreaObj	:=	_terminalAreaObj.CM_GridArea;
		gridRow		:=	rowPointer + 1;
		foreach gridColObj in gridAreaObj.allGridColumns do
			if self.addItemGridColumnAt(gridColObj, gridRow) &gt; 0 then
				gridRow	:=	gridRow + 1;
				self.setExpanded(rowPointer, self.Collapse);
			endif;
		endforeach;
			
	elseif _terminalAreaObj.isGridArea() then
		gridAreaObj	:=	_terminalAreaObj.CM_GridArea;
		gridRow		:=	rowPointer + 1;
		foreach gridRowObj in gridAreaObj.allGridRows do
			if self.addItemGridRowAt(gridRowObj, gridRow) &gt; 0 then
				gridRow	:=	gridRow + 1;
				self.setExpanded(rowPointer, self.Collapse);
			endif;
		endforeach;
		
	//cnwjo3 par 21189
	elseif _terminalAreaObj.isKindOf(CM_BlockStack) then
		//We don't need multiple (or sub-rows) here for block stack.
	elseif _terminalAreaObj.isKindOf(CM_RoRoLaneArea) then  //ccms 1018
		roro := _terminalAreaObj.CM_RoRoLaneArea;
		gridRow := rowPointer + 1;
		
		foreach roroLaneObj in roro.allLanesById do
			if self.addItemRoRoControllerAt(roroLaneObj, gridRow) &gt; 0 then
				gridRow	:=	gridRow + 1;
				self.setExpanded(rowPointer, self.Collapse);
			endif;
		endforeach;
	endif;
	
	return rowPointer;
end;</source>
        <access>protected</access>
        <Parameter name="_terminalAreaObj" type="CM_TerminalArea"/>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="adjustStatHeading" id="03726a2c-c594-4ec1-9e27-ebc1e6492465">
        <updating/>
        <source>adjustStatHeading(_text: String; _allSizes: StringArray; _titleWidth : Integer) updating, protected;
// --------------------------------------------------------------------------------
// Created:		18 February 2009 by cnwdad1:2
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	i			: Integer;
	colPointer	: Integer;
	minCol		: Integer;
	columnCount : Integer;
	newWidth : Integer;
begin
	//cnwjo3 ccms 1018
	foreach i in 1 to _allSizes.size() do
		if self.getColumnByRowName(_allSizes[i]) &gt; 0 then
			columnCount := columnCount + 1;
		endif;
	endforeach;

	foreach i in 1 to _allSizes.size() do
		colPointer	:=	self.getColumnByRowName(_allSizes[i]);
		
		if colPointer &gt; 0 then
			newWidth := (_titleWidth/columnCount).Integer;
			self.accessColumn(colPointer).width		:=	newWidth;
			self.accessColumn(colPointer).alignment	:=	Table.Alignment_Right_Middle;
			
			if minCol = 0 then
				minCol	:=	colPointer;
			else
				minCol	:=	minCol.min(colPointer);
			endif;
		endif;
	endforeach;
	
	if minCol &gt; 0 then
		self.accessCell(1, minCol).text	:=	_text;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_text" type="String"/>
        <Parameter name="_allSizes" type="StringArray"/>
        <Parameter name="_titleWidth" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="click" id="64bda372-4bde-46d8-8c25-9bbf23076196">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>click(table: Table input) updating, clientExecution;
//12 August 2008	cnwdw1	
//1 Feb 2010 cnwjo3.  Moved here from click
vars
	obj			: Object;
	colPointer	: Integer;
	
begin
	colPointer	:=	self.getColumnByRowName(ETRow_HideShow);
	
	if table.column = colPointer then
		obj	:=	table.accessRow(table.row).itemObject;
		
		if obj.isKindOf(CM_Terminal) then
			if table.column = 1 then
				self.expandTerminal(obj.CM_Terminal, not self.isRowExpanded());
				inheritMethod(table);
			endif;
		elseif obj.isKindOf(CM_TerminalArea) then
			if table.column = 1 then
				self.expandTermArea(obj.CM_TerminalArea, not self.isRowExpanded());
				inheritMethod(table);
			endif;
		endif;
	endif;
	
	inheritMethod(table);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="contextMenu" id="01f98def-a147-42c3-bfd2-60a35e83b7f8">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating, clientExecution;
//04 December 2008	cnwdw1	
//
vars

begin
	return self.myForm.contextMenu(conwin, mouse, x, y);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="dblClick" id="03465de6-1767-4217-b9fa-2cbb8a673bb6">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>dblClick(table: Table input) updating;
//12 August 2008	cnwdw1	
//1 Feb 2010 cnwjo3.  Moved here from click
vars
	obj			: Object;
	colPointer	: Integer;
	
begin
	colPointer	:=	self.getColumnByRowName(ETRow_HideShow);
	
	if table.column = colPointer then
		if table.row &lt;= table.fixedRows then
			self.expandAllRows(not self.isRowExpanded());
			inheritMethod(table);
		endif;
	endif;
	
	inheritMethod(table);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
