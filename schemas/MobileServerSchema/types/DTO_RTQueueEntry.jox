    <JadeMethod name="getLocationTargetExtra" id="43c290ae-01b7-4233-8b2c-c1260bfcac64">
        <source>getLocationTargetExtra() : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/08/2011	cnwdap1	Initial creation PAR #28047 CCMS POL 2095 display extra location information
19/10/2011	cnwdap1	PAR #28300 Refactor
23 May 2012	cnwer1  PAR 29611 didn't work with tasks that had been offered i.e. after clicking get next
*/
vars
	rtTask ,setdownRTTask: CM_RTQueueTask;

begin
	if self.myRealQueueEntry = null then
		return null;
	endif;
	rtTask := self.myRealQueueEntry.CM_RTQueueEntry.getDirectorOrPickupTask;
	if rtTask = null then
		return null;
	endif;
	if rtTask.isPickUp then
		setdownRTTask:=self.myRealQueueEntry.CM_RTQueueEntry.getDirectorOrSetDownTask(); 
	else
		setdownRTTask:=	rtTask;
	endif;
	
	if setdownRTTask = null then
		// occurred in DMAST. 06 Sep 2012	NDL
		return null;
	endif;
	
	return setdownRTTask.getTargetLocationExtra;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationTargetString" id="203b743f-c124-4eb9-bdf3-00173a4bc97a">
