<Class name="CM_YATypeDestinationPort" id="ad352009-908f-4a71-bd3e-073f141f45ee">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getAllCriteriaValues" id="c1e85e2b-40d4-4956-9e4b-ac96f5d89be2">
        <source>getAllCriteriaValues(_terminalObj:CM_Terminal; _allCriteriaValues: ObjectSet input; _filter : Integer; _allDependentObjs : CM_ObjectArray);
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//17 September 2013	cnwmc5	PAR 31255 - allowing dependent objects the criteria is based on.
// --------------------------------------------------------------------------------
vars
	port : CM_Port;
begin
	//+ cnwmd1, Par 21178
	if _filter = YAFilterOpt_Rail then
		//Note that we are not using Root.allActivePorts collection because it contains a condition
		//which filters for ports that have CM_Port.bIsPort set.
		foreach port in app.myRoot.allPorts where port.isActive and port.bIsRail do
			_allCriteriaValues.add(port);
		endforeach;
	else
		//app.myRoot.allActivePorts.copy(_allCriteriaValues);
		app.myRoot.allActiveDestinations.copy(_allCriteriaValues);	// 27/09/2011 cnwar2 #28084
	endif;
	
	//app.myRoot.allActivePorts.copy(_allCriteriaValues); //- cnwmd1, Par 21178
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaObjectForTi" id="20560141-a40f-4cd5-8e00-b82c083dcc5f">
        <source>getCriteriaObjectForTi(_ti: CM_TrackedItem; _criteriaObject: CM_Object output; _process: Boolean output);

vars

begin
	_criteriaObject := app.myRoot.allPorts[_ti.destinationPort];
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaObject" type="CM_Object" usage="output"/>
        <Parameter name="_process" type="Boolean" usage="output"/>
    </JadeMethod>
