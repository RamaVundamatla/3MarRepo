    <JadeMethod name="getOnlyDriverForTerminal" id="904af5a8-c780-43b5-b23f-9217987af5bf">
        <source>getOnlyDriverForTerminal() : CM_DriverDetails ;
/*

Date		Who		Reason
26 November 2014	cnwer1	Initial creation CCMS 2369

*/

vars
	drivers : ObjectSet;
	driver		: CM_DriverDetails;
begin
	create drivers transient;
	
	foreach driver in self.allDrivers discreteLock do
		if driver.myTerminal = self.myTerminal then
			drivers.add(driver);
		endif;
	endforeach;
	
	if drivers.size = 1 then
		return drivers.first.CM_DriverDetails;
	endif;
	return null;
epilog
	delete drivers;
end;</source>
        <ReturnType type="CM_DriverDetails"/>
    </JadeMethod>
    <JadeMethod name="getQueuedLocFromReq" id="d43911dc-d17b-43bc-a288-a1d33d957efe">
        <source>getQueuedLocFromReq(): String;
/*

Purpose:Returns the Queued location of the first Delivery Request			

Parameters:			

Return Value:		

Date		Who		Reason
13 Aug 2025	navbs1	Initial creation Story MTN-35549: TPT | Source Location for RT Moves on the Road Ops Screen - Dev

*/

vars
	job 		: CM_Job;
	request  	: CM_Request;
	queuedLoc	: String;
begin

	job := self.getCurrentRoadJob;
	foreach  request in job.allRequests do 
		if request.isKindOf(CM_DeliveryRequest) then 
			queuedLoc := request.CM_DeliveryRequest.queuedLocation;
			if queuedLoc &lt;&gt; null then 
				return queuedLoc;
			endif;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
