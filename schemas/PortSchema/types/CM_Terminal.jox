    <JadeMethod name="isLicensed" id="b26fdc0b-0a1b-410e-ad5a-0d0de51109c5">
        <source>isLicensed() : Boolean;
// ---------------------------------------------------------------------------
// Created:     02 April 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cls		: Class;
	obj		: Object;
	licName	: String;

begin

	// need to call into license key schema
	obj := app.myCheckerObject;
	licName := self.licenseName;
	if obj = null or licName = null then
		return false;
	endif;

	return obj.sendMsgWithParams('isLicenseRegistered', licName, 'JMT').Boolean;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOnePortStatusToBeProcessed" id="49b67e40-ae9c-4bf7-ba92-0690e73cf344">
        <source>isOnePortStatusToBeProcessed(_status : String; _mtnMovementStatus : Integer output) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/11/2025	navkc1 JIRA 36176 NSW | OnePort API - Change voyage creation criteria DB / UI / Process changes

*/

vars
	nvPair 	: CM_NameValuePair;
	value	: String;
	idx		: Integer;
begin
	
	nvPair := self.allOnePortStatuses[_status];
	
	if nvPair &lt;&gt; null then
		value := nvPair.value;
		
		if value.endsWith("|1") then
			idx := 1;
			_mtnMovementStatus := value.scanUntil("|", idx).Integer; // Return MTN status to calling method
			return true;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_status" type="String"/>
        <Parameter name="_mtnMovementStatus" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
