    <JadeMethod name="getEDIDataType" id="54d15aa6-3e70-4b1f-a4b6-e309708b9927">
        <source>getEDIDataType(_fileType: Integer): Class;
// ---------------------------------------------------------------------------
// Created:		20 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 7.6.3 PAR17931 - cnwsh3 Removed CM_EDIDataCBPCAMIR as no data type of this was implemented.
//						   Also added new edi data class - CM_EDIDataBillOfLading.
// 01/09/2009	cnwrl1	PAR 20320 - MES 1011 New Messina Messages
// 14 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req

vars
	type	: Integer;
	
begin
	type := _fileType;
	
	if type = EDI_Index_BayPlan then
		return CM_EDIDataBayPlan;
	elseif type = EDI_Index_BookingRef then
		return CM_EDIDataBookingRef;
	elseif type = EDI_Index_Prenote then
		return CM_EDIDataPrenote;
	elseif type = EDI_Index_StowAdvice then
		return CM_EDIDataStowAdvice;
	elseif type = EDI_Index_CustomStop then
		return CM_EDIDataCustomStop;
	elseif type = EDI_Index_OperatorStop then
		return CM_EDIDataOperatorStop;
	elseif type = EDI_Index_OutwardRail then
		return CM_EDIDataOutwardRail;
	elseif type = EDI_Index_GateDoc then
		return CM_EDIDataGateDoc;
	elseif type = EDI_Index_Generic then
		return CM_EDIDataGeneric;
	elseif type = EDI_Index_LoadList then
		return CM_EDIDataLoadList;
