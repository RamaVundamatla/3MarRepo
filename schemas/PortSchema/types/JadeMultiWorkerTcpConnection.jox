<Class name="JadeMultiWorkerTcpConnection">
    <JadeMethod name="getDiagnosticDescription" id="ae43a54b-2f51-4548-8bb9-8e8d28fe02dc">
        <source>getDiagnosticDescription() : String;

/*

Purpose:			Get a description of the receiver for diagnostic logging purposes

Parameters:			None

Return Value:		String describing receiver state, etc


Date		Who		Reason
05 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars
	temp,
	returnVal		: String;
	
begin
	returnVal := self.String;
	returnVal := returnVal &amp; " groupId=" &amp; self.getGroupId().String;
	returnVal := returnVal &amp; " connectionId=" &amp; self.connectionId.String;
	returnVal := returnVal &amp; " state=" &amp; self.state.String;
	returnVal := returnVal &amp; " remoteAddress=" &amp; self.remoteAddress;
	temp := self.getRemoteHostname();
	if temp &lt;&gt; null then
		returnVal := returnVal &amp; " (" &amp; temp &amp; ")";
	endif;
	returnVal := returnVal &amp; " remotePortnumber=" &amp; self.remotePortnumber.String;
	
	return returnVal;
	
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
