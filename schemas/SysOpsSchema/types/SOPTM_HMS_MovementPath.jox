    <JadeMethod name="create" id="54b5b718-24aa-47b4-9920-e719aa20f9cb">
        <updating/>
        <source>create() updating;
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	self.name 				:= SOP_TableMaintForm.Table_MovementPath;
	self.permissionView	 	:= PmHMSPathView;
	self.permissionMaint 	:= PmHMSPathMaint;
	self.myDataClass 		:= HMS_MovementPath;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doCloneARouteSeg" id="f2e74a46-9cc7-401d-8129-e7ef676539ef">
        <source>doCloneARouteSeg(pathSegment : HMS_PathSegment;  whereAreWe : HMS_HarbourRegion io; theForm : SOP_HMS_TableMaintForm io) : CMUI_FieldComboBox;
//-----------------------------------------------------------------------
//	Created:	24 August 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	fieldRoute : CMUI_FieldComboBox;
begin
	fieldRoute:= theForm.fieldRouteSeg.cloneSelf(true);
	allRouteSegmentCtrls.add(fieldRoute);
	theForm.addControl(fieldRoute); 
	fieldRoute.parent := theForm.frmPathSegments;
	fieldRoute.visible := true;
	fieldRoute.top := allRouteSegmentCtrls.size * 30 + 50;
	fieldRoute.labelWidth := 100;
	fieldRoute.height := 50;
	theForm.myAssistant.fieldPathSegment(fieldRoute,pathSegment, whereAreWe);
	whereAreWe := pathSegment.myRegionTo;
	return fieldRoute;
epilog

end;</source>
        <Parameter name="pathSegment" type="HMS_PathSegment"/>
        <Parameter name="whereAreWe" type="HMS_HarbourRegion" usage="io"/>
        <Parameter name="theForm" type="SOP_HMS_TableMaintForm" usage="io"/>
        <ReturnType type="CMUI_FieldComboBox"/>
    </JadeMethod>
    <JadeMethod name="doFieldRouteSegClick" id="688c4ef2-4571-4a36-b436-4cbaa991b50d">
        <source>doFieldRouteSegClick(fieldRouteSeg : CMUI_FieldComboBox );
//-----------------------------------------------------------------------
//	Created:	24 August 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars

	theForm 			: SOP_HMS_TableMaintForm;
	pathSegment			: HMS_PathSegment;
	whereAreWe			: HMS_HarbourRegion;
	idx					: Integer;
	oldFieldRouteSeg,
	newFieldRouteSeg,
	nextFieldRouteSeg	: CMUI_FieldComboBox;
begin

  	theForm 			:= self.myForm.SOP_HMS_TableMaintForm; 
	theForm.frmPathSegments.enabled := true;
	
	if self.allRouteSegmentCtrls.isEmpty then
		newFieldRouteSeg := self.doCloneARouteSeg (null, whereAreWe, theForm);
	endif;
	
	if fieldRouteSeg &lt;&gt; null then
		pathSegment 		:= fieldRouteSeg.getObject().HMS_PathSegment;
		whereAreWe 			:= pathSegment.myRegionTo;
		oldFieldRouteSeg 	:= fieldRouteSeg;
	endif;
	
	if oldFieldRouteSeg = self.allRouteSegmentCtrls.last then
		newFieldRouteSeg := self.doCloneARouteSeg (pathSegment, whereAreWe, theForm);
//		oldFieldRouteSeg.caption := "Via " &amp; (self.allRouteSegmentCtrls.size - 1).String;
//		newFieldRouteSeg.caption := "Via " &amp; (self.allRouteSegmentCtrls.size).String;
		theForm.lblDestination.top := allRouteSegmentCtrls.size * 30 + 100;
		
	else
		if oldFieldRouteSeg = null then
			nextFieldRouteSeg := self.allRouteSegmentCtrls[1].CMUI_FieldComboBox;
			whereAreWe := theForm.cmbRegionSource.listObject.HMS_HarbourRegion;
		else
			nextFieldRouteSeg := self.allRouteSegmentCtrls[self.allRouteSegmentCtrls.indexOf (oldFieldRouteSeg) + 1].CMUI_FieldComboBox;
		endif;
		nextFieldRouteSeg.visible := true;
		theForm.myAssistant.fieldPathSegment (nextFieldRouteSeg ,null, whereAreWe);
		foreach idx in (self.allRouteSegmentCtrls.indexOf (nextFieldRouteSeg) + 1) to self.allRouteSegmentCtrls.size do
			self.allRouteSegmentCtrls[idx].visible := false;
		endforeach;

	endif;
	if whereAreWe &lt;&gt; null then
		theForm.lblDestination.caption := "Finishing  Point : " &amp;  whereAreWe.description;
		theForm.lblDestination.fontBold := true;
	else
		theForm.lblDestination.caption := "Finishing  Point : " ;
	endif;
epilog

end;</source>
        <Parameter name="fieldRouteSeg" type="CMUI_FieldComboBox"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="2f7e78d2-4676-4ada-89df-d49059ab6caa">
        <updating/>
        <source>doSave(): Boolean updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	pxyMovementPath	: HMS_MovementPath;
	tmpPathSegment 	: HMS_PathSegment;
	fromHarbourRegion,
	toHarbourRegion : HMS_HarbourRegion;
	theForm : SOP_HMS_TableMaintForm;
	fieldRoute : CMUI_FieldFrame;
	
begin
  	theForm := self.myForm.SOP_HMS_TableMaintForm; 
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as HMS_MovementPath transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	pxyMovementPath := theForm.myProxyObject.HMS_MovementPath;
	theForm.tblInput1.setObjectFromTable(pxyMovementPath,null,false);
	
	pxyMovementPath.allPathSegments.clear();
	theForm.getSelected(pxyMovementPath.allPathSegments);
	pxyMovementPath.allPathSegments.removeInvalidObjects();		// cnwdad1 23/03/2007 - the last entry may be null because of how the maintenance form works.
		
	//
		
	/*if theForm.shtPathSegments.visible = true then
		pxyMovementPath.allPathSegments.clear();
		foreach fieldRoute in self.allRouteSegmentCtrls do
			if fieldRoute.visible and fieldRoute.getObject() &lt;&gt; null then
				pxyMovementPath.allPathSegments.add (fieldRoute.getObject().HMS_PathSegment);
			endif;
		endforeach;

	else
		pxyMovementPath.allPathSegments.clear();
		theForm.mulSelect1.getSelected(pxyMovementPath.allPathSegments);
		theForm.getSelected(pxyMovementPath.allPathSegments);
	endif;*/
	
	tmpPathSegment := pxyMovementPath.allPathSegments.last;
	
	if pxyMovementPath.allPathSegments.first &lt;&gt; null then
		fromHarbourRegion	:= pxyMovementPath.allPathSegments.first.myRegionFrom;
	endif;
	if tmpPathSegment &lt;&gt; null then
		toHarbourRegion		:= pxyMovementPath.allPathSegments.last.myRegionTo;
	endif;
	
	if tmpPathSegment = null then
		pxyMovementPath.setProxy(app.myRoot, fromHarbourRegion, null);
//		pxyMovementPath.setProxy(app.myRoot, theForm.cmbRegionSource.listObject.HMS_HarbourRegion, null);
	else
		pxyMovementPath.setProxy(app.myRoot, fromHarbourRegion, toHarbourRegion);
//		pxyMovementPath.setProxy(app.myRoot, theForm.cmbRegionSource.listObject.HMS_HarbourRegion, tmpPathSegment.myRegionTo);
	endif;

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateHMSObject(pxyMovementPath, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateHMSObject(pxyMovementPath, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="8d31dbf0-72fe-4cd2-9d89-f0ca028f0e89">
