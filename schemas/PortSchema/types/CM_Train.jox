    <JadeMethod name="isWorking" id="541e083b-b46c-4b2b-9560-e74f5f0b6a50">
        <source>isWorking(_inwards : Boolean) : Boolean;
/*
Purpose:			

Date		Who		Reason
10 December 2021	navab1	TFS 51853
### TFS 52914 02MAR2022 NAVAB1 changed to use WLEs, the train's job sheet has no jobs

*/

vars
	job : CM_Job;
	hasWorked, hasNonWorked : Boolean;
	wagon : CM_Wagon;
	wle : CM_WorkListEntry;
	wagonarray : CM_WagonArray;
begin

	if _inwards then
		wagonarray := self.allWagonsByOrderInward;
	else
		wagonarray := self.allWagonsByOrderOutward;

	endif;

	foreach wagon in wagonarray discreteLock do
		foreach job in wagon.allRailJobs discreteLock do
			foreach wle in job.workListEntries discreteLock do
				if wle.status = WLE_UNACTIONED then
					hasNonWorked := true;
				elseif wle.status = WLE_PART_COMPLETE
				or wle.status = WLE_COMPLETED then
					hasWorked := true;
				endif;
			endforeach;
		endforeach;
	endforeach;

	

	return (hasNonWorked and hasWorked);
epilog

end;</source>
        <Parameter name="_inwards" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
