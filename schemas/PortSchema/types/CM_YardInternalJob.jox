    <JadeMethod name="setRequest" id="6dd9fba3-2094-4300-b711-5433eec6d453">
        <updating/>
        <source>setRequest(transRequest : CM_YardDeliveryRequest) updating;
//Passed a transient request, we create/set its properties as appropriate.
vars
	aReq : CM_YardDeliveryRequest;
	reqst : CM_Request;
begin
	reserveLock(self);
	reqst := self.allRequests.first;
	if reqst = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No request object ref');
		return;
	endif;
	aReq := reqst.CM_YardDeliveryRequest;
	//----------------
	//Copy the details across to the request object
	//----------------
	aReq.copy(transRequest);

	aReq.testTargetLocation();
	//----------------
	//Create WLE's etc
	//----------------
	aReq.createWLEs();
end;</source>
        <Parameter name="transRequest" type="CM_YardDeliveryRequest"/>
