    <JadeMethod name="buildErrorArrayFromPassport" id="75ba91f9-c81e-4690-81e0-1395093a6c77">
        <source>buildErrorArrayFromPassport(_passport :CM_Passport; _errors :HugeStringArray input);
// ---------------------------------------------------------------------------
// Created:     
// Purpose:     ccms 1035 - Gate ticket printing (APM)
//				Convert persistent errors to arrays that can be passed to app.showErrorWarningDialogArray
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	error	:CM_Error;
begin
	foreach error in _passport.allErrors do
		_errors.add (error.text);
	endforeach;
end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_errors" type="HugeStringArray" usage="input"/>
    </JadeMethod>
