<Class name="CM_TaskComplete" id="db135540-5f01-4d9f-99c3-40cc2b81a2a8">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>
A general complete transaction for tasks that don't have a specific transaction to create.</text>
    <DbClassMap file="actTrans"/>
    <PrimAttribute name="todoTaskCode" id="eadf8309-51e2-4790-b9d6-9b2d29031807">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="todoTaskDesc" id="a33a0721-fb79-409e-aef8-cb4de92ad7d5">
        <length>61</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getCompletedTaskString" id="cd95beb5-5458-4bdf-a85d-9d2cf3613e82">
        <source>getCompletedTaskString(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
04 November 2014	cnwndl1	Initial creation	Par 35160
12 December 2023	navpw1	TFS: 58758 (60742) - Fixed the todo tasks completed message. It will now check to make sure the description does not already exist before adding it to the string

*/

vars

	str : String;

begin
	str := inheritMethod();
	
	if self.todoTaskDesc &lt;&gt; null and str.pos(self.todoTaskDesc, 1) &lt; 1 then
		str := app.getErrorString(Todo_Task_Completed) &amp; " " &amp; self.todoTaskDesc &amp; str;
	endif;
	
	return str;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="95ce04e3-31d9-4195-ad31-898baafa9a77">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
begin
	
	// 21/01/2011 cnwar2 #26795 don't do ETRow_Details here, to display resources used.
	
	if _attrName = ETRow_ToDoTaskComplete then
		return self.getCompletedTaskString();
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="c07dd0b8-fe7b-424e-8137-d03fb02c6300">
        <source>getEnquiryRow(): String;
//----------------------------------------------------------------
//	Created:	15 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	lDetail : String;
begin
	lDetail := inheritMethod();

	lDetail := lDetail &amp; app.getErrorString(TransType_97);

	lDetail := lDetail &amp; ": " &amp; self.todoTaskDesc;
	
	return lDetail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="fd42575f-e675-4437-be6c-55f2c751ba94">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;
//--------------------------------------------------
// Created:	31 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin

//	self.setToDoTask(_tiTransCntrl.myToDoTask);

	inheritMethod(_tiTransCntrl, _passport);
	
	self.setToDoTask(_tiTransCntrl.myToDoTask);	//06 May 2019	NDL	TFS 44248
	
end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setToDoTask" id="b724945b-bfc0-49e7-8dee-d4ae07d7a26e">
        <updating/>
        <source>setToDoTask(_toDoTask: CM_ToDoTask) updating, protected;
//----------------------------------------------------------------
//	Created:	15 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 15/10/21 	jlier1	TFS 51963
vars

	tdTask	: CM_ToDoTask;

begin

	tdTask := _toDoTask;
	
	if tdTask = null then
		self.todoTaskCode := null;
		self.todoTaskDesc := null;
	else
		self.todoTaskCode := tdTask.toDoTaskDescCode;
		self.todoTaskDesc := tdTask.toDoTaskDescDesc;
	endif;

	self.myToDoTask := tdTask;
	

epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_toDoTask" type="CM_ToDoTask"/>
    </JadeMethod>
    <JadeMethod name="validateCMIF_TITransCntrl" id="f00742fc-3701-4e52-bc09-9dd1ca724ef9">
        <source>validateCMIF_TITransCntrl(_tiTransCntrl: CMIF_TITransactionController): Boolean;
//--------------------------------------------------
// Created:	31 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	return inheritMethod(_tiTransCntrl);
	if _tiTransCntrl.myToDoTask = null and not self.isTaskCompleteDocAction then
	//	app.raiseCMException1(REQUIRED_FIELD, 'myToDoTask', null, null);
		app.raiseCMException(Input_required_field_myToDoTsk, null, null); // cnwdb2	PAR 35364
		return false;
	endif;

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
