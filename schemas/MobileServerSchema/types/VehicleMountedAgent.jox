    <JadeMethod name="comboBoxRTQueues" id="d83a1304-c153-4654-af90-e8b5884bc626">
        <updating/>
        <source>comboBoxRTQueues(_combo : ComboBox input;
				 _type : Integer) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
20 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	coll : CM_RadioTelemQueueByIdDict;
	queue : CM_RadioTelemetryQueue;
	idx, numEntries : Integer;
	str : String;
begin
	if _combo = null then
		return;
	endif;
	
	create coll transient;
	self.getAllQueuesForType(coll,_type);
	
	foreach queue in coll discreteLock do
		//epr par 25838 28/9/10
		if (queue.isKindOf(CM_VoyageQueue) and _type &lt;&gt; MACHINETYPE_IMV) then
			continue;
		endif;
		numEntries:=self.getNumberQueueEntries(queue);
		str:=queue.id &amp; "  ( " &amp; numEntries.String &amp; " )";
		idx :=_combo.addItem(str);
		_combo.itemObject[idx]:=queue;
	endforeach;

epilog
	delete coll;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
