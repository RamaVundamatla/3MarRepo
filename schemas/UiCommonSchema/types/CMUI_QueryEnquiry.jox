    <JadeMethod name="doTblDataContextMenu" id="71989416-6e0f-4071-b424-329eb2fdf5a6">
        <updating/>
        <source>doTblDataContextMenu(cntrl : Table input; conwin : Window input; mouse : Boolean; x : Integer; y : Integer) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     23 October 2003	cnwth2
//
// Purpose:     
//			 
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
vars
	xLeft 	: Real;
	yTop	: Real;
	
begin
	xLeft := x;
	yTop := y;
	
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);
	
	if app.isAllowedToInspect then
		self.mnuInspectObject.visible := true;
//		self.mnuContextCompare.visible := true;
	else
		self.mnuInspectObject.visible := false;	
//		self.mnuContextCompare.visible := false;
	endif;	   
	
	// cnwrl1 16/02/2009 - (CCMS SFW 1047 - Totals Only Lists)
	self.mnuSummarise.visible	:= false;	// default this menu level to invisible, makes sub-menu invisible.
	
	self.popupMenu(mnuContextTable, xLeft.Integer, yTop.Integer);
	
	return false;
	
end;</source>
