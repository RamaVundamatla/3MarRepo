    <JadeMethod name="setupControlsOptions" id="1f4c2c17-9edc-4b2c-9f97-0788c56ee634">
        <updating/>
        <source>setupControlsOptions() updating, protected;
// --------------------------------------------------------------------------------
// Created:		02 March 2005 by cnwdad1
//
// Purpose:		Sets up the receiver's child controls for the Options tab.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 06/03/2006	cnwdad1		Changed to check whether we're in the Painter or not
//							before dereferencing stuff on App.
//
// 09/03/2006	cnwdad1		PAR #11358 - Changed the Priority Adjustment textbox to
//							have a maxLength of 8.
//
// 26/04/2006	cnwsh3		Changed the width and placement of controls to allow for
//							new font and layout changes of JMT
//							-Colour picker is now 125 to allow for line up
//							-Expiry Option is now 398 from 383 to align with controls
//							-Option button labels have been increased in width
//							to allow for wider font.
//
// 31/10/2008	consw1		SFW1030 - Rework of Yard Allocations
// 31 Oct 2022  navvt20 	Bug 55149: MTN - Yard Allocation Form Editing
// --------------------------------------------------------------------------------
vars
	terminal : CM_Terminal;
	
begin
	create self.myShtOptions transient;
	self.myShtOptions.caption				:=	"Options";
	self.myShtOptions.parent				:=	self.myFolder;
	self.myShtOptions.parentAspect			:=	Control.ParentAspect_StretchBoth;
	self.form.addControl(self.myShtOptions);
	
	create self.myGrpOptions transient;
	self.myGrpOptions.caption				:=	"Expiry Type";
	self.myGrpOptions.parent				:=	self.myShtOptions;
	self.myGrpOptions.parentAspect			:=	Control.ParentAspect_None;
	self.form.addControl(self.myGrpOptions);
	self.myGrpOptions.move(5, 7, 398, 105);
	
	create self.myOptNever transient;
	self.myOptNever.caption					:=	"Never";
	self.myOptNever.value					:=	true;
	self.myOptNever.parent					:=	self.myGrpOptions;
	self.myOptNever.parentAspect			:=	Control.ParentAspect_None;
	self.myOptNever.setYAControl(self, false, false, false, true);
	self.form.addControl(self.myOptNever);
	self.myOptNever.move(130, 14, 110, 21);
	
	create self.myOptVoyageDepart transient;
	self.myOptVoyageDepart.caption			:=	"Voyage Departure";
	self.myOptVoyageDepart.parent			:=	self.myGrpOptions;
	self.myOptVoyageDepart.parentAspect		:=	Control.ParentAspect_None;
	self.myOptVoyageDepart.setYAControl(self, false, false, false, true);
	self.form.addControl(self.myOptVoyageDepart);
	self.myOptVoyageDepart.move(self.myOptNever.left, (self.myOptNever.top + self.myOptNever.height + 3), 125, 21);
	
	create self.myOptWhenEmpty transient;
	self.myOptWhenEmpty.caption				:=	"When Empty";
	self.myOptWhenEmpty.parent				:=	self.myGrpOptions;
	self.myOptWhenEmpty.parentAspect		:=	Control.ParentAspect_None;
	self.myOptWhenEmpty.setYAControl(self, false, false, false, true);
	self.form.addControl(self.myOptWhenEmpty);
	self.myOptWhenEmpty.move(self.myOptNever.left, (self.myOptVoyageDepart.top + self.myOptVoyageDepart.height + 3), 110, 21);
	
	create self.myOptSpecifiedDate transient;
	self.myOptSpecifiedDate.caption			:=	"Specified Date";
	self.myOptSpecifiedDate.parent			:=	self.myGrpOptions;
	self.myOptSpecifiedDate.parentAspect	:=	Control.ParentAspect_None;
	self.myOptSpecifiedDate.setYAControl(self, false, false, true, false);
	self.form.addControl(self.myOptSpecifiedDate);
	self.myOptSpecifiedDate.move(self.myOptNever.left, (self.myOptWhenEmpty.top + self.myOptWhenEmpty.height + 3), 100, 21);
	
	create self.myTxtExpiryDate transient;
	self.myTxtExpiryDate.parent				:=	self.myGrpOptions;
	self.myTxtExpiryDate.parentAspect		:=	Control.ParentAspect_None;
	// Start 31 October 2022 navvt20 TFS 55149
	// self.myTxtExpiryDate.mask :=  app.getDateEditMaskForShortFormat;
	if not self.isInPainter then
		self.myTxtExpiryDate.mask :=  app.getDateEditMaskForShortFormat;
	endif;
	// End 31 October 2022 navvt20 TFS 55149
	self.form.addControl(self.myTxtExpiryDate);
	self.myTxtExpiryDate.move((self.myOptSpecifiedDate.left + self.myOptSpecifiedDate.width + 15), (self.myOptSpecifiedDate.top - 1), 80, 21);
	
	create self.myLblColor transient;
	self.myLblColor.caption					:=	"Colour";
	self.myLblColor.transparent				:=	true;
	self.myLblColor.alignment				:=	Label.Alignment_Left_Middle;
	self.myLblColor.parent					:=	self.myShtOptions;
	self.myLblColor.parentAspect			:=	Control.ParentAspect_None;
	self.form.addControl(self.myLblColor);
	self.myLblColor.move(5, (self.myGrpOptions.top + self.myGrpOptions.height + 5), 100, 21);
	
	create self.myLblColorPicker transient;
	self.myLblColorPicker.tabStop			:=	true;
	self.myLblColorPicker.parent			:=	self.myShtOptions;
	self.myLblColorPicker.transparent		:=	true;
	self.myLblColorPicker.tabStop			:=	true;
	self.myLblColorPicker.parentAspect		:=	Control.ParentAspect_None;
	self.myLblColorPicker.transparent		:=	false;
	self.myLblColorPicker.setColor(self.getSystemColor(Window.Color_3DFace));
	self.form.addControl(self.myLblColorPicker);
	self.myLblColorPicker.move(125, self.myLblColor.top, 42, 21);
	
	create self.myLblClickToSelect transient;
	self.myLblClickToSelect.caption			:=	"(click to select)";
	self.myLblClickToSelect.alignment		:=	Label.Alignment_Left_Middle;
	self.myLblClickToSelect.transparent		:=	true;
	self.myLblClickToSelect.parent			:=	self.myShtOptions;
	self.myLblClickToSelect.parentAspect	:=	Control.ParentAspect_None;
	self.form.addControl(self.myLblClickToSelect);
	self.myLblClickToSelect.move((self.myLblColorPicker.left + self.myLblColorPicker.width + 4), self.myLblColorPicker.top, 87, 21);
	
	create self.myLblAllowOthers transient;
	self.myLblAllowOthers.caption			:=	"Allow Others";
	self.myLblAllowOthers.transparent		:=	true;
	self.myLblAllowOthers.alignment			:=	Label.Alignment_Left_Middle;
	self.myLblAllowOthers.parent			:=	self.myShtOptions;
	self.myLblAllowOthers.parentAspect		:=	Control.ParentAspect_None;
	self.form.addControl(self.myLblAllowOthers);
	self.myLblAllowOthers.move(5, (myLblColor.top + self.myLblColor.height + 5), 100, 21);
	
	create self.myCmbAllowOthers transient;
	self.myCmbAllowOthers.parent			:=	self.myShtOptions;
	self.myCmbAllowOthers.parentAspect		:=	Control.ParentAspect_None;
	self.form.addControl(self.myCmbAllowOthers);
	self.myCmbAllowOthers.move(self.myLblColorPicker.left, self.myLblAllowOthers.top, 278, 21);
	
	create self.myLblNoLocation transient;
	self.myLblNoLocation.caption			:=	"If No Location Found";
	self.myLblNoLocation.transparent		:=	true;
	self.myLblNoLocation.alignment			:=	Label.Alignment_Left_Middle;
	self.myLblNoLocation.parent				:=	self.myShtOptions;
	self.myLblNoLocation.parentAspect		:=	Control.ParentAspect_None;
	self.form.addControl(self.myLblNoLocation);
	self.myLblNoLocation.move(5, (myLblAllowOthers.top + self.myLblAllowOthers.height + 5), 120, 21);
	
	create self.myCmbNoLocation transient;
	self.myCmbNoLocation.parent				:=	self.myShtOptions;
	self.myCmbNoLocation.parentAspect		:=	Control.ParentAspect_None;
	self.form.addControl(self.myCmbNoLocation);
	self.myCmbNoLocation.move(self.myLblColorPicker.left, self.myLblNoLocation.top, 278, 21);
	
	// CCMS 1357
	
	create self.myLblOverstowRule transient;
	self.myLblOverstowRule.caption			:=	"Overstow Rule";
	self.myLblOverstowRule.transparent		:=	true;
	self.myLblOverstowRule.alignment			:=	Label.Alignment_Left_Middle;
	self.myLblOverstowRule.parent				:=	self.myShtOptions;
	self.myLblOverstowRule.parentAspect		:=	Control.ParentAspect_None;
	self.form.addControl(self.myLblOverstowRule);
	self.myLblOverstowRule.move(5, (myLblNoLocation.top + self.myLblNoLocation.height + 5), 100, 21);
	
	create self.myCmbOverstowRule transient;
	self.myCmbOverstowRule.sorted := false;
	self.myCmbOverstowRule.parent				:=	self.myShtOptions;
	self.myCmbOverstowRule.parentAspect		:=	Control.ParentAspect_None;
	self.form.addControl(self.myCmbOverstowRule);
	self.myCmbOverstowRule.move(self.myLblColorPicker.left, self.myLblOverstowRule.top, 278, 21);
	/*
	if not self.isInPainter() then
		terminal := app.getMyTerminal();
		
		if not terminal.getConfig(AutoPlanUseOverstowRules).Boolean or not app.getMyUser().canDo(terminal, PmYAOverstowRules) then
			self.myCmbOverstowRule.enabled := false;
		endif;
	endif;*/
	
	create self.myLblPriorityAdj transient;
	self.myLblPriorityAdj.caption			:=	"Priority Adjustment";
	self.myLblPriorityAdj.transparent		:=	true;
	self.myLblPriorityAdj.alignment			:=	Label.Alignment_Left_Middle;
	self.myLblPriorityAdj.parent			:=	self.myShtOptions;
	self.myLblPriorityAdj.parentAspect		:=	Control.ParentAspect_None;
	self.form.addControl(self.myLblPriorityAdj);
	self.myLblPriorityAdj.move(5, (self.myLblOverstowRule.top + self.myLblOverstowRule.height + 5), 110, 21);
	
	create self.myTxtPriorityAdj transient;
	self.myTxtPriorityAdj.scrollHorizontal	:=	true;
	self.myTxtPriorityAdj.dataType			:=	TextBox.DataType_Numeric;
	self.myTxtPriorityAdj.maxLength			:=	8;
	self.myTxtPriorityAdj.parent			:=	self.myShtOptions;
	self.myTxtPriorityAdj.parentAspect		:=	Control.ParentAspect_None;
	self.form.addControl(self.myTxtPriorityAdj);
	self.myTxtPriorityAdj.move(self.myLblColorPicker.left, self.myLblPriorityAdj.top, 100, 21);
	
	create self.myChkTestOverstowWeight transient;
	self.myChkTestOverstowWeight.caption		:=	"Test Overstow Weight";
	self.myChkTestOverstowWeight.transparent	:=	true;
	self.myChkTestOverstowWeight.alignment		:=	CheckBox.Alignment_Left;
	self.myChkTestOverstowWeight.parent			:=	self.myShtOptions;
	self.myChkTestOverstowWeight.parentAspect	:=	Control.ParentAspect_None;
	self.form.addControl(self.myChkTestOverstowWeight);
	self.myChkTestOverstowWeight.move(self.myLblColorPicker.left, (self.myLblPriorityAdj.top + self.myLblPriorityAdj.height + 5), 150, 21);
	
	create self.myChkIsDisabled transient;
	self.myChkIsDisabled.caption		:=	"Disable this Allocation";
	self.myChkIsDisabled.transparent	:=	true;
	self.myChkIsDisabled.alignment		:=	CheckBox.Alignment_Left;
	self.myChkIsDisabled.parent			:=	self.myShtOptions;
	self.myChkIsDisabled.parentAspect	:=	Control.ParentAspect_None;
	self.form.addControl(self.myChkIsDisabled);
	self.myChkIsDisabled.move(self.myLblColorPicker.left, (self.myChkTestOverstowWeight.top + self.myChkTestOverstowWeight.height + 5), 150, 21);
	
	if not self.isInPainter() then
		terminal := app.getMyTerminalDO_NOT_USE();
		self.myChkTestOverstowWeight.enabled := false;
		self.myCmbOverstowRule.enabled := false;
	
		if terminal.isAutoPlanUseOverstowRules() then
			self.myCmbOverstowRule.enabled := true;
		else
			
			self.myChkTestOverstowWeight.enabled := true;
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <ExternalMethod name="showPopupMenu" id="54ef9ec3-b5cf-49b0-84bc-628ad27f0961">
