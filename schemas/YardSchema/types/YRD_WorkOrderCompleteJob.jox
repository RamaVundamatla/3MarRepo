    <JadeMethod name="buildCmbTerminalArea" id="318b25ae-dbc3-45b6-b9e4-76ebf7cde69b">
        <source>buildCmbTerminalArea();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Feb 2024 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
27 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/

vars
	cmb : CMUI_ComboBox;
	ta	: CM_TerminalArea;
	idx	: Integer;
begin
	cmb := self.cmbTerminalArea;
	cmb.clear();
	
	foreach ta in self.myTerminal.allTerminalAreas discreteLock do		//27.03.2025 navhl20 #34493
		idx := self.cmbTerminalArea.addItem(ta.id);
		cmb.itemObject[idx] := ta;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbVoyLocation" id="562e0d8d-867c-4dcd-92a6-4a1a2effa0f2">
        <source>buildCmbVoyLocation();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Mar 2024 navhl20 ChangeRequest 62734: EUP | Ship Operations in DD - [54176.060] - [Release] Retrospective Operations
27 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/

vars
	cmb 		: CMUI_ComboBox;
	lc,
	holdLc		: CM_LocationsController;
	lcSet 		: CM_LCSet;
begin
	cmb := self.cmbVoyLocation;
	cmb.clear();
	
	create lcSet transient;
	self.myJob.CM_VoyageWorkPointJob.myVoyage.getHolds(lcSet);
	
	foreach lc in lcSet discreteLock do				//27.03.2025 navhl20 #34493
		cmb.addItemObject(lc.getFullId(), lc);
	endforeach;
	
	holdLc := self.myJob.CM_VoyageWorkPointJob.allRequests.first.CM_HoldRequest.myHoldControllerLoad;
	if holdLc &lt;&gt; null then
		cmb.setIndexFromObject(holdLc);
	endif;
epilog
	delete lcSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildcmbSubArea" id="0e0936b0-0b52-4b36-a9bf-70988570d761">
        <source>buildcmbSubArea(_ta : CM_TerminalArea);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Feb 2024 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
27 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/

vars
	lc 		: CM_LocationsController;
	obj 	: CM_Object;
	tmpTA 	: CM_TerminalArea;
	row 	: CM_GridRow;
	col 	: CM_GridColumn;
	rc  	: CM_RoRoController;
	cmb		: CMUI_ComboBox;
begin
	cmb	:= self.cmbSubArea;
	cmb.clear();
	
	if _ta &lt;&gt; null then
		tmpTA := _ta;
	
		if not tmpTA.isGridArea then
			if not tmpTA.isIrregularBlockArea() and not tmpTA.type = TA_TYPE_RORO_LANE_AREA
			and not tmpTA.isGeneralCargoAllocArea then
				return;
			endif;
		endif;
		
		if tmpTA.isIrregularBlockArea() then
			foreach lc in tmpTA.CM_IrregularBlockArea.allLocationsControllers discreteLock do
				cmb.addItemObject(tmpTA.id &amp; " - " &amp; lc.ident, lc);
			endforeach;
		elseif tmpTA.type = TA_TYPE_FORK_LIFT_STACK then
			foreach col in tmpTA.CM_GridArea.allGridColumns discreteLock do
				cmb.addItemObject(tmpTA.id &amp; " - " &amp; col.label , col);
			endforeach;
		elseif tmpTA.type = TA_TYPE_RORO_LANE_AREA then
			foreach rc in tmpTA.CM_RoRoLaneArea.allLanesById discreteLock do
				cmb.addItemObject(tmpTA.id &amp; " - " &amp; rc.ident , rc);
			endforeach;
		elseif tmpTA.isGeneralCargoAllocArea then
			foreach lc in tmpTA.CM_GeneralCargoAllocRowArea.allRowControllersById discreteLock do	//27.03.2025 navhl20 #34493
				cmb.addItemObject(tmpTA.id &amp; " - " &amp; lc.ident, lc);
			endforeach;
		else
			foreach row in tmpTA.CM_GridArea.allGridRows discreteLock do
				cmb.addItemObject(tmpTA.id &amp; " - " &amp; row.label, row);
			endforeach;
		endif;
	endif;
	
	if cmb.listCount() = 1 then
		cmb.listIndex := 1;
	endif;
epilog

end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="chkCargoGrouping_click" id="0a98a4b4-a685-439b-b549-a7cf40f045a5">
        <controlMethod name="CMUI_CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkCargoGrouping_click(checkbox: CheckBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Jul 2024 navbs1 ChangeRequest 64884: EUP - Retrospective Jobs Grouped by Cargo Group
22 Aug 2024 navbs1 Bug 65723: EUP - In complete job form clicking on cargo grouping loading two table data
04 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/

vars

begin
	self.btnExpandAll.visible	:=self.isCargoGrouping;
	self.btnCollapseAll.visible	:=self.isCargoGrouping;
	self.loadTblAvail();
	if not self.chkHideCompleted.value then			//22.08.2024 navbs1 #65723
		self.loadTblCompleted();		
	endif;
epilog

end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="chkHideCompleted_click" id="aaedf376-6310-4a4d-9a4d-346b0491c32c">
        <controlMethod name="CMUI_CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkHideCompleted_click(checkbox: CheckBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Feb 2024 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
13 Feb 2024 navhl20 ChangeRequest 62418: EUP | Retrospective Operations - [54177.040] - Road Release
11 Mar 2024 navhl20 ChangeRequest 60097: EUP | Ship Operations in DD - [54176.060] - [Receive] Retrospective Operation
25 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
03 Apr 2024 navhl20 ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
13 May 2024 navhl20 Bug 64068: EUP - Ship job is not getting updated after discharging the cargo
29 May 2024 navhl20 Bug 64345: EUP - Retrospective Partial Discharge not wokring.
20 Aug 2024 navhl20	ChangeRequest 65650: FR | 54177 - Retrospective Operations - Packing
*/
constants
	GRP_HEIGHT = 246; // ### TFS CR 62818 TASK 62821 14MAR2024 NAVAB1
vars

begin
	if self.shtUnpack.visible then								//22.03.2024 navhl20 #62863
		if self.myJob.isKindOf(CM_WOPackJob) then
			//Setup for pack job
			if checkbox.value then
				self.grpPacked.visible := false;
				self.tblChild.parentAspect := 3;
				self.grpAvailChild.height := self.grpAvailChild.height + self.grpPacked.height + 5;
			else
				self.grpPacked.visible := true;
				self.tblChild.parentAspect := 1;
				self.grpAvailChild.height := self.grpPacked.top - self.grpAvailChild.top - 5;
				self.tblChild.height := self.grpAvailChild.height - 65;									//20.08.2024 navhl20 #65650
			endif;
		else
			//Setup for unpack job
			if checkbox.value then
				self.grpUnpacked.visible := false;
				self.tblChild.parentAspect := 3;
				self.grpAvailChild.height := self.grpAvailChild.height + self.grpUnpacked.height + 5;
				self.grpToLocation.top := self.grpAvailChild.height + self.grpAvailChild.top + 5;
			else
				self.grpUnpacked.visible := true;
				self.tblChild.parentAspect := 1;
				self.grpToLocation.top := self.grpUnpacked.top - self.grpToLocation.height - 5;
				self.grpAvailChild.height := self.grpToLocation.top - self.grpAvailChild.top - 5;
				self.tblChild.height := self.grpAvailChild.height - 65;									//20.08.2024 navhl20 #65650
			endif;
		endif;
	elseif not self.myJob.isRelease then
		//Setup for receive job
		if checkbox.value then
			self.grpCompleted.visible := false;
			self.grpAvail.height := self.grpAvail.height + self.grpCompleted.height + 5;
			self.grpAvail.parentAspect := 3;															//03.04.2024 navhl20 #63302
		else
			self.grpCompleted.visible := true;
			self.grpAvail.height := GRP_HEIGHT;
			self.grpAvail.parentAspect := 1;															//03.04.2024 navhl20 #63302
			self.loadTblCompleted();
			self.setTblDataCount();																		//29.05.2024 navhl20 #64345
		endif;
		self.grpLocation.top := self.grpAvail.height + self.grpAvail.top + 5;
	else
		//Setup for release job
		if checkbox.value then
			self.grpCompleted.visible := false;
			if self.grpLocation.visible then
				self.grpAvail.height := GRP_HEIGHT + self.grpCompleted.height - 13;
			else
				self.grpAvail.height := GRP_HEIGHT + self.grpLocation.height + self.grpCompleted.height + 10;
			endif;
			self.grpAvail.parentAspect := 3;
		else
			self.grpCompleted.visible := true;
			if self.grpLocation.visible then
				self.grpAvail.height := GRP_HEIGHT;
			else
				self.grpAvail.height := GRP_HEIGHT + self.grpLocation.height + 5;
			endif;
			self.grpAvail.parentAspect := 1;
			self.loadTblCompleted();
			self.setTblDataCount();																		//29.05.2024 navhl20 #64345
		endif;
		self.grpLocation.top := self.grpAvail.height + self.grpAvail.top + 5;
		if app.isSpecial and not self.myJob.isRelByType then
			self.grpLocation.height := 80;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
