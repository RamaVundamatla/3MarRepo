*/

vars
begin
	inheritMethod();

	self.setupCmdButtons(2, 'Ok',app.getErrorString(Cancel), null, null, null );

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="ba04e562-684f-49dd-b38a-1ffe4589ac46">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:48:20.
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019366, locale);
	btnCargo1.translateCaption(Xlat_0023404, locale);
	btnCargo2.translateCaption(Xlat_0019368, locale);
	lSwapTitle.translateCaption(Xlat_0019369, locale);
	lSwapWithTruck.translateCaption(Xlat_0019370, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
