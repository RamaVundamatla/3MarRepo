    <JadeMethod name="addTempReading" id="998a5240-285d-4e09-a6b2-c3c51f333905">
        <source>addTempReading(_ti : CM_TrackedItem; _temperature : Real; _noCharge : Boolean);

/*

Purpose:		Add reefer temperature reading	

Date			Who		Reason
19/11/2015		cnwmh5	Initial creation
27/09/2021		navdap1	TFS 52081 MTN Cannot Add Reading for a Reefer for a time other than Now
16/01/2026		navdap1	MTN-36569 CPL | Reefer Runner Integration
*/

vars

	tempReadingParams			: CMIF_TempReading;
	tempParams					: CMIF_TempReading;					
	humidReadingParams			: CMIF_HumidReading;				
	humidParams					: CMIF_HumidReading;				
	ventReadingParams			: CMIF_VentReading;					
	ventParams					: CMIF_VentReading;		
	proxyTI						: CM_TrackedItem;
//	terminal					: CM_Terminal;
	
//	timeStamp					: TimeStamp;

begin

//	timeStamp := app.cnGetServerTime();
//	terminal := self.getTerminal();
//	self.assertNotNull(terminal);

	//set these once	
	create tempReadingParams transient;
/*	tempReadingParams.isRefConReading := false;
	tempReadingParams.isRefConAlarm := false;
	tempReadingParams.refConRawData := null;
	tempReadingParams.dateTime := timeStamp;
	tempReadingParams.noCharge := _noCharge;
	tempReadingParams.userId := app.getMyUserCode();
	tempReadingParams.myTerminal := terminal; */
	
	/*
	create humidReadingParams transient;							
	humidReadingParams.dateTime := timeStamp;						
	humidReadingParams.noCharge := _noCharge;			
	humidReadingParams.userId := app.getMyUserCode();				
	humidReadingParams.myTerminal := terminal;				
	*/
	
	/*
	create ventReadingParams transient;								
	ventReadingParams.dateTime := timeStamp;							
	ventReadingParams.noCharge := _noCharge;			
	ventReadingParams.userId := app.getMyUserCode();				
	ventReadingParams.myTerminal := terminal;	
	*/
	
	beginLoad;
	proxyTI := _ti.pxyCreateUpdateProxy();
	endLoad;
	
/*	tempReadingParams.myTrackedItem := proxyTI;
	tempReadingParams.noCharge := _ti.noChargeForTemperature(_noCharge, timeStamp);
	
	tempReadingParams.temperature := _temperature; */
	tempParams := tempReadingParams;
	
	//01 Sep 2021	NDL	TFS 51874 - Use common code instead of 14 different variant copies....
	tempReadingParams.initialise( 	proxyTI,	//_reefer : CM_TrackedItem;
									_noCharge,	//_defaultNoChargeValue : Boolean;
									app.actualTimeServer,	//_dateTime : TimeStamp;		// TFS 52081
									_temperature	//_temperature : Real
									);
	
	//humidReadingParams.myTrackedItem := proxyTI;
	//humidParams := humidReadingParams;
	
	//ventReadingParams.myTrackedItem := proxyTI;
	//ventParams := ventReadingParams;
	
	app.myTrxCA.trxCreateReeferReadings(tempParams, humidParams, ventParams, null, null, null, app.myPassport);		// MTN-36569
	self.assertNoTrxErrorsOrWarnings();

epilog

	delete tempReadingParams;
	delete humidReadingParams;
	delete ventReadingParams;
	delete proxyTI;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_temperature" type="Real"/>
        <Parameter name="_noCharge" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addTemperatureConversion" id="820bb072-4e08-4d80-8796-99d5041d63d8">
        <source>addTemperatureConversion(_celsius, _fahrenheit : Real) : CM_TemperatureConversion;

vars

	pxyTempConversion				: CM_TemperatureConversion;
	tempConversion					: CM_TemperatureConversion;

begin

	self.deleteTemperatureConversion(_celsius);
	
	create pxyTempConversion transient;
