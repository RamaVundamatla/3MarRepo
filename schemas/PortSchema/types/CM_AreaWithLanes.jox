    <PrimAttribute name="laneCount" id="3e87d548-a62b-4b9f-97cf-d23bbf2827fb">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
        <text>This is the number of lanes from the user point of view.

For example a gate area could have no lanes but we will create
default in/out lanes just so we have locations to move vehicles to as they move
through gate areas.</text>
    </PrimAttribute>
    <ExplicitInverseRef name="myInTransitToLocation" id="1dc1deb9-7420-432a-80ab-850e699f5561">
