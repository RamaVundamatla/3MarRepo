<Class name="CM_InvoiceProcessLinx" id="cee9f343-f51a-464c-b9fc-c5cd678d6978">
    <superclass name="CM_InvoiceProcess"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>TFS 39618</text>
    <DbClassMap file="invoice"/>
    <JadeMethod name="getNextValidStatuses" id="b883cd67-e62f-432c-86a3-6a4729c332cd">
        <source>getNextValidStatuses(_invoice: CM_Invoice; _nextStatuses: CM_InvoiceStatusByPriority input; _includeAll: Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Oct 2018	jlgsl4	TFS 39618 - LNX - Initial creation
*/

vars
	currentStatus 	: Integer;
begin
	if _includeAll then
		self.allStatuses.copy(_nextStatuses);
		return;
	endif;
	
	/* // 26/01/2023	navkc1	TFS CR 55305 TASK 55537
	currentStatus := _invoice.status;
	
	if currentStatus = CM_Invoice.INVOICE_OPEN then
		_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_PENDING_APPROVAL]); // TFS 39618 PATCH 1 use Pending Approval
		_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_VOID]);
	elseif currentStatus = CM_Invoice.INVOICE_PENDING_APPROVAL then // TFS 39618 PATCH 1 
		_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_APPROVED]);
		_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_VOID]);		
	elseif currentStatus = CM_Invoice.INVOICE_APPROVED then // if invoice needs to be returned
		if _invoice.previousStatus = CM_Invoice.INVOICE_POSTED then // it's been posted already
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_POSTED_CREDIT]);
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_POSTED_REVERSE]);			
		else
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_POSTED]);
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_VOID]);
		endif;
	elseif currentStatus = CM_Invoice.INVOICE_POSTED then
		_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_APPROVEDRETURNED]);
	elseif currentStatus = CM_Invoice.INVOICE_APPROVEDRETURNED then // TFS 39618 PATCH 1 
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_POSTED_REVERSE]);		 // TFS 39618 PATCH 1 	
	elseif currentStatus = CM_Invoice.INVOICE_VOID then // TFS 39618 PATCH 1
		_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_PENDING]); // TFS 39618 PATCH 1
	endif;
	*/
	self.getStatuses(_nextStatuses, _invoice.status, _invoice.previousStatus, _invoice.bank); // 26/01/2023	navkc1	TFS CR 55305 TASK 55537
	
epilog

end;</source>
        <text>TFS 39618</text>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_nextStatuses" type="CM_InvoiceStatusByPriority" usage="input"/>
        <Parameter name="_includeAll" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getStatuses" id="baa6b8f4-df21-45d2-b0a0-380527199f33">
        <source>getStatuses(_nextStatuses: CM_InvoiceStatusByPriority input; _status: Integer; _prevStatus : Integer; _bank : CM_Bank);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 January 2023	navkc1	Initial creation TFS CR 55305 TASK 55537

*/

vars

begin
	
	
	if _status = CM_Invoice.INVOICE_OPEN then
		_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_PENDING_APPROVAL]); // TFS 39618 PATCH 1 use Pending Approval
		_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_VOID]);
	elseif _status = CM_Invoice.INVOICE_PENDING_APPROVAL then // TFS 39618 PATCH 1 
		_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_POSTED_DRAFT]);  // ### JIRA 35465 28JUL2025 NAVAB1
		_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_APPROVED]);
		_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_VOID]);		
	 // ### JIRA 35465 28JUL2025 NAVAB1
	elseif _status = CM_Invoice.INVOICE_POSTED_DRAFT then 
		_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_APPROVED]);
		_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_VOID]);		
	elseif _status = CM_Invoice.INVOICE_APPROVED then // if invoice needs to be returned
		if _prevStatus = CM_Invoice.INVOICE_POSTED then // it's been posted already
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_POSTED_CREDIT]);
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_POSTED_REVERSE]);			
		else
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_POSTED]);
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_VOID]);
		endif;
	elseif _status = CM_Invoice.INVOICE_POSTED then
		_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_APPROVEDRETURNED]);
	elseif _status = CM_Invoice.INVOICE_APPROVEDRETURNED then // TFS 39618 PATCH 1 
			_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_POSTED_REVERSE]);		 // TFS 39618 PATCH 1 	
	elseif _status = CM_Invoice.INVOICE_VOID then // TFS 39618 PATCH 1
		_nextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_PENDING]); // TFS 39618 PATCH 1
	endif;
	

epilog

end;</source>
        <Parameter name="_nextStatuses" type="CM_InvoiceStatusByPriority" usage="input"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_prevStatus" type="Integer"/>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
