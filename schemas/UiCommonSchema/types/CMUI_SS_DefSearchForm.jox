    <JadeMethod name="doCharge" id="f871d85a-3f73-46b2-8052-7f564ded2c81">
        <updating/>
        <source>doCharge() updating;
// CCMS 1043
vars
	theReturn	: Integer;
	savedDate	: TimeStamp;
	snapshotData	: CM_SnapshotData;
	map	: CM_TranMapSSSummary;
	ssb	: CM_SnapShotServiceBroker;
	ofss : CM_OutputFormat_SS;
	invalid : Boolean;
begin

	on Exception do app.handleDeletedObject(exception, snapshotData.myOutputFormat_SS.myBankToCharge, invalid); 

	snapshotData := self.tblData.accessRow(self.tblData.row).itemObject.CM_SnapshotData;

	if snapshotData.myOutputFormat_SS &lt;&gt; null then
		if  snapshotData.myOutputFormat_SS.myBankToCharge = null then
			app.msgBox("Snapshot definition has no snap shot transaction map defined", app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
			return;
		endif;
		map := snapshotData.myOutputFormat_SS.myBankToCharge.myCurrentTranMapSnapShot;
	endif;
	if map = null then
		app.msgBox("Snapshot definition has no snap shot transaction map defined", app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
		return;
	endif;
	
	ssb := map.allSnapShotServiceBrokers[snapshotData.myOutputFormat_SS];
	if ssb = null then
		app.msgBox("A Snapshot Summary transaction map for this definition needs to set Active first", app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
		return;
	endif;

	theReturn := app.msgBox("This will produce snapshot invoice lines from the selector snapshot summary data." &amp; CrLf &amp; "Do you want to continue?", 
			   "Snapshot Summary Invoicing Run", MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second);
	if theReturn = MsgBox_Return_No then
		return;
	endif;

	savedDate := app.actualTimeServer;
	while true do
		app.myTrxUA.trxUpdateSnapshotCharge(ssb, snapshotData, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			global.beep;
			self.showInvoicingResult(snapshotData, savedDate);
			break;
		else
			theReturn := app.showErrorWarningDialog("Snapshot Invoicing", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doCreateDailyData" id="d115608d-1f14-4a64-b1ad-b8de96100028">
        <updating/>
        <source>doCreateDailyData() : Boolean updating;

/*

Purpose:			Create the daily snapshot data for the given date range,
					with confirmation and cancellable status display.

Parameters:			

Return Value:		


Date		Who		Reason
21 February 2013	cnwjre1	Initial creation

*/

vars
	fromDate	: Date;
	toDate		: Date;
	partsInJob,
	partsDone	: Integer;
	monitor		: CMIF_Monitor;
	agent		: CM_OnsiteCargoAgent;
begin
	fromDate := self.mskDailyFrom.getDate();
	if not fromDate.isValid then
		app.msgBox(app.getErrorString(Date_from_incorrect), app.getErrorString(Error), MsgBox_OK_Only);
		self.mskDailyFrom.setFocus();
		return false;
	endif;
	
	toDate := self.mskDailyTo.getDate();
	if not toDate.isValid then
		app.msgBox(app.getErrorString(DateTo_incorrect), app.getErrorString(Error), MsgBox_OK_Only);
		self.mskDailyTo.setFocus();
		return false;
	endif;
	
	if toDate &lt; fromDate then
		app.msgBox(app.getErrorString(DateFromTo), app.getErrorString(Error), MsgBox_OK_Only);
		self.mskDailyFrom.setFocus();
		return false;
	endif;
	
	create monitor transient;
	monitor.myParent := self;
	app.myPassport.setMyCMIFMonitor(monitor);
	
	self.modalDialogReturnValue := self.ModalDialogReturn_Null;	
	self.modalDialogShow(null, 'Cancel' , null, null, 'Creating Daily Data',  'Please Wait....');
	self.pbProgressBar.visible := true;

	partsInJob :=  toDate - fromDate;
	monitor.partsInJob := partsInJob;
	create agent transient;
	agent.createSnapshotSummaryData(self.myTerminal, self.myDefinition, fromDate, toDate);
	
	return true;

epilog
	app.myPassport.setMyCMIFMonitor(null);
	delete monitor;
	self.frmModalDialog.visible := false;	
	delete agent;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCreateNewData" id="9aefe30c-354d-41f7-9d25-6a762cee13b9">
        <updating/>
        <source>doCreateNewData() : Boolean updating;
// CCMS 1043 par 21800 Oct 2010 cnwjre1 add option to create new snapshot data plus invoicing to handle
//  missed background runs.  A different selector can be chosen to get historical data.
vars
	selector	: CM_MenuUserQuery;
	dataDate	: Date;
	dataTime	: Time;
	runTime		: TimeStamp;
	bgp			: BGP_SummarySnapShot;
begin
	selector := self.cmbSelector.listObject.CM_MenuUserQuery;
	if selector = null then
		app.msgBox(app.getErrorString(Terminal_reference_set), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
		self.cmbSelector.setFocus();
		return false;
	endif;
	
	dataDate := self.mskSnapDate.getDate();
	if not dataDate.isValid then
		if app.msgBox(app.getErrorString(Specify_start_date), app.getErrorString(Warning), MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_No then
			self.mskSnapDate.setFocus();
			return false;
		endif;
	endif;
	dataTime := self.mskSnapTime.getTime();
	runTime.setDate(dataDate);
	runTime.setTime(dataTime);
	
	create bgp transient;
	bgp.initRequest(app.myPassport.myUser, self.myTerminal, self.myDefinition, selector);
	bgp.createData(runTime);

	return true;
epilog
	delete bgp;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDeleteDef" id="54a347c0-491e-4afe-98a2-a1f81c26ab8b">
        <updating/>
        <source>doDeleteDef() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars

	outputFormat_SS : CM_OutputFormat_SS;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	
	if cmbDefinition.listIndex &lt; 1 then
		return;
	endif;
	
	outputFormat_SS := cmbDefinition.listObject.CM_OutputFormat_SS;
	
	if outputFormat_SS = null then
		return;
	endif;
	
	// check if really want to delete it and make them select Yes.
	if not self.confirmDelete(	app.getErrorString( XTAB_SummaryDefinition ), outputFormat_SS.name.display ) then
		return;
	endif;
	
	self.deleting := true;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteOutputFormat_SS( outputFormat_SS, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;	
	
epilog
	self.deleting := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDeleteSnapShotData" id="f227215e-15ef-4ce8-bc57-8d90fc35397b">
        <source>doDeleteSnapShotData() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars

	size : Integer;
	startRow : Integer;
	row : Integer;
	snapshotData : CM_SnapshotData;
	result : Integer;
	
begin

	size := self.tblData.rows;
	startRow := self.tblData.fixedRows + 1;
	if size &lt; startRow then
		return;
	endif;
	
	if not self.confirmDelete(	app.getErrorString( Selected_snap_shot_data ), "( x" &amp; tblData.allSelectedObjects.size.String &amp; " )" ) then
		return;
	endif;
	
	foreach row in startRow to size reversed do
		snapshotData := tblData.accessRow(row).itemObject.CM_SnapshotData;
		if self.tblData.allSelectedObjects.includes(snapshotData) then
			
			while true do
				app.myTrxDA.trxDeleteSnapshotData(snapshotData,  app.myPassport);
				if app.myPassport.trxCompletedOK then
					break; //to main loop, i.e. get next object to delete
				endif;
				if not app.myPassport.trxCompletedOK then
					result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
				endif;
				if app.myPassport.hasWarnings and result = IDOK then
					// there must have just been warnings that the user has acknownledged so.
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				// it either had errors, or warnings that were no accepted by the user 
				app.myPassport.clearErrorsWarnings();
				break; //to main loop, i.e. get next object to delete
			endwhile;
				
		endif;
	endforeach;
	
epilog

	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDisplayXTAB" id="0a783f29-1f76-4abc-a872-e8cf8c67d851">
        <source>doDisplayXTAB() protected;
// ---------------------------------------------------------------------------
// Created:     09 December 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/07/2010	cnwcs5		ccms 1156 / par 23706 Show repeated row values
// ---------------------------------------------------------------------------
vars
	snapshot	:CM_OutputFormat_SS;
	agent		:CMIF_OutputFormatAgent_SS;
	format		:CM_OutputFormat_XTAB;
	coll		:CM_ObjectSet;
	form 		:CMUI_XTABDisplayForm;
	obj			:Object;
begin
	snapshot := cmbDefinition.listObject.CM_OutputFormat_SS;
	
	// create default xtab definition for selected snapshot
	create agent transient;
	format := agent.createXTABOutputFormat (snapshot, true);
	
	// create collection with selected snapshot data
	create coll transient;
	
	self.populateSnapshotCollection (coll);
	
	form := app.loadForm (CMUI_XTABDisplayForm, CMUI_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).CMUI_XTABDisplayForm;
	
	form.initialise (format, null, null, coll);
	
	form.show;
epilog
	delete coll;
	delete agent;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="33f2a190-5e24-4c45-88fa-a008e74a9cd8">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:		23 February 2010 cnwjo3
//
// Purpose:		par 21915.  Each form should implement doNotableClear without an inheritMethod();
//
vars
	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		/*if anObject.isKindOf(____OBJECT TYPE____) then
			endNotification(anObject, self.myTerminal.getTerminalEvent(____EVENT_NAME_____));
			removedNotification := removedNotification + 1;
		endif;*/
	endforeach;

	validateNotificationRemoval(removedNotification,self.allNotableObjects.size);
	
	self.allNotableObjects.clear;
end;</source>
