    <JadeMethod name="getDisplayStringForAttribute" id="26515558-3cce-4393-bbf1-9aabd8d674c2">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2013	cnwer1	Initial creation HAT 2189

*/

vars

begin
	
	if _attrName = ETRow_ImexStatus then
		return self.getImexString;
			
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getImexString" id="224c2cf8-ab7e-4d64-a738-0f2913cba068">
        <source>getImexString() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2013	cnwer1	Initial creation HAT 2189

*/

vars
	imexStatus			: CM_IMEXStatus;
begin
		imexStatus:=app.myRoot.allImexStatuses[self.imex];
		if imexStatus &lt;&gt; null then
			return imexStatus.description;
		endif;
		return null;
			
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="79ca3879-59e4-4bd9-ae51-910c09b93545">
        <updating/>
        <source>setForCreate(_proxyDutyDocType : CM_DutyDocType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	_proxyDutyDocType.raiseExceptionIfNotTransient(method);
	
	self.myDutyDocRoot := _proxyDutyDocType.myDutyDocRoot;
	self.setForUpdate(_proxyDutyDocType);
epilog

end;</source>
        <Parameter name="_proxyDutyDocType" type="CM_DutyDocType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="62a19e17-2067-469b-971e-1035c0fe2db5">
        <updating/>
        <source>setForUpdate(_proxyDutyDocType : CM_DutyDocType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.code			:= _proxyDutyDocType.code;
	self.description 	:= _proxyDutyDocType.description;
	self.dutyCharged 	:= _proxyDutyDocType.dutyCharged;
	self.imex:=_proxyDutyDocType.imex;
epilog

end;</source>
        <Parameter name="_proxyDutyDocType" type="CM_DutyDocType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="557b16a4-2acc-4226-b7b7-1035a2bf2b9b">
        <updating/>
        <source>setProxy(	_code,
			_description : String;
			_dutyCharged : Boolean;
			_imex 		: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.raiseExceptionIfNotTransient(method);

	self.code				:= _code[1:10];
	self.description 		:= _description[1:50];
	self.dutyCharged		:= _dutyCharged;
	self.myDutyDocRoot 		:= app.myDutyDocRoot;
	self.imex:=_imex;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_dutyCharged" type="Boolean"/>
        <Parameter name="_imex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="66c8ee0c-1bcf-4034-868c-8ac4f663a859">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	if app.myDutyDocRoot.allDutyDocTypes[self.code] &lt;&gt; null then 
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code.String, null, null);
		return;
	endif;
	
	validateMe();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="ec257928-9559-42ff-8dc1-c016fa36e2d1">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	validateMe();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="6fac1cd9-79e0-488f-afc3-2fadc699bfa7">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Code), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Code), null, null); // cnwdb2	PAR 35364
	endif;
epilog

end;</source>
    </JadeMethod>
</Class>
