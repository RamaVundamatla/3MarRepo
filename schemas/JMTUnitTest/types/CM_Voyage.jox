<Class name="CM_Voyage">
    <JadeMethod name="getNextQuickCargoID2" id="6c868345-693b-414b-a78e-cd9aae0dfc57">
        <source>getNextQuickCargoID2(_cargoType : CM_CargoType io; _useDuplicateID, _doGetNextID : Boolean; _nextNum : Integer io; _location : CM_LocationsController) : String;

/*

Purpose:		

Date			Who		Reason
03/11/2014		cnwmh5	Initial creation
						Replaces the GUI version as for unit tests able to 
						create ti's with different cargo types and looks
						really strange with multiple ti's of different
						cargo types with the same id

*/


// Original
vars
	tiOnship					: CM_TrackedItem;
	tiOnsiteShip				: CM_TrackedItem;
	tiOnSiteTerm				: CM_TrackedItem;
	lc							: CM_LocationsController;
	
	nextID						: String;
	numId 						: String;
	nextNum 					: Integer;
	tempStr						: String;
	locationID					: String;
	bayID						: String;
	
begin
	//nextNum := 1112221;
	if _nextNum = 0 then
		_nextNum := 1112221;
	endif;
	
	while true do
		nextID := "SHIP" &amp; _nextNum.String;
		
		tiOnship := self.allOnshipTIsByIdCargoType[nextID,_cargoType.id];
		tiOnsiteShip := self.allOnsiteTIsByIdCargoType[nextID, _cargoType.id];
		tiOnSiteTerm := self.myTerminal.allOnsiteTIsByIdCargoType[nextID, _cargoType.id];
		
		if tiOnship = null and tiOnsiteShip = null and tiOnSiteTerm = null then
			return nextID;
		else
			if self.myROROStructure = null then
				if (tiOnship &lt;&gt; null and tiOnship.myPrimaryActualLocation.CM_SlotController.getBayId(null) &lt;&gt; _location.CM_SlotController.getBayId(null)) or 
						(tiOnsiteShip &lt;&gt; null and tiOnsiteShip.myPrimaryActualLocation.CM_SlotController.getBayId(null) &lt;&gt; _location.CM_SlotController.getBayId(null)) then
					if _cargoType.allowDuplicates and _useDuplicateID and not _doGetNextID then
						_nextNum := _nextNum + 1;
						if tiOnship &lt;&gt; null then
							tempStr := tempStr &amp; Tab &amp; tiOnship.id;
						endif;
						if tiOnsiteShip &lt;&gt; null then
							tempStr := tempStr &amp; Tab &amp; tiOnsiteShip.id;
						endif;
						if tiOnSiteTerm &lt;&gt; null then
							tempStr := tempStr &amp; Tab &amp; tiOnSiteTerm.id;
						endif;
						write class.name &amp; "::::" &amp; method.name &amp; Tab &amp; tempStr &amp; Tab &amp; nextID &amp; Tab &amp; _cargoType.id.String &amp; Tab &amp; 
							_cargoType.description;
						return nextID;
					endif;
				endif;
			endif;
		endif;
		_nextNum := _nextNum + 1;
	endwhile;
	
	return nextID;
epilog

end;


