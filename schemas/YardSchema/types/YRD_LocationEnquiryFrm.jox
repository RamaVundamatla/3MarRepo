        <source>tblDataDragOverEvent(table: Table input; win: Window input; x: Real; y: Real; state: Integer) updating;
//--------------------------------------------------
// Created:	19 February 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(table, win, x, y, state);
	if app.myMoveController &lt;&gt; null then
		self.setFocus();
		self.zOrder(1);
		self.windowState := WindowState_Normal;
	endif;	
end;</source>
