07 July 2020	jlgndl1	Initial creation	TFS 49590

*/

vars

	esEventType : CM_EventStreamEventType;

begin

	foreach esEventType in self.allEventStreamEventTypes do
		if esEventType.myObject &lt;&gt; null and esEventType.myObject.isKindOf( CM_TransactionType ) then
			if esEventType.myObject.CM_TransactionType.trxGroup = TRANS_TYPE_GROUP_TI then	//07 Jul 2020	NDL	TFS 49590
