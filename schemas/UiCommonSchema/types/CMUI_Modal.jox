    <JadeMethod name="doCancel" id="10325d90-dcd4-418e-998e-42f7ba397c5b">
        <updating/>
        <source>doCancel() updating;

vars

begin

	self.modalResult := IDCANCEL;
	self.unloadForm();

end;</source>
