    <JadeMethod name="tblRequests_dblClick" id="4b5f4f76-7eef-4a02-a467-74b134e3a732">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblRequests_dblClick(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 13th June 2024
24 June 2024	navra1	navra1 - TFS 60149/Task 64732 - 24th June 2024

*/

vars
	theRow	: Integer;
	dynaDict : DynaDictionary;
	objArray : CM_ObjectArray;
	obj : Object;
	futAct : CM_OfflineFutureActor;
begin
	if self.tableUsingDisplayCollection then														//navra1 - TFS 60149/Task 64732 - 25th June 2024								
		if dynaDict = null then
			create dynaDict transient;
		else
			dynaDict.clear();
		endif;
		
		dynaDict.setMembership(CM_OfflineFutureActor);
		if table.column = 2 or table.column = 9 then
			dynaDict.addExternalKey(TimeStamp, 500, false, false);
		else
			dynaDict.addExternalKey(String, 500, false, false);
		endif;
		dynaDict.endKeys(true);	
		
		objArray := self.offlineFutureActors;
		
		foreach obj in objArray do
			if not app.isValidObject(obj) then
				continue;
			endif;
			futAct := obj.CM_OfflineFutureActor;
			if table.column = 1 then		
				dynaDict.tryPutAtKey(futAct.getRequestType(), futAct);
			elseif table.column = 2 then
				dynaDict.tryPutAtKey(futAct.getActionFutureDate(), futAct);
			elseif table.column = 3 then
				dynaDict.tryPutAtKey(futAct.getTerminalCode(), futAct);
			elseif table.column = 4 then
				dynaDict.tryPutAtKey(futAct.getCargoId(), futAct);
			elseif table.column = 5 then
				dynaDict.tryPutAtKey(futAct.getCargoTypeId().String, futAct);
			elseif table.column = 6 then
				dynaDict.tryPutAtKey(futAct.getCargoSubTypeId(), futAct);
			elseif table.column = 7 then
				dynaDict.tryPutAtKey(futAct.getLocationString(), futAct);
			elseif table.column = 8 then
				dynaDict.tryPutAtKey(futAct.getCargoQty(), futAct);			
			elseif table.column = 9 then
				dynaDict.tryPutAtKey(futAct.getAnniversaryDate(), futAct);			
			endif;
		endforeach;
		
		
		if displayOrder then
			self.tblRequests.displayCollection(dynaDict, false, Table.DisplayCollection_Reversed, null);
			displayOrder := false;
		else
			self.tblRequests.displayCollection(dynaDict, false, Table.DisplayCollection_Forward, null);
			displayOrder := true;
		endif;
		
		table.accessCell(1,table.column).fontBold := true;
	else		
	
		theRow := table.row;
		
		if theRow &gt; table.fixedRows then
			self.selectRequest(table.row, true);
			return;
		endif;

		if self.tblRequests.sortColumn[1] &gt; 0 then
			self.tblRequests.accessCell(1, self.tblRequests.sortColumn[1]).fontBold := false;
		endif;

		self.tblRequests.resortTableByColumn(table.column);

		table.accessCell(1,table.column).fontBold := true;
	endif;																						//navra1 - TFS 60149/Task 64732 - 25th June 2024

epilog
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblRequests_displayRow" id="29416391-e442-4863-8609-7c0075eb5473">
        <controlMethod name="CM_DataTable::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblRequests_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 13th June 2024

*/

vars
	offlineActor : CM_OfflineFutureActor;
	displayStr: String;
	invalidActor : Boolean;
begin

	if not obj.isKindOf(CM_OfflineFutureActor) then
		return null;
	endif;
	
	offlineActor:=obj.CM_OfflineFutureActor;
		
	//criteria filters
	if self.searchRequestType &lt;&gt; null then
		if offlineActor.getRequestType() &lt;&gt; self.searchRequestType then
			return null;
		endif;
	endif;
	
	if self.searchTerminalCode &lt;&gt; null then
		if offlineActor.getTerminalCode() &lt;&gt; self.searchTerminalCode then
			return null;
		endif;
	endif;
	
	if self.searchCargoId &lt;&gt; null then
		if self.searchCargoIdRegex = false then														//navra1 - TFS 60149/Task 64397 - 1 - 13th June 2024
			if offlineActor.getCargoId() &lt;&gt; self.searchCargoId then
				return null;
			endif;
		else																						//navra1 - TFS 60149/Task 64397 - 1 - 13th June 2024
			if not JadeRegex@isMatch(offlineActor.getCargoId(),  self.searchCargoId, true) then		//navra1 - TFS 60149/Task 64397 - 1 - 13th June 2024
				return null;																			//navra1 - TFS 60149/Task 64397 - 1 - 13th June 2024
			endif;																					//navra1 - TFS 60149/Task 64397 - 1 - 13th June 2024
		endif;																						//navra1 - TFS 60149/Task 64397 - 1 - 13th June 2024
	endif;
	
	if self.searchCargoTypeId &lt;&gt; null then
		if offlineActor.getCargoTypeId() &lt;&gt; self.searchCargoTypeId then
			return null;
		endif;
	endif;
	
	if self.searchCargoTypeId &lt;&gt; null then
		if offlineActor.getCargoTypeId() &lt;&gt; self.searchCargoTypeId then
			return null;
		endif;
	endif;
	
	if self.searchFromDT &lt;&gt; null and self.searchFromDT.dateTime.isValid() then
		if offlineActor.actionTimeStamp.cnEcIsLessThan(self.searchFromDT.dateTime) then
			return null;
		endif;
	endif;
	
	if self.searchToDT &lt;&gt; null and self.searchToDT.dateTime.isValid() then
		if offlineActor.actionTimeStamp.cnEcIsGreaterThan(self.searchToDT.dateTime) then
			return null;
		endif;
	endif;		
	//criteria filters
	
	displayStr:=offlineActor.getDisplay();
	if invalidActor then
		invalidActor:=false;
		return null;			
	endif;
	if displayStr = null then
		return null;
	endif;
	
	return displayStr;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="cb3342b6-9d58-41e2-b97d-c6917a5a801d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 26 June 2024 10:45:32.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026840, locale);
	btnClearTable.translateBubbleHelp(Xlat_0026841, locale);
	btnClearTable.translateCaption(Xlat_0026842, locale);
	btnRefresh.translateBubbleHelp(Xlat_0026843, locale);
	btnRefresh.translateCaption(Xlat_0026844, locale);
	chkPagination.translateCaption(Xlat_0026861, locale);
	chkRegex.translateBubbleHelp(Xlat_0026845, locale);
	chkRegex.translateCaption(Xlat_0026846, locale);
	lblCargoId.translateCaption(Xlat_0026847, locale);
	lblCargoType.translateCaption(Xlat_0026848, locale);
	lblDateFrom.translateCaption(Xlat_0026849, locale);
	lblDateTo.translateCaption(Xlat_0026850, locale);
	lblRequestType.translateCaption(Xlat_0026851, locale);
	lblTerminal.translateCaption(Xlat_0026852, locale);
	mnuClear.translateCaption(Xlat_0026853, locale);
	mnuClearSingleRequest.translateCaption(Xlat_0026854, locale);
	mnuInspect.translateCaption(Xlat_0026855, locale);
	mnuProcessRequest.translateCaption(Xlat_0026856, locale);
	mnuRequests.translateCaption(Xlat_0026857, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtCargoId_lostFocus" id="b7330365-1217-4a1d-9779-e45c5272da4f">
