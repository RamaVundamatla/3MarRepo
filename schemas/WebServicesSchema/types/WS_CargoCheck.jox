    <PrimAttribute name="requiredExtraInfo" id="d21db366-efc3-4c48-8b3e-ee53813f5adb">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>Information that is required on the cargo check item. 30 characters.</text>
    </PrimAttribute>
    <PrimAttribute name="sealCheckType" id="4d159e2a-e226-4266-bd92-e73248475552">
        <embedded/>
        <type name="Integer"/>
        <text>Seal Type Type based on the context receive or release for Gate, Rail, Ship or terminal.</text>
    </PrimAttribute>
    <PrimAttribute name="sealType" id="0269243c-0acb-426e-9705-7eb5756fd647">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
