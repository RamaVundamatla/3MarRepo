    <JadeMethod name="create" id="437c86f0-6089-4cb4-a506-e870c8a3df23">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//	Date		Who		Reason
//	25 Nov 2021	navmd1	20.0.21 DevEnc Deploy Issue. Changed doCreate so its not called for transient instances.
//						Which is the case when being called from PortSchemaRelease::createAuditConfigs and no CM_VoyageLayoutGraphic objects exist in the system

vars

begin
	// Only call doCreate if we're a persistent object - which we should always be when called normally.
	if not self.isTransient then
		self.doCreate();
	endif;
end;</source>
    </JadeMethod>
