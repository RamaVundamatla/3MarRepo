    <JadeMethod name="checkSendEmailForEventRequest" id="d429621d-112d-4b40-9b99-7562bbd9fce4">
        <source>checkSendEmailForEventRequest(_statusDT : TimeStamp) : Boolean;
//--------------------------------------------------
// Created:	19 May 2005 By: cnwgd1
//--------------------------------------------------
vars

	now			: TimeStamp;
	nowTime,
	statusTime,
	runTime		: Time;

begin

	now := app.actualTimeServer();
	
	// BGP hasn't been run for this event for yesterday
	// Need to catch up.
	if _statusDT.Date &lt; now.Date then
		return true;
	endif;
	
	
	statusTime := _statusDT.Time;
	nowTime	:= now.Time;
	
	foreach runTime in self.allRunTimes do
		// If status time is before this run time then it has happened earlier.
		if statusTime &lt; runTime and
			// If run time is earlier than now then it has passed so go for it.
			runTime &lt; nowTime then
			return true;
		endif;
	endforeach;
	return false;
end;</source>
        <Parameter name="_statusDT" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkSendEmailOld" id="508fe6c2-8d73-4235-b896-458cb5b52fed">
        <source>checkSendEmailOld(_statusDT : TimeStamp) : Boolean;
//--------------------------------------------------
// Created:	19 May 2005 By: cnwgd1
//--------------------------------------------------
vars

	processTime : TimeStamp;
	startTime,
	endTime,
	scheduledTime : Time;
begin

	if self.allRunTimes.isEmpty() then
		return true;
	endif;
	
	processTime := app.actualTimeServer();
/*	
	Glenys. Decided it would be better if the 10 minutes started
	after the specified time. so....
	
	If the email is supposed to be sent at 12.00pm then
	
	12.00pm		|............| - 12.10pm
	BGP can run any time from 12 - 12.10 and the email will be sent. */
	
	startTime	:= processTime.cnEcAddMinutes(-15).Time;
	endTime		:= processTime.Time;
	
	app.writeLog(startTime.String, LogINFO);
	app.writeLog(endTime.String, LogINFO);
	foreach scheduledTime in self.allRunTimes discreteLock do
		if scheduledTime &gt;= startTime and scheduledTime &lt;= endTime then
			return true;
		endif;
	endforeach;
		
	return false;
end;</source>
        <Parameter name="_statusDT" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getEventRequestEmails" id="232557c3-3705-45d3-af35-943b17b9e290">
        <source>getEventRequestEmails(_bgpEmailDict : BGP_EmailReqByUserAddressDict input; _passport : CM_Passport input);
//--------------------------------------------------
// Created:	19 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.allRunTimes.isEmpty then
		//No run times then email gets sent when request processed
		return;
	elseif _bgpEmailDict &lt;&gt; null then
		self.myUser.actionEventRequestEmail(_bgpEmailDict, self, _passport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'null _bgpEmailDict');	
	endif;	
end;</source>
        <Parameter name="_bgpEmailDict" type="BGP_EmailReqByUserAddressDict" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getRunTimesAsStringJMT" id="6954291e-14bd-4e05-b88b-662d56de366e">
        <source>getRunTimesAsStringJMT():String;
// ---------------------------------------------------------------------------
// Created:     14 December 2010 by cnwcs5 ccms mes 1112 / par 24464
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	time	:Time;
	result	:String;
begin
	foreach time in self.allRunTimes do
		if result = null then
			result := time.asStringJMT;
		else
			result := result &amp; time.asStringJMT;
		endif;
	endforeach;
	
	return result;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="sendEventRequestEmails2" id="24f80872-9d1c-4d11-99c8-2fd92c145842">
        <source>sendEventRequestEmails2(_passport : CM_Passport input);

// Created by cnwdvb1 on 03 May 2007

vars

	bgpEmail : BGP_EmailSendRequest;
	alertDesc,
	keyAddress,
	fromAddress,
	address,	
	ccAddress,
	reqMessage,
	message	: String;
	tmpEventRequestTI : CM_EventRequest;
	tmpTerm : CM_Terminal;
	bgpEmailDict 	: BGP_EmailReqByUserAddressDict;
	
begin
	
	
	if self.allRunTimes.isEmpty then
		return;		
	endif;
	
	tmpTerm := _passport.myTerminal;
	
	fromAddress := app.myRoot.getConfig(AutoSendersEmailAddress).String;
	
	foreach tmpEventRequestTI in self.allEventRequests discreteLock where (not tmpEventRequestTI.status &gt; EventRequestActioned) do
		
		if tmpEventRequestTI.status = EventRequestMatched and tmpEventRequestTI.actionFailedReason = null then
			continue;
		endif;

		if (not self.checkSendEmailForEventRequest(tmpEventRequestTI.statusDT)) then
			continue; 
		endif;
		
		if bgpEmailDict = null then
			create bgpEmailDict transient;
		endif;
		
		reqMessage := tmpEventRequestTI.getSendMessage();
		//06 Oct 2010	NDL	Par 25771
		if reqMessage = null then
			continue;
		endif;

		foreach address in tmpEventRequestTI.allEmailAddresses do
			keyAddress := address[1:50];
			if keyAddress = null then //par15256 Nov 2007
				continue;
			endif;
			bgpEmail := bgpEmailDict.getAtKey(keyAddress);
			if bgpEmail = null then
				create bgpEmail persistent;
				bgpEmail.setEmailRequest(keyAddress,
										  tmpEventRequestTI.typeString,
										  address, 
										  fromAddress, 
										  null, 
										  null, 
										  tmpEventRequestTI.typeString,
										  reqMessage,
										  self.myUser,
										  tmpTerm,
										  null,
										  null,
										  null,
										  null,
										  EmailSource_System);
				bgpEmailDict.add(bgpEmail);										  
			else
				bgpEmail.addTextToSendMessage(reqMessage);										 
			endif;
		endforeach;
		
		tmpEventRequestTI.updateStatusAndStatusInfo(EventRequestEmailed, app.getErrorString(Email_Sent_To_BGP));

	endforeach;
	
	if bgpEmailDict &lt;&gt; null then
		app.myUtilityUA.utlUpdateBGPEmailRequests(bgpEmailDict, _passport);
	endif;
	
epilog
	delete bgpEmailDict;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="02940e53-5162-4650-b155-c3fd90c0d972">
        <updating/>
        <source>setForUpdate(_pxyEventRequestEmail : CM_EventRequestEmail; _passport : CM_Passport input) updating;
//--------------------------------------------------
// Created:	19 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	self.myUser := _pxyEventRequestEmail.myUser;
	self.myRoot := _pxyEventRequestEmail.myRoot;
	self.type := _pxyEventRequestEmail.type;

	self.allRunTimes.clear();
	_pxyEventRequestEmail.allRunTimes.copy(self.allRunTimes);
	
	//put time in order
	self.allRunTimes.cnEcSort(false);

end;</source>
        <Parameter name="_pxyEventRequestEmail" type="CM_EventRequestEmail"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="583d3f42-8f1f-4205-bbc1-6bc865155a33">
        <updating/>
        <source>setProxy(_root : CM_Root; _user : CM_User; _type : Integer; _runTimes : TimeArray) updating;
//--------------------------------------------------
// Created:	19 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.myUser := _user;
	self.myRoot := _root;
	self.type := _type;
	self.allRunTimes.clear();
	_runTimes.copy(self.allRunTimes);
end;</source>
        <Parameter name="_root" type="CM_Root"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_runTimes" type="TimeArray"/>
    </JadeMethod>
    <JadeMethod name="validateCreate" id="5f695ee6-80c4-45a2-b65a-e910ef20b091">
        <source>validateCreate(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	19 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.validateMe(_passport);
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="e988234e-614e-4e47-96dc-88c2e03feb07">
        <source>validateMe(_passport : CM_Passport input);
//--------------------------------------------------
// Created:	19 May 2005 By: cnwgd1
//--------------------------------------------------
vars
begin
	if self.myUser = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'User', ETRow_User, null);
		app.raiseCMException(Input_required_field_Usr, ETRow_User, null); // cnwdb2	PAR 35364


	endif;
	if self.myRoot = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Root', null, null);
		app.raiseCMException(Input_required_field_root, null, null); // cnwdb2	PAR 35364
	endif;
	if self.type &lt;= EventRequestTypeNull 
	or self.type &gt;= EventRequestTypeMax then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid Type (' &amp; self.type.String &amp; ')');	
	endif;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
