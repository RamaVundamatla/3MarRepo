//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.cargoType		:= TI_CargoType_COU;

end;</source>
    </JadeMethod>
    <JadeMethod name="disconnectFromPower" id="5865e768-ccbf-4d1a-ba12-3c773265434d">
        <updating/>
        <source>disconnectFromPower(params : CMIF_ConnectParams; _passport : CM_Passport input) updating;
//NFS 3814 AA 24/9/01: Encapsulates all actions to disconnect COU from power
vars
	txn : CM_TITransaction;
	txnParams : CMIF_ConnectParams;
begin
	self.onPower := false;
	
	txnParams := params;
	txnParams.type := TRANS_TYPE_DISCONNECT_POWER;
	txnParams.myOtherTrackedItem := self.myReefer;
	txnParams.myTrackedItem := self;
	txn := self.createTransaction(txnParams, _passport);	
	txn.CM_DisconnectPower.secondary := true;	
end;</source>
        <Parameter name="params" type="CMIF_ConnectParams"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCOUTypeDescription" id="46defb5e-7d40-4a27-800a-50d3a200fc2f">
        <source>getCOUTypeDescription(_couType:Integer):String;
// ---------------------------------------------------------------------------
// Created:     28 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _couType = COU_TYPE_LAND then
		return 'Land';
	elseif _couType = COU_TYPE_LONG then
		return 'Long';
	elseif _couType = COU_TYPE_MARINE then
		return 'Marine';
	elseif _couType = COU_TYPE_SHORT then
		return 'Short';
	elseif _couType = COU_TYPE_UNDEFINED then
		return 'Undefined';
	else
		return 'Undefined';
	endif;
		
end;</source>
        <Parameter name="_couType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDataForDefSpecial" id="23100840-170b-41ec-96e9-a8be636d8060">
        <source>getDataForDefSpecial(_attrName: String; _heading: String; _headings: StringArray input; _data: HugeStringArray input): Boolean protected;
// ---------------------------------------------------------------------------
// Created:     26 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _attrName = ETRow_CouType then
		_headings.add(_heading);
		_data.add(app.couTypeEnumToString(self.couType));
		return true;

	else
		return inheritMethod(_attrName, _heading, _headings, _data);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_headings" type="StringArray" usage="input"/>
        <Parameter name="_data" type="HugeStringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="f48cf39d-1aa5-485f-9413-894d2a167f11">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     28 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _attrName = ETRow_CouType then
		return self.getCOUTypeDescription(self.couType);
	elseif _attrName = ETRow_CouId then
		return self.id.String;
	elseif _attrName = ETRow_OnPower then
		return app.getYesNo(self.onPower);
	endif;
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
