    <JadeMethod name="doSave" id="0309d49e-045b-433a-984b-e5629275e2cc">
        <updating/>
        <source>doSave(): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	proxyPaymentMethod : CM_PaymentMethod;
	lCode : String;
	lDescription : String;
	isCheque : Boolean;
	isPOS	: Boolean;
	theForm : SOP_TableMaintForm;
	
begin

	theForm := self.myForm; 
	lCode := theForm.tblInput1.getValueByName(ETRow_Code).String;
	lDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;
	isCheque := theForm.tblInput1.getValueByName(ETRow_IsCheque).Boolean;
	isPOS := theForm.tblInput1.getValueByName(ETRow_IsPOS).Boolean;

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_PaymentMethod transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyPaymentMethod := theForm.myProxyObject.CM_PaymentMethod;
	proxyPaymentMethod.setProxy(lCode, lDescription, isCheque, isPOS);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreatePaymentMethod(proxyPaymentMethod, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdatePaymentMethod(proxyPaymentMethod, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
