    <JadeMethod name="populatePermissions" id="c085fb86-a79d-4aed-8c95-3f34c0ac2ba6">
        <source>populatePermissions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		TFS		Reason
05 Sep 2019	jlgdi1	45802	Initial creation

*/

vars
	permissionAgent : CM_PermissionAgent;	
	iter : Iterator;
	permission : CM_PermissionObject;
	
begin
	if not self.allPermissionByConstValue.isValid() then
		self.allPermissionByConstValue.setMembership( CM_PermissionObject );
		self.allPermissionByConstValue.addMemberKey( CM_PermissionObject::constValue.name, false, false);
		self.allPermissionByConstValue.endKeys( true );
	else
		self.allPermissionByConstValue.clear();
	endif;

	create permissionAgent transient;
	permissionAgent.populatePermissionDict(true, false, 0);
	
	iter := permissionAgent.allPermissionsByConstValue.createIterator();
	while iter.next(permission) do		
		self.allPermissionByConstValue.add(permission.cloneSelf(true));
	endwhile;

epilog
	delete permissionAgent;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateProducts" id="ad871ad0-40d3-4afb-b615-16e3edf30a43">
        <updating/>
        <source>populateProducts( _term : CM_Terminal )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2019	jlgndl1	Initial creation	TFS 44194

*/

vars

	cargoTypes : CM_CargoBOLTypeByIdDict;
	deleteDict : Boolean;
	
	cargoBolType : CM_CargoBOLType;
	product : CM_Product;

begin

	if not self.allProductsByCode.isValid then
		self.allProductsByCode.setMembership( CM_Product );
		self.allProductsByCode.addMemberKey( CM_Product::code.name, false, true );
		self.allProductsByCode.endKeys( true );
	else
		self.allProductsByCode.clear();
	endif;

		
	if not self.allProductsByDescription.isValid then
		self.allProductsByDescription.setMembership( CM_Product );
		self.allProductsByDescription.addMemberKey( CM_Product::description.name, false, true );
		self.allProductsByDescription.endKeys( true );
	else
		self.allProductsByDescription.clear();
	endif;
	
	create cargoTypes transient;
	if _term &lt;&gt; null then
		_term.allCargoBOLTypes.copy(cargoTypes);
	else
		app.myRoot.allCargoTypesById.copy(cargoTypes);
	endif;
	
	foreach cargoBolType in cargoTypes discreteLock where cargoBolType.isKindOf(CM_CargoType) do 
		if cargoBolType.CM_CargoType.isNotAvailableForEntry then
			continue;
		endif;
		foreach product in cargoBolType.CM_CargoType.allProducts discreteLock do
			self.allProductsByCode.add( product );
			self.allProductsByDescription.add( product );
		endforeach;
	endforeach;
	
	self.productDictNeedsRefresh := false; 
	
epilog

	delete cargoTypes;

end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
    </JadeMethod>
