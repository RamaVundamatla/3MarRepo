    <JadeMethod name="verifyEDIDataTIs" id="f506c7c3-35c3-49d8-81fc-b96ca421f7fd">
        <updating/>
        <source>verifyEDIDataTIs(_passport : CM_Passport input): Integer updating;
//
// par21718 cnwrs1 Dec 2008
//
//02 Jul 2012	cnwrs1		Par 29927 EDI Booking Item replace not working
// 07 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 08 Dec 2017	jlgrs1	TFS 8281 - SNO - EDI New Coaprn Issues
// 21 Nov 2018	jlgrs1	TFS 42276 STWR Make EDI MultiThreaded Stage 7
vars
	errorSet : CM_ErrorSet;
	allMatchedBRItems : CM_BookingRefItemDict;
	cmifEDIBooking : CMIF_EDIBooking;
	cmifEDIPrenote : CMIF_EDIPrenote;
	cmifEDIRequestMultiLine : CMIF_EDIRequestMultiLine;
	tmpStatus : Integer;
begin
	on Exception do validationExceptionHandler(exception, _passport);
	create cmifEDIBooking transient;
	create allMatchedBRItems transient;
	create errorSet transient;
	cmifEDIBooking.status := self.status;
	cmifEDIBooking.myOperator := self.myOperator;
	cmifEDIBooking.processEDITIs(self.allEDITrackedItems, true, _passport, allMatchedBRItems); // par 26223 cnwrs1 8 Nov 2010	
	_passport.moveErrorsToSet(errorSet);
	create cmifEDIPrenote transient;
	if cmifEDIPrenote.isExportPrenotes(self) then
//		cmifEDIPrenote.loadOrVerifyForDB(self.allEDITrackedItems, _passport, true);
		cmifEDIPrenote.verifyPrenotes(self.allEDITrackedItems, true);
	else
//		cmifEDIPrenote.updateImportCargo(self, _passport);
	endif;
	_passport.moveErrorsToSet(errorSet);
	create cmifEDIRequestMultiLine transient;
	self.allEDITrackedItems.copy(cmifEDIRequestMultiLine.allEDITrackedItems);
	self.ediFileArray.copy(cmifEDIRequestMultiLine.ediFileArray);
	cmifEDIRequestMultiLine.loadOrVerifyForDB(_passport, true);
	_passport.addErrorsFromSet(errorSet);
	tmpStatus := self.getStatusFromEDITrackedItems(true);
	if tmpStatus &lt;&gt; 0 then
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(self, tmpStatus);	// par 27392 cnwrs1 14 Apr 2011
	endif;
	return 0;
epilog
	delete allMatchedBRItems;
	delete cmifEDIBooking;
	delete cmifEDIPrenote;
	delete cmifEDIRequestMultiLine;
	delete errorSet;
end;
</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="verifyHazEDITIs" id="db193176-960b-4d81-b5c8-2e3bc88a36be">
        <source>verifyHazEDITIs( _allHazDetails : CM_EDITISet; _cmifBookingRef : CMIF_BookingRef );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2016	cnwndl1	Initial creation	TFS 2843 / 2604

*/

vars

	ediTI : CM_EDITrackedItem;
	ediHazDetailsTI : CM_EDIHazDetailsTI;
	bookingId : String;
	sequence : String;
	cmifItem : CMIF_BookingRefItem;
	selectedCmifItem : CMIF_BookingRefItem;

begin

	foreach ediTI in _allHazDetails do
		ediHazDetailsTI := ediTI.CM_EDIHazDetailsTI;
		bookingId := ediHazDetailsTI.bookingId;
		sequence := ediHazDetailsTI.bookingItemSeq;
		if _cmifBookingRef &lt;&gt; null then
			foreach cmifItem in _cmifBookingRef.allCMIF_BRItems do
				if cmifItem.sequence = sequence then
					selectedCmifItem := cmifItem;
					break;
				endif;
			endforeach;
		endif;
		if selectedCmifItem = null then
			app.raiseCMException1(Booki_item_with_seque_not_foun, sequence, null, ediTI);
		endif;
		ediHazDetailsTI.verifySelf();
	endforeach;

epilog

end;</source>
        <Parameter name="_allHazDetails" type="CM_EDITISet"/>
        <Parameter name="_cmifBookingRef" type="CMIF_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="verifyToDoEDITIs" id="5b1b6997-f00d-45f9-bd43-a6b4fc48ec99">
        <source>verifyToDoEDITIs( _allToDoRemarks : CM_EDITISet; _cmifBookingRef : CMIF_BookingRef );
/*

Purpose:			

Parameters:			

Return Value:		

