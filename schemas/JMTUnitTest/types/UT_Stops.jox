    <JadeMethod name="tAddCopyToChildStopsTable" id="5f6dcf28-d74a-4576-9473-fbdb23c3793e">
        <source>tAddCopyToChildStopsTable();
// cnwndl1
//12 November 2008	cnwdw1	
// Add a stop that has the "copy to child " process action
// CCMS 1696
vars
	selectedTypes: CM_CargoBOLTypeSet;
	stopsTable: CM_StopsTable;
	processAreas: IntegerArray;
	opts : CM_AssociationDict;
begin
	
	create opts transient;
	deleteStopsTable(99);

	create selectedTypes transient;
	selectedTypes.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	
	create processAreas transient;
	processAreas.add(StopProcessCopyToChild);
	opts.addAssoc(ETRow_ProcessStopAreas, processAreas);
	opts.copy(self.opts);
	
	stopsTable := addStopsTable(99, "UT", "Unit Test", selectedTypes, opts);
	assertNotNullMsg(stopsTable, "StopsTable not created");
	assertTrueMsg(stopsTable.isStopProcess(StopProcessCopyToChild, self.getTerminal()), "Process action Copy to Child not set");
	
	// do a little bit of tidying up here.
	self.opts.addAssoc( ETRow_IsNotAvailableForEntry, true );		// this helps to make sure it is never used!
	self.updateStopsTable( stopsTable, selectedTypes);
	
epilog
	delete selectedTypes;
	delete processAreas;
	delete opts;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tAddStopToContainer" id="5352edbd-3bcc-4a1d-ab15-a2e284678af1">
        <source>tAddStopToContainer();
// cnwndl1
//17 November 2008	cnwdw1	
// Add a stop to a container
// CCMS 1696
vars
	ti: CM_TrackedItem;
	selectedTypes: CM_CargoBOLTypeSet;
	stopsTable: CM_StopsTable;
	processAreas: IntegerArray;
	opts : CM_AssociationDict;
begin
	self.deleteContainer("TEST0000001");
	deleteStopsTable(99);

	ti := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	
	// Create a Stop Type
	create selectedTypes transient;
	selectedTypes.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	create processAreas transient;
	processAreas.add(StopProcessCopyToChild);
	create opts transient;
	opts.addAssoc(ETRow_ProcessStopAreas, processAreas);
	stopsTable := addStopsTable(99, "UT", "Unit Test", selectedTypes, opts);

	addStop(ti, stopsTable);
	
	// do a little bit of tidying up here.
	opts.copy(self.opts);
	self.opts.addAssoc( ETRow_IsNotAvailableForEntry, true );		// this helps to make sure it is never used!
	self.updateStopsTable( stopsTable, selectedTypes);
	
epilog
	delete selectedTypes;
	delete processAreas;
	delete opts;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCCMS1002_PAR21889" id="b2a86180-6408-4b1f-a306-f186be0da734">
        <source>tCCMS1002_PAR21889();
// cnwrs1 - for emails
	
/*
This method will test that a stop with and with out a clearance expiry date can be applied to TrackedItems.
Then clearance expiry date will be updated to prove that also works OK.

20 January 2010	cnwrl1	Initial creation as part of PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
	
constants
	VoyageName			= 'PAR21889';
	BoatName			= 'PAR21889';
	ContainerId1		= 'PAR21889019';
	ContainerId2		= 'PAR21889024';
	StopToBeApplied		= 198;
	StopShortHeading	= 'PAR21889';			// should only be 8 long
	
vars
	tempStr				: String;
	testDate			: Date;
	container1			: CM_TrackedItem;
	container2			: CM_TrackedItem;
	operator			: CM_Operator;
	vessel				: CM_Vessel;
	voyage				: CM_Voyage;
	stopsTable			: CM_StopsTable;
	proxyStops			: CM_Stops;
	realStops			: CM_Stops;
	theStops			: CM_StopsByIdDict;
	terminal			: CM_Terminal;
	root				: CM_Root;
	tempIntegerArray	: IntegerArray;
	selectedTypes		: CM_CargoBOLTypeSet;
	isChildIgnore		: Boolean;
	isChildOnly			: Boolean;
	isCoastalIgnore		: Boolean;
	isCoastalOnly		: Boolean;
	isFull				: Boolean;
	isMT				: Boolean;
	isNotAvailForEntry	: Boolean;
	allowExpiryDate		: Boolean;
	
begin
	create theStops transient;
	
	root		:= app.myRoot;
	terminal	:= self.getTerminal;			// should be UT terminal
	operator	:= self.getOperator( self.getProfileSetting( UT_Profile.P_OPERATOR ).asString );
	testDate	:= app.actualTimeServer.Date + 20;		// 20 days in to the future.// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	// Make sure every thing required is deleted
	self.deleteVoyage( VoyageName );
	voyage	:= self.getVoyage( VoyageName );
	self.assertIsDeleted( voyage );
	
	self.deleteVessel( BoatName );
	vessel	:= self.getVessel( BoatName );
	self.assertIsDeleted( vessel );
	
	self.deleteContainer( ContainerId1 );
	container1	:= self.getTrackedItem( ContainerId1 ).CM_Container;
	self.assertIsDeleted( container1 );
	
	self.deleteContainer( ContainerId2 );
	container2	:= self.getTrackedItem( ContainerId2 ).CM_Container;
	self.assertIsDeleted( container2 );
	
	// Delete the appropriate StopsTable if it exists.
	self.deleteStopsTable( StopToBeApplied);
	stopsTable	:= root.allAvailableStopsTables[ StopToBeApplied ];
	self.assertIsDeleted( stopsTable );
	
	// Now set up cleanly
	vessel	:= self.addVesselCellular(	BoatName,
										operator);
	self.assertNotNullMsg( vessel, 'Add vessel failed' );
	
	// Note: This picks up the first alphabetical Trade eg "Chief Tasman".
	voyage	:= self.addVoyageWithContainerStructur(	VoyageName,
													BoatName,
													operator.code, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNullMsg( voyage, 'Add voyage failed' );
	
	// Make sure the appropriate stops table exists with the required settings for this terminal
	create selectedTypes transient;
	create tempIntegerArray transient;
	isChildIgnore		:= false;
	isChildOnly			:= false;
	isCoastalIgnore		:= false;
	isCoastalOnly		:= false;
	isFull				:= true;
	isMT				:= true;
	isNotAvailForEntry	:= false;
	allowExpiryDate		:= true;
	
	self.opts.addAssoc( ETRow_ShortHeading, StopShortHeading[ 1 : CM_StopsTable::shortHeading.getLengthForString ] );
	self.opts.addAssoc( ETRow_IsChildIgnore, isChildIgnore );
	self.opts.addAssoc( ETRow_IsChildOnly, isChildOnly );
	self.opts.addAssoc( ETRow_IsCoastalIgnore, isCoastalIgnore );
	self.opts.addAssoc( ETRow_IsCoastalOnly, isCoastalOnly );
	self.opts.addAssoc( ETRow_IsFull, isFull );
	self.opts.addAssoc( ETRow_IsMT, isMT );
	self.opts.addAssoc( ETRow_CheckStopAreas, tempIntegerArray );
	self.opts.addAssoc( ETRow_SetStopAreas, tempIntegerArray );
	self.opts.addAssoc( ETRow_ProcessStopAreas, tempIntegerArray );
	self.opts.addAssoc( ETRow_RequiresInfo, false );
	self.opts.addAssoc( ETRow_CustomsInfoEntry, null );
	self.opts.addAssoc( ETRow_IsNotAvailableForEntry, isNotAvailForEntry );
	self.opts.addAssoc( ETRow_AllowClearanceExpiryDate, allowExpiryDate );
	
	selectedTypes.add( app.myRoot.allCargoTypesById[ TI_CargoType_Container ] );
	
	stopsTable	:= self.addStopsTable(	StopToBeApplied,				// ID
										'UT' &amp; StopToBeApplied.display,	// code
										method.name[ 1 : CM_StopsTable::heading.getLengthForString ],	// heading to help identify what has created it
										selectedTypes,
										self.opts );
	
	self.assertNotNullMsg( stopsTable, 'Stop Table ' &amp; StopToBeApplied.display &amp; ' does not exist' );
	
	// Setup full containers which will contain the "Customs Export" stop by default.
	container1	:= self.addContainerForExport(	ContainerId1,
												operator,
												'2200',
												'GENL',
												TI_IMEX_STATUS_EXPORT,
												'1234',
												voyage.code,
												null,
												null ).CM_Container;
	
	container2	:= self.addContainerForExport(	ContainerId2,
												operator,
												'2200',
												'GENL',
												TI_IMEX_STATUS_EXPORT,
												'1234',
												voyage.code,
												null,
												null ).CM_Container;
	
	// Create a proxy stop of the stopsTable and add to the collection.
	create proxyStops transient;
	proxyStops.id	:= stopsTable.id;
	proxyStops.setMyStopsTable( stopsTable );
	theStops.clear;
	theStops.addNoDuplicates( proxyStops, false );
	
	// Finally add this appropriate Stop to these containers.
	// Any stops that were on the real TI eg "Customs Export" will be deleted at this stage.
	self.opts.addAssoc( self.IgnoreErrors, false );
	self.addStopsFromCollection( container1, theStops, app.myPassport );
	
	proxyStops.setClearanceExpiryDate( testDate );	// 20 days in to the future
	self.addStopsFromCollection( container2, theStops, app.myPassport );
	
	// Now do the real testing on container1 this proves that a stop can stil be added which is active now.
	realStops	:= container1.getStopByIDAsAtDate( proxyStops.id, app.actualTimeServer.date + CM_Stops.CheckDate_No_Of_Days );// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	tempStr		:= 'Failed to set stop ' &amp; stopsTable.heading.display &amp; ' correctly for ' &amp; ContainerId1;
	// Make sure the stop has been applied correctly to this container
	self.assertNotNullMsg( realStops, tempStr );
	
	// Make sure it is the correct stop id.
	tempStr		:= 'Failed to get the correct stop of ' &amp; proxyStops.id.display &amp; ' for ' &amp; proxyStops.myStopsTable.heading;
	self.assertEqualMsg( realStops.id, StopToBeApplied, tempStr );
	
	// Make sure the clearance expiry date has been set correctly.
	tempStr		:= 'Failed to set stop clearance expiry date correctly, it should be null';
	self.assertEqualMsg( realStops.clearanceExpiryDate, null, tempStr );
	
	// now change container1 clearance expiry date this proves the update processing is working.
	self.addStopsFromCollection( container1, theStops, app.myPassport );
	
	realStops	:= container1.getStopByIDAsAtDate( proxyStops.id, app.actualTimeServer.date + CM_Stops.CheckDate_No_Of_Days );// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	tempStr		:= 'Failed to set stop ' &amp; stopsTable.heading.display &amp; ' correctly for ' &amp; ContainerId1;
	// Make sure the stop has been applied correctly to this container
	self.assertNotNullMsg( realStops, tempStr );
	
	// Make sure it is the correct stop id.
	tempStr		:= 'Failed to get the correct stop of ' &amp; proxyStops.id.display &amp; ' for ' &amp; proxyStops.myStopsTable.heading;
	self.assertEqualMsg( realStops.id, StopToBeApplied, tempStr );
	
	// Make sure the clearance expiry date has been set correctly.
	tempStr		:= 'Failed to set stop clearance expiry date correctly, it should be ' &amp; testDate.asStringJMT;
	self.assertEqualMsg( realStops.clearanceExpiryDate, testDate, tempStr );
	
	// Now do the real testing on container2 this proves that a stop can be added with a future date.
	realStops	:= container2.getStopByIDAsAtDate( proxyStops.id, app.actualTimeServer.date + CM_Stops.CheckDate_No_Of_Days );// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	tempStr		:= 'Failed to set stop ' &amp; stopsTable.heading.display &amp; ' correctly for ' &amp; ContainerId2;
	// Make sure the stop has been applied correctly to this container
	self.assertNotNullMsg( realStops, tempStr );
	
	// Make sure it is the correct stop id.
	tempStr		:= 'Failed to get the correct stop of ' &amp; proxyStops.id.display &amp; ' for ' &amp; proxyStops.myStopsTable.heading;
	self.assertEqualMsg( realStops.id, StopToBeApplied, tempStr );
	
	// Make sure the clearance expiry date has been set correctly.
	tempStr		:= 'Failed to set stop clearance expiry date correctly, it should be ' &amp; testDate.asStringJMT;
	self.assertEqualMsg( realStops.clearanceExpiryDate, testDate, tempStr );
	
	// Do a little bit of tidying up here.
	self.opts.addAssoc( ETRow_IsNotAvailableForEntry, true );		// this helps to make sure it is never used!
	self.updateStopsTable( stopsTable, selectedTypes );
	
epilog
	delete tempIntegerArray;
	delete selectedTypes;
	delete theStops;
	delete proxyStops;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCCMS1791_PAR20466" id="97318ab7-a657-4a10-a33f-c92db8cc592f">
        <updating/>
        <source>tCCMS1791_PAR20466() updating;
// cnwrs1 - for emails - August 2009
//27 Jul 2022	navsj20	TFS 53862	EUP - WMS - Damage Recording Extra Details

/*
This method will test that when a stops table is applied to a container then the terminal
template settings are first checked to see if the stops table are actually applicable.
*/

constants
	VoyageName			= 'PAR20466';
	BoatName			= 'PAR20466';
	TestOperator		= 'MSK';
	ContainerId1		= 'PAR20466012';
	ContainerId2		= 'PAR20466028';
	BookingId1			= 'PAR20466_1';
	DeliveryReleaseStop	= 42;
	
vars
	tempStr				: String;
	container1			: CM_TrackedItem;
	container2			: CM_TrackedItem;
	vessel				: CM_Vessel;
	voyage				: CM_Voyage;
	stopsTable			: CM_StopsTable;
	stopTableTemplate	: CM_StopTableTemplate;
	terminal			: CM_Terminal;
	bookingRef			: CM_BookingRef;
	operator			: CM_Operator;
	root				: CM_Root;
	tempIntegerArray	: IntegerArray;
	//cargoBOLType		: CM_CargoBOLType; 	// 17 Jul 2022 navsj20 TFS 53862
	cargoBOLType		: Object;			// 17 Jul 2022 navsj20 TFS 53862
	selectedTypes		: CM_CargoBOLTypeSet;
	isChildIgnore		: Boolean;
	isChildOnly			: Boolean;
	isCoastalIgnore		: Boolean;
	isCoastalOnly		: Boolean;
	isFull				: Boolean;
	isMT				: Boolean;
	criteria			: CM_YACriteria;
begin
	root		:= app.myRoot;
	terminal	:= self.getTerminal;			// should be UT terminal
	operator	:= self.getOperator( TestOperator );
	self.opts.purge();
	
	// make sure every thing required is deleted
	self.deleteVoyage( VoyageName );
	voyage	:= self.getVoyage( VoyageName );
	self.assertIsDeleted( voyage );
	
	self.deleteVessel( BoatName );
	vessel	:= self.getVessel( BoatName );
	self.assertIsDeleted( vessel );
	
	self.deleteContainer( ContainerId1 );
	container1	:= self.getTrackedItem( ContainerId1 ).CM_Container;
	self.assertIsDeleted( container1 );
	
	self.deleteContainer( ContainerId2 );
	container2	:= self.getTrackedItem( ContainerId2 ).CM_Container;
	self.assertIsDeleted( container2 );
	
	// now set up cleanly
	vessel	:= self.addVesselCellular(	BoatName,
										operator);
	self.assertNotNullMsg( vessel, 'Add vessel failed' );
	
	// Note: This picks up the first alphabetical Trade eg "Chief Tasman".
	voyage	:= self.addVoyageWithContainerStructur(	VoyageName,
													BoatName,
													operator.code, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNullMsg( voyage, 'Add voyage failed' );
	
	// Delete and add the required bookings
	self.deleteBooking( BookingId1 );
	self.opts.addAssoc( 'Stock', true );
	self.opts.addAssocIfNotNull( ETRow_PackAs, app.getString( PackAs_LCL ) );
	self.opts.addAssoc( 'number', 5 );				// ie expect 5 items
	bookingRef	:=	self.addBookingForContainer(	BookingId1,
													operator,
													voyage,
													'DEBRV',			// dischargePort
													'2200',				// ISO Type
													'GENL' );			// Commodity
	assertNotNull( bookingRef );
	
	// Get the Delivery Release Stops Table
	stopsTable	:= root.allAvailableStopsTables[ DeliveryReleaseStop ];		// 42 in D mast
	self.assertNotNullMsg( stopsTable, 'Stop Table does not exist' );
	
	// make sure the required stop table terminal settings exist and are set.
	create selectedTypes transient;
	if not stopsTable.requiresInfo or stopsTable.requiresInfoType &lt;&gt; DeliveryRelease then
		// set up the required values and update stops table
		self.opts.addAssoc( ETRow_RequiresInfo, true );
		self.opts.addAssoc( ETRow_CustomsInfoEntry, DeliveryRelease );
		self.opts.addAssoc( ETRow_IsNotAvailableForEntry, stopsTable.isNotAvailableForEntry );
		// START 27 Jul 2022 navsj20 TFS 53862
		/*foreach cargoBOLType in stopsTable.allCargoTypesNew do
			selectedTypes.add( root.allCargoTypesById[ cargoBOLType.id ] );
		endforeach;*/
		if stopsTable.myStopCriteria &lt;&gt; null then
			foreach criteria in stopsTable.myStopCriteria.allCriteria where criteria.myYACriteriaType.type = YACriteriaType_CargoType do
				foreach cargoBOLType in criteria.myYAData.CM_YADataObjects.allObjects do
					if cargoBOLType.isKindOf(CM_CargoBOLType) then
						selectedTypes.add( root.allCargoTypesById[ cargoBOLType.CM_CargoBOLType.id ]);
					endif;
				endforeach;
			endforeach;
		endif;
		// END 27 Jul 2022 navsj20 TFS 53862
		self.updateStopsTable( stopsTable, selectedTypes);
		self.assertEqualMsg( stopsTable.requiresInfoType, DeliveryRelease, 'Wrong Info Required Entry' );
	endif;
	
	// Now make sure the stops table template for this terminal exists and has required values.
	create tempIntegerArray transient;
	isChildIgnore		:= false;
	isChildOnly			:= false;
	isCoastalIgnore		:= false;
	isCoastalOnly		:= false;
	isFull				:= true;
	isMT				:= false;
	self.opts.addAssoc( ETRow_IsChildIgnore, isChildIgnore );
	self.opts.addAssoc( ETRow_IsChildOnly, isChildOnly );
	self.opts.addAssoc( ETRow_IsCoastalIgnore, isCoastalIgnore );
	self.opts.addAssoc( ETRow_IsCoastalOnly, isCoastalOnly );
	self.opts.addAssoc( ETRow_IsFull, isFull );
	self.opts.addAssoc( ETRow_IsMT, isMT );
	self.opts.addAssoc( ETRow_CheckStopAreas, tempIntegerArray );
	self.opts.addAssoc( ETRow_SetStopAreas, tempIntegerArray );
	self.opts.addAssoc( ETRow_ProcessStopAreas, tempIntegerArray );
	
	stopTableTemplate	:= stopsTable.allStopTableTemplates[ terminal, stopsTable ];
	if stopTableTemplate = null then
		stopTableTemplate	:= self.addStopsTableTemplate( stopsTable, terminal);
		self.assertNotNullMsg( stopTableTemplate, 'Create Stop Table Template failed' );
	endif;
	
	if stopTableTemplate.isFull &lt;&gt; isFull or stopTableTemplate.isMT &lt;&gt; isMT then
		self.updateStopsTableTemplate( stopTableTemplate);
	endif;
	self.assertEqualMsg( stopTableTemplate.isFull, isFull, 'stopTableTemplate.isFull is invalid' );
	self.assertEqualMsg( stopTableTemplate.isMT, isMT, 'stopTableTemplate.isMT is invalid' );
	
	// Now do the real testing
	// setup a full container
	container1	:= self.addContainerForExport(	ContainerId1,
												operator,
												'2200',
												'GENL',
												TI_IMEX_STATUS_EXPORT,
												BookingId1,
												voyage.code,
												'DEBRV',
												null ).CM_Container;
	
	// and add this required Stop to this container.
	self.opts.addAssoc( self.IgnoreErrors, false );
	self.addStop( container1, stopsTable);
	// now test it.
	tempStr	:= 'Failed to set Stops Table ' &amp; stopsTable.heading.display &amp; ' correctly for ' &amp; ContainerId1;
	self.assertEqualMsg( container1.hasStopOfType( stopsTable ), true, tempStr );
	
	// setup an empty container
	container2	:= self.addContainerForExport(	ContainerId2,
												operator,
												'2200',
												'MT',
												TI_IMEX_STATUS_EXPORT,
												BookingId1,
												voyage.code,
												'DEBRV',
												null ).CM_Container;
	
	// and add this required Stop to this container - this should NOT be added.
	self.opts.addAssoc( self.IgnoreErrors, true );
	self.addStop( container2, stopsTable);
	// now test it.
	tempStr	:= 'Failed to set Stops Table ' &amp; stopsTable.heading.display &amp; ' correctly for ' &amp; ContainerId2;
	self.assertEqualMsg( container2.hasStopOfType( stopsTable ), false, tempStr );
	
epilog
	delete tempIntegerArray;
	delete selectedTypes;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCargoStopRequestDataAccess1" id="2b3b2592-0a48-4643-a20f-233d088e4269">
        <source>tCargoStopRequestDataAccess1();
// cnwrs1 PAR 28390
// create cargo stop requests and check they can be cleared with low permission transactions
/* Changes

Date		Name	TFS#		Description
============================================================================
10 Sep 2019	cnwrs1	TFS 46030
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
============================================================================*/
constants
	VoyageName		= 'PAR28390_1';
	BoatName		= 'PAR28390Boat';
	TestOperator	= 'MSK';
	ContainerId1	= 'PAR283901_1';
	BookingId1		= 'PAR28390_1';
	UserDefined		= 'Unit Test Stop';
	StopId			= 220;
	BlockStackName = 'BS283901';
	UserCodeID = "28390";
	TestOperatorDA = "MSC";
vars
	bSynchronous		: Boolean;
	isChildIgnore		: Boolean;
	isChildOnly			: Boolean;
	isCoastalIgnore		: Boolean;
	isCoastalOnly		: Boolean;
	isFull				: Boolean;
	isMT				: Boolean;
	xmlBlock			: String;
	clientRef			: String;
	messageType			: String;
	ediText				: String;
	tempStr				: String;
	cm_Stops			: CM_Stops;
	stopsTable			: CM_StopsTable;
	selectedTypes		: CM_CargoBOLTypeSet;
	tempIntegerArray	: IntegerArray;
	container			: CM_Container;
	bookingRef			: CM_BookingRef;
	fileTypeUser		: CM_EDIFileTypeUser;
	pxyFileTypeUser		: CM_EDIFileTypeUser;
	vessel				: CM_Vessel;
	voyage				: CM_Voyage;
	operator			: CM_Operator;
	ediFile				: CM_EDIFile;
	ediData				: CM_EDIData;
	binaryMsg			: Binary;
	ediControllerAgent	: CM_EDIControllerAgent;
	eventRequest : CM_EventRequestStops;	//par 27724 cnwrs1 22 June 2011
	lc : CM_LocationsController;
	bs : CM_BlockStack;
	user : CM_User;
	pxyUser : CM_User;
//	organisation : CM_Organisation;
	daSet : CM_DataAccessControllerSet; 
	sysSecurityRole	: CM_SecurityRoleSystem;
	secRole	: CM_SecurityRoleTerminal;
	dac : CM_DataAccessController;
	osa : CM_ObjectSetActual;
	operatorDA : CM_Operator;
	startUserCode : String;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.setTerminalConfig(EDIBaplieROBReplaceDef, false);
	self.setTerminalConfig(EDIBaplieROBExtRawData, false);
	create ediControllerAgent transient;
	create tempIntegerArray transient;
	create selectedTypes transient;
	create pxyFileTypeUser transient;
	
	ediControllerAgent.setTerminal(self.getTerminal);	// cnwrl1 24/05/2010 PAR 24276
	operator := self.getOperator(TestOperator);
	startUserCode := app.getMyUserCode();

	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');
	lc := self.getTerminal.lookupTerminalArea(BlockStackName).CM_TerminalArea.allLocationsControllers.first;
	
	// the block string below represents the XML of the required user file type definition format.
	xmlBlock := self.xmlDef_Stops(UserDefined);
	
	// break up the XML into the proxy CM_EDIFileTypeUser
	pxyFileTypeUser.importMeXML(xmlBlock);
	
	// make sure the required definition name does not already exist.
	fileTypeUser := app.myRoot.allEDIFileTypes[EDIFileType_UserDefined, UserDefined].CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser(fileTypeUser, app.myPassport);
		self.assertIsDeleted(fileTypeUser);
		self.assertTrue(app.myPassport.trxCompletedOK());
	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
	fileTypeUser := app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefined).CM_EDIFileTypeUser;
	self.assertNotNullMsg(fileTypeUser, 'User Type ' &amp; UserDefined &amp; ' is missing');
	
	// Make sure the required stops table exists with the required settings for this terminal
	self.deleteStopsTable(StopId);			// first delete if it exists.
	
	isChildIgnore := false;
	isChildOnly := false;
	isCoastalIgnore := false;
	isCoastalOnly := false;
	isFull := true;
	isMT := true;
	self.opts.addAssoc(ETRow_IsChildIgnore, isChildIgnore);
	self.opts.addAssoc(ETRow_IsChildOnly, isChildOnly);
	self.opts.addAssoc(ETRow_IsCoastalIgnore, isCoastalIgnore);
	self.opts.addAssoc(ETRow_IsCoastalOnly, isCoastalOnly);
	self.opts.addAssoc(ETRow_IsFull, isFull);
	self.opts.addAssoc(ETRow_IsMT, isMT);
	self.opts.addAssoc(ETRow_CheckStopAreas, tempIntegerArray);
	self.opts.addAssoc(ETRow_ProcessStopAreas, tempIntegerArray);
	self.opts.addAssoc(ETRow_RequiresInfo, false);
	self.opts.addAssoc(ETRow_CustomsInfoEntry, null);
	self.opts.addAssoc(ETRow_IsNotAvailableForEntry, false);
	self.opts.addAssoc(ETRow_AllowClearanceExpiryDate, false);
	tempIntegerArray.add(TI_IMEX_STATUS_EXPORT);
	self.opts.addAssoc(ETRow_SetStopAreas, tempIntegerArray);
	
	selectedTypes.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	
	stopsTable := self.addStopsTable(StopId,
										'UT' &amp; StopId.display,
										method.name[1 : 30],		// to help identify what has created it
										selectedTypes,
										self.opts);
	
	self.assertNotNullMsg(stopsTable, 'Stop Table ' &amp; StopId.display &amp; ' does not exist');
	
	// now setup the low permission user
	startUserCode := app.getMyUserCode();
	user := app.myRoot.allUsers[UserCodeID];
	beginTransaction;
	delete user;
	commitTransaction;
	create daSet transient;
	dac := app.myRoot.allDataAccessControllers["CM_Operator", TestOperatorDA];
	if dac = null then
		create osa transient;
		operatorDA := self.getOperator(TestOperatorDA);
		osa.add(operatorDA);
		app.myTrxCA.trxCreateDataAccessController(TestOperatorDA, CM_Operator, osa, false, true, dac, app.myPassport);
	endif;
	daSet.add(dac);
	create pxyUser transient;
	sysSecurityRole := app.myRoot.allRoles['System Root'].CM_SecurityRoleSystem;
	secRole := app.myRoot.allRoles['Terminal Root'].CM_SecurityRoleTerminal;
//	organisation := app.myRoot.allOrganisations.first;
	pxyUser.setProxy(UserCodeID, UserCodeID, EnabledNormalUser,
						app.myPassport.myUser.myOrganisation,
						app.myRoot,
						true, false, false, false, null,
						daSet, sysSecurityRole, null, app.myRoot.allEmailEntities,
						null, null,
						app.myRoot.getDefaultLocale(true), false, false); //cnwrs1 Par 23153 11 Mar 2010
	app.myTrxCA.trxCreateUser(pxyUser, "password", user, app.myPassport);
	
	app.myPassport.setMyUserFromCode(UserCodeID);
	// setup the the edi data here.
	ediText :=
'Stop, this is one of the search keywords
A,ISO Container,' &amp; ContainerId1 &amp; ',' &amp; StopId.display &amp; ',"added via Unit Test"';
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg := ediText.Binary;
	bSynchronous := true;									// true = load, false = queue
	messageType := UserDefined[1 : fileTypeUser.name.maxLength];						// ie 63
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength];		// ie 30
	ediControllerAgent.setEdiClientRef(clientRef);
	
	// make sure all of the objects are deleted and created correctly.
	ediFile	:= ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData	:= ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile	:= ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertIsDeleted(ediFile);
/*	
	
	self.deleteContainer(ContainerId1);
	container := self.getTrackedItem(ContainerId1).CM_Container;
	self.assertIsDeleted(container);
	
	// Delete and add the required bookings
	self.opts.addAssoc('Stock', true);
	self.opts.addAssocIfNotNull(ETRow_PackAs, app.getString(PackAs_LCL));
	self.deleteBooking(BookingId1);
	bookingRef :=	self.addBookingForContainer(BookingId1,
													operator,
													voyage,
													'DEBRV',			// dischargePort
													'4102',				// ISO Type
													'WOOL');			// Commodity
	assertNotNull(bookingRef);
	
	// and add the container
	container := self.addContainerForExport(ContainerId1,
												self.getOperator(TestOperator),
												'2200',
												'GENL',
												TI_IMEX_STATUS_EXPORT,
												bookingRef.bookingReference,
												voyage.code,
												null,
												null).CM_Container;
	
	container := self.getTrackedItem(ContainerId1).CM_Container;
	tempStr	:= 'Failed to load container ' &amp; ContainerId1;
	self.assertNotNullMsg(container, tempStr);
*/	
	// load the edi data, verify and load to database
	if bSynchronous then
		ediControllerAgent.loadMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to load container ' &amp; ContainerId1;
	else
		ediControllerAgent.queueMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to queue container ' &amp; ContainerId1;
	endif;
//	self.assertEqualMsg(ediControllerAgent.ediStatusCode, null, tempStr &amp; ' pos 1');
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg(ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, tempStr);

	// get eventrequest and check it is ok.
	eventRequest := self.getTerminal.allEventRequestStopsByCargoID[ContainerId1];
	tempStr	:= 'Failed to load Event stop Request ' &amp; ContainerId1;
	self.assertNotNullMsg(eventRequest, tempStr);

	app.myPassport.setMyUserFromCode(startUserCode);

	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// now set up cleanly
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');

	self.assertNotNullMsg(vessel, tempStr);
	// Load  BAPLIE file
	ediText := "
UNB+UNOA:2+AUMEL+MSK+060616:1348+370+++++FES'
UNH+ZIZP9LYA0003AUMEL+BAPLIE:D:95B:UN:SMDG20'
BGM++370+9'
DTM+137:0606161348:201'
TDT+20+"&amp;voyage.code&amp;"+++MSK:172:20+++ZIZP9:103:11:"&amp;vessel.name&amp;"'
LOC+5+AUMEL:139:6'
LOC+61+:139:6'
DTM+132:0606161347:201'
DTM+133:0606161347:201'
LOC+147+0010682::5'
GDS+WINE'
FTX+AAA+++WINE'
MEA+WT++KGM:21000'
LOC+9+AUMEL'
LOC+11+NZAKL'
LOC+83+CNAKL'
LOC+152+CNAKL'
RFF+BM:1'
EQD+CN+"&amp;ContainerId1&amp;"+2210++2+5'
NAD+CA+CPS:172:20'
LOC+147+0010482::5'
GDS+WINE'
FTX+AAA+++WINE'
MEA+WT++KGM:21000'
LOC+9+AUMEL'
LOC+11+NZAKL'
LOC+83+CNAKL'
LOC+152+CNAKL'
RFF+BM:1'
EQD+CN+XNR60001922+2210++2+5'
NAD+CA+CPS:172:20'
LOC+147+0010282::5'
GDS+WINE'
FTX+AAA+++WINE'
MEA+WT++KGM:21000'
LOC+9+AUMEL'
LOC+11+NZAKL'
LOC+83+CNAKL'
LOC+152+CNAKL'
RFF+BM:1'
EQD+CN+XNR60001925+2210++2+5'
NAD+CA+CPS:172:20'
LOC+147+0010182::5'
GDS+WINE'
FTX+AAA+++WINE'
MEA+WT++KGM:21000'
LOC+9+AUMEL'
LOC+11+NZAKL'
LOC+83+CNAKL'
LOC+152+CNAKL'
RFF+BM:1'
EQD+CN+XNR60001928+2210++2+5'
NAD+CA+CPS:172:20'
LOC+147+0010382::5'
GDS+WINE'
FTX+AAA+++GENL'
MEA+WT++KGM:21000'
LOC+9+AUMEL'
LOC+11+NZAKL'
LOC+83+CNAKL'
LOC+152+CNAKL'
RFF+BM:1'
EQD+CN+XNR60002706+2210++2+5'
NAD+CA+CPS:172:20'
LOC+147+0010582::5'
GDS+WINE'
FTX+AAA+++GENL'
MEA+WT++KGM:21000'
LOC+9+AUMEL'
LOC+11+AUSYD'
LOC+83+CNAKL'
LOC+152+CNAKL'
RFF+BM:1'
EQD+CN+XNR60003312+2210++2+5'
NAD+CA+COS:172:20'
UNT+75+ZIZP9AOR0005AUMEL'
UNZ+1+370'
	";
	ediFile := self.ediLoadFileName(ediText, EDIFileType_Unknown, "BAPLIE", "BAPLIE"&amp;method.name);
	self.assertNotNull(ediFile);
	tempStr := "Load failed "&amp;CrLf&amp;app.myPassport.getAllErrorsWarningsAsString();
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_LOADED, tempStr);

	self.ediVerify(ediFile);
	tempStr := "Verify failed "&amp;CrLf&amp;app.myPassport.getAllErrorsWarningsAsString();
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
//	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr);	

	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);

	self.ediMakeActual(ediFile);
	tempStr	:= 'Make Actual failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_MADE_ACTUAL, tempStr);

	container := voyage.allOnshipTIsByCargoTypeId[TI_CargoType_Container, ContainerId1].CM_Container;
//	self.assertEqual(container, eventRequest.myTrackedItem);
//	self.assertEqual(eventRequest.autoCleanup, true);	// par 27724 cnwrs1 22 June 2011

	// and add this required Stop to this container.
	self.opts.addAssoc(self.IgnoreErrors, false);
	self.addStop(container, stopsTable);
	
	app.myPassport.setMyUserFromCode(UserCodeID);
	beginTransaction;
	//container.moveToLocation(lc, null, null, null, REAL_MODE, true, true, false, false, false,   false, null,null,app.myPassport);	// TFS 2651
	container.moveToLocation(lc, null, null, null, REAL_MODE, true, true, false, false, false,   false, null,null,null,null,null,app.myPassport);	// TFS 2651
	if app.myPassport.noErrors() then
		app.cmsCommitTransaction(app.myPassport);
	else
		app.cmsAbortTransaction;
	endif;
	
	// Now check the actual data has been loaded correctly.
	// this means the container has the correct stop
	tempStr	:= 'Failed to add stop ' &amp; StopId.display &amp; ' to container ' &amp; ContainerId1;
	cm_Stops := container.getStopByIDAsAtDate(StopId, null);
	self.assertEqualMsg(cm_Stops.id, StopId, tempStr);
//	self.assertEqualMsg(cm_Stops, null, tempStr);
	
	// do a little bit of tidying up here.
	self.opts.addAssoc(ETRow_IsNotAvailableForEntry, true);		// this helps to make sure it is never used!
	self.updateStopsTable(stopsTable, selectedTypes);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete ediControllerAgent;
	delete selectedTypes;
	delete tempIntegerArray;
	delete pxyFileTypeUser;
	delete pxyUser;
	delete daSet;
	// currently required if still in transaction state so that the next unit test will be run OK.
	abortTransaction;
end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;DAC ISSUE&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
