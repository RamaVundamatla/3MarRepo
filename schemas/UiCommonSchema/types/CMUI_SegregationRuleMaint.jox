    <JadeMethod name="loadConditionTypes" id="b6c827f4-bdaf-4974-9522-f44e653238c6">
        <updating/>
        <source>loadConditionTypes() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	23 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	cmb			: CMUI_ComboBox;
begin
	cmb := self.cmbRuleMode;
	cmb.clear();
	cmb.sorted := false;

	cmb.itemData[cmb.addItem(app.segregationTypeEnumToString(Segregation_Type_Yard))] := Segregation_Type_Yard;
	cmb.itemData[cmb.addItem(app.segregationTypeEnumToString(Segregation_Type_Road))] := Segregation_Type_Road;
	cmb.itemData[cmb.addItem(app.segregationTypeEnumToString(Segregation_Type_Rail))] := Segregation_Type_Rail;
	cmb.itemData[cmb.addItem(app.segregationTypeEnumToString(Segregation_Type_Ship))] := Segregation_Type_Ship;
	cmb.itemData[cmb.addItem(app.segregationTypeEnumToString(Segregation_Type_Warehouse))] := Segregation_Type_Warehouse;	//28 Jul 2015	NDL	Par 36660
	
	cmb.listIndex := 1;
	self.ruleMode := Segregation_Type_Yard;
	
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadConditions" id="73a32245-7b5f-43d5-ba45-5dba4e9b17e3">
        <source>loadConditions() protected;
/*
----------   ----------  --------------------------------------------------
Created:	23 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	condDict		: CM_SegCondByTypeIdxDict;
	segCond			: CM_SegregationCondition;
	iter			: Iterator;
	tbl				: CM_DataTable;
	colourCol,
	idx				: Integer;
	
begin
	tbl := self.tblConditions;
	tbl.rows := tbl.fixedRows;
	
	colourCol := self.colorValueColumn;
	condDict := self.myTerminal.allSegregationConditions;
	iter := condDict.createIterator();
	condDict.startKeyGeq(self.ruleMode, null, iter);
	
	while iter.next(segCond) do
		if segCond.type &lt;&gt; self.ruleMode then
			break;
		endif;
		
		idx := tbl.addItem(segCond.getAttributeStringForDefArray(tbl.allTblDataEntRows));
		tbl.accessRow(idx).itemObject := segCond;
		tbl.accessCell(idx, colourCol).backColor := segCond.colour;
	endwhile;
	
	
epilog
	delete iter;
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadSegregationMatrix" id="7bd060d7-6542-41fe-a078-2db96af0ce23">
        <source>loadSegregationMatrix(_forEdit : Boolean) protected;
/*
----------   ----------  --------------------------------------------------
Created:	28 August 2006 By cnwth2

Purpose:	if _forEdit then proxy segreation rules are created for the existing rules

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tbl				: CM_DataTable;
	hazDict			: CM_HazardClassByCodeDict;
	loop2HazClass,
	hazClass		: CM_HazardClass;
	segRule			: CM_SegregationRule;
	matrixTrans		: CM_SegregationMatrixTrans;
	matrixAgent		: CMIF_SegregationMatrixAgent;
	ruleDict		: CM_SegRuleByTypeEntity1Entity2;
	newRow,
	newCol			: Integer;
begin

	hazDict := app.myRoot.allHazardClasses;
	ruleDict := self.myTerminal.allSegRulesByEntity1Entity2;
	
	matrixAgent := self.mySegregationMatrixAgent;
	matrixAgent.allSegMatrixTransByColRow.purge();
	
	tbl := self.tblMatrix;
	newRow 				:= tbl.fixedRows;
	tbl.rows			:= tbl.fixedRows;
	newCol 				:= tbl.fixedColumns;
	tbl.columns 		:= hazDict.size + tbl.fixedColumns;
	//have to make one pass for the initial columns
	foreach hazClass in hazDict do
		newCol := newCol + 1;
		tbl.accessCell(newRow, newCol).text := hazClass.code;
		tbl.accessColumn(newCol).itemObject := hazClass;
		tbl.accessedColumn.width := self.Column_Width;
		tbl.accessedColumn.alignment := Table.Alignment_Center;
	endforeach;
	
	foreach hazClass in hazDict do
		newRow := tbl.addItem(hazClass.description &amp; Tab &amp; hazClass.code);
		tbl.accessRow(newRow).itemObject := hazClass;
		tbl.accessedRow.alignment := Table.Alignment_Center;
		newCol := 2;
		foreach loop2HazClass in hazDict do
			newCol := newCol + 1;
			create matrixTrans transient;
			matrixTrans.row := newRow;
			matrixTrans.col := newCol;
			matrixTrans.myEntity1 := hazClass;
			matrixTrans.myEntity2 := loop2HazClass;
			matrixTrans.mySegregationMatrixAgent := matrixAgent;
			tbl.accessCell(newRow, newCol).itemObject := matrixTrans;
			tbl.accessedCell.alignment := Table.Alignment_Center;
			
			segRule := ruleDict[self.ruleMode, hazClass, loop2HazClass];
			if segRule &lt;&gt; null then
				matrixTrans.mySegregationRule := segRule;
				tbl.accessedCell.backColor := segRule.getColour;
				tbl.accessedCell.text := segRule.mySegregationCondition.code;
				if _forEdit then
					matrixTrans.myPxySegregationRule := app.createUpdateProxy(segRule).CM_SegregationRule;
				endif;
			endif;
			
		endforeach;
	endforeach;
	
end;


</source>
        <access>protected</access>
        <Parameter name="_forEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSegCondFromTbl" id="9d5e2371-5878-4af6-b0bf-afb6d7b6825a">
        <source>setSegCondFromTbl() protected;
/*
----------   ----------  --------------------------------------------------
Created:	24 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	pxyCond			: CM_SegregationCondition;
	tbl				: CM_EntryTable;
	code,
	descr			: String;
	proximityHorz,
	proximityVert,
	proximityDepth,
	col				: Integer;
	isActive,
	allowedSameArea	: Boolean;
	
begin
	tbl := self.tblCondEdit;
	pxyCond := self.myPxySegregationCond.CM_SegregationCondition;
	
	code 		:= tbl.getValueByName(ETRow_ConditionCode).String;
	descr 		:= tbl.getValueByName(ETRow_ConditionDescr).String;
	col			:= tbl.getValueByName(ETRow_ConditionColour).Integer;
	isActive	:= tbl.getValueByName(ETRow_IsActive).Boolean;
	
	if pxyCond.type = Segregation_Type_Yard then
		allowedSameArea 	:= tbl.getValueByName(ETRow_AllowedYardArea).Boolean;
		proximityHorz		:= tbl.getValueByName(ETRow_ProxHorzontal).Integer;
		proximityVert		:= tbl.getValueByName(ETRow_ProxVertical).Integer;
		proximityDepth		:= tbl.getValueByName(ETRow_ProxDepth).Integer;
		
	elseif pxyCond.type = Segregation_Type_Road then
		allowedSameArea := tbl.getValueByName(ETRow_AllowedVehicle).Boolean;
	
	elseif pxyCond.type = Segregation_Type_Rail then
		proximityHorz		:= tbl.getValueByName(ETRow_NumWagonsApart).Integer;
		allowedSameArea 	:= true;
		
	elseif pxyCond.type = Segregation_Type_Ship then
		allowedSameArea 	:= true;
		proximityHorz		:= tbl.getValueByName(ETRow_ProxHorzontal).Integer;
		proximityVert		:= tbl.getValueByName(ETRow_ProxVertical).Integer;
		proximityDepth		:= tbl.getValueByName(ETRow_ProxDepth).Integer;
		
	elseif pxyCond.type = Segregation_Type_Warehouse then	//28 Jul 2015	NDL	Par 36660
		allowedSameArea := tbl.getValueByName(ETRow_AllowedLocation).Boolean;
		
	endif;
	
	
	pxyCond.setProxy(code, descr, col, isActive, allowedSameArea, proximityHorz, proximityVert, proximityDepth);
	
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setTblFromSegCond" id="d8264ac0-9a61-4ef6-bc9f-e4072e95c391">
        <source>setTblFromSegCond() protected;
/*
----------   ----------  --------------------------------------------------
Created:	28 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	segCond			: CM_SegregationCondition;
	tbl				: CM_EntryTable;
	code,
	descr			: String;
	proximityHorz,
	proximityVert,
	proximityDepth,
	col				: Integer;
	isActive,
	allowedSameArea	: Boolean;
	
begin
	tbl := self.tblCondEdit;
	segCond := self.mySelectedCondition;
	if segCond = null then	//Par13735
		return;
	endif;
	
	tbl.setValueByName(ETRow_ConditionCode, segCond.code);
	tbl.setValueByName(ETRow_ConditionDescr, segCond.description);
	tbl.setValueByName(ETRow_ConditionColour, segCond.colour);
	tbl.setValueByName(ETRow_IsActive, segCond.isActive);
	
	if segCond.type = Segregation_Type_Yard then
		tbl.setValueByName(ETRow_AllowedYardArea, segCond.allowedSameArea);
		tbl.setValueByName(ETRow_ProxHorzontal, segCond.proximityHorizontal);
		tbl.setValueByName(ETRow_ProxVertical, segCond.proximityVertical);
		tbl.setValueByName(ETRow_ProxDepth, segCond.proximityDepth);
		
	elseif segCond.type = Segregation_Type_Road then
		tbl.setValueByName(ETRow_AllowedVehicle, segCond.allowedSameArea);
	
	elseif segCond.type = Segregation_Type_Rail then
		tbl.setValueByName(ETRow_AllowedWagon, segCond.allowedSameArea);
		tbl.setValueByName(ETRow_NumWagonsApart, segCond.proximityHorizontal);
		tbl.setValueByName(ETRow_NumRakesApart, segCond.proximityVertical);
		
	elseif segCond.type = Segregation_Type_Ship then
		tbl.setValueByName(ETRow_AllowedBay, segCond.allowedSameArea);
		tbl.setValueByName(ETRow_ProxHorzontal, segCond.proximityHorizontal);
		tbl.setValueByName(ETRow_ProxVertical, segCond.proximityVertical);
		tbl.setValueByName(ETRow_ProxDepth, segCond.proximityDepth);
		
	//28 Jul 2015	NDL	Par 36660
	elseif segCond.type = Segregation_Type_Warehouse then
		tbl.setValueByName(ETRow_AllowedLocation, segCond.allowedSameArea);
		
	endif;
	
end;




</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="cc1afac1-57e7-4900-92c9-14af84058cb5">
        <updating/>
        <source>setupForm() updating;
/*
----------   ----------  --------------------------------------------------
Created:	22 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	canMaintain : Boolean;
begin
	self.frmMode.borderStyle := self.BorderStyle_None;//hide frame
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.loadConditionTypes();
	self.initTblMatrix();
	
	inheritMethod();
	self.doChangeRuleMode();
	//self.doMatrixEdit(false);
	
	//cnwmd1 Par 21114
	canMaintain := app.myPassport.myUser.canDo(self.myTerminal, self.permissionMaint);
	self.btnNewRule.enabled := canMaintain;
	self.btnEditRule.enabled := canMaintain;
	self.btnDeleteRule.enabled := canMaintain;
	self.btnEditMatrix.enabled := canMaintain;
		
	self.armNotifications();
end;


</source>
    </JadeMethod>
