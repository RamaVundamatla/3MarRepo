    <JadeMethod name="buildAllocateMenu" id="b2cd9444-c282-4b9d-9697-0d51d5265456">
        <source>buildAllocateMenu();
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lQueue 		: CM_RadioTelemetryQueue;
	lMachine	: CM_Machine;
	idx			: Integer;
	i			: Integer;
	lCaption	: String;
	mnuChild	: MenuItem;
	mnuIndex 	: Integer;
	count		: Integer;
	obj			: Object;
	task		: CM_RTQueueTask;
	machines	: CM_MachineByIdDict;
begin
	
	count := 2;
	while true do
		obj := self.mnuTaskAllocateMachine.getMenuItem(count);
		if obj = null then
			break;
		endif;
		delete obj;
		count := count + 1;
	endwhile;
	self.mnuTaskAllocate.enabled := (self.myCurrentTask.status = TASK_UNACTIONED);
	self.mnuTaskAllocate.enabled := true;
	self.mnuTaskAllocateMachine.visible := false;
	self.mnuTaskAllocateMachine.enabled := false;
	idx := 1;
	task := self.myCurrentTask;
	if task &lt;&gt; null then
		lQueue := task.queue;
		if lQueue &lt;&gt; null then
			create machines transient;
			lQueue.getAllMachines(machines, true, true,false);
			foreach obj in machines do
				lMachine := obj.CM_Machine;
				if lMachine.isInQueue(lQueue.CM_RadioTelemetryQueue) then
					idx := idx + 1;
					lCaption := lMachine.id.trimBlanks;
					mnuChild := self.mnuTaskAllocateMachine.getMenuItem(idx); // check if the menu is already cloned
					if mnuChild = null then
						mnuChild := mnuTaskAllocateMachine.loadMenu(idx); // Clone menu
						mnuChild.caption := lCaption;
						mnuChild.visible := true;
						mnuChild.enabled := true;
						mnuChild.userObject := lMachine;
					endif;
				endif;
			endforeach;
		endif;
	endif;
	
epilog
	delete machines;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildIMVSwitchMenu" id="acca2afe-d412-401b-90c5-c0e70a7704de">
        <source>buildIMVSwitchMenu();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 April 2010	cnwrd1	Initial creation

*/

vars
	lQueue 		: CM_RadioTelemetryQueue;
	lMachine	: CM_Machine;
	idx			: Integer;
	i			: Integer;
	lCaption	: String;
	mnuChild	: MenuItem;
	mnuIndex 	: Integer;
	count		: Integer;
	obj			: Object;
	task		: CM_RTQueueTask;
	machines	: CM_MachineByIdDict;
begin
	
	count := 2;
	while true do
		obj := self.mnuSwitchIMVMachine.getMenuItem(count);
		if obj = null then
			break;
		endif;
		delete obj;
		count := count + 1;
	endwhile;
	
	
	
	self.mnuSwitchIMV.enabled := (myCurrentTask.status = TASK_WORKING and myCurrentTask.machine &lt;&gt; null and myCurrentTask.machine.machineType = MACHINETYPE_IMV);
	//self.mnuSwitchIMV.enabled := true;
	self.mnuSwitchIMVMachine.visible := false;
	self.mnuSwitchIMVMachine.enabled := false;
	idx := 1;
	task := self.myCurrentTask;
	if task &lt;&gt; null then
		lQueue := task.queue;
		if lQueue &lt;&gt; null then
			create machines transient;
			task.queryIMVSwitch(machines);  //get IMV's that can work the job
			
			
			if machines.size = 0 then // no free machines
				self.mnuSwitchIMV.enabled := false;
			endif;
			
			foreach obj in machines do
				lMachine := obj.CM_Machine;
				if lMachine.isInQueue(lQueue.CM_RadioTelemetryQueue) then
					idx := idx + 1;
					lCaption := lMachine.id.trimBlanks;
					mnuChild := self.mnuSwitchIMVMachine.getMenuItem(idx); // check if the menu is already cloned
					if mnuChild = null then
						mnuChild := mnuSwitchIMVMachine.loadMenu(idx); // Clone menu
						mnuChild.caption := lCaption;
						mnuChild.visible := true;
						mnuChild.enabled := true;
						mnuChild.userObject := lMachine;
					endif;
				endif;
			endforeach;
		endif;
	endif;
	
epilog
	delete machines;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildRTMoveMethodMenu" id="20a1324e-3e99-41de-9e25-1f156ddd9b30">
        <source>buildRTMoveMethodMenu();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 February 2010	cnwer1	Initial creation

*/

vars

	idx			: Integer;
	lCaption	: String;
	mnuChild	: MenuItem;
	count		: Integer;
	obj			: Object;

	moveMethodRule  : CM_RTMoveMethodRule;
	allValidRules : CM_RTMoveMethodRuleDict;
begin
	
	count := 2;
	while true do
		obj := self.mnuAltRTMoveMethod.getMenuItem(count);
		if obj = null then
			break;
		endif;
		delete obj;
		count := count + 1;
	endwhile;

	self.mnuChgRTMoveMethod.visible:=false;
	if self.myCurrentEntry = null then
		return;
	endif;
	
	if self.myCurrentEntry.myRTMoveMethodRule = null then
		return;
	endif;
	
	self.mnuAltRTMoveMethod.visible := false;
	self.mnuAltRTMoveMethod.enabled := false;
	
	idx := 1;
	if self.myCurrentEntry &lt;&gt; null then
		create allValidRules transient;
		self.myCurrentEntry.myWorkListEntry.getAllValidRTMoveMethodRules(allValidRules);
		
		foreach  moveMethodRule in allValidRules do
			self.mnuChgRTMoveMethod.visible := true;
			idx := idx + 1;
			lCaption := moveMethodRule.getDisplayDetails(false);
			mnuChild := self.mnuAltRTMoveMethod.getMenuItem(idx); // check if the menu is already cloned
	
			if mnuChild = null then
				mnuChild := mnuAltRTMoveMethod.loadMenu(idx); // Clone menu
				
				mnuChild.caption := lCaption;
				mnuChild.visible := true;
				mnuChild.enabled := true;
				mnuChild.userObject := moveMethodRule;
					
			endif;
		endforeach;
				
	endif;

epilog
	delete allValidRules;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildTaskSwitchJobMenu" id="d3e55c1d-5d29-40f7-a562-a03f58ab2aa6">
        <source>buildTaskSwitchJobMenu();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 November 2012	cnwrd1	Initial creation
04/06/2019	JLGNS1	Bug 44998: MSL - 1090 when right clicking on the RT Queue form
*/

vars
	lQueue 		: CM_RadioTelemetryQueue;
	idx			: Integer;
	i			: Integer;
	lCaption	: String;
	mnuChild	: MenuItem;
	mnuIndex 	: Integer;
	count		: Integer;
	obj			: Object;
	task		: CM_RTQueueTask;
	aJob		: CM_Job;
	theVoyageJob,
	aVoyageJob 			: CM_VoyageJob;
	aVoyageRequest 		: CM_VoyageRequest;
	aVoyageAllocation 	: CM_VoyageAllocation;
	theVoyage 			: CM_Voyage;
	theVoyageJobs		: CM_JobSet;
	aRequest 			: CM_Request;
begin
	
	count := 2;
	while true do
		obj := self.mnuMoveTask.getMenuItem(count);
		if obj = null then
			break;
		endif;
		delete obj;
		count := count + 1;
	endwhile;
	
	self.mnuMoveTask.enabled := false;
	
	task := self.myCurrentTask;	
	
	if task = null then
		return;
	endif;
	
	if task.ti = null then // no cargo so no point moving it.
		return;
	endif;
	// we need to see if this task is for a voyage allocation load job	
	// then we need to see if there are other jobs for the same allocation with free slots &amp; wle's with unasigned cargo.
	// then we can build the menu!
	
	aJob := task.myEntry.myJob;
	
	
	
	if not aJob.isKindOf(CM_VoyageJob) then // only for voyage jobs
		return;
	else
		theVoyageJob := aJob.CM_VoyageJob;
	endif;
	
	aRequest := task.myEntry.myWorkListEntry.myRequest;
	
	aVoyageAllocation :=aRequest.getFirstAllocation();  //should only be one anyhow.
	
	if aVoyageAllocation = null then //has to be a voyage allocation job
		return;
	endif;
	
	// ok so we are a task with a ti and for a voyage alloc load job
	
	create theVoyageJobs transient;

	foreach aRequest in aVoyageAllocation.allSlotRequests do
		if aRequest.myJob = theVoyageJob then
			continue;
		endif;
		
		if aRequest.allWorkListEntries.first = null then	//Bug 44998
			continue;										//Bug 44998
		endif;												//Bug 44998
		
		if aRequest.allWorkListEntries.first.myTrackedItem = null then
			aVoyageJob := aRequest.myJob.CM_VoyageJob;
			if aVoyageJob&lt;&gt; null and aVoyageJob.isLoadedToOperations then
				theVoyageJobs.addNoDuplicates(aVoyageJob,false);
			endif;
		endif;
	endforeach;
	
	foreach aRequest in aVoyageAllocation.allRequests do
		if aRequest.myJob = theVoyageJob then
			continue;
		endif;
		if aRequest.allWorkListEntries.first = null then
			continue;
		endif;
		
		if aRequest.allWorkListEntries.first.myTrackedItem = null then
			aVoyageJob := aRequest.myJob.CM_VoyageJob;
			if aVoyageJob&lt;&gt; null and aVoyageJob.isLoadedToOperations then
				theVoyageJobs.addNoDuplicates(aVoyageJob,false);
			endif;
		endif;
	endforeach;	
		
	
	self.mnuMoveTask.enabled := not theVoyageJobs.isEmpty;
	self.mnuMoveTask.visible := not theVoyageJobs.isEmpty;
	self.mnuMoveToJobSub.visible := false;
	self.mnuMoveToJobSub.enabled := false;
	
	/*if process.isRJD then
	theVoyageJobs.inspectModal;
	endif;
	*/
	idx := 1;
	foreach aJob in theVoyageJobs do
		idx := idx + 1;
		lCaption := aJob.id;
		mnuChild := self.mnuMoveToJobSub.getMenuItem(idx); // check if the menu is already cloned
			if mnuChild = null then
				mnuChild := mnuMoveToJobSub.loadMenu(idx); // Clone menu	
			endif;
			mnuChild.caption := lCaption;
			mnuChild.visible := true;
			mnuChild.enabled := true;
			mnuChild.userObject := aJob;
	endforeach;
	
	
	
epilog
	delete theVoyageJobs;
end;</source>
    </JadeMethod>
    <JadeMethod name="canAmendTaskICTarget" id="49a166d6-238f-450c-941c-b2e49c58c3e9">
        <source>canAmendTaskICTarget(): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 January 2011	cnwer1	Initial creation

*/

vars
	lTask : CM_RTQueueTask;
begin
	if self.myCurrentTask.status = TASK_COMPLETE then
		return false;
	endif;
	// if this is an IMV task then only let them change this target location if it is going to a Interchange area
		// not an RTG interchange are
		// then we should only let them change to interchange area assoicated with the ultimate target location
	if self.myCurrentTask.taskType &lt;&gt; TASK_MOVE  and  self.myCurrentTask.taskType &lt;&gt; TASK_DIRECTOR then
		if self.myCurrentTask.taskType = TASK_PICKUP then
			lTask:=self.myCurrentTask.myEntry.findTaskOfType(TASK_SETDOWN,NULL_INTEGER);
		elseif self.myCurrentTask.taskType = TASK_SETDOWN then
			lTask:=self.myCurrentTask;
		endif;
		
		if lTask = null then  //cnwrd1 par 26734 CCMS 2014 plan on pickup , bit hacky
			return false;
		endif;
		
		if lTask.myEntry.myNextRelatedEntry &lt;&gt; null then
			if lTask.machineTypeGroup = MACHINETYPEGRP_SOURCEIC or lTask.machineTypeGroup = MACHINETYPEGRP_TARGETIC then
				if not lTask.targetLocation.isKindOf(CM_GantryICAreaLaneController) then
					// going to ic area then  if amending this task should only let them change to a new ic area / ic grid location
					return true;
				endif;
			endif;
		endif;
	endif;

	return false;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkCurrentObjects" id="f2fd74b5-e410-4abb-b4fc-a159b3d951b3">
        <source>checkCurrentObjects() : Boolean;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	invalidObj : Boolean;
	objEdition : Integer;
begin
	
	on Exception do app.handleDeletedObject(exception,self.myCurrentTask,invalidObj);
	on Exception do app.handleDeletedObject(exception,self.myCurrentEntry,invalidObj);
	
	if self.myCurrentEntry = null 
	or self.myCurrentTask = null then
		self.messageSelect();
		return false;
	endif;
	
	//epr par 27083 18/2/2011 also check for invalid objects
	objEdition:=self.myCurrentTask.edition;
	if invalidObj then
		return false;
	endif;
	
	objEdition:=self.myCurrentEntry.edition;
	if invalidObj then
		return false;
	endif;
	return true;
end;</source>
        <ReturnType type="Boolean"/>
