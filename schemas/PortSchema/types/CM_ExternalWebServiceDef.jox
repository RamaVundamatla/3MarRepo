    <JadeMethod name="comboWebServiceType" id="338ccc52-f41e-49f8-b3e6-a6670efb3d5b">
        <options>4</options>
        <source>comboWebServiceType(_combo : ComboBox input; _agent : CM_EWSTypeAgent) typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/06/2019	jlger1	Initial creation 45207
09/04/2020	jlgdap1	TFS 49003 MTN API Inline Agent
21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice
11 Oct 2021 jlier1	TFS 51963
10 Oct 2022	jlika1	TFS 54892 - POB - Vessel, Voyage and Movement EDI Messages
02 Nov 2022	navpw1	TFS: 55215 - Added EDBIC interface to the web service type combo box
06 Dec 2022	navdap1	TFS 55159 MTN - Export CAMS to JSON API Endpoint
13 Nov 2023 navra1  TFS 54090 - EUP | EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR 61386/Task - 61389)


17 Dec 2024 EWS types are now modules on a new license. This overrides the checks that used to be use for OpsView and VBS slots.
*/

vars
	idx: Integer;
	ewsType : CM_ExternalWebServiceType;
	expDate : Date;
begin
	_combo.clear();
	_combo.sorted := true;
	
	// ### JIRA 33544 17DEC2024 NAVAB1
	foreach ewsType in _agent.allEWSTypesByType do
		if ewsType.canDo() then	
			idx:=_combo.addItem(ewsType.name);
			_combo.itemObject[idx] := ewsType.classToCreate();
		endif;
	endforeach;
	
	
	/*
	idx:=_combo.addItem(ExternalWebServiceCARGOCHAIN);
	_combo.itemObject[idx] := CM_CargoChainServiceDef;
	idx:=_combo.addItem(ExternalWebServiceSAP);
	_combo.itemObject[idx] := CM_SAPWebService;
	idx:=_combo.addItem(ExternalWebServiceKiwiRail); 			// TFS 40360
	_combo.itemObject[idx] := CM_KiwiRailCheckInWSDef; 		// TFS 40360
	idx:=_combo.addItem(ExternalWebServiceNavisMACS3);			// TFS 49003
	_combo.itemObject[idx] := CM_NavisMACS3Service;			// TFS 49003
	idx:=_combo.addItem(ExternalWebServiceAllotrac);			   //04 Aug 2020	NDL	TFS 49869
	_combo.itemObject[idx] := CM_AllotracServiceDef;		   //04 Aug 2020	NDL	TFS 49869
	
	if app.myRoot.canDo(Sub_OpsView) then				   //21.09.2020 cnwma1 #49906
		idx:=_combo.addItem(ExternalWebServiceOPSVIEW);	       //21.09.2020 cnwma1 #49906
		_combo.itemObject[idx] := CM_OpsViewServiceDef;	   //21.09.2020 cnwma1 #49906
	endif;
	
	if app.myCurrentUserCan(null, PmGateReleaseRequestByPin) then
		idx:=_combo.addItem(ExternalWebService1StopVBS);		// ### TFS 52268 16Dec2021 NAVPW1
		_combo.itemObject[idx] := CM_1StopVBSWebServiceDef;		// ### TFS 52268 16Dec2021 NAVPW1
	endif;
	
	idx:=_combo.addItem(ExternalWebServiceEDBIC);			// ### TFS 55215 02Nov2022 NAVPW1
	_combo.itemObject[idx] := CM_CuxportServiceDef;			// ### TFS 55215 02Nov2022 NAVPW1
	
	idx:=_combo.addItem(ExternalWebServiceQships);
	_combo.itemObject[idx] := CM_QshipsWebServiceDef;
	
	idx := _combo.addItem(ExternalWebServiceAPIEndpoint);	// TFS 55159
	_combo.itemObject[idx] := CM_APIEndpointServiceDef;		// TFS 55159
	
	idx := _combo.addItem(ExternalWebServiceFinanceOne);	//TFS 56856 jlier1 28/3/23
	_combo.itemObject[idx] := CM_FinanceOneSeviceDef;	
	
	idx := _combo.addItem(ExternalWebServiceInvoiceAPI);	//navra1 - TFS 54090(CR 61386/Task - 61389) - 13th Nov 2023
	_combo.itemObject[idx] := CM_InvoiceAPIServiceDef;		//navra1 - TFS 54090(CR 61386/Task - 61389) - 13th Nov 2023
	*/
epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_agent" type="CM_EWSTypeAgent"/>
    </JadeMethod>
