<GUIClass name="CMUI_MultiAlignGroupBox" id="99c14e54-50f0-4046-b81e-67f4ecea1a6f">
    <superclass name="CMUI_MultiSelectGroupBox"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>This has 2 tables - left and right. You display info in both and then use up and down arrows to align the entries</text>
    <DbClassMap file="_usergui"/>
    <JadeMethod name="buildSelf" id="a436ea22-253c-4015-b9f4-e61cbc3e44f0">
        <updating/>
        <source>buildSelf() updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	self.myAvailableListBox.multiSelect := ListBox.MultiSelect_None;
	self.mySelectedListBox.multiSelect := ListBox.MultiSelect_None;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcResizeContents" id="7a1e702f-2aee-4a75-9549-b3fc11912c99">
        <updating/>
        <source>cnEcResizeContents() updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myAvailableListBox.visible then
		inheritMethod();
	else
		// we are only showing the right hand box so resize it.
		self.mySelectedLbl.move(5,5,self.width - 40, 15);
		self.mySelectedListBox.move(5,self.mySelectedLbl.top + self.mySelectedLbl.height + 5,self.clientWidth - 40, self.clientHeight -25);
		self.myUpSelectedBtn.move(self.mySelectedListBox.left + self.mySelectedListBox.width + 5,self.mySelectedListBox.top,self.myUpSelectedBtn.width, self.myUpSelectedBtn.height);
		self.myDownSelectedBtn.move(self.myUpSelectedBtn.left,self.myUpSelectedBtn.top + self.myUpSelectedBtn.height + 5,self.myUpSelectedBtn.width, self.myUpSelectedBtn.height);
	//	self.myAddAllBtn.move(self.mySelectedListBox.left + self.mySelectedListBox.width + 5,self.mySelectedListBox.top,self.myUpSelectedBtn.width, self.myUpSelectedBtn.height);
//		self.myRemoveAllBtn.move(self.myUpSelectedBtn.left,self.myUpSelectedBtn.top + self.myUpSelectedBtn.height + 5,self.myUpSelectedBtn.width, self.myUpSelectedBtn.height);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="getItemsOnLeftSide" id="7219d7ff-f3ea-437d-97ea-6a6ff1cbe989">
        <source>getItemsOnLeftSide(_aCollection : Any);
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	i	: Integer;
	obj	: Object;
	tmpCol	: Collection;

begin

	tmpCol := _aCollection.Collection;
	
	foreach i in 1 to self.myAvailableListBox.listCount do
		obj := self.myAvailableListBox.itemObject[i];
		tmpCol.add(obj);
	endforeach;

end;</source>
        <Parameter name="_aCollection" type="Any"/>
    </JadeMethod>
    <JadeMethod name="getItemsOnRightSide" id="cd3f0e42-c115-476c-a438-7229e76f6484">
