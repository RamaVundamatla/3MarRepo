    <JadeMethod name="btnShowPlanning_click" id="6c6b95ca-b7a0-44b0-ae93-0f39d0427cac">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnShowPlanning_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		12 September 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	bay1, bay2 : CM_Bay;
	aJob : CM_Job;
begin
	aJob := self.allJobs.first;
	if aJob &lt;&gt; null then
		aJob.CM_VoyageJob.getBays(bay1, bay2);
	endif;
	self.myAssistant.showVoyagePlanningForm(self.myCurrentVoyage,bay1,ShpDisplayMode_ColCodeLoad, self.myBorrowedMenuAction);
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
