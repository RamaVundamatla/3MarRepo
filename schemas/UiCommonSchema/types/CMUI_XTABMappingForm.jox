    <JadeMethod name="translateForm" id="6b50214a-aff6-4fa2-99ba-bcc20bf029f7">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017520, locale);
	btnAdd.translateCaption(Xlat_0013555, locale);
	btnDelete.translateCaption(Xlat_0013556, locale);
	btnMoveDown.translateCaption(Xlat_0013557, locale);
	btnMoveUp.translateCaption(Xlat_0013558, locale);
	btnUpdate.translateCaption(Xlat_0013559, locale);
	chkIncludeAll.translateCaption(Xlat_0013560, locale);
	grpDetails.translateCaption(Xlat_0013561, locale);
	grpMappings.translateCaption(Xlat_0013562, locale);
	grpOrder.translateCaption(Xlat_0013563, locale);
	grpOtherValues.translateCaption(Xlat_0013564, locale);
	lblAnd.translateCaption(Xlat_0013565, locale);
	lblDescription.translateCaption(Xlat_0013566, locale);
	lblMapValue.translateCaption(Xlat_0013567, locale);
	lblName.translateCaption(Xlat_0013568, locale);
	lblOperator.translateCaption(Xlat_0013569, locale);
	lblValue.translateCaption(Xlat_0013570, locale);
	optGrpHeading.translateCaption(Xlat_0013571, locale);
	optGrpProperty.translateCaption(Xlat_0013572, locale);
	optOrderMapping.translateCaption(Xlat_0013573, locale);
	optOrderValue.translateCaption(Xlat_0013574, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtDescription_lostFocus" id="7d248963-ce06-467b-9204-d6cc611282f0">
