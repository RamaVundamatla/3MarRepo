    <JadeMethod name="cp002_CN_lstTest_click" id="1cc49c6c-1494-42d4-b3bf-35ec1e87527b">
        <updating/>
        <source>cp002_CN_lstTest_click():Integer updating;

vars
	keyCode:Integer;
begin
	myCM_ErrorWarningForm_1:=app.getForm('CM_ErrorWarningForm').CM_ErrorWarningForm;
	myCMUI_Navigator_1:=app.getForm('CMUI_Navigator').CMUI_Navigator;
	myCMS_UserMessageForm_1:=app.getForm('CMS_UserMessageForm').CMS_UserMessageForm;
	myCMUI_SuperAppForm2_1:=app.getForm('CMUI_SuperAppForm2').CMUI_SuperAppForm2;
	keyCode:=9;
	myCMUI_Navigator_1.lstTest.keyUp(myCMUI_Navigator_1.lstTest, keyCode, 0);
	app.doWindowEvents(shortPause);
	keyCode:=18;
	myCMUI_Navigator_1.lstTest.keyDown(myCMUI_Navigator_1.lstTest, keyCode, 4);
	app.doWindowEvents(shortPause);
	keyCode:=9;
	myCMUI_Navigator_1.lstTest.keyUp(myCMUI_Navigator_1.lstTest, keyCode, 4);
	app.doWindowEvents(shortPause);
	keyCode:=18;
	myCMUI_Navigator_1.lstTest.keyUp(myCMUI_Navigator_1.lstTest, keyCode, 0);
	app.doWindowEvents(shortPause);
	app.doWindowEvents(shortPause);
	myCMUI_Navigator_1.lstTest.listIndex:=app.atcgGetListHierarchicalIndex(myCMUI_Navigator_1.lstTest, 'Port Otago|Voyage Functions|Planning|LOLO Planning|', 122);
	myCMUI_Navigator_1.lstTest.itemSelected[myCMUI_Navigator_1.lstTest.listIndex]:=true;
	myCMUI_Navigator_1.lstTest.click(myCMUI_Navigator_1.lstTest);  // 14:42:23
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
