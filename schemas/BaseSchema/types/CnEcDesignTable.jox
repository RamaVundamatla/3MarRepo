    <JadeMethod name="addNewColumn" id="32830ef0-3efd-4138-863f-e71d59ada1d1">
        <updating/>
        <source>addNewColumn(caption : String) updating;

vars

begin
	insertNewColumn(self.columns + 1, caption);
end;</source>
        <Parameter name="caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="addNewRow" id="9ea7e0ba-15db-4435-b670-689b823da495">
        <updating/>
        <source>addNewRow(obj : Object) updating;

vars

begin
	if excludeObject(obj) then
		rowsHaveBeenExcluded := true;
	else
		self.rows := self.rows + 1;
//		self.rowHeight[self.rows] := columnHeight;
		updateThisRow(obj, self.rows);
	endif;
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="addNewRowAt" id="48d6ebb2-3aec-49f8-8659-a59dfbc398cb">
        <updating/>
        <source>addNewRowAt(obj : Object; atRow : Integer) updating;

vars

begin
	self.addItemAt('', atRow);
//	self.rowHeight[atRow] := columnHeight;
	updateThisRow(obj, atRow);
end;</source>
        <Parameter name="obj" type="Object"/>
        <Parameter name="atRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="applyMoveColumn" id="f5070989-6d44-43cb-b7f7-5bcda53494e6">
        <updating/>
        <source>applyMoveColumn(fromColumn : Integer; toColumn : Integer) updating;

vars
	booleanInstance				: Boolean;
	stringInstance				: String;
	integerInstance				: Integer;
	fromCol						: Integer;
	toCol						: Integer;
begin
	self.moveColumn(fromColumn, toColumn);
	fromCol	:= fromColumn - 1;
	toCol	:= toColumn - 1;

	stringInstance := columnHeadingArray.removeAt(fromCol);
	columnHeadingArray.insert(toCol, stringInstance);

	stringInstance := columnAlignmentArray.removeAt(fromCol);
	columnAlignmentArray.insert(toCol, stringInstance);

	stringInstance := columnInputTypeArray.removeAt(fromCol);
	columnInputTypeArray.insert(toCol, stringInstance);

	stringInstance := columnVisibleArray.removeAt(fromCol);
	columnVisibleArray.insert(toCol, stringInstance);

	integerInstance := columnLengthArray.removeAt(fromCol);
	columnLengthArray.insert(toCol, integerInstance);

	integerInstance := columnWidthArray.removeAt(fromCol);
	columnWidthArray.insert(toCol, integerInstance);

	booleanInstance := columnPictureArray.removeAt(fromCol);
	columnPictureArray.insert(toCol, booleanInstance);
end;</source>
        <Parameter name="fromColumn" type="Integer"/>
        <Parameter name="toColumn" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="buildTableColumns" id="6946b019-9978-404b-b1d3-b895a9f777dc">
        <updating/>
        <source>buildTableColumns() updating, protected;

vars
	loopIndex					: Integer;
	maxIndex					: Integer;
	objectColumn				: Integer;
	format						: String;
	pos							: Integer;
	headerAlignment				: Integer;
	headerBold					: Boolean;
begin
	if self.isInPainter() then
		self.columns := columnHeadingArray.size();
	else
		 objectColumn := 1;
		 self.columns := columnHeadingArray.size() + 1;
		 self.columnVisible[1] := false;
	endif;
	self.row := 1;
	loopIndex := 1;
	maxIndex := columnHeadingArray.size();
	self.rowHeight[1] := columnHeight;
	allowsPictures := false;
	while loopIndex &lt;= maxIndex do
		self.setCellText(1, loopIndex + objectColumn, convertToCrLf(columnHeadingArray[loopIndex]));
		self.columnWidth[loopIndex + objectColumn] := columnWidthArray[loopIndex];
		self.columnVisible[loopIndex + objectColumn] := columnVisibleArray[loopIndex][1:1] = '1';
		self.column := loopIndex + objectColumn;
		self.accessMode := Table.AccessMode_Column;
		format := columnAlignmentArray[loopIndex];
		pos := 1;
		self.alignment := format.cnEcNextDelimitedField('\', pos)[1:1].Integer;
		self.inputType := columnInputTypeArray[loopIndex][1:1].Integer;
//		self.maxLength := columnLengthArray[loopIndex];
		self.accessMode := Table.AccessMode_Sheet;

		headerAlignment := format.cnEcNextDelimitedField('\', pos)[1:1].Integer;
		if headerAlignment &gt; 0 then
			self.accessMode := Table.AccessMode_Cell;
			self.alignment := headerAlignment;
			self.accessMode := Table.AccessMode_Sheet;
		endif;
		headerBold := format.cnEcNextDelimitedField('\', pos) = 'true';
		if headerBold then
			self.accessMode := Table.AccessMode_Cell;
			self.fontBold := headerBold;
			self.accessMode := Table.AccessMode_Sheet;
		endif;

		if columnPictureArray[loopIndex] then
			allowsPictures := true;
		endif;
		loopIndex := loopIndex + 1;
	endwhile;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="changeColumnHeading" id="7ab02f7a-312a-4595-8778-3b30b345023c">
        <updating/>
        <source>changeColumnHeading(thisColumn : String; thatColumn : String) updating;
/*
	External Method	:	This method is to be used by implementors of this Custom Control

	Purpose			:	To enable you to change the heading text of a column and continue
						to process the table irrespective of this change

	Usage			:	This method should be used as follows:
*/
vars
	loopIndex			: Integer;
	heading				: String;
begin
	loopIndex	:= 1;
	foreach heading in columnHeadingArray do
		loopIndex := loopIndex + 1;
		if heading = thisColumn then
			columnHeadingArray.replace(loopIndex, thatColumn);
			self.setCellText(1, loopIndex, thatColumn);
			break;
		endif;
	endforeach;
end;</source>
        <Parameter name="thisColumn" type="String"/>
        <Parameter name="thatColumn" type="String"/>
    </JadeMethod>
    <JadeMethod name="clear" id="d78d6ec3-4cdd-416c-9c84-0a3334ef7f3e">
        <updating/>
        <source>clear()updating;
/*
	Purpose:	
	Parameters:	none
	Returns:	nothing	
*/
vars
	loopIndex				: Integer;
	maxIndex				: Integer;
begin
	/*	Cancel all notification requests */

	if showUpdates then
		maxIndex := self.rows;
		loopIndex := 2;
		self.column := 1;
		while loopIndex &lt;= maxIndex do
			self.row := loopIndex;
			endNotification (self.itemObject, Object_Update_Event);	
			loopIndex := loopIndex + 1;
		endwhile;	
 	endif;

//	endNotificationForSubscriber(self);
	self.rows := 1;

end;</source>
    </JadeMethod>
    <JadeMethod name="click" id="152c4c16-bbc9-4a9e-8e18-441621d78df2">
        <updating/>
        <source>click(table : Table input) updating;

vars
	saveCol					: Integer;
	saveRow					: Integer;
	loopIndex				: Integer;
	maxIndex				: Integer;
begin
	app.mousePointer	:=	Busy;
	
	if self.row &gt; 1 then
		saveCol := self.column;
		saveRow := self.row;
		self.column := 1;
		selectedObject := self.itemObject;
		if self.multiSelect = 0 then
			self.selectRow();
		elseif self.multiSelect = 1 then
			self.column := 1;
		//	select or un-select the row
			if selectedObjects.includes(self.itemObject) then
				self.unselectRow();
				selectedObjects.remove(self.itemObject);
			else
				self.selectRow();
				selectedObjects.add(self.itemObject);
			endif;
			maxIndex := self.rows;
			loopIndex := 2;
			while loopIndex &lt;= maxIndex do
				self.row := loopIndex;
				if selectedObjects.includes(self.itemObject) then
					self.selectRow();
				endif;
				loopIndex := loopIndex + 1;
			endwhile;
		elseif self.multiSelect = 2 then
			// First work out if we need to reset the 'start' point for the select
			if selectedStart = null or not (shiftDown or cntlDown) then
				selectedStart:=self.itemObject;
				selectedObjects.clear();								
				selectedObjects.add(self.itemObject);
			elseif shiftDown then
				self.doMultiSelect();
			elseif cntlDown then
				// If we have cntrol down then toggle current object
				if selectedObjects.includes(self.itemObject) then
					selectedObjects.remove(self.itemObject);
				else
					selectedObjects.add(self.itemObject);
				endif;
			endif;

			// Reset the selected rows indicators for what is now selected
			self.clearAllSelected;
			maxIndex := self.rows;
			loopIndex := 2;
			while loopIndex &lt;= maxIndex do
				self.row := loopIndex;
				if selectedObjects.includes(self.itemObject) then
					self.selectRow();
				endif;
				loopIndex := loopIndex + 1;
			endwhile;
		endif;
		self.row	:= saveRow;
		self.column	:= saveCol;
	endif;

	if self.dropDown = Table.DropDown_Click then
		if not myVerticalScrollBar.visible then
			myVerticalScrollBar.visible := true;
			positionScrollbar();
		endif;
	endif;

	inheritMethod(table);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="closeup" id="c143b578-ebe5-40c1-a696-8aa9680f5509">
