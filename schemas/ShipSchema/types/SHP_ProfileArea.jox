    <JadeMethod name="isVoyageDecksOnly" id="e58303a9-fd19-4cc4-b5ff-f820eb131cf6">
        <source>isVoyageDecksOnly() : Boolean;
/*
Purpose:			
Date		Who		Reason
24 November 2011	cnwab1	Initial creation
*/

vars

begin
	return (self.allGridColumns.isEmpty() and self.allGridRows.isEmpty() and self.myCurrentVoyage.hasStructureOfType(CellularStructureRORO));

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreateDefault" id="c2fcfb06-2ca9-4141-bf4c-5cdb474c34ae">
        <updating/>
        <source>setForCreateDefault() updating;
/*
Purpose:	PAR 28701 - If there are no bays but there are decks we need to draw and 'empty' ship		
Date		Who		Reason
23 November 2011	cnwab1	Initial creation
*/

vars

begin
	// PAR 28701
	if not self.isVoyageDecksOnly() then
		return;
	endif;

	self.lastYAft := 250; 
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreateXML" id="190f37d5-7091-405a-8026-d9a63d5c3582">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>setForCreateXML(_theXMLString: String; _transitColour : Integer) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aLid : CM_HatchLid;
	aPoint : SHP_ProfilePoint;
	aBayRow		: SHP_BayRow;
	aBayCol		: SHP_BayColumn;
	aBayPoint		: SHP_BayPoint;
	theRow, theCol, pos,ordinal, alignment, lidTier, bridgeBay, totalCol  : Integer;
	firstX,firstY,lastX,lastY : Integer;
	theXMLTag, theXMLString, theXMLColours, pileWait : String;
	aOK : Boolean;
	theIndex, theColour : Integer;
	theCode : String;
	nullVoy : CM_Voyage;
	 flipH : Boolean;
begin
	if self.mySDF &lt;&gt; null then
		flipH := self.mySDF.drawInReverse;
	else
		flipH := not self.myCurrentVoyage.starboardBerthed;
	endif;
	nullVoy := self.myCurrentVoyage.myTerminal.getNullVoyage();
	self.myVoyageLayoutGraphic := nullVoy.myLayoutGraphic;
	self.myVoyageLayoutGraphic.getFirstLastPoints(CM_VoyageLayoutGraphic.INDEX_BRIDGE,firstX,firstY,lastX,lastY,flipH);
	
	if flipH then
		self.bridgeWidth := (firstX - lastX);
	else
		self.bridgeWidth := (lastX - firstX);
	endif;

	self.myVoyageLayoutGraphic.getFirstLastPoints(CM_VoyageLayoutGraphic.INDEX_CRANE1,firstX,firstY,lastX,lastY,flipH);
	
	if flipH then
		self.craneWidth := (firstX - lastX);
	else
		self.craneWidth := (lastX - firstX);
	endif;


	theXMLTag := _theXMLString.cnEcGetTagValueOfName("GO");
	theRow := theXMLTag[1:2].Integer;
	theCol := theXMLTag[3:2].Integer;
	self.column := theCol;
	self.row := theRow;
	self.drawMe := true;
	self.scaleXFactor := 2;
	
	theXMLTag := _theXMLString.cnEcGetTagValueOfName("lb");
	if theXMLTag &lt;&gt; null then
		self.label := theXMLTag;
	endif;
	self.displayMode := ShpDisplayMode_Defn;

	theXMLTag := _theXMLString.cnEcGetTagValueOfName("TR"); // ### ROWS ( TIERS )
	if theXMLTag &lt;&gt; null then
		foreach theRow in 1 to theXMLTag.Integer do
			create aBayRow transient;
			aBayRow.setForCreate(null,theRow, self);
			
		endforeach;
	endif;
	theXMLTag := _theXMLString.cnEcGetTagValueOfName("TC"); // ### COLUMNS ( BAYS )
	if theXMLTag &lt;&gt; null then
		totalCol := theXMLTag.Integer;
		theXMLTag := _theXMLString.cnEcGetTagValueOfName("AB");
		if theXMLTag &lt;&gt; null then
			bridgeBay := theXMLTag.Integer;
		endif;
		aOK := false;

		foreach theCol in 1 to totalCol  do
				if bridgeBay = theCol then
					aOK := true;
				endif;
			create aBayCol transient;
			
			alignment := theCol;
			
			
			aBayCol.setForCreate(null,theCol, self, alignment ,null);
			aBayCol.afterBridge := aOK;
		endforeach;
	endif;
	theXMLTag := _theXMLString.cnEcGetTagValueOfName("RLS");
	if theXMLTag &lt;&gt; null then
		setForCreateXMLRows(theXMLTag);
	endif;
	theXMLTag := _theXMLString.cnEcGetTagValueOfName("CLS");
	if theXMLTag &lt;&gt; null then
		setForCreateXMLCols(theXMLTag);
	endif;
	// #################
	// POINTS  
	pos := 1;
	while (pos &lt;&gt; 0) do
		theXMLString := _theXMLString.cnEcGetNextTagValueOfName("GP",pos);  
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. " &amp; pos.String &amp; " &gt;&gt;&gt;" &amp; theXMLString &amp; "&lt;&lt;&lt;");

		theXMLTag := theXMLString.cnEcGetTagValueOfName("Row");  
		theRow := theXMLTag.Integer;
		theXMLTag := theXMLString.cnEcGetTagValueOfName("Col");  
		theCol := theXMLTag.Integer;
		if self.allGridPoints[theRow,theCol] = null then
			create aPoint transient;
			aPoint.setForCreateMT(theCol, theRow, self);
			aPoint.setForCreateXML(theXMLString);
		else
			theXMLTag := theXMLString.cnEcGetTagValueOfName("BY");  

		endif;
		if pos = 0 then // PAR 6821 moved down here as it is finding a tier but is also returning zero!
			break;
		endif;
	endwhile;

	// PAR 28701
	if self.isVoyageDecksOnly() 
	and aPoint &lt;&gt; null then
		aPoint.setForCreateDefault();
	endif;

end;</source>
        <Parameter name="_theXMLString" type="String"/>
        <Parameter name="_transitColour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreateXMLCols" id="180412c0-2a14-4ec9-bb35-baa07ebb5a6f">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>setForCreateXMLCols(_theXMLString: String) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	onshipCrane, theRow, theCol, pos,ordinal : Integer;
	theXMLTag : String;
	alignment : Real;
	theGridColumn : CMUI_GridColumn;
begin
	// #################
	// ROWS  
	pos := 1;
	while (pos &lt;&gt; 0) do

		theXMLTag := _theXMLString.cnEcGetNextTagValueOfName("AL",pos);  
		if theXMLTag = null then
			break;
		endif;
		alignment := alignment + theXMLTag.Real;

		
		theXMLTag := _theXMLString.cnEcGetNextTagValueOfName("CL",pos);  
		theCol := theCol + 1;
		theGridColumn := self.allGridColumns[theCol];
		theGridColumn.label := theXMLTag;

		theXMLTag := _theXMLString.cnEcGetNextTagValueOfName("OSC",pos);  
		onshipCrane := theXMLTag.Integer;
		theGridColumn.SHP_BayColumn.onShipCrane := onshipCrane;

		theGridColumn.SHP_BayColumn.allignment := theGridColumn.SHP_BayColumn.allignment + alignment;
	endwhile;



end;</source>
        <Parameter name="_theXMLString" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreateXMLRows" id="1fd55b07-2fd1-454a-8a21-a8ca6164e3d4">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>setForCreateXMLRows(_theXMLString: String) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	theRow, theCol, pos,ordinal : Integer;
	theXMLTag : String;
	alignment : Real;
	theGridRow : CMUI_GridRow;
begin
	// #################
	// ROWS  
	pos := 1;
	while (pos &lt;&gt; 0) do

		theXMLTag := _theXMLString.cnEcGetNextTagValueOfName("RL",pos);  
		if theXMLTag = null then
//		if pos = 0 then
			break;
		endif;
		theRow := theRow + 1;
		
		theGridRow := self.allGridRows[theRow];
		theGridRow.label := theXMLTag;
		theXMLTag := _theXMLString.cnEcGetNextTagValueOfName("OD",pos);  
		theGridRow.SHP_BayRow.onDeck := (theXMLTag = "Y");
	endwhile;



end;</source>
        <Parameter name="_theXMLString" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreateXMLSlots" id="3d3fce6d-a293-47a7-b165-472feaff60d9">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>setForCreateXMLSlots(_theXMLString: String) updating, clientExecution;
// not used, but keep
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aSlot : CM_SlotDefn;
	aProfileRow		: SHP_BayRow;
	aProfileCol		: SHP_BayColumn;
	aProfilePoint		: SHP_ProfilePoint;
	theRow, theCol, pos,ordinal : Integer;
	theXMLTag : String;
	alignment : Real;
	theXMLString: String;
begin
	theXMLString := _theXMLString;

	// #################
	// SLOTS  
	pos := 1;
	while (pos &lt;&gt; 0) do

		theXMLTag := theXMLString.cnEcGetNextTagValueOfName("SD",pos);  
		aSlot := theXMLTag.asOid.CM_SlotDefn;
		if pos = 0 then
			break;
		endif;

		theXMLTag := theXMLString.cnEcGetNextTagValueOfName("Ord",pos);  
		theCol := theXMLTag[1:2].Integer;
		theRow := theXMLTag[3:2].Integer;
		if pos = 0 then
			break;
		endif;
		

		if self.allGridColumns[theCol] = null then
			create aProfileCol;
			alignment :=  theXMLString.cnEcGetNextTagValueOfName("al",pos).Real;
			aProfileCol.setForCreate(theXMLTag,theCol, self,alignment,null);

		endif;
		if self.allGridRows[1] = null then
			create aProfileRow;
			aProfileRow.setForCreate("01",1, self);
		endif;
		theXMLTag := theXMLString.cnEcGetNextTagValueOfName("na",pos);  

		create aProfilePoint transient;
		aProfilePoint.setForCreateMT(theCol, theRow, self);
		aProfilePoint.mySlotDefn := aSlot;
		aProfilePoint.bayDefnUnavailable := theXMLTag.Integer.Boolean;
	endwhile;

end;</source>
        <Parameter name="_theXMLString" type="String"/>
    </JadeMethod>
    <JadeMethod name="setGridRowColPositions" id="22b53a45-a8db-4da2-8965-2a8760ab2c16">
        <updating/>
        <source>setGridRowColPositions() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	theRowHeight,
	theColWidth : Real;
	tmpRow			: CMUI_GridRow;
	tmpCol			: CMUI_GridColumn;
	aBayCol			: SHP_BayColumn;
	aBayRow : SHP_BayRow;
	tmpPos1,tmpPos2			: Real;	
	theTopMargin 			: Integer;
	spacing,theLeftMargin, numCranes			: Integer;
	afterBridge, beforeCrane, afterCrane, flipH : Boolean;
	deckY, firstX, firstY, lastX, lastY		: Integer;	// cnwvu1 15/11/2006	ccms1048
	moveBaysDownBecauseOfCranes				: Integer;	// cnwvu1 15/11/2006	if there is no space for cranes, we'll move down all Bays
	craneHeight, bayIdHeight, topMarginBayId: Integer;// cnwvu1 15/11/2006
	
begin
	flipH := self.mySDF.drawInReverse;

	if self.hasColumnsBeforeBridge then
		theLeftMargin := 12;
		if flipH then
			theLeftMargin := theLeftMargin + 30;
		elseif not self.hasColumnsAfterBridge then
			theLeftMargin := theLeftMargin + self.bridgeWidth + 2;
		endif;	
	else
		theLeftMargin := 10; //self.bridgeWidth;
		if flipH then
			theLeftMargin := theLeftMargin + 55;
		else
			theLeftMargin := theLeftMargin + 5;
		endif;	
	endif;
	theRowHeight := RowHeightSide *  self.scaleYFactor;
	theColWidth	 := ColWidthSide * self.scaleXFactor;
	theTopMargin := 110;

	deckY := 0;	// cnwvu1 15/11/2006
	foreach tmpRow in self.allGridRows do
		aBayRow := tmpRow.SHP_BayRow;
		
		if not aBayRow.onDeck then
			spacing := 0;
		else
			spacing := 0;
		endif;
		tmpPos1 := theTopMargin + ((tmpRow.row - 1) * theRowHeight) +  spacing;
		tmpPos2 := tmpPos1 + theRowHeight;
		tmpRow.setYPos(tmpPos1, tmpPos2);
		if aBayRow.onDeck then	// cnwvu1 15/11/2006
			deckY := tmpPos1.Integer;
		endif;
	endforeach;
	
	foreach tmpCol in self.allGridColumns do
		aBayCol := tmpCol.SHP_BayColumn;

		if flipH then
			beforeCrane := (aBayCol.onShipCrane = BayOnShipCrane_Before);
			if beforeCrane then
				numCranes := numCranes + 1;
			endif;
		else
			afterCrane := (aBayCol.onShipCrane = BayOnShipCrane_After);
			if afterCrane then
				numCranes := numCranes + 1;
			endif;
		
		endif;
		afterBridge := aBayCol.afterBridge;

		tmpPos2 := 	((aBayCol.allignment) * theColWidth) + theLeftMargin;

		if afterBridge   then
			tmpPos2 := tmpPos2 + (self.bridgeWidth * self.scaleXFactor);
		endif;

		if flipH then
			tmpPos2 := tmpPos2 + ((self.craneWidth * numCranes)* self.scaleXFactor);
		else
			tmpPos2 := tmpPos2 + ((self.craneWidth * numCranes)* self.scaleXFactor);
		endif;

		tmpPos1 := tmpPos2 - theColWidth;
		
		tmpCol.setXPos(tmpPos1, tmpPos2);

		if flipH then
			afterCrane := (aBayCol.onShipCrane = BayOnShipCrane_After);
			if afterCrane then
				numCranes := numCranes + 1;
			endif;
		else
			beforeCrane := (aBayCol.onShipCrane = BayOnShipCrane_Before);
			if beforeCrane then
				numCranes := numCranes + 1;
			endif;
		
		endif;
	endforeach;

	// we will move down all bays if there is not enough space for cranes	cnwvu1 14/11/2006 ccms1048
	if deckY &gt; 0 then
		self.myVoyageLayoutGraphic.getFirstLastPoints(CM_VoyageLayoutGraphic.INDEX_CRANE1, firstX,firstY, lastX,lastY, self.mySDF.drawInReverse);
		craneHeight		:= lastY - firstY;
		bayIdHeight		:= self.getHeightForBayId();
		topMarginBayId	:= self.getTopMarginForBayId();
		if deckY - craneHeight - bayIdHeight &lt; topMarginBayId then
			moveBaysDownBecauseOfCranes := topMarginBayId - (deckY - craneHeight - bayIdHeight);
			foreach tmpRow in self.allGridRows do
				aBayRow := tmpRow.SHP_BayRow;
				tmpRow.setYPos(aBayRow.y1 + moveBaysDownBecauseOfCranes, aBayRow.y2 + moveBaysDownBecauseOfCranes);
			endforeach;
		endif;	
	endif;
	
	// add 2 extras for drawing special effects
	self.totalPointHeight := ((self.allGridRows.size) * theRowHeight);
	// we add this to allow for the draw special after. the extra rows should be enough for labels etc
	self.totalPointHeight := self.totalPointHeight + 300 + moveBaysDownBecauseOfCranes;
	if not  self.hasColumnsAfterBridge then
		self.totalPointWidth := tmpPos2 + theLeftMargin + self.bridgeWidth;
	else
		self.totalPointWidth := tmpPos2 + theLeftMargin;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setMyCurrentVoyage" id="1ef81787-759e-489e-9bc9-de782182840d">
        <updating/>
        <source>setMyCurrentVoyage(_voyage : CM_Voyage) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	self.myCurrentVoyage:=_voyage;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="updateFromNote" id="8d64b6a2-54b7-4930-b694-b7d2d4bd400c">
        <source>updateFromNote(_theRow, _theColumn : Integer;_controller : CM_LocationsController);
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars	
	aTier : CM_TierDefn;
	aSlotController : CM_SlotController;
	aPoint : SHP_ProfilePoint;
	aGPoint : CMUI_GridPoint;
	found : Boolean;
	xmlString : String;
	theRow, theColumn,total ,totalTODO : Integer;
	rightNow, rightThen : TimeStamp;
begin
	if _controller.isKindOf(CM_SlotController) then
		aSlotController := _controller.CM_SlotController;
	else
		return;
	endif;
	
	if not aSlotController.isLoadedToOps then
	//	return;
	endif;
	
	aTier := aSlotController.mySlotDefnVoyage.myTierDefinition;
	
	// ### match the tier to the GUI point
	foreach 	aGPoint in self.allGridPoints do
		aPoint := aGPoint.SHP_ProfilePoint;
		if aPoint.myTierDefn = aTier then
			found := true;
			break;
		endif;
	endforeach;
	if aPoint &lt;&gt; null and found then
		rightNow := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if aPoint.lastUpdateByNote &lt;&gt; null then
			rightThen := aPoint.lastUpdateByNote.cnEcAddSeconds(1);
		endif;
			
		if aPoint.lastUpdateByNote = null 
		or (aPoint.lastUpdateByNote &lt;&gt; null and rightNow &gt; rightThen) then
			xmlString := aTier.getXMLGridSideProfile(theRow, theColumn);
			aPoint.setForCreateXML(xmlString);
			aPoint.drawSelf(self.myGridAreaFrame);
			self.drawSpecialAfterColumn(aPoint.myGridColumn,total,totalTODO);
			self.drawSpecialAfterCrane();
//			self.mySDF.myParentForm.sendMsgWithParams("doNoteForObject", self); // this will update the macro info table
//		else
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. NOTE RECEIVED BUT NOT USED.");		
		endif;
	endif;
end;</source>
        <Parameter name="_theRow" type="Integer"/>
        <Parameter name="_theColumn" type="Integer"/>
        <Parameter name="_controller" type="CM_LocationsController"/>
    </JadeMethod>
</Class>
