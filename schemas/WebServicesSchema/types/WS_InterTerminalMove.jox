    <JadeMethod name="setProxyFromObject" id="c223e461-753a-46b9-a83d-8e4cc87f5608">
        <updating/>
        <source>setProxyFromObject(_object: CM_InterTerminalMove) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2017	cnwam15	Initial creation

*/

vars
	sourceTI : WS_TrackedItem;

begin
	
	inheritMethod(_object);
	create sourceTI transient;

	sourceTI.setProxyFromObject(_object.mySourceTI);
	
	self.cargoId := _object.cargoID;
	self.status := _object.status;
	self.mySourceTI := sourceTI;
	

epilog

end;</source>
        <Parameter name="_object" type="CM_InterTerminalMove"/>
