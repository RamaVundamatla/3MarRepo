    <JadeMethod name="trxUpdateTIUnpackComplete" id="35699853-fc38-4ae1-9112-66dc8080f3f9">
        <updating/>
        <source>trxUpdateTIUnpackComplete(_theProxyTI: CM_TrackedItem input; _passport: CM_Passport input; _unpackTime  : TimeStamp) updating;
//----------------------------------------------------------------
//	Created:	May 2007 cnwrs1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------
// 27/07/2009	consw1		PAR 20335 - SFW1075 To Do Task Scheduling
// 26/10/2021   navma1 		Bug 52255: SAL - Pack/Unpack Work Order issues
// 08 Feb 2023  navma1 		ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
// 09 Jan 2024	navma1  	Bug 60947: EUP - Cargo Scanning - Work order is not completed on unpacking all the child cargo items from scanning App
// 14 Mar 2024  navhl20 	ChangeRequest 62861: EUP | Retrospective Operations - [54177.090] - UnPack
// TFS BUG 65465 31JUL2024 NAVAB1 - a change to the storage triggers means that invoicing is wrong or does not occur at all. However if the TI transactions are deferred the invoicing will be deferred and the invoicing is correct.
// 18 Sep 2024  navma1      Bug 65975: Unpack Complete transaction is not updated with retrospective date and time if the job is completed using work order operations app
// 24 Sep 2024  navsp1      TFS ChangeRequest 65967: CUX | MasterTerminalAPI - Pack and Unpack APIs
//----------------------------------------------------------------

vars
	realTI	 : CM_TrackedItem;
	retroDT	 : TimeStamp;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	_passport.useTITransactionDeferUpdate := true;				 // ### TFS BUG 65465 31JUL2024 NAVAB1	

	realTI  := _theProxyTI.pxyGetRealObject();
	
	if _unpackTime &lt;&gt; null then										//TFS 65967
		retroDT	:= _unpackTime;										//TFS 65967
	else															//TFS 65967
		retroDT := realTI.getRetrospectiveDT(CM_WOUnpackJob);		//18.09.2024 navma1 #65975	
	endif;
	beginTransaction;

	app.myUtilityUA.utlUpdateTIUnpackComplete(_theProxyTI, realTI, retroDT, _passport);	//14.03.2024 navhl20 #62861

	if _passport.noErrors then 			// ### TFS BUG 65465 31JUL2024 NAVAB1	
		_passport.doDeferredUpdates();	// ### TFS BUG 65465 31JUL2024 NAVAB1	
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_theProxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_unpackTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTIWeightToDo" id="ba7b86ad-0fc8-4648-98c4-c2e00e590192">
        <updating/>
        <source>trxUpdateTIWeightToDo(	_pxyTI 				: CM_TrackedItem input; 
						_toDoTask			: Integer;
						_addingToDo			: Boolean;
						_weighTrx 			: Boolean;
						_comment			: String;
						_updateMode 		: Integer;
						_txnControllerDict 	: CMIF_TITxnContrlrByTypeDTDict;
						_wasAdjusted 		: Boolean;	//03 Feb 2021	TFS 50152
						_passport 			: CM_Passport input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/03/2010	cnwdap1	Initial creation PAR #23369
17/05/2023	jlika1	TFS 56398 EUP - OUT - Overlanded Cargo Handling - Web
*/
vars
	realTI : CM_TrackedItem;
	txnParams : CMIF_TITransactionController;
	doDiscrepancy : Boolean;
	priorWtValue : String;
	whereStr : String;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	if _pxyTI = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "TrackedItem", null, null);
	endif;
	
	// trx uses defered updates
	_passport.useTITransactionDeferUpdate	:= true;
	_passport.useTIDictDeferUpdate			:= true;
	
	//26 Mar 2015	NDL	Par 35920
	if _pxyTI.myCargoType.isBulkMulti then
		realTI := app.myProxyManager.getRealObject(_pxyTI).CM_TrackedItem;
		if realTI &lt;&gt; null and realTI.totalWeight &lt;&gt; _pxyTI.totalWeight then
			//Need a discrepancy created too...
			app.myValUA.valBreakBulkOverage(realTI, _pxyTI.totalQuantity, _pxyTI.totalWeight, false, _passport);
			if _passport.hasErrors then
				return;
			endif;
			doDiscrepancy := true;
		endif;
	endif;
	
	if _wasAdjusted then
		realTI := app.myProxyManager.getRealObject(_pxyTI).CM_TrackedItem;
		if realTI &lt;&gt; null then 
			priorWtValue := realTI.totalWeight.asStringJMT;
		endif;
	endif;
	
	beginTransaction;

	if doDiscrepancy then
		//26 Mar 2015	NDL	Par 35920
		app.myUtilityUA.utlBreakBulkOverage( realTI, _pxyTI.totalQuantity, _pxyTI.totalWeight, _pxyTI.weightCargo, _pxyTI.weightTare, null, false, false, false, _passport);
	else
		// update the tracked item from the proxy
		app.myUtilityUA.utlUpdateTrackedItem( _pxyTI, _comment, _updateMode, _txnControllerDict, null, null, _passport);//cnwrd1 28.8.09 par 20545
	endif;
	
	//13 Mar 2014	NDL	Par 33268
	realTI := app.myProxyManager.getRealObject(_pxyTI).CM_TrackedItem;
	if realTI &lt;&gt; null and _passport.noErrors() and _weighTrx then
		create txnParams transient;
		txnParams.type := TRANS_TYPE_WEIGH;
		txnParams.myTrackedItem := realTI;
		realTI.createTransaction(txnParams, app.myPassport);
	endif;
	
	// Add/remove to do task if we have one
	if _passport.noErrors() and _toDoTask &lt;&gt; null then
		if _addingToDo then
			// add the to do task
			realTI := app.myProxyManager.getRealObject(_pxyTI).CM_TrackedItem;
			app.myUtilityUA.utlUpdateTIToDoTaskAdd(realTI, _toDoTask, _passport);
		else
			// remove the to do task
			realTI := app.myProxyManager.getRealObject(_pxyTI).CM_TrackedItem;
			app.myUtilityUA.utlUpdateTIToDoTaskRemove(realTI, _toDoTask, _passport);
		endif;
	endif;
	
	//03 Feb 2021	NDL	TFS 50251
	if _passport.noErrors() and _wasAdjusted then
		whereStr := app.getCurrentContextNiceName();
		if whereStr = null then
			whereStr := "To Do Weight task";
		endif;
		realTI.recordWeightSetManually( "Weight manually adjusted via " &amp; whereStr &amp; ".", priorWtValue, realTI.totalWeight.asStringJMT, app.myPassport );
	endif;
	
	_passport.doDeferredUpdates();
	
epilog
	delete txnParams;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_toDoTask" type="Integer"/>
        <Parameter name="_addingToDo" type="Boolean"/>
        <Parameter name="_weighTrx" type="Boolean"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_updateMode" type="Integer"/>
        <Parameter name="_txnControllerDict" type="CMIF_TITxnContrlrByTypeDTDict"/>
        <Parameter name="_wasAdjusted" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTIandExtraInfo" id="ad8149ea-363d-43aa-b737-c400ce690e32">
        <updating/>
        <source>trxUpdateTIandExtraInfo(_pxyTI 					: CM_TrackedItem input;
					 	_updateMode 			: Integer;
						_extraParams			: CMIF_TIUpdateExtraParams;
					 	_txnControllerDict 		: CMIF_TITxnContrlrByTypeDTDict;
						_comment				: String;
					 	_passport 				: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2003	cnwth2
//
// Purpose:     Just calls toDoTasks utl, then udateTI utl
//			 
// Changed On	Changed By	Reason
// ----------   ----------  --------------------------------------------------
// 18/09/2017	jlgmd1		TFS 6813 - QNS - Jade application slow
// ---------------------------------------------------------------------------
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	_passport.useTITransactionDeferUpdate := true;		// TFS 6813
	_passport.useTIDictDeferUpdate := true;				// TFS 6813

	beginTransaction;
	
	app.myUtilityUA.utlUpdateTIAndExtraInfo(_pxyTI,	
											_updateMode,
											_extraParams,
											_txnControllerDict,
											_comment,
										 	_passport);
											
	if _passport.noErrors then				// TFS 6813
		_passport.doDeferredUpdates();		// TFS 6813
	endif;									// TFS 6813										
	
epilog	
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_updateMode" type="Integer"/>
        <Parameter name="_extraParams" type="CMIF_TIUpdateExtraParams"/>
        <Parameter name="_txnControllerDict" type="CMIF_TITxnContrlrByTypeDTDict"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTIsAssignToTrain" id="c60c59e2-95ab-42a0-b8a3-eacf66eb4327">
        <updating/>
        <source>trxUpdateTIsAssignToTrain(	_tiArray 	: CM_TIArray input;
							_train		: CM_Train;
							_tisWithWarnings : CM_TIArray input;
							_passport 	: CM_Passport input
							) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 August 2009	cnwndl1	Initial creation

*/

vars
	tmpTI : CM_TrackedItem;
	alertCreated : Boolean;
	errorSet	: CM_ErrorSet;	
	
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	app.myEventManager.setMultiTransactionTrx();
	
	create errorSet transient;

	foreach tmpTI in _tiArray do
		beginTransaction;
		
		if _passport.noErrors() then
			app.myUtilityUA.utlUpdateTIsAssignToTrain(tmpTI, _train, _passport);
		endif;
		
		if (not _passport.hasErrorsOrWarnings) and _passport.isOkToCommit(false) then
			app.cmsCommitTransaction(_passport);
		else
			app.cmsAbortTransaction;
			if _passport.hasErrors then
				app.convertErrorsWarningsToAlert(tmpTI.id &amp; app.getErrorString(Could_not_assign_to_train), _passport.allErrorWarnings);				
				alertCreated := true;
			elseif _passport.hasWarnings then
				_tisWithWarnings.add(tmpTI);
			endif;
			_passport.moveErrorsToSet(errorSet);
			_passport.initialiseTransaction();				
		endif;
	endforeach;

	if _passport.noErrors and (not process.isInTransactionState) then
		// Done so that finaliseActivityWithPassport will commit correctly
		beginTransaction;
	endif;
	_passport.addErrorsFromSet(errorSet);
	if alertCreated then
		app.raiseCMException1(SystemAlertCreated, app.getErrorString(Work_list_entries), null, self);
	endif;	
	
epilog

	self.finaliseActivityWithPassport(_passport);
	delete errorSet;
	
end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_tisWithWarnings" type="CM_TIArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTIsAutoplanToWagon" id="cf08d5f8-07b2-4f34-9d76-ce7d3a9f685e">
        <updating/>
        <source>trxUpdateTIsAutoplanToWagon(_tiArray 	: CM_TIArray input;
							_moveMode 	: Integer;
							_railArea	: CM_Rail;
							_train		: CM_Train;
							_wagon		: CM_Wagon;
							_tisWithWarnings : CM_TIArray input;
							_passport 	: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     July 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpTI : CM_TrackedItem;
	toLocn : CM_LocationsController;
	autoPlan,
	alertCreated : Boolean;
	moveController : CMIF_MoveController;
	errorSet	: CM_ErrorSet;	
	
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// DVB added 30/05/2005
	app.initialiseForStartAutoPlan(_passport);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	app.myEventManager.setMultiTransactionTrx();
	
	create errorSet transient;

	foreach tmpTI in _tiArray do
		beginTransaction;
		
		if _passport.noErrors() then
			app.myUtilityUA.utlUpdateTIsAutoplanToWagon(tmpTI, _moveMode, _railArea, _train, _wagon, _passport);
		endif;
		
		if (not _passport.hasErrorsOrWarnings) and _passport.isOkToCommit(false) then
			app.cmsCommitTransaction(_passport);
		else
			app.cmsAbortTransaction;
			if _passport.hasErrors then
				app.convertErrorsWarningsToAlert(tmpTI.id &amp; ' could not be auto-planned to a wagon', _passport.allErrorWarnings);				
				alertCreated := true;
			elseif _passport.hasWarnings then
				_tisWithWarnings.add(tmpTI);
			endif;
			_passport.moveErrorsToSet(errorSet);
			_passport.initialiseTransaction();				
		endif;
	endforeach;

	if _passport.noErrors and (not process.isInTransactionState) then
		// Done so that finaliseActivityWithPassport will commit correctly
		beginTransaction;
	endif;
	_passport.addErrorsFromSet(errorSet);
	if alertCreated then
		app.raiseCMException1(SystemAlertCreated, app.getErrorString(Work_list_entries), null, self);
	endif;	
	
epilog
	self.finaliseActivityWithPassport(_passport);
	delete errorSet;
	delete moveController;	
end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_railArea" type="CM_Rail"/>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_tisWithWarnings" type="CM_TIArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
