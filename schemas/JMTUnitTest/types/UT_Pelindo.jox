    <JadeMethod name="xmlForVoyageRequests_TAT2" id="6a42525e-92a9-47bd-b0c5-44bf32ddd1c7">
        <source>xmlForVoyageRequests_TAT2( _type : String ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2019	jlgndl1	Initial creation	TFS 44773

*/

constants
	
vars

	rawXmlString : String;
	terminal : CM_Terminal;
	
	now : TimeStamp;
	visitType : HMS_VisitType;
	arrivalDate : String;
	departureDate : String;
	
	vessel : CM_Vessel;
	voyage : CM_Voyage; 
	holdLocation1 : CM_GeneralCargoController;
	holdLocation2 : CM_GeneralCargoController;
	cargoType1 : CM_CargoType; 
	cargoType2 : CM_CargoType; 
	commodity1 : CM_Commodity;
	commodity2 : CM_Commodity; 
	operator : CM_Operator;
	voyageJobTransferType1 : CM_VoyageJobTransferType; 
	voyageJobTransferType2 : CM_VoyageJobTransferType;
	berth : HMS_Berth;
	estDate : Date;
	estDateString : String;
	homePort : String;
	cargoSubType1 : CM_Product;
	workpoint1 : CM_WorkPoint;
	workpoint2 : CM_WorkPoint;
	resourceType : HMS_ResourceType;
	resource : HMS_Resource;
	estDateToString : String;
	occursOnDTString : String;

begin

	terminal := self.getTerminal;

	if _type = CreateVoyageReq then
	
		now := app.actualTimeAppServer;
		arrivalDate := (now.date + 1).format("dd/MM/yyy");
		departureDate := (now.date + 3).format("dd/MM/yyy");
		visitType := app.myRoot.allVisitTypes.first;
	
rawXmlString := '&lt;request&gt;
&lt;warningsAcknowledged&gt;true&lt;/warningsAcknowledged&gt;
&lt;arrivalDate&gt;'&amp;arrivalDate&amp;'&lt;/arrivalDate&gt;
&lt;arrivalTime&gt;10:00&lt;/arrivalTime&gt;
&lt;departureDate&gt;'&amp;departureDate&amp;'&lt;/departureDate&gt;
&lt;departureTime&gt;22:10&lt;/departureTime&gt;
&lt;externalVoyageCode/&gt;
&lt;hasCargo&gt;true&lt;/hasCargo&gt;
&lt;lastPort&gt;JPABA&lt;/lastPort&gt;
&lt;lastPortOfCall&gt;AGANU&lt;/lastPortOfCall&gt;
&lt;nextPortOfCall&gt;DEABH&lt;/nextPortOfCall&gt;
&lt;operator&gt;'&amp;Operator_Code&amp;'&lt;/operator&gt;
&lt;operatorDischarge&gt;-1&lt;/operatorDischarge&gt;
&lt;operatorLoad&gt;-1&lt;/operatorLoad&gt;
&lt;originPort&gt;USAB3&lt;/originPort&gt;
&lt;vessel&gt;'&amp;Vessel_Name&amp;'&lt;/vessel&gt;
&lt;vesselCategory&gt;GEN&lt;/vesselCategory&gt;
&lt;visitType&gt;'&amp;visitType.getOidString&amp;'&lt;/visitType&gt;
&lt;voyageCode&gt;PELH0001&lt;/voyageCode&gt;
&lt;voyageIn/&gt;&lt;voyageOut/&gt;
&lt;/request&gt;';	

	elseif _type = CreateCargoReq then
	
	vessel := self.getVessel( Vessel_Name );
	voyage := vessel.allVoyagesByTermCodeArrival.first;
	estDate := voyage.estimatedDepartureDT.date;
	estDateString := estDate.format("dd/MM/yyy");
	holdLocation1 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.first;
	holdLocation2 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.last;
	cargoType1 := app.myRoot.getCargoTypeFromAbbrevOrDescr(CargoType1); 
	cargoType2 := app.myRoot.getCargoTypeFromAbbrevOrDescr(CargoType2);
	commodity1 := app.myRoot.allCommodities.getAtKey( Commodity1 );
	commodity2 := commodity1;
	operator := app.myRoot.allOperators.getAtKey( Operator_Code );
	voyageJobTransferType1 := app.myRoot.allVoyageJobTransferTypes.getMatchesDescription( TransferType1 );
	voyageJobTransferType2 := app.myRoot.allVoyageJobTransferTypes.getMatchesDescription( TransferType2 );
	berth := terminal.myHarbour.allBerths.getAtKey( Berth1Name );
	homePort := terminal.getConfig(PortDestCode).String;
	workpoint1 := terminal.allWorkPointsByCode[WorkPoint1];
	workpoint2 := terminal.allWorkPointsByCode[WorkPoint2];
	
rawXmlString := '&lt;_request&gt;
&lt;warningsAcknowledged&gt;true&lt;/warningsAcknowledged&gt;
&lt;allDocuments&gt;
&lt;WS_Document&gt;
&lt;description&gt;shite.txt&lt;/description&gt;
&lt;fileName&gt;shite.txt&lt;/fileName&gt;
&lt;heading&gt;Manifest&lt;/heading&gt;
&lt;/WS_Document&gt;
&lt;/allDocuments&gt;
&lt;allHMSResourcesUsed/&gt;
&lt;allVoyageHoldCargo&gt;
&lt;WS_VoyageHoldCargo&gt;
&lt;cmObjectId/&gt;
&lt;bolNumber/&gt;
&lt;cargoSubType&gt;'&amp;CargoSubType1&amp;'&lt;/cargoSubType&gt;
&lt;cargoType&gt;'&amp;cargoType1.getOidString&amp;'&lt;/cargoType&gt;
&lt;cargoWeight&gt;400000&lt;/cargoWeight&gt;
&lt;commodity&gt;'&amp;commodity1.getOidString&amp;'&lt;/commodity&gt;
&lt;consignee&gt;'&amp;Consignee_Code&amp;'&lt;/consignee&gt;
&lt;consignor&gt;'&amp;Consignor_Code&amp;'&lt;/consignor&gt;
&lt;dischargePort&gt;JPABA&lt;/dischargePort&gt;
&lt;estimatedEndDT&gt;'&amp;estDateString&amp;' 20:00&lt;/estimatedEndDT&gt;
&lt;estimatedStartDT&gt;'&amp;estDateString&amp;' 14:00&lt;/estimatedStartDT&gt;
&lt;freightForwarder&gt;'&amp;FreightF_Code&amp;'&lt;/freightForwarder&gt;
&lt;gangs&gt;2&lt;/gangs&gt;
&lt;holdLocation&gt;'&amp;holdLocation1.getOidString&amp;'&lt;/holdLocation&gt;
&lt;imexStatus&gt;2&lt;/imexStatus&gt;
&lt;loadPort&gt;'&amp;homePort&amp;'&lt;/loadPort&gt;
&lt;operator&gt;'&amp;operator.getOidString&amp;'&lt;/operator&gt;
&lt;tareWeight&gt;100000&lt;/tareWeight&gt;
&lt;totalQuantity&gt;500&lt;/totalQuantity&gt;
&lt;totalVolume&gt;0&lt;/totalVolume&gt;
&lt;totalWeight&gt;500000&lt;/totalWeight&gt;
&lt;voyageJobTransferType&gt;'&amp;voyageJobTransferType2.getOidString&amp;'&lt;/voyageJobTransferType&gt;
&lt;workpoint&gt;'&amp;workpoint2.getOidString&amp;'&lt;/workpoint&gt;
&lt;/WS_VoyageHoldCargo&gt;
&lt;WS_VoyageHoldCargo&gt;
&lt;cmObjectId/&gt;
&lt;bolNumber/&gt;
&lt;cargoSubType&gt;-1&lt;/cargoSubType&gt;
&lt;cargoType&gt;'&amp;cargoType2.getOidString&amp;'&lt;/cargoType&gt;
&lt;cargoWeight&gt;256&lt;/cargoWeight&gt;
&lt;commodity&gt;'&amp;commodity1.getOidString&amp;'&lt;/commodity&gt;
&lt;consignee&gt;'&amp;Consignee_Code&amp;'&lt;/consignee&gt;
&lt;consignor&gt;'&amp;Consignor_Code&amp;'&lt;/consignor&gt;
&lt;dischargePort&gt;'&amp;homePort&amp;'&lt;/dischargePort&gt;
&lt;estimatedEndDT&gt;'&amp;estDateString&amp;' 23:00&lt;/estimatedEndDT&gt;
&lt;estimatedStartDT&gt;'&amp;estDateString&amp;' 22:00&lt;/estimatedStartDT&gt;
&lt;freightForwarder&gt;'&amp;FreightF_Code&amp;'&lt;/freightForwarder&gt;
&lt;gangs&gt;1&lt;/gangs&gt;
&lt;holdLocation&gt;'&amp;holdLocation2.getOidString&amp;'&lt;/holdLocation&gt;
&lt;imexStatus&gt;1&lt;/imexStatus&gt;
&lt;loadPort&gt;CNSHA&lt;/loadPort&gt;
&lt;operator&gt;'&amp;operator.getOidString&amp;'&lt;/operator&gt;
&lt;tareWeight&gt;256&lt;/tareWeight&gt;
&lt;totalQuantity&gt;100&lt;/totalQuantity&gt;
&lt;totalVolume&gt;0&lt;/totalVolume&gt;
&lt;totalWeight&gt;1000&lt;/totalWeight&gt;
&lt;voyageJobTransferType&gt;'&amp;voyageJobTransferType1.getOidString&amp;'&lt;/voyageJobTransferType&gt;
&lt;workpoint&gt;'&amp;workpoint1.getOidString&amp;'&lt;/workpoint&gt;
&lt;/WS_VoyageHoldCargo&gt;
&lt;/allVoyageHoldCargo&gt;
&lt;berthOid&gt;'&amp;berth.getOidString&amp;'&lt;/berthOid&gt;
&lt;voyage&gt;'&amp;voyage.getOidString&amp;'&lt;/voyage&gt;
&lt;/_request&gt;';
	
	elseif _type = UpdateHMSResourcesUsed then
	
	vessel := self.getVessel( Vessel_Name );
	voyage := vessel.allVoyagesByTermCodeArrival.first;
	if voyage.status = Voyage_Status_DepServPending then
		estDate := voyage.departedDT.date;
		estDateToString := estDate.format("dd/MM/yyy") &amp; " " &amp; voyage.departedDT.time.format("HH:mm");
		estDateString := estDate.format("dd/MM/yyy") &amp; " " &amp; voyage.departedDT.time.cnEcAddMinutes(-20).format("HH:mm");
		occursOnDTString := estDateToString;
		resourceType := app.myRoot.allResourceTypes[ResourceType2];
		resource := resourceType.allResources.first;
		berth := terminal.myHarbour.allBerths.getAtKey( Berth2Name );
	else
		estDate := voyage.estimatedArrivalDT.date;
		estDateString := estDate.format("dd/MM/yyy") &amp; " 10:10";
		estDateToString := estDate.format("dd/MM/yyy") &amp; " 11:20";
		occursOnDTString := estDateString;
		resourceType := app.myRoot.allResourceTypes[ResourceType1];
		resource := resourceType.allResources.first;
		berth := terminal.myHarbour.allBerths.getAtKey( Berth1Name );
	endif;

rawXmlString := '&lt;_request&gt;
&lt;warningsAcknowledged&gt;true&lt;/warningsAcknowledged&gt;
&lt;allHMSResourcesUsed&gt;
&lt;WS_HMSResourceUsed&gt;
&lt;fromDateTime&gt;'&amp;estDateString&amp;'&lt;/fromDateTime&gt;
&lt;myDebtor/&gt;
&lt;quantity&gt;1&lt;/quantity&gt;
&lt;resource&gt;'&amp;resource.getOidAsString&amp;'&lt;/resource&gt;
&lt;resourceType&gt;'&amp;resourceType.getOidAsString&amp;'&lt;/resourceType&gt;
&lt;toDateTime&gt;'&amp;estDateToString&amp;'&lt;/toDateTime&gt;
&lt;/WS_HMSResourceUsed&gt;&lt;/allHMSResourcesUsed&gt;
&lt;berth&gt;'&amp;berth.getOidAsString&amp;'&lt;/berth&gt;
&lt;bowMarkTo&gt;225&lt;/bowMarkTo&gt;
&lt;draftAft&gt;1&lt;/draftAft&gt;
&lt;draftFwd&gt;1&lt;/draftFwd&gt;
&lt;hasRamp&gt;false&lt;/hasRamp&gt;
&lt;occursOnDT&gt;'&amp;occursOnDTString&amp;'&lt;/occursOnDT&gt;
&lt;starboardBerthed&gt;false&lt;/starboardBerthed&gt;
&lt;towingVoyage&gt;-1&lt;/towingVoyage&gt;
&lt;voyage&gt;'&amp;voyage.getOidAsString&amp;'&lt;/voyage&gt;
&lt;/_request&gt;';

	endif;
	
return rawXmlString;

epilog

end;</source>
        <Parameter name="_type" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="xmlForVoyageRequests_TAT3" id="09308b41-e716-4c7f-a211-84faaeb80d49">
        <source>xmlForVoyageRequests_TAT3(_type : String) : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/07/2019	jlgdap1		Initial creation TFS 45246 PEL1 Unit tests - voyage process
//
vars
	rawXmlString : String;
	terminal : CM_Terminal;
	now : TimeStamp;
	visitType : HMS_VisitType;
	arrivalDate : String;
	departureDate : String;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	estDate : Date;
	estDateString : String;
	estDateToString : String;
	occursOnDTString : String;
	resourceType : HMS_ResourceType;
	resource : HMS_Resource;
	berth : HMS_Berth;

begin
	terminal := self.getTerminal;

	if _type = CreateVoyageReq then
	
		now := app.actualTimeAppServer;
		arrivalDate := (now.date + 1).format("dd/MM/yyy");
		departureDate := (now.date + 3).format("dd/MM/yyy");
		visitType := app.myRoot.allVisitTypes.first;
	
rawXmlString := '&lt;request&gt;
&lt;warningsAcknowledged&gt;true&lt;/warningsAcknowledged&gt;
&lt;arrivalDate&gt;' &amp; arrivalDate &amp; '&lt;/arrivalDate&gt;
&lt;arrivalTime&gt;10:00&lt;/arrivalTime&gt;
&lt;departureDate&gt;' &amp; departureDate &amp; '&lt;/departureDate&gt;
&lt;departureTime&gt;22:10&lt;/departureTime&gt;
&lt;externalVoyageCode/&gt;
&lt;hasCargo&gt;false&lt;/hasCargo&gt;
&lt;lastPort&gt;JPABA&lt;/lastPort&gt;
&lt;lastPortOfCall&gt;AGANU&lt;/lastPortOfCall&gt;
&lt;nextPortOfCall&gt;DEABH&lt;/nextPortOfCall&gt;
&lt;operator&gt;' &amp; Operator_Code &amp; '&lt;/operator&gt;
&lt;operatorDischarge&gt;-1&lt;/operatorDischarge&gt;
&lt;operatorLoad&gt;-1&lt;/operatorLoad&gt;
&lt;originPort&gt;USAB3&lt;/originPort&gt;
&lt;vessel&gt;' &amp; Vessel_Name &amp; '&lt;/vessel&gt;
&lt;vesselCategory&gt;GEN&lt;/vesselCategory&gt;
&lt;visitType&gt;' &amp; visitType.getOidString &amp; '&lt;/visitType&gt;
&lt;voyageCode&gt;' &amp; self.Voyage_Code &amp; '&lt;/voyageCode&gt;
&lt;voyageIn/&gt;&lt;voyageOut/&gt;
&lt;/request&gt;';	

	elseif _type = UpdateHMSResourcesUsed then
	
		vessel := self.getVessel( Vessel_Name );
		voyage := vessel.allVoyagesByTermCodeArrival.first;
		if voyage.status = Voyage_Status_DepServPending then
			estDate := voyage.departedDT.date;
			estDateToString := estDate.format("dd/MM/yyy") &amp; " " &amp; voyage.departedDT.time.format("HH:mm");
			estDateString := estDate.format("dd/MM/yyy") &amp; " " &amp; voyage.departedDT.time.cnEcAddMinutes(-20).format("HH:mm");
			occursOnDTString := estDateToString;
			resourceType := app.myRoot.allResourceTypes[ResourceType2];
			resource := resourceType.allResources.first;
			berth := terminal.myHarbour.allBerths.getAtKey( Berth2Name );
		else
			estDate := voyage.estimatedArrivalDT.date;
			estDateString := estDate.format("dd/MM/yyy") &amp; " 10:10";
			estDateToString := estDate.format("dd/MM/yyy") &amp; " 11:20";
			occursOnDTString := estDateString;
			resourceType := app.myRoot.allResourceTypes[ResourceType1];
			resource := resourceType.allResources.first;
			berth := terminal.myHarbour.allBerths.getAtKey( Berth1Name );
		endif;

rawXmlString := '&lt;_request&gt;
&lt;warningsAcknowledged&gt;true&lt;/warningsAcknowledged&gt;
&lt;allHMSResourcesUsed&gt;
&lt;WS_HMSResourceUsed&gt;
&lt;fromDateTime&gt;'&amp;estDateString&amp;'&lt;/fromDateTime&gt;
&lt;myDebtor/&gt;
&lt;quantity&gt;1&lt;/quantity&gt;
&lt;resource&gt;'&amp;resource.getOidAsString&amp;'&lt;/resource&gt;
&lt;resourceType&gt;'&amp;resourceType.getOidAsString&amp;'&lt;/resourceType&gt;
&lt;toDateTime&gt;'&amp;estDateToString&amp;'&lt;/toDateTime&gt;
&lt;/WS_HMSResourceUsed&gt;&lt;/allHMSResourcesUsed&gt;
&lt;berth&gt;'&amp;berth.getOidAsString&amp;'&lt;/berth&gt;
&lt;bowMarkTo&gt;225&lt;/bowMarkTo&gt;
&lt;draftAft&gt;1&lt;/draftAft&gt;
&lt;draftFwd&gt;1&lt;/draftFwd&gt;
&lt;hasRamp&gt;false&lt;/hasRamp&gt;
&lt;occursOnDT&gt;'&amp;occursOnDTString&amp;'&lt;/occursOnDT&gt;
&lt;starboardBerthed&gt;false&lt;/starboardBerthed&gt;
&lt;towingVoyage&gt;-1&lt;/towingVoyage&gt;
&lt;voyage&gt;'&amp;voyage.getOidAsString&amp;'&lt;/voyage&gt;
&lt;/_request&gt;';

	endif;
	
	return rawXmlString;
	
epilog

end;</source>
        <Parameter name="_type" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="xmlVesselTAT_2" id="17c869ed-76d0-4029-9dcd-7d07a697c3cd">
        <source>xmlVesselTAT_2( _operatorCode : String; _shipLineCode : String ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2019	jlgndl1	Initial creation	TFS 44773

*/

constants

	Berth1Name : String = "PEL1T2_B11";
	
vars

	xmlString : String;

begin

	xmlString := '&lt;?xml version="1.0"?&gt;
&lt;CM_Vessel type="CM_Vessel"&gt;
&lt;airDraft&gt;0.00&lt;/airDraft&gt;
&lt;buildingLine&gt;0.00&lt;/buildingLine&gt;
&lt;callSign&gt;&lt;/callSign&gt;
&lt;canCreateVoyages&gt;true&lt;/canCreateVoyages&gt;
&lt;classLabel&gt;&lt;/classLabel&gt;
&lt;clonedFromVessel&gt;&lt;/clonedFromVessel&gt;
&lt;code&gt;PEL1WEBVESS&lt;/code&gt;
&lt;craneClearance&gt;0&lt;/craneClearance&gt;
&lt;dailyCost&gt;0&lt;/dailyCost&gt;
&lt;despatchRate&gt;0&lt;/despatchRate&gt;
&lt;draftBow&gt;0.00&lt;/draftBow&gt;
&lt;draftMid&gt;0.00&lt;/draftMid&gt;
&lt;draftStern&gt;0.00&lt;/draftStern&gt;
&lt;iSOVessel&gt;false&lt;/iSOVessel&gt;
&lt;isBarge&gt;false&lt;/isBarge&gt;
&lt;isDedicatedOrMulti&gt;false&lt;/isDedicatedOrMulti&gt;
&lt;lloydsNumber&gt;&lt;/lloydsNumber&gt;
&lt;loaWithRampsDown&gt;0.00&lt;/loaWithRampsDown&gt;
&lt;maxVesselBeam&gt;0.00&lt;/maxVesselBeam&gt;
&lt;myCellularVesselStructure type="CM_CellularVesselStructure"&gt;
&lt;myVessel type="CM_Vessel"&gt;
&lt;code&gt;PEL1WEBVESS&lt;/code&gt;
&lt;/myVessel&gt;
&lt;type&gt;1&lt;/type&gt;
&lt;allBaysByLabel type="CM_BayDefnByIdDict"&gt;
&lt;CM_BayDefn type="CM_BayDefn"&gt;
&lt;allCellsOnDeck type="CM_CellDefnByIdDict"&gt;
&lt;CM_CellDefn type="CM_CellDefn"&gt;
&lt;alignment&gt;4&lt;/alignment&gt;
&lt;id&gt;01&lt;/id&gt;
&lt;maxHeight&gt;0.0000&lt;/maxHeight&gt;
&lt;maxNumHighCubesIfFull&gt;0&lt;/maxNumHighCubesIfFull&gt;
&lt;maxPileWeight20&gt;0&lt;/maxPileWeight20&gt;
&lt;maxPileWeight40&gt;0&lt;/maxPileWeight40&gt;
&lt;ordinal&gt;4&lt;/ordinal&gt;
&lt;/CM_CellDefn&gt;
&lt;CM_CellDefn type="CM_CellDefn"&gt;
&lt;alignment&gt;3&lt;/alignment&gt;
&lt;id&gt;02&lt;/id&gt;
&lt;maxHeight&gt;0.0000&lt;/maxHeight&gt;
&lt;maxNumHighCubesIfFull&gt;0&lt;/maxNumHighCubesIfFull&gt;
&lt;maxPileWeight20&gt;0&lt;/maxPileWeight20&gt;
&lt;maxPileWeight40&gt;0&lt;/maxPileWeight40&gt;
&lt;ordinal&gt;3&lt;/ordinal&gt;
&lt;/CM_CellDefn&gt;
&lt;CM_CellDefn type="CM_CellDefn"&gt;
&lt;alignment&gt;5&lt;/alignment&gt;
&lt;id&gt;03&lt;/id&gt;
&lt;maxHeight&gt;0.0000&lt;/maxHeight&gt;
&lt;maxNumHighCubesIfFull&gt;0&lt;/maxNumHighCubesIfFull&gt;
&lt;maxPileWeight20&gt;0&lt;/maxPileWeight20&gt;
&lt;maxPileWeight40&gt;0&lt;/maxPileWeight40&gt;
&lt;ordinal&gt;5&lt;/ordinal&gt;
&lt;/CM_CellDefn&gt;
&lt;CM_CellDefn type="CM_CellDefn"&gt;
&lt;alignment&gt;2&lt;/alignment&gt;
&lt;id&gt;04&lt;/id&gt;
&lt;maxHeight&gt;0.0000&lt;/maxHeight&gt;
&lt;maxNumHighCubesIfFull&gt;0&lt;/maxNumHighCubesIfFull&gt;
&lt;maxPileWeight20&gt;0&lt;/maxPileWeight20&gt;
&lt;maxPileWeight40&gt;0&lt;/maxPileWeight40&gt;
&lt;ordinal&gt;2&lt;/ordinal&gt;
&lt;/CM_CellDefn&gt;
&lt;CM_CellDefn type="CM_CellDefn"&gt;
&lt;alignment&gt;6&lt;/alignment&gt;
&lt;id&gt;05&lt;/id&gt;
