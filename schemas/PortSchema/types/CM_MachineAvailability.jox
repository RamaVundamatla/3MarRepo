// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myRoot := app.myRoot;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="5199d12a-3ad6-4d4f-abf0-0fc9eea8c1e9">
        <updating/>
        <source>setProxy(pCode, pDescription : String) updating;

vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.code := pCode[1:4];
	self.description := pDescription[1:25];
	self.myRoot := app.myRoot;
	
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="779507d3-af56-4f85-9d27-24ecb1cbd467">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if app.myRoot.allMachineAvailabilities[code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;

	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="41b51c7c-79d9-4454-9030-904d11754857">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="67f47176-4b4b-4c9c-b1a4-d5445e0e5cce">
        <source>validateMe() protected;

vars

begin
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Machine Availability Code', null, null);
		app.raiseCMException(Input_required_field_macAvaiCd, null, null); // cnwdb2	PAR 35364


	endif;
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Machine Availability Description', null, null);
		app.raiseCMException(Input_required_field_machAvaiD, null, null); // cnwdb2	PAR 35364
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
