    <JadeMethod name="getPickupTasks" id="835cd4a3-c8a7-475e-9366-b651c09bab8f">
        <source>getPickupTasks(_arbiter: CM_RTQueueArbiter io; _isOverstowMove : Boolean);
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
/*
	method that returns the work required to pick up a TI. CRANE stuff..
*/
vars
	task : CM_RTQueueTask;
begin
	create task;
	
	//parent will be set higher up.
	task.setDetails(	self,
						_arbiter.ti.getPrimaryLocation(QUEUE_MODE),
						TASK_UNACTIONED,
						TASK_PICKUP,
						_arbiter.ti);
	task.isOverstowTask := _isOverstowMove;
	
	_arbiter.entry.addTask(task);
	//arbiter.addTask(task);
end;</source>
        <Parameter name="_arbiter" type="CM_RTQueueArbiter" usage="io"/>
        <Parameter name="_isOverstowMove" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getProposedCargo" id="f4b653cc-aeb5-4950-9d6f-12f7a44741a7">
        <source>getProposedCargo(_ti : CM_TrackedItem output; _numTIs : Integer output);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		a
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	theTI, theATI : CM_TrackedItem;

begin
	theTI := self.getTIAtIndex(REAL_MODE, 1);
	theATI := theTI; // PAR 7226 DEC2003AKB -  ADDED
	if theTI &lt;&gt; null then
		_numTIs := self.allTrackedItems.size;
		// theTI is being discharged, is some thing being loaded?
		if theTI = null then
			_numTIs := self.numPlannedTIs;
			// PAR 8207 . Whilst things are planned up this worked OK. However once the Load was complete, there were only actual TIs and no Planned
			if _numTIs = 0 then // PAR 8207
				_numTIs := self.numTIs; // PAR 8207
			endif;
		endif;
	endif;

	_ti := theTI;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="output"/>
        <Parameter name="_numTIs" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getQueueTasks" id="547a9e49-efea-4e60-8336-5a45bbce3f31">
        <source>getQueueTasks(_arbiter: CM_RTQueueArbiter io; _isSource : Boolean);
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
//Returns the tasks required to do a unit of work. (move a TI)
//Called from the RTQueueArbiter.
vars
	voyageROROJob	: CM_VoyageROROJob;
	notNotifiedJob 	: CM_VoyageNotNotifiedJob;
	roadJob			: CM_RoadJob;
	vhold : CM_VoyageHoldJob;
	ti				: CM_TrackedItem;
begin
	//--------------
	//Determine if the ti in the arbiter transient is here.
	//--------------
	//isSource := (_arbiter.sourceLocation = self);

	if not _arbiter.job.isVoyageROROJob		//cnwmc5 - 5 Feb 2014 - PAR 33204
	and not _arbiter.job.isNotNotifiedJob	// 12 Sep 2011	NDL	Par 28173
	and not _arbiter.job.isRoadJob			//cnwmc5 - 5 Feb 2014 - PAR 33204
	and not _arbiter.job.isVoyageHoldJob //TFS 49793 JLGAB1
	then
		app.raiseCMException(ERR_INVALID_JOB, null, null);		
		return;
	endif;

	if _arbiter.job.isNotNotifiedJob then
		notNotifiedJob := _arbiter.job.CM_VoyageNotNotifiedJob;
	elseif _arbiter.job.isRoadJob then		//cnwmc5 - 5 Feb 2014 - PAR 33204
		roadJob := _arbiter.job.CM_RoadJob;	//cnwmc5 - 5 Feb 2014 - PAR 33204
	elseif _arbiter.job.isVoyageHoldJob then //TFS 49793 JLGAB1
		vhold := _arbiter.job.CM_VoyageHoldJob; //TFS 49793 JLGAB1
	else
		voyageROROJob := _arbiter.job.CM_VoyageROROJob;
	endif;
	
	if _isSource then
		//This lc is the source of all evil. (the move)
		//------------
		//Get our "pickup tasks" (CRANE)
		//------------
		self.getPickupTasks(_arbiter, false);
		
		if voyageROROJob = null 
		and notNotifiedJob = null 
		and vhold = null  //TFS 49793 JLGAB1
		and roadJob = null then				//cnwmc5 - 5 Feb 2014 - PAR 33204
			app.raiseCMException(ERR_INVALID_JOB, null, null);		
			return;
		endif;
		return;
	endif;
	//---------------------------
	//We are the Target. Operation is CTA provides a set down task,
	//then a pickup task for the crane, then the machine provides a setdown task.
	//------------
	//Get the target to provide its "set-down tasks"
	//------------
	if voyageROROJob = null 
	and notNotifiedJob = null 
		and vhold = null  //TFS 49793 JLGAB1
		and roadJob = null then					//cnwmc5 - 5 Feb 2014 - PAR 33204
		app.raiseCMException(ERR_INVALID_JOB, null, null);		
		return;
	endif;
	//We provide CRANE's SetDown task.
	self.getSetdownTasks(_arbiter, false);
epilog
	if ti &lt;&gt; null then
		unlock(ti);
	endif;
end;</source>
        <Parameter name="_arbiter" type="CM_RTQueueArbiter" usage="io"/>
        <Parameter name="_isSource" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getQueues" id="e03b7e68-4cd1-4b2d-990a-410cfa1b11b9">
        <source>getQueues(_queueSet: CM_RTQueueSet io);
// ---------------------------------------------------------------------------

// 23/9/14  created for PAR 34939 

vars
	queueObj : CM_RadioTelemetryQueue;
	queueItem	: CM_RadioTelemetryQueue;
	term : CM_Terminal;
	craneWP : CM_Object;
	craneId : String;
begin

	_queueSet.clear;
	
	queueObj := self.myVoyage.myQueue;

	if queueObj = null then
		//Master Queue time
		term := self.myVoyage.getMyTerminal;	
		if term.radioTelemetry = null then
			return;
		endif;
		_queueSet.add(term.radioTelemetry.masterQueue);
		return;
	endif;
	
	
	// PAR 35397 - if this location is mapped to a crane or work point, that is the queue.
	// THIS is because the user has used option in voyage operations to allocate WPs to RT Qs
	craneWP := self.myVoyage.allCranesWPByHolds.getAtKey(self);
	if craneWP &lt;&gt; null then
		if craneWP.isKindOf(CM_Crane) then
			craneId := craneWP.CM_Crane.code;
		elseif craneWP.isKindOf(CM_WorkPoint) then
			craneId := craneWP.CM_WorkPoint.code;
		endif;
		
		if craneId &lt;&gt; null then
			foreach queueItem in queueObj.allSubQueuesById do	
				if (queueItem.isCraneQueue and queueItem.CM_VoyageCraneQueue.crane.id = craneId)
				or (queueItem.isWorkPointQueue and  queueItem.CM_VoyageWorkPointQueue.myWorkPoint.code = craneId) then
					_queueSet.add(queueItem);
					return;
				endif;
			endforeach;		
		endif;
	endif;


	foreach queueItem in queueObj.allSubQueuesById where queueItem.isCraneQueue do	//23 May 2012	NDL	Par 29621
		if not self.myVoyage.hasCraneGotJS(queueItem.CM_VoyageCraneQueue.crane) then
			_queueSet.add(queueItem);
		endif;
 	endforeach;
	
	// ### PAR 34743
	foreach queueItem in queueObj.allSubQueuesById where queueItem.isWorkPointQueue do	
		// TFS 4859 - this 'if' statement was written for voyage operation 'hidden' jobs which do not have a job sheet
		// TFS 4859 - however there is now a different type of job that might be for this location and that is a hold job, 
		// TFS 4859 - which does have a job sheet and already has a work point; so just include all wp queues that are defined.
		// TFS 4859 if not self.myVoyage.hasWorkPointGotJS(queueItem.CM_VoyageWorkPointQueue.myWorkPoint) then
			_queueSet.add(queueItem);
		// endif;
 	endforeach;
	
	
	//--------------
	//Return the Voyage queue
	//--------------
	if _queueSet.isEmpty() then
		_queueSet.add(queueObj);
	endif;
	
end;</source>
        <Parameter name="_queueSet" type="CM_RTQueueSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getSetdownTasks" id="01dc94f8-294a-4458-888d-e19b44ea2c0e">
        <source>getSetdownTasks(_arbiter: CM_RTQueueArbiter input; _isOverstowMove : Boolean);
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     method that returns the work required to set TI to this controller
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	task	: CM_RTQueueTask;
begin
	create task;
	task.setDetails(	_arbiter.ti.getPrimaryLocation(REAL_MODE),
						self,
						TASK_UNACTIONED,
						TASK_SETDOWN,
						_arbiter.ti);
	task.isOverstowTask := _isOverstowMove;
	
	_arbiter.entry.addTask(task);

end;</source>
        <Parameter name="_arbiter" type="CM_RTQueueArbiter" usage="input"/>
        <Parameter name="_isOverstowMove" type="Boolean"/>
    </JadeMethod>
