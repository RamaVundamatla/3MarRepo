    <JadeMethod name="addRow" id="3a9f35f4-ca1b-4a2b-8124-a2121c6439dd">
        <updating/>
        <source>addRow(_checked : Boolean; _value : String; _object : Object) : Integer updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		Adds an item to the table and clones the check box
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
	aControl : Control;
begin
	idx := self.addItem(Tab &amp; _value);
	aControl := self.myCheckBox.getControl(idx);
	if aControl = null then
		aControl := self.myCheckBox.loadControl(idx);
	endif;
	aControl.visible := true;
	aControl.CheckBox.caption := null;
	aControl.CheckBox.value := _checked;
//app.msgBox("AKB " &amp; class.name &amp; "::" &amp; method.name &amp; " 1. " &amp; aControl.String &amp; " " &amp; idx.String &amp; " " &amp; self.fixedColumns.String, "DBug", MsgBox_OK_Only);
	self.accessCell(idx,1).cellControl := aControl;
	self.accessRow(idx).itemObject := _object;
	if _checked then
		self.accessCell(idx,1).text := ComboValueChecked;
		if not self.allSelectedObjects.includes(_object) and _object &lt;&gt; null then
			self.allSelectedObjects.add(_object);
		endif;
	else
		self.accessCell(idx,1).text := null;
		if self.allSelectedObjects.includes(_object)  and _object &lt;&gt; null then
			self.allSelectedObjects.remove(_object);
		endif;
	endif;
	
	return idx;
end;</source>
        <Parameter name="_checked" type="Boolean"/>
        <Parameter name="_value" type="String"/>
        <Parameter name="_object" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="click" id="305ea4eb-1d77-4d76-84b0-3938ed3dc82b">
        <updating/>
        <source>click(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	aHeight , idx : Integer;
begin
	self.isDown := true;
	aHeight := self.rows * 15;
	
	if aHeight &gt; 150 then
		aHeight := 150;
	endif;
	self.height := aHeight;
	
	if self.row &gt; 1 then
		self.accessCell(self.row,1);
		
		self.accessedCell.cellControl.CheckBox.value := not self.accessedCell.cellControl.CheckBox.value;
		if self.accessedCell.cellControl.CheckBox.value.Boolean then
			self.accessedCell.text := ComboValueChecked;
			if not self.allSelectedObjects.includes(self.accessRow(self.row).itemObject) then
				self.allSelectedObjects.add(self.accessRow(self.row).itemObject);
			endif;
		else
			self.accessedCell.text := null;
			if self.allSelectedObjects.includes(self.accessRow(self.row).itemObject) then
				self.allSelectedObjects.remove(self.accessRow(self.row).itemObject);
			endif;
		
		endif;
	endif;	

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="5d7c80f8-70eb-4204-a564-0fc0e2f3c515">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.rows := 0;
	self.columns := 2;
	self.height := 17;
	self.fixedColumns := 0;
	self.fixedRows := 0;
	self.show3D := Table.Show3D_Not3D;
	self.fixed3D := false;
	self.scrollBars := Table.ScrollBar_Vertical;
	self.dropDown := Table.DropDown_Auto; //DropDown_Click; //DropDown_Auto	;
end;</source>
    </JadeMethod>
    <JadeMethod name="createCheckBox" id="3aae82f6-f64d-4cfe-aa15-29d7b047357d">
        <updating/>
        <source>createCheckBox() updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	create self.myCheckBox transient;
	self.myCheckBox.visible := false;
	self.myCheckBox.caption := null;
	self.myCheckBox.parent := self;
	self.form.addControl(self.myCheckBox);

end;</source>
    </JadeMethod>
    <JadeMethod name="lostFocus" id="73adab12-ee8c-4e23-b235-05b13f836755">
        <updating/>
        <source>lostFocus(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.row := 1;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tickRow" id="f486dba7-d72d-406c-b854-de2345165ed5">
        <updating/>
        <source>tickRow(_theRow : Integer; _tick : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _theRow &gt;= 1 then
		self.accessCell(_theRow,1);
		self.accessedCell.cellControl.CheckBox.value := _tick;
		if self.accessedCell.cellControl.CheckBox.value.Boolean then
			self.accessedCell.text := ComboValueChecked;
			if not self.allSelectedObjects.includes(self.accessRow(_theRow).itemObject) then
				self.allSelectedObjects.add(self.accessRow(_theRow).itemObject);
			endif;
		else
			self.accessedCell.text := null;
			if self.allSelectedObjects.includes(self.accessRow(_theRow).itemObject) then
				self.allSelectedObjects.remove(self.accessRow(_theRow).itemObject);
			endif;
		
		endif;
	endif;
end;</source>
        <Parameter name="_theRow" type="Integer"/>
        <Parameter name="_tick" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="d32885d3-edcd-413c-b219-8a3908940cc3">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(cntrl, persistCntrl);

	self.accessColumn(1).width := 25;
	self.accessColumn(1).alignment := Table.Alignment_Center_Middle;
	self.accessColumn(1).fontBold := true;
	self.rows := 0;
	self.columns := 2;
	self.height := 17;
	self.fixedColumns := 0;
	self.fixedRows := 0;
	self.show3D := Table.Show3D_Not3D;
	self.fixed3D := false;
	self.scrollBars := Table.ScrollBar_Vertical;
	self.gridLines := true;
	self.dropDown := Table.DropDown_Auto; //DropDown_Click; //DropDown_Auto	;
	self.createCheckBox();
	
	self.setMargins();
	
	if not self.isInPainter then
		self.addRow(null,"Select",null);
	endif;

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
