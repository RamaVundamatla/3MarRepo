    <JadeMethod name="buildTagBody" id="4a99de78-3ffe-4e66-a64e-a560c05a54b7">
        <source>buildTagBody(): String protected;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	htmlString	: String;
	
begin
	if self.headTitle &lt;&gt; null then
		htmlString	:=	htmlString &amp; '&lt;TITLE&gt;' &amp; self.headTitle &amp; '&lt;/TITLE&gt;' &amp; CrLf;
	endif;
		
	if self.headBase &lt;&gt; null then
		htmlString	:=	htmlString &amp; '&lt;BASE HREF="' &amp; self.headBase &amp; '"&gt;' &amp; CrLf;
	endif;
	
	if self.myMetaTag &lt;&gt; null then
		htmlString	:=	htmlString &amp; self.myMetaTag.getHtml();
	endif;
	
	if self.myScriptTag &lt;&gt; null then
		htmlString	:=	htmlString &amp; self.myScriptTag.getHtml();
	endif;
	
	htmlString	:=	htmlString &amp; inheritMethod();
	
	return htmlString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="83d85e0c-3c87-4075-a748-f779212824f9">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.headTitle	:=	"Untitled";
end;</source>
    </JadeMethod>
    <JadeMethod name="createMetaTag" id="a90caadc-e2d9-426e-87e3-051af98b8c9e">
        <updating/>
        <source>createMetaTag():CnEcPageHeadMetaTag updating;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Create a new meta tag object for the receiver.
//
// Parameters:	None
//
// Returns:		The newly created tag object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	metaTagObj	: CnEcPageHeadMetaTag;
	
begin
	if self.myMetaTag &lt;&gt; null then
		delete self.myMetaTag;
	endif;
	
	create metaTagObj transient;
	self.myMetaTag	:=	metaTagObj;
	
	return metaTagObj;
end;</source>
        <ReturnType type="CnEcPageHeadMetaTag"/>
    </JadeMethod>
    <JadeMethod name="createScriptTag" id="683671c0-27b1-4e64-a0eb-b82be8d08d74">
        <updating/>
        <source>createScriptTag():CnEcPageHeadScriptTag updating;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Create a new script tag object for the receiver.
//
// Parameters:	None
//
// Returns:		The newly created tag object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	scriptTagObj	: CnEcPageHeadScriptTag;
	
begin
	if self.myScriptTag &lt;&gt; null then
		delete self.myScriptTag;
	endif;
	
	create scriptTagObj transient;
	self.myScriptTag	:=	scriptTagObj;
	
	return scriptTagObj;
end;</source>
        <ReturnType type="CnEcPageHeadScriptTag"/>
    </JadeMethod>
    <JadeMethod name="getHtml" id="74d9fff1-1249-4fdd-a2df-28331cfb3529">
        <source>getHtml(): String;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return '&lt;HEAD&gt;' &amp; CrLf &amp; self.buildTagBody() &amp; '&lt;/HEAD&gt;' &amp; CrLf;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setPage" id="87693464-593d-40ba-ae83-e449468039ba">
        <updating/>
        <source>setPage(pPageObj:CnEcHtmlPage) updating;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Set a reference to the receiver's owning HTML pag tag object.
//
// Parameters:	pPageObj - The HTML page tag object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myPage &lt;&gt; pPageObj then
		self.myPage	:=	pPageObj;
	endif;
end;</source>
        <Parameter name="pPageObj" type="CnEcHtmlPage"/>
    </JadeMethod>
</Class>
