    <JadeMethod name="initForm" id="04c74e63-9b00-4c94-b053-51b2a035d2bf">
        <updating/>
        <source>initForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 March 2012	cnwndl1	Initial creation
25 September 2018	cnwma1	ChangeRequest 41080: PEL1 - Assigning Operators ID to Cranes/Work-Points
*/

vars

	breakOut : Boolean;
	availableWorkPoints : ObjectArray;
	obj : Object;
	crane : CM_Crane;
	wp : CM_WorkPoint;
	secRole : CM_SecurityRole;
begin

	self.showDataOnStartup := false;
	
	self.allowPrint := true;
	self.allowSearch := false;
	self.allowExportCSV	:= true;
	self.useTblThumb := false;
	self.tblData.disallowColumnSorter := true;
	self.mnuTblVSortByCol.enabled := false;
	self.mnuTblVSortByCol.visible := false;
	
	
	self.cmbCrane.clear();
	
	if self.amInitialisingWithObject then
		if self.myCurrentObject &lt;&gt; null then
			if self.myCurrentObject.isKindOf(CM_Voyage) then
				self.myVoyage := self.myCurrentObject.CM_Voyage;
				self.myCurrentObject := null;
			elseif self.myCurrentObject.isKindOf(CM_WorkPointOperatingHours) then
				self.myVoyage := self.myCurrentObject.CM_WorkPointOperatingHours.myVoyage;
			else
			endif;
			if self.myVoyage &lt;&gt; null then
				self.caption := app.getErrorString(Work_point_oper_hrs) &amp; " - " &amp; self.myVoyage.getId;
				create availableWorkPoints transient;
				self.myVoyage.getAllAvailableWorkPoints( availableWorkPoints );
				foreach obj in availableWorkPoints do
					if obj.isKindOf(CM_Crane) then
						crane := obj.CM_Crane;
						self.cmbCrane.itemObject[self.cmbCrane.addItem( crane.id )] := crane;
					elseif  obj.isKindOf(CM_WorkPoint) then
						wp := obj.CM_WorkPoint;
						self.cmbCrane.itemObject[self.cmbCrane.addItem( wp.getID )] := wp;
					endif;
				endforeach;
			endif;
			secRole := self.myTerminal.getConfig(ShipCraneOpHrsSecRole).CM_SecurityRole;
			if secRole &lt;&gt; null then
				self.myAssistant.comboBoxSecRoleUsers(self.cmbCraneOpr,secRole, null);
			else
				self.myAssistant.comboBoxUser(self.cmbCraneOpr, null); //25.09.2018 cnwma1 TFS #41080
			endif;
		endif;
	endif;
	
	self.minimumWidth := 750;
	self.minimumHeight := 300;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnNewTV.enabled:= false;
		self.btnEditTV.enabled:= false;
		self.btnDeleteTV.enabled:= false;
	endif;
	self.frmDetailsTop.height := 160;  //25.09.2018 cnwma1 TFS #41080
	
epilog

	delete availableWorkPoints;

end;</source>
    </JadeMethod>
