	return null;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGridDefinitionArray" id="fd2c9aad-83e0-4007-9845-7483640a2edf">
        <source>getGridDefinitionArray() : String;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	rtnStr,
	oidStr,
	rowStr,
	colStr,
	idStr,
	widthStr,
	maxHeightStr,
	heightStr,
	powerStr,
	restrictStr,
	colourStr,
	tmpLetter,
	subBlockStr	: String;
	tmpColour	: Integer;
	labRest : CM_LabourRestriction;
begin

	self.getDrawingAttributes(null, null, null, tmpColour, tmpLetter);	

	oidStr			:= self.getOidStringForObject(self);
	rowStr			:= self.myGridRow.row.String;
	colStr			:= self.myGridColumn.column.String;
	idStr			:= self.getFullId;
	widthStr		:= self.width.String;
	maxHeightStr	:= self.getMaxHeight().String;
	heightStr		:= self.getHeightNoStackFrom().String;
	powerStr		:= self.hasPower().Integer.String;
	restrictStr		:= self.getOidStringForObject(self.myLocationRestriction);
	colourStr		:= tmpColour.String;
	subBlockStr		:= self.getOidStringForObject(self.mySubBlockStack);

	rtnStr := GridData_LC &amp; GridData_Delimiter &amp;
			  oidStr &amp; GridData_Delimiter &amp;
			  rowStr &amp; GridData_Delimiter &amp;
		 	  colStr &amp; GridData_Delimiter &amp;
			  idStr &amp; GridData_Delimiter &amp;
			  widthStr &amp; GridData_Delimiter &amp;
			  maxHeightStr &amp; GridData_Delimiter &amp;
			  heightStr &amp; GridData_Delimiter &amp;
			  powerStr &amp; GridData_Delimiter &amp;
			  restrictStr &amp; GridData_Delimiter &amp;
			  colourStr &amp; GridData_Delimiter &amp;
			  tmpLetter &amp; GridData_Delimiter &amp;
			  subBlockStr;
			  
	tmpColour := NullColour;
	if self.mySubBlockStack &lt;&gt; null then
		if self.mySubBlockStack.myLayoutGraphic &lt;&gt; null then
			tmpColour := self.mySubBlockStack.myLayoutGraphic.drawLineColour;
		endif;
	endif;
	rtnStr := rtnStr &amp; GridData_Delimiter &amp; tmpColour.String; // 14

	tmpColour := NullColour;
	if self.myLocationRestriction &lt;&gt; null then
		tmpColour := self.myLocationRestriction.colour;
	endif;
	rtnStr := rtnStr &amp; GridData_Delimiter &amp; tmpColour.String; // 15
			  
	tmpColour := NullColour;
	tmpLetter := null;
	if (not self.allLabourRestrictions.isEmpty) then
		labRest := self.allLabourRestrictions.first;
		tmpColour := labRest.colour; 
		tmpLetter := labRest.id;
	endif;

	rtnStr := rtnStr &amp; GridData_Delimiter &amp; 
			tmpColour.String &amp; GridData_Delimiter &amp; 
			tmpLetter; // 16 &amp; 17
	
	return rtnStr;
		
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGridTIsArray" id="e99d1c50-7998-43eb-819c-c973f44ce5e8">
        <source>getGridTIsArray(_data : StringArray512 io; _lineType : String; _drawAttrs : CMIF_DrawingAttrController input; _theTIs : CM_TIArray input; _mode : Integer);
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	tmpTI	: CM_TrackedItem;
	tmpTIs	: CM_TIArray;
	isPrimary	: String;
	tmpLC	: CM_LocationsController;
	
begin

	// Get all the TIs that are actually here
	// Only include those TIs where my controller is their primary location
	if _mode = REAL_MODE then
		// this is a lot more efficient than calling the getTIs method
		tmpTIs := self.allTrackedItems;
	else
		tmpTIs := _theTIs;
		tmpTIs.clear;
		self.getTIs(tmpTIs, _mode, true); // PAR 27749
	endif;

	foreach tmpTI in tmpTIs do
		if _mode = REAL_MODE then
			tmpLC := tmpTI.myPrimaryActualLocation;
		elseif _mode = PLANNING_MODE then
			if tmpTI.isRehandle then
				// need to get discharge one
				tmpLC := tmpTI.getRehandleDischPrimaryLocn();
				if tmpLC = null then
					tmpLC := tmpTI.myPrimaryPlannedLocation;
				endif;
			else
				tmpLC := tmpTI.myPrimaryPlannedLocation;
			endif;
		elseif _mode = QUEUE_MODE then
			tmpLC := tmpTI.myPrimaryQueuedLocation;
		endif;

		if tmpLC &lt;&gt; null then
			isPrimary := (tmpLC = self).Integer.String;
		else
			isPrimary := false.Integer.String;
		endif;
		
		_data.add(_lineType &amp; GridData_Delimiter &amp;
				  isPrimary &amp; GridData_Delimiter &amp;
				  tmpTI.getGridDefinitionArray(null, _drawAttrs, TI_SITE_ONSITE));

	endforeach;

end;</source>
        <Parameter name="_data" type="StringArray512" usage="io"/>
        <Parameter name="_lineType" type="String"/>
        <Parameter name="_drawAttrs" type="CMIF_DrawingAttrController" usage="input"/>
        <Parameter name="_theTIs" type="CM_TIArray" usage="input"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getGriddedStackHeightObj" id="aee237c1-5687-4eb9-9149-fdb1ba5035f0">
        <source>getGriddedStackHeightObj( _firstTi : CM_TrackedItem output ):CM_GriddedTAStackHeight protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 September 2020	jlgndl1	Initial creation	TFS 49984

*/

vars

	futureMove : CM_FutureMove;

begin

	if self.getMyTerminalArea = null or self.getMyTerminalArea.allGriddedTAStackHeights.isEmpty then	
		return null;
	endif;
	
	//find the first TI
	if not self.allTrackedItems.isEmpty then
		_firstTi := self.allTrackedItems.first;
	endif;
	if _firstTi = null then
		if not self.allQueuedFutureMoves.isEmpty then
			foreach futureMove in self.allQueuedFutureMoves do
				_firstTi := futureMove.getTrackedItem;
				if _firstTi &lt;&gt; null then
					break;
				endif;
			endforeach;
		endif;
		if _firstTi = null then
			if not self.allPlannedFutureMoves.isEmpty then
				foreach futureMove in self.allPlannedFutureMoves do
					_firstTi := futureMove.getTrackedItem;
					if _firstTi &lt;&gt; null then
						break;
					endif;
				endforeach;
			endif;
		endif;
	endif;
	
	if _firstTi = null then
		return null;
	endif;
	
	
	return self.getMyTerminalArea.allGriddedTAStackHeights.getFirstMatching( _firstTi );	//24 Sep 2020	NDL	TFS 49984

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_firstTi" type="CM_TrackedItem" usage="output"/>
        <ReturnType type="CM_GriddedTAStackHeight"/>
    </JadeMethod>
