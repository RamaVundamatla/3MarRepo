	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.initTblInput(theForm.tblInput1, theForm.tblInput1.myEntTableDef.name);	// PAR #31155

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="e8813b1d-482c-4675-bee2-b54f1222f128">
        <updating/>
        <source>setupThumbnailDetails() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 June 2009	cnwndl1	Initial creation

*/

vars
	theForm : SOP_TableMaintForm;

begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_GroupClearanceDisp);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);
	theForm.shtTblInput1.caption := app.getErrorString(Details);
	theForm.initTblInput(theForm.tblInput1, ETDef_GroupClearanceEntry);
	theForm.shtTblInput1.visible := true;
	
	theForm.mulSelect1.formDisplayEntryMethodName	:=	null;
	theForm.mulSelect2.formDisplayEntryMethodName	:=	null;
    
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="a6e5ad67-5a6a-452e-8762-a6400064e6fa">
        <updating/>
        <source>showThumbnail(pObj: CM_Object) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/06/2009	cnwndl1	Initial creation
04/03/2013		cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars

	theForm : SOP_TableMaintForm;
	
begin

	theForm := self.myForm;
	//theForm.tblInput1.clearValues;		// PAR #31155 we've already set the measurement values, so don't clear them

	theForm.tblInput1.setValueByName(ETRow_Code, pObj.CM_TrackClearance.code);
	theForm.tblInput1.setValueByName(ETRow_Description, pObj.CM_TrackClearance.description);
	// PAR #31155 don't set the measurement values here, they've already been done											// PAR #31155
	//theForm.tblInput1.setValueByName(ETRow_MaxHeight, pObj.CM_TrackClearance.maxHeight.asStringMeasurementJMT() );		// PAR #31155
	//theForm.tblInput1.setValueByName(ETRow_MaxWeightWagon, pObj.CM_TrackClearance.maxWeightWagon.asStringWeightJMT() );	// PAR #31155
	//theForm.tblInput1.setValueByName(ETRow_MaxWidth, pObj.CM_TrackClearance.maxWidth.asStringMeasurementJMT() );			// PAR #31155
	theForm.tblInput1.setValueByName(ETRow_AllowHiCubeYesNo, pObj.CM_TrackClearance.allowHiCube);
	theForm.tblInput1.setValueByName(ETRow_AllowHiCube, pObj.CM_TrackClearance.allowHiCube);
	theForm.tblInput1.setValueByName(ETRow_IsNotAvailableForEntry, pObj.CM_TrackClearance.isNotAvailableForEntry);
	

	// PAR #31155 don't set the measurement values here, they've already been done											// PAR #31155
	//theForm.tblInput1.setValueByName(ETRow_MaxWeight, pObj.CM_TrackClearance.maxWeight.asStringWeightJMT() ); // PAR 23176// PAR #31155
	theForm.tblInput1.setValueByName(ETRow_NoEmptyWagons, pObj.CM_TrackClearance.noEmptyWagons); // PAR 23176
	
epilog

end;</source>
        <Parameter name="pObj" type="CM_Object"/>
    </JadeMethod>
</Class>
