    <JadeMethod name="loadDataForFirstTime" id="6544051a-c494-4521-b5a6-d32e72e9e286">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:		18 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
/*
/ note these are the meanings of the colours
 strs(1) = "Unavailable"
  strs(2) = "SubBlock"
  strs(3) = "Light"
  strs(4) = "Building"
  strs(5) = "Empty"
  strs(6) = "˝"
  strs(7) = "1"
  strs(8) = "1 ˝"
  strs(9) = "2"
  strs(10) = "2 ˝"
  strs(11) = "3"
  strs(12) = "3 ˝"
  strs(13) = "4"
  strs(14) = "4 ˝"
  strs(15) = "5"
  strs(16) = "5 ˝"
  strs(17) = "6"
  strs(18) = "6 ˝"
  strs(19) = "7"
  strs(20) = "7 ˝"
  strs(21) = "8"
*/
// ---------------------------------------------------------------------------
vars
begin
	app.myRoot.coloursForTALevels.copy(self.allColours);
	self.lblHeight1.ignoreSkin := true;

	self.lblBuilding.ignoreSkin := true; self.lblBuilding.backColor := self.allColours[4]; self.lblBuilding.foreColor := self.lblBuilding.backColor.getInverseColour();
	self.lblLight.ignoreSkin := true; self.lblLight.backColor := self.allColours[3]; self.lblLight.foreColor := self.lblLight.backColor.getInverseColour();
	self.lblHeight1.ignoreSkin := true; self.lblHeight1.backColor := self.allColours[7]; self.lblHeight1.foreColor := self.lblHeight1.backColor.getInverseColour();
	self.lblHeight2.ignoreSkin := true; self.lblHeight2.backColor := self.allColours[9]; self.lblHeight2.foreColor := self.lblHeight2.backColor.getInverseColour();
	self.lblHeight3.ignoreSkin := true; self.lblHeight3.backColor := self.allColours[11]; self.lblHeight3.foreColor := self.lblHeight3.backColor.getInverseColour();
	self.lblHeight4.ignoreSkin := true; self.lblHeight4.backColor := self.allColours[13]; self.lblHeight4.foreColor := self.lblHeight4.backColor.getInverseColour();
	self.lblHeight5.ignoreSkin := true; self.lblHeight5.backColor := self.allColours[15]; self.lblHeight5.foreColor := self.lblHeight5.backColor.getInverseColour();
	self.lblHeight6.ignoreSkin := true; self.lblHeight6.backColor := self.allColours[17]; self.lblHeight6.foreColor := self.lblHeight6.backColor.getInverseColour();
	self.lblHeight7.ignoreSkin := true; self.lblHeight7.backColor := self.allColours[19]; self.lblHeight7.foreColor := self.lblHeight7.backColor.getInverseColour();
	self.lblHeight8.ignoreSkin := true; self.lblHeight8.backColor := self.allColours[21]; self.lblHeight8.foreColor := self.lblHeight8.backColor.getInverseColour();
	
	self.btnSaveBase.visible := true;
	self.btnSaveBase.parent := self;
	self.btnSaveBase.move(self.lblBuilding.left,self.lblBuilding.top + self.lblBuilding.height + 10, self.lblBuilding.width,self.lblBuilding.height);

	self.btnCancelBase.visible := true;
	self.btnCancelBase.parent := self;
	self.btnCancelBase.move(self.btnSaveBase.left,self.btnSaveBase.top + self.btnSaveBase.height + 10, self.btnSaveBase.width,self.btnSaveBase.height);
	
	self.height := self.btnCancelBase.top + self.btnCancelBase.height + 40;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setColour" id="ff287c78-e8d7-47de-bca3-bd5e137f732b">
        <source>setColour(_index : Integer; _label : Label input);
// ---------------------------------------------------------------------------
// Created:		18 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

cmdColor	: CMDColor;
	tmpCell	: JadeTableCell;
	tmpText	: String;
begin

	create cmdColor transient;
	cmdColor.preventFullOpen := false;
	cmdColor.color := _label.backColor;
	cmdColor.dialogTitle := "Colour For " &amp; _label.caption;
	if cmdColor.open = 0 then
		self.allColours[_index] := cmdColor.color;
		_label.backColor := self.allColours[_index];
		_label.foreColor := _label.backColor.getInverseColour();

	endif;

end;</source>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_label" type="Label" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="153772cc-d847-4075-9374-1ff792409c3b">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017280, locale);
	lblBuilding.translateBubbleHelp(Xlat_0000262, locale);
	lblBuilding.translateCaption(Xlat_0000263, locale);
	lblHeight1.translateBubbleHelp(Xlat_0000266, locale);
	lblHeight1.translateCaption(Xlat_0000274, locale);
	lblHeight2.translateBubbleHelp(Xlat_0000270, locale);
	lblHeight2.translateCaption(Xlat_0000273, locale);
	lblHeight3.translateBubbleHelp(Xlat_0000264, locale);
	lblHeight3.translateCaption(Xlat_0000278, locale);
	lblHeight4.translateBubbleHelp(Xlat_0000265, locale);
	lblHeight4.translateCaption(Xlat_0000276, locale);
	lblHeight5.translateBubbleHelp(Xlat_0000269, locale);
	lblHeight5.translateCaption(Xlat_0000277, locale);
	lblHeight6.translateBubbleHelp(Xlat_0000271, locale);
	lblHeight6.translateCaption(Xlat_0000272, locale);
	lblHeight7.translateBubbleHelp(Xlat_0000268, locale);
	lblHeight7.translateCaption(Xlat_0000275, locale);
	lblHeight8.translateBubbleHelp(Xlat_0000267, locale);
	lblHeight8.translateCaption(Xlat_0000279, locale);
	lblLight.translateBubbleHelp(Xlat_0000280, locale);
	lblLight.translateCaption(Xlat_0000281, locale);
end;</source>
    </JadeMethod>
</GUIClass>
