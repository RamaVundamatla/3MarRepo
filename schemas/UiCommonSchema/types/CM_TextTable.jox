    <JadeMethod name="addObjectAndDisplay" id="b0352de6-fbbf-4dc5-97db-38dea1d60263">
        <updating/>
        <source>addObjectAndDisplay(_obj : Object; _viewName : String) updating;
/*
	Created on 05 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	strDisplay : String;
	etRow : EntTableRow;
	etView : EntTableView;
	strObj : String;
begin
	if _viewName &lt;&gt; null then
		etView := myEntTableDef.allEntTableViews[_viewName];
	endif;
	
	self.allDisplayEntTableRows.clear();
	myEntTableDef.allEntTableRows.copy(allDisplayEntTableRows);

	
	foreach etRow in allDisplayEntTableRows do
		if etView &lt;&gt; null and not etView.allEntTableRows.includes(etRow) then
			continue; // the field is not in this view
		endif;
		strObj := form.CM_BaseForm.getTextTableDisplay(_obj, etRow);
		if strObj = null then
			continue;
		endif;
		if strDisplay = '' then
			strDisplay := strObj;
		else
			strDisplay := strDisplay &amp; '; ' &amp; strObj;
		endif;
	endforeach;
	addItemObject(_obj, strDisplay);
	accessColumn(1);
	accessedColumn.widthPercent := 100;
	accessedRow.wordWrap := true;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_viewName" type="String"/>
    </JadeMethod>
    <JadeMethod name="clearAllSelected" id="fb60423c-4bcb-4493-b9ae-42018f9dd33f">
