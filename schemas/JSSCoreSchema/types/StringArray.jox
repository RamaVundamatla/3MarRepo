<CollClass name="StringArray">
    <JadeMethod name="jssDoSort" id="cda3f651-6a8d-40e9-bc63-8132bdbd7456">
        <lockReceiver/>
        <updating/>
        <source>jssDoSort(pSorterObj: JSSSorter) updating, protected, lockReceiver;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Refer to method implementation on the Array class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	stringValue		: String;
	sortKeyObj		: Object;

begin
	foreach stringValue in self do
		pSorterObj.addValue(stringValue);
	endforeach;
	
	self.purge();
	
	foreach sortKeyObj in pSorterObj.mySortColl do
		self.add(sortKeyObj.JSSSortKey.getValue.String);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pSorterObj" type="JSSSorter"/>
    </JadeMethod>
    <JadeMethod name="jssParseTokens" id="ab4552f6-13af-4074-900b-0a01d59e6cf3">
        <lockReceiver/>
        <updating/>
        <source>jssParseTokens(pString:String):StringArray updating;
	// Add each token in the input string to the receiver.
vars
	characterPos	: Integer;
	stringLength	: Integer;
	
begin
	characterPos	:=	1;
	stringLength	:=	pString.length;
	
	foreach characterPos in 1 to stringLength do
		self.add(pString.getNextToken(characterPos));
	endforeach;

	return self;
end;</source>
        <Parameter name="pString" type="String"/>
        <ReturnType type="StringArray"/>
    </JadeMethod>
</CollClass>
