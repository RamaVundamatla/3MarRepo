    <JadeMethod name="translateForm" id="ad420ba4-db65-4bfc-ade5-7f5390ab46fb">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 10 August 2018 11:53:53.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022883, locale);
	btnAddRule.translateBubbleHelp(Xlat_0011723, locale);
	btnAddRule.translateCaption(Xlat_0015862, locale);
	btnCancel.translateCaption(Xlat_0014951, locale);
	btnDeleteRule.translateBubbleHelp(Xlat_0011725, locale);
	btnDeleteRule.translateCaption(Xlat_0015863, locale);
	btnEditRule.translateBubbleHelp(Xlat_0011727, locale);
	btnEditRule.translateCaption(Xlat_0015864, locale);
	btnEditWell.translateCaption(Xlat_0020025, locale);
	btnSave.translateCaption(Xlat_0014953, locale);
	lbl20FootPos.translateCaption(Xlat_0011735, locale);
	lblCWeight.translateCaption(Xlat_0011736, locale);
	lblCarrier.translateCaption(Xlat_0011738, locale);
	lblCode.translateCaption(Xlat_0015865, locale);
	lblDoors.translateCaption(Xlat_0011740, locale);
	lblEntry.translateCaption(Xlat_0015867, locale);
	lblGenerator.translateCaption(Xlat_0015868, locale);
	lblHeight.translateCaption(Xlat_0015869, locale);
	lblIHeight.translateCaption(Xlat_0018607, locale);
	lblILength.translateCaption(Xlat_0018608, locale);
	lblIWidth.translateCaption(Xlat_0018609, locale);
	lblLength.translateCaption(Xlat_0015871, locale);
	lblLocations.translateCaption(Xlat_0015872, locale);
	lblMaxCHeight.translateCaption(Xlat_0015873, locale);
	lblMaxHeight.translateCaption(Xlat_0011749, locale);
//	lblMaxHeightUnit.translateCaption(Xlat_0011750, locale);
	lblOHeight.translateCaption(Xlat_0018610, locale);
	lblOLength.translateCaption(Xlat_0018611, locale);
	lblOWidth.translateCaption(Xlat_0018612, locale);
	lblStack.translateCaption(Xlat_0011751, locale);
	lblTare.translateCaption(Xlat_0015877, locale);
	lblTierIds.translateCaption(Xlat_0020026, locale);
	lblTotWeight.translateCaption(Xlat_0011754, locale);
//	lblTotWeightUnit.translateCaption(Xlat_0011755, locale);
	lblWagonType.translateCaption(Xlat_0018613, locale);
	shtPositRules.translateCaption(Xlat_0015880, locale);
	shtRestConsigne.translateCaption(Xlat_0015881, locale);
	shtWagonSealType.translateCaption(Xlat_0020294, locale);
	shtWells.translateCaption(Xlat_0020027, locale);
end;</source>
