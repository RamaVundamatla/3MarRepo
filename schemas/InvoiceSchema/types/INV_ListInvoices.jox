    <JadeMethod name="myCurrentInvoice" id="63bd2f64-485b-4c0c-8940-6356c743e79c">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>myCurrentInvoice(set : Boolean; _value : CM_Invoice io) updating, mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items

*/

vars

begin
	if set then
		self.myCurrentInvoice := _value;
		if _value &lt;&gt; null then
			self.isMTNDefaultProcess := _value.getMyInvoiceProcess().isDefaultProcessJMT();
			self.isInvoiceAPIProcess := _value.getMyInvoiceProcess().isInvoiceAPIProcess();
		else
			self.isMTNDefaultProcess := false;
			self.isInvoiceAPIProcess := false;
		endif;
	else
		_value := self.myCurrentInvoice;
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Invoice" usage="io"/>
    </JadeMethod>
    <JadeMethod name="populateCargoOperLocns" id="f11ad384-b4b0-490e-b894-38c666bb3f34">
        <source>populateCargoOperLocns();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2019	jlgndl1	Initial creation	TFS 47954

*/

vars

	iter : Iterator;
	operTerm : CM_OperatorTerminal;
	oper : CM_Operator;

begin

	iter := self.myTerminal.allOperatorTerminals.createIterator;
	self.cmbCargoOper.clear();
	while iter.next( operTerm ) do
		oper := operTerm.myOperator;
		self.cmbCargoOper.itemObject[ self.cmbCargoOper.addItem( oper.code ) ] := oper;
	endwhile;
	self.cmbCargoTA.listCollection( self.myTerminal.allTerminalAreasByTypeId, false, 0);

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbStatus" id="695b3a95-f453-45fe-b5ff-6323fc0481e3">
        <source>populateCmbStatus();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Dec 2018	jlgsl4	TFS 39618
30/11/2022  navmv20 Task 55549: UI - Add colour to Invoice List combo box and status column
11 Sep 2024 navlc30 Bug 65879: MTN - Duplicate "Open" values in Status Combo on invoice list
*/

vars
	invoiceStatus,
	currentInvoiceStatus  : CM_InvoiceStatus;
	nextStatuses : CM_InvoiceStatusByPriority;
	invoiceProcess : CM_InvoiceProcess;
    index          : Integer; //30/11/2022 navmv20 55549
begin

	if self.myCurrentInvoice &lt;&gt; null then
		create nextStatuses transient;
		if self.myCurrentInvoice.getMyInvoiceProcess = null then // use default invoice process if none set
			invoiceProcess := CM_InvoiceProcessDefault.firstInstance;
		else
			invoiceProcess := self.myCurrentInvoice.getMyInvoiceProcess;
		endif;
		invoiceProcess.getNextValidStatuses(self.myCurrentInvoice, nextStatuses, app.isSpecial);
		self.cmbStatus.clear;
		invoiceStatus := self.myCurrentInvoice.getInvoiceStatusObject(self.myCurrentInvoice.status);

		if invoiceStatus &lt;&gt; null then // populate combo if status is valid for chosen invoice process
			//30/11/2022 navmv20 TFS 55549 - START
			//self.cmbStatus.addItemObject(invoiceStatus.description, invoiceStatus); 
			index := self.cmbStatus.addItemObject(invoiceStatus.description, invoiceStatus); 
			self.cmbStatus.itemBackColor[index] := invoiceStatus.getStatusColour(); 
			self.cmbStatus.itemForeColor[index] := self.cmbStatus.itemBackColor[index].getInverseColour(); 
			//30/11/2022 navmv20 TFS 55549 - END
			currentInvoiceStatus := invoiceStatus;							//11.09.2024 navlc30 #65879
			
			foreach invoiceStatus in nextStatuses do
				if currentInvoiceStatus = invoiceStatus then				//11.09.2024 navlc30 #65879
					continue;
				endif;
				
				 // ### JIRA 35468 29JUL2025 NAVAB1
				if not invoiceStatus.userCanSet(self.myTerminal) then
						continue;
				endif;
				//30/11/2022 navmv20 TFS 55549 - START
				//self.cmbStatus.addItemObject(invoiceStatus.description, invoiceStatus);
				index := self.cmbStatus.addItemObject(invoiceStatus.description, invoiceStatus); 
				self.cmbStatus.itemBackColor[index] := invoiceStatus.getStatusColour(); 
				self.cmbStatus.itemForeColor[index] := self.cmbStatus.itemBackColor[index].getInverseColour();
				//30/11/2022 navmv20 TFS 55549 - END
			endforeach;
			self.cmbStatus.listIndex := 1; // show current status
		endif;
	endif;
epilog
	delete nextStatuses;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbStatusBank" id="9f479973-05be-47d1-8e6e-a8703cdeed3e">
        <source>populateCmbStatusBank();
/*

Purpose:		// TFS 39618 PATCH 1	

Parameters:			

Return Value:		

Date		Who		Reason
17 Dec 2018	jlgsl4	TFS 39618
*/

vars
	invoiceStatus : CM_InvoiceStatus;
	nextStatuses : CM_InvoiceStatusByPriority;
	invoiceProcess : CM_InvoiceProcess;
begin
	self.cmbInvoiceStatus.clear;
	
	self.cmbInvoiceStatus.sorted := true;

	if self.myCurrentBank &lt;&gt; null then
		invoiceProcess := self.myCurrentBank.getMyInvoiceProcess;
		
		foreach invoiceStatus in invoiceProcess.allStatuses	discreteLock do
			self.cmbInvoiceStatus.addItemObject(invoiceStatus.description, invoiceStatus);
			self.cmbInvoiceStatus.itemData[self.cmbInvoiceStatus.newIndex] := invoiceStatus.id;
		endforeach;
	
	endif;
	self.cmbInvoiceStatus.sorted := false;
	self.cmbInvoiceStatus.addItemAt(app.getErrorString(CM_Any_Status),1);
	self.cmbInvoiceStatus.itemData[self.cmbInvoiceStatus.newIndex] := CM_Invoice.INVOICE_ALL_STATUS;

	self.cmbInvoiceStatus.listIndex := self.cmbInvoiceStatus.newIndex;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="positionQueryFrame" id="c23d1fe7-eb0c-4f5c-bcc4-3d641c13f8ba">
        <source>positionQueryFrame() protected;
// ---------------------------------------------------------------------------
// Created:     15 March 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 24 Feb 2023	navmv20 TFS 56403 Task 56404: UI - Invoice List add Category
// ---------------------------------------------------------------------------

vars

begin
	/*  // ### TFS BUG 58793 26JUN2023 NAVAB1
	self.frmQuery.left		:=	(self.width / 2) - (self.frmQuery.width / 2);
	self.frmQuery.top		:=	100;
	*/
	//self.frmQuery.height	:=	395;	//325; 10 Aug 2021	NDl	TSF 51702 // 24/02/2023 navmv20 TFS 56403 Task 56404
	self.frmQuery.height	:=  450; //24/02/2023	navmv20 TFS 56403 Task 56404
	self.frmQuery.width		:=	400; // ### TFS 50421 17SEP2021 NAVAB1
	
	self.frmQuery.centreVerticallyInParent(); // ### TFS BUG 58793 26JUN2023 NAVAB1
	self.frmQuery.centreHorizontallyInParent(); // ### TFS BUG 58793 26JUN2023 NAVAB1
	
	
	self.fldQuery.top		:=	self.frmQueryToolbar.clientHeight()+2;
	self.fldQuery.left		:=	0;
	self.fldQuery.height	:=	frmQuery.clientHeight() - (self.frmQueryToolbar.height + 30);
	self.fldQuery.width		:=	self.frmQuery.clientWidth();

