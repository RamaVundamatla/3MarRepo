    <ImplicitInverseRef name="btnCancel" id="08586b03-c052-4148-b2cd-391940be46d4">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="btnOK" id="f0ca80c4-2445-47c4-a489-72440d69054f">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblPrompt" id="0f08b81c-496f-4447-aec0-f39400b474cc">
        <embedded/>
        <type name="Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="mySelectedMachineDesc" id="25a1adb9-6cd8-464c-98d7-04abf1a57f9c">
        <embedded/>
        <type name="MachineDescriptor"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="tblMachines" id="c0548834-ebbf-48b8-a968-a2e182aac05a">
        <embedded/>
        <type name="Table"/>
    </ImplicitInverseRef>
    <JadeMethod name="btnCancel_click" id="81e70366-3fa6-4728-8b1a-df87b886d195">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;

begin
	self.modalResult := 1;
	self.unloadForm;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOK_click" id="911c92e0-76b3-4838-8034-508a4e068548">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOK_click(btn: Button input) updating;

begin
	self.modalResult := 0;
	self.unloadForm;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="load" id="1f31dfe2-3a1b-4755-b493-774efc0cb9ed">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

vars
	md : MachineDescriptor;
	tbl : Table;
	
begin
	tbl := self.tblMachines;

	tbl.rows := tbl.fixedRows;
	tbl.accessCell(1, 1).text := "Machine" &amp; Tab &amp; "Processes";
	tbl.accessColumn(2).alignment := Table.Alignment_Center;
	
	foreach md in app.mySession.allMachineDescriptors do
		tbl.addItem(md.name &amp; Tab &amp; md.allProcessDescriptors.size.String);
		tbl.accessCell(tbl.rows, 1).itemObject := md;
	endforeach;
	
	tbl.columnWidth[1] := (tbl.clientWidth * 0.75).Integer;
	tbl.columnWidth[2] := tbl.clientWidth - tbl.columnWidth[1];

	self.centreWindow;
end;</source>
    </JadeMethod>
    <JadeMethod name="tblMachines_dblClick" id="239fb18a-9e39-478d-9a6b-3f2fc0d12187">
        <controlMethod name="Table::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMachines_dblClick(table: Table input) updating;

begin
	if self.mySelectedMachineDesc &lt;&gt; null then
		self.btnOK_click(self.btnOK);
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblMachines_mouseDown" id="a5dc3240-4cb2-4b5d-8a3c-6b3470d0c960">
        <controlMethod name="Table::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMachines_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;

vars
	r, c : Integer;
	obj : Object;
	
begin
	self.mySelectedMachineDesc := null;
	
	table.clearAllSelected;
	
	if not table.getCellFromPosition(x, y, r, c) then
		return;
	endif;

	if r &lt; 1 or r &lt;= table.fixedRows or r &gt; table.rows then
		return;
	endif;
	table.row := r;

	table.column := 2;
	table.selected := true;
	table.column := 1;
	table.selected := true;

	obj := table.accessCell(r, 1).itemObject;
	if obj = null or (not MachineDescriptor.hasInstance(obj)) then
		return;
	endif;

	self.mySelectedMachineDesc := obj.MachineDescriptor;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
</GUIClass>
