    <JadeMethod name="getPicture" id="5315678a-8c6d-472f-83d6-00ddeddba0ac">
        <source>getPicture(_bgpObject : BGP_Object; _isController : Boolean) :Binary protected;

// cnwdvb1 31 July 2003 

vars

begin

	if _bgpObject.isRunning() then
		return self.picTick.picture;
	else
		if _isController and not _bgpObject.BGP_Controller.isSetup then
			return self.picAlert.picture;
		endif;
		return self.picCross.picture;
	endif;

end;</source>
