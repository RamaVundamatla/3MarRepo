    <JadeMethod name="doNext" id="e4b82a10-00d6-4b8a-a4ea-92826551cedd">
        <updating/>
        <source>doNext() updating, protected;

vars
	indx		: Integer;
	user		: CM_User;
	listBox		: ListBox;
	typesForm 	: CMUI_CargoEnqConfigCopyTypes;
begin

	create typesForm transient;
	listBox := self.lstUserTo;
	foreach indx in 1 to listBox.listCount do
		user := listBox.itemObject[indx].CM_User;
		typesForm.allUsers.add(user);
	endforeach;
	typesForm.copyFrom := false;
	typesForm.setMyTerminal(self.myTerminal);
	typesForm.centreWindow;
	//typesForm.show;
	typesForm.showModal;	// 10/02/2015 cnwar2 #34359

	self.unloadForm();
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUserAdd" id="e9c2508c-a247-467d-b702-4870dbae50f5">
        <updating/>
        <source>doUserAdd() updating, protected;
// all selected users
vars
	indx,
	indx2	: Integer;
	userName	: String;
	ia		: IntegerArray;
	user	: CM_User;
	listBox	: ListBox;
begin
	listBox := self.lstUserFrom;
	create ia transient;
	foreach indx in 1 to listBox.listCount do
		if listBox.itemSelected[indx] then
			user := listBox.itemObject[indx].CM_User;
			if user.userName = null then
				userName := user.code;
			else
				userName := user.userName; 
			endif;
			indx2 := self.lstUserTo.addItem(userName);
			lstUserTo.itemObject[indx2] := user;
			ia.add(indx);
		endif;
	endforeach;
	
	foreach indx in ia reversed do
		listBox.removeItem(indx);
	endforeach;
	listBox.clearAllSelected();
	self.btnNext.enabled := (self.lstUserTo.listCount &gt; 0);

epilog
	delete ia;
end;</source>
        <access>protected</access>
    </JadeMethod>
