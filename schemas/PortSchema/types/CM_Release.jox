    <JadeMethod name="createTransaction" id="a8f07313-4e3c-4c44-9c06-7b84a627692c">
        <source>createTransaction(_passport : CM_Passport input) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 August 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	ti	: CM_TrackedItem;
	txnParams	: CMIF_StorageTransController;
begin
	ti:=self.myTrackedItem;
	// Create storage transactions
	create txnParams transient;
	txnParams.type 			:= TRANS_TYPE_STORAGE;
	txnParams.dateTime 		:= self.dateTime;
	txnParams.noCharge 		:= self.noCharge;
	// PAR 16898 - RJS June 2008
	txnParams.freightForwarderCode	:= self.freightForwarderCode;
	txnParams.operatorCode 	:= self.operatorCode;
	txnParams.urNumber		:= self.urNumber;
	txnParams.userId		:= self.userId;
	ti.createTransaction(txnParams, _passport);
	
epilog
	delete txnParams;
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCCEventProperties" id="3058469a-8b86-450c-b53b-c760bc93da7c">
        <source>getCCEventProperties(ccEvent: CMIF_CCEvent) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2019	jlgndl1	Initial creation	TFS 45963

*/

vars

	releaseType : String;
	
begin

	releaseType := self.getReleaseTypeforCC();

	inheritMethod(ccEvent);
	
	ccEvent.addText( "releaseType", releaseType );
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="ccEvent" type="CMIF_CCEvent"/>
    </JadeMethod>
