    <JadeMethod name="xCM_KPIVoyageExposeMethods" id="982effc6-ed81-430f-8271-c6cc4fc5ed7b">
        <updating/>
        <source>xCM_KPIVoyageExposeMethods(_features : CMIF_ExternalDBFeatureSet input; _theClass,_parentClass : Class) protected, updating;
//27/09/2011 cnwdz2 CCMS 1254 PAR 28270
vars
	xdbFeature  : CMIF_ExternalDBFeature;
	classColl	: ClassColl;
	methodDict	: MethodNDict;
	aMethod		: Method;
	xClass		: Class;
	niceName	: String;
begin
	//expose methods
	//_theClass := CM_KPIVoyageTotals;
	//_parentClass := CM_KPIVoyageEntity;
	create classColl transient;
	_theClass.allSuperclassesUpTo(classColl, _parentClass);
	
	foreach xClass in classColl do
		delete methodDict;
		create methodDict transient;
		xClass.getMethods(methodDict);
	
		foreach aMethod in methodDict do
			if aMethod.name[1] = 'z' or
			   aMethod.name[1] = '_' or
			   aMethod.name[1:3] = 'jrw' or 
			   aMethod.name[1:3] = 'set' or 
			   aMethod.name[1:5] = 'reset' or
			   aMethod.name = 'create' or
			   aMethod.name = 'calculateTotalTime'
			   then
				continue;
			endif;
			if (not aMethod.cnGetParameters.isEmpty()) then
				// method has parameters so cannot be called from SQL
				continue;
			endif;
			
			niceName := null;
			if aMethod.name.length &gt; 3 and aMethod.name[1:3] = 'get' then
				niceName := aMethod.name[4:end];
				
				if niceName.length &gt; 3 then
					if niceName[1:3] = 'All' then
						niceName := 'tot' &amp; niceName[4:end];
					elseif niceName[1:3] = 'DLR' then
						niceName := 'dlr' &amp; niceName[4:end];
					elseif niceName[1:3] = 'SOB' then
						niceName := 'sob' &amp; niceName[4:end];
					else
						niceName := niceName[1].toLower &amp; niceName[2:end];
					endif;
				endif;
			endif;
			
			create xdbFeature transient;
			xdbFeature.setupAndBuildSet(aMethod.name, _theClass.name, niceName, "", _features);
		endforeach;
	endforeach;
epilog
	delete classColl;
	delete methodDict;
end;</source>
        <access>protected</access>
        <Parameter name="_features" type="CMIF_ExternalDBFeatureSet" usage="input"/>
        <Parameter name="_theClass" type="Class"/>
        <Parameter name="_parentClass" type="Class"/>
    </JadeMethod>
