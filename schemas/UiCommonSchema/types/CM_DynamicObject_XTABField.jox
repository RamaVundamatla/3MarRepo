    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <Constant name="Function_Count" id="7afc00a4-5f10-42d6-9cc8-12c4741a74e2">
        <source>'count'</source>
        <type name="String"/>
    </Constant>
    <Constant name="Function_Max" id="c5cbd1bf-1478-4fa8-90cf-a8617e181b9b">
        <source>'max'</source>
        <type name="String"/>
    </Constant>
    <Constant name="Function_Min" id="14bc3bd5-9690-4ae5-b68a-7570484eed6d">
        <source>'min'</source>
        <type name="String"/>
    </Constant>
