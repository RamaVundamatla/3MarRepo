    <JadeMethod name="doSave" id="f78093b5-5b28-44df-991e-c210bb5ed0c7">
        <updating/>
        <source>doSave() : Boolean updating, protected;
/*
Purpose:			Transfer all "additional details" data back to parent CMUI_ReceiveCargoForm

Parameters:			

Return Value:		

Date		Who		Reason
26 August 2009	cnwdap1	Initial creation
25 November2015	cnwma1  PAR #36943 Shipping Reference error during extract
19 May 2022	navgm20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
16 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
06 April  2023	navkc1	CR# 56431 Task 56440: UI - Receive Cargo Form
*/
vars
	stops, tasks, lifts	: ObjectArray;
	parentForm			: CMUI_ReceiveCargoForm;

begin
	inheritMethod();
	
	create stops transient;
	create tasks transient;
	create lifts transient;
	
	self.lstAllStops.allSelectedObjects.copy(stops);
	self.lstToDoTasks.allSelectedObjects.copy(tasks);
	self.lstSpecialLift.allSelectedObjects.copy(lifts);
	
	parentForm := self.myParentForm.CMUI_ReceiveCargoForm;
	parentForm.doUpdateAdditionalDetails(	txtDescription.getString,
											stops, tasks,
											cmbSpecialStow.getObject.CM_SpecialStow,
											lifts,
											cmbFreightFwdr.getObject.CM_ConsigneeConsignor,
											cmbCustomsAgent.getObject.CM_CustomsAgent,
											txtHouseBOL.getString,
											txtConsignVoy.getString,
											txtEquipXchg.getString,
											txtPurchaseOrder.getString,
											txtShippingRef.getString,  //25/11/2015 cnwma1 PAR #36943
											cmbTransportMode.getString,
											txtWagon.getString.toUpper,
											txtWagonTrain.getString,	//04 Nov 2009	NDL Par 21519
											cmbWagonClass.getObject.CM_WagonClass,	//12 May 2014	NDL	Par 33615
											cmbSubTerminal.getObject.CM_SubTerminal,
											chkCurtainsIn.getBoolean,
											cmbCoolingType.getText,
											cmbVoltageType.getText,
											cmbBusUnit.getObject.CM_Bank,
											txtAddRemarks1.getString,	//03 May 2018	NDL	TFS 37795
											txtAddRemarks2.getString,	//03 May 2018	NDL	TFS 37795
											cmbShippingLine.getObject.CM_ShippingLine,	// 20 may 2022 navgm20 TFS 53204
											cmbCtryOfOrigin.getObject.CM_Country,		// 16.08.2022 navak20 TFS 54441
											cmbInvContractID.getObject.CM_InvoiceContract,	//21.02.2023 navtnr20 TFS CR 55648 Task 55663
											chkOverlanded.getBoolean()	//06/04/2023	navkc1	CR# 56431 Task 56440
											);
											
	self.unloadForm;
	self.myParentForm.setFocus;
	return true;
epilog
	delete stops;
	delete tasks;
	delete lifts;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getExtraPermissions" id="c6a001cd-7758-4f38-a7bf-8f5cf470dfb0">
        <source>getExtraPermissions(permArray: IntegerArray input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 July 2010	cnwndl1	Initial creation	Par 24983

*/

vars

begin
	inheritMethod(permArray);
	
	if not permArray.includes(PmAdmToDoTaskShowPreNote) then
		permArray.add(PmAdmToDoTaskShowPreNote);
	endif;

epilog

end;</source>
        <Parameter name="permArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="hideSelectedControls" id="6ba050ec-f6b9-4daf-8cf6-accaa470ce7a">
        <updating/>
        <source>hideSelectedControls() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 August 2009	cnwjk3	Initial creation

*/

vars

begin
	inheritMethod();
	if self.isFromFlexiGate then
		self.cmbTransportMode.isHidden := true;
	endif;
	
	if not self.isEmptyContainer then
		self.chkCurtainsIn.isHidden 	:= true;
		self.cmbCoolingType.isHidden 	:= true;
		self.cmbVoltageType.isHidden 	:= true;
	endif;
	
	// default to hiding Wagon
	self.txtWagon.isHidden := true;
	self.txtWagonTrain.isHidden := true;	//04 Nov 2009	NDL Par 21519
	// show if transport mode is rail, and we're not a rail form
	if self.cmbTransportMode.getString = TI_TRANSMODE_RAIL_STR then
		self.txtWagon.isHidden := false;
		self.txtWagonTrain.isHidden := false;	//04 Nov 2009	NDL Par 21519
	endif;
	
	// 11/03/2010 cnwmh5 #22546
	// hide subterminal if not available
	self.cmbSubTerminal.isHidden := true;
	if app.isSubTerminalsOn(self.myTerminal) then	
		self.cmbSubTerminal.isHidden := false;
	endif;
	
	if not app.getMyUser.canDo(null,PmAdmToDoTaskShowPreNote) then	//22 Jul 2010	NDL	Par 24982
		// if the user does not have this one, they are not supposed to see the to do tasks on the pre note screen.
		self.lstToDo.isHidden := true;
	endif;
	
	//epr CCMS 1409 355553 22/1/14
	if self.myTerminal.getConfig(UseReceiveReleaseEIR).Boolean then
		self.txtEquipXchg.isHidden:=true;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="isUpdatable" id="b2585af3-1f27-4e17-b26e-e3863679f3e4">
        <source>isUpdatable() : Boolean;
// -----------------------------------------------------------------------------
// Created:		15 September 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	if self.myParentForm.isKindOf(CMUI_ReceiveCargoForm) then
		return self.myParentForm.CMUI_ReceiveCargoForm.isVVRUpdatable();
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadCombos" id="4f99c284-905d-46e3-951a-005354aabe37">
        <updating/>
        <source>loadCombos() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2009	cnwdap1	Initial creation
11/03/2010	cnwmh5	PAR22546 - Only load subterminal if subterminal is on for terminal
15/03/2016	cnwdap1	PAR #37606 "Not available for entry" customs agent
19 May 2022	navgm20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field - Shipping Line - UI
16 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
27 Feb 2023 navtnr20	TFS CR 55648 Task 55663: UI - Contract Id
17 Apr 2023 navmk20		Bug 56980: MTN - Additional details form not displayed
*/
vars
	assistant	: CMUI_Assistant;
	consign		: CM_ConsigneeConsignor;
	index : Integer;
	agent 		: CM_CustomsAgent;						// PAR #37606

begin
	assistant := self.myAssistant;
	
	// Stops
	assistant.listTableStopsTable(self.lstAllStops, self.myTerminal, true);
	
	// ToDo Tasks
	//assistant.listTableToDoTasks(self.lstToDoTasks, self.myTerminal);										// 17.4.2023 navmk20 TFS 56980
	assistant.listTableToDoTasksForCargoType(self.lstToDoTasks, self.myTerminal, self.selectedCargoType);	// 17.4.2023 navmk20 TFS 56980

	// Special Stow 
	assistant.comboSpecialStow(cmbSpecialStow.getEmbeddedControl.ComboBox);
	
	// Shipping Line
	self.myAssistant.comboBoxShippingLine(self.cmbShippingLine.getEmbeddedControl.ComboBox, null);	// 19MAY2022  navgm20 TFS 53204
	
	// 16.08.2022 navak20 TFS 54441
	self.myAssistant.comboBoxCountry(self.cmbCtryOfOrigin.getEmbeddedControl.ComboBox, null);
	
	// Special Lift
	assistant.listTableSpecialLift(lstSpecialLift);

	// Freight Forwarder
	foreach consign in app.myRoot.allConsigneeConsignors where consign.isFreightFwdr do
		cmbFreightFwdr.addItemObject(consign.getYADisplay, consign);
	endforeach;
	
	// Customs Agent
	//assistant.comboBoxCustomsAgent(cmbCustomsAgent.getEmbeddedControl.ComboBox, null);		// PAR #37606
	foreach agent in app.myRoot.allCustomsAgents discreteLock do								// PAR #37606
		if agent.isNotAvailableForEntry then													// PAR #37606
			continue;																			// PAR #37606
		endif;																					// PAR #37606
		self.cmbCustomsAgent.addItemObject(agent.code &amp; Tab &amp; agent.name, agent);				// PAR #37606
	endforeach;																					// PAR #37606
	
	// Transport Mode
	assistant.comboBoxTransportModes(cmbTransportMode.getEmbeddedControl.ComboBox, null);

	// Sub-Terminal
	if app.isSubTerminalsOn(self.myTerminal) then					// 11/03/2010 cnwmh5 22546
		assistant.comboBoxSubTerminal(cmbSubTerminal.getEmbeddedControl.ComboBox, null, self.myTerminal);
	endif;															// 11/03/2010 cnwmh5 22546
	
	// Business Unit
	assistant.comboBoxBusinessUnit(cmbBusUnit.getEmbeddedControl.ComboBox, null);
	
	assistant.comboBoxWagonClass(self.cmbWagonClass.getEmbeddedControl.ComboBox, null );	//12 May 2014	NDL	Par 33615
	self.loadInvContract();//navtnr20 02-03-2023 TFS task 55663
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadInvContract" id="9802c037-f990-40bc-b99c-5fd53239282e">
        <source>loadInvContract();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Feb 2023 navtnr20	TFS CR 55648 Task 55663: UI - Contract Id

*/

vars
	contract : CM_InvoiceContract;
	combo : CMUI_FieldComboBox;
	bank : CM_Bank;
	businessUnits	: CM_CompanyByCodeDict;
	obj : Object;
	debtor : CM_Debtor;
begin
	
	combo := self.cmbInvContractID;
	combo.clear();
	if self.cmbBusUnit.getEmbeddedControl.ComboBox.listObject &lt;&gt; null and self.myOperator &lt;&gt; null then
		bank := self.cmbBusUnit.getEmbeddedControl.ComboBox.listObject.CM_Bank;
		if self.myOperator &lt;&gt; null then
			debtor := self.myOperator.debtor;
		endif;
		
		if debtor &lt;&gt; null then
			foreach contract in debtor.allInvoiceContracts where contract.myBusinessUnit = bank do		
				if contract.active then
					combo.addItemObject(contract.contractId, contract);
				endif;
			endforeach;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
