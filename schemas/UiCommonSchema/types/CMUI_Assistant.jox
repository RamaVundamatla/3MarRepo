    <JadeMethod name="comboBoxIMEXStatus" id="b0fc4389-dca6-4bb4-a0a9-518d407847a3">
        <source>comboBoxIMEXStatus(_cmb : ComboBox input; _imExStatus : Integer);
// ---------------------------------------------------------------------------
// Created:     21 February 2003		cnwth2	
//
// Purpose:     
//Changed CNWTH2 to not suck anymore	 
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 28/05/2018	jlgdap1		TFS 38560 PEL1 Voyage Work Orders
vars
	imexDict			: CM_IMEXStatusByCodeDict;
	imexStatus			: CM_IMEXStatus;
	form : Form;	//01 Jun 2011	NDL Par 27644
begin
	_cmb.clear();
	imexDict := app.myRoot.allImexStatuses;
	form := _cmb.form;	//01 Jun 2011	NDL Par 27644
	foreach imexStatus in imexDict do
		//01 Jun 2011	NDL Par 27644 - Not allowed tranship status on pre-note
		// Nov 2011 28029 don't allw remain on board
		if imexStatus.code = TI_IMEX_STATUS_TRANSHIP or
		   imexStatus.code = TI_IMEX_STATUS_REMAINONBOARD  then
			if form &lt;&gt; null and form.class.name = "GTE_PreNoteForm" then
				continue;
			endif;
		endif;
		if imexStatus.code = TI_IMEX_STATUS_REMAINONBOARD					// TFS 38560
		or imexStatus.code = TI_IMEX_STATUS_STORAGE							// TFS 38560
		or imexStatus.code = TI_IMEX_STATUS_TRANSHIP then					// TFS 38560
			if form &lt;&gt; null and form.class.name = "YRD_TaskJobTasks" then	// TFS 38560
				continue;													// TFS 38560
			endif;															// TFS 38560
		endif;																// TFS 38560
		_cmb.itemObject[_cmb.addItem(imexStatus.description)] := imexStatus;
	endforeach;
	
	if _imExStatus &lt;&gt; null then
		imexStatus := imexDict[_imExStatus];
	else
		imexStatus := imexDict[TI_IMEX_STATUS_EXPORT];	
	endif;
	
	if imexStatus &lt;&gt; null and imexStatus.code &lt;&gt; 0 then
		_cmb.listObject := imexStatus;
	endif;
	
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_imExStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxISOType" id="8f3dff31-8df6-42f8-89a3-6274a25b7a03">
        <source>comboBoxISOType(_combo : ComboBox input; _isoType : CM_ISOType);
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	_combo.listCollection(app.myRoot.allISOTypes, true, 0);
	
	if _isoType &lt;&gt; null then
		_combo.text := self.displayEntryISOType(_isoType);
		
		//epr par 290134 28/3/2012
		if _combo.findObject(_isoType) &gt; 0 then
			_combo.listObject := _isoType;
		endif;
	endif;

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_isoType" type="CM_ISOType"/>
    </JadeMethod>
    <JadeMethod name="comboBoxISOTypeByGroup" id="ba8133a0-707c-47dc-ae48-3a9ed3ee8099">
        <source>comboBoxISOTypeByGroup(_cmb : CMUI_ComboBox input; 
						_isoTypeGroup : CM_ISOTypeGroup;
						_isoType : CM_ISOType);
// ---------------------------------------------------------------------------
// Created:     15 March 2004	cnwth2
//
// Purpose:     If group passed in is null, it will load all off root - this is what the original
//				isoType method should have done, but is
//				now called from too many places to change, so this new method has been created
//			 
// ----------   ----------  --------------------------------------------------
vars
	isoDict			: CM_ISOTypeByCodeDict;
	isoType			: CM_ISOType;
begin
	_cmb.clear();
	
	_cmb.addItem(null);
	
	if _isoTypeGroup &lt;&gt; null then
		isoDict := _isoTypeGroup.allISOTypes;
	else
		isoDict := app.myRoot.allISOTypes;
	endif;

	foreach isoType in isoDict where not isoType.isNotAvailableForEntry do
	
	// changed as was populating combo with nulls for 'Not available for entry' objects and leaving gaps in the combo 
		if isoType &lt;&gt; null then 
		// want all iso types as this metod is called for filter combos so include 'Not available for entry' 
			_cmb.addItemObject(isoType.code &amp; Tab &amp; isoType.description, isoType);
		endif;
	endforeach;
	
	if _isoType &lt;&gt; null and
	   isoDict.includesKey(_isoType.code) then
		_cmb.text := self.displayEntryISOType(_isoType);
	endif;
	
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_isoTypeGroup" type="CM_ISOTypeGroup"/>
        <Parameter name="_isoType" type="CM_ISOType"/>
    </JadeMethod>
    <JadeMethod name="comboBoxISOTypeForCargoType" id="a76933d0-3e9a-4e02-be94-9fa08cfc0039">
        <source>comboBoxISOTypeForCargoType(_combo :CMUI_ComboBox input; _cargoType :CM_CargoType; _isoType :CM_ISOType);
/*
Date		Who		Reason
22 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	isoType 	: CM_ISOType;
	isoFound	: Boolean;
begin
	
	_combo.clear();
	
	foreach isoType in _cargoType.allISOTypes do
		if isoType = _isoType then
			isoFound := true;
		endif;
		_combo.itemObject[ _combo.addItem(isoType.code.trimRight &amp; Tab &amp; isoType.description.trimRight)] := isoType;
	endforeach;

	if _isoType &lt;&gt; null and isoFound then
		_combo.text := self.displayEntryISOType(_isoType);
	endif;
	
end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_isoType" type="CM_ISOType"/>
    </JadeMethod>
    <JadeMethod name="comboBoxISOTypeForGenerator" id="9c08a483-30c1-4723-9c3f-e8075cf9d4f4">
        <source>comboBoxISOTypeForGenerator( _cmb : ComboBox input; _isoType : CM_ISOType );
/* ---------------------------------------------------------------------------
Created:	22 August 2008	by cnwvu1

Purpose:	Par 17775. ccms 1045. Reefers are actual for generators
   
Change Date		Who		Reason
16/04/2018		cnwma1  Bug 37937: Bug from Functional Review of 7418
------------------------------------------------------------------------------*/
vars
	isoType : CM_ISOType;
	isoFound: Boolean;
	
begin
	
	_cmb.clear();
	
	foreach isoType in app.myRoot.allISOTypes do
		//if isoType.isReefer() then  		//16/04/2018 cnwma1 Bug # 37937
			if isoType = isoType then
				isoFound := true;
			endif;
			_cmb.itemObject[ _cmb.addItem(isoType.code.trimRight &amp; Tab &amp; isoType.description.trimRight)] := isoType;
		//endif;
	
	endforeach;

	if _isoType &lt;&gt; null and isoFound then
		_cmb.text := self.displayEntryISOType(_isoType);
		//_cmb.listObject := _isoType;
	endif;
	
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_isoType" type="CM_ISOType"/>
    </JadeMethod>
    <JadeMethod name="comboBoxISOTypeGroup" id="99cda013-065d-4327-8f62-fb4973aed2d5">
        <source>comboBoxISOTypeGroup(_cmb : ComboBox input; pISOTypeGroup : CM_ISOTypeGroup);
// ---------------------------------------------------------------------------
// Created:     20 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	isoGroupDict		: CM_ISOTypeGroupByCodeDict;	
	isoTypeGroup		: CM_ISOTypeGroup;
begin
	
	_cmb.clear();
	_cmb.sorted := false;
	_cmb.addItem(null);
	isoGroupDict := app.myRoot.allISOTypeGroups;
	
	foreach isoTypeGroup in isoGroupDict do
		_cmb.itemObject[_cmb.addItem(self.displayEntryISOTypeGrp(isoTypeGroup))] := isoTypeGroup;
	endforeach;
	
	if pISOTypeGroup &lt;&gt; null then
		if isoGroupDict.includesKey(pISOTypeGroup.code) then
			_cmb.text := self.displayEntryISOTypeGrp(pISOTypeGroup);
		endif;
	endif;
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="pISOTypeGroup" type="CM_ISOTypeGroup"/>
    </JadeMethod>
    <JadeMethod name="comboBoxISOTypeGroupFilter" id="45453ece-ef75-4871-8ce8-f7d5d99dbb8a">
        <source>comboBoxISOTypeGroupFilter(_cmb : CMUI_ComboBox input; _isoTypeGroup : CM_ISOTypeGroup);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 March 2010	cnwmh5	Initial creation

*/

vars
	tempISOGroup : CM_ISOTypeGroup;
begin	
	//epr TFS 5831 25/8/17
	if _isoTypeGroup = null then
		self.comboBoxISOTypeGroup(_cmb, null);		
		return;
	endif;
	tempISOGroup := _cmb.listObject.CM_ISOTypeGroup;
	_cmb.clear();
	_cmb.sorted := false;
	_cmb.addItem(null);
	if app.myRoot.allISOTypeGroups[_isoTypeGroup.code] = null then
		return;
	endif;
	
	_cmb.addItemObject(self.displayEntryISOTypeGrp(_isoTypeGroup),_isoTypeGroup);	
	if _isoTypeGroup = tempISOGroup then
		_cmb.listIndex :=2;
	endif;

	
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_isoTypeGroup" type="CM_ISOTypeGroup"/>
    </JadeMethod>
    <JadeMethod name="comboBoxISOTypeOtherForReports" id="85c9cb29-f1ba-44c7-9910-3b1bc75eb789">
        <source>comboBoxISOTypeOtherForReports( _cmb : ComboBox input; _isISOTypeIncludedForReports : Integer );
// ------------------------------------------------------------------------------------------------
// Created:		21 April 2008  by cnwvu1
//
// Purpose:		for 30, 45 and 53 footers to be included
//				for reports
// ------------------------------------------------------------------------------------------------
vars
	idx		: Integer;
	
begin
	
	if _cmb = null then
		return;
	endif;
	
	_cmb.clear;
	
	idx := _cmb.addItem( app.getErrorString( MSG_ISOTypeAsNotIncluded ) );
	_cmb.itemData[idx] := ISOTypeOtherNotIncluded;
	
	idx := _cmb.addItem( app.getErrorString(MSG_ISOTypeAsOwn) );
	_cmb.itemData[idx] := ISOTypeOtherIncludedAsOwn;
	
	idx := _cmb.addItem( app.getErrorString(MSG_ISOTypeAsOther) );
	_cmb.itemData[idx] := ISOTypeOtherIncludedAsOther;
	
	_cmb.text := app.getISOTypeOtherForReportsDescr( _isISOTypeIncludedForReports ); 
	
end;
</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_isISOTypeIncludedForReports" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxITSMessageStatus" id="43053f3c-4842-4d59-afd0-7d1c133deb00">
