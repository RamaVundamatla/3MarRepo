    <JadeMethod name="getNumLoadDisch" id="3dd5f163-cb30-413f-9c70-cb0c61733804">
        <source>getNumLoadDisch(_numLoad, _numDisch, _numLoadNotPlanned, _numDischNotPlanned : Decimal output);
/*
Purpose:			
Date		Who		Reason
22 August 2011	cnwab1	Initial creation
*/

vars
	roroLC : CM_VoyageROROController;
	numPlanned : Integer;
begin
	foreach roroLC in self.allROROControllers discreteLock do
		if roroLC.myRORORequestDischarge &lt;&gt; null then
			_numDisch := _numDisch + roroLC.myRORORequestDischarge.quantity;
			numPlanned := roroLC.myRORORequestDischarge.getNumTIsOfMode(PLANNING_MODE,false);
			_numDischNotPlanned := roroLC.myRORORequestDischarge.quantity - numPlanned;
		endif;
		if roroLC.myRORORequestLoad &lt;&gt; null then
			_numDisch := _numDisch + roroLC.myRORORequestLoad.quantity;
			numPlanned := roroLC.myRORORequestLoad.getNumTIsOfMode(PLANNING_MODE, false);
			_numLoadNotPlanned := roroLC.myRORORequestLoad.quantity - numPlanned;
		endif;
	
	endforeach;
epilog

end;</source>
        <Parameter name="_numLoad" type="Decimal" usage="output"/>
        <Parameter name="_numDisch" type="Decimal" usage="output"/>
        <Parameter name="_numLoadNotPlanned" type="Decimal" usage="output"/>
        <Parameter name="_numDischNotPlanned" type="Decimal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getOOWCreation" id="8ae701d7-01e4-4432-bf9b-e4f4b468d6f0">
        <source>getOOWCreation(_order : Integer io);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	voyageAllocation : CM_VoyageAllocation;
	roroRequest	 	: CM_RORORequest;
	requestsByDeck : CM_RORORequestByDeck;
	iter, requestsIter : Iterator;
	voyage : CM_Voyage;
	dupOOWCreation,
	loadSlotOOWC,
//	load40SlotOOWC,
	//loadOtherSlotOOWC,
	dischargeSlotOOWC,
	gcOOWC
	//discharge40SlotOOWCC,
	//dischargeOtherSlotOOWCC
	: CM_OOWCreationRORODetail;
	theOrder : Integer;
begin

	voyage:=self.getVoyage;
	if voyage = null then
		return;
	endif;
	
	create requestsByDeck transient;
	
	iter:=voyage.allVoyageAllocations.createIterator;
	while iter.next(voyageAllocation) do
		if voyageAllocation.allRequests.isEmpty then
			continue;
		endif;
		requestsByDeck.clear;
		voyageAllocation.allRequests.copy(requestsByDeck);
		loadSlotOOWC:=null;
		dischargeSlotOOWC:=null;
		delete requestsIter;
		requestsIter:=requestsByDeck.createIterator;
		requestsByDeck.startKeyGeq(self,requestsIter);
		while requestsIter.next(roroRequest) do
			
			if roroRequest.getDeck &lt;&gt; self then
				break;
			endif;
			
			// seperate into load slot
			if roroRequest.myROROControllerLoad &lt;&gt; null then
				if roroRequest.isKindOf(CM_ROROSlotRequest) then
					
					//load slot request
					if loadSlotOOWC = null then
						create loadSlotOOWC;
						loadSlotOOWC.setDetails(self,_order,voyageAllocation.getIs40);
						 _order:=_order + CM_OOWCreation.OOWCreationIncrement;				
					endif;
					loadSlotOOWC.addRORORequest(roroRequest);
				
				elseif roroRequest.isKindOf(CM_ROROGCRequest) then
					// load gc 
					create gcOOWC;
					gcOOWC.setDetails(self,_order,false);
					_order:=_order + CM_OOWCreation.OOWCreationIncrement;	
					gcOOWC.addRORORequest(roroRequest);
				endif;
			
				
			elseif roroRequest.myROROControllerDischarge &lt;&gt; null then
				
				if roroRequest.isKindOf(CM_ROROSlotRequest) then
				//discharge slot
					//load slot request
					if dischargeSlotOOWC = null then
						create dischargeSlotOOWC;
						dischargeSlotOOWC.setDetails(self,_order,voyageAllocation.getIs40);
						 _order:=_order + CM_OOWCreation.OOWCreationIncrement;				
					endif;
					dischargeSlotOOWC.addRORORequest(roroRequest);
				elseif roroRequest.isKindOf(CM_ROROGCRequest) then
				//discharge gc
					create gcOOWC;
					gcOOWC.setDetails(self,_order,false);
					_order:=_order + CM_OOWCreation.OOWCreationIncrement;	
					gcOOWC.addRORORequest(roroRequest);
				endif;
			endif;
		endwhile;
	endwhile;

epilog
	delete iter;
	delete requestsByDeck;
	delete requestsIter;
end;</source>
        <Parameter name="_order" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getPlanningGuide" id="2af9476c-107b-4458-a06b-c840a63bf5f3">
        <source>getPlanningGuide(_guide : CMIF_PlanningGuideBay input);
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
24/04/2013			cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars

	srSet : CM_RORORequestSet;
	cc : Integer;
	slotReq : CM_RORORequest;
begin

	if _guide = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'Guide reference', null, null);
	endif;

	_guide.hasRemarks := self.remarks &lt;&gt; null;
	//------------------------------------------------------------------------
	// Get the slot counts for this bay, both discharge and load colourcodes
	//------------------------------------------------------------------------
	create srSet transient;
	
	foreach cc in DISCHARGE_COLOURCODE to LOAD_COLOURCODE do
		self.getActiveROROReqsForColourCode(cc, srSet);
		foreach slotReq in srSet do
			slotReq.getPlanningGuide(_guide, cc);
		endforeach;		
	endforeach;
epilog
	delete srSet;
end;</source>
        <Parameter name="_guide" type="CMIF_PlanningGuideBay" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getPlanningTotals" id="9d670364-b912-45f6-9934-ca524c8ca713">
        <source>getPlanningTotals(_totalLoad,_totalDischarge,_totalLoadToPlan,_totalDischargeToPlan, _totalTodo : Integer io);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 September 2011	cnwer1	Initial creation CCMS MES 1033
Jul 2013			cnwjre1	31977 accumulate todo totals as well - added _totalTodo parameter
*/

vars
	iter : Iterator;
	slotController : CM_VoyageROROController;
	loadRequest,dischargeRequest : CM_RORORequest;
begin

	iter:=self.allROROSlotControllers.createIterator;
	while iter.next(slotController) do
		loadRequest:=slotController.myRORORequestLoad;
		if loadRequest &lt;&gt; null then	
			loadRequest.getPlannedLoadTotals(_totalLoad,_totalLoadToPlan, _totalTodo);
		endif;
		
		dischargeRequest:=slotController.myRORORequestDischarge;
		if dischargeRequest &lt;&gt; null then
			dischargeRequest.getPlannedDischargeTotals(_totalDischarge,_totalDischargeToPlan, _totalTodo);
		endif;
		
	endwhile;
	
	delete iter;
	iter:=self.allROROGCControllers.createIterator;
	while iter.next(slotController) do
		loadRequest:=slotController.myRORORequestLoad;
		if loadRequest &lt;&gt; null then	
			loadRequest.getPlannedLoadTotals(_totalLoad,_totalLoadToPlan, _totalTodo);
		endif;
		
		dischargeRequest:=slotController.myRORORequestDischarge;
		if dischargeRequest &lt;&gt; null then
			dischargeRequest.getPlannedDischargeTotals(_totalDischarge,_totalDischargeToPlan, _totalTodo);
		endif;
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_totalLoad" type="Integer" usage="io"/>
        <Parameter name="_totalDischarge" type="Integer" usage="io"/>
        <Parameter name="_totalLoadToPlan" type="Integer" usage="io"/>
        <Parameter name="_totalDischargeToPlan" type="Integer" usage="io"/>
        <Parameter name="_totalTodo" type="Integer" usage="io"/>
    </JadeMethod>
