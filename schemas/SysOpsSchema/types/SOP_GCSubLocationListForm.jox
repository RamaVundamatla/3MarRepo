        <updating/>
        <source>lstShelves_dblClick(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     29 October 2013 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.doUpdate();

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="populateData" id="84ab88ae-3bf3-4761-b3c2-0faa7563f559">
        <updating/>
        <source>populateData() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2013	cnwndl1	Initial creation	Par 32308

*/

vars

	lc : CM_IrregularBlockController;
	index : Integer;

begin
	self.lstShelves.selectionType := Table.SelectMode_FixedRow;
	self.lstShelves.rows := 0;
	self.lstShelves.columns := 4;
	self.lstShelves.addItem(app.getErrorString(Name) &amp; Tab &amp;
							app.getErrorString(Capacity) &amp; Tab &amp;
							app.getErrorString(YAMaxCapacity) &amp; Tab &amp;	// 22 Jul 2020	NDL	TFS 49775
							app.getErrorString(Maximum_Weight) &amp; Tab &amp;
							app.getErrorString(Interchange_area));
	
	self.lstShelves.fixedRows := 1;
	self.lstShelves.fixedColumns := 0;
	self.lstShelves.rows := self.lstShelves.fixedRows;

	if self.myRackLocation = null then
		self.txtName.text := null;
		self.lstShelves.rows := self.lstShelves.fixedRows;
		
	else
		self.txtName.text := self.myRackLocation.ident;
		self.setCaption( app.getErrorString1( Shelf_enquiry, self.txtName.text ) );
		
		foreach lc in self.myRackLocation.allSubLocations do
			index := self.lstShelves.addItem( lc.getDisplayStringForDefnList()  );
			self.lstShelves.accessRow(index).itemObject := lc;
		endforeach;
		
	endif;

epilog

end;</source>
    </JadeMethod>
