    <JadeMethod name="showHideToolbar" id="8b7709b4-1a4b-47f1-9e43-7f5095b5db1f">
        <updating/>
        <source>showHideToolbar(menuItem : MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     08 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	newValue	: Boolean;
	toolbar		: CMUI_Toolbar;
begin

	toolbar := self.frmToolbar;
	newValue := (not toolbar.visible);
	toolbar.visible := newValue;
	
	if newValue then
		self.refreshToolbar();
		menuItem.caption := 'Hide Toolbar';
	else
		menuItem.caption := 'Show Toolbar';
	endif;
	
	self.doResize();

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showModal" id="154b5691-f2eb-4056-ac05-015a374c95bc">
        <updating/>
        <source>showModal(): Integer updating;
// ---------------------------------------------------------------------------
// Created:     01 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 06 Apr 2011	cnwkpd1		Added code in for JBL testing
// 12/03/2018	jlgdap1		TFS 37427 PEL1 Voyage Status Enhancements
// 14/14/2022	navma1		ChangeRequest 52821: EUP - Documents Linked to Cargo Type
// 22 July 2022 navhl20 	TFS 53862 EUP - WMS - Damage Recording Extra Details
// ---------------------------------------------------------------------------

vars
	retCode			   : Integer;
	tmpTerm			   : CM_Terminal;	//29 Aug 2017	NDL	TFS 5843
	isSystemPermission : Boolean;
	user 			   : CM_User;		//18 Sep 2017	NDL	TFS 6984
	
begin
	self.isBaseFormModal := true;
	
	if currentSchema.name = "JtdDriverSchema" or
	   currentSchema.name = "AtcgTestCodeSchema" then
		//app.setPropertyValue("atcgMyModalForm", self);  // par 105
		retCode := app.sendMsg("atcgHandleShowModal").Integer;
		if retCode = 99999 then
			return inheritMethod();  // so it works in capture mode
		else
			return retCode;
		endif;
	endif;
	
	//epr TFS 4677 27/6/17 
	if self.permissionView &lt;&gt; null  then
		//29 Aug 2017	NDL	TFS 5843 - To catch where forms are not populated with term
		tmpTerm := self.myTerminal;
		if tmpTerm = null then
			isSystemPermission := app.getMyRoot.mySecurityRoleSystem.permissions[self.permissionView];
			if not isSystemPermission then
				executeWhen JMTDevelopmentEnvironment;
				//if not(self.myParentForm.isKindOf(CMUI_PackageConfigForm) and self.CMUI_ObjectCriteriaLineForm.context = CM_ObjectMatchCriteria.VvrPackageInt) then	// TFS 37427
				if not(self.myParentForm.isKindOf(CMUI_VoyStatusEmailForm) 
					or self.myParentForm.isKindOf(CMUI_InvStatusEmailForm)	// TFS 39618																				// TFS 37427
					or self.myParentForm.isKindOf(CMUI_FileAttachmentsForm)	//16.03.2022 navma1 #52821
					or (self.myParentForm.isKindOf(CM_TableViewForm) and self.CMUI_ObjectCriteriaLineForm.context = CM_ObjectMatchCriteria.StopCriteriaInt)  //22 July 2022 navhl20 TFS 53862
					or self.myParentForm.isKindOf(CMUI_ObjectCriteriaLineForm)																				 //22 July 2022 navhl20 TFS 53862
					or (self.myParentForm.isKindOf(CMUI_PackageConfigForm) and self.CMUI_ObjectCriteriaLineForm.context = CM_ObjectMatchCriteria.VvrPackageInt)) then	// TFS 37427
						write self.myParentForm;
						app.msgBox(self.name &amp; " has NOT had its 'myTerminal' attribute set.", "Dev Error", MsgBox_OK_Only);
				endif;
				endExecuteWhen;
				tmpTerm := app.myPassport.myTerminal;
				//18 Sep 2017	NDL	TFS 6984
				if tmpTerm = null then
					//still found nothing, just get the users first terminal.
					user := app.myPassport.myUser;
					if user &lt;&gt; null and not user.allUserTerminals.isEmpty then
						tmpTerm := user.allUserTerminals.first.myTerminal;
					endif;
				endif;
			endif;
		endif;
		if (not app.myCurrentUserCan(tmpTerm, self.permissionView)) then
			// user does not have access to view form
			app.msgBox(app.getErrorString1(VB_SECSHOW, self.caption), "Security Warning", MsgBox_Stop_Icon);
	//		delete self;
			return null;
		endif;
	endif;
	
	return inheritMethod();
	
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showNavigatorForm" id="5424e738-2e82-4695-9033-d8b41936d5d0">
        <source>showNavigatorForm();
// ---------------------------------------------------------------------------
// Created:     30 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 05/02/2007	cnwdad1		For Comalco, if the Navigator button is clicked
//							with a navigator window already open, then the
//							navigator will be maximized.
// 11/3/14		epr 		 voyage commodity planning as part of bulk CCMS 1366 
// ---------------------------------------------------------------------------
vars
	navForm	: CMUI_Navigator;

begin
	navForm := app.getForm(CMUI_Navigator.name).CMUI_Navigator;
	
	if navForm = null then
		navForm := app.loadForm(CMUI_Navigator, null, false, true, false, null, null).CMUI_Navigator;
	else

		navForm.show();
	endif;
	
	navForm.setFocus;
	navForm.zOrder(1);
end;</source>
    </JadeMethod>
    <JadeMethod name="showPermissionValues" id="06d6bc76-24c6-49c9-8233-618d063b4d8a">
        <source>showPermissionValues();
// ---------------------------------------------------------------------------
// Created:     12 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	permsArray	: IntegerArray;
	permAgent	: CM_PermissionAgent;
	theCaption	: String;
begin

	create permsArray transient;
	permsArray.add(self.permissionView);
	if self.permissionView &lt;&gt; self.permissionMaint then
		permsArray.add(self.permissionMaint);
	endif;
	
	self.getExtraPermissions(permsArray);
	
	theCaption := self.caption;
	if app.isSpecial then
		theCaption := self.class.name &amp; ': ' &amp; self.caption;
	endif;

	create permAgent transient;
	permAgent.showPermDetails(theCaption, permsArray, app.getMyUser, self.myTerminal);
	
epilog
	delete permsArray;
	delete permAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="showPopupInfoFrame" id="21d442b8-189a-464e-a377-a06463f3619e">
        <source>showPopupInfoFrame(thePIC : CMIF_PopupInfoController input);
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	PIC_GAP = 10;
vars
	dataContainer : CM_DataContainer;
	theTI : CM_TrackedItem;
	maxPicHeight : Integer;
	thePicture : Binary;
	showCargoPicture : Boolean;
	tmpObj	: Object;
	numTIs	: Integer;
begin
	if thePIC.theFrame.visible then
//		return; // PAR 11408 
	endif;
	thePIC.theFrame.width := 730;
	tmpObj := thePIC.myObject;
	
	if tmpObj = null then
		return;
	endif;

	//######################
	// GET DATA INFO
	create dataContainer transient;
	dataContainer.displayMode := thePIC.displayMode;
	if tmpObj.isKindOf(CM_Object) then
		tmpObj.CM_Object.getExtraInfo(dataContainer);
		if CM_TrackedItem.hasInstance(tmpObj) then
			theTI := tmpObj.CM_TrackedItem;
		elseif CM_SlotController.hasInstance(tmpObj) then
			theTI := tmpObj.CM_SlotController.getTIForDisplayMode(thePIC.displayMode, 1, numTIs);
		endif;
	elseif tmpObj.isKindOf(CMUI_GridPoint) then
		tmpObj.CMUI_GridPoint.getExtraInfoForPoint(thePIC.gridPointX,thePIC.gridPointY,dataContainer);
		theTI := tmpObj.CMUI_GridPoint.getTI(thePIC.gridPointX,thePIC.gridPointY) ;
	else
		return;
	endif;
	if dataContainer.allBlocks.isEmpty or dataContainer.allBlocks.size = 1 and app.isDevelopmentSystem then
		return;
	endif;

	showCargoPicture := self.myTerminal.getConfig(ShowCargoPicture).Boolean;
	
	//######################
	// GET CARGO ATTRIBUTES
	dataContainer.headerColour := self.colorHeadingColumn;
	dataContainer.valueColour := self.colorValueColumn;

	//######################
	// SHOW DATA INFO	
//	self.showExtraInformation(dataContainer, thePIC.theTable.CM_DataTable, true,false, 12, 4,	12, 1,2);
	self.showExtraInformation(dataContainer, thePIC.theTable.CM_DataTable, true,false, 4,1,4,1,1);
	
	thePIC.theTable.defaultRowHeight := 15;
	thePIC.theTable.move(1,thePIC.theToolbarFrame.height + 1,thePIC.theFrame.clientWidth - 2,(thePIC.theTable.defaultRowHeight * thePIC.theTable.rows));

	self.doResizeColumnWidths(thePIC.theTable, false);
	thePIC.theFrame.height := thePIC.theTable.top + thePIC.theTable.height + 100;
	thePIC.thePictureFrame.left := 2;
	thePIC.thePictureFrame.top := thePIC.theTable.top + thePIC.theTable.height + 2;

	thePIC.thePictureFrame.visible := false;
	thePIC.thePicture.picture := null;
	thePIC.thePicture.visible := true;
	thePIC.thePicture.show3D := Frame.Show3D_Not3D;

	thePIC.theButtonEnquiry.visible := thePIC.showEnquiryButton;
	if theTI &lt;&gt; null then
		if showCargoPicture then
			thePicture := theTI.getPicture();
			thePIC.thePicture.picture := thePicture;
			thePIC.thePictureFrame.visible := true;
		endif;		
		//######################
		// SETUP THE ENQUIRY BUTTON	
		thePIC.theFrame.userObject := theTI;
		thePIC.theFrame.caption := theTI.id;
		thePIC.theButtonEnquiry.bubbleHelp := "Enquire On " &amp; theTI.id;
		thePIC.theButtonEnquiry.visible := true;
	endif;
	//######################
	// REPOSITION CONTROLS
	thePIC.theTable.borderStyle := Frame.BorderStyle_None;
	if showCargoPicture then
	 	if thePIC.thePictureFrame.visible then
			maxPicHeight := thePIC.thePicture.height.Integer + PIC_GAP + PIC_GAP;
		else
			maxPicHeight := PIC_GAP;
		endif;
	else
			maxPicHeight := PIC_GAP;
	
	endif;
	thePIC.theFrame.height := thePIC.theTable.top + thePIC.theTable.height + 5 + maxPicHeight;
	thePIC.theFrame.zOrder(1);
	thePIC.theFrame.centreWindow();
	if self.clientHeight - thePIC.theFrame.height &gt; 150 then
		thePIC.theFrame.top := 150;
	else
		thePIC.theFrame.top := ((self.clientHeight - thePIC.theFrame.height) / 2).Integer;
	endif;
	
	thePIC.theTable.backColor := thePIC.theFrame.backColor;
	thePIC.theFrame.visible := true;
	thePIC.theToolbarFrame.width:=thePIC.theTable.width; //epr par 19271 3/4/09 made sure the toolbar is now same width as the table
	
epilog
	delete dataContainer;

end;</source>
        <Parameter name="thePIC" type="CMIF_PopupInfoController" usage="input"/>
    </JadeMethod>
