    <JadeMethod name="maRunBGPTask" id="fef386fa-6b4e-4ac3-a462-da54f1e6a472">
        <source>maRunBGPTask();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2018	jlgma1	Initial creation

*/

vars
	
	task			: CM_AutoTask;
	tmpClass		: Class;
	request			: BGP_Request;
	term			: CM_Terminal;
	
begin

	app.initialize();


	task := "6043.1617".asOid.CM_AutoTask;	

	write 'Processing task (' &amp; task.description &amp; ')';
	tmpClass := self.getClass(task.requestClassName);
	if tmpClass = null then
		// Class has not been correctly setup.
		write task.requestClassName &amp; ' Request class not found';
		return;
	endif;


	create request as tmpClass transient;
	request.initRequestFromTask(task);
	
	if process.isInTransactionState then
		commitTransaction;
	endif;

	request.action();

	self.unlock(task);
	write method.name&amp;" completed";	
	
epilog	
	write method.name&amp;" epilog";	
	if task &lt;&gt; null then
		self.unlock(task);
	endif;
	delete request;
end;</source>
    </JadeMethod>
