        <Parameter name="cntrl" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getClassDescription" id="f99fa3d0-2320-4bbf-abc3-de62720c420c">
        <source>getClassDescription(pSchemaObj:Schema; pClassObj:Class):String protected;
// --------------------------------------------------------------------------------
// Created:		09 February 2003 by cnwdad1
//
// Purpose:		Returns a display of a class name and the number of instances.
//
// Parameters:	pSchemaObj - A reference to the Class's Schema.
//				pClassObj - The class whose display string to return.
//
// Returns:		String - The class display string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	classDescription	: String;

begin
	if pClassObj = null then
		classDescription	:=	null;
	else
		classDescription	:=	pClassObj.Class.name;

		if pClassObj.schema &lt;&gt; pSchemaObj then
			classDescription	:=	classDescription &amp; '      (of ' &amp; pClassObj.schema.name &amp; ')';
		endif;

		if pClassObj.abstract then
			classDescription	:=	classDescription &amp; '   (Abstract)';
		else
			// Do nothing else.
		endif;
	endif;
epilog
	return classDescription;
end;</source>
        <access>protected</access>
        <Parameter name="pSchemaObj" type="Schema"/>
        <Parameter name="pClassObj" type="Class"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getClassForeColor" id="4231b2b0-b498-404c-bd14-7939dea5e11f">
        <source>getClassForeColor(pSchemaObj:Schema; pClassObj:Class; pListboxObj:ListBox input; pIndex:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		09 February 2003 by cnwdad1
//
// Purpose:		Sets the appropriate fore color for a class in a listbox control.
//
// Parameters:	pSchemaObj - A reference to the Class's Schema.
//				pClassObj - The class whose fore color we're setting.
//				pListboxObj - The listbox containing the class.
//				pIndex - The index of the class in the listbox.
//
// Returns:		Nothing.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pClassObj.isSystemObject then
		pListboxObj.itemForeColor[pIndex]	:=	Red;
		
	elseif pClassObj.schema &lt;&gt; pSchemaObj then
		pListboxObj.itemForeColor[pIndex]	:=	Blue;
		
	elseif pClassObj.abstract then
		pListboxObj.itemForeColor[pIndex]	:=	Gray;//Green;
		
	else
		pListboxObj.itemForeColor[pIndex]	:=	Black;
		
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pSchemaObj" type="Schema"/>
        <Parameter name="pClassObj" type="Class"/>
        <Parameter name="pListboxObj" type="ListBox" usage="input"/>
        <Parameter name="pIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lstClasses_click" id="17202c51-db33-4f5a-92c1-de4924f4ab2d">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstClasses_click(listbox: ListBox input) updating;
// --------------------------------------------------------------------------------
// Created:		22 March 2007 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	classObj	: Class;
	
begin
	app.mousePointer	:=	Busy;
	
	if listbox.listIndex = CNEC_NULL_INDEX then
		return;
	endif;
	
	classObj	:=	listbox.listObject.Class;
	
	if classObj &lt;&gt; self.aMyCurrentClass then
		if not self.doCheckForSave() then
			listbox.cnEcSetObjectIndex(self.aMyCurrentClass);
			return;
		endif;
	endif;
	
	self.aMyCurrentClass	:=	classObj;
	self.doDisplayClassText(classObj);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstClasses_dblClick" id="2c145c1d-9ffd-4f49-9f99-8814c66fc47b">
        <controlMethod name="ListBox::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstClasses_dblClick(listbox: ListBox input) updating;
// --------------------------------------------------------------------------------
// Created:		23 December 2007 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	listbox.cnEcExpandItem(listbox.listIndex, true);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstClasses_pictureClick" id="a9495bad-d025-4ec0-97ff-68ac30d8035c">
        <controlMethod name="ListBox::pictureClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstClasses_pictureClick(listbox: ListBox input; picIndex: Integer; whatClicked: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		22 March 2007 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.doOpenCloseClassNode(listbox, picIndex, false);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="picIndex" type="Integer"/>
        <Parameter name="whatClicked" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lstSchemas_click" id="58e4db3f-b888-4f72-9055-51c0dde8299e">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstSchemas_click(listbox: ListBox input) updating;
// --------------------------------------------------------------------------------
// Created:		22 March 2007 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	if listbox.listIndex = CNEC_NULL_INDEX then
		self.aMyCurrentSchema	:=	null;
		listbox.clear();
	else
		if listbox.listObject &lt;&gt; self.aMyCurrentSchema then
			if not self.doCheckForSave() then
				listbox.cnEcSetObjectIndex(self.aMyCurrentSchema);
				return;
			endif;
		endif;
		
		self.aMyCurrentSchema	:=	listbox.listObject.Schema;
		self.doPopulateClasses();
		rtfDocumentation.load(null, JadeRichText.Load_ReplaceAll);
	endif;
	
	self.resetIsChanged();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstSchemas_dblClick" id="f17fca53-f62a-4415-aa6c-8e1b2d4449f0">
