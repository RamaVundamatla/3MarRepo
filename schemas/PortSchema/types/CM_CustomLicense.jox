    <JadeMethod name="validateForUpdate" id="104c1c54-e61f-47a6-9251-e865fbac36e4">
        <source>validateForUpdate();
// ##### CR59571 TASK 59573 NAVAB1 04AUG2023
vars
begin

	if self.description = null then
		app.raiseCMException(NoCustomLicenseDescEntered, null, null);
	endif;
	
epilog

