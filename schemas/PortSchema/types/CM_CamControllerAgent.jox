    <JadeMethod name="createBGPExceptionLogAndAlert" id="6a92ee89-1bf9-4679-a405-5b5e01b40756">
        <source>createBGPExceptionLogAndAlert(_exObj: Exception; _passport : CM_Passport input);
//
//25 Jun 2013	cnwrs1	Par31047 - Cams Exception Handler
// 16/03/2015	cnwmh5	Transient Leak
// 08 Jan 2026  navma1  MTN-36897 PEN - Transient File Growth in PEN Production Environment 
//
vars
	stackArray 	  : StringArray512;
	longErrStr 	  : String;
	errStr		  : String;
	str 		  : String;
	callStack 	  : ProcessStackArray;
	methCallDesc  : MethodCallDesc;
	theDisplay    : String;
begin

	create stackArray transient;
	longErrStr  := self.getErrorDesc();
	errStr 		:= errStr &amp; '(' &amp;  _exObj.text &amp; ')';
	// cut back the stack to the current method
	create callStack;
	process.currentStack(callStack);
	//-------------
	// cut back the stack to the current method
	//-------------
	while callStack.size &gt; 0 and callStack[1].method &lt;&gt; _exObj.currentMethodDesc.method do
		delete callStack.removeAt(1);		// PAR #18009
	endwhile;
	//-------------
	//Add the call stack to the alert
	//-------------
	foreach methCallDesc in callStack do
		theDisplay := methCallDesc.display();
		if theDisplay.length &gt; 0 then
			stackArray.add(theDisplay[1:256]);
		endif;
	endforeach;
	
	errStr := longErrStr;
	self.logMessage(errStr, null, false, true, true);
	app.writeLog(errStr, LogINFO);
	
	foreach str in stackArray do
		errStr := errStr &amp; CrLf &amp; str;
	endforeach;
	
	if app.alertManager = null then
		app.initialize;	
	endif;

	app.alertManager.addLogAlert(errStr);
epilog
	
	if callStack &lt;&gt; null then		//08.01.2026 navma1 #MTN-36897
		callStack.purge();
		delete callStack;
	endif;
	delete stackArray;
end;
</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createCAMSInfoSentTransactions" id="9763d354-5ad9-4c45-834c-1a69d866e1e8">
        <source>createCAMSInfoSentTransactions(	_camAgent :CM_CamControllerAgent; _camProtocol :CM_CamProtocol; _camFile :CM_CamFile; _allTransactions :MemberKeyDictionary);
/*
Date		Who		Reason
17 Dec 2012	cnwcs5	Initial creation - par 30855
10/06/2013	cnwcs5	par 31752 - wrong local variable used for deleted transactions
//14 Jan 2014	cnwrs1	Par 33305 - info.clear is missing for user defined Reports
19 Aug 2022	jlger1	TFS 54478 - changed to StringArray with Jade increasing length of strings in - to fix 1035
*/
vars
	camVoyage	:CM_CamVoyage;
	camMessage	:CM_CamMessage;
	code, seq,
	report		:String;
	dd			:DynaDictionary;
	iter		:Iterator;
	coll,info	: StringArray;
	trx			:CM_TITransaction;
	ti			:CM_TrackedItem;
	passport	:CM_Passport;
begin
	create info transient;
	
	code 		:= _camProtocol.code.trimBlanks;
	report		:= _camProtocol.jrwReportName;
	seq			:= _camAgent.processSeqNumber.String;
	passport	:= app.myPassport;
	
	if _camProtocol.isUserDefinedReport then
		iter := _allTransactions.createIterator;
						
		while iter.next (trx) do
			info.clear;
			// header
			info.add ('Protocol: ' &amp; code &amp; ' seq ' &amp; seq);
			info.add ('Transaction: ' &amp; trx.getCamsDisplayDetails());
			
			if trx.deleted then
				info.add ("Deleted: " &amp; trx.deleted.getYesNo());	// par 31752 June 2013
			endif;
					
			// detail
			info.add ('JRW Design Name:' &amp; report);
			
			// create the transaction
			ti := trx.myTrackedItem;
			
			ti.createInfoEDISentTransaction (_camProtocol, info, trx, passport);
		endwhile;
	else	
		// use message header/trailer and transaction detail
		foreach camVoyage in _camFile.camVoyages do
			foreach camMessage in camVoyage.camMessages do 
				dd := camMessage.allCAMSInfoDetails;
				
				iter := dd.createIterator;
				
				while iter.next (coll) do
					trx := iter.getCurrentKey (1).CM_TITransaction;
					ti	:= trx.myTrackedItem;
					
					info.clear;
					
					// header
					info.add ('Protocol: ' &amp; code &amp; ' seq ' &amp; seq);
					info.add ('Transaction: ' &amp; trx.getCamsDisplayDetails());
					
					if trx.deleted then
						info.add ("Deleted: " &amp; trx.deleted.getYesNo());	// par 31752 June 2013
					endif;
					
					camMessage.header.copy (info);
					
					// detail
					coll.copy (info);
					
					// trailer
					camMessage.trailer.copy (info);
					
					// create transaction - use CM_EDIInfoSent instead of CM_Information
					ti.createInfoEDISentTransaction (_camProtocol, info, trx, passport);
				endwhile;
				
				delete iter;
			endforeach;
		endforeach;
	endif;
epilog
	
	delete iter;
	delete info;
end;</source>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camFile" type="CM_CamFile"/>
        <Parameter name="_allTransactions" type="MemberKeyDictionary"/>
    </JadeMethod>
    <JadeMethod name="createOutputFile" id="ea3ba2fd-b728-4aa7-b63b-f1ce816396b5">
        <source>createOutputFile(_camProtocol : CM_CamProtocol input; _camTaskHistory : CM_CamTaskHistory; _fileNameCreated : String output) : Boolean;
/*
	2/9/09 J Harliwich  MES1011  	If User defined report, create File Transfer file. JRW has already created the standard CAMS file
									Return the file name created
*/
//19 June 2012	cnwrs1		Par 29821 - CAMS single transaction per file
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask - from CM_CamTask
//21 Nov 2012	cnwrs1	Par 30728	fail with message and alert if directory disappears
//05 Dec 2012	cnwcs5	CCMS SFW 1295/par 30855
//06 Jul 2016	cnwrs1	Par 38021 - Review Cam logging
//30 Nov 2016	cnwrs1	Par 38468 setup destination folder correctly
//23 Feb 2017	cnwrs1	TFS3346 allow Cams file Transfer to work on onn user defined files
//18 Mar 2023	namvd1	TFS 57092 Skip file creation if protocol is sending to an API endpoint
//05 Sep 2025	navnk30 JIRA 35756: 8 - Create a new Cams protocol to handle Truck Departure events and generate "Ship Notice" Messages
vars
	fileFolder 		: FileFolder;
	file			: File;
	fileDirectory	: String;
	isFileError 	: Boolean;
	errorInfo 		: String;
begin
	// We're already logging these External Web Service History, so no need to write to disk
	//if _camProtocol.myExternalWebServiceDef &lt;&gt; null then
	if _camProtocol.myExternalWebServiceDef &lt;&gt; null and
			_camProtocol.protocolDesc.type &lt;&gt; EDIFileTypeCams_AgGatewayXML then	//05SEP2025 navnk30 JIRA-35756
		return true;
	endif;

	// get directory for CAMS file from terminal config
	
	fileDirectory := self.fileDirectory   &amp; 
						'\' &amp; _camProtocol.getProtocolSubDirectoryName; 								//cnwrs1 par19312 June 2009 

	
	app.writeLog(class.name &amp; "::" &amp; method.name &amp; " fileDirectory " &amp; fileDirectory, LogDEBUG);
	
	create fileFolder transient;
	
	fileFolder.fileName := fileDirectory;
	
	if not fileFolder.isAvailable then
		on FileException do self.xHandlerFile(exception, isFileError, errorInfo);		// 16 Nov 2012	cnwrs1	Par 30728
		
		app.writeLog(class.name &amp; "::" &amp; method.name &amp; " make file Directory " &amp; fileDirectory, LogINFO);
		fileFolder.make;
		
		if isFileError then
			app.writeLog(class.name &amp; "::" &amp; method.name &amp; " --- " &amp; errorInfo, LogINFO);
			self.logMessage(app.getErrorString2(ERR_CAMS_MAKEDIR, fileFolder.fileName, self.getCurrentProtocolCode()), null, true, true, false);
			
			return false;
		endif;
		
		on FileException do null;
	endif;

	if _camTaskHistory &lt;&gt; null then
		create file;
		
		file.mode := File.Mode_Output;
		
		if _camProtocol.isUserDefinedReport or  _camProtocol.isUserDefinedEventReport then	// PAR 21905 CCMS MES 1008 - PHB
			// The JRW report has already created the file.
			if _camProtocol.isFileTransferEnabled and _camProtocol.destinationFilePath &lt;&gt; null then
				// transfer another copy of the file to the specified destination folder
				if _camProtocol.transferFileSeqLength = 0 and	//19 June 2012	cnwrs1		Par 29821 - CAMS single transaction per file
				   _camProtocol.transferFileRollOver = 0 and
				   _camProtocol.transferFileStartSeq = 0 and
				   _camProtocol.lastSequenceNumberUsed = 0 then
				   
					if _camTaskHistory.fileName = null then
						_fileNameCreated   := _camProtocol.constructFileName(self, null).trimRight;
					else
						_fileNameCreated   := _camTaskHistory.fileName;
					endif;
				endif;
				fileFolder.fileName := _camProtocol.destinationFilePath;
				app.writeLog(class.name &amp; "::" &amp; method.name &amp; " transferDirectory " &amp; _camProtocol.destinationFilePath, LogDEBUG);
				
				if not fileFolder.isAvailable then
					on FileException do self.xHandlerFile(exception, isFileError, errorInfo);		// 16 Nov 2012	cnwrs1	Par 30728
							
					app.writeLog(class.name &amp; "::" &amp; method.name &amp; " make transfer Directory " &amp; _camProtocol.destinationFilePath, LogINFO);
					fileFolder.make;
					
					if isFileError then
						app.writeLog(class.name &amp; "::" &amp; method.name &amp; " --- " &amp; errorInfo, LogINFO);
						self.logMessage(app.getErrorString2(ERR_CAMS_MAKEDIR, fileFolder.fileName, self.getCurrentProtocolCode()), null, true, true, false);
					
						return false;
					endif;
					
					on FileException do null;
				endif;
				
				_fileNameCreated	:= _camProtocol.getTransferFileName;
				file.fileName 		:= _camProtocol.destinationFilePath.stripTrailingSlashes &amp; "/" &amp; _fileNameCreated;
				app.writeLog(class.name &amp; "::" &amp; method.name &amp; " transfer file " &amp; file.fileName, LogDEBUG);
				
				if _camTaskHistory.isUsingFileDataStorage then
					file.kind := file.Kind_Binary;
				endif;
				
				on FileException do self.xHandlerFile(exception, isFileError, errorInfo);		// 16 Nov 2012	cnwrs1	Par 30728

				file.open();
				
				if isFileError then
					app.writeLog(class.name &amp; "::" &amp; method.name &amp; " --- " &amp; errorInfo, LogINFO);
					self.logMessage(app.getErrorString2(ERR_CAMS_OPENFILEFAIL, file.fileName, self.getCurrentProtocolCode()), null, true, true, false);	//par 26290 cnwrs1 	15 nov 2010
					
					return false;
				endif;
				
				on FileException do null;
				
				// now actual write the data out tothe file
				app.writeLog(class.name &amp; "::" &amp; method.name &amp; " write " &amp; file.fileName, LogDEBUG);
				_camTaskHistory.writeFileDataToFile(file);
				file.close;
			endif;
		else
			
			//epr par 36867 4/9/15
			if _camProtocol.specialFileName then
				_camProtocol.protocolDesc.postSpecialFileName(_camTaskHistory);
			endif;
			
			if _camTaskHistory.fileName = null then
				_fileNameCreated   := _camProtocol.constructFileName(self, null).trimRight;
			else
				_fileNameCreated   := _camTaskHistory.fileName;
			endif;
			
			file.fileName := fileDirectory &amp; "\" &amp; _fileNameCreated;
			app.writeLog(class.name &amp; "::" &amp; method.name &amp; " file name " &amp; file.fileName, LogDEBUG);
		
			// We need to create the file by dumping out contents of the task history filedata, which is the email text
			on FileException do self.xHandlerFile(exception, isFileError, errorInfo);		// 16 Nov 2012	cnwrs1	Par 30728
			
			if file.isAvailable then
				app.writeLog(class.name &amp; "::" &amp; method.name &amp; " purge " &amp; file.fileName, LogDEBUG);
				file.purge;
				
				if isFileError then
					app.writeLog(class.name &amp; "::" &amp; method.name &amp; " --- " &amp; errorInfo, LogINFO);
					self.logMessage(app.getErrorString2(ERR_CAMS_PURGEFILEFAIL, file.fileName, self.getCurrentProtocolCode()), null, true, true, false);
					return false;
				endif;
			endif;
			
			file.open;
			
			if isFileError then
				app.writeLog(class.name &amp; "::" &amp; method.name &amp; " --- " &amp; errorInfo, LogINFO);
				self.logMessage(app.getErrorString2(ERR_CAMS_OPENFILEFAIL, file.fileName, self.getCurrentProtocolCode()), null, true, true, false);	//par 26290 cnwrs1 	15 nov 2010
				
				return false;
			endif;
			
			on FileException do null;
			
			app.writeLog(class.name &amp; "::" &amp; method.name &amp; " write " &amp; file.fileName, LogDEBUG);
			_camTaskHistory.writeFileDataToFile (file);	// this write the contents to camtaskhistory.fileData to the file
	
			file.close;
			if _camProtocol.isFileTransferEnabled and 
			   _camProtocol.destinationFilePath &lt;&gt; null and
			   _camTaskHistory.messageCount &gt; 0 then
				// now transfer the file
				if not self.transferFile(_camTaskHistory, _camProtocol.destinationFilePath, _fileNameCreated) then
					return false;
				endif;
			endif;
		endif;
	endif;
	
	return true;	// 16 Nov 2012	cnwrs1	Par 30728
epilog
	delete file;
	delete fileFolder;
end;
</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory"/>
        <Parameter name="_fileNameCreated" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cycleLog" id="a50bdf2e-b7f3-47b0-8b3e-6cc62c6bc8c2">
        <updating/>
        <source>cycleLog(_log: File io) updating, protected;
// ---------------------------------------------------------------------------
// Created:		26 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 03 May 2012	cnwrs1	Par 29520 - Moved from CM_camProtocol and changed to create alert logs and not to change _log if the raname fails
// 28 Aug 2012	cnwcs5	Clean up fileFolder transient in epilog
//21 Nov 2012	cnwrs1	Par 30728	fail with message and alert if directory disappears
//06 Jul 2016	cnwrs1	Par 38021 - Review Cam logging
vars
	oldLog			: File;
	newLog			: File;
	fileFolder		: FileFolder;
	camsDirectory	: String;
	cycledName		: String;
	isFileError : Boolean;
	errorInfo : String;
begin
//	camsDirectory := self.terminal.getConfig(CamsFileDirectory).String;	// cnwrl1 27/05/2009 PAR 19732 - what it was
	camsDirectory := self.myTerminal.getConfig_FileDirectory(CamsFileDirectory).String;
	
	if _log = null then
		return;
	endif;
	
	oldLog := _log;
	on FileException do self.xHandlerFile(exception, isFileError, errorInfo);		//16 Nov 2012	cnwrs1		Par 30728
	isFileError	:=	false;
	if oldLog.isOpen then
		oldLog.close;
	endif;
	oldLog.open;
	if isFileError then
		app.writeLog(class.name &amp; "::" &amp; method.name &amp; " --- " &amp; errorInfo, LogINFO);
		self.logMessage(app.getErrorString2(ERR_CAMS_OPENFILEFAIL, oldLog.fileName, self.getCurrentProtocolCode()), null, true, true, false);	
		return;
	endif;
	cycledName := camsDirectory.trimBlanks &amp; "\logs\" &amp; self.cycledLogFileName;
	
	oldLog.rename(cycledName);
	if isFileError then
		app.writeLog(class.name &amp; "::" &amp; method.name &amp; " --- " &amp; errorInfo, LogINFO);
		self.logMessage(app.getErrorString2(ERR_CAMS_OPENFILEFAIL, cycledName, self.getCurrentProtocolCode()), null, true, true, false);
		return;
	else
		on FileException do null;
	endif;
	
	//------------------
	// Create new log file
	//------------------
	create fileFolder;
	fileFolder.fileName := camsDirectory.trimBlanks;
	if not fileFolder.isAvailable then
		return;
	endif;
	
	fileFolder.fileName := camsDirectory.trimBlanks &amp; "\logs";
	if not fileFolder.isAvailable then
		on FileException do self.xHandlerFile(exception, isFileError, errorInfo);		//16 Nov 2012	cnwrs1		Par 30728
		isFileError	:=	false;
		fileFolder.make;
		if isFileError then
			app.writeLog(class.name &amp; "::" &amp; method.name &amp; " --- " &amp; errorInfo, LogINFO);
			self.logMessage(app.getErrorString2(ERR_CAMS_MAKEDIR, fileFolder.fileName, self.getCurrentProtocolCode()), null, true, true, false);
			return;
		else
			on FileException do null;
		endif;
	endif;

	create newLog;
	newLog.mode := File.Mode_Output; // 29/2/16  cnwns1 PAR 36286 unicode version
	newLog.fileName := self.protocolLog.fileName;
	on FileException do self.xHandlerFile(exception, isFileError, errorInfo);		//16 Nov 2012	cnwrs1		Par 30728
	isFileError := false;
	newLog.open;
	if isFileError then
		app.writeLog(class.name &amp; "::" &amp; method.name &amp; " --- " &amp; errorInfo, LogINFO);
		self.logMessage(app.getErrorString2(ERR_CAMS_OPENFILE, newLog.fileName, self.getCurrentProtocolCode()), null, true, true, false);	
		return;
	else
		on FileException do null;
	endif;
	newLog.writeLine("previous log saved as " &amp; cycledName);
	newLog.close;
	_log := newLog;
	newLog := null;

epilog
	if oldLog.isOpen then
		oldLog.close;
	endif;
	if oldLog &lt;&gt; _log then
		delete oldLog;
	endif;
	
	delete fileFolder;	// cnwcs5 August 2012
end;</source>
        <access>protected</access>
        <Parameter name="_log" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cycledLogFileName" id="02dd9329-59ee-4072-9860-80056598c3bb">
        <source>cycledLogFileName(): String protected;
// ---------------------------------------------------------------------------
// Created:		26 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 03 May 2012	cnwrs1	Par 29520 - Moved from CM_camProtocol and changed to use server time
vars
//	today	: Date;
//	now		: Time;
	ts : TimeStamp;
begin
	ts := app.actualTimeServer();
	return self.getCurrentProtocolCode() &amp; "_" &amp; ts.Date.formatAsYYYYMMDD() &amp; "_" &amp; ts.Time.formatAsHHMMSS() &amp; ".log";
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="delete" id="45606c9b-d6fd-4f1e-b3fa-ca7bdce57148">
        <updating/>
        <source>delete() updating;
//
//26 May 2016	cnwrs1	unittest testing
//10 Mar 2023	navdap1	TFS 56796 PRP Suzano EDI Delivery Communication
//16 Mar 2023	navmd1	TFS 57092 Run JSON output messages through the translation mapper dll before an external endpoint
//30 Jun 2023	jlika1	TFS 58506 57077 - Goods Receipt JADE work
begin
	if self.protocolLog &lt;&gt; null and 
	   self.protocolLog.isOpen then
		self.protocolLog.close;
		delete self.protocolLog;
	endif;
	
	self.allSuzanoDeliveryHeaders.purge;	// TFS 56796
	
	self.allJsonGoodsReceipt.purge;
	
	delete self.myWebTranslationMapperDll;
end;
</source>
    </JadeMethod>
    <JadeMethod name="endTask" id="461387f7-cda7-4610-9144-2a28ae0100b5">
        <updating/>
        <source>endTask() updating, protected;
// ---------------------------------------------------------------------------
// Created:		20 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
/*
Changed On	Changed By	Reason
----------	----------	--------------------------------------------------------
11/08/2010	cnwdad1		PAR #25172 - Pass CAM Protocol name to "logMessage" when raising an alert.
22/11/2011	cnwkpd1		PAR #28709 - Add in additional log info to errors
17 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask
25 May 2012	cnwrs1		Par 26914 - make cams restart after lock error
12 Jul 2012	cnwrs1		CCMS 1269 CAMS reduce number of Trxs
18 Jul 2012	cnwrs1		CCMS 1269 CAMS remove CM_CamTask
25 Sep 2023	navdap1		TFS 60365 EUP | FR 53853 - Goods Receipt Message Grouping
04/10/2023	navcs2		ChangeRequest 60735: EUP | CAMS Protocol - System Alert on AdHoc Run
28 May 2024 navsp1      Bug 64280: LNX - Excluded Transactions - CODECO/COARRI messages
--------------------------------------------------------------------------------
*/
vars
	camTaskHistory	: CM_CamTaskHistory;
	passport		: CM_Passport;
	str				: String;
//	camObject: CM_Object;
begin
	passport := app.myPassport;
	
	//---------------------------------
	//	Update status to Complete
	//---------------------------------
	self.setStatus(CAM_COMPLETESTATUS);       //12 Jul 2012	cnwrs1	CCMS 1269 CAMS reduce number of Trxs
//	app.myTrxUA.trxUpdateCamObjectStatus(self.myCurrentCamTask, CAM_COMPLETESTATUS, passport);
//	if not passport.trxCompletedOK() then
//		self.logMessage(app.getErrorString(ERR_CAMS_Process)&amp;' '&amp;self.getCurrentProtocolCode(), " failed to update CAM task status to complete.", false, true, false);	// PAR #28709
//		passport.clearErrorsWarnings();
//	endif;
	
	//---------------------------------
	// final wrapup and Task object deletion
	//---------------------------------
	app.myTrxUA.trxEndTaskForProtocol(self, self.myCurrentCamProtocol, passport);
	
	app.writeStatement(self.String);
	if not passport.trxCompletedOK() then
		self.logMessage(app.getErrorString(ERR_CAMS_Process)&amp;' '&amp;self.getCurrentProtocolCode(), " failed to end the CAM task.", false, true, false);	// PAR #28709
		passport.clearErrorsWarnings();
	endif;
	camTaskHistory := self.myCurrentCamProtocol.taskHistoryByProtocolSeq[self.myCurrentCamProtocol, self.processSeqNumber];		//required?  copied from v6
	
	self.allJsonGoodsReceipt.purge;			// TFS 60365
	
	self.logMessage("Excluded Transactions - " &amp; self.myCurrentCamProtocol.getDsiplayNameDate, SkipExtraDetails, false, true, false);		// 04/10/2023 navcs2 ChangeRequest 60735  //TFS 64280 - Constant(SkipExtraDetails) included
	
	//12 Jul 2012	cnwrs1	CCMS 1269 CAMS reduce number of Trxs
//	app.createActivityHistory(ActivityHistoryCams, self.myTerminal, camTaskHistory, null, false, false);
	self.writeLog(app.getErrorString(MSG_CAMS_TaskFinalised));

epilog
//	delete self.myCurrentCamTask;
//	self.myCurrentCamTask := null;	//17 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="errorAction" id="4ae8248f-e6ea-454b-a19e-5069a1af9e32">
        <updating/>
        <source>errorAction() updating, protected;
// ---------------------------------------------------------------------------
// Created:		20 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask - not used

vars
	camTaskHistory	: CM_CamTaskHistory;
begin
	app.writeLog(self.myCurrentCamProtocol.code.String &amp; " errorAction started.", LogTRACE);

	if self.runDateTime = null
	or self.startDateTime = null
	or self.endDateTime = null then
		camTaskHistory := self.myCurrentCamProtocol.taskHistoryByProtocolSeq[self.myCurrentCamProtocol, self.processSeqNumber];
		if camTaskHistory &lt;&gt; null then
			self.setDates(camTaskHistory.runDateTime, self.startDateTime, camTaskHistory.startDateTime);
		endif;
	endif;

	camTaskHistory := self.myCurrentCamProtocol.taskHistoryByProtocolSeq[self.myCurrentCamProtocol, self.processSeqNumber];
	app.writeLog(self.myCurrentCamProtocol.code.String &amp; " Processing error for " &amp; camTaskHistory.fileName.String &amp; ".", LogINFO);

	beginTransaction;
	self.setHistoryStatus(self.myCurrentCamProtocol, self.processSeqNumber);
	camTaskHistory := self.myCurrentCamProtocol.taskHistoryByProtocolSeq[self.myCurrentCamProtocol, self.processSeqNumber];
	camTaskHistory.setErrorMessage(self.processErrorMessage);
	self.processErrorMessage := null;
	if self.status = CAM_SENDSTATUS then
					                        //do nothing
	elseif self.status = CAM_RESENDSTATUS then
		if self.processResendCount &gt; 3 then
			self.setStatus(CAM_IDLESTATUS);       //restarts failed
		endif;
	else
		self.setStatus(CAM_IDLESTATUS);
	endif;
	app.cmsCommitTransaction(app.myPassport);

epilog
	app.writeLog(self.myCurrentCamProtocol.code.String &amp; " errorAction finished.", LogTRACE);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="extractAction" id="24c7b99e-b55f-4749-9323-5b0018b3b40f">
        <updating/>
        <source>extractAction() updating, protected;
// ---------------------------------------------------------------------------
// Created:		20 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
/*
Changed On	Changed By	Reason
----------	----------	--------------------------------------------------------
11/08/2010	cnwdad1		PAR #25172 - Pass CAM Protocol name to "logMessage" when raising an alert.
12 Jul 2012	cnwrs1	CCMS 1269 CAMS reduce number of Trxs
18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
--------------------------------------------------------------------------------
*/
vars
	start 			: Integer;
	camTaskHistory	: CM_CamTaskHistory;
	passport		: CM_Passport;
//	dd				: DynaDictionary;
begin
	passport := app.myPassport;
		
	self.writeLog(app.getErrorString(MSG_CAMS_ExtractStarted));

	self.setStatus(CAM_EXTRACTSTATUS);       //12 Jul 2012	cnwrs1	CCMS 1269 CAMS reduce number of Trxs
	
	self.writeLog(app.getErrorString(MSG_CAMS_BuildingFile));
	
	if self.myCurrentCamProtocol.terminal &lt;&gt; null then
		// create CAMS file
		start := app.clock();
		
		self.myCurrentCamProtocol.protocolDesc.buildFile(	self.myCurrentCamProtocol,
															self,
															self.processSeqNumber,
															self.unhSeqNumber,
															self.myTerminal);
		
		self.writeLog(app.getErrorString(MSG_CAMS_BuildingFile) &amp; " " &amp; app.getErrorString(Completed) &amp; " : " &amp; ((app.clock-start)/1000).String &amp; " secs.");
	else
		self.logMessage(app.getErrorString1(ERR_TerminalNotSet, app.getErrorString(CAM_Protocol)), self.getCurrentProtocolCode(), true, true, false);
		
		camTaskHistory := self.myCurrentCamProtocol.taskHistoryByProtocolSeq[self.myCurrentCamProtocol, self.processSeqNumber]; 
		
		app.myTrxUA.trxUpdateCamHistoryMsg(camTaskHistory, app.getErrorString1(ERR_TerminalNotSet, app.getErrorString(CAM_Protocol)), 0, passport);
		
		if not passport.trxCompletedOK() then
			self.logMessage(app.getErrorString(ERR_CAMS_Process)&amp;' '&amp;self.getCurrentProtocolCode(), " failed to update CAM history.", true, true, false);	//par 26290 cnwrs1 11 Nov 2010
			passport.clearErrorsWarnings();
		endif;
	endif;

	self.writeLog(app.getErrorString(MSG_CAMS_ExtractFinished));
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getCurrentProtocolCode" id="7eb7026f-1f7d-4781-8845-a34bc07d8020">
        <source>getCurrentProtocolCode():String;
// --------------------------------------------------------------------------------
// Created:		11 August 2010 by cnwdad1
//
// Purpose:		Returns the receiver's current CAM Protocol code.
//
// Parameters:	None
//
// Returns:		The receiver's current CAM Protocol code, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
//14 Aug 2012	cnwrs1	Par 30197 - restart not working
// --------------------------------------------------------------------------------
begin
	if self.myCurrentCamProtocol = null then
		return null;
	else
		return self.myCurrentCamProtocol.code;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEarliestCAMSRunDate" id="0a339645-cf09-4320-be7a-df74f1e4cd7b">
        <source>getEarliestCAMSRunDate():Date;
/*
Date		Who		Reason
10 De 2012	cnwcs5	Initial creation - par 30855 / CCMS SFW 1294
25 jun 2013	cnwcs5	now that final part of conversion has been run we don't expect to find any upgrader objects
*/
vars
	array		:ObjectArray;
	obj			:Object;
	upgrader	:CM_ObjectUpgraderCAMSTrx;
	date		:Date;
	terminal	:CM_Terminal;
begin
	date 		:= '01/01/1900'.Date;	// will do dd/mm/yyyy conversion
	terminal 	:= self.myTerminal;
	
	create array transient;
	
	CM_ObjectUpgraderCAMSTrx.allInstances (array, null, false);
	
	foreach obj in array do
		upgrader := obj.CM_ObjectUpgraderCAMSTrx;
		
		if upgrader.myTerminal = terminal then
			if not upgrader.isComplete then
				date := upgrader.earliestTrxUpgradedDate;
			endif;
			
			break;
		endif;
	endforeach;
	
	return date;
epilog
	delete array;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getErrorDesc" id="4b685090-19e3-413d-a7a4-69c585aaf6c4">
        <source>getErrorDesc(): String;
//
// 20 May 2013	cnwrs1	Par 31047 - Cams Exception Handler
// 10 May 2013	cnwcs5	par 31752 - Fix exception if no terminal or CAM protocol
vars
	terminal	:CM_Terminal;
	protocol	:CM_CamProtocol;
	terminalCode, 
	protocolCode, 
	msg 		: String;
begin
	terminal 	:= self.myTerminal;
	
	if terminal &lt;&gt; null then
		terminalCode := terminal.code;
	endif;
	
	protocol := self.myCurrentCamProtocol;
	
	if protocol &lt;&gt; null then
		protocolCode	:= protocol.code;
	endif;
	
	msg := app.getErrorString(ERR_CAMS_Process) &amp; ' ' &amp; 
			self.class.text.cnEcGetTagValueOfName('display') &amp; 
			' Environment: ' &amp; app.myCnKarmaCntrl.environmentId &amp; 
			" Terminal: " &amp; terminalCode &amp; 
			" Protocol: " &amp; protocolCode;
			
	return msg;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFileNameSeqNumber" id="a8a6c992-abd5-412a-a982-f5bbe00590bf">
        <source>getFileNameSeqNumber( _camProtocol : CM_CamProtocol ):Integer;
//
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask - from CM_CamTask
//11 Aug 2017	NDL		TFS 5802  - more than 99 runs in a day re-uses the file names the next day
//
vars
	size : Integer;
begin
	
	size := _camProtocol.scheduleTimes.size;	//The number of scheduled runs per day.
	
	if size &gt;= 1000 then
		// need 4 chars for the sequence number bit
		// i.e. MMDDssss
		return dailySeqNumber + (startDateTime.date.day*10000) + (startDateTime.date.month*1000000);
	elseif size &gt;= 100 then
		// need 3 chars for the sequence number bit
		//i.e MMDDsss
		return dailySeqNumber + (startDateTime.date.day*1000) + (startDateTime.date.month*100000);
	else
		//only need 2 chars - original code
		//i.e MMDDss
		return dailySeqNumber + (startDateTime.date.day*100) + (startDateTime.date.month*10000);
	endif;

	
end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="incrementDailySeqNumber" id="a2b8e8d4-f9b9-4652-8ffb-85ad10c48b07">
        <updating/>
        <source>incrementDailySeqNumber()updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 May 2016	cnwer1	Initial creation

*/

vars

begin
	self.dailySeqNumber:=self.dailySeqNumber + 1;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initAgent" id="5636c656-bba6-4f41-ba4b-1c442de0e310">
        <updating/>
        <source>initAgent():Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:		19 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
/*
Changed On	Changed By	Reason
----------	----------	--------------------------------------------------------
12/08/2010	cnwdad1		PAR #23807. If file system is unavailable, the system gets
						flooded with alerts. Changed to log the problem, then return
						"false" without attempting to process anything.
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
//21 Nov 2012	cnwrs1	Par 30728	fail with message and alert if directory make fails
//30 Nov 2016	cnwrs1	Par 38468 setup destination folder correctly -debug messages
--------------------------------------------------------------------------------
*/
vars
	fileFolder	: FileFolder;
	term		: CM_Terminal;
	isFileError	: Boolean;
	errorInfo	: String;
	maxLogSize	: Integer;
begin
	term := self.myTerminal;
	
	self.delayTime		:= term.getConfig(CamsDelayTime).Integer;
	if global.cnwer1 then
		self.fileDirectory	:="C:\Temp";
	else
		self.fileDirectory	:= term.getConfig_FileDirectory(CamsFileDirectory).String.trimRight(); 
	endif;
	self.traceLevel		:= term.getConfig(CamsTraceLevel).Integer;

	if app.logLevel &lt;&gt; LogDEBUG then
		app.changeLogLevel(self.traceLevel);
	endif;
	
	// if setting to debug or trace, then lets allow the log files to get a bit bigger before rolling them over
	if app.logLevel &gt; LogWARN then
		maxLogSize := CnCntrl.Default_LogFileMaxSize * 10;
		app.writeLog(method.qualifiedName &amp; " Setting Max log size to " &amp; maxLogSize.String, LogINFO);
		app.myCnCntrl.setLogFileMaxSize(maxLogSize);
	endif;
	
	if self.fileDirectory = null then
		self.logMessage(app.getErrorString(ERR_CAMS_DirectoryMissing)&amp;' '&amp;self.getCurrentProtocolCode(), null, (self.supportersEmail &lt;&gt; null), true, false);	//par 26290 cnwrs1 11 nov 2010
		return false;
	endif;
	
	create fileFolder transient;
	
	fileFolder.fileName := self.fileDirectory.trimBlanks();
	
	if not fileFolder.isAvailable() then
		on FileException do self.xHandlerFile(exception, isFileError, errorInfo);		// cnwdad1 12/08/2010 - PAR #23807.
		
		isFileError	:=	false;

		app.writeLog(class.name &amp; "::" &amp; method.name &amp; " make file Directory " &amp; fileFolder.fileName, LogINFO);
		fileFolder.make();
		
		if isFileError then
			app.writeLog(class.name &amp; "::" &amp; method.name &amp; " --- " &amp; errorInfo, LogINFO);
			app.writeLog(app.getErrorString2(ERR_CAMS_MAKEDIR, self.fileDirectory, self.getCurrentProtocolCode()), LogINFO);	//par 26290 cnwrs1 	15 nov 2010
			return false;
		else
			on FileException do null;
		endif;
	endif;
	
	if not fileFolder.isAvailable() then
		self.logMessage(app.getErrorString2(ERR_CAMS_MAKEDIR, self.fileDirectory, self.getCurrentProtocolCode()), null, (self.supportersEmail &lt;&gt; null), true, false);	//par 26290 cnwrs1 	11 nov 2010
		return false;
	endif;

	// PURGE OLD HISTORY.
	self.purgeOldCamsHistory(term.getConfig(CamsPurgePeriod).Integer);
	
	//check for new protocols
	self.setupCams();

	return true;
epilog
	delete fileFolder;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initLogFile" id="c0f5042e-cdd6-486c-99e7-17c06e49a102">
        <updating/>
        <source>initLogFile():File updating;
// ---------------------------------------------------------------------------
// Created:		23 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 03 May 2012	cnwrs1	Par 29520 moved from CM_CamProtcol and create alert messages
// 21 Nov 2012	cnwrs1	Par 30728 fail with message and alert if directory make fails
// 21 May 2015	cnwkpd1	PAR #36286 - Unicode exception getting fileLength for non-existant file
// 06 Jul 2016	cnwrs1	Par 38021 - old log file was being cleared during cycling the log file
constants
	BytesPerMB : Real = 1048576;//1024000;//1048576;
vars
	file			: File;
	fileFolder		: FileFolder;
	camsDirectory	: String;
	maxLogSize		: Integer;
	isFileError : Boolean;
	errorInfo : String;
begin
//	camsDirectory := self.terminal.getConfig(CamsFileDirectory).String;	// cnwrl1 27/05/2009 PAR 19732 - what it was
	if global.cnwer1 and self.isAdhoc then
		camsDirectory	:="C:\Temp\";
	else
		camsDirectory := self.myTerminal.getConfig_FileDirectory(CamsFileDirectory).String;
	endif;
	if camsDirectory = null then
		self.logMessage("Cams file directory has not been set.", null, true, true, false);
		return null;
	endif;
	
	create fileFolder;
	
	fileFolder.fileName := camsDirectory.trimBlanks;
	if not fileFolder.isAvailable then
		on FileException do self.xHandlerFile(exception, isFileError, errorInfo);		// 02 May 2012	cnwrs1	Par xxxx handle exceptions from file system
		isFileError	:=	false;
		fileFolder.make;
		if isFileError then
			app.writeLog(class.name &amp; "::" &amp; method.name &amp; " --- " &amp; errorInfo, LogINFO);
			self.logMessage(app.getErrorString2(ERR_CAMS_MAKEDIR, fileFolder.fileName, self.getCurrentProtocolCode()), null, true, true, false);	//par 26290 cnwrs1 	15 nov 2010
			return null;
		else
			on FileException do null;
		endif;
	endif;
	
	if not fileFolder.isAvailable then
		self.logMessage("Cams file directory cannot be created.  Check " &amp; camsDirectory, null, true, true, false);
		return null;
	endif;
	
	fileFolder.fileName := camsDirectory.trimBlanks &amp; "\logs";
	if not fileFolder.isAvailable then
		on FileException do self.xHandlerFile(exception, isFileError, errorInfo);		// 02 May 2012	cnwrs1	Par xxxx handle exceptions from file system
		isFileError	:=	false;
		fileFolder.make;
		if isFileError then
			app.writeLog(class.name &amp; "::" &amp; method.name &amp; " --- " &amp; errorInfo, LogINFO);
			self.logMessage(app.getErrorString2(ERR_CAMS_MAKEDIR, fileFolder.fileName, self.getCurrentProtocolCode()), null, true, true, false);	//par 26290 cnwrs1 	15 nov 2010
			return null;
		else
			on FileException do null;
		endif;
	endif;

	create file;
	file.fileName := fileFolder.fileName &amp; "\" &amp; self.getCurrentProtocolCode &amp; '.log';
	
	maxLogSize := self.myTerminal.getConfig(CamsProtocolLogSize).Integer;
	if maxLogSize &lt; 1 then	//hasn't been set - default to 1MB
		maxLogSize := 1;
	endif;
	self.protocolLog := file;

	if file.isAvailable() then			// PAR #36286
		if file.fileLength &gt; (maxLogSize * BytesPerMB) and 
		   self.protocolLog &lt;&gt; null then
			self.cycleLog(file);
			file.mode := File.Mode_Output; // 29/2/16  cnwns1 PAR 36286 unicode version
		endif;
	endif;
	
	file.allowReplace := false;
	file.mode := File.Mode_Append;
	on FileException do self.xHandlerFile(exception, isFileError, errorInfo);		// 02 May 2012	cnwrs1	Par xxxx handle exceptions from file system
	isFileError	:=	false;
	file.open;
	if isFileError then
		app.writeLog(class.name &amp; "::" &amp; method.name &amp; " --- " &amp; errorInfo, LogINFO);
		self.logMessage(app.getErrorString2(ERR_CAMS_OPENFILEFAIL, file.fileName, self.getCurrentProtocolCode()), null, true, true, false);	//par 26290 cnwrs1 	15 nov 2010
		return null;
	else
		on FileException do null;
	endif;
	return file;
epilog
	delete fileFolder;
	
end;</source>
        <ReturnType type="File"/>
    </JadeMethod>
    <JadeMethod name="isProcessAsSingleTransPerFile" id="1b43d7b5-492d-4505-8775-fd8607da94ae">
        <source>isProcessAsSingleTransPerFile(_camProtocol : CM_CamProtocol) : Boolean;
//
//25 May 2016	cnwrs1	get SingleTransPerFile setting working with Adhoc
//
vars

begin
	if _camProtocol.isSingleTransPerFile and
	   not self.isAdhoc then
		return true;
	else
		return false;
	endif;
end;
</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="killTask" id="78854b83-7366-4f8b-892b-455e7499369d">
        <updating/>
        <source>killTask() updating, protected;
// ---------------------------------------------------------------------------
// Created:		20 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
/*
Changed On	Changed By	Reason
----------	----------	--------------------------------------------------------
11/08/2010	cnwdad1		PAR #25172 - Pass CAM Protocol name to "logMessage" when raising an alert.
//25 May 2012	cnwrs1		Par 26914 - make cams restart after lock error
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask - not used
//06 Jul 2016	cnwrs1	Par 38021 - Review Cam logging
--------------------------------------------------------------------------------
*/
begin
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;self.myCurrentCamProtocol.code.String &amp; " killTask started.", LogDEBUG);
	
	//-----------------------------
	// final wrapup remove camTask record.
	//-----------------------------
	app.myTrxUA.trxEndTaskForProtocol(self, self.myCurrentCamProtocol, app.myPassport);
	if not app.myPassport.trxCompletedOK() then
		self.logMessage(app.getErrorString(ERR_CAMS_Process)&amp;' '&amp;self.getCurrentProtocolCode(), " failed to kill CAM Task.", false, true, false);	//par 26290 cnwrs1 11 Nov 2010
		app.myPassport.clearErrorsWarnings();
	endif;
epilog
//	delete self.myCurrentCamTask;
//	self.myCurrentCamTask := null;	//17 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask
	app.writeLog(self.myCurrentCamProtocol.code.String &amp; " killTask finished.", LogWARN);

//	on NormalException do null global;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="lockExceptionHandler" id="e060c916-2ca8-4094-a275-0ac44ed3a4cb">
        <source>lockExceptionHandler(le : LockException) : Integer;
/*

Purpose:			Handle lock exceptions for the CAMS processing.  Created as a clone of 
					PortSchema::alertLockExceptionHandler, with a longer timeout value to reduce
					chances of CAMS processing stopping due to a lock exception
					
Parameters:			Lock exception object

Return Value:		Standard exception handler return code

Date		Who		Reason
15 May 2012	cnwkpd1	PAR #29594 - Increase lock timoeout just for CAMS, not all BGP

*/

constants
	RetryTimeout	= 60000;			// 60 seconds
	
vars
	lockedBy		: Process;
	lockedByUserCode : String;
	invalidProcess	: Boolean;
	returnVal		: Integer;
	startRetry		: Decimal[20];
	
begin
	returnVal := Ex_Pass_Back;
	
	lockedBy := le.targetLockedBy;
 	if lockedBy = null then
		invalidProcess := true;
	else
		on Exception do app.handleDeletedObject(exception, lockedBy, invalidProcess);
 		lockedByUserCode := lockedBy.userCode;
		on Exception do null;
 	endif;
	if invalidProcess then
		lockedByUserCode := 'not available';
	endif;

	// PAR #29594 - Log when we get in here unconditionally, but only retry once
	app.writeLog('INFO &gt;&gt; CAMS lock found, (' &amp; le.errorCode.String &amp; ') Locked by ' &amp; lockedByUserCode , LogINFO);
	startRetry := app.relativeMachineTime();
	if tryLock(le.lockTarget, le.lockType, le.lockDuration, RetryTimeout) then
		app.writeLog('INFO &gt;&gt; CAMS lock cleared on retry after ' &amp; (app.relativeMachineTime() - startRetry).String &amp; ' ms', LogINFO);

		returnVal := Ex_Continue;				// must have the lock if we get to here
		return returnVal;
	endif;
	
	// Didn't get the lock on retry, so pass back the the exception
	app.writeLog('INFO &gt;&gt; CAMS lock exception generated (' &amp; le.errorCode.String &amp; ') Locked by ' &amp; lockedByUserCode , LogINFO);
	app.writeLogLockException(le);

	returnVal := Ex_Pass_Back;		// let another handler deal with it

epilog
	return returnVal;

end;</source>
        <Parameter name="le" type="LockException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="logMessage" id="2df5c3ee-d393-4664-bbbc-2583d0228e11">
        <source>logMessage(_msgText: String; _param1: String; _email: Boolean; _alert: Boolean; _protLog: Boolean);
//----------------------------------------------------------------
//	Created:	26 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*
Changed On	Changed By	Reason
----------	----------	--------------------------------------------------------
11/08/2010	cnwdad1		PAR #25172 - If _param1 has a value, and an alert is being
						raised, then record the _param1 details in extra details.
//21 Nov 2012	cnwrs1	Par 30728	fail with message and alert if directory make fails
//25 Jun 2013	cnwrs1	Par 31047	enviroment name terminal cam protocol
//04/10/2023	navcs2	ChangeRequest 60735: EUP | CAMS Protocol - System Alert on AdHoc Run
--------------------------------------------------------------------------------
*/
vars
	passport		: CM_Passport;
	emailTxt		: String;
	err				: CM_Error;
	genErrMsg		: String;
	allExtraDetails	: StringArray;
	extraDetailStr	: String;
	
begin
	passport := app.myPassport;

	if _protLog then
		self.writeLog(_msgText &amp; _param1);	//par 26290 cnwrs1 11 nov 2010
	endif;
		
	if _alert then
		//this does app.writeLog
		if _param1 = null and self.allExclusionLogMessages.isEmpty then														//04/10/2023 navcs2 ChangeRequest 60735
			app.remoteErrorWarningToAlert(_msgText, null, passport.allErrors, null, false, false);	//par 26290 cnwrs1 11 nov 2010
		elseif not self.allExclusionLogMessages.isEmpty then																//04/10/2023 navcs2 ChangeRequest 60735
			app.remoteErrorWarningToAlert(_msgText, null, passport.allErrors, self.allExclusionLogMessages, false, false);	//04/10/2023 navcs2 ChangeRequest 60735
		elseif _param1 &lt;&gt; SkipExtraDetails then		//29.May.24 navsp1 TFS 64280
			create allExtraDetails transient;
			//allExtraDetails.add("CAM Protocol: " &amp; _param1);
			// 20 May 2011	NDL	Par 27484 - 1035 error.
//			extraDetailStr := ("CAM Protocol: " &amp; _param1)[1:62];
			allExtraDetails.add(_param1[1:62]);
			if _param1.length &gt; 62 then
				allExtraDetails.add(_param1[63:62]);
			endif;
			if _param1.length &gt; 124 then
				allExtraDetails.add(_param1[125:62]);
			endif;
			if _param1.length &gt; 186 then
				allExtraDetails.add(_param1[187:62]);
			endif;
			if _param1.length &gt; 248 then
				allExtraDetails.add(_param1[249:62]);
			endif;
			app.remoteErrorWarningToAlert(_msgText, null, passport.allErrors, allExtraDetails, false, false);
		endif;
	endif;
	foreach err in passport.allErrors do
		emailTxt := emailTxt &amp; '(' &amp;err.errorCode.String &amp; ') ' &amp; err.text &amp; CrLf;
	endforeach;
	app.writeLog(_msgText &amp; _param1&amp;' - '&amp;emailTxt, LogINFO);	//par 26290 cnwrs1 11 Nov 2010 always log the message

//	if _email then
	if _email and self.supportersEmail.trimBlanks &lt;&gt; null then	//18 Jun 2021	NDL	TFS 50119
		foreach err in passport.allErrors do
			emailTxt := emailTxt &amp; '(' &amp;err.errorCode.String &amp; ') ' &amp; err.text &amp; CrLf;
		endforeach;
		
		passport.clearErrorsWarnings();
		genErrMsg := "CAM background task may require manual restart.";
		app.myTrxCA.trxCreateEmailSendRequest(	app.getErrorString(CAMS_Alert),
												self.supportersEmail,
												self.supportersEmail,
												null,
												null,
												app.getErrorString(CAMS_Alert),
												_msgText &amp; " - " &amp; genErrMsg &amp; CrLf &amp; _param1 &amp; CrLf &amp; emailTxt,
												null,
												null,
												null,
												null,
												EmailSource_CAMS,
												self,
												passport);
		
		if passport.hasErrors() then	//21 Nov 2012	cnwrs1	Par 30728	fail with message and alert if directory make fails
			app.remoteErrorWarningToAlert(app.getErrorString(ERR_CAMS_SupportEmail), null, passport.allErrors, null, false, false);
			passport.clearErrorsWarnings();
		endif;
	endif;
epilog
	delete allExtraDetails;
end;</source>
        <Parameter name="_msgText" type="String"/>
        <Parameter name="_param1" type="String"/>
        <Parameter name="_email" type="Boolean"/>
        <Parameter name="_alert" type="Boolean"/>
        <Parameter name="_protLog" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="logReasonForExclusion" id="648a5526-76b5-42a8-a457-211ced4d0c26">
        <source>logReasonForExclusion(_trx :CM_Transaction; _reason :String);
/*
Date		Who		Reason
30 May 2012	cnwcs5	Initial creation - par 29601 CAMS logging for excluded transactions
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask - from CM_CamTask
//30 Apr 2015	cnwrs1	Par35784 - increased exclusion reason logging to include non excluded
//06 Jul 2016	cnwrs1	Par 38021 - Review Cam logging
//04/10/2023	navcs2	ChangeRequest 60735: EUP | CAMS Protocol - System Alert on AdHoc Run
*/
vars
	trxTS : String;
	str :String;
	log : File;
	now	: TimeStamp;
begin
	//epr TFS 2387 19/7/16
	if not self.logExcludedTransactions then
		return;
	endif;
	
	if _trx.isKindOf (CM_TITransaction) then
		trxTS := _trx.CM_TITransaction.camsTimeStamp.formatAsYYYYMMDDHHMMSSMMM;
	elseif _trx.isKindOf (CM_EventTransaction) then
		trxTS := _trx.CM_EventTransaction.camsTimeStamp.formatAsYYYYMMDDHHMMSSMMM;
	endif;
	str :="*** Excluded Event Transaction *** " &amp;  _trx.getDisplayID &amp; ' @ ' &amp; trxTS &amp; ' - ' &amp; _reason;
	self.allExclusionLogMessages.add(str);								//04/10/2023	navcs2	ChangeRequest 60735
	if app.isDevelopmentSystemMain and self.isAdhoc then
		write str;
	endif;
	//app.writeLog(str, LogINFO); //epr TFS 2512 10/8/16 - always log   /*navma1 Temp Stopped DMAST Only*/
	log := self.protocolLog;
	if log = null then
		app.writeLog("Protocol log file not initialised.", LogINFO);
		return;
	endif;
	if not log.isOpen then 
		log.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
		log.allowReplace := false;
		log.mode := File.Mode_Append;
		log.open;
	endif;
	log.writeLine(now.literalFormat() &amp; Tab &amp; str);
	
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;now.literalFormat() &amp; Tab &amp; str;
epilog

end;</source>
        <Parameter name="_trx" type="CM_Transaction"/>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
    <JadeMethod name="logReasonForInclusion" id="8704498d-1b96-456d-afb4-ef74a4e8c73e">
        <source>logReasonForInclusion(_trx :CM_Transaction; _reason :String);
//
//06 Mar 2015	cnwrs1	Par35784 - increased exclusion reason logging to include non excluded
//
//06 Jul 2016	cnwrs1	Par 38021 - Review Cam logging
vars
	trxTS :String;
	str :String;
	log : File;
	now	: TimeStamp;
begin
	if _trx.isKindOf (CM_TITransaction) then
		trxTS := _trx.CM_TITransaction.camsTimeStamp.formatAsYYYYMMDDHHMMSSMMM;
	elseif _trx.isKindOf (CM_EventTransaction) then
		trxTS := _trx.CM_EventTransaction.camsTimeStamp.formatAsYYYYMMDDHHMMSSMMM;
	endif;
	str :="*** Included Event Transaction *** " &amp;  _trx.getDisplayID &amp; ' @ ' &amp; trxTS &amp; ' - ' &amp; _reason;
	app.writeLog(str, LogINFO); //epr TFS 2512 10/8/16 - always log
	log := self.protocolLog;
	if log = null then
		app.writeLog("Protocol log file not initialised.", LogINFO);
		return;
	endif;
	if not log.isOpen then 
		log.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
		log.allowReplace := false;
		log.mode := File.Mode_Append;
		log.open;
	endif;
	log.writeLine(now.literalFormat() &amp; Tab &amp; str);
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;now.literalFormat() &amp; Tab &amp; str;
epilog

end;</source>
        <Parameter name="_trx" type="CM_Transaction"/>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
    <JadeMethod name="processActivity" id="57a75301-0732-4948-bfad-204e7f801b1f">
        <updating/>
        <source>processActivity() updating, protected;
// ---------------------------------------------------------------------------
// Created:		19 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
20 Apr 2010	cnwkpd1	PAR #23871 - Speed up CAMS processing
17 May 2012	cnwrs1	Par 26914 - make cam task transient and remove camprotocol::camTask
25 May 2012	cnwrs1	Par 26914 - make cams restart after lock error
18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
21 Aug 2012	cnwrs1	Par 30232 cleanup memory leak
20 Nov 2012	cnwrs1	Par 30728	fail with message and alert if directory make fails
10 Dec 2012	cnwcs5	par 30855 / CCMS SFW 1294 - CAMS processing intervals
27 Mar 2013 cnwmh5	#31047 - Set myCamProtocol
*/
//01 Jul 2013	cnwrs1	Par31047 - Cams Exception Handler
//23 Feb 2015	cnwrs1	Par 35738 - if running multiple processes we may "lose" our running camTaskHistory
//04 Mar 2015	cnwrs1	Par35794 - Cams trying to update status on camTaskHistory when it is null
//06 Jul 2016	cnwrs1	Par 38021 - Review Cam logging
//12 Jul 2016 cnwrs1	Par 34046- Cams Problems in 090
vars
	terminal 			: CM_Terminal;
	passport			: CM_Passport;
	camProtocol 		: CM_CamProtocol;
	runDateTime, startDateTime, endDateTime : TimeStamp;
	log					: File;
	doSomething 		: Boolean; 	// this is set to indicate we have done a cam prorcess so loop again to see if their is anything else to do 
	delayTime 			: Time;
	dyna 				: DynaDictionary;
	iter 				: Iterator;
	protocolsToIgnore 	: ObjectSet;
	camTaskHistory 		: CM_CamTaskHistory;
	code 				: String;	// for debugging
	earliestDate		: Date;
	errCode	: Integer;
	errTxt	: String;
begin
	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, true);
	on Exception do self.controllerXhandler(exception);
	on LockException do self.lockExceptionHandler(exception);		// PAR #29594
	
	terminal 		:= self.myTerminal;
	passport		:= app.myPassport;
	doSomething 	:= true;
	earliestDate	:= self.getEarliestCAMSRunDate;		// par 30855 Dec 2012
	
	delayTime.setTime(0, terminal.getConfig(CamsDelayTime).Integer, 0, 0);
	
	create protocolsToIgnore transient;
	create dyna transient;
	
	dyna.setMembership(CM_CamProtocol);
	dyna.addExternalKey(TimeStamp, null, false, true);
	dyna.endKeys(true);
	
	while (doSomething) do //par 15350 do all outstanding work 
		doSomething 	:= false;
		
		//run thru all protocols and find all that are now due but ignore any that have failed in this cams run
		foreach camProtocol in terminal.camProtocols do
			code := camProtocol.code;

			if camProtocol.status &lt;&gt; CAM_IDLESTATUS then
				continue;
			endif;
			
			runDateTime := app.actualTimeServer(); //cnwrs1 June 2008 par 16918
			
			if protocolsToIgnore.includes(camProtocol) then
				// has failed during this run
				continue;
			endif;		
			
			if not camProtocol.isTaskNowDue(runDateTime, startDateTime, endDateTime) then
				// not due to run
				continue;
			endif;			
				
			// we are goiing to process next CAMS intervald for this protocol
			dyna.putAtKey (endDateTime, camProtocol);
			
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;code &amp; " added to be processed ", LogDEBUG);
			
			//PAR21634 - cnwsh3 Change logging as the description is not a required field
			app.writeLog(code &amp; " current status is " &amp; camProtocol.statusString &amp; ' next due ' &amp; (endDateTime + delayTime).String, LogINFO);
		endforeach;

		if dyna.isEmpty then
			// no more protocols that can be processed are due
			break;
		endif;
		
		if iter &lt;&gt; null then 				// 21 Aug 2012	cnwrs1	Par 30232
			iter.reset;
		else
			iter := dyna.createIterator();	
		endif;
		
		// process all those now due in earlest due time
		while iter.next(camProtocol) do
			runDateTime := app.actualTimeServer(); //cnwrs1 June 2008 par 16918
			code 		:= camProtocol.code;
			
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;code &amp; " to be processed ", LogDEBUG);
			
			if protocolsToIgnore.includes(camProtocol) then	
				// ignore all protocols that have failed this run
				continue;
			endif;
			
			if not camProtocol.isTaskNowDue(runDateTime, startDateTime, endDateTime) then
				continue;
			endif;		
			
				
			// par 30855 - check we have done the necessary CAMS timestamp upgrades for 8.2.1
			if startDateTime.Date &lt; earliestDate then
				protocolsToIgnore.add(camProtocol);
				
				app.writeLog(code &amp; " could not be processed as the CAMS timestamp upgrader has not been run for " &amp; startDateTime.asStringJMT, LogINFO);
				continue;
			endif;		
			
			if not self.setCurrentProtocol(camProtocol) then	
				protocolsToIgnore.add(camProtocol);
				// 20 Nov 2012	cnwrs1	Par 30728	fail with message and alert if directory make fails
				self.logMessage("CAMS failed to initialise for " &amp; self.getErrorDesc, null, true, true, false);
				self.writeCrashLogAlertAndEmail(app.myPassport);
				continue;
			endif;

			app.sendHeartbeatIfRequired();		// 1/9/17 MAP TFS5551

			self.processCamProtocol(runDateTime, startDateTime, endDateTime);
			
			camTaskHistory 	:= camProtocol.taskHistoryByProtocolSeq [camProtocol, self.processSeqNumber];
			if camTaskHistory &lt;&gt; null then
				app.myTrxUA.trxUpdateCamObjectStatus(camTaskHistory, self.status, passport);
				
				if not passport.trxCompletedOK() then
					self.logMessage(app.getErrorString(ERR_CAMS_Process)&amp; ' ' &amp; self.getCurrentProtocolCode(), " failed to end the CAM task.", false, true, false);	// PAR #28709
					
					passport.clearErrorsWarnings();
				endif;
			else
				self.logMessage(app.getErrorString(ERR_CAMS_Process)&amp; ' ' &amp; self.getCurrentProtocolCode(), " lost the CAM Task History.", false, false, false);	// PAR #35738
			endif;
			if self.status &lt;&gt; CAM_COMPLETESTATUS then	// has failed in this run so will ignore this protocol during this cams run
				protocolsToIgnore.add(camProtocol);
				if camTaskHistory &lt;&gt; null then
					app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;code &amp; " added to in error after processing " &amp; camTaskHistory.statusString, LogDEBUG);
				else
					app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;code &amp; " added to in error after processing.", LogDEBUG);
				endif;
			endif;
			
			if self.isLockedByMe(camProtocol) then
				self.unlock(camProtocol);
			endif;
			
			// we have processed something so go round again and see if anything else is due
			doSomething := true;
		endwhile;
		// clear out collection for next time through
		dyna.clear;
	endwhile;
	
epilog
	// otherwise the session unlock will not work
	if process.isInExceptionState then
		app.cmsAbortTransaction;
	endif;
	
	if self.myCurrentCamProtocol &lt;&gt; null then
		if self.isLockedByMe(self.myCurrentCamProtocol) then
			self.unlock(self.myCurrentCamProtocol);
		endif;
	endif;
	
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;"Epilog of ProcessActivity ", LogDEBUG);
	
	log := self.protocolLog;
	
	if log &lt;&gt; null and log.isOpen then
		log.close;
		delete log;
		self.protocolLog := null;
	endif;
	
	delete protocolsToIgnore;
	delete iter;
	delete dyna;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="processActivityNow" id="fb7894e7-4194-4413-8b3c-a93dd07c5d91">
        <updating/>
        <source>processActivityNow() updating, protected;
//
//20 Nov 2012	cnwrs1	Par 30728	fail with message and alert if directory make fails
//
//01 Jul 2013	cnwrs1	Par31047 - Cams Exception Handler
vars
	runDateTime 	: TimeStamp;
	startDateTime 	: TimeStamp;
	endDateTime 	: TimeStamp;
	nowDateTime 	: TimeStamp;
begin
	nowDateTime := app.actualTimeServer();
	runDateTime := app.actualTimeServer(); //cnwrs1 Jan 2008 par 15573
	
	if self.myCurrentCamProtocol.status = CAM_IDLESTATUS then
		// first thing make sure it is uptodate
		//while self.myCurrentCamProtocol.isTaskNowDue(runDateTime, startDateTime, endDateTime) do
		//epr TFS 2142 23/6/16
			self.processCamProtocol(runDateTime, startDateTime, endDateTime);
			if not self.setCurrentProtocol(self.myCurrentCamProtocol) then	//20 Nov 2012	cnwrs1	Par 30728	fail with message and alert if directory make fails
				self.logMessage("CAMS failed to initialise for " &amp; self.myTerminal.name, null, true, true, false);
				self.writeCrashLogAlertAndEmail(app.myPassport);
				return;
			endif;

		//	self.processCamProtocol(runDateTime, startDateTime, endDateTime);
			
			//startDateTime 	:= null;
			//endDateTime 	:= null;
		//endwhile;
		
		// setup to run from last run to now.
		self.startTask(runDateTime, startDateTime, nowDateTime);
		self.extractAction();
		self.sendAction();
		self.endTask();
	endif;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="processCamProtocol" id="4462e134-9fe8-4dbc-859f-4b804728b613">
        <updating/>
        <source>processCamProtocol(_runDateTime : TimeStamp; _startDateTime : TimeStamp io; _endDateTime : TimeStamp io) updating, protected;
//
// bring the current cam protocol upto date
//
/*

Date		Who		Reason
20 Apr 2010	cnwkpd1	PAR #23871 - Speed up CAMS processing
18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
30 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
17 Dec 2012	cnwcs5	CCMS SFW 1294/par 30855
25 Mar 2013	cnwrs1	CCMS SFW 1294 Testing - not failing after exception in cam task history
*/

vars
	catchup			: Boolean;
	terminal 		: CM_Terminal;
	lockWaits 		: Integer;
	startTime 		: TimeStamp;
	endTime 		: TimeStamp;
	startDate 		: Date;
	camTaskHistory 	: CM_CamTaskHistory;
begin
    terminal 	:= self.myTerminal;
	startDate 	:= _startDateTime.date;
	
	// try to lock to ensure another process is not already processing it
	if self.tryLock(self.myCurrentCamProtocol, Exclusive_Lock, Session_Duration, LockTimeout_Server_Defined) then
		catchup := terminal.getConfig(CamsContinuousCatchup).Boolean;
		
		// recheck it is still needing process another process may have already processed it
		while self.myCurrentCamProtocol.isTaskNowDue(_runDateTime, _startDateTime, _endDateTime) do :dueLoop
			app.writeLog("Task now due for " &amp; self.myCurrentCamProtocol.code&amp;' startDateTime='&amp;_startDateTime.String&amp;' endDateTime='&amp;_endDateTime.String, LogINFO);		// PAR #23871
			
			if startTime = _startDateTime and endTime = _endDateTime then
				break dueLoop;
			endif;
			
			app.sendHeartbeatIfRequired();		// 29/8/17 MAP TFS5551

			startTime 	:= _startDateTime;
			endTime 	:= _endDateTime;
			
			self.startTask(_runDateTime, _startDateTime, _endDateTime);
			
			if self.status = CAM_IDLESTATUS or self.status = CAM_EXTRACTSTATUS then
				self.extractAction();
			endif;
			
			if self.status = CAM_IDLESTATUS or self.status = CAM_EXTRACTSTATUS or self.status = CAM_SENDSTATUS then
				self.sendAction();
			endif;
			
			if self.status = CAM_IDLESTATUS or self.status = CAM_EXTRACTSTATUS or self.status = CAM_SENDSTATUS then
				self.endTask();
			endif;
			
			camTaskHistory := self.myCurrentCamProtocol.taskHistoryByProtocolSeq.last;
			
			if self.status &lt;&gt; CAM_COMPLETESTATUS then	//25 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
				break dueLoop;
			endif;
			
			if (not catchup) and _endDateTime.date &gt; startDate then
				break dueLoop;
			else
				if self.isLockedByMe(self.myCurrentCamProtocol) then
					self.unlock(self.myCurrentCamProtocol);
				endif;
				// PAR #23871 - remove sleep from here
				lockWaits := 0;

				while not self.tryLock(self.myCurrentCamProtocol, Exclusive_Lock, Session_Duration, LockTimeout_Server_Defined) do :lockWaitLoop
					if lockWaits &gt; 4 then
						app.writeLog("Current protocol still locked by another process.  Can't get lock after 5 tries.", LogINFO);
						break dueLoop;
					endif;
					
					process.sleep(2000);
					
					lockWaits := lockWaits + 1;
				endwhile;
			endif;
			
			// user may have updated protocol to "hold" status while sleeping
			if self.myCurrentCamProtocol.status = CAM_HOLDSTATUS then
				break dueLoop;
			endif;
		endwhile;
	else
		app.writeLog(self.myCurrentCamProtocol.description &amp; " found locked.  Check for stall in Terminal Admin", LogINFO);
	endif;
epilog
	if self.isLockedByMe(self.myCurrentCamProtocol) then
		self.unlock(self.myCurrentCamProtocol);
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <Parameter name="_startDateTime" type="TimeStamp" usage="io"/>
        <Parameter name="_endDateTime" type="TimeStamp" usage="io"/>
    </JadeMethod>
    <JadeMethod name="purgeOldCamsHistory" id="8a0f464e-a368-43c9-8dec-436ed01008dc">
        <source>purgeOldCamsHistory(_purgeEDICAMSPeriod: Integer) protected;
// -----------------------------------------------------------------------------
// Created:		16 May 2003  by Jason Chapman  (cnwjc2)
/*
Changed On	Changed By	Reason
----------	----------	--------------------------------------------------------
29/07/09	J Harliwich	MES1011 Need to remove old stuff off new set of processed transaction.
						Put in extra check so we never purge todays stuff, and we only run a purge once a day
12/5/2010	cnwcs5		par 23967 - remove reference to allProcessedTransactions and allProcessedEventTransactions
12/08/2010	cnwdad1		PAR #25172. Changed call of "logMessage" to record CAM Protocol
						code with error message.
//06 Jul 2016	cnwrs1	Par 38021 - Review Cam logging
// 28 Sep 2016	cnwrs1	TFS 2756 PAR38267 allow Cams to run per terminal
--------------------------------------------------------------------------------
*/
vars
	camProtocol 	: CM_CamProtocol;
	clearToDate,
	today 			: Date;
	histCount		: Integer;
	purgeCount		: Integer;
	passport		: CM_Passport;
begin
	passport 	:= app.myPassport;
	clearToDate := today - _purgeEDICAMSPeriod;
	
	if clearToDate = today then 									// MES1011
		clearToDate := clearToDate - 1;								// never remove todays processed transactions or we might end up sending some twice
	endif;
	
	app.writeLog('Starting purge of old CAM history to ' &amp; clearToDate.String, LogINFO);
	
	foreach camProtocol in self.myTerminal.camProtocols do
		if self.tryLock(camProtocol, Exclusive_Lock, Session_Duration, LockTimeout_Immediate) then
			if camProtocol.lastHistoryPurgeDate &lt;&gt; null	and				// MES1011 only do purge once a day, not every time we wake up
			   camProtocol.lastHistoryPurgeDate =  clearToDate then	// have already run it today
				self.unlock(camProtocol);
				continue;
			endif;
				
			histCount := camProtocol.taskHistoryByProtocolSeq.size();
			
			app.myTrxDA.trxDeleteCamsHistory(camProtocol, clearToDate, today, passport);
			
			if not passport.trxCompletedOK() then
				if not passport.trxCompletedOK() then
					self.logMessage(app.getErrorString(ERR_CAMS_Process)&amp;' '&amp;camProtocol.code, "Error: Old CAM history not cleared for " &amp; camProtocol.code &amp; ".  Return code: " &amp; passport.returnCode.String , false, true, false);	//par 26290 cnwrs1 11 nov 2010
					passport.clearErrorsWarnings();
				endif;
			else
				purgeCount := histCount - camProtocol.taskHistoryByProtocolSeq.size;
				
				if purgeCount &gt; 0 then
					app.writeLog("Cleared " &amp; purgeCount.String &amp; " task history items for protocol " &amp; camProtocol.code, LogINFO);
				endif;
			endif;
			self.unlock(camProtocol);
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_purgeEDICAMSPeriod" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="restartTask" id="f6444cad-917e-463b-8c25-9f6205797fee">
        <updating/>
        <source>restartTask(_camProtocol: CM_CamProtocol; _seqNumber : Integer; _msgIndex : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		20 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
/*
Changed On	Changed By	Reason
----------	----------	--------------------------------------------------------
11/08/2010	cnwdad1		PAR #25172 - Pass CAM Protocol name to "logMessage" when raising an alert.
17 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask
21 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask cleanup
17 Jul 2012	cnwcs5		par 29601 - log excluded transactions
21/08/2012	cnwcs5		par 30176 - conversion for above
-------------------------------------------------------------------------------
*/
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
//14 Aug 2012	cnwrs1	Par 30197 - restart not working
//20 Nov 2012	cnwrs1	Par 30728	fail with message and alert if directory make fails
// 26 Jun 2013	cnwrs1	par 31047 Cam Exception Handling testing

vars
	camTaskHistory	: CM_CamTaskHistory;
	errMsg			: String;
	log				: File;
	originalStatus	: Integer;
	passport		: CM_Passport;
	protocol		: CM_CamProtocol;
begin

	if not self.tryLock(_camProtocol, Exclusive_Lock, Session_Duration, LockTimeout_Server_Defined) then
		app.writeLog("Action : " &amp; method.name &amp; ".  " &amp; app.getErrorString(MSG_CAMS_ProtocolBusy), LogINFO);
		return;
	endif;		

	originalStatus	:= _camProtocol.status;
	passport		:= app.myPassport;
	
	if not self.setCurrentProtocol(_camProtocol) then	//20 Nov 2012	cnwrs1	Par 30728	fail with message and alert if directory make fails
		self.logMessage("CAMS failed to initialise for " &amp; self.myTerminal.name, null, true, true, false);
		self.writeCrashLogAlertAndEmail(app.myPassport);
		return;
	endif;
	
	self.isRestart 	:= true;
	self.msgIndex	:= _msgIndex; //jlier1 TFS 58637 20/6/23
	protocol		:= self.myCurrentCamProtocol;	// par 29601 July 2012
	
	self.initAgent();
	
	if self.armExceptionHandler then
		on NormalException do protocol.protocolExceptionHandler(exception);
	endif;

	self.logMessage(protocol.code.String &amp; app.getErrorString(MSG_CAM_TaskRestarted) &amp; _seqNumber.String &amp; ".", null, false, false, true);

	//---------------------------------------
	// Start with a new transient task
	//---------------------------------------
//	create camAgent transient;
	
	//---------------------------------------
	// Find the History with the supplied sequence number
	//---------------------------------------
	if _seqNumber &lt;&gt; Adhoc_Reprocess then //par17707
		camTaskHistory := protocol.taskHistoryByProtocolSeq [protocol, _seqNumber];
	else
		camTaskHistory := protocol.taskHistoryByProtocolSeq [protocol, Adhoc_Key];
	endif;
	
	//---------------------------------------
	// Create the new task
	//---------------------------------------
	if camTaskHistory &lt;&gt; null then
		self.setForInit(protocol, camTaskHistory.runDateTime, camTaskHistory.startDateTime, camTaskHistory.endDateTime, 
							camTaskHistory.logExcludedTransactions, self.protocolLog, camTaskHistory.dailySeqNumber, _seqNumber, camTaskHistory.status);	//par30197		// par 29601 July 2012
	else
		app.raiseCMException2(ERR_CAMS_NOHISTORY, _seqNumber.String, protocol.description, 'camsTaskHistory', null);	
		return;
	endif;	
	
	if not passport.trxCompletedOK() then
		self.logMessage(app.getErrorString(ERR_CAMS_Process)&amp;' '&amp;self.getCurrentProtocolCode(), " failed to restart CAM task.", true, true, false);	//par 26290 cnwrs1 11 Nov 2010
		passport.clearErrorsWarnings();
		app.myTrxUA.trxUpdateCamHistoryMsg(camTaskHistory, app.getErrorString(ERR_CAMS_Process), 0, passport);
		if not passport.trxCompletedOK() then
			self.writeCrashLogAlertAndEmail(app.myPassport);
		endif;
		return;
	endif;
	
	self.writeLog(app.getErrorString(MSG_CAM_TaskRestarted));
	//---------------------------------------
	// Continue processing
	//---------------------------------------
	if camTaskHistory.status = CAM_EXTRACTSTATUS then
		self.extractAction();
		self.sendAction();	
		self.endTask();
		
	elseif camTaskHistory.status = CAM_SENDSTATUS or camTaskHistory.status = CAM_RESENDSTATUS then
		self.sendAction();
		self.endTask();
	endif;
	
	//set the protocol back to what it was for restarts
	app.myTrxUA.trxUpdateCamObjectStatus(protocol, originalStatus, passport);
	
	if not passport.trxCompletedOK() then
		self.logMessage(app.getErrorString(ERR_CAMS_Process) &amp; ' ' &amp; self.getCurrentProtocolCode(), " failed to update CAM Protocol status.", true, true, false);	//par 26290 cnwrs1 11 Nov 2010
		
		passport.clearErrorsWarnings();
	endif;

	self.logMessage(protocol.code &amp; app.getErrorString(MSG_CAMS_TaskFinished) , null, false, false, true);
epilog
	// otherwise the session unlock will not work
	if process.isInExceptionState then
		app.cmsAbortTransaction;
	endif;

	if _camProtocol &lt;&gt; null and 
	   self.isLockedByMe(_camProtocol) then
		self.unlock(_camProtocol);
	endif;
	
	log := self.protocolLog;

	if log &lt;&gt; null and log.isOpen then
		log.close;
		delete log;
		self.protocolLog := null;
	endif;
end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_msgIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="run" id="96776a39-f50f-4048-84da-f0979bf1bda9">
        <updating/>
        <source>run() updating;
// ---------------------------------------------------------------------------
// Created:		19 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// Kick-off CAMS
// ---------------------------------------------------------------------------
// 03 Oct 2016	cnwrs1	TFS 2756 PAR38267 allow Cams to run per terminal
vars
	startDateTime : TimeStamp;
begin
	startDateTime := app.actualTimeServer();
	//----------------------
	// Do some initialzation
	//----------------------
	if not self.initAgent() then
		self.logMessage("CAMS failed to initialise for " &amp; self.myTerminal.name, null, true, true, false);
		return;
	endif;
	
	app.writeLog("CAMS initialised for " &amp; self.myTerminal.name, LogINFO);
	
	//----------------------
	// Process anything ready to be processed
	//----------------------
	self.processActivity();
epilog
	app.writeLog("CAMS activity closed for " &amp; self.myTerminal.name&amp;' after '&amp;(app.actualTimeServer()-startDateTime).String, LogINFO);
end;</source>
    </JadeMethod>
    <JadeMethod name="runNow" id="c1bef23a-6f95-4ddc-8de5-23e6f0e1603a">
        <updating/>
        <source>runNow(_camProtocol : CM_CamProtocol) updating;
//
//20 Nov 2012	cnwrs1	Par 30728	fail with message and alert if directory make fails
//
// 03 Oct 2016	cnwrs1	TFS 2756 PAR38267 allow Cams to run per terminal
vars
	startDateTime : TimeStamp;
begin
	startDateTime := app.actualTimeServer();
	if not self.initAgent() then
		self.logMessage("CAMS failed to initialise for " &amp; self.myTerminal.name, null, true, true, false);
		return;
	endif;
	if not self.setCurrentProtocol(_camProtocol) then	//20 Nov 2012	cnwrs1	Par 30728	fail with message and alert if directory make fails
		self.logMessage("CAMS failed to initialise for " &amp; self.myTerminal.name, null, true, true, false);
		return;
	endif;
	app.writeLog("CAMS initialised for " &amp; self.myTerminal.name, LogINFO);
	self.processActivityNow();
epilog
	app.writeLog("CAMS activity closed for " &amp; self.myTerminal.name&amp;' after '&amp;(app.actualTimeServer()-startDateTime).String, LogINFO);
end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
    </JadeMethod>
    <JadeMethod name="sendAction" id="4b4b0f90-fc7c-47ff-a4e4-68b9f12f2a2b">
        <updating/>
        <source>sendAction() updating, protected;
// ---------------------------------------------------------------------------
// Created:		19 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
/*
Changed On	Changed By	Reason
----------	----------	--------------------------------------------------------
11/08/2010	cnwdad1		PAR #25172 - Pass CAM Protocol name to "logMessage" when raising an alert.
22/11/2011	cnwkpd1		PAR #28709 - Stop CAMS Processing Error messages for protocols without Email enabled
12 Jul 2012	cnwrs1		CCMS 1269 CAMS reduce number of Trxs
18 Jul 2012	cnwrs1		CCMS 1269 CAMS remove CM_CamTask
01 Jul 2013	cnwcs5		par 31819 - do not allow "send files with no message" for user defined JRW files 
6  Oct 2023 navra1		TFS 60336 - EUP | FR 53853 - CAMS API CAMS history (Status Code)
--------------------------------------------------------------------------------
*/
vars
	protocol		: CM_CamProtocol;
	status		 	: String;
begin	
	protocol := self.myCurrentCamProtocol;
	
	if protocol.onHold then //Par 13314 cnwrs1 Feb 2007 if on hold dont send anything
		self.logMessage(method.qualifiedName &amp; " CAMS Protocol on Hold, not able to send data", null, false, false, true);
		return;
	endif;
	
	if not self.allProcessSeqNumbers.isEmpty() then
		self.sendActionMultiple();
	else
		//epr TFS 2192 21/6/16
		self.sendActionSingle(self.processSeqNumber);
	endif;
	
epilog
	// Moved to sendActionSingle instead
	//app.writeLog(protocol.code.String &amp; app.getErrorString(MSG_CAMS_SendFinished), LogWARN);
	
	//navra1 - TFS 60336 - 6th Oct 2023 - start
	if protocol.onHold then
		status := "ONHOLD";
	else
		if protocol.myExternalWebServiceDef &lt;&gt; null then
			status := protocol.myExternalWebServiceDef.status;
		endif;
	endif;
	
	if protocol.taskHistoryByProtocolSeq.size() &gt; 0 then
		app.myTrxUA.trxUpdateCamHistoryMsg(protocol.taskHistoryByProtocolSeq.last(), status, null, app.myPassport);
	endif;
	//navra1 - TFS 60336 - 6th Oct 2023 - end
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="sendActionMultiple" id="23221407-8207-4517-8539-0039178e7073">
        <updating/>
        <source> sendActionMultiple() updating, protected;
// For use when when multiple files are sent with single transaction per file.
/*
Changed On	Changed By	Reason
----------	----------	--------------------------------------------------------
11/08/2010	cnwdad1		PAR #25172 - Pass CAM Protocol name to "logMessage" when raising an alert.
22/11/2011	cnwkpd1		PAR #28709 - Stop CAMS Processing Error messages for protocols without
						Email enabled
12 Jul 2012	cnwrs1		CCMS 1269 CAMS reduce number of Trxs
18 Jul 2012	cnwrs1		CCMS 1269 CAMS remove CM_CamTask
01 Jul 2013	cnwcs5		par 31819 - do not allow "send files with no message" for user defined JRW files 
--------------------------------------------------------------------------------
*/
vars
	
begin
		
	foreach processSeqNumber in self.allProcessSeqNumbers do	
		//epr TFS 2192 refactored 
		self.sendActionSingle(processSeqNumber);
		app.sendHeartbeatIfRequired();		// TFS 48201 jlgmd1 10/01/2020
	endforeach;
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="sendActionSingle" id="35c3e7ad-41f6-4137-bfd7-da460e674d68">
        <updating/>
        <source>sendActionSingle(_processSeqNum : Integer)protected, updating;
/*

Date		Who		Reason
21 June 2016	cnwer1	Initial creation TFS 2043
//06 Jul 2016	cnwrs1	Par 38021 - Review Cam logging
//12 Jul 2016 cnwrs1	Par 34046- Cams Problems in 090
*/

vars
	protocol		: CM_CamProtocol;
	camTaskHistory	: CM_CamTaskHistory;
	emailUniqueId	: Integer;
begin
	protocol := self.myCurrentCamProtocol;
	
	camTaskHistory := protocol.taskHistoryByProtocolSeq[protocol, _processSeqNum];
	
	if camTaskHistory = null then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Protocol.code='&amp;self.myCurrentCamProtocol.code&amp;' self.processSeqNumber='&amp;_processSeqNum.String&amp;' No camTaskHistory '&amp;' startDateTime='&amp;self.startDateTime.String&amp;' endDateTime='&amp;self.endDateTime.String, LogWARN);	
		return;
	endif;
	
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Protocol.code='&amp;self.myCurrentCamProtocol.code&amp;' self.processSeqNumber='&amp;_processSeqNum.String&amp;' camTaskHistory='&amp;camTaskHistory.String&amp;' startDateTime='&amp;self.startDateTime.String&amp;' endDateTime='&amp;self.endDateTime.String, LogDEBUG);	

	// if the file has no message and camProtocol set to not send MT files return
	if camTaskHistory.messageCount = 0 then
		if protocol.sendMtFiles = false	or protocol.isUserDefinedReport or protocol.isUserDefinedEventReport then
			self.writeLog(app.getErrorString1(MSG_CAMS_FileNotSent, self.fileDirectory &amp;'\'&amp; protocol.getProtocolSubDirectoryName() &amp; "\" &amp; camTaskHistory.fileName)); //cnwrs1 June 2009 par 19312
			return;
		endif;
	endif;

	app.writeLog(protocol.code.String &amp; " " &amp; app.getErrorString(MSG_CAMS_SendStarting), LogWARN);
	
	self.setStatus(CAM_SENDSTATUS);       //12 Jul 2012	cnwrs1	CCMS 1269 CAMS reduce number of Trxs
	
	emailUniqueId := protocol.sendAction(self.fileDirectory &amp;'\'&amp; protocol.getProtocolSubDirectoryName() &amp; "\", camTaskHistory,self.msgIndex); //jlier1 TFS 58637 20/6/23

	self.writeLog(app.getErrorString1(MSG_CAMS_FileSent, self.fileDirectory &amp;'\'&amp; protocol.getProtocolSubDirectoryName() &amp; "\" &amp; camTaskHistory.fileName)); //cnwrs1 June 2009 par 19312
	
	app.myTrxUA.trxUpdateCamHistoryMsg(camTaskHistory, null, emailUniqueId, app.myPassport);

	if not app.myPassport.trxCompletedOK() then
		self.logMessage(app.getErrorString(ERR_CAMS_Process)&amp;' '&amp;self.getCurrentProtocolCode(), " failed to complete CAM task histoty.", true, true, false);	//par 26290 cnwrs1 11 nov 2010
		app.myPassport.clearErrorsWarnings();
	endif;
epilog
	app.writeLog(protocol.code.String &amp; " " &amp; app.getErrorString(MSG_CAMS_SendFinished), LogWARN);
end;</source>
        <access>protected</access>
        <Parameter name="_processSeqNum" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setCAMSEmail" id="bf37e310-5ec9-4662-b0a9-f0f015409791">
        <updating/>
        <source>setCAMSEmail(_terminal: CM_Terminal) updating;
//----------------------------------------------------------------
//	Created:	27 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	term			: CM_Terminal;
	emlEnt			: CM_EmailEntity;
	camsEmail		: String;
begin
	term := _terminal;

	camsEmail := term.getConfig(CamsEmailAddress).String;
	
	if camsEmail = null then
		return;
	endif;
	
	emlEnt := app.myRoot.getEmailEntity(camsEmail);
	
	if (emlEnt = null) then
		if (camsEmail.pos('@',1) &gt; 0) then
			self.supportersEmail := camsEmail;
		endif;
	else
		self.supportersEmail := emlEnt.getEmailAddress();
	endif;
epilog
	if self.supportersEmail = null then
		self.logMessage(app.getErrorString(ERR_CAMS_InvalidEmail)&amp;' '&amp;self.getCurrentProtocolCode(), null, false, true, false);	//par 26290 cnwrs1 11 Nov 2010
	endif;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setCurrentProtocol" id="d59f3e75-150c-41b2-9e29-6337820482bb">
        <updating/>
        <source>setCurrentProtocol(_camProtocol: CM_CamProtocol): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:		26 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 03 May 2012	cnwrs1	Par 29520 chage to call local initLogFile
//20 Nov 2012	cnwrs1	Par 30728	fail with message and alert if directory make fails
vars
	log : File;
begin

	if _camProtocol.myCamControllerAgent &lt;&gt; null then
		//already processing - exit!
		return false;
	endif;

	if self.myCurrentCamProtocol &lt;&gt; null then
		//close current log file
		log := self.protocolLog;
		if log &lt;&gt; null and log.isOpen then
			log.close;
			delete log;
			self.protocolLog := null;
		endif;
	endif;
	
	self.myCurrentCamProtocol := _camProtocol;
	self.protocolLog := self.initLogFile();
	if self.protocolLog = null then	//20 Nov 2012	cnwrs1	Par 30728	fail with message and alert if directory make fails
		return null;
	endif;
	return true;
		
end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDates" id="317eef0b-051b-40f6-8b73-8646fe45963e">
        <updating/>
        <source>setDates(_runDateTime: TimeStamp; _startDateTime: TimeStamp; _endDateTime: TimeStamp)updating;
// ---------------------------------------------------------------------------
// Created:		20 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask - from CM_CamTask
vars

begin
	self.runDateTime := _runDateTime;
	self.startDateTime := _startDateTime;
	self.endDateTime := _endDateTime;
end;</source>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <Parameter name="_startDateTime" type="TimeStamp"/>
        <Parameter name="_endDateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setExceptionHandler" id="481f421b-114f-4e71-9cef-bab9ca7cad1b">
        <updating/>
        <source>setExceptionHandler(_armed: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		20 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//this is for debugging - dev only
//06 Jul 2016	cnwrs1	Par 38021 - Review Cam logging
vars

begin
	armExceptionHandler := _armed;
	if _armed then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;"Exception handler armed", LogDEBUG);
	endif;
end;</source>
        <Parameter name="_armed" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForInit" id="108d0282-2c5c-43e0-926c-352525f4a2cf">
        <updating/>
        <source>setForInit(_camProtocol : CM_CamProtocol input; _runDateTime : TimeStamp; _startDateTime, _endDateTime : TimeStamp; _logExcludedTransactions : Boolean;
					_protocolLog : File; _dailySeqNumber : Integer; _processSeqNumber : Integer; _restartStatus : Integer)updating;
// ---------------------------------------------------------------------------
// 21 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask cleanup
// 25 May 2012	cnwrs1		Par 26914 - make cams restart after lock error
// 19 June 2012	cnwrs1		Par 29821 - CAMS single transaction per file
// 17 Jul 2012	cnwcs5		par 29601 - log excluded transactions
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask - from CM_CamTask
//28 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
//30 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
//14 Aug 2012	cnwrs1	Par 30197 - restart not working
//20 Feb 2013	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
//30 Apr 2015	cnwrs1	Par35784 - increased exclusion reason logging to include non excluded
//04 May 2016	cnwrs1	Par 37829 single transaction per file not sending output file when the are some discardable transactions
//06 Jul 2016	cnwrs1	Par 38021 - Review Cam logging
//04/10/2023	navcs2	ChangeRequest 60735: EUP | CAMS Protocol - System Alert on AdHoc Run
// ---------------------------------------------------------------------------
vars
	realCamTaskHistory 	: CM_CamTaskHistory;
	proxyCamTaskHistory	: CM_CamTaskHistory;
	loadState 			: Boolean;
begin
	// clear old data
	self.allProcessSeqNumbers.clear;
	self.allExclusionLogMessages.clear;		//04/10/2023	navcs2	ChangeRequest 60735
	self.dailySeqNumber 	:= null;
	self.processSeqNumber 	:= null;
	self.status 			:= 0;
	
	// end clear adata
	self.myCurrentCamProtocol 	:= _camProtocol;
	self.runDateTime 			:= _runDateTime;
	self.startDateTime 			:= _startDateTime;
	self.endDateTime 			:= _endDateTime;
	
	if _processSeqNumber = Adhoc_Reprocess then
		self.processSeqNumber 			:= Adhoc_Key;
		self.logExcludedTransactions 	:= _logExcludedTransactions;	// par 29601 July 2012
		
	elseif _processSeqNumber &lt;&gt; null then
		if _processSeqNumber = Adhoc_Seq then
			self.processSeqNumber 			:= Adhoc_Key;
			self.logExcludedTransactions 	:= _logExcludedTransactions;// par 29601 July 2012
			
		else
			self.unhSeqNumber 				:= self.myCurrentCamProtocol.unhSequenceNum;	//28 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
			self.processSeqNumber 			:= _processSeqNumber;
			self.logExcludedTransactions 	:= false;					// par 29601 July 2012
			self.status 					:= _restartStatus;
			self.logExcludedTransactions := _camProtocol.getLogExcludedTransactions;
			self.logIncludedTransactions := _camProtocol.getLogIncludedTransactions;
		endif;
		
		self.dailySeqNumber	:= _dailySeqNumber;
	else
		self.unhSeqNumber := self.myCurrentCamProtocol.unhSequenceNum;	//20 Feb 2013	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
		_camProtocol.getNextSeqNumber(self.processSeqNumber, self.dailySeqNumber, status);
		self.logExcludedTransactions := _camProtocol.getLogExcludedTransactions;
		self.logIncludedTransactions := _camProtocol.getLogIncludedTransactions;
		
		if status &lt;&gt; CAM_IDLESTATUS then
			self.status := status;
		endif;
	endif;
	
	self.protocolLog 	:= _protocolLog;								// par 29601 July 2012
	realCamTaskHistory 	:= _camProtocol.taskHistoryByProtocolSeq[_camProtocol, self.processSeqNumber];
	
	if realCamTaskHistory = null then
		_camProtocol.protocolDesc.createNextCamTaskHistory(self, _camProtocol, self.processSeqNumber);	//19 June 2012	cnwrs1		Par 29821 - CAMS single transaction per file
	else
		app.cmsBeginLoad(loadState);
		proxyCamTaskHistory := realCamTaskHistory.pxyCreateUpdateProxy;
		
		proxyCamTaskHistory.setRunDateTime(self.runDateTime); 
		if self.isAdhoc or
		  // self.isRestart or
		   self.status = CAM_EXTRACTSTATUS then	//30 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
			self.setTaskHistory(proxyCamTaskHistory, _camProtocol);
		endif;
		//jlier1 TFS 59815 29/8/23
		app.myTrxUA.trxUpdateCamTaskHistory(proxyCamTaskHistory, app.myPassport);
		
		app.cmsEndLoad(loadState);
	endif;
	
	realCamTaskHistory 	:= _camProtocol.taskHistoryByProtocolSeq [_camProtocol, self.processSeqNumber];
	
	if realCamTaskHistory &lt;&gt; null then	//28 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
		app.writeLog(_camProtocol.code[1:15].String &amp; " " &amp; realCamTaskHistory.fileName &amp; " " &amp; app.getErrorString2(ProcessPeriod, self.startDateTime.String, self.endDateTime.String), LogINFO);	//27 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
	endif;
epilog
	delete proxyCamTaskHistory;
end;
</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <Parameter name="_startDateTime" type="TimeStamp"/>
        <Parameter name="_endDateTime" type="TimeStamp"/>
        <Parameter name="_logExcludedTransactions" type="Boolean"/>
        <Parameter name="_protocolLog" type="File"/>
        <Parameter name="_dailySeqNumber" type="Integer"/>
        <Parameter name="_processSeqNumber" type="Integer"/>
        <Parameter name="_restartStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setHistoryStatus" id="818c5816-847b-4c61-bed9-5124fab213e2">
        <updating/>
        <source>setHistoryStatus(_camProtocol : CM_CamProtocol; _seqNumber : Integer) updating;
//
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask - from CM_CamTask
//
vars

begin
	// dont load error status to task history.
	// it needs to know the state it was in when the error occured.
	if status &lt;&gt; CAM_ERRORSTATUS and
	   _camProtocol.taskHistoryByProtocolSeq[_camProtocol, _seqNumber] &lt;&gt; null then
		_camProtocol.taskHistoryByProtocolSeq[_camProtocol, _seqNumber].setStatus(status);
	endif;
end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_seqNumber" type="Integer"/>
    </JadeMethod>
