    <JadeMethod name="includeObject" id="0bf25eb1-ba71-47de-822e-87fe08ad50bd">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 April 2023 navhl20	ChangeRequest 57712:[54552] EUP - Delivery Dispatch – Adding Work Point Types
*/

vars

begin
	if self.includeNotAvailableEntries then
		return true;
	else
		return not _obj.CM_WorkPointType.notAvailableForEntry;
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initShtMultiSelect" id="4b0b5bb4-bc1c-4c0d-ac19-c59c5098b530">
        <source>initShtMultiSelect();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 April 2023	navhl20	ChangeRequest 57712:[54552] EUP - Delivery Dispatch – Adding Work Point Types	

*/

vars
	theForm	: SOP_TableMaintForm;
begin
	inheritMethod();
	theForm := self.myForm;	
	
	theForm.mulSelect1.setVisibleButtons(false,true,true);
	self.setupMultiSelect1("Work Points",self.myForm.myTerminal.allWorkPointsByCode,SOP_TableMaintForm::displayEntryWorkPoints.name);	
	
	theForm.mulSelect1.multiSelect					:= ListBox.MultiSelect_Extended;
	theForm.mulSelect1.myAvailableListBox.sorted 	:= false;
	theForm.mulSelect1.mySelectedListBox.sorted 	:= false;
epilog

end;</source>
    </JadeMethod>
