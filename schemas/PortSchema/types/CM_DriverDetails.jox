    <JadeMethod name="isDriverOK" id="167ad6b2-3990-492a-8dd0-a75a4b77f97a">
        <source>isDriverOK() : String;
// ---------------------------------------------------------------------------
// Created:     09 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.status = CM_DriverDetails.Status_Allowed then
		return null;
	endif;
	
	if self.status = CM_DriverDetails.Status_Banned then
		return CM_DriverDetails.Status_Banned_String;
	endif;
	
	if self.status = CM_DriverDetails.Status_Suspended then
		return CM_DriverDetails.Status_Suspended_String;
	endif;
	
	return "UNKNOWN";
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isVehicleOnDriversList" id="72e50cf6-9560-43d0-adeb-e07d1b406765">
        <source>isVehicleOnDriversList(_vehicle : CM_Vehicle) : Boolean;

/*
Date		Who		Reason
20 April 2010	cnwas3	par 23865
*/

vars	
	v : CM_Vehicle;
begin
	if self.allVehicleMachines.isEmpty() then
		return true; //driver's vehicle list is blank,therefore don't worry about gating in vehicles that are not on his list
	endif;
	
	foreach v in self.allVehicleMachines where v.regNumber = _vehicle.regNumber do
		return true;
	endforeach;

	return false;
epilog

end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="4e46afcb-f07e-4372-90b5-bfce1d3593b2">
        <source>pxyCreateUpdateProxy(): SelfType;

// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxyDriver	 :CM_DriverDetails;
	completedOK		: Boolean;
	
begin

	proxyDriver := inheritMethod();

	self.allCarriers.copy(proxyDriver.allCarriers);
	self.allVehicleMachines.copy(proxyDriver.allVehicleMachines);	
	proxyDriver.myTerminal	:= self.myTerminal;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyDriver;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyDriver;
	endif;	
end;
</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
