    <JadeMethod name="createLC" id="41e65912-c970-49fb-8c69-8e5b2959b6f3">
        <updating/>
        <source>createLC() updating;
//AJA 3/7/00: Use same code as for block stack. Used to be external function that no longer
//pointed to dll entry point since CM_BlockStack::createLC was rewritten in Jade

// 16/02/2011	cnwcs5	Fix transient leak.  LC proxy was not being deleted - picked up in unti test
vars
 	aLCProxy, aLC : CM_BlockController;
begin

	exclusiveLock(self);
	if self.allLocationsControllers.size &gt; 1 then
	  	//A controller already exists! Can only be 1!!!!
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_CURR_BLOCK_CONT, null, null);

	elseif self.allLocationsControllers.size = 0 then
		//	aLC.myTerminalArea := self;
		//aLC.setForCreate(self, (self.type = TA_TYPE_REPAIR or self.type = TA_TYPE_PTI));
		create aLCProxy transient;
		create aLC;
		aLCProxy.setProxy(self);
		aLC.setForCreate(aLCProxy, self);
	endif;
epilog
	// no need to check if null as interpreter does this for you
	delete aLCProxy;
end;</source>
    </JadeMethod>
    <JadeMethod name="findLocation" id="45b47945-ae72-4c19-ba08-552a571fd7ad">
        <source>findLocation(_strs: StringArray; _noException : Boolean; _foundLC: CM_LocationsController io; _foundHeight: Integer io);
/*
 ------------------------------------------------------------------------
Created:			06 July 2001 by cnwdwq1
Purpose:			!     
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
----------			--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	//20 Feb 2014	NDL	Par 33550
	//inheritMethod(_strs, _noException, _foundLC, _foundHeight);
	_foundHeight := NULLINDEX;	//20 Feb 2014	NDL	Par 33550
	_foundLC := self.myLocationsController;

end;</source>
        <Parameter name="_strs" type="StringArray"/>
        <Parameter name="_noException" type="Boolean"/>
        <Parameter name="_foundLC" type="CM_LocationsController" usage="io"/>
        <Parameter name="_foundHeight" type="Integer" usage="io"/>
    </JadeMethod>
