    <JadeMethod name="create" id="719a5da6-9a5f-4565-a266-72711f101256">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     17 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.name := SOP_TableMaintForm.Table_User;
	self.permissionView	 := PmCmpUserTableView;
	self.permissionMaint := PmCmpUserTableMaint;
	self.myDataClass := CM_User;
	self.filterStatus := -1;	// 05/01/2006 cnwvu1 for searcher
	
