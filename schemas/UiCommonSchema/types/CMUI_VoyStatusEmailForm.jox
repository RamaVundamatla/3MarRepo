    <JadeMethod name="create" id="be07a569-fe99-444b-807f-681acae172d8">
        <updating/>
        <source>create() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
//
vars

begin
	self.permissionView  := PmAdmVSEmailDefaultView;
	self.permissionMaint := PmAdmVSEmailDefaultMaint;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateEmailDefaults" id="3ec2e82e-fa86-4926-a526-fe0cd772c05a">
        <source>doUpdateEmailDefaults(): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
//
vars
	sa : StringArray;
	returnValue : Boolean;
	emailTempl : CMIF_EmailTemplateController;
	
begin
	create sa transient;
	self.mulSelectFields.getSelectedDisplayEntries(sa);	
	
	self.myEmailDefaultStatus.setProxyStatusEmail(	self.txtSubject.text,
													self.txtMessage.text,
													sa,
													self.myEmailDefaultStatus.enabled,
													self.myEmailDefaultStatus.copyTo,
													self.chkCargoOper.value,	//_sendToOpCargo : Boolean;	//24 Apr 2018	NDL	TFS 38198
													self.chkVoyageOper.value,	//_sendToOpVoy : Boolean	//24 Apr 2018	NDL	TFS 38198
													self.chkCargoOperReqs.value	//_sendToOpCargoReqs : Boolean	//15 Oct 2018	NDL TFS 41387
													);
	
	emailTempl := self.myEmailController;
	
	//these are the only email sources we can trust 100% - what they see is what they get
	emailTempl.freeTxtToAddesses := self.txtToAddress.text.trimBlanks;
	emailTempl.freeTxtCcAddesses := self.txtCcAddress.text.trimBlanks;
	emailTempl.freeTxtBccAddesses := self.txtBccAddress.text.trimBlanks;
	
	emailTempl.setSendtoOperatorCargo( self.chkCargoOper.value );	//24 Apr 2018	NDL	TFS 38198
	emailTempl.setSendtoOperatorVoyage( self.chkVoyageOper.value );	//24 Apr 2018	NDL	TFS 38198
	emailTempl.setSendToOperatorCargoReqs( self.chkCargoOperReqs.value );	//16 Oct 2018	NDL	TFS 41387
	
	return true;
	
epilog
	delete sa;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForVoyageStatus" id="bee60a5f-b8c5-477e-a9a2-7298a201c5f8">
        <updating/>
        <source>setupForVoyageStatus(_emailDefault: CM_VoyStatusDefaultEmail; _limitedUpdate: Boolean; _sending : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
// 19/03/2018	jlgdap1		TFS 37540 PEl1 Voyage Statuses Pelindo 1
//
vars

begin
	if _emailDefault &lt;&gt; null then
		self.myEmailDefaultStatus := _emailDefault;
		self.myEmailController := self.myEmailDefaultStatus.myEmailController;
		
		if self.myEmailController = null then
			//create self.myEmailController transient;
			create self.myEmailController as CMIF_EmailTemplateVController transient;	//24 Apr 2018	NDL	TFS 38198
			self.myEmailDefaultStatus.setEmailController(self.myEmailController);
			self.myEmailDefaultStatus.setEmailControllerAddresses(self.myEmailController);
		endif;
		self.txtToAddress.text := self.myEmailController.allToAddresses.getAddresses();
		self.txtCcAddress.text := self.myEmailController.allCcAddresses.getAddresses();
		self.txtBccAddress.text := self.myEmailController.allBccAddresses.getAddresses();
		self.txtSubject.text := self.myEmailDefaultStatus.subjectLine;
		self.txtMessage.text := self.myEmailDefaultStatus.message;
		self.chkCargoOper.value := self.myEmailDefaultStatus.sendtoOperatorCargo;	//24 Apr 2018	NDL	TFS 38198
		self.chkVoyageOper.value := self.myEmailDefaultStatus.sendtoOperatorVoyage;	//24 Apr 2018	NDL	TFS 38198
		self.chkCargoOperReqs.value := self.myEmailDefaultStatus.sendToOperatorCargoReqs;	//15 Oct 2018	NDL	TFS 41387
		
	else
		self.myEmailDefaultStatus := null;
	endif;
	
	if _sending then
		self.btnOk.caption := "Send";
	endif;
	
	if _limitedUpdate then
		//can only change the subject and message
		self.txtBccAddress.enabled := false;
		self.txtCcAddress.enabled := false;
		self.txtToAddress.enabled := false;
		self.btnBccAddress.enabled := false;
		self.btnCcAddress.enabled := false;
		self.btnToAddress.enabled := false;
		self.chkCartersNote.enabled := false;
		self.chkSave2Terminal.enabled := false;
		self.shtFields.enabled := false;
	endif;

epilog

end;</source>
        <Parameter name="_emailDefault" type="CM_VoyStatusDefaultEmail"/>
        <Parameter name="_limitedUpdate" type="Boolean"/>
        <Parameter name="_sending" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="2a17ea9a-6a74-4eaa-aae1-f0813e93b896">
        <updating/>
        <source>setupForm() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
//
vars

	offSet : Integer;

begin
	self.modalDialogResize();
	self.resetFirstChangeFlag();
	
	if self.isBaseFormModal then
		self.handleMenusForModalDisplay();
	endif;
	
	self.setCaption(self.caption);
	
	self.modalResult := IDCANCEL;
	self.shtFields.enabled := true;
	self.mulSelectFields.formDisplayEntryMethodName := 'displayEntryEmailFields';
	self.mulSelectFields.availableHeading := 'Fields available';
	self.mulSelectFields.selectedHeading  := 'Fields selected';
	self.mulSelectFields.userInputEnabled := true;
	
	self.mulSelectFields.displayOrderBtns(true, true);
	self.mulSelectFields.multiSelect := ListBox.MultiSelect_Extended;
	self.mulSelectFields.setSorted(false);
	
	self.myAssistant.multiSelectEntityFields(self.mulSelectFields, self.myEmailDefaultStatus.entTableName, self.myEmailDefaultStatus.allIncludedFields);

	self.btnOk.default := false;
 	self.chkCartersNote.visible := false;
	self.chkSave2Terminal.visible := false;
	
	//24 Apr 2018	NDL	TFS 38198
	// do the big shuffle to squeeze in some extra fields.
	offSet := 65;
	self.height := self.height + offSet + 7;
	self.fldMain.height := self.fldMain.height + offSet;
	self.frmEmail.height := self.frmEmail.height + offSet;
	self.txtSubject.top := self.txtSubject.top + offSet;
	self.lblSubject.top := self.lblSubject.top + offSet;
	self.lblMessage.top := self.lblMessage.top + offSet;
	self.txtMessage.top := self.txtMessage.top + offSet;
	
	self.chkVoyageOper.top := self.txtBccAddress.top + self.txtBccAddress.height + 5 ;
	self.chkVoyageOper.left := self.txtSubject.left;
	self.chkVoyageOper.width := self.txtSubject.width;
	self.chkVoyageOper.visible := true;
	self.chkVoyageOper.enabled := true;
	
	self.chkCargoOper.top := self.chkVoyageOper.top + self.chkVoyageOper.height + 5 ;
	self.chkCargoOper.left := self.chkVoyageOper.left;
	self.chkCargoOper.width := self.chkVoyageOper.width;
	self.chkCargoOper.visible := true;
	self.chkCargoOper.enabled := true;
	
	//15 Oct 2018	NDL	TFS 41387
	self.chkCargoOperReqs.top := self.chkCargoOper.top + self.chkCargoOper.height + 5 ;
	self.chkCargoOperReqs.left := self.chkVoyageOper.left;
	self.chkCargoOperReqs.width := self.chkVoyageOper.width;
	self.chkCargoOperReqs.visible := true;
	self.chkCargoOperReqs.enabled := true;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showSelectRecipients" id="a3be1447-1a22-4c9c-b048-9f628c6b559f">
        <updating/>
        <source>showSelectRecipients(_mode: Integer) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
//
vars
	form : CMUI_RecipientSelector;
	
begin
	create form transient;
	
	self.setNavigatorHeading(form.caption);
	form.myEmailController := self.myEmailController;
	form.mode := _mode;
	form.myParentForm := self;
	form.centreWindow;
	form.showModal;

	if form.modalResult = IDOK then
		self.txtToAddress.text := self.myEmailController.allToAddresses.getAddresses();
		self.txtCcAddress.text := self.myEmailController.allCcAddresses.getAddresses();
		self.txtBccAddress.text := self.myEmailController.allBccAddresses.getAddresses();
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="0e25be5d-eb95-400e-a4b8-34053b9f525d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 October 2018 15:43:44.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022287, locale);
	chkCargoOper.translateBubbleHelp(Xlat_0022396, locale);
	chkCargoOper.translateCaption(Xlat_0022397, locale);
	chkCargoOperReqs.translateBubbleHelp(Xlat_0023045, locale);
	chkCargoOperReqs.translateCaption(Xlat_0023046, locale);
	chkVoyageOper.translateBubbleHelp(Xlat_0022398, locale);
	chkVoyageOper.translateCaption(Xlat_0022399, locale);
end;</source>
    </JadeMethod>
</GUIClass>
