    <JadeMethod name="asDateFromInaportnet" id="d1372b04-2c9b-41a0-bf24-8f606e3a2272">
        <source>asDateFromInaportnet() : Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2018	jlger1	Initial creation 38135

*/

vars
	date : Date;
	dd : String;
	mm : String;
	yy : String;
begin
	if self.length &lt;&gt; 10 then
		return null;
	endif;
	
	yy := self[1:4];
	mm := self[6:2];
	dd := self[9:2];
	
	if dd.isInteger and mm.isInteger and yy.isInteger then
		date.setDate( dd.Integer, mm.Integer, yy.Integer );
		if date.isValid then
			return date;
		endif;
	endif;
	
	return null;	
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="asDateFromWebInterface" id="a0523fec-77a5-49cb-b3ea-903fc7d6d29b">
        <source>asDateFromWebInterface():Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/10/2012	cnwndl1	Initial creation	Par 30622
22/11/2019	jlgdap1	TFS 47456 SNO Web portal Report Issue - date can come through as date/time
06/01/2020	jlgdap1	TFS 48195 JMT - Creating a voyage is saving the dates in to different format to 8.6.1.100

				The RIA may be running on a server that uses a different LOCALE than
				the client.  Convert to a known format at both ends.
				
				See Date::asStringForWebInterface

*/

vars

	date : Date;
	dd : String;
	mm : String;
	yy : String;

begin

	// The RIA is currently hard coded in the JavaScript side to use "dd/MM/yyyy", so that's what
	// we will look for regardless of the servers locale.
	
	if self.length &lt;&gt; 10 //then			// TFS 47456
	and self.length &lt;&gt; 16 then			// TFS 47456
		return null;
	endif;
	
	// TFS 47456 If the length of the date here is 16, it's come from the web portal as a timestamp and is already in dd/mm/yyyyy
	// If it's only length 10, then it's a (hidden) report parameter date and will be in whatever format the server locale is
	// TFS 48195 back these changes out, as in some circumstances we are getting a date that's already been truncated from a
	// timestamp to a date and time before being concatenated back to a timestamp again
	dd := self[1:2];
	mm := self[4:2];
	yy := self[7:4];
	
	if dd.isInteger and mm.isInteger and yy.isInteger then
		date.setDate( dd.Integer, mm.Integer, yy.Integer );
		if date.isValid then
			return date;
		endif;
	endif;
	
	return null;

epilog
	
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="asDateFromXMLFormat" id="47a07e01-1f12-4996-8088-d24588bd4d76">
        <source>asDateFromXMLFormat() : Date;
// ---------------------------------------------------------------------------
// Created:     04 April 2006 by cnwrs2
//
// Purpose:     Any changes may need to be refelected in
//					Date::asXMLFormat()
// ---------------------------------------------------------------------------
vars
	d	: Date;
begin
	if self.length &lt;&gt; 8 then
		return null;
	endif;
	if (not self.isInteger) then
		return null;
	endif;
		
	d.setDate(self[7:2].Integer, self[5:2].Integer, self[1:4].Integer);
	
	return d;

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="asDateJMT" id="49a11c67-e5ff-4fb8-93d6-22a7641467bf">
        <source>asDateJMT(): Date;
//--------------------------------------------------------------
//Created: November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	dateResult	: Date;

begin

	// now that shortFormatJMT is taking note of the locale we
	// should be able to do the following
	
	if dateResult.parseForCurrentLocale(self) then
		return dateResult;
	endif;
	return null;

/*
	dateResult := self.Date;
	if dateResult.isValid then
		return dateResult;
	endif;
	if (not self.isInteger) then
		return null;
	endif;

	if self.length = 10 then
		// Date.shortFormatJMT() dd/mm/yyyy
		dateResult.setDate(self[1:2].Integer, self[4:2].Integer, self[7:4].Integer);	
	elseif self.length = 8 then
		dateResult.setDate(self[1:2].Integer, self[3:2].Integer, self[5:4].Integer);
	elseif self.length = 6 then
		dateResult.setDate(self[1:2].Integer, self[3:2].Integer, self[5:2].Integer);
	endif;
	
	if dateResult.isValid then
		return dateResult;
	else
		return null;
	endif;
*/
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="asDecimalFromCurrencyString" id="e897c197-155b-4a4b-b737-2ac0a98ac9fc">
        <source>asDecimalFromCurrencyString():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 February 2013	cnwndl1	Initial creation	Par 30901

*/

constants
	
	JMTDecimalSeperator = ".";
	
vars

	decimalSeperator : String;
	isNegative : Boolean;
	char : String;
	pos : Integer;
	tmpStr	: String;
	workStr	: String;
	
begin

	decimalSeperator	:=	app.getMyLocaleInfoJMT().numericInfo.decimalSeparator;
	
	tmpStr := self;
	foreach pos in 1 to tmpStr.length do
		char := tmpStr[pos];
		if char = "-" then
			isNegative := true;
			continue;
		endif;
		if char = decimalSeperator or char = JMTDecimalSeperator or char.Character.isNumeric then
			workStr := workStr &amp; char;
		endif;
	endforeach;
	
	if workStr = null then
		return 0.0;
	endif;
	
	if decimalSeperator &lt;&gt; JMTDecimalSeperator then
		if workStr.pos( decimalSeperator, 1) &gt; 0 then
			workStr.replaceChar(decimalSeperator.Character, JMTDecimalSeperator);
		endif;
	endif;
	
	if isNegative then
		return ( workStr.Decimal * -1 );
	endif;
	
	return workStr.Decimal;
	
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="asDecimalFromWebInterface" id="f534b324-fdf5-48b2-b8d3-01aa4007eda6">
