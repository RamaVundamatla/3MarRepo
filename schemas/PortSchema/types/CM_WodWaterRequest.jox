    <JadeMethod name="pxyCreateUpdateProxy" id="97fb812a-bd2e-4a91-a3fa-c6011612894d">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2018	jlgndl1	Initial creation	TFS 38560

*/

vars

	pxy : SelfType;
	completedOK : Boolean;

begin

	pxy := inheritMethod();
	
	pxy.myHMSResource := self.myHMSResource;
	pxy.myHMSResourceType := self.myHMSResourceType;
	
	completedOK := true;
	return pxy;

epilog

	if not completedOK then
		delete pxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="3364f5d8-7b66-47c5-8867-0b9e085e4e67">
        <updating/>
        <source>setForUpdate( _pxyWoDDtl: CM_WodWaterRequest ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2018	jlgndl1	Initial creation	TFS 38560

*/

vars

begin

	inheritMethod(_pxyWoDDtl);
	
	self.fromDateTime := _pxyWoDDtl.fromDateTime;
	self.toDateTime := _pxyWoDDtl.toDateTime;
	self.unitsUsed := _pxyWoDDtl.unitsUsed;
	self.transferType := _pxyWoDDtl.transferType; // TFS 39718
	
	self.myHMSResource := _pxyWoDDtl.myHMSResource;
	self.myHMSResourceType := _pxyWoDDtl.myHMSResourceType;

epilog

end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WodWaterRequest"/>
    </JadeMethod>
    <JadeMethod name="setProxyWodWaterRequest" id="93649278-928c-41de-ad6d-4911fe7456e5">
        <updating/>
        <source>setProxyWodWaterRequest(	_fromDateTime : TimeStamp;
							_toDateTime : TimeStamp;
							_unitsUsed : Real;
							_transferType : Integer;
							_myHMSResource : HMS_Resource;
							_myHMSResourceType : HMS_ResourceType
							) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2018	jlgndl1	Initial creation	TFS 38560

*/

vars

begin

	self.fromDateTime := _fromDateTime;
	self.toDateTime := _toDateTime;
	self.unitsUsed := _unitsUsed;
	self.transferType := _transferType;
	
	self.myHMSResource := _myHMSResource;
	self.myHMSResourceType := _myHMSResourceType;
	
epilog

end;</source>
        <Parameter name="_fromDateTime" type="TimeStamp"/>
        <Parameter name="_toDateTime" type="TimeStamp"/>
        <Parameter name="_unitsUsed" type="Real"/>
        <Parameter name="_transferType" type="Integer"/>
        <Parameter name="_myHMSResource" type="HMS_Resource"/>
        <Parameter name="_myHMSResourceType" type="HMS_ResourceType"/>
    </JadeMethod>
    <JadeMethod name="setRequiredByDT" id="67825aff-9138-40a8-95a4-61f9d17f8149">
        <updating/>
        <source>setRequiredByDT(_dateTime: TimeStamp) updating;

/*

Purpose:		TFS 41084 SAT29SEP18 PEL1 ON CALL	

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2018	jlgab1	Initial creation

*/

vars
	span : TimeStampInterval;
begin
	inheritMethod(_dateTime);

	span := self.toDateTime - self.fromDateTime;
	self.fromDateTime := _dateTime;
	if span.asMinutes &gt; 0 then
		self.toDateTime := _dateTime + span;
	endif;
epilog

end;</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
    </JadeMethod>
