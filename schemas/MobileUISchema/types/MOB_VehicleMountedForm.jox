    <JadeMethod name="txtSearch_gotFocus" id="801d5440-1299-4113-b411-52f32d575728">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtSearch_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 April 2010	cnwer1	Initial creation

*/

vars

begin
	if textbox.text = app.getErrorString(Search) then
		textbox.foreColor:=app.myVMAgent.getMyScreenMode().screenForeColour;
		textbox.text:=null;
	endif;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtSearch_keyPress" id="8d90a903-86b3-4d8d-a28d-5a51f4b9c69b">
        <controlMethod name="TextBox::keyPress"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtSearch_keyPress(textbox: TextBox input; keyCharCode: Integer io) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 June 2010	cnwer1	Initial creation

*/

vars

begin
	if keyCharCode = J_key_Enter then
		self.btnSearch.click(self.btnSearch);
	endif;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="keyCharCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="txtSearch_lostFocus" id="c6fc647e-c2d5-40e3-97d3-4511b3d0918b">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtSearch_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 April 2010	cnwer1	Initial creation

*/

vars

begin
	if textbox.text = null then
		textbox.foreColor:=textbox.getSystemColor(Window.Color_3DShadow);
		textbox.text:=app.getErrorString(Search);	//cnwmc5 - par 30005
	endif;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateCaption" id="7b268e74-fbe3-465e-a239-438e3f298564">
        <updating/>
        <source>updateCaption() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2010	cnwjk3	Initial creation

*/

vars
	caption : String;
begin
	caption	:= self.myMachine.machineTypeString &amp; " " &amp; self.myMachine.id.asStringJMT &amp; " " &amp; app.myVMAgent.myRTQueue.id;
	
	if self.btnGraphic.visible then
		caption := caption &amp; "; " &amp; self.myDrawingController.getDrawModeDescription();
		
		if self.myDrawingController.isLandscape then
			caption := caption &amp; "; Landscape";	
		else
			caption := caption &amp; "; Portrait";		
		endif;
			
		if self.myDrawingController.flipH then
			caption := caption &amp; "; Flipped Horizontally";
		endif;
		if self.myDrawingController.flipV then
			caption := caption &amp; "; Flipped Vertically";
		endif;
			
		caption := caption &amp; "; Scale: " &amp; self.myDrawingController.scaleFactor.String;
	endif;
	self.caption := caption;
	self.lblCaption.caption:=caption;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
