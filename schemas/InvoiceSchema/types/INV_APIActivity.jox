    <JadeMethod name="load" id="bc19143a-df7b-402e-840d-f323c20e597f">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 December 2023	navra1	Initial creation for TFS 54090 CR 61417 - Task 61418 &amp; 61420  - 6th Dec 2023

*/

vars

begin	
	self.width := 1100;
	self.height := 607;
	self.left := 279;
	self.top := 18;
	
	self.txtInvoiceNumberValue.text := "";
	self.txtAttNumValue.text := "";
	self.txtPartNumValue.text := "";
	self.txtUniqueNumberValue.text := "";
	
	self.txtSendDTValue.text := "";
	self.txtSendResponseCodeValue.text := "";
	self.txtSendRespStrValue.text := "";
	
	self.txtStatusStrValue.text := "";
	self.txtResponseDTValue.text := "";
	self.txtProcessResponseValue.text := "";
	self.txtProcRespStrValue.text := "";
	
	///
	self.txtInvoiceNumberValue.readOnly := true;
	self.txtAttNumValue.readOnly := true;
	self.txtPartNumValue.readOnly := true;
	self.txtUniqueNumberValue.readOnly := true;
	
	self.txtSendDTValue.readOnly := true;
	self.txtSendResponseCodeValue.readOnly := true;
	self.txtSendRespStrValue.readOnly := true;
	
	self.txtStatusStrValue.readOnly := true;
	self.txtResponseDTValue.readOnly := true;
	self.txtProcessResponseValue.readOnly := true;
	self.txtProcRespStrValue.readOnly := true;

	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="lstEwsChildren_click" id="1e9aa8bb-91cc-47bb-bbde-771c43b7881b">
        <controlMethod name="CMUI_ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstEwsChildren_click(listbox: ListBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2023	navra1	Initial creation for TFS 54090 CR 61417 - Task 61418 &amp; 61420  - 6th Dec 2023

*/
vars
	selectedChild	: CM_EWSActivityInvoiceAPIParts;
begin
	
	selectedChild	:=	listbox.listObject.CM_EWSActivityInvoiceAPIParts;	
	
	self.txtInvoiceNumberValue.text := selectedChild.myEWSInvoiceMessageParent.myInvoice.externalNumber.String;
	self.txtAttNumValue.text := selectedChild.myEWSInvoiceMessageParent.attemptNumber.String;
	self.txtPartNumValue.text := selectedChild.partNumber.String;
	self.txtUniqueNumberValue.text := selectedChild.partUniqueRefNumber;	
	
	self.txtSendDTValue.text := selectedChild.sendDT.asStringJMT();
	self.txtSendResponseCodeValue.text := selectedChild.partSendResponse.String;
	self.txtSendRespStrValue.text := selectedChild.partSendResponseStr;	
	
	self.txtStatusStrValue.text := selectedChild.statusStr;	
	
	if selectedChild.responseDT.asStringJMT() = "" then
		self.txtResponseDTValue.text :="WAITING FOR RESPONSE..";
		self.txtResponseDTValue.backColor := LightGray;
	else
		self.txtResponseDTValue.text := selectedChild.responseDT.asStringJMT();
	endif;
	
	//the partProcessResponse is initialized to 0 so it wont be "", so check partProcessResponseStr instead
	//if selectedChild.partProcessResponse.String = "" then
	if selectedChild.partProcessResponseStr = "" then
		self.txtProcessResponseValue.text :="WAITING FOR RESPONSE..";
		self.txtProcessResponseValue.backColor := LightGray;
	else
		self.txtProcessResponseValue.text := selectedChild.partProcessResponse.String;
	endif;
	
	if selectedChild.partProcessResponseStr = "" then
		self.txtProcRespStrValue.text :="WAITING FOR RESPONSE..";
		self.txtProcRespStrValue.backColor := LightGray;	
	else
		self.txtProcRespStrValue.text := selectedChild.partProcessResponseStr;
	endif;
	
	//self.txtResponseDTValue.text := selectedChild.responseDT.asStringJMT();
	//self.txtProcessResponseValue.text := selectedChild.partProcessResponse.String;
	//self.txtProcessRespStrValue.text := selectedChild.partProcessResponseStr;	

epilog

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstEwsChildren_dblClick" id="4088f9a4-c4f4-4c9f-93fc-cb7d55a09b31">
        <controlMethod name="CMUI_ListBox::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstEwsChildren_dblClick(listbox: ListBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2023	navra1	Initial creation for TFS 54090 CR 61417 - Task 61418 &amp; 61420  - 6th Dec 2023

*/

vars
	messageLogForm 	: CMUI_MessageLogForm;
	selectedChild	: CM_EWSActivityInvoiceAPIParts;
begin
	
	selectedChild	:=	listbox.listObject.CM_EWSActivityInvoiceAPIParts;
	
	create messageLogForm transient;
	messageLogForm.setMyObject(selectedChild);
	
	if selectedChild.statusStr = CM_EWSActivityInvoiceAPIParts.INV_API_PART_STAT_SENT then
		messageLogForm.backColor := Cn_Orange;
	elseif selectedChild.statusStr = CM_EWSActivityInvoiceAPIParts.INV_API_PART_STAT_ERROR then
		messageLogForm.backColor := Red;
	elseif selectedChild.statusStr = CM_EWSActivityInvoiceAPIParts.INV_API_PART_STAT_SUCCESS then
		messageLogForm.backColor := Green;		
	endif;
	
	messageLogForm.show;	
	
epilog
	
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstEwsParent_click" id="81bcaa69-b83d-49a8-b595-5dcd70dded01">
        <controlMethod name="CMUI_ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstEwsParent_click(listbox: ListBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2023	navra1	Initial creation for TFS 54090 CR 61417 - Task 61418 &amp; 61420  - 6th Dec 2023

*/
vars
	selectedParent : CM_EWSActivityInvoiceAPI;
	ewsChild  : CM_EWSActivityInvoiceAPIParts;
	childDesc : String;
	listPointer : Integer;
	childrenListBox : CMUI_ListBox;
begin
	app.mousePointer	:=	Busy;
	
	if listbox.listIndex = CNEC_NULL_INDEX then
		return;
	endif;
	
	
	childrenListBox := self.lstEwsChildren;		
	childrenListBox.clear();
	
	selectedParent	:=	listbox.listObject.CM_EWSActivityInvoiceAPI;
	
	childrenListBox.clear();
	
	foreach ewsChild in selectedParent.allEWSMessageParts do
		childDesc := "Message Part Number:" &amp; ewsChild.partNumber.String;
			
		listPointer	:=	childrenListBox.addItem(childDesc);
		childrenListBox.itemObject[listPointer]	:=	ewsChild;
		childrenListBox.itemLevel[listPointer]	:=	1;
		
		if ewsChild.statusStr = CM_EWSActivityInvoiceAPIParts.INV_API_PART_STAT_ERROR or
			ewsChild.statusStr = CM_EWSActivityInvoiceAPIParts.INV_API_PART_STAT_SEND_ERROR then
			childrenListBox.itemBackColor[listPointer]:=Red;
		elseif ewsChild.statusStr = CM_EWSActivityInvoiceAPIParts.INV_API_PART_STAT_SENT then
			childrenListBox.itemBackColor[listPointer]:=Cn_Orange;
		elseif ewsChild.statusStr = CM_EWSActivityInvoiceAPIParts.INV_API_PART_STAT_SUCCESS then
			childrenListBox.itemBackColor[listPointer]:=Green;
		endif;
		
	endforeach;
	
	//clean out all text when only the parent is selected	
	self.txtInvoiceNumberValue.text := "";
	self.txtAttNumValue.text := "";
	self.txtPartNumValue.text := "";
	self.txtUniqueNumberValue.text := "";	
	self.txtSendDTValue.text := "";
	self.txtSendResponseCodeValue.text := "";
	self.txtSendRespStrValue.text := "";	
	self.txtStatusStrValue.text := "";	
	self.txtResponseDTValue.text := "";		
	self.txtProcessResponseValue.text := "";	
	self.txtProcRespStrValue.text := "";	
	
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="ac65eeb4-aa69-4e67-ba45-5d6f8c9395ce">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 12 March 2024 16:54:34.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026596, locale);
	lblAttNumName.translateCaption(Xlat_0026597, locale);
	lblAttemptHeading.translateCaption(Xlat_0026598, locale);
	lblInvoiceNumberName.translateCaption(Xlat_0026599, locale);
	lblMessagesHeading.translateCaption(Xlat_0026600, locale);
	lblPartNumName.translateCaption(Xlat_0026601, locale);
	lblProcessRespStrName.translateCaption(Xlat_0026602, locale);
	lblProcessResponseCode.translateCaption(Xlat_0026603, locale);
	lblResponseDT.translateCaption(Xlat_0026604, locale);
	lblSendDTName.translateCaption(Xlat_0026605, locale);
	lblSendResponseCodeName.translateCaption(Xlat_0026606, locale);
	lblSendResponseStrName.translateCaption(Xlat_0026607, locale);
	lblStatusStr.translateCaption(Xlat_0026608, locale);
	lblUniqueNum.translateCaption(Xlat_0026609, locale);
	lstEwsChildren.translateBubbleHelp(Xlat_0026627, locale);
	txtProcRespStrValue.translateBubbleHelp(Xlat_0026610, locale);
	txtSendRespStrValue.translateBubbleHelp(Xlat_0026611, locale);
	txtStatusStrValue.translateBubbleHelp(Xlat_0026612, locale);
	txtUniqueNumberValue.translateBubbleHelp(Xlat_0026628, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtProcRespStrValue_click" id="d3fe3b23-e1f7-4bfe-8068-04ce02ddec5e">
        <controlMethod name="TextBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtProcRespStrValue_click(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2023	navra1	Initial creation for TFS 54090 CR 61417 - Task 61418 &amp; 61420  - 7th Dec 2023
23 February 2024  	navra1  DEFECT 62578 - Make the API Activity screen more user friendly

*/

vars
	messageLogForm 	: CMUI_MessageLogForm;
	selectedChild	: CM_EWSActivityInvoiceAPIParts;
	hugeStringObject : CM_HugeString;
begin
	selectedChild	:=	self.lstEwsChildren.listObject.CM_EWSActivityInvoiceAPIParts;	
	
	if selectedChild = null then
		return;
	endif;
	
	create messageLogForm transient;
	create hugeStringObject transient;
	hugeStringObject.hugeString := txtProcRespStrValue.text;	
	messageLogForm.setCMHugeString("Response Message", hugeStringObject);
	
	messageLogForm.show;
	
epilog
	delete hugeStringObject;	
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
