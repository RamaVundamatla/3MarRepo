    <JadeMethod name="initializeForActivity" id="bb348747-f9af-4aca-8d84-830d9d7bdd48">
        <updating/>
        <source>initializeForActivity(_any: Any; _ewsOpsView: CM_EWSActivityOpsview) updating;
/*
Purpose:			

Date		Who		Reason
27 August 2021	navab1	TFS 51853
31 Aug 2021 navpw1 ChangeRequest 51853: MTN - Opsview Container - Gate
*/

vars
	machine		: CM_Machine;
	workPoint	: CM_WorkPoint;
begin
	inheritMethod(_any, _ewsOpsView);
	
	self.tableName		:= self.Xps_che;
	
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		self.gkey              := self.generateFullGKey(_any, "");
		return;
	endif;	
	
	//navsp1 06MAY2022 TFS#53569
	if _any	.isKindOf(CM_Machine) then
		machine	:= _any.CM_Machine;
		machine.initializeForActivity(_ewsOpsView,self);
	//navsp1 03Jun2022 TFS#53104
	elseif _any.isKindOf(CM_WorkPoint) then
		workPoint	:= _any.CM_WorkPoint;
		workPoint.initializeForActivity(_ewsOpsView,self);
	endif;
epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
    </JadeMethod>
</Class>
