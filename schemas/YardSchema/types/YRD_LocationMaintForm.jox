    <JadeMethod name="sptThumbEditShowLeftControll" id="ce4e0f72-f02f-4d43-a6dc-072f8c9eb7a6">
        <source>sptThumbEditShowLeftControll( _theArea : YRD_PadArea );
// ---------------------------------------------------------------------------
// Created:		07/09/2007	by cnwvu1
// ---------------------------------------------------------------------------
// 06/11/2012	cnwcs5	par 30475 - remove references to location restrictions
// 22/11/2016	cnwdap1	TFS 2844 STWR Hazardous Details Enhancements
vars

begin

	if _theArea = null then
		return;
	endif;
	
	self.sptThumbEdit.showRightControl(65, true);
		
	if _theArea.areaMode = YRD_PadArea.AreaMode_Height then
	
	elseif _theArea.areaMode = YRD_PadArea.AreaMode_Labour then
		self.sptThumbEdit.showLeftControl(40, true);
	
	elseif _theArea.areaMode = YRD_PadArea.AreaMode_SubBlock then
		self.sptThumbEdit.showLeftControl(35, true);
	
	elseif _theArea.areaMode = YRD_PadArea.AreaMode_TermSubArea then
		self.sptThumbEdit.showLeftControl(20, true);
	
	elseif _theArea.areaMode = YRD_PadArea.AreaMode_DoorDirection then	// par 30475
		self.sptThumbEdit.showLeftControl(25, true);
		
	elseif _theArea.areaMode = YRD_PadArea.AreaMode_Hazardous then			// TFS 2844
		self.sptThumbEdit.showLeftControl(35, true);						// TFS 2844
		
	else
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, 'Unknown area mode.', null, self );
	endif;
end;
</source>
        <Parameter name="_theArea" type="YRD_PadArea"/>
    </JadeMethod>
