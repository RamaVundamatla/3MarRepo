//nds TFS 2867 17/01/17 PKT - Bulk Process

vars
	allTIs : ObjectArray;
	
begin
	create allTIs transient;
	self.getAllSelectedTIs(allTIs,true);//nds TFS 2867 17/01/17 PKT - Bulk Process
	
	if allTIs.size &gt;  1 then
		self.myAssistant.showCargoEnquiryForTIs(self.myCurrentTrackedItem, allTIs, self.myMasterMenuAction, false);
	else
		self.myAssistant.showCargoEnquiryForm(self.myCurrentTrackedItem, self.myMasterMenuAction, true, false);
	endif;
	
delete
	allTIs;
end;</source>
