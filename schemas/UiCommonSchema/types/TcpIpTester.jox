    <JadeMethod name="doControllerCheckResponse" id="39545938-b172-4ec8-9793-a47164774de4">
        <source>doControllerCheckResponse();
// ---------------------------------------------------------------------------
// Created:     05 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  RESPONSE &gt;&gt;' &amp; self.myTcpipSendAgent.responseStr);
end;</source>
    </JadeMethod>
    <JadeMethod name="doControllerSend" id="74567774-748b-4f0e-a7e1-edc1f62620d9">
        <source>doControllerSend();
// ---------------------------------------------------------------------------
// Created:     05 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	tmpStr	: String;
	tmpDevice	: CM_RadioTelemetryDevice;
	nextId		: Integer;
	
begin
	self.myTcpipSendAgent.init(self.txtAddress.text, 
							   self.txtPort.text.Integer,
							   false, '&lt;/msg&gt;', 5000);

	tmpDevice := CM_Terminal.firstInstance.radioTelemetry.allRTDevices.first;
	if tmpDevice = null then
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  no RTDevice');
		return;
	endif;
	
	// need to keep lastMessageId as part of test data as may send
	nextId := tmpDevice.lastMessageId + 1;

tmpStr := '
&lt;msg&gt;
&lt;hdr&gt;
&lt;msgtype&gt;SclTruckRq&lt;/msgtype&gt; 
&lt;msgid&gt;' &amp; nextId.String &amp; '&lt;/msgid&gt; 
&lt;deviceid&gt;' &amp; tmpDevice.id &amp; '&lt;/deviceid&gt; 
&lt;userid&gt;CNWDVB1&lt;/userid&gt; 
&lt;pswd&gt;&lt;/pswd&gt; 
&lt;terminal&gt;POE&lt;/terminal&gt; 
&lt;version&gt;2&lt;/version&gt; 
&lt;time&gt;' &amp; app.actualTimeServer.formatAsYYYYMMDDHHmmSS &amp; '&lt;/time&gt; 
&lt;/hdr&gt;
&lt;bdy&gt;
&lt;batchrq&gt;
&lt;tibatch class="LOG" type="SCALE"&gt;
&lt;batchhdr&gt;DAVETEST014,CH,20031120114400,20031120115000&lt;/batchhdr&gt; 
&lt;tidtls class="LOG" type="SCALE"&gt;
&lt;ti&gt;XXXVETESTLOG01,OK,34,36&lt;/ti&gt; 
&lt;ti&gt;XXXVETESTLOG02,OK,34,36&lt;/ti&gt; 
&lt;ti&gt;XXXVETESTLOG03,OK,34,36&lt;/ti&gt; 
&lt;ti&gt;XXXVETESTLOG04,OK,34,36&lt;/ti&gt; 
&lt;ti&gt;XXXVETESTLOG05,OK,34,36&lt;/ti&gt; 
&lt;ti&gt;XXXVETESTLOG06,OK,34,36&lt;/ti&gt; 
&lt;ti&gt;XXXVETESTLOG07,OK,34,36&lt;/ti&gt; 
&lt;ti&gt;XXXVETESTLOG08,OK,34,36&lt;/ti&gt; 
&lt;ti&gt;XXXVETESTLOG09,OK,34,36&lt;/ti&gt; 
&lt;ti&gt;XXXVETESTLOG10,OK,34,36&lt;/ti&gt; 
&lt;/tidtls&gt;
&lt;/tibatch&gt;
&lt;/batchrq&gt;
&lt;/bdy&gt;
&lt;/msg&gt;';
 // 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
//&lt;batchhdr&gt;GD123678901236478965,CHH,20040407135832,20040407135832&lt;/batchhdr&gt;
/*
&lt;ti&gt;TDX121,OK,14,18&lt;/ti&gt;
&lt;ti&gt;TDX122,OK,14,18&lt;/ti&gt;
&lt;ti&gt;TDX123,OK,14,18&lt;/ti&gt;
&lt;ti&gt;TDX124,OK,14,18&lt;/ti&gt;
&lt;ti&gt;TDX125,OK,14,18&lt;/ti&gt;
&lt;ti&gt;TDX126,OK,14,18&lt;/ti&gt;
&lt;ti&gt;TDX127,OK,14,18&lt;/ti&gt;
&lt;ti&gt;TDX128,OK,14,18&lt;/ti&gt;
&lt;ti&gt;TDX129,OK,14,18&lt;/ti&gt;
&lt;ti&gt;TDX130,OK,14,18&lt;/ti&gt;
*/
tmpStr := '
&lt;msg&gt;
&lt;hdr&gt;
&lt;msgtype&gt;SclTruckRq&lt;/msgtype&gt;
&lt;msgid&gt;13&lt;/msgid&gt;
&lt;deviceid&gt;14&lt;/deviceid&gt;
&lt;userid&gt;CNWRS2&lt;/userid&gt;
&lt;pswd&gt;&lt;/pswd&gt;
&lt;terminal&gt;POE&lt;/terminal&gt;
&lt;version&gt;2&lt;/version&gt;
&lt;time&gt;20040407135832&lt;/time&gt;
&lt;/hdr&gt;
&lt;bdy&gt;
&lt;batchrq&gt;
&lt;tibatch class="LOG" type="SCALE"&gt;
&lt;batchhdr&gt;GD123678901236478965,CHH,20040407135832,20040407135832&lt;/batchhdr&gt;
&lt;tidtls class="LOG" type="SCALE"&gt;
&lt;ti&gt;TDX121,OK,14,18&lt;/ti&gt;
&lt;ti&gt;TDX122,OK,14,18&lt;/ti&gt;
&lt;ti&gt;TDX123,OK,14,18&lt;/ti&gt;
&lt;ti&gt;TDX124,OK,14,18&lt;/ti&gt;
&lt;ti&gt;TDX125,OK,14,18&lt;/ti&gt;
&lt;ti&gt;TDX126,OK,14,18&lt;/ti&gt;
&lt;ti&gt;TDX127,OK,14,18&lt;/ti&gt;
&lt;ti&gt;TDX128,OK,14,18&lt;/ti&gt;
&lt;ti&gt;TDX129,OK,14,18&lt;/ti&gt;
&lt;ti&gt;TDX130,OK,14,18&lt;/ti&gt;
&lt;/tidtls&gt;
&lt;/tibatch&gt;
&lt;/batchrq&gt;
&lt;/bdy&gt;
&lt;/msg&gt;';


	self.myTcpipSendAgent.dataToSend := tmpStr;
//	self.myTcpipTestController.dataToSend := '&lt;XML&gt;&lt;/XML&gt;';

	if self.myTcpipSendAgent.doSend() then
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  message sent');
	else
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  message failed');
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doExit" id="e25b1a45-095b-48ac-8ba8-a063f7071ad7">
        <updating/>
        <source>doExit() updating;
// -----------------------------------------------------------------------------
// Created:		25 July 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	delete self.myConnection;
	delete self.myTcpipSendAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="ab3d34ef-99e9-41f3-b66e-0f4c1ed7978f">
        <updating/>
        <source>doFormLoad() updating,protected;
// -----------------------------------------------------------------------------
// Created:		25 July 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//10 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
// -----------------------------------------------------------------------------
begin
	self.centreWindow;
	if self.myConnection = null then 
		create myConnection;
	endif;
	if self.myTcpipSendAgent = null then
		create self.myTcpipSendAgent transient;
	endif;
	on ConnectionException do self.xhandlerConnection(exception) global;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTCPIPSend" id="614a4039-98c6-4ba0-b6a2-33e814d8936d">
        <source>doTCPIPSend();
// -----------------------------------------------------------------------------
// Created:		25 July 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars

	fileLength	: Integer;
	sendFile	: File;
	sendBlob1,
	sendBlob2,
	sendBlob3,
	sendBlob4	: Binary;
begin
	if self.myConnection.state &lt;&gt; TcpIpConnection.Connected then
		app.msgBox('Connection not open', 'Error', MsgBox_Stop_Icon);
		return;
	endif;
	
	if self.txtFileSend.text = '' then 
		app.msgBox('no file to send', 'Error', MsgBox_Stop_Icon);
		return;
	endif;		
	if self.txtFileReply.text = '' then 
		app.msgBox('no file to write reply to', 'Error', MsgBox_Stop_Icon);
		return;
	endif;		
	
	create sendFile transient;
	sendFile.kind := File.Kind_Binary;
	sendFile.openInput(self.txtFileSend.text);
	fileLength := sendFile.fileLength;
	
	sendBlob1 := sendFile.readBinary(sendFile.fileLength);
//	sendBlob2 := sendBlob1[1 : (sendBlob1.length / 3).Integer];
//	sendBlob3 := sendBlob1[sendBlob2.length + 1 : (sendBlob1.length / 3).Integer];
//	sendBlob4 := sendBlob1[(sendBlob2.length + sendBlob3.length) + 1 : end];
	
//	sendBlob2 := sendBlob1[1:1];
//	sendBlob3 := sendBlob1[2:1];
//	sendBlob4 := sendBlob1[(sendBlob2.length + sendBlob3.length) + 1 : end];		
//	sendBlob2 := sendBlob1[1 : sendBlob1.length -2];
//	sendBlob3 := sendBlob1[sendBlob1.length - 1: end];
//	write sendBlob2.String;
//	write ' ';
//	write ' ';
//	write sendBlob3.String;
				
	sendFile.close();
	
	self.myConnection.writeBinary(sendBlob1);
//	self.myConnection.writeBinary(sendBlob2);
//	self.myConnection.writeBinary(sendBlob3);
//	self.myConnection.writeBinary(sendBlob4);
	self.myConnection.readBinaryAsynch(BufferLength, self, 'readBinaryAsynchCB');
epilog
	delete sendFile;
end;</source>
    </JadeMethod>
    <JadeMethod name="load" id="147e33d5-6390-4037-97e5-53e4b8e92f3f">
