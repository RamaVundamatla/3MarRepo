    <JadeMethod name="setComboValues" id="47423751-de06-4ed1-a3a1-1aef142e4a44">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars
	hazard			: CM_HazardClass;
	hazardDict		: CM_HazardClassByCodeDict;
begin
	_combo.clear();
	hazardDict := app.myRoot.allHazardClasses;
	
	foreach hazard in hazardDict do
		_combo.itemObject[_combo.addItem(hazard.code &amp; Tab &amp; hazard.description)] := hazard;
	endforeach;

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="af67ee34-fe01-4c7c-b6e1-d49c987ca41d">
        <source>setListValues(table 					: Table input; 
			  queryCriteriaLineHolder	: CM_QueryCriteriaLineHolder; 
			  operator					: CM_QueryOperator; 
			  passport					: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:	
	
******* Changes
Date			Who						Reason
=================================================================================================
19 June 2015	cnwndl1		Par 36338	Initial creation	
22/08/2018		jlgka1		TFS 40200 	Add the Hazard Description in the Selection List display.
=================================================================================================*/

vars
	hazard			: CM_HazardClass;
	hazardDict		: CM_HazardClassByCodeDict;
	idx				: Integer;
	cnt				: Integer;
	selectionValue 	: Integer;
begin
	table.rows := table.fixedRows;
	
	if queryCriteriaLineHolder = null then
		return;
	endif;
	hazardDict := app.myRoot.allHazardClasses;
	foreach	hazard in hazardDict do
		selectionValue := 0;
		if operator &lt;&gt; null and operator.CM_QCollIncludesOneOf.allSelectionValues.includes(hazard) then
			selectionValue := 1;
		endif;
		// to check
		if idx &gt;= JadeTableRowLimit then		// PAR #16810
			app.msgBox('Maximum number of entries in table exceeded.  Only the first ' &amp; JadeTableRowLimit.String &amp; ' will be shown', 'Error', MsgBox_OK_Only);
			break;
		endif;

		idx := table.addItem(selectionValue.String &amp; Tab &amp; hazard.code &amp; Tab &amp; '(' &amp; hazard.description &amp; ')');
		table.accessRow(idx).itemObject := hazard;
		table.row := idx;
		table.change(table);
	endforeach;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="queryCriteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="operator" type="CM_QueryOperator"/>
        <Parameter name="passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="0c4a4455-da71-48fe-a438-d061116ca699">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	str : String;
	numRows,
	idx	 : Integer;
	hazCodeDict	: CM_HazardClassByCodeDict;
	hazCode	 : CM_HazardClass;
	
begin

	create hazCodeDict transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			hazCode := _tbl.accessRow(idx).itemObject.CM_HazardClass;
			hazCodeDict.add(hazCode);
		endif;
	endforeach;
	
	_op.setSearchValue(hazCodeDict);
	
epilog

	delete hazCodeDict;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="0068ae69-b15e-462f-b94d-32bb92ea54ce">
        <source>translateToDisplayValue(_value: Any): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19/06/2015	cnwndl1	Initial creation	Par 36338
14/12/2016	cnwdap1	TFS 2844 STWR Hazardous Details Enhancements
*/
vars
	haz : CM_Hazard;					// TFS 2844
	str : String;						// TFS 2844

begin
	if _value.isKindOf(CM_HazardClass) then
		if _value &lt;&gt; null then
			return _value.CM_HazardClass.code;
		else
			return null;
		endif;
		
	elseif _value.isKindOf(CM_HazardByCodeDict) then											// TFS 2844
		foreach haz in _value.CM_HazardByCodeDict do											// TFS 2844
			if str = null then																	// TFS 2844
				str := haz.CM_TIHazard.getTableDisplay(false, true);							// TFS 2844
			else																				// TFS 2844
				str := str &amp; SemiColon &amp; Space &amp; haz.CM_TIHazard.getTableDisplay(false, true);	// TFS 2844
			endif;																				// TFS 2844
		endforeach;																				// TFS 2844
		return str;																				// TFS 2844
	endif;
	
	return _value.String;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="e35cb46f-7e68-41b4-a77e-e9df30214f77">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars
	invalidObj 		: Boolean;
	object			: CM_HazardClass;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;

		if _value.isKindOf(CM_HazardClass) then
			object := _value.CM_HazardClass;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.code;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="472e86ce-081d-451a-83e0-4e21a4eab28c">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	objSet : ObjectSet;
	object : Object;
	hazard : CM_HazardClass;
	result : String;
	collStr, str : String;
	strArray : StringArray;
	coll : CM_HazardClassByCodeDict;

begin
	if _value.isKindOf(ObjectSet) then
		objSet := _value.ObjectSet;
		foreach object in objSet do
			hazard := object.CM_HazardClass;
			result := result &amp; hazard.getOidString &amp; CNEC_COMMA &amp; Space;
		endforeach;
		result := result[1:result.length-2];
		return result;
		
	elseif _value.isKindOf(String) then
		if _value.String.cnContains("|") then
			collStr := _value.String;
			create strArray transient;
			create coll transient;
			collStr.getTokensForDelimiter("|", strArray);
			foreach str in strArray do
				hazard := str.asOid.CM_HazardClass;
				if hazard &lt;&gt; null then
					coll.addNoDuplicates(hazard, false);
				endif;
			endforeach;
			return coll;
		endif;
		
		hazard := _value.String.asOid.CM_HazardClass;
		if hazard = null then
			hazard := app.myRoot.allHazardClasses[_value.String];
			if hazard &lt;&gt; null then
				return hazard.code;
			endif;
		endif;
	endif;
	
	return inheritMethod(_value, _sending);

epilog
	delete strArray;
end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
