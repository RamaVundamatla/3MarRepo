// ---------------------------------------------------------------------------
vars

begin
	self.remarks := _remarks;
epilog

end;</source>
        <Parameter name="_remarks" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateLocations" id="85d38591-a7f1-4862-bcaa-e1365f3dc00a">
        <updating/>
        <source>updateLocations(_locations :CM_LCSet)updating;
// ---------------------------------------------------------------------------
// Created:     07 March 2011 by cnwcs5 CCMS CPL 2027/PAR 27126
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/03/2019	jlgzm1		TFS43830 no details visible on Audit details form
// ---------------------------------------------------------------------------
vars
	lc		: CM_LocationsController;
	pos 	: Integer; //tfs43830
begin
	foreach lc in _locations do
		self.allLocations.addNoDuplicates (lc, false);
	endforeach;
	
	self.locationStr := self.getLocationsString (self.allLocations);
	
	//tfs43830
	//update exisitng audit text with new locations
	if self.auditText &lt;&gt; null and self.postAuditText &lt;&gt; null then
		//both pre/post audit text should be the same until first separator
		pos := self.postAuditText.pos(AuditStringSeparator, 1); 
		if pos &gt; 0 then
			self.auditText := self.locationStr &amp; self.auditText[pos:end];
			self.postAuditText := self.locationStr &amp; self.postAuditText[pos:end];
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_locations" type="CM_LCSet"/>
    </JadeMethod>
</Class>
