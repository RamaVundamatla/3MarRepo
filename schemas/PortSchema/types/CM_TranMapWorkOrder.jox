    <JadeMethod name="getMyTerminal" id="bb0adaf4-007b-4819-8a74-e9cf774ebd53">
        <source>getMyTerminal(): CM_Terminal;
/*
Purpose:		TFS 39237	
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
*/

vars
	bu : CM_Bank;
begin
	bu := self.getBank();
	
	if bu = null then
		return null;
	endif;
	
	return bu.getMyTerminal();

epilog

end;</source>
