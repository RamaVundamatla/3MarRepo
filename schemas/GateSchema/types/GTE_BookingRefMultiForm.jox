    <JadeMethod name="btnBookingRefDis_click" id="a830551d-0597-4e16-8753-22aa7c6621a5">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBookingRefDis_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 September 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars
	bookingRef : CM_BookingRef;
	
begin
	
	if self.myCurrentObject = null then
		return;
	endif;
	
	if CM_BookingRefItem.hasInstance(self.myCurrentObject) then
		bookingRef := self.myCurrentObject.CM_BookingRefItem.myBookingReference;
	elseif CM_BookingRef.hasInstance(self.myCurrentObject) then
		bookingRef := self.myCurrentObject.CM_BookingRef;
	endif;
	
	if bookingRef = null then
		return;
	endif;
	 
	self.doShowBookingDiscrepancy(bookingRef);
	
epilog

end;</source>
