<Class name="BGP_RelReqEstDateRolloverReq" id="edb1a80e-7362-4360-b868-bd9c1a3b7706">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Release Req - Est Req Date Rollover&lt;/display&gt;
&lt;displayShort&gt;Est Req Date Rollover&lt;/displayShort&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <JadeMethod name="action" id="694f4258-7069-48dd-9b17-75ca05c583cd">
        <updating/>
        <source>action(): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2010	cnwndl1	Initial creation	Par 26650
*/
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
vars

	errCode	: Integer;
	errTxt	: String;
	msg : String;
begin

	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	msg := "Release request 'Estimated Required date' rollover started for '" &amp; self.myTerminal.code &amp; "'.";
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	app.myTrxUA.trxRelReqEstDateRollover(self.myTerminal, app.myPassport);

epilog

	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	endif;
	
	inheritMethod();	
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="0e308c7a-e026-4de0-8e5f-595502d28877">
        <source>getDisplay(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2010	cnwndl1	Initial creation	Par 26650

*/

vars
	detail : String;
begin
	
	detail := inheritMethod() &amp; Tab &amp; 'Rollover of Est Required Date on Release Requests.';
	return detail;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
