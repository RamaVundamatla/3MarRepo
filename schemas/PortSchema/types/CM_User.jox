    <JadeMethod name="setStateData" id="190d5c4b-f7eb-4fd8-bb97-65dadae46b2c">
        <source>setStateData(pSubSystem : Integer; pKey : String; pValue : Any);
// ---------------------------------------------------------------------------
// Created:     21 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 10/09/2008	concms1		par 17903/ccms 1741 Welcome screen - interim solution
// ---------------------------------------------------------------------------
vars
	stateObj	: CM_StateObject;
	
begin

	if pSubSystem &lt; 1 then
		return;
	endif;
	
	if pSubSystem &lt;= self.allSubSystemStateObjects.size then
		stateObj := self.allSubSystemStateObjects[pSubSystem];
	endif;
	
	if stateObj = null then
		// create and add into array
		if self.isTransient then			// par 17903
			create stateObj transient;		// par 17903
		else								// par 17903
			create stateObj persistent;
		endif;								// par 17903
		
		self.allSubSystemStateObjects.atPut(pSubSystem, stateObj);
	endif;
	
	stateObj.setStateData(pKey, pValue, true);

end;</source>
        <Parameter name="pSubSystem" type="Integer"/>
        <Parameter name="pKey" type="String"/>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
