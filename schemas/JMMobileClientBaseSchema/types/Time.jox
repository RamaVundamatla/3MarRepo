<PrimType name="Time">
    <JadeMethod name="currentLocaleFormatJMT" id="22571791-b4bd-4f78-9709-2d8f5b4ea4c2">
        <source>currentLocaleFormatJMT() : String;
// -------------------------------------------
// Created 10 February 2005 by cnwdvb1
// -------------------------------------------
// if format changes then you may have to change primitiveType String.convertToTimeStamp() and String.convertToTime() as well
vars

begin

	return self.format('HH:mm');

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="mbAddHours" id="130bfb43-67f5-46f8-b557-d70358e5f370">
        <source>mbAddHours(_hours:Integer):Time;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of hours to the
//				receiver time.
//
// Parameters:	_hours (Integer) - The number of hours to add (or subtract).
//
// Returns:		The resulting time.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self + (((_hours * 60) * 60) * 1000);
end;</source>
        <Parameter name="_hours" type="Integer"/>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="mbAddMinutes" id="428b4929-b607-4f11-adfc-8929597f779b">
        <source>mbAddMinutes(_minutes:Integer):Time;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of minutes to the
//				receiver time.
//
// Parameters:	_minutes (Integer) - The number of minutes to add (or subtract).
//
// Returns:		The resulting time.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self + ((_minutes * 60) * 1000);
end;</source>
        <Parameter name="_minutes" type="Integer"/>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="mbAddSeconds" id="495cf8dd-b27e-4cc0-be6b-a447e5f407ae">
        <source>mbAddSeconds(_seconds:Integer):Time;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of seconds to the
//				receiver time.
//
// Parameters:	_seconds (Integer) - The number of seconds to add (or subtract).
//
// Returns:		The resulting time.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self + (_seconds * 1000);
end;</source>
        <Parameter name="_seconds" type="Integer"/>
        <ReturnType type="Time"/>
    </JadeMethod>
</PrimType>
