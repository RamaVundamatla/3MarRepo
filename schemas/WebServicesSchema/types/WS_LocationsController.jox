<Class name="WS_LocationsController" id="6a1d7601-23a0-4870-904c-4e9ff414c3b8">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>A single location within the system.</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="description" id="ee0600cb-3dbd-406e-b6aa-440280dd8416">
        <type name="String"/>
        <text>The name of the location.</text>
    </PrimAttribute>
    <PrimAttribute name="height" id="a236d426-3f50-4d7a-96e4-9ee8d6a197e4">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="id" id="defe6757-7e02-4300-97ac-feb75e7f458c">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myCargo" id="782b9293-36e4-4605-bb5f-a39250c557cb">
        <embedded/>
        <type name="WS_CargoSummary"/>
    </ImplicitInverseRef>
    <PrimAttribute name="terminalAreaId" id="d57c0c6f-9199-4bbe-84a9-31d5cdd0bf6c">
        <length>14</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="delete" id="ff88b69d-15e2-4368-9eff-cb5283ccdcb7">
        <updating/>
        <source>delete() updating;
/*****************************************************
