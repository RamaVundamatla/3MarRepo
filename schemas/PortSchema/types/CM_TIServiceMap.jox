    <JadeMethod name="doObjectVolatilityConversion" id="69490b7e-7fe7-4531-bfc3-859c29dbae64">
        <updating/>
        <source>doObjectVolatilityConversion(_converter: CM_ObjectVolatilityConverter input; _logIndent: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20 September 2019	jlgzm1	Initial creation TFS 7286 Additional stable collections required to improve performance

*/

vars
	pgMap	: CM_ProductGroupMap;

begin
	inheritMethod(_converter, _logIndent);
	
	_converter.doChangeVolatilityOfObject(self.allProductGroupMaps, _logIndent);
	
	foreach pgMap in self.allProductGroupMaps discreteLock do
		//_converter.logMessage("Processing collections for " &amp; pgMap.String, _logIndent);				navma1 14.01.2026
		pgMap.doObjectVolatilityConversion(_converter, _logIndent + 1);
		//_converter.logMessage("Finished processing collections for " &amp; pgMap.String, _logIndent);	    navma1 14.01.2026
	endforeach;
	

epilog

end;</source>
        <Parameter name="_converter" type="CM_ObjectVolatilityConverter" usage="input"/>
        <Parameter name="_logIndent" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllPaths" id="3f165763-1fb2-4acc-a5ee-48572eec7d06">
        <source>getAllPaths(_child : CM_FinancialObject; _paths : HugeStringArray input; _items : ObjectArray input);
// 32311 return the path text and tran map item for each tran map entry, other than the entered one in _child, at the same level
vars
	productGroupMap	: CM_ProductGroupMap;
begin
	if _child.isKindOf(CM_ProductGroupMap) then
		_paths.add(self.getPath());
		_items.add(self);
		return;
	endif;
	if _child.isKindOf(CM_TIServiceMap) then
		if _child &lt;&gt; self then
			_paths.add(self.getPath());
			_items.add(self);
		endif;
		return;
	endif;
	
	foreach productGroupMap in self.allProductGroupMaps do
		productGroupMap.getAllPaths(_child, _paths, _items);
	endforeach;
end;
</source>
        <Parameter name="_child" type="CM_FinancialObject"/>
        <Parameter name="_paths" type="HugeStringArray" usage="input"/>
        <Parameter name="_items" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllPaths2" id="5b29318d-bf49-41d1-b06a-4272b2036a72">
        <source>getAllPaths2(_child : CM_FinancialObject; _paths : HugeStringArray input; _items : ObjectArray input);
// 32311 return the path text and tran map item for each tran map entry, other than the entered one in _child, at the same level
vars
	productGroupMap	: CM_ProductGroupMap;
begin
	if _child.isKindOf(CM_ProductGroupMap) then
		_paths.add(self.getPath2());
		_items.add(self);
		return;
	endif;
	if _child.isKindOf(CM_TIServiceMap) then
		if _child &lt;&gt; self then
			_paths.add(self.getPath2());
			_items.add(self);
		endif;
		return;
	endif;
	
	foreach productGroupMap in self.allProductGroupMaps do
		productGroupMap.getAllPaths2(_child, _paths, _items);
	endforeach;
end;
</source>
        <Parameter name="_child" type="CM_FinancialObject"/>
        <Parameter name="_paths" type="HugeStringArray" usage="input"/>
        <Parameter name="_items" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="567caf6c-ce57-45d4-9c6d-005aa995c3a8">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 December 2016	cnwma1	Initial creation

*/

vars
	txt,
	tmpStr	: String;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
	tmpStr := self.getTranMapBreadCrumb;
	txt := txt &amp; 'Item Path' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;

	tmpStr := null;
	if self.getMyTerminal &lt;&gt; null then
		tmpStr := self.getMyTerminal.name;
		txt := txt &amp; app.getErrorString(Terminal) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.transactionMap.getBank &lt;&gt; null then
		tmpStr := self.transactionMap.getBank.mailingName;
		txt := txt &amp; app.getErrorString(CM_Business_Unit) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
