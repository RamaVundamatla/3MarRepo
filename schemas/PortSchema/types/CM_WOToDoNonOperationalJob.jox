<Class name="CM_WOToDoNonOperationalJob" id="e48583bc-7b3c-4f68-b3bb-86232326fce9">
    <superclass name="CM_WOToDoTaskJob"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="workorder"/>
    <ExplicitInverseRef name="allDebtors" id="a1ae0c7f-4eac-4817-9a3e-b977275d2ce0">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <type name="CM_DebtorSet"/>
        <access>readonly</access>
        <Inverse name="CM_Debtor::allWorkOrderJobs"/>
    </ExplicitInverseRef>
    <JadeMethod name="getDisplayStringForAttribute" id="c88c42c9-f3e6-4d62-a315-4753d763543a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2023 navhl20 ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS

*/

vars

begin
	if _attrName = ETRow_Debtor then
		return self.allDebtors.listString(Comma,CM_Debtor::code.name);
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWSOperator" id="5cc9a0c9-caeb-45ef-98f6-99e83ae9ed28">
        <source>getWSOperator(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Dec 2024	navhl20	MTN-33560 : EUP | 53813 - Operator not shown for the Non Operational job
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	opr		: String;
	debtor : CM_Debtor;
begin
	if self.allDebtors.isNotEmpty then
		foreach debtor in self.allDebtors discreteLock do	//06.03.2025 navma1 #MTN-34179
			if opr = null then
				opr := opr &amp; debtor.operators.listStringNoDuplicate(Comma, CM_Operator::code.name);
			else
				opr := opr &amp; Comma &amp; debtor.operators.listStringNoDuplicate(Comma, CM_Operator::code.name);
			endif;
		endforeach;
	endif;
	
	return opr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
