    <JadeMethod name="reset" id="45fc1880-be05-4dea-a36b-26de71f3558f">
        <source>reset();
// ---------------------------------------------------------------------------
// Created:     20 May 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	auditAttr	: CM_AuditAttribute;

begin

	foreach auditAttr in self.allAuditAttributesByClsAttr do
		auditAttr.afterValue := null;
		auditAttr.beforeValue := null;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="resetIsAudited" id="1d50b752-17fe-4889-a1c7-d61ad5ecf43e">
        <source>resetIsAudited(_isAudited : Boolean);
// ---------------------------------------------------------------------------
// Created:     20 May 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	auditAttr	: CM_AuditAttribute;

begin

	foreach auditAttr in self.allAuditAttributesByClsAttr where auditAttr.isAudited &lt;&gt; _isAudited do
		auditAttr.isAudited := _isAudited;
	endforeach;

end;</source>
        <Parameter name="_isAudited" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAuditAttributeValues" id="cdd90d01-ac8b-48b2-b849-02ae5360b1d9">
        <source>setAuditAttributeValues(_obj : CM_Object; _isBefore : Boolean);
// ---------------------------------------------------------------------------
// Created:     20 May 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed		By			Reason
// ----------	--------	--------------------------------------------------
// 10/05/2010	cnwdap1		PAR #24193 include connect/disconnect/on power from reefer properties
// 09/01/2014	cnwer1		par 32291 renamed from setBeforeValues and merged setBeforeValues &amp; setAfterValues into one method
// 02/10/2019	JLGNS1		ChangeRequest 45790: JMT - Refactor - Seal Transactions
// 07/05/2024 	navma1 		ChangeRequest 63027: MTN - Improve Performance of Cargo Bulk Edit - Second Enhancement
vars
	auditAttr			  : CM_AuditAttribute;
	objClass			  : Class;
	iter				  : Iterator;
	value 				  : String;
	defaultReeferDetails  : CM_TIReeferProperties;
	hasSealTypes,
	isTI,
	isBreakBulkGeneric	  : Boolean;
	reeferProperties      : CM_TIReeferProperties;
	attName				  : String;
	attProp				  : Property;
begin

	objClass := _obj.class;
	//epr par 32291 8/1/13 to get default reefer details if just created i.e ventilation defaults to -1 so when the 
	// reefer details are created don't need the audit without this it thinks before for ventilation is 0 after is -1 and
	//would create the audit details 
	if _obj.isKindOf(CM_TrackedItem) then
		
		isTI 			:= true;										//07.05.2024 navma1 #63027
		hasSealTypes	:= _obj.CM_TrackedItem.hasSealTypes;			//07.05.2024 navma1 #63027
		if _obj.CM_TrackedItem.myReeferProperties = null then			//07.05.2024 navma1 #63027
			create defaultReeferDetails transient;
		endif;
		
		if _obj.isKindOf(CM_BreakBulkGeneric) then
			isBreakBulkGeneric := true;
		endif;
		
		reeferProperties := _obj.CM_TrackedItem.myReeferProperties;	   //07.05.2024 navma1 #63027
	endif;
	
	iter := self.myAuditAttributesByClsAttrIter;
	self.allAuditAttributesByClsAttr.startKeyGeq(objClass, null, iter);

	while (iter.next(auditAttr) and auditAttr.myClass = objClass) do
		value 	:= null;
		attName := null;
		attProp := null;
		if auditAttr.isAudited then
		
			attName := auditAttr.attrName;							//07.05.2024 navma1 #63027
			attProp := auditAttr.myProperty;						//07.05.2024 navma1 #63027
			
			if attProp = null then									//cnwrd1 10.11.08 CCMS JMT 1743/1764 
			
				//17 Jan 2019	NDL	TFS 48249
				if isBreakBulkGeneric 	  			and attName = CM_PalletDetailsTI::heatTreated.name then
					value := _obj.formatAuditText(attName, _obj.getAuditTextForProperty(CM_PalletDetailsTI::heatTreated) );
				elseif isBreakBulkGeneric 			and attName = CM_PalletDetailsTI::myPalletType.name then
					value := _obj.formatAuditText(auditAttr.attrName, _obj.getAuditTextForProperty(CM_PalletDetailsTI::myPalletType) );
				elseif isBreakBulkGeneric 			and attName = CM_PalletDetailsTI::storeOnPallets.name then
					value := _obj.formatAuditText(auditAttr.attrName, _obj.getAuditTextForProperty(CM_PalletDetailsTI::storeOnPallets) );
				
				//28 Sep 2010	NDL Par 25608
				/*
				07.05.2024 navma1 #63027  
				Add Extra Check with seal type
				*/
				elseif  hasSealTypes and attName = OperatorImportReleasePIN then					
					value := _obj.formatAuditText(OperatorImportReleasePIN, _obj.CM_TrackedItem.getOperatorImportReleasePIN() );
				
				elseif hasSealTypes and attName = OperatorExportReleaseNumber  then
					value := _obj.formatAuditText(OperatorExportReleaseNumber, _obj.CM_TrackedItem.getOperatorExpReleaseNo() );
				
				elseif hasSealTypes and attName = PrevSealNum   then 								
					value := _obj.formatAuditText(PrevSealNum, _obj.CM_TrackedItem.getPrevSealNum() );
				
				elseif hasSealTypes and attName = SealDT   then									
					value := _obj.formatAuditText(SealDT, _obj.CM_TrackedItem.getSealDT().asStringJMT );
				
				elseif hasSealTypes and attName = SealNum and hasSealTypes  then														
					value := _obj.formatAuditText(SealNum, _obj.CM_TrackedItem.getSealNum() );
				
				elseif hasSealTypes and attName = SealNumCustoms   then												
					value := _obj.formatAuditText(SealNumCustoms, _obj.CM_TrackedItem.getSealNumCustoms() );
				
				elseif hasSealTypes and attName = SealNumShippers   then	
					value := _obj.formatAuditText(SealNumShippers, _obj.CM_TrackedItem.getSealNumShipper() );
				
				elseif hasSealTypes and attName = SealNumVent   then	
					value := _obj.formatAuditText(SealNumVent, _obj.CM_TrackedItem.getSealNumVent() );
				
				elseif hasSealTypes and attName = SealNumTerminalOperator   then														
					value := _obj.formatAuditText(SealNumTerminalOperator, _obj.CM_TrackedItem.getSealNumTerminalOperator() );	
				
				elseif hasSealTypes and attName = SealNumUnknown   then																	
					value := _obj.formatAuditText(SealNumUnknown, _obj.CM_TrackedItem.getSealNumUnknown() );
				
				else
					//29 Sep 2010	NDL Par 25608 - auditing of user defined values...
					if  hasSealTypes  then													//07.05.2024 navma1 #63027
						value := self.getCustomSealValues( _obj, auditAttr );
					endif;
				endif;
			else
				//epr par 32291 8/1/14
				if isTI and  (attProp.schemaType = CM_TIReeferProperties or attProp.schemaType = CM_ReeferProperties) then
					if reeferProperties &lt;&gt; null then													//07.05.2024 navma1 #63027
						value := reeferProperties.getAuditTextForProperty(attProp);						//07.05.2024 navma1 #63027
					else
						value := defaultReeferDetails.getAuditTextForProperty(attProp);				
					endif;
				else
					value := _obj.getAuditTextForProperty(attProp);
				endif;
			endif;
			if _isBefore then
				auditAttr.beforeValue := value;
			else
				auditAttr.afterValue  := value;
			endif;
		
		endif;
	endwhile;
epilog
	delete defaultReeferDetails;
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_isBefore" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAuditSpecific" id="0a18aea6-7343-426b-811b-606c244e52c9">
        <updating/>
        <source>setAuditSpecific(_cls : Class; _sa : StringArray) updating;
// ---------------------------------------------------------------------------
// Created:     20 May 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
21 Sep 2009	cnwkpd1	PAR #18507 - Tidy up iterator when no class passed in

*/

vars
	tmpAttrName	: String;
	auditAttr	: CM_AuditAttribute;
	iter		: Iterator;
	tmpClsColl	: ClassColl;
	tmpCls		: Class;
	
begin

	self.resetIsAudited(false);

	tmpClsColl := self.myClassColl;
	
	if _cls &lt;&gt; null and
	   self.myCurrentClassCollClass &lt;&gt; _cls then
	   	self.myCurrentClassCollClass := _cls;
	   	// add all the subclasses into the collection
		tmpClsColl.clear();
		tmpClsColl.add(_cls);
		_cls.allSubclasses(tmpClsColl);
	endif;
	
	foreach tmpAttrName in _sa do
		if _cls &lt;&gt; null then
			foreach tmpCls in tmpClsColl do
				auditAttr := self.allAuditAttributesByClsAttr[tmpCls, tmpAttrName];
				if auditAttr &lt;&gt; null then
					auditAttr.isAudited := true;
				endif;
			endforeach;
		else
			// set all classes with that attrName to be true
			iter := self.myAuditAttributesByAttrClsIter;
			self.allAuditAttributesByAttrCls.startKeyGeq(tmpAttrName, null, iter);
			while iter.next(auditAttr) do
				if auditAttr.attrName &lt;&gt; tmpAttrName then
					break;
				endif;
				auditAttr.isAudited := true;
			endwhile;
		endif;
	endforeach;

	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_cls" type="Class"/>
        <Parameter name="_sa" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="setIsAuditedFor" id="dcdf08bb-536f-468b-b061-84ea641b6a77">
        <source>setIsAuditedFor( _attrName : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 October 2012	cnwndl1	Initial creation	Par 30594

*/

vars

	tmpCls : Class;
	auditAttr : CM_AuditAttribute;

begin
	
	foreach tmpCls in self.myClassColl do
		auditAttr := self.allAuditAttributesByClsAttr[tmpCls, _attrName];
		if auditAttr &lt;&gt; null then
			auditAttr.isAudited := true;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
    </JadeMethod>
