    <JadeMethod name="includesWPOpHrsFor" id="723e5370-a866-4130-950d-c2c5f534ad55">
        <source>includesWPOpHrsFor( _craneOrWorkPointId : String ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	iter : Iterator;
	opHr : CM_WorkPointOperatingHours;

begin

	if self.allWorkPointOperatingHours.isEmpty then
		return false;
	endif;
	
	iter := self.allWorkPointOperatingHours.createIterator;
	while iter.next( opHr ) do
		if opHr.craneWorkPointId = _craneOrWorkPointId then
			return true;
		endif;
	endwhile;
	
	return false;	//07 Aug 2012	NDL	Par 30161 - just to be explicit

epilog

	delete iter;
	
end;</source>
        <Parameter name="_craneOrWorkPointId" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
