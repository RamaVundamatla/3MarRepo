    <JadeMethod name="clearThumbnailData" id="06d81da6-5150-4837-9c2a-00d692f25dfc">
        <updating/>
        <source>clearThumbnailData() updating;

vars
	table		: CM_DataTable;
	theForm : SOP_TableMaintForm;

begin
  
	theForm := self.myForm;
	theForm.tblInput1.clearValues();
	// 31448 clear the address table
	table := self.myForm.tblData4;
	table.accessCell(1,2).text := null;
	table.accessCell(2,2).text := null;
	table.accessCell(3,2).text := null;
	table.accessCell(4,2).text := null;
	table.accessCell(5,2).text := null;
	table.accessCell(6,2).text := null;
	table.userInputEnabled := true;	
	theForm.cmbCountry.setObject(null);
end;</source>
    </JadeMethod>
