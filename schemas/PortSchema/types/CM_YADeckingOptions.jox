    <JadeMethod name="setProxyFrom" id="5744622e-5886-4dd7-9579-7b519b3ff541">
        <updating/>
        <source>setProxyFrom(_deckingOptions: CM_YADeckingOptions) updating;
//25 March 2009	cnwdw1	
// Create the proxy based on another decking options object PAR 19121
vars
	newDR, deckingRule		: CM_YADeckingRule;
begin
	_deckingOptions.allYALocationCellsIn.copy(self.allYALocationCellsIn);
	_deckingOptions.allYALocationCellsOut.copy(self.allYALocationCellsOut);
	self.showHeightsForCustom := _deckingOptions.showHeightsForCustom;
	self.useReverseOfIn := _deckingOptions.useReverseOfIn;
	foreach deckingRule in _deckingOptions.allDeckingRulesIn do
		create newDR transient;
		newDR.setForCreate(deckingRule);
		self.allDeckingRulesIn.add(newDR);
	endforeach;
	foreach deckingRule in _deckingOptions.allDeckingRulesOut do
		create newDR transient;
		newDR.setForCreate(deckingRule);
		self.allDeckingRulesOut.add(newDR);
	endforeach;

end;</source>
        <Parameter name="_deckingOptions" type="CM_YADeckingOptions"/>
    </JadeMethod>
    <JadeMethod name="setProxyRules" id="32e13f4b-b74e-40ea-9a6b-cfd399257c52">
        <updating/>
        <source>setProxyRules(_inRule, _outRule: Integer) updating;
//----------------------------------------------------------------
//	Created:	11 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//
//	Use this when updating the rules 
//
vars
	deckingRule,
	defDeckingRuleIn,
	defDeckingRuleOut	: CM_YADeckingRule;
	rule				: Integer;
	stackHeight			: Integer;
	deleteRules			: ObjectArray;
begin

	self.raiseExceptionIfNotTransient(method);
	
	create deleteRules transient;
	
	if _inRule &gt;= DeckingRule_Default then
		self.allDeckingRulesIn.purge;
		if _inRule = DeckingRule_Default then
			self.setDefaultProxyRules(1, true);
			//rule := self.getDefaultRuleIn(1);	
		else
			create defDeckingRuleIn transient;
			self.allDeckingRulesIn.add(defDeckingRuleIn);
			defDeckingRuleIn.setProxyBasic(_inRule, null, null, true);
		endif;
	else
		//check height change
		stackHeight	:= self.getStackHeight();
		foreach deckingRule in self.allDeckingRulesIn reversed do
			if deckingRule.heightTo &gt; stackHeight then
				if deckingRule.heightFrom &gt; stackHeight then
					//delete it
					deleteRules.add(deckingRule);
				else
					//update it
					deckingRule.setHeights(deckingRule.heightFrom, stackHeight);
					break;
				endif;
			else
				break;
			endif;
		endforeach;
	endif;
		
	if _outRule &gt;= DeckingRule_Default then
		self.allDeckingRulesOut.purge;
		if _outRule = DeckingRule_Default then
			self.setDefaultProxyRules(1, false);
			//rule := self.getDefaultRuleOut(1);	
		else
			create defDeckingRuleOut transient;
			self.allDeckingRulesOut.add(defDeckingRuleOut);
			defDeckingRuleOut.setProxyBasic(_outRule, null, null, false);
			self.useReverseOfIn := (_outRule = DeckingRule_ReverseOfOther) or (_outRule = DeckingRule_Default);
		endif;
	else
		//check height change
		stackHeight	:= self.getStackHeight();
		foreach deckingRule in self.allDeckingRulesOut do
			if deckingRule.heightTo &gt; stackHeight then
				if deckingRule.heightFrom &gt; stackHeight then
					//delete it
					deleteRules.add(deckingRule);
				else
					//update it
					deckingRule.setHeights(deckingRule.heightFrom, stackHeight);
					break;
				endif;
			else
				break;
			endif;
		endforeach;
	endif;
		
epilog
	deleteRules.purge;
	delete deleteRules;
end;</source>
        <Parameter name="_inRule" type="Integer"/>
        <Parameter name="_outRule" type="Integer"/>
    </JadeMethod>
