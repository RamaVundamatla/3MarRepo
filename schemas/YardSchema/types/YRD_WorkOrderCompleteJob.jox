    <JadeMethod name="populateCargoGrpDtlsDict" id="eac4c826-cc40-4348-b4be-2709b2a21fa2">
        <source>populateCargoGrpDtlsDict(_table : CM_DataTable input ; _ti : CM_TrackedItem )    ;
/*
 
Purpose: populates allCargoGroupDetails dictionary. 			
 
Parameters:			
 
Return Value:		
 
Date		Who		Reason
25 Nov 2024 navbs1 Bug MTN-33186: MTN - Performance of Data retrieval in work order operations screen has been affected by cargo grouping
*/
 
vars
	detail			: CM_CargoGroupDetail;
	failed 			: Boolean;
	cargoGroup 		: CM_CargoGroup;

begin
	cargoGroup := _ti.myCargoGroup;
	detail := allCargoGroupDetails.getAtKey(_table.name,cargoGroup).CM_CargoGroupDetail;
	if detail &lt;&gt; null  then 
		if not detail.allAssignedTrackedItems.includes(_ti) then 
			detail.addTIToDetail(_ti, failed);	
			if failed then 
				return;
			endif;
		endif;

	else
		create detail transient;
		self.allCargoGroupDetails.tryPutAtKey(_table.name,cargoGroup,detail);
		detail.initialise(null, null, cargoGroup, null, null);
		detail.addTIToDetail(_ti, failed);	
		if failed then 
			return;
		endif;
	endif;		
 
epilog
 
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="populateDetails" id="ae8bc289-3dc9-4f57-b7b5-e1314df47500">
        <updating/>
        <source>populateDetails()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Feb 2024 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
14 Feb 2024 navhl20 ChangeRequest 62418: EUP | Retrospective Operations - [54177.040] - Road Release
01 Mar 2024 navhl20 ChangeRequest 62705: EUP | Ship Operations in DD - [54176.070] - [Road] Retrospective Operations Remedial
11 Mar 2024 navhl20 ChangeRequest 60097: EUP | Ship Operations in DD - [54176.060] - [Receive] Retrospective Operations
12 Mar 2024 navhl20 ChangeRequest 62734: EUP | Ship Operations in DD - [54176.060] - [Release] Retrospective Operations
14 Mar 2024 navhl20 ChangeRequest 62861: EUP | Retrospective Operations - [54177.090] - UnPack
18 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
16 Apr 2024 navhl20 Bug 63707: EUP - 1090 Exception when clicking on the Pack button for the retrospective Pack jobs
22 Apr 2024 navhl20 Bug 63708: EUP - 1086 Exception when selecting the Complete Job option for the Pack Jobs
07 May 2024 navhl20 ChangeRequest 64031: EUP - FR | 54176 - Ship operations in Delivery Dispatch screen (retrospective)
20 May 2024 navhl20 Bug 64191: EUP - Lock and Freeze issue
29 May 2024 navhl20 Bug 64345: EUP - Retrospective Partial Discharge not wokring.
12 Jun 2024 navhl20 ChangeRequest 64602: EUP - FR | 54177 - Retrospective Operations
22 Jul 2024 navbs1 ChangeRequest 64884: EUP - Retrospective Jobs Grouped by Cargo Group
13 Aug 2024 navhl20	Bug 65565: Start/Complete Job button should be disabled from the Complete Job form for ToDo Task jobs
26 Sep 2024 navhl20	ChangeRequest 14712: EUP - FR | 54176 - Ship operations in Delivery Dispatch screen (retrospective) - 1
27 Sep 2024	navnk30	Bug 66108: MTN | WO Job Complete Permissions
03 Oct 2024	navbs1	Bug MTN-19303: FR | 54177 - Retrospective Operations - part II
30 Oct 2024	navhl20 CR MTN-33232: EUP - Start End Times for Road and Rail jobs
12 Nov 2024	navbs1	Bug MTN-33403: EUP - New To Do Complete form is not available for non-cargo To Do Task jobs
02 Dec 2024	navhl20 Bug MTN-33509: EUP - Getting 1090 for Non Cargo ToDo Jobs After Part complete From Allocated Tab
03 Dec 2024 navbs1  Bug MTN-33570: MTN - Ship WorkOrder Enhancements
20 Feb 2025	jlizm1	MTN 34067 Not displaying Weight or volume for reserve detail in WO complete job
02 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars
	woJob,
	job						: CM_Job;
	resDtl,
	childResDtl				: CM_ReserveDetail;
	relReq					: CM_BulkRelease;
	wod						: CM_WorkOrderTIDtl;
	lc						: CM_LocationsController;
	hasCompletedActivity	: Boolean;
	wagon					: CM_Wagon;
	voyageProcess   		: CM_VoyageProcess;
	jobSheet				: CM_WorkPointJobSheet;
	shift					: CM_Shift;
	detailDescription		: String;
begin
	job := self.myJob;													//02.04.2025 navhl20 #34493
	
	self.getResDtlFromJob(resDtl);										//02.04.2025 navhl20 #34493
	self.populateDetailsFromRelease(resDtl,relReq);						//02.04.2025 navhl20 #34493
	
	if job &lt;&gt; null then
		self.prePopulateShtJob();										//02.04.2025 navhl20 #34493
		self.populateDetailsFromJob();									//02.04.2025 navhl20 #3449
		self.setDateTimeFromJob();										//02.04.2025 navhl20 #34493
	endif;
	
	self.setVisibilityAndCaptions(relReq, resDtl);						//02.04.2025 navhl20 #34493
	
	if self.shtJob.visible then 										// ### TFS CR 62818 TASK 62821 14MAR2024 NAVAB1
		self.loadShtJob();												//02.04.2025 navhl20 #34493
	elseif self.shtUnpack.visible then									//14.03.2024 navhl20 #62861
		self.loadShtUnpack(relReq,resDtl);								//02.04.2025 navhl20 #34493
	else
		self.loadTblToDoResource(); 									// ### TFS CR 62818 TASK 62821 14MAR2024 NAVAB1
		self.loadTbToDoTIs(); 											// ### TFS CR 62818 TASK 62821 14MAR2024 NAVAB1
	endif;
	
	self.setupStartStop();												//02.04.2025 navhl20 #34493
	
	if self.tblAvailCargo.rows = 1 then
		self.btnOk.enabled := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);	//27.09.2024 navnk30 #66108
	endif;
	
	self.setRetroFiledsInvisible();										//02.04.2025 navhl20 #34493
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="populateDetailsFromJob" id="d9b1a638-c24e-4983-b25d-d2ab67022e24">
        <updating/>
        <source>populateDetailsFromJob()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars
	job 	: CM_Job;
	wagon	: CM_Wagon;
begin
	job := self.myJob;
	
	if job.isRoadJob then
		self.txtTransport.text := job.CM_RoadJob.myVehicle.regNumber;
		
	elseif job.isRail then
		wagon := self.getWagonForJob(job.CM_RailJob);
		if wagon &lt;&gt; null then
			self.txtTransport.text := wagon.id;
		endif;
		
	elseif job.isVoyageWorkpointJob then
		self.txtTransport.text 	:= job.CM_VoyageWorkPointJob.myVoyage.code;
		self.chkCargoGrouping.visible := true;
		if self.isCargoGrouping then 
			self.btnExpandAll.visible:=true;
			self.btnCollapseAll.visible:=true;
		endif;
		
	elseif job.isKindOf(CM_WOToDoTaskJob) then
		self.shtJob.visible := false;
		self.shtToDo.visible := true;
		self.myWLE := job.getFirstWle();
		self.lblTransport.visible := false;
		self.txtTransport.visible := false;
		self.chkHideCompleted.visible:= false;
		self.setShtTodoForVASJobs();
		
	elseif job.isKindOf(CM_WOUnpackJob) or job.isKindOf(CM_WOPackJob) then
		self.shtJob.visible  	:= false;
		self.shtToDo.visible 	:= false;
		self.shtUnpack.visible	:= true;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateDetailsFromRelease" id="b19b45ce-897f-4545-b622-3928c3b3b212">
        <source>populateDetailsFromRelease(_resDtl : CM_ReserveDetail; _release : CM_BulkRelease io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars
	detailDescription 	: String;
	job					: CM_Job;
	request				: CM_Request;
	cargoGroup			: CM_CargoGroup;
begin
	job := self.myJob;
	if _resDtl &lt;&gt; null then
		_release 	:= _resDtl.myReserveHeader;
		if job.isVoyageWorkpointJob then
			self.txtResDtl.text := _resDtl.getDescriptionShort();
		else
			if _resDtl.isReserveSelection then
				detailDescription	:= job.getTotalQuantity.String &amp; " x " &amp; _resDtl.getProductISOTypeDescr;
				if detailDescription.length &gt; 30 then 
					detailDescription := detailDescription[1:30];
				endif;
				self.txtResDtl.text := detailDescription;
			endif;
		endif;
		
		cargoGroup := _resDtl.myCargoGroup;
		if cargoGroup &lt;&gt; null then
			self.txtCargoGroup.text 	:= cargoGroup.id;
			self.lblCargoGroup.visible	:= true;
			self.txtCargoGroup.visible 	:= true;
		endif;
	endif;
	
	if _release = null then
		request := job.allRequests.first;
		if request &lt;&gt; null then
			_release := request.myOriginatingBulkRelease;
		endif;
	endif;
	
	if _release &lt;&gt; null then
		self.txtRelReq.text := _release.code;
	endif;
epilog

end;</source>
        <Parameter name="_resDtl" type="CM_ReserveDetail"/>
        <Parameter name="_release" type="CM_BulkRelease" usage="io"/>
    </JadeMethod>
    <JadeMethod name="populateLocation" id="9e49a00f-b46c-4409-b91d-ff0a50e54f01">
        <updating/>
        <source>populateLocation()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Feb 2024 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive

*/

vars
	ti			: CM_TrackedItem;
	location	: CM_LocationsController;
begin
	if self.tblAvailCargo.allSelectedObjects.isNotEmpty then
		ti := self.tblAvailCargo.allSelectedObjects.first.CM_TrackedItem;
		location := ti.myPrimaryPlannedLocation;
		if location = null then
			location := ti.myPrimaryQueuedLocation;
		endif;
		if location &lt;&gt; null then
			self.cmbTerminalArea.setIndexFromObject(location.myTerminalArea);
			self.cmbTerminalArea_click(self.cmbTerminalArea);
			self.cmbSubArea.setIndexFromObject(location);
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="prePopulateShtJob" id="8a02bdf8-5c0d-4565-8ae0-579a98fb4a31">
        <source>prePopulateShtJob();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 April 2025	navhl20	Initial creation

*/

vars
	job : CM_Job;
begin
	job := self.myJob;
	self.shtJob.visible := true;
	self.shtToDo.visible := false;
	self.shtUnpack.visible := false;

	if job.myJobSheetForWorkPoint &lt;&gt; null then
		self.txtGang.text 	:= job.myJobSheetForWorkPoint.externalName;
	endif;
	
	if job.id &lt;&gt; null then
		self.txtJobId.text 		:= job.id;
	else
		self.txtJobId.text 		:= job.jobId;
	endif;
	
	self.txtJobType.text 	:= job.getJobTypeDescription();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="refreshCargoGroupDetail" id="9cf2b57e-81a5-45c1-b1a6-2fb51a400d45">
        <updating/>
        <source>refreshCargoGroupDetail(_table :CM_DataTable input;_cgInAvailTbl : CM_TISet) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Aug 2024 navlc30 Bug 65501: Performance Issue - The progress bar never goes away when discharging the cargo group using the complete job form
*/

vars
	detail,
	newDetail      : CM_CargoGroupDetail;
	tis			   : CM_TIByIdDups;
	ti             : CM_TrackedItem;
	failed         : Boolean;
	rowIdx         : Integer;
	cell           : JadeTableCell;
	result		   : String;
	deleteFlag 	   : Boolean;
	cg			   : CM_CargoGroup;
begin
	// Code to refresh the cargo Group Detail moved from removeObjectFromCGDtlDict
	foreach cg in _cgInAvailTbl as CM_CargoGroup do
		if cg = null then 
			continue;
		endif;
		deleteFlag := false;

		detail:=self.allCargoGroupDetails[_table.name, cg].CM_CargoGroupDetail;
		if detail &lt;&gt; null then
			tis:=detail.allAssignedTrackedItems;
		endif;
		
		//update the row display string
		if tis &lt;&gt; null and tis.size &lt;&gt; 0 then
			if cg &lt;&gt; null then
				create newDetail transient;
				newDetail.initialise(null,null,cg,null,null);
				foreach ti in tis do 
					newDetail.addTIToDetail(ti,failed);
				endforeach;
				self.allCargoGroupDetails.removeKeyEntry(_table.name,cg,detail);
				self.allCargoGroupDetails.putAtKey(_table.name,cg,newDetail);
				rowIdx := _table.fixedRows+1;
				self.findObjectInTableRows(_table,cg,rowIdx);
				result := newDetail.getAttributeStringForDefArray(_table.allTblDataEntRows);
				cell := _table.accessCell(rowIdx, 1);
				cell.text := cell.text[1:2] &amp; result;	// Leave the existing +/- indiacator as is
				deleteFlag := true;
			endif;
		endif;
	endforeach;
	
epilog
	if deleteFlag then
		delete detail;
	endif;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_cgInAvailTbl" type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="reloadTablesForPack" id="a711a016-2614-4cc4-95be-48b5af75454e">
        <source>reloadTablesForPack();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars

begin
	self.loadTblParent();
	self.loadTblChild(null);
	self.loadTblPackedParent();
	self.loadTblPackedChild(null);
	self.setTblDataCount();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="reloadTablesUnpack" id="69482d97-9c82-4f67-b8e4-72bc441e28dc">
        <source>reloadTablesUnpack();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars

begin
	self.loadTblParent();
	if self.tblParent.rows &gt; 1 and self.tblParent.allSelectedObjects.isNotEmpty() then
		self.loadTblChild(self.tblParent.allSelectedObjects.first.CM_TrackedItem);
	else
		self.tblChild.clearAllData();
		self.btnUnpack.enabled := false;
	endif;
	self.loadTblUnpacked();
	
	self.setTblDataCount();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="removeObjectFromCGDtlDict" id="cda9e3e3-670a-4cdc-9449-ffd61707410d">
        <updating/>
        <source>removeObjectFromCGDtlDict(_table :CM_DataTable input;_ti :CM_TrackedItem) updating;
/*

Purpose:	

Parameters:			

Return Value:		

Date		Who		Reason
22 Jul 2024 navbs1 ChangeRequest 64884: EUP - Retrospective Jobs Grouped by Cargo Group
12 Aug 2024 navlc30 Bug 65501: Performance Issue - The progress bar never goes away when discharging the cargo group using the complete job form
04 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars
	detail      	: CM_CargoGroupDetail;
	tis			   : CM_TIByIdDups;
	deleteFlag 	   : Boolean;
begin
	if _ti = null then 
		return;
	endif;
	deleteFlag := true;

	detail:=self.allCargoGroupDetails[_table.name, _ti.myCargoGroup].CM_CargoGroupDetail;
	tis:=detail.allAssignedTrackedItems;
	tis.tryRemove(_ti);
	
	if tis.size = 0 then   //if all items are moved ,remove group from table and dict 	
		if _ti.myCargoGroup = null then 
			self.allCargoGroupDetails.removeKeyEntry(_table.name,_ti.myCargoGroup,detail);
			_table.removeItem(_table.rows);
		else
			self.allCargoGroupDetails.removeKeyEntry(_table.name,_ti.myCargoGroup,detail);
			_table.removeItemObject(_ti.myCargoGroup);
		endif;
	else
		deleteFlag :=false;																			//12.08.2024 navlc30 #65501			
	endif;

epilog
	if deleteFlag then
		delete detail;
	endif;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="rowPostprocess" id="97a55c6c-d682-41cc-8703-8d1433522c93">
        <updating/>
        <source>rowPostprocess(_dataTable: CM_DataTable io; _idx: Integer; _obj: Object) : Boolean updating;
/*

Purpose:			

Parameters:			
	
Return Value:		

Date		Who		Reason
13 May 2024	navra1	Initial creation - //navra1 - TFS 63751/Task 63752 - 13th May 2024
04 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/

vars
	ti : CM_TrackedItem;
begin
	
	if _dataTable.name = self.tblUnpacked.name then		
		_dataTable.accessRow(_idx).foreColor := White;
		_dataTable.accessRow(_idx).backColor := Grey;		
	elseif _dataTable.name = self.tblParent.name then		
	elseif _dataTable.name = self.tblPackParent.name then		
		_dataTable.accessRow(_idx).foreColor := White;
		_dataTable.accessRow(_idx).backColor := Grey;
	elseif _dataTable.name = self.tblPackChild.name then
		_dataTable.accessRow(_idx).foreColor := White;
		_dataTable.accessRow(_idx).backColor := Grey;		
	elseif _dataTable.name = self.tblCompletedCargo.name then	
		_dataTable.accessRow(_idx).foreColor := White;
		_dataTable.accessRow(_idx).backColor := Grey;
	elseif _dataTable.name = self.tblAvailCargo.name then		
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_dataTable" type="CM_DataTable" usage="io"/>
        <Parameter name="_idx" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="rowPreprocess" id="77b1f357-ff49-4655-98a7-8056d0b53d01">
        <updating/>
        <source>rowPreprocess(_dataTable : CM_DataTable; _obj: Object) : Boolean updating;
/*

Purpose:			

Parameters:			
	
Return Value:		

Date		Who		Reason

13 May 2024	navra1	Initial creation - //navra1 - TFS 63751/Task 63752 - 13th May 2024
					This method can be used to do any preprocess that the row/row object might need,
					and can determine if the row needs to be displayed. Returning false, will make the
					caller(CM_DataTable::getDataAndDisplayRowsForColl) not show the row
04 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
13 Nov 2025	jlizm1	MTN 35927 Filter Issues on paginated forms
*/

vars
	ti:CM_TrackedItem;
	filterText : String;
	tmpString : String;

begin	
	if _dataTable.name = self.tblParent.name then
		if _obj.isKindOf(CM_TrackedItem) then
			ti := _obj.CM_TrackedItem;
			
			if self.myJob.isKindOf(CM_WOUnpackJob) and not ti.allChildren.isNotEmpty() then
				return false;
			endif;
		endif;
	endif;
	
	// MTN 35927
	if _dataTable.isPaginated then
		if _dataTable.name = self.tblParent.name then
			filterText := self.tblFilterParent.txtFilterBox.text.toUpper();
		elseif _dataTable.name = self.tblChild.name then
			filterText := self.tblFilterChild.txtFilterBox.text.toUpper();
		elseif _dataTable.name = self.tblAvailCargo.name then
			filterText := self.frmTableFilter.txtFilterBox.text.toUpper();
		endif;
		
		if filterText &lt;&gt; null then
			tmpString := _obj.getAttributeStringForDefArray(_dataTable.allTblDataEntRows).toUpper;

			if tmpString.pos(filterText, 1) = 0 then
				return false;
			endif;
		endif;
	endif;
	
	return inheritMethod(_dataTable, _obj);	
epilog

end;</source>
        <Parameter name="_dataTable" type="CM_DataTable"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveXMLStrForTblColumns" id="7e4f1b22-f737-49ea-8c57-0621dd95b81a">
        <updating/>
        <source>saveXMLStrForTblColumns(table: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Feb 2024 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
13 Feb 2024 navhl20 ChangeRequest 62418: EUP | Retrospective Operations - [54177.040] - Road Release
11 Mar 2024 navhl20 ChangeRequest 60097: EUP | Ship Operations in DD - [54176.060] - [Receive] Retrospective Operations
14 Mar 2024 navhl20 ChangeRequest 62861: EUP | Retrospective Operations - [54177.090] - UnPack
*/

vars
	xmlStr : String;
begin
	if table = self.tblAvailCargo then
		xmlStr := self.tblAvailCargo.getXmlStrForColumns(true);
		self.defAvailCargo := xmlStr;
	endif;
	if table = self.tblCompletedCargo then
		xmlStr := self.tblCompletedCargo.getXmlStrForColumns(true);
		self.defCompletedCargo := xmlStr;
	endif;
	if table = self.tblParent then											//14.03.2024 navhl20 #62861
		xmlStr := self.tblParent.getXmlStrForColumns(true);
		self.defParent := xmlStr;
	endif;
	if table = self.tblChild then											//14.03.2024 navhl20 #62861
		xmlStr := self.tblChild.getXmlStrForColumns(true);
		self.defChild := xmlStr;
	endif;
	if table = self.tblUnpacked then										//14.03.2024 navhl20 #62861
		xmlStr := self.tblUnpacked.getXmlStrForColumns(true);
		self.defUnpacked := xmlStr;
	endif;
epilog

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCaptionsForShtUnpack" id="2c2665dd-ebf3-4ff0-89fe-e16d2c557484">
        <source>setCaptionsForShtUnpack(_parentRes ,_resDetl : CM_ReserveSelection);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
08 Aug 2025	jlizm1	MTN 35316 Pagination - Work Order Complete

*/

vars
	job 		: CM_Job;
	count,
 	totalReq	: Integer;
begin
	job := self.myJob;
	
	if job.isKindOf(CM_WOUnpackJob) then
		//Available Parent Table Caption
		self.grpAvailParent.caption 	:= self.grpParentCaption &amp; Space &amp; "[" &amp; (self.tblParent.getRowCount()).String &amp; "]" ;
		//Available Child Table Caption
		self.grpAvailChild.caption 		:= self.grpChildCaption &amp; Space &amp; "[" &amp; (self.tblChild.getRowCount()).String &amp; "]" ;
		//Unpacked Table Caption
		self.grpUnpacked.caption 		:= self.grpUnpackedCaption &amp; Space &amp; "[" &amp; (self.tblUnpacked.getRowCount()).String &amp; "]" ;
	else
		//Available Parent Table Caption
		count := self.getTotalCount(self.tblParent);
		self.grpAvailParent.caption 	:= self.grpParentCaption &amp; Space &amp; "[" &amp; app.getErrorString(Items) &amp; " - " &amp; (self.tblParent.getRowCount()).String &amp; "]" ;
		self.grpAvailParent.caption 	:= self.grpAvailParent.caption &amp; Space &amp; "[" &amp; app.getErrorString(CM_Quantity) &amp; " - " &amp; count.String &amp; "]";
		
		//Available Child Table Caption
		count := self.getTotalCount(self.tblChild);
		self.grpAvailChild.caption 		:= self.grpChildCaption &amp; Space &amp; "[" &amp; app.getErrorString(Items) &amp; " - " &amp; (self.tblChild.getRowCount()).String &amp; "]" ;
		self.grpAvailChild.caption 		:= self.grpAvailChild.caption &amp; Space &amp; "[" &amp; app.getErrorString(CM_Quantity) &amp; " - " &amp; count.String &amp; "]";
		
		//Packed Table Caption
		count 	 := self.getTotalCount(self.tblPackParent);
		if _parentRes &lt;&gt; null then														//16.04.2024 navhl20 #63708
			totalReq := _parentRes.totalRequested;
		else
			totalReq := job.getTotalQuantity();
		endif;
		self.grpPacked.caption := self.grpPackedCaption &amp; Space &amp; "[" &amp; app.getErrorString(Parent) &amp; " - " &amp; count.String &amp; Forward_Slash &amp; totalReq.String &amp; "]" ;
		
		count 	 := self.getTotalCount(self.tblPackChild);
		if _resDetl &lt;&gt; null then
			totalReq := _resDetl.totalRequested;
		endif;
		self.grpPacked.caption := self.grpPacked.caption &amp; Space &amp; "[" &amp; app.getErrorString(Child) &amp; " - " &amp; count.String &amp; Forward_Slash &amp; totalReq.String &amp; "]" ;
	endif;
epilog

end;</source>
        <Parameter name="_parentRes" type="CM_ReserveSelection"/>
        <Parameter name="_resDetl" type="CM_ReserveSelection"/>
    </JadeMethod>
    <JadeMethod name="setDateTimeFromJob" id="3b2732eb-e743-4f68-8873-8b4bfc35daa9">
        <source>setDateTimeFromJob();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars
	job 		: CM_Job;
	jobSheet	: CM_WorkPointJobSheet;
	shift		: CM_Shift;
begin
	job := self.myJob;
	
	if job.retrospectiveDT &lt;&gt; null then
		self.txtDate.setDate(job.retrospectiveDT.Date);
		self.txtTime.setTime(job.retrospectiveDT.Time);
	else
		if job.isVoyageWorkpointJob and job.CM_VoyageWorkPointJob.actualEndTs.isValid then
			self.txtDate.setDate(job.CM_VoyageWorkPointJob.actualEndTs.Date);
			self.txtTime.setTime(job.CM_VoyageWorkPointJob.actualEndTs.Time);
		else
			jobSheet := job.myJobSheetForWorkPoint;
			if jobSheet &lt;&gt; null then
				shift := jobSheet.myShift;
			endif;
			if shift &lt;&gt; null and shift.endDateTime.isValid then
				self.txtDate.setDate(shift.endDateTime.Date);
				self.txtTime.setTime(shift.endDateTime.Time);
			endif;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setIsBulkMode" id="2216f173-c684-47c1-b062-1493ed7397ca">
        <updating/>
        <source>setIsBulkMode(_isBulk : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Apr 2024 navhl20	ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen

*/

vars

begin
	self.isBulkMode := _isBulk;
epilog

end;</source>
        <Parameter name="_isBulk" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyJob" id="ce6f0b04-d0d4-431e-9b0c-75f8f94eead5">
        <updating/>
        <source>setMyJob(_job : CM_Job)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Feb 2024 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive

*/

vars

begin
	self.myJob := _job;
epilog

end;</source>
        <Parameter name="_job" type="CM_Job"/>
