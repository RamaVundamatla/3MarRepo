    <JadeMethod name="pxyCreateUpdateProxy" id="a51e346a-9a94-40f0-8b27-2ca6c09095c6">
        <source>pxyCreateUpdateProxy(): SelfType;
/*
----------   ----------  --------------------------------------------------
Created:	20 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
20/04/2011	 cnwmh5		 PAR #27401 - Add code to handle prossible exceptions occurring when
 						 trying to create the proxy	
						 
27/06/2022	navak20		 ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
----------   ----------  --------------------------------------------------
*/
vars
	pxyDamage		: CM_DamageInstance;
	completedOK		: Boolean;
begin
	pxyDamage := inheritMethod();
	pxyDamage.myDamageDefinition := self.myDamageDefinition;
	pxyDamage.myDamagePosition := self.myDamagePosition;// 04/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
		
		
	pxyDamage.myDamagePlace	:= self.myDamagePlace;				// Jun 27, 2022 navak20 TFS 53862
	pxyDamage.myDamageParty := self.myDamageParty;				// Jun 27, 2022 navak20 TFS 53862
	pxyDamage.myDamageReason := self.myDamageReason;			// Jun 27, 2022 navak20 TFS 53862
	pxyDamage.damageSize := self.damageSize;					// Jun 27, 2022 navak20 TFS 53862
	pxyDamage.damageDateTime := self.damageDateTime;			// Jun 27, 2022 navak20 TFS 53862
	pxyDamage.status := self.status;							// Jun 27, 2022 navak20 TFS 53862
	pxyDamage.repairedDateTime := self.repairedDateTime;		// Jun 27, 2022 navak20 TFS 53862
	pxyDamage.myRepairReason := self.myRepairReason;			// Jun 27, 2022 navak20 TFS 53862
	pxyDamage.repairRemarks := self.repairRemarks;				// Jun 27, 2022 navak20 TFS 53862
	pxyDamage.myDamageSeverity := self.myDamageSeverity;		// Jun 27, 2022 navak20 TFS 53862
		
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyDamage;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyDamage;
	endif;
	
end;


</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
