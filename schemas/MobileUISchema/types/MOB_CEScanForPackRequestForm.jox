    <JadeMethod name="setupForm" id="1e148623-f7fe-49e4-9772-0745daec3a6f">
        <updating/>
        <source>setupForm() updating, protected;
// ---------------------------------------------------------------------------
// Created:     by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 22/03/2011	cnwdap1		PAR #19664 Set focus to the cargo id field so drivers don't need
//										to do this manually
begin
	inheritMethod();
	
	self.sht_Request.caption := 'Request ' &amp; self.allBulkReleases.first.code;	//app.getErrorString(Packing_request);
	self.sht_CargoID.caption := app.getErrorString(Pack) &amp; " " &amp; self.myCargoTI.id;
	
	if self.sht_Request.caption.length + self.sht_CargoID.caption.length &gt; 35 then
		self.fld_RequestForm.fontSize := 12;
	else
		self.fld_RequestForm.fontSize := 14;
	endif;
	
	/*Date		      Who		Reason
	   20 June 2008	 cnwdz2	    Par17080 -  disable the Gross Weight text box since it should be read-only.
	*/
	self.txt_GrossWeight.enabled := false;
	self.txt_GrossWeight.text := self.myCargoTI.totalWeight.asStringWeightJMT();
	
	// PAR #19664
	self.txt_CargoID.setFocus();
end;</source>
        <access>protected</access>
    </JadeMethod>
