    <JadeMethod name="getBulkGateIn" id="3a4ab731-d77c-4a67-bc1d-3b0e61f67ef0">
        <source>getBulkGateIn(_beforeMe : CM_VehicleVisitRecordDetail):CM_VehicleVisitRecordDetail;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 November 2016	cnwndl1	Initial creation

*/

vars
	
	detail	: CM_VehicleVisitRecordDetail;
	nextOne : Boolean;
	modSt : String;
begin
	if _beforeMe &lt;&gt; null then
		foreach detail in self.allVehicleVisitRecordDetails reversed do
			if detail.recordType = VisitRecord_Bulk_In and not	detail.getExtraInfo_BulkGateModified(modSt) then
				if not nextOne then
					if detail = _beforeMe then
						nextOne := true;
					endif;
				else
					return detail;
				endif;
			endif;
		endforeach;
	else
		foreach detail in self.allVehicleVisitRecordDetails reversed do
				if detail.recordType = VisitRecord_Bulk_In and not	detail.getExtraInfo_BulkGateModified(modSt) then
				return detail;
			endif;
		endforeach;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_beforeMe" type="CM_VehicleVisitRecordDetail"/>
        <ReturnType type="CM_VehicleVisitRecordDetail"/>
    </JadeMethod>
