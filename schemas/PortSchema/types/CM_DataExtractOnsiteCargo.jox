    <JadeMethod name="initDataExtractFields_CustNum" id="538a154c-0ae6-4c91-b1c9-548f8faeeed3">
        <source>initDataExtractFields_CustNum(_fields : CM_DataExtractFieldSet input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2011	cnwkpd1	PAR #27436 - CCMS DCT 2073 - Product Transition Services
26 May 2011 cnwdz2  PAR #27598 Reviewed.
*/

vars
	fieldName	 : String;
	childField   : CM_DataExtractField; 
    colField     : CM_DataExtractCollectionField;
begin
	
	fieldName := CM_TrackedItem::allCustomsEntryNumbers.name;
	colField  := self.initDataExtractCollectionField(_fields, CM_Container, fieldName, "Customs Entry Number Details");
	
	fieldName := CM_TrackedItem.name&amp;"CustEntry";
	childField := self.initDataExtractField(null, String.name, null, fieldName, STRING, "Customs Entry Number", "Customs entry number", STRING, "Comma-separated customs entry numbers");	
	colField.extractOrder.add(fieldName);
	colField.allChildFields.add(childField);
	
epilog

end;</source>
        <Parameter name="_fields" type="CM_DataExtractFieldSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initDataExtractFields_Damage" id="27b32daa-5994-4f95-bcfa-bcecb51d7a64">
        <source>initDataExtractFields_Damage(_fields : CM_DataExtractFieldSet input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2011	cnwkpd1	PAR #27436 - CCMS DCT 2073 - Product Transition Services
26 May 2011 cnwdz2  PAR #27598 Reviewed.
//13 Oct 2022	navak20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
*/

vars
	fieldName		: String;
	childField   : CM_DataExtractField; 
    colField     : CM_DataExtractCollectionField;
begin
	
	fieldName := CM_TrackedItem::allDamageInstances.name;
	colField  := self.initDataExtractCollectionField(_fields, CM_DamageInstance, fieldName, "Damage Details");
	
	fieldName := CM_DamageInstance::getDamageDescrForLoc.name;
	childField := self.initDataExtractField(null, CM_DamageInstance.name, null, fieldName, STRING, "Damage Position", "Position of Damage", STRING, "One of the following: All, Left, Right, Bottom, Top, Back, Front");	
	colField.extractOrder.add(fieldName);
	colField.allChildFields.add(childField);
	
	fieldName := CM_DamageInstance::getDefCode.name;
	childField := self.initDataExtractField(null, CM_DamageInstance.name, null, fieldName, STRING, "Code", "Code of Damage", STRING, "No more than 10 characters and/or digits");	
	colField.extractOrder.add(fieldName);
	colField.allChildFields.add(childField);
	
	//fieldName := CM_DamageInstance::severity.name;	// 13.10.2022 navak20 TFS 53862
	fieldName := CM_DamageInstance::getSeverityLevel.name;	// 13.10.2022 navak20 TFS 53862
	childField := self.initDataExtractField(null, CM_DamageInstance.name, null, fieldName, INTEGER, "Severity", "Severity of Damage", INTEGER, INTEGER_POSSIBLEVAL);	
	colField.extractOrder.add(fieldName);
	colField.allChildFields.add(childField);
epilog

end;</source>
        <Parameter name="_fields" type="CM_DataExtractFieldSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initDataExtractFields_Default" id="2cf690eb-7fc0-4f44-a3f2-ee286048ff55">
        <source>initDataExtractFields_Default(_fields : CM_DataExtractFieldSet input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 May 2011	cnwkpd1	PAR #27436 - CCMS DCT 2073 - Product Transition Services
25 May 2011 cnwdw1  Reveiwed
*/

vars
	fieldName		: String;
	
begin
	fieldName := "id";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "id", fieldName, STRING, "ID", "Identification string for Cargo", STRING, "Valid JMT Cargo ID");

	fieldName := "cargoType";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "cargoType", fieldName, STRING, "Cargo Type", "Description from JMT Cargo Type", STRING, "Valid JMT Cargo Type description");

	//fieldName := "operatorCode";
	//self.initDataExtractField(_fields, CM_TrackedItem.name, "operatorCode", fieldName, STRING, "Operator", "Operator code", STRING, "Valid Operator code in JMT (4 characters maximum)");

	fieldName := "locationId";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "locationId", fieldName, STRING, "Location ID", "JMT location string for current position", STRING, "Valid JMT Yard location string");

	fieldName := "isoType";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "isoType", fieldName, STRING, "ISO Type", "JMT ISO Type code", STRING, "Valid JMT ISO Type (4 characters maximum)");

	fieldName := CM_TrackedItem::getImexStatusStrDesc.name;
	self.initDataExtractField(_fields, CM_TrackedItem.name, null, fieldName, STRING, "IMEX Status", "IMEX Status", STRING, "One of IMPORT/EXPORT/TRANSHIPMENT/STORAGE");

	fieldName := "myVoyage";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "myVoyage", fieldName, STRING, "Voyage", "Voyage code", STRING, "Valid JMT Voyage code (20 characters maximum)");

//	fieldName := "customsEntryNumber";
//	self.initDataExtractField(_fields, CM_TrackedItem.name, "customsEntryNumber", fieldName, STRING, "Customs Entry Number", "**** fill in with field description ****", STRING, "**** fill in with possible values description ****");

	fieldName := "customsDSK";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "customsDSK", fieldName, STRING, "DSK Number", "DSK Number", STRING, "Maximum 30 characters");

	fieldName := "customExportEntryNumber";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "customExportEntryNumber", fieldName, STRING, "Customs Export Delivery Order", "Customs Export Delivery Order", STRING, "");

	fieldName := "commodity";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "commodity", fieldName, STRING, "Commodity", "JMT Commodity code", STRING, "Valid JMT Commodity code (4 characters maximum)");

	fieldName := "commodityGroup";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "commodityGroup", fieldName, STRING, "Commodity Group", "JMT Commodity Group code", STRING, "Valid JMT Commodity Group code (4 characters maximum)");

	fieldName := "transitStatus";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "transitStatus", fieldName, STRING, "Transit Status", "The status of cargo that is staying on board, but may need to be moved", STRING, "Double Lift Restow, Shift On Board, Unknown Transit");

	fieldName := "isHazardous";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "isHazardous", fieldName, BOOLEAN, "Is Hazardous", "Flag to indicate the cargo is Hazardous", BOOLEAN, BOOLEAN_POSSIBLEVAL);

	fieldName := "isOverDimensions";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "isOverDimensions", fieldName, BOOLEAN, "Is Over Dimensions", "Flag to indicate the cargo is Over Dimension", BOOLEAN, BOOLEAN_POSSIBLEVAL);

	fieldName := "companyCode";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "companyCode", fieldName, STRING, "Business Unit", "The Business Unit for invoicing purposes", STRING, "A valid Invoicing Business Unit");

	fieldName := "length";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "length", fieldName, INTEGER, "Length", "Length of the cargo", INTEGER, INTEGER_POSSIBLEVAL);

	fieldName := "height";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "height", fieldName, INTEGER, "Height", "Height of the cargo", INTEGER, INTEGER_POSSIBLEVAL);

	fieldName := "width";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "width", fieldName, INTEGER, "Width", "Width of the cargo", INTEGER, INTEGER_POSSIBLEVAL);

	fieldName := "site";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "site", fieldName, STRING, "Site (Current)", "The current site status of the container", STRING, "On site, Off site, TBA, On ship or Undefined");

	fieldName := "plannedSite";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "plannedSite", fieldName, STRING, "Site (Planned)", "The next planned site of the container", STRING, "On site, Off site, TBA, On ship or Undefined");

	fieldName := "plannedState";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "plannedState", fieldName, STRING, "Planned State", "The current state the container is registered as", STRING, "Undefined, Archived, Normal, Ghost, Prenotified, Off Site, On Ship, Deleted, EDI or TBA");

	fieldName := "state";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "state", fieldName, STRING, "State", "The current state the container is registered as", STRING, "Undefined, Archived, Normal, Ghost, Prenotified, Off Site, On Ship, Deleted, EDI or TBA");

	fieldName := "receiptTransportMode";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "receiptTransportMode", fieldName, STRING, "Receipt Transport Mode", "How the container was received into the terminal", STRING, "Road, Rail, Ship");

	fieldName := "isSecureExport";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "isSecureExport", fieldName, BOOLEAN, "Is Secure Export (SEP)", "True if the consignor is a secure export partner", BOOLEAN, BOOLEAN_POSSIBLEVAL);

	fieldName := "consignorVoyageCode";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "consignorVoyageCode", fieldName, STRING, "Consignor Voyage Code", "Voyage code as entered by the consignor", STRING, "Maximum 20 characters");

	fieldName := "carrier";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "carrier", fieldName, STRING, "Receipt Carrier", "The road carrier delivering the container to the terminal", STRING, "Maximum 10 characters");

	fieldName := "wagon";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "wagon", fieldName, STRING, "Receipt Wagon", "The wagon id the container was delivered to the terminal on", STRING, "Maximum 20 characters");

	fieldName := "releasedDT";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "releasedDT", fieldName, TIMESTAMP, "Released Date/Time", "Date and time this container was released", TIMESTAMP, TIMESTAMP_POSSIBLEVAL);

	fieldName := "releasedTransportMode";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "releasedTransportMode", fieldName, STRING, "Released Transport Mode", "What transport the container left the terminal on", STRING, "Road, Rail, Ship");

	fieldName := "deliveryRelease";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "deliveryRelease", fieldName, STRING, "Delivery Release", "A users request number for a container", STRING, "Maximum 25 characters");

	fieldName := "releaseCarrier";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "releaseCarrier", fieldName, STRING, "Release Carrier", "The carrier code of the company picking up a container from a terminal", STRING, "Maximum 10 characters");

	fieldName := "releaseWagon";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "releaseWagon", fieldName, STRING, "Release Wagon", "The wagon id the container was released from the terminal on", STRING, "Maximum 20 characters");

	fieldName := "myCustomsAgent";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "myCustomsAgent", fieldName, STRING, "Customs Agent", "Customs Agent name related to the container", STRING, "Maximum 20 characters");

	fieldName := "alternativeId";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "alternativeId", fieldName, STRING, "Alternative Id", "Cargo's alternative ID", STRING, "Maximum 30 characters");

	fieldName := "clientRef";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "clientRef", fieldName, STRING, "Client Ref", "A free text field for a client reference numbers", STRING, "Maximum 30 characters");

	fieldName := "houseBillOfLading";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "houseBillOfLading", fieldName, STRING, "House Bill of Lading", "Forwarders bill on lading", STRING, "Maximum 20 characters");

	fieldName := "isAvailable";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "isAvailable", fieldName, BOOLEAN, "Is Available",  "True if an onsite container has no stops or todo tasks", BOOLEAN, BOOLEAN_POSSIBLEVAL);


epilog

end;</source>
        <Parameter name="_fields" type="CM_DataExtractFieldSet" usage="input"/>
    </JadeMethod>
