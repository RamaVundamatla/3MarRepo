    <JadeMethod name="doQtyRangeMapSetProxy" id="db1e984d-3099-4868-a0c1-f64816423132">
        <updating/>
        <source>doQtyRangeMapSetProxy(_updateController : CMIF_TranMapLinesController input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
//       AKB    21MAY2008     PAR 16415 CCMS 1029 30,45,53s
// ---------------------------------------------------------------------------

vars
	pxyQR : CM_QuantityRangeMap;
	methodName : String;
	i,j,key,l , methodIndex: Integer;
	ild : CM_InvoiceLineDesc;
	theTable : Table;
	theBank : CM_Bank;
	theQuantityRangeMap : CM_QuantityRangeMap;
	groupType			: CM_TranMapInvoiceLineGroupType;
	pxyMapping			: CM_TranMapInvoiceLineMapping;
	transferType		: CM_VoyageJobTransferType;
	vesselCategory		: HMS_VesselCategory;
	colAfterCheckBoxes	: Integer;
	showTransType,
	showVesselCat		: Boolean;

begin
	if self.myTranMapForm.myCurrentMapTM &lt;&gt; null then
		theBank := self.myTranMapForm.myCurrentMapTM.bank;
	else
		theBank := self.myTranMapForm.myCurrentMapTMVoyage.myBank;
	endif;
	theTable := self.tblLines;
	theQuantityRangeMap := self.myCurrentMapQuantityRange;
	pxyQR := _updateController.pxyQRMap;
	
	if self.myTranMapForm.myCurrentMapServiceBroker.isKindOf(CM_ResourceServiceBroker) then				// 18/6/18 MAP TFS38899
		showTransType := true;
		showVesselCat := true;
		colAfterCheckBoxes := 1;
	elseif self.myTranMapForm.myCurrentMapServiceBroker.isKindOf(CM_TransServiceBroker) then			// 16/4/18 MAP TFS37555
		if (self.myTranMapForm.myCurrentMapServiceBroker.CM_TransServiceBroker.className = CM_ReceiveShip.name
		or self.myTranMapForm.myCurrentMapServiceBroker.CM_TransServiceBroker.className = CM_ReleaseShip.name
		or self.myTranMapForm.myCurrentMapServiceBroker.CM_TransServiceBroker.className = CM_WorkOrderExtraTI.name) then // TFS 42221
			colAfterCheckBoxes := theTable.columns - 2;
			showTransType := true;
		else
			colAfterCheckBoxes := theTable.columns - 1;
		endif;
	endif;

	//### Populate the registeredMethods
	i := 1;
	methodIndex := 1;
	while i &lt; colAfterCheckBoxes do		// 22/3/18 MAP TFS37555
	
		methodIndex := self.getMethodIndex(i);
	
		theTable.column := i;
		j := 2;
		while j &lt;= theTable.rows do
			theTable.row := j;
			if theTable.text &lt;&gt; "0" then
				theTable.row := 1;
				pxyQR.allRegisteredMethods.add(self.allMethods[methodIndex]);
				break;
			endif;
			j := j + 1;
		endwhile;
		i := i + 1;
		 
	endwhile;

	i := 2;
	while i &lt;= theTable.rows do
		theTable.row := i;
		j := 1;
		methodIndex := 1;
		key := 0;
		while j &lt; colAfterCheckBoxes do		// 22/3/18 MAP TFS37555

			methodIndex := self.getMethodIndex(j);
			theTable.column := j;
			if theTable.text &lt;&gt; "0" then
				theTable.row := 1;
				methodName := self.allMethods[methodIndex];
				l := self.doSBMapGetMethodPos(pxyQR.allRegisteredMethods,methodName);
				key := key.bitOr(2^(l-1));
				theTable.row := i;
			endif;
			j := j + 1;
		endwhile;

		if showTransType then
			theTable.column := theTable.columns - 2;	// 22/3/18 MAP TFS37555
			transferType := theTable.accessCell(i, theTable.column).itemObject.CM_VoyageJobTransferType;
		endif;
		theTable.column := theTable.columns - 1;
		groupType := theTable.accessCell(i, theTable.column).itemObject.CM_TranMapInvoiceLineGroupType;
		
		theTable.column := theTable.columns;
		// TFS 40620 pxyQR.allInvoiceLineMaps.putAtKey(key, theBank.invoiceLineDescriptors[theTable.text]);
		ild := theTable.accessRow(theTable.row).itemObject.CM_InvoiceLineDesc;
		/* // TFS 40620
		if not pxyQR.allInvoiceLinesUsed.includes(ild) then
			pxyQR.allInvoiceLinesUsed.add(ild);
		endif;
		*/
		
		create pxyMapping transient;
		pxyMapping.update(key, ild, pxyQR, groupType, transferType, vesselCategory, null, null, null);
		
		i := i + 1;
	endwhile;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_updateController" type="CMIF_TranMapLinesController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doQtyRangeMapSetProxyBOL" id="c46c5032-6642-49b9-b285-585ad466b381">
        <updating/>
        <source>doQtyRangeMapSetProxyBOL( _updateController :CMIF_TranMapLinesController input ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars
	pxyQRM : CM_QuantityRangeMap;
	ild : CM_InvoiceLineDesc;
	idx : Integer;
	key	: Integer;
	theTable : Table;
	theBank : CM_Bank;
	theQuantityRangeMap : CM_QuantityRangeMap;
	
	groupType			: CM_TranMapInvoiceLineGroupType;
	pxyMapping			: CM_TranMapInvoiceLineMapping;
	transferType		: CM_VoyageJobTransferType;
	vesselCategory		: HMS_VesselCategory;
	showTransType,
	showVesselCat		: Boolean;

begin
	theBank := self.myTranMapForm.myCurrentMapTMBOL.myBank;
	theQuantityRangeMap := self.myCurrentMapQuantityRange;
	pxyQRM := _updateController.pxyQRMap;

	pxyQRM.allRegisteredMethods.clear;

	theTable := self.tblLines;
	theTable.row := 2;
	theTable.column := theTable.columns;

	foreach idx in 2 to theTable.rows do
		ild := theTable.accessRow(idx).itemObject.CM_InvoiceLineDesc;
		key := CM_WorkOrderServiceBroker.DEFAULT_INVOICELINE_KEY;

		if showTransType then
			theTable.column := theTable.columns - 2;	// 22/3/18 MAP TFS37555
			transferType := theTable.accessCell(idx, theTable.column).itemObject.CM_VoyageJobTransferType;
		endif;
		theTable.column := theTable.columns - 1;
		groupType := theTable.accessCell(idx, theTable.column).itemObject.CM_TranMapInvoiceLineGroupType;
		
		create pxyMapping transient;
		pxyMapping.update(key, ild, pxyQRM, groupType, transferType, vesselCategory, null, null, null);
	endforeach;

epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_updateController" type="CMIF_TranMapLinesController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doQtyRangeMapSetProxyEvent" id="ea8ef159-22a1-45e9-bde6-1e4565e5625c">
        <updating/>
        <source>doQtyRangeMapSetProxyEvent(_updateController :CMIF_TranMapLinesController input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		October 2007By Andrew Bishop cnwab1
//
// Purpose:		The mappings for IN and OUT are stored on the same QTy Range object
//
// ---------------------------------------------------------------------------

vars
	pxyQRM : CM_QuantityRangeMap;
	ild : CM_InvoiceLineDesc;
	idx : Integer;
	key	: Integer;
	theTable : Table;
	theBank : CM_Bank;
	theQuantityRangeMap : CM_QuantityRangeMap;
	iter : Iterator;
	groupType			: CM_TranMapInvoiceLineGroupType;
	pxyMapping			: CM_TranMapInvoiceLineMapping;
	transferType		: CM_VoyageJobTransferType;
	vesselCategory		: HMS_VesselCategory;
	showTransType,
	showVesselCat		: Boolean;

begin
	theBank := self.myTranMapForm.myCurrentMapTMEvent.myBank;
	theQuantityRangeMap := self.myCurrentMapQuantityRange;
	pxyQRM := _updateController.pxyQRMap;

	pxyQRM.allRegisteredMethods.clear;
// TFS 40620	pxyQRM.allInvoiceLineMaps.clear;

/* TFS 42221 neither of these if staements are ever going ot be true only  CM_EventServiceBroker
	if self.myTranMapForm.myCurrentMapServiceBroker.isKindOf(CM_ResourceServiceBroker) then		// 18/6/18 MAP TFS38899
		showTransType := true;
		showVesselCat := true;
	elseif self.myTranMapForm.myCurrentMapServiceBroker.isKindOf(CM_TransServiceBroker)
		and (self.myTranMapForm.myCurrentMapServiceBroker.CM_TransServiceBroker.className = CM_ReceiveShip.name
		or self.myTranMapForm.myCurrentMapServiceBroker.CM_TransServiceBroker.className = CM_ReleaseShip.name) then
			showTransType := true;
	endif;
*/
	theTable := self.tblLines;
	theTable.row := 2;
	theTable.column := theTable.columns;

	foreach idx in 2 to theTable.rows do
		ild := theTable.accessRow(idx).itemObject.CM_InvoiceLineDesc;
		key := CM_EventServiceBroker.DEFAULT_INVOICELINE_KEY;
		
// TFS 40620		pxyQRM.allInvoiceLineMaps.putAtKey(key, ild);

		if showTransType then
			theTable.column := theTable.columns - 2;	// 22/3/18 MAP TFS37555
			transferType := theTable.accessCell(idx, theTable.column).itemObject.CM_VoyageJobTransferType;
		endif;
		theTable.column := theTable.columns - 1;
		groupType := theTable.accessCell(idx, theTable.column).itemObject.CM_TranMapInvoiceLineGroupType;
		
		create pxyMapping transient;
		pxyMapping.update(key, ild, pxyQRM, groupType, transferType, vesselCategory, null, null, null);
	endforeach;

epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_updateController" type="CMIF_TranMapLinesController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doQtyRangeMapSetProxyVTMIS" id="fa3477b5-3e79-4bd4-89b7-db2786ba591e">
        <updating/>
        <source>doQtyRangeMapSetProxyVTMIS(_updateController :CMIF_TranMapLinesController input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		The mappings for IN and OUT are stored on the same Qty Range object
//
// ---------------------------------------------------------------------------

vars
	pxyQRM : CM_QuantityRangeMap;
	currKey	: Integer;
	ild : CM_InvoiceLineDesc;
	idx : Integer;
	key	: Integer;
	found	: Boolean;
	theTable : Table;
	theBank : CM_Bank;
	theQuantityRangeMap : CM_QuantityRangeMap;
	iter : Iterator;
	lineMapDict			: CM_TMInvLineMapByCargoAttrDict;
	groupType			: CM_TranMapInvoiceLineGroupType;
	lineMapping,
	pxyMapping			: CM_TranMapInvoiceLineMapping;
	transferType		: CM_VoyageJobTransferType;
	vesselCategory		: HMS_VesselCategory;
	cargotype : CM_CargoType;
	subtype : CM_Product;
	comm : CM_Commodity;
	showTransType,
	showVesselCat		: Boolean;

begin
	theBank := self.myTranMapForm.myCurrentMapTMVoyage.myBank;
	theQuantityRangeMap := self.myCurrentMapQuantityRange;
	pxyQRM := _updateController.pxyQRMap;

	pxyQRM.allRegisteredMethods.clear;
// TFS 40620	pxyQRM.allInvoiceLineMaps.clear;

	if self.myTranMapForm.myCurrentMapServiceBroker.isKindOf(CM_ResourceServiceBroker) then		// 18/6/18 MAP TFS38899
		//	TFS 41096 showTransType := true;
		showVesselCat := true;
		/*	TFS 41096
	elseif self.myTranMapForm.myCurrentMapServiceBroker.isKindOf(CM_TransServiceBroker)
		and (self.myTranMapForm.myCurrentMapServiceBroker.CM_TransServiceBroker.className = CM_ReceiveShip.name
		or self.myTranMapForm.myCurrentMapServiceBroker.CM_TransServiceBroker.className = CM_ReleaseShip.name) then
			showTransType := true;
			*/
	endif;

	theTable := self.tblLines;
	theTable.row := 2;
	theTable.column := theTable.columns;
	ild := theBank.invoiceLineDescriptors[theTable.text];

	foreach idx in 2 to theTable.rows do
		ild := theTable.accessRow(idx).itemObject.CM_InvoiceLineDesc;
		
		if self.myTranMapForm.myTMCContractIN &lt;&gt; null then
			key := CM_ResourceServiceBroker.INVOICELINE_KEY_IN_CONTRACT;
		else
			key := CM_ResourceServiceBroker.INVOICELINE_KEY_OUT_CONTRACT;
		endif;
		// TFS 40620 pxyQRM.allInvoiceLineMaps.putAtKey(key, ild);

		if showVesselCat then
			// ### TFS CR 65328 TASK 65329 06AUG2024 NAVAB1
			cargotype := theTable.accessCell(idx, 1).itemObject.CM_CargoType;
			subtype := theTable.accessCell(idx, 2).itemObject.CM_Product;
			comm := theTable.accessCell(idx, 3).itemObject.CM_Commodity;
			theTable.column := 4;						// 18/6/18 MAP TFS38899
			vesselCategory := theTable.accessCell(idx, theTable.column).itemObject.HMS_VesselCategory;
		endif;
		if showTransType then
			theTable.column := theTable.columns - 2;	// 22/3/18 MAP TFS37555
			transferType := theTable.accessCell(idx, theTable.column).itemObject.CM_VoyageJobTransferType;
		endif;
		theTable.column := theTable.columns - 1;
		groupType := theTable.accessCell(idx, theTable.column).itemObject.CM_TranMapInvoiceLineGroupType;

		create pxyMapping transient;
		pxyMapping.update(key, ild, pxyQRM, groupType, transferType, vesselCategory, cargotype, subtype, comm);
	endforeach;

	// go through the real object and put the opposite mappings into the pxy
	// code cleaned up for 30955 to get the correct mappings for the other contract type
	lineMapDict := theQuantityRangeMap.allTMInvoiceLineMappings;
	foreach lineMapping in lineMapDict do
		ild := lineMapping.myTMInvoiceLineDesc;
		currKey := lineMapping.mapValue;
		transferType := lineMapping.myTransferType;
		vesselCategory := lineMapping.myVesselCategory;
		
		
		// ### TFS CR 65328 TASK 65329 06AUG2024 NAVAB1
		cargotype := lineMapping.myCargoType;
		subtype := lineMapping.myCargoSubtype;
		comm := lineMapping.myCommodity;
		
		groupType := lineMapping.myTMInvoiceLineGroupType;
		found := false;
		if self.myTranMapForm.myTMCContractIN &lt;&gt; null then
			if currKey = CM_ResourceServiceBroker.INVOICELINE_KEY_OUT_CONTRACT then
				key := CM_ResourceServiceBroker.INVOICELINE_KEY_IN_CONTRACT;
				found := true;
			endif;
		else
			if currKey = CM_ResourceServiceBroker.INVOICELINE_KEY_IN_CONTRACT then
				key := CM_ResourceServiceBroker.INVOICELINE_KEY_OUT_CONTRACT;
				found := true;
			endif;
		endif;
		if found then
// TFS 40620			pxyQRM.allInvoiceLineMaps.putAtKey(currKey, ild);

			create pxyMapping transient;
			pxyMapping.update(currKey, ild, pxyQRM, groupType, transferType, vesselCategory, cargotype, subtype, comm);
		endif;
	endforeach;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_updateController" type="CMIF_TranMapLinesController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doQtyRangeMapSetProxyWorkOrder" id="df28b3a5-202c-4589-9ee2-ce89717e7eba">
