        <Parameter name="colNum" type="Integer"/>
        <Parameter name="gridArea" type="CM_GridArea"/>
        <ReturnType type="CM_GridController"/>
    </JadeMethod>
    <JadeMethod name="createRailOutPlanned" id="9fe7769f-b3c8-4ee2-8e02-b425b8e9cabf">
        <source>createRailOutPlanned( _wagon : CM_Wagon; _cargo : CM_TrackedItem );
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
13 June 2019	jlgndl1	Initial creation
10 July 2019	jlgzm1	TFS42863 MSL - Direct Release Between RORO Voyages and Rail - Break Bulk

*/

vars

	moveController : CMIF_MoveController;
	lc, tmpLC : CM_LocationsController;
	quantity : Integer;
	receiveWle : CM_WorkListEntry;
	req : CM_Request;

begin

	//default values
	lc := _wagon.allLocationsControllersArray.first();
	quantity := _cargo.totalQuantity;
	
	if self.opts.includesKey("TotalQuantity") then
		quantity := self.opts.int("TotalQuantity");
	endif;
	
	receiveWle := _cargo.getIncompleteRoadReceiveWle();
	if receiveWle = null then
		//check for a rail receive wle
		receiveWle := _cargo.getIncompleteRailReceiveWle();	
		if receiveWle = null then
			//check for a ship receive wle
			if _cargo.allLocations.isNotEmpty then		//tfs42863
				tmpLC := _cargo.allLocations.first();	//tfs42863
				if tmpLC.isVoyagePlanningLC() then
					req := tmpLC.getRequest(false);
					if req &lt;&gt; null then
						receiveWle := req.getFirstUnactionedWLE( PLANNING_MODE );
						if receiveWle = null then						//tfs42863
							receiveWle := req.allWorkListEntries.last;	//tfs42863
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	
	create moveController transient;
	
	if receiveWle &lt;&gt; null then
		moveController.setMyWorkListEntry(receiveWle);
		moveController.setJobForMove(receiveWle.job);	
	endif;
	
	moveController.setMoveMode( PLANNING_MODE );
	moveController.setMyTrackedItem( _cargo );
	moveController.setQuantity( quantity );
	moveController.setMyToPrimaryLocation( lc );
	if req &lt;&gt; null then													//tfs42863
		if req.isKindOf(CM_SlotRequest) then							//tfs42863
			moveController.mySlotRequest := req.CM_SlotRequest;			//tfs42863
		elseif req.isKindOf(CM_VoyageRequest) then						//tfs42863
			moveController.myVoyageRequest := req.CM_VoyageRequest;		//tfs42863
		endif;
	endif;
	
	while true do
		app.myTrxUA.trxMoveTrackedItemNewRailJob(moveController, app.myPassport);
		if  app.myPassport.trxCompletedOK then
			break;
		elseif app.myPassport.noErrors then
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		break;
	endwhile;
	
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "Failed to plan '" &amp; _cargo.id &amp; "' to '" &amp; _wagon.id &amp; "' - " &amp; app.myPassport.getErrorsAndWarningsAsString );

epilog

	delete moveController;

end;
</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_cargo" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createRepairReason" id="a398c720-3192-45d3-ad3b-e168566f73da">
        <source>createRepairReason(code,desc : String; isnot: Boolean) : CM_RepairReason;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2022	navds20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	pxyRR						: CM_RepairReason;
	drr,drrOld						: CM_RepairReason;
begin
	drrOld := self.getTerminal().allRepairReasons[code];
	self.deleteRepairReason(drrOld);
	
	create pxyRR transient;
	pxyRR.setProxy(code, desc, isnot, self.getTerminal());
	
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateRepairReason(pxyRR, drr, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return drr;
epilog
	delete pxyRR;
end;</source>
        <Parameter name="code" type="String"/>
        <Parameter name="desc" type="String"/>
        <Parameter name="isnot" type="Boolean"/>
        <ReturnType type="CM_RepairReason"/>
    </JadeMethod>
    <JadeMethod name="createReportTemplateFileType" id="3ba91cc5-819b-401e-bf53-aa9930e71138">
        <source>createReportTemplateFileType(_filter : CMQF_FilterReports; _templateName : String; _profName : String; _outputDest : Integer) : CM_ReportTemplate;

vars
	networkFilepath			: String;
	newUserReport			: CM_MenuUserReport;
	pxyReportTemplate		: CM_ReportTemplate;
	newReportTemplate		: CM_ReportTemplate;
	user					: CM_User;
	allUsersToGetOutput,
	allUsersWhoCanEdit		: CM_UserSet;
	
begin
	
	create pxyReportTemplate transient;

	user := app.getMyUser();
	networkFilepath := "";
	create allUsersToGetOutput transient;
	create allUsersWhoCanEdit transient;
	
	allUsersWhoCanEdit.add(user);
	allUsersToGetOutput.add(user);
	
	pxyReportTemplate.setForProxy(	_templateName,
									_templateName,
									_profName,
									null,
									networkFilepath,
									_outputDest,
									BGP_ReportRequest.Save,
									false,
									_filter,
									null, //self.myReportAgent.myQryReport,
									null,
									null,
									user,
									allUsersToGetOutput,
									allUsersWhoCanEdit,
                                    null,       //MTN-36668
									app.myPassport);
									
	
	app.myTrxCA.trxCreateReportTemplate(pxyReportTemplate, newReportTemplate, newUserReport, app.myPassport);

	return newReportTemplate;
epilog	
	delete pxyReportTemplate;
	delete allUsersToGetOutput;
	delete allUsersWhoCanEdit;
	
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports"/>
        <Parameter name="_templateName" type="String"/>
        <Parameter name="_profName" type="String"/>
        <Parameter name="_outputDest" type="Integer"/>
        <ReturnType type="CM_ReportTemplate"/>
    </JadeMethod>
    <JadeMethod name="createRoadJob" id="9488755d-2201-41c2-8282-c860f2fc543a">
        <source>createRoadJob(_truck : CM_Vehicle) : CM_RoadJob;

/*

Purpose:		Create a Road Job

Date			Who		Reason
12/02/2014		cnwmh5	Initial creation

*/

vars

	pxyRoadJob					: CM_RoadJob;
	roadJob						: CM_RoadJob;
	terminal					: CM_Terminal;
	
	strTermArea					: String;
	
begin

	terminal := self.getTerminal();

	strTermArea := terminal.getConfig(DefWarehouseArea).String.trimRight();

	create pxyRoadJob transient;
	pxyRoadJob.setProxyRoadJob(terminal,
		null,
		_truck.carrierCode,
		_truck.regNumber,
		null,
		strTermArea,
		false,
		true,
		null, 
		null, 
		null, 
		null); 
							
	app.myTrxCA.trxCreateRoadJob(pxyRoadJob, roadJob, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return roadJob;
	
epilog

	delete pxyRoadJob;

end;</source>
        <Parameter name="_truck" type="CM_Vehicle"/>
        <ReturnType type="CM_RoadJob"/>
    </JadeMethod>
