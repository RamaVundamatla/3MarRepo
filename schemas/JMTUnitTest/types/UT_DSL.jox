    <JadeMethod name="deleteDeliveryParty" id="cad1e0ec-e17a-49e7-b642-626699f33f4f">
        <source>deleteDeliveryParty(_code, _name : String; _terminal : CM_Terminal);
/*

Purpose:			Deletes a Delivery Party for the Unit test terminal and removes the default address

Parameters:			_code		String	Code used for Delivery Party
					_name		String	Name used for Delivery Party
					_terminal	String	Terminal to use for Delivery Party

Return Value:		NONE

Date		Who		Reason
08 July 2022	navpw1	Initial creation TFS: 53953

*/

vars
	deliveryParty : CM_DeliveryParty;
	
begin
	deliveryParty :=  _terminal.allDeliveryParties[_code];
	
	if deliveryParty = null then
		deliveryParty :=  _terminal.allDeliveryParties.getDeliveryPartyByName(_name);
	endif;
	
	self.assertNotNullMsg(deliveryParty, "Removing Delivery Party - Delivery Party");
	
	app.myTrxDA.trxDeleteDeliveryParty(deliveryParty, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
epilog

end;</source>
