    <JadeMethod name="handleNoColourException" id="20bd74b4-a81c-447e-af51-e1a318f14911">
        <source>handleNoColourException(_exc : Exception) : Integer;
// ---------------------------------------------------------------------------
// Created:     August 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

constants
	InvalidProperty	= 1011; 
	
vars
	returnVal		: Integer;
	
begin
	returnVal := Ex_Pass_Back;
	if _exc.errorCode = InvalidProperty then
		returnVal := Ex_Resume_Next;
	endif;


epilog
	return returnVal;
	

end;</source>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="populateForm" id="ea375388-6767-47dd-9cad-46f6e7733f99">
        <updating/>
        <source>populateForm() updating;
// adm 080609 Par 19637 defaultYACodeChanged
//26 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	criteria : CM_YACriteria;
	expiryTS : TimeStamp;
begin
	on Exception do self.handleBadCriteriaValue(exception);  //cnwrd1 par  19084 18.3.09
	
	defaultYACodeChanged	:= false;
//	self.populateIMEX();
	self.doIMEXSelected();
	self.populateOptions();
	
	if self.myYardAllocation &lt;&gt; null then
		self.populateCriteriaFrames(true);
	endif;

	if self.myProxyYA = null then
		return;
	endif;
	
	self.cmbYATemplate.setIndexFromObject( self.myProxyYA.myYATemplate );
	//self.doTemplateSelected( self.myProxyYA.myYATemplate ); //cnwrd1 par 19062 17.3.09 --  // purging trmplate critera after loading above??
	self.displayCriteriaDesc(); //cnwrd1 par 19062 17.3.09 ++
	
	if self.myProxyYA.checkIfDefaultYACode(self.txtYACode.text) then	
		defaultYACodeChanged	:= false;
	else
		defaultYACodeChanged	:= true;
	endif;
	self.txtYACode.text		:= self.myProxyYA.code;
	self.txtYADescription.text		:= self.myProxyYA.description;
	self.txtRemarks.text			:= self.myProxyYA.remarks;
	self.populateExpiryType( self.myProxyYA.expiryType );
	
	//26 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	expiryTS.cnEcSetDateAndTime(self.myProxyYA.expiryDate,TimeEndOfDay);
	self.dateExpiryDate.setDate(self.systemToLocalTime( expiryTS).date());
	//self.dateExpiryDate.setDate( self.myProxyYA.expiryDate );
	
	// cnwjk3 SFW1030
	//self.clrYAColour.setColor( self.myProxyYA.color );
	self.setIMEXDefaultColour();
	
	self.chkDisableYA.value			:= self.myProxyYA.isDisabled;

	if self.myProxyYA.remarks &lt;&gt; null then
		shtRemarks.caption := shtRemarks.caption &amp; " (*)";
	endif;

	//08 Oct 2013	NDL	Par 32456
//	if not self.isBulkEdit() then
//		self.shtLocation.visible := true;
//		self.populateLocations();
//	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resizeForRail" id="5db9d41a-aea4-411c-9dc9-71f2920ffef4">
        <updating/>
        <source>resizeForRail() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 September 2009	cnwndl1	Initial creation
28/11/2023			navkc1 Bug 60782: FR | 54089 EUP -Invoice Contracts - Criteria screen width issues
*/

vars

	criteriaFrame: CMUI_YACriteriaCntl;
	newHeight : Real;
	diff : Integer;
//	topOfLastControl : Real;
//	topOfNextControl : Real;
	
begin

/*	while true do
		index := index + 1;
		criteriaFrame := self.frmCriteria.getControl( index );
		if criteriaFrame = null then
			break;
		endif;
		if criteriaFrame.top &gt; topOfLastControl then
			topOfLastControl := criteriaFrame.top;
		endif;
	endwhile;
	
	topOfNextControl := topOfLastControl + self.frmCriteria.height + 8; */
	
	/*// 28/11/2023	navkc1 Bug 60782
	self.clrYAColour.top := self.picCriteria.height + self.frmCriteria.height + 10; 
	self.lblYAColour.top := self.clrYAColour.top; 
	*/
	
	self.clrYAColour.left := 157;
	self.lblYAColour.left := 22;
	
	//08 Oct 2013	NDL	Par 32456
	criteriaFrame := self.frmCriteria.getControl( 1 );
	if criteriaFrame &lt;&gt; null then
		self.lblYAColour.alignment := TextBox.Alignment_Left;
		self.lblYAColour.left := criteriaFrame.lblCriteriaType.left;	//10
		self.lblYAColour.width := criteriaFrame.lblCriteriaType.width; //118;
		self.clrYAColour.left := criteriaFrame.txtCriteriaValue.left;	//130;
		self.clrYAColour.width := criteriaFrame.txtCriteriaValue.width;	//181;
	endif;
	
	// 28/11/2023	navkc1 Bug 60782
	self.lblYAColour.parentBottomOffset := 10;
	self.clrYAColour.parentBottomOffset := 10;
	
	newHeight := self.lblYAColour.top + self.lblYAColour.height + 30 ;
	self.height := self.fldYardAlloc.top + newHeight + 80;
	self.fldYardAlloc.height := newHeight;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="saveData" id="343a5925-beb0-4110-a6a6-330cffe89b85">
        <updating/>
        <source>saveData(_saveAs: Boolean) : Boolean updating;

/*

Purpose:		Standard method to perform a "Save" operation.

Parameters:		None	

Return Value:	True if the save ws successful, otherwise false.


Date			Who		Reason
05 August 2008	consw1	Initial creation

*/
vars
	terminalObj				: CM_Terminal;
	yardAllocationObj		: CM_YardAllocation;
	proxyYAObj				: CM_RailAllocation;
	cmif_object : CMIF_Object;
	cmif_criteria : CMIF_YACriteriaPriority;
	pxyCriteria : CM_YACriteria;
	fillOptionIn			: Integer;
	fillOptionOut			: Integer;
	yaCode					: String;
	yaDescription			: String;
	yaRemarks				: String;
	expiryType				: Integer;
	expiryDate				: Date;
	allowOthers				: Integer;
	noLocation				: Integer;
	priorityAdj				: Integer;
	isTestOverstowWeight	: Boolean;
	isDisabled				: Boolean;
	allTransientCriteriaObj	: CMIF_Array;
	yaColor					: Integer;
	overstowRule			: CM_YAOverstowRule;
	blockGroupsInColl		: CM_YABlockGroupArray;
	blockGroupsOutColl		: CM_YABlockGroupArray;
	result					: Integer;
	createYA				: Boolean;
	mode					: Integer;

	wagon						: CM_Wagon;
	wagCode : String;
begin
	self.allWagons.rebuild();
	if self.allWagons.isEmpty then
		app.msgBox(app.getErrorString(Wagon_ColourCoding_Empty), app.getErrorString(NO_WAGONS_TO_UPDATE), MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	wagon := self.allWagons.first;
	if wagon &lt;&gt; null then
		wagCode := wagon.id;
	endif;
	
	proxyYAObj			:=	self.myProxyYA.CM_RailAllocation;

	create allTransientCriteriaObj transient;
	self.getCriteriaAllCMIF( allTransientCriteriaObj );
	
	foreach cmif_object in allTransientCriteriaObj do
		cmif_criteria := cmif_object.CMIF_YACriteriaPriority;
		pxyCriteria := cmif_criteria.myProxy.CM_YACriteria;
		pxyCriteria.setYardAllocation(proxyYAObj);
	endforeach;


	proxyYAObj.setProxy(wagCode,app.getErrorString(Rail_colour_coding),
								null,
								YAFillOption_InOrder,
								YAFillOption_InOrder,
								YAExpiryType_Never,
								null,
								self.clrYAColour.getColor(), 			//+ cnwmd1, CCMS 1067, Par 19710
								//0,//colour					//- cnwmd1, CCMS 1067, Par 19710
								null,  //cnwjo3 par 24145
								YAOverlap_Never,//allow others
								YANoLocation_Continue,
								null,
								0, //priority adjustment
								false,
								false,
								null,
								null,
								true,
								self.myTerminal);
								
								
	
	while true do
		app.myTrxUA.trxUpdateWagonRailAlloc(self.allWagons, proxyYAObj, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Rail_colour_coding), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		break;
	endwhile;
	
	self.unloadForm;
epilog	
end;</source>
        <Parameter name="_saveAs" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setYardAllocation" id="3df1a3fe-68c8-46f8-977f-99b962853e6e">
        <updating/>
        <source>setYardAllocation(_yas: ObjectArray) updating;

/*

Purpose:		This method will make transient proxies of the whole Yard Allocation
				structure (i.e. the Yard Allocation, the Location Blocks, and the
				Criteria) and store them on this form.  When the "Save" button is
				clicked, the original Yard Allocation object will be discarded, and
				the modified Yard Allocation structure will be persisted anew.

Parameters:		_yas - A collection of yard allocations to edit, if null then add a new ya
Return Value:	None


Date			Who		Reason
05 August 2008	consw1	Initial creation

*/
// adm 190509 Par 19238
vars
	ya, proxyObj		: CM_RailAllocation;
	blockGroupObj	: CM_YABlockGroup;
	isLoadSet		: Boolean;
	criteria		: CM_YACriteria;
	imex			: CM_YACriteria;
	proxyCriteria	: CM_YACriteria;
	imexStatus		: CM_IMEXStatus;
	yaIMEXConfig	: CM_YAIMEXConfig;
	criteriaType: CM_YACriteriaType;
	opCriteria: CM_YACriteriaArray;
begin
	self.doClearCurrentYA();

	if _yas = null then
		create proxyObj transient;
		create blockGroupObj transient;
		proxyObj.allYABlockGroupsIn.add(blockGroupObj);
		proxyObj.allYABlockGroupsOut.add(blockGroupObj);
		self.myProxyYA	:=	proxyObj;
		self.myProxyYA.setTerminal(self.myTerminal);
	elseif _yas.size = 1 then
		ya := _yas.first.CM_RailAllocation;
		proxyObj	:=	app.createUpdateProxy(ya).CM_RailAllocation;
		//  Also save off flag indicating if template criteria has been modified
		self.isTemplateModified := ya.isTemplateModified;
		self.myProxyYA			:=	proxyObj;
		self.myYardAllocation	:=	ya;
	else
		_yas.copy(self.allBulkEditYAs);
	endif;
	self.setCmbYATemplateBehaviour();
epilog
	delete opCriteria;
end;</source>
        <Parameter name="_yas" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="27fffdba-6964-46ef-baf3-a192abf941ca">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     26 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	
	self.resizeForRail();
	
	self.grpTemplate.visible := false;
	self.cmbIMEX.visible := false;
	self.lblHeader.visible := false;
	self.chkDisableYA.visible := false;
	self.btnFindImex.visible := false;
	self.shtLocation.visible := false;
	self.shtOptions.visible := false;
	self.txtGroupName.visible := false;
	self.lblGroupName.visible := false;
	self.txtImex.visible := false;
	self.btnNext.visible := false;
	self.lblRailYA.visible := true;
	self.btnSave.left := self.btnNext.left;
	self.setCaption(app.getErrorString(Rail_colour_coding));
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="dfab51d1-5d0c-485b-97b5-5a91dc0275ba">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0012243, locale);
	lblRailYA.translateCaption(Xlat_0012244, locale);
end;</source>
    </JadeMethod>
</GUIClass>
