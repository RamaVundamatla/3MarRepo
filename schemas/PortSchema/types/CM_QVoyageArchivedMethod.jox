    <JadeMethod name="getValueForObject" id="8585e045-0f7e-4ce0-95fb-f9fcd4686599">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 November 2011	cnwndl1	Initial creation	Par 28421

*/

vars

begin

	return _obj.sendMsg(self.propertyName).Integer;
	
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="9b73162a-1889-4f20-9cdc-c3d5cd7f8f72">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 November 2011	cnwndl1	Initial creation	Par 28421

*/

vars

	index : Integer;

begin

	_combo.clear();

	index := _combo.addItem( app.getErrorString(No) );
	_combo.itemData[index] := MsgBox_Return_No;
	
	index := _combo.addItem( app.getErrorString(Yes) );
	_combo.itemData[index] := MsgBox_Return_Yes;

epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="a978445c-27ec-47ba-95a9-acae1b43fca9">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 November 2011	cnwndl1	Initial creation	Par 28421

*/

vars

	strObj : CM_String;
	idx : Integer;

begin

	_tbl.purgeTableObjects();
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;
	
	create strObj transient;
	strObj.string := app.getErrorString(No);
	if _operator.CM_QIntegerIsOneOf.allSelectionValues.includes(MsgBox_Return_No) then
		idx := _tbl.addItem( 1.String &amp; Tab &amp; strObj.string );
	else
		idx := _tbl.addItem( 0.String &amp; Tab &amp; strObj.string );	
	endif;
	_tbl.accessRow(idx).itemObject := strObj;
	_tbl.row := idx;
	_tbl.change(_tbl);
	
	create strObj transient;
	strObj.string := app.getErrorString(Yes);
	if _operator.CM_QIntegerIsOneOf.allSelectionValues.includes(MsgBox_Return_Yes) then
		idx := _tbl.addItem( 1.String &amp; Tab &amp; strObj.string );
	else
		idx := _tbl.addItem( 0.String &amp; Tab &amp; strObj.string );	
	endif;
	_tbl.accessRow(idx).itemObject := strObj;
	_tbl.row := idx;
	_tbl.change(_tbl);
	
epilog

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="0501e61e-b449-4b23-8c3d-48e6cf6127be">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 November 2011	cnwndl1	Initial creation	Par 28421

*/

vars
	str		: String;
	numRows,
	idx		: Integer;
	ia		: IntegerArray;

begin
	create ia transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			str := _tbl.accessCell(idx, 2).text;
			ia.add(self.translateToSearchValue(str).Integer);
		endif;
	endforeach;
	
	_op.setSearchValue(ia);
	
epilog
	delete ia;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="936f62c2-9297-4c0e-a8a0-e13147cfc9e0">
        <source>translateToDisplayValue(_value: Any): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 November 2011	cnwndl1	Initial creation	Par 28421

*/

vars

	intValue : Integer;

begin

	intValue := _value.Integer;
	
	if intValue = MsgBox_Return_No then
		return app.getErrorString(No);
	elseif intValue = MsgBox_Return_Yes then
		return app.getErrorString(Yes);
	endif;
	
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="6f0ebe8a-2006-4325-a150-c5064a507531">
        <source>translateToSearchValue(_value: Any): Any;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02/11/2011	cnwndl1	Initial creation	Par 28421
*/

vars
	strValue : String;

begin
	strValue := _value.String;
	
	if strValue = app.getErrorString(No) then
		return MsgBox_Return_No;
	elseif strValue = app.getErrorString(Yes) then
		return MsgBox_Return_Yes;
	endif;
	
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
