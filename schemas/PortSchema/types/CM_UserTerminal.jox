    <JadeMethod name="getMyTerminal" id="ef2949d3-bfd8-4f48-8a86-9033057d5d0d">
        <source>getMyTerminal() : CM_Terminal;
// ---------------------------------------------------------------------------
// Created:     05 January 2007 by cnwrs2
//
// Purpose:     Returns the scenario CM_TerminalScenario if in scenario mode.
//				User getRealTermianl if you always want the real one.
// ---------------------------------------------------------------------------
vars

begin

	return self.myTerminal;

end;</source>
