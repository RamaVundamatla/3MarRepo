    <JadeMethod name="setTextForDisplayCollection" id="e0aa3252-ad24-488f-916f-d6667450be0e">
        <updating/>
        <source>setTextForDisplayCollection(_text : String) updating;
// ---------------------------------------------------------------------------
// Created:     02 March 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.clear();//added by cnwyl1 
	self.text := _text;
	self.myObject := null;
	self.init();
end;
</source>
        <Parameter name="_text" type="String"/>
    </JadeMethod>
    <JadeMethod name="validate" id="8d474999-f0b0-462d-a8e7-d8187abbe6b3">
        <updating/>
        <source>validate(keyValue: Any; _textStr: String io) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     28 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx		: Integer;
	coll	: Collection;
	tmpObj	: Object;
	str		: String;
	
begin

	if keyValue = null then
		return false;
	endif;

	str := keyValue.String;
	coll := self.getCollectionJMT();

	if coll = null then
		return false;
	endif;

	// do toUpper search first as usually looking for a code
	tmpObj := coll.MemberKeyDictionary[str.toUpper()];

	if tmpObj = null then
		tmpObj := coll.MemberKeyDictionary[str];
	endif;
	self.myObject := tmpObj;
	if tmpObj = null then
		return false;
	else
		_textStr := self.displayEntry(self, tmpObj, idx);
	endif;
	
	return true;
	
end;</source>
        <access>protected</access>
        <Parameter name="keyValue" type="Any"/>
        <Parameter name="_textStr" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="2b4b40e2-8acd-4f9b-9dca-97d52032ae30">
        <updating/>
        <source>windowCreated(cntrl: CMUI_ComboBoxObject input; persistCntrl: CMUI_ComboBoxObject) updating;
// ---------------------------------------------------------------------------
// Created:     24 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(cntrl, persistCntrl);
	
	cntrl.style	:= ComboBox.Style_DropDownComboList;
	
	// Par 9408
	cntrl.useManualDropDown	:= false;	//true;
	
	// ### TFS DEFECT 56495 10FEB2023 NAVAB1 - change style so that filtering works, this was noticed by Mason
	if not self.isInPainter then
		self.filterIgnore := app.doNotFIlterCombos;
		if not app.doNotFIlterCombos then
			self.style := ComboBox.Style_DropDown;
	
		endif;
	endif;

end;</source>
        <Parameter name="cntrl" type="CMUI_ComboBoxObject" usage="input"/>
        <Parameter name="persistCntrl" type="CMUI_ComboBoxObject"/>
    </JadeMethod>
    <JadeMethod name="zInit" id="856748f7-e748-417a-8557-0c86de251205">
        <updating/>
        <source>zInit() updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	pointerUpdated	: Boolean;
	savePointer		: Integer;
begin

	if self.amInitialised then
		return;
	endif;

	savePointer := app.mousePointer;
	if savePointer &lt;&gt; MousePointer_HourGlass then
		pointerUpdated := true;
		app.mousePointer := MousePointer_HourGlass;
	endif;

	self.init();

	self.amInitialised := true;

epilog
	if pointerUpdated then
		app.mousePointer := savePointer;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
