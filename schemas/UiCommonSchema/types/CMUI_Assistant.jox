        <source>comboBoxBooms(_combo : CMUI_ComboBox input; _canAdd :Boolean; _value : String);

/*
Date			Who		Reason
07 July 2009	cnwar2	Initial creation

*/
vars
	idx		: Integer;
	lstIdx	: Integer;
	boom	: CM_Boom;
	
begin
	_combo.clear;
	_combo.addItem("");
	
	//19 Mar 2019 NDL	TFS 43811 - remove add
	//if _canAdd then
	//	_combo.addItem(app.getErrorString(NewBoom));
	//endif;
	
	foreach boom in self.myTerminal.allBoomsByCode do
		idx := _combo.addItemObject(boom.description, boom);
