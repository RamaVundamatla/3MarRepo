<Class name="CM_LocationRestrictBulk" id="2c47bc73-517d-41cf-8acd-fed4a32fff53">
    <superclass name="CM_LocationRestriction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restrictions"/>
    <JadeMethod name="doesAllowType" id="fda86766-16f9-457a-a9f4-77ea32d5c760">
        <source>doesAllowType(_operator : CM_Operator;  _cargoType : CM_CargoType;  _product : CM_Product) : Boolean;

// Created:     R Barr 3/11/2006 Comalco (based on CM_LocationRestrictWarehouse)

begin

	return  ( allCargoTypes.isEmpty or  allCargoTypes.includes(_cargoType))
		and ( allProducts.isEmpty   or  allProducts.includes(_product));

end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_product" type="CM_Product"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="931ea5eb-807c-48a7-97d1-c1746ce5f044">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Created:     R Barr 3/11/2006 Comalco (based on CM_LocationRestrictWarehouse)
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 20/06/2022	navdap1		TFS 53362 EUP Master Data interface customers between TOS and ERP
vars
	operator		: CM_Operator;
	str				: String;
	cargoType		: CM_CargoType;
	product			: CM_Product;
	int				: Integer;
begin
	if _attrName = ETRow_Operator then
		operator :=  allOperators.first;
		if operator = null then
			return 'No Restriction';
		endif;
		if app.myRoot.getConfig(ComboByNameOperator).Boolean then	// TFS 53362
			return operator.description;							// TFS 53362
		else														// TFS 53362
			return operator.code;
		endif;														// TFS 53362

	elseif _attrName = ETRow_CargoType then
		if allCargoTypes.isEmpty then
			return 'No Restriction';
		endif;
		foreach cargoType in  allCargoTypes do
			str := str &amp; cargoType.description &amp; ', ';
		endforeach;
		return str;
	
	elseif _attrName = ETRow_Product then
		if allProducts.isEmpty then
			return 'No Restriction';
		endif;
			
		foreach product in  allProducts do
			str := str &amp; product.code &amp; ', ';
		endforeach;
		
		if str.length &gt; 2047 then  // bit large (max in hugeStrArray is 2047 so truncate. 
			str := str.truncatedAt(1000) &amp; '........'; // more managable
		endif;
		return str;
	endif;
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationController" id="84612c6f-4c70-42c5-94ec-6344dbc29da6">
        <source>getLocationController():CM_BulkLocation;

// Created:     R Barr 3/11/2006 Comalco

begin
	// Bulk Area has only one location controller
	return allLocationControllers.first.CM_BulkLocation;
end;
</source>
        <ReturnType type="CM_BulkLocation"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="0f021e23-f196-4096-8211-034e0f71e03e">
        <source>pxyCreateUpdateProxy(): SelfType;

// Created:     R Barr 3/11/2006 Comalco
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy	: CM_LocationRestrictBulk;
	completedOK		: Boolean;
	
begin
	proxy := inheritMethod;
	// allCargoTypes copied in inheritMethod
	allProducts.copy(proxy.allProducts);
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="767a378b-c468-4a7d-9e8e-0d48636c328f">
        <updating/>
        <source>setForCreate(proxy: CM_LocationRestrictBulk) updating;

// Created:     R Barr 3/11/2006 Comalco (based on CM_LocationRestrictWarehouse)

vars
	realBulkArea : CM_BulkArea;
begin
	allCargoTypes.clear();
	proxy.allCargoTypes.copy(allCargoTypes);

	allProducts.clear;
	proxy.allProducts.copy(allProducts);

	// set references
	realBulkArea := proxy.myTerminalArea.pxyGetRealObject.CM_BulkArea;
	setReferences(realBulkArea);

end;</source>
        <Parameter name="proxy" type="CM_LocationRestrictBulk"/>
    </JadeMethod>
    <JadeMethod name="setForCreateAuto" id="c3355097-6e20-4f81-89ec-fbd00cd56f79">
        <updating/>
        <source>setForCreateAuto(_ta: CM_TerminalArea; _trackedItem: CM_TrackedItem; _passport: CM_Passport input) updating;

// Created:     R Barr 3/11/2006 Comalco (based on CM_LocationRestrictWarehouse)

vars
	bulkItem	: CM_Bulk;
begin
	inheritMethod(_ta, _trackedItem, _passport);

	if (not CM_Bulk.hasInstance(_trackedItem)) then
		return;
	endif;
	
	bulkItem := _trackedItem.CM_Bulk;
	
	if bulkItem.myProduct &lt;&gt; null then
		allProducts.add(bulkItem.myProduct);
	endif;
	
end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="707cab82-5a65-4940-bbe8-2c3df13059ac">
        <updating/>
        <source>setForUpdate(proxy: CM_LocationRestrictBulk) updating;

// Created:     R Barr 3/11/2006 Comalco (based on CM_LocationRestrictWarehouse)

vars

begin
	
	allCargoTypes.clear();
	proxy.allCargoTypes.copy(allCargoTypes);

	allProducts.clear;
	proxy.allProducts.copy(allProducts);

end;</source>
        <Parameter name="proxy" type="CM_LocationRestrictBulk"/>
    </JadeMethod>
    <JadeMethod name="setId" id="75f06aeb-4e24-4f1b-86b2-0f0467fb8da5">
        <updating/>
        <source>setId(_terminalArea: CM_TerminalArea) updating, protected;

// Created:     R Barr 3/11/2006 Comalco -- there's only one location and restriction for a bulk area

begin
	id := "1";
end;
</source>
        <access>protected</access>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="bcfd0f2d-863f-4586-a985-77b2b60d2540">
        <updating/>
        <source>setProxy(_colour : Integer; _user, _comment	: String; _terminalArea : CM_TerminalArea; _allCargoTypes : CM_CargoTypeSet; _allProducts : CM_ProductSet) updating;

// Created:     R Barr 3/11/2006 Comalco (based on CM_LocationRestrictWarehouse)

begin

	 raiseExceptionIfNotTransient(method);
	 setId(_terminalArea);
	 setForProxyRestriction(_colour, _user, _comment);
	 myTerminalArea := _terminalArea;

	
	 allCargoTypes.clear();
	 if _allCargoTypes &lt;&gt; null then
		_allCargoTypes.copy( allCargoTypes);
	endif;
	
	 allProducts.clear();
	 if _allProducts &lt;&gt; null then
		_allProducts.copy( allProducts);
	endif;
end;</source>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_user" type="String"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_allCargoTypes" type="CM_CargoTypeSet"/>
        <Parameter name="_allProducts" type="CM_ProductSet"/>
    </JadeMethod>
    <JadeMethod name="setReferences" id="b1f1f42e-bea1-4d00-a582-43af7377921f">
        <updating/>
        <source>setReferences(_bulkArea : CM_BulkArea) updating;

vars
	bulk : CM_BulkLocation;
begin
	// watch out! transient proxy CM_LocationRestrictBulk references transient proxy CM_BulkArea, 
	// not the persistent CM_BulkArea, as set in pxyCreateUpdateProxy(), because we're going to update the proxy

	self.myTerminalArea := _bulkArea;
	bulk := self.getLocationController();
	
	if bulk = null and _bulkArea.myLocationsController &lt;&gt; null then
			self.allLocationControllers.add(_bulkArea.myLocationsController);		
		
	endif;
end;
</source>
        <Parameter name="_bulkArea" type="CM_BulkArea"/>
    </JadeMethod>
    <JadeMethod name="validate" id="a7541211-03c7-4dde-8e1d-efc64983f3c9">
        <source>validate();

// Created:     R Barr 3/11/2006 Comalco (based on CM_LocationRestrictWarehouse)

begin
	inheritMethod();
	 validateIsCompatible();
end;</source>
    </JadeMethod>
</Class>
