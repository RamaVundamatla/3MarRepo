	// Do nothing at this level.
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcSortCollection" id="6fc08a1d-c66f-409d-8ae9-f70db8e3427f">
        <source>cnEcSortCollection(	pDynaDictionaryObj:DynaDictionary io;
					pCollectionName:String;
					pAllSortKeys:CnEcSortKeyNameArray;
					pIsAllowDuplicates:Boolean):Boolean;
// --------------------------------------------------------------------------------
// Created:		13 March 2001 by cnwdad1
//
// Purpose:		This method will sort a collection by the keys specified in the
//				pAllSortKeys array.  If the collection is not a Dictionary, then
//				it cannot be sorted with this method.
//
// Parameters:	pDynaDictionaryObj - The dynamic dictionary to contain the sorted
//					collection members.
//				pCollectionName - The name of the collection attribute to be sorted.
//				pAllSortKeys - An array of CnEcSortKeyName objects identifying the
//					keys by which to sort the collection.
//				pIsAllowDuplicates - A flag to indicate whether duplicates are
//					allowed in the sort result.
//
// Returns:		True if the collection is successfully sorted, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/01/2002	cnwdad1		Removed check of whether the receiver is a Dictionary
//							(sub)class, and added a check for whether the property
//							is a dictionary (sub)class.
// --------------------------------------------------------------------------------
vars
	collectionObj	: Dictionary;
	sortKeyObj		: CnEcSortKeyName;
	propertyObj		: Property;

begin
	// Check that the property to sort is a collection Type.
	
	propertyObj		:=	self.class().getProperty(pCollectionName);
	
	if (not propertyObj.cnEcIsCollection()) then
		return false;
	endif;
	
	// Set up the dyna-dictionary membership and keys.
	
	collectionObj	:=	self.getPropertyValue(pCollectionName).Dictionary;
	pDynaDictionaryObj.setMembership(collectionObj.cnEcGetMemberClass());

	foreach sortKeyObj in pAllSortKeys do
		pDynaDictionaryObj.addMemberKey(sortKeyObj.keyName,
										sortKeyObj.isDescending,
										sortKeyObj.isCaseSensitive);
	endforeach;
	
	pDynaDictionaryObj.endKeys(pIsAllowDuplicates);
	
	// Copy the members of the collection to the dyna-dictionary.
	
	collectionObj.copy(pDynaDictionaryObj);
	
	return true;
end;</source>
        <Parameter name="pDynaDictionaryObj" type="DynaDictionary" usage="io"/>
        <Parameter name="pCollectionName" type="String"/>
        <Parameter name="pAllSortKeys" type="CnEcSortKeyNameArray"/>
        <Parameter name="pIsAllowDuplicates" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcWritePreviousMethods" id="b0c5f986-0342-413c-82e8-50ff0452639c">
        <source>cnEcWritePreviousMethods();
// --------------------------------------------------------------------------------
// Created:		10 March 2001 by cnwdad1
//
// Purpose:		Use this method for debugging to see where a method has been called
//				from.  The names of each method in the call stack will be written
//				to the JADE Interpreter Output Viewer window.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	callStackObj	: ProcessStackArray;
	methodCallObj	: MethodCallDesc;
	
begin
	create callStackObj transient;
	self.cnEcGetPreviousMethods(callStackObj);
	
	delete callStackObj.removeAt(1);			// Remove this method call (i.e. self).
	
	foreach methodCallObj in callStackObj do
		write methodCallObj.display();
	endforeach;
epilog
	callStackObj.purge();
	delete callStackObj;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcXMLGetTheAttributeValue" id="762000a9-2b5f-4563-bfa4-9cac9996d0f1">
        <source>cnEcXMLGetTheAttributeValue(pFormat : CnEcXmlFormat; pInput: CnEcXmlStructureInstance; pClassName:String; pAttributeName : String):String;

vars
	inputField1Obj		: CnEcXmlStructureInstance;
	formatClassObj		: CnEcXmlFormatClass;
	formatPropertyObj	: CnEcXmlFormatProperty;
	retValue			: String;
	
begin
	if pFormat = null or pFormat.formatName = CNEC_DEFAULT_FULL then
       	// see if we have a tag the same as the properties name
		inputField1Obj	:=	pInput.findStructure(pAttributeName);
	else
		// see if we have a tag by the name the property is mapped to in the format.
		formatClassObj	:=	pFormat.getFormatClass(pClassName);
		
		if formatClassObj &lt;&gt; null then
			formatPropertyObj	:=	formatClassObj.getFormatProperty(pAttributeName);
			
			if formatPropertyObj &lt;&gt; null then
				inputField1Obj	:=	pInput.findStructure(formatPropertyObj.tagName);
			endif;
		endif;
	endif;
	
	if inputField1Obj &lt;&gt; null then
		retValue	:=	inputField1Obj.tagData;
	endif;
epilog
	return retValue;
end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <Parameter name="pClassName" type="String"/>
        <Parameter name="pAttributeName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="reloadObjectCollections" id="d01527f0-ec4f-4282-95ed-e1b9296ece01">
        <updating/>
        <source>reloadObjectCollections(reloader : CnEcJadeDBUnloadReload input; textLine : String) updating;

// called by reloadJadeDB on THIRD pass through data only

// deals with, and sets values for: COLLECTIONS

vars
	prop				: Property;
	propType			: Type;
	propTypeString		: String;
	binaryField			: Binary;
	textField			: String;

	fieldLength			: Integer;
	tokenPos			: Integer;
	fieldPos			: Integer;
	fieldName			: String;
	fieldType			: String;
	fieldValue			: String;
	fieldBinary			: Binary;
	fieldAny			: Any;
	fieldColl			: Collection;
	match				: Boolean;
	processing			: Boolean; 
begin

	reloader.countInstances := reloader.countInstances + 1;

	tokenPos := 1;
	textLine.getNextToken(tokenPos);		// skip Class Name	
	textLine.getNextToken(tokenPos);		// skip Object Oid String

	processing := true;

	while processing do 

		fieldLength := textLine.getNextToken(tokenPos).Integer;		// get length of following field
		if fieldLength = 0 then										// an empty Instance
			return;
		endif;
		textField := textLine[tokenPos:fieldLength];				// get field for the length just got
		tokenPos := tokenPos + fieldLength;							// adjust tokenPos to end of this field
		fieldPos := 1;
		fieldName := textField.getNextToken(fieldPos);				// first token of field is the property name

	  	match := false;

	  	foreach prop in reloader.currentClassProperties do
	  		if fieldName = prop.getName then	  		
	  			match := true;
	  			break;
	  		endif; 
	  	endforeach;

	  	if match = true then 

 	  		fieldType := textField.getNextToken(fieldPos);
 	  		reloader.debugCollection := fieldType;
	  		if prop.getType.isKindOf(Class) then
	  			if prop.getType.isCollection then
	  				if prop.getType.isArray then
	  					propTypeString := Collection.name;
	  				else
	  					propTypeString := Collection.name;
	  				endif;
	  			else
	  				propTypeString := Reference.name;
	  			endif;
	  		else
	  			propTypeString := prop.getType.name;
	  		endif;

	  		if fieldType = propTypeString then

				if fieldType = Collection.name then 

					fieldColl := self.getPropertyValue(prop.getName).Collection;

					// handling a non exclusive collection where the object needs to be created 
					// first of all  - fixed to allow Emergency code to reload 10/97

					if fieldColl = null then

						create fieldColl as prop.getType.Class;
						self.setPropertyValue(prop.getName,fieldColl);

					endif;

		  			fieldValue := textField.getNextToken(fieldPos);
		  			while fieldValue &lt;&gt; '' do
			  			fieldAny := reloader.xref[fieldValue];
			  			if fieldAny = null then
			  				write 'Class ' &amp; reloader.currentClass.name &amp;', Collection ' &amp; prop.getName &amp; " couldn't find Oid " &amp; fieldValue;

			  			else
			  				if not fieldColl.includes(fieldAny) then
								fieldColl.add(fieldAny);
							endif;
							reloader.countCollections := reloader.countCollections + 1;

            			endif;
			  			fieldValue := textField.getNextToken(fieldPos);
			  		endwhile;

		  		endif;

	  		else // fieldType is not propTypeString
	  		endif;

  		else // no match
  		endif;

	endwhile;
end;</source>
        <Parameter name="reloader" type="CnEcJadeDBUnloadReload" usage="input"/>
        <Parameter name="textLine" type="String"/>
    </JadeMethod>
    <JadeMethod name="reloadObjectData" id="cf3231d3-a1aa-4819-8e8a-738f16345d62">
        <updating/>
        <source>reloadObjectData(reloader : CnEcJadeDBUnloadReload input; textLine : String) updating;

// called by reloadJadeDB on FIRST pass through data only

// sets REFERENCES to null (for now)
// ignores COLLECTIONS
// deals with, and sets values for:  ARRRAYS, and BINARIES/PRIMITIVES

vars
	prop				: Property;
	propTypeString		: String;
	binaryField			: Binary;
	textField			: String;
	arrayField			: String;
	fieldLength			: Integer;
	tokenPos			: Integer;
	fieldPos			: Integer;
	fieldName			: String;
	fieldType			: String;
	fieldValue			: String;
	fieldArray			: Array;
	arrayLength			: Integer;
	fieldAny			: Any;
	fieldConvert		: Any;
	arrayType			: String;
	nullAny				: Object;
	processing			: Boolean;
	match				: Boolean;
	strOffset			: String;
	strTemp				: String;
	intOffsetPos		: Integer;

begin
	reloader.countInstances := reloader.countInstances + 1;

	tokenPos := 1;
	textLine.getNextToken(tokenPos);		// skip Class Name	
	textLine.getNextToken(tokenPos);		// skip Object Oid String
	processing := true;

	while processing do 
		fieldLength := textLine.getNextToken(tokenPos).Integer;		// get length of following field
		if fieldLength = 0 then										// an empty Instance
			return;
		endif;
		textField := textLine[tokenPos:fieldLength];				// get field for the length just got
		tokenPos := tokenPos + fieldLength;							// adjust tokenPos to end of this field
		fieldPos := 1;
		fieldName := textField.getNextToken(fieldPos);				// first token of field is the property name
        reloader.debugField := fieldName;


	   		// now check to see if this field is still a property to reload 

	   		match := false;

	  		foreach prop in reloader.currentClassProperties do
	  			if fieldName = prop.getName then 
	  				match := true;
	  		   		break; 
	  		   	endif;
	  		endforeach;


			if match then 
		  		fieldType := textField.getNextToken(fieldPos);
		  		if prop.getType.isKindOf(Class) then
		  			if prop.getType.isCollection then
		  				if prop.getType.isArray then
		  					propTypeString := 'Array';
		  				else
		  					propTypeString := 'Collection';
		  				endif;
		  			else
		  				propTypeString := 'Reference';
		  			endif;
		  		else
		  			propTypeString := prop.getType.name;
		  		endif;
		  		if fieldType = propTypeString 
		  			// allow for limited reorg capability
		  			or (fieldType = 'BString' and propTypeString = 'String') 
		  		    or (fieldType = 'Integer' and propTypeString = 'String') 
		  		    or (fieldType = 'String'  and propTypeString = 'Integer')
		  		    or (fieldType = 'Date'    and propTypeString = 'String')
		  		    or (fieldType = 'Integer' and propTypeString = 'Decimal')
		  		    or (fieldType = 'Decimal' and propTypeString = 'Integer') then

		  			if fieldType = 'Reference' then
		  				self.setPropertyValue(prop.getName,nullAny);
			  		elseif fieldType = 'Collection' then
			  		elseif fieldType = 'Array' then
			  			arrayType := textField.getNextToken(fieldPos);
			  			if prop.isKindOf(CompAttribute) then
							fieldArray := self.getPropertyValue(prop.getName).Array;
			  			else
							fieldArray := self.getPropertyValue(prop.getName).Array;
							if fieldArray = null then
								create fieldArray as prop.getType.Class;
								self.setPropertyValue(prop.getName,fieldArray);
							endif;
			  			endif;
			  			while fieldPos &lt; textField.length do
							arrayLength := textField.getNextToken(fieldPos).Integer;		// get length of following field

						 	// need to allow for a null string as per a ABM fault  01/98

						 	if arrayLength &gt; 0 then
								arrayField := textField[fieldPos:arrayLength];				// get field for the length just got
							else
								arrayField := null;
							endif;

							fieldPos := fieldPos + arrayLength;
							if arrayType = 'BinaryArray' then
							elseif arrayType = 'BooleanArray' then
								fieldArray.add((arrayField[1].Character &lt;&gt; '0').Boolean);
							elseif arrayType = 'DateArray' then
								fieldArray.add(arrayField.Date);
							elseif arrayType = 'DecimalArray' then
								fieldArray.add(arrayField.Decimal);
							elseif arrayType = 'IntegerArray' then
								fieldArray.add(arrayField.Integer);
							elseif arrayType = 'RealArray' then
								fieldArray.add(arrayField.Real);
							elseif arrayType = 'StringArray' then
								fieldArray.add(arrayField.String);
							elseif arrayType = 'BStringArray' then
							elseif arrayType = 'TimeArray' then
								fieldArray.add(arrayField.Time);
							elseif arrayType = 'TimeStampArray' then
								fieldArray.add(arrayField.TimeStamp);
							endif;
			  			endwhile;
			  		else
	//		  			fieldValue := textField.getNextToken(fieldPos);
						if fieldPos &gt; textField.length then
							fieldValue := '';
			  			else
			  				fieldValue := textField[fieldPos:end].trimBlanks;
			  			endif;
				  		if fieldType = 'Binary' then

				  			// check and see what format is in the file .... it has been extended to 
				  			// allow for positioning in the binary file, thereby allowing records and 
				  			// attributes to be dropped without screwing up the load


							intOffsetPos := 1;
							strTemp := fieldValue.getNextToken(intOffsetPos);
							if strTemp &lt;&gt; fieldValue then

								// there is additional data...

							    strOffset := fieldValue[intOffsetPos:end].trimBlanks;
							    fieldValue := strTemp;

                                //  and position within the file

                                reloader.binaryFile.seek(strOffset.Integer);
                          	endif;

				  			binaryField := reloader.binaryFile.readBinary(fieldValue.length);
				  			if binaryField.String.Integer &lt;&gt; fieldValue.Integer then

								write   ' Binary field out of Synch(' &amp; fieldValue.length.String &amp; ') - ' &amp; reloader.currentClass.getName &amp; ' ' &amp; self.getOidString();
                   				write ' - text ' &amp; fieldValue &amp; '[' &amp; fieldValue.Integer.String &amp; ']' &amp;
				  		      ' binary ' &amp; binaryField.String &amp; '[' &amp; binaryField.String.Integer.String &amp; ']';
	//			  				fieldValue := binaryField.String;
				  			endif;
				  			binaryField := reloader.binaryFile.readBinary(1);			  					// skip the Forward Slash
				  			fieldAny := null;
				  			fieldAny := reloader.binaryFile.readBinary(fieldValue.Integer);
				  			binaryField := reloader.binaryFile.readBinary(1);		// skip the ending Space
				  		elseif fieldType = 'BString' then

				  			// check and see what format is in the file .... it has been extended to 
				  			// allow for positioning in the binary file, thereby allowing records and 
				  			// attributes to be dropped without screwing up the load


							intOffsetPos := 1;
							strTemp := fieldValue.getNextToken(intOffsetPos);
							if strTemp &lt;&gt; fieldValue then

								// there is additional data...

							    strOffset := fieldValue[intOffsetPos:end].trimBlanks;
							    fieldValue := strTemp;

                                //  and position within the file

                                reloader.binaryFile.seek(strOffset.Integer);
                          	endif;

				  			binaryField := reloader.binaryFile.readBinary(fieldValue.length);
				  			if binaryField.String.Integer &lt;&gt; fieldValue.Integer then
				  				write 'BString field out of Synch(' &amp; fieldValue.length.String &amp; ') - ' &amp; reloader.currentClass.getName &amp; ' ' &amp; self.getOidString();
				  				write ' - text ' &amp; fieldValue &amp; '[' &amp; fieldValue.Integer.String &amp; ']' &amp;
				  				      ' binary ' &amp; binaryField.String &amp; '[' &amp; binaryField.String.Integer.String &amp; ']';
	//			  				fieldValue := binaryField.String;
				  			endif;
				  			binaryField := reloader.binaryFile.readBinary(1);		// skip the Forward Slash
				  			fieldAny := reloader.binaryFile.readBinary(fieldValue.Integer);
				  			binaryField := reloader.binaryFile.readBinary(1);		// skip the ending Space
						else
							if fieldType = 'Integer' then 
								fieldAny := fieldValue.Integer;
							elseif fieldType = 'Boolean' then
								fieldAny := (fieldValue[1].Character &lt;&gt; '0').Boolean;
							elseif fieldType = 'String' then
								if prop.getLength &lt;&gt; Max_UnboundedLength and prop.getLength &lt; 540 and 
								 	(prop.getLength - 1) &lt; fieldValue.length then
								 	fieldAny:= fieldValue[1:(prop.getLength - 1)];
								else
									fieldAny := fieldValue;
								endif;
	//						elseif fieldType = 'Binary' then
	//							fieldAny := fieldValue;
							elseif fieldType = 'Character' then
								fieldAny := fieldValue[1].Character;
							elseif fieldType = 'Real' then
								fieldAny := fieldValue.Real;
							elseif fieldType = 'Date' then
								fieldAny := fieldValue.Date;
							elseif fieldType = 'Decimal' then
								fieldAny := fieldValue.Decimal;
							elseif fieldType = 'Time' then
								fieldAny := fieldValue.Time;
							elseif fieldType = 'TimeStamp' then
								fieldAny := fieldValue.TimeStamp;
							else
								fieldAny := fieldValue.Any;
							endif;
			 	 		endif;

			 	 		// now check out the new type  of the property... hopefully no-one is 
			 	 		// trying too much .... but we will do our best to convert

			 	 		if prop.getType = Integer  then
			 	 			fieldConvert := fieldAny.Integer;
						elseif prop.getType = Boolean then
							fieldConvert := fieldAny.Boolean;
						elseif prop.getType = String then
								fieldConvert := fieldAny.String;
	//						elseif fieldType = 'Binary' then
	//							fieldAny := fieldValue;
						elseif prop.getType = Character then
							fieldConvert := fieldAny.Character;
						elseif	prop.getType = Real then
							fieldConvert := fieldAny.Real;
						elseif prop.getType = Date then
							fieldConvert := fieldAny.Date;
						elseif prop.getType = Decimal then
							fieldConvert := fieldAny.Decimal;
						elseif prop.getType = Time then
							fieldConvert := fieldAny.Time;
						elseif prop.getType = TimeStamp then
						    fieldConvert := fieldAny.TimeStamp;
						else
							fieldConvert := fieldAny.Any;
						endif;

						self.setPropertyValue(prop.getName,fieldConvert);
			  		endif;
		  		else
		  		endif;


	  		else
	  		endif;

	endwhile; 
end;</source>
        <Parameter name="reloader" type="CnEcJadeDBUnloadReload" usage="input"/>
        <Parameter name="textLine" type="String"/>
    </JadeMethod>
    <JadeMethod name="reloadObjectReferences" id="ed3558c9-6253-4a3c-a3e8-d66f6f897564">
        <updating/>
        <source>reloadObjectReferences(reloader : CnEcJadeDBUnloadReload input; textLine : String) updating;

// called by reloadJadeDB on SECOND pass through data only

// deals with, and sets values for: REFERENCES

vars
	prop				: Property;
	propTypeString		: String;
	textField			: String;
	fieldLength			: Integer;
	tokenPos			: Integer;
	fieldPos			: Integer;
	fieldName			: String;
	fieldType			: String;
	fieldValue			: String;
	fieldAny			: Any;
	match				: Boolean;
	processing			: Boolean;
	
begin
	reloader.countInstances := reloader.countInstances + 1;

	tokenPos := 1;
	textLine.getNextToken(tokenPos);		// skip Class Name	
	textLine.getNextToken(tokenPos);		// skip Object Oid String

	processing := true;

	while processing do 

		fieldLength := textLine.getNextToken(tokenPos).Integer;		// get length of following field
		if fieldLength = 0 then										// an empty Instance
			return;
		endif;
		textField := textLine[tokenPos:fieldLength];				// get field for the length just got
		tokenPos := tokenPos + fieldLength;							// adjust tokenPos to end of this field
		fieldPos := 1;
		fieldName := textField.getNextToken(fieldPos);				// first token of field is the property name

	  	match := false;

	  	foreach prop in reloader.currentClassProperties do
	  		if fieldName = prop.getName then	  		
	  			match := true;
	  			break;
	  		endif; 
	  	endforeach;

	  	if match = true then 

 	  		fieldType := textField.getNextToken(fieldPos);
 	  		reloader.debugCollection := fieldType;
	  		if prop.getType.isKindOf(Class) then
	  			if prop.getType.isCollection then
	  				if prop.getType.isArray then
	  					propTypeString := Collection.name;
	  				else
	  					propTypeString := Collection.name;
	  				endif;
	  			else
	  				propTypeString := Reference.name;
	  			endif;
	  		else
	  			propTypeString := prop.getType.name;
	  		endif;

	  		if fieldType = propTypeString then
		  		if fieldType = Reference.name then
		  			fieldValue := textField.getNextToken(fieldPos);

		  			reloader.debugReference := fieldValue;
		  			fieldAny := reloader.xref[fieldValue];

		  			if self.getPropertyValue(prop.getName) = null then			  			
						self.setPropertyValue(prop.getName,fieldAny);
						reloader.countReferences := reloader.countReferences + 1;

					else
		  				write 'Class ' &amp; reloader.currentClass.name &amp;', Reference ' &amp; prop.getName &amp; ' [' &amp; fieldValue &amp;
		  					  '] already has ' &amp; self.getPropertyValue(prop.getName).String &amp; ' in it.';
					endif;

		  		elseif fieldType = Collection.name then 
		  			// leave for next pass through data
		  		endif;

	  		else // fieldType is not propTypeString
	  		endif;

  		else // no match
  		endif;

	endwhile;
end;</source>
        <Parameter name="reloader" type="CnEcJadeDBUnloadReload" usage="input"/>
        <Parameter name="textLine" type="String"/>
    </JadeMethod>
    <JadeMethod name="unloadObjectData" id="34c4400c-8a1c-45a3-8e1a-dde85c0e674b">
        <source>unloadObjectData(unloader : CnEcJadeDBUnloadReload input);

// called by unloadJadeDB
// deals with, and outputs values for:
//  ARRRAYS, and BINARIES/PRIMITIVES, COLLECTIONS, REFERENCES

constants
	FWDSLASH = 47;
	SPACE = 32;

vars
    prop				: Property;
    coll				: Collection;
    array				: Array;
    any					: Any;
    dataLength			: Binary;
    binaryLine			: Binary;
    binaryField			: Binary;
    textLine			: String;
    textField			: String;
    arrayField			: String;
    stringField			: String;
    propName			: String;
    intBinaryOffset		: Integer;
    darray				: DecimalArray;

begin
	unloader.countInstances := unloader.countInstances + 1;

	textLine := unloader.currentClass.getName &amp; ' ' &amp; self.getOidString() &amp; ' ';

  	foreach prop in unloader.currentClassProperties do

  		propName := prop.name;

   		if prop.getType.isKindOf(Class) then
   			if prop.getType.isCollection then
//   			if prop.isKindOf(CompAttribute) or prop.getType.isArray then
   				if prop.getType.isArray  and 
   				not	prop.getType.inheritsFrom(ObjectArray) then
					textField := prop.getName &amp; ' Array ' &amp; prop.getType.name &amp; ' ';
					array := self.getPropertyValue(prop.name).Array;
					if prop.getType.name = 'BinaryArray' then
						binaryLine := ''.Binary;
						if array &lt;&gt; null then
							foreach any in array do
								binaryField := any.String.Binary;
								dataLength := binaryField.length.String.Binary;
								binaryLine[binaryLine.length + 1 : dataLength.length] := dataLength;
								binaryLine[binaryLine.length + 1] := FWDSLASH;
								binaryLine[binaryLine.length + 1 : binaryField.length] := binaryField;
							endforeach;
							intBinaryOffset := unloader.binaryFile.currentOffset();
							unloader.binaryFile.writeBinary(binaryLine);
							textField := textField &amp; binaryField.length.String &amp; ' ' &amp; intBinaryOffset.String;
						endif;
					elseif prop.getType.name = 'BooleanArray' then
							if array &lt;&gt; null then
								foreach any in array do
									arrayField := any.Boolean.Integer.String;
									textField := textField &amp; arrayField.length.String &amp; '/' &amp; arrayField;
								endforeach;
							endif;
					elseif prop.getType.name = 'DateArray' then
							if array &lt;&gt; null then 
								foreach any in array do
									arrayField := any.Date.String;
									textField := textField &amp; arrayField.length.String &amp; '/' &amp; arrayField;
								endforeach;
							endif;
					elseif prop.getType.name = 'DecimalArray' then

						// altered - this was not casting to an array was not
						//  working and the code to setup array scale factor etc 
						// did not work  (PS - July 98)

						darray := self.getPropertyValue(prop.name).DecimalArray;

					 	if darray &lt;&gt; null then	
							foreach any in darray do
								arrayField := any.Decimal.String;
								textField := textField &amp; arrayField.length.String &amp; '/' &amp; arrayField;
							endforeach;
						endif;
					elseif prop.getType.name = 'IntegerArray' then
						if array &lt;&gt; null then
							foreach any in array do
								arrayField := any.Integer.String;
								textField := textField &amp; arrayField.length.String &amp; '/' &amp; arrayField;
							endforeach;
						endif;
					elseif prop.getType.name = 'ObjectArray' then
						if array &lt;&gt; null then
							foreach any in array do
								arrayField := any.Object.getOidString();
								textField := textField &amp; arrayField.length.String &amp; '/' &amp; arrayField;
							endforeach;
						endif;
					elseif prop.getType.name = 'RealArray' then
						if array &lt;&gt; null then
							foreach any in array do
								arrayField := any.Real.String;
								textField := textField &amp; arrayField.length.String &amp; '/' &amp; arrayField;
							endforeach;
						endif;
					elseif prop.getType.name = 'StringArray' then
						stringField := '';
						if array &lt;&gt; null then 
							foreach any in array do
								arrayField := any.String;
								stringField := stringField &amp; arrayField.length.String &amp; '/' &amp; arrayField;
							endforeach;
						endif;
						if unloader.unWriteReadable(stringField) then
							textField := prop.getName &amp; ' Array B' &amp; prop.getType.name &amp; ' ';
							binaryField := stringField.Binary;
							dataLength := binaryField.length.String.Binary;
							binaryLine := dataLength;
							binaryLine[binaryLine.length + 1] := FWDSLASH;
							binaryLine[binaryLine.length + 1 : binaryField.length] := binaryField;
							binaryLine[binaryLine.length + 1] := SPACE;

							intBinaryOffset := unloader.binaryFile.currentOffset();
							unloader.binaryFile.writeBinary(binaryLine);
							textField := textField &amp; binaryField.length.String &amp; ' ' &amp; intBinaryOffset.String;
						else
							textField := textField &amp; stringField;
						endif;
					elseif prop.getType.name = 'TimeArray' then
						if array &lt;&gt; null then
							foreach any in array do
								arrayField := any.Time.String &amp; '.' &amp; any.Time.milliSecond.String;
								textField := textField &amp; arrayField.length.String &amp; '/' &amp; arrayField;
							endforeach;
						endif;
					elseif prop.getType.name = 'TimeStampArray' then
						if array &lt;&gt; null then
							foreach any in array do
								arrayField := any.TimeStamp.String &amp; '.' &amp; any.TimeStamp.time.milliSecond.String;
								textField := textField &amp; arrayField.length.String &amp; '/' &amp; arrayField;
							endforeach;
						endif;
					else
						if array &lt;&gt; null then
							foreach any in array do
								arrayField := any.String;
								textField := textField &amp; arrayField.length.String &amp; '/' &amp; arrayField;
							endforeach;
						endif;
					endif;
   				else
					textField := prop.getName &amp; ' Collection ';
					coll := self.getPropertyValue(prop.name).Collection;

					// need to allow for the fact that the collection  may be a null 
					//reference at the moment

					if coll &lt;&gt; null then
						foreach any in coll do
							if app.isValidObject(any.Object) then
								textField := textField &amp; any.getOidString() &amp; ' ';
							endif;
						endforeach;
					endif;
				endif;
   			else
//				textField := prop.getName &amp; ' Reference ' &amp; self.getPropertyValue(prop.name).getOidString() &amp; ' ';
				any := self.getPropertyValue(prop.name);
				if app.isValidObject(any.Object) then
					textField := prop.getName &amp; ' Reference ' &amp; any.getOidString() &amp; ' ';
				else
					textField := prop.getName &amp; ' Reference 0.0' &amp; ' ';
				endif;
			endif;
			textLine := textLine &amp; textField.length.String &amp; '/' &amp; textField &amp; ' ';
		else     
			textField := prop.getName &amp; ' ' &amp; prop.getType.name &amp; ' ';
			any := self.getPropertyValue(prop.name);
			if prop.getType.name = 'String' then
				textField := textField &amp; any.String;
				if unloader.unWriteReadable(textField) then
					textField := prop.getName &amp; ' B' &amp; prop.getType.name &amp; ' ';
					binaryField := any.String.trimBlanks.Binary;
					dataLength := binaryField.length.String.Binary;
					binaryLine := dataLength;
					binaryLine[binaryLine.length + 1] := FWDSLASH;
					binaryLine[binaryLine.length + 1 : binaryField.length] := binaryField;
					binaryLine[binaryLine.length + 1] := SPACE;

					intBinaryOffset := unloader.binaryFile.currentOffset();
					unloader.binaryFile.writeBinary(binaryLine);
					textField := textField &amp; binaryField.length.String &amp; ' ' &amp; intBinaryOffset.String;

				endif;
			elseif prop.getType.name = 'Character' then
				if any.Character &lt;&gt; null then 
					textField := textField &amp; any.Character;
				else
					textField := textField &amp; " ";
				endif;

			elseif prop.getType.name = 'Binary' then
				binaryField := any.String.Binary;
				dataLength := binaryField.length.String.Binary;
				binaryLine := dataLength;
				binaryLine[binaryLine.length + 1] := FWDSLASH;
				binaryLine[binaryLine.length + 1 : binaryField.length] := binaryField;
				binaryLine[binaryLine.length + 1] := SPACE;

				intBinaryOffset := unloader.binaryFile.currentOffset();
				unloader.binaryFile.writeBinary(binaryLine);
				textField := textField &amp; binaryField.length.String &amp; ' ' &amp; intBinaryOffset.String;

			elseif prop.getType.name = 'TimeStamp' then
				textField := textField &amp; any.TimeStamp.String &amp; '.' &amp; any.TimeStamp.time.milliSecond.String;
			elseif prop.getType.name = 'Time' then
				textField := textField &amp; any.Time.String &amp; '.' &amp; any.Time.milliSecond.String;
			elseif prop.getType.name = 'Boolean' then
				textField := textField &amp; any.Integer.String;
			elseif prop.getType.name = 'Decimal' then
				textField := textField &amp; any.Decimal.String;

		//		textField[textField.length:1] := '[';
		//		textField := textField &amp; (prop.getLength - 1).String &amp; ',' &amp; prop.getScaleFactor.String &amp; '] ';
		//		textField := textField &amp; any.Decimal.String;
		//		textField := textField &amp; any.Integer.String;
			else
				textField := textField &amp; any.String;
			endif;
			textLine := textLine &amp; textField.length.String &amp; '/' &amp; textField &amp; ' ';

		endif;
    endforeach;
//    textLength := textLine.length.String;
//    textFile.writeLine(textLength &amp; '/' &amp; textLine);
//    textLength := textLine.length.String;
//    unloader.textFile.writeLine(textLine.length.String &amp; '/' &amp; textLine);

    unloader.textFile.writeLine(textLine);
    if textLine.length &gt; unloader.longestLine then
    	unloader.longestLine := textLine.length;
    endif;
end;</source>
        <Parameter name="unloader" type="CnEcJadeDBUnloadReload" usage="input"/>
    </JadeMethod>
    <JadeMethod name="xHandlerGetPropertyValue" id="65c0d7e6-f763-4056-afbc-407d35d1f52a">
        <source>xHandlerGetPropertyValue(pExceptionObj:Exception):Integer;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		If we're using the "getPropertyValue" method and wish to ignore an
//				exception if the requested property name was not valid, then we'll
//				using this handler to simply resume execution.
//
// Parameters:	pExceptionObj - The raised exception.
//
// Returns:		Resume Next if error 1011 is receiver, otherwise Pass Back to the
//				next handler in the stack.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	ERROR_1011	: Integer = 1011;

begin
	if pExceptionObj.errorCode = ERROR_1011 then
		return Ex_Resume_Next;
	else
		return Ex_Pass_Back;
	endif;
end;</source>
        <Parameter name="pExceptionObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
