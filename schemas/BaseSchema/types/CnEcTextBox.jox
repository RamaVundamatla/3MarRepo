    <JadeMethod name="controlNamePrefix" id="42ab50e8-a773-4c3c-8e2b-1b84bb9dd349">
        <source>controlNamePrefix(): String;
// --------------------------------------------------------------------------------
// Created:		18 November 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return "txt";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="2e772502-2f29-4bde-b927-dcbc91c273ec">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		01 February 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 28/02/2003	cnwdad1		Changed from setting background color with a global
//							constant to use the getSystemColor() method.
// --------------------------------------------------------------------------------
begin
	self.focusColor		:=	self.backColor;
	self.colorNoFocus	:=	self.backColor;
	
	self.show3D			:=	Control.Show3D_Use3D;
	self.selectionStyle	:=	TextBox.SelectionStyle_SelectAll;
//	self.backColor 		:= 	Window.Color_Window + CNEC_SYSTEM_COLOUR;		// cnwdad1 28/02/2003.
	self.backColor 		:= 	self.getSystemColor(Window.Color_Window);		// cnwdad1 28/02/2003.
	self.height			:=	20;
end;</source>
    </JadeMethod>
    <JadeMethod name="gotFocus" id="3672aa75-aed8-4226-8a74-9e735cfe9fa2">
        <updating/>
        <source>gotFocus(textbox: TextBox input) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(textbox);
	
	if self.isFocusColorUsed and self.backColor &lt;&gt; self.focusColor then
		self.colorNoFocus	:=	self.backColor;
		self.backColor		:=	self.focusColor;
	endif;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lostFocus" id="b0fc144b-4923-4f7e-b89e-15caba921049">
        <updating/>
        <source>lostFocus(textbox: TextBox input) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(textbox);
	
	if self.isFocusColorUsed and self.backColor &lt;&gt; self.colorNoFocus then
		self.backColor		:=	self.colorNoFocus;
	endif;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="readOnly" id="a5413f6e-fe99-4d97-abb3-734f147ed1a9">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>readOnly(set: Boolean; value: Boolean io) updating, mapping;
// --------------------------------------------------------------------------------
// Created:		01 February 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 31/10/2001	cnwdad1		Modified to only change (or reset) the background color
//							to that of a 3D Face where the readOnlyDefaultColor flag
//							not is also set.
// 28/02/2003	cnwdad1		Changed from setting background color with a global
//							constant to use the getSystemColor() method.
// 17/06/2003	cnwdad1		The background color of the receiver was not being
//							reset when the control's readOnly property was changed
//							from true to false.
// --------------------------------------------------------------------------------
begin
	if isTransient() = true then
		if set then
			inheritMethod(set, value);
			
			if app.getName() = "Jade" then
				if value then
					if (not self.isReadOnlyDefaultColor) then
// cnwdad1 31/10/2001 - Don't change (or reset) the background color.
//						backColor	:=	Window.Color_Window + CNEC_SYSTEM_COLOUR;
//						tabStop		:=	true;
//					else
//						backColor	:=	Window.Color_3DFace + CNEC_SYSTEM_COLOUR;		// cnwdad1 28/02/2003.
						backColor	:=	self.getSystemColor(Window.Color_3DFace);		// cnwdad1 28/02/2003.
						tabStop		:=	false;
					endif;
				else
					backColor	:=	self.getSystemColor(Window.Color_Window);		// cnwdad1 17/06/2003.
					tabStop		:=	true;											// cnwdad1 17/06/2003.
				endif;
			else
				if value then
					//backColor	:=	Gray;											// cnwdad1 02/08/2007.
					backColor	:=	self.getSystemColor(Window.Color_3DFace);		// cnwdad1 02/08/2007.
					tabStop		:=	false;
				else
					//backColor	:=	White;											// cnwdad1 02/08/2007.
					backColor	:=	self.getSystemColor(Window.Color_Window);		// cnwdad1 02/08/2007.
					tabStop		:=	true;
				endif;
			endif;

			// Make sure that a repaint is done.
			self.refresh();
		else
			inheritMethod(set, value);
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="b8e3cba6-c9ed-4f33-ad24-6072c1e52708">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// -----------------------------------------------------------------------------
// Created:		26 November 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	inheritMethod(cntrl, persistCntrl);
	
	if self.isRequired then
		self.autoRedraw	:=	true;
		self.drawSolidRectangle(self.clientWidth()-4, 0, self.clientWidth(), 4, Red);
	endif;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
