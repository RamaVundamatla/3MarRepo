<Class name="CM_AuditLog" id="e6380ca0-bdd9-4a7f-a864-617038062d17">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>NFS 3798: This class is to capture edits made to bulk releases.
If the audit object stuff for the new gate works out, I expect
this class will not last too long !</text>
    <DbClassMap file="transact"/>
    <PrimAttribute name="dateTime" id="0d8857d0-7f1b-4e8b-8463-a8831b12fd48">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <CompAttribute name="logDetail" id="dc75d047-d1f9-4312-a412-0d8a519926b8">
        <type name="StringArray"/>
    </CompAttribute>
    <ExplicitInverseRef name="logDetails" id="9d7c8e9f-3af9-455c-8086-5b12777818b0">
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Strings"/>
        <Inverse name="CM_Strings::myObject"/>
    </ExplicitInverseRef>
    <PrimAttribute name="userCode" id="e2ab969c-2a26-4944-845e-b8df80615baa">
        <length>11</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="addLogDetail" id="d2dc52dd-f6b5-4a76-8708-2bb54453f7a6">
        <updating/>
        <source>addLogDetail(str : String) updating;
/*

Date		Who		Reason
06 Jul 2015	cnwkpd1	PAR #36578 - Tidy up leaked CM_Strings objects
	
*/

vars

begin
	if logDetails = null then
		if self.isTransient then
			create logDetails transient;
		else
			create logDetails persistent;
		endif;
	endif;
	logDetails.add(str);
end;</source>
        <Parameter name="str" type="String"/>
    </JadeMethod>
    <JadeMethod name="delete" id="7f0f1aac-52c7-4be7-86b6-f475d4decd5a">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jul 2015	cnwkpd1	PAR #36578 - Clean up leaked CM_Strings objects


*/

vars

begin
	delete self.logDetails;
	
epilog

end;</source>
    </JadeMethod>
</Class>
