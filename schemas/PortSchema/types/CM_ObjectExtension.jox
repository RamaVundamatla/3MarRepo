<Class name="CM_ObjectExtension" id="991c3b25-7362-46cb-9b79-f3b824e52f66">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmextension"/>
    <ExplicitInverseRef name="allStateData" id="92872c6f-7f43-4395-a3ff-5c7b93dd261c">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_StateDataDict"/>
        <access>readonly</access>
        <Inverse name="CM_StateData::myParent"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="myCMObject" id="337f36cc-5955-43bd-bac4-36be110a927b">
        <embedded/>
        <type name="CM_Object"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ExplicitInverseRef name="myRoot" id="f740641d-adde-4ee9-860c-8f729776d51e">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Root"/>
        <access>readonly</access>
        <Inverse name="CM_Root::allCMObjectExtensions"/>
    </ExplicitInverseRef>
    <JadeMethod name="delete" id="9e986d2e-73a0-4ef2-ae85-72ab0ab6a879">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Feb 2012	cnwkpd1	CCMS SFW 1223 - delivery mechanisms

*/

vars
	
begin
	// Need to manually maintain the proxy manager collection of object extensions for transients
	if self.isTransient then
		if app.myProxyManager &lt;&gt; null then
			app.myProxyManager.allCMObjectExtensions.removeIfPresent(self);
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getValue" id="b9ec0538-9f1d-49e9-9b22-748aac9a298e">
        <source>getValue(_key : String) : Any;
/*

Purpose:			Get the value for the passed in key

Parameters:			Unique key of the value required

Return Value:		Value attached (if any)

Date		Who		Reason
27 Sep 2011	cnwkpd1	PAR #28262 - CCMS 1223 - Delivery Mechanisms

*/

vars
	returnVal		: Any;
	
begin
	global.getExtraData(self.allStateData, _key, returnVal);
	
	return returnVal;
		
epilog

end;</source>
        <Parameter name="_key" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="e639f55a-6d4a-4472-9cd7-5b56ea6b25b7">
        <updating/>
        <source>setForCreate(_owner : CM_Object) updating;
/*

Purpose:			Set the owner object and root for a newly created extension

Parameters:			Owner object

Return Value:		None

Date		Who		Reason
27 Sep 2011	cnwkpd1	PAR #28262 - CCMS 1223 - Delivery Mechanisms
23/02/2012	cnwcs5	Par 29158 - CCMS CPL 2086 - Allow transients to have object extensions 
*/

vars
	root		: CM_Root;
	proxyMgr	: CM_ProxyManager;
begin
	if self.isTransient then
		// par 29158 - for transients object extensions are stored on the proxy manager.
		// this means they can only have values within the scope of the JMT application.
		proxyMgr := app.myProxyManager;
		
		if proxyMgr = null then
			app.raiseUnexpectedProgramError(class.name, method.name, "No CM_ProxyManager object");
		endif;
		
		self.myCMObject := _owner;
		
		// the collection on CM_ProxyManager is manually maintained
		proxyMgr.allCMObjectExtensions.add (self);
	else
		// Must work outside of normal application context
		root := app.myRoot;
		
		if root = null then
			root := CM_Root.firstInstance();
			if root = null then
				app.raiseUnexpectedProgramError(class.name, method.name, "No CM_Root object");
				return;
			endif;
		endif;
		
		self.myCMObject := _owner;
		self.myRoot 	:= root;
	endif;
epilog

end;</source>
        <Parameter name="_owner" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setValue" id="94386cd5-484c-40c8-960e-d2110a158c48">
        <source>setValue(_key : String; _value : Any);
/*

Purpose:			set the value for the passed in key

Parameters:			Unique key and the value required

Return Value:		None

Date		Who		Reason
27 Sep 2011	cnwkpd1	PAR #28262 - CCMS 1223 - Delivery Mechanisms

*/

vars
	stateData		: CM_StateData;
	
begin
	// For the Object Extension mechanism, there is a special requirement to tidy up - if the 
	// value to be set is null, then just delete the State Data for this key, rather than update it
	if _value = null then
		stateData := self.allStateData[_key];
		if stateData &lt;&gt; null then
			delete stateData;
		endif;
	else
		global.setExtraData(self.allStateData, self, _key, _value);
	endif;	
		
epilog

end;</source>
        <Parameter name="_key" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
</Class>
