    <JadeMethod name="convertToRelease" id="008b5031-835b-4762-a343-685a16da4392">
        <updating/>
        <source>convertToRelease( _reason : String) updating;
//--------------------------------------------------------------
//Created: 12 February 2003 By: cnwgd1
//--------------------------------------------------------------
// 10/09/2009 	cnwcs5	ccms 1061 - create vehicle visit record detail for the turnaround
// 18 Jun 2013	cnwcs5	par 31670 - new _context parameter for createVehicleVisitDetail method
vars
	visit	:CM_VehicleVisitRecord;
begin

	if (not self.isUnactionedTIReceipt) or
	   (not self.allRTQueueEntries.isEmpty) then
		app.raiseCMException1(ERR_TURNAROUND, self.id, null, null);
		return;
	endif;
	
	// Creates a new release request and wle as a turnaround job
	self.myRequest.convertToRelease();
	
	// complete as new request and wle has been created above.
	// self.myRequest no longer has a tracked item
	// so I'm now a TI receipt without a TI to work.
	// Maybe I should just be erase but that will get sorted out when status updated
	// self.job.rebuildStatus gets called from the utility layer and will update my status there
	
	// create a vehicle visit record for the turnaround
	if self.job.isRoadJob then
		visit := self.job.CM_RoadJob.myVehicleVisit;
		
		if visit &lt;&gt; null then
			visit.createVisitRecordDetail (VisitRecord_Turnaround, _reason, null); // par 31670 cnwrd1 par 22624 3.5.2010
		endif;
	endif;	
end;</source>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
    <JadeMethod name="createSystemAlert" id="14290b22-3fc8-48d4-ac62-ad88c62bf666">
        <source>createSystemAlert(_oldStatus : Integer; _oldStatusString : String);
//--------------------------------------------------------------
//Created: 27 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	alert : CM_SystemAlert;
begin
	if self.status = _oldStatus then
		return;
	endif;

	create alert transient;
	alert.details := app.getErrorString3(StatusConverted, self.job.jobId, _oldStatusString, self.statusString);
	alert.setSeverity(SEVERE_INFO);
	alert.add;

end;</source>
        <Parameter name="_oldStatus" type="Integer"/>
        <Parameter name="_oldStatusString" type="String"/>
    </JadeMethod>
    <JadeMethod name="departureProcess" id="d09978b7-0078-46c0-a044-2ae33f0058d8">
        <updating/>
        <source>departureProcess(_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 07 October 2002 By: cnwgd1
//--------------------------------------------------------------
/*

Date		Who		Reason
26/09/2008	concms1	par 16130 - new parameter for clearPIN method
23 Sep 2009	cnwkpd1	PAR #20648 - prevent exit if cargo has stops preventing release
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
22 03 2011 cnwer1	PAR #25573 - no longer needs to call rebuild status
03/03/2016	cnwdap1	PAR #37523 - Don't set consignee on TI if yard request has an "update consignee"
02 Feb 2017	cnwrs1	TFS 3256 Par 38585 dont processed merged cargo
30/01/2017  cnwns1	TFS 3674 CIG - CONSIGNEE INFORMATION IS CLEARED
17 Mar 2025 navma1  MTN-34120 MTN | Dead Lock (1081) on CM_OfflineFutureActorParentDct
*/

vars
	tmpReq 		: CM_Request;
	invalid 	: Boolean;
	bol			: CM_BOL;
	gte			: CMGTE_Entity;
begin

	exclusiveLock(self);

	tmpReq := 	self.myRequest;
	
	if tmpReq = null then
		//epr par 33221 3/3/2014 wles can be created from Break bulk discrepancy
		return;
	endif;	
	
	exclusiveLock(tmpReq);

	if self.status &lt;&gt; WLE_COMPLETED then
		app.raiseCMException1(ERR_JOB_NOT_COMPLETE, self.job.jobId, "", null);
		return;
	endif;		
	
	// ### AKB2005MAY handle duplicate BR codes	tmpReq.setMyOriginatingBulkRelease(null);	// RJS 1466
	//Update the BOLs myJobReceive
	//cnwth2 -temp to make AS 400 loading of logs work

	bol := self.myBOL;
	if bol &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, bol, invalid);
		bol.setMyJobReceive(null);
		on Exception do null;
	endif;

	//Update the TI
	if tmpReq.isReleaseType then
		if self.myTrackedItem = null then
			// nothing user can do, just let it through to be deleted
			//app.raiseUnexpectedProgramError(class.name, method.name, 'Null self.myTrackedItem. Contact Developer.');
			return;
		endif;
		if self.myTrackedItem.hasBeenMerged then
			return;
		endif;
		exclusiveLock(self.myTrackedItem);
		
		// PAR #20648 - Last chance to check stops before release
		self.myTrackedItem.checkStopsToBePrevented(StopPreventReleaseRequest, null, true); 

		// set the TI release data before job gets erased			
		self.myTrackedItem.setReleaseDataFromRequest(tmpReq.CM_YardRequest,self.quantity.max(1), _passport);
		
		//This creates ediData for Rail and checks ti on vehicle for Road
		//should be called after release data is set and before changeState offsite
		self.job.setTIForRelease(self.myTrackedItem, _passport);
		
		//Does the changeState/site, clears pin and undo planned/queued moves 			
		self.myTrackedItem.setReleasedOffSite(_passport);
	
		//epr par 32500 25/9/13
		if self.myTrackedItem.myCargoType.isBreakBulkMulti then	
			// 34620 29/07/2014 overwrite remarks only if set, so existing remarks are kept
			if tmpReq.CM_YardRequest.remarks &lt;&gt; null then
				self.myTrackedItem.setRemarks(tmpReq.CM_YardRequest.remarks,false);	
			endif;
			// PAR #37523 don't set consignee here if the yard request has a GTE release,			// PAR #37523
			// and the GTE release has an "update consignee" - the TI will already have had			// PAR #37523
			// its consignee updated to the correct one in setReleaseDataFromRequest				// PAR #37523
			gte := tmpReq.CM_YardRequest.myGateEntity;												//17.03.2025 navma1 #MTN-34120
			
			if gte &lt;&gt; null 																			// PAR #37523
			and gte.isKindOf(CMGTE_Release) 														// PAR #37523
			and gte.CMGTE_Release.updateConsigneeCode &lt;&gt; null then									// PAR #37523
			else																					// PAR #37523
				if tmpReq.CM_YardRequest.consigneeCode &lt;&gt; null then									// TFS 3674
					self.myTrackedItem.setConsigneeByString(tmpReq.CM_YardRequest.consigneeCode);	// TFS 3674
				endif;																				// TFS 3674
			endif;																					// PAR #37523
			 
		endif;
		
		if not app.myPassport.isOpsViewEnabled(self.getMyTerminal()) then // ### TFS 52914 28FEB2022 NAVAB1 do not delete the release WLEs, need them for OpsView. The job.erase deletes all the WLEs anyway.
			self.erase(NORMAL_ERASE);
		endif; // ### TFS 52914 28FEB2022 NAVAB1
		
		
		if tmpReq.allWorkListEntries.isEmpty then
			tmpReq.setMyOriginatingBulkRelease(null);	// ### AKB2005MAY duplicate BR codes, moved down from above // RJS 1466
		endif;
	
	elseif self.myTrackedItem &lt;&gt; null then
		tmpReq.setMyOriginatingBulkRelease(null);		// ### AKB2005MAY duplicate BR codes, moved down from above // RJS 1466
		self.myTrackedItem.removePIN(true, false); // cnwrd1 par 22624 3.5.2010
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCompleteWorkOrder" id="a507d4c2-2ff3-468e-9641-f01d0f34bb5d">
        <updating/>
        <source>doCompleteWorkOrder()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jun 2023 navma1  ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
19 Jun 2023	navma1	Defect 58633: MTN - The WO status is not updated even if the Move Task is Complete
22 Aug 2023	navma1  ChangeRequest 59121: EUP | Handle Work orders Packing By Type
01 Sep 2023 navhl20 ChangeRequest 59121: EUP | Handle Work orders Packing By Type
04 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
*/

vars
	request 	: CM_Request;
	woWle	    : CM_WorkListEntry;
	wod			: CM_WorkOrderDtl;
	ti			: CM_TrackedItem;
	woPackWle	: CM_WorkListEntry;
begin

	request := self.myRequest;
	woWle   := self.myWorkOrderWLE;
	
	if request.isKindOf(CM_WOMoveRequest)  then
		//Move jobs
		app.myEventManager.createSingleObjInfoNoteEvt(self, EVENT_WLE_COMPLETE, self);
		self.setWorkOrderComplete();
	else
		
		//Road jobs 
		if woWle &lt;&gt; null then
			woWle.setCompletedDate(app.serverTimestampAtTrxStart);
			woWle.status := WLE_COMPLETED;
			app.myEventManager.createSingleObjInfoNoteEvt(woWle, EVENT_WLE_COMPLETE, self);
			woWle.setWorkOrderComplete();
		else
			wod := self.job.myWODtl;
			ti  := self.myTrackedItem;
			if self.isKindOf(CM_WOPackChildWLE) then
				if wod &lt;&gt; null then
					wod.CM_WodPack.allPackingTIs.addNoDuplicates(ti,false);
				endif;
				app.myEventManager.createSingleObjInfoNoteEvt(self, self.getMyTerminal.getTerminalEvent(WLE_Status_Event), self);
			elseif  self.isKindOf(CM_WOPackParentWLE) then
				self.setCompletedDate(app.serverTimestampAtTrxStart);
				if wod &lt;&gt; null then																			//01.9.2023 navhl20 #59121
					wod.CM_WodPack.allSelectedTIs.addNoDuplicates(ti,false);
				endif;
				self.status := WLE_COMPLETED;
				app.myEventManager.createSingleObjInfoNoteEvt(self, self.getMyTerminal.getTerminalEvent(WLE_Status_Event), self);
				self.setWorkOrderComplete();
			elseif self.isKindOf(CM_WOReceiveCargoWLE) or self.isKindOf(CM_WOReleaseCargoWLE) then													//04.12.2023 navhl20 #58400[61617]
				if wod &lt;&gt; null and wod.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_SHIP then
					self.setWorkOrderComplete();
				endif;
				/*
				wod := self.job.myWODtl;
				ti  := self.myTrackedItem;
				if wod &lt;&gt; null then
					woPackWle := self.myRequest.hasMatchingWOWLETypeStatus(null,WO_TASK_PACK,WLE_UNACTIONED);
						if woPackWle &lt;&gt; null then
							woPackWle.setMyTrackedItem(ti);
						endif;
					wod.CM_WorkOrderTIDtl.setTIComplete(self.myTrackedItem,null);
				endif;
				*/
			endif;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMoveToLocn" id="b6dfc6e8-2b87-413d-9519-131d1d99feb1">
        <updating/>
        <source>doMoveToLocn(_moveController : CMIF_MoveController input; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 10 April 2002 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------
// 22/11/2010	cnwdap1		PAR #23794 CCMS MES 1102 Treat TBA TI same as no TI
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	ti : CM_TrackedItem;
	invalidWLE : Boolean;
	arbiter	: CM_RTQueueArbiter;
begin
	on Exception do app.handleDeletedObject(exception, self, invalidWLE); 

	if _moveController = null then
		app.setContinueCMExceptions(false);	
		app.raiseCMException1(ERR_NO_OBJECT, '_moveController reference', null, null);
		return;
	endif;
	
	if _moveController.myToPrimaryLocation = null then
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null Location Controller, contact developer');
		return;
	endif;	

	//if self.myTrackedItem = null then								// PAR #23794
	if self.myTrackedItem = null or self.myTrackedItem.isTBAorIsRRP then	// PAR #23794 // 06 Apr 2020	NDL	TFS 47004
		app.setContinueCMExceptions(false);
		if _moveController.moveMode = QUEUE_MODE
		and CM_YardDeliveryRequest.hasInstance(self.myRequest)
		and self.myRequest.CM_YardDeliveryRequest.sourceLocation = null and self.myRequest.CM_YardDeliveryRequest.targetLocation = null then //cnwrd1 par 25488 23.8.2010
			app.raiseCMException2(ERR_NO_SOURCE_LOCATION, self.getTreeDescription, 'Queued', null, null);		
		else
			//app.raiseCMException1(ERR_WLE_NO_TI, self.getTreeDescription, null, null);
			
			// we dont have a tracked item here so we can try use the queue arbiter to generate a director rtq task
			//cnwrd1 par 24967 13.7.2010
			create arbiter transient;
			arbiter.job := self.job;
			self.enqueueWLE(arbiter);
		endif;
		return;		
	endif;

	exclusiveLock(self.myTrackedItem);

	ti := self.myTrackedItem;
	//jlier1 TFS 62784 19/3/24
	if ti &lt;&gt; null and not ti.isTBA then		
		_moveController.setMyTrackedItem(ti);
		_moveController.isRehandleMove := ti.isRehandle;
	endif;
	// MUST set the controllers wle reference	
	_moveController.setMyWorkListEntry(self);
	//_moveController.isSystemMove := true;
	
	self.setMoveControllerAllOtherTIs(_moveController);

	if (not _moveController.allOtherTrackedItems.isEmpty) then
		if (not self.job.isTrackedItemOnTransport(ti)) then	
			ti := _moveController.allOtherTrackedItems.first;
			_moveController.allOtherTrackedItems.remove(ti);
			self.assignTIandBOL(ti, self.myBOL);			
		endif;
	endif;

	//Check there are still TI's to move	
	//if ti &lt;&gt; null then					// PAR #23794
	if ti &lt;&gt; null and not ti.isTBA then		// PAR #23794
		app.myUtilityUA.utlUpdateMoveTrackedItem(_moveController, _passport);
	endif;

	if self.myBOL &lt;&gt; null then
		self.myBOL.sendNoteOnMoveCompletion(_passport);
	endif;
		
/*	if self.myBOL &lt;&gt; null 
	and _mode = REAL_MODE 
	and (not self.myRequest.isReleaseType) 
	and CM_YardController.hasInstance(_newLocn) then
		self.myBOL.setOrigLocation();
	endif;*/
epilog
	delete arbiter;
end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dwellTime" id="46337571-912b-4baf-8afb-8e80035939c6">
        <source>dwellTime() : Integer;
//Returns the time in minutes between the creation of this
//job and now. Indicates how long a truck has been inside
//the terminal
vars
	aT	:	Time;
	isPos	:	Integer;
	numDays	:	Integer;
	mins : Integer;
begin

	aT := app.actualTimeServer.differenceAsTime(self.createdTime, isPos, numDays);
	mins :=  (numDays * 24 * 60) + (aT.hour * 60) + aT.minute + 1;
	return mins;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="dwellTimeAsString" id="d1e34e6e-575b-4666-87a3-ef4865ff7242">
        <source>dwellTimeAsString() : String;
//Returns the milliseconds between the creation of this
//job and now. Indicates how long a truck has been inside
//the terminal
vars

	str : String;
begin

	str := app.actualTimeServer.cnEcDiff(self.createdTime).String.padLeadingZeros(40);
	return str;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="enqueueWLE" id="d1653bf8-8760-4db8-a8dc-7eecc6d761e3">
        <updating/>
        <source>enqueueWLE(arbiter	: CM_RTQueueArbiter io) updating;
//This method enqueues the target Worklist entry to a relevant Queue
//It calls the task creation methods on each WLE as required.
// Changed On	By			Reason
// ----------	--------	----------------------------------------------
// 22/11/2010	cnwdap1		PAR #23794 CCMS MES 1102 Treat TBA TI same as null TI
// 22 Apr 2025  navma1  	MTN-34387 MTN - Removing Unnecessary Audits
// 28/10/2025	jlizm1		MTN 36255 Rotabox Assign Release To Vessel
vars
	request : CM_Request;
	ti		: CM_TrackedItem;
begin
 	exclusiveLock(self);	//If this is not here, we get confused sometimes!

	// AKB added not  //cnwrd1 ccms 2014 if we are POP then we are coming in here with an rtq entry
	if (not self.allRTQueueEntries.isEmpty) and not self.isPlanOnPickup then 
		return;
	endif;
	
	request := self.myRequest;				//22.04.2025 navma1 #MTN-34387
	ti		:= self.myTrackedItem;			//22.04.2025 navma1 #MTN-34387
	
	sharedLock(request);
	
	if request.isKindOf(CM_DeliveryRequest) or
	   request.isKindOf(CM_SlotRequest)     or
	   request.isKindOf(CM_RORORequest)     or  //cnwrd1 par 30842 1303
	   request.isKindOf(CM_HoldRequest) 	or
	   request.isKindOf(CM_YardMoveRequest) then

		if ti = null or ti.isRRP then	//18 Mar 2020	NDL	TFS 47004
			//This is a request for "X of type"... A Special case.
			self.enqueueWLEDelivery(arbiter);
			return;
		endif;
	endif;
	
	if ti = null and  request.isKindOf(CM_WOMoveRequest) then
		// work order move without tracked item cant rtq yet
		return;
	endif;

	self.enqueueWLETI(arbiter);
	
end;</source>
        <Parameter name="arbiter" type="CM_RTQueueArbiter" usage="io"/>
    </JadeMethod>
    <JadeMethod name="enqueueWLEAutoPlanOut" id="cae719d9-75f6-4611-b148-fe9155efcf3a">
        <updating/>
        <source>enqueueWLEAutoPlanOut(_toTermArea : CM_TerminalArea) updating;
// 09/02/2010	cnwjre1	CCMS 1101
vars
	lc,
 	lcFound	: CM_LocationsController;
	ya	: CM_YardAllocation;
begin

	//cnwrd1 17.2.2012 par 28820
	if not _toTermArea.isKindOf(CM_GridArea) then
		lc := _toTermArea.getMyLocationsController();
	endif;

	self.enqueueWLEDeliveryToLocation(lc); 

end;
</source>
        <Parameter name="_toTermArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="enqueueWLEDelivery" id="a8cb3b14-60cf-4e5e-99a0-05ad3f478da5">
        <updating/>
        <source>enqueueWLEDelivery(arbiter	: CM_RTQueueArbiter io) updating, protected;
//This is a REQUEST for a class of container, not a specific container
//we do special stuff!
//09 Jul 2025	navhl20 Bug MTN-35305: MTN - Optimize Saving Road Jobs to Avoid Redundant Yard Allocation Checks
//12 Aug 2025	navbs1	Story MTN-35549: TPT | Source Location for RT Moves on the Road Ops Screen - Dev
vars
	arbiterLocal	: Boolean;
	theSourceLocation	:	CM_LocationsController;
	alert	:	CM_SystemAlert;	
	reason : String;
	task : CM_RTQueueTask;
begin
	if arbiter = null then
		//--------------
		//Create the arbiter, it supplies contextual information
		//[This is the lowest level we can be called without an arbiter].
		//--------------
		arbiterLocal := true;	//Not called from job level.
		create arbiter;
	endif;

	arbiter.job		:= self.myRequest.myJob;	//moved out here from above IF  JC
	arbiter.wle		:= self;
	arbiter.ti		:= null;
	arbiter.queue	:= null;
	
	if self.myRequest.isKindOf(CM_YardDeliveryRequest) then //changed back to this cnwrd1 par 25488 24.8.2010
	///if self.myRequest.isKindOf(CM_YardDeliveryRequest) and self.myRequest.CM_YardDeliveryRequest.bulkRelease &lt;&gt; null then // 09/08/2010 cnwmh5 #25169
		//----------------
		//IF We pass in a nullLC reference the autoplan will have ago at finding a location, else it will queue from this source
		//----------------
		theSourceLocation := self.myRequest.CM_YardDeliveryRequest.sourceLocation;
		if theSourceLocation.isKindOf(CM_GridController) and self.job.getMyTerminal().getConfig(UseBestPickDirector).Boolean then
			// we are trying to test plan to a nominated ta grid/row
			theSourceLocation := null;
		endif;
	elseif self.myRequest.isKindOf(CM_YardMoveRequest) then
		//epr par 21210 16/10/09
		theSourceLocation := self.myRequest.CM_YardMoveRequest.mySourceLocation;

	//04 Aug 2014	NDL	Par 34675 - Director task based for a list of cargo
	//								(rather than a single TI or a release by Type)
	elseif self.myRequest.isAnyId then
		theSourceLocation := self.myRequest.getFirstLocationForAnyId();
	
	else
		//----------------
		//We pass in a nullLC reference, as we want the Autoplan to attempt to find one!
		//----------------
		theSourceLocation := null;
	endif;


	//*********************************  
	arbiter.enqueueRequest(theSourceLocation);
	//*********************************  

	//if arbiter.queue = null then
	if arbiter.allRTQueueEntries.isEmpty() then
		//Could not locate a Queue, which means the system could not
		//locate a source suitable for this request.
		return;
	endif;
	//---------------
	//Set the reference to the queue from the entry, it will always find one.
	//IF it managed to locate a source for the request.
	//---------------
	
	if arbiter.sourceLocation &lt;&gt; null then 
		if self.isBulkRelease() then
			self.locationSource := arbiter.sourceLocation.getID();
		elseif self.isYardWle() then																	//09.07.2025 navhl20 #35305
			self.locationSource := arbiter.sourceLocation.getFullId();
			if self.myRequest.isKindOf(CM_DeliveryRequest) then 													//12.08.2025 navbs1 #35549
				self.myRequest.CM_DeliveryRequest.queuedLocation := arbiter.sourceLocation.getFullSourceId();
			endif;
		endif;
	endif;
	
	if (not self.isReceipt) then
		// Release job, check to make sure there are no receipts still on the vehicle/wagon
		if self.job.checkReceiptsNotQueued(self) then
			create alert;
			alert.details := "Queue Entry set to HELD: " &amp; self.job.jobId &amp; ' still has cargo on board';
			alert.setSeverity(SEVERE_WARNING);
			//-----------
			//Tell alert to add itself to system
			//-----------
			alert.add;
			arbiter.entry.setEntryStatus(QSTATUS_HELD);
			alert.setLinkedTo(arbiter.entry);	
		endif;
	endif;	
	//---------------
	//Done!
	//---------------
epilog
	if arbiterLocal then
		//Arbiter is no longer needed, if locally created, destroy it.
		delete arbiter;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="arbiter" type="CM_RTQueueArbiter" usage="io"/>
    </JadeMethod>
    <JadeMethod name="enqueueWLEDeliveryToLocation" id="cb95ad7b-9acb-4ba2-932a-7ae4f5c95325">
        <source>enqueueWLEDeliveryToLocation(_toLocCont : CM_LocationsController);
//Special method, (was called from VB.) When we cannot FIND a source for an ISO
//request, we give the users the ability to select a terminal area to supply
//the mt's from. The method take that terminal area, and links to the WLE
//and Queues the WLE.
//-----------------------------------------
//Changed: February 2003 By: cnwgd1 Reason: V7
// 09/02/2010	cnwjre1	CCMS 1101 parameter changed from CM_TerminalArea to CM_LocationsController
// was enqueueWLEDeliveryToLocation(_toTermArea : CM_TerminalArea);
//-----------------------------------------
vars
	arbiter		:	CM_RTQueueArbiter;
	sourceLC	:	CM_LocationsController;
	alert		: 	CM_SystemAlert;
	reason : String;
	task : CM_RTQueueTask;
begin
	create arbiter;
	arbiter.job		:= self.myRequest.myJob;
	arbiter.wle		:= self;
	arbiter.ti		:= null;
	arbiter.queue	:= null;

// was	sourceLC := _toTermArea.getMyLocationsController;
	sourceLC := _toLocCont;

	//------------------
	//Pass the LC into the requestenqueue method.
	//------------------
	arbiter.enqueueRequest(sourceLC);
	
	if (not self.isReceipt) then
		// Release job, check to make sure there are no receipts still on the vehicle/wagon
		if self.job.checkReceiptsNotQueued(self) then
			create alert;
			alert.details := "Queue Entry set to HELD: " &amp; self.job.jobId &amp; ' still has cargo on board';
			alert.setSeverity(SEVERE_WARNING);
			//-----------
			//Tell alert to add itself to system
			//-----------
			alert.add;
			arbiter.entry.setEntryStatus(QSTATUS_HELD);
			alert.setLinkedTo(arbiter.entry);
			
			//23 Feb 2016	NDL	Par 37572
	//		task := self.getNextUnactionedRTQueueTask();
	//		if task &lt;&gt; null then
	//			if not task.requiresSystemHold(false, null, reason) then
	//				app.myUtilityUA.utlUpdateQueueTaskStatus(task, TASK_USER_HELD);
	//			endif;
	//		endif;
			
		endif;
	endif;	
	//---------------
	//Done!
	//---------------
epilog
	arbiter.erase(0);
end;</source>
        <Parameter name="_toLocCont" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="enqueueWLETI" id="5f80b546-b839-46fe-8cd1-388efdb3fba0">
        <updating/>
        <source>enqueueWLETI(arbiter : CM_RTQueueArbiter io) updating, protected;
/*
17 Mar 2025 navma1 MTN-34120 MTN | Dead Lock (1081) on CM_OfflineFutureActorParentDct
*/
vars
	arbiterLocal	: Boolean;
	slc, 
	tlc				: CM_LocationsController;	// PAR #28658
begin

	if self.myTrackedItem = null then
		if self.myRequest.isKindOf(CM_BOLYardRequest) then
			// For a BOL request coming from Road we accept without queuing at this
			// stage if the trackedItem reference is null.
			return;
		endif;
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_WLE_NO_TI, job.jobId, null, null);
		return;	
	endif;

	//---------------
	//Check WLE's status
	//---------------
	//epr par 25573 6/2/2011  
	if self.myFutureMove = null and self.isCompleteForJob  then 	//17.03.2025 navma1 #MTN-34120
		app.setContinueCMExceptions(false);
		app.raiseCMException3(ERR_QUEUE_WLE_STAT, self.getTreeDescription(), self.statusString, 'queued', null, null);
		return;		
	endif;
	
	// CCMS 1577
	//epr CCMS 1391 21/8/14 driver initiated moves don't have to have a target the driver will specify one
	if arbiter &lt;&gt; null and not arbiter.isDriverInitiatedMove and self.myTrackedItem.getLastQueuedLocation() = null  then 	//17.03.2025 navma1 #MTN-34120
		//--------------------		
		//Its not queued yet, simply quit here..  unless its has a futuremovePOP
		//--------------------		
	
		if not self.myTrackedItem.allQueuedFutureMoves.last.isKindOf(CM_FutureMoveQueuedPOP) then //cnwrd1 par 26734 CCMS 2014 plan on pickup
			return;
		endif;
	endif;	
	if arbiter = null then
		//--------------
		//Create the arbiter, it supplies contextual information
		//[This is the lowest level we can be called without an arbiter].
		//--------------
		create arbiter transient;
		arbiterLocal := true;	//Not called from job level.
		arbiter.job  := self.myRequest.myJob;
	endif;

	arbiter.wle	    := self;
	arbiter.ti 		:= self.myTrackedItem;
	arbiter.queue   := self.myRequest.mySelectedRTQueue; //cnwrd1 ccms 2014 31.3.2011
	if self.myTrackedItem &lt;&gt; null then // AKB2002NOV added
		arbiter.setMyTerminal( self.myTrackedItem.myTerminal); // AKB2002NOV added
	endif;
	if arbiter.myTerminal = null then // AKB2002NOV added
		arbiter.setMyTerminal( self.myRequest.myTerminal); // AKB2002NOV added
	endif;
	arbiter.queue	:= null;
	arbiter.enqueueTI();
	
	// PAR #28658 get the original source and ultimate target location for this move - if these locations are 
	// both terminal areas, this is an internal move - see if we need to unset the TI's "pin in progress" flag
	// This change is related to PAR #27146, which sets the pin status to PIN_InProgress in method CM_YardRequest::createYardWLE
	// We can't just reset it in there, as it's not until this point that the WLE has any RT queue entries
	slc := self.getOriginalTaskSourceLoc;
	tlc := self.getFinalTaskTargetLoc;
	if slc &lt;&gt; null and slc.myTerminalArea &lt;&gt; null and tlc &lt;&gt; null and tlc.myTerminalArea &lt;&gt; null then
		if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.myPinNo &lt;&gt; null and self.myTrackedItem.myPinNo.status = PIN_InProcess then
			self.myTrackedItem.myPinNo.updateStatus(PIN_Normal);
		endif;
	endif;
	// PAR #28658 end

	//---------------
	//Done!
	//---------------
epilog
	if arbiterLocal then
		//Arbiter is no longer needed, if locally created, destroy it.
		delete arbiter;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="arbiter" type="CM_RTQueueArbiter" usage="io"/>
    </JadeMethod>
    <JadeMethod name="erase" id="6573e570-c0e7-44fc-b19a-41e0fb3cc5c0">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//--------------------------------------------------------------
//Created: 02 July 2002 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------
// 10/11/2010	cnwdap1		PAR #23794 CCMS MES 1102 erase TBA tracked item if we have one too
vars

begin
	self.eraseAlerts();

	self.myBOL := null;
	
	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.isTBA then		// PAR #23794
		self.myTrackedItem.erase(_eraseLevel);							// PAR #23794
	endif;																// PAR #23794
	
	inheritMethod(_eraseLevel);
	
epilog

	
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="eraseAlerts" id="61412b54-7537-464f-9818-0406e96c3c24">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_AlertAlarm::eraseAlerts"/>
        </interfaceImplements>
        <source>eraseAlerts();

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			


Return Value:		


Date		Who		Reason
20 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	iter : Iterator;
	alert : CM_SystemAlert;
	
	invalidObject : Boolean;
	
begin

	on Exception do app.handleDeletedObject( exception, alert, invalidObject );

	iter:=self.alerts.createIterator;
	while iter.next(alert) do
	// tidy up this manual collection
		alert.setReviewed(true);
		alert.setLinkedTo(null);
	endwhile;


epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="eraseFromTI" id="f8441739-7e48-4d87-ae62-e21578cfc803">
        <updating/>
        <source>eraseFromTI() updating;
//Removes our references to a tracked item.
vars

begin
	exclusiveLock(self);
	if self.myTrackedItem = null then
		return;
	endif;
	if (not job.isKindOf(CM_YardInternalJob)) then
		return;
	endif;
	//---------------
	//Has no requests. Ti Reference here is to jobYardInternal property of TI
	//---------------
	exclusiveLock(self.myTrackedItem);
	self.myTrackedItem.doRemoveJob(job, self.myRequest);
end;</source>
    </JadeMethod>
    <JadeMethod name="executePostMoveCleanUp" id="901ff753-ddcd-4376-b170-c4114635d10c">
        <updating/>
        <source>executePostMoveCleanUp(_control : CMIF_MoveController;_tiThatWasMoved : CM_TrackedItem) updating;

// cnwdvb1 28 May 2003 
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
28 Jun 2019	jlgzm1	TFS 42863 MSL - Direct Delivery Between RORO Voyages and Rail - Break Bulk

*/

vars
	passport		: CM_Passport;
	bbMaster,
	rtQueueEntry,
	currentQueueEntry: CM_RTQueueEntry;
	rtTask			: CM_RTQueueTask;
	saveStatus,
	saveJobStatus,
	numCleaned		: Integer;
	isVoyageRoroJob,	
	isInternalJob	: Boolean;
	tmpJob			: CM_Job;
	tmpJobSheet		: CM_JobSheet;
	theWLE			: CM_WorkListEntry;
	iter 			: Iterator;
	completePreviousMoves,
	invalid , invalidEntry, invalidBBEntry		: Boolean;
	ed				: Integer;
	otherWLEs 		: CM_WLESet;
	tmpFM1, tmpFM2	: CM_FutureMove;		// tfs42863
	tmpWleDR, drWLE	: CM_WorkListEntry;		// tfs42863
	queuedFM		: CM_FutureMoveQueued;	// tfs42863	
	plannedFM		: CM_FutureMovePlanned; // tfs42863
	adjustAmount	: Boolean; 				// tfs42863
begin
	
	
	if _control.isUndoMove and _control.isDirectorWithTIUndo then
		self.unQueueDirectorWithTI(app.myPassport);
		return;
	endif;
	
	if _control.isUndoMove then
		// PAR 26699 self.unQueueWLE(null);
		self.unQueueWLE(app.myPassport); // PAR 26699
		
		//TEMPORARY
		//self.moveEvent();
		if self.job &lt;&gt; null then // PAR 7593
			if self.job.isKindOf(CM_YardInternalJob) then
				self.job.cleanup(numCleaned);
			// PAR 23819
			elseif self.job.isKindOf(CM_VoyageROROJob) then
				//05 Feb 2015	NDL	Par 35643
				if self.myFutureMove &lt;&gt; null
				and self.myFutureMove.isKindOf(CM_FutureMoveQueued)
				and self.myFutureMove.CM_FutureMoveQueued.myFutureMovePlanned &lt;&gt; null
				then	
					//don't do it. Will be associated with the planned one.
				else
					self.job.cleanup(numCleaned);
				endif;
			elseif self.job.isNotNotifiedJob then	//12 Sep 2011	NDL	Par 28173
				self.job.cleanup(numCleaned);				
			endif;
		endif;
		return;
	endif;
	
	saveStatus := self.status;
	if self.job &lt;&gt; null then    // 15 May 2014 DJW PAR 34094
		saveJobStatus := self.job.status;
		isInternalJob := self.job.isYardInternalJob();
		isVoyageRoroJob := self.job.isKindOf(CM_VoyageROROJob);
	endif;
	theWLE := self;
			
	on Exception do app.handleDeletedObject(exception,currentQueueEntry,invalidEntry);
	if _control.isRTMultiMove then
		completePreviousMoves:=true;
		iter:=self.allRTQueueEntries.createIterator;
		currentQueueEntry:=_control.myRTQueueEntry;
		//epr par 35702 CCMS 2457 17/2/15
		if currentQueueEntry &lt;&gt; null and currentQueueEntry.myBreakBulkMaster &lt;&gt; null then	
			
			foreach rtTask in currentQueueEntry.allTasks do
				if rtTask.status &lt;&gt; TASK_COMPLETE then
					// Overstow check. Only want to completed appropriate tasks.
					if rtTask.ti = _tiThatWasMoved and rtTask.isOverstowTask = _control.isOverstowMove then
						rtTask.setStatusComplete();
					endif;
				endif;
			endforeach;
		
			currentQueueEntry.updateStatus(TASK_COMPLETE);
			currentQueueEntry:=currentQueueEntry.myBreakBulkMaster;
			
			if  currentQueueEntry.areAllTasksEqualStatus(TASK_COMPLETE) then
				currentQueueEntry.updateStatus(TASK_COMPLETE);
			endif;
			
			completePreviousMoves:= currentQueueEntry.status =  ENTRY_COMPLETE;
		endif;
		if completePreviousMoves then
			iter.startAtObject(currentQueueEntry);	
			while iter.back(rtQueueEntry) do
				foreach rtTask in rtQueueEntry.allTasks do
					if rtTask.status &lt;&gt; TASK_COMPLETE then
						// Overstow check. Only want to completed appropriate tasks.
						if rtTask.ti = _tiThatWasMoved and rtTask.isOverstowTask = _control.isOverstowMove then
							rtTask.setStatusComplete();
						endif;
					endif;
				endforeach;
				rtQueueEntry.updateStatus(TASK_COMPLETE);
			endwhile;
		endif;
	else
		// We go through all entries in job looking for tasks that have been completed for this ti.
		foreach rtQueueEntry in self.allRTQueueEntries do
			foreach rtTask in rtQueueEntry.allTasks do
				if rtTask.status &lt;&gt; TASK_COMPLETE then
					// Overstow check. Only want to completed appropriate tasks.
					if rtTask.ti = _tiThatWasMoved and rtTask.isOverstowTask = _control.isOverstowMove then
						rtTask.setStatusComplete();
					endif;
				endif;
			endforeach;
			rtQueueEntry.updateStatus(TASK_COMPLETE);
		endforeach;	
	endif;
	// Revised to let internal jobs with multiple entries through so they get removed promptly. Par 10641
	if isInternalJob then
//		and not global.isValidObject(theWLE) then
		if theWLE = null then
			invalid := true;
		else
			on Exception do app.handleDeletedObject(exception, theWLE, invalid);
			// Dereference to check if valid
			ed := theWLE.edition();
			on Exception do null;
		endif;
		if invalid then
			// internal jobs are erased in job.cleanup(numCleaned);
			return;
		endif;
	endif;
	
	if saveStatus &lt;&gt; self.status 
	and self.status = WLE_COMPLETED 
	and self.myRequest &lt;&gt; null then
		passport := _control.myPassport;	
		self.myRequest.changeToDoTasksStatus(STATUS_COMPLETE, passport);
	endif;
	
	if self.myBOL &lt;&gt; null and 
	   _control.moveMode = REAL_MODE and 
	   (not self.myRequest.isReleaseType) and 
	   CM_YardController.hasInstance(_control.myToPrimaryLocation) then
		tmpJob := self.job;
		if tmpJob &lt;&gt; null then
			if CM_RoadJob.hasInstance(tmpJob) then
				tmpJob.CM_RoadJob.lockVehicleTerminalAreaLocns();
			endif;
			tmpJobSheet := tmpJob.myJobSheet;
			if tmpJobSheet &lt;&gt; null then
				// done here to avoid a deadlock later.  This way
				// we lock the allJobsByOrder dict BEFORE we lock (via update of inverse)
				// the CM_LocationsController.allPlannedBOLs collection
				exclusiveLock(tmpJobSheet.allJobsByOrder);
			endif;
		endif;
		self.myBOL.setOrigLocation();
	endif;	
	
	//epr par 35702 CCMS 2457 17/2/15
	currentQueueEntry:=_control.myRTQueueEntry;
	//on Exception do app.handleDeletedObject(exception,currentQueueEntry,invalidEntry);
	if not self.job.isKindOf(CM_VoyageDeckJob) 
	and not self.job.isKindOf(CM_VoyageHoldJob) then // TFS 42872 jlgzm1 13/09/2019
		
		create otherWLEs transient;
		if currentQueueEntry &lt;&gt; null  then
			if currentQueueEntry.isBreakBulkGenericMaster then
				bbMaster:=currentQueueEntry;
			elseif currentQueueEntry.myBreakBulkMaster &lt;&gt; null then
				bbMaster:=currentQueueEntry.myBreakBulkMaster;
			endif;
			if bbMaster &lt;&gt; null then
				if bbMaster.areAllTasksEqualStatus(TASK_COMPLETE) then
						bbMaster.updateStatus(TASK_COMPLETE);
				endif;
			endif;
			
			if bbMaster &lt;&gt; null and bbMaster.status = ENTRY_COMPLETE and bbMaster.areAllBreakBulksEqualStatus(TASK_COMPLETE) and not self.isDRLinkedByFM then
				//tidy up break bulk moves
				foreach rtQueueEntry in bbMaster.allBreakBulkMoves do
						if rtQueueEntry.myWorkListEntry &lt;&gt; bbMaster.myWorkListEntry and not otherWLEs.includes(rtQueueEntry.myWorkListEntry) then
							otherWLEs.add(rtQueueEntry.myWorkListEntry);
						endif;
				endforeach;

				bbMaster.allBreakBulkMoves.purge;

				foreach theWLE in otherWLEs do	
					//epr par 35702 2/3/15
					if theWLE.myTrackedItem &lt;&gt; null and theWLE.myTrackedItem.id &lt;&gt; self.myTrackedItem.id then
						continue;
					endif;
					if theWLE.allRTQueueEntries.isEmpty then
						theWLE.erase(NORMAL_ERASE);
					endif;	
				endforeach;

			elseif self.isDRLinkedByFM and bbMaster &lt;&gt; null and bbMaster.areAllBreakBulksEqualStatus(TASK_COMPLETE) then
				// Direct release move for splittable cargo,  merge split wles back into one
				drWLE := self.getDRLinkedWLE;
				// get all other wles relating to bbMaster
				foreach rtQueueEntry in bbMaster.allBreakBulkMoves do
					if rtQueueEntry.myWorkListEntry &lt;&gt; bbMaster.myWorkListEntry and not otherWLEs.includes(rtQueueEntry.myWorkListEntry) then
						otherWLEs.add(rtQueueEntry.myWorkListEntry);
					endif;
				endforeach;
				
				if bbMaster.status = ENTRY_COMPLETE then
					// any wles that are already complete, we don't want to merge.
					// bbMaster.myWorkListEntry will have already had its amount set to the total moved, 
					// so need to subtract amounnt we're not merging
					if self.myTrackedItem &lt;&gt; null
					and((self.myTrackedItem.isKindOf(CM_BreakBulkGeneric) and bbMaster.totalMoved = self.quantity)
					or (self.myTrackedItem.isKindOf(CM_Bulk) and bbMaster.weightMoved = self.weight)) then
						adjustAmount := true;
					endif;
					foreach tmpWleDR in otherWLEs do
						if tmpWleDR.status = WLE_COMPLETED then
							if adjustAmount then
								bbMaster.myWorkListEntry.setQuantity(bbMaster.myWorkListEntry.quantity - tmpWleDR.quantity);
								bbMaster.myWorkListEntry.setWeight(bbMaster.myWorkListEntry.weight - tmpWleDR.weight);
							endif;
							otherWLEs.remove(tmpWleDR);
						endif;
					endforeach;
					bbMaster.allBreakBulkMoves.purge;
				else
					// leave the most recent wle behind.
					// we'll use it for merging into
					tmpWleDR := otherWLEs.last;
					if tmpWleDR &lt;&gt; null then
						otherWLEs.remove(tmpWleDR);
					endif;
				endif;
				
				foreach theWLE in otherWLEs do	
					if theWLE.myTrackedItem &lt;&gt; null and theWLE.myTrackedItem.id &lt;&gt; self.myTrackedItem.id then
						continue;
					endif;
					
					// this is a direct release wle, then we also need to 
					// cleanup the wles on the other side of the move
					if theWLE.isDRLinkedByFM then
						tmpWleDR := theWLE.getDRLinkedWLE;
						//need to delete the FutureMoves too
						//otherwise they'll be left with no references
						tmpFM1 := theWLE.getDRFutureMove;
						if tmpFM1 &lt;&gt; null then
							if tmpFM1.isKindOf(CM_FutureMoveQueued) then
								tmpFM2 := tmpFM1.CM_FutureMoveQueued.myFutureMovePlanned;
							else
								tmpFM2 := tmpFM1.CM_FutureMovePlanned.myFutureMoveQueued;
							endif;
							tmpFM1.erase(NORMAL_ERASE);
							if tmpFM2 &lt;&gt; null then
								tmpFM2.erase(NORMAL_ERASE);
							endif;
						endif;
						// merge the quantity/volume into the other wle
						drWLE.setQuantity(drWLE.quantity + tmpWleDR.quantity);
						drWLE.setWeight(drWLE.weight + tmpWleDR.weight);
						// if wles are being merged after a partial move, then need to
						// update counts on both sides
						// but if move is complete then self has already has it's count updated
						if not bbMaster.status = ENTRY_COMPLETE then
							self.setQuantity(self.quantity + theWLE.quantity);
							self.setWeight(self.weight + theWLE.weight);
						endif;
							
						// Notifiy form of WLE delete
						app.myEventManager.createSingleObjInfoNoteEvt(drWLE.job.getMyVoyageObject, drWLE.job.getMyTerminal.getTerminalEvent(WLE_Delete_Event), tmpWleDR);
						theWLE.erase(NORMAL_ERASE);
						tmpWleDR.erase(NORMAL_ERASE);
					endif;
						
				endforeach;
				
				// need to make make sure the Direct Release WLEs, FMs, and TI are correctly linked together.		
				if self.myTrackedItem &lt;&gt; null and
				   self.myTrackedItem.allPlannedFutureMoves.isEmpty and
				   self.myTrackedItem.allQueuedFutureMoves.isEmpty then
					// work out which FMs we're using
					if self.getDRFutureMove.isKindOf(CM_FutureMovePlanned) then
						plannedFM := self.getDRFutureMove.CM_FutureMovePlanned;
						if plannedFM.myFutureMoveQueued &lt;&gt; null then
							queuedFM := plannedFM.myFutureMoveQueued;
						endif;
					elseif tmpFM1.isKindOf(CM_FutureMoveQueued) then
						queuedFM := self.getDRFutureMove.CM_FutureMoveQueued;
						if queuedFM.myFutureMovePlanned &lt;&gt; null then
							plannedFM := queuedFM.myFutureMovePlanned;
						endif;
					endif;
					
					// update TI on planned future move
					if plannedFM &lt;&gt; null and plannedFM.myTrackedItem &lt;&gt; null then
						plannedFM.myTrackedItem.allPlannedFutureMoves.remove(plannedFM);
						self.myTrackedItem.allPlannedFutureMoves.add(plannedFM);
					endif;
					// update TI on queued future move
					if queuedFM &lt;&gt; null and queuedFM.myTrackedItem &lt;&gt; null then
						queuedFM.myTrackedItem.allQueuedFutureMoves.remove(queuedFM);
						self.myTrackedItem.allQueuedFutureMoves.add(queuedFM);
					endif;
				endif;
			endif;
		endif;
	elseif currentQueueEntry &lt;&gt; null then
		// If job is a voyageDeckJob then do not want to delete any WLEs,
		// but splitting/merging cargo to IMV can leave some RTQTasks around
		// will want to clean these up
		bbMaster:= currentQueueEntry.myBreakBulkMaster;
		if bbMaster &lt;&gt; null and bbMaster.areAllTasksEqualStatus(TASK_COMPLETE)  then
			create otherWLEs transient;
			foreach rtQueueEntry in bbMaster.allBreakBulkMoves do
				if rtQueueEntry.myWorkListEntry &lt;&gt; bbMaster.myWorkListEntry and not otherWLEs.includes(rtQueueEntry.myWorkListEntry) then
					otherWLEs.add(rtQueueEntry.myWorkListEntry);
				endif;
			endforeach;
			foreach theWLE in otherWLEs do	
				if theWLE.myTrackedItem &lt;&gt; null and theWLE.myTrackedItem.id &lt;&gt; self.myTrackedItem.id then
					continue;
				endif;
				theWLE.unQueueWLE(app.myPassport);
			endforeach;
			bbMaster := null;
		endif;
		// tfs42863 end
	endif;
	
	//epr par 25573 6/2/2011 - changes for multi machine queueing job cleanup no longer needed
	if self.status = WLE_COMPLETED and self.areAllEntryTasksEqStatus(TASK_COMPLETE) then
		//PAR 8945 Remove the queue entry when complete
		//epr par 35702 CCMS 2457 17/2/15
		on Exception do app.handleDeletedObject(exception,bbMaster,invalidBBEntry);
		invalidBBEntry:=false;
		
		if bbMaster &lt;&gt; null then
			if bbMaster.myNextRelatedEntry = null or bbMaster.myNextRelatedEntry.areAllTasksEqualStatus(TASK_COMPLETE) then
				if bbMaster.myWorkListEntry &lt;&gt; self then
						self.unQueueWLE(app.myPassport);
				endif;
				bbMaster.myWorkListEntry.unQueueWLE(app.myPassport);			
			endif;	
		else
			self.unQueueWLE(app.myPassport); // PAR 26699
		endif;
	endif;
	
	//12 Oct 2017	NDL	TFS 7089 - To ground moves for break bulk getting screwed up.
	if isVoyageRoroJob and self.allRTQueueEntries.isEmpty then
		if self.myRequest &lt;&gt; null and self.myRequest.isKindOf(CM_SlotRequest) then
			if self.myRequest.CM_SlotRequest.moveType = 1 then // Discharge
				if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.myCargoType.allowDuplicates then
					if self.myTrackedItem.myPrimaryActualLocation &lt;&gt; null then
						if not self.myTrackedItem.myPrimaryActualLocation.isVoyageController then
							//It is no longer on the ship.
							self.setStatus( WLE_COMPLETED );
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	//epr 27/4/2011 moved to after the unqueue was not deleting internal jobs after they are completed
	// This is done in self.moveEvent(); for all but internalJobs
	// RT May not be involved
	// 28738 VoyageRoroJobs need to be deleted
	
	//
	if (isInternalJob or isVoyageRoroJob) and self.allRTQueueEntries.isEmpty then
		self.rebuildStatus();
		
		if isVoyageRoroJob then
			if job.status = JOB_COMPLETE then
			
				self.job.cleanup(numCleaned);
			endif;
		else
		
			self.job.cleanup(numCleaned);	
		endif;
	endif;
	
epilog
	delete iter;
	delete otherWLEs;

end;</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
        <Parameter name="_tiThatWasMoved" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="generateOpsView" id="020152a4-dab5-49aa-8b96-6db1be6326ad">
        <updating/>
        <source>generateOpsView(_status : Integer)updating;
/*

Purpose:			
	// ### TFS 51853 27AUG2021 NAVAB1
	// ### TFS 51855 03FEB2022 NAVAB1
	// ### TFS 52925 22FEB2022 NAVAB1
	// ### TFS 53105 17JUN2022 NAVAB1
	Refactor Done to move all of the opsView code in one method 
Parameters:			

Return Value:		

Date		Who		Reason
06 Jun 2023 navma1  ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation

*/

vars
	ti 				: CM_TrackedItem;
	wle				: CM_WorkListEntry;
	updateAction	: Character;
	updateTypeTI,
	updateTypeWlE   : String;
begin
	
	// ### TFS 51855 03FEB2022 NAVAB1
	if app.myPassport.isOpsViewEnabled(self.getMyTerminal()) then
		
		ti 			  := self.myTrackedItem;
		updateAction  := BGP_OpsViewWSRequest.OPS_ACTION_UPDATE;
		updateTypeTI  := BGP_OpsViewWSRequest.OPS_TYPE_TRACKEDITEM;
		updateTypeWlE := BGP_OpsViewWSRequest.OPS_TYPE_WLE;
		
		if self.isForDischargeJob() then 									 
			if self.isSOB() then 											
				if not self.isSOBLoad() then 								
					
					if ti &lt;&gt; null then
						ti.createOpsViewEWSActivity(updateAction,updateTypeTI, ti); 
					endif;
					self.createOpsViewEWSActivity(updateAction,updateTypeWlE, self);  	   
					
				endif;
			elseif _status &lt;&gt; WLE_COMPLETED then 
				if ti &lt;&gt; null then
					ti.createOpsViewEWSActivity(updateAction,updateTypeTI, ti);
				endif;
				self.createOpsViewEWSActivity(updateAction,updateTypeWlE, self);
			elseif not self.job.isVoyageJob then 
				if self.isCargoSplittable() then
					wle := self.myRequest.allWorkListEntries.first; 
					wle.createOpsViewEWSActivity(updateAction,updateTypeWlE, wle);  
				else
					self.createOpsViewEWSActivity(updateAction,updateTypeWlE, self);   
				endif;
			endif;
		elseif not self.isSOBLoad() then
			if ti &lt;&gt; null then
				ti.createOpsViewEWSActivity(updateAction,updateTypeTI, ti);
			endif;

			if self.isRail() and self.isReceipt then 
				self.createOpsViewEWSActivity(updateAction,updateTypeWlE, self);  
			else  
				if self.isCargoSplittable() then 
					wle := self.myRequest.allWorkListEntries.first; 
					wle.createOpsViewEWSActivity(updateAction,updateTypeWlE, wle);  
				else
					self.createOpsViewEWSActivity(updateAction,updateTypeWlE, self);  
				endif;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
