    <JadeMethod name="initForm" id="033336b3-895b-4134-895b-012a524a7c8a">
        <updating/>
        <source>initForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2018	jlgndl1	Initial creation

*/

vars

begin
	self.allowPrint		:= true;
	self.allowExportCSV	:= true;
	self.allowSearch	:= false;
	// if more than one business unit, enable business unit search
	if self.cmbBank.listCount &gt; 1 then
		self.allowSearch := true;
	endif;
	self.allowTblDataSearch := true;
	
	self.setNavigatorHeading(self.caption);

	self.useTblThumb := true;
	self.frmDetailsBottom.visible := false;
	self.mnuTblVPrint.enabled	:= true;	
	self.mnuTblVExportCSV.enabled:= true;	
	
	self.tblThumb.clear;
	self.initTblEntDetail();
	self.clearErrorWarnings();	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initTblEntDetail" id="8ee81a5f-9288-406c-b1fa-b865198457af">
        <source>initTblEntDetail();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2018	jlgndl1	Initial creation	TFS 38535

*/

vars
	entTableDef		: EntTableDef;
	theRow			: Integer;
	theTable		: CM_EntryTable;
	
begin

	theTable := self.tblEntDetail;
	theTable.warningMethod := 'entTableWarning';

	theTable.stretchToParent := true;
	theTable.optimiseRowHeight := true;
	entTableDef := app.myController.getEntTableDef(ETDef_InvSignoffEntry);
	theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	
	theTable.adjustHeight(200);	
	theTable.optimiseHeadingColumn();
	theTable.changeMode := theTable.ChangeMode_FirstOnly;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateEntDetailTable" id="250c6235-7ebd-464d-98a8-f16b11c406d7">
        <source>populateEntDetailTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2018	jlgndl1	Initial creation	TFS 38535

*/

vars

	signoffUser : CM_InvoiceSignoffUser;
	
begin

	signoffUser := self.myCurrentObject.CM_InvoiceSignoffUser;
	
	if self.mode = Mode_Add then
	
		self.doCmbJobTitleBuild( null );
		
		tblEntDetail.setValueByName( ETRow_BusUnit, null );
		self.cmbBankMaint.listIndex := self.cmbBank.listIndex;
		tblEntDetail.setValueByName( ETRow_User, null );
		self.cmbUser.setObject( null );
		tblEntDetail.setValueByName( ETRow_UserJobTitle, null );	
		tblEntDetail.setValueByName( ETRow_EffectiveDate, null );
		tblEntDetail.setValueByName( ETRow_EffectiveTime, null );
	
	elseif ( self.mode = Mode_Update and signoffUser &lt;&gt; null ) then
	
		self.doCmbJobTitleBuild( signoffUser );
	
		tblEntDetail.setValueByName( ETRow_BusUnit, signoffUser.myBusinessUnit.code );
		self.cmbBankMaint.listIndex := self.cmbBankMaint.findObject( signoffUser.myBusinessUnit );
		tblEntDetail.setValueByName( ETRow_User, signoffUser.myUser.userName );	
		self.cmbUser.setObject( signoffUser.myUser );
		tblEntDetail.setValueByName( ETRow_UserJobTitle, signoffUser.userJobTitle );	
		tblEntDetail.setValueByName( ETRow_EffectiveDate, signoffUser.effectiveDT.date );
		tblEntDetail.setValueByName( ETRow_EffectiveTime, signoffUser.effectiveDT.time );
		
	endif;
	
end;</source>
    </JadeMethod>
