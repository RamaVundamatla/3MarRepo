    <JadeMethod name="trxCreateBargeCopies" id="86efcc5b-51d4-4aaa-9f7e-223f2d864247">
        <updating/>
        <source>trxCreateBargeCopies(	_allPxyVoyages : CM_VoyageArray input; 
						_sourceBargeVoyage : CM_Voyage; 
						_allTIs : CM_TIArray input;							// TFS 50878
						_passport : CM_Passport input	) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2020	jlgndl1	Initial creation	TFS 49417
24 May 2021	navdap1	TFS 50878 ASPA Bulk Barge Cargo Creation
*/

vars
	term : CM_Terminal;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	_passport.useEventDeferUpdate := true; //30/05/2025	navkc1 JIRA MTN 34639
	_passport.useTIDictDeferUpdate := true; //30/05/2025	navkc1 JIRA MTN 34639
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	
	//app.myUtilityCA.utlCreateBargeCopies( _allPxyVoyages, _sourceBargeVoyage, _passport );				// TFS 50878
	app.myUtilityCA.utlCreateBargeCopies( _allPxyVoyages, _sourceBargeVoyage, _allTIs, true, _passport );	// TFS 50878

epilog
	//30/05/2025	navkc1 JIRA MTN 34639
	if _passport.noErrors() then
		_passport.doDeferredUpdates();
	endif;
	
	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_allPxyVoyages" type="CM_VoyageArray" usage="input"/>
        <Parameter name="_sourceBargeVoyage" type="CM_Voyage"/>
        <Parameter name="_allTIs" type="CM_TIArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateBarges" id="a689ba3f-fe3d-44d6-a9c2-e8265cfc8d66">
        <updating/>
        <source>trxCreateBarges(	_pxyVoyage : CM_Voyage input;
					_eventTypes : CM_EventTypeSet;
					_prefix : String;
					_number : Integer;
					_padLength : Integer;
					_allTIs : CM_TIArray input;					// TFS 50878
					_allVessels : CM_ObjectArray input;			// TFS 50878
					_passport : CM_Passport input
					) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2020	jlgndl1	Initial creation	TFS 49417
21 May 2021	navdap1	TFS 50878 ASPA Bulk Barge Cargo Creation
*/

vars

	realVessel : CM_Vessel;
	newVoyage : CM_Voyage;
	realVoyGlobal : CM_VoyageGlobal;
	createSPS : Boolean;
	eventType : CM_EventType;
	proxyEvent : CM_EventTransaction;
	newEventTrans : CM_EventTransaction;
	index : Integer;
	pxyVoyage : CM_Voyage;
	allPxyVoyages : CM_VoyageArray;
	voyageCode : String;
	pxyTI, newTI : CM_TrackedItem;				// TFS 50878

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
	_passport.useEventDeferUpdate := true; //30/05/2025	navkc1 JIRA MTN 34639
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	
	realVessel := _pxyVoyage.myVessel;
	createSPS := _pxyVoyage.structureIncludesLOLO;

	app.myUtilityCA.utlCreateVoyage( _pxyVoyage, newVoyage, realVessel, realVoyGlobal, createSPS, _passport );
	
	if _passport.hasErrors or newVoyage = null then
		return;
	endif;
	
	// TFS 50878 create cargo on the voyage if requested
	if _allTIs &lt;&gt; null then
		pxyTI := _allTIs.first;
		if pxyTI &lt;&gt; null then
			pxyTI.changeVoyage(newVoyage, _passport);
			pxyTI.zSetPxyLocationId(newVoyage.myShipBlockStack.ident);
			app.myUtilityCA.utlCreateTrackedItem(pxyTI, newTI, _passport);
			if _passport.hasErrors then
				return;
			endif;
			// if successful, move new TI to voyage, remove the first TI from the array, and add to deferred updates
			newTI.moveToLocation(newVoyage.myShipBlockStack, null, null, null, REAL_MODE, false, true, false, false, false, true, null, null, null, app.actualTimeServer, null, app.myPassport);
			_allTIs.remove(pxyTI);
			_allVessels.remove(realVessel);
			_passport.addTrackedItemForDeferUpd(newTI);
		endif;
	endif;
	// TFS 50878 end of this bit
	
	//now create the events
	foreach eventType in _eventTypes do
		proxyEvent := eventType.createEvent( newVoyage.arrivedDT, newVoyage.myTerminal, app.myPassport.myUser.code, true, false, 1);
		proxyEvent.CMEVT_VoyageEvent.setMyVoyage( newVoyage );
		proxyEvent.CMEVT_VoyageEvent.setEndDataTime( eventType.isFromToDateTimeRequired, newVoyage.arrivedDT );
		proxyEvent.CMEVT_VoyageEvent.setUnitDescription( eventType.unitDescription );					
		
		app.myUtilityCA. utlCreateEventTransaction( proxyEvent, newEventTrans,  _passport );
					
		delete proxyEvent;
		
		if _passport.hasErrors then
			break;
		endif;
					
	endforeach;
	
	if _number &lt; 2 then
		// there are no extra barges to be made.
		return;
	endif;
	
	//now create the proxys for the extra barges
	create allPxyVoyages transient;
	foreach index in 2 to _number do
		voyageCode := _prefix &amp; index.padLeadingWith('0',_padLength);
		realVessel := _allVessels.first.CM_Vessel;													// TFS 50878
		pxyVoyage := newVoyage.pxyFromBargeUsingVesselAndCode( realVessel, voyageCode, newVoyage.myTerminal );
		allPxyVoyages.add( pxyVoyage );
		_allVessels.remove(realVessel);																// TFS 50878
	endforeach;
	
	//now create the extra barges
	//app.myUtilityCA.utlCreateBargeCopies( allPxyVoyages, newVoyage, _passport );					// TFS 50878
	app.myUtilityCA.utlCreateBargeCopies( allPxyVoyages, newVoyage, _allTIs, false, _passport );	// TFS 50878
	
epilog
	if _passport.noErrors() then																	// TFS 50878
		_passport.doDeferredUpdates();																// TFS 50878
	endif;																							// TFS 50878
	
	if allPxyVoyages &lt;&gt; null then
		allPxyVoyages.purge();
	endif;
	delete allPxyVoyages;

	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_pxyVoyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_eventTypes" type="CM_EventTypeSet"/>
        <Parameter name="_prefix" type="String"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_padLength" type="Integer"/>
        <Parameter name="_allTIs" type="CM_TIArray" usage="input"/>
        <Parameter name="_allVessels" type="CM_ObjectArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
