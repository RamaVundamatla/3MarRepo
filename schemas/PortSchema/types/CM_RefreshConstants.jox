    <JadeMethod name="btnDoIt_click" id="922e72c7-eb0d-4693-98ad-669070b2b5e6">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDoIt_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 October 2015	cnwndl1	Initial creation

*/

vars

begin

	self.clickDoIt();

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="clickDoIt" id="1b2ced71-707b-49bc-9c09-e65259ce61e1">
        <source>clickDoIt();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 October 2015	cnwndl1	Initial creation

*/

vars

	release : PortSchema_8_4_2;
	str : String;
	agent : CM_DataDumpMaintenanceAgent;
	msgResult : Integer;
	
begin

	app.mousePointer :=	Busy;
	
	if (app.myCnKarmaCntrl.environmentId.toUpper = "NAVDMAST" or app.myCnKarmaCntrl.environmentId.toUpper = "NAVEMAST") and self.chkEntTable.value and self.chkErrors.value then
		msgResult := app.msgBox("You are currently running this app in DMAST/EMAST this is NOT RECOMMENDED. Please double check the implications with a SENIOR DEV before running this, as it is only required in certain circumstances." &amp; CrLf &amp; CrLf &amp; "Are you sure you want to do this?", "Running in DMAST/EMAST!!", MsgBox_Yes_No + MsgBox_Stop_Icon);
		if msgResult = MsgBox_Return_No then
			return;
		endif;
	endif;
	
	self.doWrite( true, null, 0 ); 

	if self.chkEntTable.value then
	
		if release = null then
			create release transient;
		endif;
		self.doWrite( true, "doing " &amp; chkEntTable.caption &amp; "..." , 0  );
	
		str := release.sendMsg( PortSchemaRelease::loadEntTableDetails.name ).String;
		if str.length &gt; 0 then
			self.doWrite( false, str, Red  );
			return;
		else
			self.doWrite( false, "done " &amp; chkEntTable.caption &amp; ".", 0  );
		endif;
	
	endif;
	
	if self.chkErrors.value then
	
		if release = null then
			create release transient;
		endif;
		
		self.doWrite( true,  "doing " &amp; chkErrors.caption &amp; "...", 0  );
		
		str := release.sendMsg( PortSchemaRelease::loadTranslatableText.name ).String;
		if str.length &gt; 0 then
			self.doWrite( false, str, Red  );
			return;
		else
			self.doWrite( false, "done " &amp; chkErrors.caption &amp; ".", 0  );
		endif;
	
	endif;
	
	if self.chkEventTypes.value then
	
		if release = null then
			create release transient;
		endif;
		self.doWrite( true, "doing " &amp; chkEventTypes.caption &amp; "...", 0  );
	
		release.sendMsg( PortSchemaRelease::resetEventTypes.name );
		if app.myPassport.hasErrors then
			self.doWrite( false, app.myPassport.getErrorsAndWarningsAsString, Red  );
			return;
		else
			self.doWrite( false, "done " &amp; chkEventTypes.caption &amp; ".", 0  );
		endif;
	
	endif;
	
	if self.chkPerms.value then
	
		if release = null then
			create release transient;
		endif;
		self.doWrite( true, "doing " &amp; chkPerms.caption &amp; "...", 0  );
	
		release.sendMsg( PortSchemaRelease::resetRootSecurityRoles.name );
		if app.myPassport.hasErrors then
			self.doWrite( false, app.myPassport.getErrorsAndWarningsAsString, Red  );
			return;
		else
			self.doWrite( false, "done " &amp; chkPerms.caption &amp; ".", 0  );
		endif;
	
	endif;
	
	if self.chkQuery.value then
	
		if release = null then
			create release transient;
		endif;
		self.doWrite( true, "doing " &amp; chkQuery.caption &amp; "...", 0  );
	
		app.myRoot.createQueryDefinitionObjects();
		if app.myPassport.hasErrors then
			self.doWrite( false, app.myPassport.getErrorsAndWarningsAsString, Red  );
			return;
		else
			doWrite( false, "done " &amp; chkQuery.caption &amp; ".", 0  );
		endif;
	
	endif;
	
	if self.chkTransTypes.value then
	
		if release = null then
			create release transient;
		endif;
		self.doWrite( true, "doing " &amp; chkTransTypes.caption &amp; "...", 0  );
	
		release.sendMsg( PortSchemaRelease::resetTrxTypes.name );
		if app.myPassport.hasErrors then
			self.doWrite( false, app.myPassport.getErrorsAndWarningsAsString, Red  );
			app.myPassport.inspect;
			return;
		else
			self.doWrite( false, "done " &amp; chkTransTypes.caption &amp; ".", 0  );
		endif;
	
	endif;
	
	if self.chkYATypes.value then
	
		if release = null then
			create release transient;
		endif;
		self.doWrite( true, "doing " &amp; chkYATypes.caption &amp; "...", 0  );
	
		release.sendMsg( PortSchemaRelease::createYATypesStandard.name );
		if app.myPassport.hasErrors then
			self.doWrite( false, app.myPassport.getErrorsAndWarningsAsString, Red  );
			return;
		else
			self.doWrite( false, "done " &amp; chkYATypes.caption &amp; ".", 0  );
		endif;
	
	endif;
	
	if self.chkHookTypes.value then
	
		if release = null then
			create release transient;
		endif;
		self.doWrite( true, "doing " &amp; chkHookTypes.caption &amp; "...", 0  );
	
		release.sendMsg( PortSchemaRelease::resetHookTypes.name );
		if app.myPassport.hasErrors then
			self.doWrite( false, app.myPassport.getErrorsAndWarningsAsString, Red  );
			return;
		else
			self.doWrite( false, "done " &amp; chkHookTypes.caption &amp; ".", 0  );
		endif;
	
	endif;
	
	if self.chkDataDump.value then
	
		self.doWrite( true, "doing " &amp; self.chkDataDump.caption &amp; "...", 0  );
	
		create agent transient;
		agent.maintainDataDumpClasses();
		agent.maintainDataDumpFeatureUpdate();
		if app.myPassport.hasErrors then
			self.doWrite( false, app.myPassport.getErrorsAndWarningsAsString, Red  );
			return;
		else
			self.doWrite( false, "done " &amp; self.chkDataDump.caption &amp; ".", 0  );
		endif;
	
	endif;
	
	if self.chkAuditProperties.value then
	
		if release = null then
			create release transient;
		endif;
		self.doWrite( true, "doing " &amp; chkAuditProperties.caption &amp; "...", 0  );
	
		release.sendMsg( PortSchemaRelease::resetAuditedClassProperties.name );
		if app.myPassport.hasErrors then
			self.doWrite( false, app.myPassport.getErrorsAndWarningsAsString, Red  );
			return;
		else
			self.doWrite( false, "done " &amp; chkAuditProperties.caption &amp; ".", 0  );
		endif;
	
	endif;
	
	if release = null and agent = null then
		self.doWrite( true, "Nothing selected!", Red );
	else
		self.doWrite( true, "Completed.", 0 );
	endif;
	
	
epilog

	app.mousePointer :=	Idle;

	delete release;
	delete agent;

end;</source>
    </JadeMethod>
    <JadeMethod name="doProcessCmdLine" id="42c85092-bb1e-4b06-9b7b-2be12593cc40">
        <updating/>
        <source>doProcessCmdLine() updating, protected;
/*

Purpose:			Used by the GitSchemaLoader app to programmatically run the back patch app

Parameters:			

Return Value:		

Date				Who		Reason
09 October 2025		navmd1	Initial creation DOMTN-285

*/

vars
	cmdLine		: String;
	endJadePos	: Integer;
	argString	: String;
	initParams	: StringArray;
	param		: String;
	key, value	: String;
	pos			: Integer;
begin
	cmdLine := process.getCommandLine();
	endJadePos := cmdLine.pos("endJade", 1);
	if endJadePos &lt; 1 then
		return;
	endif;
	
	create initParams transient;
	argString := cmdLine[endJadePos+8:end];
	argString.getTokensForDelimiter(" ", initParams);
	
	foreach param in initParams do
		pos := 1;
		key := param.scanUntil("=", pos);
		if pos &lt;&gt; 0 then
			value := param[pos+1:end];
		endif;
		
		if key = self.chkAuditProperties.name then
			self.chkAuditProperties.value := value.Boolean;
		elseif key = self.chkDataDump.name then
			self.chkDataDump.value := value.Boolean;
		elseif key = self.chkEntTable.name then
			self.chkEntTable.value := value.Boolean;
		elseif key = self.chkErrors.name then
			self.chkErrors.value := value.Boolean;
		elseif key = self.chkEventTypes.name then
			self.chkEventTypes.value := value.Boolean;
		elseif key = self.chkHookTypes.name then
			self.chkHookTypes.value := value.Boolean;
		elseif key = self.chkPerms.name then
			self.chkPerms.value := value.Boolean;
		elseif key = self.chkQuery.name then
			self.chkQuery.value := value.Boolean;
		elseif key = self.chkTransTypes.name then
			self.chkTransTypes.value := value.Boolean;
		elseif key = self.chkYATypes.name then
			self.chkYATypes.value := value.Boolean;
		endif;
	endforeach;
	
	self.clickDoIt();
	
epilog
	if initParams &lt;&gt; null then
		delete initParams;
		terminate;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doWrite" id="49c66101-78c4-4543-b1bd-31e65c8b3d14">
        <source>doWrite( _clear : Boolean; _str : String; _colour : Integer );
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 October 2015	cnwndl1	Initial creation
09 October 2025	navmd1	DOMTN-285 Log out to the app log too, so the GitLoaderSchema app can grab it

*/

vars

	mess : String;
	now : Time;

begin

	now := app.actualTimeServer().time();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if not _clear then
		if _colour = 0 then
			app.writeLog(_str, LogINFO);
		else
			app.writeLog(_str, LogERROR);
		endif;
	endif;
	
	if _clear then
		self.lblStatus.caption := null;
		self.lblStatus.foreColor := Black;
		self.lblStatus.fontBold := false;
	endif;
	if _str &lt;&gt; null then
		mess := now.format("HH:mm:ss") &amp; " - " &amp; _str;
		if self.lblStatus.caption.trimBlanks = null then
			self.lblStatus.caption := mess;
		else
			self.lblStatus.caption := self.lblStatus.caption &amp; CrLf &amp;  mess;	
		endif;
		if _colour &gt; 0 then
			self.lblStatus.foreColor := _colour;
			self.lblStatus.fontBold := true;
		endif;
	endif;
	
	self.lblStatus.doWindowEvents(1);
	
	// If we've had an error, then change our exit code to indicate the same
	if _colour &gt; 0 then
		beginTransaction;
		process.userExitCode := 63;
		commitTransaction;
	endif;

epilog

end;</source>
        <Parameter name="_clear" type="Boolean"/>
        <Parameter name="_str" type="String"/>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="94b03683-9b5d-4e74-8343-eb6ab745e37a">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 November 2022	navpw1	Initial creation
09 October 2025		navmd1	DOMTN-285 Process any command line arguments to programmitically do stuff

*/

vars

begin
	if app.myCnKarmaCntrl.environmentId.toUpper = "NAVDMAST" or app.myCnKarmaCntrl.environmentId.toUpper = "NAVEMAST" then
		self.chkEntTable.enabled := false;
		self.chkErrors.enabled := false;
	endif;
	
	self.doProcessCmdLine();
epilog

end;</source>
    </JadeMethod>
</GUIClass>
