    <JadeMethod name="addTempReading" id="4f25bcd3-d749-48da-a0e0-d7dd4e086d90">
        <source>addTempReading(_ti : CM_TrackedItem; _temperature : Real; _noCharge : Boolean);

/*

Purpose:		Add reefer temperature reading	

Date			Who		Reason
19/11/2015		cnwmh5	Initial creation
27/09/2021		navdap1	TFS 52081 MTN Cannot Add Reading for a Reefer for a time other than Now
16/01/2026		navdap1	MTN-36569 CPL | Reeefer Runner Integration
*/

vars

	tempReadingParams			: CMIF_TempReading;
	tempParams					: CMIF_TempReading;					
	humidReadingParams			: CMIF_HumidReading;				
	humidParams					: CMIF_HumidReading;				
	ventReadingParams			: CMIF_VentReading;					
	ventParams					: CMIF_VentReading;		
	proxyTI						: CM_TrackedItem;
//	terminal					: CM_Terminal;
	
//	timeStamp					: TimeStamp;

begin

//	timeStamp := app.cnGetServerTime();
//	terminal := self.getTerminal();
//	self.assertNotNull(terminal);

	//set these once	
	create tempReadingParams transient;
/*	tempReadingParams.isRefConReading := false;
	tempReadingParams.isRefConAlarm := false;
	tempReadingParams.refConRawData := null;
	tempReadingParams.dateTime := timeStamp;
	tempReadingParams.noCharge := _noCharge;
	tempReadingParams.userId := app.getMyUserCode();
	tempReadingParams.myTerminal := terminal; */
	
	/*
	create humidReadingParams transient;							
	humidReadingParams.dateTime := timeStamp;						
	humidReadingParams.noCharge := _noCharge;			
	humidReadingParams.userId := app.getMyUserCode();				
	humidReadingParams.myTerminal := terminal;				
	*/
	
	/*
	create ventReadingParams transient;								
	ventReadingParams.dateTime := timeStamp;							
	ventReadingParams.noCharge := _noCharge;			
	ventReadingParams.userId := app.getMyUserCode();				
	ventReadingParams.myTerminal := terminal;	
	*/
	
	beginLoad;
	proxyTI := _ti.pxyCreateUpdateProxy();
	endLoad;
	
/*	tempReadingParams.myTrackedItem := proxyTI;
	tempReadingParams.noCharge := _ti.noChargeForTemperature(_noCharge, timeStamp);
	
	tempReadingParams.temperature := _temperature; */
	tempParams := tempReadingParams;
	
	//01 Sep 2021	NDL	TFS 51874 - Use common code instead of 14 different variant copies....
	tempReadingParams.initialise( 	proxyTI,	//_reefer : CM_TrackedItem;
									_noCharge,	//_defaultNoChargeValue : Boolean;
									app.actualTimeServer,	//_dateTime : TimeStamp;		// TFS 52081
									_temperature	//_temperature : Real
									);
	
	//humidReadingParams.myTrackedItem := proxyTI;
	//humidParams := humidReadingParams;
	
	//ventReadingParams.myTrackedItem := proxyTI;
	//ventParams := ventReadingParams;
	
	app.myTrxCA.trxCreateReeferReadings(tempParams, humidParams, ventParams, null, null, null, app.myPassport);		// MTN-36569
	self.assertNoTrxErrorsOrWarnings();

epilog

	delete tempReadingParams;
	delete humidReadingParams;
	delete ventReadingParams;
	delete proxyTI;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_temperature" type="Real"/>
        <Parameter name="_noCharge" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addTermAreaMaxStackHeights" id="67a5bc98-4f63-4311-a39a-439875a3c3ab">
        <source>addTermAreaMaxStackHeights( 	_tam : CM_TerminalAreaMaster input;
								_names : StringArray;
								_nevers : BooleanArray;
								_heights : IntegerArray;
								_objectArray : ObjectArray // of CM_YACriteriaArray objects
								);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 September 2020	jlgndl1	Initial creation	TFS 49984

*/

vars

	maxHeight : CM_GriddedTAStackHeight;
	priority : Integer;
	name : String;
	maxStackHeight : Integer;
	crit : CMIF_Array;
	pxyTAM : CM_TerminalAreaMaster;
	index : Integer;
	pxyGriddedTAStackHeight : CM_GriddedTAStackHeight;
	neverMix : Boolean;
	

begin

	self.assertTrueMsg( _tam &lt;&gt; null, "No Terminal Area Master object passed to " &amp; method.qualifiedName );
	
	self.assertTrueMsg( _tam.type.isOneOf( TA_TYPE_FORK_LIFT_STACK, TA_TYPE_STRADDLE_STACK, TA_TYPE_RTG ), "Terminal Area Master type invalid for 'Max Stack Height Criteria' in " &amp; method.qualifiedName);
	
	self.assertTrueMsg( _names.size &gt; 0, "Names parameter may not be empty" &amp; method.qualifiedName );
	self.assertTrueMsg( _names.size = _heights.size, "Number of names must equal number of heights " &amp; method.qualifiedName );
	self.assertTrueMsg( _names.size = _objectArray.size, "Number of namse must equal number of criteria collections " &amp; method.qualifiedName );
	
	pxyTAM := app.createUpdateProxy( _tam ).CM_TerminalAreaMaster;
	self.assertTrueMsg( pxyTAM &lt;&gt; null, "No Terminal Area Master proxy created " &amp; method.qualifiedName );
	
	foreach index in 1 to _names.size do
		priority := index;
		name := _names[index];
		neverMix := _nevers[index];
		maxStackHeight := _heights[index];
		crit := _objectArray[index].CMIF_Array;
		
		create pxyGriddedTAStackHeight transient;
		pxyGriddedTAStackHeight.setProxy( 	crit,	//_criterias: CMIF_Array;
											priority	//_priority : Integer
											);					
		pxyGriddedTAStackHeight.setProxyBaseData(	maxStackHeight, //_maxStackHeight : Integer;
													name, //_name : String;
													neverMix,	//neverMix : Boolean;
													pxyTAM //_termAreaMaster : CM_TerminalAreaMaster
													);
		pxyGriddedTAStackHeight.validateMe();
		self.assertTrueMsg( not app.myPassport.hasErrors, "No Gridded TA Stack Height proxy created [" &amp; index.String &amp; "] in " &amp; method.qualifiedName &amp; " - " &amp; app.myPassport.getAllErrorsWarningsAsString );
	endforeach;
	
	app.myTrxUA.trxUpdateTerminalArea( pxyTAM, app.myPassport );
	
	self.assertTrueMsg( not app.myPassport.hasErrors, "Terminal Area updatefailed in " &amp; method.qualifiedName &amp; " - " &amp; app.myPassport.getAllErrorsWarningsAsString );
	
epilog

	delete pxyTAM;

end;</source>
        <Parameter name="_tam" type="CM_TerminalAreaMaster" usage="input"/>
        <Parameter name="_names" type="StringArray"/>
        <Parameter name="_nevers" type="BooleanArray"/>
        <Parameter name="_heights" type="IntegerArray"/>
        <Parameter name="_objectArray" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="addTerminal" id="0c9cea7f-728e-4f22-b034-4c04ba12fced">
        <source>addTerminal(_name, _code: String): CM_Terminal;
//11 October 2010	cnwdw1	
// 22 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// 04 July 2017	cnwdap1	TFS 4492 SNO VERMAS Changes
// 21 June 2023	navdap1	TFS 56747 EUP Manifest Load - Internal (Zimmer) - Create
//
vars
	proxyTerm,
	newTerm		: CM_Terminal;
	cmif_Config	: CMIF_ConfigTerminal;
	cargoBolTypeArray : CM_CargoBOLTypeArray;
	cargoType: CM_CargoType;
	harbours		: ObjectArray;
	harbour			: HMS_Harbour;
	obj				: Object;	
	pxyPrenoteValidation : CM_TermPrenoteWeightCriteria;
	
begin

	//self.deleteTerminal(_code);

	create proxyTerm transient;
	create cmif_Config transient;
	create cargoBolTypeArray transient;
	
	foreach cargoType in self.getRoot.allCargoTypesById do
		if cargoType.isSystemCargoBOLType then
			cargoBolTypeArray.add(cargoType);
		endif;
	endforeach;

	// 22 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	proxyTerm.setProxy(_code, _name,app.systemTimeZoneID,null, cargoBolTypeArray, TI_CargoType_Container, 0, TI_CargoType_Container, TI_CargoType_Null, TI_CargoType_Null, null);	// TFS 56747
	
	// 26/05/2016 cnwmh5
	create pxyPrenoteValidation transient;
	pxyPrenoteValidation.setMyTerminal(proxyTerm);
	
	app.myTrxCA.trxCreateTerminal(proxyTerm, app.actualTimeServer.date, cmif_Config, newTerm, app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	
	beginTransaction;
	if self.opts.includesKey("defVoyage") then
		newTerm.setConfig(DefVoyage, newTerm.allVoyagesByCode.first.CM_Voyage);
	endif;
	if self.opts.includesKey("UseMultipleMachineQueuing") then
		newTerm.setConfig(GateAllowDualGate, self.opts.bool("UseMultipleMachineQueuing"));
	endif;
	if self.opts.includesKey("AutoPlanEnabled") then
		newTerm.setConfig(AutoPlanEnabled, self.opts.bool("AutoPlanEnabled"));
	endif;
//	if self.opts.includesKey("RadioTelemetryEnabled") then
//		newTerm.setConfig("RadioTelemetryEnabled", self.opts.bool("RadioTelemetryEnabled"));
//	endif;
	if self.opts.includesKey("PortDestCode") then
		newTerm.setConfig(PortDestCode, self.opts.str("PortDestCode"));
	endif;
	if self.opts.includesKey("Harbour") then
		harbours := self.opts.obj("Harbour").ObjectArray;
		foreach obj in harbours do
			harbour := obj.HMS_Harbour;
			harbour.allTerminalsByCode.add(newTerm);
		endforeach;
	endif;
	commitTransaction;
	
	
	return newTerm;
epilog
	delete proxyTerm;
	delete cmif_Config;
	delete cargoBolTypeArray;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="addTerminalAreaPhoto" id="77e9bc94-bbab-4605-b8d0-ff61f462c11f">
        <source>addTerminalAreaPhoto(_ta: CM_TerminalArea; _description:String; _binary:Binary) : CM_Photo;
/*
Purpose - 	
Who - NAVAB1
Date - 28DEC2023
ADO -  CR 58499 TASK 61456

Date		Who		Reason
20 Nov 2025	navsp1	MTN-36650 Integrate DotNet Image Library for Automatic Thumbnail Generation in Thin Client
*/

vars
	proxyPhoto, 
	newPhoto   : CM_Photo;
begin
	create proxyPhoto transient;
	proxyPhoto.setDescription(_description);
	proxyPhoto.setMyParent(_ta);
	
	proxyPhoto.setPhotoContent(_binary);
	//proxyPhoto.setThumbnailContent(_binary);      //MTN-36650	- automatically create in PortSchema::CM_Photo::setForUpdate
	
	app.myTrxCA.trxCreateCargoPhoto(proxyPhoto, newPhoto, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	return newPhoto;
epilog
	delete proxyPhoto;
end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_binary" type="Binary"/>
        <ReturnType type="CM_Photo"/>
    </JadeMethod>
    <JadeMethod name="addTerminalAreaStorageGroup" id="4a132a25-e580-4dfb-adae-d3cfb8bb2292">
        <source>addTerminalAreaStorageGroup(_code : String; _description : String; _terminalAreas : CM_TerminalAreaArray) : CM_TerminalAreaStorageGroup;

vars
	proxyTASG	: CM_TerminalAreaStorageGroup;
	termAreaStorageGroup	: CM_TerminalAreaStorageGroup;
begin
	create proxyTASG transient;
	
	proxyTASG.setProxy(_code, _description, _terminalAreas, self.getTerminal());
	
	app.myTrxCA.trxCreateTerminalAreaStorageGp(proxyTASG, termAreaStorageGroup, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return termAreaStorageGroup;
	
epilog
