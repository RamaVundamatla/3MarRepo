    <JadeMethod name="doLoadTerminals" id="ac38c68d-71e4-4290-ada2-fba6942d9598">
        <updating/>
        <source>doLoadTerminals(_qryReport : CM_QryReport) : String updating;
// ---------------------------------------------------------------------------
// Created:     18 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	currentTerminal,
	terminal			: CM_Terminal;
	user				: CM_User;
	userTerminal		: CM_UserTerminal;
	check				: Boolean;
	obj					: Object;
	row,
	numRows				: Integer;
	tbl					: CMUI_ListTable;
begin
	tbl := self.myLstTblTerminals;

	if tbl = null then
		return null;
	endif;
	
	tbl.clearSelected();//clear();
	currentTerminal := self.myParentForm.myTerminal;
	self.allTerminals.clear();
	
	tbl.rows := tbl.fixedRows;
	
	if _qryReport = null then
		return null;
	endif;
	
	user := app.getMyUser();
	if user = null then
		return null;
	endif;
	foreach userTerminal in user.allUserTerminals do
		terminal := userTerminal.getMyTerminal;
		
		if not userTerminal.canDoReport(_qryReport.menuId) then
			continue;
		endif;
		if terminal = currentTerminal then
			check := true;
			self.allTerminals.add(terminal);
		elseif currentTerminal &lt;&gt; null then
			check := false;
		endif;
	
		tbl.accessRow(tbl.addItem(check.cnEcGetTableCheckBoxValue &amp; Tab &amp; terminal.code &amp; ' - ' &amp; terminal.name)).itemObject := terminal;
		if check then
			tbl.addSelectedObject(terminal);
		endif;
		
	endforeach;
	
	//no point doing this here only sets selected for current row   PAR 9708 JC
	//tbl.change(tbl);
end;</source>
        <Parameter name="_qryReport" type="CM_QryReport"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadTerminalsForBuilder" id="2002d105-8463-420f-928e-df5105042d9f">
        <updating/>
        <source>doLoadTerminalsForBuilder(_qryReport: CM_QryReport): String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2010	cnwmd1	Initial creation

*/

vars
	user : CM_User;
	userTerminal : CM_UserTerminal;
	terminal : CM_Terminal;
begin
	if _qryReport = null then
		return null;
	endif;
	
	user := app.getMyUser();
	if user = null then
		return null;
	endif;
	
	foreach userTerminal in user.allUserTerminals do
		
		terminal := userTerminal.getMyTerminal;
		
		if not userTerminal.canDoReport(_qryReport.menuId) then
			continue;
		endif;
		
		if not self.allTerminals.includes(terminal) then
			self.allTerminals.add(terminal);
		endif;
		
	endforeach;
epilog

end;</source>
        <Parameter name="_qryReport" type="CM_QryReport"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadToDoTaskDescs" id="5a80c41b-2d6b-4e5a-bcf0-bea000256109">
        <updating/>
        <source>doLoadToDoTaskDescs(	_lstTblTransact	: CMUI_ListTable input;
						_filterObject	: CMQF_FilterReports ) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 October 2010	cnwndl1	Initial creation	Par 23800
14 Aug 2023 navhl20 ChangeRequest 59284:[59664] EUP | FR - VAS Work Order Transactions
*/

vars

begin

	if _lstTblTransact = null then
		return;
	endif;
	_lstTblTransact.allSelectedObjects.clear();

	_lstTblTransact.displayCollection(app.myRoot.allToDoTaskDescriptions, false, Table.DisplayCollection_Forward, null);
	if CMQF_ResourceUsage.hasInstance(_filterObject) then
		_lstTblTransact.setSelected(_filterObject.CMQF_ResourceUsage.allToDoTaskDescs);
	endif;
	if CMQF_WOTransactions.hasInstance(_filterObject) then											//14.8.2023 navhl20 #59284[59664]
		_lstTblTransact.setSelected(_filterObject.CMQF_WOTransactions.allToDoTaskDescs);
	endif;
	
	_lstTblTransact.lostFocus(_lstTblTransact);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lstTblTransact" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_filterObject" type="CMQF_FilterReports"/>
    </JadeMethod>
    <JadeMethod name="doLoadTrains" id="c4f5aae6-2c19-4144-a78e-fa30366c601e">
        <source>doLoadTrains(	_combo : CMUI_ComboBox input ; 
				_defaultValueStr : String;
				_filter : CMQF_FilterReports); 	//+ cnwmd1 Par 25069
				//_filter : CMQF_Train);		//- cnwmd1, Par 25069
// -----------------------------------------------------------------------------
// Created:		13 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 13/07/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// -----------------------------------------------------------------------------

vars
	desc : String;
	invalidTrain : Boolean;
	idx : Integer;
	terminal : CM_Terminal;
	train : CM_Train;
	includeDeparted : Boolean;
	hideAny : Boolean;
begin
	if _combo = null then
		return;
	endif;

	on Exception do app.handleDeletedObject(exception, train, invalidTrain);
	
	if _filter &lt;&gt; null and _filter.isKindOf(CMQF_Train) then //+ cnwmd1 Par 25069 - added class check
		includeDeparted := _filter.CMQF_Train.includeDeparted; //+ cnwmd1 Par 23826
	endif;
	
	hideAny := self.myQryReport &lt;&gt; null and self.myQryReport.constantValue = CM_RepRailRakeClear; //+ cnwmd1, Par 21850
	
	_combo.clear();
	
	if not hideAny then //+ cnwmd1, Par 21850
		_combo.addItem(Any_String);
	endif;
	
	foreach terminal in self.allTerminals do
		foreach train in terminal.allTrainsOnTerminal do
			invalidTrain := false;
			desc := train.getCodeDateString(); //code &amp; ' ' &amp; train.description;
			if not invalidTrain then
				_combo.itemObject[_combo.addItem(desc)] := train;
			endif;
		endforeach;
		
		if includeDeparted then //+ cnwmd1, Par 21850
			foreach train in terminal.allTrainsDeparted do
				invalidTrain := false;
				desc := train.getCodeDateString();
				if not invalidTrain then
					_combo.itemObject[_combo.addItem(desc)] := train;
				endif;
			endforeach;
		endif;
	endforeach;

	_combo.text := _defaultValueStr; //+ cnwmd1 Par 23826
	if _combo.listIndex = 0 then  
		_combo.listIndex := 1;
	endif;
	self.setValueByName(ETRow_Train, _defaultValueStr);

epilog

end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_defaultValueStr" type="String"/>
        <Parameter name="_filter" type="CMQF_FilterReports"/>
    </JadeMethod>
    <JadeMethod name="doLoadUnitOfMeasure" id="caa69997-f842-4a0b-bbfa-e49b4e199f1a">
        <source>doLoadUnitOfMeasure(_cmb : CMUI_ComboBox input; _description : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting

*/

vars
	invUOM	: CM_InvoiceUnitOfMeasure;
	root	: CM_Root;
begin
	
	_cmb.clear();
	
	_cmb.addItem(Any_String);
	
	root := app.myRoot;
	
	foreach invUOM in root.allInvoiceUnitOfMeasure do
		_cmb.addItemObject(invUOM.description, invUOM);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_description" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadUserList" id="ccf9d74b-5540-42e1-b9f9-549b3789c0aa">
        <source>doLoadUserList(_lstTable	: CMUI_ListTable input; _defaultTemplate : CMQF_FilterReports) protected;
//----------------------------------------------------------------
//	Created:	04 November 2004	by Jason Chapman  (cnwjc2)
//  19 Jun 2024 navhl20 Bug 64718: EUP | 53812 - VAS Work Order - WO Transactions Report issues
//----------------------------------------------------------------
vars
	
	user				: CM_User;
	idx					: Integer;
	defaultUsers		: CM_UserByCodeDict;
	select				: Integer;
	
begin
	if CMQF_Events.hasInstance(_defaultTemplate) then
		defaultUsers := _defaultTemplate.CMQF_Events.allUsers;
	endif;
	
	if CMQF_Transactions.hasInstance(_defaultTemplate) then
		defaultUsers := _defaultTemplate.CMQF_Transactions.allUsers;
	endif;
	
	if CMQF_WOTransactions.hasInstance(_defaultTemplate) then					//19.06.2024 navhl20 #64718
		defaultUsers := _defaultTemplate.CMQF_WOTransactions.allUsers;
	endif;
	
	if _lstTable = null then
		return;
	endif;
	
	_lstTable.rows := _lstTable.fixedRows;
	_lstTable.clearSelected();

	foreach user in app.myRoot.allUsers do
		select := 0;
		if defaultUsers &lt;&gt; null and defaultUsers[user.code] &lt;&gt; null then
			select := 1;
			_lstTable.allSelectedObjects.add(user);	
		endif;
		
		idx := _lstTable.addItem(select.String &amp; Tab &amp; user.code); 
		_lstTable.accessRow(idx).itemObject := user;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_lstTable" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_defaultTemplate" type="CMQF_FilterReports"/>
    </JadeMethod>
    <JadeMethod name="doLoadUsers" id="33bb97c9-da1f-4968-82a1-e56937040188">
        <source>doLoadUsers(_cmbUser : CMUI_ComboBox input; _userCode : String) protected;
// ---------------------------------------------------------------------------
// Created:     05 January 2004	cnwth2
//
// Purpose:     Two combos here because both can be used in the same query
//			 
// ----------   ----------  --------------------------------------------------
vars
	userDict			: CM_UserByCodeDict;
begin
	if _cmbUser = null then
		return;
	endif;
	
	userDict := app.myRoot.allUsers;
	
	_cmbUser.listCollectionWithAny(userDict, ETRow_Code);
	
	if userDict[_userCode] &lt;&gt; null then
		_cmbUser.text := _userCode;
	else
		_cmbUser.text := Any_String;
	endif;
		
	self.setValueByName(ETRow_ScalerCode, _cmbUser.text);
	
end;</source>
        <access>protected</access>
        <Parameter name="_cmbUser" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadVBSStatus" id="6bcd9f39-55f9-4d8a-a5b8-b2b4da4b62ee">
        <updating/>
        <source>doLoadVBSStatus(
	_lstTblVBSStatus	: CMUI_ListTable input;
	_filterObject	: CMQF_FilterReports ) updating, protected;
	
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Aug 2023 navhl20 Bug 60056: FR | 53429 - VBS Selector issues

*/
vars
	taskType			: CM_WorkOrderDetailType;
	idx,
	select,
	count				: Integer;
	defaultStatus		: StringArray;
	obj					: Object;
	statusArr			: ObjectArray;
	status				: CM_Association;
begin
	create defaultStatus transient;
	create statusArr transient;
	if CMQF_VehicleBookingReport.hasInstance(_filterObject) then
		_filterObject.CMQF_VehicleBookingReport.getVBSStatusStringArray(defaultStatus);
	endif;
	
	if _lstTblVBSStatus = null then
		return;
	endif;
	
	_lstTblVBSStatus.rows := _lstTblVBSStatus.fixedRows;
	_lstTblVBSStatus.clearSelected();
	
	foreach count in 1 to 8 do
		create status transient;
		status.setValue(app.vbsStatusStringToNum(app.vbsStatusNumToString(count)));
		statusArr.insert( count, status);
	endforeach;

	foreach obj in statusArr do
		select := 0;
		if defaultStatus &lt;&gt; null and defaultStatus.includes(app.vbsStatusNumToString(obj.CM_Association.getValue().Integer)) &lt;&gt; null then
			select := 1;
			_lstTblVBSStatus.allSelectedObjects.add(obj);
		endif;
		
		idx := _lstTblVBSStatus.addItem(select.String &amp; Tab &amp; app.vbsStatusNumToString(obj.CM_Association.getValue().Integer)); 
		_lstTblVBSStatus.accessRow(idx).itemObject := obj;
	endforeach;
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_lstTblVBSStatus" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_filterObject" type="CMQF_FilterReports"/>
    </JadeMethod>
    <JadeMethod name="doLoadVBSTsType" id="d8e868f9-16ec-4919-ba9f-2616b7d9dd7e">
        <source>doLoadVBSTsType(	_lstTblVBSTsType	: CMUI_ListTable input;
						_filterObject	: CMQF_FilterReports ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Aug 2023 navhl20 Bug 60056: FR | 53429 - VBS Selector issues

*/

vars
	tsType				: CM_VehicleBookingTimeSlotType;
	idx					: Integer;
	defaultTypes		: StringArray;
	select				: Integer;
	terminalColl		: CM_TerminalByCodeDict;
	term				: CM_Terminal;
begin
	create defaultTypes transient;
	if CMQF_VehicleBookingReport.hasInstance(_filterObject) then
		_filterObject.CMQF_VehicleBookingReport.getVBSTsTypeStringArray(defaultTypes);
	endif;
	
	if _lstTblVBSTsType = null then
		return;
	endif;
	
	_lstTblVBSTsType.rows := _lstTblVBSTsType.fixedRows;
	_lstTblVBSTsType.clearSelected();
	
	
	if self.allTerminals.isNotEmpty() then
		terminalColl := self.allTerminals;
	else
		terminalColl := app.myRoot.allTerminals;
	endif;
	
	foreach term in terminalColl do
		foreach tsType in term.allTerminalVBSSlotTypes do
			select := 0;
			if defaultTypes &lt;&gt; null and defaultTypes.includes(tsType.description) &lt;&gt; null then
				select := 1;
				_lstTblVBSTsType.allSelectedObjects.add(tsType);	
			endif;
			
			idx := _lstTblVBSTsType.addItem(select.String &amp; Tab &amp; tsType.description); 
			_lstTblVBSTsType.accessRow(idx).itemObject := tsType;
		endforeach;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lstTblVBSTsType" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_filterObject" type="CMQF_FilterReports"/>
    </JadeMethod>
    <JadeMethod name="doLoadVessels" id="4da4638c-b147-4d9a-831f-a8b3fab2cf53">
        <source>doLoadVessels(_combo : CMUI_ComboVessels input; _vesselCode : String) protected;
// ---------------------------------------------------------------------------
// Created:     12 August 2008 by concms1
//
// Purpose:     Loads the vessels combo box
//			 
// ----------   ----------  --------------------------------------------------
// 27/05/2009	concms1		par 19768 - fixed exception while testing
vars
	terminal: CM_Terminal;
//	dict	: CM_VesselByCodeDict; par 19768
	vessel	: CM_Vessel;
	str		: String;
	index	: Integer;
begin
	if _combo = null then
		return;
	endif;
	
	terminal := app.getMyTerminalDO_NOT_USE;	// par 19768
	
	if terminal &lt;&gt; null then		// par 19768
		_combo.isDisplayByName 	:= terminal.getConfig(VesselComboByName).Boolean;	// par 19768
	endif;							// par 19768
	
	_combo.useDisplayCollection	:= true;	// so we can add an extra entry

	_combo.setTextForDisplayCollection (Any_String);
	
	if _vesselCode &lt;&gt; null then
		vessel := app.myRoot.allVessels[_vesselCode];	// par 19768
	else
		vessel := null;
	endif;
	
	if vessel &lt;&gt; null then
		_combo.listObject := vessel;
	else
		_combo.text := Any_String;
	endif;
		
	self.setValueByName(ETRow_Vessel, _combo.text);
	
end;</source>
        <access>protected</access>
        <Parameter name="_combo" type="CMUI_ComboVessels" usage="input"/>
        <Parameter name="_vesselCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadVoySumOrderedBy" id="9e63c385-96d6-490c-a8d5-7bd74af5a4f6">
        <source>doLoadVoySumOrderedBy(_cmbOrder1, _cmbOrder2 : CMUI_ComboBox input) protected;
// ---------------------------------------------------------------------------
// Created:     05 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	

	if _cmbOrder1 = null or _cmbOrder2 = null then
		return;
	endif;

	_cmbOrder1.clear();
	_cmbOrder1.addItem(CMQF_OperatorContainerSummary.ORDERED_BY_BAY);
	_cmbOrder1.addItem(CMQF_OperatorContainerSummary.ORDERED_BY_CONSIGNEE);
	_cmbOrder1.addItem(CMQF_OperatorContainerSummary.ORDERED_BY_OPERATOR);
	_cmbOrder1.addItem(CMQF_OperatorContainerSummary.ORDERED_BY_LOADPORT);
	_cmbOrder1.addItem(CMQF_OperatorContainerSummary.ORDERED_BY_DISCHARGEPORT);
	
	_cmbOrder2.clear();
	_cmbOrder2.addItem(CMQF_OperatorContainerSummary.ORDERED_BY_BAY);
	_cmbOrder2.addItem(CMQF_OperatorContainerSummary.ORDERED_BY_CONSIGNEE);
	_cmbOrder2.addItem(CMQF_OperatorContainerSummary.ORDERED_BY_OPERATOR);
	_cmbOrder2.addItem(CMQF_OperatorContainerSummary.ORDERED_BY_LOADPORT);
	_cmbOrder2.addItem(CMQF_OperatorContainerSummary.ORDERED_BY_DISCHARGEPORT);
		
	_cmbOrder1.listIndex := 3;
	self.setValueByName(ETRow_OrderedBy, CMQF_OperatorContainerSummary.ORDERED_BY_OPERATOR);

	_cmbOrder2.listIndex := 5;
	self.setValueByName(ETRow_OrderedBy2, CMQF_OperatorContainerSummary.ORDERED_BY_DISCHARGEPORT);


end;</source>
        <access>protected</access>
        <Parameter name="_cmbOrder1" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_cmbOrder2" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doLoadVoyageEvent" id="cfd9e045-37d6-4d4f-af97-d1c28303c259">
        <source>doLoadVoyageEvent( _combo : CMUI_ComboBox; _defaultValueStr : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 August 2019	jlgndl1	Initial creation	TFS 46131

*/

vars

	combo : CMUI_ComboBox;
	iter : Iterator;
	event : CM_EventType;
	index : Integer;

begin

	combo := _combo;
	combo.clear();
	combo.sorted := true;
	
	combo.addItem(" ");
	
	iter := app.myRoot.allEventTypesByCategory.createIterator;
	event := app.myRoot.allEventTypesByCategory.getAtKeyGeq(CM_EventType.VOYAGE_EVENT,0);
	if event &lt;&gt; null then
		iter.startAtObject( event );
	endif;
	while iter.next( event ) do
		if not event.isVoyageEvent then
			break;
		endif;
		index := combo.addItem( event.name );
		combo.itemObject[ index ] := event;
	endwhile;
	
	if _defaultValueStr &lt;&gt; null then
		combo.listIndex := combo.findStringExact( 1, _defaultValueStr );
		combo.lostFocus( combo );
	endif;

epilog


	delete iter;
end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox"/>
        <Parameter name="_defaultValueStr" type="String"/>
    </JadeMethod>
