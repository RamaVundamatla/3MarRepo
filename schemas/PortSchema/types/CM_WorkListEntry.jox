    <JadeMethod name="changeTBAForRealTI" id="45314ed4-9d3a-41a8-a073-22d1f001252c">
        <updating/>
        <source>changeTBAForRealTI(_ti : CM_TrackedItem input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12/11/2010	cnwdap1	Initial creation PAR #23794 Copy TBA future move details to real TI and erase TBA TI
15/12/2010	cnwdap1	PAR #26426 CCMS MES 1102 renamed setRailDataFromTBATI method to setRealDataFromTBATI
*/
vars
	tbaTI 		: CM_TrackedItem;
	futureMove 	: CM_FutureMove;

begin
	
	if _ti = null then
		return;
	endif;
	
	if not self.myTrackedItem.isTBAorIsRRP then
		return;
	endif;
	
	tbaTI := self.myTrackedItem;
	_ti.setRealDataFromTBATI(tbaTI);
	tbaTI.erase(NORMAL_ERASE);
epilog

end;</source>
