	self.myOrganisation 	:= _myOrganisation;
	self.myTerminal 		:= _myTerminal;
	self.remarks 			:= _remarks;
	self.requiredByDT 		:= _requiredByDT;
	self.startAtDT 			:= _startAtDT;
	self.taskStatus 		:= _taskStatus;

epilog

