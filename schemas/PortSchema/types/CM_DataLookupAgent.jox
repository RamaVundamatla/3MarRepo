    <JadeMethod name="resolveDataAccessController" id="bfbebacc-e0ac-4d40-8c56-0c26e20f6df8">
        <source>resolveDataAccessController(_property : String; _key: String): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2026	naviv1	Initial creation

*/

vars
	containedClassName : String;
	pxyClassName : String;
begin
	if _key = null or _key = "" then
        return null;
    endif;
	if _property = CM_DataAccessController::name.name then
		pxyClassName := self.proxyObject.class.name;
		if pxyClassName = CM_Carrier.name then
			containedClassName := CM_Operator.name;
		else
			containedClassName := pxyClassName;
		endif;
		return app.myRoot.allDataAccessControllers[containedClassName,_key];
	endif;
    
    return null;
epilog

end;</source>
        <Parameter name="_property" type="String"/>
