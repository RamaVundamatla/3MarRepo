<CollClass name="CM_EDITIById" id="b6b7ba74-3a7c-4fa0-8b96-726a08718393">
    <duplicatesAllowed/>
    <memberType name="CM_EDITrackedItem"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <MemberKey>
        <property name="CM_EDITrackedItem::id"/>
    </MemberKey>
    <JadeMethod name="includesStockBook" id="787a992b-1048-4030-aaab-e913c9ec01b3">
        <source>includesStockBook(	_bookingRefString : String;
					_operatorCode : String;
					_voyageCode : String
					):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2017	cnwndl1	Initial creation	TFS 3703

*/

vars

	ediTi : CM_EDITrackedItem;
	hdr : CM_EDIBookingHeaderTI;

begin

	foreach ediTi in self do
		if ediTi.isKindOf( CM_EDIBookingHeaderTI ) then
			hdr := ediTi.CM_EDIBookingHeaderTI;
			if hdr.id &lt;&gt; _bookingRefString then
				continue;
			endif;
			if hdr.isStockBookingRef then
				continue;
			endif;
			if hdr.operatorCode &lt;&gt; _operatorCode then
				continue;
			endif;
			if hdr.getVoyageCode &lt;&gt; _voyageCode then
				continue;
			endif;
			return true;
		endif;
	endforeach;

	return false;

epilog

end;</source>
        <Parameter name="_bookingRefString" type="String"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
