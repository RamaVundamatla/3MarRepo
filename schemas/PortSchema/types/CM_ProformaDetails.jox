    <JadeMethod name="setup" id="4b78e495-c82c-4fc7-8d32-e62431689f23">
        <updating/>
        <source>setup(_chargeTime      : TimeStamp; 
	  _lineTotal       : Real;
	  _quantity        : Real; 
	  _rate            : Real; 
	  _remarks         : String;
	  _cashReceipt     : CM_CashReceipt;
	  _invoiceLineType : CM_InvoiceLineDesc; 
	  _trackedItem     : CM_TrackedItem;
	  _transactionType : Integer; 
	  _voyage          : CM_Voyage; 
	  _overridden      : Boolean) updating;
/*

Purpose:			
		create with a copy of the essential pro forma invoice line details
Parameters:			

Return Value:		

Date		Who		Reason

*/

vars

begin
	self.chargeTime 	   := _chargeTime;
	self.lineTotal 		   := _lineTotal;
	self.quantity 		   := _quantity;
	self.rate 			   := _rate;
	self.remarks 		   := _remarks;
	self.myCashReceipt     := _cashReceipt;
	self.myInvoiceLineType := _invoiceLineType;
	self.myTrackedItem     := _trackedItem;
	self.transactionType   := _transactionType;
	self.myVoyage          := _voyage; 				// TFS 37454
	self.overridden        := _overridden;			// 29 Jan 2019	NDL	TFS 42940
end;
</source>
        <Parameter name="_chargeTime" type="TimeStamp"/>
        <Parameter name="_lineTotal" type="Real"/>
        <Parameter name="_quantity" type="Real"/>
        <Parameter name="_rate" type="Real"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_cashReceipt" type="CM_CashReceipt"/>
        <Parameter name="_invoiceLineType" type="CM_InvoiceLineDesc"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_transactionType" type="Integer"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_overridden" type="Boolean"/>
    </JadeMethod>
</Class>
