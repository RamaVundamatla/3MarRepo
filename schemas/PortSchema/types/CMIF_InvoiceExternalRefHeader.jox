    <JadeMethod name="delete" id="1b57e243-996c-4a1f-a389-f88b2ab474de">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//08/12/2025	navkc1 JIRA 36262 ROS - 1 - External Reference updates in MTN 

*/

vars

begin
	self.allSummaries.purge();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildSummary" id="f7ae403e-04bf-46e1-a38c-5f4e1518f9dc">
        <updating/>
        <source>doBuildSummary() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//08/12/2025	navkc1 JIRA 36262 ROS - 1 - External Reference updates in MTN 

*/

vars
	inv				: CM_Invoice;
	
begin
	
	inv := self.myInvoice;
	
	if inv = null then
		app.invLog(method.getNiceName() &amp; " invoice is null, failed to build summary.", LogINFO.String);
		return;
	endif;
	
	self.doBuildSummaryFromInvLines(inv.invoiceLines);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildSummaryFromInvLines" id="c55cad9e-fae0-47a6-98e7-1121cbb1fe47">
        <updating/>
        <source>doBuildSummaryFromInvLines(_invLines : CM_InvoiceLineBySeqNumDict) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//08/12/2025	navkc1 JIRA 36262 ROS - 1 - External Reference updates in MTN 

*/

vars
	cmifSummary		: CMIF_InvoiceExternalRefSummary;
	invLine			: CM_InvoiceLine;
	invLineDesc		: CM_InvoiceLineDesc;
	rate			: Decimal[23,6];
	contractID		: String;
	lineType		: String;
	doGrouping,
	isNew			: Boolean;

begin
	
	// If it's being called from the Invoice screen, user we want to display the invoice lines in grouping
	// If user call this from Invoice Line screen, don't do it because they may have selected lines that do not belong to same grouping.
	doGrouping := self.isFromInvoice;
	
	foreach invLine in _invLines discreteLock do
		isNew := false;
		lineType := null;
		
		rate := invLine.getRate();
		contractID := invLine.contractId;
		
		invLineDesc := invLine.invoiceLineDesc;
		if invLineDesc &lt;&gt; null then
			lineType := invLineDesc.narration;
		endif;
		
		if doGrouping then
			cmifSummary := self.allSummaries.getAtKey(contractID, lineType, rate);
		elseif invLine.invoice &lt;&gt; null then
			self.invoiceID.addStringToList(invLine.invoice.sequenceNum.String,",");
		endif;
		
		if cmifSummary = null then
			create cmifSummary transient;
			isNew := true;
		endif;
		
		cmifSummary.doAddInvoiceLine(invLine, self.isFromInvoice);
		
		if isNew then
			self.allSummaries.add(cmifSummary);
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_invLines" type="CM_InvoiceLineBySeqNumDict"/>
    </JadeMethod>
    <JadeMethod name="initFromInvoice" id="0be42da2-aefe-4445-acd4-3ff4961d397c">
        <updating/>
        <source>initFromInvoice(_inv : CM_Invoice) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/12/2025	navkc1 JIRA 36262 ROS - 1 - External Reference updates in MTN 

*/

vars
	
begin
	
	if _inv = null then
		app.invLog(method.getNiceName() &amp; " Invoice is null, unable to do init", LogINFO.String);
		return;
	endif;
	
	self.myInvoice := _inv;
	
	//self.externalFinancialID 		:= _inv.externalFinancialId;
	self.externalFinancialID 		:= _inv.getExternalFinancialId(); //08/12/2025	navkc1 JIRA 36262
	self.externalNumber 			:= _inv.externalNumber;
	self.externalTaxNumber 			:= _inv.externalTaxNumber;
	self.invoiceID					:= _inv.sequenceNum.String;
	self.numberOfLines				:= _inv.invoiceLines.size();
	self.total 						:= _inv.getTotalAmount();
	
	
epilog

end;</source>
        <Parameter name="_inv" type="CM_Invoice"/>
    </JadeMethod>
</Class>
