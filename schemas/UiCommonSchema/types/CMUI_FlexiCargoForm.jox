    <JadeMethod name="bringMainFormToFront" id="6305f2cb-4757-4ef8-97f8-3dcc0c69eb71">
        <source>bringMainFormToFront() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwdap1	Initial creation

*/

vars

begin
	//epr par 34945
	if self.myParentForm = null then
		return;
	endif;
	self.myParentForm.zOrder(1);
	self.myParentForm.setFocus();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
