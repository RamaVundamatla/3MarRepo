    <JadeMethod name="rawDataToHSA" id="a1996399-9749-4572-a9bb-714b6073b2eb">
        <source>rawDataToHSA(_ediFile : CM_EDIFile; _theLines : HugeStringArray input);
//
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
// 28 Jul 2015	cnwrs1	Par 36683 since new data is in rawData suport old data (8.3.2) from compressedFilelines
//
vars
	ediFile : CM_EDIFile;
	fileLine : String;
	theLines: HugeStringArray;
	eqdCount : Integer;
	x12Delimiter : Character;
begin
	_theLines.clear;
	fileLine := _ediFile.getRawDataString();
	if fileLine = null then
		self.compressedDataToHSD(_ediFile, _theLines);
	else
		x12Delimiter := fileLine[106:1].Character;
		if x12Delimiter = Cr then
			fileLine := fileLine.replaceString(Lf, null);
		elseif x12Delimiter = Cr then
			fileLine := fileLine.replaceString(Cr, null);
		else
			fileLine := fileLine.replaceString(CrLf, null);
			fileLine := fileLine.replaceString(Cr, null);
			fileLine := fileLine.replaceString(Lf, null);
		endif;
		create theLines transient;
		fileLine.getHugeTokensForDelimiter(x12Delimiter, theLines);
		foreach fileLine in theLines do
			if fileLine.isBlank then
				continue;
			endif;
				if fileLine[1:2] = "N7" then
				eqdCount := eqdCount + 1;
			endif;
			_theLines.addTruncated(fileLine);
		endforeach;
		ediFile := _ediFile;
		if process.isInTransactionState then
			ediFile.setNumContainers(eqdCount);
		endif;
	endif;
epilog
	delete theLines;
end;
</source>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
        <Parameter name="_theLines" type="HugeStringArray" usage="input"/>
    </JadeMethod>
</Class>
