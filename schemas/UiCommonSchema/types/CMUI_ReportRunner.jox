    <JadeMethod name="updateBGR" id="d5affc16-30e5-4e4f-8c73-c1d306a92526">
        <updating/>
        <source>updateBGR() protected, updating;
// ---------------------------------------------------------------------------
// Created:     12 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	userRep			: CM_MenuUserReport;
	bgrName,
	bgrDescription		: String;
begin

	userRep := self.myBGPReport;
	if userRep = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Current BGP Report is null');
		return;
	endif;
	
	bgrName := self.tblBGPEnt.getValueByName(ETRow_ReportName).String;
	bgrDescription := self.tblBGPEnt.getValueByName(ETRow_ReportDescr).String;
	//didn't bother with trx for this
	beginTransaction;
	userRep.setNameAndDescr(bgrName, bgrDescription);
	commitTransaction;

	self.doTreeClick();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateProgress" id="a1ec461b-6f17-4561-b759-6f0daf41f488">
        <updating/>
        <source>updateProgress(_cmifMonitor: CMIF_Monitor input) updating;
// ---------------------------------------------------------------------------
// Created:     28 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.frmModalDialog.visible then
//		self.modalDialogShow(null,'Return Data','Cancel',null,		// cnwrl1 11/11/2009 PAR 19951 - what it was
//						_cmifMonitor.message,
//						'Searched ' &amp; _cmifMonitor.partsInJob.String &amp; '  found ' &amp; _cmifMonitor.partsDone.String);
		self.modalDialogShow(	null,
								app.getString( ReturnData ),
								app.getString( Cancel ),
								null,
								_cmifMonitor.message,
								app.getString( Searched_And_Found, _cmifMonitor.partsInJob.display, _cmifMonitor.partsDone.display ) );
	endif;
	
	self.btnModalDefault.doWindowEvents(0);
	// see if the user has pressed the Cancel button
	self.btnModalOpt1.doWindowEvents(0);
	self.btnModalOpt2.doWindowEvents(0);

	if self.modalDialogReturnValue = self.ModalDialogReturn_Default then
		_cmifMonitor.monitorReturnValue := _cmifMonitor.MonitorReturnValue_Return;
	elseif self.modalDialogReturnValue = self.ModalDialogReturn_Option1 then
		_cmifMonitor.monitorReturnValue := _cmifMonitor.MonitorReturnValue_Cancel;
	endif;

	if _cmifMonitor.message = self.REPORT_COMPLETE_MESSAGE then
		if _cmifMonitor.monitorReturnValue = _cmifMonitor.MonitorReturnValue_Cancel then
//			self.statusLine.caption := 'Reporting cancelled by user';	// cnwrl1 11/11/2009 PAR 19951 - what it was
			self.statusLine.caption := app.getString( Reporting_Cancelled_By_User );
		else
//			self.statusLine.caption := _cmifMonitor.partsDone.String &amp; ' items passed to the Jade Report Writer. Report now running...';	// cnwrl1 11/11/2009 PAR 19951 - what it was
			self.statusLine.caption :=	app.getString( Items_Passed_JWR_Running, _cmifMonitor.partsDone.display );
		endif;
		
		self.statusLine.refreshNow();
		self.progressFinish();
	endif;
	
end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateTemplateFileType" id="bb06f861-42d6-4773-bf1d-93053e383887">
        <updating/>
        <source>updateTemplateFileType(
	_filter			: CMQF_FilterReports; 
	_extraDetail	: CM_ExtraDetail;
	_profName		: String ) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 September 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	realUserReport			: CM_MenuUserReport;
	printerName				: String;
	networkFilepath			: String;
	ls						: Boolean;
	doEmail					: Boolean;
	emailTemplate			: CM_EmailTemplate;
	outputDest				: Integer;
	realTemplate			: CM_ReportTemplate;
	pxyReportTemplate		: CM_ReportTemplate;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	ftpEntity               : CM_FTPEntity;
begin
	app.cmsBeginLoad(ls);
	realUserReport := self.myMenuEntity.CM_MenuUserReport;
		
	if self.cmbPrinter.listObject &lt;&gt; null then
		printerName := self.cmbPrinter.listObject.CM_PrinterDef.physicalPrinterName; //epr TFS 2401 21/7/16;;
	endif;
	
	doEmail := self.tblPrintOptions.getValueByNameIfVisible(ETRow_DoEmail).Boolean;
	if doEmail then
		if realUserReport.myEmailTemplate = null then
			create emailTemplate transient;
		else
			emailTemplate := app.createUpdateProxy(realUserReport.myEmailTemplate).CM_EmailTemplate;
		endif;
		
		app.mousePointer := MousePointer_Default;
		if not self.doDisplayEmailForm(null, emailTemplate, true) then
			return false;
		endif;
		app.mousePointer := MousePointer_HourGlass; 
	endif;
	outputDest := self.cmbFormat.itemData[self.cmbFormat.listIndex];
	networkFilepath := self.tblPrintOptions.getValueByNameIfVisible(ETRow_ServerFilePath).String;
	if self.cmbFTPEntity.listObject &lt;&gt; null then                            //MTN-36668
       ftpEntity   := self.cmbFTPEntity.listObject.CM_FTPEntity;            //MTN-36668
    endif; 
    
	realTemplate := realUserReport.myReportTemplate;
	
	pxyReportTemplate := app.createUpdateProxy(realTemplate).CM_ReportTemplate;
	
	self.setReportTemplateProxy(pxyReportTemplate, _filter, _extraDetail, emailTemplate, outputDest, _profName, printerName, ftpEntity);     //MTN-36668
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateReportTemplate(pxyReportTemplate, realUserReport, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.myMenuEntity := realUserReport;
			self.lbReportTree.displayTree(true, null);
			self.lbReportTree.selectObject(self.myMenuEntity);
			statusLine.caption := app.getString( File_Type_Template_Created );
			return true;
		else
			theResult := app.showErrorWarningDialog( app.getString( Update_Template ), app.myPassport, ErrWarnMode_Update );
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		statusLine.caption := app.getString( Error_OccuredUpdatingTemplate );
		return false;
		
	endwhile;
	
epilog	
	delete emailTemplate;
	delete pxyReportTemplate;
	endLoad;
	
end;</source>
        <access>protected</access>
        <Parameter name="_filter" type="CMQF_FilterReports"/>
        <Parameter name="_extraDetail" type="CM_ExtraDetail"/>
        <Parameter name="_profName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateTemplateStandard" id="2f48884c-8bd4-4328-b664-b95ababfa922">
        <updating/>
        <source>updateTemplateStandard(
	_filter			: CMQF_FilterReports; 
	_extraDetail	: CM_ExtraDetail; 
	_profName		: String ) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 September 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	realUserReport		: CM_MenuUserReport;
	printerName			: String;
	networkFilepath		: String;
	ls					: Boolean;
	doEmail				: Boolean;
	emailTemplate		: CM_EmailTemplate;
	realTemplate		: CM_ReportTemplate;
	pxyReportTemplate	: CM_ReportTemplate;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	
begin
	app.cmsBeginLoad(ls);
	realUserReport := self.myMenuEntity.CM_MenuUserReport;
	
	if self.cmbPrinter.listObject &lt;&gt; null then
		printerName := self.cmbPrinter.listObject.CM_PrinterDef.physicalPrinterName; //epr TFS 2401 21/7/16;
	endif;
	
	doEmail := self.tblPrintOptions.getValueByNameIfVisible(ETRow_DoEmail).Boolean;
	if doEmail then
		if realUserReport.myEmailTemplate = null then
			create emailTemplate transient;
		else
			emailTemplate := app.createUpdateProxy(realUserReport.myEmailTemplate).CM_EmailTemplate;
		endif;
		
		app.mousePointer := MousePointer_Default;
		if not self.doDisplayEmailForm(null, emailTemplate, true) then
			return false;
		endif;
		app.mousePointer := MousePointer_HourGlass; 
	endif;
	
	networkFilepath := self.tblPrintOptions.getValueByNameIfVisible(ETRow_ServerFilePath).String;

	realTemplate := realUserReport.myReportTemplate;
	
	if realTemplate = null then
		// Raise big exception
		return false;
	endif;
	
	pxyReportTemplate := app.createUpdateProxy(realTemplate).CM_ReportTemplate;

	self.setReportTemplateProxy(pxyReportTemplate, _filter, _extraDetail, emailTemplate, JadeReportWriterReport.PRINTER, _profName, printerName, null); //MTN-36668
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateReportTemplate(pxyReportTemplate, realUserReport, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.myMenuEntity := realUserReport;
			self.lbReportTree.displayTree(true, null);
			self.lbReportTree.selectObject(self.myMenuEntity);
			statusLine.caption := app.getString( StandardPrinterTemplateUpdated );
			return true;
		else
			theResult := app.showErrorWarningDialog( app.getString( Update_Template ), app.myPassport, ErrWarnMode_Update );
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		statusLine.caption := app.getString( Error_OccuredUpdatingTemplate );
		return false;
		
	endwhile;
	
epilog	
	delete emailTemplate;
	delete pxyReportTemplate;
	endLoad;
	
end;</source>
        <access>protected</access>
        <Parameter name="_filter" type="CMQF_FilterReports"/>
        <Parameter name="_extraDetail" type="CM_ExtraDetail"/>
        <Parameter name="_profName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="c966908c-bd88-487e-9409-aa3a9f894b32">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     04 December 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.handleNotification(eventType, theObject, eventTag, userInfo);

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="warningFieldsOK" id="ff3c9a25-f387-4e16-b6a7-289089071330">
        <source>warningFieldsOK(): Boolean protected;
// ---------------------------------------------------------------------------
// Created:		05 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	tmpStartDate 	: Date;
	tmpEndDate		: Date;

begin
	//warnings for site/state
	if self.tblParameter.isRowVisible(ETRow_SiteState) then
		//offsite warning
	  	if self.tblParameter.getValueByName(ETRow_SiteState).String.pos("Offsite",1).Boolean then
			if app.msgBox(	app.getString( Searching_Offsite_Warning ),
							app.getString( Searching_Offsite ),
							MsgBox_Yes_No + MsgBox_Default_Second + MsgBox_Question_Mark_Icon ) = MsgBox_Return_No then
				return false;
			endif;
	  	endif;
		
		//check for voyage when onship is selected, if not in a template - 31539
		if self.myReportAgent.state &lt;&gt; CMUI_ReportAgent.STATE_TEMPLATE_SAVE and
		   self.myReportAgent.state &lt;&gt; CMUI_ReportAgent.STATE_TEMPLATE_EDIT then
			if self.tblParameter.getValueByName(ETRow_SiteState).String.pos("On Ship",1).Boolean and		// from 31156 dev Feb 2013, was "Onship" 
			   self.tblParameter.getValueByName(ETRow_Voyage).String = Any_String then
				app.msgBox(	app.getString( Must_Select_Voyage_When_Onship ),
							app.getString( Parameter_Required ),
							MsgBox_OK_Only + MsgBox_Information_Icon );
				return false;
			endif;
		endif;
	endif;
	
	//warning if the end date is earlier than the start date.
	if self.tblParameter.isRowVisible(ETRow_StartDate) and
		self.tblParameter.isRowVisible(ETRow_EndDate) then
		tmpStartDate := self.tblParameter.getValueByName(ETRow_StartDate).Date;
		tmpEndDate := self.tblParameter.getValueByName(ETRow_EndDate).Date;
		
		if tmpStartDate &gt; tmpEndDate then
			app.msgBox(	app.getString( EndDate_Before_StartDate ),
						app.getString( Parameter_Invalid ),
						MsgBox_OK_Only + MsgBox_Information_Icon );
			return false;
		endif;
	endif;
	
	//warning if the match end date is earlier than the match start date.
	if self.tblParameter.isRowVisible(ETRow_MatchDateStart) and
		self.tblParameter.isRowVisible(ETRow_MatchDateEnd) then
		tmpStartDate := self.tblParameter.getValueByName(ETRow_MatchDateStart).Date;
		tmpEndDate := self.tblParameter.getValueByName(ETRow_MatchDateEnd).Date;
		
		if tmpStartDate &gt; tmpEndDate then
			app.msgBox(	app.getString( MatchEndDate_B4_MatchStartDate ),
						app.getString( Parameter_Invalid ),
						MsgBox_OK_Only + MsgBox_Information_Icon );
			return false;
		endif;
	endif;
	
	return true;
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
