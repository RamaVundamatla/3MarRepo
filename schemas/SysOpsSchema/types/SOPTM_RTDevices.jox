    <JadeMethod name="setProxyForVehicle" id="e77913e4-181c-474b-99d6-1a97ab0e415c">
        <source>setProxyForVehicle(_id : String; 
					_model,
					_computerName	: String; 
					_useSerialConnection : Boolean;
					_useLocalTCPConnection : Boolean);	// +17/08/2016 cnwrh7	TFS	2501

vars
// 17/08/2016 cnwrh7	TFS	2501
	machine			: CM_Machine;
