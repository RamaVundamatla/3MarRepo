    <JadeMethod name="btnEnlarge_click" id="0f922589-3fe6-41f0-8301-5d5d62154d55">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnEnlarge_click(btn: Button input) updating;
/*
------------------------------------------------------------------------
Created:			04 September 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars

begin
	self.aZoomScale := 0;
	self.getAPage(aCurrentPage);
	self.btnEnlarge.enabled := false;
	self.btnReduce.enabled := true;
epilog
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnFindNext_click" id="00f832e5-1bbb-4cbb-8804-42271b95d1ba">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnFindNext_click(btn: Button input) updating;
/*
------------------------------------------------------------------------
Created:			27 May 2004 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

begin
		// if they changed page - start from there
	if aV_findNextPage &lt;&gt; self.aCurrentPage then
		aV_findPageImage := null;
		aV_findNextPage := aCurrentPage;
		aV_findNextPagePos := 0;
	endif;
	btnFindPrev.enabled := true;
	
	self.findString(false, false);

epilog
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnFindPrev_click" id="6fb8fbdb-8e66-4b66-82d1-7e2ba351cd50">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnFindPrev_click(btn: Button input) updating;
/*
------------------------------------------------------------------------
Created:			28 May 2004 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	point : Point;
begin
	self.aBackwardsCounter := self.aBackwardsCounter -1;
	if self.aBackwardsCounter &gt;= 1 then
		point := self.aAllFoundPositions[self.aBackwardsCounter];
		//The point array stores the page number AND the char pos for the last find (v_findNextPage, v_findNextPagePos);
			// if they changed page - start from there
		if point.x &lt;&gt; self.aCurrentPage then
			aV_findPageImage := null;
			aV_findNextPage := point.x;
			aV_findNextPagePos := point.y -1;
		endif;
	endif;	
	self.findString(false, true);
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
