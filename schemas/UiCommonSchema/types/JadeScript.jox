    <JadeMethod name="unloadGlobals" id="761c75fa-2283-4bfb-a3ba-ed124aad3d0a">
        <source>unloadGlobals();
// ---------------------------------------------------------------------------
// Created:     31 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	baseScm 	: Schema;
	category 	: ConstantCategory;
	const 		: Constant;
	constDict	: ConstantNDict;

begin

	baseScm := rootSchema.getSchema('UiCommonSchema');
	category := baseScm.getCategory('CMUI_NavObjectCodes');
	constDict := category.getConstants();

	foreach const in constDict do
		app.writeStatement( Tab &amp; Tab &amp; const.name &amp; ': String = "' &amp; const.valueAsString &amp; '";');
		app.writeStatement( Tab &amp; 'documentationText');
		app.writeStatement( '`' &amp; const.text &amp; '`');
	endforeach;

end;</source>
    </JadeMethod>
</Class>
