    <JadeMethod name="tCoparnAppendBookings" id="8404948f-4f65-4e3f-b532-db954226ffac">
        <source>tCoparnAppendBookings();
/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#		Description
============================================================================
02 May 2019	jlgzm1	TFS 43425 	Initial creation SNO Append Bookings
01 Aug 2019	jlgka1 	TFS 45467	SNO - Clean attribute in release request
// 10 Sep 2019	cnwrs1	TFS 46030
07 Nov 2019 jlgzm1	TFS 47229	SNO - Replace Bookings
08 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
============================================================================*/

constants

	ShipName  		= "MAERSK DUFFIELD";
	VoyageName		= "MSK001";
	BookingNo		= "2523500333";
	PARTY 			= "SNO_COPARN43425";
	SENDER1	 		= "HLL-SNO";
	ContainerId1 	= "UTZMXZ00011";
	ContainerId2 	= "UTZMXZ00012"; 
	TestOperator	= "HLL";
	ISOType1		= "45G1";
	ISOType2		= "2200";
	
vars

	vessel			: CM_Vessel;
	voyage 			: CM_Voyage;
	ediParty		: CM_EDIParty;
	proxyEDIParty	: CM_EDIParty;
	operator 		: CM_Operator;
	booking 		: CM_BookingRef;
	bookingItem		: CM_BookingRefItem;
	rules			: CM_EDIPartyCoparnRules;
	ediFile 		: CM_EDIFile;
	pxyRules 		: CM_EDIPartyRules;
	pxyItem			: CM_EDIEDIFactRule;
	terminal 		: CM_Terminal;
	ti				: CM_TrackedItem;
	strData 		: String;
	tempStr			: String;
	bookingsUniqueByNumber		: Boolean;
	opBookUnique	: Boolean;
	contId			: String;
	contId2			: String;
	ediUseOldCoparn	: Boolean;
	isDoClearanceCheck : Boolean;
	pxyCollection	: CM_ObjectArray;
	
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	
	//########################
	//## Pre-run
	//########################
	self.deleteVoyageCutoff("PRENOTES");
	self.deleteVoyageCutoff("RELEASES");
	terminal := self.getTerminal;
	operator :=  app.myRoot.allOperators [TestOperator]; 
	
	ediUseOldCoparn := terminal.getConfig(EdiUseOldCoparn).Boolean; // remember value to reset it later
	opBookUnique := operator.bookingsUniqueByNumber;			//Remember what has been set in order to reset after running unit test
	beginTransaction;
	operator.setPropertyValue(CM_Operator::bookingsUniqueByNumber.name, false);
	terminal.setConfig(EdiUseOldCoparn, false);
	commitTransaction;
	
	//Clean up from previous tests
	
	self.deleteVoyage(VoyageName);			//delete Voyage
	self.deleteVessel(ShipName);			//delete Vessel
	self.deleteBooking(BookingNo);			//delete Booking
	contId := ContainerId1;
	self.deleteTrackedItem(contId, false);
	contId2 := ContainerId2;
	self.deleteTrackedItem(contId2, false);
	
	
	//########################
	//## Setup
	//########################
	
	//Now set up cleanly
	//Add Vessel
	vessel := self.addVesselCellular(ShipName, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(vessel, "Add vessel failed");
	
	//Add Voyage
	voyage := self.addVoyageWithContainerStructur(VoyageName, ShipName, TestOperator, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	beginTransaction;
		voyage.addPortToAllPorts(self.getPort("MTMLA"));
	commitTransaction;
	
	create pxyCollection transient;
	//##########################################
	//## TEST ONE - Append Bookings, merge line
	//##########################################
	
	// INITIALIZE

	// Create EDI Party
	self.deleteEDIParty(PARTY);
	ediParty 	:= self.createEDIParty(PARTY, PARTY, SENDER1, operator);
	beginLoad;
	proxyEDIParty := ediParty.pxyCreateUpdateProxy;
	endLoad;
	
	self.setTerminalConfig(EdiBookingCommodity, false);
	
	// Setup EDI Party's rules and config
	create pxyRules as CM_EDIPartyCoparnRules transient;	
	pxyRules.setMyEDIParty(proxyEDIParty);
	pxyRules.setMyEDIConfig(terminal.myEdiConfig);
	pxyRules.CM_EDIPartyCoparnRules.setProxy (true, // allow updates actioned
											false, 	// allow updates archived
											true, 	// allow updates completed
											true, 	// allow deleted actioned
											false, 	// allow deletes archived
											false,	// block deletes completed
											false,	// email updates
											false, 	// email deletes
											false, 	// email failed updated
											false,  // email failed deletes
											true,	// reset completed (par 31185)
											false, 	// use ISO group
											false, 	// create generator request
											null, 	// sub terminal
											null, 	// carrier
											BR_TYPE_ROAD, 	//rel type
											BR_ACTIVE,		//rel status
											null,	//voyage 	
											null, 	//delivery reason
											4, 		// grade dry
											3, 		// grade reefer
											null,	// generator iso type
											false,  // rel by tpe only
											true, 	// update vgm if onsite
											true,	// create prenotes
											true,	// append new bookings
											false,  // use bookings not gate doc
											false); // Include Non-Clean Reefers in Requests jlgka1 TFS 45467

	create pxyItem transient;
	pxyCollection.add(pxyItem);
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_BGM_1_1, '11', CM_EDIEDIFactRule.Function_BGM_1_1_Booking);
	create pxyItem transient;
	pxyCollection.add(pxyItem);
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_FTX_1_1, 'AAA', CM_EDIEDIFactRule.Function_FTX_1_1_BookingRemark);
	create pxyItem transient;
	pxyCollection.add(pxyItem);
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_FTX_3_1, 'HAN', CM_EDIEDIFactRule.Function_FTX_3_1_Stowage);
	create pxyItem transient;
	pxyCollection.add(pxyItem);
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_RFF_1_1, '-', CM_EDIEDIFactRule.Function_RFF_1_1_RelNo);
	create pxyItem transient;
	pxyCollection.add(pxyItem);
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_NAD_1_1, 'CA', CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper);
	create pxyItem transient;
	pxyCollection.add(pxyItem);
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_NAD_1_1, 'CZ', CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignee);
	create pxyItem transient;
	pxyCollection.add(pxyItem);
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_NAD_1_1, 'CN', CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignor);	

	app.myTrxUA.trxUpdateEDIParty(proxyEDIParty, app.myPassport);

	delete proxyEDIParty;
	
	strData := "
UNA:+.'
UNB+UNOA:2+" &amp; SENDER1 &amp; "+ITSALSCT+190208:1004+65541'
UNH+CANITSAL169533+COPARN:D:95B:UN:SMDG10'
BGM+11:::GATE IN ORDER+" &amp; BookingNo &amp; "-001+9'
FTX+OSI++L'
RFF+BN:" &amp; BookingNo &amp; "-001'
TDT+20+" &amp; VoyageName&amp;"+1++HLC:172:166+++V2OF2:103::" &amp; ShipName &amp; "'
RFF+VON:625504'
LOC+9+ITSAL:139:6++SALERN:BER:ZZZ:SALERNO CONTAINER TERMINAL SPA'
DTM+133:201902192200:203'
DTM+132:201902220800:203'
NAD+CF+HLC:160:166'
GID+1'
FTX+AAA+++FOAM PRODUCTS'
SGP+" &amp; ContainerId1 &amp; "'
EQD+CN+" &amp; ContainerId1 &amp; "+45G1:102:5++2+5'
RFF+BN:" &amp; BookingNo &amp; "-0001'
EQN+1'
TMD+3++2'
LOC+9+ITSAL:139:6+SALERN:BER:ZZZ:SALERNO CONTAINER TERMINAL SPA'
LOC+11+MTMLA:139:6+:TER:ZZZ:MALTA FREEPORT TERMINAL LIMITED'
LOC+8+YEADE:139:6'
LOC+7+YEADE:139:6'
MEA+AAE+T+KGM:3830'
MEA+AAE+G+KGM:24000'
TDT+10++9'
LOC+5+ITSAL:139:6'
DTM+133:201902081527:203'
DTM+132:201902192200:203'
NAD+CF+HLC:160:166'
NAD+CU+763631:ZZZ++U. DEL CORONA &amp; SCARDIGLI SRL++LIVORNO (LEGHORN)++57123'
CNT+16:1'
UNT+31+CANITSAL169533'
UNH+CANITSAL169534+COPARN:D:95B:UN:SMDG10'
BGM+11:::GATE IN ORDER+" &amp; BookingNo &amp; "-002+9'
FTX+OSI++L'
RFF+BN:" &amp; BookingNo &amp; "-002'
TDT+20+" &amp; VoyageName &amp;"+1++HLC:172:166+++V2OF2:103::" &amp; ShipName &amp; "'
RFF+VON:625504'
LOC+9+ITSAL:139:6++SALERN:BER:ZZZ:SALERNO CONTAINER TERMINAL SPA'
DTM+133:201902192200:203'
DTM+132:201902220800:203'
NAD+CF+HLC:160:166'
GID+1'
FTX+AAA+++FOAM'
SGP+" &amp; ContainerId2 &amp; "'
EQD+CN+" &amp; ContainerId2 &amp; "+45G1:102:5++2+5'
RFF+BN:" &amp; BookingNo &amp; "-0002'
EQN+1'
TMD+3++2'
LOC+9+ITSAL:139:6+SALERN:BER:ZZZ:SALERNO CONTAINER TERMINAL SPA'
LOC+11+MTMLA:139:6+:TER:ZZZ:MALTA FREEPORT TERMINAL LIMITED'
LOC+8+YEADE:139:6'
LOC+7+YEADE:139:6'
