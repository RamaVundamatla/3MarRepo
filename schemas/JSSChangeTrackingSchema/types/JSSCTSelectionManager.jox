    <JadeMethod name="closeIterator" id="8ffd1352-ca55-43ac-be41-0ea93748ba97">
        <updating/>
        <source>closeIterator() updating, protected;
/*
*/
begin
	self.allSelectedChanges.clear;
	if self.myIterator &lt;&gt; null then
		delete self.myIterator;
		self.myIterator := null;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="create" id="c4603c82-4535-4dee-a645-7ce297a1c153">
        <updating/>
        <source>create() updating;
/*
*/
begin
	self.myChangeTrackingRoot := JSSCTChangeTrackingRoot.firstInstance;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="2c806f20-5120-45aa-b722-96ed9658c911">
        <updating/>
        <source>delete() updating;
/*
*/
begin
	self.allSelectedChanges.clear;
	if self.myIterator &lt;&gt; null then
		delete self.myIterator;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getClassChangesNumber" id="1f0a5894-056b-4a08-b6af-14b76b0c9905">
        <source>getClassChangesNumber(_className: String; _strArray : StringArray io) : Integer;
//
// 17 Jun 2014	cnwrs1	Par 34413 lost updates in DSS
//	31 Oct 2017	NDL	TFS 7579
//
vars
	ctObject: JSSCTChangeTrackingObject;
	count : Integer;
	invalidObject : Boolean;
	str : String;
	chgObj : Object;	//31 Oct 2017	NDL	TFS 7579
begin
	if self.className &lt;&gt; _className then
		return 0;
	endif;
	on Exception do app.handleDeletedObject(exception, chgObj, invalidObject);
	foreach ctObject in self.allSelectedChanges do
		invalidObject := false; //cnwrd1 par 35138
		chgObj := ctObject.changeObject;	//31 Oct 2017	NDL	TFS 7579
		if chgObj = null then	//31 Oct 2017	NDL	TFS 7579
			continue;
		endif;
		str := chgObj.creationTime.String;
		if not invalidObject then
			_strArray.add(ctObject.changeObjectID);
			count := count + 1;
		endif;
	endforeach;
	return self.allSelectedChanges.size;
end;
</source>
        <Parameter name="_className" type="String"/>
        <Parameter name="_strArray" type="StringArray" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getClassList" id="aa1da9d0-8344-4d9c-892b-792a6c97b843">
        <source>getClassList(pSchema: Schema): ClassColl;
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	classList: ClassColl;
	class: Class;
	changeClass: JSSCTChangeTrackingClass;
	iterDict: Iterator;
begin
	create classList transient;
	//
	iterDict := self.myChangeTrackingRoot.allChangeClasses.createIterator();
	while iterDict.next(changeClass) do

		//classList.add(pSchema.getClass(changeClass.className));  // Only add if class is valid. If class removed then get null ones
		class := pSchema.getClass(changeClass.className);
		if class &lt;&gt; null then
			classList.add(class);
		endif;
	endwhile;

	return (classList);

epilog
	delete iterDict;		// PAR #26678
	
end;</source>
        <Parameter name="pSchema" type="Schema"/>
        <ReturnType type="ClassColl"/>
    </JadeMethod>
    <JadeMethod name="getClassSize" id="eb4f5fbb-7582-43b9-b9bc-5f47053b0c4e">
        <source>getClassSize(pClassName: String): Integer;
/*
		Return the number of objects currently being tracked for the passed class
*/
vars
	changeClass: JSSCTChangeTrackingClass;
	changeDictSize: Integer;
begin
	//	get the number of creates/updates
	changeClass := self.myChangeTrackingRoot.allChangeClasses[pClassName, false];
	if changeClass = null then
	else
		changeDictSize := changeClass.allChangesByOid.size;
	endif;
	//	get the number of deletes
	changeClass := self.myChangeTrackingRoot.allDeleteClasses[pClassName, false];
	if changeClass = null then
	else
		changeDictSize := changeDictSize + changeClass.allChangesByOid.size;
	endif;
	return (changeDictSize);
end;</source>
        <Parameter name="pClassName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNextClassChange" id="c3448c67-860f-4179-b467-9cc4f21a06a5">
        <updating/>
        <source>getNextClassChange(pSelectionObject: Object input): Integer updating;
/*
// 17 Jun 2014	cnwrs1	Par 34413 lost updates in DSS
//	31 Oct 2017	NDL	TFS 7579
*/
vars
	ctObject: JSSCTChangeTrackingObject;
	action: String;
	rtn: Boolean;
	returnCode: Integer;
	invalidObject : Boolean;
	str : String;
	chgObj : Object;	//31 Oct 2017	NDL	TFS 7579
begin
	//	check that we have a current Iterator
	if self.myIterator = null then
		return (2);
	endif;
	//	check that we have the correct Iterator
	if self.isDelete then
		return (3);
	endif;
	//	get the next object for the iterator
	rtn := self.myIterator.next(ctObject);

	//	step over any change objects that have been deleted
	//	but not yet applied from the available journal
	on Exception do app.handleDeletedObject(exception, chgObj, invalidObject);
	while rtn do

		chgObj := ctObject.changeObject;	//31 Oct 2017	NDL	TFS 7579
		invalidObject := chgObj = null; //cnwrd1 par 35138		
		if not invalidObject then
			str := chgObj.creationTime.String;
		endif;
		if not invalidObject then
			break;
		endif;
		rtn := self.myIterator.next(ctObject);
	endwhile;

	//	do we have an object, and is it within the specified chronological range
	if rtn then
		pSelectionObject.setPropertyValue("changeAction", 	 ctObject.changeAction);
		pSelectionObject.setPropertyValue("changeObject", 	 ctObject.changeObject);
		pSelectionObject.setPropertyValue("changeTimestamp", ctObject.changeTimestamp);
	else
		self.closeIterator();
		returnCode := 1;
	endif;
	return (returnCode);
end;</source>
        <Parameter name="pSelectionObject" type="Object" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNextClassDelete" id="e35ffd7c-7990-467e-bea6-d05e442dd7f5">
        <updating/>
        <source>getNextClassDelete(pSelectionObject: Object input): Integer updating;
/*
// 17 Jun 2014	cnwrs1	Par 34413 lost updates in DSS
*/
vars
	deleteObject: JSSCTChangeTrackingObject;
	rtn: Boolean;
	returnCode: Integer;
begin
	//	check that we have a current Iterator
	if self.myIterator = null then
		return (2);
	endif;
	//	check that we have the correct Iterator
	if not self.isDelete then
		return (4);
	endif;
	//	get the next object for the iterator
	rtn := self.myIterator.next(deleteObject);

	//	do we have an object, and is it within the specified chronological range
	if rtn then
		pSelectionObject.setPropertyValue("changeAction", 	 deleteObject.changeAction);
		pSelectionObject.setPropertyValue("changeObjectID",  deleteObject.changeObjectID);
		pSelectionObject.setPropertyValue("changeTimestamp", deleteObject.changeTimestamp);
	else
		self.closeIterator();
		returnCode := 1;
	endif;
	return (returnCode);
end;</source>
        <Parameter name="pSelectionObject" type="Object" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleObjectAlreadyInColl" id="c7219ea8-4991-464f-9c58-014fd447836d">
        <source>handleObjectAlreadyInColl(exObj: Exception): Integer protected;
// --------------------------------------------------------------------------------
//
// Purpose:		Exception handler that can be used to skip additions of objects to
//              a collection where the object already exists in the collection.
//              Arming an exception handler to catch any occurrences of this is
//              more efficient than guarding every "add" with an "includes" call.
//              Of course, this handler should only be armed in cases where it is
//              valid to have an object already in the collection.
// --------------------------------------------------------------------------------
constants
	ObjectAlreadyInCollection = 1309;
	KeyAlreadyUsedInCollection = 1310;

begin
	if exObj.errorCode = ObjectAlreadyInCollection
	or exObj.errorCode = KeyAlreadyUsedInCollection then
		// The object already exists in the collection so resume to the next
		// statement in the method that armed the handler
		return Ex_Resume_Next;
	endif;
	// Some other exception, so pass it back to the next handler
	return Ex_Pass_Back;

end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="selectClassChanges" id="d317333c-adab-4cb6-aebe-dbf60e77e1dd">
        <updating/>
        <source>selectClassChanges(pClassName: String; pFromTimeStamp: TimeStamp; pToTimeStamp: TimeStamp; _ignoreDeletesForUser : String): Integer updating;

/*

Date		Who		Reason
08 Jun 2009	cnwkpd1	PAR #19821 - Ensure Change Class is always unlocked at exit
07 Jan 2014	NDL	Par 33264

*/

vars
	changeClass		: JSSCTChangeTrackingClass;
	changeObject	: JSSCTChangeTrackingObject;
	nullToDate		: Boolean;
	lockedObject	: Object;
	
begin
	//	check if we have an unfinished selection
	self.closeIterator();
	
	//21 Jan 2013	NDL	Par 30699
	if self.myChangeTrackingRoot = null then
		return (JSSCTChangeTrackingInterface.SELECTION_INVALID_CLASS);
	endif;

	//	create the iterator and position at the first instance chronologically
	if not self.tryShareLockingObject(self.myChangeTrackingRoot.allChangeClasses) then
		return (JSSCTChangeTrackingInterface.SELECTION_INVALID_CLASS);	//	not quite correct, but will do for now
	endif;
	//	check that we have a valid class
	changeClass := self.myChangeTrackingRoot.allChangeClasses[pClassName, false];
	self.unlock(self.myChangeTrackingRoot.allChangeClasses);
	if changeClass = null then
		return (JSSCTChangeTrackingInterface.SELECTION_INVALID_CLASS);
	endif;
	//	check that we have a valid time period
	if (not pToTimeStamp.isValid()) or pToTimeStamp &gt; pFromTimeStamp then
	else
		return (JSSCTChangeTrackingInterface.SELECTION_INVALID_RANGE);
	endif;
	self.className := pClassName;
	self.fromTS := pFromTimeStamp;
	self.toTS := pToTimeStamp;
	self.isDelete := false;

	//	create the iterator and position at the first instance chronologically
	if not self.tryShareLockingObject(changeClass) then
		return (JSSCTChangeTrackingInterface.SELECTION_INVALID_CLASS);	//	not quite correct, but will do for now
	endif;
	
	lockedObject := changeClass;		// PAR #19821
	
	self.myIterator := changeClass.allChangesByTime.createIterator();
	changeClass.allChangesByTime.startKeyGeq(pFromTimeStamp, self.myIterator);

// arm the exception handler
	on Exception do handleObjectAlreadyInColl(exception);

	nullToDate := not self.toTS.isValid();
	beginLoad;
	while self.myIterator.next(changeObject) do
		if nullToDate or changeObject.changeTimestamp &lt;= self.toTS then
			if changeObject.changeTransactionID = null then
				if changeObject.isDeleteForUser( _ignoreDeletesForUser ) then	//07 Jan 2014	NDL	Par 33264
					continue;
				endif;
				self.allSelectedChanges.add(changeObject);
			endif;
		else
			break;
		endif;
	endwhile;
//	self.unlock(changeClass);		// PAR #19821 - this is ineffective inside beginLoad/endLoad
	endLoad;
	
	delete self.myIterator;
	self.myIterator := self.allSelectedChanges.createIterator();

	return (JSSCTChangeTrackingInterface.SELECTION_OK);

	
epilog
	// PAR 19821 - moved to epilog to ensure it's always done
	if lockedObject &lt;&gt; null then
		self.unlock(lockedObject);
	endif;
	
end;</source>
        <Parameter name="pClassName" type="String"/>
        <Parameter name="pFromTimeStamp" type="TimeStamp"/>
        <Parameter name="pToTimeStamp" type="TimeStamp"/>
        <Parameter name="_ignoreDeletesForUser" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="selectClassDeletes" id="894aa496-e74a-4e28-b8ee-1d8989af1567">
        <updating/>
        <source>selectClassDeletes(pClassName: String; pFromTimeStamp: TimeStamp; pToTimeStamp: TimeStamp; _ignoreDeletesForUser : String): Integer updating;

/*

Date		Who		Reason
08 Jun 2009	cnwkpd1	PAR #19821 - Ensure Change Class is always unlocked at exit

*/

vars
	deleteClass		: JSSCTChangeTrackingClass;
	deleteObject	: JSSCTChangeTrackingObject;
	nullToDate		: Boolean;
	lockedObject	: Object;
	
begin
	//	check if we have an unfinished selection
	self.closeIterator();

	if self.myChangeTrackingRoot = null then
		return (JSSCTChangeTrackingInterface.SELECTION_INVALID_CLASS);
	endif;

	//	create the iterator and position at the first instance chronologically
	if not self.tryShareLockingObject(self.myChangeTrackingRoot.allDeleteClasses) then
		return (JSSCTChangeTrackingInterface.SELECTION_INVALID_CLASS);	//	not quite correct, but will do for now
	endif;
	//	check that we have a valid class
	deleteClass := self.myChangeTrackingRoot.allDeleteClasses[pClassName, true];
	self.unlock(self.myChangeTrackingRoot.allDeleteClasses);
	if deleteClass = null then
		return (JSSCTChangeTrackingInterface.SELECTION_INVALID_CLASS);
	endif;
	//	check that we have a valid time period
	if (not pToTimeStamp.isValid()) or pToTimeStamp &gt; pFromTimeStamp then
	else
		return (JSSCTChangeTrackingInterface.SELECTION_INVALID_RANGE);
	endif;
	self.className := pClassName;
	self.fromTS := pFromTimeStamp;
	self.toTS := pToTimeStamp;
	self.isDelete := true;

	//	create the iterator and position at the first instance chronologically
	if not self.tryShareLockingObject(deleteClass) then
		return (JSSCTChangeTrackingInterface.SELECTION_INVALID_CLASS);	//	not quite correct, but will do for now
	endif;
	
	lockedObject := deleteClass;		// PAR #19821
	
	//	create the iterator and position at the first instance chronologically
	self.myIterator := deleteClass.allChangesByTime.createIterator();
	deleteClass.allChangesByTime.startKeyGeq(pFromTimeStamp, self.myIterator);

// arm the exception handler
	on Exception do handleObjectAlreadyInColl(exception);

	nullToDate := not self.toTS.isValid();
	beginLoad;
	while self.myIterator.next(deleteObject) do
		if nullToDate or deleteObject.changeTimestamp &lt;= self.toTS then
			if deleteObject.changeTransactionID = null then
				if deleteObject.isDeleteForUser( _ignoreDeletesForUser ) then	//07 Jan 2014	NDL	Par 33264
					continue;
				endif;
				self.allSelectedChanges.add(deleteObject);
			endif;
		else
			break;
		endif;
	endwhile;
//	self.unlock(deleteClass);		// PAR #19821 - ineffective inside beginLoad/endLoad
	endLoad;
	
	delete self.myIterator;
	self.myIterator := self.allSelectedChanges.createIterator();

	return (JSSCTChangeTrackingInterface.SELECTION_OK);
	
	
epilog
	// PAR 19821 - moved to epilog to ensure it's always done
	if lockedObject &lt;&gt; null then
		self.unlock(lockedObject);
	endif;
	
end;</source>
        <Parameter name="pClassName" type="String"/>
        <Parameter name="pFromTimeStamp" type="TimeStamp"/>
        <Parameter name="pToTimeStamp" type="TimeStamp"/>
        <Parameter name="_ignoreDeletesForUser" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
