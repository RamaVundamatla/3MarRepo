	self.buildCombosForHarbour();
		
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="handleRefreshView" id="557abd19-a38f-47ef-8e7a-a4f46164f106">
        <updating/>
        <source>handleRefreshView()updating;

vars

begin
	self.myHarbour := self.myTerminal.myHarbour;
	self.buildCombosForHarbour();	
	self.setMyCurrentWorkingVoyage(null);
	if self.myHarbour &lt;&gt; null then
