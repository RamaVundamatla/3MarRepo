        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:     08 February 2001 by cnwrs2
//
// Purpose:     Called in the load method of the form to enable processing to
//				be done at the lower level prior to other methods being called.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if app.isDevelopmentSystem then
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  WARNING - you need to reimplement this method in your own form.');
	endif;
	
/*
	// sample code
	
	self.allowAdd	 := true;
	self.allowDelete := true;
	self.allowFilter := true;
	self.allowPrintCurrent := true;
	self.allowPrintSelected := true;
	self.allowUpdate := true;
	
