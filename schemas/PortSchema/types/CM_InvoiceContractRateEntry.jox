    <JadeMethod name="validateMe" id="ef5df44d-5fa9-4999-ad11-dd004fc25495">
        <source>validateMe(_create : Boolean);
/*
Purpose:			

Date		Who		Reason
08 December 2022	navab1	TFS CR 55623 TASK 55677
*/

vars
	contractDtl : CM_InvoiceContractDetails;
	contractRate : CM_InvoiceContractRate;
	message : String;
begin
	
	if self.fromAmount &gt; self.toAmount then
		app.raiseCMException(Rate_entry_from_amoun_canno_gr, null, null);
	endif;
	
	if self.fromTS = null then
		app.raiseCMException(Rate_entry_from_datet_must_ent, null, null);
	elseif self.fromTS &gt; self.toTS then
		app.raiseCMException(Rate_entry_from_datet_canno_gr, null, null);
	elseif self.fromTS &lt; self.systemToLocalTime(app.actualTimeServer).subtractYears(100) then
		app.raiseCMException(Rate_entry_from_datet_canno_ol, null, null);
	endif;
	
	if self.toTS = null then
		app.raiseCMException(Rate_entry_dateti_must_entere, null, null);
	elseif self.toTS &lt; self.fromTS then
		app.raiseCMException(Rate_entry_datet_canno_less_th, null, null);
	elseif self.toTS &gt; self.systemToLocalTime(app.actualTimeServer).addYears(100) then
		app.raiseCMException(Rate_entry_datet_canno_older_t, null, null);
	endif;

	contractRate := self.myInvoiceContractRate;
	if contractRate = null then
		app.raiseCMException(Rate_entry_rate_must_entere, null, null);
	else
		if _create then
			if not self.doIConflictWithRangesForCreate(contractRate, message) then
				app.raiseCMException1(QuantityRangeConflict, message, null, self);
			endif;
			if not self.doIConflictWithDateRanges(contractRate, message) then // ### TFS BUG 56868 02MAR2023 NAVAB1
				app.raiseCMException1(Date_range_confl_with_other_da, message, null, self); // ### TFS BUG 56868 02MAR2023 NAVAB1
			endif;
			
			
		else
			if not self.doIConflictWithRangesForUpdate(contractRate, message) then
				app.raiseCMException1(QuantityRangeConflict, message, null, self);
			endif;
			if not self.doIConflictWithDateRanges(contractRate, message) then // ### TFS BUG 56868 02MAR2023 NAVAB1
				app.raiseCMException1(Date_range_confl_with_other_da, message, null, self); // ### TFS BUG 56868 02MAR2023 NAVAB1
			endif;
		endif;
		
		contractDtl := contractRate.myInvoiceContractDetail;
		if contractDtl &lt;&gt; null then
		
		
			if contractDtl.fromTS &gt; self.fromTS then
				app.raiseCMException(Rate_entry_from_datet_canno_be, null, null);
			endif;
			
			if contractDtl.toTS &lt; self.toTS then
				app.raiseCMException(Rate_entry_datet_canno_after_c, null, null);
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_create" type="Boolean"/>
    </JadeMethod>
</Class>
