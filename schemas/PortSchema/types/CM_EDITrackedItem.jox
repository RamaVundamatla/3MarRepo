    <JadeMethod name="getValueSpecial" id="058a172c-37e3-4b22-83fc-ae34763407d5">
        <source>getValueSpecial(_propName : String;	_xlationOperator : CM_Operator) : String;
//
// 16 Jan 2012	MSL CCMS 1009 PAR 29024
//
// this is the sister method to assignValueSpecial If you change this also look at changing assignValueSpecial
// an entry is normally required is the EtRow name and property name are different
// if the entry is an array
// if the property needs xlation
//
//05 Apr 2012	cnwrs1		Par 29391 - EDI RORO Stowage Advice hazard codes
//05 Jul 2012	cnwrs1	Par 29894 - write negative numbers out as negative not zero
// 10/09/2012	cnwmh5		PAR 30354 - Change Real / Decimal to use asStringJMTWithDecSeperator and no locales
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures

vars
	value 		: Any;
	property 	: Property;
	foundMatch	: Boolean;
begin

	if _propName = ETRow_OperatorCode then
		if _xlationOperator &lt;&gt; null then
			return _xlationOperator.getXlationForeignCode(self.getOperatorCode()[1:30], XLATION_TYPE_OPERATOR_BYOP, foundMatch);
		else
			return self.getOperatorCode();
		endif;
	elseif _propName = ETRow_ImCodes or
	   _propName = ETRow_Hazards or	
	   _propName = ETRow_Hazardous then
		return self.getHazardsAsString();
		
	elseif _propName = ETRow_VoyageCode then
		if _xlationOperator &lt;&gt; null then
			return _xlationOperator.getXlationForeignCode(self.getVoyageCode()[1:30], XLATION_TYPE_VOYAGETERMINAL, foundMatch);
		else
			return self.getVoyageCode();
		endif;
	else
		property := self.class.getPropertyInHTree(_propName);
		if property &lt;&gt; null then
			value := self.getPropertyValue(_propName).Any;
			if property.type = String then
				return value.String;
			elseif property.type = Real then
				return value.Real.asStringJMTWithDecSeparator(".");				//asStringJMT();    // 10/09/2012 cnwmh5 #30354
			elseif property.type = Integer then
				return value.Integer.asStringJMT();
			elseif property.type = Boolean then
				return value.Boolean.asStringJMT;
			elseif property.type = Decimal then
				return value.Decimal.asStringJMTWithDecSeparator(".");				//asCSVFormatString();	//05 Jul 2012	cnwrs1	Par 29894 - write negative numbers out as negative not zero  // 10/09/2012 cnwmh5 #30354
			else
				return value.String;
			endif;
		else
			return null;
		endif;
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyage" id="626b33ad-f9a6-4867-be2c-9f87e48fa5f9">
        <source>getVoyage() : CM_Voyage;
/*

Date		Who		Reason
16 October 2015	cnwer1	Initial creation PAR 37090

*/

vars
	voyageCode : String;
	term  :CM_Terminal;
begin
	voyageCode := self.getVoyageCode;
	if voyageCode = null then
		return null;
	endif;
	
	term := self.getMyTerminal;
	if term = null then
		return null;
	endif;
	
	return  term.lookupVoyage(voyageCode,null,false);
	
epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
