    <JadeMethod name="getManager" id="084b1211-2f00-4557-9f2d-b3cdf74ef3cc">
        <source>getManager(): JSSFMServiceManager protected;
// --------------------------------------------------------------------------------
// Created:		30 June 2002 by cnwdad1
//
// Purpose:		The standard JSS CoreSchema service object method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myServiceManager.JSSFMServiceManager;
end;</source>
        <access>protected</access>
        <ReturnType type="JSSFMServiceManager"/>
    </JadeMethod>
