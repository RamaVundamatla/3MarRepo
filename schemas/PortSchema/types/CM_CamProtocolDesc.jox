    <JadeMethod name="outputFileMessage" id="ffa2fe22-1f07-4530-8fa0-82c6fe7d674b">
        <updating/>
        <source>outputFileMessage(_camTaskHistory : CM_CamTaskHistory input; _message : String; _coll :HugeStringArray input) : String updating;
// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed _camTaskHistory parameter usage from io to input
// 19/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	str	:String;
begin
	str := _camTaskHistory.addFileDataLineEDIFACT(_message);
	
	if _coll &lt;&gt; null then
		_coll.add (str);
	endif;
	
	return str;
end;</source>
