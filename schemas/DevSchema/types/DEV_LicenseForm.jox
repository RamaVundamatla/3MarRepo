    <JadeMethod name="clientAdd" id="8836a93f-7a24-4dc5-a178-72aae0c2300b">
        <updating/>
        <source>clientAdd() updating, protected;
// ---------------------------------------------------------------------------
// Created:     06 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	clientName	: String;
	licClient	: DEV_LicenseClient;
	
begin

	read clientName;
	if clientName = null then
		return;
	endif;
	
	clientName := clientName.trimBlanks;
	
	if self.allClients.includesKey(clientName) then
		app.msgBox('A client with name (' &amp; clientName &amp; ') already exists.', 'Error', 0);
		return;
	endif;
	
	create licClient transient;
	licClient.setForCreate(clientName);
	
	self.allClients.add(licClient);
	
	self.initComboClient();
	// ### JIRA 33502 20DEC2024 NAVAB1 mode := Mode_New;	//08 Oct 2019	NDL	TFS 46169
	self.setCurrentClient(licClient);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="clientDelete" id="09b96ea5-c93c-42c1-986b-55815d2a8282">
        <updating/>
        <source>clientDelete() updating, protected;
// ---------------------------------------------------------------------------
// Created:     06 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	 audit : CMUI_LicenseAudit;
	 
	 userCode, clientName, licenseName, changeNote, dateChange : String;
	 changeTS : TimeStamp;
	 
begin

	if self.myCurrentClient = null then
		app.msgBox('You must select a client', 'Error', 0);
		return;
	endif;
	
	if app.msgBox('Delete client ' &amp; self.myCurrentClient.name, 'Delete', MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	
	self.allClients.remove(self.myCurrentClient);
	
	 // ### JIRA 36920 07JAN2026 NAVAB1
	userCode := process.signOnUserCode;
	changeTS := app.actualTimeAppServer;
	clientName := self.myCurrentClient.name;
	changeNote := "This client was deleted";
	beginTransaction;
	create audit;
	audit.setForCreate(userCode, "Client Deleted", clientName, changeNote, changeTS);
	commitTransaction;		
	
	delete self.myCurrentClient;
	
	self.myCurrentClient := null;

	// save the data in the "dataBase"
	self.saveAsXML();

	self.initComboClient();
	mode := 0;	//09 Oct 2019	NDL	TFS 46169
	self.setCurrentClient(self.allClients.first);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="clientSave" id="35855e5c-92dc-426d-98ac-81d5fca8e99a">
        <updating/>
        <source>clientSave() : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     06 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpClient,
	chkClient	: DEV_LicenseClient;
	tmpName		: String;
	numTerminals	: Integer;
	
begin

	tmpClient := self.myCurrentClient;
	
	if tmpClient = null then
		app.msgBox('Current client is null', 'Error', 1);
		return false;
	endif;

	tmpName := self.txtName.text.trimBlanks;
	
	chkClient := self.allClients[tmpName];
	
	if chkClient &lt;&gt; null and chkClient &lt;&gt; tmpClient then
		app.msgBox('A client with name (' &amp; tmpName &amp; ') already exists.', 'Error', 0);
		self.txtName.setFocus();
		return false;
	endif;
	
	numTerminals := self.txtNumTerminals.text.Integer;
	if numTerminals &lt; 1 then
		app.msgBox('You must be licensed for at least 1 terminal', 'Error', 0);
		self.txtNumTerminals.setFocus();
		return false;
	endif;
	
	tmpClient.setForUpdate(tmpName, numTerminals, self.chkSite.value, self.chkRealClient.value, self.txtNotes.text);

	// save the data in the "dataBase"
	self.saveAsXML();
	
	self.compareChanges(); // ### JIRA 36920 05JAN2026 NAVAB1
	
	// force a refresh of the client combo
	self.initComboClient();
	mode := 0;	//09 Oct 2019	NDL	TFS 46169
	self.setCurrentClient(tmpClient);
	
	return true;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cmbClient_click" id="dc3c5980-d088-42f5-b846-c3552f44c6c8">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbClient_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     05 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if self.hasClientDetailsChanged or
	   self.hasLicenseDtlsChanged then
		if app.msgBox('Data has changed.  Save Now?', 'Info', MsgBox_Yes_No + MsgBox_Information_Icon) = MsgBox_Return_Yes then
			self.doSave();
		endif;
	endif;
	mode := 0;	//09 Oct 2019	NDL	TFS 46169
	self.setCurrentClient(combobox.listObject.DEV_LicenseClient);

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
