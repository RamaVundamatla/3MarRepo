    <JadeMethod name="lstAddressPerson_dblClick" id="b1711983-354f-4932-bed4-4c9929559089">
        <controlMethod name="ListBox::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstAddressPerson_dblClick(listbox: ListBox input) updating;
// --------------------------------------------------------------------------------
// Created:		23 March 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	btnAddressBook.click(btnAddressBook);
epilog
	app.mousePointer	:=	Idle;
end;</source>
