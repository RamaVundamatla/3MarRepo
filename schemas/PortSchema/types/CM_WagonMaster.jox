    <JadeMethod name="pxyCreateUpdateProxy" id="1aba5643-5839-42bb-be58-52c482b6f76f">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
01 July 2009	cnwndl1	Initial creation
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/

vars
	tmpWagonMaster : CM_WagonMaster;
	damageInstance, pxyDamageInstance : CM_DamageInstance;
	completedOK		: Boolean;
begin
	tmpWagonMaster := inheritMethod();
	tmpWagonMaster.myWagonClass := self.myWagonClass;
	tmpWagonMaster.myCarrier := self.myCarrier;
	
	tmpWagonMaster.propogateChanges := AskPropogateChgs;

	foreach damageInstance in self.allDamageInstancesByPos  discreteLock do
		pxyDamageInstance := damageInstance.pxyGetProxyObject();
		if pxyDamageInstance = null then
			pxyDamageInstance := damageInstance.pxyCreateUpdateProxy().CM_DamageInstance;
		endif;
		pxyDamageInstance.setMySubject(tmpWagonMaster);
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return tmpWagonMaster;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete tmpWagonMaster;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="5b8c6029-faf9-4d7a-81f9-165ed58e55b2">
        <updating/>
        <source>setForCreate( pProxyWagonMaster : CM_WagonMaster) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2009	cnwndl1	Initial creation

*/

vars

begin

	self.id := pProxyWagonMaster.id;

	self.setForUpdate(pProxyWagonMaster);
	
	self.myRoot := app.myRoot;
	self.populateAllWagonsOnCreate();
	
epilog

end;</source>
        <Parameter name="pProxyWagonMaster" type="CM_WagonMaster"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="15375acf-1aa4-4efa-bd5f-1a0764276bd0">
        <updating/>
        <source>setForUpdate( pProxyWagonMaster : CM_WagonMaster ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2009	cnwndl1	Initial creation

*/

vars
newDamageInstance, damageInstance : CM_DamageInstance;
	changedValues : StringArray;
	wagon : CM_Wagon;
	
begin	
	create changedValues transient;
	
	self.autoCreated := pProxyWagonMaster.autoCreated;
	self.myWagonClass := pProxyWagonMaster.myWagonClass;
	
	if self.myCarrier &lt;&gt; pProxyWagonMaster.myCarrier then
		self.myCarrier := pProxyWagonMaster.myCarrier;
		changedValues.add(CM_WagonMaster::myCarrier.name);
	endif;
	
	if self.maxCargoHeight &lt;&gt; pProxyWagonMaster.getMaxCargoHeight then
		self.maxCargoHeight := pProxyWagonMaster.getMaxCargoHeight;	//Par 21924
		changedValues.add(CM_WagonMaster::maxCargoHeight.name);
	endif;
	
	if self.maxCargoWeight &lt;&gt; pProxyWagonMaster.getMaxCargoWeight then
		self.maxCargoWeight := pProxyWagonMaster.getMaxCargoWeight;	//Par 21924
		changedValues.add(CM_WagonMaster::maxCargoWeight.name);
	endif;
	
	if self.tareWeight &lt;&gt; pProxyWagonMaster.getTareWeight then
		self.tareWeight := pProxyWagonMaster.getTareWeight;	//Par 21924
		changedValues.add(CM_WagonMaster::tareWeight.name);
	endif;
		
	if pProxyWagonMaster.propogateChanges = DoNotPropogateChgs then
		// do nothing
	elseif pProxyWagonMaster.propogateChanges = DoPropogateChgs then
		if not self.allCurrentWagons.isEmpty and not changedValues.isEmpty then
			foreach wagon in allCurrentWagons do
				wagon.updateValuesFromMaster( changedValues );
			endforeach;
		endif;
	endif;
	
	propogateChanges := DoNotPropogateChgs;

	self.allDamageInstancesByPos.purge;
	/*### TFS BUG 58868 27JUN2023 NAVAB1
	
	// #### No Damage on Fleet File anymore, was not used on 'visit' objects. 
	// #### Also problem showing advanced damage for fleet as most damage code/description type master data is at terminal level.
	foreach damageInstance in pProxyWagonMaster.allDamageInstancesByPos do
		damageInstance.validateForUpdate();
		create newDamageInstance persistent;
		newDamageInstance.setForUpdateSubject(damageInstance,self);	
	endforeach;
	*/

	
epilog

	delete changedValues;
	
end;</source>
        <Parameter name="pProxyWagonMaster" type="CM_WagonMaster"/>
    </JadeMethod>
