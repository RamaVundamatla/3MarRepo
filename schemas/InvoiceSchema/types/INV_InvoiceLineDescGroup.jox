    <JadeMethod name="populateEntDetailTable" id="41809202-e2e5-463c-8eba-dfe1361a2707">
        <source>populateEntDetailTable();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	entRow			: EntTableRow;
	invoiceType : CM_InvoiceLineDescGroup;
	displayValue	: String;	
	prodAttr		: String;
	handlingType	: CM_HandlingType;
	sysType			: Boolean;
	entDef		:EntTableDef;
begin
	entDef := app.myController.getEntTableDef(ETDef_InvMaintLineGroupEnt);

	invoiceType := self.myCurrentObject.CM_InvoiceLineDescGroup;
	if self.mode = Mode_Add then
		self.tblEntDetail.clearValues();
		return;
	endif;	
	if invoiceType = null then
		return;
	endif;
	
	foreach entRow in entDef.allEntTableRows do
		if invoiceType &lt;&gt; null then
			displayValue := invoiceType.getDisplayStringForAttribute(entRow.name, false).String;
		else
			displayValue := null;
		endif;
		
		tblEntDetail.setValueByName(entRow.name, displayValue);		
	endforeach;

	self.cmbChargeType.cnEcSetObjectIndex(self.myCurrentObject.CM_InvoiceLineDescGroup.myMinimumChargeInvoiceLineType);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="affbee76-e3a0-49b1-908f-7a61bc073991">
