------------------------------------------------------------------------
*/
begin
	return (_ti = self.myTrackedItem);
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="2399c4d0-7962-47d1-82aa-01c54f69e7c8">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 April 2009	cnwer1	Initial creation 
						PAR 19566 moved from erase was not being called when a collection of these objects
								were purged

*/

vars

	invalidTi : Boolean;
	invalidRtq : Boolean;
	iter : Iterator;
	rtQueueEntry : CM_RTQueueEntry;
	job : CM_Job;
	
begin

	// 30 August 2012	NDL	Par 30252 - ship lander acting as loader for a crane queue or a wpoint queue
	// the CM_TrackedItem::cleanupMoveControllers was deleteing the q entry but leaving the Q in 'allQueues' on tracked item
	on Exception do app.handleDeletedObject( exception, self.myTrackedItem, invalidTi );
	on Exception do app.handleDeletedObject( exception, rtQueueEntry, invalidRtq );
	if self.myTrackedItem &lt;&gt; null then
		iter := self.allRTQueueEntries.createIterator;
		while iter.next( rtQueueEntry ) do
			self.myTrackedItem.removeFromQueue( rtQueueEntry );
		endwhile;
	endif;
	on Exception do null;
	on Exception do null;

	// May just be unqueuing, set WLE FM to plannedFM.
	if self.myFutureMovePlanned &lt;&gt; null then
		self.myFutureMovePlanned.setMyWorkListEntry(self.myWorkListEntry, true);
		self.myFutureMovePlanned.setMyWorkListEntryDR(self.myWorkListEntryDR, true); // tfs42840 jlgzm1 31/05/2019
	endif;
	
	on Exception do app.handleDeletedObject( exception, self.myTrackedItem, invalidTi );	//28 Apr 2020	NDL	Found in unit tests
	
	if self.myTrackedItem &lt;&gt; null then
		self.causeUpdateDisplayEvents(self.myTrackedItem, self.allLocationsControllers);
		if invalidTi then	//28 Apr 2020	NDL	Found in unit tests
			return;
		endif;
		// DVB added.
		self.myTrackedItem.refreshMyFutureLocations(QUEUE_MODE,self); // PAR 9747
		self.myTrackedItem.setHazardLocationsForMode(QUEUE_MODE, true); // PAR 16097
	endif;

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="getAllLocationsString" id="c3a616a2-dc1d-44c4-9a59-7f10e3f08745">
        <source>getAllLocationsString(): String;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 06/11/2024	navdap1		MTN-18897 EUP | FR 53485 EUP - Warehouse Yard Allocation
// ---------------------------------------------------------------------------
vars
	lc	: CM_LocationsController;
	theString, tmpString : String;
	
	gcGroup : CM_GeneralCargoAllocGroup;	//22 Jul 2021	NDL	TFS 51429
	allGroups : CM_LCSet;	//22 Jul 2021	NDL	TFS 51429
	isAutoPlanFullGC : Boolean;
begin
	
	isAutoPlanFullGC := self.myTerminal.getAutoPlanAllowFullGCArea; //17Feb2023 navsp1 TFS 56543
	
	foreach	lc in self.allLocationsControllers do
		//22 Jul 2021	NDL	TFS 51429
		if lc.isGCAllocCont then
			gcGroup := lc.CM_GeneralCargoAllocController.myGroup;
			if gcGroup &lt;&gt; null then
				if allGroups = null then
					create allGroups transient;
					allGroups.add( gcGroup );
					//and let it fall through and have teh name added
				elseif allGroups.includes( gcGroup ) then
					continue;
					//same group, no need to add it again.
				else
					//add it
					allGroups.add( gcGroup );
					//and let it fall through and have this name added
				endif;
			endif;
		endif;
	
		tmpString := lc.getFullIdForTI(true);
		if self.isMoveToFullGCArea then				// MTN-18897
			tmpString := lc.myTerminalArea.id;
		endif;
		
		if theString = null then
			theString := tmpString;
		else
			theString :=  theString &amp; ", " &amp; tmpString;
		endif;
	endforeach;
	
	return theString[1:30];			// 13/01/2010 cnwmh5 #22132
	
epilog

	delete allGroups;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationsArray" id="0b3b9c11-4201-44a4-8514-d14174dca1b6">
