<CollClass name="CM_HazardByCodeDict" id="d31547eb-229a-49a0-be89-37beed7c08ca">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="CM_Hazard"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="stops"/>
    <MemberKey>
        <property name="CM_Hazard::code"/>
    </MemberKey>
    <JadeMethod name="getMatchingHazard" id="983baae7-d97e-4892-beee-851898e2036d">
        <source>getMatchingHazard( _haz : Any ):CM_TIHazard;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 January 2018	jlgndl1	Initial creation	TFS 36824

*/

vars

	iter : Iterator;
	hazCode : String;
	tiHazard : CM_TIHazard;

begin

	if self.isEmpty then
		return null;
	endif;
	
	if _haz.isKindOf(CM_Hazard) then
		hazCode := _haz.CM_Hazard.code;
	elseif _haz.isKindOf(CM_HazardClass) then
		hazCode := _haz.CM_HazardClass.code;
	else
		hazCode := _haz.String;
	endif;

	iter := self.createIterator;
	while iter.next( tiHazard ) do
		if hazCode = tiHazard.code then
			return tiHazard;
		endif;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_haz" type="Any"/>
        <ReturnType type="CM_TIHazard"/>
    </JadeMethod>
    <JadeMethod name="includesHazard" id="520fe894-85b1-446f-9377-2e736fb224cb">
        <source>includesHazard( _haz : Any ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	iter : Iterator;
	hazCode : String;
	tiHazard : CM_TIHazard;

begin

	if self.isEmpty then
		return false;
	endif;
	
	if _haz.isKindOf(String) then
		hazCode := _haz.String;
	elseif _haz.isKindOf(CM_Hazard) then
		hazCode := _haz.CM_Hazard.code;
	elseif _haz.isKindOf(CM_HazardClass) then
		hazCode := _haz.CM_HazardClass.code;
	else
		return false;
	endif;

	iter := self.createIterator;
	while iter.next( tiHazard ) do
		if hazCode = tiHazard.code then
			return true;
		endif;
	endwhile;
	
	return false;

epilog

	delete iter;

end;</source>
        <Parameter name="_haz" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
