    <JadeMethod name="doQuery" id="ae348985-f209-4966-8560-51cf2aa3af91">
        <updating/>
        <source>doQuery(_qDef: CM_QueryDefinition) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
*/
//17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts

vars

	bankSet		 : ObjectSet;
	drSet 		 : ObjectSet;
	crit 		 : CM_SelectorCriteriaLine;
	obj 		 : Object;
	int		     : Integer;
	terminal     : CM_Terminal;
	termSet      : ObjectSet;
	userTermDict : CM_UserTerminalByTerminalDict;
	userTerm 	 : CM_UserTerminal;
	bank 		 : CM_Bank;

begin

	self.reset();
	
	create termSet transient;
	create bankSet transient;
	create drSet transient;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_InvoiceContract::myTerminal.name, CM_InvoiceContract.name];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_IsOneOf then
			crit.myQueryOperator.getSearchValueAsObjectSet(termSet);
		elseif crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then
			terminal := crit.myQueryOperator.getSearchValue().CM_Terminal;
		endif;
	endif;
	if termSet.isEmpty then
		if terminal &lt;&gt; null then
			termSet.add(terminal);
		else
			userTermDict := app.myPassport.myUser.allUserTerminals;
			foreach userTerm in userTermDict do
				termSet.add(userTerm.getMyTerminal);
			endforeach;
		endif;
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_InvoiceContract::myBusinessUnit.name, CM_InvoiceContract.name];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_IsOneOf then
			crit.myQueryOperator.getSearchValueAsObjectSet(bankSet);
		elseif crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then
			self.myBank := crit.myQueryOperator.getSearchValue().CM_Bank;
		endif;
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_InvoiceContract::getDebtor.name, CM_InvoiceContract.name];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_IsOneOf then
			crit.myQueryOperator.getSearchValueAsObjectSet(drSet);
		elseif crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then
			self.myDebtor := crit.myQueryOperator.getSearchValue().CM_Debtor;
		endif;
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_InvoiceContract::fromTS.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.isKindOf(CM_QDateRange) then
			self.fromTsStart := crit.myQueryOperator.CM_QDateRange.getSearchValueFromDate().TimeStamp;
			self.fromTsEnd := crit.myQueryOperator.CM_QDateRange.getSearchValueToDate().TimeStamp;
			self.fromTsEnd.setTime('23:59:59:999'.Time);
		endif;
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_InvoiceContract::toTS.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.isKindOf(CM_QDateRange) then
			self.toTsStart := crit.myQueryOperator.CM_QDateRange.getSearchValueFromDate().TimeStamp;
			self.toTsEnd := crit.myQueryOperator.CM_QDateRange.getSearchValueToDate().TimeStamp;
			self.toTsEnd.setTime('23:59:59:999'.Time);
		endif;
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_InvoiceContract::getFromTSDetls.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.isKindOf(CM_QDateRange) then
			self.fromTSDetlsSt := crit.myQueryOperator.CM_QDateRange.getSearchValueFromDate().TimeStamp;
			self.fromTSDetlsEnd := crit.myQueryOperator.CM_QDateRange.getSearchValueToDate().TimeStamp;
			self.fromTsEnd.setTime('23:59:59:999'.Time);
		endif;
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_InvoiceContract::getToTSDetls.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.isKindOf(CM_QDateRange) then
			self.toTSDetlsSt := crit.myQueryOperator.CM_QDateRange.getSearchValueFromDate().TimeStamp;
			self.toTSDetlsEnd := crit.myQueryOperator.CM_QDateRange.getSearchValueToDate().TimeStamp;
			self.toTSDetlsEnd.setTime('23:59:59:999'.Time);
		endif;
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_InvoiceContract::getFromTSRateEntry.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.isKindOf(CM_QDateRange) then
			self.fromTSEntrySt := crit.myQueryOperator.CM_QDateRange.getSearchValueFromDate().TimeStamp;
			self.fromTSEntryEnd := crit.myQueryOperator.CM_QDateRange.getSearchValueToDate().TimeStamp;
			self.fromTSEntryEnd.setTime('23:59:59:999'.Time);
		endif;
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_InvoiceContract::getToTSRateEntry.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.isKindOf(CM_QDateRange) then
			self.toTSEntrySt := crit.myQueryOperator.CM_QDateRange.getSearchValueFromDate().TimeStamp;
			self.toTSEntryEnd := crit.myQueryOperator.CM_QDateRange.getSearchValueToDate().TimeStamp;
			self.toTSEntryEnd.setTime('23:59:59:999'.Time);
		endif;
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_InvoiceContract::contractId.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then
			contractId := crit.myQueryOperator.getSearchValue().String;
		endif;
	endif;
	
	
	if self.myDebtor &lt;&gt; null then
		if not bankSet.isEmpty then
			foreach obj in bankSet do
				self.myBank := obj.CM_Bank;
				self.doSearch();
			endforeach;
		else
			self.doSearch();
		endif;
		
	elseif self.myBank &lt;&gt; null then
		if not drSet.isEmpty then
			foreach obj in drSet do
				self.myDebtor := obj.CM_Debtor;
				self.doSearch();
			endforeach;
		else
			self.doSearch();
		endif;
	
	elseif not bankSet.isEmpty then
		foreach obj in bankSet do
			self.myBank := obj.CM_Bank;
			self.doSearch();
		endforeach;
		
	else
		foreach obj in termSet do
			terminal := obj.CM_Terminal;
			foreach bank in terminal.companies do
				bankSet.addNoDuplicates(bank,false);
			endforeach;
		endforeach;
		foreach obj in bankSet do
			self.myBank := obj.CM_Bank;
			self.doSearch();
		endforeach;
	
	endif;
	
epilog
	delete bankSet;
	delete drSet;
	delete termSet;
end;</source>
        <Parameter name="_qDef" type="CM_QueryDefinition"/>
    </JadeMethod>
    <JadeMethod name="doSearch" id="a0240f45-293e-4491-8c15-eeef8f0a21bb">
        <updating/>
        <source>doSearch() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
*/

vars
	iter 	    : Iterator;
	invoiceContract     : CM_InvoiceContract;
	breakOut    : Boolean;
	passport    : CM_Passport;
	startObject : Object;
begin

	passport := app.myPassport;
	
	if self.fromTSEntrySt.isValid()
		or self.fromTSEntryEnd.isValid()
		or self.toTSEntrySt.isValid()
		or self.toTSEntryEnd.isValid() then
		self.getContractsForRateDates();
	elseif self.fromTSDetlsSt.isValid()
		or self.fromTSDetlsEnd.isValid()
		or self.toTSDetlsSt.isValid()
		or self.toTSDetlsEnd.isValid() then
		self.getContractsForDetailDates();
	elseif self.fromTsStart.isValid()
		or self.fromTsEnd.isValid()
		or self.toTsStart.isValid()
		or self.toTsEnd.isValid() then
		self.getContractsForDates();
	elseif self.myDebtor &lt;&gt; null then
		self.getContractsForDebtors();
	elseif self.contractId &lt;&gt; null then
		self.getContractsForId();
	else
		self.getContractsForBU();
	endif;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getContractsForBU" id="67bb0d27-1eaa-43db-b1ca-60907f210cb9">
        <updating/>
        <source>getContractsForBU() updating;
/*
Purpose:			

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
*/

vars
	contract : CM_InvoiceContract;
	breakOut    : Boolean;
begin
	
	foreach contract in self.myBank.allInvoiceContractsById discreteLock do
		if self.includesObject(contract, breakOut, app.myPassport) then
			self.addObjectToSet(contract);
		endif;
		if breakOut	or self.breakOutOfSearch then
			break;
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getContractsForDates" id="3d94917a-c495-4ac5-aab2-70959567eef0">
        <updating/>
        <source>getContractsForDates() updating;
/*
Purpose:			

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
*/

vars
	debtor : CM_Debtor;
	contract : CM_InvoiceContract;
	iter : Iterator;
	breakOut : Boolean;
begin

	if self.fromTsStart.isValid() then
		contract := self.myBank.allInvoiceContractsByFromTS.getAtKeyGeq(self.fromTsStart);
		iter := self.myBank.allInvoiceContractsByFromTS.createIterator();
		if contract = null then
			contract := self.myBank.allInvoiceContractsByFromTS.first;
		endif;
			
		iter.startAtObject(contract);
		
		while iter.next(contract) do : outerloop
			if self.fromTsEnd.isValid() then
				if contract.fromTS &gt; self.fromTsEnd then
					break outerloop;
				endif;
			endif;
			if self.includesObject(contract, breakOut, app.myPassport) then
				self.addObjectToSet(contract);
			endif;
			if breakOut	or self.breakOutOfSearch then
				break;
			endif;
				
		endwhile;

		delete iter;
		
		return;
	endif;
	
	// ### Contract fromTS filter has an end range, no start range
	if self.fromTsEnd.isValid() then
		contract := self.myBank.allInvoiceContractsByFromTS.first;
		iter := self.myBank.allInvoiceContractsByFromTS.createIterator();
		iter.startAtObject(contract);
		
		while iter.next(contract) do : outerloop
			if contract.fromTS &gt; self.fromTsEnd then
				break outerloop;
			endif;
			
			if self.includesObject(contract, breakOut, app.myPassport) then
				self.addObjectToSet(contract);
			endif;
			
			if breakOut	or self.breakOutOfSearch then
				break;
			endif;
		endwhile;
	
		delete iter;
		
		return;
	endif;
	
	// ### Contract toTS filter has a start range
	if self.toTsStart.isValid() then
		contract := self.myBank.allInvoiceContractsByToTS.getAtKeyGeq(self.toTsStart);
		iter := self.myBank.allInvoiceContractsByToTS.createIterator();
		
		iter.startAtObject(contract);
		
		while iter.next(contract) do : outerloop
			if self.toTsEnd.isValid() then
				if contract.toTS &gt; self.toTsEnd then
					break outerloop;
				endif;
			endif;
			
			if self.includesObject(contract, breakOut, app.myPassport) then
				self.addObjectToSet(contract);
			endif;
			
			if breakOut	or self.breakOutOfSearch then
				break;
			endif;
				
		endwhile;

		delete iter;
		
		return;
	endif;
	
	// ### Contract toTS filter has an end range, no start range
	if self.toTsEnd.isValid() then
		contract := self.myBank.allInvoiceContractsByToTS.first;
		iter := self.myBank.allInvoiceContractsByToTS.createIterator();
		
		iter.startAtObject(contract);
		
		while iter.next(contract) do : outerloop
			if contract.fromTS &gt; self.toTsEnd then
				break outerloop;
			endif;

			if self.includesObject(contract, breakOut, app.myPassport) then
				self.addObjectToSet(contract);
			endif;
			
			if breakOut	or self.breakOutOfSearch then
				break;
			endif;
				
		endwhile;

		delete iter;
		
		return;
	endif;

epilog
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="getContractsForDebtors" id="d0b04626-e193-4c88-92ca-c46b18988053">
        <updating/>
        <source>getContractsForDebtors() updating;
/*
Purpose:			

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
*/

vars
	contract : CM_InvoiceContract;
	breakOut : Boolean;
begin
	
	foreach contract in myDebtor.allInvoiceContracts discreteLock do
		if self.includesObject(contract, breakOut, app.myPassport) then
			self.addObjectToSet(contract);
		endif;
		
		if breakOut	or self.breakOutOfSearch then
			break;
		endif;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getContractsForDetailDates" id="365f187a-6820-40fc-9044-e9d340735c63">
        <updating/>
        <source>getContractsForDetailDates() updating;
/*
Purpose:			

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
*/

vars
	debtor : CM_Debtor;
	contract : CM_InvoiceContract;
	detail : CM_InvoiceContractDetails;
	iter : Iterator;
	contractSet : CM_InvoiceContractSet;
	breakOut : Boolean;
begin
	create contractSet transient;
	
	// ### DETAIL 'FROM' DATE RANGE
	if self.fromTSDetlsSt.isValid() 
	or self.fromTSDetlsEnd.isValid() then
		if self.fromTSDetlsSt.isValid() then
			detail := self.myBank.allInvoiceContractDetailByFrom.getAtKeyGeq(self.fromTSDetlsSt);
		endif;
		
		if detail = null then
			detail := self.myBank.allInvoiceContractDetailByFrom.first;
		endif;
		iter := self.myBank.allInvoiceContractDetailByFrom.createIterator();
		
		if detail = null then
			return;
		endif;
		
		iter.startAtObject(detail);
		
		while iter.next(detail) do : outerloop
			if self.fromTSDetlsEnd.isValid() then
				if detail.fromTS &gt; self.fromTSDetlsEnd then
					break outerloop;
				endif;
			endif;

			contract := detail.myInvoiceContract;
			contractSet.tryAdd(contract);
		endwhile;

		delete iter;
	
	// ### DETAIL 'TO' DATE RANGE
	elseif self.toTSDetlsSt.isValid() 
	or self.toTSDetlsEnd.isValid() then
		if self.toTSDetlsSt.isValid() then
			detail := self.myBank.allInvoiceContractDetailByTo.getAtKeyGeq(self.toTSDetlsSt);
		else	// ### Detail toTS filter has an end range, no start range
			detail := self.myBank.allInvoiceContractDetailByTo.first;
		endif;
		
		iter := self.myBank.allInvoiceContractDetailByTo.createIterator();
		
		iter.startAtObject(detail);
		
		while iter.next(detail) do : outerloop
			if self.toTSDetlsEnd.isValid() then
				if detail.fromTS &gt; self.toTSDetlsEnd then
					break outerloop;
				endif;
			endif;

			contract := detail.myInvoiceContract;
			contractSet.tryAdd(contract);
		endwhile;

		delete iter;	

	endif;

	
	foreach contract in contractSet discreteLock do
		if self.includesObject(contract, breakOut, app.myPassport) then
			self.addObjectToSet(contract);
		endif;
		
		if breakOut	or self.breakOutOfSearch then
			break;
		endif;
	endforeach;
	
epilog
	delete iter;
	delete contractSet;

end;</source>
    </JadeMethod>
    <JadeMethod name="getContractsForId" id="9ebfbb2c-8f28-4386-8466-8d75ec579443">
        <updating/>
        <source>getContractsForId() updating;
/*
Purpose:			

Date		Who		Reason
30 December 2022	navab1	TFS CR 55645 TASK 55662
*/

vars

	contract : CM_InvoiceContract;
	iter : Iterator;
	breakOut : Boolean;
begin
	contract := self.myBank.allInvoiceContractsById[self.contractId,null];
	
	if contract &lt;&gt; null then
		iter := self.myBank.allInvoiceContractsById.createIterator();
		iter.startAtObject(contract);
		if contract = null then
			contract := self.myBank.allInvoiceContractsById.first;
		endif;
	
		while iter.next(contract) do : outerloop
			if contract.contractId &lt;&gt; self.contractId then
				break;
			endif;
			
			if self.includesObject(contract, breakOut, app.myPassport) then
				self.addObjectToSet(contract);
			endif;
			
			if breakOut	or self.breakOutOfSearch then
				break;
			endif;
		endwhile;
		
	else 
		foreach contract in self.myBank.allInvoiceContractsById discreteLock do
			if self.includesObject(contract, breakOut, app.myPassport) then
				self.addObjectToSet(contract);
			endif;
			
			if breakOut	or self.breakOutOfSearch then
				break;
			endif;
		endforeach;
	endif;

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="getContractsForRateDates" id="91a8ba95-8851-415c-b770-258e502071d9">
        <updating/>
        <source>getContractsForRateDates() updating;
/*
Purpose:			

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
*/

vars
	debtor 		: CM_Debtor;
	rate 		: CM_InvoiceContractRate;
	rateEntry 	: CM_InvoiceContractRateEntry;
	contract 	: CM_InvoiceContract;
	detail 		: CM_InvoiceContractDetails;
	iter 		: Iterator;
	contractSet : CM_InvoiceContractSet;
	breakOut 	: Boolean;
begin
	
	create contractSet transient;
	
	if self.fromTSEntrySt.isValid() 
	or self.fromTSEntryEnd.isValid() then
		if self.fromTSEntrySt.isValid() then
			rateEntry := self.myBank.allInvoiceContractRteEntByFrom.getAtKeyGeq(self.fromTSEntrySt);
		else
			rateEntry := self.myBank.allInvoiceContractRteEntByFrom.first;
		endif;
		iter := self.myBank.allInvoiceContractRteEntByFrom.createIterator();
		
		if rateEntry = null then
			return;
		endif;
		
		iter.startAtObject(rateEntry);
		
		while iter.next(rateEntry) do : outerloop
			if self.fromTSEntryEnd.isValid() then
				if rateEntry.fromTS &gt; self.fromTSEntryEnd then
					break outerloop;
				endif;
			endif;

			rate := rateEntry.myInvoiceContractRate;
			
			detail := rate.myInvoiceContractDetail;
			contract := detail.myInvoiceContract;
			contractSet.tryAdd(contract);
		endwhile;

		delete iter;
	
	elseif self.toTSEntrySt.isValid() 
	or self.toTSEntryEnd.isValid() then
		if self.toTSEntrySt.isValid() then
			rateEntry := self.myBank.allInvoiceContractRteEntByTo.getAtKeyGeq(toTSEntrySt);
		else
			rateEntry := self.myBank.allInvoiceContractRteEntByTo.first;
		endif;
		
		iter := self.myBank.allInvoiceContractRteEntByTo.createIterator();
		
		iter.startAtObject(rateEntry);
		
		while iter.next(rateEntry) do : outerloop
			if self.toTSEntryEnd.isValid() then
				if rateEntry.fromTS &gt; self.toTSEntryEnd then
					break outerloop;
				endif;
			endif;

			rate := rateEntry.myInvoiceContractRate;
			
			detail := rate.myInvoiceContractDetail;
			contract := detail.myInvoiceContract;
			contractSet.tryAdd(contract);
		endwhile;

		delete iter;	

	endif;

	
	foreach contract in contractSet discreteLock do
		if self.includesObject(contract, breakOut, app.myPassport) then
			self.addObjectToSet(contract);
		endif;
		
		if breakOut	or self.breakOutOfSearch then
			break;
		endif;
	endforeach;
		
	
epilog
	delete iter;
	delete contractSet;

end;</source>
