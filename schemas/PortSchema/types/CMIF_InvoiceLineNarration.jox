<Class name="CMIF_InvoiceLineNarration" id="c047980e-ebb3-4823-b078-9c7e6390058c">
    <superclass name="CMIF_Object"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <JadeMethod name="doExtractInvLnTypTransCsvFile" id="79b63e7a-a88d-40ea-8433-054be2b00013">
        <updating/>
        <source>doExtractInvLnTypTransCsvFile(_file : File input; _bank : CM_Bank input; _cmifMonitor : CMIF_Monitor io) : Integer updating;
/*

Purpose:			Extracts Invoice Line Translations to a CSV File

Parameters:			_file			File			The file to extract the data to
					_bank			CM_Bank			The bank to use to get the data from
					_cmifMonitor	CMIF_Monitor	The monitor to use to show update on the UI

Return Value:		Integer	Representing how many records were extracted

Date		Who		Reason
05 September 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

vars
	count,
	totalCount,
	translationsExported 	: Integer;
	headers,
	msg						: String;
	invLineType				: CM_InvoiceLineDesc;
	invLineNarration 		: CM_InvoiceLineNarration;
	locale 					: CM_Locale;
	terminal 				: CM_Terminal;
	localeName,
	terminalCode 			: String;
	
begin
	if _bank = null then
		app.raiseCMException(Bank_selected, null, null);
	endif;
	
	headers := "mode,terminalCode,businessUnit,localeName,invoiceLineTypeNarration,translatednarration,translatedUnitNarration";
	_file.writeLine(headers);
	
	if _bank.invoiceLineDescriptors.isEmpty then
		return 0;
	endif;
	
	totalCount := _bank.invoiceLineDescriptors.size;
	
	foreach invLineType in _bank.invoiceLineDescriptors do
		count += count;
		foreach invLineNarration in invLineType.allInvoiceLineNarrations do
			translationsExported += 1;
			terminalCode := null;
			terminal := _bank.terminal;
			if terminal &lt;&gt; null then
				terminalCode := terminal.code;
			endif;
			
			localeName := null;
			locale := invLineNarration.myLocale;
			if locale &lt;&gt; null then
				localeName := locale.localeDescription;
			endif;
			
			msg := ',' &amp; terminalCode &amp; ',' &amp; _bank.code &amp; ',' &amp; localeName &amp; ',' &amp; invLineType.narration &amp; ',' &amp; invLineNarration.narration &amp; ',' &amp; invLineNarration.unitNarration;
			_file.writeLine(msg);
			
		endforeach;
		
		if _cmifMonitor &lt;&gt; null then
			_cmifMonitor.updateProgress(app.getErrorString(Writing_export_file), totalCount, count);
			
		endif;
		
	endforeach;
	
	return translationsExported;
	
end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_bank" type="CM_Bank" usage="input"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doExtractInvLnTypTransXmlFile" id="eef3df40-8f79-4d5d-b9db-50710c291bb8">
        <source>doExtractInvLnTypTransXmlFile(_file : File input; _bank : CM_Bank input) : Integer;
/*

Purpose:			Extracts Invoice Line Translations to a XML File

Parameters:			_file			File			The file to extract the data to
					_bank			CM_Bank			The bank to use to get the data from
					_cmifMonitor	CMIF_Monitor	The monitor to use to show update on the UI

Return Value:		Integer	Representing how many records were extracted

Date		Who		Reason
05 September 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

vars
	count				: Integer;
	msg					: String;
	invLineType			: CM_InvoiceLineDesc;
	invLineNarration 	: CM_InvoiceLineNarration;
	locale 				: CM_Locale;
	terminal 			: CM_Terminal;
	localeName,
	terminalCode		: String;
	
begin
	msg := '&lt;invoiceLineTranslations&gt;';
	_file.writeLine(msg);
	foreach invLineType in _bank.invoiceLineDescriptors do
		foreach invLineNarration in invLineType.allInvoiceLineNarrations do
			count := count + 1;
			msg := '&lt;lineTranslation&gt;';
			_file.writeLine(msg);
			
			msg := self.formatAsXML("mode", "");
			_file.writeLine(msg);
			
			terminalCode := null;
			terminal := _bank.terminal;
			if terminal &lt;&gt; null then
				terminalCode := terminal.code;
			endif;
			
			msg := self.formatAsXML("terminalCode", terminalCode);
			_file.writeLine(msg);
			
			msg := self.formatAsXML("businessUnit", _bank.code);
			_file.writeLine(msg);
			
			localeName := null;
			locale := invLineNarration.myLocale;
			if locale &lt;&gt; null then
				localeName := locale.localeDescription;
			endif;
				
			msg := self.formatAsXML("localeName", localeName);
			_file.writeLine(msg);
			
			msg := self.formatAsXML("invoiceLineTypeNarration", invLineType.narration);
			_file.writeLine(msg);
			
			msg := self.formatAsXML("translatedNarration", invLineNarration.narration);
			_file.writeLine(msg);
			
			msg := self.formatAsXML("translatedUnitNarration", invLineNarration.unitNarration);
			_file.writeLine(msg);
			
			msg := '&lt;/lineTranslation&gt;';
			_file.writeLine(msg);
		endforeach;
	endforeach;
	msg := '&lt;/invoiceLineTranslations&gt;';
	_file.writeLine(msg);
	
	return count;
	
end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_bank" type="CM_Bank" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doLoadInvLnTypTransCsvFile" id="6a79256e-f2dd-4883-bfa3-7cf83c5330e7">
        <source>doLoadInvLnTypTransCsvFile(_file : File; _proxyUArray, _proxyDArray : ObjectArray input; 
							   _errorStore : CM_ErrorSet input; _bank : CM_Bank; _noLines : Integer io);
/*

Purpose:			Loads Invoice Line Translations from a CSV File

Parameters:			_file			File			The file to extract the data to
					_proxyUArray	ObjectArray		Holds the items we want to create or update
					_proxyDArray	ObjectArray		Holds the items we want to delete
					_errorStore		CM_ErrorSet		A collection to hold all the errors encountered
					_bank			CM_Bank			The bank to use to get the data from
					_cmifMonitor	CMIF_Monitor	The monitor to use to show update on the UI
					_noLines		Integer			Outputs the amount of lines loaded

Return Value:		NONE

Date		Who		Reason
05 September 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

vars
	fileLine 				: String;
	fieldArray 				: StringArray;
	mode,
	terminalCode,
	businessUnit,
	localeName,
	invLnTypNarration,
	translatedNarration,
	translatedUnitNarration : String;
	
begin
	//ignore first line
	fileLine 	:= _file.readLine();
	_noLines	:= 1;
	
	create fieldArray transient;
	
	while not _file.endOfFile() do
		fileLine := _file.readLine();
		
		if fileLine = null then
			continue;
		endif;
		
		fieldArray.clear();
		
		fileLine.csvToStringArray(fieldArray, ",");
		
		if fieldArray.isEmpty then
			continue;
		endif;
		
		//Set fields default to null
		mode					:= null;
		terminalCode			:= null;
		businessUnit			:= null;
		localeName				:= null;
		invLnTypNarration		:= null;
		translatedNarration		:= null;
		translatedUnitNarration	:= null;
		
		/*
		The import layout for this table is exactly (or similar) to the column organiser "JMT Default".
		This is what has been supplied to Messina in document CCMS MES 1008, 1010 Interfaces Messages,
		also see the JMT User Guide section for System Codes Reference.
		*/
		if fieldArray.size &lt; 7 then
			//Incorrect file format
			app.raiseCMException(ERR_LineFormatInvalidFile, null, null);
		endif;
		
		mode 					:= fieldArray[1].trimBlanks();
		terminalCode 			:= fieldArray[2].trimBlanks();
		businessUnit			:= fieldArray[3].trimBlanks();
		localeName				:= fieldArray[4].trimBlanks();
		invLnTypNarration		:= fieldArray[5].trimBlanks();
		translatedNarration		:= fieldArray[6].trimBlanks();
		translatedUnitNarration	:= fieldArray[7].trimBlanks();
		
		self.processInvoiceLineNarration(_proxyUArray, _proxyDArray, _errorStore, _bank, mode, terminalCode, businessUnit, localeName, 
												invLnTypNarration, translatedNarration, translatedUnitNarration);
		_noLines += 1;
		
	endwhile;

epilog
	delete fieldArray;
	
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_proxyUArray" type="ObjectArray" usage="input"/>
        <Parameter name="_proxyDArray" type="ObjectArray" usage="input"/>
        <Parameter name="_errorStore" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_noLines" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doLoadInvLnTypTransXmlFile" id="332cf71b-3bbd-4f97-96e9-d79ebb53346f">
        <updating/>
        <source>doLoadInvLnTypTransXmlFile(_file : File; _proxyUArray, _proxyDArray : ObjectArray input; 
							   _errorStore : CM_ErrorSet input; _bank : CM_Bank; _noLines : Integer io) updating;
/*

Purpose:			Loads Invoice Line Translations from a XML File

Parameters:			_file			File			The file to extract the data to
					_proxyUArray	ObjectArray		Holds the items we want to create or update
					_proxyDArray	ObjectArray		Holds the items we want to delete
					_errorStore		CM_ErrorSet		A collection to hold all the errors encountered
					_bank			CM_Bank			The bank to use to get the data from
					_cmifMonitor	CMIF_Monitor	The monitor to use to show update on the UI
					_noLines		Integer			Outputs the amount of lines loaded

Return Value:		NONE

Date		Who		Reason
05 September 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

vars
	xmlDocumentParser 		: JadeXMLDocumentParser;
	rootElement 			: JadeXMLElement;
	rootNode				: JadeXMLNode;
	childElement			: JadeXMLElement;
	xmlDocument				: JadeXMLDocument;
	iter					: Iterator;
	xmlNode					: JadeXMLNode;
	xmlElement				: JadeXMLElement;
	mode,
	terminalCode,
	businessUnit,
	localeName,
	invLnTypNarration,
	translatedNarration,
	translatedUnitNarration : String;
	
begin
	create xmlDocumentParser transient;
	create xmlDocument transient;
	xmlDocumentParser.parseDocumentFile(xmlDocument,_file.fileName);
	rootElement := xmlDocument.rootElement;
	
	foreach rootNode in rootElement.childNodes do
		if rootNode.isKindOf(JadeXMLElement) then
			childElement := rootNode.JadeXMLElement;
			if childElement = null then
				continue;
			endif;
			
			mode 					:= null;
			terminalCode			:= null;
			businessUnit			:= null;
			localeName				:= null;
			invLnTypNarration 		:= null;
			translatedNarration 	:= null;
			translatedUnitNarration := null;
			
			iter := childElement.childNodes.createIterator;
			while iter.next(xmlNode) do
				if not xmlNode.isKindOf(JadeXMLElement) then
					continue;
				endif;
				
				xmlElement := xmlNode.JadeXMLElement;
				// property values for this invoice line type translations
				if xmlElement.tagName = "mode" then
					mode := xmlElement.textData.String;
					
				elseif xmlElement.tagName = "terminalCode" then
					terminalCode := xmlElement.textData.String;
					
				elseif xmlElement.tagName = "businessUnit" then
					businessUnit := xmlElement.textData.String;
					
				elseif xmlElement.tagName = "localeName" then
					localeName := xmlElement.textData.String;
					
				elseif xmlElement.tagName = "invoiceLineTypeNarration" then
					invLnTypNarration := xmlElement.textData.String;
					
				elseif xmlElement.tagName = "translatedNarration" then
					translatedNarration := xmlElement.textData.String;
					
				elseif xmlElement.tagName = "translatedUnitNarration" then
					translatedUnitNarration := xmlElement.textData.String;
					
				endif;
				
			endwhile;
			
			self.processInvoiceLineNarration(_proxyUArray, _proxyDArray, _errorStore, _bank, mode, terminalCode, businessUnit, localeName, 
												invLnTypNarration, translatedNarration, translatedUnitNarration);
			_noLines += 1;
		endif;
		
	endforeach;
	
epilog
	delete xmlDocumentParser;
	delete xmlDocument;
	delete iter;
	
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_proxyUArray" type="ObjectArray" usage="input"/>
        <Parameter name="_proxyDArray" type="ObjectArray" usage="input"/>
        <Parameter name="_errorStore" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_noLines" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processInvoiceLineNarration" id="e4712196-0f9a-4baa-bb44-bf000a5317c2">
        <source>processInvoiceLineNarration(_proxyUArray, _proxyDArray : ObjectArray input; 
							   _errorStore : CM_ErrorSet input; _bank : CM_Bank;
							   _mode, _terminalCode, _businessUnit, _localeName, 
							   _invLnTypNarration, _translatedNarration, 
							   _translatedUnitNarration : String) protected;
/*

Purpose:			Creates a Invoice Line Narration from the data passed in

Parameters:			_proxyUArray				ObjectArray	Holds all the items we want to create or update
					_proxyDArray				ObjectArray	Holds all the items we want to delete
					_errorStore					CM_ErrorSet	Holds all the errors encountered while creating an invoice line narration
					_bank						CM_Bank		The bank to use for the information
					_mode						String		The mode whether we are Updating or Deleting the record
					_terminalCode				String		The terminal code for the invoice line narration
					_businessUnit				String		The business unit for the Invoice Line Translation
					_localeName					String		The locale name for the invoice line narration
					_invLnTypNarration			String		The original narration for the invoice line narration
					_translatedNarration		String		The translated narration for the invoice line narration
					_translatedUnitNarration	String		The translated unit narration for the invoice line narration

Return Value:		NONE

Date		Who		Reason
05 September 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

vars
	realILTN,
	proxyILTN				: CM_InvoiceLineNarration;
	
	terminal 				: CM_Terminal;
	myBuisnessUnit 			: CM_Bank;
	locale,
	myLocale 				: CM_Locale;
	myInvoiceLineDesc 		: CM_InvoiceLineDesc;
	invoiceLineNarration 	: CM_InvoiceLineNarration;
	
begin
	// don't error from these being null, just skip them and sort out manually later
	if _terminalCode &lt;&gt; null then
		terminal := app.myRoot.allTerminals[_terminalCode];
		
	endif;
	
	if terminal = null then
		app.raiseCMException2(Imp_inv_line_type_narr_err, _invLnTypNarration, app.getErrorString1(Err_InvalidTerminal, _terminalCode), null, null);
		
	endif;
	
	if _businessUnit &lt;&gt; null then
		myBuisnessUnit := terminal.companies[_businessUnit];
		
	endif;
	
	if myBuisnessUnit = null then
		app.raiseCMException2(Imp_inv_line_type_narr_err, _invLnTypNarration, app.getErrorString1(Business_unit_invalid, _businessUnit), null, null);
		
	elseif not myBuisnessUnit.isBusinessUnit then
		app.raiseCMException2(Imp_inv_line_type_narr_err, _invLnTypNarration, app.getErrorString1(Business_unit_invalid, _businessUnit), null, null);
		
	endif;
	
	if _localeName &lt;&gt; null then
		foreach locale in app.myRoot.allLocales do
			if locale.localeDescription &lt;&gt; _localeName then
				continue;
			endif;
			
			myLocale := locale;
			break;
			
		endforeach;
		
	endif;
	
	if myLocale = null then
		app.raiseCMException2(Imp_inv_line_type_narr_err, _invLnTypNarration, "Locale is invalid", null, null);
		
	endif;
	
	if _invLnTypNarration &lt;&gt; null then
		myInvoiceLineDesc := myBuisnessUnit.invoiceLineDescriptors[_invLnTypNarration];
		
	endif;

	if myInvoiceLineDesc = null then
		app.raiseCMException2(Imp_inv_line_type_narr_err, _invLnTypNarration, "Invoice Line Type invalid", null, null);
		
	endif;
	
	if _mode = "U" then
		// add if new otherwise update existing object
		foreach invoiceLineNarration in myInvoiceLineDesc.allInvoiceLineNarrations do
			if invoiceLineNarration.myLocale.localeDescription &lt;&gt; _localeName then
				continue;
				
			endif;
			
			realILTN := invoiceLineNarration;
			break;
			
		endforeach;
		
		if realILTN &lt;&gt; null then
			proxyILTN := app.createUpdateProxy(realILTN).CM_InvoiceLineNarration;
			
		else
			create proxyILTN as CM_InvoiceLineNarration transient;
			
		endif;
		
		proxyILTN.setMyInvoiceLineType(myInvoiceLineDesc);
		proxyILTN.setProxy(myLocale, _translatedNarration, _translatedUnitNarration);
		_proxyUArray.add(proxyILTN);
		
	elseif _mode = "D" then
		foreach invoiceLineNarration in myInvoiceLineDesc.allInvoiceLineNarrations do
			if invoiceLineNarration.myLocale.localeDescription &lt;&gt; _localeName then
				continue;
				
			endif;
			
			realILTN := invoiceLineNarration;
			break;
			
		endforeach;
		
		if realILTN = null then
			app.raiseCMException2(Imp_inv_line_type_narr_err, _invLnTypNarration, "Real Invoice Line Narration not found", null, null);
		endif;
		
		_proxyDArray.add(realILTN);
		
	else
		app.raiseCMException2(Imp_inv_line_type_narr_err, _invLnTypNarration, "Mode is invalid must either be 'U' or 'D'", null, null);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_proxyUArray" type="ObjectArray" usage="input"/>
        <Parameter name="_proxyDArray" type="ObjectArray" usage="input"/>
        <Parameter name="_errorStore" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_mode" type="String"/>
        <Parameter name="_terminalCode" type="String"/>
        <Parameter name="_businessUnit" type="String"/>
        <Parameter name="_localeName" type="String"/>
        <Parameter name="_invLnTypNarration" type="String"/>
        <Parameter name="_translatedNarration" type="String"/>
        <Parameter name="_translatedUnitNarration" type="String"/>
    </JadeMethod>
</Class>
