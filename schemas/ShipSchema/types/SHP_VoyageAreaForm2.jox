    <JadeMethod name="setCurrentJob" id="c1937b57-3832-4e8c-bfd6-419b9fec0e9b">
        <updating/>
        <source>setCurrentJob(_job : CM_VoyageJob) updating, protected;
// ---------------------------------------------------------------------------
// Created:     17 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpWorkMode		: Integer;
	req				: CM_Request;
	slotReq			: CM_SlotRequest;
	seqObj			: CMIF_CustomSequenceObject;
	isStarboardBerthed	: Boolean;
	tmpDrawController	: SHP_BayDrawingController;
	
begin
	self.myCurrentJob := _job;

	if not global.isValidObject(_job) then
		self.customSeqObjPurge();
		return;
	endif;

	tmpWorkMode 	:= self.workingMode;

	if tmpWorkMode = WorkMode_CustomSeq then
		// need to create transient CMIF_
		self.customSeqObjPurge();

		tmpDrawController	:= self.myBayDrawingController;
		isStarboardBerthed := self.myCurrentVoyage.starboardBerthed;
		
		foreach req in _job.allRequests do
			slotReq := req.CM_SlotRequest;
			create seqObj transient;
			seqObj.setFromRequest(slotReq, isStarboardBerthed);
			tmpDrawController.drawObject(null,  slotReq.mySlotController);
			self.customSeqObjAdd(seqObj);
		endforeach;
		
		self.hasChanged := false;
	endif;
	
	//if self.myCurrentJob.hasMultipleAllocations then
	//	self.chkOutOfSequence.value := false;
	//else
		self.chkOutOfSequence.value := self.myCurrentJob.allowOutOfOrderLoading; //cnwrd1 par 30626 ccms 2209 23.10.12		
	//endif;
end;</source>
        <access>protected</access>
        <Parameter name="_job" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="setDisplayMenuForProposed" id="cd7009b2-8866-448a-9984-5165646790b8">
        <source>setDisplayMenuForProposed();
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	mnuChild : MenuItem;

begin
	mnuChild := self.mnuDisplay.getMenuItem(DISPLAY_MODE_PLAN); 
	if mnuChild &lt;&gt; null then
		mnuChild.caption := "Display Proposed";
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setDisplayMode" id="fc4c7d91-4612-4f23-8271-c40192d92413">
        <updating/>
        <source>setDisplayMode(_mode: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		This is called from the click event on the context menu at 
//				the bottom right of the form in the status line so we emulate the 
//				toolbar being clicked
//
// ---------------------------------------------------------------------------
vars
	newMode,
	theIndex : Integer;

begin
	if _mode = DISPLAY_MODE_ACTUAL then
		newMode := ShpDisplayMode_Actual;
		theIndex := VIEW_BAYACTUAL;

	elseif _mode = DISPLAY_MODE_PLAN then
		newMode := ShpDisplayMode_Proposed;
		theIndex := VIEW_BAYPLANNED;
		self.setDisplayMenuForProposed();

	elseif _mode = DISPLAY_MODE_QUEUE then
		theIndex := VIEW_BAYQUEUED;
		return; // not implemented yet
	else
		return;
	endif;

	self.doBtnToolBarMouseUP(theIndex);

	self.myBayDrawingController.setDisplayMode(newMode);
	if self.myCurrentVoyage &lt;&gt; null then
		self.doNotesForLegendStartStop(self.myBayDrawingController.viewMode);
	endif;
	self.frmStatusLine.displayMode := _mode;

end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setLoadColorCodeAttributes" id="a75d725b-fb14-4542-a623-a98a9e82fb4a">
        <source>setLoadColorCodeAttributes(_loadColorCode : CMIF_LoadColorCode input ; _bulkReleaseReserveDetail : CM_ReserveDetail) protected;
// ---------------------------------------------------------------------------
// Created:     28 July 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	emptyCommodityCode : String;
	
begin
	if _loadColorCode = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_loadColorCode', null, null);
		return;
	endif;
	
	if _bulkReleaseReserveDetail &lt;&gt; null then
		_loadColorCode.myBulkReleaseReserveDetail := _bulkReleaseReserveDetail;
	else
		_loadColorCode.myBulkReleaseReserveDetail := null;
		_loadColorCode.myCargoType		:=	self.cmbCargoType.listObject.CM_CargoType;
		_loadColorCode.myCommodityGroup	:=	self.cmbCommodity.listObject.CM_CommodityGroup;
		_loadColorCode.myDischargePort	:=	self.cmbPortDis.listObject.CM_Port;
		_loadColorCode.weight			:=	self.txtWeight.cnEcDecimal();		// cnwdad1 30/07/2010 - PAR #24045.
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_loadColorCode" type="CMIF_LoadColorCode" usage="input"/>
        <Parameter name="_bulkReleaseReserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="setLoadColorCodeAttributesVA" id="6d2a877f-6f4e-462a-87a3-0ff008991fee">
        <source>setLoadColorCodeAttributesVA(_loadColorCode : CMIF_LoadColorCode input ; _voyageAllocation : CM_VoyageAllocation) protected;
// ---------------------------------------------------------------------------
// Created:     22 Dec 2008 by cnwas3
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	//emptyCommodityCode : String;
	criteria : CM_YACriteria;
begin
	if _loadColorCode = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_loadColorCode', null, null);
		return;
	endif;
	
	_loadColorCode.myBulkReleaseReserveDetail := null;
	_loadColorCode.myVoyageAllocation := _voyageAllocation;
	
	foreach criteria in _voyageAllocation.allCriteria do
		if criteria.myYACriteriaType.isKindOf(CM_YATypeDischargePort) then
			_loadColorCode.myDischargePort	:= criteria.myYAData.CM_YADataObjects.allObjects.first().CM_Port;
			
		elseif criteria.myYACriteriaType.isKindOf(CM_YATypeCargoType) then
			_loadColorCode.myCargoType	:= criteria.myYAData.CM_YADataObjects.allObjects.first().CM_CargoType;
			
		elseif criteria.myYACriteriaType.isKindOf(CM_YATypeIsThirty) then
			_loadColorCode.isThirty	:= (criteria.myYAData.CM_YADataBoolean.value = CM_YADataBoolean.VALUE_TRUE);
			
		elseif criteria.myYACriteriaType.isKindOf(CM_YATypeIsForty) then
			_loadColorCode.isForty	:= (criteria.myYAData.CM_YADataBoolean.value = CM_YADataBoolean.VALUE_TRUE);
			
		elseif criteria.myYACriteriaType.isKindOf(CM_YATypeIsFortyFive) then
			_loadColorCode.isFortyFive	:= (criteria.myYAData.CM_YADataBoolean.value = CM_YADataBoolean.VALUE_TRUE);
			
		elseif criteria.myYACriteriaType.isKindOf(CM_YATypeIsOverDimensional) then
			_loadColorCode.overDimension := (criteria.myYAData.CM_YADataBoolean.value = CM_YADataBoolean.VALUE_TRUE);
			
		elseif criteria.myYACriteriaType.isKindOf(CM_YATypeRequiresPower) then
			_loadColorCode.requiresPower := (criteria.myYAData.CM_YADataBoolean.value = CM_YADataBoolean.VALUE_TRUE);
			
		elseif criteria.myYACriteriaType.isKindOf(CM_YATypeWaterCooled) then
			_loadColorCode.waterCooled	:= (criteria.myYAData.CM_YADataBoolean.value = CM_YADataBoolean.VALUE_TRUE);
			
		elseif criteria.myYACriteriaType.isKindOf(CM_YATypeIsHazardous) then
			_loadColorCode.isHazardous := (criteria.myYAData.CM_YADataBoolean.value = CM_YADataBoolean.VALUE_TRUE);
			
		elseif criteria.myYACriteriaType.isKindOf(CM_YATypeIsFiftyThree) then
			_loadColorCode.isFiftyThree	:= (criteria.myYAData.CM_YADataBoolean.value = CM_YADataBoolean.VALUE_TRUE);
			
		elseif criteria.myYACriteriaType.isKindOf(CM_YATypeCommodityGroup) then
			_loadColorCode.myCommodityGroup	:= criteria.myYAData.CM_YADataObjects.allObjects.first().CM_CommodityGroup;
			
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_loadColorCode" type="CMIF_LoadColorCode" usage="input"/>
        <Parameter name="_voyageAllocation" type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="setModes" id="0aa7d69e-5ecf-41e8-9104-598f9d735735">
        <source>setModes();
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	oldMode : Integer;
	tmpDrawingController	: SHP_BayDrawingController;
begin
	self.mnuWorkMain.visible := true;

	tmpDrawingController := self.myBayDrawingController;
	tmpDrawingController.setModes(self.displayMode, self.imexMode, self.workingMode);

end;</source>
    </JadeMethod>
    <JadeMethod name="setMoveControllerSource" id="e105fee5-b623-49ce-949d-90e77f44a0ea">
        <updating/>
        <source>setMoveControllerSource(_ti: CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theLSlotRequest,
	theDSlotRequest		: CM_SlotRequest;
	theSlotController	: CM_SlotController;
	theReturn 			: Integer;
	tmpMoveController	: CMIF_MoveController;
	origLC				: CM_LocationsController;
	objects : CM_ObjectArray;
	obj : Object;
	theTI : CM_TrackedItem;
	
begin
	inheritMethod(_ti);

	tmpMoveController	:=	app.myMoveController;
	
	if tmpMoveController = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'app.myMoveController is null');
		return;
	endif;

	tmpMoveController.ignoreWeightValidation	:=	self.chkIgnoreWeightV.value;	// cnwdad1 02/08/2010 - PAR #24045.
	origLC := _ti.getPrimaryLocation(REAL_MODE);

	if origLC = null then
		app.raiseCMException1(Cargo_no_location,_ti.id,null,null);
		//app.raiseUnexpectedProgramError(class.name, method.name, 'app.myMoveController.myOriginatingLocation is null');
		return;
	endif;

	tmpMoveController.setMyOriginatingLocation(origLC);

	if (not origLC.isKindOf(CM_SlotController))
	or (_ti.isTranshipExport() and self.moveModeForm = PLANNING_MODE) // should be an export replan. This has already been plan loaded and they can drag drop to a different slot
	then
		// ### if the orig location for this TI in this event on this form is not a slot controller 
		// then it must be that we are dragging an export TI 
		// that is planned to the ship and we want it planned elsewhere
		if _ti.myPrimaryActualLocation = origLC 
		or _ti.isTranshipExport()
		then
			if _ti.myPrimaryPlannedLocation &lt;&gt; null then
				if _ti.myPrimaryPlannedLocation.isKindOf(CM_SlotController) then
					theSlotController := _ti.myPrimaryPlannedLocation.CM_SlotController;
					theLSlotRequest := theSlotController.mySlotRequestLoad;
				endif;
			endif;
		endif;
		if theLSlotRequest &lt;&gt; null then
			tmpMoveController.setMoveMode(self.moveModeForm);
			tmpMoveController.mySlotRequest := theLSlotRequest;
			tmpMoveController.setMyTrackedItem(_ti);
		endif;

		return;
	endif;

	theSlotController := origLC.CM_SlotController;
	
	// #### DISCHARGE
	if self.displayMode = ShpDisplayMode_ColCodeDisch then
		theLSlotRequest := theSlotController.mySlotRequestDischarge;
		if theLSlotRequest &lt;&gt; null then
//		   (not theLSlotRequest.isSOB) then // PAR 8942. if they drag drop from one form showing a SOB discharge to  a different form showing SOB load then 
			tmpMoveController.mySlotRequest := theLSlotRequest;
		endif;

	// ##### LOAD
	else
		// it is possible to have discharge CC for a SOB AND load CC for an export, in the same slot.
		// the user is allowed to drag drop either, so if we have both we ask which one to use
		// only get the TI from the discharge CC if it is SOB, else get the ti for the load
		// if the TI is actaully here then we want the Discharge slot request, else we want the load
		// NOTE see baypoint getTI for the choosing of the TI
		if _ti.myPrimaryActualLocation = theSlotController then
			theLSlotRequest := theSlotController.mySlotRequestDischarge;
		else
			theLSlotRequest := theSlotController.mySlotRequestLoad;
		endif;
		// may have been erased so will be null move type
		if theLSlotRequest &lt;&gt; null then //and (theLSlotRequest.moveType = LOAD_MOVETYPE or theLSlotRequest.moveType = DLR_MOVETYPE) then
//			self.setMoveControllerTarget(theSlotController);
			tmpMoveController.setMoveMode(self.moveModeForm);
			tmpMoveController.mySlotRequest := theLSlotRequest;
			tmpMoveController.setMyTrackedItem(_ti);
			tmpMoveController.setMyOriginatingLocation(theSlotController); // reset this as it is blanked in the setMyTI
		endif;
	endif;
epilog
	delete objects;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setMyCCPalette" id="04b5c807-7732-49ce-bc1c-e4913f5b3f43">
