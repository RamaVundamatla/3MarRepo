    <JadeMethod name="create" id="9fdc1736-e974-4ba8-955b-bece1309ecad">
        <updating/>
        <source>create() updating;

vars
	p : Property;
	t : Type;
	
begin
	// cache our property names and their type when we're created so that
	// jtdAsString and jtdSetFromString don't have to keep accessing the
	// persistent meta-data from the database (and placing locks/unlocks)
	
	foreach p in self.class.rootType.jtdGetProperties do
		t := p.type.rootType;

		// jtdAllPropertyNames is an array, so we'll hold the property
		// names in the same order that we read them		

		if t = Integer then
			self.jtdAllPropertyNames.add('I' &amp; p.name);
		elseif t = Real then
			self.jtdAllPropertyNames.add('R' &amp; p.name);
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="jtdAddSummary" id="ec7f8bf5-d829-4508-8325-45738b798687">
        <updating/>
        <source>jtdAddSummary(jds : JtdDriverSummary; addSecs : Boolean) updating;

begin
	if jds = null then
		return;
	endif;

	self.jtdTotalDeadlocks := self.jtdTotalDeadlocks + jds.jtdTotalDeadlocks;
	self.jtdTotalLocks := self.jtdTotalLocks + jds.jtdTotalLocks;
	self.jtdTotalReadErrs := self.jtdTotalReadErrs + jds.jtdTotalReadErrs;
	self.jtdTotalReads := self.jtdTotalReads + jds.jtdTotalReads;
	self.jtdTotalUnhandledExceptions := self.jtdTotalUnhandledExceptions + jds.jtdTotalUnhandledExceptions;
	self.jtdTotalUpdErrs := self.jtdTotalUpdErrs + jds.jtdTotalUpdErrs;
	self.jtdTotalUpds := self.jtdTotalUpds + jds.jtdTotalUpds;

	if addSecs then
		self.jtdTotalReadGenSecs := self.jtdTotalReadGenSecs + jds.jtdTotalReadGenSecs;
		self.jtdTotalReadTrxSecs := self.jtdTotalReadTrxSecs + jds.jtdTotalReadTrxSecs;
		self.jtdTotalUpdGenSecs := self.jtdTotalUpdGenSecs + jds.jtdTotalUpdGenSecs;
		self.jtdTotalUpdTrxSecs := self.jtdTotalUpdTrxSecs + jds.jtdTotalUpdTrxSecs;
	endif;
end;</source>
        <Parameter name="jds" type="JtdDriverSummary"/>
        <Parameter name="addSecs" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdAsString" id="9623931f-c81b-4899-bfb7-c951d3a416e9">
        <source>jtdAsString() : String;

vars
	s, propName, typ : String;
	
begin
	s := null;
	
	foreach propName in self.jtdAllPropertyNames do
		typ := propName[1];
		propName := propName[2 : end];
		
		if typ = 'I' then
			s := s &amp; self.getPropertyValue(propName).Integer.String &amp; ';';
		elseif typ = 'R' then
			s := s &amp; self.getPropertyValue(propName).Real.String &amp; ';';
		endif;
	endforeach;
	
	return s;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdGetGPS" id="b1eed430-108a-439f-8dda-ceed63f9105d">
        <source>jtdGetGPS() : Real;

vars
	totalSecs : Real;
	totalTrx : Integer;
	
begin
	totalSecs := self.jtdGetTotalGenSecs;
	totalTrx := self.jtdGetTotalTransactions;
	
	if totalTrx &lt; 1 then
		return 0;
	endif;
	
	if totalSecs &lt;= 0 then
		return totalTrx;
	endif;
	
	return totalTrx / totalSecs;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="jtdGetMaxSecs" id="6b2238db-465d-4375-905a-80dcc7914477">
        <updating/>
        <source>jtdGetMaxSecs(readGenSecs, readTrxSecs, updGenSecs, updTrxSecs : Real io) updating;

begin
	if self.jtdTotalReadGenSecs &gt; readGenSecs then
		readGenSecs := self.jtdTotalReadGenSecs;
	endif;
	if self.jtdTotalReadTrxSecs &gt; readTrxSecs then
		readTrxSecs := self.jtdTotalReadTrxSecs;
	endif;
	if self.jtdTotalUpdGenSecs &gt; updGenSecs then
		updGenSecs := self.jtdTotalUpdGenSecs;
	endif;
	if self.jtdTotalUpdTrxSecs &gt; updTrxSecs then
		updTrxSecs := self.jtdTotalUpdTrxSecs;
	endif;
end;</source>
        <Parameter name="readGenSecs" type="Real" usage="io"/>
        <Parameter name="readTrxSecs" type="Real" usage="io"/>
        <Parameter name="updGenSecs" type="Real" usage="io"/>
        <Parameter name="updTrxSecs" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="jtdGetReadGPS" id="97983e33-457c-4a5d-a970-c39ccd8e6f14">
        <source>jtdGetReadGPS() : Real;

begin
	if self.jtdTotalReads &lt; 1 then
		return 0;
	endif;
	
	if self.jtdTotalReadGenSecs &lt;= 0 then
		return self.jtdTotalReads;
	endif;
	
	return self.jtdTotalReads / self.jtdTotalReadGenSecs;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
