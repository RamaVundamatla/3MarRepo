    <JadeMethod name="pxyCreateUpdateProxy" id="886cfa47-0d70-478d-849d-795553bb53a9">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
23 March 2011	cnwer1	Initial creation
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/

vars
	pxyMe : SelfType;
	pxyDeckLayout : CM_DeckLayout;
	pxyDeckLayerLayout, realDeckLayerLayout : CM_DeckLayerLayout;
	pxyDeckItemLayout, realDeckItemLayout : CM_DeckItemLayout;
	pxyLocnDefn, realLocnDefn, pxyAft, pxyFwd : CM_ROROLocnDefn;
	pxyLaneDefn, realLaneDefn : CM_ROROLaneDefn;
	completedOK		: Boolean;
begin
	pxyMe := inheritMethod();

	pxyDeckLayout := app.createUpdateProxy(self.myDeckLayout).CM_DeckLayout;
	
	foreach realDeckLayerLayout in self.myDeckLayout.allDeckLayerLayouts discreteLock do
		// PAR 29236
		if realDeckLayerLayout.type = ROROLayerType_CCLoad
		or  realDeckLayerLayout.type = ROROLayerType_CCDischarge then
			continue;
		endif;
		
		pxyDeckLayerLayout := app.createUpdateProxy(realDeckLayerLayout).CM_DeckLayerLayout;
		foreach realDeckItemLayout in realDeckLayerLayout.allDeckItemLayouts discreteLock do
			pxyDeckItemLayout := app.createUpdateProxy(realDeckItemLayout).CM_DeckItemLayout;
			
		endforeach;
	endforeach;
	
	foreach realLocnDefn in self.allROROLocnDefnByOrdinal discreteLock do
	
		// PAR 29236
		if realLocnDefn.myLayout.myDeckLayer.type = ROROLayerType_CCLoad
		or  realLocnDefn.myLayout.myDeckLayer.type = ROROLayerType_CCDischarge then
			continue;
		endif;

		pxyLocnDefn := app.createUpdateProxy(realLocnDefn).CM_ROROLocnDefn;
	endforeach;
	
	// Now that we have proxied all the locations, we need to join them all up
	foreach pxyLocnDefn in pxyMe.allROROLocnDefnByOrdinal  discreteLock do
		realLocnDefn := pxyLocnDefn.pxyGetRealObject();
		pxyAft := null;
		pxyFwd := null;
		
		if  realLocnDefn.myAdjacentSlotAft &lt;&gt; null then
			pxyAft := realLocnDefn.myAdjacentSlotAft.pxyGetProxyObject();
		endif;
		if  realLocnDefn.myAdjacentSlotFwd &lt;&gt; null then
			pxyFwd := realLocnDefn.myAdjacentSlotFwd.pxyGetProxyObject();
		endif;
		pxyLocnDefn.setProxyAdjacent(pxyAft,pxyFwd);
	endforeach;
	
	
	foreach realLaneDefn in self.allROROLaneDefnByOrdinal discreteLock do
		// PAR 29236
		if realLaneDefn.myLayout.myDeckLayer.type = ROROLayerType_CCLoad
		or  realLaneDefn.myLayout.myDeckLayer.type = ROROLayerType_CCDischarge then
			continue;
		endif;
		pxyLaneDefn := app.createUpdateProxy(realLaneDefn).CM_ROROLaneDefn;
		
	endforeach;
	
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyMe;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyMe;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
