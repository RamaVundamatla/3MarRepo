<Class name="CM_EDIBayPlanTI">
    <JadeMethod name="getColoursForEDITrackedItem" id="d4496fdb-7f7d-400e-9882-84f0ed9206d5">
        <source>getColoursForEDITrackedItem(_ediData: CM_EDIData; _localPort: String; _foreColor: Integer output; _backColor: Integer output);
/*
Date		Who		Reason
07 Aug 2013	cnwcs5		CCMS POL 2221 / par 32094(2)
04 Sep 2013	cnwcs5	par 32389 - regression
// 13 Mar 2018	jlgrs1	TFS 37484 - QNS Allow DB Loading of Bay Plan files
*/
vars

begin
	if self.isForLocal (_localPort) then
		_foreColor	:= Black;
		_backColor	:= CM_BaseForm.ColorGreenLight;
	else
		_backColor	:= White;	
		_foreColor	:= CM_BaseForm.ColorGreyDark;
	endif;
	if self.status = CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS or	
	   self.status = CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS then
		_foreColor	:= Black;
		_backColor 	:= LightRed;
	elseif self.status = CM_EDITrackedItem.EDI_STATUS_LOCKERROR then
		_foreColor	:= Black;
		_backColor 	:= Cosmos;
	endif;
epilog

end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_localPort" type="String"/>
        <Parameter name="_foreColor" type="Integer" usage="output"/>
        <Parameter name="_backColor" type="Integer" usage="output"/>
    </JadeMethod>
</Class>
