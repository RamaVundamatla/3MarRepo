    <JadeMethod name="doAddSortIdColumn" id="7f0f0c5b-2435-4f62-bdf4-acce3b1d7b3a">
        <source>doAddSortIdColumn(_table : CM_FilterTable);
/*

Purpose:			
		This method is created for limiting number of rows to display.
		It checks whether ID column is currently displayed as it's required for table sorting.
		Add ID column if it's not already there, set table to sort by ID (ascending)
		
Parameters:			

Return Value:		

Date		Who		Reason
13 December 2022	navkc1	Initial creation ChangeRequest 55409: MTN - Voyage Ops Form - Pagination of tables

*/

vars
	table				: CM_FilterTable;
	idCol				: Integer;
	entDef				: EntTableDef;
	entRow				: EntTableRow;
	col					: JadeTableColumn;
begin
	table := _table;
	
	if table.getColumnByRowName(ETRow_Id) &lt;&gt; null then
		return;
	endif;
	
	entDef := table.myEntTableDef;
	entRow := entDef.getEntTableRow(ETRow_Id);
	
	table.allTblDataEntRows.add(entRow);
	table.allTblDataColHeadings.add(entRow.getHeading(table.getMyTerminologyCargoBOLType, table.getMyTerminologyTerminal, app.myCurrentLocale));
	table.allTblDataColInputTypes.add(Table.InputType_None);
	table.allTblDataColPropertyNames.add(entRow.name);
	
	idCol := table.columns + 1;
	table.insertColumn(idCol);
	
	col := table.accessColumn(idCol);
	col.inputType := Table.InputType_None;
	
	table.accessCell(table.fixedRows, idCol).text := table.allTblDataColHeadings.last();
	table.sortColumn[1] := idCol;
	table.sortAsc[1] 	:= true;
epilog

end;</source>
        <Parameter name="_table" type="CM_FilterTable"/>
    </JadeMethod>
    <JadeMethod name="doAssignToRelease" id="7ab86db9-e358-4beb-8417-7f1da89273b4">
        <updating/>
        <source>doAssignToRelease(_reserveDetail : CM_ReserveDetail input; _location : CM_LocationsController input) updating;
/*
Purpose:			
Date				Who		Reason
10 February 2017	cnwab1	Initial creation
31 October 2025		jlizm1	MTN 36255 Rotabox Assign Release To Vessel
*/

vars
	pxyJob, newJob : CM_VoyageHoldJob;
	jobParams : CMIF_VoyageJobParams;
	jobType, result : Integer;
	jobId, remarks, str : String;
	holdReq : CM_HoldRequest;
	wleQty, thereturn : Integer;
	ct : CM_CargoType;
begin
	self.wleQuantity := 0;
	self.wleWeight := 0;
	
	if _reserveDetail &lt;&gt; null then
		ct := _reserveDetail.getMyCargoType();
		if ct &lt;&gt; null then
		
			if ct.isBreakBulk() then // TFS 3873
				if ct.isBreakBulkMulti() then
					if not self.doGetAmount(_reserveDetail, GETVALUE_QUANTITY, holdReq) then
						return;
					endif;
				else
					self.wleQuantity := self.doGetReserveDetailQuantity(_reserveDetail);
				endif;
			elseif ct.isBulk() then // TFS 3873
				if ct.isBulkMulti()  then
					if ct.isBulkByWeight() then
						if not self.doGetAmount(_reserveDetail, GETVALUE_WEIGHT, holdReq) then
							return;
						endif;
					endif;
				else
					if ct.isBulkByWeight() then
						self.wleWeight := self.doGetReserveDetailWeight(_reserveDetail);
					endif;
				endif;
				
			else
				self.wleQuantity := self.doGetReserveDetailQuantity(_reserveDetail);
				if self.wleQuantity &gt; 1 then
					if not self.doGetAmount(_reserveDetail, GETVALUE_QUANTITY, holdReq) then
						return;
					endif;
				endif;
			endif;

		endif;
	endif;
	
	
	while true do
		app.myTrxCA.trxCreateHoldJobForRelReq(_reserveDetail, newJob, _location, self.wleQuantity, self.wleWeight); // TFS 3873
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Voyage_job), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

		endif;
		return;
	endwhile;
	
	holdReq :=newJob.allRequests.first.CM_HoldRequest;

epilog
	delete jobParams;
	delete pxyJob;
end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail" usage="input"/>
        <Parameter name="_location" type="CM_LocationsController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doAutoPlanGetTIs" id="b5144db3-659f-449e-b606-0602082944c4">
        <updating/>
        <source>doAutoPlanGetTIs(_mode : Integer; _all : Boolean; _params : CMIF_AutoplanParams input; _table : CM_DataTable) updating;

/*

Purpose:			BUG 58922

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2023	navab1	Initial creation

*/

vars
	table 	: CM_DataTable;
	idx : Integer;
	ti : CM_TrackedItem;
	obj : Object;
begin
	table := _table;
	if _all then
		foreach idx in table.fixedRows + 1 to table.rows do
			ti := table.accessRow(idx).itemObject.CM_TrackedItem;
			if ti = null then
				continue;
			endif;
			
			if (_mode = PLANNING_MODE and ti.myPrimaryPlannedLocation = null)
			or (_mode = QUEUE_MODE and ti.myPrimaryQueuedLocation = null) then
				_params.allTrackedItems.add(ti);
			endif;
		endforeach;
	else
		foreach obj in table.allSelectedObjects do
			if obj.isKindOf(CM_TrackedItem) then
				ti := obj.CM_TrackedItem;
				if (_mode = PLANNING_MODE and ti.myPrimaryPlannedLocation = null)
				or (_mode = QUEUE_MODE and ti.myPrimaryQueuedLocation = null) then
					_params.allTrackedItems.add(ti);
				endif;
			endif;
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_all" type="Boolean"/>
        <Parameter name="_params" type="CMIF_AutoplanParams" usage="input"/>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="doAutoPlanQueue" id="9c980b50-5545-4ef3-a361-d21157f2d343">
        <updating/>
        <source>doAutoPlanQueue(_mode : Integer; _all : Boolean; _table : CM_DataTable) protected, updating;
// -------------------------------------------
// Created  APRIL 2009 AKB // PAR 19450 CCMS 1064 SFW 
// -------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------
// 07/05/2015	cnwdap1		PAR #36157 Correct autoplan menu handling
// 28/10/2025	jlizm1		MTN 36255 Rotabox Assign Release To Vessel
// 10 December 2025	jlier1	JIRA# 36738
vars
	tiArray	: CM_TIArray;
	str		: String;
	result	: Integer;
	ti		: CM_TrackedItem;
	table 	: CM_DataTable;
	obj 	: Object;
	params 	: CMIF_AutoplanParams;
	currentFormMoveMode	: Integer;
	idx		: Integer;
	wleArray			: CM_WLEArray;
	wlesWithWarnings 	: CM_WLEArray;
	wle 	: CM_WorkListEntry;
begin
	table := _table;
	if table = null then 
		return;
	endif;
	if _mode &lt;&gt; PLANNING_MODE and _mode &lt;&gt; QUEUE_MODE then
		return;
	endif;
	
	create tiArray transient;
	create params transient;
	
	self.doAutoPlanGetTIs(_mode,_all,params,table); // ### TFS 58922 04JUL23 NAVAB1
	
	//if _mode = QUEUE_MODE then
		create wleArray transient;
		create wlesWithWarnings transient;
		foreach  ti in params.allTrackedItems do
			if ti.isRRPforVoyage then
				wle := ti.allWorklistEntries.getFirstUnactionedWLE();
				if wle &lt;&gt; null and wle.isKindOf(CM_VoyageWLE) and wle.CM_VoyageWLE.getMyVoyageObject = self.myCurrentVoyage then
					wleArray.add(wle);	
					tiArray.add(ti);
					
				endif;
			endif;
		endforeach;
		
		foreach ti in tiArray do
			params.allTrackedItems.tryRemoveIfNotNull(ti);
		endforeach;
	//endif;
	
	/* // ### TFS 58922 04JUL23 NAVAB1
	if _all then
		foreach idx in table.fixedRows + 1 to table.rows do
			ti := table.accessRow(idx).itemObject.CM_TrackedItem;
			if ti = null then
				continue;
			endif;
			if ti.myPrimaryPlannedLocation = null then
				params.allTrackedItems.add(ti);
			endif;
		endforeach;
	else
		foreach obj in table.allSelectedObjects do
			if obj.isKindOf(CM_TrackedItem) then
				ti := obj.CM_TrackedItem;
				if (_mode = PLANNING_MODE and ti.myPrimaryPlannedLocation = null)
				or (_mode = QUEUE_MODE and ti.myPrimaryQueuedLocation = null) then
					params.allTrackedItems.add(ti);
				endif;
			endif;
		endforeach;
	endif;
	*/
	currentFormMoveMode := _mode;
	
	params.moveMode := currentFormMoveMode;
	params.myTerminalArea := null;
	params.myJob := null;
	params.showWarningWhenNoPlan := false;
	
	//21 Aug 2018	NDL	TFS 39972
	if table = self.tblOnship then
		params.isVoyageOps := true;
	endif;
		
	while true do
		
		str := app.myTrxUA.trxUpdateAutoplanTrackedItems(params, app.myPassport);
		if app.myPassport.trxCompletedOK then
		
			break;
		else
			result := app.showErrorWarningDialog('Move', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
		endif;
		break;
	endwhile;	
	
	if wleArray &lt;&gt; null and not wleArray.isEmpty then
		while true do
			if _mode = PLANNING_MODE then
				app.myTrxUA.trxUpdateWLEsAutoplan(wleArray, wlesWithWarnings, PLANNING_MODE, app.myPassport);
			else
				app.myTrxUA.trxUpdateWLEsDoMove(wleArray, wlesWithWarnings, _mode, true, null, app.myPassport);
			endif;
			if app.myPassport.trxCompletedOK then
			
				break;
			else
				result := app.showErrorWarningDialog('Move', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
					result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				
			endif;
			break;
		endwhile;	
	endif;
	
	if str.trimBlanks &lt;&gt; null  
	and app.myPassport.returnCode = ERR_NO_AUTOPLAN then
		if app.msgBox(str &amp; app.getErrorString(INFO_NO_AUTOPLAN), "Could Not Autoplan", MsgBox_Information_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
			app.showSystemAlertsWindow(self.myMasterMenuAction, self.myTerminal, null);			
		
		endif;
	endif;
epilog
	delete params;
	delete tiArray;
	delete wleArray;
	delete wlesWithWarnings;
end;</source>
        <access>protected</access>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_all" type="Boolean"/>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="doBargeLoadMoves" id="7dc197f6-1cf5-42eb-8ddd-dc6a464c6db1">
        <source>doBargeLoadMoves( _targetLocn : CM_LocationsController );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Jun 2021	navndl1	Initial creation	TFS 51231
20/02/2024 	navcs2 	MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
14 Jan 2026 navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
*/

vars
	result 				: Integer;
	ti 					: CM_TrackedItem;
	tiArray 			: CM_TIArray;
	moveController 		: CMIF_MoveController;
	wle 				: CM_WorkListEntry;
	tiIDs 				: String;
	tiId 				: String;
	showMoveConfirmation: Boolean;
	isLoadJobExist 		: Boolean;
	vwle 				: CM_VoyageWLE;		
	obj 				: Object;
	planLocn 			: CM_LocationsController;
begin
	planLocn := self.cmbLoadLocation.listObject.CM_LocationsController;
	if planLocn = _targetLocn then
		planLocn := null;
	endif;

	if self.myCurrentVoyage = null or not self.myCurrentVoyage.isBarge or _targetLocn = null then 
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;		

	if global.isValidObject(app.myMoveController) then
		delete app.myMoveController;
	else
		app.myMoveController := null;
	endif;
	
	create moveController transient;
	app.myMoveController := moveController;
	create tiArray transient;
	foreach obj in self.tblOnsite.allSelectedObjects do
		tiArray.add(obj.CM_TrackedItem);			
	endforeach;	
	if tiArray.isEmpty then
		return;
	endif;

	moveController.transferType := self.getVoyJobTransferType();
	moveController.setMyToPrimaryLocation( _targetLocn );	
	moveController.setMoveMode(QUEUE_MODE);
	moveController.isNonCraneVoyageMove := true; 
	moveController.myVoyage := self.myCurrentVoyage; 
			
	foreach ti in tiArray do
		if tiIDs = null then
			tiIDs := ti.id;
		else
			tiIDs := tiIDs &amp; Comma &amp; Space &amp; ti.id;
		endif;
	endforeach;
	
	if app.myPassport.myTerminal.getConfig(HhShowUnplanOptions).Boolean then
		moveController.nonWorkedInstantPreMove();
		if moveController.priority = 888 then
			return;		// user has cancelled attempt to move cargo already planned
		endif;
	endif;

	foreach ti in tiArray discreteLock do 
		vwle := ti.getVoyageWLEUnactioned(true);
		if vwle &lt;&gt; null and vwle.job &lt;&gt; null  then
			if not vwle.job.isVoyageROROJob() then // TFS 45983 ignore 'hidden' jobs
				isLoadJobExist := true;
				tiId := ti.id;
				break;
			endif;
		endif;	
	endforeach;
	
	if isLoadJobExist then
		if app.msgBox(app.getErrorString2(Release_Wle_Exist,tiId,app.getErrorString(Load)), app.getErrorString(Error), MsgBox_OK_Only) = MsgBox_Return_OK then
			return;
		endif;
	endif;
	
	while true do
		
		app.myTrxUA.trxMoveTrackedItemsInOrder( tiArray, moveController, planLocn, app.myPassport );
		if not app.myPassport.trxCompletedOK then
			result := app.showErrorWarningDialog('Load Cargo', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
		
	endwhile;

epilog
	if moveController &lt;&gt; null then
		moveController.isMoveToPlanned := false;
	endif;
	delete tiArray;
	app.mousePointer := MousePointer_Default;
	
end;</source>
        <Parameter name="_targetLocn" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="82482dc6-22c3-45c7-8fbe-ae42c5f60efa">
