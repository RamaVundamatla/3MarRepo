    <JadeMethod name="getExtraInfo_BulkGateInOrOut" id="d665c807-0207-4f06-9cb9-ac8b2a634c47">
        <source>getExtraInfo_BulkGateInOrOut():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 November 2016	cnwndl1	Initial creation	TFS 2867 / 2779

*/

vars
	value	:String;
begin
