    <JadeMethod name="getRequiredByDT" id="5539ed3f-2624-4e6a-8284-0a5deac60b5c">
        <source>getRequiredByDT(): TimeStamp;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 October 2009	cnwrd1	Initial creation

*/

vars
begin
		
		if self.myWODtl = null or self.myWODtl.requiredByDT = null then		
			if self.allRequests.first() &lt;&gt; null then
				return self.allRequests.first.getRequiredByDT();
			else
				return null;
			endif;
		endif;
		
		return self.myWODtl.requiredByDT;

epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getSelectedTiIds" id="d6296bf5-1457-48c7-a207-a594501527a8">
        <source>getSelectedTiIds(): String;
// -------------------------------------------
// Created 21 January 2005 by cnwdvb1
// -------------------------------------------
vars

	ti		: CM_TrackedItem;
	iter	: Iterator;
	str		: String;

begin

	iter := self.selectedTIs.createIterator();
	
	while iter.next(ti) do
		// Already got this one.
		if self.allTrackedItems.includes(ti) then
			continue;
		endif;
		str := str &amp; ',' &amp; ti.id;
	endwhile;

	if str.length &gt; 0 then
		str := str[2 : end];
	endif;
	
	return str;

epilog	
	delete iter;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
