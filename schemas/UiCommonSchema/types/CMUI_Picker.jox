    </JadeMethod>
    <JadeMethod name="doFilter" id="1fe946b2-4fd8-4522-86ab-10ef7a2290ed">
        <source>doFilter();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2018	jlgns1	Initial creation
5/09/2018 	JLGNS1	Bug 40285: STWO - 7182 - Search Cargo ID in Road Gate Picker screen
Moved from btnFilter_click
*/

vars

	searchString : String;
	compareString : String;
	columns : Integer;
	rowIndex : Integer;
	colIndex: Integer;
	include,hasIncluded : Boolean;
	isFirstRow : Boolean;	//Bug 40285
	obj : Object;
begin

	searchString := self.txtFilter.text.toUpper;
	columns := self.tblList.columns;
	isFirstRow := true;		//Bug 40285
	foreach rowIndex in 1 to self.tblList.rows do
		if rowIndex &lt;= self.tblList.fixedRows then
			continue;
		endif;
		
		self.tblList.allSelectedRows.clear;
		
		//jlier1 20/6/24 TFS 64592
		if self.showRailPreCheck and not self.chkRailPrenotes.value then
			obj := self.tblList.accessRow(rowIndex).itemObject;
			if obj &lt;&gt; null and obj.isKindOf(CM_TrackedItem) then
				if obj.CM_TrackedItem.isPreNote and obj.CM_TrackedItem.receiptTransportMode = TI_TRANSMODE_RAIL then
					self.tblList.accessRow( rowIndex ).visible := false;
					continue;
				endif;
			endif;
		endif;
		
		
		if searchString &lt;&gt; null then
			compareString := null;
			foreach colIndex in 1 to columns do
				compareString := compareString &amp; self.tblList.accessCell( rowIndex, colIndex ).text.toUpper &amp; " ";
			endforeach;
			
			include := compareString.pos( searchString, 1 ) &gt; 0;
			self.tblList.accessRow( rowIndex ).visible := include;
			
			if include  then												//Bug 40285	Set selected row to the first visible row		
				hasIncluded:=true;
				self.tblList.accessRow(rowIndex).selected := isFirstRow;	//Bug 40285
				isFirstRow := false;										//Bug 40285
			endif;															//Bug 40285
		else
			self.tblList.accessRow( rowIndex ).visible := true;				//Bug 40285
			self.tblList.accessRow(rowIndex).selected := isFirstRow;		//Bug 40285
			isFirstRow := false;											//Bug 40285
		endif;
	endforeach;
	
	if not hasIncluded then
		self.txtFilter.foreColor := Red;
		self.txtFilter.bubbleHelp := app.getErrorString(UiNo_Items_Found);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="fa826a6d-a119-4004-9168-2dddb10152bc">
        <updating/>
        <source>doOK() updating, protected;
//
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------
// 26/06/2014	cnwdap1		PAR #34066 Make sure disabled rows can't be selected
vars
	count	: Integer;
	oa	: ObjectArray;
	obj	: Object;
	row	: Integer;
	msg : String;
begin

	app.mousePointer := MousePointer_HourGlass;
	
	// 29287 Apr 2012 multi-select pre-notes in road gate
	if self.allowMultiSelect then
		foreach row in self.tblList.fixedRows+1 to self.tblList.rows do
			//if self.tblList.accessRow(row).selected then											// PAR #34066
			if self.tblList.accessRow(row).selected and self.tblList.accessRow(row).enabled then	// PAR #34066
				if oa = null then
					create oa transient;
				endif;
				obj := self.tblList.accessRow(row).itemObject;
				oa.add(obj);
				count := count + 1;
			endif;
		endforeach;
	//	if not self.validateMultiSelection(oa) then
		if not self.validateMultiSelection(oa,msg) then	//14 Nov 2013	NDL	Par 32995
			if msg &lt;&gt; null then
				app.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only);
			else
				app.msgBox(app.getErrorString(Selec_items_must_be_singl_book), app.getErrorString(Error), MsgBox_OK_Only);
			endif;
			delete oa;
			return;
		endif;
		// if only one, return it otherwise return an array (TIs only)
		if count = 1 then
			self.selectedObject := obj;
		else
			self.selectedObject := oa;
		endif;
	else
		row := self.tblList.row;
		//if row &gt; 0 then																			// PAR #34066
		if row &gt; 0 and self.tblList.accessRow(row).enabled then										// PAR #34066
			self.selectedObject := self.tblList.accessRow(row).itemObject;
		endif;
	endif;

	self.modalResult := MsgBox_Return_OK;
	self.unloadForm();
epilog
	if count = 1 then
		delete oa;
	endif;
	app.mousePointer := MousePointer_Default;		//+cnwml2 PAR23045
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="6fe17fc4-fe7c-46fd-bd29-4e88e60b7aae">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     15 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpWidth,
	tmpTop		: Real;

begin
	inheritMethod();
	return;
	tmpWidth := self.width - WinLeftMargin - WinRightMargin;
	
	lblInstructions.move(WinLeftMargin, WinTopMargin, tmpWidth, lblInstructions.height);
	
	tmpTop := self.height - WinBottomMargin - btnCancel.height;
	
	btnCancel.move(self.width - WinRightMargin - btnCancel.width,
				   tmpTop, btnCancel.width, btnCancel.height);

	btnOK.move(btnCancel.left - HorizontalSpacing - btnOK.width,
				   tmpTop, btnOK.width, btnOK.height);
				   
	tmpTop := lblInstructions.top + lblInstructions.height + VerticalSpacing;
	
	tblList.move(WinLeftMargin, tmpTop, tmpWidth, btnCancel.top - VerticalSpacing - tmpTop);

end;</source>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="c79d09f6-04ee-4ae8-860a-810aea69e642">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2017	cnwndl1	Initial creation	TFS 3758
10 Apr   2017   cnwma1	TFS #4031:PAR38664 STWR - Columns do not expand to the size of the Picker screen
20 Jun   2024 	jlier1  TFS 64592 - couldn't get settings to save
*/

vars
	oldXmlStr,newXmlStr : String;
begin	
	self.xmlSavedSettings := global.formatAsXML(CHKTAG,self.chkPrenotesByBookItem.value.Integer.String) &amp; Cr &amp; global.formatAsXML(CHKRAIL,self.chkRailPrenotes.value.Integer.String);
	self.getXmlStringForTable( false, oldXmlStr, newXmlStr );
	self.xmlSavedSettings := self.xmlSavedSettings &amp; Cr &amp; newXmlStr;
	return self.xmlSavedSettings;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXmlStringForCheckbox" id="0f5051be-575c-4944-85ac-4abbb3d4b4f4">
        <source>getXmlStringForCheckbox();
/*
Purpose:			
Date				Who			Reason
APRIL 2017		CNWAB1		Initial creation
20 Jun 2024		jlier1  	TFS 64592
*/


vars
	value : Boolean;
	str : String;
begin
	str :=  self.xmlSavedSettings.cnEcGetTagValueOfName(CHKTAG);
	
 	value := str.Integer.Boolean;

	self.chkPrenotesByBookItem.value := value;

	str :=  self.xmlSavedSettings.cnEcGetTagValueOfName(CHKRAIL);
	
 	if str = null then
		value:=true;
	else
		value := str.Integer.Boolean;
	endif;

	self.chkRailPrenotes.value := value;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getXmlStringForTable" id="8e496a39-463a-40f5-9cad-4f650ab8b91e">
        <source>getXmlStringForTable( _stripExtraTagSet : Boolean; _currentXmlStr : String output; _newXmlStr : String output );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2017	cnwndl1	Initial creation	TFS 3758

*/

vars

	rawTagName : String;
	startTag : String;
	endTag : String;
	startPos : Integer;
	endPos : Integer;
	length : Integer;
	workString : String;

begin

	if self.tblList.myEntTableDef = null then
		return;
	endif;
	
	rawTagName := self.tblList.name &amp; self.tblList.myEntTableDef.name;
	startTag := global.formatAsXMLPrefix( rawTagName );
	endTag := global.formatAsXMLSuffix( rawTagName );
	
	_newXmlStr := startTag &amp; self.tblList.getXmlStrForColumns(true) &amp; endTag;

	startPos := self.xmlSavedSettings.pos( startTag, 1 );
	if startPos &lt; 1 then	
		return;
	endif;
	
	endPos := self.xmlSavedSettings.pos( endTag, 1 );
	endPos := endPos + endTag.length;
	if endPos &lt; 1 or endPos &lt; startPos then	
		return;
	endif;
	
	length := endPos - startPos;
	_currentXmlStr := self.xmlSavedSettings[ startPos : length ];
	
	if _stripExtraTagSet then
		startPos := startTag.length + 1;
		endPos := _currentXmlStr.pos( endTag, 1);
		if endPos &lt; 1 or endPos &lt; startPos or startPos &gt; _currentXmlStr.length then
			_currentXmlStr := null;
			return;
		endif;
		workString := _currentXmlStr[ startPos : ( endPos - startPos ) ];
		_currentXmlStr := workString;
	endif;
	
epilog

end;</source>
        <Parameter name="_stripExtraTagSet" type="Boolean"/>
        <Parameter name="_currentXmlStr" type="String" usage="output"/>
        <Parameter name="_newXmlStr" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="641554e7-25e0-4f4f-921c-47f94d6454c4">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2017	cnwndl1	Initial creation	TFS 3758

*/

vars

begin

	inheritMethod(_userWindow);
	
	self.xmlSavedSettings := _userWindow.xmlInfo;

epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="b3f542e9-a7d5-46b7-8ca1-0c9bbc2c41fa">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2018	jlgns1	Initial creation
5/09/2018 	JLGNS1	Bug 40285: STWO - 7182 - Search Cargo ID in Road Gate Picker screen
*/

vars

begin
	
	//if txtFilter is selected then mahe the return key call doFilter
	if keyCode = J_key_Return and self.frmFilter.visible and app.activeControl() = txtFilter then
		btnOK.default := false;
		self.doFilter();
	else
		btnOK.default := true;
	endif;
	
epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="924d549e-8288-49aa-a2a8-8223ddc6fe20">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

vars

	showBtns : Boolean;
	offSet : Real;
	term : CM_Terminal;
	
begin
	inheritMethod();
	
	term := app.getMyTerminalDO_NOT_USE();
	if term &lt;&gt; null then
		self.frmFilter.visible := term.getConfig(ShowPickerFilter).Boolean;	//18 Jul 2018	NDL	TFS 38617
	endif;
	//22 Dec 2016	NDL	TFS 3134/2683
	showBtns :=  self.allowCreateJobsBtn and self.myCallingForm &lt;&gt; null and self.myCallingForm.name = "GTE_FlexiGateForm";
	btnSelected.visible := showBtns;	//22 Dec 2016	NDL	TFS 3134/2683
	btnSelectAll.visible := showBtns;	//22 Dec 2016	NDL	TFS 3134/2683
	btnDeSelectAll.visible := showBtns;	//09 Feb 2017	NDL	TFS 3134/2683

	self.chkPrenotesByBookItem.visible := showBtns; // TFS 3702
	self.chkRailPrenotes.visible:=self.showRailPreCheck; //jlier1 TFS 64592 20/6/24
	if not showBtns then
		self.chkRailPrenotes.left:=self.chkPrenotesByBookItem.left;
	endif;
	
	self.lblInstructions2.visible := showBtns; // TFS 3702
	if not showBtns then // TFS 3702
		self.tblList.top := self.lblInstructions2.top; // TFS 3702
		self.tblList.height := self.tblList.height + 50; // TFS 3702
		//18 Jul 2018	NDL	TFS 38617
		if self.frmFilter.visible then
			offSet := self.frmFilter.height + 2;
			self.frmFilter.top := self.lblInstructions2.top;
			self.chkRailPrenotes.top:=self.lblInstructions2.top;
			self.frmFilter.left := self.tblList.left;
			self.tblList.top := self.tblList.top + offSet;
			self.tblList.height := self.tblList.height - offSet;
		endif;
	endif;
	
	showBtns := self.isGenericScanMode;
	if showBtns then
		self.btnDiscard.visible := showBtns;	//TFS 52777
		self.btnDiscard.left := 12;
		self.btnDiscard.top := self.btnOK.top;
	endif;
	
	frmToolbarBtns.visible	:=	false;
	self.modalResult := MsgBox_Return_Cancel;
	self.centreWindow();
	self.resize();
	
	// TFS 3702 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnOK.enabled:= false;
		self.btnSelected.enabled:= false;
	endif;
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
