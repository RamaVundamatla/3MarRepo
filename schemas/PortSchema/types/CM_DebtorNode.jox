vars

begin
	self.myParentDebtorNode	:= self.group;
end;</source>
    </JadeMethod>
    <JadeMethod name="checkParentage" id="295f9fab-b794-4a26-a17d-bcb4dbceeaf6">
        <source>checkParentage(_debtorNode : CM_DebtorNode ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 September 2017	jlgns1	Initial creation
Checks if there is already an incompatible relationship between the debtor nodes
//13/09/17 jlgns1 TFS 6921 1201 : ADP Kernel stack overflow
*/

vars
	parentNode : CM_DebtorNode;
begin
	parentNode := self.myParentDebtorNode;
		
	if _debtorNode = self then
		return true;
	elseif parentNode &lt;&gt; null then
		if parentNode = _debtorNode then
			return true;
		else
			return parentNode.checkParentage(_debtorNode); 
		endif;
	endif;

	return false;
end;</source>
        <Parameter name="_debtorNode" type="CM_DebtorNode"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="debtorMatches" id="59bc1a30-6a2f-442e-812c-9c987bef8262">
        <source>debtorMatches( _strToMatch : String ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 July 2018	jlgndl1	Initial creation	TFS 39254

*/

vars

	strToCheck : String;

begin

	strToCheck := self.name.toUpper;
	
	if self.myParentDebtorNode &lt;&gt; null and not self.myParentDebtorNode.isKindOf(CM_RootDebtorGroup) then
		strToCheck := strToCheck &amp; " " &amp; self.myParentDebtorNode.name.toUpper;
	endif;
	
	return strToCheck.pos( _strToMatch, 1 ) &gt; 0;

epilog

end;</source>
        <Parameter name="_strToMatch" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
