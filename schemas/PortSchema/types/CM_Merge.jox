    <JadeMethod name="typeString" id="e2b2a62f-c272-4175-be30-2121ba7ccc4f">
        <methodInvocation>mapping</methodInvocation>
        <source>typeString(_set: Boolean; _value: String io) mapping;

// Created by cnwdvb1 on 15 November 2006

vars

begin
	
	if self.mode = PLANNING_MODE then

		if self.unplan then
			_value := "Unplanned";
		else
			_value := "Planned";
		endif;
	elseif self.mode = QUEUE_MODE then
		if self.unplan then
			_value := "Unqueue";
		else
			_value := "Queued";
		endif;
	else
		inheritMethod(_set, _value);
	endif;

end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
</Class>
