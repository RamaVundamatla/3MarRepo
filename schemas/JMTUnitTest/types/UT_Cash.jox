    <JadeMethod name="tReleaseUnpaidCargoConfig2" id="3499ac2b-2cfd-4966-b52d-a4910838202a">
        <updating/>
        <source>tReleaseUnpaidCargoConfig2() updating;
/*

Purpose:			This UT is prety much the same as "tReleaseUnpaidCargoConfig"
					It's just that in this UT, it will trigger 2 invoice lines/cash payment for storage to cover the scenario in QTS
					

Parameters:			

Return Value:		

Date		Who		Reason
14/04/2025	navkc1 JIRA Bug MTN-34628: QTS | UAT Issue - Incorrect Cash payment validation at Gate out
// ### JIRA 34988 06JUN2025 NAVAB1 changes to the error messages raised
*/

constants
	CEN = "UTCEN";
	CEN2 = "UTCEN2";
	VOYCODE = "CASHAPIVOY";
	VESSCODE = "CASHAPIVESS";
	CARGOID = "33930-1";
	CARGOID2 = "33930-2";
	CARGOID3 = "33930-3";
	CARGOID4 = "33930-4";
	CARGOID5 = "33930-5";
	TRANMAP = "CASHAPI";
	EXTUSER1 = "USER1";
	EXTUSER2 = "USER2";
	INVLINEDESC1 = "UT33930-1";
	INVLINEDESC2 = "UT33930-2";
	INVLINEDESC3 = "UT33930-3";
	INVLINEDESC4 = "UT33930-4";
	TODOTASKDESC = "33930TDT";
	TRUCKID = "33930T";
	CARRIERID = "33930C";
vars
	err,
	fileContext,				
	itemCode,
	cargoId,
	cargoId2,
	cargoId3,
	cargoId4,
	cargoId5,
	voyCode,
	agentId					: String;
	
	today,
	effectiveDate 			: Date;
	
	ts						: TimeStamp;
	receiptNumber			: Integer;
	
	vvr						: CM_VehicleVisitRecord;
	tm						: CM_TranMap;
	voyage					: CM_Voyage;
	operator				: CM_Operator;
	ti,	ti1,
	ti2, ti3, ti4, ti5		: CM_TrackedItem;
	debtorType				: CM_DebtorType;
	customagent				: CM_CustomsAgent;
	terminal				: CM_Terminal;
	debtorNode				: CM_DebtorNode;
	debtor					: CM_Debtor;
	debtorTerminal			: CM_DebtorTerminal;
	bank					: CM_Bank;
	proxyCriteria			: CM_YACriteria;
	proxyProCrit 			: CM_ProformaTransactionCriteria;
	realProCrit 			: CM_ProformaTransactionCriteria;
	value 					: Any;
	criterias				: CMIF_Array;
	cmifCriteria 			: CMIF_YACriteriaPriority;
	selectedTrxTypes		: CM_TransactionTypeByType;
	critType 				: CM_YACriteriaType;
	pxyTransService 		: CM_TransServiceBroker;
	cashReceipt,
	cashReceipt2,
	cashReceipt3,
	cashReceipt4,
	cashReceipt5,
	cashReceiptForBoth		: CM_CashReceipt;
	invLineDesc1,
	invLineDesc2,
	invLineDesc3,
	invLineDesc4			: CM_InvoiceLineDesc;
	services				: CM_ServiceByNameDict;
	cmifCashAgent			: CMIF_CashInvoiceProformaCtrl;
	tiSet					: CM_TISet;
	toDoTaskDesc			: CM_ToDoTaskDesc;
	ta1						: CM_TerminalArea;
	tiTrans					: CM_TITransaction;
	storageConfig			: CM_StorageConfig;
	actualMess, expectedMess1, expectedMess2 : String;
begin
	//return;
	create services transient;
	create cmifCashAgent transient;
	create tiSet transient; 
	// Terminal Area
	ta1 := self.addBlockStack("UTPHT1",9999999,null);
	self.assertNotNullMsg(ta1, "Failed to create TA1");
	// Terminal
	terminal := self.getMyTerminal();
	
	// Operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	// Custom Agent
	
	customagent := self.addCustomsAgent("APIAGENT", "UTCASHAPI");
	self.assertNotNullMsg(customagent, "Failed to create customs agent");
	
	// Delete Truck
	self.deleteVehicle(TRUCKID);
	self.deleteCarrier(CARRIERID);
	
	// Create To Do Task Desc
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[TODOTASKDESC];
	if toDoTaskDesc &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTaskDesc);
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("CargoType", app.myRoot.allCargoTypesById[TI_CargoType_BreakBulk]);
	toDoTaskDesc := self.createToDoTaskDesc(TODOTASKDESC);
	self.assertNotNullMsg(toDoTaskDesc, "Failed to create to do task desc");
	
	
	// Debtor
	debtor := self.getDebtor("APIDEBT");
	if debtor = null then
		debtorNode := self.addDebtor("APIDEBT", PaymentType_None);
		debtor := debtorNode.CM_Debtor;
	endif;
	beginTransaction;
		customagent.setDebtor(debtor);
	commitTransaction;
	debtorTerminal := debtor.allDebtorTerminals[terminal];
	self.setDebtorCashOnly(debtor, terminal, true);
	
	// Set terminal to Cash config
	self.enableCashOnlyTerminal(terminal, true);
	self.setTerminalConfig(CashRoadExitChkServices, true);
	self.setTerminalConfig(CashOnlyInDebtOption, 1);
	
	// Get Invoice Line Type
	invLineDesc1 := self.getInvoiceLineType(INVLINEDESC1); // Days Since receival
	self.assertNotNullMsg(invLineDesc1, "Failed to get invoice line type 1");
	invLineDesc2 := self.getInvoiceLineType(INVLINEDESC2); // Cargo Value of 1
	self.assertNotNullMsg(invLineDesc2, "Failed to get invoice line type 2");
	invLineDesc3 := self.getInvoiceLineType(INVLINEDESC3); // Storage days on site by volune
	self.assertNotNullMsg(invLineDesc3, "Failed to get invoice line type 3");
	invLineDesc4 := self.getInvoiceLineType(INVLINEDESC4); // Storage days on site by volume
	self.assertNotNullMsg(invLineDesc4, "Failed to get invoice line type 4");
	
	// Setup transaction mapping
	tm := self.getTransactionMap(TRANMAP);
	if tm = null then
		tm := self.createTransactionMap(TRANMAP);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;	
	self.assertNotNullMsg(tm, "Failed to create transaction mapping");
	app.myTrxUA.trxUpdateBankTMActive(tm, app.myPassport);
	
	fileContext := 
'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested?
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) †,(Default),,,**Any**,All,VOID
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Released - Road,,(Default),(Default) †,(Default),,,**Any**,All,UT33930-1
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Todo Task Added,,(Default),(Default) ›,(Default),,,**Any**,All,UT33930-2
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Storage,,(Default),|CCT07|Days Onsite At 00:00:00 »,08 to 12,,,**Any**,Highest 1,UT33930-3
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Storage,,(Default),|CCT07|Days Onsite At 00:00:00 »,13 to MAX,,,**Any**,Highest 1,UT33930-4';

	self.transactionMapLoad(fileContext, null);
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	
	// Setup cash config
	debtorType := app.myRoot.allDebtorTypes["SDT6"];
	self.assertNotNullMsg(debtorType, "Failed to get cash debtor type");
	self.setTerminalConfig(CashDebtorType, debtorType);
	
	bank := terminal.getDefaultCompanyBank();
	
	create criterias transient;
	critType := app.myRoot.allYACriteriaTypes.getAtKey(19);	//Operator
	create proxyCriteria transient;
	itemCode := critType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	value := operator.code;
	proxyCriteria.setProxy(critType, value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	criterias.add(cmifCriteria);
	
	create selectedTrxTypes transient;
	selectedTrxTypes.add( app.myRoot.allTransactionTypes[32] ); // Receive Ship
	
	create proxyProCrit transient;
	proxyProCrit.setProxy( criterias, selectedTrxTypes, 2, bank, null, null, null, null, null,null );
	app.myTrxCA.trxCreateProformaCriteria(proxyProCrit, realProCrit, app.myPassport);
	self.assertTrueMsg(app.myPassport.noErrors, "Pro Forma allocation create failed - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	delete proxyProCrit;
	
	// Setup storage config
	self.deleteStorageConfig(true);
	storageConfig := terminal.myStorageConfig;
	
	// Hacky way to include first day, so the storage gets calculated 
	beginTransaction;
		storageConfig.setPropertyValue("includeFirstDay", true);
	commitTransaction;
	
	// Create voyage
	self.opts.purge();
	
	self.opts.addAssoc("dateArrival", today.addDays(-30));
	voyage := self.createVesselVoyage(VOYCODE, VESSCODE, operator);
	self.assertNotNullMsg(voyage, "Failed to create voyage");
	cargoId := CARGOID&amp;today.asStringJMT();
	cargoId2 := CARGOID2&amp;today.asStringJMT();
	cargoId3 := CARGOID3&amp;today.asStringJMT();
	cargoId4 := CARGOID4&amp;today.asStringJMT();
	cargoId5 := CARGOID5&amp;today.asStringJMT();
	self.opts.purge();
	// Create cargo 1
	ti1 := self.getTrackedItem(cargoId);
	if ti1 &lt;&gt; null then
		self.deleteTrackedItem(ti1, true);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("TotalVolume", 1000);
	
	// Cargo 1
	ti1 := self.addCargoForVoyage(voyage, cargoId);
	self.assertNotNullMsg(ti1, "Failed to creatt TI1");
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_IMPORT, true);
	
	// Create cargo 2
	ti2 := self.getTrackedItem(cargoId2);
	if ti2 &lt;&gt; null then
		self.deleteTrackedItem(ti2, true);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	// Cargo 2
	ti2 := self.addCargoForVoyage(voyage, cargoId2);
	self.assertNotNullMsg(ti2, "Failed to creatt TI2");
	self.editIMEXStatus(ti2, TI_IMEX_STATUS_IMPORT, true);
	
	// Create cargo 3
	ti3 := self.getTrackedItem(cargoId3);
	if ti3 &lt;&gt; null then
		self.deleteTrackedItem(ti3, true);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	// Cargo 3
	ti3 := self.addCargoForVoyage(voyage, cargoId3);
	self.assertNotNullMsg(ti3, "Failed to creatt TI3");
	self.editIMEXStatus(ti3, TI_IMEX_STATUS_IMPORT, true);
	
	// Create cargo 4
	ti4 := self.getTrackedItem(cargoId4);
	if ti4 &lt;&gt; null then
		self.deleteTrackedItem(ti4, true);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	// Cargo 4
	ti4 := self.addCargoForVoyage(voyage, cargoId4);
	self.assertNotNullMsg(ti4, "Failed to creatt TI4");
	self.editIMEXStatus(ti4, TI_IMEX_STATUS_IMPORT, true);
	
	// Create cargo 5
	ti5 := self.getTrackedItem(cargoId5);
	if ti5 &lt;&gt; null then
		self.deleteTrackedItem(ti5, true);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	// Cargo 5
	ti5 := self.addCargoForVoyage(voyage, cargoId5);
	self.assertNotNullMsg(ti5, "Failed to creatt TI5");
	self.editIMEXStatus(ti5, TI_IMEX_STATUS_IMPORT, true);
	
	// Set Customs Agent and Customs Entry Number to all cargo
	beginTransaction;
	ti1.setCustomsAgent(customagent);
	ti1.setCustomsEntryNumber(CEN);
	ti2.setCustomsAgent(customagent);
	ti2.setCustomsEntryNumber(CEN);
	ti3.setCustomsAgent(customagent);
	ti3.setCustomsEntryNumber(CEN);
	ti4.setCustomsAgent(customagent);
	ti4.setCustomsEntryNumber(CEN);
	ti5.setCustomsAgent(customagent);
	ti5.setCustomsEntryNumber(CEN);
	commitTransaction;
	
	// Discharge Cargo and set it to be 30 days ago
	tiSet.clear();
	tiSet.add(ti1);
	tiSet.add(ti2);
	tiSet.add(ti3);
	tiSet.add(ti4);
	tiSet.add(ti5);
	self.moveCargo(ti1, tiSet, ta1.allLocationsControllers.first(), app.myPassport);
	beginTransaction;
		foreach ti in tiSet do
			tiTrans := ti.getLastTransOfType(TRANS_TYPE_REC_SHIP); // Received Ship transaction
			ts.setDate(today.addDays(-30));
			tiTrans.setPropertyValue("dateTime", ts);
			ti.setPropertyValue("receivedDT", ts);
		endforeach;
	commitTransaction;
	
	self.opts.purge();
	self.opts.addAssoc("CENum", CEN);
	
	// Delete stops
	foreach ti in tiSet do
		self.deleteStops(ti);
	endforeach;
	
	tiSet.clear();
	
	/*==============================
		
		Scenario 1 - No payment made
		Should get error
		
	================================*/
		
		// Create a VVR and simulate gate out - Should get an error
		vvr := self.gateOutGC(TRUCKID, null, "UTDRIVER", ti1, self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString()), null);
		self.assertNotNullMsg(vvr, "Failed to create VVR");
		self.clearExpectedTrxErrors();
		self.expectedTrxErrors.add(Cash_cargo_not_paid);
		app.myValUA.valCashCollectionForVVR(vvr,true,true,null,app.myPassport);
		self.assertTrxErrorMsg(Cash_cargo_not_paid, "Error not raised 001");
		
		/*actualMess := app.myPassport.getErrorsAsString();
		expectedMess1 := "for cash-only debtor APIDEBT is not fully paid for

Cash Total Required = 112129.900000
Cash Paid So Far = 0.000000
Cash Outstanding = 112129.900000";

		self.assertTrueMsg(actualMess.pos(expectedMess1, 1) &gt; 0, "Error not raised 001 - " &amp; actualMess );
//		self.assertTrueMsg(app.myPassport.getErrorsAsString().pos(ti1.id &amp; " for cash-only debtor APIDEBT not fully paid for", 1) &gt; 0, "Error not raised");
		*/
		if vvr &lt;&gt; null then
			self.deleteVVR(vvr);
		endif;
	
	
	/*==============================
		
		Scenario 2 - Paid exact amount. i.e. paid for today, pickup today.
		Shoudl get no error
		
	================================*/
		
		// Init details for Cash CMIF
		voyCode := voyage.code;
		today := app.actualTimeServer().date();
		effectiveDate := today;
		agentId := customagent.code;
		
		// Initialize CMIF	
		delete cmifCashAgent;
		create cmifCashAgent transient;
		cmifCashAgent.initialize(voyCode, null, CEN, cargoId2, effectiveDate, voyage.arrivedDT.date(), terminal, agentId, false, true);
		cmifCashAgent.doValidateCashCalculate(err);
		self.assertNullMsg(err, "TI2 - CMIF agent validation failed - " &amp; err &amp; ", " &amp; app.myPassport.getAllErrorsWarningsAsString());
		
		// Do calulate cash amout
		cmifCashAgent.doCalculate();
		
		// Get Cash receipt
		cashReceipt2 := cmifCashAgent.myNewCashReceipt;
		self.assertNotNullMsg(cashReceipt2, "TI2 - Failed to create cash receipt");
		
		// Change Cash Receipt status to HOLD
		receiptNumber := cashReceipt2.sequenceNum;
		delete cmifCashAgent;
		create cmifCashAgent transient;
		
		cmifCashAgent.initializeForProformaStatus(agentId, CEN, receiptNumber, null, null, null, null, null, null, CM_CashReceipt.API_RECEIPT_HOLD, terminal);
		cmifCashAgent.doChangeProformaStatusFromAPI();
		self.assertTrueMsg(cashReceipt2.paymentStatus = CM_CashReceipt.API_RECEIPT_HOLD, "TI2 - Cash Receipt status update to HOLD failed");
		
		// Change Cash Receipt status to PAID then to FINAL
		delete cmifCashAgent;
		create cmifCashAgent transient;
		
		cmifCashAgent.initializeForProformaStatus(agentId, CEN, receiptNumber, null, null, null, null, null, null, CM_CashReceipt.API_RECEIPT_PAID, terminal);
		cmifCashAgent.doChangeProformaStatusFromAPI();
		self.assertTrueMsg(cashReceipt2.paymentStatus = CM_CashReceipt.API_RECEIPT_FINAL, "TI2 - Cash Receipt status update to PAID failed");
		
		self.deleteStops(ti2);
		
		self.deleteVehicle(TRUCKID);
		// Create a VVR and simulate gate out - Should get an error
		vvr := self.gateOutGC(TRUCKID, null, "UTDRIVER", ti2, self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString()), null);
		self.assertNotNullMsg(vvr, "TI2 - Failed to create VVR");
		app.myValUA.valCashCollectionForVVR(vvr,true,true,null,app.myPassport);
		self.assertTrueMsg(app.myPassport.getErrorsAsString() = null, "TI2 - Should not get error");
		
		if vvr &lt;&gt; null then
			self.deleteVVR(vvr);
			vvr := null;
		endif;
	
	/*==============================
		
		Scenario 3 - Overpaid. i.e. paid for next month, pickup today.
		Shoudl get no error
		
	================================*/
		
		// Init details for Cash CMIF
		voyCode := voyage.code;
		today := app.actualTimeServer().date();
		effectiveDate := today.addDays(30);
		agentId := customagent.code;
		
		// Initialize CMIF	
		delete cmifCashAgent;
		create cmifCashAgent transient;
		cmifCashAgent.initialize(voyCode, null, CEN, cargoId3, effectiveDate, voyage.arrivedDT.date(), terminal, agentId, false, true);
		cmifCashAgent.doValidateCashCalculate(err);
		self.assertNullMsg(err, "TI3 - CMIF agent validation failed - " &amp; err&amp; ", " &amp; app.myPassport.getAllErrorsWarningsAsString());
		
		// Do calulate cash amout
		cmifCashAgent.doCalculate();
		
		// Get Cash receipt
		cashReceipt3 := cmifCashAgent.myNewCashReceipt;
		self.assertNotNullMsg(cashReceipt3, "TI3 - Failed to create cash receipt");
		
		// Change Cash Receipt status to HOLD
		receiptNumber := cashReceipt3.sequenceNum;
		delete cmifCashAgent;
		create cmifCashAgent transient;
		
		cmifCashAgent.initializeForProformaStatus(agentId, CEN, receiptNumber, null, null, null, null, null, null, CM_CashReceipt.API_RECEIPT_HOLD, terminal);
		cmifCashAgent.doChangeProformaStatusFromAPI();
		self.assertTrueMsg(cashReceipt3.paymentStatus = CM_CashReceipt.API_RECEIPT_HOLD, "TI3 - Cash Receipt status update to HOLD failed");
		
		// Change Cash Receipt status to PAID then to FINAL
		delete cmifCashAgent;
		create cmifCashAgent transient;
		
		cmifCashAgent.initializeForProformaStatus(agentId, CEN, receiptNumber, null, null, null, null, null, null, CM_CashReceipt.API_RECEIPT_PAID, terminal);
		cmifCashAgent.doChangeProformaStatusFromAPI();
		self.assertTrueMsg(cashReceipt3.paymentStatus = CM_CashReceipt.API_RECEIPT_FINAL, "TI3 - Cash Receipt status update to PAID failed");
		
		self.deleteStops(ti3);
		
		self.deleteVehicle(TRUCKID);
		// Create a VVR and simulate gate out - Should get an error
		vvr := self.gateOutGC(TRUCKID, null, "UTDRIVER", ti3, self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString()), null);
		self.assertNotNullMsg(vvr, "TI3 - Failed to create VVR");
		app.myValUA.valCashCollectionForVVR(vvr,true,true,null,app.myPassport);
		self.assertTrueMsg(app.myPassport.getErrorsAsString() = null, "TI3 - Should not get error");
		
		if vvr &lt;&gt; null then
			self.deleteVVR(vvr);
			vvr := null;
		endif;
		
	/*==============================
		
		Scenario 4 - Overpaid, then add extra charges. i.e. paid for next month, then add a todo task which trigger additonal charge. Then pickup today
		Should get error amount owe
		
	================================*/
	
		// Init details for Cash CMIF
		voyCode := voyage.code;
		today := app.actualTimeServer().date();
		effectiveDate := today.addDays(30);
		agentId := customagent.code;
		
		// Initialize CMIF	
		delete cmifCashAgent;
		create cmifCashAgent transient;
		cmifCashAgent.initialize(voyCode, null, CEN, cargoId4, effectiveDate, voyage.arrivedDT.date(), terminal, agentId, false, true);
		cmifCashAgent.doValidateCashCalculate(err);
		self.assertNullMsg(err, "TI4 - CMIF agent validation failed - " &amp; err &amp; ", " &amp; app.myPassport.getAllErrorsWarningsAsString());
		
		// Do calulate cash amout
		cmifCashAgent.doCalculate();
		
		// Get Cash receipt
		cashReceipt4 := cmifCashAgent.myNewCashReceipt;
		self.assertNotNullMsg(cashReceipt4, "TI4 - Failed to create cash receipt");
		
		// Change Cash Receipt status to HOLD
		receiptNumber := cashReceipt4.sequenceNum;
		delete cmifCashAgent;
		create cmifCashAgent transient;
		
		cmifCashAgent.initializeForProformaStatus(agentId, CEN, receiptNumber, null, null, null, null, null, null, CM_CashReceipt.API_RECEIPT_HOLD, terminal);
		cmifCashAgent.doChangeProformaStatusFromAPI();
		self.assertTrueMsg(cashReceipt4.paymentStatus = CM_CashReceipt.API_RECEIPT_HOLD, "TI4 - Cash Receipt status update to HOLD failed");
		
		// Change Cash Receipt status to PAID then to FINAL
		delete cmifCashAgent;
		create cmifCashAgent transient;
		
		cmifCashAgent.initializeForProformaStatus(agentId, CEN, receiptNumber, null, null, null, null, null, null, CM_CashReceipt.API_RECEIPT_PAID, terminal);
		cmifCashAgent.doChangeProformaStatusFromAPI();
		self.assertTrueMsg(cashReceipt4.paymentStatus = CM_CashReceipt.API_RECEIPT_FINAL, "TI4 - Cash Receipt status update to PAID failed");
		
		// Add to do task to create charges
		tiSet.clear();
		tiSet.add(ti4);
		self.addToDoTask(toDoTaskDesc, tiSet);
		self.assertTrueMsg(ti4.allToDoTasksToDo.isNotEmpty(), "TI4 - Failed to add to do task to TI4");
		
		self.deleteStops(ti4);
		
		self.deleteVehicle(TRUCKID);
		// Create a VVR and simulate gate out - Should get an error
		vvr := self.gateOutGC(TRUCKID, null, "UTDRIVER", ti4, self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString()), null);
		self.assertNotNullMsg(vvr, "TI4 - Failed to create VVR");
		self.clearExpectedTrxErrors();
		self.expectedTrxErrors.add(Cash_cargo_not_paid);
		app.myValUA.valCashCollectionForVVR(vvr,true,true,null,app.myPassport);
		self.assertTrxErrorMsg(Cash_cargo_not_paid, "Error not raised 002");
		
		/*actualMess := app.myPassport.getErrorsAsString();
		expectedMess1 := "for cash-only debtor APIDEBT is not fully paid for

Cash Total Required = 266764.800000
Cash Paid So Far = 266759.800000
Cash Outstanding = 5.000000";

		self.assertTrueMsg(actualMess.pos(expectedMess1, 1) &gt; 0, "Error not raised 002");
//		self.assertTrueMsg(app.myPassport.getErrorsAsString().pos('Cargo "' &amp; ti4.id &amp; '" owes amount 5.000000', 1) &gt; null, "TI4 - Error is not raised correctly");
		*/
		if vvr &lt;&gt; null then
			self.deleteVVR(vvr);
			vvr := null;
		endif;
		
	/*==============================
		
		Scenario 5 - Paid exact amount, then add extra charges. i.e. paid for today, then add a todo task which trigger additonal charge. Then pickup today
		Should get error 
		
	================================*/
	
		// Init details for Cash CMIF
		voyCode := voyage.code;
		today := app.actualTimeServer().date();
		effectiveDate := today;
		agentId := customagent.code;
		
		// Initialize CMIF	
		delete cmifCashAgent;
		create cmifCashAgent transient;
		cmifCashAgent.initialize(voyCode, null, CEN, cargoId5, effectiveDate, voyage.arrivedDT.date(), terminal, agentId, false, true);
		cmifCashAgent.doValidateCashCalculate(err);
		self.assertNullMsg(err, "TI5 - CMIF agent validation failed - " &amp; err &amp; ", " &amp; app.myPassport.getAllErrorsWarningsAsString());
		
		// Do calulate cash amout
		cmifCashAgent.doCalculate();
		
		// Get Cash receipt
		cashReceipt5 := cmifCashAgent.myNewCashReceipt;
		self.assertNotNullMsg(cashReceipt5, "TI5 - Failed to create cash receipt");
		
		// Change Cash Receipt status to HOLD
		receiptNumber := cashReceipt5.sequenceNum;
		delete cmifCashAgent;
		create cmifCashAgent transient;
		
		cmifCashAgent.initializeForProformaStatus(agentId, CEN, receiptNumber, null, null, null, null, null, null, CM_CashReceipt.API_RECEIPT_HOLD, terminal);
		cmifCashAgent.doChangeProformaStatusFromAPI();
		self.assertTrueMsg(cashReceipt5.paymentStatus = CM_CashReceipt.API_RECEIPT_HOLD, "TI5 - Cash Receipt status update to HOLD failed");
		
		// Change Cash Receipt status to PAID then to FINAL
		delete cmifCashAgent;
		create cmifCashAgent transient;
		
		cmifCashAgent.initializeForProformaStatus(agentId, CEN, receiptNumber, null, null, null, null, null, null, CM_CashReceipt.API_RECEIPT_PAID, terminal);
		cmifCashAgent.doChangeProformaStatusFromAPI();
		self.assertTrueMsg(cashReceipt5.paymentStatus = CM_CashReceipt.API_RECEIPT_FINAL, "TI5 - Cash Receipt status update to PAID failed");
		
		// Add to do task to create charges
		tiSet.clear();
		tiSet.add(ti5);
		self.addToDoTask(toDoTaskDesc, tiSet);
		self.assertTrueMsg(ti5.allToDoTasksToDo.isNotEmpty(), "TI5 - Failed to add to do task to TI5");
		
		self.deleteStops(ti5);
		
		self.deleteVehicle(TRUCKID);
		// Create a VVR and simulate gate out - Should get an error
		vvr := self.gateOutGC(TRUCKID, null, "UTDRIVER", ti5, self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString()), null);
		self.assertNotNullMsg(vvr, "TI5 - Failed to create VVR");
		self.clearExpectedTrxErrors();
		self.expectedTrxErrors.add(Cash_cargo_not_paid);
		app.myValUA.valCashCollectionForVVR(vvr,true,true,null,app.myPassport);
		self.assertTrxErrorMsg(Cash_cargo_not_paid, "Error not raised 003");
		/*actualMess := app.myPassport.getErrorsAsString();
		expectedMess1 := "for cash-only debtor APIDEBT is not fully paid for

Cash Total Required = 112134.900000
Cash Paid So Far = 112129.900000
Cash Outstanding = 5.000000";

		self.assertTrueMsg(actualMess.pos(expectedMess1, 1) &gt; 0, "Error not raised 003");
//		self.assertTrueMsg(app.myPassport.getErrorsAsString().pos(ti5.id &amp; " for cash-only debtor APIDEBT not fully paid for", 1) &gt; 0, "TI 5 - Error not raised");
		*/
		if vvr &lt;&gt; null then
			self.deleteVVR(vvr);
			vvr := null;
		endif;
epilog
	self.deleteVehicle(TRUCKID);
	self.resetDefaultTranMap();
	self.deleteVoyage(VOYCODE);
	self.deleteTrackedItem(ti1, true);
	self.deleteTrackedItem(ti2, true);
	self.deleteTrackedItem(ti3, true);
	self.deleteTrackedItem(ti4, true);
	self.deleteTrackedItem(ti5, true);
	self.deleteVessel(VESSCODE);
	if criterias &lt;&gt; null then
		criterias.purge();
	endif;
	delete criterias;
	delete selectedTrxTypes;
	delete proxyProCrit;
	if realProCrit &lt;&gt; null then
		app.myTrxDA.trxDeleteProformaCriteria(realProCrit, app.myPassport);
	endif;
	if cashReceipt &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceipt);
	endif;
	if cashReceipt2 &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceipt2);
	endif;
	if cashReceipt3 &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceipt3);
	endif;
	if cashReceipt4 &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceipt4);
	endif;
	if cashReceipt5 &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceipt5);
	endif;
	if cashReceiptForBoth &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceiptForBoth);
	endif;
	delete pxyTransService;
	delete services;
	delete cmifCashAgent;
	delete tiSet;
	if vvr &lt;&gt; null and app.isValidObject(vvr) then
		self.deleteVVR(vvr);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tSAL52163Cash" id="3f5a79f6-9d2e-4ec1-944a-04806669f8d9">
        <updating/>
        <source>tSAL52163Cash()updating;
/*

Purpose:			
		1- Create invoice Line Description with 200 narration
		2- Convert Invoice line description and make sure audits created correctly
Parameters:			

Return Value:		

Date		Who		Reason
28 Oct 2021 navma1 ChangeRequest 52163: SAL - Unicode Arabic Support Business Requirements

*/
constants
	BS1					: String = "UT_521632";
	TI1					: String = "UT521631";
	InvoiceType		    : String = "UT_SALCASH521631";
	DebtorName			: String = "UT_SAL521631";
	InvoiceServiceId	: String = "UT_SAL521631";
	UT_ILT08Narration	: String = "UT_ILT08 Line1 - Cash be used to Test change Request 52163 SAL - Unicode Arabic Support Business Requirements 52001 SAL - SD Unicode Database Requirements - Arabic Support v_0.2.52001 SAL - SD-Unicode";
	UT_ILT09Narration 	: String = "UT_ILT09 Line2 - Cash be used to Test change Request 52163 SAL - Unicode Arabic Support Business Requirements 52001 SAL - SD Unicode Database Requirements - Arabic Support v_0.2.52001 SAL - SD-Unicode";
	UT_ILT10Narration 	: String = "UT_ILT10 Line3 - Cash be used to Test change Request 52163 SAL - Unicode Arabic Support Business Requirements 52001 SAL - SD Unicode Database Requirements - Arabic Support v_0.2.52001 SAL - SD-Unicode";
	UT_ILT11Narration 	: String = "UT_ILT10 Line4 - Cash be used to Test change Request 52163 SAL - Unicode Arabic Support Business Requirements 52001 SAL - SD Unicode Database Requirements - Arabic Support v_0.2.52001 SAL - SD-Unicode";
vars

	debtor				: CM_Debtor;		
	service				: CM_Service;
	operator			: CM_Operator;
	invoice				: CM_Invoice;
	terminal			: CM_Terminal;
	invType				: CM_InvoiceDesc;
	cashInvType			: CM_InvoiceDesc;
	cargoId1,
	cargoId2			: String;
	debtorName			: String;
	cargoIds			: StringArray;
	drTerm1 			: CM_DebtorTerminal;
	costs 				: DecimalArray;
	debtorRate 			: CM_DebtorRate;
	endDate 			: Date;
	proxyDebtor			: CM_Debtor;
	debtorNode	  		: CM_DebtorNode;
	debtorNodeController	: CMIF_DebtorNode;
	debtorType			: CM_DebtorType;
	invLineType1,
	invLineType2  		: CM_InvoiceLineDesc;
	customsAgent		: CM_CustomsAgent;
begin
	
	cashInvType := self.getInvoiceType("UT_InvType");		
	
	create cargoIds transient;
	// ids with valid check digits
	self.getCargoIds(cargoIds);
	foreach cargoId1 in cargoIds do
		self.deleteContainer(cargoId1);
	endforeach;
	
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	debtorName := "UT_Debtor1";
	debtor := app.myRoot.myRootCompany.debtorNodes[debtorName].CM_Debtor;
	
	if debtor = null then
		create debtorNodeController transient;
		create proxyDebtor transient;
		self.setDebtorNodeController1(debtorName, debtorNodeController, proxyDebtor);
		app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		debtor := debtorNode.CM_Debtor;
	endif;
	
	beginTransaction;
		operator.setPropertyValue(CM_Operator::debtor.name, debtor);
	commitTransaction;
	self.myOperator := operator;
	
	endDate := app.actualTimeServer.Date + 10;	
	self.enableCashOnlyTerminal( self.myTerminal, true );
	self.setBankAvailAllocCriteria();
	self.setBankProFormaAllocations();
	
	//create cash only debtors.
	self.myDebtor1 := app.myRoot.myRootCompany.debtors[DrNameOne];
	if self.myDebtor1 = null then
		self.myDebtor1 := self.addCashOnlyDebtor( DrNameOne );
	endif;
	self.assertTrueMsg(self.myDebtor1 &lt;&gt; null, "Cash only Debtor not created...");
	drTerm1 := self.myDebtor1.allDebtorTerminals.getAtKey( self.myTerminal );
	self.assertTrueMsg(drTerm1 &lt;&gt; null, "Debtor/Terminal not created...");
	self.assertTrueMsg(drTerm1.isCashOnly, "Debtor/Terminal is not cash only...");
	// clear any credits etc from prior tests such as tCashCredit
	self.zPurgeCashDebtor(drTerm1);
	
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;

	// Voyage invoice type, ILT8 invoice line type, used in ship receive, charged to shipping operator, calc type Cargo Quantity
	invType := self.addIfNewInvoiceType("UT_Voyage");
	self.addIfNewServiceILD("UT_ServiceX8", "CCT01", UT_ILT08Narration, null, invType);
	
	service := self.myBank.services["UT_ServiceX8"];		
	self.setServiceRate(service, debtor, "01/01/2013".Date, 100.00);

	invLineType1 := self.myBank.invoiceLineDescriptors[UT_ILT08Narration];
	debtorType := app.myRoot.allDebtorTypes["SDT4"];	
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX9", "CCT01", UT_ILT09Narration, null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors[UT_ILT09Narration];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := self.myBank.services["UT_ServiceX9"];		
	self.setServiceRate(service, debtor, "01/01/2013".Date, 20.00);
	
	
	// Yard invoice type, ILT10 and ILT11 invoice line type, used in storage, charged to customs agent, calc type Days Since Receival
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX10", "CCT06", UT_ILT10Narration, null, invType);
	self.addIfNewServiceILD("UT_ServiceX11", "CCT06",UT_ILT11Narration, null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors[UT_ILT10Narration];
	invLineType2 := self.myBank.invoiceLineDescriptors[UT_ILT11Narration];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	invLineType2.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := self.myBank.services["UT_ServiceX10"];			
	self.setServiceRate(service, debtor, "01/01/2013".Date, 20.00);
	service := self.myBank.services["UT_ServiceX11"];		
	self.setServiceRate(service, debtor, "01/01/2013".Date, 40.00);
	service := self.myBank.services["UT_ServiceX8"];			
	self.setServiceRate(service, debtor, "01/01/2013".Date, 100.00);
	
	
	debtor := operator.debtor;
	service := self.myBank.services["UT_ServiceX8"];			
	self.setServiceRate(service, debtor, "01/01/2013".Date, 5.00);
	
	self.myVoyage := self.createVesselVoyageCash("JMT STAR", "JSTAR001", operator.code);
	self.assertTrueMsg(self.myVoyage &lt;&gt; null, "Voyage '" &amp; CashVoyageCode &amp; "' not created...");

	self.tranMapLoadCashSAL52163();
	
	// one receipt, 2 cargo items with negative extras 
	cargoId1 := cargoIds[1];
	cargoId2 := cargoIds[2];
	self.cashTestExtras(cargoId1, cargoId2, drTerm1, 0);
	
epilog
	delete costs;
	delete debtorRate;
	delete cargoIds;
	self.resetDefaultTranMap();
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateCashOptions" id="93dd8b53-8022-4b95-868b-76024cdb64df">
        <source>tUpdateCashOptions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/05/2014  cnwma1	Initial creation

*/

vars
	cmif : CMIF_InvoiceCashModule;
	terminal : CM_Terminal;
	strCashACforGL : String;
	cashProcUnderpayIsError  : Boolean;
	cashCollectAllowUnderpay : Boolean;
	cashCollectAllowOverPay  : Boolean;
	strGateCashReceiptReport    : String;
	strCashOnlyReceiptReport    :String;
	strGateCashInvReceiptReport : String;
	strDutyDocumentReport       : String;
	strDutyDocCarReport			: String;
	cashAllowSecondCurrency  : Boolean;
	strCashSecondPayCurrency    : String;
	cashSecondPayConvertRate :Real;
	cashSecPayDivConvertRate :Real;
	cashDebtorType          	: CM_DebtorType;
	cashInvoiceType  			: CM_InvoiceDesc;
	strProFormaItemQuery		: String;
	proFormaInclDDTicket		: Boolean;
	proFormaInclDDBill		: Boolean;
	allConfigBanks : CMIF_ConfigBankByBankDict;	//09 Jan 2018	NDL	TFS 40010
begin
	
	terminal := self.getTerminal;
	
	create cmif transient;
	cmif.cashACforGL :="1205.155";
	cmif.secondCurrencyType :="LE";
	
	create allConfigBanks transient;
	
	app.myTrxUA.trxUpdateTermCashOpts(terminal,cmif,allConfigBanks,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertEqual(cmif.cashACforGL,"1205.155");
	self.assertEqual(cmif.secondCurrencyType,"LE");
epilog
	delete cmif;
	delete allConfigBanks;
		
end;</source>
    </JadeMethod>
    <JadeMethod name="tranMapLoadBBlkRecShip" id="9c45df90-0f25-4c16-8ba3-852ae4f027e8">
        <source>tranMapLoadBBlkRecShip();
/*
Purpose - 	
Who - NAVAB1
Date - 02MAY2025
ADO - JIRA 34760
*/

vars
	ct			: String;
	fileContent : String;
	fileName	: String;
	mapName		: String;
	bank		: CM_Bank;
	cargoMap	: CM_TranMap;

begin
	if self.opts.includesKey("CargoType") then
		ct := self.opts.obj("CargoType").CM_CargoType.abbreviation;
	endif;
	self.assertNotNullMsg(ct, "Failed to get cargo type abbr");
	
	fileName := "BBlkRecShip";
	mapName := "UT_BBlkRecShip";
	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),VOID' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;','&amp;ct&amp;',(Default),(Default),Import,(Default),(Default),Received - Ship,,(Default),CCT01 Cargo Quantity ›,00 to MAX,UT_ILT81,,,,,,,,,,';

	
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	cargoMap := bank.myCurrentTranMapCargo[mapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

epilog

end;
</source>
    </JadeMethod>
