    <JadeMethod name="addToDataTable" id="49f2d911-934e-44c8-adb1-223b6a7b9080">
        <updating/>
        <source>addToDataTable(_value: Integer; _item : CMIF_CandHSummaryItem; _row, _column: Integer; _colTotal: Integer io) updating;
//----------------------------------------------------------------
//	Created:	10 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	cell		: JadeTableCell;
	tmpValue	: Integer;
begin

	cell := self.tblData.accessCell(_row, _column);
	cell.itemObject := _item;
	cell.alignment := Table.Alignment_Right_Middle;
	
	tmpValue := _value;
	if _item &lt;&gt; null then
		if (not self.showOriginalData)
		and (not self.hideColours) then
			//show some colour
			if _item.hasEdits
			or ((_item.allSnapShots.size &lt;&gt; tmpValue)
			and _item.allSnapShots.isNotEmpty) then
				//some have been hidden - colour the cell
				cell.backColor := self.ColourYellowDark;
			endif;
			if tmpValue = 0 then
				_colTotal := _colTotal + _item.allSnapShots.size;
			endif;
		endif;
	endif;
	
	if tmpValue = 0 then
		cell.text := null;
	else
		cell.text := tmpValue.asStringJMT;
		_colTotal := _colTotal + tmpValue;
	endif;

end;</source>
        <Parameter name="_value" type="Integer"/>
        <Parameter name="_item" type="CMIF_CandHSummaryItem"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_column" type="Integer"/>
        <Parameter name="_colTotal" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="5220655a-cbb0-4760-a201-3db72b25ba54">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	frm				: CMUI_Toolbar;
begin	
	frm := self.frmToolbar;
	frm.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
