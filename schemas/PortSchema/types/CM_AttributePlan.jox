    <JadeMethod name="erase" id="63658638-3ed1-453a-800e-4acf0583cb50">
        <updating/>
        <source>erase(_eraseLevel : Integer) updating;
//Holds all the bits n pieces we have to do to delete an attribute plan
vars

begin
	exclusiveLock(self);
	self.movePlans.clear();	//Automatic inverses will remove us...
	self.myMoveMap := null;	//Remove us from the moveMap's dict.	
	inheritMethod(_eraseLevel);
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAreaFromTermArea" id="9880c69f-6cf2-4777-bb85-4813f6e7beb9">
        <source>getAreaFromTermArea(_theArea : CM_TerminalArea) : CM_AttributeArea;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin
	return self.attributeAreasByTermAreaId[_theArea.id.trimBlanks];
end;</source>
        <Parameter name="_theArea" type="CM_TerminalArea"/>
        <ReturnType type="CM_AttributeArea"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="27546c88-c8ac-4cca-ae3b-5a9b19f9ab84">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     21 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	pxyAttrPlan		: SelfType;
	realAttrArea,
	pxyAttrArea		: CM_AttributeArea;
	completedOK		: Boolean;
	
begin
	pxyAttrPlan := inheritMethod();
	
	pxyAttrPlan.myMoveMap := self.myMoveMap;
	
	foreach realAttrArea in self.attributeAreas do
		pxyAttrArea := realAttrArea.pxyCreateUpdateProxy();
		pxyAttrPlan.attributeAreaAdd(pxyAttrArea);
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyAttrPlan;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyAttrPlan;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setAttributePlanAreas" id="797a24e9-b126-44ed-83ab-7738b90273ba">
        <updating/>
        <source>setAttributePlanAreas(taId : String input; lcs : CM_LCArray input) updating;
//Given an array of locations controllers, adds them to the list of controllers
//held in the system. Updates dict as well.
vars
	attribArea : CM_AttributeArea;
	lc : CM_LocationsController;
	terminal 	: CM_Terminal;
	termArea : CM_TerminalArea;
begin

	terminal := self.myMoveMap.terminal;
	termArea := terminal.allTerminalAreas[taId];
	if termArea = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(VB_INVALID_TERM_AREA, taId, null, null);
		return;
	endif;
	//----------------
	//Does this TA exist for the Attribute Plan?
	//----------------
	attribArea := self.attributeAreasByTermAreaId[taId];
	if attribArea = null then
		create attribArea;
//rs 31/10/2003 get rid of compile error
//		attribArea.setForUpdate(taId, termArea, lcs);
		//We set here, if they want to set the order then recall this with the lcs in the right order.
		self.attributeAreaAdd(attribArea);
	else
		attribArea.setAttributeLocations(lcs);
	endif;
end;</source>
        <Parameter name="taId" type="String" usage="input"/>
        <Parameter name="lcs" type="CM_LCArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="6a6330af-6a2e-4233-a89e-830d5e4d0733">
        <updating/>
        <source>setForCreate(_theProxyAP : CM_AttributePlan) updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theProxyArea, 
	theRealArea 		: CM_AttributeArea;
	expectedEdition 	: Integer;

begin
	self.id := _theProxyAP.id;
	self.imexStatus := _theProxyAP.imexStatus;

	self.attributeAreasClear();
	
	foreach theProxyArea in _theProxyAP.attributeAreas do
		theProxyArea.pxyGetRealObjectAndEdition(theRealArea, expectedEdition);
		
		if theRealArea = null then	// This should always be the case
			create theRealArea;
			theRealArea.setForCreate(theProxyArea);
		endif;
		self.attributeAreaAdd(theRealArea);
	endforeach;

	self.setForUpdateMovePlan(_theProxyAP.movePlans.first); // as it is a create this proxy will ony have 1 map

end;</source>
        <Parameter name="_theProxyAP" type="CM_AttributePlan"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="6f84d13b-4469-4bae-a8e5-05f96f809e52">
        <updating/>
        <source>setForUpdate(_theProxy : SelfType) updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theProxyArea, 
	theRealArea 	: CM_AttributeArea;
	expectedEdition : Integer;
	toDeleteAreas	: CM_AttributeAreasArray;
	
begin

	create toDeleteAreas transient;

	self.attributeAreas.copy(toDeleteAreas);
	self.attributeAreasClear;
	
	if _theProxy.attributeAreas.size &gt; 0 then
		foreach theProxyArea in _theProxy.attributeAreas do
			theProxyArea.pxyGetRealObjectAndEdition(theRealArea, expectedEdition);
			
			if theRealArea = null then
				create theRealArea;
				theRealArea.setForCreate(theProxyArea);
			else
				theRealArea.setAttributeLocations(theProxyArea.allLocationControllers);
				if toDeleteAreas.includes(theRealArea) then
					toDeleteAreas.remove(theRealArea);
				endif;
			endif;
			self.attributeAreaAdd(theRealArea);
		endforeach;
	endif;

	toDeleteAreas.purge;

	self.id			:= _theProxy.id;
	self.imexStatus := _theProxy.imexStatus;
	self.setForUpdateMovePlan(_theProxy.movePlans.first); // The proxy update will ony have 1 map

epilog
	delete toDeleteAreas;
end;</source>
        <Parameter name="_theProxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateMovePlan" id="d5234549-9809-48c8-aa80-2ec664575d2d">
        <updating/>
        <source>setForUpdateMovePlan(_theMovePlan : CM_MovePlan) updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if not self.movePlans.includes(_theMovePlan) then
		self.movePlans.add(_theMovePlan);
	endif;
	self.myMoveMap := _theMovePlan.moveMap;

end;</source>
        <Parameter name="_theMovePlan" type="CM_MovePlan"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="37c6bede-f76c-4aa3-a9da-176174ade240">
        <updating/>
        <source>setProxy(_commodityGroup : CM_CommodityGroup; 
		_isoTypeGroup : CM_ISOTypeGroup; 
		_myCargoType : CM_CargoType; 
		_imexStatus : Integer; 
		_id : String; 
		_movePlan : CM_MovePlan) updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.id := _id[1:40];
	self.imexStatus := _imexStatus;
	if not self.movePlans.includes(_movePlan) then
		self.movePlans.add(_movePlan);
	endif;
	self.myMoveMap := _movePlan.moveMap;

end;</source>
        <Parameter name="_commodityGroup" type="CM_CommodityGroup"/>
        <Parameter name="_isoTypeGroup" type="CM_ISOTypeGroup"/>
        <Parameter name="_myCargoType" type="CM_CargoType"/>
        <Parameter name="_imexStatus" type="Integer"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_movePlan" type="CM_MovePlan"/>
    </JadeMethod>
    <JadeMethod name="setSortedAreas" id="8e56bea2-3cea-422c-b11a-80c9056f7769">
        <updating/>
        <source>setSortedAreas(sortedAreas : CM_AttributeAreasArray input) updating;
//Method to set the passed in array of attributeAreas that are SORTED
//into the order the users want to search through. We check that each
//object is in the array, and shift it to the desired location.
vars
	attribArea 	: CM_AttributeArea;
begin
/* PAR 6843 AKB2003DEC removed - it always clears out so why check if it is there or not?
	if sortedAreas.size = 0 then
		return;
	endif;
	//----------------
	//Check they are all present
	//----------------
	foreach	attribArea in sortedAreas do
		if (not self.attributeAreas.includes(attribArea)) then
			app.setContinueCMExceptions(false);
			app.raiseCMException2(ERR_ATTR_LABEL_MISSING, id, attribArea.restrictedTermAreaId, null, null);
			return;			
		endif;
	endforeach;
	//----------------
	//Make sure there are NO extras!
	//----------------
	foreach	attribArea in self.attributeAreas do
		if (not sortedAreas.includes(attribArea)) then
			app.setContinueCMExceptions(false);
			app.raiseCMException2(ERR_ATTR_LABEL_MISSING, id, attribArea.restrictedTermAreaId, null, null);
			return;			
		endif;
	endforeach;
	*/
	//----------------
	//Clear the array, and set the ordered areas to it
	//----------------
	self.attributeAreasClear;
	
	foreach attribArea in sortedAreas do
		self.attributeAreaAdd(attribArea);
	endforeach;
end;</source>
        <Parameter name="sortedAreas" type="CM_AttributeAreasArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="396cb6fb-59a1-4777-a691-fd0be8afbb2a">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;

// cnwdvb1 25 June 2003 

vars
	propName	: String;

begin

	propName := _property.name;

	if	propName = CM_AttributePlan::myMoveMap.name then
		return false;
	endif;
	return inheritMethod(_rootClass, _property);

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sortAttributeAreasByFIFO" id="cef399ec-be44-471e-9a6a-fcbebd6003b4">
        <source>sortAttributeAreasByFIFO(otherAreas, sortedAreas  : CM_AttributeAreasArray input) protected;
//The attribute plan stores attribute areas in the order the users require the 
//system to search through. As they may have a requirement for FIFO, this order
//can be made irrelevant by the movements of TI's into and from block stacks.
//We must therefore sort them by the fifo date (if they have told us to do this.)
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars
	area	:	CM_AttributeArea;
	byFIFODate	: CM_BlockStackByFIFODate;
	blockStack	:	CM_BlockStack;
begin
	
	create byFIFODate transient;
	
	otherAreas.clear;
	sortedAreas.clear;
	//------------------
	//Build up the dictionary by date
	//------------------
	foreach area in self.attributeAreas do
		if area.myTerminalArea.isKindOf(CM_BlockStack) then
			blockStack := area.myTerminalArea.CM_BlockStack;
			//--------------
			//Do they want FIFO Processing for this area?
			//--------------
			otherAreas.add(area);
		else
			otherAreas.add(area);
		endif;
	endforeach;
	//---------------------
	//Build the array to pass back
	//---------------------
	foreach blockStack in byFIFODate do
		area := self.attributeAreasByTermAreaId[blockStack.id];
		sortedAreas.add(area);				
	endforeach;
epilog
	//-----------------
	//Cleanup transient dictionary
	//-----------------
	byFIFODate.clear;
	delete byFIFODate;
end;</source>
        <access>protected</access>
        <Parameter name="otherAreas" type="CM_AttributeAreasArray" usage="input"/>
        <Parameter name="sortedAreas" type="CM_AttributeAreasArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="testIncludesTerminalArea" id="8bf99bbc-312e-42dd-b8c7-df905e8479ab">
        <source>testIncludesTerminalArea(_theArea : CM_TerminalArea) : Boolean;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theAttributeArea : CM_AttributeArea;
	iter : Iterator;
begin


	return self.attributeAreasByTermAreaId[_theArea.id.trimBlanks] &lt;&gt; null;


end;</source>
        <Parameter name="_theArea" type="CM_TerminalArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testIncludesTerminalAreaSBs" id="794194a7-45c2-4b8f-97a6-539e0e6ed667">
        <source>testIncludesTerminalAreaSBs(_theArea : CM_TerminalArea) : Boolean;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theAttributeArea : CM_AttributeArea;
	theGridArea : CM_GridArea;
	aSBS : CM_BlockStack;
	iter : Iterator;
begin

	if _theArea.isKindOf(CM_GridArea) then
		theGridArea := _theArea.CM_GridArea;
		
		foreach aSBS in theGridArea.allSubBlockStacks do
			if self.attributeAreasByTermAreaId[aSBS.id.trimBlanks] &lt;&gt; null then
				return true;
			endif;
		endforeach;
	else
		return false;
	endif;

	return false;
end;</source>
        <Parameter name="_theArea" type="CM_TerminalArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
