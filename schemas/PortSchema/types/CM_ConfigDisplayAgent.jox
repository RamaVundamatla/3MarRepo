    <JadeMethod name="addDisplayObject" id="c1de9f74-1784-43c2-91bd-b491f7a636d6">
        <source>addDisplayObject( _optName, _form, _sheet, _row, _value, _constant : String; _isTerm : Boolean) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2014	cnwndl1	Initial creation

*/

vars

	cmif : CMIF_ConfigOptionsDisplay;
	dataString : String;
	etrow : EntTableRow;

begin


	create cmif transient;
	cmif.setValues(	_isTerm,	//_appliesToTerm : Boolean;
					_constant,	//_constantName : String;
					_value,	//_currentValue : String;
					_form,	//_maintFormName : String;
					_optName,	//_optionName : String;
					_row,	//_position : String;
					_sheet	//_sheetName : String
					);
	self.allDisplayLineObjects.add( cmif );

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_optName" type="String"/>
        <Parameter name="_form" type="String"/>
        <Parameter name="_sheet" type="String"/>
        <Parameter name="_row" type="String"/>
        <Parameter name="_value" type="String"/>
        <Parameter name="_constant" type="String"/>
        <Parameter name="_isTerm" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addItem" id="7812b3d9-04b5-46db-a703-f2099c64e576">
        <source>addItem( _element : JadeXMLElement input; _optName, _form, _sheet, _row, _value, _constant : String; _isTerm : Boolean) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2014	cnwndl1	Initial creation

*/

vars

begin

	if _element &lt;&gt; null then
		self.addXMLElement( _element, _optName, _value, _constant );
	else
		self.addDisplayObject( _optName, _form, _sheet, _row, _value, _constant, _isTerm );
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_element" type="JadeXMLElement" usage="input"/>
        <Parameter name="_optName" type="String"/>
        <Parameter name="_form" type="String"/>
        <Parameter name="_sheet" type="String"/>
        <Parameter name="_row" type="String"/>
        <Parameter name="_value" type="String"/>
        <Parameter name="_constant" type="String"/>
        <Parameter name="_isTerm" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addXMLElement" id="aa4beb5a-627c-4ce4-a67d-c618febb6d53">
        <source>addXMLElement( _element : JadeXMLElement input; _optName, _value, _constant : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 August 2014	cnwndl1	Initial creation

*/

vars

	xmlElement : JadeXMLElement;
	dummyConstant : String;

begin

	if _element = null then
		return;
	endif;

	if _constant &lt;&gt; null and _constant.pos(" ",1) &lt; 1 then
	
		if _constant = "InvoiceCurrencySymbol" or _constant = "invoiceCurrencySymbol" then	//15 Nov 2017	NDL	TFS 7472
			dummyConstant := InvoiceCurrencySymbol; // to provide a reference only.
			//The value is a character that may not be UTF-8
			xmlElement := _element.addElement( _constant );
			xmlElement.setText(  _value.Character.Integer.String );
		else
			xmlElement := _element.addElement( _constant );
			xmlElement.setText( _value.asXML );
		endif;
		
	else
		dummyConstant := self.convertValueForXMLTagUse(_optName);
		xmlElement := _element.addElement( dummyConstant );
		xmlElement.setText( _value.asXML );
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_element" type="JadeXMLElement" usage="input"/>
        <Parameter name="_optName" type="String"/>
        <Parameter name="_value" type="String"/>
        <Parameter name="_constant" type="String"/>
    </JadeMethod>
    <JadeMethod name="convertValueForXMLTagUse" id="bcd94030-04c5-4a6b-a826-38e7a3665c78">
        <source>convertValueForXMLTagUse( _rawString : String ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2014	cnwndl1	Initial creation

*/

vars

	processedString : String;

begin

	processedString := _rawString;
	processedString := processedString.replaceString(" ","");
	processedString := processedString.replaceString("-","");
	processedString := processedString.replaceString("/","");
	processedString := processedString.replaceString("(","");
	processedString := processedString.replaceString(")","");
	
	return processedString;

epilog

end;</source>
        <Parameter name="_rawString" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="delete" id="27bc544e-7cac-4ed8-b935-c933a50e7e78">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2014	cnwndl1	Initial creation

*/

vars

begin

	if self.xmlDoc &lt;&gt; null then
		delete self.xmlDoc;
	endif;
	
	if self.allDisplayLineObjects &lt;&gt; null then
		self.allDisplayLineObjects.purge();
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAutoIdConfiguration" id="b6f7de6a-87c4-4d15-9fc6-c7ac5a042c5d">
        <source>getAutoIdConfiguration( _terminal : CM_Terminal; _termElement : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2014	cnwndl1	Initial creation

*/

vars

	tabName : String;
	position : String;
	category : ConstantCategory;
	const : Constant;
	value : String;
	autoIdGen : CM_AutoIdGenerator;
	appScm : Schema;

begin

	appScm := rootSchema.getSchema(PortSchemaName);
	category := appScm.getCategory("AutoIdStyle");


	tabName := "Main";
	position := null;
	
	autoIdGen := _terminal.getMyAutoIdGenerator( CM_AutoCargoIdGen );
	value := null;
	if autoIdGen &lt;&gt; null then
		foreach const in category.getConstants do
			if autoIdGen.idStyle = const.GlobalConstant.valueAsInteger then
				value := const.GlobalConstant.text;
				break;
			endif;
		endforeach;
		if autoIdGen.idPrefix &lt;&gt; null then
			value := value &amp; ", " &amp; autoIdGen.idPrefix;
		endif;
		value := value &amp; ", " &amp; autoIdGen.idSeqNumLength.String;
	endif;
	self.addItem(_termElement, app.getErrorString(CargoId), self.AutoId_Config, tabName, position, value, CM_AutoCargoIdGen.name, true);
	
	autoIdGen := _terminal.getMyAutoIdGenerator( CM_AutoBookingIdGen );
	value := null;
	if autoIdGen &lt;&gt; null then
		foreach const in category.getConstants do
			if autoIdGen.idStyle = const.GlobalConstant.valueAsInteger then
				value := const.GlobalConstant.text;
				break;
			endif;
		endforeach;
		if autoIdGen.idPrefix &lt;&gt; null then
			value := value &amp; ", " &amp; autoIdGen.idPrefix;
		endif;
		value := value &amp; ", " &amp; autoIdGen.idSeqNumLength.String;
	endif;
	self.addItem(_termElement, app.getErrorString(BookingId), self.AutoId_Config, tabName, position, value, CM_AutoBookingIdGen.name, true);
	
	autoIdGen := _terminal.getMyAutoIdGenerator( CM_AutoReleaseIdGen );
	value := null;
	if autoIdGen &lt;&gt; null then
		foreach const in category.getConstants do
			if autoIdGen.idStyle = const.GlobalConstant.valueAsInteger then
				value := const.GlobalConstant.text;
				break;
			endif;
		endforeach;
		if autoIdGen.idPrefix &lt;&gt; null then
			value := value &amp; ", " &amp; autoIdGen.idPrefix;
		endif;
		value := value &amp; ", " &amp; autoIdGen.idSeqNumLength.String;
	endif;
	self.addItem(_termElement, app.getErrorString(ReleaseId), self.AutoId_Config, tabName, position, value, CM_AutoReleaseIdGen.name, true);
	
	if app.isVehicleBookingEnabled then
		autoIdGen := _terminal.getMyAutoIdGenerator( CM_AutoVehicleBookingIdGen );
		value := null;
		if autoIdGen &lt;&gt; null then
			foreach const in category.getConstants do
				if autoIdGen.idStyle = const.GlobalConstant.valueAsInteger then
					value := const.GlobalConstant.text;
					break;
				endif;
			endforeach;
			if autoIdGen.idPrefix &lt;&gt; null then
				value := value &amp; ", " &amp; autoIdGen.idPrefix;
			endif;
			value := value &amp; ", " &amp; autoIdGen.idSeqNumLength.String;
		endif;
		self.addItem(_termElement, app.getErrorString(VehicleBookingId), self.AutoId_Config, tabName, position, value, CM_AutoVehicleBookingIdGen.name, true);
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_termElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCashConfigOptions" id="efa779d7-7938-4500-9b36-02570dcab828">
        <source>getCashConfigOptions( _terminal : CM_Terminal; _termElement : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2014	cnwndl1	Initial creation

*/

vars

	schema : Schema;
	form : Form;
	formClass : Class;
	entDef : EntTableDef;
	entRow : EntTableRow;
	tabName : String;
	category : ConstantCategory;
	constant : Constant;
	constantName : String;
	index : Integer;
	int : Integer;
	value : String;
	sourceValue : String;

begin

	if not app.isCashOnlyEnabled then
		return;
	endif;

	category := self.myPortSchema.getCategory(ConfigConstants);
	schema := rootSchema.getSchema("InvoiceSchema");
	formClass := schema.getClass("INV_CashModuleConfigForm");

	create form as formClass transient;
	form.sendMsg("translateForm");
	
	tabName := self.getControlCaption( form, "shtCashConfigOpt");

	//INV_CashModuleConfigForm   Invoice_Config
	entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_TermCashOps];
	
	if entDef &lt;&gt; null then
	
		int := 0;
		foreach entRow in entDef.allEntTableRows do
			int := int + 1;
			constantName := null;
			value := null;
			
			//ETRow names don't match constant value...
	// 30 May 2018	NDL	TFS 38952		
	//		if entRow.name = ETRow_CashProcUnderpayIsError then
	//			constantName := CashProcUnderpayIsError;	
	//			value := self.getTermValueForDisplay(_terminal,CashProcUnderpayIsError,null);
	//		else
			if entRow.name = ETRow_CashCollectOverpay then
				constantName := CashCollectAllowOverPay;	
				value := self.getTermValueForDisplay(_terminal,CashCollectAllowOverPay,null);
			elseif entRow.name = ETRow_CashReceiptReport then
				constantName := "GateCashReceiptReport";  // has lower case first character in declaration
				value := self.getTermValueForDisplay(_terminal,GateCashReceiptReport,null);
			elseif entRow.name = ETRow_CashInvReceiptReport then
				constantName := "GateCashInvReceiptReport";	// has lower case first character in declaration
				value := self.getTermValueForDisplay(_terminal,GateCashInvReceiptReport,null);
			/*21 Mar 2018	- TFS 37550 Now stored on CM_CurrencyRate objects
			elseif entRow.name = ETRow_CashSecondPayConvert then
				constantName := CashSecondPayConvertRate;	
				value := self.getTermValueForDisplay(_terminal,CashSecondPayConvertRate,null); */
			elseif entRow.name = ETRow_CashCollectUnderpay then
				constantName := CashCollectAllowUnderpay;	
				value := self.getTermValueForDisplay(_terminal,CashCollectAllowUnderpay,null);
			/*21 Mar 2018	- TFS 37550 Now stored on CM_CurrencyRate objects
			elseif entRow.name = ETRow_CashSecPayDivConvert then
				constantName := CashSecPayDivConvertRate;	
				value := self.getTermValueForDisplay(_terminal,CashSecPayDivConvertRate,null); */
			elseif entRow.name = ETRow_InvoiceEveryCashReceipt then
				constantName := CashInvoiceEveryReceipt;
				value := self.getTermValueForDisplay(_terminal,CashInvoiceEveryReceipt,null);
			/* TFS 45953
			elseif entRow.name = ETRow_NoDuplicatesActualEst then
				constantName := CashNoDuplicatesActualEst;	
				value := self.getTermValueForDisplay(_terminal,CashNoDuplicatesActualEst,null);
			elseif entRow.name = ETRow_ShowCargoItemsWithParent then
				constantName := CashShowCargoItemsWithParent;	
				value := self.getTermValueForDisplay(_terminal,CashShowCargoItemsWithParent,null);
			elseif entRow.name = ETRow_ShowParentAndChildItems then
				constantName := CashShowParentAndChildItems;	
				value := self.getTermValueForDisplay(_terminal,CashShowParentAndChildItems,null);
			elseif entRow.name = ETRow_ShowInvoiceLineType then
				constantName := CashShowInvoiceLineType;	
				value := self.getTermValueForDisplay(_terminal,CashShowInvoiceLineType,null);
				*/
			elseif entRow.name = ETRow_AllCashTax then
				constantName := CashAllCashTax;	
				value := self.getTermValueForDisplay(_terminal,CashAllCashTax,null);
			//  
			else
				foreach constant in category.getConstants do
					if constant.name.toUpper = entRow.name.toUpper then
						constantName := constant.name;
						sourceValue := constant.getSource.replaceString("'"," ");
						sourceValue := sourceValue.replaceString('"'," ");
						sourceValue := sourceValue.trimBlanks;
						value := self.getTermValueForDisplay(_terminal,sourceValue,null).String;
						break;
					endif;
				endforeach;
			endif;
			
			self.addItem( _termElement, entRow.getRawHeadingValue, self.Cash_Config, tabName, "row " &amp; int.String, value, constantName, true);
			
		endforeach;
	endif;
	
epilog

	delete form;

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_termElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getControlCaption" id="855a7add-d6e2-4934-961e-c9fcfeae0028">
        <source>getControlCaption( _form : Form; _controlName : String ):String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2014	cnwndl1	Initial creation

*/

vars

	index : Integer;
	control : Control;
	caption : String;

begin

	if _form = null then
		return "*** Form not found [" &amp; _controlName &amp; "]***";
	endif;
	
	control := _form.getPropertyValue(_controlName).Control;
	if control &lt;&gt; null then
		if control.isKindOf(Sheet) then
			return control.Sheet.caption;
		elseif control.isKindOf(CheckBox) then
			return control.CheckBox.caption;
		elseif control.isKindOf(Label) then
			return control.Label.caption;
		elseif control.isKindOf(GroupBox) then
			return control.GroupBox.caption;
		else
			return "*** Unhandled control type *** " &amp; control.String;
		endif;
	endif;
	
	return "*** Control not found on form [" &amp; _controlName &amp; "]***";

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_form" type="Form"/>
        <Parameter name="_controlName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGateConfiguration" id="d8406b5d-5660-4ca0-bfd9-2161b7fbd5fc">
        <source>getGateConfiguration( _terminal : CM_Terminal; _termElement : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Aug 2014	cnwndl1	Initial creation
10 Oct 2022 navma1	ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
08 Nov 2023	navlw1	Bug 60951: EUP | 53824 - Transport Manifest - VBS Slot Not Always Being Created
20 Mar 2025 navlc30 JIRA 34268 - Create a new setting that is to be enabled for this new functionality
*/

constants
	Grp : String = " (Group)";
vars

	tabName 	 : String;
	form 		 : Form;
	schema 		 : Schema;
	formClass  	 : Class;
	position 	 : String;
	entDef 		 : EntTableDef;
	entRow 		 : EntTableRow;
	category 	 : ConstantCategory;
	constant 	 : Constant;
	constantName : String;
	int			 : Integer;
	value		 : String;
	sourceValue  : String;
	imexDef 	 : Integer; 

begin

	schema 		:= rootSchema.getSchema("SysOpsSchema");
	formClass 	:= schema.getClass("SOP_GateConfigForm");
	
	create form as formClass transient;
	form.sendMsg("translateForm");
	
	//Gate tab.
	tabName  := self.getControlCaption( form, "shtGate");
	position := self.getControlCaption( form, "grpReceive") &amp; Grp;

	self.addItem(_termElement, self.getControlCaption( form, "chkRecISO"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,GateInCheckISOTypes,null), GateInCheckISOTypes, true);
	self.addItem(_termElement, self.getControlCaption( form, "lblBookingReq"), self.Gate_Config, tabName, position, app.bookingRequiredEnumToString(self.getTermValueForDisplay(_terminal,BookingRefRequired,null).Integer), BookingRefRequired, true);
	//26 May 2017	NDL	TFS 4452
	imexDef := self.getTermValueForDisplay(_terminal,DefRecTrailIMEX,null).Integer;
	if imexDef = 0 then
		imexDef := TI_IMEX_STATUS_STORAGE;
	endif;
	self.addItem(_termElement, self.getControlCaption( form, "lblTrailDefIMEX"), self.Gate_Config, tabName, position, app.getIMEXStringFromIMEXStatus(imexDef), DefRecTrailIMEX, true);
	self.addItem(_termElement, self.getControlCaption( form, "lblTrailDefOper"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,DefRecTrailOper,null), DefRecTrailOper, true);	//22 Oct 2020	NDL	TFS 50113
	
	
	position := self.getControlCaption( form, "grpMT") &amp; Grp;
	self.addItem(_termElement, self.getControlCaption( form, "chkRecHazard"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,GateInOutHazardousWarning,null), GateInOutHazardousWarning, true);
	self.addItem(_termElement, self.getControlCaption( form, "chkRecBR"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,DoNotCreateBulkRelease,null), DoNotCreateBulkRelease, true);
	self.addItem(_termElement, self.getControlCaption( form, "chkConsignee"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,GateOutConsigneeReqd,null), GateOutConsigneeReqd, true);	// PAR #30344
	
	position := self.getControlCaption( form, "grpMisc") &amp; Grp;
	self.addItem(_termElement, self.getControlCaption( form, "chkOtherTwin"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,TwinLiftFromGate,null), TwinLiftFromGate, true);
	self.addItem(_termElement, self.getControlCaption( form, "chkTrailerDet"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,TrailerDetailsVisible,null), TrailerDetailsVisible, true);
	self.addItem(_termElement, self.getControlCaption( form, "lblOtherMinutes"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,GateElapsedTimeExceeded,null), GateElapsedTimeExceeded, true);
	self.addItem(_termElement, self.getControlCaption( form, "chkShowState"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,ShowVehicleState,null), ShowVehicleState, true);
	self.addItem(_termElement, self.getControlCaption( form, "chkSecurityGate"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,SiteHasSecurityGate,null), SiteHasSecurityGate, true);		// PAR #32849
	
	position := self.getControlCaption( form, "grpGateChecker") &amp; Grp;
	self.addItem(_termElement, self.getControlCaption( form, "chkEnterId"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,GateCheckRequiresCargoId,null), GateCheckRequiresCargoId, true);
	self.addItem(_termElement, self.getControlCaption( form, "chkAllowIso"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,GateCheckAllowsIsoChg,null), GateCheckAllowsIsoChg, true);
	
	//Application tab.
	tabName := self.getControlCaption( form, "shtApplication");
	
	position := self.getControlCaption( form, "grpRoadEntry") &amp; Grp;
	self.addItem(_termElement, self.getControlCaption( form, "lblDefGateEntry"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,GateDefaultEntry,null), GateDefaultEntry, true);
	self.addItem(_termElement, self.getControlCaption( form, "chkEntryHideBAT"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,GateInOutHideBatNumber,null), GateInOutHideBatNumber, true);
	self.addItem(_termElement, self.getControlCaption( form, "chkEntryTare"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,GateInVehicleTareWeight,null), GateInVehicleTareWeight, true);
	self.addItem(_termElement, self.getControlCaption( form, "chkEntryWeigh"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,WeighBridgeEnabled,null), WeighBridgeEnabled, true);
	self.addItem(_termElement, self.getControlCaption( form, "chkEntryHideName"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,HideRGateDriverCodeName,null), HideRGateDriverCodeName, true);
	self.addItem(_termElement, self.getControlCaption( form, "chkEntryGateRec"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,GateReceiptRequired,null), GateReceiptRequired, true);
	self.addItem(_termElement, self.getControlCaption( form, "chkYardTransitIN"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,GateTransitIntoYard,null), GateTransitIntoYard, true);
	
	position := self.getControlCaption( form, "grpRoadExit") &amp; Grp;
	self.addItem(_termElement, self.getControlCaption( form, "lblDefGateEntr_1"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,GateDefaultExit,null), GateDefaultExit, true);
	self.addItem(_termElement, self.getControlCaption( form, "lblExitSort"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,GateExitDefaultSortCol,null), GateExitDefaultSortCol, true);
	
	position := self.getControlCaption( form, "grpAuto") &amp; Grp;
	self.addItem(_termElement, self.getControlCaption( form, "chkAutoComplete"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,GateInAllowAutoComplete,null), GateInAllowAutoComplete , true);
	self.addItem(_termElement, self.getControlCaption( form, "chkAutoCompDef"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,GateInAutoComplete,null), GateInAutoComplete, true);
	self.addItem(_termElement, self.getControlCaption( form, "chkEntryAutoComp"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,GateIOHideAutoComplete,null), GateIOHideAutoComplete, true);
	self.addItem(_termElement, self.getControlCaption( form, "chkAutoBOL"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,GateInAutoBOLNumber,null), GateInAutoBOLNumber, true);
	
	position := self.getControlCaption( form, "grpVehicleVisit") &amp; Grp;
	self.addItem(_termElement, self.getControlCaption( form, "chkAutoVisitNo"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,GateInAutoVisitNo,null), GateInAutoVisitNo, true);
	self.addItem(_termElement, self.getControlCaption( form, "lblRoadProcess"), self.Gate_Config, tabName, position, _terminal.myRoadProcess.description, "CM_Terminal.myRoadProcess", true);	//22 Oct 2020	NDL	TFS 50113
	
	//Printing tab.
	tabName := self.getControlCaption( form, "shtPrint");
	
	position := self.getControlCaption( form, "grpPrinting");
	self.addItem(_termElement, self.getControlCaption( form, "lblPrintCarter"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,GateCarterNoteReport,null), GateCarterNoteReport, true);
	self.addItem(_termElement, self.getControlCaption( form, "lblDriverInstr"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,GateDriverInstructionsReport,null), GateDriverInstructionsReport, true);
	self.addItem(_termElement, self.getControlCaption( form, "lblPrintRRR"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,GateRoadJobReceipt,null), GateRoadJobReceipt, true);
	self.addItem(_termElement, self.getControlCaption( form, "lblReprintDI"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,GateReprintDriverIns,null), GateReprintDriverIns, true);
	self.addItem(_termElement, self.getControlCaption( form, "lblInterChg"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,GateInterchangeReport,null), GateInterchangeReport, true);	//14 Jan 2019	NDL	TFS 40479
	
	position := self.getControlCaption( form, "grpPrintOther") &amp; Grp;
	self.addItem(_termElement, self.getControlCaption( form, "lblPrintCopies"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,GateReceiptCopies,null), GateReceiptCopies, true);
	self.addItem(_termElement, self.getControlCaption( form, "chkPrintBuckslip"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,PrintBuckslip,null), PrintBuckslip, true);
	self.addItem(_termElement, self.getControlCaption( form, "chkPrintConfirm"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,DisplayPrintConfirmation,null), DisplayPrintConfirmation, true);
	self.addItem(_termElement, self.getControlCaption( form, "chkPrintPreview"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,PrintPreview,null), PrintPreview, true);
	self.addItem(_termElement, self.getControlCaption( form, "chkPrintInterchg"), self.Gate_Config, tabName, position, self.getTermValueForDisplay(_terminal,PrintInterchange,null), PrintInterchange, true);	//14 Jan 2019	NDL	TFS 40479
	
	//14 May 2015	NDL	Par 36234
	category := self.myPortSchema.getCategory(ConfigConstants);
	tabName := self.getControlCaption( form, "shtVBS");
	entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_VBSConfig];
	if entDef &lt;&gt; null then
		int := 0;
		foreach entRow in entDef.allEntTableRows do
			int := int + 1;
			value := null;
			foreach constant in category.getConstants do
				if constant.name.toUpper = entRow.name.toUpper then
					constantName := constant.name;
					sourceValue  := constant.getSource.replaceString("'"," ");
					sourceValue  := sourceValue.replaceString('"'," ");
					sourceValue  := sourceValue.trimBlanks;
					value 	 	 := self.getTermValueForDisplay(_terminal,sourceValue,null).String;
					break;
				endif;
			endforeach;
			
			if constantName = VsTruckDriverMand  and entRow.name = ETRow_VsTruckDriverMand
			or constantName = VsOntimeGracePeriod  and entRow.name = ETRow_VsOntimeGracePeriod
			or constantName = VsGenerateDaysInAdvance  and entRow.name = ETRow_VsGenerateDaysInAdvance
			or constantName = VsPurgeSlotsOlderThan  and entRow.name = ETRow_VsPurgeSlotsOlderThan
			or constantName = VsBookMinAdvanceHrs  and entRow.name = ETRow_VsBookMinAdvanceHrs
			or constantName = VsBookMinAdvancePu  and entRow.name = ETRow_VsBookMinAdvancePu
			or constantName = VsBookingRule  and entRow.name = ETRow_VsBookingRule
			or constantName = VsDefaultProcess and entRow.name = ETRow_VbsProcess							//05.10.2022 navma1 #53697
			or constantName = AllowVBSInPast and entRow.name = ETRow_AllowVBSInPast 						// #60951
			or constantName = VsEnhancedStdVBS and entRow.name = ETRow_VsEnhancedStdVBS						//20.03.2025 navlc30 #34268
			then
				if not app.isVehicleBookingEnabled then
					continue;
				endif;
				value := self.getTermValueForDisplay(_terminal,constantName,null).String;
			endif;
			
			self.addItem( _termElement, entRow.getRawHeadingValue, self.Gate_Config, tabName, "row " &amp; int.String, value, constantName, true);
		
		endforeach;
	endif;
epilog

	delete form;

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_termElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getHandHeldConfig" id="1f4dcab7-5506-402a-98aa-e75b50866ff4">
        <source>getHandHeldConfig( _terminal : CM_Terminal; _termElement : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 October 2016	cnwndl1	Initial creation	TFS 2850 / 2370

*/

vars

	schema : Schema;
	form : Form;
	formClass : Class;
	entDef : EntTableDef;
	entRow : EntTableRow;
	tabName : String;
	category : ConstantCategory;
	constant : Constant;
	constantName : String;
	index : Integer;
	int : Integer;
	value : String;
	sourceValue : String;
	hhLanderGroundingOpt : Integer;
	dischargeHHLanderOpt : Integer;
	hhTruckLoadScan : Integer;	//16 Dec 2016	NDL	TFS 3129

begin

	category := self.myPortSchema.getCategory(ConfigConstants);
	schema := rootSchema.getSchema("UiCommonSchema");
	formClass := schema.getClass("CMUI_HandHeldConfigForm");
	
	create form as formClass transient;
	form.sendMsg("translateForm");
	
	tabName := self.getControlCaption( form, "shtSettings");
	
	entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_TermHHConfig];
	
	if entDef &lt;&gt; null then
	
		int := 0;
		foreach entRow in entDef.allEntTableRows do
			int := int + 1;
			constantName := null;
			value := null;
			
			//skip the headings
			if entRow.name.toUpper[1:11] = "ZTABLEBREAK" then
				continue;
			endif;
			
			//ETRow names don't match constant value...
			if entRow.name = ETRow_DischargeHHLanderOption then
				constantName := DischargeHHLanderOption;	
				dischargeHHLanderOpt := self.getTermValueForDisplay(_terminal,DischargeHHLanderOption,null).Integer;
				if dischargeHHLanderOpt = DiscHHLander_ToMach then
					value := app.getErrorString(To_Machine);
				elseif dischargeHHLanderOpt = DiscHHLander_ToGround then
					value := app.getErrorString(To_Ground);
				elseif dischargeHHLanderOpt = DiscHHLander_Both then
					value := app.getErrorString(Both);
				endif;
			elseif entRow.name = ETRow_HhLanderGroundingOpt then
				constantName := HhLanderGroundingOpt;	
				hhLanderGroundingOpt := self.getTermValueForDisplay(_terminal,HhLanderGroundingOpt,null).Integer;
				value := app.hhGroundingEnumToString(hhLanderGroundingOpt);
			elseif entRow.name = ETRow_HhTruckLoadScan then
				constantName := HhTruckLoadScan;	
				hhTruckLoadScan := self.getTermValueForDisplay(_terminal,HhTruckLoadScan,null).Integer;
				value := app.hhScanningEnumToString(hhTruckLoadScan);
			elseif entRow.name = ETRow_IgnoreFindCargoConsignee then	//16 Nov 2017	NDL	TFS 7472 - non std constant value used.
				constantName := IgnoreHHFindCargoConsignee;
				value := self.getTermValueForDisplay(_terminal,constantName,null).String;
			else
				foreach constant in category.getConstants do
					if constant.name.toUpper = entRow.name.toUpper then
						constantName := constant.name;
						sourceValue := constant.getSource.replaceString("'"," ");
						sourceValue := sourceValue.replaceString('"'," ");
						sourceValue := sourceValue.trimBlanks;
						value := self.getTermValueForDisplay(_terminal,sourceValue,null).String;
						break;
					endif;
				endforeach;
			endif;
			
			self.addItem( _termElement, entRow.getRawHeadingValue, self.HandHeld_Config, tabName, "row " &amp; int.String, value, constantName, true);
			
		endforeach;
		
	endif;
	
epilog

	delete form;


end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_termElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceSystemDefaults" id="d4ae0da2-7f17-4a82-98f0-a19511050eb7">
        <source>getInvoiceSystemDefaults( _terminal : CM_Terminal; _termElement : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2014	cnwndl1	Initial creation

*/

vars

	schema : Schema;
	form : Form;
	formClass : Class;
	entDef : EntTableDef;
	entRow : EntTableRow;
	tabName : String;
	category : ConstantCategory;
	constant : Constant;
	constantName : String;
	index : Integer;
	int : Integer;
	value : String;
	ioClass : CM_ExtFinanceIO;
	sourceValue : String;
	bank : CM_Bank;
	keyseries :  CM_KeySeries;
	serieskey :  CM_SeriesKey;
	nextInvNum : Integer;

begin

	category := self.myPortSchema.getCategory(ConfigConstants);
	schema := rootSchema.getSchema("InvoiceSchema");
	formClass := schema.getClass("INV_InvoiceSystemDefaults");

	create form as formClass transient;
	form.sendMsg("translateForm");
	
	tabName := null;

	//INV_InvoiceSystemDefaults   Invoice_Config
	entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_TerminalFinancial];
	
	if _terminal &lt;&gt; null then
		ioClass := _terminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	endif;
	
	if entDef &lt;&gt; null then
	
		int := 0;
		foreach entRow in entDef.allEntTableRows do
			int := int + 1;
			constantName := null;
			value := null;
			
			//skip the headings
			if entRow.name.toUpper[1:11] = "ZTABLEBREAK" then
				continue;
			endif;
			
			if entRow.name = ETRow_FirstMonthFinancialYear then
				constantName := "CM_ExtFinanceIO.firstMonthOfFinYear";
				if ioClass &lt;&gt; null then
					value := ioClass.firstMonthOfFinYear.String;
				endif;
			elseif entRow.name = ETRow_ExternalExportPath then
				constantName := "CM_ExtFinanceIO.exportPath";
				if ioClass &lt;&gt; null then
					value := ioClass.exportPath.String;
				endif;
			elseif entRow.name = ETRow_CurrentGLPeriod then
				constantName := "CM_ExtFinanceIO.glPeriod";
				if ioClass &lt;&gt; null then
					value := ioClass.glPeriod.String;
				endif;
			elseif entRow.name = ETRow_CurrentGLYear then
				constantName := "CM_ExtFinanceIO.glYear";
				if ioClass &lt;&gt; null then
					value := ioClass.glYear.String;
				endif;
			elseif entRow.name = ETRow_ExternalFinancialName then
				constantName := "CM_ExtFinanceIO.name";
				if ioClass &lt;&gt; null then
					value := ioClass.name; // PAR 33572
				endif;
			elseif entRow.name = ETRow_ExternalFinSysRemarks then
				constantName := "CM_ExtFinanceIO.remarks";
				if ioClass &lt;&gt; null then
					value := ioClass.remarks.String;
				endif;
			elseif entRow.name = ETRow_AllowInvPostUnqualAudits then
				constantName := InvPostWithoutAuditQual;
				value := self.getTermValueForDisplay( _terminal, constantName, null ).String;
			elseif entRow.name = ETRow_FinancialsCalendar then
				constantName := "CM_Terminal.myCalendar";
				if _terminal.myCalendar &lt;&gt; null then
					value := _terminal.myCalendar.code;
				endif;
			elseif entRow.name = ETRow_DefaultBusinessUnitCargo then
				constantName := DefCompany;
				value := self.getTermValueForDisplay( _terminal, constantName, null ).String;
			elseif entRow.name = ETRow_DefaultDebtor then
				constantName := DefDebtor;
				value := self.getTermValueForDisplay( _terminal, constantName, null ).String;
			elseif entRow.name = ETRow_NextInvoiceNumber then
				constantName := "CM_SeriesKey.root";
				bank := _terminal.getConfig( DefCompany ).CM_Bank;
				if bank &lt;&gt; null then
					keyseries := bank.keySeries[SN_INVOICE];
					if keyseries &lt;&gt; null then
						serieskey := keyseries.nextKey;
						if serieskey &lt;&gt; null then
							nextInvNum := serieskey.root;
							if nextInvNum &lt;&gt; 0 then
								value := nextInvNum.String;
							endif;
						endif;
					endif;	
				endif;
			elseif entRow.name = ETRow_FinancialIOClass then
				constantName := FinancialIOClass;
				value := self.getTermValueForDisplay( _terminal, constantName, null ).String;
			elseif entRow.name = ETRow_InvReeferTempReadings then
				constantName := ChargeFirstTemperatureOnly;
				if _terminal.getConfig(ChargeFirstTemperatureOnly).Boolean then
					value := app.getErrorString(Charge_only_first_temper_readi);
				else
					value := app.getErrorString(Charge_temperatur_readings);
				endif;
			elseif entRow.name = ETRow_InvoiceCurrencySymbol then	//16 Nov 2017	NDL	TFS 7472
				constantName := InvoiceCurrencySymbol;
				value := self.getTermValueForDisplay( _terminal, constantName, null ).String;
				if value = null then
					value := app.myRoot.getInvoiceCurrencySymbol().Character;
				endif;
			else
			
				foreach constant in category.getConstants do
					if constant.name.toUpper = entRow.name.toUpper then
						constantName := constant.name;
						sourceValue := constant.getSource.replaceString("'"," ");
						sourceValue := sourceValue.replaceString('"'," ");
						sourceValue := sourceValue.trimBlanks;
						value := self.getTermValueForDisplay( _terminal, sourceValue, null ).String;
						break;
					endif;
				endforeach;		
			
			endif;
			
			self.addItem( _termElement, entRow.getRawHeadingValue, self.Invoice_Config, tabName, "row " &amp; int.String, value, constantName, true);
			
		endforeach;
	endif;
	
	if app.isCashOnlyEnabled then
		self.getCashConfigOptions( _terminal, _termElement );
	endif;
	
epilog

	delete form;

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_termElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getRailConfiguration" id="c9121df6-8d79-4457-a894-e3f886978111">
        <source>getRailConfiguration( _terminal : CM_Terminal; _termElement : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2014	cnwndl1	Initial creation
25 July	 2022	jlika1	TFS 54050 - EUP- Max Wagon Payload
*/

constants

	Grp : String = " (Group)";

vars

	tabName : String;
	schema : Schema;
	form : Form;
	formClass : Class;
	position : String;

begin

	schema := rootSchema.getSchema("YardSchema");
	formClass := schema.getClass("YRD_RailConfiguration");
	//YRD_RailConfiguration

	position := null;
	
	create form as formClass transient;
	form.sendMsg("translateForm");
	
	//Hand helds tab.
	tabName := self.getControlCaption( form, "shtHandHelds");
	
	self.addItem( _termElement, self.getControlCaption( form,"chkHHContPrenote"), self.Rail_Config, tabName, position, self.getTermValueForDisplay(_terminal,RailHHCargoMustPrenote,null), RailHHCargoMustPrenote, true);
	self.addItem( _termElement, self.getControlCaption( form,"chkHHWarnHaz"), self.Rail_Config, tabName, position, self.getTermValueForDisplay(_terminal,RailHHWarnPrenoteHazDiffer,null), RailHHWarnPrenoteHazDiffer, true);
	self.addItem( _termElement, self.getControlCaption( form,"chkHHContIdFull"), self.Rail_Config, tabName, position, self.getTermValueForDisplay(_terminal,RailHHAlwaysCargoFullID,null), RailHHAlwaysCargoFullID, true);
	self.addItem( _termElement, self.getControlCaption( form,"chkHHWagIdFull"), self.Rail_Config, tabName, position, self.getTermValueForDisplay(_terminal,RailHHAlwaysWagonFullID,null), RailHHAlwaysWagonFullID, true);
	self.addItem( _termElement, self.getControlCaption( form,"chkHHWagIdRev"), self.Rail_Config, tabName, position, self.getTermValueForDisplay(_terminal,RailHHWagonUseReversedID,null), RailHHWagonUseReversedID, true);
	
	//Hand helds tab.
	tabName := self.getControlCaption( form, "shtConfig");
	self.addItem( _termElement, self.getControlCaption( form,"lblTrainManIN"), self.Rail_Config, tabName, position, self.getTermValueForDisplay(_terminal,TrainManifestReportIn,null), TrainManifestReportIn, true);
	self.addItem( _termElement, self.getControlCaption( form,"lblTrainManOUT"), self.Rail_Config, tabName, position, self.getTermValueForDisplay(_terminal,TrainManifestReportOut,null), TrainManifestReportOut, true);
	self.addItem( _termElement, self.getControlCaption( form,"lblAutoNumPrefix"), self.Rail_Config, tabName, position, self.getTermValueForDisplay(_terminal,TrainAutoNumberPrefix,null), TrainAutoNumberPrefix, true);
	self.addItem( _termElement, self.getControlCaption( form,"lblRailPost"), self.Rail_Config, tabName, position, self.getTermValueForDisplay(_terminal,RailPostDepartVisHrs,null), RailPostDepartVisHrs, true);
	self.addItem( _termElement, self.getControlCaption( form,"chkAutoTrainNum"), self.Rail_Config, tabName, position, self.getTermValueForDisplay(_terminal,TrainAutoNumber,null), TrainAutoNumber, true);
	self.addItem( _termElement, self.getControlCaption( form,"chkOutwardRailCo"), self.Rail_Config, tabName, position, self.getTermValueForDisplay(_terminal,UseOutwardRailConfirm,null), UseOutwardRailConfirm, true);
	self.addItem( _termElement, self.getControlCaption( form,"chknoTLonWagons"), self.Rail_Config, tabName, position, self.getTermValueForDisplay(_terminal,RailNoTwinLiftMoves,null), RailNoTwinLiftMoves, true);
	self.addItem( _termElement, self.getControlCaption( form,"lRailArea"), self.Rail_Config, tabName, position, self.getTermValueForDisplay(_terminal,DefRailOpsArea,null), DefRailOpsArea, true);
	self.addItem( _termElement, self.getControlCaption( form,"lRailCarrier"), self.Rail_Config, tabName, position, self.getTermValueForDisplay(_terminal,DefRailCarrier,null), DefRailCarrier, true);
	self.addItem( _termElement, self.getControlCaption( form,"lWagonClass"), self.Rail_Config, tabName, position, self.getTermValueForDisplay(_terminal,DefWagonClass,null), DefWagonClass, true);
	self.addItem( _termElement, self.getControlCaption( form,"chkRunEDI"), self.Rail_Config, tabName, position, self.getTermValueForDisplay(_terminal,CustomsEDIonTrain,null), CustomsEDIonTrain, true);
	self.addItem( _termElement, self.getControlCaption( form,"lblRailToDoTask"), self.Rail_Config, tabName, position, self.getTermValueForDisplay(_terminal,RailHHToDoTask,null), RailHHToDoTask, true);
	self.addItem( _termElement, self.getControlCaption( form,"chkRelReqRail"), self.Rail_Config, tabName, position, self.getTermValueForDisplay(_terminal,ShowRelReqOnRailLoadList,null), ShowRelReqOnRailLoadList, true);
	self.addItem( _termElement, self.getControlCaption( form,"chkOutQing"), self.Rail_Config, tabName, position, self.getTermValueForDisplay(_terminal,RailDisallowOutwardQueue,null), RailDisallowOutwardQueue, true);
	self.addItem( _termElement, self.getControlCaption( form,"chkTrkError"), self.Rail_Config, tabName, position, self.getTermValueForDisplay(_terminal,RailTrackClearErr,null), RailTrackClearErr, true);
	self.addItem( _termElement, self.getControlCaption( form,"chkAutoSwitch"), self.Rail_Config, tabName, position, self.getTermValueForDisplay(_terminal,RailAutoSwitch,null), RailAutoSwitch, true);
	self.addItem( _termElement, self.getControlCaption( form,"chkAllowWagonWeightsToBeUpd"), self.Rail_Config, tabName, position, self.getTermValueForDisplay(_terminal,AllowWagonWeightsToBeUpd,null), AllowWagonWeightsToBeUpd, true);
	self.addItem( _termElement, self.getControlCaption( form,"chkRaiseErrorMaxLoadWeight"), self.Rail_Config, tabName, position, self.getTermValueForDisplay(_terminal,RaiseErrorMaxLoadWeight,null), RaiseErrorMaxLoadWeight, true);
	
epilog

	delete form;

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_termElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getRootValueForDisplay" id="84f22b0e-902e-431d-9127-87b963b1d356">
        <source>getRootValueForDisplay( _constName : String ):String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2014	cnwndl1	Initial creation

*/

vars

	any : Any;
	value : String;

begin

	value := null;

	if self.myTerminal &lt;&gt; null then
		if _constName &lt;&gt; null then
			any := app.myRoot.getConfig( _constName );
		endif;
		
		value := self.getStringFromAny(any);
		
	endif;
	
	return value;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_constName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStorageConfig" id="cacdf602-f610-4efe-91b4-43e95a60efd8">
        <source>getStorageConfig( _terminal : CM_Terminal; _termElement : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		TFS		Reason
20 Sep 2019	jlgndl1	45972	Initial creation
*/

vars
	schema : Schema;
	form : Form;
	formClass : Class;
	tabName : String;
	storageConfig : CM_StorageConfig;
	value : String;

begin
	schema := rootSchema.getSchema("InvoiceSchema");
	formClass := schema.getClass("INV_StorageConfig");

	create form as formClass transient;
	form.sendMsg("translateForm");
	
	tabName := self.getControlCaption( form, "shtStorage");
	
	if _terminal &lt;&gt; null then
		storageConfig := _terminal.myStorageConfig;
	endif;
	
	if storageConfig &lt;&gt; null then
		value := storageConfig.includeFirstDay.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkInc1stDay"), self.Storage_Config, tabName, "", value, "CM_StorageConfig.includeFirstDay", true);
	if storageConfig &lt;&gt; null then
		value := storageConfig.includeLastDay.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkIncLastDay"), self.Storage_Config, tabName, "", value, "CM_StorageConfig.includeLastDay", true);
	if storageConfig &lt;&gt; null then
		value := storageConfig.firstDayTimeCutoff.asStringJMT;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "lblCutoff"), self.Storage_Config, tabName, "", value, "CM_StorageConfig.firstDayTimeCutoff", true);
	if storageConfig &lt;&gt; null then
		if storageConfig.myWorkingDaysCalendar &lt;&gt; null then
			value := storageConfig.myWorkingDaysCalendar.getDisplayDetails(false);
		else
			value := null;
		endif;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "lblWorkingDays"), self.Storage_Config, tabName, "", value, "CM_StorageConfig.myWorkingDaysCalendar", true);
	if storageConfig &lt;&gt; null then
		if storageConfig.myCompulsoryCalendar &lt;&gt; null then
			value := storageConfig.myCompulsoryCalendar.getDisplayDetails(false);
		else
			value := null;
		endif;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "lblCompulsory"), self.Storage_Config, tabName, "", value, "CM_StorageConfig.myCompulsoryCalendar", true);
	if storageConfig &lt;&gt; null then
		value := storageConfig.getShipReceDescption;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "lblReceivalBased"), self.Storage_Config, tabName, "", value, "CM_StorageConfig.shipReceivalType", true);
	if storageConfig &lt;&gt; null then
		value := storageConfig.getShipReleDescption;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "lblReleaseBased"), self.Storage_Config, tabName, "", value, "CM_StorageConfig.shipReleaseType", true);
	
	
	self.addItem( _termElement, self.getControlCaption( form, "chkMTStorage"), self.Storage_Config, tabName, "", self.getTermValueForDisplay(_terminal, MTsByDebtor, null), MTsByDebtor, true);
	self.addItem( _termElement, self.getControlCaption( form, "chkMTStorageEX"), self.Storage_Config, tabName, "", self.getTermValueForDisplay(_terminal, MTsByDebtorExport, null), MTsByDebtorExport, true);

epilog
	delete form;
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_termElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getStringFromAny" id="69c2e00a-1f04-40ca-a73f-504bf1597a19">
        <source>getStringFromAny( any : Any ):String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2014	cnwndl1	Initial creation - If you are changing this look at "isObjectUsedinConfig" too
10 Nov 2022	navak20 Bug 55275: MTN - Configure Options Locator showing object in Current Value for Damage Size Default Measurement Type
8 Aug 2023 	navhl20 Bug 59197: MTN - Terminal Config Option Search does not Show Current Values
05 Dec 2024	navah1	Bug 12628: MTN - No Info Discharge Port in configuration options shows object not description
*/

vars

	value : String;

begin

	if any = null then
		value := null;
	else
		if any.isKindOf( CM_Object ) then
			if any.isKindOf( Collection ) then
				value := null;
			elseif any.isKindOf( CM_Bank ) then
				value := any.CM_Bank.code;
			elseif any.isKindOf( CM_Operator ) then
				value := any.CM_Operator.code;
			elseif any.isKindOf( CM_ISOType ) then
				value := any.CM_ISOType.code;
			elseif any.isKindOf( CM_SelectorQueryAccess ) then
				value := any.CM_SelectorQueryAccess.description;
			elseif any.isKindOf( CM_Voyage ) then
				value := any.CM_Voyage.code;
			elseif any.isKindOf( CM_ToDoTaskDesc ) then
				value := any.CM_ToDoTaskDesc.description;
			elseif any.isKindOf( CM_Stevedore ) then
				value := any.CM_Stevedore.code;
			elseif any.isKindOf( CM_ExtFinanceIO ) then
				value := any.CM_ExtFinanceIO.getNiceName; // PAR 33572
			elseif any.isKindOf( CM_Gate ) then
				value := any.CM_Gate.name;
			elseif any.isKindOf( CM_InvoiceDesc ) then
				value := any.CM_InvoiceDesc.description;
			elseif any.isKindOf( CM_InvoiceLineDesc ) then
				value := any.CM_InvoiceLineDesc.narration;
			elseif any.isKindOf( CM_VoidDebtor ) then
				value := any.CM_VoidDebtor.name;
			elseif any.isKindOf( CM_ConsigneeConsignor ) then
				value := any.CM_ConsigneeConsignor.code;
			elseif any.isKindOf( CM_SubTerminal ) then
				value := any.CM_SubTerminal.code;
			elseif any.isKindOf( CM_DebtorType ) then
				value := any.CM_DebtorType.code;
			elseif any.isKindOf( CM_OutputFormat ) then
				value := any.CM_OutputFormat.name;
			elseif any.isKindOf( CM_TerminalAreaType ) then
				value := any.CM_TerminalAreaType.description;
			elseif any.isKindOf( CM_WagonClass ) then
				value := any.CM_WagonClass.code;
			elseif any.isKindOf( CM_StopsTable ) then
				value := any.CM_StopsTable.code;
			elseif any.isKindOf( CM_Vessel ) then
				value := any.CM_Vessel.code;
			elseif any.isKindOf( CM_DayType ) then
				value := any.CM_DayType.code;
			elseif any.isKindOf( HMS_HarbourRegion ) then
				value := any.HMS_HarbourRegion.code;
			elseif any.isKindOf( CM_DelayTypeGroup ) then
				value := any.CM_DelayTypeGroup.description;
			elseif any.isKindOf( CM_StorageConfigType ) then
				value := any.CM_StorageConfigType.getNiceName;
			elseif any.isKindOf( CM_UserPasswordDefaultEmail ) then	//22 May 2018	NDL	TFS 38768
				value := "&lt;set&gt;";
			elseif any.isKindOf( CM_RoadProcess ) then	//22 Oct 2020	NDL	TFS 50113
				value := any.CM_RoadProcess.description;
			elseif any.isKindOf( CM_EventType ) then	//21 June 2021	NDL	TFS 51245
				value := any.CM_EventType.name;
			elseif	any.isKindOf( CM_MeasurementType) then	// 10.11.2022 navak20 TFS 55275
				value := any.CM_MeasurementType.name;	// 10.11.2022 navak20 TFS 55275
			elseif any.isKindOf( CM_DamageSeverity ) then			//8.8.2023 navhl20 #59197
                value := any.CM_DamageSeverity.description;
			elseif any.isKindOf( CM_Port ) then			//05.12.2024 navah1 #12628
                value := any.CM_Port.code;
			else
				value := any.CM_Object.display &amp; "  [" &amp; any.CM_Object.class.name &amp; "]";
			endif;
		elseif any.isKindOf( Binary ) then
			value := null;
		else
			value := any.String;
		endif;
	endif;
	
	return value;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="any" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSystemConfigOptions" id="ec4d2f2d-a386-4f4c-9ef1-bd340a8a9bdf">
        <source>getSystemConfigOptions( _rootElement : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Aug 2014	cnwndl1	Initial creation
20 Jun 2017	cnwkpd1	TFS 3369 - Push Events application - hide password fields from display

*/

vars

	entDef : EntTableDef;
	entRow : EntTableRow;
	tabName : String;
	category : ConstantCategory;
	constant : Constant;
	constantName : String;
	index : Integer;
	int : Integer;
	value : String;
	sourceValue : String;

begin

	category := self.myPortSchema.getCategory(ConfigConstants);
		
	foreach index in 1 to 5 do 
		if index = 1 then
			//Settings sheet;
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_RootDefaults];
		elseif index = 2 then
			//Security sheet;
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_SecurityConfig];
		elseif index = 3 then
			//Auto Admin sheet;
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_AutoConfig];
		elseif index = 4 then
			//Email sheet;
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_EmailServerConfig];
		elseif index = 5 then
			//Vessel sheet;
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_VesselSettings];
		endif;
		
		if entDef &lt;&gt; null then
			tabName := entDef.description;
			int := 0;
			foreach entRow in entDef.allEntTableRows do
				int := int + 1;
				constantName := null;
				value := null;
				
				if entRow.name = ETRow_PortLogoPic then
					continue;
				endif;
				
				foreach constant in category.getConstants do
					if constant.name.toUpper = entRow.name.toUpper then
						constantName := constant.name;
						sourceValue := constant.getSource.replaceString("'"," ");
						sourceValue := sourceValue.replaceString('"'," ");
						sourceValue := sourceValue.trimBlanks;
						value := self.getRootValueForDisplay(sourceValue).String;
						break;
					endif;
				endforeach;
				
				// TFS 3369 - Hide actual password values
				if entRow.name = ETRow_AutoOutwardPassword then
				   
					if value &lt;&gt; null then
						value := '&lt;set&gt;';
					endif;
				endif;
				   
				self.addItem( _rootElement, entRow.getRawHeadingValue, self.System_Config, tabName, "row " &amp; int.String, value, constantName, false);
				
			endforeach;
		endif;
	
	endforeach;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTermConfigOptions" id="7e6df274-a500-406c-a9da-65c7a291db7a">
        <source>getTermConfigOptions( _terminal : CM_Terminal; _termElement : JadeXMLElement input ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
14 August 2014	cnwndl1	Initial creation
20 Jun 2017		cnwkpd1	TFS 3369 - Push Events application - hide password fields from display
03 Oct 2022		navkc1	ChangeRequest #54463: MTN - Subscription License, New Feature Support Phase 1
10 Nov 2022		navak20 Bug 55275: MTN - Configure Options Locator showing object in Current Value for Damage Size Default Measurement Type
8 Aug 2023 		navhl20 Bug 59197: MTN - Terminal Config Option Search does not Show Current Values
08 Nov 2023		navlw1	Bug 60951: EUP | 53824 - Transport Manifest - VBS Slot Not Always Being Created
20 Mar 2025 	navlc30 JIRA 34268 - Create a new setting that is to be enabled for this new functionality
16 Jun 2025		jlizm1	MTN 34950 Add config to set if consignee must match release
*/

vars
	entDef : EntTableDef;
	entRow : EntTableRow;
	tabName : String;
	category : ConstantCategory;
	constant : Constant;
	constantName : String;
	index : Integer;
	int : Integer;
	value : String;
	sourceValue : String;
	dischargeHHLanderOpt : Integer;
	hhLanderGroundingOpt : Integer;
	hhTruckLoadScan : Integer;	//16 Dec 2016	NDL	TFS 3129
	imexDef : Integer;
	rrConsignVal : Integer;
	ioClass : CM_ExtFinanceIO;	//16 Nov 2017	NDL	TFS 7472
	bank : CM_Bank;
	keyseries :  CM_KeySeries;
	serieskey :  CM_SeriesKey;
	nextInvNum : Integer;	
	tmpUser : CM_User;

begin

	//16 Nov 2017	NDL	TFS 7472
	if _terminal &lt;&gt; null then
		ioClass := _terminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	endif;

	category := self.myPortSchema.getCategory(ConfigConstants);
	
	tmpUser := app.getMyUser(); // navkc1	03/10/2022	#54463
	
	foreach index in 1 to 12 do 
		if index = 1 then
			//Settings sheet;
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_TerminalSettings];
		elseif index = 2 then
			//Gate sheet;
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_GateConfig];
		elseif index = 3 then
			//Defaults sheet;
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_TerminalDefaultsConfig];
		elseif index = 4 then
			//Financial sheet;
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_TerminalFinancial];
		elseif index = 5 then
			//cams sheet;
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_CamsConfig];
		elseif index = 6 then
			//edi  sheet
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_EDIConfig];
		elseif index = 7 then
			//logs
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_TerminalLogSpecific];
		elseif index = 8 then
			//ship
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_ShipSettings];
		elseif index = 9 then
			//rail
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_RailConfig];
		elseif index = 10 then
			//reefer
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_RefConConfig];
		elseif index = 11 then
			//email read
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_EmailReadServerConfig];
		elseif index = 12 then
			//VGM
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_VGMConfig];
		endif;
		
		if entDef &lt;&gt; null then
			tabName := entDef.description;
			int := 0;
			foreach entRow in entDef.allEntTableRows do
				int := int + 1;
				if entRow.name.toUpper[1:11] = "ZTABLEBREAK" then
					continue;
				endif;
				
					value := null;
					constantName := null;
				
					//First check constants where the value doesn't match its name have not been followed 
					// or hard coded attributes exist.
					if entRow.name = ETRow_HhLanderGroundingOpt then
						constantName := HhLanderGroundingOpt;	
						hhLanderGroundingOpt := self.getTermValueForDisplay(_terminal,HhLanderGroundingOpt,null).Integer;
						value := app.hhGroundingEnumToString(hhLanderGroundingOpt);
					elseif entRow.name = ETRow_HhTruckLoadScan then	//16 Dec 2016	NDL	TFS 3129
						constantName := HhTruckLoadScan;	
						hhTruckLoadScan := self.getTermValueForDisplay(_terminal,HhTruckLoadScan,null).Integer;
						value := app.hhScanningEnumToString(hhTruckLoadScan);
					elseif entRow.name = ETRow_DischargeHHLanderOption then
						constantName := DischargeHHLanderOption;	
						dischargeHHLanderOpt := self.getTermValueForDisplay(_terminal,DischargeHHLanderOption,null).Integer;
						if dischargeHHLanderOpt = DiscHHLander_ToMach then
							value := app.getErrorString(To_Machine);
						elseif dischargeHHLanderOpt = DiscHHLander_ToGround then
							value := app.getErrorString(To_Ground);
						elseif dischargeHHLanderOpt = DiscHHLander_Both then
							value := app.getErrorString(Both);
						endif;
					elseif entRow.name = ETRow_RelReqOnRailLoadList then
						constantName := "ShowRelReqOnRailLoadList";
						value := self.getTermValueForDisplay(_terminal,ShowRelReqOnRailLoadList,null).String;
					elseif entRow.name = ETRow_RelReqOnShipLoadList then
						constantName := "ShowRelReqOnShipLoadList";
						value := self.getTermValueForDisplay(_terminal,ShowRelReqOnShipLoadList,null).String;
					elseif entRow.name = ETRow_DefCommodityMT then
						constantName := "EmptyCommodity";
						value := self.getTermValueForDisplay(_terminal,EmptyCommodity,null).String;
					elseif entRow.name = ETRow_ShpLinearMeterWidthRORO then
						constantName := "RoRoLinearMeteringWidth";
						value := self.getTermValueForDisplay(_terminal,RoRoLinearMeteringWidth,null).String;
					elseif entRow.name = ETRow_TerminalsForRelease then
						constantName := "CM_Terminal.allTerminalsForRelease";
						value := _terminal.allTerminalsForRelease.getCommaDelimitedList;
					elseif entRow.name = ETRow_TerminalsForVoyInland then
						constantName := "CM_Terminal.allTerminalsForVoyageInland";
						value := _terminal.allTerminalsForVoyageInland.getCommaDelimitedList;
					elseif entRow.name = ETRow_FinancialsCalendar then
						constantName := "CM_Terminal.myCalendar";
						if _terminal.myCalendar &lt;&gt; null then
							value := _terminal.myCalendar.code;
						endif;	
					elseif entRow.name = ETRow_Is30IncludedForReports then
						constantName := "Is30IncludedForReports";
						value := app.getISOTypeOtherForReportsDescr( self.getTermValueForDisplay(_terminal,Is30IncludedForReports,null).Integer );
					elseif entRow.name = ETRow_Is45IncludedForReports then
						constantName := "Is45IncludedForReports";
						value := app.getISOTypeOtherForReportsDescr( self.getTermValueForDisplay(_terminal,Is45IncludedForReports,null).Integer );
					elseif entRow.name = ETRow_Is53IncludedForReports then
						constantName := "Is53IncludedForReports";
						value := app.getISOTypeOtherForReportsDescr( self.getTermValueForDisplay(_terminal,Is53IncludedForReports,null).Integer );
					elseif entRow.name = ETRow_AllowInvPostUnqualAudits then	//06 May 2016	NDL	TFS 1960
						constantName := InvPostWithoutAuditQual;
						value := self.getTermValueForDisplay( _terminal, constantName, null ).String;
					elseif entRow.name = ETRow_PrenoteCertWeightValCrit then
						constantName := "CM_Terminal.myPrenoteWeightCriteria";
						if _terminal.myPrenoteWeightCriteria &lt;&gt; null then
							value:= _terminal.myPrenoteWeightCriteria.getDisplayStringForAttribute(ETRow_PrenoteCertWeightValCrit,false);
						endif;
					elseif entRow.name = ETRow_TimeZoneID then
						constantName := CM_Terminal.name &amp; "." &amp; CM_Terminal::timeZoneID.name;
						value := self.myTerminal.timeZoneID;
					elseif entRow.name = ETRow_TimeZoneShortID then
						constantName := CM_Terminal.name &amp; "." &amp; CM_Terminal::timeZoneShortID.name;
						value := self.myTerminal.timeZoneShortID;
					elseif entRow.name = ETRow_DefRecTrailIMEX then	//26 May 2017	NDL	TFS 4452
						constantName := DefRecTrailIMEX;
						imexDef := self.getTermValueForDisplay(_terminal,DefRecTrailIMEX,null).Integer;
						if imexDef = 0 then
							imexDef := TI_IMEX_STATUS_STORAGE;
						endif;
						value := app.getIMEXStringFromIMEXStatus( imexDef );
					//16 Nov 2017	NDL	TFS 7472
					elseif entRow.name = ETRow_InvoiceCurrencySymbol then	
						constantName := InvoiceCurrencySymbol;
						value := self.getTermValueForDisplay( _terminal, constantName, null ).String;
						if value = null then
							value := app.myRoot.getInvoiceCurrencySymbol().Character;
						endif;
					elseif entRow.name = ETRow_FirstMonthFinancialYear then
						constantName := "CM_ExtFinanceIO.firstMonthOfFinYear";
						if ioClass &lt;&gt; null then
							value := ioClass.firstMonthOfFinYear.String;
						endif;
					elseif entRow.name = ETRow_ExternalExportPath then
						constantName := "CM_ExtFinanceIO.exportPath";
						if ioClass &lt;&gt; null then
							value := ioClass.exportPath.String;
						endif;
					elseif entRow.name = ETRow_CurrentGLPeriod then
						constantName := "CM_ExtFinanceIO.glPeriod";
						if ioClass &lt;&gt; null then
							value := ioClass.glPeriod.String;
						endif;
					elseif entRow.name = ETRow_CurrentGLYear then
						constantName := "CM_ExtFinanceIO.glYear";
						if ioClass &lt;&gt; null then
							value := ioClass.glYear.String;
						endif;
					elseif entRow.name = ETRow_ExternalFinancialName then
						constantName := "CM_ExtFinanceIO.name";
						if ioClass &lt;&gt; null then
							value := ioClass.name; // PAR 33572
						endif;
					elseif entRow.name = ETRow_ExternalFinSysRemarks then
						constantName := "CM_ExtFinanceIO.remarks";
						if ioClass &lt;&gt; null then
							value := ioClass.remarks.String;
						endif;	
					elseif entRow.name = ETRow_DefaultBusinessUnitCargo then
						constantName := DefCompany;
						value := self.getTermValueForDisplay( _terminal, constantName, null ).String;
					elseif entRow.name = ETRow_DefaultDebtor then
						constantName := DefDebtor;
						value := self.getTermValueForDisplay( _terminal, constantName, null ).String;
					elseif entRow.name = ETRow_IgnoreFindCargoConsignee then
						constantName := IgnoreHHFindCargoConsignee;
						value := self.getTermValueForDisplay(_terminal,constantName,null).String;
					elseif entRow.name = ETRow_NextInvoiceNumber then
						constantName := "CM_SeriesKey.root";
						bank := _terminal.getConfig( DefCompany ).CM_Bank;
						if bank &lt;&gt; null then
							keyseries := bank.keySeries[SN_INVOICE];
							if keyseries &lt;&gt; null then
								serieskey := keyseries.nextKey;
								if serieskey &lt;&gt; null then
									nextInvNum := serieskey.root;
									if nextInvNum &lt;&gt; 0 then
										value := nextInvNum.String;
									endif;
								endif;
							endif;	
						endif;
					 // ### TFS BUG 58862 27JUN2023 NAVAB1
					elseif entRow.name = ETRow_DamageSeverityDefault then
						constantName := DamageSeverityDefault;
						value := self.getTermValueForDisplay( _terminal, constantName, null ).String;
					elseif entRow.name = ETRow_InvReeferTempReadings then
						constantName := ChargeFirstTemperatureOnly;
						if _terminal.getConfig(ChargeFirstTemperatureOnly).Boolean then
							value := app.getErrorString(Charge_only_first_temper_readi);
						else
							value := app.getErrorString(Charge_temperatur_readings);
						endif;
					elseif entRow.name = ETRow_RoadGateCargoCheckCrit then	//22 Oct 2019	NDL	TFS 46911
						constantName := "CM_Terminal.myRoadGateCargoCheckCriteria";
						if _terminal.myRoadGateCargoCheckCriteria = null
						or _terminal.myRoadGateCargoCheckCriteria.allCriteria.isEmpty	
						then
							value := app.getErrorString1( Not_configured, app.getErrorString(Filter_criteria) );	
						else
							value := _terminal.myRoadGateCargoCheckCriteria.getTableDisplayString();
						endif;
					elseif entRow.name = ETRow_LocActRailYardCount then	//21 Jun 2021	NDL	TFS 51245
						constantName := LocActRailToYard;
						value := self.getTermValueForDisplay( _terminal, constantName, null ).String;
					elseif entRow.name = ETRow_LocActVesselRailCount then	//21 Jun 2021	NDL	TFS 51245
						constantName := LocActVesselToRail;
						value := self.getTermValueForDisplay( _terminal, constantName, null ).String;
					elseif entRow.name = ETRow_LocActYardRailCount then	//21 Jun 2021	NDL	TFS 51245
						constantName := LocActYardToRail;
						value := self.getTermValueForDisplay( _terminal, constantName, null ).String;
					elseif entRow.name = ETRow_LocActRailVesselCount then	//21 Jun 2021	NDL	TFS 51245
						constantName := LocActRailToVessel;
						value := self.getTermValueForDisplay( _terminal, constantName, null ).String;
					//16 Aug 2021	NDL	TFS 51785
					elseif entRow.name = ETRow_RoadGateRelReqVal then
						constantName := RoadGateRelReqVal;
						value := self.getTermValueForDisplay( _terminal, constantName, null ).String;
						if value = null then
							value := app.getErrorString( Raise_error_cargo_does_not_mat );
						elseif value = '1' then
							value := app.getErrorString( Raise_warni_cargo_does_not_mat );
						elseif value = '2' then
							value := app.getErrorString( Validat_against_release_reques );
						endif;
						
					//elseif entRow.name = DamageDetailsOptional or entRow.name = DamageSeverityOptional then // navkc1	03/10/2022	#54463						//8.8.2023 navhl20 #59197
					elseif entRow.name = ETRow_DamageDetailsOptional or entRow.name = ETRow_DamageSeverityOptional then 										//8.8.2023 navhl20 #59197
						// navkc1	03/10/2022	#54463 - Do not display this if user does not have access.
						if not tmpUser.canDo(_terminal, PmAdmDamageCodeAdvancedMaint) then
							continue;
						endif;
						if entRow.name = ETRow_DamageDetailsOptional then																						//8.8.2023 navhl20 #59197
							constantName := DamageDetailsOptional;
							value := self.getTermValueForDisplay( _terminal, constantName, null ).String;
						elseif entRow.name = ETRow_DamageSeverityOptional then
							constantName := DamageSeverityOptional;
							value := self.getTermValueForDisplay( _terminal, constantName, null ).String; 
						endif;
					//Start 10.11.2022 navak20 TFS 55275
					elseif entRow.name = ETRow_DamageSizeDMType then
						constantName := DamageSizeDMType;
						value := self.getTermValueForDisplay( _terminal, constantName, null ).String;
					//End 10.11.2022 navak20 TFS 55275
					
					elseif entRow.name = ETRow_RelReqConsigneeValidate then
						constantName := RelReqConsigneeValidate;
						rrConsignVal := _terminal.getConfig(constantName).Integer;
						value := app.relReqConsigneeValEnumToStr(rrConsignVal);
						
					elseif entRow.name = ETRow_RelReqConsignorValidate then
						constantName := RelReqConsignorValidate;
						rrConsignVal := _terminal.getConfig(constantName).Integer;
						value := app.relReqConsignorValEnumToStr(rrConsignVal);
					
					else
					
						// all others
						foreach constant in category.getConstants do
							if constant.name.toUpper = entRow.name.toUpper then
								constantName := constant.name;
								sourceValue := constant.getSource.replaceString("'"," ");
								sourceValue := sourceValue.replaceString('"'," ");
								sourceValue := sourceValue.trimBlanks;
								value := self.getTermValueForDisplay(_terminal,sourceValue,null).String;
								break;
							endif;
						endforeach;
					endif;
					
					if entRow.name = ETRow_BookingRefRequired then
						value := app.bookingRequiredEnumToString( value.Integer );
					endif;
					
					if constantName = VsTruckDriverMand  	   and entRow.name = ETRow_VsTruckDriverMand
					or constantName = VsOntimeGracePeriod  	   and entRow.name = ETRow_VsOntimeGracePeriod
					or constantName = VsGenerateDaysInAdvance  and entRow.name = ETRow_VsGenerateDaysInAdvance
					or constantName = VsPurgeSlotsOlderThan    and entRow.name = ETRow_VsPurgeSlotsOlderThan
					or constantName = VsBookMinAdvanceHrs  	   and entRow.name = ETRow_VsBookMinAdvanceHrs
					or constantName = VsBookMinAdvancePu 	   and entRow.name = ETRow_VsBookMinAdvancePu
					or constantName = VsBookingRule  		   and entRow.name = ETRow_VsBookingRule
					or constantName = VsDefaultProcess		   and entRow.name = ETRow_VsDefaultProcess				//05.10.2022 navma1 #53697
					or constantName = AllowVBSInPast 		   and entRow.name = ETRow_AllowVBSInPast 				// #60951
                    or constantName = VsEnhancedStdVBS         and entRow.name = ETRow_VsEnhancedStdVBS				//20.03.2025 navlc30 #34268
					then
						if not app.isVehicleBookingEnabled then
							continue;
						endif;
						value := self.getTermValueForDisplay(_terminal,constantName,null).String;
					endif;
					
					// TFS 3369 - Hide password fields from display
					if entRow.name = ETRow_AutoPop3Password then
						if value &lt;&gt; null then
							value := '&lt;set&gt;';
						endif;
					endif;
					
					self.addItem( _termElement, entRow.getRawHeadingValue, self.Terminal_Config, tabName, "row " &amp; int.String, value, constantName, true);
				
			endforeach;
		endif;
	
	endforeach;
	
	//manually add the Terminal seal checks stuff
	tabName := app.getErrorString(Seal_Checks);
	constantName := "CM_Terminal.sealCheckShipReceival";
	value := app.sealCheckTypeEnumToString(self.myTerminal.sealCheckShipReceival) &amp; " " &amp; app.sealCheckTypeEnumToString(self.myTerminal.sealCheckShipRelease);
	self.addItem( _termElement, BR_TYPE_SHIP_STR &amp; " " &amp; tabName, self.Terminal_Config, tabName, "row 1", value, constantName, true);
	
	constantName := "CM_Terminal.sealCheckRailReceival";
	value := app.sealCheckTypeEnumToString(self.myTerminal.sealCheckRailReceival) &amp; " " &amp; app.sealCheckTypeEnumToString(self.myTerminal.sealCheckRailRelease);
	self.addItem( _termElement, BR_TYPE_RAIL_STR &amp; " " &amp; tabName, self.Terminal_Config, tabName, "row 2", value, constantName, true);
	
	constantName := "CM_Terminal.sealCheckRoadReceival";
	value := app.sealCheckTypeEnumToString(self.myTerminal.sealCheckRoadReceival) &amp; " " &amp; app.sealCheckTypeEnumToString(self.myTerminal.sealCheckRoadRelease);
	self.addItem( _termElement, BR_TYPE_ROAD_STR &amp; " " &amp; tabName, self.Terminal_Config, tabName, "row 3", value, constantName, true);
	
	constantName := "CM_Terminal.sealCheckUnpack";
	value := app.sealCheckTypeEnumToString(self.myTerminal.sealCheckUnpack) &amp; " " &amp; app.sealCheckTypeEnumToString(self.myTerminal.sealCheckPack);
	self.addItem( _termElement, BR_TYPE_PACKING_STR &amp; " " &amp; tabName, self.Terminal_Config, tabName, "row 4", value, constantName, true);
	
	constantName := "CM_Terminal.sealCheckWagonDischarge";
	value := app.sealCheckTypeEnumToString(self.myTerminal.sealCheckWagonDischarge) &amp; " " &amp; app.sealCheckTypeEnumToString(self.myTerminal.sealCheckWagonLoad);
	self.addItem( _termElement, app.getErrorString(Rail_wagon) &amp; " " &amp; tabName, self.Terminal_Config, tabName, "row 5", value, constantName, true);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_termElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTermValueForDisplay" id="9d428239-18e8-4fca-b2c8-b48424cd748b">
        <source>getTermValueForDisplay( _terminal : CM_Terminal; _constName : String; _etRow : String ):String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2014	cnwndl1	Initial creation

*/

vars

	any : Any;
	value : String;
	terminal : CM_Terminal;

begin

	value := null;
	
	terminal := _terminal;
	if terminal = null then
		terminal := self.myTerminal;
	endif;

	if terminal &lt;&gt; null then
		if _constName &lt;&gt; null then
			any := terminal.getConfig( _constName );
		elseif _etRow &lt;&gt; null then
			any := terminal.getDisplayStringForAttribute( _etRow, false );
		endif;
		
		value := self.getStringFromAny(any);
		
	endif;
	
	return value;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_constName" type="String"/>
        <Parameter name="_etRow" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVehicleRTConfiguration" id="4784e9f0-4040-4fe2-9431-ca2684b363ad">
        <source>getVehicleRTConfiguration( _terminal : CM_Terminal; _termElement : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2014		cnwndl1	Initial creation
28 November 2017	jlgmd1	TFS 7728 - Configure Options Locator extract isn't working correctly

*/

constants

	Grp : String = " (Group)";

vars

	tabName : String;
	constantName : String;
	position : String;
	value : String;
	rtConfig : CM_RTVehicleConfig;
	schema : Schema;
	form : Form;
	formClass : Class;

begin
/*  // ### JIRA 33504 11DEC2024 NAVAB1 no longer supporting the OLD JADE VMT App
	if _terminal &lt;&gt; null then
		rtConfig := _terminal.getRTVehicleConfigForObject(_terminal);
	endif;
	
	//constantName := "No constant, hard coded!";
	constantName := null;
	
	schema := rootSchema.getSchema("UiCommonSchema");
	formClass := schema.getClass("CMUI_RTVehicleConfig");

	create form as formClass transient;
	form.sendMsg("translateForm");
	
	//Gate tab.
	tabName := self.getControlCaption( form, "shtSetttings");
	value := "&lt;machine dependant&gt;";
	
	position := null;
	if rtConfig &lt;&gt; null then
		constantName := "CM_RTVehicleConfig.useSeperatePickupSetdown";
		value := rtConfig.useSeperatePickupSetdown.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkSepPickSet"), self.Vehicle_Config, tabName, position, value, constantName, true);
	if rtConfig &lt;&gt; null then
		constantName := "CM_RTVehicleConfig.allowChangeSetdown";
		value := rtConfig.allowChangeSetdown.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkAllowChgSet"), self.Vehicle_Config, tabName, position, value, constantName, true);
	if rtConfig &lt;&gt; null then
		constantName := "CM_RTVehicleConfig.ignoreWarnings";
		value := rtConfig.ignoreWarnings.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkIgnoreWarn"), self.Vehicle_Config, tabName, position, value, constantName, true);
	if rtConfig &lt;&gt; null then
		constantName := "CM_RTVehicleConfig.allowChangeQueue";
		value := rtConfig.allowChangeQueue.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkAllowChgQ"), self.Vehicle_Config, tabName, position, value, constantName, true);
	if rtConfig &lt;&gt; null then
		constantName := "CM_RTVehicleConfig.useDetailsViewForPickup";
		value := rtConfig.useDetailsViewForPickup.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkDtViewPickup"), self.Vehicle_Config, tabName, position, value, constantName, true);
	if rtConfig &lt;&gt; null then
		constantName := "CM_RTVehicleConfig.autoResequenceJobs";
		value := rtConfig.autoResequenceJobs.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkAutoReseq"), self.Vehicle_Config, tabName, position, value, constantName, true);
	if rtConfig &lt;&gt; null then
		constantName := "CM_RTVehicleConfig.useDetailsViewForSetdown";
		value := rtConfig.useDetailsViewForSetdown.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkDtViewSetdown"), self.Vehicle_Config, tabName, position, value, constantName, true);
	
	//10 Nov 2017	NDL	TFS 7427
	if rtConfig &lt;&gt; null then	
		constantName := "CM_RTVehicleConfig.autoSearchDirector";
		value := rtConfig.useDetailsViewForSetdown.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkAutoSrchDirMatch"), self.Vehicle_Config, tabName, position, value, constantName, true);
	
	if rtConfig &lt;&gt; null then
		constantName := "CM_RTVehicleConfig.showSecondaryQueues";
		value := rtConfig.showSecondaryQueues.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkShowSecQueues"), self.Vehicle_Config, tabName, position, value, constantName, true);
	if rtConfig &lt;&gt; null then
		constantName := "CM_RTVehicleConfig.displayAcceptOnLeftHandSide";
		value := rtConfig.displayAcceptOnLeftHandSide.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkDisplayLeft"), self.Vehicle_Config, tabName, position, value, constantName, true);
	if rtConfig &lt;&gt; null then
		constantName := "CM_RTVehicleConfig.limitEnquiryToCurrentQ";
		value := rtConfig.limitEnquiryToCurrentQ.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkEnqCurrentQ"), self.Vehicle_Config, tabName, position, value, constantName, true);
	if rtConfig &lt;&gt; null then
		constantName := "CM_RTVehicleConfig.maxNumberQueueEntries";
		value := rtConfig.maxNumberQueueEntries.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "lblNumQEntries"), self.Vehicle_Config, tabName, position, value, constantName, true);
	if rtConfig &lt;&gt; null then
		constantName := "CM_RTVehicleConfig.highlightHight";
		value := rtConfig.highlightHight.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "lblHighlight"), self.Vehicle_Config, tabName, position, value, constantName, true);
	
	position := self.getControlCaption( form, "grpTaskView") &amp; Grp;
	if rtConfig &lt;&gt; null then
		//constantName := "CM_RTVehicleConfig.taskViewMode";
		constantName := "CM_RTVehicleConfig.taskViewList";		// TFS 7728
		value := ( rtConfig.taskViewMode = CM_RTVehicleConfig.TASKVIEW_LIST or rtConfig.taskViewMode = CM_RTVehicleConfig.TASKVIEW_BOTH).String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkTaskList"), self.Vehicle_Config, tabName, position, value, constantName, true);
	if rtConfig &lt;&gt; null then
		//constantName := "CM_RTVehicleConfig.taskViewMode";
		constantName := "CM_RTVehicleConfig.taskViewNext";		// TFS 7728
		value := ( rtConfig.taskViewMode = CM_RTVehicleConfig.TASKVIEW_GETNEXT or rtConfig.taskViewMode = CM_RTVehicleConfig.TASKVIEW_BOTH).String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkTaskGetNext"), self.Vehicle_Config, tabName, position, value, constantName, true);
	if rtConfig &lt;&gt; null then
		constantName := "CM_RTVehicleConfig.automaticGetNextTask";
		value := rtConfig.automaticGetNextTask.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkAutoGetNext"), self.Vehicle_Config, tabName, position, value, constantName, true);
	
	position := self.getControlCaption( form, "grpGraphViews") &amp; Grp;
	if rtConfig &lt;&gt; null then
		//constantName := "CM_RTVehicleConfig.allAvailableGraphicViews";
		constantName := "CM_RTVehicleConfig.allAvailableGraphicViewTop";		// TFS 7728
		value := rtConfig.allAvailableGraphicViews.includes(CM_RTVehicleConfig.VIEW_TOP).String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkTop"), self.Vehicle_Config, tabName, position, value, constantName, true);
	if rtConfig &lt;&gt; null then
		//constantName := "CM_RTVehicleConfig.allAvailableGraphicViews";
		constantName := "CM_RTVehicleConfig.allAvailableGraphicViewEnd";		// TFS 7728
		value := rtConfig.allAvailableGraphicViews.includes(CM_RTVehicleConfig.VIEW_END).String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkEnd"), self.Vehicle_Config, tabName, position, value, constantName, true);
	if rtConfig &lt;&gt; null then
		//constantName := "CM_RTVehicleConfig.allAvailableGraphicViews";
		constantName := "CM_RTVehicleConfig.allAvailableGraphicViewFace";		// TFS 7728
		value := rtConfig.allAvailableGraphicViews.includes(CM_RTVehicleConfig.VIEW_FACE).String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkFace"), self.Vehicle_Config, tabName, position, value, constantName, true);
	
	position := self.getControlCaption( form, "lblColPlacement") &amp; Grp;
	if rtConfig &lt;&gt; null then
		constantName := "CM_RTVehicleConfig.columnLabelsPlacement";
		value := ( rtConfig.columnLabelsPlacement = COLUMN_LABEL_TOP ).String &amp; ' ' &amp; ( rtConfig.columnLabelsPlacement = COLUMN_LABEL_BOTTOM ).String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "lblColPlacement"), self.Vehicle_Config, tabName, position, value, constantName, true);
	
	position := self.getControlCaption( form, "lblRowPlacement") &amp; Grp;
	if rtConfig &lt;&gt; null then
		constantName := "CM_RTVehicleConfig.rowLabelsPlacement";
		value := ( rtConfig.rowLabelsPlacement = ROW_LABEL_LEFT ).String &amp; ' ' &amp; ( rtConfig.rowLabelsPlacement = ROW_LABEL_RIGHT ).String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "lblRowPlacement"), self.Vehicle_Config, tabName, position, value, constantName, true);
	
	position := self.getControlCaption( form, "grpOstow") &amp; Grp;
	if rtConfig &lt;&gt; null then
		constantName := "CM_RTVehicleConfig.overstowMoveMode";
		if rtConfig.overstowMoveMode = 0 then
			value := app.getErrorString(None);
		elseif rtConfig.overstowMoveMode = 0 then
			value := app.getErrorString(AutoPlan);
		elseif rtConfig.overstowMoveMode = 0 then
			value := app.getErrorString(Manual);
		elseif rtConfig.overstowMoveMode = 0 then
			value := app.getErrorString(Accept_only);
		endif;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "lblMoveOS"), self.Vehicle_Config, tabName, position, value, constantName, true);
	if rtConfig &lt;&gt; null then
		constantName := "CM_RTVehicleConfig.maxNumberOverstowForDriver";
		value := rtConfig.maxNumberOverstowForDriver.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "lbNumOS"), self.Vehicle_Config, tabName, position, value, constantName, true);
	
	position := null;
	if rtConfig &lt;&gt; null then
		constantName := "CM_RTVehicleConfig.allowCargoSearch";
		value := rtConfig.allowCargoSearch.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkAllowEnquiry"), self.Vehicle_Config, tabName, position, value, constantName, true);
	if rtConfig &lt;&gt; null then
		constantName := "CM_RTVehicleConfig.allowNonRTMoves";
		value := rtConfig.allowNonRTMoves.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkAllowNonRT"), self.Vehicle_Config, tabName, position, value, constantName, true);
	if rtConfig &lt;&gt; null then
		constantName := "CM_RTVehicleConfig.maxNumberSearchResults";
		value := rtConfig.maxNumberSearchResults.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "lbNumEnquiry"), self.Vehicle_Config, tabName, position, value, constantName, true);
	
	position := self.getControlCaption( form, "grpQueries") &amp; Grp;
	if rtConfig &lt;&gt; null then
		constantName := "CM_RTVehicleConfig.maxNumberQueryResults";
		value := rtConfig.maxNumberQueryResults.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "lblQueries"), self.Vehicle_Config, tabName, position, value, constantName, true);
	*/
epilog

	delete form;

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_termElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getVehicleRTVehAppsSettings" id="eaa2d806-5fe4-4ec9-b125-6fd2a3c4bbf0">
        <source>getVehicleRTVehAppsSettings( _terminal : CM_Terminal; _termElement : JadeXMLElement input ) protected;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 21 March 2023
TFS#		: 57126
Function	: Add Vehicle Apps Sheet Settings Tab into the Configure Option Locator

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
constants
	Grp : String = ' (Sheet) ';
vars
	tabName : String;
	constantName : String;
	position : String;
	value : String;
	schema : Schema;
	form : Form;
	formClass : Class;

begin
	schema := rootSchema.getSchema("UiCommonSchema");
	formClass := schema.getClass("CMUI_RTVehicleConfig");

	create form as formClass transient;
	form.sendMsg("translateForm");
	
	//Vehicle Apps | Settings Tab
	
	tabName := self.getControlCaption( form, "shtSettingsOther"); // ### JIRA 33504 11DEC2024 NAVAB1
	value := "&lt;machine dependant&gt;";	
	position := self.getControlCaption( form, "shtSettingsOther") &amp; Grp; // ### JIRA 33504 11DEC2024 NAVAB1
	constantName := "CM_RTVehicleConfig.allowColumnFiltering";
	self.addItem( _termElement, self.getControlCaption( form, "chkAllowColumnFiltering"), self.Vehicle_Config, tabName, position, value, constantName, true);	
epilog

	delete form;

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_termElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getVesselRoRoConfig" id="2bb6e7e7-fc92-4e9f-bc58-88788b6aa850">
        <source>getVesselRoRoConfig( _rootElement : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2014	cnwndl1	Initial creation

*/

vars

	tabName : String;
	constantName : String;
	position : String;
	value : Any;
	stateData : CM_StateDataDict;
	schema : Schema;
	form : Form;
	formClass : Class;

begin

	//CMUI_VesselROROConfig
	constantName := "No constant, hard coded!";
	position := null;
	
	schema := rootSchema.getSchema("UiCommonSchema");
	formClass := schema.getClass("CMUI_VesselROROConfig");

	create form as formClass transient;
	form.sendMsg("translateForm");
	
	//Location tab.
	tabName := self.getControlCaption( form, "shtLocnLabels");
	//value := "&lt;vessel dependant&gt;";

	stateData := app.myRoot.getStateObject(ConfigGrp_System).allStateData;
	
	global.getExtraData(stateData,RoRoDeckLabelPrefix,value);
	self.addItem( _rootElement, self.getControlCaption( form, "lblDeckPre"), self.ROROVessel_Config, tabName, position, value.String, RoRoDeckLabelPrefix, false);
	global.getExtraData(stateData,RoRoSubDeckLabelPrefix,value);
	self.addItem( _rootElement, self.getControlCaption( form, "lblSubDeckPre"), self.ROROVessel_Config, tabName, position, value.String, RoRoSubDeckLabelPrefix, false);
	global.getExtraData(stateData,RoRoLocationNumberLength,value);
	self.addItem( _rootElement, self.getControlCaption( form, "lblLocNumLen"), self.ROROVessel_Config, tabName, position, value.String, RoRoLocationNumberLength, false);
	global.getExtraData(stateData,RoRoLaneCodeIsZeroFilled,value);
	self.addItem( _rootElement, self.getControlCaption( form, "lblLaneCodeZero"), self.ROROVessel_Config, tabName, position, value.String, RoRoLaneCodeIsZeroFilled, false);
	global.getExtraData(stateData,RoRoRotatedLabel,value);
	self.addItem( _rootElement, self.getControlCaption( form, "lblRotatedLabel"), self.ROROVessel_Config, tabName, position, value.String, RoRoRotatedLabel, false);
	global.getExtraData(stateData,RoRoOutOfTwistLockSuffix,value);
	self.addItem( _rootElement, self.getControlCaption( form, "lblOOTLS"), self.ROROVessel_Config, tabName, position, value.String, RoRoOutOfTwistLockSuffix, false);
	global.getExtraData(stateData,RoRoGeneralCargoSuffix,value);
	self.addItem( _rootElement, self.getControlCaption( form, "lblGCS"), self.ROROVessel_Config, tabName, position, value.String, RoRoGeneralCargoSuffix, false);
	global.getExtraData(stateData,RoRoLaneLabelPrefix,value);
	self.addItem( _rootElement, self.getControlCaption( form, "lblLanePre"), self.ROROVessel_Config, tabName, position, value.String, RoRoLaneLabelPrefix, false);
	global.getExtraData(stateData,RoRoLaneNumberLength,value);
	self.addItem( _rootElement, self.getControlCaption( form, "lblLaneNumLen"), self.ROROVessel_Config, tabName, position, value.String, RoRoLaneNumberLength, false);
	global.getExtraData(stateData,RoRoLocationCodeIsZeroFilled,value);
	self.addItem( _rootElement, self.getControlCaption( form, "lblLocCodeZero"), self.ROROVessel_Config, tabName, position, value.String, RoRoLocationCodeIsZeroFilled, false);
	global.getExtraData(stateData,RoRoAutoGenerateStartEnd,value);
	self.addItem( _rootElement, self.getControlCaption( form, "lbAutoGen"), self.ROROVessel_Config, tabName, position, value.String, RoRoAutoGenerateStartEnd, false);
	
	//Size tab.
	tabName := self.getControlCaption( form, "shtLocnSize");
	
	global.getExtraData(stateData,RoRoLocationWidth,value);
	self.addItem( _rootElement, self.getControlCaption( form, "lblContPosWidth"), self.ROROVessel_Config, tabName, position, value.String, RoRoLocationWidth, false);
	global.getExtraData(stateData,RoRoLocationLength,value);
	self.addItem( _rootElement, self.getControlCaption( form, "lblContPosLength"), self.ROROVessel_Config, tabName, position, value.String, RoRoLocationLength, false);
	global.getExtraData(stateData,RoRoLocationGap,value);
	self.addItem( _rootElement, self.getControlCaption( form, "lblContPosGap"), self.ROROVessel_Config, tabName, position, value.String, RoRoLocationGap, false);
	global.getExtraData(stateData,RoRoLaneWidth,value);
	self.addItem( _rootElement, self.getControlCaption( form, "lblLaneWidth"), self.ROROVessel_Config, tabName, position, value.String, RoRoLaneWidth, false);
	global.getExtraData(stateData,RoRoLaneLength,value);
	self.addItem( _rootElement, self.getControlCaption( form, "lblLaneLength"), self.ROROVessel_Config, tabName, position, value.String, RoRoLaneLength, false);
	global.getExtraData(stateData,RoRoLaneGap,value);
	self.addItem( _rootElement, self.getControlCaption( form, "lblLaneGap"), self.ROROVessel_Config, tabName, position, value.String, RoRoLaneGap, false);

epilog

	delete form;

end;</source>
        <access>protected</access>
