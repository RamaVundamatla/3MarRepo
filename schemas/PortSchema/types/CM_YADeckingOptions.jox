    <JadeMethod name="validateCustomIn" id="b799d6e8-606f-4d08-9e0a-8ef7085b47e1">
        <source>validateCustomIn();
//----------------------------------------------------------------
//	Created:	27 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	rule	: CM_YADeckingRule;
begin

	if self.allYALocationCellsIn.isEmpty then
		app.raiseUnexpectedProgramError(class.name, method.name, 'allYALocationCellsIn is empty');	
		return;
	endif;
	
	
	//all heights must be after the lower positions
	self.validateCellPositions(true, self.allYALocationCellsIn);

	rule := self.allDeckingRulesIn.first;
	rule.validateForCustom();


end;</source>
    </JadeMethod>
    <JadeMethod name="validateCustomOut" id="c1aa07ef-922e-4198-a77d-6b52d50b391f">
        <source>validateCustomOut();
//----------------------------------------------------------------
//	Created:	27 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	rule	: CM_YADeckingRule;
begin

	if self.allYALocationCellsOut.isEmpty then
		app.raiseUnexpectedProgramError(class.name, method.name, 'allYALocationCellsOut is empty');
		return;	
	endif;
	
			
	//all heights must be after the lower positions
	self.validateCellPositions(false, self.allYALocationCellsOut);

	rule := self.allDeckingRulesOut.first;
	rule.validateForCustom();

	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDecking" id="135ce942-c986-4022-a7d9-cf7e8c80a36d">
        <updating/>
        <source>validateForDecking() updating;
//----------------------------------------------------------------
//	Created:	26 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	inTrans : Boolean;
begin

	inTrans := process.isInTransactionState();
	//these are critical
	if self.allYALocationCellsIn.isEmpty
	or self.allYALocationCellsOut.isEmpty
	or (self.allYALocationCellsIn.size &lt;&gt; self.allYALocationCellsOut.size) then
		if not inTrans then
			beginTransaction;
		endif;
		self.initialiseForDecking();
		if not inTrans then
			commitTransaction;
		endif;
	endif;

	//validate rules
	if self.inOptionType = DeckingRule_Custom then
		self.validateCustomIn();
	else
		//validate the rules don't overlap or miss out cells
		self.validateInRules();
	endif;
	
	if self.outOptionType = DeckingRule_Custom then
		self.validateCustomOut();
	else
		//validate the rules don't overlap or miss out cells
		self.validateOutRules();
	endif;
	
end;</source>
    </JadeMethod>
