    <JadeMethod name="validateForUpdate" id="e184a882-1d2c-4608-90d0-65fc2257aca4">
        <source>validateForUpdate();
/*
Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 April 2010	conkc1	Initial creation

*/
vars
	realClass : CM_DataDumpSQLColumn;
	
begin
	self.validateCommon;
	realClass := self.pxyGetRealObject;
	if realClass = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, self.class.name, null, null);
	endif;

epilog

end;</source>
    </JadeMethod>
