    <JadeMethod name="delete" id="3b6d5736-0516-4843-b5ae-b7fb90a2c990">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 October 2010	cnwndl1	Initial creation

*/

vars

begin

	if not self.allResourceUsageSums.isEmpty then
		self.allResourceUsageSums.purge;
	endif;

epilog

end;</source>
