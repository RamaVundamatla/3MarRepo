    <JadeMethod name="deleteWONoVal" id="d5d36af6-612a-4596-97e8-feb1324354a8">
        <source>deleteWONoVal(_workOrder : String; _term : CM_Terminal);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2023 navhl20 ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping

*/
vars
	workOrder : CM_WorkOrder;
	wod       : CM_WorkOrderDtl;
	job		  : CM_Job;
	jobArr    : CM_JobArray;
	wodTodo	  : CM_WodToDo;
begin
	create jobArr transient;
	
	workOrder := _term.allWorkOrders[_workOrder];
	if workOrder &lt;&gt; null then
		
		foreach wod in workOrder.allWoDtls do
			
			if wod.isKindOf(CM_WorkOrderTIDtl) then
				foreach job in wod.CM_WorkOrderTIDtl.allJobs do
					jobArr.add(job);
				endforeach;
				foreach wodTodo in  wod.CM_WorkOrderTIDtl.allToDoRequests do 
					
					foreach job in wodTodo.allJobs do
						jobArr.add(job);
					endforeach;
				endforeach;
			elseif wod.isKindOf(CM_WorkOrderToDoDtl) then
				foreach job in wod.CM_WorkOrderToDoDtl.allJobs do
					jobArr.add(job);
				endforeach;
			endif;
		endforeach;
		
		beginTransaction;
		
		jobArr.purge();
		
		workOrder.erase(NORMAL_ERASE);
		
		commitTransaction;
	endif;
epilog
	delete jobArr;
end;</source>
        <Parameter name="_workOrder" type="String"/>
        <Parameter name="_term" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="micoBenchmarking" id="6beae47c-b794-4f1a-843b-b6559b25a7d9">
        <source>micoBenchmarking();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2024		navma1	Initial creation

*/

vars
    oldWay : Boolean;
    dts,dte : Decimal[19];
    s,t,u,v : String;
    i,j,reps : Integer;
	prof	 : JadeProfiler;
	starTM   : Decimal[19,0];
	invoiceProcess	 : CM_InvoiceProcess;
	root : CM_Root;
begin
	app.myRoot.startJadeProfiler(prof,method.getNiceName,20,false,'MA',starTM);
    write CrLf &amp; "Starting...";
    reps   := 10000;  // adjust this to get a run length of 1 to 10 seconds
    oldWay := false;
    dts    := app.relativeMachineTime;
	
	write 'Start Time :' &amp; app.actualTimeAppServer.String;
   root := app.myRoot;
   
   foreach i in 1 to reps do
        if oldWay then
           invoiceProcess := CM_InvoiceProcessDefault.firstInstance;
		  // write invoiceProcess.description;
        else
            invoiceProcess := root.allInvoiceProcesses[InvoiceProcessDefault];
			//write invoiceProcess.description;
        endif;
    endforeach;
	
	write 'End Time : ' &amp; app.actualTimeAppServer.String;
    dte := app.relativeMachineTime;
    write "&lt;" &amp; s &amp; "&gt;" &amp; "&lt;" &amp; t &amp; "&gt;";  // to verify the functional results
    write ((dte-dts)/reps).roundedTo(6).String &amp; " ms/rep";
epilog
    write "Finished";
	app.myRoot.stopJadeProfiler(prof,starTM);
end;</source>
    </JadeMethod>
    <JadeMethod name="removeRDTFromTi" id="24d50645-c75a-410e-9476-5809e3e6b12a">
        <source>removeRDTFromTi();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 June 2025	navhl20	Initial creation

*/

vars
	term 	: CM_Terminal;
	ta 		: CM_LocationsController;
	ti		: CM_TrackedItem;
	count	: Integer;
begin
	app.initialize();
	
	term := app.myRoot.allTerminals["WO"];
	ta := term.allTerminalAreas["BS01"].allLocationsControllers.first;
	
	count := 0;
	foreach ti in ta.allTrackedItems do
		count := count + 1; 
		beginTransaction;
		ti.resetReceivedDT();
		commitTransaction;
		
		if count = 5000 then
			break;
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
