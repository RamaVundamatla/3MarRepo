    <JadeMethod name="changeOption" id="d5cfcdb9-3a9a-4613-8213-ed88899ac710">
        <updating/>
        <source>changeOption() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2013	cnwndl1	Initial creation

*/

vars

begin

	if self.optNewBB.value then
		self.lblSuffix.visible := false;
		self.txtSuffix.visible := false;
		self.txtSuffix.text := null;
		self.txtNewCargoId.text := self.lblNewCargoId.caption;
		self.lblOptBB.enabled := true;
		self.lblOptPieceBB.enabled := false;
		
	else
		self.lblSuffix.visible := true;
		self.txtSuffix.visible := true;
		
		if self.myTrackedItem &lt;&gt; null then
			self.txtNewCargoId.text := self.myTrackedItem.id &amp; "-";
		else
			self.txtNewCargoId.text := self.lblNewCargoId.caption;
		endif;
		self.lblOptBB.enabled := false;
		self.lblOptPieceBB.enabled := true;
		
	endif;
	
	self.resetExample();
	
epilog

end;</source>
    </JadeMethod>
