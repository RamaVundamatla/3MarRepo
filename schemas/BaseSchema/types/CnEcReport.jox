    <JadeMethod name="doPrint" id="908d3451-189b-4dc1-b2b2-ab99224ef74f">
        <updating/>
        <source>doPrint(pPrintFrameObj:Frame input; pErrorMessage:String output):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		24 July 2000 by cnwdad1
//
// Purpose:		Use this method to print a frame and return any resulting error
//				message from the request.
//
// Parameters:	pPrintFrameObj - The frame to be printed.
//				pErrorMessage - An error message if the requst was unsuccessful.
//
// Returns:		True if the print was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	printResult	: Integer;

begin
	printResult	:=	self.aMyPrinter.print(pPrintFrameObj);

	if printResult = Print_Successful then
		return true;
	else
		return self.getPrintResult(printResult, pErrorMessage);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pPrintFrameObj" type="Frame" usage="input"/>
        <Parameter name="pErrorMessage" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doValidateParameterValues" id="20151015-4bee-4ec5-8f73-4f6294931e34">
        <updating/>
        <source>doValidateParameterValues(pParameterCollObj:CnEcReportParameterValueDict; pErrorMessage:String output):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		24 July 2000 by cnwdad1
//
// Purpose:		This method is to be reimplemented for each report form to validate
//				report parameter values and return true if report parameters pass
//				the validation.
//
// Parameters:	pParameterCollObj - The collection of parameters.
//				pErrorMessage - The error message if any of the parameters fail validation.
//
// Returns:		True if the parameters are valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	parameterValueObj	: CnEcReportParameterValue;

begin
	return true;		// Default implementation.
	
	// The following is an example and should be reimplemented accordingly.
	
	foreach parameterValueObj in pParameterCollObj do
		if (parameterValueObj.myReportParameter.parameterName = "&lt;parameter name 1&gt;"
		and parameterValueObj.stringValue = null)
		then
			pErrorMessage	:=	"where's my parameter value ?";
			return false;
		elseif (parameterValueObj.myReportParameter.parameterName = "&lt;parameter name 2&gt;"
		and parameterValueObj.myObjectValue = null)
		then
			pErrorMessage	:=	"where's my object parameter ?";
			return false;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pParameterCollObj" type="CnEcReportParameterValueDict"/>
        <Parameter name="pErrorMessage" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCurrentimeStamp" id="bf2104e3-b4ea-4854-949e-ba63d8bccd99">
        <source>getCurrentimeStamp():TimeStamp protected;
// --------------------------------------------------------------------------------
// Created:		23 July 2000 by cnwdad1
//
// Purpose:		Returns the receiver's current timestamp value.
//
// Parameters:	None
//
// Returns:		The receiver's timestamp value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.aCurrentTimeStamp;
end;</source>
        <access>protected</access>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDefaultParameterValue" id="0ed98ad9-3246-4a76-a86c-0c847cf2f07d">
        <updating/>
        <source>getDefaultParameterValue(pParameterObj:CnEcReportParameter; pParameterCollObj:CnEcReportParameterValueDict):String updating;
// --------------------------------------------------------------------------------
// Created:		24 July 2000 by cnwdad1
//
// Purpose:		Returns a default value for report parameter, and is to be
//				reimplemented for each report form.
//
// Parameters:	pParameterObj - The parameter whose default to return.
//				pParameterCollObj - A collection of the parameter values.
//
// Returns:		The default value for the requested report parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 31/07/2003	cnwdad1		Changed from using BaseSchema method to fetch a timestamp
//							from the server to use a native method.
// --------------------------------------------------------------------------------
/*

*/
vars
	timeStamp	: TimeStamp;

begin
	// Default implementation (returns current date/time)
	timeStamp	:=	app.actualTimeServer();	//global.cnEcGetServerTimeStamp();

	if (pParameterObj.parameterType = "Date") then
		return timeStamp.date.String;
	elseif (pParameterObj.parameterType = "Time") then
		return timeStamp.time.String;
	elseif (pParameterObj.parameterType = "TimeStamp") then
		return timeStamp.String;
	endif;

	return null;
end;</source>
        <Parameter name="pParameterObj" type="CnEcReportParameter"/>
        <Parameter name="pParameterCollObj" type="CnEcReportParameterValueDict"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getParameterClassValues" id="39530261-6b70-42ae-a888-457fbbc34fdd">
        <updating/>
        <source>getParameterClassValues(pParameterObj:CnEcReportParameter; pParameterCollObj:CnEcReportParameterValueDict):Collection updating;
// --------------------------------------------------------------------------------
// Created:		24 July 2000 by cnwdad1
//
// Purpose:		Returns a collection of parameter value pick list entries.  This
//				method should be reimplemented for each report form subclass.
//
// Parameters:	pParameterObj - The parameter whose values to get.
//				pParameterCollObj - Contains all parameter values that have been
//					entered.  This can be used if a value pick list for the current
//					parameter depends on the values that have already been entered/
//					selected for other parameters.
//
// Returns:		A collection of values, or null is the values could not be obtained.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pParameterObj.isPrimitiveType() then
		return null;
	else
		// Default implementation (returns all instances of the class !).

		return currentSchema.getClass(pParameterObj.parameterType).instances;

//		// Reimplemented code may look something like the following:
//
//		if pParameter.parameterType = "User" then
//			return app.myRoot.allUsers;
//		elseif pParameter.parameterType = "Company" then
//			return app.myRoot.allCompanies;
//		else
//			return currentSchema.getClass(pParameter.parameterType).instances;
//		endif;
	endif;
end;</source>
        <Parameter name="pParameterObj" type="CnEcReportParameter"/>
        <Parameter name="pParameterCollObj" type="CnEcReportParameterValueDict"/>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="getPrintResult" id="67b0b865-78b1-4f27-919d-a96c177c75d2">
        <source>getPrintResult(pPrintResult:Integer; pResultMessage:String output):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		24 July 2000 by cnwdad1
//
// Purpose:		Returns the message of a print result in the output parameter "pResultMessage".
//
// Parameters:	pPrintResult (Integer) - The result of the last print statement.
//				pResultMessage (String) - The message corresponding to the print result.
//
// Returns:		A boolean flag to indicate whether printing is to be aborted.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (pPrintResult = Print_Successful) then
		pResultMessage	:=	$CNEC_PRINT_SUCCESSFUL;
		return false;
	elseif (pPrintResult = Print_Invalid_Control) then
		pResultMessage	:=	$CNEC_PRINT_INVALID_CONTROL;
		return true;
	elseif (pPrintResult = Print_NewPage_Failed) then
		pResultMessage	:=	$CNEC_PRINT_NEWPAGE_FAILED;
		return true;
	elseif (pPrintResult = Print_Printer_Not_Open) then
		pResultMessage	:=	$CNEC_PRINT_PRINTER_NOT_OPEN;
		return true;
	elseif (pPrintResult = Print_TextOut_Error) then
		pResultMessage	:=	$CNEC_PRINT_TEXTOUT_ERROR;
		return true;
	elseif (pPrintResult = Print_Printer_Open_Failed) then
		pResultMessage	:=	$CNEC_PRINT_PRINTER_OPEN_FAILED;
		return true;
	elseif (pPrintResult = Print_Header_Footer_Too_Large) then
		pResultMessage	:=	$CNEC_PRINT_HEADER_FOOTER_TOO_L;
		return true;
	elseif (pPrintResult = Print_Frame_Too_Large) then
		pResultMessage	:=	$CNEC_PRINT_FRAME_TOO_LARGE;
		return true;
	elseif (pPrintResult = Print_Preview_Ignored) then
		pResultMessage	:=	$CNEC_PRINT_PREVIEW_IGNORED;
		return false;
	elseif (pPrintResult = Print_Copies_Ignored) then
		pResultMessage	:=	$CNEC_PRINT_COPIES_IGNORED;
		return false;
	elseif (pPrintResult = Print_Orientation_Invalid) then
		pResultMessage	:=	$CNEC_PRINT_ORIENTATION_INVALID;
		return true;
	elseif (pPrintResult = Print_Currently_Open) then
		pResultMessage	:=	$CNEC_PRINT_CURRENTLY_OPEN;
		return true;
	elseif (pPrintResult = Print_Failed_To_Obtain_Printer) then
		pResultMessage	:=	$CNEC_PRINT_FAILED_TO_OBTAIN_PR;
		return true;
	elseif (pPrintResult = Print_Cancelled) then
		pResultMessage	:=	$CNEC_PRINT_CANCELLED;
		return true;
	elseif (pPrintResult = Print_Stopped) then
		pResultMessage	:=	$CNEC_PRINT_STOPPED;
		return true;
	elseif (pPrintResult = Print_Not_Available) then
		pResultMessage	:=	$CNEC_PRINT_NOT_AVAILABLE;
		return true;
	else
		pResultMessage	:=	$CNEC_PRINT_UNKNOWN_VALUE(pPrintResult.String);
		return true;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pPrintResult" type="Integer"/>
        <Parameter name="pResultMessage" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isParameterRequired" id="1eac60b4-2467-4e2a-b944-a02047ccc1bb">
        <source>isParameterRequired(pParameterName:String):Boolean;
// --------------------------------------------------------------------------------
// Created:		24 July 2000 by cnwdad1
//
// Purpose:		Returns a flag to indicate whether the requested parameter is
//				mandatory.  The intention is that this method should be
//				reimplemented on report subclasses to enforce the rules that
//				apply to the subclass.
//
// Parameters:	pParameterName (String) - The name of the parameter.
//
// Returns:		True if the parameter must be provided, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return false;
end;</source>
        <Parameter name="pParameterName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="printFinish" id="ddc08e9a-250a-4590-baf4-1edd39866f5a">
        <source>printFinish():Integer protected;
// --------------------------------------------------------------------------------
// Created:		09 August 2000 by cnwdad1
//
// Purpose:		Closes the printer and any print-files.  If this method is not
//				called after printing is done, then the output will never be
//				produced.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aMyPrinter &lt;&gt; null then
		if self.aMyPrinter.myFile &lt;&gt; null then
			// Close the "print-to-file" file.
			self.aMyPrinter.myFile.close();
		endif;

		self.aMyPrinter.close();
	endif;
	
	return CNEC_REPORT_PRINTED;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="printReport" id="06f264b2-483a-4b38-a050-e37db3d91fc3">
        <updating/>
        <source>printReport(pQueueEntryObj:CnEcReportQueueEntry; pIsPreview:Boolean; pErrorMessage:String output):Integer updating;
// --------------------------------------------------------------------------------
// Created:		23 July 2000 by cnwdad1
//
// Purpose:		This method is to be reimplemented for each report form to do the
//				actual printing and return the print result/status code:
//
//					CNEC_REPORT_ERROR	- if an error occured
//					CNEC_REPORT_PRINTED	- if printed OK
//
//				The reason for any errors should be returned in the output
//				parameter of "pErrorMessage".
//
//					************************************************
//					* The printer object "self.aMyPrinter" must be *
//					* used instead of the "app.printer" object.    *
//					************************************************
//
// Parameters:	pQueueEntryObj - The print job request object.
//				pIsPreview - A flag to indicate whether to enable print-preview.
//				pErrorMessage - A message if the print request fails.
//
// Returns:		The (return) value of the print result.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	printerName	: String;
	printResult	: Integer;
	printFile	: File;

begin
	// First, validate the report parameters.
	
	if not self.doValidateParameterValues(pQueueEntryObj.allReportParameterValues, pErrorMessage) then
		return CNEC_REPORT_ERROR;
	endif;

	// Set printer object properties.
	
	printerName	:=	pQueueEntryObj.printerName;
	printResult	:=	self.aMyPrinter.setPrinter(printerName);

	if (not printResult = Print_Successful) then
		if self.getPrintResult(printResult, pErrorMessage) then
			return CNEC_REPORT_ERROR;
		endif;
	endif;

	self.aMyPrinter.copies			:=	pQueueEntryObj.copies;
	self.aMyPrinter.topOfPage		:=	pQueueEntryObj.myReportDefinition.marginTop;
	self.aMyPrinter.bottomOfPage	:=	pQueueEntryObj.myReportDefinition.marginBottom;
	self.aMyPrinter.leftMargin		:=	pQueueEntryObj.myReportDefinition.marginLeft;
	self.aMyPrinter.rightMargin		:=	pQueueEntryObj.myReportDefinition.marginRight;	
	self.aMyPrinter.orientation		:=	pQueueEntryObj.myReportDefinition.orientation;
	self.aMyPrinter.documentType	:=	pQueueEntryObj.myReportDefinition.paperSize;
	self.aMyPrinter.printPreview	:=	pIsPreview;

	if (pIsPreview) then
		self.aMyPrinter.suppressDialog	:=	false;
	else
		self.aMyPrinter.suppressDialog	:=	true;
	endif;

	if (pQueueEntryObj.isPrintToFile) then
		create printFile;
		printFile.openOutput(pQueueEntryObj.destination);
		self.aMyPrinter.setFile(printFile);
	endif;

	return CNEC_REPORT_PRINTED;		// i.e. initialization completed.
end;</source>
        <Parameter name="pQueueEntryObj" type="CnEcReportQueueEntry"/>
        <Parameter name="pIsPreview" type="Boolean"/>
        <Parameter name="pErrorMessage" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setCurrentTimeStamp" id="0a350d19-9dd3-4a7b-96fc-fc2f129845c7">
        <updating/>
        <source>setCurrentTimeStamp() updating, protected;
// --------------------------------------------------------------------------------
// Created:		23 July 2000 by cnwdad1
//
// Purpose:		Set the current tomestamp value of the server node.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aCurrentTimeStamp	:=	app.actualTimeServer();	//global.cnEcGetServerTimeStamp();
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
