<Class name="CMQF_LogTransaction">
    <JadeMethod name="setFromAgent" id="f04a2164-cf70-4d3d-ac3a-c764948019bc">
        <updating/>
        <source>setFromAgent(_agent : CMUI_ReportAgent input) updating;
// ---------------------------------------------------------------------------
// Created:     04 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tmpCarrier	: CM_Carrier;
	tmpOperator	: CM_Operator;
begin
	inheritMethod(_agent);
	
	_agent.getSelectedTxnType(self.transType, self.transTypeStr);
	
	self.loggingOrganisation := _agent.getValueByNameIfVisible(ETRow_LoggingOrganisation).String;
	self.gangNumber := _agent.getValueByNameIfVisible(ETRow_GangNumber).String;
	
	if _agent.isRowIncluded(ETRow_CarrierCode) then
		tmpCarrier := _agent.getSelectedCarrier();
		if tmpCarrier &lt;&gt; null then
			self.carrierCode := tmpCarrier.code;
		endif;
	endif;
	
	self.operatorCode 	:= _agent.getSelectedOperatorCode();
	self.speciesCode	:= _agent.getSelectedLogSpeciesCode();
	self.gradeCode		:= _agent.getSelectedLogGradeCode();
	self.typeCode		:= _agent.getSelectedLogTypeCode();
	self.treatmentCode	:= _agent.getSelectedLogTreatmentCode();
	self.lengthCode		:= _agent.getSelectedLogLengthCode();
	self.sourceLocation := _agent.getSelectedSrcLocationCode();
	self.sourceSubLocation := _agent.getSelectedSrcSubLocationCode();
	self.sourceSubSubLocation := _agent.getSelectedSrcSubSubLocnCode();
	
end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
