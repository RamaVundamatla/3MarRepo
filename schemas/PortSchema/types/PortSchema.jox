    <JadeMethod name="remoteErrorWarningToAlert" id="aec8f60e-dfea-4548-8089-39d2a4e8683b">
        <updating/>
        <source>remoteErrorWarningToAlert(_details : String; _remoteDataHdr : CM_RemoteDataHdr; 
				_errorSet : CM_ErrorSet; _allExtraDetail : StringArray; _sendEmail, _sendMsg : Boolean) updating;


vars
	err			: CM_Error;
	alert		: CM_SystemAlert;
	extraDetail,
	emailTo,
	emailSubject,
	emailBody,
	emailFrom	: String;
begin
	
	create alert;
	alert.details := _details;
	alert.setSeverity(SEVERE_ERROR);
	if _errorSet &lt;&gt; null then
		foreach err in _errorSet do
			extraDetail := '(' &amp;err.errorCode.String &amp; ') ' &amp; err.text;
			emailBody := emailBody &amp; extraDetail &amp; CrLf;
			alert.addLogEntry(extraDetail);
		endforeach;
	endif;
	
	if _allExtraDetail &lt;&gt; null then
		foreach extraDetail in _allExtraDetail do	
			alert.addLogEntry(extraDetail);
			emailBody := emailBody &amp; extraDetail &amp; CrLf;
		endforeach;
	endif;

	if emailBody = null then
		emailBody := _details;
	endif;
	
	alert.setMyRemoteDataHdr(_remoteDataHdr);

	alert.add;
	self.commitAlert();
	if _sendMsg then
		self.sendMessageToUsers(_details, _allExtraDetail); 
	endif;
	if _sendEmail then
		emailTo	:= app.myRoot.getConfig(AutoSupportEmailAddress).String;
		emailFrom := app.myRoot.getConfig(AutoSendersEmailAddress).String;
		if emailTo &lt;&gt; null and emailFrom &lt;&gt; null then	//18 Jun 2021	NDL	TFS 50119
			app.myTrxCA.trxCreateEmailSendRequest(app.getErrorString(BGP_Processing),emailTo, emailFrom, null, null, _details,
													emailBody, null, null, null, null, EmailSource_System,null, app.myPassport);
		endif;
	endif;

end;</source>
        <Parameter name="_details" type="String"/>
        <Parameter name="_remoteDataHdr" type="CM_RemoteDataHdr"/>
        <Parameter name="_errorSet" type="CM_ErrorSet"/>
        <Parameter name="_allExtraDetail" type="StringArray"/>
        <Parameter name="_sendEmail" type="Boolean"/>
        <Parameter name="_sendMsg" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeAutoYardAllocation" id="77dae574-74b5-4b88-ae31-0d2ecb984943">
        <updating/>
        <source>removeAutoYardAllocation(_terminalArea : CM_TerminalArea; _yardAllocation : CM_YardAllocation io) : Boolean updating;
// -------------------------------------------
// Created 20 September 2005 by cnwdvb1
// -------------------------------------------

vars

	agent 				: CM_YAAutoplanAgent;

begin
	
	if not self.checkYardAllocationLicensing(_terminalArea.myTerminal) then
	 	return null;
	endif;

	agent := self.myYAAgent;
	
	return agent.removeAutoYardAllocation(_terminalArea, _yardAllocation);

	
end;</source>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_yardAllocation" type="CM_YardAllocation" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeFile" id="417b75b4-6b09-4c10-84d6-9d8cb5c478c4">
        <source>removeFile(_fileName : String; _executeOnAppServer : Boolean) : Boolean;


/*

Purpose:			Remove the passed in filename from disk

Parameters:			Filename to remove

Return Value:		True if the file is removed


Date		Who		Reason
19 Jan 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
03 Dec 2020 jlgmd1	TFS 50459 - Allow deletion of files from app server too

*/

vars
	f 				: File;
	excOccurred		: Boolean;
	
begin
	create f transient;
	f.fileName := _fileName;
	if _executeOnAppServer then
		f.usePresentationFileSystem := false;
	endif;

	if f.isAvailable then
		on FileException do handleRemoveFileException(exception, _fileName, excOccurred);
		f.purge;
		on FileException do null;
		if f.isAvailable then
			app.writeLog("Delete of file " &amp; _fileName &amp; " failed", LogERROR);	//26 Nov 2019	NDL	TFS 47053
			return false;
		else
			app.writeLog("File " &amp; _fileName &amp; " deleted successfully", LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
			return true;
		endif;
	else
		app.writeLog("File " &amp; _fileName &amp; " not available to delete", LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
		return false;
	endif;


epilog
	delete f;
	
end;</source>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_executeOnAppServer" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
