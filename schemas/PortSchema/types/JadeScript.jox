                        }
                    ]
                },
                "eventHash": "D75E0AE5AF51BD7ED59EF7C488279FB2"
            }
        ]
    }
]';

	if jsonResponse[1:1] = CN_LEFT_BRACKET and jsonResponse[jsonResponse.length:1] = CN_RIGHT_BRACKET then
		jsonResponse := jsonResponse[2:jsonResponse.length() - 2];
	endif;
	write jsonResponse;

	create jsonHelper;
	str := jsonHelper.convertJsonToXML(jsonResponse);
	//write str;

	create xml;
	create xmlHelper;
	xmlHelper.tryParseToXMLDocument(str, xml);

	xmlElement := xml.rootElement.getElementByTagName("profileSecretId");
	if xmlElement &lt;&gt; null then
		secret := xmlElement.text();
	endif;
	write secret;

epilog
	delete jsonHelper;
	delete xmlHelper;
	delete xmlHelper;
end;</source>
