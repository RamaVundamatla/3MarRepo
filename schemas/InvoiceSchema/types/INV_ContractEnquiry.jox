    <JadeMethod name="doCmbBUBuild" id="99edc1c9-dd95-499d-92fd-ed91802605ff">
        <source>doCmbBUBuild(_combo : CMUI_ComboBox input);
/*
Purpose:			

Date		Who		Reason
13DEC2022	NAVAB1	TFS CR 55645 TASK 55662
*/

vars
	aTerm : CM_Terminal;
	company:  CM_Bank;
	failedDAC  :CM_DataAccessController;
begin
	_combo.clear;
	_combo.sorted := false;

	foreach company in self.myTerminal.companies do
		if company.isBusinessUnit then
			_combo.addItem(company.code);
			_combo.itemObject[_combo.newIndex] := company;
		endif;
	endforeach;

	if self.myCurrentBank &lt;&gt; null then
		_combo.listObject := self.myCurrentBank;
	else
		_combo.listIndex := 1;
	endif;

end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMsgDebtorBuild" id="437bc8ba-53d2-4ce5-8cbc-8f637b86c049">
        <source>doMsgDebtorBuild();
/*
Purpose:			

Date		Who		Reason
13 December 2022	navab1	TFS CR 55645 TASK 55662
*/

vars
	debtors : CM_DebtorSet;
	debtorTerminal : CM_DebtorTerminal;
	dr : CM_Debtor;
begin
	
	create debtors transient;
	// CR #55652 Task 57014: UI - Contract Copy UI
	foreach debtorTerminal in self.myTerminal.allDebtorTerminals discreteLock do
		dr := debtorTerminal.myDebtor;
		debtors.add(dr);
	endforeach;
	
	self.msgDebtors.myAvailableListBox.sorted 	:= true;
	self.msgDebtors.mySelectedListBox.sorted 	:= true;
	self.msgDebtors.setupControl(null, debtors, INV_InvTypeSurchargeExemptions::getDebtorsDescription.name);
	self.msgDebtors.availableHeading	:= app.getErrorString(Available);
	self.msgDebtors.selectedHeading	:= app.getErrorString(Selected);
	self.msgDebtors.myBaseForm	:= self;
	self.msgDebtors.setSelected(null);

epilog
	delete debtors;
end;</source>
