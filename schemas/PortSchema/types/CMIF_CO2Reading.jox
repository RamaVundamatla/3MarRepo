<Class name="CMIF_CO2Reading" id="d6e78187-ffa8-43b2-ac5c-7db0c21fb8e8">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="tempreading"/>
    <PrimAttribute name="co2" id="fcfff387-8fbe-4c5d-9185-248ef4acc5d8">
        <precision>6</precision>
        <scaleFactor>2</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <PrimAttribute name="dateTime" id="cdec37d4-bda4-4978-8892-989951e690d8">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myTerminal" id="19b7b98a-36b0-4eec-bc9f-936a3b1cd6a6">
        <embedded/>
        <type name="CM_Terminal"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTrackedItem" id="e807a78f-563a-4231-b2ee-2e8b57a7e369">
        <embedded/>
        <type name="CM_TrackedItem"/>
    </ImplicitInverseRef>
    <PrimAttribute name="noCharge" id="52e4a5d8-72df-41ce-8b12-74b3ec5c542c">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="userId" id="341f3509-85ae-4aec-a0c4-7ea2ce872f57">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="initialise" id="f0edd7e2-e1f7-4329-a994-ee456485ab92">
        <updating/>
        <source>initialise(	_ti : CM_TrackedItem;
			_terminal : CM_Terminal;
			_readingTime : TimeStamp;
			_reading : Decimal;
			_noCharge : Boolean;
			_user : String	) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12/12/2025	navdap1		Initial creation MTN-36569 CPL | Reefer Runner Integration
//
vars

begin
	self.co2 := _reading;
	self.dateTime := _readingTime;
	self.noCharge := _noCharge;
	self.userId := _user;
	
	self.myTerminal := _terminal;
	self.myTrackedItem := _ti;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_readingTime" type="TimeStamp"/>
        <Parameter name="_reading" type="Decimal"/>
        <Parameter name="_noCharge" type="Boolean"/>
        <Parameter name="_user" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTITransController" id="7cac594c-42cf-499c-b167-cd74ad2fe320">
        <source>setTITransController(_tiTransController: CMIF_TITransactionController input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/12/2025	navdap1		Initial creation MTN-36569 CPL | Reefer Runner Integration
//
vars

begin
	_tiTransController.userGenerated 	:= false;
	_tiTransController.userId 			:= self.userId;
	_tiTransController.noCharge 		:= self.noCharge;
	_tiTransController.myTrackedItem 	:= self.myTrackedItem;
	_tiTransController.type 			:= TRANS_TYPE_CO2READING;
	_tiTransController.dateTime 		:= self.dateTime;
epilog

end;</source>
        <Parameter name="_tiTransController" type="CMIF_TITransactionController" usage="input"/>
    </JadeMethod>
</Class>
