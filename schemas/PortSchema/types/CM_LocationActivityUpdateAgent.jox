<Class name="CM_LocationActivityUpdateAgent" id="31822315-4e15-4a92-aecc-1fe61d495748">
    <superclass name="CM_Agent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="allPreviousTTerminalAreas" id="0281e47c-2ada-4308-b0bd-1e87ae181ce2">
        <memberTypeInverse/>
        <type name="CM_TerminalAreaMasterSet"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allTerminalAreas" id="fb7c8779-8614-4e61-a422-46ae9abef2b8">
        <memberTypeInverse/>
        <type name="CM_TerminalAreaMasterSet"/>
        <access>readonly</access>
    </ImplicitInverseRef>
