<Class name="CM_ROROLaneDefnVessel" id="e050e0fd-0982-4d90-ac85-ccefd4685cf9">
    <superclass name="CM_ROROLaneDefn"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="vesselStructures"/>
    <ExplicitInverseRef name="myROROStructure" id="dab21b1f-d03f-4a8c-bbbb-7986e83882e3">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_ROROVesselStructure"/>
        <access>readonly</access>
        <Inverse name="CM_ROROVesselStructure::allROROLaneDefnByCode"/>
        <Inverse name="CM_ROROVesselStructure::allROROLaneDefnByOrdinal"/>
