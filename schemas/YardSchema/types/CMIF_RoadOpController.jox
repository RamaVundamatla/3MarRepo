    <JadeMethod name="buildDockBars" id="4b270c48-52b1-4383-bfd6-c98d3d3a8c01">
        <source>buildDockBars()protected;

vars
	i : Integer;
	obj : Object;
	dockBar : JadeDockBar;
	control , clonedControl : Control;
	controlArray : CnEcControlArray;
	y: String;
	allObjects : CMIF_RoadOpObjects;
	roadOpObj : CMIF_RoadOpObject;
begin
	create controlArray transient;
	myBaseDockBar.cnEcGetAllChildControls(controlArray, true);
	i:=1;
	
	create allObjects transient;
	self.getAllRoadOpObjectsByDockOrder(allObjects);
	
	
	foreach roadOpObj in allObjects reversed, discreteLock  do
		dockBar:=null;		
		if dockBar = null then
			dockBar:=myBaseDockBar.loadControl(roadOpObj.getDockOrder).JadeDockBar;			
			//self.allDockBars[roadOpObj.getDockOrder]:=dockBar;
			roadOpObj.setMyDockBar(dockBar);
			self.allDockBars.add(dockBar);
			dockBar.parent:=self.myBaseDockContainer;
			foreach control in controlArray where control.parent = myBaseDockBar do
					clonedControl:=null;
					// index equals index of allDockBars which points to an object and the control.tabIndex
					clonedControl:=control.loadControl((roadOpObj.getDockOrder.String &amp; control.tabIndex.String).Integer);
					clonedControl.parent:=dockBar;
					clonedControl.parentBottomOffset:=0;
					clonedControl.parentRightOffset:=0;
					clonedControl.visible:=true;
			endforeach;
		
		endif;
		dockBar.userObject:=roadOpObj;
	endforeach;
	
	self.getTilePlan();
	
epilog
	delete controlArray;
	delete allObjects;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="changeProceedOptionsEnabled" id="013169e5-5b02-462c-8299-7a565452a717">
        <source>changeProceedOptionsEnabled()protected;
/*
Purpose:			
Return Value:		

Date				Who		Reason
04 September 2006	cnwer1	Initial creation - PAR#xxxx
02/09/2009			cnwcs5	ccms 1061 - remove old VTA code
*/
vars
	obj: CMIF_RoadOpObject;
begin
	// change Yard process options (to outward gate lanes)
	obj := self.allCMIFRoadOpObjects[RoadOpsForm_Yard];

	if obj &lt;&gt; null then
		obj.changeProceedOptionsEnabled;
	endif;
	
	// change pre-gate proceed options - to inward gate lanes
	obj := self.allCMIFRoadOpObjects[RoadOpsForm_PreGate];
	
	if obj &lt;&gt; null then
		obj.changeProceedOptionsEnabled;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="changeTerminalAreas" id="8b2d6ddc-e20f-423e-b201-605a2812aa01">
        <updating/>
        <source>changeTerminalAreas(_gates :CM_GateArray; _areas :CM_TerminalAreaArray; _operators:CM_OperatorArray)updating;
// ---------------------------------------------------------------------------
// Created:     24 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//10/06/2022 	navhl20 TFS 53058 MTN - Job List in Road Operations screen not filtered out by Gate
// ---------------------------------------------------------------------------
vars

begin
	self.allGates.clear;			_gates.copy (self.allGates);
	self.allInterchangeAreas.clear;	_areas.copy (self.allInterchangeAreas);
	self.allOperators.clear;	_operators.copy (self.allOperators);		//10/06/2022 	navhl20 TFS 53058 
	
	self.loadAreaTables;
epilog

end;</source>
        <Parameter name="_gates" type="CM_GateArray"/>
        <Parameter name="_areas" type="CM_TerminalAreaArray"/>
        <Parameter name="_operators" type="CM_OperatorArray"/>
    </JadeMethod>
