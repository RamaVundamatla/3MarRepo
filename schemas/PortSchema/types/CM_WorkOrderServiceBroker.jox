/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 June 2018	jlgab1	Initial creation

*/

vars

begin
	return app.myRoot.allTransactionTypes[self.workOrderType].description;
// TFS 39236	return app.getWorkOrderTransactionStr(self.workOrderType);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
