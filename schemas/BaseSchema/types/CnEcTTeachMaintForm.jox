    <JadeMethod name="chkDoStartup_click" id="433bc1e7-400e-4293-9092-100163523454">
        <controlMethod name="CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkDoStartup_click(checkbox: CheckBox input) updating;

begin
	if checkbox.value then
		picPlinthStartup1.enabled := true;
	else
		chkCheckIsEnabled.value := false;
		chkCheckIsVisible.value := false;
		chkCheckHasAValue.value := false;
		picPlinthStartup1.enabled := false;
	endif;
end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="chkStopOnError_click" id="2f813037-242d-49d1-87f8-42ffee7cc313">
        <controlMethod name="CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkStopOnError_click(checkbox: CheckBox input) updating;

begin
	chkActionOnError.enabled := not checkbox.value;
end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doActivityDisplayAvailable" id="499a1b87-829a-41e0-8bb5-553e3d65d0f0">
        <source>doActivityDisplayAvailable(pTheLesson : CnEcTLesson);

vars
	theObject	: Object;
	activity	: CnEcTActivity;
	
begin
	lstActivities.clear();

	if pTheLesson &lt;&gt; null then
		foreach theObject in pTheLesson.allActivities do
			activity := theObject.CnEcTActivity;
			lstActivities.itemObject[lstActivities.addItem(activity.name)] := activity;
		endforeach;

		lstActivities.listIndex := lstActivities.findObject(self.aMyActivity);
	endif;
end;</source>
        <Parameter name="pTheLesson" type="CnEcTLesson"/>
    </JadeMethod>
    <JadeMethod name="doActivityDisplayDetail" id="6e5d1e4e-a4d7-46ef-83e1-7de58846b9d5">
        <updating/>
        <source>doActivityDisplayDetail() updating;

vars
	activity	: CnEcTActivity;
	object		: Object;

begin
	activity := lstActivities.listObject.CnEcTActivity;

	if activity = null then
		return;
	endif;

	if lstActivities.listIndex &gt; 1 then
		btnMoveActivity1.enabled := true;
	endif;

	self.aMyActivity := activity;

	txtActivityName.text	 	:= activity.name;
	txtAction.text 				:= activity.action;
	txtText.text 				:= activity.text;
	txtTextAfter.text 			:= activity.afterText;
	txtTextError.text 			:= activity.errorText;
	chkUseCurrentValu.value		:= activity.useExistingValue;
	chkStopOnError.value 		:= activity.onErrorStop;
	chkActionOnError.value 		:= activity.onErrorDoAction;
	chkActionOnError.enabled 	:= (not activity.onErrorStop);
	picPlinthActivity.visible	:= true;
	picPlinthLesson.visible		:= false;

	if activity.controlName.length() &gt; 0 then
		lstControl.listIndex := lstControl.findString(1, activity.controlName);
	else
		lstControl.listIndex := lstControl.findString(1, self.NO_LIST_ENTRY);
	endif;

	if activity.afterControlName.length &gt; 0 then
		lstControlAfter.listIndex := lstControlAfter.findString(1, activity.afterControlName);
	else
		lstControlAfter.listIndex := lstControlAfter.findString(1, self.NO_LIST_ENTRY);
	endif;

	self.doPreviewText(true);
	txtActivityName.setFocus();
end;</source>
    </JadeMethod>
    <JadeMethod name="doActivityRemove" id="3b984aef-0593-49d5-9652-cf2912fd1b40">
        <updating/>
        <source>doActivityRemove() updating, protected;

begin
	if self.aMyActivity &lt;&gt; null then
		self.aError	:=	self.aMyTA.trxTActivityDelete(self.aMyActivity);
		self.doActivityDisplayAvailable(self.aMyLesson);
		btnMoveActivity1.enabled := false;		
	endif;

	self.miscClearActivityFields();
	self.doPreviewText(true);
	txtActivityName.setFocus();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doActivitySave" id="846187e7-b7c8-4d80-84ab-88d7147db88a">
        <updating/>
        <source>doActivitySave():Boolean updating, protected;

vars
	action				: String;
	afterControlName	: String;
	afterText			: String;
	controlName			: String;
	errorText			: String;
	theLesson		 	: CnEcTLesson;
	activityName		: String;
	isOnErrorDoAction 	: Boolean;
	isOnErrorStop		: Boolean;
	isUseExistingValue	: Boolean;
	activityText		: String;

begin
	controlName 			:= lstControl.text;
	
	if controlName = self.NO_LIST_ENTRY then
		controlName 		:= "";
	endif;

	afterControlName 		:= lstControlAfter.text;
	if afterControlName = self.NO_LIST_ENTRY then
		afterControlName	:= "";
	endif;

	action					:= txtAction.text;
	afterText				:= txtTextAfter.text;
	errorText				:= txtTextError.text;
	theLesson		 		:= aMyLesson;
	activityName			:= txtActivityName.text;
	isOnErrorDoAction 		:= chkActionOnError.value;
	isOnErrorStop			:= chkStopOnError.value;
	isUseExistingValue		:= chkUseCurrentValu.value;
	activityText	 		:= txtText.text;


	// do the save...

	if self.aMyActivity = null then
		self.aError	:=	self.aMyTA.valTActivityCreate(	action,
														afterControlName,
														afterText,
														controlName,
														errorText,
														theLesson,
														activityName,
														isOnErrorDoAction,
														isOnErrorStop,
														isUseExistingValue,
														activityText);

		if self.aError = null then
		self.aError	:=	self.aMyTA.trxTActivityCreate(	action,
														afterControlName,
														afterText,
														controlName,
														errorText,
														theLesson,
														activityName,
														isOnErrorDoAction,
														isOnErrorStop,
														isUseExistingValue,
														activityText,
														self.aMyActivity);
		endif;
	else
		self.aError	:=	self.aMyTA.valTActivityUpdate	(	self.aMyActivity,
															self.aObjectEdition,
															action,
															afterControlName,
															afterText,
															controlName,
															errorText,
															theLesson,
															activityName,
															isOnErrorDoAction,
															isOnErrorStop,
															isUseExistingValue,
															activityText);


		if self.aError = null then
			self.aError	:=	self.aMyTA.trxTActivityUpdate(	self.aMyActivity,
															self.aObjectEdition,
															action,
															afterControlName,
															afterText,
															controlName,
															errorText,
															theLesson,
															activityName,
															isOnErrorDoAction,
															isOnErrorStop,
															isUseExistingValue,
															activityText);

		endif;
	endif;
epilog
	return self.doShowError();
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDisplayRules" id="a5f24a6a-aff8-418b-a67d-0519381053b8">
        <source>doDisplayRules();
//	Displays rules (action) for the control types, as implemented in CnEcTTeachShow::doAction
//
//	ListBox						: integer	- selects the nth item in the list (or last one if greater)
//								: string	- finds the first match for the string
//	ComboBox					: integer	- selects the nth item in the list (or last one if greater)
//								: "string	- enters the string (may or may not match)
//								: string	- finds the first match for the string
//	TextBox						: any		- sets textbox to the value if non-blank
//	OptionButton				: any		- sets the optionbutton if non-blank
//	CheckBox					: "true"	- sets the checkbox
//								: "false"	- unsets the checkbox
//								: else		- changes the checkbox setting if non-blank
//	Button, JadeJuiceControl	: any		- clicks the button if non-blank
//	Table						: integer	- clicks row in table
begin
	txtRules.text := "List/Combo: integer - select in list" &amp; CrLf &amp;
					 "            string - find first match" &amp; CrLf &amp;
					 'Combo (only): "string - set to string' &amp; CrLf &amp;
 					 "Textbox: any - set to value" &amp; CrLf &amp;
					 "Option: any - set if non-blank" &amp; CrLf &amp;
					 'Checkbox: "true" - set' &amp; CrLf &amp;
					 '          "false" - unset' &amp; CrLf &amp;
					 "          else - change checkbox" &amp; CrLf &amp;
					 "Button: any - click if non-blank" &amp; CrLf &amp;
					 "Table: integer - click row";
end;</source>
    </JadeMethod>
    <JadeMethod name="doLessonDisplayAvailable" id="083d5cbb-f5bc-4bf5-b315-2e4502d43ea5">
        <updating/>
        <source>doLessonDisplayAvailable(pSelectedObject : CnEcTLesson)updating;

vars
	theLesson	: CnEcTLesson;
	
begin
	//clear the listboxes
	lstLessons.clear();
	lstNextLesson.clear();

	//populate the listbox
	foreach theLesson in app.myBaseRoot.allTLessons do
		lstLessons.itemObject[lstLessons.addItem(theLesson.getName)]		:=	theLesson;
		lstNextLesson.itemObject[lstNextLesson.addItem(theLesson.getName)]	:=	theLesson;
	endforeach;

	lstNextLesson.addItem(self.NO_LIST_ENTRY);

	//select the working item from the list (may be null for initial form load/deleted lessons
	lstLessons.listIndex := lstLessons.findObject(pSelectedObject);

	//load the lesson specific tab items
	self.doLessonDisplayDetail(pSelectedObject);
end;</source>
        <Parameter name="pSelectedObject" type="CnEcTLesson"/>
    </JadeMethod>
    <JadeMethod name="doLessonDisplayDetail" id="ec056675-ef04-4bd6-bade-9985e07b5ab1">
        <updating/>
        <source>doLessonDisplayDetail( lesson : CnEcTLesson )updating;

vars
	object		: Object;
	activity	: CnEcTActivity;
	index		: Integer;

begin
	lstActivities.clear();
	self.aMyActivity := null;
	self.miscPopulateControlsListbox(lesson);

	if lesson = null then
		txtLessonName.text 			:= "";
		lstForms.listIndex 			:= CNEC_NULL_INDEX;
		txtLessonText.text			:= "";
		lstLessons.listIndex 		:= CNEC_NULL_INDEX;
		lstStartupControl.listIndex := CNEC_NULL_INDEX;
		lstNextLesson.listIndex 	:= CNEC_NULL_INDEX;

		chkCheckIsEnabled.value 	:= false;
		chkCheckIsVisible.value 	:= false;
		chkCheckHasAValue.value 	:= false;

		chkIsEnabled.value 			:= true;
		chkIsVisible.value 			:= true;
		chkHasAValue.value 			:= false;

	else
		txtLessonName.text 		:= lesson.name;
		lstForms.listIndex 		:= lstForms.findString(1, lesson.formName);
		txtLessonText.text 		:= lesson.text;

//		write("'" &amp; lesson.nextLessonName &amp; "' " &amp; lbNextLesson.findString(1, lesson.nextLessonName).String);

		if lesson.nextLessonName.length &gt; 0 then
			lstNextLesson.listIndex := lstNextLesson.findString(1, lesson.nextLessonName);
		else
			lstNextLesson.listIndex := lstNextLesson.findString(1, self.NO_LIST_ENTRY);
		endif;

		chkCheckIsEnabled.value := lesson.checkControlEnabled;
		chkCheckIsVisible.value := lesson.checkControlVisible;
		chkCheckHasAValue.value := lesson.checkControlValue;

		chkIsEnabled.value 		:= lesson.controlIsEnabled;
		chkIsVisible.value 		:= lesson.controlIsVisible;
		chkHasAValue.value 		:= lesson.controlHasAValue;
		
		if lesson.controlName.length &gt; 0 then
			lstStartupControl.listIndex := lstStartupControl.findString( 1, lesson.controlName );
		else
			lstStartupControl.listIndex := CNEC_NULL_INDEX;
		endif;

		self.doActivityDisplayAvailable(lesson);
	endif;

	btnMoveActivity1.enabled := false;

	chkDoStartup.value 	:= chkCheckIsEnabled.value or chkCheckIsVisible.value or chkCheckHasAValue.value;
	picPlinthStartup1.enabled	:= chkDoStartup.value;
	chkIsEnabled.enabled 		:= chkCheckIsEnabled.value;
	chkIsVisible.enabled 		:= chkCheckIsVisible.value;
	chkHasAValue.enabled 		:= chkCheckHasAValue.value;

	self.miscClearActivityFields();
	self.doPreviewText(true);
	txtLessonName.setFocus();

	self.aMyLesson := lesson;
end;</source>
        <Parameter name="lesson" type="CnEcTLesson"/>
    </JadeMethod>
    <JadeMethod name="doLessonRemove" id="46144849-8932-4be8-b7fa-e296f7d360ff">
        <updating/>
        <source>doLessonRemove() updating, protected;

begin
	if self.aMyLesson &lt;&gt; null then
		self.aError	:=	self.aMyTA.trxTLessonDelete(self.aMyLesson);
		self.doLessonDisplayAvailable(null);
	else
		self.doLessonDisplayDetail(null);		
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLessonSave" id="4bc8e0db-a3d1-4b96-8ff1-b3ca36226ddf">
        <updating/>
        <source>doLessonSave():Boolean updating, protected;

vars
	lessonName 				: String;
	formName 				: String;
	nextLessonName 			: String;
	text 					: String;
	isCheckControlEnabled	: Boolean;
	isCheckControlValue		: Boolean;
	isCheckControlVisible	: Boolean;
	isControlHasAValue 		: Boolean;
	isControlEnabled 		: Boolean;
	isControlVisible 		: Boolean;
	controlName 			: String;
	logDirectory 			: String;
	nextLesson				: CnEcTLesson;
	
begin
	lessonName				:= txtLessonName.text;
	formName 				:= lstForms.text;
	text 					:= txtLessonText.text;
	isCheckControlEnabled	:= chkCheckIsEnabled.value;
	isCheckControlValue 	:= chkCheckHasAValue.value;
	isCheckControlVisible	:= chkCheckIsVisible.value;
	isControlHasAValue 		:= chkHasAValue.value;
	isControlEnabled 		:= chkCheckIsEnabled.value;
	isControlVisible 		:= chkIsVisible.value;
	controlName 			:= lstStartupControl.text;
	logDirectory 			:= txtLogDirectory.text.trimBlanks();

	nextLesson := lstNextLesson.listObject.CnEcTLesson;
	
	if nextLesson = null then
		nextLessonName := "";
	else
		nextLessonName := nextLesson.getName();
	endif;

	// do the save...

	if self.aMyLesson = null then
		self.aError	:=	self.aMyTA.valTLessonCreate(	lessonName,
														formName,
														nextLessonName,
														text,
														isCheckControlEnabled,
														isCheckControlValue,
														isCheckControlVisible,
														isControlHasAValue,
														isControlEnabled,
														isControlVisible,
														controlName,
														logDirectory);

		if self.aError = null then
			self.aError	:=	self.aMyTA.trxTLessonCreate(lessonName,
														formName,
														nextLessonName,
														text,
														isCheckControlEnabled,
														isCheckControlValue,
														isCheckControlVisible,
														isControlHasAValue,
														isControlEnabled,
														isControlVisible,
														controlName,
														logDirectory,
														self.aMyLesson);
		endif;
	else
		self.aError	:=	self.aMyTA.valTLessonUpdate	(	self.aMyLesson,
														self.aObjectEdition,
														lessonName,
														formName,
														nextLessonName,
														text,
														isCheckControlEnabled,
														isCheckControlValue,
														isCheckControlVisible,
														isControlHasAValue,
														isControlEnabled,
														isControlVisible,
														controlName,
														logDirectory);

		if self.aError = null then
			self.aError	:=	self.aMyTA.trxTLessonUpdate(self.aMyLesson,
														self.aObjectEdition,
														lessonName,
														formName,
														nextLessonName,
														text,
														isCheckControlEnabled,
														isCheckControlValue,
														isCheckControlVisible,
														isControlHasAValue,
														isControlEnabled,
														isControlVisible,
														controlName,
														logDirectory);

		endif;
	endif;
epilog
	return self.doShowError();
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doNewActivity" id="a0187974-36e0-4bd6-bb5b-a61c9d0b3ff8">
        <updating/>
        <source>doNewActivity()updating;

vars
	lesson	: CnEcTLesson;
begin
	lesson := lstLessons.listObject.CnEcTLesson;
	
	if lesson = null then
		app.msgBox("Please select a Lesson to run the new Activity against","Lesson Builder Error", MsgBox_OK_Only);
		return;
	endif;

	// clear fields and set up misc rights
	self.miscClearActivityFields();
	lstActivities.listIndex 	:= CNEC_NULL_INDEX;
	lstLessons.enabled 			:= false;
	lstActivities.enabled 		:= false;
	picPlinthPreview.visible	:= true;
	picPlinthLesson.visible		:= false;
	picPlinthActivity.visible 	:= true;

	lstControl.listIndex 		:= lstControlAfter.findString( 1, self.NO_LIST_ENTRY );
	lstControlAfter.listIndex 	:= lstControlAfter.findString( 1, self.NO_LIST_ENTRY );
	self.doPreviewText(true);
	txtActivityName.setFocus();

	// set the aMyActivity reference to null - used by save routine
	self.aMyActivity	:= null;
end;</source>
    </JadeMethod>
    <JadeMethod name="doNewLesson" id="9a3f7ccf-fd37-449d-add7-cfb8e4bb8130">
        <updating/>
        <source>doNewLesson() updating;

begin
	// initialize the lesson fields
	self.doLessonDisplayDetail( null );

	// setup misc rights
	lstLessons.enabled 			:= false;
	lstActivities.enabled 		:= false;
	picPlinthPreview.visible	:= true;
	picPlinthActivity.visible 	:= false;
	picPlinthLesson.visible 	:= true;

	// set focus and clear the preview window
	txtLessonName.setFocus();
	self.doPreviewText(true);

	// set the aMyLesson reference to null - used by save routine
	self.aMyLesson := null;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPreviewText" id="97f2885d-a30e-4855-ba84-f0d1059b083d">
        <source>doPreviewText(updPreview : Boolean);

begin
	if updPreview then
		// sync the preview with the main body
		if picPlinthLesson.visible then
			txtPreviewA.text := txtLessonText.text;
			txtPreviewB.text := "";
		else
			txtPreviewA.text := txtText.text;
			txtPreviewB.text := txtTextAfter.text;
		endif;		
	else
		// the user is typing in the preview window, sync the body
		if picPlinthLesson.visible then
			txtLessonText.text := txtPreviewA.text;
		else
			txtText.text := txtPreviewA.text;
			txtTextAfter.text := txtPreviewB.text;
		endif;		
	endif;

	if lblStep_01.visible then
		lblStep_01.visible := false;
	endif;

	if picPlinthActivity.visible = false then
		btnNextActivity.enabled := false;
	endif;			
end;</source>
        <Parameter name="updPreview" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSelectNextLesson" id="20cadab3-4016-479a-8bcb-61bb15e22d76">
        <source>doSelectNextLesson(itemToSelect : Integer);

vars
	index		: Integer;

begin
	foreach index in 1 to lstNextLesson.listCount do
		lstNextLesson.itemSelected[index] := (index = itemToSelect);
	endforeach;

	if itemToSelect &gt; 0 and itemToSelect &lt;= lstNextLesson.listCount then
		lstNextLesson.listIndex := itemToSelect;
	else
		lstNextLesson.listIndex		:= CNEC_NULL_INDEX;
		lstNextLesson.listObject	:= null;
	endif;
end;</source>
        <Parameter name="itemToSelect" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doShowError" id="f62d5b39-71d8-43ab-9f8c-8ad3bb9f99bc">
        <updating/>
        <source>doShowError():Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Generic method to display an error message for a database transaction.
//
// Parameters:	None
//
// Returns:		Boolean - Flag to indicate whether an error message as found and show.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;

begin
	errorMessage	:=	self.aError;

	if errorMessage &lt;&gt; null then
		app.msgBox(errorMessage, "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
	endif;
epilog
	self.aError	:=	null;
	return (errorMessage = null);
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTeachExport" id="8189b56d-9b41-49a6-bc8d-d6ba1d9be5e6">
        <source>doTeachExport();

vars
	file		: File;
	openFile	: CMDFileOpen;
	lesson		: CnEcTLesson;
begin
    create openFile;

	openFile.fileName := "lesson.txt";

	if openFile.open() = 0 then
		create file;
		file.mode := File.Mode_Output; // 4/3/16  cnwns1 PAR 36286 unicode version
		file.fileName := openFile.fileName;

		foreach lesson in app.myBaseRoot.allTLessons do
			lesson.writeToFile(file);
		endforeach;
		
		file.writeLine(CNEC_TEACH_EOF &amp; Tab &amp; "End of file");
		file.close();
		delete file;
	endif;

    delete openFile;
end;</source>
    </JadeMethod>
    <JadeMethod name="doTeachImport" id="c612f3d2-ab4d-4b0b-8ec2-f93ea45ee7f9">
        <updating/>
        <source>doTeachImport()updating;

vars
	file		: File;
	openFile	: CMDFileOpen;
	lesson		: CnEcTLesson;
	inStr		: String;
	error		: String;
begin
    create openFile;

	openFile.fileName := "lesson.txt";

	if openFile.open() = 0 then
		create file;
		file.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version
		file.fileName := openFile.fileName;

		beginTransaction;

		while not file.endOfFile() do
			inStr := file.readLine();

			if inStr.pos(CNEC_TEACH_EOF &amp; Tab, 1) &gt; 0 then	// end of file marker
				break;
			endif;

			create lesson;
			error := lesson.readFromFile(file, inStr);

			if error.length = 0 and lesson.name.length &gt; 0 then
				lstLessons.itemObject[lstLessons.addItem(lesson.name)] := lesson;
				lstLessons.refreshNow();
			else
				delete lesson;
				break;
			endif;
		endwhile;

		if error.length = 0 then
			commitTransaction;
		else
			abortTransaction;
			app.msgBox(error, "Error reading file", 0);
		endif;

		file.close();
		delete file;
	endif;

    delete openFile;
	self.doLessonDisplayAvailable(null);
end;</source>
    </JadeMethod>
    <JadeMethod name="keyUp" id="79e8a0db-612b-4f1d-8631-c005002417b3">
        <controlMethod name="Form::keyUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyUp(keyCode: Integer io; shift: Integer) updating;

begin
	if keyCode = 76 and shift = 2 then // 'CTRL' &amp; "L"  
//		app.cnEcTeachDisplayTutorial(self);				// cnwdad1 17/08/2000 - As advised by cnwrdd1.
		app.cnEcTeachDisplayTutorial(self, true);		// cnwdad1 17/08/2000 - As advised by cnwrdd1.
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="af692f59-82f8-4c2d-9eac-0a31b7f043cd">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	app.mousePointer := Busy;
	inheritMethod();
	create self.aMyTA transient;
	loadForm;
epilog
	app.mousePointer := Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadForm" id="2aaa297d-01f2-4c49-a43c-393c2cd7bcfc">
        <updating/>
        <source>loadForm()updating;

begin
	if app.myBaseRoot = null then
		self.aError := "The Base Root is not set";
		self.doShowError();
		unloadForm();
		return;
	endif;

	self.doLessonDisplayAvailable(null);
	self.doDisplayRules();
	self.miscPopulateFormsListbox();

	picPlinthLesson.visible 	:= false;
	picPlinthActivity.visible 	:= false;
	picPlinthPreview.visible	:= false;
	lblStep_01.caption 			:= $CNEC_LESSON_STEP;
	lblStep_01.visible 			:= true;

	beginClassNotification(CnEcTLesson, false, Any_System_Event, Response_Continuous, self.NOTIFY_LESSON);
	beginClassNotification(CnEcTActivity, false, Any_System_Event, Response_Continuous, self.NOTIFY_ACTIVITY);
end;</source>
    </JadeMethod>
    <JadeMethod name="lstActivities_click" id="33c7ca7b-69c5-4538-9b4c-7fa3988f8c9a">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstActivities_click(listbox: ListBox input) updating;

begin
	self.doActivityDisplayDetail();

	picPlinthActivity.visible 	:= true;
	picPlinthLesson.visible		:= false;
	picPlinthPreview.visible	:= true;

	self.doPreviewText(true);
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstLessons_click" id="77a7980a-19c7-4313-a675-f46faca1c1b1">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstLessons_click(listbox: ListBox input) updating;

begin
	self.doLessonDisplayDetail( listbox.listObject.CnEcTLesson );

	picPlinthActivity.visible 	:= false;
	picPlinthLesson.visible		:= true;
	picPlinthPreview.visible	:= true;

	self.doPreviewText(true);
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="miscClearActivityFields" id="2e74735c-1115-4c8e-8ab5-980ebedd371d">
        <source>miscClearActivityFields();

begin
	txtActivityName.text 		:= "";
	txtAction.text 				:= "";
	txtText.text 				:= "";
	lstControl.listIndex 		:= CNEC_NULL_INDEX;
	lstControlAfter.listIndex	:= CNEC_NULL_INDEX;
	txtTextAfter.text 			:= "";
	txtTextError.text 			:= "";
	chkStopOnError.value 		:= true;
	chkUseCurrentValu.value		:= true;
	chkActionOnError.value		:= false;
	chkActionOnError.enabled 	:= false;

	self.doPreviewText(true);
end;</source>
    </JadeMethod>
    <JadeMethod name="miscMoveActivity" id="2d1cc269-70e4-46d5-9f4f-96dba0474bf9">
        <source>miscMoveActivity();

vars
	listPointer	: Integer;
	counter		: Integer;
	lesson		: CnEcTLesson;

begin
	lesson := lstLessons.listObject.CnEcTLesson;

	if lesson = null then
		return;
	endif;	

	listPointer := lstActivities.listIndex;

	if listPointer &lt;= 1 then
		return;
	endif;

	beginTransaction;

	lesson.clearActivities();

	foreach counter in 1 to listPointer - 2 do
		lesson.addActivity(lstActivities.itemObject[counter].CnEcTActivity);
	endforeach;

	lesson.addActivity(lstActivities.itemObject[listPointer].CnEcTActivity);
	lesson.addActivity(lstActivities.itemObject[listPointer - 1].CnEcTActivity);	

	foreach counter in listPointer + 1 to lstActivities.listCount do
		lesson.addActivity(lstActivities.itemObject[counter].CnEcTActivity);
	endforeach;

	commitTransaction;

	self.doActivityDisplayAvailable(lesson);
	lstActivities.listIndex := listPointer -1;
end;</source>
    </JadeMethod>
    <JadeMethod name="miscPopulateControlsListbox" id="8371e7b4-6152-45a1-923c-f02e3eb51071">
        <source>miscPopulateControlsListbox(lesson : CnEcTLesson);

vars
	form		: Form;
	ctrl		: Control;
	listPointer	: Integer;

begin
	lstControl.clear();
	lstControlAfter.clear();
	lstStartupControl.clear();

	lstControl.addItem(self.NO_LIST_ENTRY);
	lstControlAfter.addItem(self.NO_LIST_ENTRY);

	if lesson = null or lesson.formName.length() = 0 then
		return;
	endif;

	create form as currentSchema.getClass(lesson.formName);

	foreach listPointer in 1 to form.controlCount do
		ctrl := form.controls(listPointer);
		lstControl.addItem(ctrl.name);
		lstControlAfter.addItem(ctrl.name);
		lstStartupControl.addItem(ctrl.name);
	endforeach;

	delete form;
end;</source>
        <Parameter name="lesson" type="CnEcTLesson"/>
    </JadeMethod>
    <JadeMethod name="miscPopulateFormsListbox" id="f316ae61-a0b2-47e1-a65a-3d2a4be35110">
        <source>miscPopulateFormsListbox();

vars
	theClass		: Class;
	theForm			: Class;
	allSubclasses	: ClassColl;
	allClasses		: ClassColl;

begin
	allClasses	:=	currentSchema.allClasses();
	create allSubclasses transient;

	foreach theClass in allClasses do
		if theClass.schema.name = currentSchema.name and theClass.name = "Form" then
			allSubclasses.clear();
			theClass.allSubclassesUpToSchema(currentSchema, allSubclasses);
			
			foreach theForm in allSubclasses do 
				lstForms.addItem(theForm.name);
			endforeach;		
		endif;		
	endforeach;
epilog
	delete allSubclasses;
	delete allClasses;
end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="a59f4a8e-7d03-437b-ba42-5c3d4a76ada3">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;

begin
	if eventTag = self.NOTIFY_LESSON then
		if eventType = Object_Delete_Event then
			self.aMyLesson := null;
			self.doLessonDisplayAvailable(null);
		else
			if eventType = Object_Create_Event then
				self.doLessonDisplayAvailable(theObject.CnEcTLesson);
			endif;
		endif;
	elseif eventTag = self.NOTIFY_ACTIVITY then
		if eventType = Object_Delete_Event then
			self.aMyActivity := null;
		endif;
		
		self.doActivityDisplayAvailable(self.aMyLesson);
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
