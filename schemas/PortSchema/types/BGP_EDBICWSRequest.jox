    <JadeMethod name="action" id="486d63db-62fb-4e9d-81e1-0c5ae3523421">
        <updating/>
        <source>action(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Nov 2022	navpw1	Initial creation TFS: 55215
11 Apr 2023	navdap1	TFS 57362 CUX Changes to Outgoing Message Formats
17 Apr 2023	navdap1	TFS 57207 EUP - Refactor Inspection App API Message
*/

vars
	activeCuxPortInterface	: CM_CuxportServiceDef;
	agent					: CM_CuxportConsumerAgent;
	
	//Error Stuff
	errCode					: Integer;
	errTxt					: String;
	
	//Invalid Objects
	invalidTI				: Boolean;
	invalidTrain			: Boolean;
	invalidVVR				: Boolean;			// TFS 57362
	invalidVoyage			: Boolean;			// TFS 57362
	noData					: Boolean;			// TFS 57362
	
	edition					: Integer;
	request					: BGP_Request;
	returnVal				: Boolean;
	
begin
	app.writeLog( method.qualifiedName,LogINFO);
	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	
	//activeCuxPortInterface := app.myRoot.getFirstActiveExtWebService( CM_CuxportServiceDef ).CM_CuxportServiceDef;	// TFS 57207
	activeCuxPortInterface := self.getWebServiceDefForType().CM_CuxportServiceDef;										// TFS 57207
	
	if activeCuxPortInterface = null then
		app.doRaiseAlert(app.getErrorString(Active_edbic_service_definit));
		app.raiseCMException(Active_edbic_service_definit, null, null);
	endif;
	
	create agent transient;
	agent.setupFromWebServiceDefinition(activeCuxPortInterface);
	
	on Exception do app.handleDeletedObject( exception, self.myTrackedItem, invalidTI );
	on Exception do app.handleDeletedObject( exception, self.myTrain, invalidTrain );
	on Exception do app.handleDeletedObject( exception, self.myVehicleVisit, invalidVVR );
	on Exception do app.handleDeletedObject( exception, self.myVoyage, invalidVoyage );
	
	if self.myTrackedItem = null and self.myTrain = null and self.myVehicleVisit = null and self.myVoyage = null then
		app.writeLog(method.qualifiedName() &amp; Space &amp; "EDBIC Request - No Cargo, Train, Vehicle Visit or Voyage supplied.", LogERROR);
		return true;
	endif;
	
	if self.myTrackedItem &lt;&gt; null then
		edition := self.myTrackedItem.edition;
	endif;
	if invalidTI then
		app.writeLog(method.qualifiedName() &amp; Space &amp; "EDBIC Request - Invalid Tracked Item.", LogERROR);
		return true;
	endif;
	
	if self.myTrain &lt;&gt; null then
		edition := self.myTrain.edition;
	endif;
	if invalidTrain then
		app.writeLog(method.qualifiedName() &amp; Space &amp; "EDBIC Request - Invalid Train.", LogERROR);
		return true;
	endif;
	
	if self.myVehicleVisit &lt;&gt; null then
		edition := self.myVehicleVisit.edition;
	endif;
	if invalidVVR then
		app.writeLog(method.qualifiedName() &amp; Space &amp; "EDBIC Request - Invalid Vehicle Visit.", LogERROR);
		return true;
	endif;
	
	if self.myVoyage &lt;&gt; null then
		edition := self.myVoyage.edition;
	endif;
	if invalidVoyage then
		app.writeLog(method.qualifiedName() &amp; Space &amp; "EDBIC Request - Invalid Voyage.", LogERROR);
		return true;
	endif;
	
	if self.dataType = self.Type_Unknown then
		app.writeLog(method.qualifiedName() &amp; Space &amp; "EDBIC Request - Unknown request type.", LogERROR);
		return true;
	endif;
	
	// TFS 57362 start
	if self.myTrackedItem = null and self.myTrain = null and self.myVehicleVisit = null and self.myVoyage = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "EDBIC Request - no TI, train, vehicel visit or voyage - nothing to do", LogERROR);
		noData := true;
		return true;
	endif;
	// TFS 57362
	
	returnVal := self.sendRequest(agent, activeCuxPortInterface);

	return returnVal;
	
epilog
	delete agent;
	
	if errCode &lt;&gt; null  then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	endif;
	
	if invalidTI or invalidTrain or invalidVVR or invalidVoyage or noData then		// TFS 57362
		request := self;
		app.myTrxDA.trxDeleteBGPRequest(null, request, true, app.myPassport);
	endif;

	inheritMethod();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="1b3393b1-2b7a-4a3b-9ca3-ffef08426154">
        <source>getDisplay(): String;
/*

Purpose:			ToDo : Needs to be modified

Parameters:			

Return Value:		

Date		Who		Reason
30 Nov 2022	navpw1	Initial creation TFS: 55215
11 Apr 2023	navdap1	TFS 57362 CUX Changes to Outgoing Message Formats
*/

vars
	invalidTrackedItem,
	invalidVehicleVisit,
	invalidTrain,
	invalidVoyage		: Boolean;
	termCode			: String;
	desc				: String;
	termStr				: String;
	edition				: Integer;
	
begin
	on Exception do app.handleDeletedObject(exception, self.myTrackedItem, invalidTrackedItem);
	on Exception do app.handleDeletedObject(exception, self.myVehicleVisit, invalidVehicleVisit);
	on Exception do app.handleDeletedObject(exception, self.myTrain, invalidTrain);				// TFS 57362
	on Exception do app.handleDeletedObject(exception, self.myVoyage, invalidVoyage);			// TFS 57362
	
	if self.myTrackedItem &lt;&gt; null then
		edition := self.myTrackedItem.edition;
	endif;
	
	if self.myVehicleVisit &lt;&gt; null then
		edition := self.myVehicleVisit.edition;
	endif;
	
	if self.myTrain &lt;&gt; null then					// TFS 57362
		edition := self.myTrain.edition;			// TFS 57362
	endif;											// TFS 57362
	
	if self.myVoyage &lt;&gt; null then					// TFS 57362
		edition := self.myVoyage.edition;			// TFS 57362
	endif;											// TFS 57362
	
	if invalidTrackedItem or invalidVehicleVisit or invalidTrackedItem or invalidVoyage then	// TFS 57362
		return inheritMethod;
	endif;
	
	//if self.actTerminal &lt;&gt; null then				// TFS 57362
	//	termCode := self.actTerminal.code;			// TFS 57362
	if self.myTerminal &lt;&gt; null then					// TFS 57362
		termCode := self.myTerminal.code;			// TFS 57362
		termStr  := 'Activity Term: ['&amp; termCode &amp;']';
	endif;
	
	if self.myTrackedItem &lt;&gt; null then
		desc := "Tracked Item: " &amp; self.myTrackedItem.id;
		
	elseif self.myVehicleVisit &lt;&gt; null then
		desc := "Vehicle Visit: " &amp; self.myVehicleVisit.visitNumber;
		
	elseif self.myTrain &lt;&gt; null then				// TFS 57362
		desc := "Train: " &amp; self.myTrain.code;		// TFS 57362
		
	elseif self.myVoyage &lt;&gt; null then				// TFS 57362
		desc := "Voyage: " &amp; self.myVoyage.code;	// TFS 57362
		
	endif;
	
	return inheritMethod &amp; Tab &amp;  'EDBIC ' &amp; termStr &amp;' [' &amp; desc &amp;']';							// TFS 57362

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWebServiceDefForType" id="cd297116-b94d-4ce9-8f2b-00e13a203fcd">
        <source>getWebServiceDefForType() : CM_ExternalWebServiceDef protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18 Apr 2023	navdap1		TFS 57207 EUP - Refactor Inspection App API Message
//
vars
	defName : String;

begin
	if self.dataType = self.Type_ShipReceival then
		defName := ETRow_ShipReceivalEDBIC;
	elseif self.dataType = self.Type_ShipRelease then
		defName := ETRow_ShipReleaseEDBIC;
	elseif self.dataType = self.Type_TrainDeparture then
		defName := ETRow_TrainDepartureEDBIC;
	elseif self.dataType = self.Type_TrainReceival then
		defName := ETRow_RailReceivalEDBIC;
	elseif self.dataType = self.Type_TruckArrival then
		defName := ETRow_TruckArrivalEDBIC;
	elseif self.dataType = self.Type_TruckDeparture then
		defName := ETRow_TruckDepartureEDBIC;
	elseif self.dataType = self.Type_TruckReceival then
		defName := ETRow_RoadReceivalEDBIC;
	elseif self.dataType = self.Type_VoyageArrival then
		defName := ETRow_VoyageArrivalEDBIC;
	elseif self.dataType = self.Type_VoyageDeparture then
		defName := ETRow_VoyageDepartureEDBIC;
	endif;
	
	return app.myRoot.getFirstActiveEWSForEndpoint(defName);
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="CM_ExternalWebServiceDef"/>
    </JadeMethod>
    <JadeMethod name="sendRequest" id="27a4dece-3bb9-4506-bca8-ce2070efd80d">
        <updating/>
        <source>sendRequest(_agent : CM_CuxportConsumerAgent input; _activeCuxPortInterface : CM_CuxportServiceDef) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Nov 2022	navpw1	Initial creation TFS: 55215
06 Apr 2023	navdap1	TFS 57362 CUX - Changes to Outgoing Message Formats
18 Jun 2024	jlier1 TFS 63898 
*/

begin
	// User Story 57370.080 Send Export Cargo Details to EDBIC for Cargo Received via Rail
	if self.dataType = self.Type_TrainReceival then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "dataType is Type_TrainReceival - doing _agent.sendRailReceivalToEDBIC with TI " &amp; self.myTrackedItem.id, LogDEBUG);
		return _agent.sendRailReceivalToEDBIC(_activeCuxPortInterface, self.myTrackedItem, self.myTerminal);		// TFS 57362
		
	// User Story 53730.020 Send Cargo Details for Cargo Received at the Gate House
	elseif self.dataType = self.Type_TruckReceival then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "dataType is Type_TruckReceival - doing _agent.sendRoadReceivalToEDBIC with visit " &amp; self.myVehicleVisit.visitNumber, LogDEBUG);
		return _agent.sendRoadReceivalToEDBIC(_activeCuxPortInterface, self.myVehicleVisit, self.myTerminal);		// TFS 57362
		
	// User Story 57370.110 Send Import Cargo Details to EDBIC for Each Unit of Cargo Discharged from the Vessel
	elseif	self.dataType = self.Type_ShipReceival then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "dataType is Type_ShipReceival - doing _agent.sendShipReceivalToEDBIC with TI " &amp; self.myTrackedItem.id, LogDEBUG);
		return _agent.sendShipReceivalToEDBIC(_activeCuxPortInterface, self.myTrackedItem, self.myTerminal);		// TFS 57362
		
	// User Story 53730.050 Send Export Cargo Details to EDBIC for Each Unit of Cargo Loaded to the Vessel
	elseif	self.dataType = self.Type_ShipRelease then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "dataType is Type_ShipRelease - doing _agent.sendShipReleaseToEDBIC with TI " &amp; self.myTrackedItem.id, LogDEBUG);
		return _agent.sendShipReleaseToEDBIC(_activeCuxPortInterface, self.myTrackedItem, self.myTerminal);			// TFS 57362
		
	// TFS 57362 start
	// User Story 57370.170 Send Road Jobs for Visy-Integration to EDBIC
	elseif self.dataType = self.Type_TruckArrival then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "dataType is Type_TruckArrival - doing _agent.sendTruckArrivalToEDBIC with visit " &amp; self.myVehicleVisit.visitNumber, LogDEBUG);
		return _agent.sendTruckArrivalToEDBIC(_activeCuxPortInterface, self.myVehicleVisit, self.myTerminal);
		
	// User Story 57370.140 Send Import Cargo Details to EDBIC for Cargo Released vi Rail
	elseif self.dataType = self.Type_TrainDeparture then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "dataType is Type_TrainDeparture - doing _agent.sendTrainDepartureToEDBIC with train " &amp; self.myTrain.code, LogDEBUG);
		return _agent.sendTrainDepartureToEDBIC(_activeCuxPortInterface, self.myTrain, self.myTerminal);
		
	// User Story 57370.130 Send Import Cargo Details to EDBIC for Cargo Released at the Gate House
	elseif self.dataType = self.Type_TruckDeparture then
		if self.myVehicleVisit &lt;&gt; null then
			app.writeLog(method.qualifiedName &amp; Tab &amp; "dataType is Type_TruckDeparture - doing _agent.sendTruckDepartureToEDBIC with visit " &amp; self.myVehicleVisit.visitNumber, LogDEBUG);
			return _agent.sendTruckDepartureToEDBIC(_activeCuxPortInterface, self.myVehicleVisit, self.myTerminal);
		elseif self.myTrackedItem &lt;&gt; null then //jlier1 TFS 63898 18/6/24
			app.writeLog(method.qualifiedName &amp; Tab &amp; "dataType is Type_TruckDeparture - doing _agent.sendTruckDepartureToEDBIC with cargo " &amp; self.myTrackedItem.id, LogDEBUG);
			return _agent.sendTruckDepartureCargoToEDBIC( self.myTrackedItem);
		endif;
		
	// User Story 57370.120 Send Vessel Arrival Message to EDBIC
	elseif self.dataType = self.Type_VoyageArrival then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "dataType is Type_VoyageArrival - doing _agent.sendVoyageArrivalToEDBIC with voyage " &amp; self.myVoyage.code, LogDEBUG);
		return _agent.sendVoyageArrivalToEDBIC(_activeCuxPortInterface, self.myVoyage, self.myTerminal);
		
	// User Story 57370.060 Send Vessel Departed Message to EDBIC
	elseif self.dataType = self.Type_VoyageDeparture then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "dataType is Type_VoyageDeparture - doing _agent.sendVoyageDepartureToEDBIC with voyage " &amp; self.myVoyage.code, LogDEBUG);
		return _agent.sendVoyageDepartureToEDBIC(_activeCuxPortInterface, self.myVoyage, self.myTerminal);
	// TFS 57362 end
	else
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Unknown dataType - returning false", LogDEBUG);
		return false;
	endif;
	
end;</source>
        <Parameter name="_agent" type="CM_CuxportConsumerAgent" usage="input"/>
        <Parameter name="_activeCuxPortInterface" type="CM_CuxportServiceDef"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDetails" id="1ee9576b-bd0f-4ce4-9505-f3300a4845b1">
        <updating/>
        <source>setDetails(_trackedItem : CM_TrackedItem; _vehicleVisit : CM_VehicleVisitRecord; _train : CM_Train; _voyage : CM_Voyage; _terminal : CM_Terminal; _dataType : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Nov 2022	navpw1	Initial creation TFS: 55215
06 Apr 2023	navdap1	TFS 57362 CUX - Changes to Outgoing Message Formats
*/

begin
	self.myTrackedItem	:= _trackedItem;
	self.myVehicleVisit	:= _vehicleVisit;
	self.myTrain		:= _train;			// TFS 57362
	self.myVoyage 		:= _voyage;			// TFS 57362
	self.myTerminal		:= _terminal;		// TFS 57362
	self.dataType		:= _dataType;
	
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_vehicleVisit" type="CM_VehicleVisitRecord"/>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_dataType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="b1defd85-eeca-4f82-b307-99f1c3d29133">
        <updating/>
        <source>setForCreate(_proxySelf: SelfType input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12/04/2023	navdap1		Initial creation TFS 57362 CUX Changes to Outgoing Message Formats
//
vars

begin
	inheritMethod(_proxySelf);
	self.myTerminal 	:= _proxySelf.myTerminal;
	self.dataType 		:= _proxySelf.dataType;
	self.myTrackedItem 	:= _proxySelf.myTrackedItem;
	self.myTrain 		:= _proxySelf.myTrain;
	self.myVehicleVisit	:= _proxySelf.myVehicleVisit;
	self.myVoyage 		:= _proxySelf.myVoyage;
epilog

end;</source>
        <Parameter name="_proxySelf" type="SelfType" usage="input"/>
    </JadeMethod>
</Class>
