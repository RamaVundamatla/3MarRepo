vars
	idx : Integer;
	aLGraphic : CM_LayoutGraphic;
	thePoints : PointArray;
	aPoint : Point;
	minX,maxX,minY,maxY,hValue, vValue : Integer;
begin
	if theMenuItem.helpKeyword &lt;&gt; null then
		self.xmlScaleFactor := theMenuItem.helpKeyword.Real;
		self.doDrawGraphics();
		self.doCentreOnSelectedTA(self.mnuZoom.userObject);
	endif;

end;</source>
