    </JadeMethod>
    <JadeMethod name="copyErrors" id="3407e399-dddc-44f7-b975-382891122781">
        <updating/>
        <source>copyErrors() updating;
//
// 20 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
//
vars
	ediError : CM_EDIError;
	trxError : CM_Error;
	obj	: Object;
	ediTI : CM_EDITrackedItem;
	gotException : Boolean;
	keepErrors : Boolean;
	status : Integer;
	allErrorsMatched : Boolean;
	errorMatched : Boolean;
begin
	// first lets if the error list has changed if not we do nothing.
	if self.allErrorWarnings.size &lt;&gt; app.myPassport.allErrorWarnings.size then
		// if we dont have the same number of messages
		// dont try and match them up
		allErrorsMatched := false;
	else
		allErrorsMatched := true;
		// for each passport error see if we already have an existing matching pesistant error
		foreach trxError in app.myPassport.allErrorWarnings do
			errorMatched := false;
			foreach ediError in  self.allErrorWarnings do
				if trxError.errorCode = ediError.errorCode and
				   trxError.text = trxError.text and
				   trxError.warningOnly = trxError.warningOnly then
					errorMatched := true;
					break;
				endif;
			endforeach;
			if errorMatched = false then
				allErrorsMatched := false;
				break;
			endif;
		endforeach;
	endif;
	if allErrorsMatched then
		return;
	endif;
	
	// Note:  Ideally I would like to mark the errors themselves as needing to be kept
	// but this would require a reorg and we are patching this CCMS
	// if we have any EDI TIs with a status that means they will be skiped in 
	// subsequent runs then keep any errors associated with them
	on Exception do app.handleDeletedObject(exception, obj, gotException);
	
	foreach ediError in self.allErrorWarnings do
		obj := ediError.myUserObject;
		
		if obj &lt;&gt; null and 
		   obj.isKindOf(CM_EDITrackedItem) then	
			ediTI := obj.CM_EDITrackedItem;
			
			keepErrors := ediTI.getKeepPersistentErrors;
						
			if gotException then
				// for next iteration
				gotException := false;
			elseif keepErrors then
				// keep this error				
				continue;
			endif;
		elseif obj &lt;&gt; null and obj.isKindOf(CM_EDIDataGateDoc) and (obj.CM_EDIDataGateDoc.isTransportManifestRelated or obj.CM_EDIDataGateDoc.isCallOffRelated) then	//MTN-33568
			continue;																																					//MTN-33568
		endif;																																							//MTN-33568
		// not an error we need to keep
		self.allErrorWarnings.remove(ediError);
		delete ediError;
	endforeach;
		
	// for each passport error create a persistent copy - even if we dont want to store all errors persistenly we do
	// need to keep those errors for EDI TIs that have been marked as skipped in this run
	foreach trxError in app.myPassport.allErrorWarnings do
		keepErrors := false;  
	
		// do we need to persist these errors for an EDI TI that will be skipped next run.
		obj := trxError.myUserObject;
	
		if obj &lt;&gt; null and obj.isKindOf(CM_EDITrackedItem) then
			ediTI := obj.CM_EDITrackedItem;
			status := ediTI.status;
			
			if gotException then
				// really hope this does not happen
				gotException := false;
				
			else					
				if status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING or
					status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X then
					// these will never be reprocessed so if there are errors for them
					// in this run make sure we don't delete them in a subseuqnet run
					if not ediTI.getKeepPersistentErrors then
						ediTI.setKeepPersistentErrors(true); 
					endif;
					// need to persist errors as this EDi TI will not be procesed again and we dont want to loase the errors
					keepErrors := true;
				endif;
			endif;
		endif;
		
		if not keepErrors then
			// if we don't allow partial loading then all errors are persisted
			keepErrors := self.storePersistentErrors;  
		endif;
		
		if keepErrors then
			if self.isTransportManifestRelated and self.allErrorWarnings.includesErrorOrWarning(trxError.text) then				//MTN-33568
				//skip adding this error if already exists																		//MTN-33568
			else
				create ediError;
				
				ediError.set(trxError.errorCode, trxError.text, trxError.warningOnly, trxError.fieldName, trxError.myUserObject);
				
				self.allErrorWarnings.add(ediError);
			endif;
		endif;
	endforeach;
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doesCargoForExptDateExist" id="d455f0b7-4861-4aaf-b69c-7e8d8d18525a">
        <source>doesCargoForExptDateExist(_eta : Date): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2023	navra1	Initial creation for 57263

*/

vars
	ediTI: CM_EDITrackedItem;
begin
	foreach ediTI in self.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIPrenoteTI) and ediTI.CM_EDIPrenoteTI.expectedArrivalDate &lt;&gt; null then
			if _eta = ediTI.CM_EDIPrenoteTI.expectedArrivalDate then
				return true;
			endif;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_eta" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doesReceiptTransportModeExist" id="89d3013d-018b-4e57-8a54-96206702c113">
        <source>doesReceiptTransportModeExist(_receiptTransportMode: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
6 April 2023	navra1	Initial creation for 57263

*/

vars
	ediTi: CM_EDITrackedItem;
begin
	foreach ediTi in self.allEDITrackedItems do
		if ediTi.isKindOf(CM_EDIPrenoteTI) then
			if ediTi.CM_EDIPrenoteTI.transportMode.toUpper().compareEql(_receiptTransportMode.toUpper(), true, false, null) then
				return true;
			endif;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_receiptTransportMode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCargoETA" id="3bcccbdb-9843-4e75-a587-f1473b96145d">
        <source>getCargoETA(): Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
*/

vars
	ediTI: CM_EDITrackedItem;
begin
	foreach ediTI in self.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIPrenoteTI) and ediTI.CM_EDIPrenoteTI.expectedArrivalDate &lt;&gt; null then
			return ediTI.CM_EDIPrenoteTI.expectedArrivalDate;
		endif;
	endforeach;
	return null;
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
