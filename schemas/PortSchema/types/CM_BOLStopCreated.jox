    <JadeMethod name="getDisplayStringForAttribute" id="cfb338b4-5bd1-4864-b357-6f3b5e7bcba0">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Date		Who		Reason
29 January 2015	cnwer1	Initial creation PAR

*/

vars

begin
	
	if _attrName = ETRow_Details then
		return app.getErrorString( TransType_95 ) &amp; ColonAndSpace &amp; self.stopDescription;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
