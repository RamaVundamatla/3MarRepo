<Class name="CMQF_BOLTransaction">
    <JadeMethod name="setFromAgent" id="06489e7c-6862-4388-9a54-2ef9afaf0010">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;

vars

begin
	inheritMethod(_agent);

	if _agent.isRowIncluded(ETRow_Bol) then
		self.setMyBOLIn( _agent.getSelectedBOLIn() );
	endif;
	if _agent.isRowIncluded(ETRow_BolVoyage) then
		self.setMyVoyage( _agent.getSelectedBOLVoyage() );
	endif;
end;
</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
