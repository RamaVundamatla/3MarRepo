    <JadeMethod name="doColourSummaryRows" id="9c5a584c-1c2b-494f-bd72-d5f8629f08a8">
        <source>doColourSummaryRows();
/*
Purpose:			
Date				Who			Reason
June 2013		CNWAB1		Initial creation
*/
constants
	PaleBlueRow : Integer = 16772055;
vars
	stIdx, endIdx,
	rowIdx		: Integer;
	jRow		: JadeTableRow;
	
begin
	endIdx 		:= self.tblData.rows;
	
	// PAR 31756 find first non job row
	foreach rowIdx in self.tblData.fixedRows + 1 to endIdx do
		if self.tblData.accessRow(rowIdx).itemObject = null then
			stIdx := rowIdx;
			break;
		endif;
	endforeach;	

	foreach rowIdx in stIdx to endIdx do
		jRow := self.tblData.accessRow(rowIdx);
		if rowIdx mod 2 = 0 then
			jRow.backColor := White;
		else
			jRow.backColor := PaleBlueRow;
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="b2bf4d52-8ff4-4e9c-8937-8f23592a1dcb">
        <updating/>
        <source>doDelete() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theObject : Object;
	theJob : CM_VoyageJob;
	theReturn : Integer;
	result : Integer;
	jobs : CM_VoyageJobSet;
begin
	if self.tblData.allSelectedObjects.size = 0 then
		app.msgBox(app.getErrorString(Please_select_job_delete),app.getErrorString(Delete_Job), MsgBox_OK_Only);
		return;
	endif;
	
	theReturn := app.msgBox(app.getErrorString2(ConfirmDelete, app.getErrorString(The_selected_jobs), ''),app.getErrorString(Confirm_Job_Delete), MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	if theReturn = MsgBox_Return_No then
		return;
	endif;
	
	self.mousePointer := Window.MousePointer_HourGlass;
	
	//epr TFS 1925 29/4/16 removed code just call one trx and copies selected to a collection to avoid 1308 exception
	create jobs transient;
	self.tblData.allSelectedObjects.copy(jobs);
	
	while true do
		app.myTrxDA.trxDeleteVoyageJobs(jobs, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Order_Of_Work), app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;			
	
epilog
	delete jobs;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doFullPlan" id="01c1ac8a-e441-4745-822f-bfe5991af62f">
        <updating/>
        <source>doFullPlan() updating;
// --------------------------------------------------------------------------------
// Created:		15 November 2010 by cnwjo3
//
// Purpose:		this method is effectively a copy of CMUI_ShipFullyPlanForm::doQueury
//
vars
	cmifMonitor		: CMIF_Monitor;
	now : TimeStamp;
	allJobs : CM_JobArray;
	shipController : CMIF_ShipPlanningController;
begin
	now := app.actualTimeServer();	// 9/5/16 cnwmp6 TFS 488 - Multi timezone support
	
	create allJobs transient;
	
	create shipController transient;

	self.tblData.allSelectedObjects.copy(allJobs);  //copy allJobs from the ones selected on the table

	//create dialog to progress
	cmifMonitor := app.myPassport.myCMIFMonitor;
	if cmifMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		app.myPassport.setMyCMIFMonitor(cmifMonitor);
	endif;

	self.modalDialogReturnValue := self.ModalDialogReturn_Null;	
	self.modalDialogShow(null,app.getErrorString(Cancel) , null, null, app.getErrorString(AutomaticLoadPlanning),  app.getErrorString(PleaseWait) &amp; '....');
	self.pbProgressBar.visible := true;

	//set up everything 
	self.myAssistant.doFullyPlan(allJobs, self.myCurrentVoyage, cmifMonitor,shipController);

	if shipController &lt;&gt; null then
		self.displayLoadPlanDetails(now,shipController,allJobs);
	endif;
epilog
	delete cmifMonitor;	
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
	delete allJobs;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMenuPlanJobsClick" id="04e997c4-9ab6-403b-ac3a-487a48eb463e">
        <updating/>
        <source>doMenuPlanJobsClick() updating;
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	jobs : CM_JobArray;
begin

	create jobs transient;		
	self.getSelectedJobs(jobs,true);
	self.myAssistant.showShipFullyPlanForm(null, jobs, null, CMIF_ShipPlanningController.Mode_Job, self.myMasterMenuAction);
	
epilog

	delete jobs;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuContextBuild" id="3e8fca32-56ed-4ee6-a7e3-1d460bc19bd8">
        <updating/>
        <source>doMnuContextBuild(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	----------	--------------------------------------------------
// 16/12/2019	jlgdap1		TFS 47144 JMT Refactor OOW Job Split Transfer
// 17/06/2020   cnwma1		Bug 49384: PEN - Problem with splitting jobs
vars

	anObject, 
	selectedObject  : Object;
	aJob, 
	selectedJob 	: CM_VoyageJob;
	wle 			: CM_WorkListEntry;			// TFS 47144
	jobType			: String;					// TFS 47144
	jobClass 		: String;					// TFS 47144
	
begin

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return true;
	endif;

	// cnwrl1 16/02/2009 - (CCMS SFW 1047 - Totals Only Lists)
	self.mnuSummarise.visible	:= false;	// default this menu level to invisible, makes sub-menu invisible.
	
	self.mnuOOWFullPLan.visible := true;
	self.mnuOOWFullUnpLan.visible := true;
	
	anObject :=  cntrl.accessRow(cntrl.row).itemObject;
	if CM_VoyageJob.hasInstance(anObject) then
		aJob := anObject.CM_VoyageJob;
	else
		self.doMnuContextNullObject();
		return false;
	endif;

	if app.isAllowedToInspect then
		self.mnuInspectObject.visible := true;
	else
		self.mnuInspectObject.visible := false;	
	endif;	   

	//cnwjo3 CCMS 1178 par 23366
	if app.getMyUser.canDo(self.myTerminal,PmAdmMoveCargoFromJob) then
		self.mnuMoveCargoFromJob.visible := true;
	endif;
	
	//cnwjo3 ccms 1178 par 23366
	self.mnuSplitWork.visible := true;
	self.mnuSplitWork.enabled := true;
	// TFS 47144 enable / disable Split and Transfer menu items
	if self.tblData.allSelectedObjects.size &gt; 1 or self.tblData.allSelectedObjects.isEmpty then
		self.mnuSplitWork.enabled := false;
	else
		self.mnuSplitWork.enabled := false;
		if aJob &lt;&gt; null then
			/* 
			17.06.2020 cnwma1 #49384
			foreach wle in aJob.workListEntries discreteLock do
				if wle.status = WLE_COMPLETED then
					self.mnuSplitWork.enabled := true;
				endif;
			endforeach;
			*/
			self.mnuSplitWork.enabled := true;    //17.06.2020 cnwma1 #49384
		endif;
	endif;
	self.mnuTransferWork.visible := true;
	self.mnuTransferWork.enabled := true;
	if self.tblData.allSelectedObjects.isEmpty then
		self.mnuSplitWork.enabled := false;
	else
		foreach selectedObject in self.tblData.allSelectedObjects do
			if not CM_VoyageJob.hasInstance(selectedObject) then
				continue;
			endif;
			selectedJob := selectedObject.CM_VoyageJob;
			if (selectedJob.jobTypeId &lt;&gt; jobType and jobType &lt;&gt; null)
			or (selectedJob.getJobClassNiceString &lt;&gt; jobClass and jobClass &lt;&gt; null) then
				self.mnuTransferWork.enabled := false;
				break;
			endif;
			foreach wle in selectedJob.workListEntries discreteLock do
				if not wle.status = WLE_UNACTIONED then
					self.mnuTransferWork.enabled := false;
					break;
				endif;
			endforeach;
			if not self.mnuTransferWork.enabled then
				break;
			endif;
			jobType := selectedJob.jobTypeId;
			jobClass := selectedJob.getJobClassNiceString;
		endforeach;
	endif;
	// TFS 47144 end
	
	self.mnuMoveCargoFromJob.enabled := false;
	if self.myCurrentJob &lt;&gt; null then
		if self.myCurrentJob.isDischarge then
			self.mnuMoveCargoFromJob.enabled := true;
		endif;
	endif;
	
	self.mnuContextJobCargoList.visible := true;
	self.mnuContextRenumber.visible := true;
	self.mnuContextSep01.visible := true;
	self.mnuContextRemarks.visible := true;
	self.mnuContextJobTimes.visible := true;
	self.mnuContextLashInfo.visible := true;
	self.mnuContextHideHatchJob.visible := true;
	self.mnuContextRemarks.userObject := anObject;

	//cnwjo3 par 26193
	if not self.useDeckingRules() then
		self.doBuildMnuFullPlan(self.mnuOOWFullPLan);
	endif;
	self.doBuildMnuFullPlan(self.mnuOOWFullUnpLan);
	
	self.mnuContextJobDelete.visible := true;
	self.mnuContextJobDelete.userObject := anObject;

	self.mnuContextJobPos.visible := true;
	self.mnuContextJobEdit.userObject := anObject;

	self.mnuContextJobNew.visible := true;

	if not aJob.isLoadedToOperations then
		self.mnuContextJobUnload.visible := false;
		self.mnuContextJobLoad.visible := true;
		self.mnuContextJobLoad.userObject := anObject;
	else
		self.mnuContextJobLoad.visible := false;
		self.mnuContextJobUnload.visible := true;
		self.mnuContextJobUnload.userObject := anObject;
	endif;
	
	if aJob.myJobSheet = null
	or self.filterWorkPoint = null then
		self.mnuContextJobDown.visible := false;
		self.mnuContextJobUp.visible := false;
	else
		if aJob.myJobSheet.allJobsByOrder.first = aJob then
			self.mnuContextJobUp.visible := false;
			self.mnuContextJobDown.visible := true;
			self.mnuContextJobDown.userObject := anObject;
		elseif aJob.myJobSheet.allJobsByOrder.last = aJob then
			self.mnuContextJobDown.visible := false;
			self.mnuContextJobUp.visible := true;
			self.mnuContextJobUp.userObject := anObject;
		else
			self.mnuContextJobDown.visible := true;
			self.mnuContextJobDown.userObject := anObject;
			self.mnuContextJobUp.visible := true;
			self.mnuContextJobUp.userObject := anObject;
		endif;
	endif;
	
	//02 Apr 2012	NDL	Par 29369
	self.mnuContextWPOpHrs.visible := self.myCurrentVoyage &lt;&gt; null;
	self.mnuContextWPOpHrs.userObject := anObject;
	
	return self.showContextMenu(self.mnuContextTable,cntrl,conwin,mouse,x, y);

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuContextJobPosClick" id="e0a1c264-9667-49fd-b20a-40d5911b6264">
        <updating/>
        <source>doMnuContextJobPosClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
