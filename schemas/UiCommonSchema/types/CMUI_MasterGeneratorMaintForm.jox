    <JadeMethod name="setupForm" id="89eec9d0-ca8b-4850-9d78-de6f801f50da">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29/07/2008	cnwer1	Initial creation
12/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
06/03/2014	cnwdap1	PAR #33638 Correct measurement field
23 Oct 2019	jlgsl4	TFS 46767 - PEN - GenSet Trailer Linking
*/
vars
	weightType	: CM_MeasurementType;				// PAR #31155

begin

	inheritMethod();
	//self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.toolbarStyle := self.ToolbarStyle_None;
	self.showToolbar := false;
	self.hasChanged := false;
	//self.height := 346;
	//self.width := 837;
	//self.btnNext2.visible := app.isSpecial();
	
	self.centreWindow();	//Par18122 Oct 2008
	self.initFrm();
	
	if self.isEdit then
		self.btnNext.visible := false;
		self.txtID.enabled := false;
		if self.myParentForm.isKindOf(CMUI_ReceiveCargoForm) then // --&gt; TFS 46767 - 31/10/2019 - enable autocreation for 100
			self.btnDeleteGen.visible := true;
			self.btnDeleteGen.caption := "Detach";
		endif; // &lt;-- TFS 46767
	else
		self.btnNext.visible := true;		
		self.btnNext.bubbleHelp:="Save Next";
		self.txtID.enabled := true;		
		self.btnOk.left := self.btnOk.left -74;
	endif;
	
	// PAR #31155 Include default system weight type in caption for Tare Weight
	//self.lblWeight.setCaptionForMeasurementType(Type_Weight);						// PAR #33638
	self.txtWeight.setup(Type_Weight, self.backColor);								// PAR #33638
	self.txtWeight.tabKey := J_key_Tab;												// PAR #33638

	self.myAssistant.comboBoxOperator( self.cmbOperator, null, null );
	self.myAssistant.comboBoxOperator( self.cmbOwner, null, null );
	self.myAssistant.comboBoxISOTypeForGenerator( self.cmbISOType, null );
	self.myAssistant.comboBoxGeneratorType( self.cmbGeneratorType, null );
	
	self.myAssistant.listTableStopsTableSysUser( self.lstTblStops, app.myRoot.allCargoTypesById[ TI_CargoType_Generator ], self.allStopsForUser, true);
	self.myAssistant.listTableToDoTasksSysUser( self.lstTblToDoTasks, app.myRoot.allCargoTypesById[ TI_CargoType_Generator ], self.allToDoTasksForUser );	//self.myAssistant.listTableToDoTasks(self.lstToDoTasks,self.myTerminal);
	//self.tblDamageInit();

	self.beginClassNotification(CM_TIMasterGenerator, false, Any_System_Event, Response_Continuous, null); //cnwrd1 par #18127 23.1.09
	
	self.loadData();
//	self.myAssistant.comboBoxTAType( cmbTAType, null, true );	
//	self.myAssistant.comboBoxTerminalArea(self.cmbTermArea, TA_TYPE_NULL, null);	
//	self.myAssistant.comboBoxLocationControllers(self.cmbYardLocation, null, false);	
	
	self.btnDamage.visible := false;  // ### TFS 55313 08NOV2022 NAVAB1 - Recorded damage is not used anywhere

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="e9a3df77-c388-46d0-8113-307845e22ad5">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 January 2009	cnwrd1	Initial creation
//cnwrd1 par #18127 23.1.09
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars

begin

	
		if eventType = Object_Update_Event and theObject = self.myTiMaster then
				app.msgBox('Generator Maintanance Screen: Another user has updated the Generator you currently have selected.' &amp; CrLf &amp;
							'The Generator must now be re-loaded.', 'Generator updated', MsgBox_Exclamation_Mark_Icon);
				self.loadData();
		elseif eventType = Object_Delete_Event and theObject = self.myTiMaster then
			app.msgBox('Another user has deleted the Generator you are currently editing. The editing must now be cancelled','Generator deleted by another user.',MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			self.unloadForm();
		endif;
	
	
	

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="a31e5d8a-7213-4e7e-83cd-8e81aca794d5">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 24 October 2019 08:48:31.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0010019, locale);
	btnCancel.translateCaption(Xlat_0010020, locale);
	btnDamage.translateCaption(Xlat_0013462, locale);
	btnDelete.translateBubbleHelp(Xlat_0010021, locale);
	btnDelete.translateCaption(Xlat_0010022, locale);
	btnDeleteGen.translateCaption(Xlat_0023768, locale);
	btnNext.translateCaption(Xlat_0010023, locale);
	btnOk.translateCaption(Xlat_0010024, locale);
	lblDescription.translateCaption(Xlat_0010026, locale);
	lblGenType.translateCaption(Xlat_0010027, locale);
	lblID.translateCaption(Xlat_0010028, locale);
	lblISOType.translateCaption(Xlat_0010029, locale);
	lblOperator.translateCaption(Xlat_0010030, locale);
	lblOwner.translateCaption(Xlat_0010031, locale);
	lblStops.translateCaption(Xlat_0010032, locale);
	lblToDoTasks.translateCaption(Xlat_0010033, locale);
	lblWeight.translateCaption(Xlat_0010034, locale);
end;</source>
    </JadeMethod>
