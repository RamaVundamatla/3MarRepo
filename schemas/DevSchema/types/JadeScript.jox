    </JadeMethod>
    <JadeMethod name="xlat_Filter_Logs" id="7ae8d7f7-7320-4daa-879f-ed200b1e1b44">
        <source>xlat_Filter_Logs() protected;
// --------------------------------------------------------------------------------
// Created:		11 March 2009 by cnwdad1
//
// Purpose:		Reads a log file that was generated by the Xlat_ProcessFormCaptions
//				script, and writes to the output window any lines that have a "***"
//				which denotes a warning or information message.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	WARNING_FLAG	: String = "***";
	
vars
	logFileObj		: File;
	fileLine		: String;
	warningCount	: Integer;
	totalCount		: Integer;
	startTime		: Integer;
	
begin
	create logFileObj transient;
	logFileObj.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version

	if logFileObj.cnEcSetOpenName(true, false, CNEC_FILE_FILTER_LOG) then
		startTime	:=	app.clock();
		write "Filtering Xlation logs...";
		
		while not logFileObj.endOfFile() do
			fileLine	:=	logFileObj.readLine();
			totalCount	:=	totalCount + 1;
			
//			if fileLine.length() &gt;= 3 and fileLine[1:3] = WARNING_FLAG then
			if fileLine.length() &gt;= 3 and fileLine.pos(WARNING_FLAG, 1) &gt; 0 then
				warningCount	:=	warningCount + 1;
				write fileLine;
			endif;
		endwhile;
	else
		startTime	:=	app.clock();
		write "Log file not opened.";
	endif;
	
	logFileObj.close();
epilog
	delete logFileObj;
	write	"Filtered " &amp; warningCount.cnEcNumberFormat() &amp; " warnings from " &amp; totalCount.cnEcNumberFormat() &amp;
			" log entries in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="xlat_Filter_Unreferenced" id="f2937e70-c3f7-4ee3-9a09-72f4166a033f">
        <source>xlat_Filter_Unreferenced() protected;
// --------------------------------------------------------------------------------
// Created:		11 March 2009 by cnwdad1
//
// Purpose:		Reads a log file that was generated by the Xlat_ProcessFormCaptions
//				script, and writes to the output window any lines that indicate an
//				unreference Global Constant.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	FILTER			: String = "Unreferenced Global Constant";
	
vars
	logFileObj		: File;
	fileLine		: String;
	warningCount	: Integer;
	totalCount		: Integer;
	startTime		: Integer;
	
begin
	create logFileObj transient;
	logFileObj.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version

	if logFileObj.cnEcSetOpenName(true, false, CNEC_FILE_FILTER_LOG) then
		startTime	:=	app.clock();
		write "Filtering unreferenced Xlations...";
		
		while not logFileObj.endOfFile() do
			fileLine	:=	logFileObj.readLine();
			totalCount	:=	totalCount + 1;
			
			if fileLine.pos(FILTER, 1) &gt; 0 then
				warningCount	:=	warningCount + 1;
				write fileLine;
			endif;
		endwhile;
	else
		startTime	:=	app.clock();
		write "Log file not opened.";
	endif;
	
	logFileObj.close();
epilog
	delete logFileObj;
	write	"Filtered " &amp; warningCount.cnEcNumberFormat() &amp; " log lines from " &amp; totalCount.cnEcNumberFormat() &amp;
			" log entries in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="xlat_ProcessFormCaptions" id="e6d7c679-02a2-4d67-bc43-a944c812ea09">
        <source>xlat_ProcessFormCaptions();
// ---------------------------------------------------------------------------
// Created:     12 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	agent		: FormCaptionsAgent;
	startTime	: Integer;
	
begin
	startTime	:=	app.clock();
	create agent transient;
	agent.fillSchemas();
	agent.initAllForms();
	if (not agent.loadDefinedFormConstants()) then
		app.msgBox('Error in loadDefinedFormConstants', 'Error', 0);
		return;
	endif;
	agent.processAllForms();
	agent.writeSchemaFile(null);
	
epilog
	delete agent.fileFolder;
	delete agent;
	write "Form/Control/Menu captions processed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="xlat_TranslateForm" id="ae3565cd-44d5-4937-9961-aa92ff3469ab">
        <source>xlat_TranslateForm();
// ---------------------------------------------------------------------------
// Created:     12 October 2007 by cnwrs2
//
// Purpose:     Creates schema files for the text translation constants and text
//				translateForm method for the entered form:
//				This method creates 2 scm files:
//					PortSchema-FormCaptions-partial.scm - the global contants to create
//					???Schema-FormCaptions-partial.scm - the translateForm method for
//							the form being translated.
//
//				Once run load the scm files (or hand copy the changes) and then run
//				the PortSchema JadeScript loadTranslationConstants to load the
//				global constants.
//
//				To test the translations open the Text Translation form and output the
//				translations for a locale (e.g Polish).  In dev this will create a file 
//				with all the translations prefixed with ZZZ.  Load this file back in and 
//				selec the Polish Locale (options/preferences) and open the form translated.
// ---------------------------------------------------------------------------
vars
	agent	: FormCaptionsAgent;
	theForm	: Class;
	tmpSchema	: Schema;
	formClassName,
	schemaName		: String;
	
begin
	// === To use set the schema and form class names here
	schemaName		:= 'SysOpsSchema';				// eg UiCommonSchema SysOpsSchema etc
//	schemaName      := 'ShipSchema';
	formClassName	:= 'SOP_ExternalWebServicesMonitor';					// eg CMUI_StopsForm.name or CM_ContainerEnqForm
//	formClassName	:= 'SHP_VoyageDefinitionForm';
	// ======================
	
	tmpSchema := rootSchema.getSchema(schemaName);
	if tmpSchema = null then
		app.msgBox('Schema (' &amp; schemaName &amp; ') not found', 'Error', 0);
		return;
	endif;
	
	theForm := tmpSchema.getClass(formClassName);
	if theForm = null then
		app.msgBox('Form (' &amp; formClassName &amp; ') not found in schema ' &amp; schemaName, 'Error', 0);
		return;
	endif;
	
	// This may take some time
	create agent transient;
	agent.fillSchemas();
	if (not agent.loadDefinedFormConstants()) then
		app.msgBox('Error in loadDefinedFormConstants', 'Error', 0);
		return;
	endif;
	agent.processForm(theForm);
	
	// This will ask for the directory to output the scm files to
	agent.writeSchemaFile(null);
	
epilog
	delete agent.fileFolder;
	delete agent;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="xmlVoyageGraphicChop" id="894cd783-b4d5-48be-b1b0-dbe4e1eb3328">
        <source>xmlVoyageGraphicChop();
vars

	theXML, theXMLTagValue : String;
	theXMLFile : File;
	fileXML : CMDFileOpen;
	pos,pos2, idx, lenXML : Integer;
	theID,thePoints,thePoint : String;
	theTerminal : CM_Terminal;
	layoutGraphic : CMIF_LayoutGraphics;
	theTerminalArea : CM_TerminalArea;
	thePointsArray : PointArray;
	theXYStrings : StringArray;
	theX, theY : Integer;
	anError : CM_Error;
	aPoint:Point;
	fileName, theChop : String;
	theReturn : Integer;
begin
	create fileXML;
	
	fileXML.fileName := "NullVoyageGraphic.xml";
	fileXML.filter := "JMT Ship Graphic (*.xml)|*.xml";
	if fileXML.open = 0 then
		app.mousePointer := Window.MousePointer_HourGlass;
		create theXMLFile;
		theXMLFile.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version

		theXMLFile.fileName := fileXML.fileName;
		fileName := fileXML.fileName;
	
		theXMLFile.maxRecordSize := 40000;
		theXML := theXMLFile.readLine();
		lenXML := theXML.length;
		foreach idx in 1 to lenXML step 200 do
			theChop := theXML[idx:200];
			app.writeStatement( 'theXML := theXML &amp; "' &amp; theChop &amp; '";');
		endforeach;
		if idx &lt;= lenXML then
			theChop := theXML[idx:end];
			app.writeStatement( 'theXML := theXML &amp; "' &amp; theChop &amp; '";');
		endif;
	endif;
epilog
	if theXMLFile &lt;&gt; null then
		theXMLFile.close;
	endif;


end;</source>
    </JadeMethod>
    <JadeMethod name="xmlVoyageGraphicGet" id="d71a7ebc-9d50-44c8-85ab-acfc4633c58b">
        <source>xmlVoyageGraphicGet();
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theXML, theXMLTagValue : String;
	theXMLFile : File;
	pos,pos2 : Integer;
	theID,thePoints,thePoint : String;
	theTerminal : CM_Terminal;
	layoutGraphic : CMIF_LayoutGraphics;
	theTerminalArea : CM_TerminalArea;
	thePointsArray : PointArray;
	theXYStrings : StringArray;
	theX, theY, idx : Integer;
	anError : CM_Error;
	aPoint:Point;
	nullVoy : CM_Voyage;
begin

	app.initialize();
	theTerminal := app.myRoot.allTerminals["T01"];	
	if theTerminal = null then
		app.writeStatement( "NO Terminal");
		return;
	endif;

	nullVoy := theTerminal.getNullVoyage();	
	
	if nullVoy = null then
		app.writeStatement( "No Null Voyage");
		return;
	endif;
	
	create theXMLFile;	
	theXMLFile.mode := File.Mode_Output; // 29/2/16  cnwns1 PAR 36286 unicode version
	theXMLFile.fileName := "C:\JMT\cnwdmast\XMLSideProfile\NullVoyageGraphic751.xml";
	// use these if not compressed		
	theXMLFile.maxRecordSize := 40000;
	theXMLFile.writeString(nullVoy.myLayoutGraphic.getXMLData());
	
	app.writeStatement( "FIN");
epilog
	theXMLFile.close;
end;</source>
    </JadeMethod>
    <JadeMethod name="xmlVoyageGraphicSet" id="52bdaf65-0a69-45ac-a593-9d99047f3cd5">
        <source>xmlVoyageGraphicSet();
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		Use JS:xmlVoyageGraphicGet to write the current Side Profile Graphics to disk
//				Then use JS:xmlVoyageGraphicChop to output basic jade script to the Output Viewer
//				Then cut and Paste the output from the viewer into xmlVoyageGraphicXML
//				Then this method will set the new graphics into the DB
// ---------------------------------------------------------------------------
vars
	theXML, theXMLTagValue : String;
	theXMLFile : File;
	pos,pos2 : Integer;
	theID,thePoints,thePoint : String;
	theTerminal : CM_Terminal;
	layoutGraphic : CMIF_LayoutGraphics;
	theTerminalArea : CM_TerminalArea;
	thePointsArray : PointArray;
	theXYStrings : StringArray;
	theX, theY, idx : Integer;
	anError : CM_Error;
	aPoint:Point;
	nullVoy : CM_Voyage;

	path: String;
	filePathName: String;
	fileFolder: FileFolder;
begin

	app.initialize();
	
	foreach theTerminal in app.myRoot.allTerminals do	

		nullVoy := theTerminal.getNullVoyage();	
		
		if nullVoy = null then
			app.writeStatement( "No Null Voyage");
			return;
		endif;
	
		theXML := self.xmlVoyageGraphicXML();	
		if nullVoy.myLayoutGraphic	= null then
			nullVoy.createGraphicForNullVoyage();
		endif;
		nullVoy.myLayoutGraphic.setXMLData(theXML);
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="xmlVoyageGraphicXML" id="c15db4b8-fb1e-4c47-9fba-8c0d2e9ad456">
        <source>xmlVoyageGraphicXML() : String;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		use xmlVoyageGraphicChop to chop the XML into many strings and cut and paste the ouput from the write statement into here.
//				this is then called as part of the release load
//
// ---------------------------------------------------------------------------

vars
	theXML : String;
begin
theXML := theXML &amp; "&lt;AFT&gt;&lt;maxAft&gt;49&lt;/maxAft&gt;&lt;maxBridge&gt;46&lt;/maxBridge&gt;&lt;maxForward&gt;37&lt;/maxForward&gt;&lt;CMD&gt;&lt;FILL_CLR&gt;0&lt;/FILL_CLR&gt;&lt;CLR&gt;0&lt;/CLR&gt;&lt;LB&gt;&lt;/LB&gt;&lt;TP&gt;1&lt;/TP&gt;&lt;X1&gt;1&lt;/X1&gt;&lt;X2&gt;0&lt;/X2&gt;&lt;Y1&gt;1&lt;/Y1&gt;&lt;Y2&gt;0&lt;/Y2&gt;&lt;/CMD&gt;&lt;CMD&gt;&lt;FILL_CLR&gt;0&lt;/FI";
theXML := theXML &amp; "LL_CLR&gt;&lt;CLR&gt;0&lt;/CLR&gt;&lt;LB&gt;&lt;/LB&gt;&lt;TP&gt;1&lt;/TP&gt;&lt;X1&gt;1&lt;/X1&gt;&lt;X2&gt;0&lt;/X2&gt;&lt;Y1&gt;54&lt;/Y1&gt;&lt;Y2&gt;0&lt;/Y2&gt;&lt;/CMD&gt;&lt;CMD&gt;&lt;FILL_CLR&gt;0&lt;/FILL_CLR&gt;&lt;CLR&gt;0&lt;/CLR&gt;&lt;LB&gt;&lt;/LB&gt;&lt;TP&gt;1&lt;/TP&gt;&lt;X1&gt;2&lt;/X1&gt;&lt;X2&gt;0&lt;/X2&gt;&lt;Y1&gt;56&lt;/Y1&gt;&lt;Y2&gt;0&lt;/Y2&gt;&lt;/CMD&gt;&lt;CMD&gt;&lt;FILL";
theXML := theXML &amp; "_CLR&gt;0&lt;/FILL_CLR&gt;&lt;CLR&gt;0&lt;/CLR&gt;&lt;LB&gt;&lt;/LB&gt;&lt;TP&gt;1&lt;/TP&gt;&lt;X1&gt;5&lt;/X1&gt;&lt;X2&gt;0&lt;/X2&gt;&lt;Y1&gt;59&lt;/Y1&gt;&lt;Y2&gt;0&lt;/Y2&gt;&lt;/CMD&gt;&lt;CMD&gt;&lt;FILL_CLR&gt;0&lt;/FILL_CLR&gt;&lt;CLR&gt;0&lt;/CLR&gt;&lt;LB&gt;&lt;/LB&gt;&lt;TP&gt;1&lt;/TP&gt;&lt;X1&gt;9&lt;/X1&gt;&lt;X2&gt;0&lt;/X2&gt;&lt;Y1&gt;61&lt;/Y1&gt;&lt;Y2&gt;0&lt;/Y2&gt;&lt;/CMD&gt;";
theXML := theXML &amp; "&lt;CMD&gt;&lt;FILL_CLR&gt;0&lt;/FILL_CLR&gt;&lt;CLR&gt;0&lt;/CLR&gt;&lt;LB&gt;&lt;/LB&gt;&lt;TP&gt;1&lt;/TP&gt;&lt;X1&gt;22&lt;/X1&gt;&lt;X2&gt;0&lt;/X2&gt;&lt;Y1&gt;65&lt;/Y1&gt;&lt;Y2&gt;0&lt;/Y2&gt;&lt;/CMD&gt;&lt;CMD&gt;&lt;FILL_CLR&gt;0&lt;/FILL_CLR&gt;&lt;CLR&gt;0&lt;/CLR&gt;&lt;LB&gt;&lt;/LB&gt;&lt;TP&gt;1&lt;/TP&gt;&lt;X1&gt;31&lt;/X1&gt;&lt;X2&gt;0&lt;/X2&gt;&lt;Y1&gt;68&lt;/Y1&gt;&lt;Y2&gt;";
theXML := theXML &amp; "0&lt;/Y2&gt;&lt;/CMD&gt;&lt;CMD&gt;&lt;FILL_CLR&gt;0&lt;/FILL_CLR&gt;&lt;CLR&gt;0&lt;/CLR&gt;&lt;LB&gt;&lt;/LB&gt;&lt;TP&gt;1&lt;/TP&gt;&lt;X1&gt;36&lt;/X1&gt;&lt;X2&gt;0&lt;/X2&gt;&lt;Y1&gt;71&lt;/Y1&gt;&lt;Y2&gt;0&lt;/Y2&gt;&lt;/CMD&gt;&lt;CMD&gt;&lt;FILL_CLR&gt;0&lt;/FILL_CLR&gt;&lt;CLR&gt;0&lt;/CLR&gt;&lt;LB&gt;&lt;/LB&gt;&lt;TP&gt;1&lt;/TP&gt;&lt;X1&gt;40&lt;/X1&gt;&lt;X2&gt;0&lt;/X2&gt;&lt;Y1";
theXML := theXML &amp; "&gt;75&lt;/Y1&gt;&lt;Y2&gt;0&lt;/Y2&gt;&lt;/CMD&gt;&lt;CMD&gt;&lt;FILL_CLR&gt;0&lt;/FILL_CLR&gt;&lt;CLR&gt;0&lt;/CLR&gt;&lt;LB&gt;&lt;/LB&gt;&lt;TP&gt;1&lt;/TP&gt;&lt;X1&gt;40&lt;/X1&gt;&lt;X2&gt;0&lt;/X2&gt;&lt;Y1&gt;102&lt;/Y1&gt;&lt;Y2&gt;0&lt;/Y2&gt;&lt;/CMD&gt;&lt;CMD&gt;&lt;FILL_CLR&gt;0&lt;/FILL_CLR&gt;&lt;CLR&gt;0&lt;/CLR&gt;&lt;LB&gt;&lt;/LB&gt;&lt;TP&gt;1&lt;/TP&gt;&lt;X1&gt;42&lt;/X1&gt;";
theXML := theXML &amp; "&lt;X2&gt;0&lt;/X2&gt;&lt;Y1&gt;105&lt;/Y1&gt;&lt;Y2&gt;0&lt;/Y2&gt;&lt;/CMD&gt;&lt;CMD&gt;&lt;FILL_CLR&gt;0&lt;/FILL_CLR&gt;&lt;CLR&gt;0&lt;/CLR&gt;&lt;LB&gt;&lt;/LB&gt;&lt;TP&gt;1&lt;/TP&gt;&lt;X1&gt;45&lt;/X1&gt;&lt;X2&gt;0&lt;/X2&gt;&lt;Y1&gt;106&lt;/Y1&gt;&lt;Y2&gt;0&lt;/Y2&gt;&lt;/CMD&gt;&lt;CMD&gt;&lt;FILL_CLR&gt;0&lt;/FILL_CLR&gt;&lt;CLR&gt;0&lt;/CLR&gt;&lt;LB&gt;&lt;/LB&gt;&lt;TP&gt;1&lt;/";
theXML := theXML &amp; "TP&gt;&lt;X1&gt;49&lt;/X1&gt;&lt;X2&gt;0&lt;/X2&gt;&lt;Y1&gt;106&lt;/Y1&gt;&lt;Y2&gt;0&lt;/Y2&gt;&lt;/CMD&gt;&lt;CMD&gt;&lt;FILL_CLR&gt;0&lt;/FILL_CLR&gt;&lt;CLR&gt;0&lt;/CLR&gt;&lt;LB&gt;&lt;/LB&gt;&lt;TP&gt;3&lt;/TP&gt;&lt;X1&gt;0&lt;/X1&gt;&lt;X2&gt;0&lt;/X2&gt;&lt;Y1&gt;0&lt;/Y1&gt;&lt;Y2&gt;0&lt;/Y2&gt;&lt;/CMD&gt;&lt;CMD&gt;&lt;FILL_CLR&gt;0&lt;/FILL_CLR&gt;&lt;CLR&gt;0&lt;/CLR&gt;&lt;LB&gt;&lt;";
theXML := theXML &amp; "/LB&gt;&lt;TP&gt;1&lt;/TP&gt;&lt;X1&gt;18&lt;/X1&gt;&lt;X2&gt;0&lt;/X2&gt;&lt;Y1&gt;71&lt;/Y1&gt;&lt;Y2&gt;0&lt;/Y2&gt;&lt;/CMD&gt;&lt;CMD&gt;&lt;FILL_CLR&gt;0&lt;/FILL_CLR&gt;&lt;CLR&gt;0&lt;/CLR&gt;&lt;LB&gt;&lt;/LB&gt;&lt;TP&gt;1&lt;/TP&gt;&lt;X1&gt;18&lt;/X1&gt;&lt;X2&gt;0&lt;/X2&gt;&lt;Y1&gt;106&lt;/Y1&gt;&lt;Y2&gt;0&lt;/Y2&gt;&lt;/CMD&gt;&lt;CMD&gt;&lt;FILL_CLR&gt;0&lt;/FILL_CLR&gt;&lt;CLR";
theXML := theXML &amp; "&gt;0&lt;/CLR&gt;&lt;LB&gt;&lt;/LB&gt;&lt;TP&gt;1&lt;/TP&gt;&lt;X1&gt;12&lt;/X1&gt;&lt;X2&gt;0&lt;/X2&gt;&lt;Y1&gt;106&lt;/Y1&gt;&lt;Y2&gt;0&lt;/Y2&gt;&lt;/CMD&gt;&lt;CMD&gt;&lt;FILL_CLR&gt;0&lt;/FILL_CLR&gt;&lt;CLR&gt;0&lt;/CLR&gt;&lt;LB&gt;&lt;/LB&gt;&lt;TP&gt;1&lt;/TP&gt;&lt;X1&gt;7&lt;/X1&gt;&lt;X2&gt;0&lt;/X2&gt;&lt;Y1&gt;101&lt;/Y1&gt;&lt;Y2&gt;0&lt;/Y2&gt;&lt;/CMD&gt;&lt;CMD&gt;&lt;FILL_CLR&gt;0&lt;/";
