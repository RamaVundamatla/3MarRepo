    <JadeMethod name="hasSpaceIfSplit" id="dab1629a-8149-4efc-8965-afee168b49e2">
        <source>hasSpaceIfSplit( _yaAgent : CM_YAAutoplanAgent ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2016	cnwndl1	Initial creation	TFS 2172

*/

vars

	ti : CM_TrackedItem;
	errorMsg : String;
	errorNum : Integer;
	location : CM_LocationsController;
	availableQuantity : Integer;
	availableWeight : Decimal [18,4];//navsp1 13MAY2022 TFS#53529
	availableVolume : Decimal [18,4];//navsp1 13MAY2022 TFS#53529
	totAvailQuantity : Integer;
	totAvailWeight : Decimal [18,4];//navsp1 13MAY2022 TFS#53529
	totAvailVolume : Decimal [18,4];//navsp1 13MAY2022 TFS#53529
	
	cargoType : CM_CargoType;

begin

	ti := self.myTrackedItem;
	if ti = null or not ti.canSplitTotalQuantity then
		return false;
	endif;

	foreach location in self.allLocationsForSplit do
		location.checkControllerFullTAMax(ti,null,null,errorMsg,errorNum,availableQuantity,availableWeight,availableVolume);
		totAvailQuantity := totAvailQuantity + availableQuantity;
		totAvailWeight := totAvailWeight + availableWeight;
		totAvailVolume := totAvailVolume + availableVolume;
	endforeach;
	
	if ti.myCargoType.isTrackByWeight then
		if ti.totalWeight &lt;= totAvailWeight then
			return true;
		endif;
	elseif ti.myCargoType.isTrackByVolume then
		if ti.totalVolume &lt;= totAvailVolume then
			return true;
		endif;
	else
		if ti.totalQuantity &lt;= totAvailQuantity then
			return true;
		endif;
	endif;

	return false;

epilog

end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
