    <JadeMethod name="zDoRefresh" id="21627496-ff65-4481-aefe-0e2d039130ff">
        <updating/>
        <source>zDoRefresh() protected, updating;

vars

begin

	self.txtDetails.text := null;
	self.myTrackedItem := null;
	self.tblActionData.userInputEnabled := false;
	// Do appropriate processing for selected option.
	if self.selection = ITEMID then
		self.doOptTicketClick();
	elseif self.selection = DOCKET then
		self.doOptDocketClick();
	elseif self.selection = LOCATION then
		self.doOptLocationClick;
	else
		self.doOptTicketClick();
		self.optSingleItem.value := true;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoSearch" id="3df3206d-d286-42bb-b070-a74d7dd413ff">
        <updating/>
        <source>zDoSearch(_isLostFocus : Boolean) : Boolean protected, updating;

begin


	// Do appropriate search based on what option button is current.
	self.myBOLIn := null;
	self.myTrackedItem := null;
	self.mySOHLocation := null;
	self.myDocketLocationHelper := null;
	
	if self.selection = ITEMID then
		self.displaySingleItem();
	elseif self.selection = DOCKET then
		return false; //docket display should happen on the click event of the cmbDocket
	elseif self.selection = LOCATION then
		self.displaySOHLocations(self.cmbLocation.listObject.CM_LocationsController);
	endif;
	
epilog
	return self.myTrackedItem &lt;&gt; null or self.allTrackedItems &lt;&gt; null;
end;</source>
        <access>protected</access>
        <Parameter name="_isLostFocus" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zGetOperator" id="d79a05ce-6b14-4f5e-916d-ac98d8dea553">
