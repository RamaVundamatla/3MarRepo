    <JadeMethod name="isOnboardMove" id="edd8a5e4-4099-43fc-9b1e-df061d85b97c">
        <source>isOnboardMove(_control : CMIF_MoveController) : Boolean protected;
/*
------------------------------------------------------------------------
Created:			18 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	origLC	: CM_LocationsController;
begin

	// Added null check to myOriginatingLocation because EDI trackedItems do not have an originating location.
	origLC := _control.myOriginatingLocation;
	if origLC &lt;&gt; null and (not CM_VoyageController.hasInstance(origLC)) then
		return false;
	endif;
	if (not CM_VoyageController.hasInstance(_control.myToPrimaryLocation)) then
		return false;
	endif;
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_control" type="CMIF_MoveController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
