//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
// START 28 july 2022 navvt20 Bug 54199: EUP - Tables with Operator/Stevedore not adhering to the configuration
vars

begin


     // START 28.07.2022 navvt20 TFS 54199
     if app.getMyRoot.getConfig(ComboByNameOperator).Boolean then
	    return self.description;
	 endif;
	 // END 28.07.2022 navvt20 TFS 54199
	 
	//if _short = 1 then
	if _short then
