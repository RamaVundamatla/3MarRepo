begin
	myGTE_BookingRefMultiForm_1:=app.getForm('GTE_BookingRefMultiForm').GTE_BookingRefMultiForm;
	picture:=app.atcgGetAddedControl(myGTE_BookingRefMultiForm_1, 'Show Searcher;picture;CMUI_ToolbarOverlay;0;-20;0;0;|;frame;CMUI_ToolbarButton;56;-534;0;4;|').Picture;
	picture.mouseDown(picture, 1, 0, 7, 10);
	app.doWindowEvents(shortPause);
	picture:=app.atcgGetAddedControl(myGTE_BookingRefMultiForm_1, 'Show Searcher;picture;CMUI_ToolbarOverlay;0;-20;0;0;|;frame;CMUI_ToolbarButton;56;-534;0;4;|').Picture;
	picture.mouseUp(picture, 1, 0, 7, 10);
	app.doWindowEvents(shortPause);
	picture:=app.atcgGetAddedControl(myGTE_BookingRefMultiForm_1, 'Show Searcher;picture;CMUI_ToolbarOverlay;0;-20;0;0;|;frame;CMUI_ToolbarButton;56;-534;0;4;|').Picture;
	app.doWindowEvents(shortPause);
