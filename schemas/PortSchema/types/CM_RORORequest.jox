    <JadeMethod name="getTargetLocationID" id="5060ffd9-67b6-41e6-8efb-74cd28d175cc">
        <source>getTargetLocationID(): String;
// ---------------------------------------------------------------------------
// Created:     11 December 2014 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lc :CM_LocationsController;
	id : String;
	invalidObj : Boolean;
begin
	on Exception do app.handleDeletedObject(exception,lc,invalidObj);
	
	lc:= self.myROROController;
	if lc &lt;&gt; null then
		id := lc.getFullId;
	endif;
	
	if invalidObj then
		return null;
	endif;
	
	return id;

epilog

end;</source>
        <ReturnType type="String"/>
