    <JadeMethod name="doBtnAdd" id="d711b25c-28ed-440f-89b7-003d0b188be7">
        <source>doBtnAdd();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2022	navhl20	ChangeRequest 54281: EUP - Wagon Track Planning

*/

vars
	int				:Integer;
	wagon				:CM_Wagon;
	coll			:CM_IntegerArray;
	invalidObject 	:Boolean;
begin
	on Exception do app.handleDeletedObject (exception, wagon, invalidObject);
	create coll transient;
	
	self.lstDoNotMoveWagons.getSelectedEntries (coll);
	
	foreach int in coll do
		wagon	:= self.lstDoNotMoveWagons.itemObject[int].CM_Wagon;
		wagon.edition();
		if invalidObject then			
			invalidObject	:= false;	
			continue;					
		endif;							
		
		int := self.lstMoveWagons.addItem(wagon.id);
		self.lstMoveWagons.itemObject[int] := wagon;
		self.allSelectedWagons.add(wagon);
	endforeach;
	self.lstDoNotMoveWagons.removeSelectedObjects;
epilog
	self.btnRemove.enabled	:= false;
	
	delete coll;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnAddAll" id="89355f69-fa6e-4f11-887a-10c792ce340e">
        <source>doBtnAddAll();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2022	navhl20	ChangeRequest 54281: EUP - Wagon Track Planning

*/

vars
	listBoxCount 		: Integer;
	wagon 				: CM_Wagon;
	invalidObject		: Boolean;
	count 				: Integer;
	countSelectedItems 	: Integer;
begin
	on Exception do app.handleDeletedObject (exception, wagon, invalidObject);
	listBoxCount := self.lstDoNotMoveWagons.listCount;
	countSelectedItems := self.lstMoveWagons.listCount;
	
	count := 1;
    while count &lt;= listBoxCount do
		countSelectedItems += 1;
		wagon := self.lstDoNotMoveWagons.itemObject[count].CM_Wagon;
		wagon.edition();
		if invalidObject then			
			invalidObject	:= false;	
			continue;					
		endif;
		self.lstMoveWagons.addItem(wagon.id);
		self.lstMoveWagons.itemObject[countSelectedItems] := wagon;
		self.allSelectedWagons.add(wagon);
		count += 1;
    endwhile;
	self.lstDoNotMoveWagons.clear;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnMove" id="84fe4662-8260-4a6a-8d50-ca4bbeb54db4">
        <updating/>
        <source>doBtnMove() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2022	navhl20	ChangeRequest 54281: EUP - Wagon Track Planning
01/05/2023		navkc1	Bug 57742: Wagon Track Planning - Capacity for Same Train

*/

vars
	moveController : CMIF_WagonMoveController;
	wagon			: CM_Wagon;
	result			: Integer;
begin
	create moveController transient;
	foreach wagon in self.allSelectedWagons do
		moveController.allWagons.add(wagon);
	endforeach;
	moveController.myTargetRailLine := self.cmbRailLine.listObject.CM_RailLine;
	moveController.setMoveMode(self.cmbMoveMode.listData);
	moveController.isInwardTarget := not self.chkOutward.value; // 01/05/2023	navkc1	Bug 57742
	if self.cmbMoveMode.text = self.Move_Instant then
		moveController.targetPosition := self.cmbRakePosition.listIndex;
	endif;
	while true do
		app.myTrxUA.trxMoveWagons(moveController, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.unloadForm();
		else
			result := app.showErrorWarningDialog(app.getErrorString(Wagon), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ...
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
epilog
	delete moveController;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnRemove" id="e110c2ff-203f-419a-8a17-2bea0d2c3609">
        <source>doBtnRemove();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2022	navhl20	ChangeRequest 54281: EUP - Wagon Track Planning

*/

vars
	int				:Integer;
	wagon				:CM_Wagon;
	coll			:CM_IntegerArray;
	invalidObject 	:Boolean;
begin
	on Exception do app.handleDeletedObject (exception, wagon, invalidObject);	
	create coll transient;
	
	self.lstMoveWagons.getSelectedEntries (coll);
	
	foreach int in coll do
		invalidObject	:= false;	
		
		wagon	:= self.lstMoveWagons.itemObject[int].CM_Wagon;
		int := self.lstDoNotMoveWagons.addItem(wagon.id);
		self.allSelectedWagons.remove(wagon);
		
		if not invalidObject then	
			self.lstDoNotMoveWagons.itemObject[int] := wagon;
		endif;						
	endforeach;
	
	self.lstMoveWagons.removeSelectedObjects;
epilog
	self.btnRemove.enabled	:= false;
	
	delete coll;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnRemoveAll" id="633632f8-0f41-4010-81db-a68278c3ff67">
        <source>doBtnRemoveAll();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2022	navhl20	ChangeRequest 54281: EUP - Wagon Track Planning

*/

vars
	wagon				: CM_Wagon;
	invalidObject		: Boolean;
	listBoxCount 		: Integer;
	count 				: Integer;
	countAvailableItems : Integer;
begin
	on Exception do app.handleDeletedObject (exception, wagon, invalidObject);
	
	listBoxCount := self.lstMoveWagons.listCount;
	countAvailableItems := self.lstDoNotMoveWagons.listCount;
	
	count := 1;
    while count &lt;= listBoxCount do
		countAvailableItems +=1;
		wagon := self.lstMoveWagons.itemObject[count].CM_Wagon;
		self.lstDoNotMoveWagons.addItem(wagon.id);
		if invalidObject then
			continue;			
		endif;
		self.lstDoNotMoveWagons.itemObject[countAvailableItems] := wagon;
		self.allSelectedWagons.remove(wagon);
		count += 1;
    endwhile;
	self.lstMoveWagons.clear();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPermissionCheck" id="9a095044-715f-4490-a25a-a04b109ed8de">
        <source>doPermissionCheck();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2022	navhl20	ChangeRequest 54281: EUP - Wagon Track Planning
 01/05/2023			navkc1	Bug 57742: Wagon Track Planning - Capacity for Same Train
*/

vars

begin
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.cmbMoveMode.enabled := false;
		self.cmbRailArea.enabled:= false;
		self.cmbRailLine.enabled	:= false;
		self.cmbRakePosition.enabled := false;
		self.chkOutward.enabled := false;  // 01/05/2023	navkc1	Bug 57742
		self.btnPlan.enabled := false;	
		self.lstDoNotMoveWagons.enabled := false;
		self.lstMoveWagons.enabled:= false;
		self.btnAdd.enabled	:= false;
		self.btnAddAll.enabled := false;
		self.btnRemove.enabled := false;
		self.btnRemoveAll.enabled := false;	
	endif;
epilog

end;</source>
    </JadeMethod>
