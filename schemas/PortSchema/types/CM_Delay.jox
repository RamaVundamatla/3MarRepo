    <JadeMethod name="updateAssociatedEvent" id="0a7467ad-77df-41eb-a087-859ae1324ac9">
        <source>updateAssociatedEvent();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2018	jlgndl1	Initial creation	TFS 40309

*/

vars


begin

	if self.myVoyageEvent &lt;&gt; null then

		if self.endDT.Date.isValid and self.endDT &lt;&gt; myVoyageEvent.dateTimeEnd then
			self.myVoyageEvent.setEndDataTime( true, self.endDT );
		endif;

	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateMachineHistory" id="acb8df7b-752f-4d7f-bb4d-0f6ad0fd7b63">
        <source>updateMachineHistory(_event :CM_EventTransaction)protected;
// ---------------------------------------------------------------------------
// Created:     31 March 2011 by cnwcs5
// Purpose:     Handle changes to machine and date/time(s) in the history
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	type	:Integer;
	history	:CM_MachineDelayHistory;
	machine	:CM_Machine;
begin
	type := _event.type;
	
	if type = EVT_DelayStart then
		history := _event.CMEVT_DelayStart.myMachineHistory;
	elseif type = EVT_DelayEnd then
		history := _event.CMEVT_DelayEnd.myMachineHistory;
	else
		// coding error
		return;
	endif;
	
	machine := self.myMachine;
	
	if history &lt;&gt; null then
		if machine = null then
			// delete the history - delay is no longer for a machine
			delete history;
			return;
		else
			history.updateFromEvent	(_event);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_event" type="CM_EventTransaction"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="dda0dd9e-c048-4bc1-8eb3-e7bfe76fb2fb">
        <source>validateForCreate();
/*
----------   ----------  --------------------------------------------------
Created:	13 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
// 14/08/2008	concms1	par 17714 - display warning if delay start/end times are
//						outside voyage arrival/departure dates
*/
vars
	startTS, endTS, 
	estEndTS, arriveTS, 
	departTS	:TimeStamp;
	delayType			:CM_DelayType;
	voyage				:CM_Voyage;
begin
	delayType 	:= self.myDelayType;
	voyage		:= self.myVoyage;
	
	if delayType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(ERROR_Delay_Type), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(ERROR_Delay_Type), null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	if delayType.requiresVoyage and voyage = null then
		app.raiseCMException1(ERROR_Voyage_Is_Required, null, null, null);
	endif;
	
	if delayType.requiresMachine and self.myMachine = null then
		app.raiseCMException1(ERROR_Machine_Is_Required, null, null, null);
	endif;
	
	if delayType.requiresWorkpoint and self.myWorkPoint = null then
		app.raiseCMException (ERROR_Workpoint_Is_Required, null, null);
	endif;
	
	if self.myTerminal = null then
		app.raiseCMException1(Error, app.getErrorString(Terminal), null, null);
	endif;

	startTS 	:= self.startDT;
	endTS		:= self.endDT;
	estEndTS	:= self.estEndDT;
		
	if not startTS.isValid() then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(ERROR_Start_Delay_Time), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(ERROR_Start_Delay_Time), null, null); // cnwdb2	PAR 35364
	endif;
	
	/*******need to change the error msg to be more understandable*****/
	if startTS.isValid() then 
		if endTS.isValid() and startTS &gt; endTS then // can not have start date &gt; end date
			app.raiseCMException1(Error_Invalid_Delay_Dates, app.getErrorString(EndDate) ,  null, null);
		endif;
		if estEndTS.isValid() and  startTS &gt; estEndTS then
			app.raiseCMException1(Error_Invalid_Delay_Dates, app.getErrorString(EstimatedEndDate),null, null);
		endif;
	endif;
	
	if (not endTS = null) and (not endTS.isValid()) then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(ERROR_End_Delay_Time), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(ERROR_End_Delay_Time), null, null);// cnwdb2	PAR 35364
	endif;
	

	
	// need to change the error string
	if not endTS.isValid then 	//+ cnwmd1 Par 21695 - Estimated End Date is only required if no End Date.
		if self.myMachine &lt;&gt; null and  not estEndTS.isValid() then 
			//app.raiseCMException1(REQUIRED_FIELD,app.getErrorString(EstimatedEndDate), null, null); //- cnwmd1, Par 21695
			app.raiseCMException1(RequiredFields,app.getErrorString(EstimatedEndDate) &amp; " or " &amp; app.getErrorString(ERROR_End_Delay_Time) , null, null); //+ cnwmd1 Par 21695
		elseif self.myVoyage &lt;&gt; null and  not estEndTS.isValid() then 
			//app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(EstimatedEndDate), null, null); //- cnwmd1, Par 21695
			app.raiseCMException1(RequiredFields,app.getErrorString(EstimatedEndDate) &amp; " or " &amp; app.getErrorString(ERROR_End_Delay_Time) , null, null); //+ cnwmd1 Par 21695
		endif;
	endif;
	
	// check delay dates against arrival/departue dates for vo9yage
	
	if voyage &lt;&gt; null then 
		departTS	:= voyage.departedDT;
		arriveTS	:= voyage.arrivedDT;
		
		if startTS &lt; arriveTS or 
			(departTS &lt;&gt; null and 
				(startTS &gt; departTS or
					(endTS &lt;&gt; null and endTS &gt; departTS))) then
			if departTS &lt;&gt; null then
				app.raiseCMWarning2 (WARN_DelayOusideVoyageDates, '(' &amp; arriveTS.asStringJMT &amp; ')', '(' &amp; departTS.asStringJMT &amp; ')', null, null, null);
			else
				app.raiseCMWarning2 (WARN_DelayOusideVoyageDates, '(' &amp; arriveTS.asStringJMT &amp; ')', null, null, null, null);
			endif;
		endif;
	endif;
	
	//29 May 2015	NDL	Par 36088
	if startTS.Date.isValid then
		if startTS.Date  &gt; app.actualTimeServer.Date + 60 then
			app.raiseCMException( Elaps_time_this_delay_seems_ex, null, null);
		endif;
		
		if endTS.Date.isValid then
			//epr TFS 3448 14/2/17
			if startTS.Date + 30 &lt; endTS.Date then
				app.raiseCMException( Elaps_time_this_delay_seems_ex, null,null);
			endif;
			
			if startTS.Date + 2 &lt; endTS.Date then
				app.raiseCMWarning( Elaps_time_this_delay_seems_ex, null, null , null);
			endif;
			
			
		elseif estEndTS.Date.isValid then
			//epr TFS 3448 14/2/17
			if startTS.Date + 30 &lt; estEndTS.Date then
				app.raiseCMException( Elaps_time_this_delay_seems_ex, null, null);
			endif;
			
			if startTS.Date + 2 &lt; estEndTS.Date then
				app.raiseCMWarning( Elaps_time_this_delay_seems_ex, null, null , null);
			endif;
			
		endif;
		
		
		
	endif;
	
end;
</source>
    </JadeMethod>
