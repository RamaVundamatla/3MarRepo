    <JadeMethod name="getBackButtonCaption" id="216c417d-d0f3-48cd-963c-b5a2c2f50b13">
        <source>getBackButtonCaption() : String;
/*
Finds what the 'Back' button should have as its caption. Either it should be Back, Menu, or Logout depending on various
situations.

Date		Who		Reason
03 February 2009	cnwcp2	Initial creation
01 Apr 2010	NDL	Par 23557
*/

vars
	
begin
	
	if self.myVMAgent &lt;&gt; null then
		if app.isWarehouseVMTApp then
			return app.getErrorString(Back);
		endif;
		return app.getErrorString(Menu);	
	
	elseif self.myMobileAgent.allAvailableForms.size = 1 or self.myMobileAgent.allPreviousForms.last = MOB_HandHeldLogonForm then

		return app.getErrorString(Logout);
		
	elseif self.myMobileAgent.allPreviousForms.last = MOB_HandHeldMenuForm then

		return app.getErrorString(Menu);
	
	else

		return app.getErrorString(Back);
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDefaultSystemColors" id="38133817-c764-4966-bd2c-f45fc95d3316">
        <source>getDefaultSystemColors(_sysBackColorGeneral, _sysForeColorGeneral, _sysBackColorTable, _sysForeColorTable : Integer output) : Boolean;
// -------------------------------------------
// Created 25 January 2006 by cnwdvb1
// -------------------------------------------
vars
	terminalObj		: CM_Terminal;
	tokenControl	: Label;
	screenConfig	: CM_RTScreenConfig;
begin
	terminalObj	:=	app.getMyTerminalDO_NOT_USE();
	
	if terminalObj = null then
		return false;
	endif;
	
	screenConfig:=	terminalObj.myRTVehicleConfig.myDayScreenConfig;
	
	if screenConfig = null then
		return false;
	endif;
	_sysBackColorGeneral	:=	screenConfig.screenBackColour;//terminalObj.getConfig(DefaultRTColorBackground).Integer;
	_sysBackColorTable		:=	screenConfig.tableBackColour; // terminalObj.getConfig(DefaultRTColorTableBack).Integer;
	_sysForeColorGeneral	:=	screenConfig.screenForeColour; //terminalObj.getConfig(DefaultRTColorForeground).Integer;
	_sysForeColorTable		:=	screenConfig.tableForeColour;// terminalObj.getConfig(DefaultRTColorTableFore).Integer;
	
	if _sysBackColorGeneral = null or _sysForeColorGeneral = null then
		return false;
	endif;
	
	return true;
end;</source>
        <Parameter name="_sysBackColorGeneral" type="Integer" usage="output"/>
        <Parameter name="_sysForeColorGeneral" type="Integer" usage="output"/>
        <Parameter name="_sysBackColorTable" type="Integer" usage="output"/>
        <Parameter name="_sysForeColorTable" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getHandHeldCurrentFormName" id="ea6cc111-41bd-4985-b8e9-64e60ce59b94">
