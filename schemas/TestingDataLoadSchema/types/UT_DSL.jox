    <JadeMethod name="deleteWagonAndAssociatedObjs" id="68835fa1-6aba-4843-b3b2-c506449f93b9">
        <source>deleteWagonAndAssociatedObjs( _wagon : CM_Wagon io );

//cnwndl
/*

Purpose:			Deletes wagon, cargo, jobs, audits, non-invoiced transactions

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2011	cnwndl1	Initial creation

*/

vars

	invalidWagon : Boolean;
	invalidJob : Boolean;
	invalidTi : Boolean;
	invalidLocCont : Boolean;
	iter : Iterator;
	job : CM_Job;
	jobs : CM_JobSet;
	edition : Integer;
	tiSet : CM_TISet;
	ti : CM_TrackedItem;
	locCont : CM_WagonController;
	trx : CM_EventTransaction;
	audit : CM_AuditObject;

begin

	on Exception do app.handleDeletedObject( exception, _wagon, invalidWagon );
	if _wagon = null then
		return;
	endif;
	iter := _wagon.allRailJobs.createIterator;
	if invalidWagon then
		return;
	endif;
	
	on Exception do app.handleDeletedObject( exception, job, invalidJob );
	create jobs transient;
	while iter.next( job ) do
		invalidJob := false;
		edition := job.edition;
		if not invalidJob then
			jobs.add(job);
		endif;
	endwhile;
	
	while true do
		app.myTrxDA.trxDeleteJobs(jobs, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			if app.myPassport.noErrors then
				// there must have just been warnings
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	
	delete iter;
	on Exception do app.handleDeletedObject( exception, ti, invalidTi );
	create tiSet transient;
	iter := _wagon.allTIsReceived.createIterator;
	if invalidWagon then
		return;
	endif;
	
	if not _wagon.allTIsReceived.isEmpty then
		while iter.next( ti ) do
			invalidTi := false;
			edition := ti.edition;
			if not invalidTi then
				tiSet.addNoDuplicates(ti,false);
			endif;
		endwhile;
	endif;
	
	delete iter;
	iter := _wagon.allTIsReleased.createIterator;
	if invalidWagon then
		return;
	endif;
	
	if not _wagon.allTIsReleased.isEmpty then
		while iter.next( ti ) do
			invalidTi := false;
			edition := ti.edition;
			if not invalidTi then
				tiSet.addNoDuplicates(ti,false);
			endif;
		endwhile;
	endif;
	
	delete iter;
	iter := _wagon.allNotifiedTIsByCargoID.createIterator;
	if invalidWagon then
		return;
	endif;
	
	if not _wagon.allNotifiedTIsByCargoID.isEmpty then
		while iter.next( ti ) do
			invalidTi := false;
			edition := ti.edition;
			if not invalidTi then
				tiSet.addNoDuplicates(ti,false);
			endif;
		endwhile;
	endif;
	
	delete iter;
	on Exception do app.handleDeletedObject( exception, locCont, invalidLocCont );
	iter := _wagon.allLocationsControllersArray.createIterator;
	if invalidWagon then
		return;
	endif;
	
	if not _wagon.allLocationsControllersArray.isEmpty then
		while iter.next( locCont ) do
			invalidLocCont := false;
			edition := locCont.edition;
			if not invalidLocCont then
				foreach ti in locCont.allTrackedItems do
					invalidTi := false;
					edition := ti.edition;
					if not invalidTi then
						tiSet.addNoDuplicates(ti,false);
					endif;
				endforeach;
			endif;
		endwhile;
	endif;
	
	delete iter;
	iter := tiSet.createIterator;
	while iter.next( ti ) do
		self.deleteTrackedItem(ti, false); // AKB added false
	endwhile;
	
	
	
	beginTransaction;
	foreach audit in _wagon.allAuditObjects do
		audit.setPropertyValue("myAuditConfig",null);
		audit.setPropertyValue("mySubject",null);
		audit.setPropertyValue("myUser",null);
		delete audit;
	endforeach;
	foreach trx in _wagon.allTransactions where trx.allInvoiceLines.isEmpty do
		delete trx;
	endforeach;
	
	_wagon.allLocationsControllersArray.purge;
	
/*	foreach locCont in _wagon.allLocationsControllersArray do
		delete locCont;
	endforeach;		This code resulted in a 1308 - replaced with purge above */
	
	if _wagon.myRailLine &lt;&gt; null then
		_wagon.myRailLine.removeWagon(_wagon);
	endif;
	if _wagon.myTrainOutwards &lt;&gt; null then
		_wagon.myTrainOutwards.removeWagon(false,_wagon);
	endif;
	if _wagon.myTrainInwards &lt;&gt; null then
		_wagon.myTrainInwards.removeWagon(true,_wagon);
	endif;
	_wagon.setMyTrain(false, null);
	_wagon.setMyTrain(true, null);
	_wagon.setPropertyValue("myTerminalDeparted",null);
	_wagon.setPropertyValue("myTerminal",null);
	_wagon.setPropertyValue("myWagonMaster",null);
	_wagon.setPropertyValue("myWagonClass",null);
	_wagon.setPropertyValue("myCarrier",null);
	
	delete _wagon;
	
	commitTransaction;

epilog

	delete iter;
	delete jobs;
	delete tiSet;

end;</source>
        <Parameter name="_wagon" type="CM_Wagon" usage="io"/>
    </JadeMethod>
    <JadeMethod name="deleteWagonClassAndWagons" id="0701a461-00fa-43dc-9cc0-edf55eacde1a">
        <source>deleteWagonClassAndWagons( _wagonClass : CM_WagonClass );

/*

Purpose:			
	In order to delete a Wagon Class,
	you must first delete all of its associated wagons.
		
Parameters:			

Return Value:		


Date		Who		Reason
09 July 2009	cnwndl1	Initial creation

*/

vars

	wagonClass : CM_WagonClass;
	wagon : CM_Wagon;
	
	
	
begin

	wagonClass := _wagonClass;
	
	if app.isValidObject( wagonClass ) then
		self.ignoreTrxWarnings(true);
		//app.myPassport.setWarningsIgnored(true);
		foreach wagon in wagonClass.allWagons do
			app.myTrxDA.trxDeleteWagon(wagon, false, app.myPassport);
			self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
		endforeach;
		app.myTrxDA.trxDeleteWagonClass(wagonClass, app.myPassport);
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
		self.assertTrueMsg(not app.isValidObject(wagonClass), "Wagon class deletion failed");
		

	
	endif; 
	
epilog

end;</source>
        <Parameter name="_wagonClass" type="CM_WagonClass"/>
    </JadeMethod>
    <JadeMethod name="deleteWagonMasterAndWagons" id="73011b61-78d5-4454-a96d-6755b0634ec2">
        <source>deleteWagonMasterAndWagons( _wagonMaster : CM_WagonMaster );

/*

Purpose:
			
		In order to delete a Wagon Master, you must first delete all of its associated wagons.
		
Parameters:			

Return Value:		


Date		Who		Reason
16 July 2009	cnwndl1	Initial creation

*/

vars

	wagon : CM_Wagon;
	cm_ObjectToDelete : CM_Object;
	ls : Boolean;
	wagonUpdateCtrl : CMIF_WagonUpdateController;
	train : CM_Train;
	pxyWagon : CM_Wagon;
	
begin

	if app.isValidObject( _wagonMaster ) then
		foreach wagon in _wagonMaster.allWagons do
			if wagon.confirmed then
				beginTransaction;
				wagon.erase(0);
				commitTransaction;
				continue;
			endif; 
			app.myTrxDA.trxDeleteWagon(wagon, false, app.myPassport);
			self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
			
		endforeach;
		cm_ObjectToDelete := _wagonMaster;
		app.myTrxDA.trxDeleteCMObject( cm_ObjectToDelete, app.myPassport );
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	endif;
	
epilog
	abortTransaction;
end;</source>
        <Parameter name="_wagonMaster" type="CM_WagonMaster"/>
    </JadeMethod>
    <JadeMethod name="deleteWaypoint" id="95a5952b-0bba-4ee2-8e32-8ea763902e97">
        <source>deleteWaypoint(_wayPoint : Any);

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
12 January 2012	cnwmh5	Initial creation

*/

vars
	wayPoint 				: HMS_Object;
	movementPath			: HMS_MovementPath;
	pathSegment				: HMS_PathSegment;
	routeTemplate			: HMS_RouteTemplate;
begin

	if _wayPoint.isKindOf(String) then
		wayPoint := app.myRoot.allHMSHarbourRegions[_wayPoint.String];
	elseif _wayPoint.isKindOf(HMS_HarbourRegion) then
		wayPoint := _wayPoint.HMS_HarbourRegion;
	endif;
	
	if wayPoint &lt;&gt; null then
	
		foreach movementPath in wayPoint.HMS_HarbourRegion.allMovementPaths do
			beginTransaction;
			if movementPath.myRegionFrom = wayPoint then
				movementPath.setPropertyValue('myRegionFrom', null);
			endif;
			if movementPath.myRegionTo = wayPoint then
				movementPath.setPropertyValue('myRegionTo', null);
			endif;
			commitTransaction;
		endforeach;
		
		foreach pathSegment in wayPoint.HMS_HarbourRegion.allPathSegments do
			beginTransaction;
			if pathSegment.myRegionFrom = wayPoint then
				pathSegment.setPropertyValue('myRegionFrom', null);
			endif;
			if pathSegment.myRegionTo = wayPoint then
				pathSegment.setPropertyValue('myRegionTo', null);
			endif;
			commitTransaction;
		endforeach;
	
		beginTransaction;
		foreach routeTemplate in wayPoint.HMS_HarbourRegion.allRouteTemplates do
			if routeTemplate.allHarbourRegions.includes(wayPoint.HMS_HarbourRegion) then
				routeTemplate.allHarbourRegions.remove(wayPoint.HMS_HarbourRegion);
			endif;
			wayPoint.HMS_HarbourRegion.allRouteTemplates.remove(routeTemplate);
		endforeach;
		commitTransaction;
	
		beginTransaction;
		foreach routeTemplate in app.myRoot.allRouteTemplates do
			if routeTemplate.allHarbourRegions.includes(wayPoint.HMS_HarbourRegion) then
				routeTemplate.allHarbourRegions.remove(wayPoint.HMS_HarbourRegion);
			endif;
		endforeach;
		commitTransaction;	
	
		app.myTrxDA.trxDeleteHMSObject(wayPoint, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;

epilog

end;</source>
        <Parameter name="_wayPoint" type="Any"/>
    </JadeMethod>
    <JadeMethod name="deleteWharf" id="ae35b92b-7a5c-499d-84b8-94ddd1dec330">
