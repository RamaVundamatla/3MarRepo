    <JadeMethod name="getLastGroundedLocation" id="f7d4558d-2d55-451d-a0c4-29bea1ec6bf3">
        <source>getLastGroundedLocation(_machine : CM_Machine output; _lastGroundedLocation : CM_LocationsController output);
/*

Purpose:			Returns the last grounded location of the tracked item associated with the wle;
					and if it is on a machine returns the machine

Parameters:			

Return Value:		


Date		Who		Reason
08 March 2011	cnwer1	Initial creation

*/

vars
	terminal : CM_Terminal;
	foundHeight : Integer;
	ti 			: CM_TrackedItem; 
	originalSourceLoc,lastGroundedLocation : CM_LocationsController;
	firstUncompletedEntry 	: CM_RTQueueEntry;
	pickupTask,setdownTask	 			: CM_RTQueueTask;
begin
	if self.myTrackedItem = null then
		return;
	endif;
	
	ti:=self.myTrackedItem;
	terminal:=self.getMyTerminal;
	originalSourceLoc:=self.getOriginalTaskSourceLoc();
	
	
	if ti.myPrimaryActualLocation.isKindOf(CM_MachineController) then
		_machine:=ti.myPrimaryActualLocation.CM_MachineController.myMachine;
		
		if terminal = null then	//15 Feb 2012	NDL	Par 28757
			terminal := _machine.myTerminal;
		endif;
		
		terminal.findLocationFromString(ti.priorLocation,true,lastGroundedLocation,foundHeight);
		if lastGroundedLocation = null or 
			not lastGroundedLocation.isKindOf(CM_YardController) then
			
			
			
		//RTGs are a special case if is on an RTG and the last grounded location was not a yard controller then
		// we need to get a just a location in the target RTG area if this is the 
			if _machine &lt;&gt; null and _machine.getMachineTypeGroup.type = MACHINETYPEGRP_RTG then
				firstUncompletedEntry:=self.getFirstUncompleteRTEntry;
				//should have 2 tasks 
				pickupTask:= firstUncompletedEntry.getDirectorOrPickupTask();
				if pickupTask.sourceLocation &lt;&gt; null and pickupTask.sourceLocation.isKindOf(CM_RTGController) then
					lastGroundedLocation:=pickupTask.sourceLocation;
				else
					setdownTask:=firstUncompletedEntry.getDirectorOrSetDownTask();
					if setdownTask.targetLocation &lt;&gt; null and setdownTask.targetLocation.isKindOf(CM_RTGController) then
						lastGroundedLocation:=setdownTask.targetLocation;
					endif;
				endif;
				
				if not lastGroundedLocation.isKindOf(CM_YardController) then
					lastGroundedLocation:=originalSourceLoc;
				endif;
				
			else
				lastGroundedLocation:=originalSourceLoc;
			endif;
		endif;
	else
		lastGroundedLocation:=ti.myPrimaryActualLocation;
	endif;
	
	_lastGroundedLocation:=lastGroundedLocation;
epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="output"/>
        <Parameter name="_lastGroundedLocation" type="CM_LocationsController" usage="output"/>
    </JadeMethod>
