    <JadeMethod name="doInitializeWithObject" id="f46964b0-0033-4521-b289-d014720ca578">
        <updating/>
        <source>doInitializeWithObject( ) updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		See setInitializeWithObject. the areamode has aleady been set. They may also be a secong init object - sub block, restriction etc
//
// ---------------------------------------------------------------------------
// 06/11/2012	cnwcs5	par 30475 - removed references to location restrictions
// 22/11/2016	cnwdap1	TFS 2844 STWR Hazardous Details Enhancements
vars
	idx 		: Integer;
	aGridPoint 	: CMUI_GridPoint;
	centrePoint : CM_LocationsController;
	centreOn 	: Boolean;
begin
	self.lstRestrictions.listIndex 	:= -1;
	self.sptThumbEdit.visible 		:= false;
	centreOn 						:= false;

	if self.myCurrentObject &lt;&gt; null then
		self.myCurrentTerminalArea := self.myCurrentObject.CM_TerminalArea;
	endif;
	
	if self.myCurrentTerminalArea &lt;&gt; null then // set in setInitializeWithObject
		if not self.isValidType(myCurrentTerminalArea) then
			return;
		endif;
		
		self.cmbTermAreas.listObject := self.myCurrentTerminalArea;
		
		self.doShowTerminalArea(self.myCurrentTerminalArea);
		
		if self.theAreaMode = YRD_PadArea.AreaMode_Labour then
			if self.myCurrentLabourRestriction &lt;&gt; null then
				self.lstRestrictions.listObject := self.myCurrentLabourRestriction;
				centrePoint 					:= self.myCurrentLabourRestriction.allLocationControllers.first;
			endif;
		
		elseif self.theAreaMode = YRD_PadArea.AreaMode_SubBlock then
			if self.myCurrentSubBlockStack &lt;&gt; null then
				self.lstRestrictions.listObject := self.myCurrentSubBlockStack;
				centrePoint 					:= self.myCurrentSubBlockStack.allByPassedControllers.first;
			endif;

		elseif self.theAreaMode = YRD_PadArea.AreaMode_TermSubArea then
			if self.myCurrentTermSubArea &lt;&gt; null then
				self.lstRestrictions.listObject := self.myCurrentTermSubArea;
				centrePoint 					:= self.myCurrentTermSubArea.allYardControllers.first;
			endif;
		
		elseif self.theAreaMode = YRD_PadArea.AreaMode_DoorDirection then	//ccms1572	cnwvu1
			if self.myCurrentDoorDirectionRule &lt;&gt; null then
				self.lstRestrictions.listObject := self.myCurrentDoorDirectionRule;
				centrePoint 					:= self.myCurrentDoorDirectionRule.allDoorDirectionLocations.first.myLocationsController;
			endif;
			
		elseif self.theAreaMode = YRD_PadArea.AreaMode_Hazardous then							// TFS 2844
			if self.myCurrentHazardDetail &lt;&gt; null then											// TFS 2844
				self.lstRestrictions.listObject := self.myCurrentHazardDetail;					// TFS 2844
				centrePoint := self.myCurrentHazardDetail.allLocationsControllers.first;		// TFS 2844
			endif;																				// TFS 2844
		endif; 
		
		if centrePoint &lt;&gt; null then
			aGridPoint := self.mySDF.getPointFromLC(centrePoint);
			
			if aGridPoint &lt;&gt; null then
				centreOn := true;
			endif;
		endif;

	endif;
	
	// if no init object then the listIndex will be -1 so go to the heading for the areamode
	if self.lstRestrictions.listIndex &lt; 0 then
		idx := self.getListIndexForAdd() - 1;
		
		if idx &gt; 0 then
			self.lstRestrictions.listIndex := idx;
		endif;
	endif;
	
	if self.lstRestrictions.listIndex &gt; 0 then
		self.lstRestrictions.itemExpanded[self.lstRestrictions.listIndex] := true;
		self.doLstRestrictionsClick(self.lstRestrictions);
		if self.myInitController &lt;&gt; null // a Grid Controller has been passed in...
			and self.theAreaMode = YRD_PadArea.AreaMode_Height then
			aGridPoint := self.mySDF.getPointFromLC(self.myInitController);
			
			if aGridPoint &lt;&gt; null then
				centreOn := true;
			endif;
		endif;

		if aGridPoint &lt;&gt; null and centreOn then
			self.frmGridArea.myGridArea.allSelectedPoints.clear;
			self.frmGridArea.myGridArea.allSelectedPoints.add(aGridPoint);
			aGridPoint.drawSelf(self.frmGridArea.myGridArea.myGridAreaFrame);
			self.mySDF.doCentreOnSelectedPoint();
			
			if self.theAreaMode = YRD_PadArea.AreaMode_Height then
				self.btnEditTV.click(self.btnEditTV);
			endif;
		endif;

	endif;
epilog
	self.sptThumbEdit.visible := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="doLstRestrictionsClick" id="66c8fe24-8457-4d30-ac1c-ce0d9dc1a93c">
        <updating/>
        <source>doLstRestrictionsClick(listbox : ListBox) updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 06/11/2012	cnwcs5	par 30475 - remove references to location restrictions
// 22/11/2016	cnwdap1	TFS 2844 STWR Hazardous Details Enhancements
vars
	theSheet 	: CMUI_Sheet;
	theObject 	: Object;
	theArea 	: YRD_PadArea;
	
begin
	app.mousePointer	:=	Busy;
	theArea 			:= self.frmGridArea.myGridArea.YRD_PadArea;
	self.theAreaMode 	:=  listbox.itemData[listbox.listIndex];
	if self.theAreaMode = null then
		self.btnEditTV.enabled 		:= false;
		self.btnNewTV.enabled 		:= false;
		self.btnDeleteTV.enabled	:= false;
		return;
		
	elseif self.theAreaMode = YRD_PadArea.AreaMode_DoorDirection and 	// par 30475
		not self.myCurrentTerminalArea.isGridArea() then
		self.btnEditTV.enabled 		:= false;
		self.btnNewTV.enabled 		:= false;
		self.btnDeleteTV.enabled 	:= false;
		return;
	endif;
	theObject :=  listbox.itemObject[listbox.listIndex];
	
	if theObject = self.myCurrentTerminalArea then
		theObject := null;
	endif;
	self.doEnableControls(false);
	self.frmGridArea.enabled := false;
	self.mulNotifyEmails.visible := true;								// TSF 2844

	if theArea &lt;&gt; null then
		if theArea.areaMode &lt;&gt; self.theAreaMode or self.amInitialisingWithObject then
			self.amInitialisingWithObject 	:= false;
			theArea.areaMode 				:= self.theAreaMode;
			
			theArea.doClearUpLabels();

			theArea.drawingMode := true;
			
			theArea.mySDF.drawSelf();
			
			theArea.drawingMode := false;

			self.setMyDataClass();
			self.doSheetRedraw(self.theAreaMode);
		else
			//cnwjo3 ccms 1018.  need this here so top right table is displayed correctly.
			self.setMyDataClass();
			self.doSheetRedraw(self.theAreaMode);
		endif;
	else
		self.setMyDataClass();
		self.doSheetRedraw(self.theAreaMode);
	endif;
	self.setUpdateDeleteTBButtons(self.theAreaMode);
	if theObject &lt;&gt; null then
		self.myCurrentObject := theObject;
		
		if self.theAreaMode = YRD_PadArea.AreaMode_SubBlock then
			self.displaySBS(theObject.CM_SubBlockStack);
		
		elseif self.theAreaMode = YRD_PadArea.AreaMode_Labour then
			self.displayLabour(theObject.CM_LabourRestriction);
				
		elseif self.theAreaMode = YRD_PadArea.AreaMode_TermSubArea then 
			self.displayTermSubArea(theObject.CM_TerminalSubArea);
		
		elseif self.theAreaMode = YRD_PadArea.AreaMode_DoorDirection then
			self.displayDoorDirectionRule( theObject.CM_DoorDirectionRule );
			
		elseif self.theAreaMode = YRD_PadArea.AreaMode_Hazardous then					// TFS 2844
			self.loadCombos();															// TFS 2844
			self.displayHazardDetails(theObject.CM_TerminalAreaHazDetails);				// TFS 2844
			if not app.myCurrentUserCan(self.myTerminal, PmAdmHazardAreaMaint) then		// TFS 2844
				self.btnEditTV.enabled := false;										// TFS 2844
				self.btnNewTV.enabled := false;											// TFS 2844
				self.btnDeleteTV.enabled := false;										// TFS 2844
			endif;																		// TFS 2844
		endif;
	else
		// they have clicked on a heading
		if self.theAreaMode = YRD_PadArea.AreaMode_Height then
			self.setUpdateDeleteTBButtons(self.theAreaMode);
			self.myCurrentObject := self.myCurrentTerminalArea;
		
		elseif self.theAreaMode = YRD_PadArea.AreaMode_SubBlock then
			self.myCurrentSubBlockStack := null;
		
		elseif self.theAreaMode = YRD_PadArea.AreaMode_Labour then
			self.myCurrentLabourRestriction := null;
				
		elseif self.theAreaMode = YRD_PadArea.AreaMode_TermSubArea then 
			self.myCurrentTermSubArea := null;
		
		elseif self.theAreaMode = YRD_PadArea.AreaMode_DoorDirection then
			self.myCurrentDoorDirectionRule := null;
	
		elseif self.theAreaMode = YRD_PadArea.AreaMode_Hazardous then					// TFS 2844
			self.loadCombos();															// TFS 2844
			self.myCurrentHazardDetail := null;											// TFS 2844
			if not app.myCurrentUserCan(self.myTerminal, PmAdmHazardAreaMaint) then		// TFS 2844
				self.btnEditTV.enabled := false;										// TFS 2844
				self.btnNewTV.enabled := false;											// TFS 2844
				self.btnDeleteTV.enabled := false;										// TFS 2844
			endif;																		// TFS 2844
			
		endif;
	endif;
	
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="listbox" type="ListBox"/>
    </JadeMethod>
    <JadeMethod name="doMenuHeightsClick" id="af41b3fc-d725-4b22-b6d2-3c330995c4c3">
        <updating/>
        <source>doMenuHeightsClick(_theMode, _theValue : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		We allow the user to paint power good, power bad, locations avail or unavail
//				Plus height restrictions. We store each of these as a seperate set of updates to the location controller
//				When they click the height save button we pass the array of CMIF objects to the TRX
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aPoint : CMUI_GridPoint;
	rtnValue, noPower : Boolean;
	aController : CM_LocationsController;
	obj			: Object;
	iObj,
	anInterfaceObject : CMIF_GridTARegion;
	theFrame : CMUI_GridAreaFrame;
begin
	//if self.myCurrentTerminalArea.type = TA_TYPE_BLOCK_STACK  then
	if self.myCurrentTerminalArea.isRestrictionBlockStack() then
	 	return;
	endif;
	create anInterfaceObject transient; // this is deleted in the save button
	
	self.allInterfaceObjects.add(anInterfaceObject);
	theFrame := self.frmGridArea;
	anInterfaceObject.updateMode := _theMode;
//	anInterfaceObject.remarks := self.txtHeight.text;
	noPower := false;
	
	//cnwjo3
	if self.myCurrentTerminalArea.isKindOf(CM_GridArea) then
		anInterfaceObject.myGridArea := self.myCurrentTerminalArea.CM_GridArea;
	else
		return;  //could be a RoRo.  Can't do much here
	endif;
	
	foreach aPoint in self.frmGridArea.myGridArea.allSelectedPoints do
		aController := aPoint.myLocationsController;
		if aController &lt;&gt; null then
			if aController.isKindOf(CM_GapController) then
				continue;
			else
				anInterfaceObject.allLocationControllers.add(aController);
			endif;
			foreach obj in self.allInterfaceObjects do
				iObj := obj.CMIF_GridTARegion;
				if iObj = anInterfaceObject then
					continue;
				endif;
				//remove these from other interface objects
				if iObj.allLocationControllers.includes(aController) then
					iObj.allLocationControllers.remove(aController);
				endif;
			endforeach;
		endif;
		// ### HEIGHTS, Availability etc
		if _theMode &lt;&gt; CMIF_GridTARegion.UpdateMode_PowerGood
		and _theMode &lt;&gt; CMIF_GridTARegion.UpdateMode_PowerDamaged then
			anInterfaceObject.oldAvailability := aPoint.YRD_PadPoint.availability; // for undoing
			anInterfaceObject.availability := _theValue;
			aPoint.YRD_PadPoint.availability := _theValue;
			aPoint.drawSelf(theFrame);
		// ### POWER GOOD OR BAD
		else
			if aPoint.YRD_PadPoint.power then
				if _theMode = CMIF_GridTARegion.UpdateMode_PowerGood then
					anInterfaceObject.oldPowerDamaged := aPoint.YRD_PadPoint.powerDamaged;
					aPoint.YRD_PadPoint.powerDamaged := false;
				endif;
				// only do this if the point has a power ability
				if _theMode = CMIF_GridTARegion.UpdateMode_PowerDamaged and aPoint.YRD_PadPoint.power then
					anInterfaceObject.oldPowerDamaged := aPoint.YRD_PadPoint.powerDamaged;
					aPoint.YRD_PadPoint.powerDamaged := true;
				endif;
				aPoint.drawSelf(theFrame);
			else
				noPower := true;
			endif;
		endif;
	endforeach;
	if noPower then
		app.msgBox("Some/All of the locations selected do not have power abilities. " &amp; Cr &amp; "Locations without power abilities cannot have the power Damaged/Good set" 
			&amp; Cr &amp; "No action will be taken with these locations.","No Power Ability",MsgBox_OK_Only + MsgBox_Information_Icon);
	endif;
	
end;</source>
        <Parameter name="_theMode" type="Integer"/>
        <Parameter name="_theValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doMenuHeightsHide" id="9809e0c2-17df-4e59-bfca-7af1ea961a46">
        <source>doMenuHeightsHide(_visible : Boolean; _enabled : Boolean);
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.mnuHeights.visible := _visible;
	self.mnuHNothing1.visible := _visible;
	self.mnuHNothing2.visible := _visible;
	self.mnuHNothing3.visible := _visible;
	self.mnuHNothing4.visible := _visible;
	self.mnuHNothing5.visible := _visible;
	self.mnuHNothing6.visible := _visible;
	self.mnuHNothing7.visible := _visible;
	self.mnuHNothing8.visible := _visible;
	self.mnuHPadAvail.visible := _visible;
	self.mnuHPadUnavail.visible := _visible;
	self.mnuHPowerDamaged.visible := _visible;
	self.mnuHPowerGood.visible := _visible;
	self.mnuLegend.visible := _visible;
	self.btnPenUnavail.visible := _visible;
	self.btnPenPower.visible := _visible;
	self.btnPenAvail.visible := _visible;
	self.btnPenPowerDam.visible := _visible;
//	self.doBuildMenuHeights();
	self.btnPenHeight1.enabled := _enabled;
	self.btnPenHeight2.enabled := _enabled;
	self.btnPenHeight3.enabled := _enabled;
	self.btnPenHeight4.enabled := _enabled;
	self.btnPenHeight5.enabled := _enabled;
	self.btnPenHeight6.enabled := _enabled;
	self.btnPenHeight7.enabled := _enabled;
	self.btnPenHeight8.enabled := _enabled;
	self.btnPenUnavail.enabled := _enabled;
	self.btnPenPower.enabled := _enabled;
	self.btnPenAvail.enabled := _enabled;
	self.btnPenPowerDam.enabled := _enabled;

	self.frmToolbar.positionToolbarControls();
end;</source>
        <Parameter name="_visible" type="Boolean"/>
