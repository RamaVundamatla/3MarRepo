    <JadeMethod name="getTerminalsForUser" id="22dc9365-88db-49b1-a07a-21270c329f83">
        <source>getTerminalsForUser();
//
// cnwrs1 aug 2007 CCMS 1017
//
vars
	user : CM_User;
	userTerminal : CM_UserTerminal;
	iter : Iterator;
begin
	self.allTerminalsForThisUser.clear();
	user := app.getMyUser();
	iter := user.allUserTerminals.createIterator();
	while iter.next(userTerminal) do
		self.allTerminalsForThisUser.add(userTerminal.getRealTerminal);
	endwhile;
epilog
	delete iter;	
end;</source>
    </JadeMethod>
    <JadeMethod name="includeObject" id="8878c55d-d846-4c12-ad28-116578d06f34">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
// --------------------------------------------------------------------------------
// Created:		24 April 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.includeNotAvailableEntries then
		return true;
	else
		return not _obj.CM_StopsTable.isNotAvailableForEntry;
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initShtDataTable1" id="c733ff20-78b8-4bb1-bac2-6c9ab4c83877">
        <updating/>
        <source>initShtDataTable1() updating;
// ---------------------------------------------------------------------------
// Created:     04 June 2009 by concms1:1
// Purpose:     par 19830
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	form	:SOP_TableMaintForm;
	table	:Table;
begin 
	inheritMethod(); 
	
	form 	:= self.myForm;
	table	:= form.tblData1;
	
	form.shtDataTable1.visible	:= true;
	form.shtDataTable1.caption	:= app.getErrorString (Stop_Table_Terminals);
	
	table.clear;
	table.rows		:= 0;
	table.columns	:= 2;
	table.fixedRows	:= 0;
	table.selectMode 	:= Table.SelectMode_CurrentRow;
	
	table.accessColumn(1).inputType	:= Table.InputType_None;
	table.wordWrap					:= true;
	table.columnWidth[1]			:= 200;
	table.columnWidth[2]			:= table.clientWidth - table.columnWidth[1];
	table.autoSize					:= Table.AutoSize_Row;
	table.top						:= form.frmTBDataTable1.height + 1;
	form.frmTBDataTable1.visible	:= true;
epilog

end;</source>
    </JadeMethod>
