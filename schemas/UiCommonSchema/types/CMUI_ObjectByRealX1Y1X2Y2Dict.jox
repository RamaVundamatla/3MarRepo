    <JadeMethod name="findObjectInDict" id="cae00e40-24de-477b-b255-8a41b9bad47f">
        <lockReceiver/>
        <updating/>
        <source>findObjectInDict( x, y : Real; _x1,_y1,_x2,_y2 : Real output; _z : Integer output) : Object updating;
// ---------------------------------------------------------------------------
// Created:     30 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpObj		: Object;
	x1, y1,
	x2, y2		: Real;
	z :			Integer;
	tmpIterator	: Iterator;
begin
	tmpIterator := self.myIterator;
	
	if tmpIterator = null then
		self.myIterator := self.createIterator();
//		app.raiseUnexpectedProgramError(class.name, method.name, 'myIterator = null');
//		return null;
	endif;
	
	tmpIterator.reset();

	/*
	tmpObj := self.getAtKeyGeq(x1,y1,0,0);
	if tmpObj &lt;&gt; null then
		tmpIterator.startAtObject(tmpObj);
		tmpIterator.back(tmpObj);
	endif;
	*/
	while tmpIterator.next(tmpObj) do
		self.getIteratorKeys(x1, y1, x2, y2,z, tmpIterator);
		if x &gt;= x1 and
		   x &lt;= x2 and
		   y &gt;= y1 and
		   y &lt;= y2 then
			_x1:=x1;
			_y1:=y1;
			_x2:=x2;
			_y2:=y2;
			_z:=z;
			return tmpObj;
		endif;
	endwhile;

	return null;
end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="_x1" type="Real" usage="output"/>
        <Parameter name="_y1" type="Real" usage="output"/>
        <Parameter name="_x2" type="Real" usage="output"/>
        <Parameter name="_y2" type="Real" usage="output"/>
        <Parameter name="_z" type="Integer" usage="output"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="findObjectInDictByClass" id="89ac7518-ffb0-491a-86c4-9161d1bd1ed3">
        <lockReceiver/>
        <updating/>
        <source>findObjectInDictByClass( x, y : Real; _x1,_y1,_x2,_y2 : Real output; _class : Class) : Object updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpObj		: Object;
	x1, y1,
	x2, y2		: Real;
	z  		: Integer;
	tmpIterator	: Iterator;
	
begin
	tmpIterator := self.myIterator;
	
	if tmpIterator = null then
		self.myIterator := self.createIterator();
//		app.raiseUnexpectedProgramError(class.name, method.name, 'myIterator = null');
//		return null;
	endif;
	
	tmpIterator.reset();
	
	while tmpIterator.next(tmpObj) do
		if not tmpObj.isKindOf(_class) then
			continue;
		endif;

		self.getIteratorKeys(x1, y1, x2, y2,z, tmpIterator);
		if x &gt;= x1 and
		   x &lt;= x2 and
		   y &gt;= y1 and
		   y &lt;= y2 then
			_x1:=x1;
			_y1:=y1;
			_x2:=x2;
			_y2:=y2;
			return tmpObj;
		endif;
	endwhile;

	return null;
end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="_x1" type="Real" usage="output"/>
        <Parameter name="_y1" type="Real" usage="output"/>
        <Parameter name="_x2" type="Real" usage="output"/>
        <Parameter name="_y2" type="Real" usage="output"/>
        <Parameter name="_class" type="Class"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="findObjectInDictGetXY" id="a46a999e-968a-4c85-b29f-6e87161e6968">
        <lockReceiver/>
        <updating/>
        <source>findObjectInDictGetXY(_obj : Object; _x1,_y1,_x2,_y2 : Real output; _z : Integer output) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     30 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpObj		: Object;
	x1, y1,
	x2, y2		: Real;
	z 			: Integer;
	tmpIterator	: Iterator;
begin
	tmpIterator := self.myIterator;
	
	if tmpIterator = null then
		self.myIterator := self.createIterator();
//		app.raiseUnexpectedProgramError(class.name, method.name, 'myIterator = null');
//		return false;
	endif;
	
	tmpIterator.reset();
	
	tmpIterator.startAtObject(_obj);
	while tmpIterator.next(tmpObj) do
		self.getIteratorKeys(x1, y1, x2, y2,z,  tmpIterator);
			_x1:=x1;
			_y1:=y1;
			_x2:=x2;
			_y2:=y2;
			_z :=z;
			return true;
	endwhile;

	return false;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_x1" type="Real" usage="output"/>
        <Parameter name="_y1" type="Real" usage="output"/>
        <Parameter name="_x2" type="Real" usage="output"/>
        <Parameter name="_y2" type="Real" usage="output"/>
        <Parameter name="_z" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findObjectsInDict" id="c3baca7c-dda5-442d-a198-bd566b061901">
        <lockReceiver/>
        <updating/>
        <source>findObjectsInDict( _x1, _y1,_x2,_y2 : Real; _objs : ObjectArray input; _class : Class; _includeTouched : Boolean) updating ;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpObj		: Object;
	x1, y1,
	x2, y2		: Real;
	z 			: Integer;
	tmpIterator	: Iterator;
begin
	if _objs = null then
		return;
	endif;
	
	tmpIterator := self.myIterator;
	
	if tmpIterator = null then
		self.myIterator := self.createIterator();
//		app.raiseUnexpectedProgramError(class.name, method.name, 'myIterator = null');
//		return;
	endif;
	
	tmpIterator.reset();
	
	while tmpIterator.next(tmpObj) do
		self.getIteratorKeys(x1, y1, x2, y2,z, tmpIterator);
		
		if _includeTouched then
			if ((x1 &lt;= _x1 and x2 &gt;= _x1) or (x1 &gt;= _x1 and x2 &lt;= _x2) or (x1 &lt;= _x2 and x2 &gt;= _x2))
			and ((y1 &lt;= _y1 and y2 &gt;= _y1) or (y1 &gt;= _y1 and y2 &lt;= _y2) or (y1 &lt;= _y2 and y2 &gt;= _y2)) then
			
				if tmpObj.isKindOf(_class) then
					if not _objs.includes(tmpObj) then
					   _objs.add(tmpObj);
					  endif;
				endif;
			endif;
		else
			if x1 &gt;= _x1 and
			   x2 &lt;= _x2 and
			   y1 &gt;= _y1 and
			   y2 &lt;= _y2 then
	
				if tmpObj.isKindOf(_class) then
					if not _objs.includes(tmpObj) then
					   _objs.add(tmpObj);
					  endif;
				endif;
			endif;
		endif;
	endwhile;

end;</source>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_objs" type="ObjectArray" usage="input"/>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_includeTouched" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findObjectsInDictAtXY" id="027a0cd5-1d3c-450c-8225-89745b68fa71">
