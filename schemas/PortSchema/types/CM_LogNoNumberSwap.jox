    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <ImplicitInverseRef name="myOtherTrackedItem" id="79383a55-ff5e-4119-8806-8755e82b5a93">
        <embedded/>
        <type name="CM_TrackedItem"/>
        <access>protected</access>
    </ImplicitInverseRef>
