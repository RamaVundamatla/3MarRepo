<CollClass name="CM_EmailEntityByTypeNameDict" id="ef81a7fa-90c6-4213-9929-1bf28c3f117f">
    <loadFactor>66</loadFactor>
    <memberType name="CM_EmailEntity"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cams"/>
    <MemberKey>
        <property name="CM_EmailEntity::type"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_EmailEntity::name"/>
    </MemberKey>
    <JadeMethod name="getAddresses" id="60d4ba4c-2490-441b-b9c7-32322b39419e">
        <source>getAddresses() : String;
// -------------------------------------------
// Created 06 November 2003 by cnwdvb1
// -------------------------------------------
vars

	entity	: CM_EmailEntity;
	str		: String;

begin

	foreach entity in self do
		str := str &amp; ';' &amp; entity.getEmailAddress();
	endforeach;
	if str.length &gt; 1 then
		return str[2:end];
	endif;


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNames" id="2a1a071e-ad14-43c7-9ed6-83b30bf92b01">
        <source>getNames() : String;
// -------------------------------------------
// Created 05 November 2003 by cnwdvb1
// -------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	entity	: CM_EmailEntity;
	str		: String;
begin

	foreach entity in self do
		str := str &amp; ';' &amp; entity.name;
	endforeach;

	if str.length &gt; 1 then
		return str[2:end];
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
