    <JadeMethod name="setFilterDefaults" id="8d50f991-18f7-4c2f-a25e-d084dda53ec5">
        <updating/>
        <source>setFilterDefaults() updating;
// ---------------------------------------------------------------------------
// Created:     06 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	13/05/2022  navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
//  13 Dec 2022 navmp20 ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes
// ---------------------------------------------------------------------------
vars
	today			: Date;
begin


	self.filterTimeIn		:= null;
	self.filterTimeOut	 	:= null;
	self.filterCarrier		:= null;
	self.filterSubCarrier  	:= null;				//13/05/2022 navhl20 TFS 53430 
	self.cmbFiltCarrier.listObject	:= null;
	self.cmbFiltSubCarrier.listObject := null;			//13/05/2022 navhl20 TFS 53430 
	self.cmbFiltVoyage.listObject	:= null;
	self.cmbFiltAGateUser.listObject	:= null;//cnwrd1 ccms 1862 par 27435 2.5.2011
	self.cmbFiltCargoType.listObject	:= null; // cnwwrd1 ccms 1695 23.1.09
	self.cmbFiltDirection.text	:= Direction_Both;
	//par 16321
	self.tblSearch.setValueByControlName(self.cmbFiltDirection.name, self.cmbFiltDirection.text);
	self.filterRegNumber 	:= null;
	self.cmbStevedore.listObject	:= null;	//13 Oct 2020	NDL	TFS 49189
	self.cmbFiltInStatus.listIndex  := -1;      //13.12.2022  navmp20 TFS 55580
	self.cmbFiltOutStatus.listIndex := -1;      //13.12.2022  navmp20 TFS 55580
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setFilterValues" id="128db1b7-0b52-4d33-a523-06a3a81364fe">
        <updating/>
        <source>setFilterValues() updating;
//15/01/2015	cnwma1		PAR #35462 Carrier Drop-down Fields	
//14/04/2016	cnwmp6		TFS 488 - Multi timezone support
//13/05/2022 	navhl20 	TFS 53430  EUP - Sub Carrier registration in MTN
//13 Dec 2022   navmp20     ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes
//17 Nov 2023   navlc30     ChangeRequest 61254: EUP | FR | 54329 | VBS - Pending issues - Issue 8
// 06 Aug 2025	naviv1		MTN-35545: FR 35007.020 Display Release Request ID in Vehicle Visit Enquiry
vars
	timeInLocal,
	timeOutLocal,
	timeInSystem,
	timeOutSystem: TimeStamp;
begin
	timeInLocal.setDate(tblSearch.getValueByName(ETRow_FilterDateIn).Date);
	timeInLocal.setTime(tblSearch.getValueByName(ETRow_FilterTimeIn).Time);
	timeInSystem := self.localToSystemTime(timeInLocal);
	timeOutLocal.setDate(tblSearch.getValueByName(ETRow_FilterDateOut).Date);
	timeOutLocal.setTime(tblSearch.getValueByName(ETRow_FilterTimeOut).Time);
	timeOutSystem := self.localToSystemTime(timeOutLocal);
	
	self.filterTimeIn.setDate(timeInSystem.Date);
	self.filterTimeIn.setTime(timeInSystem.Time);
	self.filterTimeOut.setDate(timeOutSystem.Date);
	self.filterTimeOut.setTime(timeOutSystem.Time);
	
	//self.filterCarrier			:= self.tblSearch.getValueByName(ETRow_FilterCarrier).String; // 12/01/2015 cnwma1 PAR #35462
	if self.cmbFiltCarrier.listObject.CM_Carrier &lt;&gt; null then  									  // 12/01/2015 cnwma1 PAR #35462
		self.filterCarrier		:= self.cmbFiltCarrier.listObject.CM_Carrier.code;
	else
		self.filterCarrier		:= null;
	endif;
	
	//Start 13/05/2022 navhl20 TFS 53430
	if self.isSubCarrierEnabled and self.cmbFiltSubCarrier.listObject.CM_Carrier &lt;&gt; null then  								
		self.filterSubCarrier		:= self.cmbFiltSubCarrier.listObject.CM_Carrier.code;
	else
		self.filterSubCarrier		:= null;
	endif;
	//Start 13/05/2022 navhl20 TFS 53430
	
	self.filterDirection 		:= self.tblSearch.getValueByName(ETRow_FilterDirection).String;
	self.filterCargoID			:= self.tblSearch.getValueByName(ETRow_FilterCargoID).String;
	self.filterBOL				:= self.tblSearch.getValueByName(ETRow_FilterBOL).String;
	self.filterBookingRef		:= self.tblSearch.getValueByName(ETRow_FilterBookingRef).String;
	self.filterReleaseRequestID	:= self.tblSearch.getValueByName(ETRow_FilterReleaseRequestID).String;  //12-Aug-2025 naviv1 MTN-35545
	self.filterGatePass			:= self.tblSearch.getValueByName(ETRow_FilterGatePass).String;
	
	if self.cmbFiltCargoType.listObject.CM_CargoType &lt;&gt; null then //cnwrd1 ccms 1695 23.1.09
		self.filterCargoType		:= self.cmbFiltCargoType.listObject.CM_CargoType.id;
		if self.cmbCargoSubType.listObject.CM_Product &lt;&gt; null then	//13 Oct 2020	NDL	TFS 49189
			self.filterCargoSubType := self.cmbCargoSubType.listObject.CM_Product;
		else
			self.filterCargoSubType := null;
		endif;
	else
		self.filterCargoType		:= null;
		self.filterCargoSubType := null;	//13 Oct 2020	NDL	TFS 49189
	endif;
	
	if self.cmbFiltVoyage.listObject.CM_Voyage &lt;&gt; null then
		self.filterVoyageCode := self.cmbFiltVoyage.listObject.CM_Voyage.code;
	else	
		self.filterVoyageCode := null;
	endif;
	
	//cnwrd1 ccms 1862 par 27435 2.5.2011
	if self.cmbFiltAGateUser.listObject.CM_User &lt;&gt; null then
		self.filterAGateUserCode := self.cmbFiltAGateUser.listObject.CM_User.code;
	else	
		self.filterAGateUserCode := null;
	endif;
	
	//epr par 35090 20/11/14
	self.filterRegNumber		:= self.tblSearch.getValueByNameIfVisible(ETRow_FilterRegNumber).asStringJMT.trimBlanks.toUpper;
	//epr 21/1/15 CCMS 1409 par 35553 
	self.filterEIR 			:=self.tblSearch.getValueByNameIfVisible(ETRow_FilterEIR).asStringJMT.trimBlanks.toUpper;
	
	//13 Oct 2020	NDL TFS 49189
	if self.cmbStevedore.listObject.CM_Stevedore &lt;&gt; null then
		self.filterStevedore := self.cmbStevedore.listObject.CM_Stevedore;
	else
		self.filterStevedore := null;
	endif;
	
	self.filterInStatus := self.cmbFiltInStatus.text;     //13.12.2022  navmp20 TFS 55580
	self.filterOutStatus:= self.cmbFiltOutStatus.text;    //13.12.2022  navmp20 TFS 55580
	
	self.filterVBSId := self.tblSearch.getValueByName(ETRow_FilterVBSId).String;									//17.11.2023 navlc30 #61254
	self.filterExternalReference := self.tblSearch.getValueByName(ETRow_FilterExternalReference).String;			//17.11.2023 navlc30 #61254
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setFromQuickFind" id="35f84c3a-cdf9-4659-ab16-aa8dde213444">
        <updating/>
        <source>setFromQuickFind( _vvr : CM_VehicleVisitRecord; _text : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2014	cnwndl1	Initial creation	Par 33350

*/

vars

begin

	if _vvr &lt;&gt; null then
		//epr par 35090 20/11/14
		if _vvr.vehicle &lt;&gt; null then
			self.tblSearch.setValueByName(ETRow_FilterRegNumber, _vvr.vehicle.regNumber);
		endif;
		self.tblSearch.setValueByName(ETRow_FilterDateIn, self.systemToLocalTime(_vvr.timeIn).Date);	// 14/4/16 cnwmp6 TFS 488 - Multi timezone support
		self.tblSearch.setValueByName(ETRow_FilterTimeIn, "00:00".Time);
		self.filterTimeIn.setDate(_vvr.timeIn.Date);
		self.filterTimeIn.setTime("00:00".Time);
		
		self.tblSearch.setValueByName(ETRow_FilterDateOut, self.systemToLocalTime(_vvr.timeOut).Date);	// 14/4/16 cnwmp6 TFS 488 - Multi timezone support
		self.tblSearch.setValueByName(ETRow_FilterTimeOut, "23:59".Time);
		self.filterTimeOut.setDate(_vvr.timeOut.Date);
		self.filterTimeOut.setTime("23:59".Time);
		
		self.tblSearch.setValueByName(ETRow_FilterGatePass, _vvr.visitNumber);
		self.filterGatePass := _vvr.visitNumber;
		
		self.isFirstActivateComplete := true;
		self.zDoSearch();
		self.tblData.setFocus();
		
	endif;
	

epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
        <Parameter name="_text" type="String"/>
    </JadeMethod>
    <JadeMethod name="setMyDataClass" id="36d9e6b5-cd94-4321-b7e5-72374bde8dd1">
        <updating/>
        <source>setMyDataClass() updating;
// ---------------------------------------------------------------------------
// Created:     19 February 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myDataClass := CM_VehicleVisitRecord;

end;</source>
    </JadeMethod>
    <JadeMethod name="setSearcherHeight" id="224c22ef-c23a-4a87-bdaf-ed874c489e95">
        <source>setSearcherHeight();
/*
----------   ----------  --------------------------------------------------
Created:	13 April 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
constants
	RowHeight		: Integer = 20;		// Nominal row height for CM_EntryTables for calc of height
 
vars
 entTableDef		: EntTableDef;
	theTable		: CM_EntryTable;
begin
	theTable := self.tblSearch;
	
	entTableDef := app.myController.getEntTableDef(ETDef_VisitRecordForFind);
	self.tblSearch.adjustHeight(RowHeight * entTableDef.allEntTableRows.size);//added by cnwyl1 for par13847
	self.frmSearch.height := tblSearch.height + tblSearch.top + 25;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupContextMenuItems" id="8005a0d4-d70d-4f80-9520-7d38f23a6238">
        <updating/>
        <source>setupContextMenuItems(conwin: Window input) updating;
//--------------------------------------------------
// Created:	17 February 2004 By: cnwgd1
//--------------------------------------------------
// 25/11/2011	cnwdap1		PAR #28733 CCMS SFW 1261 added new Reprint Driver Instructions menu item
// 14/05/2022 	navhl20		TFS 53430  EUP - Sub Carrier registration in MTN
// 12 sep 2022	navtnr20	Bug 52463: MTN - Vehicle Visit Cancellation Issues
// 13 Dec 2022  navmp20     ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes
// 07 Mar 2023	navdap1		TFS 57001 FR | 53667 - EUP - Inspection App checks - New Fields in Column Organiser
// 06 Apr 2023	jlizm1		TFS 57098 EUP Seal numbers on trucks
// 27/09/2023	navkc1		CR 60428 Task 60702: UI - Cargo Review Option in Transport UI
// 23/01/2024	navcs2		ChangeRequest 57088: EUP | Correct Info on Departed Transport for Itemized Cargo
//14/02/2024	navcs2	Bug 62454: FR | 53667 - Inspection App - Resend Message discrepancy (Removed Some Code)
// 26/07/2024   navsp1      TFS Bug 65247: EUP - Gate Out Check Status not getting updated
// 26/11/2024	jlizm1		MTN 33235 Delete current entry reverting already exported cargo
// 08 Aug 2025	navhl20 	Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
// 16 Sep 2025 	navhl20 	Defect MTN-36050: The page goes blank after clicking on the Photo Checks on the Truck Unloader app
// 08 Oct 2025 	navhl20 	Story MTN-36217: TPT | Enable Uploading of Photos into MTN Production
vars
	vvr						: CM_VehicleVisitRecord;
	index					: Integer;
	menu					: MenuItem;
	truck					: CM_Vehicle;
	ti						: CM_TrackedItem;
	tiSet					: CM_TISet;
	errMsg					: String;						//08 Jan 2018	NDL	36437
	tmpMenu,
	clonedStatus,
	clonedCancelVisit,
	clonedSend,												//13.12.2022 navmp20 TFS 55580
	clonedDisAssocBooking,									// ### TFS 54049 (55843) 19May2023 NAVPW1
	clonedVbsSlot			: MenuItem;						// ### TFS 54049 (55843) 19May2023 NAVPW1
	idx						: Integer;						// ### TFS 54049 (55843) 19May2023 NAVPW1
	vbsProcess				: CM_VBSProcess;				// ### TFS 54049 (55843) 19May2023 NAVPW1
	terminal				: CM_Terminal;					// ### TFS 54049 (55843) 19May2023 NAVPW1
	vbts	,
	vbsSlot					: CM_VehicleBookingTimeSlot;	// ### TFS 54049 (55843) 19May2023 NAVPW1
	gateInCheck,
	gateOutCheck			: Boolean;

begin
	inheritMethod(conwin);
	
	vbsProcess := self.myVBSProcess; // ### TFS 54049 (55843) 19May2023 NAVPW1
	
	//Start 13.12.2022  navmp20 TFS 55580
	vvr := self.myCurrentObject.CM_VehicleVisitRecord;
	self.mnuChangeStatus.visible := false;
	self.mnuSendInspection.visible := false;
	self.mnuRegenerateBarrierIn.visible:=false; //jlier1 TFS  57936 18/5/23
	self.mnuRegenerateBarrierOut.visible:=false; //jlier1 TFS  57936 18/5/23
	self.mnuUpdBarrierInTime.visible:=false; //jlier1 TFS  57936 18/5/23
	self.mnuSendBarrierIn.visible:=false;
	self.mnuSendBarrierOut.visible:=false;
	self.mnuSendReport.visible := false;			//08.08.2025 navhl20 #35650
	
	if vvr &lt;&gt; null then							// TFS 57001
		if app.myCurrentUserCan(self.myTerminal, PmGteInspectionManualMsgSend) then
			self.mnuSendInspection.visible := true;
			clonedSend := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuSendInspection, false);
		endif;
		if app.myCurrentUserCan(self.myTerminal, PmGteInspectionStatusChange) then
			self.mnuChangeStatus.visible := true;
			clonedStatus := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuChangeStatus, false);
		endif;
		if app.myCurrentUserCan(self.myTerminal, PmGteCorrectReleaseData) and vvr.status = CM_VehicleVisitRecord.Status_Complete then		//23/01/2024 navcs2	ChangeRequest 57088
			self.mnuCorrectReleaseData.visible := true;																						//23/01/2024 navcs2	ChangeRequest 57088
			self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuCorrectReleaseData, false);													//23/01/2024 navcs2	ChangeRequest 57088
		endif;																																//23/01/2024 navcs2	ChangeRequest 57088
		/*	reverting this changes							//TFS 65247
		//14/02/2024	navcs2	Bug 62454 start
		vbsSlot := vvr.myVehicleBookingTimeslot;
		if vbsSlot &lt;&gt; null then
			gateInCheck := vvr.myVehicleBookingTimeslot.preGateInCheck;
			gateOutCheck := vvr.myVehicleBookingTimeslot.preGateOutCheck;
		else
			gateInCheck := true;
			gateOutCheck := true;
		endif;	*/
		
		gateInCheck 	:= true;							//TFS 65247
		gateOutCheck 	:= true;							//TFS 65247	
		
		//14/02/2024	navcs2	Bug 62454 end
		self.mnuStatusInCompleted.enabled := gateInCheck;		//14/02/2024	navcs2	Bug 62454
		self.mnuStatusInNA.enabled := gateInCheck;				//14/02/2024	navcs2	Bug 62454
		self.mnuStatusInPending.enabled := gateInCheck;			//14/02/2024	navcs2	Bug 62454
		self.mnuStatusInFailed.enabled := gateInCheck;			//14/02/2024	navcs2	Bug 62454
		self.mnuStatusOutCompleted.enabled := gateOutCheck;		//14/02/2024	navcs2	Bug 62454
		self.mnuStatusOutNA.enabled := gateOutCheck;			//14/02/2024	navcs2	Bug 62454
		self.mnuStatusOutPending.enabled := gateOutCheck;		//14/02/2024	navcs2	Bug 62454
		self.mnuStatusOutFailed.enabled := gateOutCheck;		//14/02/2024	navcs2	Bug 62454
		self.mnuMaintainSeals.visible := false;
		self.mnuCheckSeals.visible := false;
		
		if vvr.gateInCheckStatus = CM_VehicleVisitRecord.InspectionCompleted then
			self.mnuStatusInCompleted.enabled := false;
		elseif vvr.gateInCheckStatus = CM_VehicleVisitRecord.InspectionNA then 
			self.mnuStatusInNA.enabled := false;
		elseif vvr.gateInCheckStatus = CM_VehicleVisitRecord.InspectionPending then
			self.mnuStatusInPending.enabled := false;
		elseif vvr.gateInCheckStatus = CM_VehicleVisitRecord.InspectionFailed then
			self.mnuStatusInFailed.enabled := false;
		endif;
		
		if vvr.gateOutCheckStatus = CM_VehicleVisitRecord.InspectionCompleted then
			self.mnuStatusOutCompleted.enabled := false;
		elseif vvr.gateOutCheckStatus = CM_VehicleVisitRecord.InspectionNA then
			self.mnuStatusOutNA.enabled := false;
		elseif vvr.gateOutCheckStatus = CM_VehicleVisitRecord.InspectionPending then
			self.mnuStatusOutPending.enabled := false;
		elseif vvr.gateOutCheckStatus = CM_VehicleVisitRecord.InspectionFailed then
			self.mnuStatusOutFailed.enabled := false;
		endif;
		
		if app.myCurrentUserCan(self.myTerminal, PmGteInspectionStatusChange) then
			self.zCloneMenu(clonedStatus, self.mnuStatusInCompleted, true);
			self.zCloneMenu(clonedStatus, self.mnuStatusInNA, true);
			self.zCloneMenu(clonedStatus, self.mnuStatusInPending, true);
			self.zCloneMenu(clonedStatus, self.mnuStatusInFailed, true);
			self.zCloneMenu(clonedStatus, self.mnuStatusOutCompleted, true);
			self.zCloneMenu(clonedStatus, self.mnuStatusOutNA, true);
			self.zCloneMenu(clonedStatus, self.mnuStatusOutPending, true);
			self.zCloneMenu(clonedStatus, self.mnuStatusOutFailed, true);
		
		//elseif app.myCurrentUserCan(self.myTerminal, PmGteInspectionManualMsgSend) then			//14/02/2024	navcs2	Bug 62454
			//self.zCloneMenu(clonedSend, self.mnuSendGateIn, true);								//14/02/2024	navcs2	Bug 62454
			//self.zCloneMenu(clonedSend, self.mnuSendGateOut, true);								//14/02/2024	navcs2	Bug 62454
		endif;
		
		//jlier1 TFS 57936 18/5/23
		if app.myCurrentUserCan(self.myTerminal, PmGteBarrierManualRegen) then
			
				self.mnuRegenerateBarrierIn.visible:=vvr.myBarrierCodeIn &lt;&gt; null and vvr.myRoadJob &lt;&gt; null ;
				self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuRegenerateBarrierIn, false);
			
			// has a barrier code and has done the road exit
				self.mnuRegenerateBarrierOut.visible:=vvr.myBarrierCodeOut &lt;&gt; null ; //jlier1 TFS 60590 20/9/23 
				self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuRegenerateBarrierOut, false);		
				
				//jlier1 TFS 60590 20/9/23 
				self.mnuSendBarrierIn.visible:=vvr.myBarrierCodeIn &lt;&gt; null ;
				self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuSendBarrierIn, false);
				self.mnuSendBarrierOut.visible:=vvr.myBarrierCodeOut &lt;&gt; null ;
				self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuSendBarrierOut, false);
		endif;
		
		if  app.myCurrentUserCan(self.myTerminal,PmGteBarrierInTimeMaint) then
			self.mnuUpdBarrierInTime.visible:=vvr.myBarrierCodeIn &lt;&gt; null;
			self.zCloneMenu(self.mnuTblVCloneDataTbl,self.mnuUpdBarrierInTime,false);
		endif;
		
	endif;										// TFS 57001
	//End 13.12.2022  navmp20 TFS 55580
	
	// PAR #28733 add reprint menu item
	self.mnuReprint.visible := false;
	if self.myCurrentObject &lt;&gt; null then
		self.mnuReprint.visible := true;
		self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuReprint, false);
	endif;
	
	//cnwrd1 28025 24.2.2012
	//self.mnuCancelVVR.visible := false;			//12.09.2022 navtnr20 52463
	//13 Mar 2014	NDL	Par 33268
	self.mnuWeigh.visible := false;
	self.mnuSubCarrierUpdate.visible := false;		//14/05/2022 navhl20 TFS 53430 
	self.mnuAssocBooking.visible := false;
	self.mnuDisAssocBooking.visible := false;
	self.mnuRecordWeight.visible := false;	// 20/6/17 MAP TFS4273
	
	if self.myCurrentObject &lt;&gt; null then
		vvr := self.myCurrentObject.CM_VehicleVisitRecord;
	//	if vvr = null then
	//		return;
	//	endif;
	endif;
	
	//08 Aug 2016	NDL	TFS 2506
	if vvr = null then
		return;
	endif;
	
	//Start 14/05/2022 navhl20 TFS 53430
	if self.isSubCarrierEnabled then
		self.mnuSubCarrierUpdate.visible := app.myCurrentUserCan(self.myTerminal, self.permissionMaint); // TFS 2198;
		self.mnuSubCarrierUpdate.userObject := vvr;
		self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuSubCarrierUpdate, false);
	endif;
	//End 14/05/2022 navhl20 TFS 53430
	
	truck := vvr.vehicle;
	self.mnuCancelVVR.visible := false;
	clonedCancelVisit := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuCancelVVR, false);
	if vvr.isIncomplete then
		if (app.myCurrentUserCan(self.myTerminal, self.permissionMaint) and vvr.timeOut = null) then
			self.mnuCancelVVR.visible := true;
			clonedCancelVisit.visible := true;
		endif;
			
		if truck &lt;&gt; null and truck.isWeighBridgeWeighable(null,errMsg) then
			if truck.locationsController.allTrackedItems.isEmpty then
				self.mnuWeigh.visible := app.myCurrentUserCan(self.myTerminal, self.permissionMaint); // TFS 2198
				self.mnuWeigh.userObject := truck;
				self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuWeigh, false);
			else
				ti := truck.locationsController.allTrackedItems.first;
				if not ti.isChassis then
					self.mnuWeigh.visible := app.myCurrentUserCan(self.myTerminal, self.permissionMaint); // TFS 2198;
					self.mnuWeigh.userObject := ti;
					self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuWeigh, false);
				else
					create tiSet transient;
					ti.CM_TILC.getAllOnboardTIs( tiSet );
					if tiSet.size &lt; 2 then
						if tiSet.isEmpty or not tiSet.first.isChassis then
							self.mnuWeigh.visible := app.myCurrentUserCan(self.myTerminal, self.permissionMaint); // TFS 2198;
							self.mnuWeigh.userObject := ti.CM_TILC;
							self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuWeigh, false);	
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	//10 Apr 2013	NDL	Par 31393
	/*if self.myTerminal.isVehicleBookingEnabled then
		foreach index in 1 to self.clonedMenuCount do
			menu := self.mnuTblVCloneDataTbl.getMenuItem(index);
			if menu &lt;&gt; null then
				if menu.caption = self.mnuAssocBooking.caption then
					menu.visible := false;
				elseif menu.caption = self.mnuDisAssocBooking.caption then
					menu.visible := false;
				endif;
			endif;
		endforeach;
		
		// TFS 2198 CNWAB1
		if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
			if vvr.myVehicleBookingTimeslot = null then	
				self.mnuAssocBooking.visible := true;
				self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuAssocBooking, false);
			elseif vvr.myVehicleBookingTimeslot &lt;&gt; null then	
				self.mnuDisAssocBooking.visible := true;
				self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuDisAssocBooking, false);
			endif;
		
		endif;
		
	endif;*/
	
	// ### TFS 54049 (55843) 19May2023 NAVPW1
	if self.myTerminal.isVehicleBookingEnabled then
		foreach idx in 1 to self.clonedMenuCount do
			tmpMenu := self.mnuTblVCloneDataTbl.getMenuItem(idx);
			if tmpMenu &lt;&gt; null then
				if tmpMenu.caption = self.mnuDisAssocBooking.caption then
					tmpMenu.visible := false;
				elseif tmpMenu.caption = self.mnuAssocBooking.caption then
					tmpMenu.visible := false;
				endif;
			endif;
		endforeach;
		
		// TFS 2198 CNWAB1
		if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
			if vbsProcess = null or (vbsProcess &lt;&gt; null and vbsProcess.isVbsStandard) then
				if vvr.allVehicleBookingSlots.isNotEmpty then
					self.mnuDisAssocBooking.visible := true;
					clonedDisAssocBooking := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuDisAssocBooking, false);
					clonedDisAssocBooking.setEventMapping("click", GTE_VehicleVisitEnqForm::doDisAssocBooking.name);
					clonedDisAssocBooking.visible := true;
				else
					self.mnuAssocBooking.visible := true;
					self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuAssocBooking, false);
				endif;
				
			elseif vbsProcess &lt;&gt; null and vbsProcess.isVbsSlotValidation then
				if vvr.allVehicleBookingSlots.isNotEmpty then
					clonedDisAssocBooking := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuDisAssocBooking, false);
					clonedDisAssocBooking.visible := true;
					foreach idx in 1 to 20 do
						clonedVbsSlot := clonedDisAssocBooking.getMenuItem(idx);
						if clonedVbsSlot = null then
							break;
						endif;
						clonedVbsSlot.caption := null;
						clonedVbsSlot.userObject := null;
						clonedVbsSlot.visible := false;
					endforeach;
					
					idx := 0;
					foreach vbts in vvr.allVehicleBookingSlots do
						idx := idx + 1;
						clonedVbsSlot := clonedDisAssocBooking.getMenuItem(idx);
						if clonedVbsSlot = null then
							clonedVbsSlot := clonedDisAssocBooking.loadSubMenu(idx);
						endif;
						clonedVbsSlot.caption := vbts.id;
						clonedVbsSlot.userObject := vbts;
						clonedVbsSlot.visible := true;
						clonedVbsSlot.setEventMapping("click", GTE_VehicleVisitEnqForm::doVbsSlotClick.name);
					endforeach;
				endif;
			endif;
		endif;
		
	endif;
	
	// ### TFS 54049 (55843) 19May2023 NAVPW1
	
	if truck &lt;&gt; null then		// 19/6/17 MAP TFS4273
		self.mnuRecordWeight.visible := app.myCurrentUserCan(self.myTerminal, PmGteVVRTruckWeighMaint) or app.myCurrentUserCan(self.myTerminal, PmGteVVRTruckWeighView);
		self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuRecordWeight, false);
	endif;
	
	if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		if vvr.getMyJob &lt;&gt; null and vvr.getMyJob.isJobComplete then
			self.mnuMaintainSeals.visible := true;
			self.mnuCheckSeals.visible := true;
		endif;
	else
		self.mnuAssocBooking.visible := false; // TFS 2198 CNWAB1
	endif;
	
	if self.tblData.allSelectedObjects.size = 1 then							//08.08.2025 navhl20 #35650
		self.mnuSendReport.visible := true;
	endif;

	self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuMaintainSeals, false);
	self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuCheckSeals, false);	
	self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuCargoReview, false); //27/09/2023	navkc1	CR 60428 Task 60702
	self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuSendReport, false);		//08.08.2025 navhl20 #35650
epilog

	delete tiSet;
	
end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="bd94994b-9d7c-4ce3-ac06-edab153726d1">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	01 July 2004 By: cnwgd1
//--------------------------------------------------
// 25/11/2011	cnwdap1	PAR #28733 CCMS FW 1261 Change Print context menu caption and Print button bubble help
// 04/12/2012	cnwcs5	par 30413 - xlations
// 13/05/2022 	navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
// 16 Sep 2025 	navhl20 Defect MTN-36050: The page goes blank after clicking on the Photo Checks on the Truck Unloader app
// 08 Oct 2025 	navhl20 Story MTN-36217: TPT | Enable Uploading of Photos into MTN Production
vars
	today	: Date;
begin
	self.allowAdd 		:= false;
	self.allowUpdate 	:= false;
	self.allowDelete 	:= false;
	//self.allowSearch	:=true;
	inheritMethod();
	
	self.myVBSProcess := self.myTerminal.getMyVBSProcess;	// ### TFS 54049 (55843) 19May2023 NAVPW1
	
	//added by cnwyl1 for par 13847
	self.setSearcherHeight();	
	
	self.myThumbDef := app.myController.getEntTableDef(ETDef_VisitRecordThumb);

	if self.myThumbDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef (ETDef_VisitRecordThumb) not found');
		return;
	endif;
	
	//Start 13/05/2022 navhl20 TFS 53430 
	self.isSubCarrierEnabled := self.myTerminal.getConfig(IsSubCarrierEnabled).Boolean;
	if self.isSubCarrierEnabled then
		tblSearch.showRowByName(ETRow_FilterSubCarrier,false);
		self.initSubCarrierCombo();
	else
		tblSearch.hideRowByName(ETRow_FilterSubCarrier,false);
	endif;
	//End 13/05/2022 navhl20 TFS 53430

	self.myAssistant.comboBoxCargoTypes(self.cmbFiltCargoType,null); // cnwrd1 ccms 1695 23.1.09
	
	self.btnPrintTV.bubbleHelp 	:= app.getErrorString (GTE_VehicleVisit_Print1);	// PAR #28733
	self.mnuTblVPrint.caption 	:= app.getErrorString (GTE_VehicleVisit_Print2);	// PAR #28733
	
	self.frmTableFilter.setCallbackMethod(GTE_VehicleVisitEnqForm::doFilterTable.name); //25/06/2024	navkc1 CR 64823 Task 64824
epilog
	
end;</source>
    </JadeMethod>
