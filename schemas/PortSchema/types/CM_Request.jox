    <JadeMethod name="hasAssignedItems" id="2186663d-f84c-4d52-aec1-e3d07424c541">
        <source>hasAssignedItems(_brTIs : ObjectSet input) : Boolean;

/*

Purpose:		Return collection of ti's can display from the release request	

Parameters:			

Return Value:		


Date		Who		Reason
15/12/2010	cnwmh5	Initial creation #26586
29/10/2019	jlgdap1	TFS 47079 PRP Release Qty Issue
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	bulkRelease			: CM_BulkRelease;
	ti					: CM_TrackedItem;
	lc					: CM_LocationsController;
begin

	bulkRelease := getBulkRelease();
	if bulkRelease = null then
		bulkRelease := self.myOriginatingBulkRelease;
	endif;
	if bulkRelease &lt;&gt; null then
		foreach ti in bulkRelease.allTrackedItemsAssigned discreteLock do
			
			lc := ti.myPrimaryActualLocation;							//06.03.2025 navma1 #MTN-34179
			
			if lc.isKindOf(CM_YardController) and 
				not lc.isKindOf(CM_CraneLaneController) and
				not lc.isKindOf(CM_YardICAreaLaneController) and    // CCMS 2384
				not lc.isWorkPointLaneController and 				//cnwrd1 par 31084 25/1/13
				not lc.isRailTransferArea() then					// TFS 47079
					_brTIs.add(ti);
			endif;			
		endforeach;
	endif;
	
	return not _brTIs.isEmpty();

epilog

end;</source>
        <Parameter name="_brTIs" type="ObjectSet" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasJobLoadToOps" id="db36f3ce-e82f-4d78-ad2c-f37aa76a9fe6">
        <source>hasJobLoadToOps(_workPoint: IF_VoyageWorkPoint) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2012	cnwer1	Initial creation CCMS MES 1026

*/

vars

	job: CM_VoyageJob;
	request : CM_Request;
begin
	if 	(self.isSOB) and self.myRequestLinkedDischarge &lt;&gt; null  then
		
		request:=self.myRequestLinkedDischarge;
	else
		request:=self;
	endif;
	
	job	:= request.myJob.CM_VoyageJob;
	
	
	if job = null then
		return false;
	endif;
	if not job.isLoadedToOperations then
		return false;
	endif;
	if job.getMyWorkPointObject.IF_VoyageWorkPoint &lt;&gt; _workPoint then
		return false;
	endif;
	

	return true;
epilog

end;</source>
        <Parameter name="_workPoint" type="IF_VoyageWorkPoint"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasMatchingWOWLETypeStatus" id="e9de740e-a852-4c17-b379-88f441ca6ca5">
        <source>hasMatchingWOWLETypeStatus(_operationWle : CM_WorkListEntry;
						   _woDetailType : Integer ; 
						   _status 		 : Integer):CM_WorkListEntry;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
06 Jun 2023 navma1  ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
15 Aug 2023 navma1	ChangeRequest 59218: EUP | Handle Work order for Release Rail by Type
22 Aug 2023	navma1 	ChangeRequest 59121: EUP | Handle Work orders Packing By Type
21 Sep 2023 navhl20 Bug 60615: MTN - Release by type work order job is not appearing on the Delivery dispatch screen
05 Mar 2024 navhl20 Bug 62758: EUP | FR | Work Order status - complete without loading all items
26 Mar 2024 navhl20 Defect 63074: Release by type work orders is not displaying on the work order operations form
18 Sep 2024	navpw1	TFS: 65623 (65624) - Added code to help matching if release request is by type by weight added a check for isAnyAmount
31 Jan 2025	navhl20 Bug MTN-33648: EUP - Partial move by weight is not working in Work Order Operation screen - Release
*/

vars
	woWle 			: CM_WorkListEntry;
	ti	  			: CM_TrackedItem;
	wod   			: CM_WorkOrderDtl;
	woJob 			: CM_Job;
	parent			: CM_WorkOrder;
	releaseByType	: Boolean;
begin
	
	if _woDetailType &lt;&gt; WO_TASK_PACK then
		if _operationWle = null then
			return null;
		endif;
		ti := _operationWle.myTrackedItem;
	endif;
	
	if self.myReserveDetail &lt;&gt; null and self.myReserveDetail.myReserveHeader &lt;&gt; null then		//21.9.2023 navhl20 #60615
		releaseByType := self.myReserveDetail.myReserveHeader.releaseByType;
	endif;
	
	//if ti &lt;&gt; null and not ti.isTBAorIsRRP then //15.08.2023 navma1 #59218						//21.9.2023 navhl20 #60615
	if ti &lt;&gt; null and not ti.isTBAorIsRRP and not releaseByType then							//21.9.2023 navhl20 #60615
		/*
		Known TrackedItem
		*/
		foreach woWle in ti.allWorklistEntries do
			if not woWle.isKindOf(CM_WOWLE) then
				continue;
			endif;
			
			if woWle.status &lt;&gt; _status then
				continue;
			endif;
			
			if woWle.job = null then
				continue;
			endif;
			
			wod := woWle.job.myWODtl;
			
			if woWle = null then
				continue;
			endif;
			
			if wod.detailType &lt;&gt; _woDetailType then
				continue;
			endif;
			
			return woWle;
		endforeach;
	else
		/*
		Unknown TrackedItem
		Release by Type 
		*/
		if _woDetailType = WO_TASK_RELEASE then
			if self.myReserveDetail = null then
				return null;
			endif;
			foreach wod in self.myReserveDetail.allWodReleases do
				if wod.status = WO_STATUS_COMPLETE  then    // to handle part complete work orders 
					continue;
				endif;
				
				
				parent := wod.myParent;
				
				if not parent.approvedByDT.isValid then    // Must be approved before
					continue;
				endif;
				
				if parent.taskStatus = WO_STATUS_COMPLETE  then    // to handle part complete work orders 
					continue;
				endif;
				
				foreach woJob in wod.CM_WorkOrderTIDtl.allJobs do
					foreach woWle in woJob.workListEntries do
						
						if not woWle.isKindOf(CM_WOWLE) then
							continue;
						endif;
						
						if woWle.CM_WOWLE.myOperationalWLE &lt;&gt; null then			// Already Linked
							continue;
						endif;
						if woWle.status &lt;&gt; _status then
							continue;
						endif;
						
						if not self.myReserveDetail.byTypeByWeight and 				// ### TFS 65623 (65624) 18Sep2024 NAVPW1
							self.myReserveDetail.isKindOf(CM_ReserveSelection) and 	//05.03.2024 navhl20 #62758
							(woWle.quantity &lt;&gt; _operationWle.quantity.max(1) and
							// ### TFS 65623 (65624) 25Sep2024 NAVPW1 - If its any amount we will link first wowle as the quantities may not match (Any Amount forces operationWle to have a quantity of 1)
							not _operationWle.isAnyAmount) and _operationWle.weight = null	//31.01.2025 navhl20 #33648
						then		//26.03.2024 navhl20 #63074
							continue;
						endif;
						
						if self.myReserveDetail.isKindOf(CM_ReserveSelection) and 
						self.myReserveDetail.CM_ReserveSelection.myCargoType &lt;&gt; null and
						self.myReserveDetail.CM_ReserveSelection.myCargoType.isTrackByWeight and
						woWle.weight &lt;&gt; _operationWle.weight then				//31.01.2025 navhl20 #33648
							continue;
						endif;
						
						if woWle.myRequest.myReserveDetail &lt;&gt; self.myReserveDetail then
							continue;
						endif;
						
						return woWle;
						
					endforeach;
				endforeach;
			endforeach;
		elseif  _woDetailType = WO_TASK_PACK then
			if self.myReserveDetail = null then
				return null;
			endif;
			
			foreach woWle in self.myJob.workListEntries do

				if not woWle.isKindOf(CM_WOWLE) then
					continue;
				endif;
				
				if woWle.CM_WOWLE.myOperationalWLE &lt;&gt; null then			// Already Linked
					continue;
				endif;
				if woWle.status &lt;&gt; _status then
					continue;
				endif;
				
				if woWle.myRequest.myReserveDetail &lt;&gt; self.myReserveDetail then
					continue;
				endif;
				
				return woWle;
			endforeach;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_operationWle" type="CM_WorkListEntry"/>
        <Parameter name="_woDetailType" type="Integer"/>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
