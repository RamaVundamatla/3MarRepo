    <JadeMethod name="convertAllCTNToSC" id="d28cf2b1-ce15-41e4-824b-fbce75aa247e">
        <source>convertAllCTNToSC(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2022	navhl20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
*/

vars
	cargoType : CM_CargoBOLType;	
	objArr 		: ObjectArray;
	obj			: CM_StopsTable;
	stopCriteria,criteria	: CM_StopCriteria;
	objSet	: ObjectSet;
	
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " On Stops Table", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" On Stops Table") ;	
	endif;
	
	create objArr transient;
	CM_StopsTable.allInstances(objArr, 0, true);
	
	beginTransaction;
	foreach obj in objArr as CM_StopsTable do
	
		criteria := obj.myStopCriteria;
		if criteria &lt;&gt; null then
			criteria.setPropertyValue("myStopTable",null);
			delete criteria;
		endif;
		 
	
		if obj.allCargoTypesNew &lt;&gt; null and obj.allCargoTypesNew.size &gt; 0 then		
			obj.allCargoTypesNew.rebuild();

			create objSet transient;				
			foreach cargoType in obj.allCargoTypesNew do											
					objSet.add(cargoType);			
			endforeach;
			create stopCriteria transient;
			stopCriteria.createStopCriteria(objSet, YACriteriaType_CargoType,stopCriteria);
			stopCriteria.setProxyBaseData(obj);
			create criteria persistent;
			criteria.setForCreate(stopCriteria);
		endif;
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " On Stops Table", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" On Stops Table") ;
	endif;
	
	self.addScriptRun(method.name);
epilog
	abortTransaction;
	delete objSet;
	delete objArr;
	delete stopCriteria;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertAllDamageSeverity" id="8322f3d2-eacc-45cf-be08-a95fb2b764cf">
        <source>convertAllDamageSeverity(_controller : CnEcReleaseController);
/*

Purpose:	this must be run AFTER populateDamageSeverties()		

Parameters:			

Return Value:		

Date		Who		Reason
 // ### TFS 55311 03NOV2022 NAVAB1
*/

vars
	objArr 		: ObjectArray;
	damage			: CM_DamageInstance;
	objSet	: ObjectSet;
	severity, default : CM_DamageSeverity;
	root : CM_Root;
	term, defterm : CM_Terminal;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Convert Severity on Damage Instances", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Convert Severity on Damage Instances") ;	
	endif;
	
	root := CM_Root.firstInstance;
	
	// Damage can be on master object (fleet file) which are system based. The UI in the Fleet Maint just gets the first terminal on the user, we will use the last on root.
	defterm := root.allTerminals.last;

	
	create objArr transient;
	CM_DamageInstance.allInstances(objArr, 0, true);
	
	beginTransaction;
	foreach damage in objArr as CM_DamageInstance do
	
		if damage.myDamageSeverity = null then
			if damage.mySubject &lt;&gt; null then // Tracked Item, Wagon, Fleet File; null subject is because it has been deleted.
				term := damage.mySubject.getMyTerminal();
			endif;
			
			if term = null then // probably the fleet file
				term := defterm;
			endif;
			
			if term &lt;&gt; null then
				
				severity := term.allDamageSeverities[damage.severity.String];
				
				if severity &lt;&gt; null then
					damage.setPropertyValue("myDamageSeverity", severity);
				endif;
			endif;
		endif;
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Convert Severity on Damage Instances", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Convert Severity on Damage Instances") ;
	endif;
	
	self.addScriptRun(method.name);
epilog
	abortTransaction;
	delete objSet;
	delete objArr;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertAllRTVehicleConfigs" id="8011e207-18b5-4051-977c-9e758ca8d334">
        <source>convertAllRTVehicleConfigs(_controller: CnEcReleaseController);
/*

Purpose:			Rename all RT Config EntTableView objects to include a separator between Terminal Code and Machine Type Code.
					So things like SCT + 2 and SCT2 don't run into conflicts.
					(so that then becomes SCT/2 which isn't the same as SCT2)

Parameters:			

Return Value:		

Date				Who		Reason
17 February 2023	navmd1	Initial creation TFS 56666 SNO - 1310 when creating new Terminal level RT Config

*/

constants
	UpdateMode = true;
vars
	oa 			: ObjectArray;
	machConfig 	: CM_RTTermMachTypeConfig;
	machType	: CM_MachineType;
	config		: CM_RTVehicleConfig;
	views		: StringArray;
	kvPair		: String;
	pos			: Integer;
	oldName,
	newName,
	viewName,
	propName	: String;
	etView		: EntTableView;
	term		: CM_Terminal;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Renaming RT Vehicle Config Views", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Renaming RT Vehicle Config Views") ;	
	endif;
	
	create views transient;
	views.add("myPrimaryCargoFields|primary cargo");
	views.add("myPrimaryDirectorFields|primary director");
	views.add("myPrimaryTaskFields|primary tasks");
	
	views.add("mySecondaryCargoFields|secondary cargo");
	views.add("mySecondaryDirectorFields|secondary director");
	views.add("mySecondaryTaskFields|secondary tasks");
	
	views.add("myVisibleCargoFields|cargo view");
	views.add("myVisibleDirectorFields|director view");
	views.add("myVisibleTaskFields|task view");	
	
	create oa transient;
	CM_RTVehicleConfig.allInstances(oa, 0, false);
	
	beginTransaction;
	foreach config in oa as CM_RTVehicleConfig do
		
		// 3 types of config to 'deal' with (in order)
		
		// 1. Machine Level
		if config.myMachine &lt;&gt; null then
			term := config.myMachine.myTerminal;
			
			app.writeLog("Converting Machine Level Config: [" &amp; term.code &amp; "] " &amp; config.myMachine.code, LogINFO);
			if _controller &lt;&gt; null then
				_controller.logEntry(" Converting Machine Level Config: [" &amp; term.code &amp; "] " &amp; config.myMachine.code);
			endif;
			
		// 2. Terminal Level
		elseif config.myTerminal &lt;&gt; null then
			term := config.myTerminal;
			
			app.writeLog("Converting Terminal Level Config: [" &amp; term.code &amp; "]", LogINFO);
			if _controller &lt;&gt; null then
				_controller.logEntry(" Converting Terminal Level Config: [" &amp; term.code &amp; "]");
			endif;
			
		// 3. Machine Type Level
		elseif config.myTerminalMachineType &lt;&gt; null then
			machConfig := config.myTerminalMachineType;
			machType := config.myTerminalMachineType.myMachineType;
			term := config.myTerminalMachineType.myTerminal;
			
			// Dmast has some crap in it... on the off chance customers do as well ...
			if term = null or machType = null then
				app.writeLog("BAD DATA for CM_RTTermMachTypeConfig " &amp; machConfig.getOidAsString &amp; ", skipping", LogERROR);
				if _controller &lt;&gt; null then
					_controller.logEntry(" BAD DATA for CM_RTTermMachTypeConfig " &amp; machConfig.getOidAsString &amp; ", skipping");
				endif;
				continue;
			endif;
		
			app.writeLog("Converting Machine Type Level Config: [" &amp; term.code &amp; "] " &amp; machType.description, LogINFO);
			if _controller &lt;&gt; null then
				_controller.logEntry(" Converting Machine Type Level Config: [" &amp; term.code &amp; "] " &amp; machType.description);
			endif;
		
		else
			// Bad Data!
			// Lets record it if it gets this far
			app.writeLog("BAD DATA for CM_RTVehicleConfig " &amp; config.getOidAsString &amp; ", skipping", LogERROR);
			if _controller &lt;&gt; null then
				_controller.logEntry(" BAD DATA for CM_RTVehicleConfig " &amp; config.getOidAsString &amp; ", skipping");
			endif;
			continue;
		endif;
		
		// Actually, this will run after getUniqueViewName has been updated, so we can offload the hard work of working out the new name to it
		// Meaning that we can handle all 3 configs in the same way :O
		
		foreach kvPair in views do
			pos := 1;
			propName := kvPair.cnGetToken(pos, "|");
			viewName := kvPair.cnGetToken(pos, "|");
			
			// Make sure the view is populated, skip if its not
			etView := config.getPropertyValue(propName).EntTableView;
			if etView = null then
				continue;
			endif;
		
			oldName := etView.name;
			newName := config.getUniqueViewName() &amp; CM_RTVehicleConfig.ETVIEW_SEPARATOR &amp; viewName;	// eg, SCT/2/primary cargo vs SCT2/primary cargo
			
			app.writeLog(Tab &amp; "Renaming [" &amp; oldName &amp; "] to [" &amp; newName &amp; "]", LogINFO);
			if _controller &lt;&gt; null then
				_controller.logEntry(" " &amp; Tab &amp; "Renaming [" &amp; oldName &amp; "] to [" &amp; newName &amp; "]");
			endif;
			
			etView.set(newName, etView.description, etView.myEntTableDef);
		endforeach;
		
		// No need to do hook codes, as they are only on the Terminal level config, and thats just the Terminal Code!
		// Plus their names don't seem to need to be unique
		
	endforeach;
	
	if UpdateMode then
		commitTransaction;
	else
		// addScriptRun goes into transaction state :\
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " all RT Vehicle Config Views Renamed", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" all RT Vehicle Config Views Renamed") ;
	endif;
	
	self.addScriptRun(method.name);
epilog
	abortTransaction;
	
	delete views;
	delete oa;
	
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertAllWebReqResDataToBin" id="33bf161b-0a63-4ce2-90de-fab7b1171e60">
        <source>convertAllWebReqResDataToBin(_controller : CnEcReleaseController);
/*

Purpose:			Same as convertWebReqResDataToBinary but without the time limit

Parameters:			

Return Value:		

Date		Who		Reason
21 July 2023	navra1	Initial creation for 54078 - MTN - Compress msgWebReq and msgWebRes on CM_EdiFile

*/

vars
	terminal : CM_Terminal;	
	ediConfig : CM_EDIConfig;
	allEDIFilesForTerm : CM_EDIFileByCreatedTSDict;
	ediFile : CM_EDIFile;	
	numCompleted : Integer;
	totalNumber : Integer;
	finishTs : TimeStamp;
	nextCommitTs : TimeStamp;
	now : TimeStamp;
	numConverted : Integer;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Converting EDIFile WebReq and WebRes strings start", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Converting EDIFile WebReq and WebRes strings start");
	endif;
	
	foreach terminal in app.myRoot.allTerminals do
		ediConfig := terminal.myEdiConfig;
		if ediConfig &lt;&gt; null then
			allEDIFilesForTerm := ediConfig.ediFiles;
			totalNumber := totalNumber + allEDIFilesForTerm.size();
		endif;
	endforeach;
	
	finishTs := app.actualTimeServer.addSeconds(60);
	nextCommitTs := app.actualTimeServer.addSeconds(10);
	
	beginTransaction;
	
		foreach terminal in app.myRoot.allTerminals do
			ediConfig := terminal.myEdiConfig;		
			allEDIFilesForTerm := ediConfig.ediFiles;
			
			if allEDIFilesForTerm &lt;&gt; null then
				foreach ediFile in allEDIFilesForTerm  do
					if ediFile.msgWebReq &lt;&gt; null then
						ediFile.setWebReqString(ediFile.msgWebReq);						
						ediFile.setMsgWebReqAsNull();
						numConverted += 1;
					endif;
					
					if ediFile.msgWebRes &lt;&gt; null then
						ediFile.setWebResString(ediFile.msgWebRes);
						ediFile.setMsgWebResAsNull();
						numConverted += 1;
					endif;					
				
					numCompleted := numCompleted  + 1;
					
					// we need to convert everything now, so no timelimits during this upgrade
					/*now := app.actualTimeAppServer();
					
					//see if its time to end
					if now &gt;= finishTs then
						break;
					endif;
					
					// commit in batches to reduce the final commit time to keep close to our 60 second limit
					if now &gt;= nextCommitTs then
						commitTransaction;
						nextCommitTs := now.addSeconds(10);
						beginTransaction;
					endif;*/
					
				endforeach;					
			endif;
		
		endforeach;
	
	commitTransaction;
	
	app.writeLog("Total Converted: " &amp; numConverted.String, LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Total Converted: " &amp; numConverted.String);
	endif;
	
	// If we've converted everything, or hit the timelimit without converting anything, then we can stop
	// The rest will be handle during the next major upgrade
	if numCompleted = totalNumber or numConverted = 0 then
		app.writeLog("Converted all EDIFile WebReq and WebRes strings!" &amp; numConverted.String, LogINFO);
		self.addScriptRun(method.name);
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Converting EDIFile WebReq and WebRes strings finished", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Converting EDIFile WebReq and WebRes strings finished");
	endif;
	
epilog
	
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertAutoVoyageStatuses" id="54b52baa-0513-4fd3-94a2-b9cba66947de">
        <source>convertAutoVoyageStatuses(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 October 2024	navra1	Initial creation for //navra1 - MTN-33086 - 21st Oct 2024

*/

vars
	objArr 		: ObjectArray;
	damage			: CM_DamageInstance;
	objSet	: ObjectSet;
	severity, default : CM_DamageSeverity;
	root : CM_Root;
	term, defterm : CM_Terminal;
	
	voyStatus : CM_VoyageStatus;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Beginning to convert Auto voyage statuses", LogINFO);				//navra1 - MTN-33366 - 6th Nov 2024
	if _controller &lt;&gt; null then
		_controller.logEntry(" Beginning to convert Auto voyage statuses") ;								//navra1 - MTN-33366 - 6th Nov 2024
	endif;
	
	root := CM_Root.firstInstance;
	
	voyStatus := root.allVoyageStatuses[Voyage_Status_AutoOn_Auto];
	if voyStatus &lt;&gt; null then
		beginTransaction;
		voyStatus.setPropertyValue("description",Voyage_Status_AutoOn_Auto_Str);
		commitTransaction;
	endif;
	
	voyStatus := root.allVoyageStatuses[Voyage_Status_Autoff_Auto];
	if voyStatus &lt;&gt; null then
		beginTransaction;
		voyStatus.setPropertyValue("description",Voyage_Status_Autoff_Auto_Str);
		commitTransaction;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Completed convertion of Auto voyage statuses", LogINFO);			//navra1 - MTN-33366 - 6th Nov 2024
	if _controller &lt;&gt; null then
		_controller.logEntry(" Completed convertion of Auto voyage statuses") ;								//navra1 - MTN-33366 - 6th Nov 2024
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertBOLTypeAbbrv" id="c38314c1-4cc0-4300-b877-cc8d7996f9e4">
        <source>convertBOLTypeAbbrv(_controller : CnEcReleaseController);
/*

Purpose:	There are 3 system CM_BOLType. Two of them have the same abbreviation as 2 system CM_CargoType. 
			This creates an issue in the new stop YA criteria, which contain CM_CargoType and CM_BOLType, 
			because if the 2 CM_BOLType are selected, it is the CM_CargoType that is saved.	
			Changing the abbreviation of the system CM_BOLTypes.
			We are not sure how many, if any, clients use CM_BOLTypes on stops; and those that do may have created CM_CargoTypes called LOGD or GEND, but the risk is very small.

Parameters:			

Return Value:		

Date		Who		Reason
25OCT2022	navab1	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
*/

vars
	bolType : CM_BOLType;
	
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " CM_BOLType", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" On Stops Table") ;	
	endif;
	
	bolType := app.myRoot.allBOLTypes[BOLType_Log];
	if bolType &lt;&gt; null then
		beginTransaction;
		bolType.setPropertyValue("abbreviation","LOGD");
		commitTransaction;
	endif;
	bolType := app.myRoot.allBOLTypes[BOLType_GeneralDocket];
	if bolType &lt;&gt; null then
		beginTransaction;
		bolType.setPropertyValue("abbreviation","GEND");
		commitTransaction;
	endif;

	app.writeLog(method.qualifiedName &amp; " COMPLETE CM_BOLType", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" COMPLETE CM_BOLType") ;
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertCargoTypeForContents" id="769dc61a-11b4-438f-a8c3-9c103e32f2e1">
        <source>convertCargoTypeForContents(_controller: CnEcReleaseController);
/*

Purpose:			/================================================================
					OUTDATED
						This upgrade script is meant to be run on the next major release
						It's expected to get the value from CM_TrackedItem::allExtraData CargoTypeForContets and set the value to the attribute CM_TrackedItem::myCargoTypeForContents
					/==================================================================
					
					/================================================================
					UPDATED 17/11/2025
						We are now adding CM_TrackedItem::myCargoTypeForContents to WMAST as it won't have significant impact on the month release reorg
						As no client will be data created on their system yet, this script is not needed for clients
						However, Dev and QA envs have data created and is stored in CM_TrackedItem::allExtraData(CargoTypeForContents)
						So, we only need to run this script on DEV and QA envs
					/==================================================================

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2025	navkc1 JIRA 36151 AAT | RotaBox ISO Type and New Attributes - JADE

*/

vars
	root  			     : CM_Root;
	terminal			 : CM_Terminal;
	ti					 : CM_TrackedItem;
	cargoTypeForContent	 : CM_CargoType;
	xlationOperatorCode	 : String;
	stateData 			 : CM_StateData;
	containers			 : CM_TISet;
	tsRotaCutDate 		 : TimeStamp;
begin
	
	//10/11/2025	navkc1 JIRA 36553 - We now added myCargoTypeForContents to CM_TrackedItem in WMAST
	// No client will have data populated in CM_TrackedItem::allExtraData(CargoTypeForContents) so we can skip the script on client side
	// However, there are data created in DEV and QA environments so we need to run this script for DEV and QA envs
	if not (app.myRoot.isClientJadeMaster() or app.myRoot.isClientJMTTesting())then
		return;
	endif;
	
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Converting CargoTypeForContents to be stored into CM_Container::myCargoTypeForContents attribute", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Converting CargoTypeForContents to be stored into CM_Container::myCargoTypeForContents attribute") ;	
	endif;
	
	root := app.myRoot;
	
	create containers transient;
	
	CM_Container.instances.copy(containers);
	
	//ts2026.setDate("01/01/2026".asDateJMT()); // AAT will be going live with the rotainer changes in 2026. No other client is using rotainers so it's safe to take this as cutoff date.
	tsRotaCutDate.setDate("01/10/2025".asDateJMT()); // Running this script to reset the data for DEV and QA environments. This is when the original cut date for Rotabox and may have data created in DEV and QA envs
	
	beginTransaction;
	
	foreach ti in containers reversed, discreteLock do
		
		if ti.createdTime &lt; tsRotaCutDate then
			break;
		endif;
		
		stateData := null;
		cargoTypeForContent := null;
		
		stateData := ti.allExtraData[CargoTypeForContents];
		
		if stateData &lt;&gt; null then
			cargoTypeForContent := stateData.getValue().CM_CargoType;
			
			ti.setCargoTypeForContents(cargoTypeForContent);
			
			delete stateData;
		endif;
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Converting CargoTypeForContents to be stored into CM_Container::myCargoTypeForContents attribute complete", LogINFO);
	
	if _controller &lt;&gt; null then
		_controller.logEntry(" Converting CargoTypeForContents to be stored into CM_Container::myCargoTypeForContents attribute complete") ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog
	delete containers;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertChargeTaxDetails" id="a5064c73-4cfc-434b-93ad-6c3bfd36f99c">
        <source>convertChargeTaxDetails(_controller : CnEcReleaseController);
/*
Purpose - 	
Who - NAVAB1
Date - 02APR2024
ADO -  CR 62992 TASK 62994 
*/

vars
	iter01 : Iterator;
	theInvLine : CM_InvoiceLine;
	theInv : CM_Invoice;
	oArray : ObjectArray; 
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Convert Invoice Charge Tax", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Convert Invoice Charge Tax") ;	
	endif;
	
	create oArray transient;
	CM_TaxCode.allInstances(oArray,0,false);
	if oArray.size = 0 then
		app.writeLog(method.qualifiedName &amp; " No tax codes in system, no charges converted", LogINFO);
		if _controller &lt;&gt; null then
			_controller.logEntry(" No tax codes in system, no charges converted") ;
		endif;
		
		self.addScriptRun(method.name);
		
		return;
	endif;
	
	// null the values on the invoices
	oArray.clear();
	CM_Invoice.allInstances(oArray,0,false);
	iter01 := oArray.createIterator;
	
	while iter01.next(theInv) do
		beginTransaction;
		theInv.setTaxDetailsToNull();
		commitTransaction;
	endwhile;
	
	
	// now set the invoice lines and the charges, this also sets the invoice
	oArray.clear();
	CM_InvoiceLine.allInstances(oArray,0,false);
	iter01 := oArray.createIterator;
	
	beginTransaction;
	while iter01.next(theInvLine) do
		theInvLine.setTaxDetails();
	endwhile;
	commitTransaction;


	
	app.writeLog(method.qualifiedName &amp; " all Invoice Charges converted", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" all Invoice Charges converted") ;
	endif;
	
	self.addScriptRun(method.name);
epilog
	delete oArray;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertContractRateCalcType" id="f0703297-54d6-4eb8-aef7-099b9cf7bb98">
        <source>convertContractRateCalcType(_controller : CnEcReleaseController);
/*
Purpose - 	
Who - NAVAB1
Date - 13FEB2024
ADO -  CR 61579 TASK 62472
*/


vars
	terminal : CM_Terminal;
	rate	:CM_InvoiceContractRate;
	detail : CM_InvoiceContractDetails;
	objArr 		: ObjectArray;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Convert Invoice Contract Rate Calculation Type", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Convert Invoice Contract Rate Calculation Type") ;	
	endif;
	
	create objArr transient;
	CM_InvoiceContractRate.allInstances(objArr, 0, true);
	
	beginTransaction;
	
	foreach rate in objArr as CM_InvoiceContractRate do
		detail := rate.myInvoiceContractDetail;
