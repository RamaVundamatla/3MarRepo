    <JadeMethod name="setFormForEmptyCollection" id="99befee3-f8b7-4744-85e1-6175843a9cfc">
        <source>setFormForEmptyCollection();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 January 2010	cnwndl1	Initial creation	CCMS MES 1004

*/

vars

begin

	self.txtNumCopys.text := "1";
	self.lblSelection.caption := app.getErrorString(Nothing_Selected);
