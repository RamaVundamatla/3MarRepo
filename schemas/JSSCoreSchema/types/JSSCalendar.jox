    <JadeMethod name="redrawSelf" id="1d6e395f-6ab7-4dd0-9536-0f91f0b5f2f3">
        <updating/>
        <source>redrawSelf() updating, protected;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Redraw after some visual change to the appearance has occurred.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	firstDate		: Date;					// Date of the 1st of the current month
	firstDay		: Integer;				// dayOfWeek of 1st of the current month

	fillDays		: Integer;				// Number of filler days before first day
	daysInMonth		: Integer;				// Number of days in the current month

	controlObj		: Control;
	calendarDayObj	: JSSCalendarDay;
	monthRow		: Integer;
	monthColumn		: Integer;
	workDate		: Date;

	dayIter			: Iterator;
	dayNumber		: Integer;

begin
	daysInMonth	:= currentMonth.jssDaysInMonth(currentYear.jssIsLeapYear());
    firstDate.setDate(1, currentMonth, currentYear);
    firstDay	:= firstDate.dayOfWeek;

	// Calculate number of filler days before start of month.
	
	fillDays := firstDay - self.weekStartsOn;
	
	if fillDays &lt; 0 then
		fillDays := fillDays + 7;
	endif;

	// Calculate number of week lines required to display this month.
	
	self.numberOfWeeks := (fillDays + daysInMonth + 6) div 7;

    // Set up month heading
    if self.isShowMonthHeading then
    	self.myMonthHeading.visible		:= true;
    	self.myMonthHeading.caption		:= firstDate.monthName &amp; ' ' &amp; firstDate.year.String;
    else
    	self.myMonthHeading.visible		:= false;
	endif;

	// Set up day headings.
	
	workDate := firstDate - fillDays;
	
	foreach controlObj in self.allDayHeadings do
		controlObj.fontBold	:=	self.isMonthHeadingBold;
		
		if self.isShortDayName then
			controlObj.JSSCalendarHeading.caption	:= workDate.dayName[1:3];
		else
			controlObj.JSSCalendarHeading.caption	:= workDate.dayName;
		endif;
		
		controlObj.visible						:= self.isShowWeekends or workDate.dayOfWeek &lt; 6;
		workDate								:= workDate + 1;		
	endforeach;

	// Set up days.
	
	dayIter		:= self.allDays.createIterator();
	dayNumber	:= 0;
	workDate	:= firstDate - fillDays - 1;
	
	foreach monthRow in 1 to 6 do
		foreach monthColumn in 1 to 7 do
			dayIter.next(controlObj);
			calendarDayObj	:= controlObj.JSSCalendarDay;
			workDate		:= workDate + 1;

			if monthRow &gt; 1 or monthColumn &gt; fillDays then
				dayNumber := dayNumber + 1;
			endif;

			// Make weekend days invisible if necessary.
			
			calendarDayObj.visible := self.isShowWeekends or workDate.dayOfWeek &lt; 6;

			if dayNumber = 0 or dayNumber &gt; daysInMonth then
				calendarDayObj.setDay(0);
				calendarDayObj.backColor := self.unavailableColor;
				
				if monthRow &gt; self.numberOfWeeks then
					calendarDayObj.visible := false;
				endif;
				
				continue;
			endif;

			// Must be a vaild date in the month.
			
			calendarDayObj.setDay(dayNumber);
			calendarDayObj.backColor	:= self.availableColor;
			calendarDayObj.foreColor	:= self.availableTextColor;

			// Update caption with any events for this day.
			
            calendarDayObj.refreshCaption();
		endforeach;
	endforeach;

    // Now resize with new settings.
    
    self.resizeContents();
epilog	
	delete dayIter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="repositionAfterResize" id="1d1d9131-2062-48aa-b85b-04fc24664c5e">
        <updating/>
        <source>repositionAfterResize() updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Repositions the child controls after the receiver is resized.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
   	newLeft		: Real;
   	newTop		: Real;
   	newWidth	: Real;
   	newHeight	: Real;

begin
	newLeft		:= self.left;
	newTop		:= self.top;
	newWidth	:= self.width;
	newHeight	:= self.height;

	if isLockRight then
		newLeft		:= (parent.width - newWidth - distanceFromRight).max(0);
	endif;
	
	if isLockBottom then
		newTop		:= (parent.height - newHeight - distanceFromBottom).max(0);
	endif;
	
	if isStretchWidth then
		newWidth	:= (parent.width - newLeft - distanceFromRight).max(0);
	endif;
	
	if isStretchHeight then
		newHeight	:= (parent.height - newTop - distanceFromBottom).max(0);
	endif;

	if newLeft &lt;&gt; self.left
	or newTop &lt;&gt; self.top
	or newWidth &lt;&gt; self.width
	or newHeight &lt;&gt; self.height
	then
		self.move(newLeft, newTop, newWidth, newHeight);
		self.resizeContents();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="resizeContents" id="90509d1e-9631-4a95-a23a-f648ce6b7263">
        <updating/>
        <source>resizeContents() updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Resizes the receiver's child controls.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	MAX_MONTH_HEADING_HEIGHT	: Integer = 50;
	MAX_DAY_HEADING_HEIGHT		: Integer = 30;
	MONTH_HEADING_PROPORTION	: Decimal = 0.1;
// cnwdad1 20/05/2001.  Where the calendar control is quite small, the day heading names were too large for the row.
	DAY_HEADING_PROPORTION		: Decimal = 0.12;	// 0.08;

vars
	numberOfColumns		: Integer;
	widthPerColumn		: Real;
	heightPerRow		: Real;
	nextLeft			: Real;
	nextTop				: Real;
	firstDayRowTop		: Real;
	controlObj			: Control;
	columnNumber		: Integer;
	monthColumn			: Integer;
	columnWidth			: Integer;
	monthRow			: Integer;
	rowHeight			: Integer;
	dayIter				: Iterator;
	monthHeadingHeight	: Integer;
	dayHeadingHeight	: Integer;
	maxDayFontSize		: Real;

begin
	// Handle resize call before control has been built.
	
	if self.myMonthHeading = null then
		return;
	endif;

	if self.isShowWeekends then
		numberOfColumns	:= 7;
	else
		numberOfColumns	:= 5;
	endif;

	monthHeadingHeight	:= MAX_MONTH_HEADING_HEIGHT.min((self.clientHeight() * MONTH_HEADING_PROPORTION).Integer);
	dayHeadingHeight	:= MAX_DAY_HEADING_HEIGHT.min((self.clientHeight() * DAY_HEADING_PROPORTION).Integer);	

	widthPerColumn		:= self.clientWidth() / numberOfColumns;
	heightPerRow		:= self.clientHeight() - dayHeadingHeight;
	
	if self.isShowMonthHeading then
		heightPerRow	:= heightPerRow - monthHeadingHeight;
	endif;
	
	heightPerRow	:= heightPerRow / self.numberOfWeeks;

	// First size month heading.
	
	nextTop := 0;
	
	if self.isShowMonthHeading then
		myMonthHeading.move(0, nextTop, self.clientWidth(), monthHeadingHeight);
		myMonthHeading.setMaximumFontSize();
		nextTop := monthHeadingHeight;
	endif;

	// Then size the day headings.
	
	nextLeft		:= 0;
	columnNumber	:= 0;
	maxDayFontSize	:= 100;
	
	foreach controlObj in self.allDayHeadings do
		if controlObj.visible then
			columnNumber	:= columnNumber + 1;
			columnWidth		:= (columnNumber * widthPerColumn - nextLeft).rounded;
			controlObj.move(nextLeft, nextTop, columnWidth, dayHeadingHeight);
			controlObj.JSSCalendarHeading.setMaximumFontSize();
			maxDayFontSize	:= controlObj.fontSize.min(maxDayFontSize);
			nextLeft		:= nextLeft + columnWidth;
		endif;
	endforeach;

	// Now set all the font sizes for the days to the same value.
	
	foreach controlObj in self.allDayHeadings do
		if controlObj.visible then
			controlObj.fontSize := maxDayFontSize;
		endif;
	endforeach;

	nextTop			:= nextTop + dayHeadingHeight;
	firstDayRowTop	:= nextTop;

	// Now size all the days.
	
	dayIter := self.allDays.createIterator();
	
	foreach monthRow in 1 to self.numberOfWeeks do
		rowHeight		:= (monthRow * heightPerRow + firstDayRowTop - nextTop).rounded;
		columnNumber	:= 0;
		nextLeft		:= 0;
		
		foreach monthColumn in 1 to 7 do
			dayIter.next(controlObj);
			
			if controlObj.visible then
				columnNumber	:= columnNumber + 1;
				columnWidth		:= (columnNumber * widthPerColumn - nextLeft).rounded;
				controlObj.move(nextLeft, nextTop, columnWidth, rowHeight);
				nextLeft		:= nextLeft + columnWidth;
			endif;
		endforeach;
		
		nextTop := nextTop + rowHeight;
	endforeach;
epilog
	delete dayIter;
end;</source>
    </JadeMethod>
    <JadeMethod name="setAvailableColor" id="fd506a80-2be2-41ce-8c26-debb9c4aac00">
        <updating/>
        <source>setAvailableColor(pValue: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Updates the color for an available day, and resets all other colors.
//
// Parameters:	pValue - The new color for available days.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
   	if self.availableColor &lt;&gt; pValue then 
   		self.changeColors(	self.availableColor,
   							pValue,
   							self.unavailableColor,
   							self.unavailableTextColor,
   							self.highlightColor,
   							self.highlightTextColor,
   							self.headingTextColor,
   							self.headingColor);
		self.availableTextColor := pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setAvailableTextColor" id="86b566b8-26cb-4e40-93d2-8d83b78d4b57">
