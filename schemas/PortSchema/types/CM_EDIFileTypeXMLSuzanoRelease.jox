    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="create" id="ea1b056b-0aa8-4fba-8778-d6894f449592">
        <updating/>
        <source>create() updating;
//
//11 Jul 2014	cnwrs1	Par 34566 CCMS 2346 Suzano - Viagram Prenote file 
//
vars

begin
	self.name := "Suzano EDI Release";
	self.type := EDIFileType_XMLSuzanoRelease;
end;
</source>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="d158fbe1-2edb-4267-8c92-aab69837137d">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType, _fileTypeCode: Integer io); // cnwrs1 Par 24207 ccms 1117 11 May 2010
//----------------------------------------------------------------
//11 Jul 2014	cnwrs1	Par 34566 CCMS 2346 Suzano - Viagram Prenote file 
//----------------------------------------------------------------
vars
	ediData : CM_EDIData;
begin
	_ediDataClass := CM_EDIDataReleaseRequest;
	_dataType := EDIDataType_ReleaseRequest;
	_fileTypeCode := self.type;
end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_dataType" type="Integer" usage="io"/>
        <Parameter name="_fileTypeCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getEDIBundle" id="4f4fed7c-7625-45e5-8ba8-d62276229a0f">
        <source>getEDIBundle(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

