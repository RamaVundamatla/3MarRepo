    <JadeMethod name="pxyCreateUpdateProxy" id="17ad449d-987d-47a4-839e-c72001cdabcd">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------
// Created:	30 October 2003 By: cnwgd1
//--------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// 18 Nov 2019	jlgrs1	TFS 47300 collections not in pxyCreateUpdateProxy method
//
vars
	proxy : SelfType;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
//	proxy.myTerminal := self.myTerminal;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
