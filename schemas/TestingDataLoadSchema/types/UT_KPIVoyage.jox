    <JadeMethod name="uCreateDelay" id="73a185e2-7df0-4705-bb93-27afdf3df3f2">
        <source>uCreateDelay();
// ---------------------------------------------------------------------------
// Created:     08 June 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	delayProxy, realDelay : CM_Delay;
	voy : CM_Voyage;
	delayType : CM_DelayType;
	startDT, estEndDT, endDT : TimeStamp;
	kpiShift : CM_KPI ;
	time : Time;
	machine : CM_Machine;
	terminal, passportTerm	: CM_Terminal;
begin
	app.initialize();
	 
	 terminal := app.myRoot.allTerminals["MTNQ"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("MTN-OPS");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	write "Create a delay on crane COV1";
	app.writeLog("Create a delay on crane COV1", LogINFO);
	
	delayType := app.myRoot.allDelayTypes.first;
	self.assertTrueMsg((delayType &lt;&gt; null), "No delay types are setup!");
	
	//voy := self.getVoyage("OPSVIEW0018");
	machine := voyage.myTerminal.machines["COV1"];
	
	foreach kpiShift in voyage.allVoyageKPIEntities discreteLock do
		if kpiShift.isKindOf(CM_KPIVoyageCraneShift) then
			//startDT := kpiShift.CM_KPIVoyageCraneShift.shiftStartTS;
			time := startDT.time;
			time :=  time + 60000; // Plus 1 minute
			startDT.setTime(time);
			
			endDT := startDT;
			time := startDT.time;
			time :=  time + 3600000; // Plus 1 hour
			endDT.setTime(time);
			
			estEndDT := endDT;
			
			break;
		endif;
	endforeach;

	create delayProxy transient;
	delayProxy.setProxy(voyage.myTerminal,
					voyage,
					delayType,
					startDT,
					estEndDT,
					endDT,
					machine,
					app.getMyUser(),
					null,
					null);
	app.myTrxCA.trxCreateDelay(delayProxy, realDelay, app.myPassport);
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), app.myPassport.getAllErrorsWarningsAsString());

epilog
	delete delayProxy;
end;</source>
    </JadeMethod>
    <JadeMethod name="uEraseColourCoding" id="e23c1b8e-908b-4852-9e4d-46eebd3c34ad">
        <updating/>
        <source>uEraseColourCoding() updating;
/*23 September 2010	cnwas3	  par 25517*/

vars
	voyage : CM_Voyage;
begin

	//voyage := self.createVesselVoyage();
	//voyage := self.getTerminal.allVoyagesByCode.getAtKeyGeq('OPSVIEW001', null);

	self.deleteVoyageJob(voyage,"COV1",'100');
	
	self.createCargoOnship(voyage);
	self.createCargoOnSite(VoyageId, "OPBS1");
	
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);	
	
	self.createVoyageLoadJobs();
	self.deleteVoyageSlotsLoadCC();
	self.assertNoTrxErrorsOrWarnings();
	
	self.createVoyageSlotsLoadCC();
	self.planLoadItems();
	self.deleteVoyageSlotsLoadCC();	
	if not self.expectedTrxErrors.includes(Colour_coding_being_erased_pla) then				
		self.raiseTestException(false, null, ExceptionCode_ExpTRXError);
	endif;
	
	////////////
	
	self.deleteVoyageJob(voyage,"COV1",'100');	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uHighCubePlanning" id="4c0b9ebf-481b-403a-996e-f5af3f700400">
        <updating/>
        <source>uHighCubePlanning() updating;
/*24 September 2010	cnwas3	  23453*/

vars
	
	voyage : CM_Voyage;
	voyageJob : CM_VoyageJob;
	slots : CM_SlotControllerArray;
	tmpLoadCC	: CMIF_LoadColorCode;
	hicubePlanningWarning : Integer;
	
begin
	self.setTerminalConfig(HiCubePlanningWarning,HCPlanWarn_HCFullCheck);
	
	//voyage := self.getTerminal.allVoyagesByCode.getAtKeyGeq('OPSVIEW001', null);

	self.deleteVoyageJob(voyage,"COV1",'100');
	
	//self.createCargoOnship(voyage);
	//self.createCargoOnSite();
	
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);	
	
	//////////////////////create the colour coding, assign the job, load cargo
	
	create slots transient;
	create tmpLoadCC transient;
	tmpLoadCC.overrideMoveType :=true;
	tmpLoadCC.myDischargePort:=app.myRoot.allPorts["NZAKL"];
	
	
	self.getJobSlotControllers(voyage.code,"01",DeckOnDeck,1,1,6,slots);
	self.markSlotsAsLoadJob(slots,tmpLoadCC);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Hicubed);	
	voyageJob:=self.addVoyageJob(voyage,"COV1",slots, false);
	assertTrue(voyageJob &lt;&gt; null);
	
	self.planLoadItems();	
	if not self.expectedTrxErrors.includes(TI_TestReqHighCubed) then				
		self.raiseTestException(false, null, ExceptionCode_ExpTRXError);
	endif;
	
	//////////////////////delete the voyage jobs
	
	self.deleteVoyageJob(voyage,"COV1",voyageJob.id);
	
	slots.clear();	
	self.getJobSlotControllers(voyage.code,"01",DeckOnDeck,1,1,6,slots);
	self.unmarkSlotsAsLoadJob(slots);
	
epilog
	
	delete slots;
	delete tmpLoadCC;
end;</source>
    </JadeMethod>
    <JadeMethod name="uKPIBGP" id="e0c270e5-70f8-493e-9bfa-cfc7336c1d14">
        <source>uKPIBGP();
// ---------------------------------------------------------------------------
// Created:     30 August 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lc : CM_LocationsController;
	voy : CM_Voyage;
	slots : CM_LCSet;
	jobSlots : CM_SlotControllerArray;
	voyageJob : CM_VoyageJob;
	controller : CMIF_KPIShipMove;
	ti : CM_TrackedItem;
	tran : CM_Receive;
	term : CM_Terminal;
begin

	//voy := self.getVoyage("OPSVIEW001");
	lc := voyage.getNextFreeSlotLCByDischargeCC(false);
	
	if lc &lt;&gt; null then
		create slots transient;
		slots.add(lc);
		//voy.createQuickCargo(slots, false);
		self.createQuickCargoLOLO(voy, slots, false);									// 10/09/2015 cnwmh5
	else
		return;
	endif;
	
	ti := lc.allTrackedItems.first;
	app.myTrxUA.trxSetDfltDischargeColourCode(voy.myCellularVoyageStructure, app.myPassport);
	create jobSlots transient;
	slots.copy(jobSlots);
	voyageJob:=self.addVoyageJob(voy,"COV1",jobSlots, true);
	
	assertTrue(voyageJob &lt;&gt; null);

	self.planDischargeItem(voyageJob);
	self.loadVoyJobToOps(voyageJob, true, false);
	self.moveCargoForVoyageJob(voyageJob, REAL_MODE);
	
	tran := ti.getTransReceive();
	create controller transient ;
	controller.CMIF_KPIShipMove.myJobSheet := voyageJob.myJobSheet.CM_VoyageJobSheet;
	controller.myTiTransaction := tran;

	// BPG style KPI update
	controller.processKPI();

	
	
epilog
	delete slots;
	delete jobSlots;
	delete controller;
end;</source>
    </JadeMethod>
    <JadeMethod name="uMain" id="acd1068e-9979-48fc-a4cb-97f62bc27c34">
        <updating/>
        <source>uMain() updating;
// ---------------------------------------------------------------------------
// Created:     31 May 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	//voyage : CM_Voyage;
begin

	self.setConfigDLRSOBStart();
	
	setupCranes();
	
	setupShifts();
		
	voyage := self.createVoyage(VoyageId);
	self.assertNotNullMsg(voyage, "Unable to find voyage: " &amp; VoyageId);
		
	beginTransaction;
	voyage.setStatusFromObject(app.myRoot.allVoyageStatuses[Voyage_Status_Loading]);
	voyage.setVoyProcessFromTerm();
	commitTransaction;
	
		
	self.createCargoOnship(voyage);
		
	self.createCargoOnSite(voyage.code, "OVBS1");
	
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
		
	self.createVoyageDischargeJobs();
	
	
	if voyage.useVoyageAllocations then
		self.createVoyageLoadJobsVA(); // and Colour Coding
	else
		self.createVoyageLoadJobs(); // and Colour Coding
	endif;



	//self.createLidJobs();
	self.planLoadItems();

	self.loadAllJobsToOpsOpsview(voyage, true);
	self.planDischargeItems();

	// Added in these expect's (after removing comment in UT_DSL::moveCargoForVoyageJob) - cnwmc5
	self.expectTrxError(Cargo_that_locat_colou_codedee);
	self.expectTrxError(WarningPileHeightExceed2);
	self.expectTrxError(SystemAlertCreated);
	

	
epilog
	
	self.opts.purge();
end;</source>
    </JadeMethod>
    <JadeMethod name="uOnlyCheckKPIsFortMainVoy" id="56be894f-8cb9-4471-bf3e-5d98d0673e48">
        <updating/>
        <source>uOnlyCheckKPIsFortMainVoy() updating;

/*

Purpose:		Just run the checkKPIs method for the voyage created in tMain (OPSVIEW1)

Date		Who		Reason
28/06/2012	cnwmh5	Initial creation
*/
constants
	VoyageCodeUT		: String = "OPSVIEW001";
vars
	voyage 				: CM_Voyage;
	terminal			: CM_Terminal;
begin
	
	// get the terminal we are running in 
	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	self.assertEqual(terminal.code, "MTNQ");
	
	// get the required voyage for the terminal
	foreach voyage in terminal.allVoyagesByCode do
		if voyage.code = VoyageId then
			break;
		endif;
	endforeach;
	self.assertNotNull(voyage);
	self.assertEqual(voyage.code, VoyageId);
	
	// check the kpi's
	self.checkKPIs(voyage);	
	self.checkWPOpHrMethods(voyage);
	
epilog

end;</source>
    </JadeMethod>
