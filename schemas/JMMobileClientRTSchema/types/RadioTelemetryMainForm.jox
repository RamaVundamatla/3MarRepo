    <JadeMethod name="tableContainerSearchInit" id="7b8ba8da-d293-4616-bb31-e2d02c0f4dea">
        <source>tableContainerSearchInit() protected;

/*

Purpose:			Initialise the Container Search Results table


Return Value:		None


Date		Who		Reason
05 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	tableObj		: Table;
	columnObj		: JadeTableColumn;
	rowObj			: JadeTableRow;
	numCols,
	i				: Integer;
	
begin
	tableObj					:= self.tblContSrchRes;
	
	tableObj.rows				:= 1;
	tableObj.columns			:= 3;
	tableObj.fixedColumns		:= 0;
	tableObj.fixedRows			:= 1;
		
	tableObj.partialTextIndication	:=	true;

	columnObj					:= tableObj.accessColumn(1);
	columnObj.widthPercent		:= 30;
	
	columnObj					:= tableObj.accessColumn(2);
	columnObj.widthPercent		:= 35;
		
	columnObj					:= tableObj.accessColumn(3);
	columnObj.widthPercent		:= 35;

	tableObj.backColor			:= tableObj.parent.backColor;
	tableObj.gridLines			:= false;
	tableObj.defaultRowHeight	:= 60;
	
	tableObj.readOnly			:= false;
	
	rowObj						:= tableObj.accessRow(1);
	rowObj.fontBold				:= true;
	
	tableObj.setCellText(1, 1, "ID" &amp; Tab &amp; "Current Location" &amp; Tab &amp; "Queued Location");

	self.lblSearchWarning.caption := null;
	
	
epilog

end;</source>
