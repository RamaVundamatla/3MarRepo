    <JadeMethod name="outputHeader_LOC" id="c3e1df6e-2541-45c2-aa5d-07b0a9e74b2e">
        <updating/>
        <source>outputHeader_LOC(_protocol: CM_CamProtocol; _camMessage: CM_CamMessage input; _camTaskHistory: CM_CamTaskHistory input; _terminal: CM_Terminal; _coll: HugeStringArray input): String updating, protected;
//
// Purpose:			Swires don't want a LOC+9 in the header of their CODECO messages, they want it at the group level
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/08/2020	jlgdap1		Initial creation TFS 49880 TML Swire Shipping Outgoing EDI Depot and Terminal
//
vars

begin
	return null;

epilog

end;</source>
