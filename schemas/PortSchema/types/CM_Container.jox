    <JadeMethod name="getOtherTrackedItem" id="bf7b0810-be6e-4156-90d8-60dacaa2ea51">
        <source>getOtherTrackedItem(_theAction : Integer): CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		used in connect and disconnect code
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aTI : CM_TrackedItem;
	aLocation,aTowerController : CM_LocationsController;
begin
	// DISCONNECT
	if _theAction = ACTION_DISCONNECT then
		if self.hasCOU then
			aTI := self.getCou;
		elseif self.getTower &lt;&gt; null then
			aTI := self.getTower;
		else
			aTI := null;
		endif;
	endif;
	
	
	// CONNECT
	if _theAction = ACTION_CONNECT then
		if self.isPortHole then
			// get our controller
			aLocation := self.getPrimaryLocation(REAL_MODE);
			if CM_GridController.hasInstance(aLocation) then
				//try to get a tower controller next to us
				aTowerController := aLocation.CM_GridController.getNextControllerOfType(CM_TowerController);
				if aTowerController = null then
					aTowerController := aLocation.CM_GridController.getPreviousControllerOfType(CM_TowerController);
				endif;
				
				// get the tower Ti that is at the same height as us
				if aTowerController &lt;&gt; null then
				// aTI is updated by this method 'getTIAtHeight'
					aTowerController.CM_TowerController.getTIAtHeight(aTI, aLocation.allTrackedItems.indexOf(self), REAL_MODE);
				endif;
			endif;
		else
			aTI := null;
		endif;
	endif;
	
	return aTI;

end;</source>
        <Parameter name="_theAction" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getOverstowWeight" id="4460acb8-e14b-405a-b8c4-00babc20ebe7">
        <source>getOverstowWeight() : Decimal;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tiArraySort	: CMIF_RTSortByPosDict;
	rtSort		: CMIF_RTSort;
	infoCols	: IntegerArray;
	rtnWeight,
	tmpWeight	: Decimal[14,4];
begin

	create infoCols transient;
	create tiArraySort transient;
	self.getOverstowedByTIs(REAL_MODE, tiArraySort, infoCols, true);
	
	if tiArraySort = null then
		return -1;
	endif;
	
	foreach rtSort in tiArraySort do
		tmpWeight := rtSort.myTi.totalWeight;
		rtnWeight := tmpWeight + rtnWeight;
	endforeach;

epilog
	delete infoCols; // PAR 17136
	delete tiArraySort; // PAR 17136
	
	return rtnWeight;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getOverstowedByTIs" id="c14e4ec8-b94b-4fd2-a443-45e529e85437">
        <source>getOverstowedByTIs(mode: Integer; tis: CMIF_RTSortByPosDict input; _40Info : IntegerArray input; _includeSelf : Boolean);

// cnwdvb1 15 July 2003 

vars

	lc		: CM_LocationsController;
	tiSort	: CMIF_RTSort;
	locations : CM_LCArray;
begin

//	if self.is40 then
	if self.requiresMoreThan1TwentyLC() then  // PAR 16415 CCMS 1029
		//epr TFS 37584 9/5/18 mode was passed in but always using self.locations ??
		locations :=self.getLocationsArray(mode,0);
		if locations = null then
			return;
		endif;
		foreach lc in locations do
			
			lc.getOverstowedByTIs(mode, self, tis, _includeSelf);			
		endforeach;
	
		if _40Info &lt;&gt; null then
			foreach lc in locations do
				
				if not lc.isKindOf(CM_GridController) then
					break;
				endif;
				if not _40Info.includes(lc.CM_GridController.column) then
					_40Info.add(lc.CM_GridController.column);
				endif;
			endforeach;
//			self.allLocations.copy(_40Info);
		endif;
	else
		inheritMethod(mode, tis, _40Info, _includeSelf);
	endif;
	foreach tiSort in tis where tiSort.myTi &lt;&gt; self do
		if tiSort.myTi.isAttributeTrue(TI_Attrib_IsForty) then
			locations := tiSort.myTi.getLocationsArray(mode,0);
			if locations = null then
				return;
			endif;
			
			if _40Info &lt;&gt; null then
				foreach lc in locations do
					if not lc.isKindOf(CM_GridController) then
						break;
					endif;
					if not _40Info.includes(lc.CM_GridController.column) then
						_40Info.add(lc.CM_GridController.column);
					endif;
				endforeach;
//					tiSort.myTi.allLocations.copy(_40Info);
			endif;
			foreach lc in locations do
				lc.getOverstowedByTIs(mode, tiSort.myTi, tis, _includeSelf);
			endforeach;
			break;
		endif;
	endforeach;

end;</source>
        <Parameter name="mode" type="Integer"/>
        <Parameter name="tis" type="CMIF_RTSortByPosDict" usage="input"/>
        <Parameter name="_40Info" type="IntegerArray" usage="input"/>
        <Parameter name="_includeSelf" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getPMTemp" id="37b145db-ea80-4505-87d7-a6439929252e">
