    <JadeMethod name="getTiTxnClassForType" id="8cad84af-b6c5-41d1-a23d-419bb0848ca4">
        <source>getTiTxnClassForType(pType : Integer; _doLookup : Boolean) : Class;
// ---------------------------------------------------------------------------
// Created:     19 September 2001 by cnwrs2
//
/****Changes

Date		Name	TFS#						Description
=======================================================================================================
04/06/2010	cnwdad1	CCMS 1129 - 				Added CM_StopDelete.
19/08/2010	cnwdad1	CCMS 1903 (PAR #24065). 	CM_InfoEDISent.
23/08/2010	cnwrl1	PAR 23697 - CCMS 1097 - 	Stop Expiry - retain info after expiry.
04/02/2013	cnwcs5	CCMS SFW 1294 /par 30855 	CAMS Audit
17/03/2015	cnwdap1	PAR #35874 TFS 265 			Humidity and Ventilation Readings
14/08/2017	cnwma1	TFS #5695:STWO - 			Re-Calculate Volumes on Forms and EDI
07/05/2018	jlgdap1	TFS 38501 					PEL1 Work Order Changes
30/11/2018	jlgka1	TFS 41225 					SNO - Repaired Transaction Revisit
20/09/2109	jlgzm1	TFS 46054					STWO - Adding Extra Details to Manual Invoice Lines
25/10/2019	jlgdi1	46578						Added TRANS_TYPE_RECVROADCANCELLED
23/09/2022  navcs2	ChangeRequest 56633:[56211] 54253.101 - Work order Transactions
06/03/2023	jlika1	TFS 56882					Added TRANS_TYPE_HAZ_CHECK to return CM_HazardsCheck
28/03/2023	navkc1	CR# 56430 Task 56433		Jade - New Transaction Types
02/06/2023 navmv20 CR 58213 Task 58214: Jade - New TI Transaction
05/09/2023	navkc1	CR 59934 Task 59935: Jade - Cust Doc Cargo Transactions
09/02/2024	jlika1	TFS 62215 CUX | Transactions when loading/unloading a MAFI
26/01/2024	jlika1	TFS 62524 CUX | MAFI Priority Override and Transactions
13/03/2024	navkc1 	CR 62890 Task 62891: Jade - New Cargo Transaction Types
26/08/2025	navcs2	MTN-35846 Dev - Returning of Lot Based Cargo | PortSchema Changes
16/12/2025	navdap1	MTN-36569 CPL | Reefer Runner Integration
=======================================================================================================*/
vars
	tmpTrxType	: CM_TransactionType;
	strObj		: CM_StringWithObject;
	
begin
	if _doLookup then
		tmpTrxType := app.myRoot.allTransactionTypes[pType];
		if tmpTrxType = null then
			return null;
		endif;
		
		if tmpTrxType.trxGroup = TRANS_TYPE_GROUP_TI then
			if app.allTITransClassNames = null then
				app.initTITransClassNames();
			endif;
			
			strObj := app.allTITransClassNames[tmpTrxType.classNameToCreate].CM_StringWithObject;
			if strObj &lt;&gt; null then
				return strObj.object.Class;
			endif;
			//return CM_Transaction.getSubclassByName(tmpTrxType.classNameToCreate);
		// ### TFS CR 60699 TASK 60700 27SEP2023 NAVAB1 - user definable WO transaction types only use this class
		elseif tmpTrxType.trxGroup = TRANS_TYPE_GROUP_WO then
			return CM_WOTI_ToDoTask;
		elseif pType = TRANS_TYPE_BOL_TRANSFER then					//28 Apr 2016	NDL TFS 1903
			return CM_BOLTransferTransaction;
		elseif pType = TRANS_TYPE_BOL_GLDATE then // TFS 4272
			return CM_BOLGeneralLandingDate; // TFS 4272
		elseif pType = TRANS_TYPE_BOL_STOP_ADD then	//31 Dec 2018	NDL	TFS 42686
			return CM_BOLStopCreated;
		elseif pType = TRANS_TYPE_BOL_STOP_CLEARED then	//31 Dec 2018	NDL	TFS 42686
			return CM_BOLStopCleared;
		elseif pType = TRANS_TYPE_BOLSTATUSMESSREC then	//31 Dec 2018	NDL	TFS 42686
			return CM_BOLStatusMessageReceived;
		elseif pType = TRANS_TYPE_BOLCREATED then	//31 Dec 2018	NDL	TFS 42686
			return CM_BOLCreate;
		elseif pType = TRANS_TYPE_BOL_TFRD then	//30 Oct 2019	NDL	TFS 47100
			return CM_BOLTransferred;
		elseif pType = TRANS_TYPE_BOL_CONSEE then	//30 Oct 2019	NDL	TFS 47100
			return CM_BOLConsigneeChanged;
		elseif pType = TRANS_TYPE_BOL_CONSOR then	//30 Oct 2019	NDL	TFS 47100
			return CM_BOLConsignorChanged;
		elseif pType = TRANS_TYPE_BOL_OPER then	//30 Oct 2019	NDL	TFS 47100
			return CM_BOLOperatorChanged;
		elseif pType = TRANS_TYPE_BOLIN_SCALER then
			return CM_BOLInScalerTransaction;
		elseif pType = TRANS_TYPE_TRAILER_CARGO_DIS then
			return CM_TrailerDischarge;
		elseif pType = TRANS_TYPE_TRAILER_CARGO_LOAD then
			return CM_TrailerLoad;
		endif;
		
		return null;
		
	endif;

	if pType = TRANS_TYPE_ATTACH then
		return CM_Attach;
	//Added 26/06/2006 cnwsh3 Was omitted in update in May 2006
	elseif pType = TRANS_TYPE_AvailableForRelease then
		return CM_AvailableForRelease;
	elseif pType = TRANS_TYPE_BOL_STOP_ADD then// 14/09/2009 cnwsh3	CCMS SFW1044 - AMS changes
		return CM_BOLStopCreated;
	elseif pType = TRANS_TYPE_BOL_STOP_CLEARED then
		return CM_BOLStopCleared;
	elseif pType = TRANS_TYPE_BOL_GLDATE then // TFS 4272
		return CM_BOLGeneralLandingDate; // TFS 4272
	elseif pType = TRANS_TYPE_BOLSTATUSMESSREC then
		return CM_BOLStatusMessageReceived;
	elseif pType = TRANS_TYPE_BOLCREATED then
		return CM_BOLCreate;
	elseif pType = TRANS_TYPE_BUSINESS_U_RECEIVE then
		return CM_BusinessUnitReceive;
	elseif pType = TRANS_TYPE_BUSINESS_U_RELEASE then
		return CM_BusinessUnitRelease;
	elseif pType = TRANS_TYPE_CHILL_TEST then
		return CM_ChillTest;
	elseif pType = TRANS_TYPE_CONNECT then
		return CM_Connect;
	elseif pType = TRANS_TYPE_CONNECT_POWER then
		return CM_ConnectPower;
	elseif pType = TRANS_TYPE_CONNECT_TOWER then
		return CM_ConnectTower;
	elseif pType = TRANS_TYPE_CREATED then
		return CM_Create;
	elseif pType = TRANS_TYPE_CSC_INSPECT then
		return CM_CscInspect;
	elseif pType = TRANS_TYPE_CUSTSTOP_CLRD then
		return CM_CustomStopClear;
	elseif pType = TRANS_TYPE_CURTAIN then
		return CM_Curtain;
	elseif pType = TRANS_TYPE_DAIRY then
		return CM_DairyBoard;
	elseif pType = TRANS_TYPE_DAMAGED then
		return CM_Damage;
	elseif pType = TRANS_TYPE_DAMAGE_LOC then	//01 Mar 2016	NDL TFS 1593
		return CM_DamageLocation;
	elseif pType = TRANS_TYPE_DETACH then
		return CM_Detach;
	elseif pType = TRANS_TYPE_DISCONNECT_POWER then
		return CM_DisconnectPower;
	elseif pType = TRANS_TYPE_DISCONNECT_TOWER then
		return CM_DisconnectTower;
	elseif pType = TRANS_TYPE_DOORS_OFF then
		return CM_RemoveDoors;
	elseif pType = TRANS_TYPE_ERASE then
		return CM_Erase;
	elseif pType = TRANS_TYPE_EDIT then
		return CM_Edit;
	elseif pType = TRANS_TYPE_EXT_CLEAN then
		return CM_ExternalClean;
	elseif pType = TRANS_TYPE_FUELED then
		return CM_Fuel;
	elseif pType = TRANS_TYPE_FUMIGATE then
		return CM_Fumigation;
	elseif pType = TRANS_TYPE_GRP_ASSIGN then	//03 Jun 2915	NDL	Par 36338	
		return CM_GroupAssign;
	elseif pType = TRANS_TYPE_GRP_COMPLETE then	//21 Aug 2915	NDL	Par 36608	
		return CM_GroupComplete;
	elseif pType = TRANS_TYPE_GRP_UNASSIGN then	//03 Jun 2915	NDL	Par 36338	
		return CM_GroupUnassign;
	
	elseif pType = TRANS_TYPE_HIDE then
		return CM_HideLined;
	elseif pType = TRANS_TYPE_HIRE then
		return CM_Hire;
	elseif pType = TRANS_TYPE_HUMIDITYREADING then			// PAR #35874
		return CM_HumidityReading;							// PAR #35874
	elseif pType = TRANS_TYPE_INFO_EDI_SENT then	// cnwdad1 19/08/2010 - PAR #24065.
		return CM_InfoEDISent;						// cnwdad1 19/08/2010 - PAR #24065.
	elseif pType = TRANS_TYPE_INSPECT then
		return CM_Inspect;
	elseif pType = TRANS_TYPE_INFORMATION then
		return CM_Information;
	elseif pType = TRANS_TYPE_INTER_STG_TRANSPORT then
		return CM_InterStorageTransport;
	elseif pType = TRANS_TYPE_LocationCheck then	//12 Aug 2015	NDL	Par 36608	
		return CM_LocationCheck;
	elseif pType = TRANS_TYPE_Logical_Delete then	//03 Aug 2017	NDL	TFS 5679
		return CM_LogicallyDeleted;
	elseif pType = TRANS_TYPE_LogNoNumberOffload then
		return CM_LogNoNumberOffload;
	elseif pType = TRANS_TYPE_LogNoNumberRetain then
		return CM_LogNoNumberRetain;
	elseif pType = TRANS_TYPE_LogNoNumberSwap then
		return CM_LogNoNumberSwap;
	elseif pType = TRANS_TYPE_MANUALLINECREATED then	// TFS 46054
		return CM_ManualInvoiceLineCreated;
	elseif pType = TRANS_TYPE_MOVE then
		return CM_Move;
	elseif pType = TRANS_TYPE_NEEDSPRETRIP then	//cnwrs1 par 28043
		return CM_NeedsPreTrip;
	elseif pType = TRANS_TYPE_NEEDSDAIRYBOARD then		//cnwrs1 par 28644 10 nov 2011
		return CM_NeedsDairyBoard;
	elseif pType = TRANS_TYPE_NEEDSWASH then	//cnwrs1 par 28043
		return CM_NeedsWash;
	elseif pType = TRANS_TYPE_Offload then
		return CM_Offload;
	elseif pType = TRANS_TYPE_OUTTURN then	//07 Aug 2017	NDL	TFS 5701
		return CM_Outturn;
	elseif pType = TRANS_TYPE_MOVE_PICKUP then
		return CM_Pickup;
