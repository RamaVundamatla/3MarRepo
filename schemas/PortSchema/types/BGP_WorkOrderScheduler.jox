    </JadeMethod>
    <JadeMethod name="initApp" id="fcca1ab1-d793-4cb8-b320-c3dfd939ff3a">
        <updating/>
        <source>initApp() updating;
/*

Date		Who			Reason
19 jan 2010	conkc1		created

*/
//03 Jan 2013	cnwrs1	32983 crash after user deleted.

vars

	ls      	: Boolean;
	str	        : String;
	errorText	: String;
	errorCode	: Integer;
	workOrderSchedController : CMIF_WorkOrderSchedController;
	msg : String;
begin

	on Exception do self.xHandlerGlobal(exception) global;
	on LockException do app.alertLockExceptionHandler(exception) global;
	str := self.getOidString();
	str.replaceChar('.' , '_');
	app.logFileNameSpecific := 'BGPController_' &amp; self.logFileName() &amp; '_' &amp; str; 
	
	app.setCnAppAlias(self.class.name);		//epr TFS 36655 29/4/19
	
	app.initialize();

	app.setIsBackGroundApp(true);

 	app.cmsBeginLoad(ls);
	exclusiveLock(self);
	if self.isRunning() then
		app.isBGPAppAbort := true;
		msg := 'ERR &gt;&gt; app is already running';
		app.writeLog(msg, LogFATAL);	//25 Nov 2019	NDL	TFS 47053
		
		app.exitLogFile();
		terminate;
	endif;
	
	if app.myPassport &lt;&gt; null then
 		app.myPassport.setMyUser(self.myUser);
  	endif;

	app.myTrxUA.trxUpdateBGPControllerProcess(self, process, process.signOnTime, true, app.myPassport);
	self.beginNotification(self, BGP_Object.BGP_TerminateAppRequest, Response_Cancel , null);
	self.beginNotification(self, BGP_Object.BGP_DebugLevelChangeEvent, Response_Continuous , null);
	self.beginNotification(self, BGP_Object.BGP_OutputInfo, Response_Continuous , null);
	self.beginNotification(self, BGP_Object.BGP_ApplicationStartRequest, Response_Continuous , null);

	create workOrderSchedController transient;
	workOrderSchedController.initworkOrderScheduler;
	workOrderSchedController.setMyController(self.BGP_WorkOrderScheduler);
	//
	// The Current policy is to set the start time to the current time and 
	// 
	beginTransaction;
	self.updateLastStartTime(app.actualTimeServer);
	commitTransaction;
epilog
	app.cmsEndLoad(ls);
end;</source>
    </JadeMethod>
    <JadeMethod name="setAttributesForCreate" id="be422e49-5745-4a38-bb59-407f29e1996f">
        <updating/>
        <source>setAttributesForCreate() updating, protected;
/*
Purpose:			

Return Value:		

Date			Who		Reason
19 January 2010	conkc1	Initial creation
*/
vars

begin
	self.name				:= 'WorkOrder Scheduler';
	self.schemaName			:= 'UiCommonSchema';
	self.isEditable			:= true;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateLastStartTime" id="dbcd0672-8913-487a-9483-627e6eac7bd2">
        <updating/>
        <source>updateLastStartTime(_lastStartTime : TimeStamp) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2010	conkc1	Initial creation
*/
begin
	self.lastStartTime := _lastStartTime;
epilog

end;</source>
        <Parameter name="_lastStartTime" type="TimeStamp"/>
    </JadeMethod>
</Class>
