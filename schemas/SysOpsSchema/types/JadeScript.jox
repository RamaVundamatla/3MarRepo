    <JadeMethod name="getAllTableNames" id="c039a1e3-9fe0-4246-898a-48a44803eb24">
        <source>getAllTableNames();
/*

Purpose:			
 returns all table name headings with naming convention errors
Parameters:			

Return Value:		

Date		Who		Reason
09 July 2014	cnwdb2	Initial creation Par #33977

*/
constants
    FileNameWrite : String = 'C:\Users\cnwdb2\Documents\FileWriteTest.txt'; // set file name of contents to write to change to your address when testing
vars
    fileWrite    : File;
	harb : HMS_Harbour  ; 
	entTableDef	: EntTableDef;
	entTableRow : EntTableRow ;
	rowHeading,str1,error,error2  : String ; 
	hugeString : HugeStringArray ; 
	seperatedLines : StringArray ; 
	int  : Integer ; 
	allNameErrors : HugeStringArray ; 
	errorCount,idx : Integer ; 
	number  : IntegerArray ; 

	
begin

	hugeString := zGetHugeStringArray() ; 
	create seperatedLines transient ; 
	create allNameErrors transient ; //create the array of all the name errors
	create	number transient  ; 

	create fileWrite;
    fileWrite.mode     := File.Mode_Output;
    fileWrite.fileName := FileNameWrite;
    fileWrite.open;
	
	foreach entTableDef in app.myRoot.myEntTableDataRoot.allEntTableDefs do
		//if entTableDef.name = "HMSHarbourDefaults" then
			foreach entTableRow in entTableDef.allEntTableRows do 
				rowHeading := entTableRow.getHeading(null,null,null) ;
				foreach str1 in hugeString do
					if seperatedLines.size &gt;  0 then		 
						seperatedLines.clear() ;
					endif;
					
					str1.getTokensForDelimiter(",",seperatedLines) ; 
					
					if seperatedLines.size &lt;= 1 then
						continue ;
					endif;				
					
					if rowHeading.cnContains(seperatedLines[2]) then
							idx :=  allNameErrors.indexOf(seperatedLines[2]);
							if idx &gt; 0 then
								number[idx] := number[idx] + 1;
							else
								allNameErrors.add(seperatedLines[2]);
								number[allNameErrors.size] := 1;
							endif;
					      //  fileWrite.writeLine(" - " &amp; "Entity Table: "  &amp; entTableDef.name &amp; " , " &amp; " Translation Result: "   &amp; rowHeading &amp;  " , " &amp; " Has Incorrect Term: " &amp; seperatedLines[2]  &amp; " , " &amp; " Correct Term is : " &amp; seperatedLines[1] );
							fileWrite.writeLine(" - " &amp; "Entity Table: "  &amp; entTableDef.name &amp; " - " &amp; " Translation Result: "   &amp; rowHeading &amp;  " - " &amp; " Has Incorrect Term: " &amp; seperatedLines[2]  &amp; " - " &amp; " Correct Term is : " &amp; seperatedLines[1] );

								//write " - " &amp; "Entity Table: "  &amp; entTableDef.name &amp; " , " &amp; " Translation Result: "   &amp; rowHeading &amp;  " , " &amp; " Has Incorrect Term: " &amp; seperatedLines[2]  &amp; " , " &amp; " Correct Term is : " &amp; seperatedLines[1]  ; 
								int := int +1  ;
						
					endif ;
				endforeach  ;
			endforeach ; 
		//endif ;  
	endforeach  ; 
	
	//This outputs the most common numbers
	write "Most common errors as Percentage" ; 
	foreach idx in 1 to allNameErrors.size do
		write allNameErrors[idx] &amp; " &gt;&gt;&gt; " &amp; (number[idx]/int * 100).String &amp; " %";
	endforeach;
	
	
	//	write error  ;
		
	//	write "total  num errors   " &amp; int.String ; 
	fileWrite.writeLine("total  num errors   " &amp; int.String ) ;
	
	fileWrite.close  ; //close the file 

	
epilog

	delete seperatedLines ;
	delete hugeString ; 
	delete fileWrite  ; 
	delete allNameErrors ; 
	delete number ; 


end;</source>
    </JadeMethod>
    <JadeMethod name="getEntRowXlations" id="4c57d06c-b2cd-415c-81c3-3e986e8fe12b">
        <source>getEntRowXlations();
/*

Purpose:			
This gets all the EntRow xltations for each of the table names. This is done in order to compare these against our unit test
'uGetNamingTableConvents' which compares the rows with the expected naming conventions.

 *update - uGetNamingTableConvents no longer used 
Parameters:			

Return Value:		

Date		Who		Reason
06 June 2014	cnwdb2	Initial creation

*/

vars
	subClasses	: ClassColl;
	subClass	: Class;
	item		: SOP_TableMaintItem;
	tmpTerminal	: CM_Terminal;
	tmpUser		: CM_User;
	includeDutyDoc	: Boolean;
	nameEntDef : String;
	entTableDef	: EntTableDef;
	entTableRow : EntTableRow ; 
	entTabText : XLAT_EntityTableText ; 
	xlation : XLAT_Translation;
	xlationResult : String ; 
	hugeString : HugeStringArray ; 
	seperatedLines : StringArray ; 
	str : String ; 
	int : Integer ; 
	b  : String ; 
	str2 : String ; 
	strArray : StringArray  ; 
	subString : StringArray ; 
	
	
	
begin

	int := 0 ; 
	app.initialize();
	
	create seperatedLines transient  ;
	create subString transient ; 
	hugeString := zGetHugeStringArray();


	beginLoad;
	
	includeDutyDoc := app.isDutyDocEnabled;

	
	tmpUser := app.getMyUser;

	create subClasses transient;
	SOP_TableMaintItem.allLocalSubclasses(subClasses);
	
	create strArray transient ; 
		
	strArray := db2Test()  ;
					

	foreach subClass in subClasses do

		if subClass.abstract then
			continue;
		endif;
		
		if subClass.Class = SOPTM_EDIActions then 
			continue;							  
		endif;
		
		if not includeDutyDoc then
			if subClass = SOPTM_DutyDocHSCodes 
			or subClass = SOPTM_DutyDocType 
			or subClass = SOPTM_DutyDocExchangeRate then
				continue ; 
			endif;
		endif;
		
		
		if subClass = SOPTM_DataAccessSubTerminal or subClass = SOPTM_SubTerminal then
			if not app.isSubTerminalsLicensed then
			   continue;
			endif;
		endif;		
		
		create item as subClass transient;

		nameEntDef := item.getEntTableDef();
		
		if nameEntDef &lt;&gt; null then
		 // write "Entity Definition: " &amp; nameEntDef ;
			
		endif ; 
		
		entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[nameEntDef];
		
		//entTableDef.inspectModal	;
	
		//break;
	
		if entTableDef	&lt;&gt; null	 then
			foreach	entTableRow	in entTableDef.allEntTableRows do
				entTabText := entTableRow.myEntTableText;
				if entTabText &lt;&gt; null then
					foreach xlation in entTabText.allTextByLocale do
						if xlation.myLocale.localeId = "0000" then
							xlationResult :=	xlation	.text	;
							//write xlationResult  ;
						endif ; 
					endforeach;
				endif;
				//write	entTableRow.number	;
				
				//write "Entity Definition: " &amp; nameEntDef &amp; ", " &amp;  xlationResult ;
				
							//This displays the good array stuff
				//Just to this point
				foreach str in hugeString do
					if seperatedLines.size &gt;  0 then		 
						seperatedLines.clear() ;
					endif	  ;
					str.getTokensForDelimiter(",",seperatedLines) ; 
				
					if seperatedLines.size &lt;= 1 then
						continue ;
					endif;
					//write seperatedLines[2] ; 
					//write seperatedLines[1] &amp; " &lt;&lt;&gt;&gt; " &amp; seperatedLines[2]  ;
					if xlationResult.cnContains(seperatedLines[2])  then
						b := seperatedLines[2] ; 
						//if b = "40ft" then
						write " - " &amp; "Entity Table: "  &amp; entTableDef.name &amp; " , " &amp; " Translation Result: " &amp; xlationResult  &amp; " , " &amp; " Has Incorrect Term: " &amp; seperatedLines[2]  &amp; " , " &amp; " Correct Term is : " &amp; seperatedLines[1]  ; 
							int := int +1  ;
					 	//endif ; 
						//write nameEntDef &amp; " - " &amp; xlationResult &amp; " has bad word: " &amp; seperatedLines[2] &amp; " should be " &amp; seperatedLines[1] ;
					endif ; 
					
				endforeach  ;  	
			endforeach	;
		endif ; 
	endforeach;
		if int = 0 then
			write "No errors found,naming conventions are good!" ; 
		else
			write "Total Number of Errors = " &amp; int.String ; 

		endif ; 
		
		
		
	epilog
			delete zGetHugeStringArray ;
			delete seperatedLines ; 
			delete strArray ; 
			delete subString ; 

//write ", "  &amp; "Entity Rows Name =  " &amp; entTableRow.name  &amp; " |" &amp; " Translation text  =  " &amp; xlation.text &amp; " |" &amp; " MY LOCALE Language = " &amp; xlation.myLocale.localeDescription;
end  ;</source>
    </JadeMethod>
    <JadeMethod name="getIsoTypesTabNames" id="0ea3c457-3411-4d4a-981c-8ec294016607">
        <source>getIsoTypesTabNames();
/*

Purpose:			
// this will get the ISO type AND Terminal table names and check against recommended naming conventions
Parameters:			

Return Value:		

Date		Who		Reason
27 June 2014	cnwdb2	Initial creation

*/

vars
	entTableDef	: EntTableDef;
	entTableRow : EntTableRow ;
	hugeString : HugeStringArray ; 
	strArray : StringArray ; 
	rowHeading  : String ; 
	seperatedLines : StringArray ; 
	subStrArr : StringArray;
	int : Integer  ; 
	str1,str2 : String ; 
	subStr : String ; 

begin

	hugeString := zGetHugeStringArray() ; 
	create seperatedLines transient ; 
	create subStrArr transient  ; 
	
	foreach entTableDef in app.myRoot.myEntTableDataRoot.allEntTableDefs do
		
		if entTableDef.myEntTableGroup.name = "ISOTypeMaint" then
			foreach entTableRow in entTableDef.allEntTableRows do
				rowHeading := entTableRow.getHeading(null,null,null)  ;
				foreach str1 in hugeString do
				
					if seperatedLines.size &gt;  0 then		 
						seperatedLines.clear() ;
					endif	  ;
					
					str1.getTokensForDelimiter(",",seperatedLines) ; 
				
					if seperatedLines.size &lt;= 1 then
						continue ;
					endif;
						//write seperatedLines[1] &amp; " &lt;&lt;&lt;&gt;&gt;&gt;  " &amp; seperatedLines[2] ; 
						
					if rowHeading.cnContains(seperatedLines[2]) then
								write " - " &amp; "Entity Table: "  &amp; entTableDef.name &amp; " , " &amp; " Translation Result: "   &amp; rowHeading &amp;  " , " &amp; " Has Incorrect Term: " &amp; seperatedLines[2]  &amp; " , " &amp; " Correct Term is : " &amp; seperatedLines[1]  ; 
								int := int +1  ;
					endif ;
						
				endforeach  ;
			endforeach ; 
		elseif entTableDef.myEntTableGroup.name = "ConfigGroup" then
			
			
			foreach entTableRow in entTableDef.allEntTableRows do
				rowHeading :=  entTableRow.getHeading(null, null, null)  ; 
				
				foreach str1 in hugeString do
					
					if seperatedLines.size &gt;  0 then		 
						seperatedLines.clear() ;
					endif	  ;
					
					str1.getTokensForDelimiter(",",seperatedLines) ; 
				
					if seperatedLines.size &lt;= 1 then
						continue ;
					endif;
						//write seperatedLines[1] &amp; " &lt;&lt;&lt;&gt;&gt;&gt;  " &amp; seperatedLines[2] ; 
						///////foreach str2 in strArray do
					subStrArr.clear();
					////////str2.getTokensForDelimiter(" ", subStrArr);
					rowHeading.getTokensForDelimiter(" ", subStrArr);
					foreach subStr in subStrArr do
					//write subStr;
						if subStr.toUpper() = seperatedLines[2].toUpper() then
							write "Entity table: " &amp; entTableDef.name &amp; " - " &amp; rowHeading &amp; " Has Incorrect Term: " &amp; " , "  &amp; seperatedLines[2]  &amp; " , " &amp; " Correct Term is : " &amp; seperatedLines[1];  
							int :=  int + 1 ;
						endif;
					endforeach;
				endforeach  ;
			endforeach; 
		endif ; 
	endforeach ; 		
	write " Total number of Naming errors =  " &amp; int.String  ;
epilog
	delete seperatedLines ;
	delete subStrArr ; 


end;</source>
    </JadeMethod>
    <JadeMethod name="getTermConfigTabNames" id="6954f49e-d6db-4243-9742-a56d6b7e939c">
        <source>getTermConfigTabNames() ;
/*

Purpose:			
// checks the Terminal config file table names and returns results that are considered bad naming practice.
Parameters:			

Return Value:		

Date		Who		Reason
26 June 2014	cnwdb2	Initial creation PAR #33977

*/

vars
	subClasses	: ClassColl;
	subClass	: Class;
	str1,str2 : String ; 
	strArray : StringArray ; 
	includeDutyDoc	: Boolean;
	hugeString : HugeStringArray ; 
	seperatedLines : StringArray ; 
	int : Integer  ; 
	tmpUser		: CM_User;
	subStr : String;
	subStrArr : StringArray;
	item		: SOP_TableMaintItem;
	nameEntDef : String;
	entTableDef	: EntTableDef;
	entTableRow : EntTableRow ;
	rowHeading : String;
	
begin


	create seperatedLines transient  ;
//	create strArray transient ; 
	create subStrArr transient;
	
	//strArray := db2Test()  ;
	hugeString := zGetHugeStringArray() ; 

	foreach entTableDef in app.myRoot.myEntTableDataRoot.allEntTableDefs do
		
		if entTableDef.myEntTableGroup.name = "ConfigGroup" then
			
			
			foreach entTableRow in entTableDef.allEntTableRows do
				rowHeading :=  entTableRow.getHeading(null, null, null)  ; 
				
				foreach str1 in hugeString do
					
					if seperatedLines.size &gt;  0 then		 
						seperatedLines.clear() ;
					endif	  ;
					
					str1.getTokensForDelimiter(",",seperatedLines) ; 
				
					if seperatedLines.size &lt;= 1 then
						continue ;
					endif;
						//write seperatedLines[1] &amp; " &lt;&lt;&lt;&gt;&gt;&gt;  " &amp; seperatedLines[2] ; 
					///////foreach str2 in strArray do
					subStrArr.clear();
					////////str2.getTokensForDelimiter(" ", subStrArr);
					rowHeading.getTokensForDelimiter(" ", subStrArr);
					foreach subStr in subStrArr do
					//write subStr;
						if subStr.toUpper() = seperatedLines[2].toUpper() then
							write "Entity table: " &amp; entTableDef.name &amp; " - " &amp; rowHeading &amp; " Has Incorrect Term: " &amp; " , "  &amp; seperatedLines[2]  &amp; " , " &amp; " Correct Term is : " &amp; seperatedLines[1];  
							int :=  int + 1 ;
						endif;
					endforeach;
					//if str2.cnContains(seperatedLines[2]) then
					//	if not str2.cnContains("Seq") then
								//write " - " &amp; "Entity Table: "  &amp; /*entTableDef.name*/  " , " &amp; " Translation Result: "   &amp; " , " &amp; " Has Incorrect Term: " &amp; seperatedLines[2]  &amp; " , " &amp; " Correct Term is : " &amp; seperatedLines[1]  ; 
					//			int := int +1  ;
					//			write str2 &amp; " Has Incorrect Term: " &amp; seperatedLines[2]  &amp; " , " &amp; " Correct Term is : " &amp; seperatedLines[1]  ;   
					//	endif	;
					//endif ;
					//write str2 ; 
						
					//////endforeach  ;		
				endforeach  ;
			endforeach;
		endif ; 
	endforeach  ;

	write "Total Num Errors in config Table " &amp; int.String ; 
	
	epilog
		delete subStrArr;
		delete strArray  ; 
		delete zGetHugeStringArray ;
		delete seperatedLines ; 
	
	end;</source>
    </JadeMethod>
    <JadeMethod name="jkTest" id="95e95b69-a077-47a6-bbab-1f2f40b2c374">
        <updating/>
        <source>jkTest() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 December 2008	cnwjk3	Initial creation

*/

vars
	aJS : JadeScript;
	aDT : CM_DrawingAttribute;
	idx : Integer;
	theStringArray,theNameArray : StringArray;
	theIntegerArray,theColArray : IntegerArray;
	theRoot : CM_Root;
begin
	theRoot := CM_Root.firstInstance;
	
	create theStringArray transient;
	create theIntegerArray transient;
	create theNameArray transient;
	create theColArray transient;
	// NOTE this code is generated by a jade script - do references on CM_DrawingAttribute

	
	// CCMS 1032
	theStringArray.add(PicTADoorAft); theIntegerArray.add(216); theColArray.add(16711680); theNameArray.add('Wingdings');
	theStringArray.add(PicTADoorFwd); theIntegerArray.add(215); theColArray.add(16711680); theNameArray.add('Wingdings');
	theStringArray.add(PicTATwinLiftPrev); theIntegerArray.add(33); theColArray.add(16711680); theNameArray.add('Wingdings 3');
	theStringArray.add(PicTATwinLiftNext); theIntegerArray.add(34); theColArray.add(16711680); theNameArray.add('Wingdings 3');
	theStringArray.add(PicTATwinLiftArrows); theIntegerArray.add(74); theColArray.add(16711680); theNameArray.add('Wingdings 3');

	foreach idx in 1 to theStringArray.size do
		if theRoot.allDrawingAttributes[theStringArray[idx].trimBlanks] &lt;&gt; null then
			beginTransaction;
			theRoot.allDrawingAttributes[theStringArray[idx].trimBlanks].myRoot := null;
			commitTransaction;
		endif;
	endforeach;	
	
	foreach idx in 1 to theStringArray.size do
		//if theRoot.allDrawingAttributes[theStringArray[idx].trimBlanks] = null then
			beginTransaction;
			create aDT;
			aDT.myRoot := theRoot;
			aDT.fontName := theNameArray[idx];
			aDT.fontCharacter := theIntegerArray[idx];
			aDT.code := theStringArray[idx].trimBlanks;
			aDT.colour := theColArray[idx];
			commitTransaction;
		//endif;
	endforeach;	
	global.beep;
epilog
delete theIntegerArray;
delete theStringArray;
delete theColArray;
delete theNameArray;


end;</source>
    </JadeMethod>
