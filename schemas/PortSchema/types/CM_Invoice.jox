    <JadeMethod name="setProxyForCreate" id="2ba21e01-36f5-4822-ac8b-748530029dd4">
        <updating/>
        <source>setProxyForCreate(	_theBank			: CM_Bank; 
					_theDebtor			: CM_Debtor; 
					_theDebtorAddress	: CM_Address;
					_theVoyage			: CM_Voyage; 
					_theType			: CM_InvoiceDesc; 
					//_isStatusSuspense	: Boolean;	// 26.4.2023 navmk20 TFS 57663
					_invoiceStatus		: Integer;	// 26.4.2023 navmk20 TFS 57663
					_isManual			: Boolean;
					_ti					: CM_TrackedItem;
					_bol				: CM_BOL;
					_booking			: CM_BookingRef;
					_cargoGroup			: CM_CargoGroup;
					_releaseRequest		: CM_BulkRelease;
					_category			: Integer;  // 01/02/2023	navkc1	TFS CR 55305 TASK 55537
					_poNumber 			: String;  // ### BUG 56925 07MAR2023 NAVAB1
					_invoiceProcess		: CM_InvoiceProcess;		// 26.4.2023 navmk20 TFS 57663
					_workOrder			: CM_WorkOrderSet;
					_narr				: String;					//14/08/2023	navkc1	Bug 59803
					_termOfTrade		: CM_InvoiceTermsOfTrade;	//14/08/2023	navkc1	Bug 59803
					_debtorReference	: String;					//14/08/2023	navkc1	Bug 59803
					_currency			: CM_CurrencyType;			//14/08/2023	navkc1	Bug 59803
					_locale				: CM_Locale;				//14/08/2023	navkc1	Bug 59803
					_theDebtAltAddress	: CM_Address				//14/08/2023	navkc1	Bug 59803
					) updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
// 08 June 2020 cnwma1  ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
// 18 Aug 2022	navpw1	TFS: 54564 (54375) - EUP - Inv Config - Debtor Currencies and Countries
// 03 Oct 2022	navpw1	TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges
// 01/02/2023	navkc1	TFS CR 55305 Task 55537 UI - Invoice List UI changes
// 16 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type
// 26 April 2023  navmk20 Bug 57663: EUP - Incorrect Statuses Available when copying an invoice
//14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
// ---------------------------------------------------------------------------

vars
	debtorTerminal : CM_DebtorTerminal; // ### TFS 54564 (54375) 18Aug2022 NAVPW1
	debtorSep : CM_InvTypeDebtorSeparation;
	
begin
	self.raiseExceptionIfNotTransient(method);

	self.bank 		     		:= _theBank;
	self.invoiceType      		:= _theType;
	self.debtor 	      		:= _theDebtor;
	self.myVoyage	 	  		:= _theVoyage;
	self.isManual    	  		:= _isManual;
	self.myBillingAddress 		:= _theDebtorAddress;
	self.narration		  		:= _narr; //14/08/2023	navkc1	Bug 59803
	self.purchaseOrderNumber 	:= _poNumber; //14/08/2023	navkc1	Bug 59803
	self.debtorReference  		:= _debtorReference; //14/08/2023	navkc1	Bug 59803
	self.myAlternativeAddress 	:= _theDebtAltAddress; //14/08/2023	navkc1	Bug 59803
	
	//14/08/2023	navkc1	Bug 59803
	if _termOfTrade &lt;&gt; null then
		self.termsOfTrade := _termOfTrade.description;
		self.termsOfTradeCode := _termOfTrade.code;
	endif;

	if _workOrder &lt;&gt; null then	//navtnr20 23-05-2023 BUG 58089
		self.allWorkOrders.clear();
		_workOrder.copy(self.allWorkOrders);	//navtnr20 23-05-2023 BUG 58089
	endif;

	if _theDebtor &lt;&gt; null then // 09/02/2023	navkc1	TFS CR 55305 TASK 55537
		// ### TFS 54564 (54375) 18Aug2022 NAVPW1
		debtorTerminal := _theDebtor.allDebtorTerminals[app.myPassport.myTerminal];
		if self.invoiceType &lt;&gt; null then //16/03/2023  navmv20 TFS 56128 Task 56129
			debtorSep := self.invoiceType.getDebtorSeparation(self.debtor); // ### BUG 56925 07MAR2023 NAVAB1
		endif; //16/03/2023  navmv20 TFS 56128 Task 56129
	endif;
	
	self.myCurrencyType := _currency;	//14/08/2023	navkc1	Bug 59803
	self.myLocale 		:= _locale;		//14/08/2023	navkc1	Bug 59803
	
	if debtorTerminal &lt;&gt; null then
		//14/08/2023	navkc1	Bug 59803
		if self.myCurrencyType = null then
			self.myCurrencyType := debtorTerminal.myCurrencyType;
		endif;
		//14/08/2023	navkc1	Bug 59803
		if self.myLocale = null then
			self.myLocale		:= debtorTerminal.myLocale;
		endif;
	endif;
	
	// ### TFS 54564 (54375) 18Aug2022 NAVPW1
	
	//03/06/2020 cnwma1 Tfs #49400
	if _theVoyage &lt;&gt; null then
		self.voyageGroupCode := _theVoyage.voyageGroupCode;
	endif;
	
	if self.invoiceType &lt;&gt; null then
		//16/03/2023  navmv20 TFS 56128 Task 56129 - START
		if self.myTerminal.getConfig(InvShowAllSeparation).Boolean then
			self.myTrackedItem := _ti;
			self.myBOL := _bol;
			self.myBookingRef := _booking;
			self.myCargoGroup := _cargoGroup;
			self.myReleaseRequest := _releaseRequest;
			self.purchaseOrderNumber := _poNumber;
		else 
		//16/03/2023  navmv20 TFS 56128 Task 56129 - END
			//if self.invoiceType &lt;&gt; null and self.invoiceType.isCargoItemSpecific() then
			if self.invoiceType.isCargoSpecificSeparation(debtorSep) then
			// ### BUG 56925 07MAR2023 NAVAB1 if self.invoiceType &lt;&gt; null and self.invoiceType.isCargoItemSpecificDebtor(_theDebtor) then // ### TFS 54565 (54384) 22Sep2022 NAVPW1
				self.myTrackedItem := _ti;
			endif;
			
			// ### TFS 54565 (54384) 03Oct2022 NAVPW1
			if self.invoiceType.isBOLSpecificSeparation(debtorSep) then
			// ### BUG 56925 07MAR2023 NAVAB1		if self.invoiceType &lt;&gt; null and self.invoiceType.isBOLSpecificDebtor(_theDebtor) then
				self.myBOL := _bol;
			endif;
			
			if self.invoiceType.isBookingSpecificSeparation(debtorSep) then
			// ### BUG 56925 07MAR2023 NAVAB1		if self.invoiceType &lt;&gt; null and self.invoiceType.isBookingSpecificDebtor(_theDebtor) then
				self.myBookingRef := _booking;
			endif;
			
			if self.invoiceType.isCargoGroupSpecificSeparation(debtorSep) then
			// ### BUG 56925 07MAR2023 NAVAB1		if self.invoiceType &lt;&gt; null and self.invoiceType.isCargoGroupSpecificDebtor(_theDebtor) then
				self.myCargoGroup := _cargoGroup;
			endif;
			
			if self.invoiceType.isReleaseSpecificSeparation(debtorSep) then
			// ### BUG 56925 07MAR2023 NAVAB1		if self.invoiceType &lt;&gt; null and self.invoiceType.isReleaseSpecificDebtor(_theDebtor) then
				self.myReleaseRequest := _releaseRequest;
			endif;

			// ### BUG 56925 07MAR2023 NAVAB1	
			if self.invoiceType.isPONumberSpecificSeparation(debtorSep) then
				self.purchaseOrderNumber := _poNumber;
			endif;
			
			// ### TFS 54565 (54384) 03Oct2022 NAVPW1
		endif; //16/03/2023  navmv20 TFS 56128 Task 56129
	endif;
	//Start 26.4.2023 navmk20 TFS 57663
	/*if _isStatusSuspense then
		self.setStatus( INVOICE_SUSPENSE );	//13 Jun 2018	NDL	TFS 39197
	else
		self.setStatus( INVOICE_PENDING );	//13 Jun 2018	NDL	TFS 39197
	endif;*/
	self.setStatus(_invoiceStatus); 
	self.setMyInvoiceProcess(_invoiceProcess);
	//End 26.4.2023 navmk20 TFS 57663
	self.setCategory(_category); // 01/02/2023	navkc1	TFS CR 55305 TASK 55537
	
end;</source>
        <Parameter name="_theBank" type="CM_Bank"/>
        <Parameter name="_theDebtor" type="CM_Debtor"/>
        <Parameter name="_theDebtorAddress" type="CM_Address"/>
        <Parameter name="_theVoyage" type="CM_Voyage"/>
        <Parameter name="_theType" type="CM_InvoiceDesc"/>
        <Parameter name="_invoiceStatus" type="Integer"/>
        <Parameter name="_isManual" type="Boolean"/>
