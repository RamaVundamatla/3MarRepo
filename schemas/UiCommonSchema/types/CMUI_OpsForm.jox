    <JadeMethod name="setGridAreaContextMenu" id="c47b7597-e4ad-403d-a518-b1d2c8de4d53">
        <updating/>
        <source>setGridAreaContextMenu(_gridPoint : CMUI_GridPoint input; _x, _y : Integer)updating;
//--------------------------------------------------------------
//Created: 19 March 2003 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	---------------------------------------------
// 25/01/2013	cnwdap1		PAR #31018 CCMS POL 2223 Added menu item to disconnect reefers received on power
begin
	self.mnuCargo.visible := false;
	self.mnuEnquiry.visible := true;
	self.mnuUnplan.visible := false;
	self.mnuLocationEnquiry.visible := true;

	self.mnuCargoTaskAdd.visible := false;	//07 Oct 2015	NDL	Par 37011
	self.mnuCargoTaskComplete.visible := false;	//07 Oct 2015	NDL	Par 37011
	self.mnuCargoTaskRemarks.visible := false;	//07 Oct 2015	NDL	Par 37011
	
	self.mnuTaskAdd.visible := false;
	self.mnuTaskComplete.visible := false;
	self.mnuStops.visible := false;
	
	self.mnuCargoSep2.visible := false;
	self.mnuAttach.visible := false;
	self.mnuConnect.visible := false;
	self.mnuLCL.visible := false;
	self.mnuCargoRemarks.visible := false;
	self.mnuCargoDiscon.visible := false;		// PAR #31018
	self.mnuCargoDiscon.userObject := null;		// PAR #31018
	self.mnuCargoPositionSwap.visible := false;	//11Aug 2009	NDL CCMS 1094
	
	self.mnuWagonConfirm.visible := false;
	self.mnuWagonCC.visible := false;
	self.mnuInTransit.visible := false;	//24 July 2009	NDL
	self.mnuInTransitNO.visible := false;	//24 July 2009	NDL
	self.mnuReturnWagon.visible := false;	//06 Nov 2009	NDL Par 21519
	self.mnuWagonMaster.visible := false;	//07 Feb 2014	NDL	Par 33439
	
	self.mnuConfirmWagonOut.visible := false;
	self.mnuUnconfirmWagonOut.visible := false;
	self.mnuWagonEdit.visible := false;
	self.mnuWagonSeals.visible := false; //10 Mar 2015	NDL	Par 35828
	self.mnuWagonDelete.visible := false;
	self.mnuPlanTI.visible := false;
	self.mnuWagonTwistlock.visible := false;
	self.mnuTwistNA.visible := true;
	self.mnuTwistAvail.visible := true;
	self.mnuTwistLocked.visible := false; // 12 Aug 2009 SFW1067
	self.mnuTwistUp.visible := true;
	
	
	self.mnuWagonUpdate.visible := false;	//
	
	self.doBuildMnuZoom();

	// options only available when transport graphic visible - SFW1067 12/05/2009
	self.mnuToggleToolbar.visible := self.shtTransportView.visible;
	self.mnuToggleLegend.visible := self.shtTransportView.visible;
	self.mnuToggleExtraInfo.visible := self.shtTransportView.visible;
	self.mnuMultiMove.visible := self.shtTransportView.visible;//23 Aug 2011	NDL	Par 28035

	self.mnuMove.visible := false;		//
