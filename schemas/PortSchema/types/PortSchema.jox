    <JadeMethod name="causeEventForSystemAlertType" id="257f5411-c854-45e2-beab-36fddb38eb30">
        <source>causeEventForSystemAlertType(_alert : CM_SystemAlert; _terminal : CM_Terminal);
/* ---------------------------------------------------------------------------
Created:     06 May 2010 by cnwrs2

Purpose:    Adds the code to causeEvent and possibly send an email when
			an alert of with an alertType is created
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	alertType : CM_SystemAlertType;
	addresses, subject, message, fromAddress : String;
	notifyAddresses : CM_EmailEntityByTypeNameDict;
	tmpRoot	: CM_Root;
begin
	if _alert &lt;&gt; null then
		alertType := _alert.mySystemAlertType;
	endif;
	
	if not process.isInTransactionState then
		app.raiseCMException2(ERR_TRANS_STATE, method.name, self.class.String, null, null);
	endif;
	
	if _terminal = null then
		tmpRoot := app.myRoot;
		if tmpRoot &lt;&gt; null then
			tmpRoot.causeEvent(EventSystemAlertAdd, false, _alert);
		endif;
	elseif alertType &lt;&gt; null then // If the user is registered for this alert type then show the alert alarm picture...
		_terminal.causeEvent(_terminal.getTerminalEvent(EventTerminalAlertAdd), false, _alert);		//+cnwml2 PAR24948
		_terminal.causeEvent(alertType.type, false, _alert); //Listening for this in CM_Passport::userNotification
	endif;
	
	if alertType = null then
		return; //Cannot send email because collection of email addresses is on CM_AlertType
	endif;
	
	notifyAddresses := alertType.allNotifyEmailAddresses;
	if notifyAddresses.size = 0 then
		return;
	endif;
	
	addresses := notifyAddresses.getAddresses;
	fromAddress := app.myRoot.getConfig(AutoSendersEmailAddress).String;
	subject := alertType.description;
	message := _alert.details;
	
	on CM_Exception do self.handleEmailAlertException(exception);
	
	app.myUtilityCA.utlCreateEmailSendRequest(false, 
									alertType.description, 
									addresses, 
									fromAddress, 
									null, 
									null, 
									subject, 
									message, 
									null, 
									null, 
									null, 
									null, 
									null, 
									null, 
									app.myPassport);
										
	/*else - cnwmd1 CCMS 1871 - Should always be in txn state
		app.myTrxCA.trxCreateEmailSendRequest(alertType.description,
										addresses,
										fromAddress,
										null, 
										null,
										subject,
										message,
										null,
										null,
										null,
										null,
										EmailSource_System,
										null,
										app.myPassport);
	endif;
	*/
epilog

end;</source>
        <Parameter name="_alert" type="CM_SystemAlert"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
