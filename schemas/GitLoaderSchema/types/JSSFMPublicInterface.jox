// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myServiceObject.sendMsgWithParams(method.name, pDirectoryName, pNodeOptions).Boolean;
end;</source>
