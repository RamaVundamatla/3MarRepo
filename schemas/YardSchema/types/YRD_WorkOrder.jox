    <JadeMethod name="stub_SaveSelectedTrackedItems" id="0107e93b-0077-4292-b38f-e1fafc4bf0e0">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CMUI_TrackedItems::saveSelectedTrackedItems"/>
        </interfaceImplements>
        <source>stub_SaveSelectedTrackedItems(_allTIs : CM_TIArray) : Boolean;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements for the IF_CMUI_TrackedItems interface 
	*/
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Apr 2022	navcs2	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
7 Mar 2023  navhl20	ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
*/

vars
	pxyTask     : CM_WorkOrderDtl;
begin
	pxyTask		:= self.myPxyTask;														//12.01.2023 navma1 #56141 Task#56147
	
	if self.myPxyTask &lt;&gt; null then
		
		if self.isPackItems = false then												//12.01.2023 navma1 #56141 Task#56147
			//self.myPxyWorkOrder.CM_WorkOrderTI.allTIs.clear();
			//_allTIs.copyNoDups( self.myPxyWorkOrder.CM_WorkOrderTI.allTIs);			//12.01.2023 navma1 #56141 Task#56147
			self.myPxyTask.CM_WorkOrderTIDtl.allSelectedTIs.clear();					//08.02.2023 navma1 #56457 Task#56458
			_allTIs.copyNoDups( self.myPxyTask.CM_WorkOrderTIDtl.allSelectedTIs);		//08.02.2023 navma1 #56457 Task#56458
		elseif pxyTask &lt;&gt; null and   pxyTask.isKindOf(CM_WodPack) then					//12.01.2023 navma1 #56141 Task#56147
			pxyTask.CM_WodPack.allPackingTIs.clear();
			_allTIs.copyNoDups(self.myPxyTask.CM_WodPack.allPackingTIs);
		endif;
	endif;
	
	self.loadTabCargoTis();
	//self.buildTxtEntitiesList();														//08.02.2023 navma1 #56457 Task#56458
	self.buildTblChildItems();
	
	if myPxyTask.isKindOf(CM_WodToDo) then
		//self.buildCmbToDo(myPxyTask.CM_WodToDo);		//7.3.2023 navhl20	#56614[56615]
		self.buildWOToDoList(myPxyTask.CM_WodToDo);		//7.3.2023 navhl20	#56614[56615]
	endif;
	
	return true;
	
epilog

end;</source>
