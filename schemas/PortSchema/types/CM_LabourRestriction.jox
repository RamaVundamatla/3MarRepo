    <JadeMethod name="getAuditTALocationDetails" id="ab817803-e05b-4c82-ab52-ac7df4778eea">
        <source>getAuditTALocationDetails():String;
// ---------------------------------------------------------------------------
// Created:     02 March 2011 by cnwcs5 CCMS CPL 2027/PAR 27126
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str,text		:String;
	hours, minutes	:String;
begin
	// code, duration, reason, organisation, expiry, notify
	text := self.id;
	
	if self.durationHours &lt;&gt; null then
		hours 	:= self.durationHours.hour.asStringJMT;
		minutes	:= self.durationHours.minute.asStringJMT;
		
		if hours &lt;&gt; null and minutes &lt;&gt; null then
			text 	:= text &amp; ', ' &amp; hours &amp; ' hrs ' &amp; minutes &amp; ' mins';
		elseif hours &lt;&gt; null then
			text 	:= text &amp; ', ' &amp; hours &amp; ' hrs';
		elseif minutes &lt;&gt; null then
			text 	:= text &amp; ', ' &amp; minutes &amp; ' mins';
		endif;
		
	elseif self.durationDays &lt;&gt; null then
		text := text &amp; ', ' &amp; self.durationDays.asStringJMT &amp; ' days';
	endif;
	
	if self.myReason &lt;&gt; null then
		text := text &amp; ', ' &amp; self.myReason.description;
	endif;
	
	if self.expiryDateTime &lt;&gt; null then
		text := text &amp; ', ' &amp; self.expiryDateTime.asStringJMT;
	endif;
	
	if self.hasMembers (self.allNotifyEmailEntities) then
		text := text &amp; ', ' &amp; self.getNotifyEmailEntities;
	endif;
	
	return text;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="e072f401-70f2-4401-87fc-deb0407b1cb9">
        <source>getAuditText(): String;
// --------------------------------------------------------------------------------
// Created:		05 August 2008 by cnwdad1
//
// Purpose:		Standard method to return an audit string of the receiver properties.
//
// Parameters:	None
//
// Returns:		The audit string to record.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 26 Aug 2009	cnwkpd1		PAR #20528 - Handle invalid non-inversed references
// 07/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
// --------------------------------------------------------------------------------

vars
	auditString		: String;
	controllerObj	: CM_LocationsController;
	emailObj		: CM_EmailEntity;
	multiValue		: String;
	invalidOrg,
	invalidReason	: Boolean;
	organisation	: CM_Organisation;
	reason			: CM_LabourRestrictionReasonCode;
	
begin
	auditString	:=	inheritMethod();
	
	auditString	:=	auditString &amp; "Duration Days" &amp; AuditStringSeparator &amp; self.durationDays.String.length().String &amp; AuditStringSeparator &amp; self.durationDays.String &amp; AuditStringSeparator;
	auditString	:=	auditString &amp; "Duration Hours" &amp; AuditStringSeparator &amp; self.durationHours.String.length().String &amp; AuditStringSeparator &amp; self.durationHours.String &amp; AuditStringSeparator;
	auditString	:=	auditString &amp; "Expiry Date/Time" &amp; AuditStringSeparator &amp; self.expiryDateTime.String.length().String &amp; AuditStringSeparator &amp; self.expiryDateTime.String &amp; AuditStringSeparator;
	auditString	:=	auditString &amp; "Id" &amp; AuditStringSeparator &amp; self.id.length().String &amp; AuditStringSeparator &amp; self.id &amp; AuditStringSeparator;
	
	organisation := self.myOrganisation;
	if organisation &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, organisation, invalidOrg);		// PAR #20528
		
		auditString	:=	auditString &amp; "Organisation" &amp; AuditStringSeparator &amp; organisation.name.length().String &amp; AuditStringSeparator &amp; organisation.name &amp; AuditStringSeparator;
	endif;
	
	if invalidOrg or organisation = null then
		auditString	:=	auditString &amp; "Organisation" &amp; AuditStringSeparator &amp; 0.String &amp; AuditStringSeparator &amp; "" &amp; AuditStringSeparator;
	endif;
	
	reason := self.myReason;
	if reason &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, reason, invalidReason);		// PAR #20528
		
		auditString	:=	auditString &amp; "Reason" &amp; AuditStringSeparator &amp; reason.code.length().String &amp; AuditStringSeparator &amp; reason.code &amp; AuditStringSeparator;
	endif;

	if invalidReason or reason = null then
		auditString	:=	auditString &amp; "Reason" &amp; AuditStringSeparator &amp; 0.String &amp; AuditStringSeparator &amp; "" &amp; AuditStringSeparator;
	endif;
	
	if self.myTerminalArea = null then
		auditString	:=	auditString &amp; "Terminal Area" &amp; AuditStringSeparator &amp; 0.String &amp; AuditStringSeparator &amp; "" &amp; AuditStringSeparator;
	else
		auditString	:=	auditString &amp; "Terminal Area" &amp; AuditStringSeparator &amp; self.myTerminalArea.id.length().String &amp; AuditStringSeparator &amp; self.myTerminalArea.id &amp; AuditStringSeparator;
	endif;
	
	multiValue	:=	null;
	
	foreach controllerObj in self.allLocationControllers do
		if multiValue = null then
			multiValue	:=	controllerObj.ident;
		else
			multiValue	:=	multiValue &amp; ", " &amp; controllerObj.ident;
		endif;
	endforeach;
	
	auditString	:=	auditString &amp; "Location(s)" &amp; AuditStringSeparator &amp; multiValue.length().String &amp; AuditStringSeparator &amp; multiValue &amp; AuditStringSeparator;
	
	multiValue	:=	null;
	
	foreach emailObj in self.allNotifyEmailEntities do
		if multiValue = null then
			multiValue	:=	emailObj.name;
		else
			multiValue	:=	multiValue &amp; ", " &amp; emailObj.name;
		endif;
	endforeach;
	
	auditString	:=	auditString &amp; "Notify Email(s)" &amp; AuditStringSeparator &amp; multiValue.length().String &amp; AuditStringSeparator &amp; multiValue &amp; AuditStringSeparator;
	
	return auditString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditTextDescription" id="f99a82d7-d6f6-48c2-8ee9-fad6c9a6d873">
        <source>getAuditTextDescription(): String;
// ---------------------------------------------------------------------------
// Created:     03 June 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 16/08/2011	cnwmh5	#27976 - Change to handle myReason being null
vars
	locnFrom, 
	locnTo,
	str	: String;
	rtnStr	: String;
begin
	
	// PAR 17051 - return the locations as part of audit text
	self.getRestrictionBounds(locnFrom, locnTo, self.allLocationControllers);
	str := self.id &amp; ' (' &amp; locnFrom &amp; '-' &amp; locnTo &amp; ')';
	
//	return self.auditIdDisplay() &amp;  AuditStringSeparator &amp; str.length.String &amp; AuditStringSeparator &amp; str &amp; AuditStringSeparator;  

	
	// CCMS JMT 2027 - need to record more detail for changes on terminal area
	rtnStr := self.auditIdDisplay() &amp; '-locations' &amp;  AuditStringSeparator &amp; str.length.String &amp; AuditStringSeparator &amp; str &amp; AuditStringSeparator;  
	
	str := null;					// 16/08/20111 cnwmh5 #27976
	if self.myReason &lt;&gt; null then
		str := self.myReason.description;
	endif;
	rtnStr := rtnStr &amp;
			self.auditIdDisplay() &amp; '-reason' &amp;  AuditStringSeparator &amp; str.length.String &amp; AuditStringSeparator &amp; str &amp; AuditStringSeparator;  
			
	str := self.comment;
	rtnStr := rtnStr &amp;
			self.auditIdDisplay() &amp; '-comment' &amp;  AuditStringSeparator &amp; str.length.String &amp; AuditStringSeparator &amp; str &amp; AuditStringSeparator;  

	return rtnStr;
	
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringFull" id="d68143c1-e24b-47af-9567-b108410ccea2">
        <source>getDisplayStringFull(): String;
// ---------------------------------------------------------------------------
// Created:     09 June 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	str : String;
begin
	if self.myReason &lt;&gt; null then 
		str := ' - ' &amp; self.myReason.description;
	endif;

	
	return self.id &amp; str &amp; self.getExpiryDateTimeString;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExpiryDateTimeString" id="8ff57821-fc8d-4293-909a-50efa5be09d0">
        <source>getExpiryDateTimeString() : String;
// ---------------------------------------------------------------------------
// Created:     09 June 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.expiryDateTime = null then 
		return ' - Indefinite';
	else
		return ' - until ' &amp; self.expiryDateTime.cnEcShortFullFormat;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="c4805b4d-4dfc-4eea-8239-ddb071803d7c">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	block : CM_DataContainerBlock;

begin
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Labour_Restriction), DC_Label, 1,self);
	block.addNewItem(self.id, DC_Data, 1, self);

	inheritMethod(_dataContainer);

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getNotifyEmailEntities" id="1dd36513-761d-4360-b477-f4f430578e89">
        <source>getNotifyEmailEntities():String;
// ---------------------------------------------------------------------------
// Created:     02 March 2011 by cnwcs5 CCMS 2027/par 27126
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	email	:CM_EmailEntity;
	str		:String;
begin
	foreach email in self.allNotifyEmailEntities do
		if str = null then
			str	:=	email.name;
		else
			str	:=	str &amp; ", " &amp; email.name;
		endif;
	endforeach;
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getQueueEntries" id="24753b45-3943-4fb3-ac07-90c14d8924a7">
        <source>getQueueEntries( queueEntrySet : CM_RTQueueEntrySet input );
// ---------------------------------------------------------------------------
// Created:		27 August 2007 By cnwvu1
// ---------------------------------------------------------------------------
vars
	lc					: CM_LocationsController;
	ti					: CM_TrackedItem;
	futureMove			: CM_FutureMove;
	
	queueArray : CM_RTQueueArray;
	ta : CM_TerminalArea;
	iter : Iterator;
	iter2 : Iterator;
	iter3 : Iterator;
	task : CM_RTQueueTask;
	entry : CM_RTQueueEntry;
	queue : CM_RadioTelemetryQueue;
	sourceLocation : CM_LocationsController;
	targetLocation : CM_LocationsController;

begin

	foreach lc in self.allLocationControllers discreteLock do
		// Find queue entries going to locations.
		lc.getToQueueEntriesForLocation( queueEntrySet );
	
		// Find queue entries leaving locations.
		foreach ti in lc.allTrackedItems do
			foreach futureMove in ti.allQueuedFutureMoves do
				futureMove.CM_FutureMoveQueued.getQueueEntries( queueEntrySet );
			endforeach;
		endforeach;
	endforeach;
	
	//28 Apr 2015	NDL	Par 36014 - find the director tasks that are effected too
	// TA.allRTQueueTAsks is only set for the source, so target location restrictions would not be found..
	// have to resort to using queues
	create queueArray transient;
	if self.myTerminalArea &lt;&gt; null then
		self.myTerminalArea.myTerminal.getAllQueues( queueArray );
	endif;
	if not queueArray.isEmpty then
		iter := queueArray.createIterator;
		while iter.next( queue ) do
			iter2 := queue.allEntries.createIterator;
			while iter2.next( entry ) do
				iter3 := entry.allTasks.createIterator;
				while iter3.next( task ) do
					if task.taskType &lt;&gt; TASK_DIRECTOR then
						continue;
					endif;
					if task.status = TASK_COMPLETE then
						continue;
					endif;
					sourceLocation := task.sourceLocation;
					if sourceLocation &lt;&gt; null then
						if self.allLocationControllers.includes(sourceLocation) then
							queueEntrySet.addNoDuplicates(entry,false);
							continue;
						endif;
					endif;
					targetLocation := task.targetLocation;
					if targetLocation &lt;&gt; null then
						if self.allLocationControllers.includes(targetLocation) then
							queueEntrySet.addNoDuplicates(entry,false);
							continue;
						endif;
					endif;
				endwhile;
				delete iter3;
			endwhile;
			delete iter2;
		endwhile;
	endif;

epilog

	delete queueArray;
	delete iter;
	delete iter2;
	delete iter3;
	
end;
</source>
        <Parameter name="queueEntrySet" type="CM_RTQueueEntrySet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTerminalForAlert" id="f092a9dd-61c7-40c1-a727-fa585c1cf0ff">
