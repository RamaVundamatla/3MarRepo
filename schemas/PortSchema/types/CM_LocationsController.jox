    <JadeMethod name="getQVWforDate" id="4e2c7f9d-981e-42e7-9455-4b3588dab0fe">
        <source>getQVWforDate(_requiredDate 	: Date; 
			  _startFromDate	: Date;	
			  _closingLevel 	: Boolean; 
			  _product 			: CM_Product; 
			  _quantity 		: Integer output; 
			  _volume 			: Decimal output; 
			  _weight 			: Decimal output);
/*-------------------------------------------------------------------------------------------------------------
	Created by cnwdvb1 on 26 October 2006 

	Purpose		Return Quantity, Volume and Weight for the given date and product at this location
				Can select opening or closing levels for the day. Future dates will include projected 
				levels based on auto task adjustments and planned cargo movements
				
	Parameters	_requiredDate - The date for which the stock leves are required.
				_startFromDate - seed date for future projections if calling for a series of dates, then use
				this date to avoid repetitive iteration. If supplied, then returned QVW levels are deltas.
				If null, then ignored, and returned QVW levels are absolute values.
				(note this assumes schedules have repeat cycle &gt;= 1 day. Change to timestamp for greater frequency).
				
				_closingLevel - true: Figures based on closing levels for the day, otherwise opening levels for the day.
				
				_product: selected product, or null for all products at the location
				
				_quantity, _volume, _weight: returned stock levels (delta or absolute - see _startFromDate above)
-------------------------------------------------------------------------------------------------------------*/ 
vars
	sohLocation			: CM_SOHLocation;
	today				: Date;
	allSohLocations		: CM_SOHLocationsByProduct;
	locControllerObj	: CM_LocationsController;
	tmpQ				: Integer;
	tmpW				: Decimal[14,4];
	tmpV				: Decimal[16,4];
	showDiscrepancy		: String;
	
begin
	// R Barr 9/11/2006
	// The signature that should hopefully support the needs of the form, but code is untested.
		
	if not self.myTerminalArea.isStockControlled then
		// Raise exception saying that the location is not stock controlled.
		return;
	endif;
	
	create allSohLocations transient;
	
	beginLoad;
	
	// get stock on hand location(s) based on product selected
	if _product &lt;&gt; null then
		sohLocation := self.allProductLocations[_product];
		
		if sohLocation &lt;&gt; null then
			allSohLocations.add(sohLocation);
		endif;
	else
		self.allProductLocations.copy(allSohLocations);
	endif;
	
	today	:=	app.actualTimeServer().date();
	
	// future date? 
	if _requiredDate &gt;= today then
		// This isn't called from evaluation form because it is never null.
		if _startFromDate = null then
			// get current values
			foreach sohLocation in allSohLocations do
				sohLocation.getSOHLevelsForDate(today, _closingLevel, tmpQ, tmpV, tmpW);
				_quantity 	:= _quantity + tmpQ;
				_volume 	:= _volume + tmpV;
				_weight		:= _weight + tmpW;
			endforeach;
		endif;
		
		// Accumulate projected levels based on auto task adjustments
		self.getQVWforFutureAutoTaskAdjusts(_requiredDate, _startFromDate, _product, _quantity, _volume, _weight);
		
		// ... and planned cargo movements 
		self.getQVWforFutureCargoMoves(_requiredDate, _startFromDate, _product, _quantity, _volume, _weight);
	endif;
	
	if _requiredDate &lt;= today then
		// get levels for date
		foreach sohLocation in allSohLocations do
			sohLocation.getSOHLevelsForDate(_requiredDate, _closingLevel, tmpQ, tmpV, tmpW);
			
			if app.isSpecial() and _requiredDate = today then
				locControllerObj	:=	sohLocation.myLocationsController;
				
				if locControllerObj.totalQuantity &lt;&gt; tmpQ then
					showDiscrepancy	:=	"Actual=" &amp; locControllerObj.totalQuantity.cnEcNumberFormat() &amp; ", Derived=" &amp; tmpQ.cnEcNumberFormat();
					app.raiseUnexpectedProgramError(class.name, method.name, "Bulk Location Quantity does not match derived value - " &amp; showDiscrepancy);
				endif;
				if locControllerObj.totalVolume &lt;&gt; tmpV then
					showDiscrepancy	:=	"Actual=" &amp; locControllerObj.totalVolume.cnEcNumberFormat() &amp; ", Derived=" &amp; tmpV.cnEcNumberFormat();
					app.raiseUnexpectedProgramError(class.name, method.name, "Bulk Location Volume does not match derived value - " &amp; showDiscrepancy);
				endif;
				if locControllerObj.totalWeight &lt;&gt; tmpW then
					showDiscrepancy	:=	"Actual=" &amp; locControllerObj.totalWeight.cnEcNumberFormat() &amp; ", Derived=" &amp; tmpW.cnEcNumberFormat();
					app.raiseUnexpectedProgramError(class.name, method.name, "Bulk Location Weight does not match derived value - " &amp; showDiscrepancy);
				endif;
			endif;
			
//			_quantity 	:= _quantity + tmpQ;
//			_volume 	:= _volume + tmpV;
//			_weight		:= _weight + tmpW;
			_quantity 	:= tmpQ;
			_volume 	:= tmpV;
			_weight		:= tmpW;
		endforeach;
	endif;
epilog
	endLoad;
	
	delete allSohLocations;
end;</source>
        <Parameter name="_requiredDate" type="Date"/>
        <Parameter name="_startFromDate" type="Date"/>
        <Parameter name="_closingLevel" type="Boolean"/>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_quantity" type="Integer" usage="output"/>
        <Parameter name="_volume" type="Decimal" usage="output"/>
        <Parameter name="_weight" type="Decimal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getQVWforFutureAutoTaskAdjusts" id="78736165-c196-4c28-9379-64f23838fb90">
        <source>getQVWforFutureAutoTaskAdjusts(	_requiredDate	: Date;
								_startFromDate	: Date;
								_product : CM_Product;
								_deltaQuantity	: Integer io;
								_deltaVolume	: Decimal io;
								_deltaWeight	: Decimal io);
								// NEED TO ADD PRODUCT IN HERE
/*	R Barr 9/11/2006 Comalco

	Get future stock level deltas for the given date, by projecting ahead based on the configured 
 	stock adjustment schedule (CM_AutoSchedule).

	_requiredDate (mandatory) - date for which SOH levels are required
	
	_startFromDate - seed date if calling for a series of dates. If supplied, then levels returned are
					 deltas, otherwise absolute.

	_quantity, _volume, _weight: returned stock levels (delta or absolute - see _startFromDate above)
*/
vars
	tmpStockAdjust		: CM_AutoTaskStockAdjustment;
	realSchedule		: CM_AutoSchedule;	// persistent
	nextSchedule		: CM_AutoSchedule;	// transient clone used for future projection
	startFromDateTmp	: TimeStamp;
	requiredDateTmp		: TimeStamp;
	
begin

	foreach tmpStockAdjust in self.allAutoTaskStockAdjustments do
		if _product &lt;&gt; null and tmpStockAdjust.myProduct &lt;&gt; _product then
			continue;
		endif;
	
		realSchedule	:=	tmpStockAdjust.getAutoSchedule();
		
		if realSchedule = null then
			continue;
		endif;
		
		requiredDateTmp		:=	_requiredDate.TimeStamp;
		requiredDateTmp		:=	requiredDateTmp.cnEcAddDays(1);
		startFromDateTmp	:=	_startFromDate.TimeStamp;
		
		// clone the schedule
		delete nextSchedule;
		nextSchedule	:=	realSchedule.cloneSelf(true);
		
		// use the cloned schedule to calculate future levels up to the requested date
		while true do
			// determine next scheduled date
			nextSchedule.setNextRunTs(CM_AutoSchedule.Make_Process, true, startFromDateTmp);
	
			
	
			// We have found the next run date after the passed in timestamp. If this
			// value is less than the passed in data plus one day then we want to include
			// these results.
			if nextSchedule.runTs = null 				// end of schedule (endScheduleTs)
			or nextSchedule.runTs &gt; requiredDateTmp	// reached required date
			then
				break;
			endif;
			
			// accumulate the QVW amounts
			_deltaQuantity 	:= _deltaQuantity + tmpStockAdjust.quantity;
			_deltaVolume	:= _deltaVolume	  + tmpStockAdjust.volume;
			_deltaWeight	:= _deltaWeight	  + tmpStockAdjust.weight;
			
			startFromDateTmp	:=	nextSchedule.runTs;
		endwhile;
	endforeach;
	
epilog
	delete nextSchedule;
end;</source>
        <Parameter name="_requiredDate" type="Date"/>
        <Parameter name="_startFromDate" type="Date"/>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_deltaQuantity" type="Integer" usage="io"/>
        <Parameter name="_deltaVolume" type="Decimal" usage="io"/>
        <Parameter name="_deltaWeight" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getQVWforFutureCargoMoves" id="46f32de3-cda5-4216-9b39-c8cd128bb2ad">
        <source>getQVWforFutureCargoMoves(_requiredDate		: Date;
						  _startFromDate	: Date;	
						  _product : CM_Product;
						  _deltaQuantity	: Integer io;
						  _deltaVolume		: Decimal io;
						  _deltaWeight		: Decimal io);
/*	R Barr 9/11/2006 Comalco

	Get future stock level deltas for the given date, by examining future planned cargo movements

	_requiredDate (mandatory) - date for which SOH levels are required

	_startFromDate - seed date if calling for a series of dates. If supplied, then levels returned are
					 deltas, otherwise absolute.

	_quantity, _volume, _weight: returned stock levels (delta or absolute - see _startFromDate above)
*/
vars
	futureMove		: CM_FutureMove;
	plannedMove		: CM_FutureMovePlanned;
	pseudoMoveTI	: CM_TrackedItem;
	
begin
	foreach futureMove in self.allPlannedFutureMoves where futureMove.class = CM_FutureMovePlanned do
		if futureMove.estDateTime = null then
			// raise exception???? or continue
			continue;
		endif;
		
		// reached (optional) start date?
		if _startFromDate &lt;&gt; null and futureMove.estDateTime.date &lt; _startFromDate then
			continue;
		endif;
	
		// reached required date?
		if futureMove.estDateTime.date &gt; _requiredDate then
			// cannot break as allPlannedFutureMoves is not ordered
			continue;
		endif;
	
		plannedMove  := futureMove.CM_FutureMovePlanned;
		pseudoMoveTI := plannedMove.myTrackedItem;
		
		if _product &lt;&gt; null and pseudoMoveTI.myProduct &lt;&gt; _product then
			continue;
		endif;

		_deltaQuantity 	:= _deltaQuantity	+ pseudoMoveTI.quantity;
		_deltaVolume	:= _deltaVolume		+ pseudoMoveTI.getMyTotalVolume;
		//_deltaWeight	:= _deltaWeight		+ pseudoMoveTI.weight;				//-cnwml2 MSL CCMS 1017
		_deltaWeight 	:= _deltaWeight		+ pseudoMoveTI.totalWeight;			//+cnwml2 MSL CCMS 1017
	endforeach;
end;</source>
        <Parameter name="_requiredDate" type="Date"/>
        <Parameter name="_startFromDate" type="Date"/>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_deltaQuantity" type="Integer" usage="io"/>
        <Parameter name="_deltaVolume" type="Decimal" usage="io"/>
        <Parameter name="_deltaWeight" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getQuantityActual" id="891e5d95-6566-43ef-bffd-cc5c5b8da531">
        <source>getQuantityActual() : Integer;
//-----------------------------------------
//Created: October 2002 By: cnwgd1
//-----------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 22/05/2013	cnwer1		CCMS 2274 renamed from getQuantityActual because looks at quanitity on ti  not totalQuantity
vars
	ti			: CM_TrackedItem;
	tot			: Integer;
	loadState	: Boolean;
begin

	app.cmsBeginLoad(loadState);
	foreach ti in self.allTrackedItems do
		tot := tot + ti.quantity;
	endforeach;
	return tot;
	
epilog
	app.cmsEndLoad(loadState);
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
