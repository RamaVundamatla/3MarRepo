<Class name="HMS_Resource">
    <JadeMethod name="importPLXMLReference" id="a4eb469a-6d91-4bc3-984e-67dee9670fd4">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = "myRoot" then
		return app.myRoot;
	elseif _name = "myHarbour" then
		return app.getMyHarbour();
	elseif _name = "myResourceType" then
		return app.myRoot.allResourceTypes[_theCode];
	elseif _name = "myWharf" then
		return app.getMyHarbour().allWharves[_theCode];
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
