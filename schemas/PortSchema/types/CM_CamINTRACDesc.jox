    </JadeMethod>
    <JadeMethod name="outputTrailer_UNZ" id="f1f9512b-b052-4d3f-a17c-39ccf32143b5">
        <updating/>
        <source>outputTrailer_UNZ(_protocol :CM_CamProtocol; _camTaskHistory :CM_CamTaskHistory input; _count, _seqNumber :Integer; _coll :HugeStringArray input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars

begin
