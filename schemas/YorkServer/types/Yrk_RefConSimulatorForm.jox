    </JadeMethod>
    <JadeMethod name="sendOnlyOneNoTI" id="9d3461c4-95ea-45b2-a2dc-2cea8d5aff1b">
        <updating/>
        <source>sendOnlyOneNoTI(_ti : String; _tempSupply : Real) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09 September 2015	cnwdap1		Initial creation PAR #
//
vars
	message		: Binary;
