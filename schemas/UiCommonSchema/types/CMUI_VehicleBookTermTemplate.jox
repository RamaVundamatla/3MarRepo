    <JadeMethod name="addObjToTblDays" id="259c09fa-26b5-4efd-a9ff-6500a19f9cfa">
        <source>addObjToTblDays( _dayTemp : CM_VehicleBookingDayTemplate );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	dataLine : String;
	index : Integer;

begin

	dataLine := _dayTemp.getAttributeStringForDefArray(self.tblDays.allTblDataEntRows);
	
	index := self.tblDays.rows + 1;
	
	self.tblDays.addItemAt( dataLine, index );
	self.tblDays.accessRow( index ).itemObject := _dayTemp;

epilog

end;</source>
        <Parameter name="_dayTemp" type="CM_VehicleBookingDayTemplate"/>
    </JadeMethod>
    <JadeMethod name="btnAddDay_click" id="875c0c77-bc5e-4f02-886a-d700581bbe5a">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAddDay_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars
	vssTemplate : CMUI_VehicleBookDayTemplate;
	
begin

	vssTemplate := app.loadForm(CMUI_VehicleBookDayTemplate, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_VehicleBookDayTemplate;
	if vssTemplate &lt;&gt; null then
		vssTemplate.CMUI_VehicleBookDayTemplate.setMyTemplates( null, self.myVehicleBookingTerminal );
		vssTemplate.setParentForm(self);
		vssTemplate.showModal;
		self.initTblDays();
	endif;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
