end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="executePostMoveForOrigLocation" id="c19a4acf-b0f4-4b9e-a6a9-36bd600bfc75">
        <updating/>
        <source>executePostMoveForOrigLocation(control: CMIF_MoveController; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
/*
// Purpose:		A Discharge Move
// 21/08/2017	cnwma1	TFS #5470 MSL - Voyage definition - Field "Ship Exchange Started Date/Time"
// 22/04/2024	jlika1	TFS 63747 CUX | FLP - Apply 'unload' logic to empty import MAFIs
   07/05/2024	jlika1	TFS 64026 CUX - Full Import MAFI's are Being Cleared in Voyage Ops Live When Doing Cargo Checks
   14/05/2024	jlika1	TFS 64116 CUX - FLP no queued move after Full MAFI Cargo Checks and Empty MAFI's disappear from the system
   06/08/2024	jlier1  TFS  5230 CUX  - MAFI stack behaviour on discharge - they want a MAFI with only MAFIs onboard to be treated like an MT 
// ---------------------------------------------------------------------------*/

vars
	aVJob : CM_VoyageJob;
	aReq : CM_Request;      // 21.08.2017 cnwma1 TFS #5470
	aRTI,aTI : CM_TrackedItem;
	aJS : CM_JobSheet;
	pxyMAFI : CM_TrackedItem;
	controller	: CMIF_TIUpdateController;
begin
	inheritMethod(control, _passport);

	aTI := control.myTrackedItem;
	if aTI = null then
		return;
	endif;

	// ### this stuff is for the Side Profile Screen
	if control.moveMode = REAL_MODE then // PAR 8436
	// we need to set the current job so that the side profile can position the crane in the graphic
	//	aReq := self.mySlotRequestDischarge;  // 21.08.2017 cnwma1 TFS #5470
		aReq := self.getRequest(false);		  // 21.08.2017 cnwma1 TFS #5470
		if aReq 	&lt;&gt; null then
			aRTI := aReq.getTrackedItem;
			if aRTI = aTI then
				aVJob := aReq.myJob.CM_VoyageJob;
				if aVJob &lt;&gt; null then
					aJS := aVJob.myJobSheet;
					
					if CM_VoyageJobSheet.hasInstance(aJS) then
						aJS.CM_VoyageJobSheet.setCurrentJob(aVJob);
						// if the ship exchange date is null then this is the first move so set it
						if (not self.myVoyage.shipExchangeDate.isValid()) then
							self.myVoyage.setShipExchangeDate(app.serverTimestampAtTrxStart);
						endif;						
					endif;
				endif;		
			endif;
		endif;
	endif;
	
	if aTI.isMAFI() and control.moveMode = REAL_MODE  then		
		if  aTI.isEmpty() then
			pxyMAFI:=aTI.pxyCreateUpdateProxy;
			pxyMAFI.setContentsStatus(TI_CONTENTS_STATUS_EMPTY);
			pxyMAFI.setMyCustomerPriority(null);
		endif;
		// jlier1 CR 65459 5/8/24 - moved code to CM_TrackedItem::statusEvent so not competing with IMEX transistion rules
		
		if pxyMAFI &lt;&gt; null then
			controller := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
			aTI.setForUpdate(pxyMAFI, controller, null, true, _passport); 
		endif;
		
	endif;
epilog
	delete pxyMAFI;
	delete controller;
end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="executePostMoveForToLocation" id="56892205-5e4c-47c2-be09-74c18115dab9">
        <updating/>
        <source>executePostMoveForToLocation(control: CMIF_MoveController; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 11 October 2002 By: cnwgd1
//
// Changed On	By			Reason
// ----------	--------	------------------------------------
// 04/04/2012	cnwdap1		PAR #29378 Don't change the voyage on a tranship that's still on the import voyage
// 21/08/2017	cnwma1		TFS #5470 MSL - Voyage definition - Field "Ship Exchange Started Date/Time"
//--------------------------------------------------------------
vars
	ti,aRTI 					: CM_TrackedItem;
	txnParams 			: CMIF_TITransactionController;
	txn 				: CM_TITransaction;
	editVoyage,
	editDischarge 		: Boolean;
	theDischargePort 	: String;
	theRelease			: CM_BulkRelease;
	invalidObject		: Boolean;
	aReq				: CM_Request; 	//21.08.2017	cnwma1 TFS #5470
	aVJob 				: CM_VoyageJob; //21.08.2017	cnwma1 TFS #5470
	aJS 				: CM_JobSheet;  //21.08.2017	cnwma1 TFS #5470
	tiEvent 			: Integer; 	    //21.08.2017	cnwma1 TFS #5470
begin
	inheritMethod(control, _passport);
	if control.isUndoMove then
		return;
	endif;	
	ti := control.myTrackedItem;
		
	//if ti.myVoyage &lt;&gt; self.myVoyage then										// PAR #29378
	if	ti.myVoyage &lt;&gt; self.myVoyage and not ti.isTranshipOnInboundVoyage then	// PAR #29378
		
		//epr  par33948 28/4/14
		if ti.myCargoType.isBreakBulkMulti or ti.myCargoType.isBulkMulti then
			editVoyage := control.moveMode = REAL_MODE;
		else
			editVoyage := true;
		endif;
	endif;
	
	//26 Oct 2011	NDL	Par 28476 - Replans during ship planning cause the wle to be deleted in CM_TrackedItem.setMyLocations before we get to here.
	on Exception do app.handleDeletedObject( exception, control.myWorkListEntry, invalidObject );
	
	if control.myWorkListEntry &lt;&gt; null //cnwrd1 8.12.2010 par 26525 we need to also set the discharge port if we are from a ship release
	 and control.myWorkListEntry.myRequest &lt;&gt; null 
	 //and control.myWorkListEntry.myRequest.isKindOf(CM_SlotRequest)
	 and ( control.myWorkListEntry.myRequest.isKindOf(CM_VoyageRequest) or control.myWorkListEntry.myRequest.isKindOf(CM_SlotRequest) )	//04 Apr 2013	NDL	Par 31359
	 and control.myWorkListEntry.myRequest.getBulkReleaseReserveDetail &lt;&gt; null then
		theRelease := control.myWorkListEntry.myRequest.getBulkRelease;
		if theRelease.myDischargePort &lt;&gt; null and theRelease.myDischargePort.code &lt;&gt; ti.dischargePort then
			theDischargePort := theRelease.myDischargePort.code;
			editDischarge := true;
		endif;
	endif;
	
	if editVoyage or editDischarge then
		create txnParams transient;
		txnParams.type := TRANS_TYPE_EDIT;
		txnParams.myTrackedItem := ti;
		txnParams.myTerminal := self.myTerminal;
		txnParams.dateTime := app.serverTimestampAtTrxStart;
		txn := ti.createTransaction(txnParams, _passport);
		
		
		if txn &lt;&gt; null then // PAR 11337
		
			if editVoyage then
				if ti.myVoyage = null then			
					txn.CM_Edit.fieldsValues.add(CM_TrackedItem::myVoyage.name &amp; " ' ' =&gt;  " &amp; self.myVoyage.code);
				else
					txn.CM_Edit.fieldsValues.add(CM_TrackedItem::myVoyage.name &amp; ti.myVoyage.code &amp; " =&gt;  " &amp; self.myVoyage.code);
				endif;
				
				ti.setMyVoyage(self.myVoyage, _passport);				
			endif;
			
			if editDischarge then  //cnwrd1 par 26525 8.12.2010
				if ti.myVoyage = null then			
					txn.CM_Edit.fieldsValues.add(CM_TrackedItem::dischargePort.name &amp; " ' ' =&gt;  " &amp;theDischargePort);
				else
					txn.CM_Edit.fieldsValues.add(CM_TrackedItem::dischargePort.name &amp; ti.dischargePort &amp; " =&gt;  " &amp; theDischargePort);
				endif;
				
				ti.setDischargePort(theDischargePort);
			endif;
		endif;
		//jlier1 TFS 65459 06/08/24
		ti.updateMAFIForVoyageChange(  _passport);
		
		
	endif;
	ti.setPostMoveToTransport(control, _passport);
	
	//21.08.2017	cnwma1 TFS #5470
	
	ti := control.myTrackedItem;
	if ti = null then
		return;
	endif;
	
	// we need to set the current job so that the side profile can position the crane in the graphic
	// ### this stuff is for the Side Profile Screen
	if control.moveMode = REAL_MODE then // PAR 8436
		//aReq := self.mySlotRequestLoad;
		aReq := self.getRequest(true);
		if aReq 	&lt;&gt; null then
			aRTI := aReq.getTrackedItem;
			if aRTI = ti then
				aVJob := aReq.myJob.CM_VoyageJob;
				if aVJob &lt;&gt; null then
					aJS := aVJob.myJobSheet;
					
					if aJS &lt;&gt; null then
						aJS.CM_VoyageJobSheet.setCurrentJob(aVJob);
						// if the ship exchange date is null then this is the first move so set it
						if self.myVoyage.shipExchangeDate = null then
							self.myVoyage.setShipExchangeDate(app.serverTimestampAtTrxStart);
						endif;
					endif;
				endif;		
			endif;
		endif;
	endif;
	
	// PAR #26018 Need to ensure that the load port is updated on the tracked item, 
	// so call ti.miscTIEvents with the correct event constant
	tiEvent := NULL_TI_EV;
	if control.moveMode = REAL_MODE then
		if control.isForcedMove then
			tiEvent := NON_OPS_REAL_MOVE_TO_EV;
		else
			tiEvent := OPS_MOVE_TO_EV;
	    endif;
	elseif control.moveMode = PLANNING_MODE and control.isForcedMove = false then
		tiEvent := PLANNED_MOVE_TO_EV;
	endif;
	if tiEvent = NULL_TI_EV then
		return;
	endif;
	ti.miscTIEvent(tiEvent);
	
	//21.08.2017	cnwma1 TFS #5470
	

	
epilog
	delete txnParams;
end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
