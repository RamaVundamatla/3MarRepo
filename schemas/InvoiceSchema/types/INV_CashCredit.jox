    <JadeMethod name="doCmbBankBuild" id="9c34bd92-79c6-4c72-9872-63da56afd260">
        <source>doCmbBankBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Jul 2019	jlgsl4	TFS 44274 - JMT - Add Business Unit to Cash Credit
*/

vars
	company			: CM_Bank;
	businessUnits	: CM_CompanyByCodeDict;
	currentBU		: CM_Bank;
	combo			: CMUI_ComboBox;
begin
	
	combo := self.cmbBank;
	create businessUnits transient;
	
	currentBU := self.myTerminal.getAvailableCompanies(businessUnits);	
	
	foreach company in businessUnits discreteLock do
		combo.addItem(company.code);
		combo.itemObject[combo.newIndex] := company;
	endforeach;
	
	
	if self.myCashReceipt &lt;&gt; null then
		combo.listObject := self.myCashReceipt.getBank();
	else
		if currentBU &lt;&gt; null then
			combo.listObject := currentBU;
		endif;
	endif;
	
epilog
	delete businessUnits;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="48a1e644-63e9-463d-a3ff-942117cc3a62">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 July 2012	cnwndl1	Initial creation
24 Jul 2019	jlgsl4	TFS 44274 - Cash Credit
*/

vars

	tblHeight : Real;

begin

	inheritMethod();
	self.frmMain.move(5,self.frmToolbar.clientHeight + 5,self.clientWidth - 10,self.clientHeight - 10 - self.frmToolbar.clientHeight); // TFS 44274
	self.frmTables.height:= self.frmFooter.top - self.frmTables.top;		// 22/04/2016 cnwjre1 clean-up the screen
	tblHeight := (( self.frmTables.height - 50 ) / 2 ).Integer - 2;

end;</source>
    </JadeMethod>
    <JadeMethod name="doRowSelectDeselect" id="42e5f032-698e-465c-b47e-77bf47f7099d">
        <updating/>
        <source>doRowSelectDeselect( _select 	   : Boolean; 
					 _cashPayment  : CM_CashPayment) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Jul 2019	jlgsl4	TFS 44274 - Cash Credit
17 Oct 2019 cnwma1 ChangeRequest 46984: JMT - Refactor Cash Credit UI and Tax
*/

vars
	obj                 : Object;
begin

	if _cashPayment = null then
