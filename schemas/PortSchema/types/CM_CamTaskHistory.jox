    <JadeMethod name="dateFormat" id="30c7f771-1828-4659-9a71-8c74c5e99b50">
        <source>dateFormat(_timeStamp: TimeStamp):String;
// ---------------------------------------------------------------------------
// Created:		22 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
return _timeStamp.date.shortFormatJMT() &amp; " " &amp; _timeStamp.time.shortFormatJMT()&amp;' ';
end;</source>
        <Parameter name="_timeStamp" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayString" id="a874e494-6785-4c63-bf74-0d3c53d1ba00">
        <source>displayString():String;
// ---------------------------------------------------------------------------
// Created:		22 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
//17 Oct 2023   navra1	TFS 60207 - EUP | FR 54536 - D&amp;R - History issues with Multiple Files 
vars
	msgCount	: String;
	emailID		: String;
begin
	//if self.messageCount &gt; 0 then						//navra1 - TFS 60207 - 17th Oct 2023
		msgCount := self.messageCount.String;
	//endif;											//navra1 - TFS 60207 - 17th Oct 2023
	
	if self.uniqueEmailID &gt; 0 then
		emailID := self.uniqueEmailID.String;
	endif;
	
	return  self.seqNumber.String &amp; Tab &amp; 
			self.dateFormat(runDateTime) &amp; Tab &amp;
			self.dateFormat(startDateTime) &amp; Tab &amp; 
			self.dateFormat(endDateTime) &amp; Tab &amp; 
			self.statusString &amp; Tab &amp; 
			emailID &amp; Tab &amp; 
			msgCount &amp; Tab &amp;
			self.computerName &amp; " " &amp; Tab &amp; 
			self.fileName &amp; "  " &amp; Tab &amp; 
			self.errorMessage;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="ba0f1423-7a27-43fe-bf6c-e344233fbb7f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2024	navcs2	Initial creation

*/

vars

begin
	if _attrName = ETRow_CamProtocol then
		return self.camProtocol.code;
	elseif _attrName = ETRow_SequenceNumber then
		return self.seqNumber.asStringJMT;
	elseif _attrName = ETRow_Computer then
		return self.computerName;
	elseif _attrName = ETRow_Messages then
		return self.messageCount.asStringJMT;
	elseif _attrName = ETRow_ErrorMessage then
		return self.errorMessage;
	elseif _attrName = ETRow_TaskStatus then
		return self.statusString();
	elseif _attrName = ETRow_RunDate then
		return self.runDateTime.asStringJMT;
	elseif _attrName = ETRow_ProtocolDesc then
		return self.camProtocol.description;
	endif;
		
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getProtocolCode" id="45904cd9-f5db-4187-830d-353c8a486088">
        <source>getProtocolCode():String;
// --------------------------------------------------------------------------------
// Created:		11 August 2010 by cnwdad1
//
// Purpose:		Returns the receiver's CAM Protocol code.
//
// Parameters:	None
//
// Returns:		The receiver's CAM Protocol code, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.camProtocol = null then
		return null;
	else
		return self.camProtocol.code &amp; " (History " &amp; self.seqNumber.asStringJMT() &amp; ")";
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRawDataString" id="80bc806f-0d8c-41d6-8878-b192447acce7">
        <source>getRawDataString() : String;
//
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//
vars

begin
	if self.rawData.isEmpty() then
		return null;
	else
		return self.rawData.getContent().uncompressToString();
	endif;
epilog

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isRestartable" id="143dd721-0652-4393-be8c-9facea98e53e">
        <source>isRestartable():Boolean;
// ---------------------------------------------------------------------------
// Created:		27 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	if	self.status = CAM_EXTRACTSTATUS 
	or	self.status = CAM_SENDSTATUS 
	or	self.status = CAM_RESENDSTATUS then
		return true;
	endif;
	
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isUsingFileDataStorage" id="a2a5eb91-b116-4def-ad20-cbb9c1b424cd">
        <source>isUsingFileDataStorage() : Boolean;
/* 
---------------------------------------------------------------------------
 Created:     J Harliwich               

 Purpose:     

 Parameters:  None

 Returns:     Nothing

 Changed On   Changed By  Reason
 ----------   ----------  --------------------------------------------------
 
 ---------------------------------------------------------------------------
*/

vars

begin
	if  myFileDataStorageHeader 					&lt;&gt; null 		and		// if this exists then we use always get from here 
		myFileDataStorageHeader.allFileDataStorageDetail.size &gt; 0 	then 	
		return true;
	endif;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="3c5a3607-d853-4cb5-8521-61ab7e0d4866">
        <source>pxyCreateUpdateProxy(): SelfType;
//
//25 May 2012	cnwrs1		Par 26914 - make cams restart after lock error
//
vars
	tmpCamTaskHistory : CM_CamTaskHistory;
	completedOK	: Boolean;
begin
	tmpCamTaskHistory := inheritMethod();
	tmpCamTaskHistory.camProtocol := self.camProtocol;
	tmpCamTaskHistory.myFileDataStorageHeader := self.myFileDataStorageHeader;
	completedOK := true;
	return tmpCamTaskHistory;
epilog
	if not completedOK then	
		delete tmpCamTaskHistory;
	endif;	
end;
</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="rawDataToHSA" id="067fad45-1a02-413e-afc7-5814ea4ee821">
        <source>rawDataToHSA(_theLines : HugeStringArray input);
//
//26 Mar 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//21 Jul 2015	cnwrs1	Par 35544 - Switch Cams to camtaskhistory::rawData
//31 Jan 2023	navra1  TFS - 55859 - Making it possible to get strings longer than 2048
//18 Mar 2023	navmd1	TFS 57092 Revert changes made for 55859
//03/07/2023	navcs2	Bug 58947 handle JSON messages longer than StringArray membership

vars
	fileLine	: String;
	theLines	: HugeStringArray;
	msg			: String;
	pos,
	crPos,
	maxLength,
	i			: Integer;
	delim,
	chunk		: String;	
begin
	_theLines.clear;
	create theLines transient;
	fileLine := self.getRawDataString();
	
	//03/07/2023 navcs2 Bug 58947 Start
	if not self.camProtocol.isJson then
		fileLine.getHugeTokensForDelimiter(Cr, theLines);
	else
		// Individual JSON messages may be longer than the limit of HugeStringArray, so we need to split/chunk them
		// We may as well use the same Delimiter that the CAM Protocol uses
		// The actual message delimiter is still just a CR though
		//fileLine.getHugeTokensForDelimiter(self.camProtocol.JSON_Output_Delimeter.unicodeToString, theLines);
		
		delim := CM_CamProtocol.JSON_Output_Delimeter.unicodeToString;
		maxLength := _theLines.getMaxLength() - delim.length;
		
		while true do
			pos += 1;
			crPos := fileLine.pos(Cr, pos);
			
			// Grab a single message
			if crPos = 0 then
				msg := fileLine[pos:end];
			else
				msg := fileLine[pos:crPos-pos];
			endif;
			
			if msg.length &lt;= maxLength then
				_theLines.add(msg);
			else
				// Too big! Split
			
				i := 1;
				while true do
					// While maxLength is technically shorter (by Delim length) than the real max length
					// Its more efficient and easier to read to just split it there
					if i + maxLength &lt; msg.length then
						chunk := msg[i:maxLength];
					else
						chunk := msg[i:end];
					endif;
					
					if i = 1 then
						_theLines.add(chunk);
					else
						_theLines.add(delim &amp; chunk);
					endif;
					
					i += maxLength;
					if i &gt;= msg.length then
						break;
					endif;
				endwhile;
			endif;
			
			pos := crPos;
			if pos = 0 then
				break;
			endif;
		endwhile;
		
	endif;
	//03/07/2023 navcs2 Bug 58947 End
	
	foreach fileLine in theLines do
		if fileLine &lt;&gt; null then
			_theLines.add(fileLine);
		endif;
	endforeach;

epilog
	delete theLines;
end;
</source>
        <Parameter name="_theLines" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="set" id="d53888a8-a27f-4f06-9d58-bcf924f8ae2d">
        <updating/>
        <source>set(_runDateTime, _startDateTime, _endDateTime: TimeStamp; _logExcludedTransactions :Boolean;
	_camProtocol: CM_CamProtocol; _processSeqNumber, _dailySeqNumber: Integer;	_fileName: String; 
	_status: Integer; _errorMessage: String) updating;
//----------------------------------------------------------------
//	Created:	20 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 17/07/2012	cnwcs5	par 29601 - log excluded transactions
// 21/08/2012	cnwcs5	par 30176 - conversion for above
//27 Oct 2015	cnwrs1	Par37082 special file name longer than 30 chars
vars

begin
	self.runDateTime		:= _runDateTime;
	self.startDateTime		:= _startDateTime;
	self.endDateTime		:= _endDateTime;
	
	self.logExcludedTransactions := _logExcludedTransactions;	// par 30176 Aug 2012
	
	self.seqNumber			:= _processSeqNumber;				// key in self.camProtocol.taskHistoryByProtocolSeq
	self.camProtocol		:= _camProtocol;					// auto inverse update
	self.dailySeqNumber		:= _dailySeqNumber;
	self.fileName			:= _fileName[1:60];					//cnwmc5 - 24 Oct 2014 - CCMS 2380
	self.computerName		:= app.computerName();
	self.status				:= _status;	
	self.errorMessage		:= _errorMessage;
end;</source>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <Parameter name="_startDateTime" type="TimeStamp"/>
        <Parameter name="_endDateTime" type="TimeStamp"/>
        <Parameter name="_logExcludedTransactions" type="Boolean"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_processSeqNumber" type="Integer"/>
        <Parameter name="_dailySeqNumber" type="Integer"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_errorMessage" type="String"/>
    </JadeMethod>
