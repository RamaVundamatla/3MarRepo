    <JadeMethod name="setProxyFromReeferJob" id="7994bb0c-184f-48e8-989d-466117b50c83">
        <updating/>
        <source>setProxyFromReeferJob(_job : CM_YardActivity) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/11/2020	jlgdap1		Initial creation TFS 49227 MTN Navis API - nReefer API
// 22/12/2020	jlgdap1		TFS 50522 MTN Reefer API
// 28SEP2022    NAVSP1      TFS 54899: PEN - Reefer Monitor App Changes
vars

begin
	self.ufvGkey := _job.getOidString;
	self.rmAction := _job.getNReeferAction;
	self.setProxyFromTI(_job.myTrackedItem);
	// TFS 50522 Set both on and wants power for monitor jobs	// TFS 50522
	if _job.isReeferMonitor then								// TFS 50522
		self.rmOnPower := "true";								// TFS 50522
		self.rmWantPower := "true";								// TFS 50522
	endif;														// TFS 50522
	self.reeferJobCreationTS := _job.getDisplayStringForAttribute(ETRow_ReeferJobCreationTS,false); //28SEP2022 NAVSP1 TFS 54899
epilog

end;</source>
        <Parameter name="_job" type="CM_YardActivity"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromTI" id="fa4ca2e4-4e0c-49af-96fd-7c2686bc18b3">
        <updating/>
        <source>setProxyFromTI(_ti: CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2020	jlgrr1	Initial creation TFS 49227 Navis API - nReefer API
18 Jan 2021	jlgdap1	TFS 50648 MTN Reefer App Issue (4)
20 Jan 2021	jlgdap1	TFS 50672 MTN Reefer Wants Power and On Power Issue
23 Feb 2021	navdap1	TFS 50512 MTN Reefer Monitor App Layout
28SEP2022   NAVSP1  TFS 54899: PEN - Reefer Monitor App Changes
*/
vars
	propertyDict : PropertyNDict;
	prop : Property;
	value : String;

begin
	create propertyDict transient;
	propertyDict := self.class.getProperties();
	
	foreach prop in propertyDict do
		if prop.name = ETRow_TemperatureDT 
		or prop.name = ETRow_UfvGkey 
		or prop.name = ETRow_RmAction then
			continue;
		endif;
		if prop.name = ETRow_ReeferJobCreationTS then	//27SEP2022 NAVSP1 TFS 54899
			self.reeferJobCreationTS := null;
			continue;
		endif;
		
		value := _ti.getDisplayStringForAttribute(prop.name, false);
		//if prop.name = ETRow_IsConnected then	// TFS 50672												// TFS 50512
		if prop.name = ETRow_IsConnected or prop.name = ETRow_IsExternallyMonitored then	// TFS 50672	// TFS 50512
			if value.toUpper = "YES" then		// TFS 50672
				value := "true";				// TFS 50672
			else								// TFS 50672
				value := "false";				// TFS 50672
			endif;								// TFS 50672
		endif;									// TFS 50672
		self.setPropertyValue(prop.name, value);
	endforeach;
	
	if self.ufvGkey = null then					// TFS 50648
		self.ufvGkey := _ti.getOidString;		// TFS 50648
	endif;										// TFS 50648
	
epilog
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="updateForNewJob" id="8034ebec-444e-4c21-899e-98565c322866">
        <updating/>
        <source>updateForNewJob(_job : CM_YardActivity) updating;
//
// Purpose:			Add the details for this job to an existing WS_NUnit object
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/12/2020	jlgdap1		Initial creation TFS 50508 MTN Reefer App - Job List
// 22/12/2020	jlgdap1		TFS 50522 MTN Reefer App - Job List
// 02/11/2022	navdap1		TFS 54899 PEN Reefer Monitor App Changes
//
vars

begin
	if self.rmAction &lt;&gt; null then											// TFS 54899
		self.rmAction := self.rmAction &amp; Comma &amp; _job.getNReeferAction;
	else																	// TFS 54899
		self.rmAction := _job.getNReeferAction;								// TFS 54899
	endif;																	// TFS 54899
	self.ufvGkey := self.ufvGkey &amp; Comma &amp; _job.getOidString;
	// TFS 50522 only send one flag for connect / disconnect			// TFS 50522
	if _job.isReeferConnect and self.rmOnPower = "true" then			// TFS 50522
		self.rmOnPower := "false";										// TFS 50522
	elseif _job.isReeferDisconnect and self.rmWantPower = "true" then	// TFS 50522
		self.rmWantPower := "false";									// TFS 50522
	endif;																// TFS 50522
epilog

end;</source>
        <Parameter name="_job" type="CM_YardActivity"/>
    </JadeMethod>
    <JadeMethod name="updateForNoJob" id="ecf5967b-c3aa-43f4-9002-746d2bac5f93">
        <updating/>
        <source>updateForNoJob() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 October 2022	navsp1	Initial creation - ChangeRequest 54899: PEN - Reefer Monitor App Changes

*/

vars

begin
	self.rmAction := "M";	
epilog

end;</source>
    </JadeMethod>
</Class>
