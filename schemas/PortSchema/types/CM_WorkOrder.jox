    <JadeMethod name="setApproved" id="20fc35c5-ea28-45f4-a514-3638d95113bd">
        <updating/>
        <source>setApproved( _approvedBy : String ; _approvedBtDT : TimeStamp ; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Jul 2009	cnwrd1	Initial creation
20 Jun 2018 cnwma1	ChangeRequest 38815: PEL1 - WP TI Work Order Changes
19 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars
	woDtl 			: CM_WorkOrderDtl;
	derivedDate 	: TimeStamp;
begin
	
	self.approvedBy   	 := _approvedBy;	
	self.approvedByDT 	 := app.actualTimeServer();
	self.notApprovedBy   := null;						//15 Jun 2018	NDL	TFS 39167
	self.notApprovedByDT := null;       				//15 Jun 2018	NDL	TFS 39167
	
	foreach woDtl in self.allWoDtls do 													//24.01.2023 navma1 #56141 Task#56147
		if woDtl.isKindOf(CM_WodRelease) or  woDtl.isKindOf(CM_WodExportReturn)  then
			derivedDate := woDtl.getConfiguredApprovalExpiryTS(self.requiredByDT);		// TFS 43405 jlgdap1 24/04/2019
			if not derivedDate.isValid or self.requiredByDT &gt; derivedDate then
				self.setApprovalExpiry( self.requiredByDT );							//12 Mar 2019	NDL	TFS 43405
			else
				self.setApprovalExpiry( derivedDate );									//04 Apr 2019	NDL	TFS 43405
			endif;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_approvedBy" type="String"/>
        <Parameter name="_approvedBtDT" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
