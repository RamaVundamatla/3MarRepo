    <JadeMethod name="load" id="83e10987-078f-41d5-8841-356884648765">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
//--------------------------------------------------
// Created:	09 December 2005 By: cnwgd1
//--------------------------------------------------
vars

begin

	app.initialize();
	app.myPassport.setMyUserFromCode('CNWGD1');
	app.myPassport.setMyTerminal(CM_Terminal.firstInstance);
	self.myTerminal := app.myPassport.myTerminal;	
	self.setColorsFromController(null);

	self.frmToolbar.priorityRight := true;

	self.initPosition();
	self.setupForm();
	self.setMenus();

	if self.toolbarStyle &lt;&gt; ToolbarStyle_None then
		self.zSetupToolbar();
	endif;

	self.frmToolbarBtns.top := -1000;	// move out of visible area

	if self.windowState &lt;&gt; self.WindowState_Minimized then
		// at startup we open windows minimised so don't 
		// bother resizing.  Resize will get done when
		// user first access them
		self.doResize();
	endif;

	self.show;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="2414c9d4-fda6-41ab-8e9d-8567a86671b1">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//--------------------------------------------------
// Created:	22 December 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();

	self.centreWindow();
	
	self.tblData.columns := 14;
	self.tblData.accessColumn(1).inputType := Table.InputType_TextBox;
	self.tblData.accessColumn(2).inputType := Table.InputType_TextBox;
	self.tblData.accessColumn(3).inputType := Table.InputType_TextBox;
	self.tblData.accessColumn(4).inputType := Table.InputType_TextBox;	
	self.tblData.accessColumn(5).inputType := Table.InputType_TextBox;	
	self.tblData.accessColumn(6).inputType := Table.InputType_TextBox;	
	self.tblData.accessColumn(7).inputType := Table.InputType_TextBox;	
	self.tblData.accessColumn(8).inputType := Table.InputType_CheckBox;
	self.tblData.accessColumn(9).inputType := Table.InputType_TextBox;				
	self.tblData.accessColumn(10).inputType := Table.InputType_TextBox;	
	self.tblData.accessColumn(11).inputType := Table.InputType_TextBox;	
	self.tblData.accessColumn(12).inputType := Table.InputType_TextBox;									
	self.tblData.accessColumn(13).inputType := Table.InputType_CheckBox;	
	self.tblData.accessColumn(14).inputType := Table.InputType_CheckBox;					
					
	self.tblData.selectionType := self.tblData.SelectionType_Row;
	self.tblData.selectMode := self.tblData.SelectMode_CurrentRow;
	
	self.tblData.accessCell(1,1).text := ('ID' &amp; Tab &amp; 'Cargo Type' &amp; Tab &amp; 'Commodity' &amp; Tab &amp; 'Load Port' &amp; Tab &amp; 'Discharge Port' &amp; Tab &amp; 'Operator' &amp; Tab &amp; 'Size Attributes' &amp; Tab &amp; 'Is Tranship' &amp; Tab &amp; 'Transit Status' &amp; Tab &amp; 'ImEx Status'&amp; Tab &amp; 'Type Attributes' &amp; Tab &amp; 'Contents Status' &amp; Tab &amp; 'O/D' &amp; Tab &amp; 'Hide');
	self.tblData.addItem('SUDU1234567' &amp; Tab &amp; 'ISO Container' &amp; Tab &amp; 'MT' &amp; Tab &amp; 'SPE' &amp; Tab &amp; 'POE' &amp; Tab &amp; 'CHL' &amp; Tab &amp; '40' &amp; Tab &amp; '0' &amp; Tab &amp; 'N/A' &amp; Tab &amp; 'STO'&amp; Tab &amp; 'ISO_GENERAL' &amp; Tab &amp; 'MT' &amp; Tab &amp; '0' &amp; Tab &amp; '0');
	self.tblData.addItem('SUDU2345678' &amp; Tab &amp; 'ISO Container' &amp; Tab &amp; 'AUTO' &amp; Tab &amp; 'SPE' &amp; Tab &amp; 'POE' &amp; Tab &amp; 'CHL' &amp; Tab &amp; '40' &amp; Tab &amp; '0' &amp; Tab &amp; 'DLR' &amp; Tab &amp; 'TRA'&amp; Tab &amp; 'ISO_MACHINERY' &amp; Tab &amp; 'LCL' &amp; Tab &amp; '0' &amp; Tab &amp; '0');
	self.tblData.addItem('SUDU3456879' &amp; Tab &amp; 'ISO Container' &amp; Tab &amp; 'HOPS' &amp; Tab &amp; 'SPE' &amp; Tab &amp; 'POE' &amp; Tab &amp; 'CHL' &amp; Tab &amp; '20' &amp; Tab &amp; '0' &amp; Tab &amp; 'SOB' &amp; Tab &amp; 'TRA'&amp; Tab &amp; 'ISO_GENERAL' &amp; Tab &amp; 'FULL' &amp; Tab &amp; '0' &amp; Tab &amp; '0');
	self.tblData.addItem('SUDU4567890' &amp; Tab &amp; 'ISO Container' &amp; Tab &amp; 'ALUM' &amp; Tab &amp; 'SPE' &amp; Tab &amp; 'POE' &amp; Tab &amp; 'CHL' &amp; Tab &amp; '40' &amp; Tab &amp; '1' &amp; Tab &amp; 'N/A' &amp; Tab &amp; 'IMP'&amp; Tab &amp; 'ISO_GENERAL' &amp; Tab &amp; 'FULL' &amp; Tab &amp; '1' &amp; Tab &amp; '1');
	self.tblData.addItem('SUDU5678910' &amp; Tab &amp; 'ISO Container' &amp; Tab &amp; 'APLA' &amp; Tab &amp; 'POE' &amp; Tab &amp; 'SPE' &amp; Tab &amp; 'COL' &amp; Tab &amp; '20' &amp; Tab &amp; '0' &amp; Tab &amp; 'N/A' &amp; Tab &amp; 'EXP'&amp; Tab &amp; 'ISO_REEFER' &amp; Tab &amp; 'FULL' &amp; Tab &amp; '0' &amp; Tab &amp; '0');				

	//tblData.colourRows(self.colorRow1, self.colorRow2);
	self.setColorsForTable(self.tblData);
		
end;</source>
