    <JadeMethod name="valJobSplit" id="f4940350-67da-4ac8-94b0-d9c879c4e134">
        <source>valJobSplit(_job : CM_Job; _wleSet : CM_WLESet; _jobID : String; _jobSheet : CM_WorkPointJobSheet);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Aug 2024	navhl20	Bug 65424: EUP | 53729 - WO Jobs - Split Pack or Unpack job issues

*/

vars
	wle		: CM_WorkListEntry;
	countP,
 	countC	: Integer;
begin
	if not _job.isKindOf(CM_WOPackJob) then
		if _wleSet.size = 0 then
			app.raiseCMException(Atlea_work_list_entry_shoul_se, null, null);
		endif;
	else
		if _wleSet.size = 1 then
			app.raiseCMException(Pleas_selec_both_paren_child_w, null, null);
		elseif _wleSet.size &gt; 1 then
			countP := 0;
			countC := 0;
			foreach wle in _wleSet do
				if wle.isKindOf(CM_WOPackParentWLE) then
					countP := countP+1;
				endif;
				if wle.isKindOf(CM_WOPackChildWLE) then
					countC := countC+1;
				endif;
			endforeach;
			if countP = 0 or countC = 0 then
				app.raiseCMException(Pleas_selec_both_paren_child_w, null, null);
			endif;
		endif;
	endif;
	
	if _jobID = null then
		app.raiseCMException(Input_required_JobNumber,null,null);
	endif;
	
	if _jobSheet = null then
		app.raiseCMException(Input_required_JobSheet,null,null);
	endif;
epilog

end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_wleSet" type="CM_WLESet"/>
        <Parameter name="_jobID" type="String"/>
        <Parameter name="_jobSheet" type="CM_WorkPointJobSheet"/>
    </JadeMethod>
    <JadeMethod name="valJobStatus" id="dd67d8ed-2696-47c8-bc98-95d81915dcf5">
