    <JadeMethod name="setProxy" id="276a2fbb-ebc1-41c2-85f5-cc83cb7962e4">
        <updating/>
        <source>setProxy(_cargoType : Integer;
			_commodity, 
			_description : String;
			_remarks : String;
			_hazards : CM_HazardByCodeDict;
			
			_isoType : String;
			_quantity : Integer;
			
			_weight : Decimal; //par19252 cnwrs1 may 2009
			_maxToRelease : Integer;
			_grade  : Integer;
			_humidity : Decimal;
			_temperature : Real;
			_ventilation : Decimal; //par19252 cnwrs1 may 2009
			_ventilationUnits : Integer;
			_carbonDioxide : Decimal;
			_oxygen : Decimal;
			_curtainsIn : Boolean;
			_isClean : Boolean;
			_heavyRated :Boolean;
			_specialStow : CM_SpecialStow;
			_isoGroup :String;
			_inspected : Boolean;
			_specialLift : CM_SpecialLiftByCodeDict;					//+cnwml2 PAR20173 SFW CCMS 1091
			_purchaseOrder : String;									// PAR #33193
			_serviceOrder : String;										// PAR #33193			
			_matchMode : Integer										//navra1 - CR 63764/Task 64227 - 23nd May 2024
			)updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
12 November 2008	cnwer1	Initial creation
26 May 2009			cnwjo3	add specialStow for CCMS 1079
04 March 2014		cnwdap1	PAR #33193 CCMS DPH 2285 new purchaseOrder and serviceOrder fields
23rd May 2024		navra1	//navra1 - CR 63764/Task 64227 - 23rd May 2024
*/

vars
	
begin
	self.cargoType			:= _cargoType;
	self.commodity 			:= _commodity;
	self.description 		:= _description;
	self.remarks			:= _remarks;
	

	self.setPxyHazards(_hazards);
	
	self.setSpecialLifts(_specialLift);
	
	self.isoType			:= _isoType;
	self.weight				:= _weight; //cnwrd ccms 1060 12.1.09
	self.quantity			:= _quantity;
	self.clean				:=_isClean;
	
	//cnwjo3 CCMS 1079
	self.mySpecialStow		:= _specialStow;
	
	self.isoTypeGroup		:= _isoGroup;						//+cnwml2 PAR20173 SFW CCMS 1091
	self.inspected			:= _inspected;						//+cnwml2 PAR20173 SFW CCMS 1091
			

	if _maxToRelease &gt; 0 or _maxToRelease = -1 then									//+cnwml2 PAR20173 SFW CCMS 1091
		self.setProxyReserveDetail(_quantity,_maxToRelease,_grade,_heavyRated);
	endif;
	
	self.purchaseOrder		:= _purchaseOrder;					// PAR #33193
	self.serviceOrder		:= _serviceOrder;					// PAR #33193
	
	self.matchMode			:= _matchMode;						//navra1 - CR 63764/Task 64227 - 23rd May 2024

epilog

end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_hazards" type="CM_HazardByCodeDict"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_maxToRelease" type="Integer"/>
        <Parameter name="_grade" type="Integer"/>
        <Parameter name="_humidity" type="Decimal"/>
        <Parameter name="_temperature" type="Real"/>
        <Parameter name="_ventilation" type="Decimal"/>
        <Parameter name="_ventilationUnits" type="Integer"/>
        <Parameter name="_carbonDioxide" type="Decimal"/>
        <Parameter name="_oxygen" type="Decimal"/>
        <Parameter name="_curtainsIn" type="Boolean"/>
        <Parameter name="_isClean" type="Boolean"/>
        <Parameter name="_heavyRated" type="Boolean"/>
        <Parameter name="_specialStow" type="CM_SpecialStow"/>
        <Parameter name="_isoGroup" type="String"/>
        <Parameter name="_inspected" type="Boolean"/>
        <Parameter name="_specialLift" type="CM_SpecialLiftByCodeDict"/>
        <Parameter name="_purchaseOrder" type="String"/>
        <Parameter name="_serviceOrder" type="String"/>
        <Parameter name="_matchMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxyBasic" id="c4251438-47ee-4bc7-8d4a-3d51bbf942ff">
        <updating/>
        <source>setProxyBasic(	_cargoType : Integer;
				_commodity, 
				_isoType,
				_isoTypeGroup : String;
				_product : CM_Product) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2018	jlger1	Initial creation 38518
18 Mar 2019	NDL	TFS 43881

*/

vars

	isoTypeObj : CM_ISOType;
	isoTypeGroupObj : CM_ISOTypeGroup;

begin
	self.cargoType			:= _cargoType;
	self.commodity 			:= _commodity;
	self.isoType			:= _isoType;
	self.quantity			:= 1;
	
	//18 Mar 2019	NDL	TFS 43881 - to get around the 'checkAll' behaviour in 'CM_BookingRefItem::doesCargoMatch' which without IsoTypeGroup
	// can cause mis matching of cargo on the same Booking Ref Item.
	if _isoTypeGroup &lt;&gt; null then
		self.isoTypeGroup := _isoTypeGroup;
	elseif self.isoType &lt;&gt; null then
		isoTypeObj := app.myRoot.allISOTypes.getAtKey( self.isoType );
		if isoTypeObj &lt;&gt; null and isoTypeObj.myISOTypeGroup &lt;&gt; null then
			self.isoTypeGroup := isoTypeObj.myISOTypeGroup.code;
		endif;
	endif;
	
	//27.April.2023 navsp1 TFS 56592
	if _product &lt;&gt; null then
		self.myProduct :=  _product;
	endif;
	
	
epilog

end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_isoTypeGroup" type="String"/>
        <Parameter name="_product" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="setProxyForCargo" id="9b699ed8-fb7b-4b91-83b9-fb0590f7e8d3">
        <updating/>
        <source>setProxyForCargo(	_cargoType : Integer;
					_commodity : String; _description : String;
					_hazards : CM_HazardByCodeDict;
					_quantity : Integer; _remarks : String;
					_height : Decimal; _length : Decimal;
					_width : Decimal; _heightString : String;
					_lengthString : String; _widthString : String;
					_type : String; _density : Decimal;				// ### TFS 52193 22Nov2021 NAVPW1
					_volume : Decimal; _pQuantity : Integer;
					_shippingMarks : String; _weight : Decimal;
					_product : CM_Product; _ediBookingRefTI : CM_EDIBookingRefTI;
					_rawEDIData : String; _generatorType : String;
					_specialStow : CM_SpecialStow;
					_id : String;
					_colour : String;
					_markNumber : String;											//+cnwml2 PAR20173 SFW CCMS 1091
					_specialLifts : CM_SpecialLiftByCodeDict;						//+cnwml2 PAR20173 SFW CCMS 1091
					_productWeight : Decimal;										//+cnwml2 PAR20173 SFW CCMS 1091
					_productVolume : Real;											//+cnwml2 PAR20299 SFW CCMS 1091
					_trailerType : String;
					_purchaseOrder : String;										// PAR #33193
					_serviceOrder : String;											// PAR #33193
					_matchMode : Integer) updating;									//navra1 - CR 63764/Task 64227 - 23rd May 2024
// --------------------------------------------------------------------------------
// Created:		25 May 2009 by cnwjo3
//
// Purpose:		Set all the properties for a cargo item (convert values, calculate volume)
//
// adm 160310 Par 22937 remove bolType
// 04/03/2014	cnwdap1		PAR #33193 CCMS DPH 2285 Added purchaseOrder and serviceOrder fields
// 27/06/2014   cnwma1		PAR #34475 Editing Booking Item causes problems while receiving
vars

begin
	self.cargoType			:= _cargoType;
	self.commodity 			:= _commodity;
	self.description 		:= _description;
	self.setPxyHazards(_hazards);
	self.quantity			:= _quantity;
	self.remarks			:= _remarks;
	self.height				:= _height;
	self.length				:= _length;
	self.width				:= _width;
	self.heightString		:= _heightString;
	self.lengthString		:= _lengthString;
	self.widthString		:= _widthString;
	self.typeString			:= _type;  //i'm pretty sure type goes into typeString

	self.productQuantity	:= _pQuantity;
	self.productVolume		:= _productVolume;			//+cnwml2 PAR20173 SFW CCMS 1091
	self.productWeight		:= _productWeight;			//+cnwml2 PAR20173 SFW CCMS 1091
	self.shippingMarks		:= _shippingMarks;
	self.weight				:= _weight;
	self.density			:= _density;
	self.volume				:= _volume;
	self.myProduct			:= _product;
	self.rawEDIData			:= _rawEDIData;
	//self.ediBookingRefTI	:= _ediBookingRefTI;   //where is this property?
	self.generatorType		:= _generatorType;
	self.trailerType		:= _trailerType;
	self.mySpecialStow		:= _specialStow;
	self.id					:= _id;
	self.colour				:= _colour;
	self.markNumber			:= _markNumber;							//+cnwml2 PAR20299 SFW CCMS 1091
	
	//clear values of CM_BookingRef if set previously
	self.isoType			:= null;
	self.isoTypeGroup		:= null;								//+cnwma1 PAR #34475
	self.clean				:= false;
	self.cubicMetres		:= NULL_INTEGER;
	self.inspected			:= false;
	self.myReserveDetail	:= null;
	
	self.setSpecialLifts(_specialLifts);						//+cnwml2 PAR20173 SFW CCMS 1091
	
	self.purchaseOrder		:= _purchaseOrder;					// PAR #33193
	self.serviceOrder		:= _serviceOrder;					// PAR #33193
	
	self.matchMode 			:= _matchMode;						//navra1 - CR 63764/Task 64227 - 23rd May 2024
end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_hazards" type="CM_HazardByCodeDict"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_height" type="Decimal"/>
        <Parameter name="_length" type="Decimal"/>
        <Parameter name="_width" type="Decimal"/>
        <Parameter name="_heightString" type="String"/>
        <Parameter name="_lengthString" type="String"/>
        <Parameter name="_widthString" type="String"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_density" type="Decimal"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_pQuantity" type="Integer"/>
        <Parameter name="_shippingMarks" type="String"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_ediBookingRefTI" type="CM_EDIBookingRefTI"/>
        <Parameter name="_rawEDIData" type="String"/>
        <Parameter name="_generatorType" type="String"/>
        <Parameter name="_specialStow" type="CM_SpecialStow"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_colour" type="String"/>
        <Parameter name="_markNumber" type="String"/>
        <Parameter name="_specialLifts" type="CM_SpecialLiftByCodeDict"/>
        <Parameter name="_productWeight" type="Decimal"/>
        <Parameter name="_productVolume" type="Real"/>
        <Parameter name="_trailerType" type="String"/>
        <Parameter name="_purchaseOrder" type="String"/>
        <Parameter name="_serviceOrder" type="String"/>
        <Parameter name="_matchMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxyReserveDetail" id="511e0b9f-9569-4051-884f-00b6e49acb4e">
        <updating/>
        <source>setProxyReserveDetail(_quantity, _maxToRelease, _grade  : Integer; _heavyRated : Boolean) updating;
/*
Date		Who		Reason
24 Nov 2008	cnwer1	Initial creation
29 Sep 2009	consw1	SFW1035 - Changed to reserve the 'Max. to Release' quantity rather than 'Number of Items' booked.
					This also means that quantity could be changed to zero so now supporting the deletion of a reserve.
18/09/2012	cnwcs5	par 30390 - change of signature for CM_ReserveSelection setProxy
//09 Sep 2014	cnwrs1	CCMS 2351 att Sequence to Release request 
14 Jun 2022 jlier1	TFS 53678
//19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level	
28 June 2023 navmv20 CR 58410 Task 58411: UI - Cargo Review - Release Request		
// 6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight														
*/

vars
	theMaxToRelease : Integer;
	bulkRelease 	: CM_BulkRelease;
	availGrades		: IntegerArray;
	realBooking 	: CM_BookingRef;
	realBookingItem : CM_BookingRefItem;
	tmpISOTypeGoup 	: CM_ISOTypeGroup;  //cnwrd1 par 20810 9/10/9
	
begin
	if _maxToRelease = -1 then
		theMaxToRelease := 0;
	else
		theMaxToRelease := _maxToRelease;
	endif;
	
	if self.myBookingReference &lt;&gt; null then
		bulkRelease:=self.myBookingReference.allReleaseRequests.first;
	else
		return;
	endif;
	
	if theMaxToRelease = 0 then
		delete self.myReserveDetail;
		if bulkRelease &lt;&gt; null and
		   bulkRelease.allReserveDetails.isEmpty() then
			delete bulkRelease;
		endif;
		return;
	endif;
	
	if bulkRelease = null and self.myBookingReference &lt;&gt; null then
		realBooking := self.myBookingReference.pxyGetRealObject();
		if realBooking = null or
		   realBooking.allReleaseRequests.isEmpty() then
			create bulkRelease transient;
		else
			bulkRelease := realBooking.allReleaseRequests.first.pxyCreateUpdateProxy();
		endif;
		bulkRelease.setBookingRefStock(self.myBookingReference);
		if app.isSubTerminalsOn(app.getMyTerminalDO_NOT_USE) then
// cnwdad1 27/01/2010 - PAR #22205.
//			bulkRelease.setSubTerminal(app.getMyTerminal.getDefaultSubTerminal(CM_SubTerminal.Type_BulkRelease, null, null, null));
			bulkRelease.setSubTerminal(app.getMyTerminalDO_NOT_USE().getDefaultSubTerminalForRel(bulkRelease.type));
		endif;
	endif;
	
	if self.myReserveDetail = null then
		realBookingItem := self.pxyGetRealObject();
		if realBookingItem = null or
		   realBookingItem.myReserveDetail = null then
			create self.myReserveDetail as CM_ReserveSelection transient;
		else
			self.myReserveDetail := realBookingItem.myReserveDetail.pxyCreateUpdateProxy();
		endif;
	endif;
	
	create availGrades transient;
	if _grade &lt;&gt; NULL_INTEGER then
		availGrades.add(_grade);
	endif;
	
	tmpISOTypeGoup := app.myRoot.allISOTypeGroups[self.isoTypeGroup];  //cnwrd1 par 20810 9/10/9
	
	self.myReserveDetail.CM_ReserveSelection.setProxy(CM_ReserveSelection.PackType_Parent, 
													self.myCargoType,
													self,
													self.myISOType,
													tmpISOTypeGoup ,  //cnwrd1 par 20810 9/10/9
													null,
													null,
													null,
													theMaxToRelease, // was _quantity,
													availGrades, //avail grades
													null,//clean
													null, //iso check
													_heavyRated, //heavy rated
													null, //mask ids
													theMaxToRelease,
													null,
													null,
													null,
													null,
													null,
													null,
													null,
													null,
													null,
													null,
													null,
													null,
													null,
													null,
													null,
													false,
													null,null,null,null,null,null,false,false,null,null,null,null,null,null,null,null,
													null,	// ### TFS 53953 11July2022 NAVPW1
													null,null,  //12-07-2022 navtnr20 53974
													null, //28/06/2023 navmv20 CR 58410 Task 58411
													false, // 6/12/2023 navcs2 ChangeRequest 57537
													false, //19/02/2023	navkc1 CR 60078 Task 62450
													null,  //24/04/2025	navrv30	MTN 34319
													null);
	
	if not bulkRelease.allReserveDetails.includes(self.myReserveDetail) then
		bulkRelease.allReserveDetails.add(self.myReserveDetail);
	endif;

epilog
	delete availGrades;
end;</source>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_maxToRelease" type="Integer"/>
        <Parameter name="_grade" type="Integer"/>
        <Parameter name="_heavyRated" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setPxyHazards" id="fbcaee00-73e7-4454-a047-3abea1dce5c7">
        <updating/>
        <source>setPxyHazards(_hazards : CM_HazardByCodeDict) updating, protected;
/*
	Created on 17 January 2008
	
	by Debby Hutchison
	
	Purpose:

Changed On	By			Reason
----------	--------	-----------------------------------------------
11/06/2015	cnwdap1		PAR #36421 Change in signature of CM_TIHazard::setProxy
09/11/2016	cnwdap1		TFS 2842 Hazardous Details Enhancements
*/

vars
	obj		: Object;
	tiHaz	: CM_TIHazard;
	newHaz	: CM_TIHazard;
begin
	self.allTIHazards.clear;	//just clear

	if _hazards = null or _hazards.isEmpty then
		return;
	endif;
	
	foreach obj in _hazards do
		if CM_TIHazard.hasInstance(obj) then
			tiHaz := obj.CM_TIHazard;
			create newHaz transient;
			//is transient need to use setProxy
			//newHaz.setProxy(tiHaz.code, tiHaz.description, tiHaz.allUNDGCodes.asCSV(false),null,tiHaz.limitedQuantity);					// PAR #36421
			//newHaz.setProxy(tiHaz.code, tiHaz.description, tiHaz.allUNDGCodes.asCSV(false),null,tiHaz.limitedQuantity,tiHaz.packingGroup);	// TFS 2842
			newHaz.setProxy(	tiHaz.code, 							// TFS 2842
								tiHaz.description, 						// TFS 2842
								tiHaz.allUNDGCodes.asCSV(false),		// TFS 2842
								null,									// TFS 2842
								tiHaz.limitedQuantity,					// TFS 2842
								tiHaz.packingGroup,						// TFS 2842
								tiHaz.flashpointTemperature,			// TFS 2842
								tiHaz.isMarinePollutant,				// TFS 2842
								tiHaz.acidsBases	);					// TFS 2842
			self.allTIHazards.add(newHaz);
		endif;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_hazards" type="CM_HazardByCodeDict"/>
    </JadeMethod>
    <JadeMethod name="setSpecialLifts" id="4fc70fdf-f196-42bb-8def-9021ef408d5b">
        <source>setSpecialLifts(_allSpecialLifts : CM_SpecialLiftByCodeDict);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 July 2009	cnwml2	Initial creation

*/

vars
	spLift : CM_SpecialLift;
begin
	self.allSpecialLifts.clear;	//just clear

	if _allSpecialLifts = null or _allSpecialLifts.isEmpty then
		return;
	endif;
	
	foreach spLift in _allSpecialLifts do
		self.allSpecialLifts.add(spLift);
	endforeach;
epilog

end;</source>
