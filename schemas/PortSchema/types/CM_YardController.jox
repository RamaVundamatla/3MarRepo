        <Parameter name="pTerminalArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="setForDeckingIn" id="d6e84b8b-6d29-46cd-bc42-d4033abd42de">
        <source>setForDeckingIn(_fromHeight, _toHeight: Integer; _yaLocnCells: CM_YALocationCellArray input; _yaIndex: Integer io);
//----------------------------------------------------------------
//	Created:	07 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	yaIndex,
	intHeight		: Integer;
	yaLocnCell		: CM_YALocationCell;
begin
	if _fromHeight &lt; 1 then
		//applies to nothing
		return;
	endif;
	
	//other rules may cover other heights
	foreach intHeight in _fromHeight to _toHeight do
		//default index
		_yaIndex			:= _yaIndex + 1;	//decking index
		yaIndex				:= null;
		
		if intHeight &gt; self.allYAYardLocationCells.size then
			yaLocnCell := null;
		else
			yaLocnCell := self.allYAYardLocationCells[intHeight];		
		endif;

		if yaLocnCell = null then
			//the next one is missing
			create yaLocnCell persistent;
			self.allYAYardLocationCells.insert(intHeight, yaLocnCell);
			yaLocnCell.setForCreate(intHeight);
			//add it to TA array
			_yaLocnCells.insert(_yaIndex, yaLocnCell);
			//what else?
			yaIndex := _yaIndex;
		else
			yaIndex := _yaLocnCells.indexOf(yaLocnCell);
			if yaIndex = 0 then
				_yaLocnCells.insert(_yaIndex, yaLocnCell);
				yaIndex := _yaIndex;
			endif;
		endif;
		
		if yaIndex &lt;&gt; _yaIndex then
			_yaLocnCells.remove(yaLocnCell);
			_yaLocnCells.insert(_yaIndex, yaLocnCell);
		endif;
		
	endforeach;

end;</source>
        <Parameter name="_fromHeight" type="Integer"/>
        <Parameter name="_toHeight" type="Integer"/>
        <Parameter name="_yaLocnCells" type="CM_YALocationCellArray" usage="input"/>
        <Parameter name="_yaIndex" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForDeckingOut" id="497f2060-4627-4226-9fa0-f582ee0965df">
        <source>setForDeckingOut(_fromHeight, _toHeight: Integer; _yaLocnCells: CM_YALocationCellArray input; _yaIndex: Integer io);
//----------------------------------------------------------------
//	Created:	07 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	yaIndex,
	intHeight		: Integer;
	yaLocnCell		: CM_YALocationCell;
begin
	if _fromHeight &lt; 1 then
		//applies to nothing
		return;
	endif;

	//other rules may cover other heights
	foreach intHeight in _toHeight to _fromHeight step-1 do
		//default index
		_yaIndex			:= _yaIndex + 1;	//system default decking index
		yaIndex				:= null;
		
		if intHeight &gt; self.allYAYardLocationCells.size then
			yaLocnCell := null;
		else
			yaLocnCell := self.allYAYardLocationCells[intHeight];		
		endif;

		if yaLocnCell = null then
			//the next one is missing
			while intHeight &gt; (self.allYAYardLocationCells.size+1) do
				create yaLocnCell persistent;
				self.allYAYardLocationCells.add(yaLocnCell);
				yaLocnCell.setForCreate(self.allYAYardLocationCells.size);
			endwhile;
			
			create yaLocnCell persistent;
			self.allYAYardLocationCells.insert(intHeight, yaLocnCell);
			yaLocnCell.setForCreate(intHeight);
			//add it to TA array
			_yaLocnCells.insert(_yaIndex, yaLocnCell);
			//what else?
			yaIndex := _yaIndex;
		else
			yaIndex := _yaLocnCells.indexOf(yaLocnCell);
			if yaIndex = 0 then
				_yaLocnCells.insert(_yaIndex, yaLocnCell);
				yaIndex := _yaIndex;
			endif;
		endif;
		
		if yaIndex &lt;&gt; _yaIndex then
			_yaLocnCells.remove(yaLocnCell);
			_yaLocnCells.insert(_yaIndex, yaLocnCell);
		endif;
		
	endforeach;
end;</source>
        <Parameter name="_fromHeight" type="Integer"/>
        <Parameter name="_toHeight" type="Integer"/>
        <Parameter name="_yaLocnCells" type="CM_YALocationCellArray" usage="input"/>
        <Parameter name="_yaIndex" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForProxyYardController" id="54b9cc8a-1f25-4e2f-ab50-0ca1a3aa785f">
