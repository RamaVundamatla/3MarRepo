    <JadeMethod name="displayCCTableTotalNums" id="51ff3516-ba8f-496d-9c73-5170de80bd6c">
        <source>displayCCTableTotalNums();
/*

Date		    Who			Reason
24 January 2011	cnwas3	  par26773

*/

vars	
	tbl				: CM_DataTable;	
	totalColumn,dlrColumn,exportColumn,sobColumn, idx, totTIs : Integer;	
begin
	tbl := self.tblCCAllocation;
	totalColumn := tbl.getColumnByRowName(ETRow_TotalActual);
	if totalColumn = 0 then
		return;
	endif;	
	
	sobColumn := tbl.getColumnByRowName(ETRow_NumSoB);
	
	dlrColumn := tbl.getColumnByRowName(ETRow_NumRehandles);	
	exportColumn := tbl.getColumnByRowName(ETRow_MatchingTIsCollection);	
	
	
	foreach idx in tbl.fixedRows + 1 to tbl.rows do		//cnwas3 par 26840	
		totTIs := 0;
		if sobColumn &lt;&gt; 0 then
			totTIs := totTIs + tbl.accessCell(idx,sobColumn).text.asIntegerJMT();
		endif;
		if dlrColumn &lt;&gt; 0 then
			totTIs := totTIs + tbl.accessCell(idx,dlrColumn).text.asIntegerJMT();
		endif;
		if exportColumn &lt;&gt; 0 then
			totTIs := totTIs + tbl.accessCell(idx,exportColumn).text.asIntegerJMT();
		endif;
		tbl.accessCell(idx,totalColumn).text := totTIs.zeroNotAllowed();		
	endforeach;
	
epilog
		
end;</source>
    </JadeMethod>
    <JadeMethod name="displayCCTableTotals" id="0cc4dbd6-0f91-4168-84f8-4c0f0a6f9ecd">
        <source>displayCCTableTotals();
// ---------------------------------------------------------------------------
// Created:     28 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//	26 jan 2011       cnwas3        par 26773
// ---------------------------------------------------------------------------

vars
	
	allocTotals : CM_VoyAllocationByPriority;
	tbl				: CM_DataTable;
	voyAlloc : CM_VoyageAllocation;
	
	
	varianceColumn,
	projectedColumn, 
	plannedColumn, 
	ccTotalColumn, 
	ccExportColumn,
	ccSOBColumn,	 
	ccDLRColumn, 
	selectedCol,
	exportActualColumn,
	sobActualColumn,
	dlrActualColumn,
	actualTotalColumn	: Integer;			
	
	exportActualTotal,
	varianceTotal, 
	projectedTotal, 
	plannedTotal,
	ccExportTotal,
	ccTotal, 
	ccSOBTotal,
	dlrActualTotal, 
	ccDLRColumnTot, 
	sobActualTotal,
	actualTotalTotal	: Integer;					
	
	idx, totTIs, varience : Integer;
	iter : Iterator;
	doTotals : Boolean;
	
begin
	
	tbl := self.tblCCAllocation;
	
	// ### GET COLUMN NUMBERS
	exportActualColumn := tbl.getColumnByRowName(ETRow_MatchingTIsCollection);	
	varianceColumn := tbl.getColumnByRowName(ETRow_Variance);	
	projectedColumn := tbl.getColumnByRowName(ETRow_Projected);	
	plannedColumn := tbl.getColumnByRowName(ETRow_SlotReqWithPlannedTIs);	
	ccTotalColumn := tbl.getColumnByRowName(ETRow_SlotRequests);	
	ccDLRColumn := tbl.getColumnByRowName(ETRow_ColourCodedRehandles);	
	dlrActualColumn := tbl.getColumnByRowName(ETRow_NumRehandles);				
	sobActualColumn := tbl.getColumnByRowName(ETRow_NumSoB);
	actualTotalColumn := tbl.getColumnByRowName(ETRow_TotalActual);
	ccExportColumn := tbl.getColumnByRowName(ETRow_ColourCodedExports);
	ccSOBColumn := tbl.getColumnByRowName(ETRow_ColourCodedSobs);
	
	// ### ADD UP ALL THE NUMBERS
	foreach idx in tbl.fixedRows + 1 to tbl.rows do		//cnwas3 par 26840
		if projectedColumn &gt; 0 then
			projectedTotal := projectedTotal + tbl.accessCell(idx,projectedColumn).text.Integer;
		endif;
		if exportActualColumn &gt; 0 then
			exportActualTotal := exportActualTotal + tbl.accessCell(idx,exportActualColumn).text.Integer;
		endif;
		if varianceColumn &gt; 0 then
			varianceTotal := varianceTotal + tbl.accessCell(idx,varianceColumn).text.Integer;
		endif;
		if plannedColumn &gt; 0 then
			plannedTotal := plannedTotal + tbl.accessCell(idx,plannedColumn).text.Integer;
		endif;
		if ccTotalColumn &gt; 0 then
			ccTotal := ccTotal + tbl.accessCell(idx,ccTotalColumn).text.Integer;
		endif;
		if ccDLRColumn &gt; 0 then
			ccDLRColumnTot := ccDLRColumnTot + tbl.accessCell(idx,ccDLRColumn).text.Integer;
		endif;
		if dlrActualColumn &gt; 0 then								
			dlrActualTotal := dlrActualTotal + tbl.accessCell(idx,dlrActualColumn).text.Integer;
		endif;
		if sobActualColumn &gt; 0 then								
			sobActualTotal := sobActualTotal + tbl.accessCell(idx,sobActualColumn).text.Integer;
		endif;
		if actualTotalColumn &gt; 0 then								
			actualTotalTotal := actualTotalTotal + tbl.accessCell(idx,actualTotalColumn).text.Integer;
		endif;
		if ccExportColumn &gt; 0 then								
			ccExportTotal := ccExportTotal + tbl.accessCell(idx,ccExportColumn).text.Integer;
		endif;
		if ccSOBColumn &gt; 0 then								
			ccSOBTotal := ccSOBTotal + tbl.accessCell(idx,ccSOBColumn).text.Integer;
		endif;
		doTotals := true;
	endforeach;

	
	
	selectedCol := tbl.getColumnByRowName(ETRow_Projected);

	// ### DISPLAY TOTALS
	if doTotals then
		// blank line
		idx := tbl.addItem(null);
		tbl.accessRow(idx).height := 5;
		tbl.accessedRow.gridBottom := false;
		tbl.accessedRow.gridRight := false;
		if selectedCol &gt; 0 then tbl.accessCell(idx, selectedCol).inputType := Table.InputType_None; endif; // NO TEXT INPUT
		// bold black line
		idx := tbl.addItem(null);
		tbl.accessRow(idx).height := 2;
		tbl.accessedRow.backColor := Black;
		tbl.accessedRow.gridBottom := false;
		tbl.accessedRow.gridRight := false;
		if selectedCol &gt; 0 then tbl.accessCell(idx, selectedCol).inputType := Table.InputType_None; endif; // NO TEXT INPUT
		
		// totals line
		idx := tbl.addItem(null);
		tbl.accessRow(idx);
		tbl.accessedRow.gridBottom := false;
		tbl.accessedRow.gridRight := false;
		if selectedCol &gt; 0 then tbl.accessCell(idx, selectedCol).inputType := Table.InputType_None; endif; // NO TEXT INPUT
		if projectedColumn &gt; 0 then
			tbl.accessCell(idx,projectedColumn).text := projectedTotal.zeroNotAllowed();
		endif;
		if exportActualColumn &gt; 0 then
			tbl.accessCell(idx,exportActualColumn).text := exportActualTotal.zeroNotAllowed();
		endif;
		if varianceColumn &gt; 0 then
			tbl.accessCell(idx,varianceColumn).text := varianceTotal.zeroNotAllowed();
		endif;
		if plannedColumn &gt; 0 then
			tbl.accessCell(idx,plannedColumn).text := plannedTotal.zeroNotAllowed();
		endif;
		if ccTotalColumn &gt; 0 then
			tbl.accessCell(idx,ccTotalColumn).text := ccTotal.zeroNotAllowed();
		endif;
		if ccDLRColumn &gt; 0 then
			tbl.accessCell(idx,ccDLRColumn).text := ccDLRColumnTot.zeroNotAllowed();
		endif;
		if dlrActualColumn &gt; 0 then						
			tbl.accessCell(idx,dlrActualColumn).text := dlrActualTotal.zeroNotAllowed();
		endif;
		if sobActualColumn &gt; 0 then						
			tbl.accessCell(idx,sobActualColumn).text := sobActualTotal.zeroNotAllowed();
		endif;		
		if actualTotalColumn &gt; 0 then						
			tbl.accessCell(idx,actualTotalColumn).text := actualTotalTotal.zeroNotAllowed();
		endif;
		if ccExportColumn &gt; 0 then						
			tbl.accessCell(idx,ccExportColumn).text := ccExportTotal.zeroNotAllowed();
		endif;
		if ccSOBColumn &gt; 0 then						
			tbl.accessCell(idx,ccSOBColumn).text := ccSOBTotal.zeroNotAllowed();
		endif;

		// bold black line
		idx := tbl.addItem(null);
		tbl.accessRow(idx).height := 2;
		tbl.accessedRow.backColor := Black;
		tbl.accessedRow.gridBottom := false;
		tbl.accessedRow.gridRight := false;
		if selectedCol &gt; 0 then tbl.accessCell(idx, selectedCol).inputType := Table.InputType_None; endif; // NO TEXT INPUT

	endif;
	
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="displayCCTableTotalsRemove" id="b4c88f90-fc66-4d59-8a76-ccf9341c6f8d">
        <source>displayCCTableTotalsRemove();
// ---------------------------------------------------------------------------
// Created:     18 April 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	allocTotals : CM_VoyAllocationByPriority;
	tbl				: CM_DataTable;
	voyAlloc : CM_VoyageAllocation;
	idx, totRows, varience : Integer;
	iter : Iterator;
	doTotals : Boolean;
begin
	tbl := self.tblCCAllocation;
	totRows := tbl.rows;
	
	foreach idx in tbl.fixedRows + 1 to tbl.rows reversed do		//cnwas3 par 26840  
		voyAlloc := tbl.accessRow(idx).itemObject.CM_VoyageAllocation;
		if voyAlloc &lt;&gt; null then
			break;
		endif;
		tbl.removeItem(idx);
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="0c6e214a-1e2e-4bb5-a934-c50e237e7634">
