    <JadeMethod name="setProxy" id="ec7aab8f-7eb3-4dad-9362-e5434bd9465a">
        <updating/>
        <source>setProxy(_name : String; _toDoTaskDesc : CM_ToDoTaskDesc; _toDoTask : CM_ToDoTask; _requiredExtraInfo : String; _required : Boolean; _cargoCheck : CM_CargoCheck) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2010	cnwdap1	Initial creation
*/
vars

begin
	self.name				:= _name;
	self.myToDoTaskDesc		:= _toDoTaskDesc;
	self.requiredExtraInfo	:= _requiredExtraInfo;
	self.required			:= _required;
	
	self.myCargoCheck		:= _cargoCheck;
	self.myToDoTask			:= _toDoTask;
epilog

end;</source>
        <Parameter name="_name" type="String"/>
