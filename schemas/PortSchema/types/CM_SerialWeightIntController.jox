    <JadeMethod name="closeEvent" id="e619f70e-d547-4a31-9e8d-d6533421a48a">
        <updating/>
        <source>closeEvent(_connection : Connection) updating, protected;
/*

Purpose:		a close event has occurs on the Serial port.  set to not listening,
//				delete JadeSerialPort object (need to do this so Jade cleans stuff up)
//				and recreate JadeSerialPort		

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2017	cnwns1	Initial creation

*/

vars

begin
	self.diagnosticLog(method.qualifiedName &amp; " mySerialPort=" &amp; self.mySerialPort.String &amp; " listeningState=" &amp; self.listeningState.String);
	
	self.listeningState := self.PendingDelete;
	
end;</source>
        <access>protected</access>
        <Parameter name="_connection" type="Connection"/>
    </JadeMethod>
    <JadeMethod name="commandParser" id="b8924de0-94f6-4e8c-ace2-7e3f67cf984e">
        <updating/>
        <source>commandParser(_commandLine : String) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2017	cnwns1	Initial creation
19 April 2018	jlgns1 Bug 38134: PKT - Weight Discrepancy
*/
	
vars
	
	startPos : Integer;
	weightString : String;
	weightDec : Decimal[16,4];
	weightKg : Decimal[16,4];
	weightType : CM_MeasurementType;
begin

/*
	Expected input format From Mettler Toledo 227 Weighbridge
	)8 123456     0
    |a |b|  c   | d  |e|
	
	a start of text &lt;ignore&gt;
	b status		&lt;ignore&gt;
	c weight data	&lt;Use&gt;	 
	d tare weight	&lt;ignore&gt; &lt;blank in testing&gt;
	e end of text	&lt;ignore&gt;
	
	*/
	
	
		
	self.diagnosticLog(method.qualifiedName &amp; " _commandLine=|" &amp; _commandLine &amp; "| length=" &amp; _commandLine.length.String);	
		
	//when test device starts it sends 2 initialized messages that is longer than the 17 chr normal message
	if _commandLine.length &gt; self.latestReturnValue.maxLength then
		self.latestReturnValue := _commandLine[1:self.latestReturnValue.maxLength];
		
		self.raiseWeightICException(0,"Invalid _commandLine value received: '" &amp; _commandLine &amp; "'");
		
		return;
	else
		self.latestReturnValue := _commandLine;
	endif;
	
	//If return value is null there is no working connection
	if _commandLine = null then
		self.hasValidConnection := false;
		self.raiseWeightICException(0,"Null value received: '" &amp; _commandLine &amp; "'");
		return;
	endif;
	
	self.hasValidConnection := true;
	
		
	startPos := 5;
	
	//get relevant part of input message
	
	weightString :=_commandLine.getNextToken(startPos);
	
	
	// Validate the data 
	if weightString.trimBlanks.isDecimal then
		weightDec := weightString.trimBlanks.Decimal;
	else
		self.raiseWeightICException(0,"Invalid Weight value received: '" &amp; weightString &amp; "'");
	endif;
		
	// Get Unit from config	
	weightType := self.mySerialDetails.myWeighBridgeObj.myWeightType;
	
	if weightType = null then
		self.raiseWeightICException(0,"Invalid weightType received: '" &amp; " _commandLine=|" &amp; _commandLine &amp; "|" &amp; "WeighBridge: " &amp; self.mySerialDetails.myWeighBridgeObj.name );
	endif;
		
	weightKg := app.convertMeasurementForStorage(weightType.shortName,weightDec);
			
	self.diagnosticLog(method.qualifiedName &amp; " _commandLine=|" &amp; _commandLine &amp; "| weightValue= " &amp; weightKg.String &amp; "|");			
			
	self.latestWeight := weightKg;
	self.latestWeightSetAt := app.actualTimeServer;		//Bug 38134
	
	executeWhen JMTDevelopmentEnvironment;
		write _commandLine &amp; Tab &amp; weightDec.String &amp; Tab &amp; weightKg.String &amp; Tab &amp; weightType.name;
	endExecuteWhen;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_commandLine" type="String"/>
    </JadeMethod>
    <JadeMethod name="connectedState" id="cc4a5d60-ee98-4d21-b4c8-14c16d7c80d0">
        <source>connectedState() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2017	cnwns1	Initial creation

*/

vars

begin
	return (self.mySerialPort.state = Connection.Connected);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="4a9a629a-32b9-4e86-810a-c9db50567623">
        <updating/>
        <source>create() updating;
/*

Purpose:	make sure we have a serialConnection object to play with and see exception handler		

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2017	cnwns1	Initial creation

*/

vars

begin
	on ConnectionException do self.handleConnectionException(exception) global;
	
	create mySerialPort;
	
	self.diagnosticLog(method.qualifiedName &amp; " mySerialPort=" &amp; self.mySerialPort.String);
	
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="3162f0bb-6df7-4253-912c-e9376ac7f5dd">
        <updating/>
        <source>delete() updating;
/*

Purpose:	tidy up objects when deleted

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2017	cnwns1	Initial creation
19 April 2018	jlgns1 Bug 38134: PKT - Weight Discrepancy
*/

vars
	invalid : Boolean;
begin
	self.diagnosticLog(method.qualifiedName &amp; " mySerialPort=" &amp; self.mySerialPort.String &amp; " listeningState=" &amp; self.listeningState.String);
	
	self.listeningState := self.NotListening;
	self.callBackReady := false;
	
	if self.mySerialDetails &lt;&gt; null and self.mySerialDetails.isTransient then	//Bug 38134
		delete self.mySerialDetails;											//Bug 38134
	endif;																		//Bug 38134
		
	on Exception do app.handleDeletedObject(exception,mySerialPort,invalid);	//Bug 38134

	delete mySerialPort;

	on ConnectionException do null global;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="diagnosticLog" id="39753f7e-e65f-4e18-96ff-83b17990f394">
        <source>diagnosticLog(_msg : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason

*/

vars

begin
	
	app.writeLog(_msg, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		
epilog

end;</source>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="getLatestWeight" id="3c0e657f-5674-4f73-87e1-412fa566d440">
        <source>getLatestWeight(_requestTimeStamp : TimeStamp; _hasTimedOut : Boolean output; _timeOutSeconds : Integer ) : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2018	jlgns1	Initial creation
19 April 2018	jlgns1 Bug 38134: PKT - Weight Discrepancy
*/

vars
	posNeg 		 : Integer;
	numberOfDays : Integer;
begin
		
	if _timeOutSeconds &gt; 0 then
		if self.latestWeightSetAt.addSeconds(_timeOutSeconds) &lt; _requestTimeStamp then
			self.diagnosticLog(method.qualifiedName &amp; "Latest Weight is older than " &amp; _timeOutSeconds.String &amp; " seconds, returning 0. mySerialPort=" &amp; self.mySerialPort.String &amp; " listeningState=" &amp; self.listeningState.String);
			_hasTimedOut := true;
			return 0;
		endif;
	endif;
		
	_hasTimedOut := false; 
	return self.latestWeight;
epilog

end;</source>
        <Parameter name="_requestTimeStamp" type="TimeStamp"/>
        <Parameter name="_hasTimedOut" type="Boolean" usage="output"/>
        <Parameter name="_timeOutSeconds" type="Integer"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getWeighBridgeDetails" id="3a05bfb4-f9fd-4b58-bce5-774e5bcafab7">
        <source>getWeighBridgeDetails() :String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2017	cnwns1	Initial creation

*/

vars
	name : String;
	stateString : String;
	listeningString : String;
	details : String;
	
begin
	
	if self.hasValidConnection then

		if self.mySerialDetails.myWeighBridgeObj &lt;&gt; null then
			name := self.mySerialDetails.myWeighBridgeObj.name;
		endif;
		
		if self.mySerialPort &lt;&gt; null then
			if self.mySerialPort.state = Connection.Connected  then
				stateString := app.getErrorString(Connected);
			elseif self.mySerialPort.state = Connection.Connecting then
				stateString := "Connecting";
			elseif self.mySerialPort.state = Connection.Disconnected then
				stateString := app.getErrorString(Disconnected);
			elseif self.mySerialPort.state = Connection.Disconnecting then
				stateString := "Disconnecting";
			endif;
		else
			stateString := "No Serial Port Configured";
		endif;
		
		
	
		if self.listeningState = self.Listening then
			listeningString := "Listening";
		elseif self.listeningState = self.NotListening then
			listeningString := "Not Listening";
		elseif self.listeningState = self.PendingClose then
			listeningString := "Pending Close";
		elseif self.listeningState = self.PendingDelete then
			listeningString := "Pending Delete";
		endif;
		
		details := name &amp; CrLf &amp; stateString &amp; Space &amp; listeningString;
		
	else
		details := null;
	endif;
	
	self.diagnosticLog(method.qualifiedName &amp; " myWeighBridgeObj=|" &amp; name &amp; "| state=" &amp; stateString &amp; "| listeningState=|" &amp; listeningString &amp; "|" );	

	return details;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleConnectionException" id="d7a069f3-ea6a-4c48-b36f-e5344594e23c">
        <updating/>
        <source>handleConnectionException(_connectionException : ConnectionException) : Integer updating;
/*

Purpose:	handle exception and log error	

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2017	cnwns1	Initial creation

*/

vars

begin
	self.diagnosticLog(method.qualifiedName &amp; " errorCode=" &amp; _connectionException.errorCode.String &amp; " " &amp; "errorItem=" &amp; _connectionException.errorItem &amp; " " &amp; "extendedErrorText=" &amp; _connectionException.extendedErrorText);
	
	if _connectionException.errorCode = 31305 then
		self.raiseWeightICException(0,"errorCode=" &amp; _connectionException.errorCode.String &amp; " " &amp; "errorItem=" &amp; _connectionException.errorItem &amp; " " &amp; "extendedErrorText=" &amp; _connectionException.extendedErrorText &amp; " ");
		return Ex_Abort_Action;
	elseif _connectionException.errorCode =  31320 then
		self.raiseWeightICException(0,"errorCode=" &amp; _connectionException.errorCode.String &amp; " " &amp; "errorItem=" &amp; _connectionException.errorItem &amp; " " &amp; "extendedErrorText=" &amp; _connectionException.extendedErrorText &amp; " ");
		app.msgBox("Serial port connection failed" &amp; CrLf &amp; "Close current form and reopen" ,"Error code 31320",0);
		return Ex_Abort_Action;
	endif;
		
	self.raiseWeightICException(0,"errorCode=" &amp; _connectionException.errorCode.String &amp; " " &amp; "errorItem=" &amp; _connectionException.errorItem &amp; " " &amp; "extendedErrorText=" &amp; _connectionException.extendedErrorText &amp; " ");
	
//	return Ex_Pass_Back;
	return Ex_Abort_Action;
epilog

end;</source>
        <Parameter name="_connectionException" type="ConnectionException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initializeWithSerialDetails" id="708324cf-a055-47d7-b932-cee70572550f">
        <updating/>
        <source>initializeWithSerialDetails(_serialDetails : CM_WinCEJadeSerialDetails) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2017	cnwns1	Initial creation

*/

constants
	MinTimeout		= 500;
	
vars

begin
	self.diagnosticLog(method.qualifiedName &amp; " mySerialPort=" &amp; self.mySerialPort.String &amp; " listeningState=" &amp; self.listeningState.String);
	
	if self.mySerialPort &lt;&gt; null then
		if self.listeningState = self.Listening then
			self.raiseWeightICException(0,"Attempting to initialize but you are listening");
			return;
		else
			delete self.mySerialPort;
		endif;
	endif;
	
	if _serialDetails = null then
		return;
	endif;
	
	create self.mySerialPort as JadeSerialPort transient;
	
	self.mySerialPort.dataBits := _serialDetails.dataBits;
	self.mySerialPort.fillReadBuffer := true;
	self.mySerialPort.flowControl := _serialDetails.flowControl;
	self.mySerialPort.name := _serialDetails.portName;
	self.mySerialPort.parity := _serialDetails.parity;
	self.mySerialPort.speedBps := _serialDetails.speedBps;
	self.mySerialPort.stopBits := _serialDetails.stopBits;
	self.mySerialPort.timeout := _serialDetails.timeout.max(MinTimeout);	
	self.diagnosticLog(method.qualifiedName &amp; " timeout set to " &amp; self.mySerialPort.timeout.String);
	self.mySerialPort.usePresentationClient := true;  //make sure this is always true
	
	if not _serialDetails.isTransient then
		self.mySerialDetails := _serialDetails;
	endif;
	
	self.listeningState := self.NotListening;
	
	self.diagnosticLog(method.qualifiedName &amp; " mySerialPort=" &amp; self.mySerialPort.String &amp; " listeningState=" &amp; self.listeningState.String);
end;</source>
        <Parameter name="_serialDetails" type="CM_WinCEJadeSerialDetails"/>
    </JadeMethod>
    <JadeMethod name="isOkToDelete" id="ef76480b-250c-4865-9279-f640f3cf1705">
        <source>isOkToDelete(): Boolean;
/*

Purpose:			Determine whether or not it is OK to delete the receiver.  Can't be deleted if there
					ais a current outstanding asynch operation pending			

Parameters:			None

Return Value:		True if it's ok to delete the receiver

Date		Who		Reason
10 January 2017	cnwns1	Initial creation

*/

vars

begin
	// If there is no serial port object then it is OK
	if self.mySerialPort = null then
		return true;
	endif;
	
	// If we're not listening or in a Pending Delete state then it is OK
	return self.listeningState = self.NotListening or 
		   self.listeningState = self.PendingDelete;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="openEvent" id="734d1173-6bfb-4f86-9570-b60d39c60ed6">
        <updating/>
        <source>openEvent(_connection : Connection) updating, protected;
/*

Purpose:			serial port is open.  now start reading

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2017	cnwns1	Initial creation
2/10/2017  jlgns1 TFS 6865 PKT - Weighbridge Connection Issue
18 April 2018	jlgns1	Bug 38134: PKT - Weight Discrepancy
*/

constants
	Carriage : Binary =	#[0d];
vars

begin
	self.diagnosticLog(method.qualifiedName &amp; " mySerialPort=" &amp; self.mySerialPort.String &amp; " listeningState=" &amp; self.listeningState.String);
	
	if self.listeningState = self.PendingDelete or self.listeningState = self.PendingClose  then	//Bug 38134
		return;																						//Bug 38134
	endif;																							//Bug 38134
	
	self.listeningState := self.Listening;
	
	self.hasValidConnection := true;
	
	if self.myWeightCallerInterface &lt;&gt; null then				//TFS 6865 
		self.myWeightCallerInterface.openEvent(_connection);	//TFS 6865 
	endif;														//TFS 6865 
		
	self.mySerialPort.readUntilAsynch(Carriage,1000,self,CM_SerialWeightIntController::readEvent.name);
		
end;</source>
        <access>protected</access>
        <Parameter name="_connection" type="Connection"/>
    </JadeMethod>
    <JadeMethod name="raiseWeightICException" id="1fdc51f0-cb46-4898-b185-dcd66e5bd791">
        <source>raiseWeightICException(_exceptionCode : Integer; _exceptionData : String);
/*

Purpose:	log any issue with device and call handleWeightICException method (if interface ready)

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2017	cnwns1	Initial creation

*/

vars

begin
	app.writeLog("CM_WeightInterfaceController: " &amp; _exceptionCode.String &amp; " " &amp; _exceptionData,0);
	if callBackReady then
		self.myWeightCallerInterface.handleWeightICException(_exceptionCode,_exceptionData);
	endif;
end;</source>
        <Parameter name="_exceptionCode" type="Integer"/>
        <Parameter name="_exceptionData" type="String"/>
    </JadeMethod>
    <JadeMethod name="readEvent" id="7983295f-4feb-47c1-9492-59528cab60e6">
        <updating/>
        <source>readEvent(_connection : Connection; _binaryData : Binary) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2017	cnwns1	Initial creation

*/

constants
	Carriage : Binary =	#[0d];// 11/3/16  cnwns1 PAR 36286 unicode version
vars

begin
	self.diagnosticLog(method.qualifiedName &amp; " mySerialPort=" &amp; self.mySerialPort.String &amp; " listeningState=" &amp; self.listeningState.String);

	self.commandParser(_binaryData.ansiToString());// 11/3/16  cnwns1 PAR 36286 unicode version
	
	if self.listeningState = self.PendingClose then
		self.mySerialPort.closeAsynch(self,CM_SerialWeightIntController::closeEvent.name);
		return;
	endif;	
	
	self.mySerialPort.readUntilAsynch(Carriage,1000,self,CM_SerialWeightIntController::readEvent.name);
end;</source>
        <access>protected</access>
        <Parameter name="_connection" type="Connection"/>
        <Parameter name="_binaryData" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="setWeightCallerInterface" id="0ec8a181-a12e-497d-a600-04ed351cb7fa">
        <updating/>
        <source>setWeightCallerInterface(_weightCallerInterface :  IF_TCPWeightCallerInterface) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2017	cnwns1	Initial creation

*/

vars

begin
	self.myWeightCallerInterface := _weightCallerInterface;

	
	if self.myWeightCallerInterface = null then
		self.callBackReady := false;
	else
		self.callBackReady := true;
	endif;
epilog

end;</source>
        <Parameter name="_weightCallerInterface" type="IF_TCPWeightCallerInterface"/>
    </JadeMethod>
    <JadeMethod name="startListening" id="adc314d1-344a-471a-bb29-47dc5d8e504c">
        <updating/>
        <source>startListening() updating;
// --------------------------------------------------------------------------------
// Created:		10 Jan 17 cnwns1
//
// Purpose:		open connection to serial port and start reading (in open event)
//
/*

Date		Who		Reason
	
*/

vars

begin
	self.diagnosticLog(method.qualifiedName &amp; " mySerialPort=" &amp; self.mySerialPort.String &amp; " listeningState=" &amp; self.listeningState.String);
	
//	write "State " &amp;	self.listeningState.String ;
	
	if self.listeningState = self.PendingDelete then
		self.initializeWithSerialDetails(self.mySerialDetails);
	endif;
	
	if not self.connectedState() and self.callBackReady and self.listeningState = self.NotListening then
		self.mySerialPort.openAsynch(self,CM_SerialWeightIntController::openEvent.name);
	else
		self.raiseWeightICException(0,"Start Listening failed.  ConnectedState: " &amp; self.connectedState.String &amp; " callBackReady: " &amp; self.callBackReady.String &amp; " Listening State: " &amp; self.listeningState.String);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="stopListening" id="39832cf1-11c7-4329-904e-19808bdaf34a">
        <updating/>
        <source>stopListening() updating;
/*

Purpose:	close connection and reset JadeSerialPort connection for possible startListening again

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2017	cnwns1	Initial creation
19 April 2018	jlgns1 Bug 38134: PKT - Weight Discrepancy
*/

vars

begin
	self.diagnosticLog(method.qualifiedName &amp; " mySerialPort=" &amp; self.mySerialPort.String &amp; " listeningState=" &amp; self.listeningState.String);

	if self.connectedState() and (self.listeningState = self.Listening or  self.listeningState = self.NotListening) then	//Bug 38134
		self.listeningState := self.PendingClose;
	else
		self.raiseWeightICException(0,"Stop Listening failed.  ConnectedState: " &amp; self.connectedState.String &amp; " Listening State: " &amp; self.listeningState.String);
	endif;
epilog

end;</source>
    </JadeMethod>
</Class>
