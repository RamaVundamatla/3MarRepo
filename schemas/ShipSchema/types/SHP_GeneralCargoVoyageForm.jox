    <JadeMethod name="txtDate_lostFocus" id="f4a47d23-2fe3-4287-927c-09b5d28239e7">
        <controlMethod name="CMUI_DateMask::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtDate_lostFocus(editMask: JadeEditMask input) updating;
//----------------------------------------------------------------
//	Created:	18 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	now,
	dateTime : TimeStamp;
begin
	now := self.systemToLocalTime(app.actualTimeServer);// 17 June 2016	cnwns1	TFS 488 - Multi Timezone Support


	dateTime.setDate(txtDate.getDate());
	dateTime.setTime(self.txtTime.getTime());
	if self.chkRetroSpec.value and dateTime &gt; now then
		app.msgBox(app.getErrorString(RetrospectiveOperations), 'Retrospective DateTime', MsgBox_Stop_Icon + MsgBox_OK_Only);
		self.txtDate.setFocus();
		return;
	endif;		
	self.doRetrospective(dateTime);
end;</source>
        <Parameter name="editMask" type="JadeEditMask" usage="input"/>
    </JadeMethod>
