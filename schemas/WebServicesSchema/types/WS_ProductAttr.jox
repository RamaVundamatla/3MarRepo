<Class name="WS_ProductAttr" id="44ef2071-fdd2-46de-8db7-188c3a121345">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>A class to represent product attributes eg length, height and adds the associated viewable and values</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="isViewable" id="f42c5ad2-7729-42ad-8449-755b9868e539">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="name" id="23ec2b64-6889-40f3-a817-027d26137035">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="aa3110cf-c276-4c6d-9878-52312d52edb7">
        <updating/>
        <source>setProxyFromObject(_object: CM_ProductAttr) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2023	navcs2	Defect 58048: MTN - Mobile Apps cargo damage repair details adding for cargo dimensions issue

*/

vars

begin
	inheritMethod(_object);

	if _object.isViewable &lt;&gt; null then
		self.isViewable := _object.isViewable;
	endif;
	if _object.name &lt;&gt; null then
		self.name		:= _object.name;
	endif;
epilog

end;</source>
        <Parameter name="_object" type="CM_ProductAttr"/>
    </JadeMethod>
</Class>
