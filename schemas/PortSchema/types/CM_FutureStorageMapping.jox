    <JadeMethod name="getBank" id="a1542f6c-f8db-470e-aebc-28c404b49e1c">
        <source>getBank() : CM_Bank;
/*
Purpose:			
Date		Who		Reason
21 May 2015	cnwab1	Initial creation
*/

vars

begin
	if self.myStorageGroup &lt;&gt; null then
		return self.myStorageGroup.getBank();
	endif;
	
	return null;
		
epilog

end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="15fec5db-4964-4853-a608-0264dea68c13">
        <source>initialise();
/*
Purpose:			
Date		Who		Reason
21 May 2015	cnwab1	Initial creation
*/

vars
	bank	: CM_Bank;
	ct : CM_CalculationType;
	pxyqm, qm : CM_QuantityMap;
	pxyqrm, qrm : CM_QuantityRangeMap;
	ild : CM_InvoiceLineDesc;
	mapType	: CM_TranMapInvoiceLineGroupType;
	pxyMapping		: CM_TranMapInvoiceLineMapping;
begin
// NO LONGER USED	ild := self.myInvoiceLineType;
	
	if ild &lt;&gt; null then
		ct := ild.myCalculationType;
	endif;
		
	create pxyqm transient;
	pxyqm.setProxy(null, false, CM_QuantityMap.MapType_Single, ct, self);
	
	create qm;
	qm.setForUpdate(pxyqm);
	
	create pxyqrm transient;
	pxyqrm.setProxy(qm, 0, CM_QuantityRangeMap.MAX_RANGE.Integer, TranMapInvLineGroupTypeAll);
	
	create qrm;
	qrm.setForCreate(pxyqrm);
	
	if ild &lt;&gt; null then
		// TFS 40620 pxyqrm.allInvoiceLineMaps.add(ild);
		// 37434 create CM_TranMapInvoiceLineMapping as well
		create pxyMapping transient;
		bank := self.getBank();
		if bank &lt;&gt; null then
			mapType := bank.getInvLineGroupAll();
		endif;
		pxyMapping.update(CM_QuantityRangeMap.DEFAULT_INVOICELINE_KEY, ild, pxyqrm, mapType, null, null, null, null, null);
		qrm.setForUpdate(pxyqrm);
	endif;

epilog
	delete pxyqm;
	delete pxyqrm;
	if app.isValidObject(pxyMapping) then		// 11/07/2016 cnwmh5 - if has ild causes error 4
		delete pxyMapping;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="06fd7b95-ae4a-4e68-8943-91b21a0faf71">
        <updating/>
        <source>setForCreate(_proxyFutureStorageMapping : CM_FutureStorageMapping; _passport : CM_Passport input) updating;
// 28 May 2013	cnwjre1	CCMS DPH 2278 Storage Billing by Teminal Area
begin
	_proxyFutureStorageMapping.raiseExceptionIfNotTransient(method);

	self.setForUpdate(_proxyFutureStorageMapping);
//	set any properties which are only to be done from create, not update
end;</source>
        <Parameter name="_proxyFutureStorageMapping" type="CM_FutureStorageMapping"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="2e088eed-f64f-4096-90e0-e3037c21d6d5">
        <updating/>
        <source>setForUpdate(_proxyFutureStorageMapping : CM_FutureStorageMapping) updating;
// 28 May 2013	cnwjre1	CCMS DPH 2278 Storage Billing by Teminal Area
begin
	// member key dict property first
	self.myStorageGroup := _proxyFutureStorageMapping.myStorageGroup;
	
// PAR 36275	self.myInvoiceLineType := _proxyFutureStorageMapping.myInvoiceLineType;
	self.myQuantityMap := _proxyFutureStorageMapping.myQuantityMap;
	//self.myStorageDetail := _proxyFutureStorageMapping.myStorageDetail;
	self.setStorageDetail(_proxyFutureStorageMapping.myStorageDetail); //19 May 2016	NDL TFS 1981
end;</source>
        <Parameter name="_proxyFutureStorageMapping" type="CM_FutureStorageMapping"/>
    </JadeMethod>
