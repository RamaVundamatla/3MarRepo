    <JadeMethod name="translateForm" id="b81c1b85-f85f-422b-96a0-c8f9f52764ff">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 23 September 2021 10:46:33.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0024491, locale);
	btnCancel.translateBubbleHelp(Xlat_0024492, locale);
	btnCancel.translateCaption(Xlat_0024493, locale);
	btnClear.translateBubbleHelp(Xlat_0024494, locale);
	btnClear.translateCaption(Xlat_0024495, locale);
	btnGetWeight.translateCaption(Xlat_0024496, locale);
	btnRefresh.translateBubbleHelp(Xlat_0024497, locale);
	btnSave.translateBubbleHelp(Xlat_0024498, locale);
	btnSave.translateCaption(Xlat_0024499, locale);
	chkReceiptReq.translateCaption(Xlat_0024500, locale);
	lblCargoWeightCap.translateCaption(Xlat_0024501, locale);
	lblGate.translateCaption(Xlat_0024502, locale);
	lblGateLane.translateCaption(Xlat_0024503, locale);
	lblGatePrinter.translateCaption(Xlat_0024504, locale);
	lblRegno.translateCaption(Xlat_0024505, locale);
	lblSearchDays.translateCaption(Xlat_0024506, locale);
	lblWeibridge.translateCaption(Xlat_0024507, locale);
	lblWeighbridgeMessage.translateCaption(Xlat_0024508, locale);
	lblWgtOUT.translateCaption(Xlat_0024509, locale);
	mnuDeleteCurrentEntry.translateCaption(Xlat_0024510, locale);
	mnuInspectObj.translateCaption(Xlat_0024511, locale);
	mnuTableContext.translateCaption(Xlat_0024512, locale);
end;</source>
    </JadeMethod>
