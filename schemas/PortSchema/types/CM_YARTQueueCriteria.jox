<Class name="CM_YARTQueueCriteria" id="5811cf22-911a-4153-ac8f-3f596b490752">
    <superclass name="CM_YACriteria"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <ExplicitInverseRef name="myQueue" id="1db1580d-3f5a-494a-8fd7-056f431d3658">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_RadioTelemetryQueue"/>
        <access>readonly</access>
        <Inverse name="CM_RadioTelemetryQueue::allCriteria"/>
    </ExplicitInverseRef>
    <JadeMethod name="pxyCreateUpdateProxy" id="548b1dd2-db8f-4631-a5b8-5cf2157239c0">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 October 2025		jlizm1	Initial creation MTN 35861 RTQueue configuration - cargo attribute criteria

*/

vars
	proxyObj		: SelfType;
	completedOK		: Boolean;
	
begin

	proxyObj := inheritMethod();
	proxyObj.myQueue := self.myQueue;

	completedOK := true;
	return proxyObj;

epilog
	if not completedOK then
		delete proxyObj;
	endif;
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="6e27fd14-eed0-405c-ab6c-71bd42612209">
        <updating/>
        <source>setForCreate(pProxyObj: SelfType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 October 2025		jlizm1	Initial creation MTN 35861 RTQueue configuration - cargo attribute criteria

*/

vars

begin
	self.setForUpdate(pProxyObj);
	
	self.myQueue := pProxyObj.myQueue;

epilog

end;</source>
        <Parameter name="pProxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setMyQueue" id="b7091022-67bc-4b38-b0aa-e720cfc13d3a">
        <updating/>
        <source>setMyQueue(_queue : CM_RadioTelemetryQueue) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 October 2025		jlizm1	Initial creation MTN 35861 RTQueue configuration - cargo attribute criteria

*/

vars

begin
	self.myQueue := _queue;
	
epilog

end;</source>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue"/>
    </JadeMethod>
</Class>
