    <JadeMethod name="delete" id="8283a523-5d3c-4488-87ed-433dcef04621">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 Oct 2022		navlw1	TFS 54812: EUP - WMS - Damage REST Objects and Requests

*/

vars

begin
	delete self.myDamageCode;
	delete self.myDamagePosition;
	delete self.myDamageSeverity;
	delete self.myDamagePlace;
	delete self.myDamageReason;
	delete self.myDamageParty;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="56c705dc-0197-4c98-ab8d-f39c209a9eb8">
        <updating/>
        <source>setProxyFromObject(_object: CM_DamageInstance) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 Oct 2022		navlw1 	TFS 54812: EUP - WMS - Damage Extra Details

*/

vars

begin

	inheritMethod(_object);
	
	if _object.myDamageSeverity &lt;&gt; null then
		create self.myDamageSeverity transient;
		self.myDamageSeverity.setProxyFromObject(_object.myDamageSeverity);
	endif;
	
	if _object.myDamagePosition &lt;&gt; null then
		create self.myDamagePosition transient;
		self.myDamagePosition.setProxyFromObject(_object.myDamagePosition);
	endif;
	if _object.myDamageDefinition &lt;&gt; null then
		create self.myDamageCode transient;
		self.myDamageCode.setProxyFromObject(_object.myDamageDefinition);
	endif;
	if _object.myDamagePlace &lt;&gt; null then
		create self.myDamagePlace transient;
		self.myDamagePlace.setProxyFromObject(_object.myDamagePlace);
	endif;
	if _object.myDamageReason &lt;&gt; null then
		create self.myDamageReason transient;
		self.myDamageReason.setProxyFromObject(_object.myDamageReason);
	endif;
	if _object.myDamageParty &lt;&gt; null then
		create self.myDamageParty transient;
		self.myDamageParty.setProxyFromObject(_object.myDamageParty);
	endif;
	
	self.damageStatus := _object.status;
	self.measurementValue := _object.damageSize;
	self.isRepaired := _object.repaired;
	self.isNewDamage := _object.isNewDamage;
	self.quantity := _object.quantity;
	self.damageDateTime := _object.damageDateTime.asStringForWebInterface;        
	self.remarks := _object.remarks;
epilog

end;</source>
        <Parameter name="_object" type="CM_DamageInstance"/>
    </JadeMethod>
</Class>
