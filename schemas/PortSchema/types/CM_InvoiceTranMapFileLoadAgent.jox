        <source>getCommodityDetails(_commodity : String; _default : Boolean output; _commodityObj : CM_Commodity output) updating, protected;

vars
	commodityObj : CM_Commodity;
begin
	if _commodity = CM_FinancialObject.Extract_Default then
		_default := true;
	else
		commodityObj := myRoot.allCommodities[_commodity];
		if commodityObj = null then
			self.validationError("Invalid commodity", _commodity);
		else
			_commodityObj := commodityObj;
		endif;
	endif;

end;
</source>
        <access>protected</access>
        <Parameter name="_commodity" type="String"/>
