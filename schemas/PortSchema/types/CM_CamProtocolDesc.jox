    <JadeMethod name="getXlatedForeignCode" id="40b4e49e-0bc0-43a7-a266-d012768d8e31">
        <source>getXlatedForeignCode(_operatorCode : String; _code : String io; _codeType : Integer; _terminal: CM_Terminal) : String;
// getForeignCode

// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
//												  - use CM_Operator.getXlationForeignCode instead of CM_OperatorTerminal.getXlationForeignCode
vars
	operator 		: CM_Operator;
	foreignCode 	: String;
	matchFound 		: Boolean;
begin
	if _code.trimBlanks &lt;&gt; null then
		operator := app.myRoot.allOperators[_operatorCode];
		
		if operator &lt;&gt; null then
			foreignCode := operator.getXlationForeignCode (_code, _codeType, matchFound);	// par 31259

		else //par15042 oct 2007 cnwrs1
			foreignCode := _code.trimBlanks;
		endif;
	endif;
	
	return foreignCode;
end;</source>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_code" type="String" usage="io"/>
        <Parameter name="_codeType" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXlatedVesselCode" id="e97bc7b6-d97b-42c4-9343-947e4c3fbb60">
        <source>getXlatedVesselCode(_operatorCode : String; _code : String) : String;
//
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS Cams
//
vars
	operator : CM_Operator;
	foreignCode : String;
	matchFound : Boolean;
	xlatedVessCode : String;
begin
	if _code.trimBlanks &lt;&gt; null then
		operator := app.myRoot.allOperators[_operatorCode];
		
		if operator &lt;&gt; null then
			foreignCode := operator.getXlationForeignCode(_code, XLATION_TYPE_VESSEL_BYOP, matchFound);
			if not matchFound then
				foreignCode := operator.getXlationForeignCode(_code, XLATION_TYPE_VESSEL, matchFound);
			endif;
			if matchFound then 
				xlatedVessCode := foreignCode;
			else
				xlatedVessCode := _code.trimBlanks;
			endif;
		else //par15042 oct 2007 cnwrs1
			xlatedVessCode := _code.trimBlanks;
		endif;
	endif;
	
	return xlatedVessCode;
end;
</source>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_code" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
