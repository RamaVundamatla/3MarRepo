    <JadeMethod name="setupItemTable" id="bfecef9a-af36-4110-aafa-32c698b36d34">
        <source>setupItemTable(tbl : CM_MobTable input);
/*
	Created on 10 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	intColumns 		: Integer;
	strHeader 		: String;

begin		
	self.getTableSettings(intColumns, strHeader);
	//20/05/2009 cnwdz2 ccms1801
	tbl.selectMode := tbl.SelectMode_WholeRows;//SelectMode_CurrentRow; 
	tbl.multiSelect := true;
	
	tbl.columns := intColumns;
	tbl.rows := 0;
	tbl.addItem(strHeader);
	tbl.fixedRows := 1;
	tbl.defaultRowHeight := 30;
	tbl.accessRow(1);
	//tbl.accessedRow.fontSize := 12;
	//tbl.accessedRow.fontBold := true;
	tbl.accessedRow.height := 30;
	tbl.gridLines := true;
	tbl.gridColor := Black;
	tbl.setUseHighlightColours(false);
	tbl.alignment := Table.Alignment_Center_Middle;
	tbl.fixed3D := false;
	tbl.setFixedColours();
	tbl.height := tbl.height - 34;
end;</source>
        <Parameter name="tbl" type="CM_MobTable" usage="input"/>
    </JadeMethod>
