    <JadeMethod name="setColorsFromController" id="603fa479-8d40-4ae8-bee3-99d77cd81f6a">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 06/11/2012	cnwcs5	par 39475 - removing location restrictions
vars
	colour 	: Integer;
	sdf		: CMUI_ScrollableDrawingFrame;
begin
	inheritMethod(_colorControl);
	
	colour := self.backColor;
	sdf		:= self.mySDF;
	
	self.fldTop.backColor 				:= colour;
	self.sptThumbEdit.backColor		 	:= colour;
	self.frmGridArea.backColor 			:= colour;
	sdf.backColor 						:= colour;
	sdf.myDrawingFrame.backColor 		:= colour;
	sdf.borderStyle 					:= Frame.BorderStyle_None;
	sdf.myDrawingFrame.borderStyle 		:= Frame.BorderStyle_None;
	sdf.myTopLeftFillerFrame.backColor 	:= colour;
	sdf.myHLabels.backColor 			:= colour;
	sdf.myVLabels.backColor 			:= colour;
	

	self.shtRestrictData.backColor := colour;

	self.setColorsForEntryTable(self.tblOther);
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="d92042ae-7095-40c9-bab3-cec2bc9a878f">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 06/11/2012	cnwcs5	par 30475 - remove references to locatoin restrictions
// 23/11/2016	cnwdap1	TFS 2844 STWR Hazardous Details Enhancements
// ---------------------------------------------------------------------------

vars
	theArea 	: YRD_PadArea;
	areaMode 	: Integer;
	doCancel 	: Boolean;
begin

	self.tblData.enabled 			:= false;
	self.frmGridArea.enabled 		:= false;
	self.cmbTermAreas.enabled 		:= false;
	self.lstRestrictions.enabled 	:= false;
	
	self.doMenuHeightsHide(true, false);

	theArea 	:= self.frmGridArea.myGridArea.YRD_PadArea;
	areaMode 	:=  self.theAreaMode;

	if self.mode = Mode_Update then
		self.myProxyTerminalArea := app.createUpdateProxy(self.myCurrentTerminalArea).CM_TerminalArea;// PAR 17049
		
		if areaMode = YRD_PadArea.AreaMode_SubBlock then
			self.doBtnSubEdit();
		elseif areaMode = YRD_PadArea.AreaMode_Height then
			self.doBtnHeightEdit();
		
		elseif areaMode = YRD_PadArea.AreaMode_Labour then
			self.doBtnLabourEdit();
		
		elseif areaMode = YRD_PadArea.AreaMode_TermSubArea then 
			self.doBtnTermSubAreaEdit();
		
		elseif areaMode = YRD_PadArea.AreaMode_DoorDirection then
			self.doBtnDoorDirectionRuleEdit();
			
		elseif areaMode = YRD_PadArea.AreaMode_Hazardous then					// TFS 2844
			self.doBtnHazardsEdit();											// TFS 2844
		endif;	
	else
		if theArea &lt;&gt; null then // Block Stacks do not have a drawing frame
			theArea.allSelectedPoints.clear;
		endif;
		if areaMode = YRD_PadArea.AreaMode_SubBlock then
			self.doBtnSubAdd();
		
		elseif areaMode = YRD_PadArea.AreaMode_Height then
			self.doBtnHeightEdit();
		
		elseif areaMode = YRD_PadArea.AreaMode_Labour then
			self.doBtnLabourAdd();
				
		elseif areaMode = YRD_PadArea.AreaMode_TermSubArea then 
			self.doBtnTermSubAreaAdd();
		
		elseif areaMode = YRD_PadArea.AreaMode_DoorDirection then
			self.doBtnDoorDirectionRuleAdd();
			
		elseif areaMode = YRD_PadArea.AreaMode_Hazardous then					// TFS 2844
			self.doBtnHazardsAdd();												// TFS 2844
			
		endif;
	endif;
	
	self.tblOther.setFocus();
	self.fldTop.initSheetBackColors();
epilog
	if self.mode = Mode_Update and self.myProxyTerminalArea = null then // PAR 17049
		self.zDoCancel(); // PAR 17049
		return;// PAR 17049
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="b610cea3-fef4-4e87-bd15-a6801d63e33d">
        <updating/>
        <source>setControlsForView() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/11/2012	cnwcs5		par 30475 - removing location restricitons
// 31/01/2017 cnwrh7		TFS	3212	Hazardous location shows sub area colours on the Location Maintenance screen
// ---------------------------------------------------------------------------

vars
	theArea : YRD_PadArea;
begin

	inheritMethod();
	
	delete self.myProxyTerminalArea;// PAR 17049
	
	
	self.doEnableControls(false);
	
	self.frmGridArea.enabled 		:= false;
	self.cmbTermAreas.enabled 		:= true;
	self.lstRestrictions.enabled 	:= true;
	
	self.tblOther.clearAllSelected();
	self.mulNotifyEmails.setAvailable( null, true ); // TFS 2198
	self.mulNotifyEmails.setSelected( null );
	
	theArea := self.frmGridArea.myGridArea.YRD_PadArea;
	
	if theArea &lt;&gt; null then
		theArea.allSelectedPoints.clear;
		self.sptThumbEditShowLeftControll( theArea );

		if theArea.areaMode = YRD_PadArea.AreaMode_Height then
			self.myCurrentObject := self.myCurrentTerminalArea; 
			
			self.sptThumbEdit.hideLeftControl(true);
			
			self.btnNewTV.enabled := false;
		endif;
	endif;
	
	if self.myCurrentTerminalArea &lt;&gt; null then
		self.caption := self.myCurrentTerminalArea.id &amp; " Locations";
		
		//08 July 2015	NDL	Par 36588
		self.mulNotifyEmails.multiSelect := ListBox.MultiSelect_Simple;
		self.mulNotifyEmails.formDisplayEntryMethodName := YRD_LocationMaintForm::displayEmailAddress.name;
		self.mulNotifyEmails.availableHeading := app.getErrorString(Available_email_addresses);
		self.mulNotifyEmails.selectedHeading :=  app.getErrorString(Selected_email_addresses);
		self.mulNotifyEmails.caption := app.getErrorString(Notify_adddeleteexpiry);
		self.mulNotifyEmails.myBaseForm	:= self;
		self.mulNotifyEmails.mySelectedListBox.sorted := true;
		
		/* TFS 2198 - REMOVED SETTING EMAIL, WASTE OF TIME
		
		self.mulNotifyEmails.setAvailable(app.myRoot.allEmailAddressesByAddress, true);
		if self.myProxyLabourRestriction &lt;&gt; null then
			self.mulNotifyEmails.setSelected( self.myProxyLabourRestriction.allNotifyEmailEntities );
		elseif self.myCurrentLabourRestriction &lt;&gt; null then
			self.mulNotifyEmails.setSelected( self.myCurrentLabourRestriction.allNotifyEmailEntities );
		else
			self.mulNotifyEmails.setSelected( null );
		endif;
		*/

		//self.grpNotifyEmails.visible := true;														//-TFS3212	not visialbe in here but in AreaMode_Labour
		self.tblOther.hideRowByName(ETRow_NotifyOnExpiry, false);

		if self.myCurrentTerminalArea.isRestrictionBlockStack() then
			self.mySDF.visible := false;
		else
			self.mySDF.visible := true;
		endif;
	endif;
	
	
	

end;</source>
    </JadeMethod>
    <JadeMethod name="setInitializeWithObject" id="3579a251-ac98-4f23-9d87-631a36848c33">
        <updating/>
        <source>setInitializeWithObject(_anArea : CM_TerminalArea; _areaMode : Integer; _initObject : CM_Object;_flipH, _flipV : Boolean) updating;
//----------------------------------------------------------------
//	Recreated:	16 October 2003	by Jason Chapman  (cnwjc2)
//	Mysteriously went missing
//----------------------------------------------------------------
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
// ---------------------------------------------------------------------------
// 06/11/2012	cnwcs5	par 30475 - removed referenecs to location restricitons
// 22/11/2016	cnwdap1	TFS 2844 STWR Hazardous Details Enhancements
vars

begin
	self.myCurrentObject 			:= _anArea;
	self.myCurrentTerminalArea 		:= _anArea;
	self.amInitialisingWithObject 	:= true;
	self.useTblData 				:= true;
	self.theAreaMode 				:= _areaMode;
	self.xmlFlipH 					:= _flipH;
	self.xmlFlipV 					:= _flipV;
	
	if _initObject &lt;&gt; null then
		if _initObject.isKindOf(CM_BlockStack) then
			self.myCurrentSubBlockStack := _initObject.CM_BlockStack;
		
		elseif _initObject.isKindOf(CM_LabourRestriction) then
			self.myCurrentLabourRestriction := _initObject.CM_LabourRestriction;
				
		elseif _initObject.isKindOf(CM_GridController) then
			self.myInitController := _initObject.CM_GridController;
		
		elseif _initObject.isKindOf(CM_DoorDirectionRule) then
			self.myCurrentDoorDirectionRule := _initObject.CM_DoorDirectionRule;
			
		elseif _initObject.isKindOf(CM_TerminalAreaHazDetails) then						// TFS 2844
			self.myCurrentHazardDetail := _initObject.CM_TerminalAreaHazDetails;		// TFS 2844
			
		endif;
	endif;
end;</source>
        <Parameter name="_anArea" type="CM_TerminalArea"/>
        <Parameter name="_areaMode" type="Integer"/>
        <Parameter name="_initObject" type="CM_Object"/>
        <Parameter name="_flipH" type="Boolean"/>
        <Parameter name="_flipV" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyDataClass" id="d685ed2d-5292-4957-8bb4-c02af63fc77c">
        <updating/>
        <source>setMyDataClass() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Changed On   Changed By  Reason
// --------- 	----------  --------------------------------------------------
// 06/11/2012	cnwcs5		par 30475 - remove references to location restrictions
// 22/11/2016	cnwdap1		TFS 2844 STWR hazardous Details Enhancements
// ---------------------------------------------------------------------------
vars
	areaMode : Integer;
begin
	areaMode :=  self.theAreaMode;
		
	if areaMode = YRD_PadArea.AreaMode_SubBlock then
		self.myDataClass := CM_BlockStack;
		
	elseif areaMode = YRD_PadArea.AreaMode_Height then
		self.myDataClass := CM_TerminalArea;
		
	elseif areaMode = YRD_PadArea.AreaMode_Labour then
		self.myDataClass := CM_LabourRestriction;
		
	elseif areaMode = YRD_PadArea.AreaMode_TermSubArea then
		self.myDataClass := CM_TerminalSubArea;
		
	elseif areaMode = YRD_PadArea.AreaMode_DoorDirection then
		self.myDataClass := CM_DoorDirectionRule;
		
	elseif areaMode = YRD_PadArea.AreaMode_Hazardous then			// TFS 2844
		self.myDataClass := CM_TerminalAreaHazDetails;				// TFS 2844
		
	else
		self.myDataClass := CM_TerminalArea;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setNotifications" id="ce9f25da-07bd-44a2-8bc3-fc56f8885bde">
        <source>setNotifications();
// -------------------------------------------
// Created 30 July 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	
	self.endNotificationForSubscriber(self);
	// ###
	/*if self.myCurrentTerminalArea &lt;&gt; null then
		self.endNotification(self.myCurrentTerminalArea, self.myTerminal.getTerminalEvent(Event_TALocation_Create));
		self.endNotification(self.myCurrentTerminalArea, self.myTerminal.getTerminalEvent(Event_TALocation_Update));
		self.endNotification(self.myCurrentTerminalArea, self.myTerminal.getTerminalEvent(Event_TALocation_Delete));
	endif;*/
		

	if self.myCurrentTerminalArea &lt;&gt; null then
		self.beginNotification(self.myCurrentTerminalArea, self.myTerminal.getTerminalEvent(Event_TALocation_Create), Response_Continuous, null);
		self.beginNotification(self.myCurrentTerminalArea, self.myTerminal.getTerminalEvent(Event_TALocation_Update), Response_Continuous, null);
		self.beginNotification(self.myCurrentTerminalArea, self.myTerminal.getTerminalEvent(Event_TALocation_Delete), Response_Continuous, null);
//		self.beginNotification(self.myCurrentTerminalArea, self.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA), Response_Continuous, null); // PAR 17049 removed
	endif;
			
end;</source>
    </JadeMethod>
    <JadeMethod name="setShtRestrictions" id="8fda6e3d-4005-4c5f-83f7-259dcf3099b0">
        <updating/>
        <source>setShtRestrictions( ) updating, protected;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/11/2012	cnwcs5		par 30475 - remove location restrictios
// ---------------------------------------------------------------------------

vars

	area	: CM_TerminalArea;
	table	: CM_EntryTable;
	
begin
	area := self.myCurrentTerminalArea;
	
	if area &lt;&gt; null then
		table	:= self.tblOther;
	
		table.clearValues;
		self.mulNotifyEmails.setSelected( null );	//08 Jul 2015	NDL	Par 36588
		table.adjustHeight(1000);
		table.optimiseHeadingColumn();
		table.cnEcResizeContents();
		
		self.mulNotifyEmails.multiSelect := ListBox.MultiSelect_Simple;
		self.mulNotifyEmails.formDisplayEntryMethodName := YRD_LocationMaintForm::displayEmailAddress.name;
		self.mulNotifyEmails.availableHeading := app.getErrorString(Available_email_addresses);
		self.mulNotifyEmails.selectedHeading :=  app.getErrorString(Selected_email_addresses);
		self.mulNotifyEmails.caption := app.getErrorString(Notify_adddeleteexpiry);
		self.mulNotifyEmails.myBaseForm	:= self;
		self.mulNotifyEmails.mySelectedListBox.sorted := true;
		self.mulNotifyEmails.cnEcResizeContents();
		self.mulNotifyEmails.readOnly := true;

		//07 July 2015	NDL	Par 36588				
		self.grpNotifyEmails.left := self.tblOther.left;
		self.grpNotifyEmails.height := self.tblOther.height;
		self.grpNotifyEmails.width := self.tblOther.width;
		self.grpNotifyEmails.top := self.tblOther.top + self.tblOther.height + 2;
		self.shtRestrictData.height := self.grpNotifyEmails.top + self.grpNotifyEmails.height + 4;
		self.mulNotifyEmails.cnEcResizeContents;

	endif;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setUpdateDeleteTBButtons" id="ac24ef76-ccae-47b7-b5ec-ec3df11a4e24">
        <updating/>
        <source>setUpdateDeleteTBButtons(_areaMode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theObject : Object;
	isHeader : Boolean;
begin
	self.doMenuHeightsHide(true,false);
	if _areaMode = YRD_PadArea.AreaMode_Height then
		self.btnEditTV.enabled := true;
		self.btnNewTV.enabled := false;
		self.btnDeleteTV.enabled := false;
	else
		theObject :=  self.lstRestrictions.itemObject[self.lstRestrictions.listIndex];
		if theObject &lt;&gt; null then
			isHeader := 	theObject = self.myCurrentTerminalArea; // the headers have the terminal area object on them
			if isHeader then
				self.btnEditTV.enabled := false;
				self.btnNewTV.enabled := true;
				self.btnDeleteTV.enabled := false;
			else
				self.btnEditTV.enabled := true;
				self.btnNewTV.enabled := false;
				self.btnDeleteTV.enabled := true;
			
			endif;
		else
			self.btnEditTV.enabled := false;
			self.btnNewTV.enabled := false;
			self.btnDeleteTV.enabled := false;
		
		endif;
	endif;
end;</source>
        <Parameter name="_areaMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupBtnPens" id="911e2c21-c5fd-42ea-a3d7-49ba5ac239f2">
        <source>setupBtnPens() protected;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	atttDict	: CM_DrawingAttributesByCodeDict;
	drawAttr	: CM_DrawingAttribute;
	ls			: Boolean;
	
begin

	atttDict := app.myRoot.allDrawingAttributes;

	app.cmsBeginLoad(ls);	
	
	drawAttr := atttDict[PicTIUnavail];
	if drawAttr &lt;&gt; null then
		self.btnPenUnavail.setFontFromDrawingAttr(drawAttr);
	endif;
	drawAttr := atttDict[PicTIPowerDamaged];
	if drawAttr &lt;&gt; null then
		self.btnPenPowerDam.setFontFromDrawingAttr(drawAttr);
	endif;
	
	drawAttr := atttDict[PicTIBuilding];
	if drawAttr &lt;&gt; null then
		self.btnPenBuilding.setFontFromDrawingAttr(drawAttr);
	endif;
	
	drawAttr := atttDict[PicTIGap];
	if drawAttr &lt;&gt; null then
		self.btnPenGap.setFontFromDrawingAttr(drawAttr);
	endif;
	
	drawAttr := atttDict[PicTILight];
	if drawAttr &lt;&gt; null then
		self.btnPenLight.setFontFromDrawingAttr(drawAttr);
	endif;
	
	drawAttr := atttDict[PicTIPower];
	if drawAttr &lt;&gt; null then
		self.btnPenPower.setFontFromDrawingAttr(drawAttr);
	endif;
	
	
	drawAttr := atttDict[PicTI1];
	if drawAttr &lt;&gt; null then
		self.btnPenHeight1.setFontFromDrawingAttr(drawAttr);
	endif;
	
	drawAttr := atttDict[PicTI2];
	if drawAttr &lt;&gt; null then
		self.btnPenHeight2.setFontFromDrawingAttr(drawAttr);
	endif;
	
	drawAttr := atttDict[PicTI3];
	if drawAttr &lt;&gt; null then
		self.btnPenHeight3.setFontFromDrawingAttr(drawAttr);
	endif;
	
	drawAttr := atttDict[PicTI4];
	if drawAttr &lt;&gt; null then
		self.btnPenHeight4.setFontFromDrawingAttr(drawAttr);
	endif;
	
	drawAttr := atttDict[PicTI5];
	if drawAttr &lt;&gt; null then
		self.btnPenHeight5.setFontFromDrawingAttr(drawAttr);
	endif;
	
	drawAttr := atttDict[PicTI6];
	if drawAttr &lt;&gt; null then
		self.btnPenHeight6.setFontFromDrawingAttr(drawAttr);
	endif;
	
	drawAttr := atttDict[PicTI7];
	if drawAttr &lt;&gt; null then
		self.btnPenHeight7.setFontFromDrawingAttr(drawAttr);
	endif;
	
	drawAttr := atttDict[PicTI8];
	if drawAttr &lt;&gt; null then
		self.btnPenHeight8.setFontFromDrawingAttr(drawAttr);
	endif;

epilog
	app.cmsEndLoad(ls);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="bb56768a-9109-49fe-a03a-95a419f6788c">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
vars

begin
	inheritMethod();
	self.setupBtnPens();
	self.doMenuHeightsHide(false, false);

	self.btnNewTV.enabled 		:= false;
	self.btnEditTV.enabled 		:= false;
	self.btnDeleteTV.enabled 	:= false;
	self.btnPenHeight1.visible 	:= false;
	self.btnPenHeight2.visible 	:= false;
	self.btnPenHeight3.visible 	:= false;
	self.btnPenHeight4.visible 	:= false;
	self.btnPenHeight5.visible 	:= false;
	self.btnPenHeight6.visible 	:= false;
	self.btnPenHeight7.visible 	:= false;
	self.btnPenHeight8.visible 	:= false;

end;</source>
    </JadeMethod>
    <JadeMethod name="showLegend" id="b910dec9-97e5-46bf-bff3-9f80d788d2c7">
        <source>showLegend();
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theFrame : CMUI_MoveableFrame;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	theFrame := self.frmLegend;
	theFrame.visible := not theFrame.visible;
	
	theFrame.move(10,40,175,300);
	self.btnLegend.top  := 268;
	theFrame.zOrder(1);
	
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="bc4fe171-7cf2-4996-87ea-8f57852489ce">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	termArea	: CM_TerminalArea;
begin

	if obj.isKindOf(CM_TerminalArea) and not obj.isKindOf(CM_SubBlockStack) then
		// not obj.isKindOf(CM_SubBlockStack) added 06/11/05 as if get here with a sub block stack as object 
		// (eg canceling edit of SBS) then SBS was set as myCurrentTerminalArea which caused casting errors in latter code HG
		termArea := obj.CM_TerminalArea;
		self.myCurrentTerminalArea := termArea;
	endif;
	
	self.setNavigatorHeading(self.myCurrentTerminalArea.id.trimBlanks &amp; " Locations");
	self.doResize();
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
