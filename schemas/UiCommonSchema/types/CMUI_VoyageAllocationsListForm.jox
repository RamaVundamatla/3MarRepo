    <JadeMethod name="addToolbarControls" id="f2ca0290-da8e-4a10-810b-5668515bd71d">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     29 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	toolbar			: CMUI_Toolbar;
	showCaptions	: Boolean;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;

	showCaptions := toolbar.showCaptions;

	toolbar.addButton(self.btnPrintTable, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnExportCSV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnDeleteVA, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEraseAlloc, CMUI_Toolbar.Control_Alignment_Left);//cnwas3 ccms 1035
	toolbar.addButton(self.btnDeleteVALL, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSaveProj, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSummCargo, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSummBooking, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
