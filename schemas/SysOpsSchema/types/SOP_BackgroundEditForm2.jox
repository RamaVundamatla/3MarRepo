    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="fcb54dd0-b7d8-4ac5-9abd-262fd16488f1">
        <updating/>
        <source>doBaseFormSave() updating, protected;
// -------------------------------------------
// Created 09 September 2003 by cnwdvb1
// -------------------------------------------
vars
	cntrl : Control;
	index : Integer;
begin

	if self.aMode = SOP_BackgroundForm.Mode_Add then
		if self.doCreateNewManager() then
			self.aIsSavedSuccessfully	:=	true;
			self.unloadForm();
		endif;
		
	elseif self.aMode = SOP_BackgroundForm.Mode_Edit then
		if global.isValidObject(self.aMyBGPObject) and self.aMyBGPObject.isKindOf(BGP_Manager) then
			if self.aMyBGPObject.isRunning then
				app.msgBox('Manager must not be running during edit', 'Edit Manager', MsgBox_OK_Only + MsgBox_Information_Icon);
				self.aIsSavedSuccessfully	:=	true;
				self.unloadForm();
				return;
			endif;
			
			if self.doEditManager() then
				self.aIsSavedSuccessfully	:=	true;
				self.unloadForm();
			endif;
		else
			if self.doEditController() then
				self.aIsSavedSuccessfully	:=	true;
				self.unloadForm();
			endif;
		endif;
	endif;
	
	if self.aIsSavedSuccessfully then
		self.modalResult	:=		MsgBox_Return_OK;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCreateNewManager" id="e8038a88-40b6-416e-862c-1acc38802d85">
        <updating/>
        <source>doCreateNewManager() : Boolean protected, updating;

// cnwdvb1 24 October 2002 

vars
	proxyObj		: CMIF_BGPManagerChildren;
	managerObj		: BGP_Manager;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	create proxyObj transient;
	self.getManagerInfoFromTable(proxyObj);
	
	if proxyObj &lt;&gt; null then	
	
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxCA.trxCreateBGPManager(managerObj, proxyObj, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				return true;
				break;
			else
				theResult := app.showErrorWarningDialog('Error creating BGP Manager', app.myPassport, ErrWarnMode_Add);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;

	endif;
	
	return false;
	
epilog

	delete proxyObj;
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doEditController" id="bd518ac8-2f1f-48f9-87e0-3053120569f6">
        <updating/>
        <source>doEditController() : Boolean protected, updating;

// cnwdvb1 12 November 2002 

vars
	proxyObj		: CMIF_BGPManagerChildren;
	controllerObj	: BGP_Controller;
	userResponse	: Integer;

begin
	controllerObj	:=	self.aMyBGPObject.BGP_Controller;
	create proxyObj transient;
	
	if self.getControllerInfoFromTable(proxyObj) and proxyObj &lt;&gt; null then
		while true do
			app.myTrxUA.trxUpdateBGPControllerSetup(controllerObj, proxyObj, app.myPassport);
			
			if app.myPassport.trxCompletedOK() then
				self.clearErrorWarnings();
				return true;
			else
				userResponse	:=	app.showErrorWarningDialog(	'Error editing BGP Controller',
																app.myPassport,
																ErrWarnMode_CanAckWarnings);
				
				if app.myPassport.noErrors
				and userResponse = IDOK
				then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				
			endif;
			
			break;
		endwhile;
	endif;
	
	return false;
epilog
	delete proxyObj;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doEditManager" id="f8d774d6-6806-4810-8b02-8f96d2422c5c">
        <updating/>
        <source>doEditManager() : Boolean protected, updating;

// cnwdvb1 24 October 2002 

vars
	proxyObj	: CMIF_BGPManagerChildren;
	managerObj	: BGP_Manager;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	managerObj	:=	self.aMyBGPObject.BGP_Manager;
	create proxyObj transient;
	self.getManagerInfoFromTable(proxyObj);	
	
	if proxyObj &lt;&gt; null then
		proxyObj.myManager	:=	self.aMyBGPObject.BGP_Manager;
		
		if app.msgBox('Editing this manager will refresh controller setup. Do you wish to update this manager','Error',MsgBox_Yes_No) = MsgBox_Return_Yes then
			
			//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxUA.trxUpdateBGPManager(managerObj, proxyObj, app.myPassport);
			
				if app.myPassport.trxCompletedOK then
					return true;
				else
					theResult := app.showErrorWarningDialog('Error editing BGP Manager', app.myPassport, ErrWarnMode_Update);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				break;
				
			endwhile;
			
		endif;
	endif;
	
	return false;
epilog
	delete proxyObj;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLoadTable" id="6d12ab22-a44c-42fb-9a0e-8a59a26593e5">
        <updating/>
        <source>doLoadTable() protected, updating;
// -------------------------------------------
// Created 09 September 2003 by cnwdvb1
// -------------------------------------------
//28 Apr 2016	cnwrs1	TFS Push Events Geneva
// 28 Sep 2016	cnwrs1	TFS 2756 PAR38267 allow Cams to run per terminal
// 10 May 2017	cnwrs1	TFS 3518 remove Push Events
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
vars
	fieldFrameObj	: CMUI_FieldFrame;
	allFieldNames	: StringArray;
	fieldName		: String;
	isViewOnly		: Boolean;
	nextTop			: Real;
begin
	self.aAllFieldFrames.clear();
	isViewOnly	:=	(self.aMode = SOP_BackgroundForm.Mode_EditView);
	
	if self.aIsManager then
		if self.aMode = SOP_BackgroundForm.Mode_EditView then
			
		endif;
		
		self.aAllFieldFrames.add(fieldManagerName);
		self.aAllFieldFrames.add(fieldIsServer);
		self.aAllFieldFrames.add(fieldNoRemotes);
		self.aAllFieldFrames.add(fieldNoReports);
		self.aAllFieldFrames.add(fieldNoExtWSrvs);
		self.aAllFieldFrames.add(fieldNoDirect);
		self.aAllFieldFrames.add(fieldNoTcpServer);
		self.aAllFieldFrames.add(fieldNoTcpClient);
		self.aAllFieldFrames.add(fieldIsAutoTimer);
		self.aAllFieldFrames.add(fieldIsFutureTim);	// ****
		self.aAllFieldFrames.add(fieldIsLocStats);
		self.aAllFieldFrames.add(fieldIsLockKeep);
		self.aAllFieldFrames.add(fieldIsRFIDList);
		self.aAllFieldFrames.add(fieldIsChgTrack);
		self.aAllFieldFrames.add(fieldIsBackupJnl);
		self.aAllFieldFrames.add(fieldIsAutoWarn);
		self.aAllFieldFrames.add(fieldMachineName);
		self.aAllFieldFrames.add(fieldIsFatOnly);
		self.aAllFieldFrames.add(fieldIsLocStats);
		self.aAllFieldFrames.add(fieldIsWOSched);
		self.aAllFieldFrames.add(fieldIsCalCheck);	// 02 Nov 2010	NDL	Par 25530
		self.aAllFieldFrames.add(fieldIsVSBookGen);	//15 Apr 2013	NDL	Par 31393
		self.aAllFieldFrames.add(fieldIsDeferred);	//06 Jul 2021	NDL	TFS 51443
		self.setMaxLengths();//par 15302
		self.doPermissions();
	else
		if self.aMyBGPObject.isKindOf(BGP_BackupJournal)
		or self.aMyBGPObject.isKindOf(BGP_CalendarCheckController)	// 02 Nov 2010	NDL	Par 25530
		or self.aMyBGPObject.isKindOf(BGP_ChangeTrackerController) 
		or self.aMyBGPObject.isKindOf(BGP_ExternalWSController)	// 02 Nov 2010	NDL	Par 25530
		or self.aMyBGPObject.isKindOf(BGP_GenericController)
		or self.aMyBGPObject.isKindOf(BGP_LocationStatistics)
		or self.aMyBGPObject.isKindOf(BGP_LockKeeperController)
		or self.aMyBGPObject.isKindOf(BGP_RFIDListenController)	
		or self.aMyBGPObject.isKindOf(BGP_ReportController)
		or self.aMyBGPObject.isKindOf(BGP_TCPClient)
		or self.aMyBGPObject.isKindOf(BGP_AutoTimerController)
		or self.aMyBGPObject.isKindOf(BGP_AutoWarningController)
		or self.aMyBGPObject.isKindOf(BGP_DirectoryController)
		or self.aMyBGPObject.isKindOf(BGP_FutureTimerController)		// ****
		or self.aMyBGPObject.isKindOf(BGP_VehicleBookingSlotCont)	//17 Apr 2013	NDL	Par 31393
		or self.aMyBGPObject.isKindOf(BGP_DeferredChargingController)	//06 Jul 2021	NDL	TFS 51443
		or self.aMyBGPObject.isKindOf(BGP_WorkOrderScheduler)
		or self.aMyBGPObject.isKindOf(BGP_XMLListenController)
		then
			create allFieldNames transient;
			self.aMyBGPObject.getFields(allFieldNames);
			
			foreach fieldName in allFieldNames do
				if fieldName = ETRow_BgpControllerUser then
					self.aAllFieldFrames.add(fieldUser);
				elseif fieldName = ETRow_CellAddress then
					self.aAllFieldFrames.add(fieldCellAddress);
				elseif fieldName = ETRow_CellNumbers then
					self.aAllFieldFrames.add(fieldCellNumbers);
				elseif fieldName = ETRow_LoggingLevel then
					self.aAllFieldFrames.add(fieldLogLevel);
				elseif fieldName = ETRow_RequestClassName then
					if self.aMyBGPObject.isKindOf(BGP_AutoWarningController) then
						self.aAllFieldFrames.add(fieldWarnList);
					else
						self.aAllFieldFrames.add(fieldClassList);
					endif;
				elseif fieldName = ETRow_BgpLogTransactions then
					self.aAllFieldFrames.add(fieldIsLogTrans);
				elseif fieldName = ETRow_BgpDoingKPI then
					self.aAllFieldFrames.add(fieldIsDoingKPI);
				elseif fieldName = ETRow_DefaultPDFPrinter then
					self.aAllFieldFrames.add(fieldPDFPrinter);
				elseif fieldName = ETRow_ExtWebService then
					self.aAllFieldFrames.add(fieldExtWebSrvs);
				elseif fieldName = ETRow_TcpIpPort then
					self.aAllFieldFrames.add(fieldTcpPort);
				elseif fieldName = ETRow_TcpIpServerName then
					self.aAllFieldFrames.add(fieldServerName);
				elseif fieldName = ETRow_TcpIpClientWorkerType then
					self.aAllFieldFrames.add(fieldWorkerType2);
				elseif fieldName = ETRow_BgpTerminal then
					self.aAllFieldFrames.add(fieldTerminal);
				elseif fieldName = ETRow_DirectoryPath then
					self.aAllFieldFrames.add(fieldDirPath);
				elseif fieldName = ETRow_DirectoryPathProcessed then
					self.aAllFieldFrames.add(fieldDirProcess);
				elseif fieldName = ETRow_TimerInterval then
					self.aAllFieldFrames.add(fieldTimInterval);
				elseif fieldName = ETRow_Mask then
					self.aAllFieldFrames.add(fieldMask);
				elseif fieldName = ETRow_BgpTcpIpInterface then
					self.aAllFieldFrames.add(fieldTcpAddress);
				elseif fieldName = ETRow_NumberOfWorkers then
					self.aAllFieldFrames.add(fieldNoWorkers);
				elseif fieldName = ETRow_BgpTagReaders then
					self.aAllFieldFrames.add(self.fieldTagRead);
				elseif fieldName = ETRow_BgpEmailAddresses then	//02 Nov 2010	NDL	Par 25530
					self.aAllFieldFrames.add(self.fieldEmailAdd);
					self.lstEmailAddress.clear();
					self.lstEmailAddress.displayCollection(app.myRoot.allEmailAddressesByAddress, false, 0, null);
				elseif fieldName = ETRow_BgpDaysNotice then	//02 Nov 2010	NDL	Par 25530
					self.aAllFieldFrames.add(self.fieldDaysNotice);
				elseif fieldName = ETRow_TcpipWorkerType then
					self.aAllFieldFrames.add(fieldWorkerType);
				elseif fieldName = ETRow_TemplateKey then
					self.aAllFieldFrames.add(fieldReqHeading);
				elseif fieldName = ETRow_BgpIsServerEx then
					self.aAllFieldFrames.add(self.fieldIsServerEx);
				elseif fieldName = ETRow_BgpCommitFreq then
					self.aAllFieldFrames.add(self.fieldCommitFreq);
				elseif fieldName = ETRow_BgpRetainDays then
					self.aAllFieldFrames.add(self.fieldRetainTrack);
				elseif fieldName = ETRow_TempFileLocation then
					self.aAllFieldFrames.add(self.fieldTempFileLoc);
				elseif fieldName = ETRow_BgpDebug then	//cnwrs1 par 25828 14 Feb 2011
					self.aAllFieldFrames.add(self.fieldIsDebug);
				elseif fieldName = ETRow_BgpMaxTimeForRemoveToRun then	//cnwrs1 par 25828 14 Feb 2011
					self.aAllFieldFrames.add(self.fieldMaxTimeRun);
				endif;
			endforeach;
			self.setMaxLengths();
		else
			app.raiseCMException1(ERR_INVALID_TYPE, self.aMyBGPObject.class.name, "Unexpected Type for BackGround Processor.", null);
		endif;
	endif;
	
	self.fieldTerminal.enabled := true;
	if self.aMyBGPObject.isKindOf(BGP_GenericController) then
		self.aAllFieldFrames.add(fieldTerminal);
		if not self.aMyBGPObject.BGP_GenericController.allRequestClassesToProcess.includes(BGP_CamsRequest.name) then
			self.fieldTerminal.enabled := false;
		endif;
	endif;
	self.aAllFieldFrames.alignFields(self.DEFAULT_LEFT, self.DEFAULT_TOP, self.DEFAULT_WIDTH, isViewOnly);
	self.aAllFieldFrames.doTabOrders(10000);
	fieldFrameObj	:=	self.aAllFieldFrames.last();
	nextTop			:=	fieldFrameObj.top + fieldFrameObj.height;
	
	if nextTop &lt;&gt; 0 then	
		self.height	:=	nextTop + self.DEFAULT_HEIGHT_EXTENSION;
	endif;
epilog
	delete allFieldNames;
end;</source>
        <access>protected</access>
    </JadeMethod>
