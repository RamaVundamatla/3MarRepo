        <source>getVehicleMake():CM_VehicleMake;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2013	cnwndl1	Initial creation	Par 32215

*/

vars
	
	vehMake : CM_VehicleMake;

begin

	if self.make &lt;&gt; null then
		if app &lt;&gt; null and app.myDutyDocRoot &lt;&gt; null then
			vehMake := app.myDutyDocRoot.allVehicleMakes.getAtKey( self.make );
			return vehMake;
		endif;
	endif;
	
	return null;

epilog

end;</source>
