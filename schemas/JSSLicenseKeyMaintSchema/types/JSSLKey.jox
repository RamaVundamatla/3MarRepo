    <JadeMethod name="calculateCheckSum" id="4a756f75-ae9f-4f55-9db3-c65bad9a40f3">
        <source>calculateCheckSum(pRegistrationData:Binary):Integer protected;
// --------------------------------------------------------------------------------
// Created:		16 January 2003 by cnwdad1
//
// Purpose:		Calculates a checksum for the binary registration data to verify
//				that the registration details have not been altered.
//
// Parameters:	pRegistrationData - The binary registration data.
//
// Returns:		The checksum value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	checkSum		: Integer;
	dataLength		: Integer;
	bytePosition	: Integer;
	
begin
	dataLength	:=	pRegistrationData.length();
	
	foreach bytePosition in 5 to dataLength do
		checkSum	:=	checkSum.bitXor(pRegistrationData[bytePosition]);
	endforeach;
epilog
	return checkSum;
end;</source>
        <access>protected</access>
        <Parameter name="pRegistrationData" type="Binary"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clearBit" id="e250baf8-13de-42b2-bae1-0cb8fa7da979">
        <updating/>
        <source>clearBit(pBinaryData:Binary io; pIndex:Integer) updating, protected;
// --------------------------------------------------------------------------------
// Created:		16 January 2003 by cnwdad1
//
// Purpose:		Turns off a bit in the receiver, such as for a bit-mask.
//
// Parameters:	pIndex - The index of the bit to be turned off.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	byteIndex		: Integer;
	byteValue		: Integer;
	bitPointer		: Integer;
	
begin
	if self.isBit(pBinaryData, pIndex) then
		byteIndex	:=	((pIndex - 1) div 8) + 1;
		byteValue	:=	pBinaryData[byteIndex];
		bitPointer	:=	(pIndex mod 8);
		
		if bitPointer = 1 then			// Right-most bit.
			byteValue	:=	byteValue.bitXor(1);
		elseif bitPointer = 2 then
			byteValue	:=	byteValue.bitXor(2);
		elseif bitPointer = 3 then
			byteValue	:=	byteValue.bitXor(4);
		elseif bitPointer = 4 then
			byteValue	:=	byteValue.bitXor(8);
		elseif bitPointer = 5 then
			byteValue	:=	byteValue.bitXor(16);
		elseif bitPointer = 6 then
			byteValue	:=	byteValue.bitXor(32);
		elseif bitPointer = 7 then
			byteValue	:=	byteValue.bitXor(64);
		elseif bitPointer = 0 then		// Left-most bit.
			byteValue	:=	byteValue.bitXor(128);
		endif;
		
		pBinaryData[byteIndex]	:=	byteValue;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pBinaryData" type="Binary" usage="io"/>
        <Parameter name="pIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="convertHexToBinary" id="86ba6b63-d6a3-4169-83b9-4b8467edb9c7">
        <source>convertHexToBinary(pHex:String):Binary protected;
// --------------------------------------------------------------------------------
// Created:		16 January 2003 by cnwdad1
//
// Purpose:		Convert the integer value of the string of hex characters into binary
//				data.  Take the leading hex characters, maximum of 7 to fit within
//				integer max size, or take 0 if first character of string is not hex.
//
// Parameters:	pHex - The hex character to convert to binary.
//
// Returns:		The binary data.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	charIndex			: Integer;
	hexValueOfString	: Integer;
	integerValueOfChar	: Integer;
	maximumLength		: Integer;
	multiplier			: Integer;
	substringChar		: Character;
	workString			: String;

begin
	hexValueOfString	:=	0;
	multiplier			:=	1;
	maximumLength		:=	pHex.length();

	if maximumLength &gt; 7 then
		maximumLength	:=	7;
	endif;

	foreach charIndex in 1 to maximumLength do
		if charIndex &gt;= maximumLength then
			break;
		endif;

		multiplier	:=	multiplier * 16;
	endforeach;

	foreach charIndex in 1 to maximumLength do
		workString			:=	pHex[charIndex:1].toUpper;
		substringChar		:=	workString.Character;
		integerValueOfChar	:=	"0123456789ABCDEF".pos(substringChar, 1);

		if integerValueOfChar &lt;&gt; 0 then
			integerValueOfChar	:=	integerValueOfChar - 1;
			hexValueOfString	:=	hexValueOfString + integerValueOfChar * multiplier;
		else
			charIndex	:=	maximumLength;		// To terminate the loop.
		endif;

		multiplier	:=	multiplier div 16;
	endforeach;
	
	return hexValueOfString.Byte.Binary;// 11/3/16  cnwns1 PAR 36286 unicode version
	//return hexValueOfString.Character.Binary;
end;</source>
        <access>protected</access>
        <Parameter name="pHex" type="String"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="createKeyByte" id="39c3d219-0967-4a8e-9e0c-6ecd51406864">
        <source>createKeyByte():Integer protected;
// --------------------------------------------------------------------------------
// Created:		15 January 2003 by cnwdad1
//
// Purpose:		Creates a key byte used when encrypting the "secret" part of the
//				binary registration data.
//
// Parameters:	None
//
// Returns:		The key byte.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	keyByte		: Integer;
	
begin
	keyByte	:=	app.random(255);
epilog
	return keyByte;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="decompose" id="4f487f09-25ae-404f-8d34-e9d87d916fa8">
        <updating/>
        <source>decompose(pCustomerName:String; pLicenseKey:String):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		16 January 2003 by cnwdad1
//
// Purpose:		Installs the Customer's Product license key.
//
// Parameters:	pCustomerName - The name of the Customer.
//				pLicenseKey - The product license key.
//
// Returns:		True if the license was successfull installed, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	registrationData	: Binary;
	testCustomerHash	: Integer;
	currentDate			: Date;
	
	// Serial checksum and key.
	
	checkSum			: Integer;		// Bytes 1-4
	keyByte				: Integer;		// Bytes 5-8
	
	// Encrypted details.
	
	productCodeSize		: String[2];	// Bytes 9-10
	productCode			: String[10];	// Bytes 11-20
	customerHash		: Integer;		// Bytes 21-24
	expiryDate			: Date;			// Bytes 25-28
	bitMask				: Binary;		// Bytes 29-... (depending upon the number of options)
	
begin
	// Convert the hex key into a binary, and unencrypt the data.
	
	registrationData	:=	self.doHexToBinary(pLicenseKey);
	self.xorRegistrationData(registrationData);
	
	// Validate the checksum to ensure that the license hasn't been tampered with.
	
	if not self.validateCheckSum(registrationData) then
		JSSLKException.raise_(99999, $INVALID_CHECKSUM);
		return false;
	endif;
	
	// Extract the license key information from the registration data.
	
	checkSum		:=	registrationData[1:4].Integer;
	keyByte			:=	registrationData[5:4].Integer;
	// 11/3/16  cnwns1 PAR 36286 unicode version
	if app.isUnicode then	
		productCodeSize	:=	registrationData[9:2].ansiToUnicode().String;
		productCode		:=	registrationData[11:(productCodeSize.Integer)].ansiToUnicode().String;
	else
		productCodeSize	:=	registrationData[9:2].String;
		productCode		:=	registrationData[11:(productCodeSize.Integer)].String;
	endif;
	// 11/3/16  cnwns1 PAR 36286 unicode version
	customerHash	:=	registrationData[21:4].Integer;
	expiryDate		:=	registrationData[25:4].Date;
	bitMask			:=	registrationData[29:end];
	
	// Compare the customer name hash to ensure that the license is for the correct customer.
	
	testCustomerHash	:=	self.hashCustomer(pCustomerName);
	
	if customerHash &lt;&gt; testCustomerHash then
		JSSLKException.raise_(99999, $INVALID_CUSTOMER_NAME(pCustomerName));
		return false;
	endif;
	
	// Check the expiry date of the license key.
	
	currentDate	:=	app.actualTimeServer().date();
	
	if currentDate &gt; expiryDate then
		JSSLKException.raise_(99999, $LICENSE_EXPIRED_ON(expiryDate.display()));
		return false;
	endif;
	
	// All is well, so store the license key information on the receiver.
	
	self.data1	:=	pLicenseKey;
	self.data2	:=	bitMask;
	self.data3	:=	expiryDate.Binary;
	self.data4	:=	productCode.Binary;

	return true;
end;</source>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pLicenseKey" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="decomposeSubs" id="ed40a1e3-aa5c-43f1-9dae-8f5042e46f39">
        <updating/>
        <source>decomposeSubs(pCustomerName:String; pLicenseKey:String):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 June 2020	jlgndl1	Initial creation	TFS 49586

*/

vars
	registrationData	: Binary;
	testCustomerHash	: Integer;
	currentDate			: Date;
	
	// Serial checksum and key.
	
	checkSum			: Integer;		// Bytes 1-4
	keyByte				: Integer;		// Bytes 5-8
	bitMaskLength 		: Integer;		// Bytes 9-12
	
	// Encrypted details.
	
	productCodeSize		: String[2];	// Bytes 13-10
	productCode			: String[10];	// Bytes 15-20
	customerHash		: Integer;		// Bytes 25-24
	expiryDate			: Date;			// Bytes 29-28
	bitMask				: Binary;		// Bytes 33-... (depending upon bitMaskLength)
	datesArray			: Binary;		// Bytes ...-end;
	
begin
	// Convert the hex key into a binary, and unencrypt the data.
	
	registrationData	:=	self.doHexToBinary(pLicenseKey);
	self.xorRegistrationData(registrationData);
	
	// Validate the checksum to ensure that the license hasn't been tampered with.
	
	if not self.validateCheckSum(registrationData) then
		JSSLKException.raise_(99999, $INVALID_CHECKSUM);
		return false;
	endif;
	
	// Extract the license key information from the registration data.
	
	checkSum		:=	registrationData[1:4].Integer;
	keyByte			:=	registrationData[5:4].Integer;
	bitMaskLength	:=	registrationData[9:4].Integer;
	if app.isUnicode then	
		productCodeSize	:=	registrationData[13:2].ansiToUnicode().String;
		productCode		:=	registrationData[15:(productCodeSize.Integer)].ansiToUnicode().String;
	else
		productCodeSize	:=	registrationData[13:2].String;
		productCode		:=	registrationData[15:(productCodeSize.Integer)].String;
	endif;
	// 11/3/16  cnwns1 PAR 36286 unicode version
	customerHash	:=	registrationData[25:4].Integer;
	expiryDate		:=	registrationData[29:4].Date;
	bitMask			:=	registrationData[33:bitMaskLength];
	datesArray 		:= registrationData[33+bitMaskLength:end];
	
	// Compare the customer name hash to ensure that the license is for the correct customer.
	
	testCustomerHash	:=	self.hashCustomer(pCustomerName);
	
	if customerHash &lt;&gt; testCustomerHash then
		JSSLKException.raise_(99999, $INVALID_CUSTOMER_NAME(pCustomerName));
		return false;
	endif;
	
	// Check the expiry date of the license key.
	
	currentDate	:=	app.actualTimeServer().date();
	
	if currentDate &gt; expiryDate then
		JSSLKException.raise_(99999, $LICENSE_EXPIRED_ON(expiryDate.display()));
		return false;
	endif;
	
	// All is well, so store the license key information on the receiver.
	
	self.data1	:=	pLicenseKey;
	self.data2	:=	bitMask;
	self.data3	:=	expiryDate.Binary;
	self.data4	:=	productCode.Binary;
	self.data5	:=	datesArray;

	return true;
end;</source>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pLicenseKey" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doHexToBinary" id="fd07ccbb-5b53-4ed4-abb2-487086dd5fcc">
        <source>doHexToBinary(pLicenseKey:String):Binary protected;
// --------------------------------------------------------------------------------
// Created:		16 January 2003 by cnwdad1
//
// Purpose:		Converts the hex license key into binary data.
//
// Parameters:	pLicenseKey - The product license key.
//
// Returns:		The binary registration data.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	hexPointer			: Integer;
	stringLength		: Integer;
	hexCharacter		: String;
	registrationData	: Binary;
	
begin
	stringLength	:=	pLicenseKey.length();
	
	foreach hexPointer in 1 to stringLength step 2 do
		hexCharacter		:=	pLicenseKey[hexPointer:2];
		registrationData	:=	registrationData &amp; self.convertHexToBinary(hexCharacter);
	endforeach;
epilog
	return registrationData;
end;</source>
        <access>protected</access>
        <Parameter name="pLicenseKey" type="String"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="generateKey" id="92cad516-e2ed-44de-9603-a882fe3bab25">
        <updating/>
        <source>generateKey(pCustomerName:String; pProductCode:String; pExpiryDate:Date; pAllOptions:BooleanArray):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		15 January 2003 by cnwdad1
//
// Purpose:		Generates a license key using the Customer name, an expiry date,
//				and an array of boolean options.
//
// Parameters:	pCustomerName - The name of the customer.
//				pProductCode - The product's unique code.
//				pExpiryDate - The expiry date of the product license.
//				pAllOptions - An array of boolean options.  The index of each
//					element represents a unique Product Component ID.  The boolean
//					flag itself indicates whether the Customer is licensed for the
//					Component represented by the flag's index number.
//
// Returns:		True if the license key was successfully generated, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	registrationData	: Binary;
	arrayPointer		: Integer;
	productOption		: Boolean;
	maskLength			: Integer;
	
	// Serial checksum and key.
	
	checkSum			: Integer;		// Bytes 1-4
	keyByte				: Integer;		// Bytes 5-8
	
	// Encrypted details.
	
	productCodeSize		: String[2];	// Bytes 9-10
	productCode			: String[10];	// Bytes 11-20
	customerHash		: Integer;		// Bytes 21-24
	expiryDate			: Date;			// Bytes 25-28
	bitMask				: Binary;		// Bytes 29-... (depending upon the number of options)
	
begin
	// Get the relevant product license data.
	
	keyByte			:=	self.createKeyByte();
	customerHash	:=	self.hashCustomer(pCustomerName);
	productCode		:=	pProductCode;
	productCodeSize	:=	productCode.length().String;
	expiryDate		:=	pExpiryDate;
	
	// Assemble the registration data into a binary.
	
	registrationData[5:4]	:=	keyByte.Binary;
	registrationData[9:2]	:=	productCodeSize.asANSI(0);// 11/3/16  cnwns1 PAR 36286 unicode version
	registrationData[11:10]	:=	productCode.asANSI(0);// 11/3/16  cnwns1 PAR 36286 unicode version
	registrationData[21:4]	:=	customerHash.Binary;
	registrationData[25:4]	:=	expiryDate.Binary;
	
	// Build up a bitmask based upon the product components that are granted access.
	
	maskLength			:=	(pAllOptions.size() div 8) + 1;
	bitMask[maskLength]	:=	null;
	arrayPointer		:=	0;
	
	foreach productOption in pAllOptions do
		arrayPointer	:=	arrayPointer + 1;
		
		if productOption then
			self.setBit(bitMask, arrayPointer);
		else
			self.clearBit(bitMask, arrayPointer);
		endif;
	endforeach;
	
	registrationData[29:bitMask.length()]	:=	bitMask;	// Add the bitmask to the registration data binary.
	
	// Calculate the checksum for the license key, then store the data on the receiver.
	
	checkSum				:=	self.calculateCheckSum(registrationData);
	registrationData[1:4]	:=	checkSum.Binary;
	self.xorRegistrationData(registrationData);				// Encrypt the registration data.
	
	self.data1	:=	self.makeRegistrationKey(registrationData);
	self.data2	:=	bitMask;
	self.data3	:=	expiryDate.Binary;
	self.data4	:=	productCode.asANSI(0);// 11/3/16  cnwns1 PAR 36286 unicode version

	return true;
end;</source>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pProductCode" type="String"/>
        <Parameter name="pExpiryDate" type="Date"/>
        <Parameter name="pAllOptions" type="BooleanArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="generateSubsKey" id="049f398a-8a75-4c99-952c-3a8694bd6e3b">
        <updating/>
        <source>generateSubsKey(pCustomerName:String; pProductCode:String; pExpiryDate:Date; pAllOptions:BooleanArray; pAllSubsExpDates : DateArray):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 June 2020	jlgndl1	Initial creation	TFS 49586

*/

vars
	registrationData	: Binary;
	arrayPointer		: Integer;
	productOption		: Boolean;
	maskLength			: Integer;
	date 				: Date;
	dateStr 			: String;
	nextStartPos		: Integer;
	datesArrayLength : Integer;
	
	// Serial checksum and key.
	
	checkSum			: Integer;		// Bytes 1-4
	keyByte				: Integer;		// Bytes 5-8
	bitMaskLength 		: Integer;		// Bytes 9-12
	// Encrypted details.
	
	productCodeSize		: String[2];	// Bytes 13-14
	productCode			: String[10];	// Bytes 15-24
	customerHash		: Integer;		// Bytes 25-28
	expiryDate			: Date;			// Bytes 29-32
	bitMask				: Binary;		// Bytes 33- ( 29 + bitMaskLength) (depending upon the number of options)
	datesArray			: Binary;		// Bytes ...-end;
	
begin
	// Get the relevant product license data.

	keyByte			:=	self.createKeyByte();
	customerHash	:=	self.hashCustomer(pCustomerName);
	productCode		:=	pProductCode;
	productCodeSize	:=	productCode.length().String;
	expiryDate		:=	pExpiryDate;
	
	// Build up a bitmask based upon the product components that are granted access.
	
	maskLength			:=	(pAllOptions.size() div 8) + 1;
	bitMask[maskLength]	:=	null;
	arrayPointer		:=	0;
	
	foreach productOption in pAllOptions do
		arrayPointer	:=	arrayPointer + 1;
		
		if productOption then
			self.setBit(bitMask, arrayPointer);
		else
			self.clearBit(bitMask, arrayPointer);
		endif;
	endforeach;
	
	bitMaskLength := bitMask.length();
	
	//build up a comma delimited string of dates
	arrayPointer := 0;
	foreach date in pAllSubsExpDates do
		arrayPointer	:=	arrayPointer + 1;
		if date.isValid then
			dateStr := dateStr &amp; arrayPointer.padLeadingWith('0',3) &amp; date.format("ddMMyyy");
		endif;
	endforeach;
	//convert string to bunary;
	datesArray := dateStr.Binary;
	datesArrayLength := datesArray.length();
	nextStartPos := 33 + bitMaskLength;
	
	
	// Assemble the registration data into a binary.
	
	registrationData[5:4]	:=	keyByte.Binary;
	registrationData[9:4]	:=	bitMaskLength.Binary;
	registrationData[13:2]	:=	productCodeSize.asANSI(0);// 11/3/16  cnwns1 PAR 36286 unicode version
	registrationData[15:10]	:=	productCode.asANSI(0);// 11/3/16  cnwns1 PAR 36286 unicode version
	registrationData[25:4]	:=	customerHash.Binary;
	registrationData[29:4]	:=	expiryDate.Binary;
	registrationData[33:bitMaskLength]	:=	bitMask;	// Add the bitmask to the registration data binary.
	registrationData[nextStartPos:datesArrayLength] := datesArray;
	
	// Calculate the checksum for the license key, then store the data on the receiver.
	
	checkSum				:=	self.calculateCheckSum(registrationData);
	registrationData[1:4]	:=	checkSum.Binary;
	self.xorRegistrationData(registrationData);				// Encrypt the registration data.
	
	self.data1	:=	self.makeRegistrationKey(registrationData);
	self.data2	:=	bitMask;
	self.data3	:=	expiryDate.Binary;
	self.data4	:=	productCode.asANSI(0);// 11/3/16  cnwns1 PAR 36286 unicode version
	self.data5	:=	datesArray;

	return true;
end;</source>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pProductCode" type="String"/>
        <Parameter name="pExpiryDate" type="Date"/>
        <Parameter name="pAllOptions" type="BooleanArray"/>
        <Parameter name="pAllSubsExpDates" type="DateArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hashCustomer" id="f9a3854a-c6f8-49cc-a215-7fa28238b1a8">
        <source>hashCustomer(pCustomerName:String):Integer protected;
// --------------------------------------------------------------------------------
// Created:		15 January 2003 by cnwdad1
//
// Purpose:		Generate a hash from the Customer's name, for inclusion in the
//				binary registration data, and hence the license key.
//
// Parameters:	pCustomerName - The name of the Customer.
//
// Returns:		The name hash.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	nameHash		: Integer;
	charPosition	: Integer;
	nameLength		: Integer;
	currentChar		: Character;
	
begin
	nameLength	:=	pCustomerName.length();
	
	foreach charPosition in 1 to nameLength do
		currentChar	:=	pCustomerName[charPosition];
		// Multiplying nameHash by 2 rotates all bits to the left, leaving the low-end bit as "0".
		nameHash	:=	(nameHash * 2).bitXor(currentChar.Integer);
	endforeach;
	
	if nameHash &lt; 0 then
		nameHash	:=	nameHash * -1;
	endif;
epilog
	return (nameHash.bitAnd(#FF000000) div #1000000);	// Return the high-byte value of the hash.
end;</source>
        <access>protected</access>
        <Parameter name="pCustomerName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isBit" id="7a9ae72d-020f-4aef-9014-e355f91a601e">
        <source>isBit(pBinaryData:Binary; pIndex:Integer):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		16 January 2003 by cnwdad1
//
// Purpose:		Returns a flag to indicate whether a bit in the receiver is on.
//
// Parameters:	pBinaryData - The binary in which to set the specified bit.
//				pIndex - The index of the bit to check.
//
// Returns:		True if the bit is set, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	byteIndex		: Integer;
	byteValue		: Integer;
	bitPointer		: Integer;
	
begin
	byteIndex	:=	((pIndex - 1) div 8) + 1;
	byteValue	:=	pBinaryData[byteIndex];
	bitPointer	:=	(pIndex mod 8);
	
	if bitPointer = 1 then			// Right-most bit.
		return byteValue.bitAnd(1) &lt;&gt; 0;
	elseif bitPointer = 2 then
		return byteValue.bitAnd(2) &lt;&gt; 0;
	elseif bitPointer = 3 then
		return byteValue.bitAnd(4) &lt;&gt; 0;
	elseif bitPointer = 4 then
		return byteValue.bitAnd(8) &lt;&gt; 0;
	elseif bitPointer = 5 then
		return byteValue.bitAnd(16) &lt;&gt; 0;
	elseif bitPointer = 6 then
		return byteValue.bitAnd(32) &lt;&gt; 0;
	elseif bitPointer = 7 then
		return byteValue.bitAnd(64) &lt;&gt; 0;
	elseif bitPointer = 0 then		// Left-most bit.
		return byteValue.bitAnd(128) &lt;&gt; 0;
	endif;
	
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="pBinaryData" type="Binary"/>
        <Parameter name="pIndex" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="makeRegistrationKey" id="7f7bb57b-16d6-49e9-8552-db2c790de90f">
        <source>makeRegistrationKey(pRegistrationData:Binary):String protected;
// --------------------------------------------------------------------------------
// Created:		16 January 2003 by cnwdad1
//
// Purpose:		Converts the binary registration data into a string of hex codes.
//
// Parameters:	pRegistrationData - The binary registration data.
//
// Returns:		The string of hex codes.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	registrationKey	: String;
	bytePosition	: Integer;
	dataLength		: Integer;
	
begin
	dataLength	:=	pRegistrationData.length();
	
	foreach bytePosition in 1 to dataLength do
		registrationKey	:=	registrationKey &amp; pRegistrationData[bytePosition].Character.toHex();
	endforeach;
epilog
	return registrationKey;
end;</source>
        <access>protected</access>
        <Parameter name="pRegistrationData" type="Binary"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setBit" id="7993f9ae-b4aa-41fe-86b5-36311ec36aab">
        <source>setBit(pBinaryData:Binary io; pIndex:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		16 January 2003 by cnwdad1
//
// Purpose:		Turns on a bit in the receiver, such as for a bit-mask.
//
// Parameters:	pIndex - The index of the bit to be set.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	byteIndex		: Integer;
	byteValue		: Integer;
	bitPointer		: Integer;
	
begin
	byteIndex	:=	((pIndex - 1) div 8) + 1;
	byteValue	:=	pBinaryData[byteIndex];
	bitPointer	:=	(pIndex mod 8);
	
	if bitPointer = 1 then			// Right-most bit.
		byteValue	:=	byteValue.bitOr(1);
	elseif bitPointer = 2 then
		byteValue	:=	byteValue.bitOr(2);
	elseif bitPointer = 3 then
		byteValue	:=	byteValue.bitOr(4);
	elseif bitPointer = 4 then
		byteValue	:=	byteValue.bitOr(8);
	elseif bitPointer = 5 then
		byteValue	:=	byteValue.bitOr(16);
	elseif bitPointer = 6 then
		byteValue	:=	byteValue.bitOr(32);
	elseif bitPointer = 7 then
		byteValue	:=	byteValue.bitOr(64);
	elseif bitPointer = 0 then		// Left-most bit.
		byteValue	:=	byteValue.bitOr(128);
	endif;
	
	pBinaryData[byteIndex]	:=	byteValue;
end;</source>
        <access>protected</access>
        <Parameter name="pBinaryData" type="Binary" usage="io"/>
        <Parameter name="pIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateCheckSum" id="0b77981c-5bee-4e43-aade-dabf049db2a7">
        <source>validateCheckSum(pRegistrationData:Binary):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		16 January 2003 by cnwdad1
//
// Purpose:		Validates the binary registration data by comparing a checksum of
//				it against the checksum stored in the registration data itself, to
//				determine whether the registration details have been altered.
//
// Parameters:	pRegistrationData - The binary registration data.
//
// Returns:		True if the checksum is successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	checkSum	: Integer;
	
begin
	checkSum	:=	self.calculateCheckSum(pRegistrationData);
	
	if checkSum = pRegistrationData[1:4].Integer then
		return true;
	else
		return false;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pRegistrationData" type="Binary"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xorRegistrationData" id="8e4e9810-8a6f-4b5e-a013-8ddb947972ae">
        <source>xorRegistrationData(pRegistrationData:Binary io) protected;
// --------------------------------------------------------------------------------
// Created:		16 January 2003 by cnwdad1
//
// Purpose:		Encrypts the "secret" part of the binary registration data.
//
// Parameters:	pRegistrationData - The binary registration data.
//
// Returns:		The binary registration data, as the I/O parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	keyByte			: Byte;
	bytePosition	: Integer;
	dataLength		: Integer;
	
begin
	keyByte		:=	pRegistrationData[5:4].Byte;
	dataLength	:=	pRegistrationData.length();
	
	// Only XOR the encrypted stuff, not the whole binary.
	
	foreach bytePosition in 9 to dataLength do
		pRegistrationData[bytePosition]	:=	pRegistrationData[bytePosition].bitXor(keyByte);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pRegistrationData" type="Binary" usage="io"/>
    </JadeMethod>
</Class>
