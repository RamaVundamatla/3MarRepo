    <JadeMethod name="populateBookings" id="f457c531-260b-4d3a-bab6-962ac8650078">
        <source>populateBookings();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 April 2013	cnwndl1	Initial creation
// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	heading1 : String;
	iter : Iterator;
	vvsBooking : CM_VehicleBookingTimeSlot;
	startObject : CM_VehicleBookingTimeSlot;
	localStartTS,
	startTS : TimeStamp;
	indexLine : Integer;
	entTableDef : EntTableDef;
	localToTS,
	toTS : TimeStamp;
	existingBooking : CM_VehicleBookingTimeSlot;
	ti : CM_TrackedItem;	//12 Feb 2014	NDL	Par 33500
	tiBooking : CM_VehicleBookingTimeSlot;	//12 Feb 2014	NDL	Par 33500
	firstOutwardTi : CM_TrackedItem;	//12 Feb 2014	NDL	Par 33500
	clearIndex : Integer;	//12 Feb 2014	NDL	Par 33500

begin

//	self.tblBookings.clear();
	self.tblBookings.rows := 1;	//09 Apr 2021	NDL	TFS 51045
	
	if self.tblBookings.myEntTableDef = null then		//09 Apr 2021	NDL	TFS 51045
		entTableDef := app.myController.getEntTableDef(ETDef_AssociateBooking);
	//	self.tblBookings.setTblDataEntRowsFromDef(entTableDef);
		self.tblBookings.setTblDataEntRowsFromXML(entTableDef, self.xmlStrTblText);	//09 Apr 2021	NDL	TFS 51045
	endif;
	self.tblBookings.selectMode := Table.SelectMode_Row;

	if self.myVehicleBookingTerminal = null then
		return;
	endif;
	
	//12 Feb 2014	NDL	Par 33500
	if not self.txtDateStart.getDate.isValid then
		return;
	endif;
	if not self.txtDateEnd.getDate.isValid then
		return;
	endif;
	
	localStartTS.setDate(self.txtDateStart.getDate);	// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	localStartTS.setTime(self.txtTimeStart.getTime);	// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	localToTS.setDate(self.txtDateEnd.getDate);			// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	localToTS.setTime(self.txtTimeEnd.getTime);			// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	startTS := self.localToSystemTime(localStartTS);	// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	toTS := self.localToSystemTime(localToTS);			// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if self.myVehicleVisitRecord = null and self.myProxyTrackedItem &lt;&gt; null then
		//doing it from a proxy tracked item - I.e we are coming from the PRE Note form or a Cargo enquiry in update mode
		existingBooking := self.myProxyTrackedItem.myVehicleBookingTimeslot;
		
		iter := self.myVehicleBookingTerminal.allBookingsByCarrierTS.createIterator;
		startObject := self.myVehicleBookingTerminal.allBookingsByCarrierTS.getAtKeyGeq(self.myCarrier,startTS);
		
		if startObject &lt;&gt; null then
			iter.startAtObject(startObject);
			
			while iter.next( vvsBooking ) do
	
				if self.myCarrier &lt;&gt; vvsBooking.myCarrier then
					break;
				endif;
				if vvsBooking.bookingTSstart &gt; toTS then
					break;
				endif;
				if vvsBooking.isUsed then
					continue;
				endif;

				self.addBookingSlotToTable( vvsBooking, false, indexLine );
				self.tblBookings.accessRow(indexLine).selected := false;
		
			endwhile;
			
		endif;
	
	elseif self.myVehicleVisitRecord &lt;&gt; null then
	

		iter := self.myVehicleBookingTerminal.allUnusedBookingsByCarrierTS.createIterator;
		startObject := self.myVehicleBookingTerminal.allUnusedBookingsByCarrierTS.getAtKeyGeq(self.myCarrier,startTS);
		
		//12 Feb 2014	NDL	Par 33500
		foreach ti in self.myVehicleVisitRecord.allReceivedTrackedItems do
			if ti.myVehicleBookingTimeslot &lt;&gt; null then
				tiBooking := ti.myVehicleBookingTimeslot;
				break;
			endif;
		endforeach;
		if tiBooking = null then
			if not self.myVehicleVisitRecord.allReleasedTrackedItems.isEmpty then
				firstOutwardTi := self.myVehicleVisitRecord.allReleasedTrackedItems.first;
			endif;
		endif;
		
		if startObject &lt;&gt; null then
			iter.startAtObject(startObject);
			
			while iter.next( vvsBooking ) do
				if vvsBooking.bookingTSstart &gt; toTS then
					break;
				endif;
				if self.myCarrier &lt;&gt; vvsBooking.myCarrier then
					break;
				endif;
				
				if self.myDriver &lt;&gt; null and vvsBooking.myDriver &lt;&gt; null then
					if vvsBooking.myDriver &lt;&gt; self.myDriver then
						continue;
					endif;
				endif;
				
				if self.myVehicle &lt;&gt; null and vvsBooking.myVehicle &lt;&gt; null then
					if vvsBooking.myVehicle &lt;&gt; self.myVehicle then
						continue;
					endif;
				endif;
				
				self.addBookingSlotToTable( vvsBooking, false, indexLine );
				
				//12 Feb 2014	NDL	Par 33500
				if existingBooking = null then
					if tiBooking = vvsBooking then
						existingBooking := vvsBooking;
					elseif firstOutwardTi &lt;&gt; null then
						if vvsBooking.allBookedTrackedItems.includes( firstOutwardTi ) then
							existingBooking := vvsBooking;
						endif;
					endif;
				endif;
		
			endwhile;
			
			self.reColourBookings();
			
		endif;
	
	endif;
	
	//12 Feb 2014	NDL	Par 33500
	if existingBooking &lt;&gt; null then
		indexLine := 1;
		self.tblBookings.findObjectInRow( existingBooking,indexLine);
		if indexLine &gt; self.tblBookings.fixedRows and  indexLine &lt;= self.tblBookings.rows then
			foreach clearIndex in 1 to self.tblBookings.rows do
				self.tblBookings.accessRow(clearIndex).selected := false;
			endforeach;
			self.tblBookings.row := indexLine;
			self.tblBookings.accessRow(self.tblBookings.row).selected := true;
		endif;
	endif;

epilog

	delete iter;

end;</source>
    </JadeMethod>
