    <JadeMethod name="isReceivalTypeForStorage" id="c47be051-0981-4f20-8013-33f33b439314">
        <source>isReceivalTypeForStorage(): Boolean;
// included in "Receival type transactions are
//   CM_Create  because tracked items that have been created have no receive type transactions
//   CM_CompanyTransfer because companies can have different charging regimes

/*
IMPORTANT - This is just receival transaction for STORAGE calculations only
*/
begin
	return type = TRANS_TYPE_CREATED or
		type = TRANS_TYPE_REASSEMBLY or
		type = TRANS_TYPE_RECEIVE or
		type = TRANS_TYPE_REC_RAIL or
		type = TRANS_TYPE_REC_RAIL_INTER_TERM or
		type = TRANS_TYPE_REC_ROAD or
		type = TRANS_TYPE_REC_ROAD_INTER_TERM or
		type = TRANS_TYPE_REC_SHIP or
		type = TRANS_TYPE_EXPORT_RETURNED or		
		type = TRANS_TYPE_ReinstateReject or
		type = TRANS_TYPE_BUSINESS_U_RECEIVE or
		type = TRANS_TYPE_REC_TRANSHIP;
		
		/* PAR 21569 - this is causing wrong linkage on storage transactions
		or
		type = TRANS_TYPE_REC_ST_DEPOT_INT or		// CCMS 1875
		type = TRANS_TYPE_REC_ST_DEPOT_RAIL or		// CCMS 1875
		type = TRANS_TYPE_REC_ST_DEPOT_ROAD or		// CCMS 1875
		type = TRANS_TYPE_REC_ST_DEPOT_SHIP or		// CCMS 1875
		type = TRANS_TYPE_REC_ST_MARINE_INT or		// CCMS 1875
		type = TRANS_TYPE_REC_ST_MARINE_RAIL or		// CCMS 1875
		type = TRANS_TYPE_REC_ST_MARINE_ROAD or		// CCMS 1875
		type = TRANS_TYPE_REC_ST_MARINE_SHIP or		// CCMS 1875
		type = TRANS_TYPE_REC_ST_WHOUSE_INT or		// CCMS 1875
		type = TRANS_TYPE_REC_ST_WHOUSE_RAIL or		// CCMS 1875
		type = TRANS_TYPE_REC_ST_WHOUSE_ROAD or		// CCMS 1875
		type = TRANS_TYPE_REC_ST_WHOUSE_SHIP or		// CCMS 1875
		type = TRANS_TYPE_RECEIVE_ST_DEPOT or		// CCMS 1875
		type = TRANS_TYPE_RECEIVE_ST_MARINE or		// CCMS 1875
		type = TRANS_TYPE_RECEIVE_ST_WHOUSE;		// CCMS 1875
		*/
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isReceiveReleaseByTransport" id="d4b52022-44c1-4225-8fb4-a7b99a75efd6">
