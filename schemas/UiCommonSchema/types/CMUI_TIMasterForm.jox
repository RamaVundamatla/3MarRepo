    <JadeMethod name="ackTodoStop" id="392e7b19-962b-4fce-99a0-088c9ee10f84">
        <source>ackTodoStop() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2008	cnwrd1	Initial creation

*/

vars

begin
	return app.myPassport.myUser.getAcknowledgeTodoStop();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="be088793-89b7-418b-993c-9c3ed64e742a">
        <updating/>
        <source>addToolbarControls() updating, protected;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	toolbar,
	toolbarSearcher	: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnReportOptions, CMUI_Toolbar.Control_Alignment_Left);		
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnSearcher, CMUI_Toolbar.Control_Alignment_Left);		

	
	toolbar.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);
	//if app.isSpecial() then
		toolbar.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	//endif;
	toolbar.addButton(self.btnSelectAll, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	/* //23/04/2024	navkc1 CR63736 Task 63770 - Use new filter control
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left); 						// ### TFS 51912 14Sep2021 NAVPW1
	toolbar.addFrame(self.frmFilter, CMUI_Toolbar.Control_Alignment_Left); 			// ### TFS 51912 14Sep2021 NAVPW1
	toolbar.addButton(self.btnClearFilter, CMUI_Toolbar.Control_Alignment_Left); 	// ### TFS 51912 14Sep2021 NAVPW1
	*/ //23/04/2024	navkc1 CR63736 Task 63770 end
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left); 						//05/06/2024	navkc1 CR 63736 Task 63770
	toolbar.addFrame(self.frmTableFilter, CMUI_Toolbar.Control_Alignment_Left); 	//05/06/2024	navkc1 CR 63736 Task 63770
	
	//=======================================
	// now setup searchToolbar
	//=======================================
	toolbarSearcher := self.toolbarSearcher;

	toolbarSearcher.addButton(self.btnDoSearch, CMUI_Toolbar.Control_Alignment_Left);
	toolbarSearcher.addButton(self.btnCloseSearcher, CMUI_Toolbar.Control_Alignment_Left);
	toolbarSearcher.showCaptions := false;
	toolbarSearcher.positionToolbarControls();
	toolbarSearcher.visible := true;
//	self.lstMasterGrps.top := toolbarSearcher.height + 5;
	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
