<GUIClass name="CMUI_BGPButton" id="409d4a72-7d57-420d-be32-1a0a112181c8">
    <superclass name="CMUI_Button"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <ImplicitInverseRef name="myFrame" id="830a2450-7d37-4e89-9770-65adb1a9349e">
        <embedded/>
        <type name="CMUI_Frame"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="click" id="a83e7ca1-10af-43c1-b4ed-2e7ad86ca6eb">
        <updating/>
        <source>click(btn: Button input) updating;

// cnwdvb1 17 December 2002 

vars

begin
	inheritMethod(btn);
	if self.myFrame &lt;&gt; null then
		self.myFrame.doButtonClick(self);
	endif;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyFrame" id="a1f9e76b-1bf1-4719-b4d5-94770b65f0be">
        <updating/>
        <source>setMyFrame(_frame : CMUI_Frame) updating;

// cnwdvb1 17 December 2002 

vars

begin

	self.myFrame := _frame;
end;</source>
        <Parameter name="_frame" type="CMUI_Frame"/>
    </JadeMethod>
