    <JadeMethod name="isSnapShotDataMatch" id="7db0c338-fe65-4a69-8c85-0faddc59f8ac">
        <source>isSnapShotDataMatch(_criteria: CM_YACriteria; _yaType: Integer; _propertyValue: String): Boolean;
// fixed Apr 2011 after failing qual, not using the lower and upper values
vars
	value	: Integer;
	obj		: Object;
begin
	if _yaType &lt;&gt; self.type then
		return false;
	endif;
	
	value := _propertyValue.Integer;
	foreach obj in _criteria.myYAData.CM_YADataObjects.allObjects do
		if value &gt;= obj.CM_WeightRange.lower and
		   value &lt;= obj.CM_WeightRange.upper then
			return true;
		endif;
	endforeach;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_yaType" type="Integer"/>
        <Parameter name="_propertyValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
