    <JadeMethod name="displayCriteriaDesc" id="444eecf4-d651-4df0-89ee-23456ccb269d">
        <source>displayCriteriaDesc(_mode : Integer);
/*

Date		Who		Reason
13 May 2016	cnwer1	Initial creation PAR
// navvt20 10 June 2022 TFS53234 --&gt; 1090 when selecting VGM tab when creating a terminal
*/
vars
	criteria: CM_YACriteria;
	template : CM_YATemplate;
	text: String;
	cmifCriteria: CMIF_Object;
begin

	if self.myForm.tblInput2.getRow(ETRow_PrenoteCertWeightValCrit) = null then
		return;
	endif;
	
	
	if _mode = CM_TableViewForm.Mode_View  then
	// if self.getTerminal.myPrenoteWeightCriteria &lt;&gt; null then 
		if self.getTerminal &lt;&gt; null and self.getTerminal.myPrenoteWeightCriteria &lt;&gt; null then // navvt20 10 june 2022 TFS53234 
			text:= self.getTerminal.myPrenoteWeightCriteria.getDisplayStringForAttribute(ETRow_PrenoteCertWeightValCrit,false);
		endif;
	else
	
		foreach cmifCriteria in self.allCriteria do
			criteria := cmifCriteria.CMIF_YACriteriaPriority.myProxy.CM_YACriteria;
			text := text &amp; criteria.getListDisplay &amp; " ";
		endforeach;
	endif;
	
	if text &lt;&gt; null then
		self.myForm.tblInput2.setValueByName(ETRow_PrenoteCertWeightValCrit,text);
	else
		self.myForm.tblInput2.setValueByName(ETRow_PrenoteCertWeightValCrit,"-- Dbl Click to Add --");
	endif;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doBtnAdvanced" id="17a289e2-4903-4400-b840-c065da53334c">
        <updating/>
        <source>doBtnAdvanced() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 September 2009	cnwkpd1	PAR #20398 - Add Booking Reference cross reference functionality

*/

vars
	theForm 		: SOP_TableMaintForm;
	selectedObj		: Object;
	settingsFormObj	: SOP_TerminalAdvSettingsForm;

begin
	theForm := self.myForm;
	selectedObj	:= theForm.myCurrentObject;
	
	if selectedObj.isKindOf(CM_Terminal) then
		create settingsFormObj;
		settingsFormObj.setMyTerminal(selectedObj.CM_Terminal);
		settingsFormObj.showModal();
	endif;
	
	
epilog

end;</source>
    </JadeMethod>
