epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="9f238afd-0d8f-4c74-8db8-149cad6606a3">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// --------------------------------------------------------------------------------
// Created:		31 August 2009 by cnwjo3
//
// Purpose:		return properties as strings for CM_YardICAreaLaneController, par 20582 ccms 1061
//
// 25/05/2010	cnwcs5	par 24292 - interchange area capacity
vars

begin
	if _attrName = ETRow_GateLaneId then
		if self.isDefaultLane() then
			return app.getErrorString(CM_Default);
		else	
			return self.row.asStringJMT();
		endif;
	elseif _attrName = ETRow_IsClosed then
		return self.isUnavailable.asStringJMT();
	elseif _attrName = ETRow_RFIDTagReader then
		if self.getRFIDTagReader(true) &lt;&gt;  null then
			return self.getRFIDTagReader(true).description;
		endif;
		return null;
	elseif _attrName = ETRow_Printer then
		if self.getPrinter &lt;&gt; null then
			return self.getPrinter.description;
		endif;
		return null;
	elseif _attrName = ETRow_Capacity then	// par 24292 cnwcs5 25/05/2010
		return self.capacity.String;		// par 24292 cnwcs5 25/05/2010
	elseif _attrName = ETRow_VehicleCount then
		if self.pxyIsProxy() then
			return self.pxyGetRealObject.getVehicleCount().asStringJMT;
		else
			return self.getVehicleCount.asStringJMT;
		endif;
	elseif _attrName = ETRow_MachineCount then
		if self.pxyIsProxy() then
			return self.pxyGetRealObject.getMachineCount().asStringJMT;
		else
			return self.getMachineCount.asStringJMT;
		endif;
	endif;			
	
	return inheritMethod(_attrName, _short);
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFullId" id="c90e02f8-aad4-4493-8bab-d169b4398801">
