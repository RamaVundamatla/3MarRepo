    <JadeMethod name="setNavigator" id="558ebeea-f110-481b-beb3-68205241807e">
        <source>setNavigator() protected;

/*
Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
16 April 2009		cnwrl1	Initial creation PAR 19440
*/
	
vars
	naviString	: String;
	loadLstStr	: String;
	
begin
	if self.myCurrentVoyage = null then
		self.setNavigatorHeading( app.getErrorString( List_Comparison ) );
