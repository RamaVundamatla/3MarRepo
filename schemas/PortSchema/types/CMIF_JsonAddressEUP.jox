    <JadeMethod name="setFromAddress" id="02873702-3352-4a7b-90ff-6eaba92ceccc">
        <updating/>
        <source>setFromAddress(_address : CM_Address) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 June 2023	jlier1	Initial creation 57077

*/

vars

begin
	if _address = null then
		return;
	endif;
	self.city:=_address.city;
	self.country:=_address.countryName;
	self.countryCode:=_address.countryCode;
	self.street1:=_address.addr1;
	self.street2:=_address.addr2;
	self.postalCode:=_address.postCode;
	self.county:=_address.region;
epilog

end;</source>
        <Parameter name="_address" type="CM_Address"/>
    </JadeMethod>
</Class>
