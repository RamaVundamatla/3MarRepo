    <JadeMethod name="getLogRow" id="795ade0f-e9df-4c04-a990-123268f4c213">
        <source>getLogRow(_logAreaId, _logRowId: String): CM_LogController;
//09 September 2010	by cnwvu1

vars
	logArea		: CM_LogArea;
	logRow		: CM_LogController;
	tmpLogRow	: CM_LocationsController;
	
begin

	logArea := self.getLogArea(_logAreaId);
	
	foreach tmpLogRow in logArea.allLocationsControllers do
		if tmpLogRow.ident = _logRowId then
			logRow := tmpLogRow.CM_LogController;
			break;
		endif;
	endforeach;
	// archived and empty log rows are special cases
	if logRow = null then
		foreach tmpLogRow in logArea.allLCsArchived do
			if tmpLogRow.ident = _logRowId then
				logRow := tmpLogRow.CM_LogController;
				break;
			endif;
		endforeach;
	endif;
	if logRow = null then
		foreach tmpLogRow in logArea.allEmptyLogControllers do
			if tmpLogRow.ident = _logRowId then
				logRow := tmpLogRow.CM_LogController;
				break;
			endif;
		endforeach;
	endif;

	return logRow;
	
end;</source>
        <Parameter name="_logAreaId" type="String"/>
        <Parameter name="_logRowId" type="String"/>
        <ReturnType type="CM_LogController"/>
    </JadeMethod>
