    <JadeMethod name="handleBtnTwo" id="08b6c75d-55d0-4ed7-88ca-234944818257">
        <updating/>
        <source>handleBtnTwo() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 November 2013	cnwrd1	Initial creation

*/

vars

begin
