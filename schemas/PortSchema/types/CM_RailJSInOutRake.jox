    <JadeMethod name="clearRake" id="882eb022-378f-4c31-a03a-4acd3d1a89b9">
        <updating/>
        <source>clearRake(_passport : CM_Passport input) updating;
//--------------------------------------------------
// Created:	02 December 2003 By: cnwgd1
//--------------------------------------------------
vars
	job : CM_RailJob;
	iter : Iterator;
	numJobs,
	cnt : Integer;
	tmpArray : CM_RailJobArray;
begin
	create tmpArray transient;
	iter := self.railJobs.createIterator;
	while iter.next(job) do
		if job.status = JOB_COMPLETE then
			tmpArray.add(job);
		endif;
	endwhile;
	
	numJobs := tmpArray.size;
	while cnt &lt;= numJobs do
		cnt := cnt +1;
		job := tmpArray.last;
		if job = null then
			break;
		endif;
		tmpArray.remove(job);
		job.departureProcess(_passport);
	endwhile;

epilog
	delete tmpArray;
	delete iter;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllWLEs" id="9a730828-897b-4445-98a3-5af996c45f7c">
        <source>getAllWLEs(_wleArray : CM_WLEArray input);
//--------------------------------------------------------------
//Created: 25 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	railJob	: CM_RailJob;
begin

	foreach railJob in self.railJobs do
		railJob.getAllWLEs(_wleArray);
	endforeach;
	
end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="9d5f3d9c-9a47-4684-ba85-a5c4c4c0b2a8">
        <source>getDisplayDetails(_short: Boolean): String;
//--------------------------------------------------------------
//Created: 07 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpStr : String;
begin

	if _short then
		return self.rake;
	else
		tmpStr := self.inOut.getDisplayDetails(_short); // PAR 22037
		if self.myRail = null then // PAR 22037
			return tmpStr; // PAR 22037
		else
			return tmpStr &amp; ' ' &amp; self.rake;
		endif;
	endif;

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getIoType" id="01117ce7-16f9-4473-a480-a5321604cd94">
        <source>getIoType() : Integer;
/*
Method:			getIoType();	
Author:     cnwspg1 created on 01 February 2000
Description:

Fixes:
Date        User      Description
--------    --------  ------------------
*/
vars

begin

	return self.inOut.getIoType();

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getName" id="9b5640a7-358b-497a-8883-001b6c38121e">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:     26 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myRail = null then
		return self.getDisplayDetails(false);
	else
		return self.myRail.getName();
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="init" id="b73d11d0-d7b3-4fde-abc9-1397c62b5d72">
        <source>init();

/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	railJobSheet : CM_RailJobSheet;
	job : CM_Job;
	rjob : CM_RailJob;
	count : Integer;
	inRakeSheet : CM_RailJSInOutRake;
	outRakeSheet : CM_RailJSInOutRake;
	invalid 		: Boolean;	
	
begin

	// handle removing release and receipt jobs and put them into the correct
	//layer of the heirarchy
	railJobSheet := app.myPassport.myTerminal.myRailJobSheet;

	on Exception do app.handleDeletedObject(exception, rjob, invalid);
	
	if inOut.outwards = Rail_JSIO_Type_Build then
		count := 1;
		while count &lt;= railJobSheet.jobsByOrder.size do
			rjob := railJobSheet.jobsByOrder[count].CM_RailJob;
//			if global.isValidObject(rjob) then
			if rjob &lt;&gt; null then
				if rjob.status = JOB_UNACTIONED then 
					rjob.inOutRakeSheet := self;
					railJobSheet.jobsByOrder.remove(rjob);
					count := count - 1;
				endif;
			endif;
			count := count + 1;
		endwhile;
	endif;


	count := 1;
	while count &lt;= railJobSheet.jobsByOrder.size do
		rjob := railJobSheet.jobsByOrder[count].CM_RailJob;
//		if global.isValidObject(rjob) then
		if rjob &lt;&gt; null then
			if rjob.railTransAreaId.trimRight = rake.trimRight then
				if (rjob.isRelease and inOut.outwards = Rail_JSIO_Type_Out) or 
						( not rjob.isRelease and inOut.outwards = Rail_JSIO_Type_In) then
					rjob.inOutRakeSheet := self;
					railJobSheet.jobsByOrder.remove(rjob);
					count := count - 1;
				endif;
			endif;
		endif;
		count := count + 1;
	endwhile;

	railJobSheet.jobsByOrder.clear;

end;</source>
    </JadeMethod>
    <JadeMethod name="initialise" id="2e27f2b7-fd28-484e-b171-0413564f7278">
        <source>/*
Author:      cnwspg1
Date:        12 January 2000
Description: Initialise the rake
							1. Pickup and remove any jobs out of the old structures and place them in 
								 in the new structures
							2. So that over time we can remove the old structure all together.

--------------------
Fixes
*/

initialise();

vars
	railJobSheet : CM_RailJobSheet;
	job : CM_Job;
	rjob : CM_RailJob;
	count : Integer;
	inRakeSheet : CM_RailJSInOutRake;
	outRakeSheet : CM_RailJSInOutRake;

begin

	// handle removing release and receipt jobs and put them into the correct
	//layer of the heirarchy
	railJobSheet := self.myRail.myTerminal.myRailJobSheet; //app.getMyTerminal().myRailJobSheet;
/*
	if inOut.outwards = CM_RailJSInOut.JS_BUILD then
		count := 1;
		while count &lt;= railJobSheet.jobsByOrder.size do
			rjob := railJobSheet.jobsByOrder[count].CM_RailJob;
			if global.isValidObject(rjob) then
				if rjob.status = CM_Job.JOB_UNACTIONED or rjob.status = CM_Job.JOB_WLES_RETURNED then 
					rjob.inOutRakeSheet := self;
					railJobSheet.jobsByOrder.remove(rjob);
					count := count - 1;
				endif;
			endif;
			count := count + 1;
		endwhile;
	endif;


	count := 1;
	while count &lt;= railJobSheet.jobsByOrder.size do
		rjob := railJobSheet.jobsByOrder[count].CM_RailJob;
		if global.isValidObject(rjob) then
			if rjob.railTransAreaId.trimRight = rake.trimRight then
				if (rjob.isRelease and inOut.outwards = CM_RailJSInOut.JS_OUT) or 
						( not rjob.isRelease and inOut.outwards = CM_RailJSInOut.JS_IN) then
					rjob.inOutRakeSheet := self;
					railJobSheet.jobsByOrder.remove(rjob);
					count := count - 1;
				endif;
			endif;
		endif;
		count := count + 1;
	endwhile;
*/
	railJobSheet.jobsByOrder.clear;

end;</source>
    </JadeMethod>
</Class>
