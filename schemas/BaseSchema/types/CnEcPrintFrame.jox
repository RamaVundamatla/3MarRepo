    <DbClassMap file="_usergui"/>
    <Constant name="TEXT_SIZE_CHARACTER" id="58692a93-9c40-4de8-8ce1-6e2d521333ef">
        <source>"a"</source>
        <type name="String"/>
    </Constant>
    <PrimAttribute name="columns" id="b6b1b927-b262-4945-883a-adbfae097b34">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="isHeader" id="72e549c4-6ed4-4f52-a963-3ac2a5c21ae7">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="rows" id="eb06f343-350a-4785-bf30-5ccd042cc488">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="create" id="6f215964-e1e3-4e75-be16-651098bf6661">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		23 July 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.caption	:=	null;
end;</source>
    </JadeMethod>
    <JadeMethod name="paint" id="11acbe05-f85e-4b53-907b-1c8f2a4924cd">
        <updating/>
        <source>paint(frame: Frame input) updating;
// --------------------------------------------------------------------------------
// Created:		23 July 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (not isInPainter()) and self.isTransient() then
		self.rows		:=	(height / getTextHeight(TEXT_SIZE_CHARACTER)).roundedUp();
		self.columns	:=	(width / getTextExtent(TEXT_SIZE_CHARACTER)).roundedUp();
	endif;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
