    <JadeMethod name="canBeSized" id="df34fb42-00ed-4e32-8dc7-d3d7dcc011f4">
        <source>canBeSized(): Boolean;
// ---------------------------------------------------------------------------
// Created:		12 May 2003  by Jason Chapman  (cnwjc2)
//
//	Tests whether the selected column can be sized  (is it a bunch of gap controllers?)
// ---------------------------------------------------------------------------

vars
	selectedCol : Integer;
	gridCol		: CMUI_GridColumn;
	gridPoint 	: CMUI_GridPoint;
begin

	selectedCol := self.selectedColumn;
	if selectedCol = 0 then
		return false;
	endif;
	
	gridCol := self.allGridColumns[selectedCol];
	
	if gridCol = null then
		return false;
	endif;
	
	foreach gridPoint in gridCol.allGridPointsByRow do
		if not gridPoint.SOP_GridPoint.isGap then
			return false;
		endif;
	endforeach;	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
