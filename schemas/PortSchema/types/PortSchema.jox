    <JadeMethod name="getDefaultSeqSheetReportName" id="e5fdf3b4-b6db-48d9-ba2a-64af0f56bc80">
        <source>getDefaultSeqSheetReportName( _config : String) : String;
/*

Purpose:	takes one of the config names for the sequence sheet and returns
			the appropriate system defined report name

Parameters:			

Return Value:		


Date		Who		Reason
26 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	if _config = ShipSeqShtMedium then
		return 'CM_VoyageJobSeqMed';
	elseif _config = ShipSeqShtLarge then
		return 'CM_VoyageJobSeqLarge';
	elseif _config = ShipSeqShtXLarge then
		return 'CM_VoyageJobSeqLargeLandscape';
	elseif _config = ShpSeqShtMediumRORO then
		return 'CM_VoyageJobSeqMedRORO';
	elseif _config = ShpSeqShtLargeRORO then
		return 'CM_VoyageJobSeqLargeRORO';
	elseif _config =  ShpSeqShtXLargeRORO then
		return 'CM_VoyageJobSeqLargeLandRORO';
	endif;
epilog

end;</source>
        <Parameter name="_config" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
