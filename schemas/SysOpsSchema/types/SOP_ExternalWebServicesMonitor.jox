    <JadeMethod name="updateProgress" id="c6de2f0c-e9e4-4539-b90b-99315574ee0f">
        <updating/>
        <source>updateProgress(_cmifMonitor : CMIF_Monitor input) updating;
// ---------------------------------------------------------------------------
// Created:     01/08/24 Navcs2	
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.pbProgressBar.visible := true;
	self.pbProgressBar.partsInJob := _cmifMonitor.partsInJob;	
	self.pbProgressBar.partsDone := _cmifMonitor.partsDone;
	self.lblModalMessage.caption := _cmifMonitor.message;																		// TFS 63307
	self.lblModalInfo.caption := 'Found ' &amp; _cmifMonitor.partsDone.String &amp; ' of ' &amp; _cmifMonitor.partsInJob.String;

	self.frmModalDialog.refreshNow();
	self.btnModalDefault.doWindowEvents(0);
	self.btnModalOpt1.doWindowEvents(0);

	if self.modalDialogReturnValue &lt;&gt; ModalDialogReturn_Null then
		_cmifMonitor.monitorReturnValue := _cmifMonitor.MonitorReturnValue_Cancel;
	endif;

end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="4c83e066-70fc-4b0f-86ac-2827d05bc28f">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(_eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*
Purpose:			

Date		Who		Reason
20 Aug 2021	navab1	TFS 50669
14 Feb 2022	navdap1	TFS 52268 AAT 1-Stop VBS Integration
*/

vars

begin
	if self.isOpsView then
		if _eventType = BGP_Object.BGP_NavisSmartProducerStarting then
				self.picBGPStatus.picture := self.picStarting.picture;
				self.picBGPStatus.bubbleHelp := "BGP Producer for OpsView is Starting";
		elseif _eventType = BGP_Object.BGP_NavisSmartProducerRunning then
				self.picBGPStatus.picture := self.picRunning.picture;
				self.picBGPStatus.bubbleHelp := "BGP Producer for OpsView is Running";
		elseif _eventType = BGP_Object.BGP_NavisSmartProducerStopped then
				self.picBGPStatus.picture := self.picStopped.picture;
				self.picBGPStatus.bubbleHelp := "BGP Producer for OpsView is Stopped";
		elseif _eventType = BGP_Object.BGP_NavisSmartProducerSnapshot then
				self.picBGPStatus.picture := self.picStarting.picture;
				self.picBGPStatus.bubbleHelp := "BGP Producer for OpsView is Starting";
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="xmlGetObjectListSelected" id="5ec3b337-17cb-400b-b55a-e0ff360c74df">
        <source>xmlGetObjectListSelected(_tagName : String; _objectSet : Dictionary; _propertyName: String): String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/11/2024	navcs2	MTN-33423 MTN - External Web service monitor - Selected options are not saved when form is closed and reopened

*/

vars
	str : String;
	obj	: Object;
begin
	foreach obj in _objectSet do 
		str := str &amp; global.formatAsXML(_tagName, obj.getPropertyValue(_propertyName).String);
	endforeach;
	
	return str;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_tagName" type="String"/>
        <Parameter name="_objectSet" type="Dictionary"/>
        <Parameter name="_propertyName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
</GUIClass>
