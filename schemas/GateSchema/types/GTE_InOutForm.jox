// Created by cnwdvb1 on 30 January 2007

vars

	dischargeCombo,
	transhipCombo	: CMUI_ComboPorts;	

begin

	// DVB changed 24/01/07
	// Set up the discharge combo voyage here. Forces and initialise
	dischargeCombo := self.getTopSheetControl(self.cmbDischarge.name).CMUI_ComboPorts;
	transhipCombo := self.getTopSheetControl(self.cmbTranship.name).CMUI_ComboPorts;
	if dischargeCombo = null or transhipCombo = null then
		return;
	endif;
	dischargeCombo.setObjectAndVoyage(null, combobox.listObject.CM_Voyage);	
	//transhipCombo.setObject(null);
	transhipCombo.setObjectAndVoyageDischPort(dischargeCombo.listObject.CM_Port,combobox.listObject.CM_Voyage);	

end;</source>
