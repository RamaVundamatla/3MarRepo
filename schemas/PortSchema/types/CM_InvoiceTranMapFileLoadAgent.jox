    <JadeMethod name="getContentsStatusDetails" id="520f09b0-aeb8-48c8-8019-71a688244e4a">
        <updating/>
        <source>getContentsStatusDetails(_contentsStatus : String; _default : Boolean output; _contentsStatusObj : CM_CargoStatus output) updating, protected;

vars
	found	: Boolean;
	contentsStatusObj	: CM_CargoStatus;
begin
	if _contentsStatus = CM_FinancialObject.Extract_Default then
		_default := true;
	else
		foreach	contentsStatusObj in myRoot.allContentsStatuses do
			if contentsStatusObj.abbreviation = _contentsStatus then
				found := true;
				break;
			endif;
		endforeach;
		if not found then
			self.validationError("Invalid contents status", _contentsStatus);
		else
			_contentsStatusObj := contentsStatusObj;
		endif;
	endif;

end;
</source>
        <access>protected</access>
        <Parameter name="_contentsStatus" type="String"/>
        <Parameter name="_default" type="Boolean" usage="output"/>
        <Parameter name="_contentsStatusObj" type="CM_CargoStatus" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaAllCMIF" id="421af0ad-0048-43a0-abbb-182fc49334b8">
        <source>getCriteriaAllCMIF( _broker : CM_SnapShotServiceBroker; _criteriaValues : HugeStringArray; _cmifArray : CMIF_Array input ) : String protected;

vars
	criteriaType	: CM_YACriteriaType;
	i				: Integer;
	sValue			: String;
	groupName		: String;
	bValue			: Any;
	nullString		: String;
	oa				: ObjectArray;

begin

	create oa transient;
	_broker.getYACriteriaTypes(_broker.allYACriteriaTypes, oa);

	foreach sValue in _criteriaValues do
		groupName := groupName &amp; " " &amp; sValue;
		if sValue = "(Default)" then
			bValue := nullString;	// NOTE: nullString rather than null, because a null Any ends up in YA_DATA pattern as '** not initialised **' rather than null
		else
			bValue := sValue;
		endif;
		i := i + 1;
		criteriaType := oa[i].CM_YACriteriaType;
		self.getCriteriaSingleCMIF( _cmifArray, criteriaType, bValue );
	endforeach;
	
	return groupName;
epilog
	delete oa;
end;</source>
        <access>protected</access>
        <Parameter name="_broker" type="CM_SnapShotServiceBroker"/>
        <Parameter name="_criteriaValues" type="HugeStringArray"/>
        <Parameter name="_cmifArray" type="CMIF_Array" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaSingleCMIF" id="078a5a5c-ed01-4c9a-aca0-777c70383c6d">
        <source>getCriteriaSingleCMIF( _cmifArray : CMIF_Array input; _criteriaType : CM_YACriteriaType; _value : Any ) protected;

/*

Purpose:		Update/add transient maintenance object for given criteria type

Parameters:			

Return Value:		


Date			Who		Reason
06 August 2008	consw1	Initial creation

*/

vars
	cmifCriteria : CMIF_YACriteriaPriority;
	itemCode : String;
	proxyCriteria: CM_YACriteria;

begin
	// Create an Add Criteria request
	
	create proxyCriteria transient;
	itemCode := _criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	proxyCriteria.setProxy(_criteriaType, _value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	cmifCriteria.setFlag(true, false, false);
	_cmifArray.add(cmifCriteria);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cmifArray" type="CMIF_Array" usage="input"/>
        <Parameter name="_criteriaType" type="CM_YACriteriaType"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaValues" id="b892c81d-85d0-43ac-a82f-ad71c5f822a7">
        <updating/>
        <source>getCriteriaValues(_outputFormat : CM_OutputFormat_SS; _headers : HugeStringArray; _criteriaValues : IntegerArray) updating, protected;
// --------------------------------------------------------------------------------
// Created:		oct 2010 by cnwjre1
//
// Purpose:		Do per-field validation 
//
// Parameters:	_allFileRows - An object array of file rows (each one being a HugeStringArray)
//				_headers	HugeStringArray of the file headers, which contain the query property names
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	max,
	index		: Integer;
	found		: Boolean;
	propName	: String;
	allGroupProps : CM_QueryPropertyArray;
	queryProp	: CM_QueryProperty;
	
begin
	create allGroupProps transient;
	_outputFormat.getGroupingProperties( allGroupProps );
	
	max := _headers.size - 5;	// trailing fixed items
	foreach index in 4 to max do
		propName := _headers[index];
		found := false;
		foreach queryProp in allGroupProps where queryProp.allocationAttribute &lt;&gt; 0 do
			if queryProp.niceName = propName then
				_criteriaValues[index - 3] := queryProp.allocationAttribute;
				break;
			endif;
		endforeach;
	endforeach;

epilog
	delete allGroupProps;

end;
</source>
        <access>protected</access>
        <Parameter name="_outputFormat" type="CM_OutputFormat_SS"/>
        <Parameter name="_headers" type="HugeStringArray"/>
        <Parameter name="_criteriaValues" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="getDebtorDetails" id="6c14d251-e6c1-4894-a075-978814006aad">
        <updating/>
        <source>getDebtorDetails(_debtorCode : String; _default : Boolean output; _debtorObj : CM_DebtorNode output; _debtorTypeObj : CM_DebtorType output) updating, protected;
// 24051 _debtorCode is now &lt;debtor code&gt;:&lt;debtor type&gt; but note that converted data may have a null debtor type
vars
	pos	: Integer;
	debtorCode	: String;
	debtorType	: String;
	debtorObj : CM_DebtorNode;
	debtorTypeObj	: CM_DebtorType;
begin
	if _debtorCode = CM_FinancialObject.Extract_Default then
		_default := true;
	else
		debtorCode := _debtorCode;
		pos := _debtorCode.pos(":", 1);
		if pos &gt; 1 then
			debtorCode := _debtorCode[1:pos-1];
			if pos &lt; _debtorCode.length then		// from 33095 testing only if pos &gt; 1
				debtorType := _debtorCode[pos+1:end];
			endif;
		endif;
		debtorObj	:=	myRootDebtor.allChildDebtorNodes[debtorCode];
		if debtorObj = null then
			debtorObj	:=	myRoot.myRootCompany.debtorNodes[debtorCode];
		endif;
		if debtorObj = null then
			self.validationError("Invalid debtor", debtorCode);
		else
			_debtorObj := debtorObj;
		endif;

		// debtor type is required from the GUI but may be null from conversion of existing maps
		if debtorType &lt;&gt; null then
			debtorTypeObj := app.myRoot.allDebtorTypes[debtorType];
			if debtorTypeObj = null then
				self.validationError("Invalid debtor type", debtorType);	// from 33095 testing, was using _debtorCode
			endif;
			_debtorTypeObj := debtorTypeObj;
		endif;
	endif;

end;
</source>
        <access>protected</access>
        <Parameter name="_debtorCode" type="String"/>
        <Parameter name="_default" type="Boolean" usage="output"/>
        <Parameter name="_debtorObj" type="CM_DebtorNode" usage="output"/>
        <Parameter name="_debtorTypeObj" type="CM_DebtorType" usage="output"/>
    </JadeMethod>
