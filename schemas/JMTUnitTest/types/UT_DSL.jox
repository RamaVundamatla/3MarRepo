    <JadeMethod name="deleteInvoiceLineType" id="0fbfb4b3-1f18-476c-a10d-6332dc5e42ba">
        <source>deleteInvoiceLineType(_narration : String; _eraseLevel : Integer);
// --------------------------------------------------------------------------------
// Created:		23 November 2009 by cnwjo3
//
// Purpose:		Delete an Invoice Line Type
// 28 Oct 2021 navma1 ChangeRequest 52163: SAL - Unicode Arabic Support Business Requirements
vars
	ild	 : CM_InvoiceLineDesc;
	bank : CM_Bank;
begin
	
	bank := self.getTerminal().getDefaultCompanyBank();
	
	self.assertNotNull(bank);
	
	ild := bank.invoiceLineDescriptors[_narration];
	
	if ild &lt;&gt; null and ild.narration = _narration then
		if _eraseLevel = FORCED_ERASE then
				app.myTrxDA.trxDeleteInvoiceLineDescForce(ild, app.myPassport);
				self.assertNoTrxErrorsOrWarnings();
			else
				app.myTrxDA.trxDeleteInvoiceLineDesc(ild, app.myPassport);
			endif;
	endif;
	
	/*
	28.10.2021 navma1 #52163
	foreach ild in CM_InvoiceLineDesc.instances do
		if ild.narration = _narration then
			if _eraseLevel = FORCED_ERASE then
				app.myTrxDA.trxDeleteInvoiceLineDescForce(ild, app.myPassport);
				self.assertNoTrxErrorsOrWarnings();
			else
				app.myTrxDA.trxDeleteInvoiceLineDesc(ild, app.myPassport);
			endif;
		endif;
	endforeach;
	*/
end;</source>
        <Parameter name="_narration" type="String"/>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
