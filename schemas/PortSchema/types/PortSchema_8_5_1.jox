	self.convertTidalClassRates(pControllerObj);	//29 Jun 2018	NDL	TFS 39338
	self.fixupVoyageProcess(); // 29JUN2018JLGAB1 TFS 39236
	self.createWorkOrderCalcTypes(pControllerObj); // 12JUL2018JLGAB1 TFS 39236
	self.setUseRelReqAnyVoyLoad( pControllerObj ); //16 Jul 2018	NDL	TFS 38679
	self.addVoyStatsCancelled( pControllerObj );	//02 Aug 2018	NDL	TFS 39924
	self.convertVoyWoNumbers( pControllerObj );	//17 Aug 2018	NDL	TFS 40249
	self.upgradeCargoGroupAssign( pControllerObj );//05 Oct 2018	NDL	TFS 39186
	self.renameRenumberPELVoyageSatuses(pControllerObj);  // 25OCT18 TFS 41539
	self.renumberPriPELVoyageSatuses(pControllerObj);  // 25OCT18 TFS 41539
	self.convertTermConfigToBank( pControllerObj );//08 Jan 2019	NDL	TFS 40010
	self.resetSystemMenuIcon(pControllerObj);	// 18 Jan 2019 jlgdap1 TFS 41738
	
epilog

end;</source>
