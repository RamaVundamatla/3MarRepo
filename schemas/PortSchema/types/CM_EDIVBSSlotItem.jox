    <JadeMethod name="assignValueSpecial" id="e3cd30a8-f03f-4ea8-a9d1-2a4274c3c6b9">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 June 2023		jlizm1	Initial creation TFS 53901 EUP VBS EDI

*/

vars

begin
	if _propName = ETRow_BookingItemSeq then
		self.bookingItemSequence := _processedValue;
		return true;
		
	elseif _propName = ETRow_CargoID then
		self.cargoId := _processedValue;
		return true;
		
	elseif _propName = ETRow_ExternalReference then
		self.externalReference := _processedValue.toUpper();
		return true;
		
	endif;

	return inheritMethod(_propName, _processedValue, _xlationOperator);

epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createProxy" id="4d220e96-6e3c-4634-a1ed-df01296df2d7">
        <source>createProxy(_pxyHeader : CM_VehicleBookingTimeSlot) : CM_VehicleBookingTimeSlotItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 June 2023		jlizm1	Initial creation TFS 53901 EUP VBS EDI

*/

vars
	terminal : CM_VehicleBookingTerminal;
	vbSLot	: CM_VehicleBookingTimeSlot;
	item : CM_VehicleBookingTimeSlotItem;
	real : CM_VehicleBookingTimeSlotItem;
	proxy : CM_VehicleBookingTimeSlotItem;
	pxyParent : CM_VehicleBookingTimeSlot;
	booking : CM_BookingRef;
	bookingItem : CM_BookingRefItem;
	bulkRelease : CM_BulkRelease;
	reserveDetail : CM_ReserveDetail;
	ti : CM_TrackedItem;
	tmpTI : CM_TrackedItem;
	cType : CM_CargoType;
	sourceType : Integer;
	dir : Integer;
	
begin
	if _pxyHeader = null then
		// can't do anything without a header
		return null;
	endif;

	proxy := _pxyHeader.getItemBySequence(self.sequence);
	
	if proxy = null then
		create proxy transient;
	endif;

	if self.source.toUpper() = self.SRC_BOOKING.toUpper() then
		booking := self.getBookingRef(bookingItem);
		sourceType := CM_VehicleBookingTimeSlotItem.SOURCE_BOOKING;
		
	elseif self.source.toUpper() = self.SRC_RELEASE.toUpper() then
		bulkRelease := self.getBulkRelease(reserveDetail);
		sourceType := CM_VehicleBookingTimeSlotItem.SOURCE_RELEASE;
	else
		sourceType := CM_VehicleBookingTimeSlotItem.SOURCE_CARGO;
	endif;
	
	ti := self.getTI();
	
	if self.direction.toUpper() = self.DIR_DELIVERY.toUpper() then
		dir := DIRECTION_DELIVERY;
	elseif self.direction.toUpper() = self.DIR_PICKUP.toUpper() then
		dir := DIRECTION_PICKUP;
	endif;
	
	proxy.setProxy(	dir,
					booking,
					bookingItem,
					bulkRelease,
					reserveDetail,
					ti,
					_pxyHeader,
					self.quantity,
					self.sequence,
					sourceType,
					self.weight, null,
					null);	// ### TFS 61525 (61527) 11Jul2024 NAVPW1
	
	return proxy;
	
epilog

end;</source>
        <Parameter name="_pxyHeader" type="CM_VehicleBookingTimeSlot"/>
        <ReturnType type="CM_VehicleBookingTimeSlotItem"/>
    </JadeMethod>
    <JadeMethod name="getBookingRef" id="5e783f8e-8223-4bc7-b010-f3f6605ba008">
        <source>getBookingRef(_bookingRefItem : CM_BookingRefItem output) : CM_BookingRef;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 June 2023		jlizm1	Initial creation TFS 53901 EUP VBS EDI

*/

vars
	terminal : CM_Terminal;
	booking : CM_BookingRef;
	item : CM_BookingRefItem;
	tmpSequence : Integer;
	iter : Iterator;
	idx : Integer;
	
begin
	if self.bookingRef = null then
		return null;
	endif;
	
	terminal := self.getMyTerminal;
	
	if terminal = null then
		return null;
	endif;

	if self.operatorCode &lt;&gt; null then
		booking := terminal.getBookingReferenceLatest(self.operatorCode, self.bookingRef);
	else
		booking := terminal.getBookingReference(null, self.bookingRef, null);
	endif;
	
	if booking &lt;&gt; null then
		if booking.allBookingRefItems.size = 1 then
			_bookingRefItem := booking.allBookingRefItems.first;
			
		elseif booking.isSequenced and self.bookingItemSequence &lt;&gt; null then
			foreach item in booking.allBookingRefItems do
				if item.sequence = self.bookingItemSequence then
					_bookingRefItem := item;
					break;
				endif;
			endforeach;
			
		else
			tmpSequence := self.bookingItemSequence.Integer;
			if tmpSequence &gt; 0 and tmpSequence &lt;= booking.allBookingRefItems.size then
				iter := booking.allBookingRefItems.createIterator();
				idx := 1;
				while iter.next(item) do
					if idx = tmpSequence then
						_bookingRefItem := item;
						break;
					endif;
					idx := idx + 1;
				endwhile;
			endif;
		endif;
		
	endif;
	
	return booking;

epilog

end;</source>
        <Parameter name="_bookingRefItem" type="CM_BookingRefItem" usage="output"/>
        <ReturnType type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="getBulkRelease" id="79ee7f55-439a-432c-a91c-529b897ebfa7">
        <source>getBulkRelease(_reserveDetail : CM_ReserveDetail output) : CM_BulkRelease;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 June 2023		jlizm1	Initial creation TFS 53901 EUP VBS EDI

*/

vars
	terminal 	: CM_Terminal;
	release 	: CM_BulkRelease;
	detail 		: CM_ReserveDetail;
	ti 			: CM_TrackedItem;
	cType 		: CM_CargoType;
	
begin
	if self.bulkRelease = null then
		return null;
	endif;
	
	terminal := self.getMyTerminal;
	
	if terminal = null then
		return null;
	endif;
	
	release := terminal.getBulkReleaseActiveFromCode(self.bulkRelease, BR_TYPE_ROAD);
	
	if release = null then
		return null;
	endif;

	if release.allReserveDetails.size = 1 then
		_reserveDetail := release.allReserveDetails.first;
		return release;
	endif;
		
	if release.releaseByType and self.bulkReleaseLineNumber &lt;&gt; null then
		foreach detail in release.allReserveDetails	 do
			if detail.CM_ReserveSelection.lineNumber = self.bulkReleaseLineNumber then
				_reserveDetail := detail;
				break;
			endif;
		endforeach;
		
	elseif self.cargoId &lt;&gt; null and self.cargoTypeDescr &lt;&gt; null then
		cType := self.getCargoTypeObj();
		if cType = null then
			return release;
		endif;
		
		foreach detail in release.allReserveDetails	 do
			ti := detail.CM_ReserveTI.getTI();
			
			if ti = null then
				continue;
			endif;
			
			if ti.id = self.cargoId and ti.myCargoType = cType then
				_reserveDetail := detail;
				break;
			endif;
		endforeach;
	endif;		
	
	return release;

epilog

end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail" usage="output"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="getCargoTypeObj" id="1e6233b5-4e2c-4ecf-b3ee-539f24b4ff2b">
        <source>getCargoTypeObj():CM_CargoType;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 June 2023		jlizm1	TFS 53901 EUP VBS EDI
*/

vars

	cType : CM_CargoType;

begin

	cType := app.myRoot.allCargoTypesById[self.cargoType];
	
	if cType = null then
		if self.cargoTypeDescr.isInteger then
			cType := app.myRoot.allCargoTypesById[self.cargoTypeDescr.Integer];
		else
			cType := app.myRoot.getCargoTypeFromAbbrevOrDescr( self.cargoTypeDescr );
		endif;
	endif;
	
	return cType;

epilog

end;</source>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="036e5bcb-8fd8-46da-864c-87e078a7a2cc">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 June 2023		jlizm1	Initial creation TFS 53901 EUP VBS EDI

*/

vars
	rowName, type	: String;
	
begin
	if _attrName = ETRow_BookingItemSeq then
		return self.bookingItemSequence;
		
	elseif _attrName = ETRow_CargoID then
		return self.cargoId;
		
	elseif _attrName.isMeasurementType then
		_attrName.getRowNameMeasureType(rowName, type);
		return self.getMeasurementStringForAttrib(rowName, type, _short);
		
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTIDisplayDefName" id="5971cc0d-12d6-47ec-979f-7c8ae164a327">
        <source>getMyTIDisplayDefName(): String;
/*

Purpose:			

Parameters:			

Return Value:		

