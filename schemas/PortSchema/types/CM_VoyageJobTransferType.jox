    <JadeMethod name="setForUpdate" id="755c17a6-9a57-4487-85b5-e97e7b86f055">
        <updating/>
        <source>setForUpdate( _proxySelf: SelfType input; _passport: CM_Passport input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2018	jlgndl1	Initial creation	TFS 37444

*/

vars

begin

	if ( self.isSystem and self.id = 0 )
	or ( not self.isSystem and ( self.id &lt;&gt; _proxySelf.id ) )
	then
		self.id := _proxySelf.id;
	endif;
	self.description := _proxySelf.description;
	self.isSystem := _proxySelf.isSystem;
	self.myRoot := app.myRoot;
	self.code :=_proxySelf.code;
epilog

end;</source>
        <Parameter name="_proxySelf" type="SelfType" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
