    <JadeMethod name="doRefreshCalendar" id="2a09d801-7700-4177-abe7-d82c0c951f29">
        <updating/>
        <source>doRefreshCalendar( _immediate : Boolean ) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 October 2010	cnwndl1	Initial creation
//21 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	timeStampSystem : TimeStamp;
	date : Date;
	today : Date;
	
begin

	//10 Jun 2013	NDL Par 31665
	if not _immediate then
		// do timer stuff...
		if not timerSet then
			self.doSetTimer();
		endif;
		return;
	endif; 
	
	timeStampSystem.setDateTime(self.year,self.month,self.day,0,0,0,0);			// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	date := self.systemToLocalTime(timeStampSystem).date();			//21 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	today := self.systemToLocalTime(app.actualTimeServer()).date();	// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if self.cmbPeriod.text = ByMonth then
		self.txtDate.visible := false;
		self.btnBack.visible := false;
		self.btnNext.visible := false;
		self.mthPicker.visible := true;
		if date.isValid then
			self.mthPicker.setYear( date.year );
			self.mthPicker.setMonth( date );
		else
			self.mthPicker.setYear( today.year );
			self.mthPicker.setMonth( today );
		endif;
		
	elseif self.cmbPeriod.text = ByWeek then
		self.txtDate.visible := true;
		self.btnBack.visible := true;
		self.btnNext.visible := true;
		self.mthPicker.visible := false;
		if date.isValid then
			self.txtDate.setDate( date );
		else
			self.txtDate.setDate( today );
		endif;
		
	elseif self.cmbPeriod.text = ByDay then
		self.txtDate.visible := true;
		self.btnBack.visible := true;
		self.btnNext.visible := true;
		self.mthPicker.visible := false;
		date.setDate(day, month, year);
		if date.isValid then
			self.txtDate.setDate( date );
		else
			self.txtDate.setDate( today );
		endif;
		self.txtDate.setDate( date );
	
	endif;


	self.initTblCalendar();

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_immediate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="b2a347aa-e7eb-43e0-a06d-acbe11986d9b">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 October 2010	cnwndl1	Initial creation

*/

vars

	left : Real;
	top : Real;
	width : Real;
	height : Real;

begin

	inheritMethod();
	
	self.localToolBarResize();
	
	left := 1;
	top := self.frmToolbar.top + self.frmToolbar.height + 2;
	width := self.width - ( left * 2 ) - 6;
//	height := self.height - top - 40;
	height := self.height - top;
	self.splMain.move(	left,	//x : Real;
						top,	//y : Real;
						width,	//width2 : Real;
						height	//height2 : Real
						);
							
	if self.cmbPeriod.text = ByMonth or self.cmbPeriod.text = ByWeek then
		self.reScaleWeekMonthHeight();
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSetTimer" id="dfe20483-7e13-44fb-8089-b230d865532e">
        <updating/>
        <source>doSetTimer() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 June 2013	cnwndl1	Initial creation	Par 31665

*/
vars

	delay : Integer;

begin

	self.timerSet := true;
	delay := 2 * 60000;
	self.beginTimer(delay, Timer_OneShot, self.Timer_Set);

end;
</source>
    </JadeMethod>
    <JadeMethod name="doShowHideFilterSummary" id="67f9c6cd-e754-4df1-9d6d-448a79886809">
