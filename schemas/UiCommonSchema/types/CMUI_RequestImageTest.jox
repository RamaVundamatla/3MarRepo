    <JadeMethod name="translateForm" id="a2092dd1-d6f9-4f9e-b49b-7405c0cc998c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008053, locale);
	lblComments.translateCaption(Xlat_0008054, locale);
	lblContainer.translateCaption(Xlat_0008055, locale);
	lblDummyComment.translateCaption(Xlat_0008056, locale);
	lblEmailAddress.translateCaption(Xlat_0008057, locale);
	lblInstructions.translateCaption(Xlat_0014599, locale);
	lblName.translateCaption(Xlat_0008058, locale);
	lblPhoneNo.translateCaption(Xlat_0008059, locale);
	txtEmailAddress.translateBubbleHelp(Xlat_0018826, locale);
end;</source>
    </JadeMethod>
