    <JadeMethod name="isStopSetToBePrevented" id="b2fde208-cf0d-41d7-bf25-7210cab901f8">
        <source>isStopSetToBePrevented(_stopType : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:	02 October 2008 By Graeme Black cnwgb1
// Purpose:	Does a BOL have a Stop that prevents this action?
//			CCMS SFW 1012 Customs AMS Interface (PAR 17931)
// ---------------------------------------------------------------------------
vars
	stopTbl : CM_StopsTable;
	stop : CM_Stops;
begin
	if _stopType &lt; StopNull or _stopType &gt; StopMax then 
		return false;
	endif;
	if not self.allStops.isEmpty then
		foreach stop in self.allStops do
			stopTbl := stop.myStopsTable;
			if stopTbl &lt;&gt; null then
				if stopTbl.isToBePreventedBOLStop(_stopType, self, self.myTerminal) then
					return true;
				endif;
			endif;
		endforeach;
	endif;

	return false;
epilog
end;</source>
        <Parameter name="_stopType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
