    <JadeMethod name="genReceiptExternalNumber" id="5b50d65e-89c4-476d-9653-4d2fb77144ef">
        <source>genReceiptExternalNumber(_cashReceipt : CM_CashReceipt): String;
/*

Purpose:			

	Estimation code: Pelindo 1 have confirmed the following for the estimation code;
	
	the estimate number ex. 011801010961 consists of:
	013 = terminal code (same like pre invoice number) 3 Digits
	18 = year of created
	01 = month of created
	010961 = running number
	
	re Storage Calculation (37146.270);

Parameters:			

Return Value:		

Date			Who		Reason
22 March 2018	jlgndl1	Initial creation	TFS 37559
23 Oct 2024		navlw1	JIRA-33107: Invoice Logging Use Levels
*/
constants
	Sep1 : String = ".";
	Sep2 : String = ".";
	Sep3 : String = ".";
vars
	date : Date;
	term : CM_Terminal;
	taxStatusValue ,
	sapTermCode   ,
	yearValue   ,
	seqValue    ,
	monthValue  ,
	sequenceKey	,
	sequenceNum	,
	returnValue : String;
	
begin

	if _cashReceipt = null then
		return null;
	endif;
	term 	   := _cashReceipt.myTerminal;
	date 	   := _cashReceipt.dateTime.Date;
	yearValue  := date.format("yy");
	monthValue := date.format("MM");
	
	sapTermCode:= self.getPelindoSapTermCode( _cashReceipt.myTerminal );
	if sapTermCode = null  then
		app.invLog(method.qualifiedName &amp; " Terminal 'Additional Info 1', needs to set up.", LogINFO.String);
		return null;
	endif;
	
	//01.11.2018 cnwma1 TFS #41688
	if process.isInTransactionState then
		if self.myAutoExternalReceiptGen = null then
			self.createMyAutoExtReceiptNbrGen();
		endif;
		sequenceNum := self.myAutoExternalReceiptGen.getNextIdForYear( date );
	else
		beginTransaction;
		if self.myAutoExternalReceiptGen = null then
			self.createMyAutoExtReceiptNbrGen();
		endif;
		sequenceNum := self.myAutoExternalReceiptGen.getNextIdForYear( date );
		commitTransaction;
	endif;
	
	seqValue := sequenceNum.Integer.padLeadingWith('0', 6);
	
	returnValue := sapTermCode &amp; yearValue &amp; monthValue &amp; seqValue;

epilog

	return returnValue;

end;</source>
        <Parameter name="_cashReceipt" type="CM_CashReceipt"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="generateExternalNumber" id="7728898d-b918-4664-8656-c33c602af984">
        <source>generateExternalNumber(_invoice : CM_Invoice): String;
/*

Purpose:			
	The Pelindo1 external invoice number is 15 characters long. E.g. 2018014AA002576
	
	The first 4 digits are the year the pre-invoice was created. E.g. 2018
	The next 3 digits are the last two digits of the SAP terminal code (Set as Additional field #1 on the terminal) e.g. 01 for Belawan.
	The next three characters are the invoice type code (Set as the external code on the invoice type) e.g. 4AA is a voyage invoice).
	The last 6 digits are a zero padded sequence number that resets at the beginning of each year. 
Parameters:			

Return Value:		

Date			Who		Reason
22 March 2018	jlgndl1	Initial creation	TFS 37559
22 Nov   2018   cnwma1	ChangeRequest 42156: PEL1 - External Invoice Number - Additional field 1
23 Oct 2024		navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars
	autoExternalNumberGen : CM_AutoExternalNumberGen;
	term 		: CM_Terminal;
	invType 	: CM_InvoiceDesc;
	ts 			: TimeStamp;
	date 		: Date;
	yearValue   ,
	sapTermCode ,
	invTypeCode	,
	sequenceNum	,
	returnValue : String;

begin

	if _invoice = null then
		app.invLog(method.qualifiedName &amp; " No Invoice found.", LogTRACE.String);
		return null;
	endif;
	
	ts := _invoice.getRateDateFromStatus();
	if ts &lt;&gt; null and ts.date.isValid then
		date := ts.date;
	else
		date := _invoice.createdTime.Date;
	endif;
	
	yearValue := date.format("yyy");
	term 	  := _invoice.myTerminal;
	invType   := _invoice.invoiceType;
	
	if term = null then
		app.invLog(method.qualifiedName &amp; " No Terminal found.", LogTRACE.String);
		return null;
	endif;
	
	if invType = null then
		app.invLog(method.qualifiedName &amp; " No Invoice Type found.", LogTRACE.String);
		return null;
	endif;
	
	sapTermCode := self.getPelindoSapTermCode(term);
	
	if sapTermCode = null  then
		app.invLog(method.qualifiedName &amp; " Terminal 'Additional Info 1', needs to set up.", LogTRACE.String);
		return null;
	endif;
	
	// sapTermCode := sapTermCode[ ( sapTermCode.length - 1 ): 2];     // 22.11.2018 cnwma1 #42156
	
	if invType.externalReference.length &lt;&gt; 3 then
		app.invLog(method.qualifiedName &amp; " Invoice Type 'External reference' incorrect length, needs to 3 characters.", LogTRACE.String);
		return null;
	endif;
	
	invTypeCode := invType.externalReference;
	
	if process.isInTransactionState then
		if self.myAutoExternalNumberGen = null then
			self.createMyAutoExternalNumberGen();
		endif;
		sequenceNum := self.myAutoExternalNumberGen.getNextIdForYear( date );
	else
		beginTransaction;
		if self.myAutoExternalNumberGen = null then
			self.createMyAutoExternalNumberGen();
		endif;
		sequenceNum := self.myAutoExternalNumberGen.getNextIdForYear( date );
		commitTransaction;
	endif; 
	
	returnValue := yearValue;
	returnValue := returnValue &amp; sapTermCode;
	returnValue := returnValue &amp; invTypeCode;
	returnValue := returnValue &amp; sequenceNum;

epilog

	return returnValue;

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExternalInvoiceNumber" id="dd6f6b15-cac9-4758-9fdc-0c6a2cfe327f">
        <source>getExternalInvoiceNumber(_invoice: CM_Invoice): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 March 2018	jlgndl1	Initial creation	TFS 37559

*/

vars

	tranNum		: String;

begin

	tranNum := _invoice.getExternalInvoiceNumberRaw();
	if tranNum = null then	
		tranNum := self.generateExternalNumber( _invoice );
	endif;

	return tranNum;
	
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExternalReciptNumber" id="4a2ffcc8-8c3a-4608-bbb5-750de668dd92">
        <source>getExternalReciptNumber(_cashReceipt : CM_CashReceipt): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 March 2018	jlgndl1	Initial creation	TFS 37559

*/

vars

	tranNum		: String;

begin
	// the invoice type on the cash payment's proformadetails is needed in the external number.
	// do not want the SEQUENCE KEY SERIES number skipping any
	// This method is recalled later in the web services call
	if _cashReceipt.allCashPayments.isEmpty() then
		return inheritMethod(_cashReceipt);
	endif;
	
	tranNum := self.genReceiptExternalNumber(_cashReceipt);
						
	return tranNum;
	
epilog

end;</source>
        <Parameter name="_cashReceipt" type="CM_CashReceipt"/>
        <ReturnType type="String"/>
    </JadeMethod>
