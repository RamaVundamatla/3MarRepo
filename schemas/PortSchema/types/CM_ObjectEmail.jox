    <JadeMethod name="getToAddressCol" id="571a898a-2ec1-40a4-ab95-10b109949546">
        <source>getToAddressCol(_toAddresses: CM_EmailEntityByTypeNameDict input);
//----------------------------------------------------------------
//	Created:	28 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	email	: CM_EmailEntity;
begin

	if self.myEmailController &lt;&gt; null then
		foreach email in self.myEmailController.allToAddresses do
			_toAddresses.add(email);
		endforeach;
	endif;
	
end;</source>
        <Parameter name="_toAddresses" type="CM_EmailEntityByTypeNameDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getToAddresses" id="21633622-7f76-49c8-b325-d3bb445c1f8f">
        <source>getToAddresses(): String;
//----------------------------------------------------------------
//	Created:	24 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if self.myEmailController &lt;&gt; null then
		return self.myEmailController.freeTxtToAddesses;
	else
		return "";
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="okToSend" id="70695b8e-23ba-427b-9ac7-02933b5112f8">
        <source>okToSend(): Boolean;
//----------------------------------------------------------------
//	Created:	28 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if not self.enabled then
		return false;
	endif;
	
	if self.myEmailController &lt;&gt; null then
		if self.myEmailController.allToAddresses.isEmpty 
			and self.myEmailController.freeTxtToAddesses = null then		
			return false;
		else
			return true;
		endif;
	endif;
	
	return false; 
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
