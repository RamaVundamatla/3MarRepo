    <JadeMethod name="showSearchFrame" id="f499ea01-91cd-4715-8b6c-53a0e01fe747">
        <updating/>
        <source>showSearchFrame() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theFrame : CMUI_MoveableFrame;
begin
	self.txtSearch.text := null;
	self.txtSearch.visible := false;
	self.lblSearch.visible := false;
	
	theFrame := self.frmSearch;
	
	self.grpTranMapTypes.visible := true;
	self.grpTranMapTypes.parent := theFrame;
	self.grpTranMapTypes.left := 4;
	// 35872 if more than one business unit, enable business unit search on the types search
	if self.cmbBank.listCount &gt; 1 then
		self.lblSearch.caption  := "Business Unit";
		self.lblSearch.visible := false; // ### TFS 50421 17SEP2021 NAVAB1
		self.cmbBank.visible := true;
		self.grpTranMapTypes.top := 90;
		theFrame.height := 310; // TFS 39236 increased by 30 // TFS 51219

	else
		self.lblSearch.visible := false;
		self.cmbBank.visible := false;
		self.lblBank.visible := false;  // ### TFS 50421 12OCT2021 NAVAB1
		self.grpTranMapTypes.top := 30;
		theFrame.height := 310; // TFS 39236 increased by 30 // TFS 51219  // ### TFS 50421 12OCT2021 NAVAB1 made 310

	endif;

	
	
	self.lblBank.top := self.frmSeachToolbar.height; // ### TFS 50421 17SEP2021 NAVAB1
	self.cmbBank.top := self.lblBank.top + self.lblBank.height; // ### TFS 50421 17SEP2021 NAVAB1
	self.lblSearch.top := self.cmbBank.top  + self.lblBank.height; // ### TFS 50421 17SEP2021 NAVAB1
	self.txtBank.visible := false; // ### TFS 50421 17SEP2021 NAVAB1
	self.grpTranMapTypes.top := self.cmbBank.top  + self.lblBank.height + 10; // ### TFS 50421 17SEP2021 NAVAB1
	
	theFrame.zOrder(1);
	theFrame.centreWindow();
	theFrame.visible := true;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="5cd70f66-d89e-423f-963b-8f0382cdf64b">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
// 23659 turn off in-load state after ignoring notifications caused by it
vars
	now : Time;
begin

	// ### TFS 51912 14Sep2021 NAVPW1
	if eventTag = self.Timer_TableData_Filter then 
		self.doFilterTree();
		return;
	endif;

	if eventTag = 1 then
		self.startedTimer := false;
		self.inLoad := false;
	endif;
	
end;
</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="2a5e10b0-79b6-45fc-883a-f229a29ea240">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 April 2025 10:17:32.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006235, locale);
	btnCDCancel.translateBubbleHelp(Xlat_0019255, locale);
