    <JadeMethod name="addShipReceivals" id="9f129b3a-3207-4252-b63f-0399d0d342e6">
        <source>addShipReceivals( _voyage : CM_Voyage; _operator : CM_Operator; _mtGrade : CM_MTGrade ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

	port : CM_Port;
	strs : StringArray;
	cargo : CM_TrackedItem;
	theSlot : CM_LocationsController;
	idx : Integer;

begin

	port := app.myRoot.allPorts[_voyage.myTerminal.getConfig(PortDestCode).String];
	create strs transient;
	
	strs.clear;
	strs.add("030682");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch("THRS1110501", "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	beginTransaction;
		cargo.setAvailabilityGradeRT(_mtGrade.code, app.myPassport);
		cargo.setMyOperator( _operator );
		cargo.setReceiptTransportMode(TI_TRANSMODE_SHIP);
	commitTransaction;
	
	strs.clear;
	strs.add("030482");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch("THRS1110502", "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	beginTransaction;
		cargo.setAvailabilityGradeRT(_mtGrade.code, app.myPassport);
		cargo.setMyOperator( _operator );
		cargo.setReceiptTransportMode(TI_TRANSMODE_SHIP);
	commitTransaction;
	
	strs.clear;
	strs.add("030282");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch("THRS1110503", "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	beginTransaction;
		cargo.setMyOperator( _operator );
		cargo.setReceiptTransportMode(TI_TRANSMODE_SHIP);
	commitTransaction;
	
	strs.clear;
	strs.add("030182");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch("THRS1110504", "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	beginTransaction;
		cargo.setMyOperator( _operator );
		cargo.setReceiptTransportMode(TI_TRANSMODE_SHIP);
	commitTransaction;
	
	strs.clear;
	strs.add("030382");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch("THRS1110505", "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	beginTransaction;
		cargo.setMyOperator( _operator );
		cargo.setReceiptTransportMode(TI_TRANSMODE_SHIP);
	commitTransaction;
	
epilog

	delete strs;

end;</source>
