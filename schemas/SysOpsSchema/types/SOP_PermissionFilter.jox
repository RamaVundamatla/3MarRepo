    <JadeMethod name="setupAppsCombo" id="0cf2a871-5f8d-4f8c-942b-4f128f659757">
        <source>setupAppsCombo() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2018	jlger1	Initial creation

*/

vars
	allUsed : StringArray;
	used  : String;
	
begin
	
	
	create allUsed transient;

	self.myPermissionsAgent.getAllHandHeldAppsUsed(allUsed);

	foreach used in allUsed  do
			self.cmbHandHeldApp.addItem(used);
	endforeach;
	
epilog
	delete allUsed;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a35d3dd2-061c-440b-8de9-730ad2a88b2e">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2018	jlger1	Initial creation

*/

vars

begin
	inheritMethod();
	self.setupAppsCombo;
	self.setupWebservicesCombo;
	self.setupMobileAppsCombo;
	
	//05 Feb 2021	NDL	TFS 50757
	if self.mode = SOP_SecurityRoleForm.ViewTerminal then
		self.frmTermOpts.enabled := true;
	elseif self.mode = SOP_SecurityRoleForm.ViewSystem then
		self.frmTermOpts.enabled := false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupMobileAppsCombo" id="392afdb9-61d0-4a28-86af-f00c39e3c8d2">
        <source>setupMobileAppsCombo() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2018	jlger1	Initial creation

*/

vars
	allUsed : StringArray;
	used  : String;
begin	
	create allUsed transient;

	self.myPermissionsAgent.getAllMobileAppsUsed(allUsed);

	foreach used in allUsed do
			self.cmbMobileApp.addItem(used);
	endforeach;

	
epilog
	delete allUsed;

end;</source>
        <access>protected</access>
    </JadeMethod>
