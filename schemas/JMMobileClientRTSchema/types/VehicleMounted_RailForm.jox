    <JadeMethod name="checkErrors_msgBox" id="2b95eb8a-94c8-40af-9212-db02126a6ab6">
        <source>checkErrors_msgBox(): Boolean protected;
/*

Purpose:			


Return Value:		


Date			Who		Reason
16 June 2008	concms1	PAR 17123 (CCMS 1671) DCT GDansk RDT Screen to relocate containers

*/
vars
	errorMsg	:MobileHandHeldThin::DTO_HandHeldGateError;
	str			:String;
begin

	if self.allErrorMsgs.size &gt; 0 then
		foreach errorMsg in self.allErrorMsgs do
				str :=errorMsg.errorDescr &amp; CrLf;
		endforeach;
		
		app.msgBox(str,'Errors occurred', MsgBox_Exclamation_Mark_Icon);
		
		return true;
	endif;	

	return false;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearMoveDetails" id="2b288ff0-5f11-4e83-8ef5-69e6a605e1c1">
        <updating/>
        <source>clearMoveDetails() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
17 June 2008	concms1	PAR 17123 (CCMS 1671) DCT GDansk RDT Screen to relocate containers

*/

vars

begin
	lblLocation2.caption	:= null;
	lblOperator2.caption	:= null;
	lblISOType2.caption		:= null;
	lblWeight2.caption		:= null;
	txtMoveTo.text			:= null;
	
	self.currentContainerId_forMove	:= null;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doAcceptTask" id="17101ed1-4377-4aa2-87eb-667427f99f70">
        <updating/>
        <source>doAcceptTask()  protected, updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
15 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

	obj 		: Object;
	errorString : String;
	_type	: String;
	_containerId,
	_fromLoc,
	_toLoc: String;
	ostowValue,
	_ostow,
	_canEdit,
	_toIsVehicle: Boolean;
	errorMsg		: MobileHandHeldThin::DTO_HandHeldGateError;
	theTable 	: Table;
begin

	app.mousePointer	:=	Busy;
	theTable:=tblJobs;
	obj := theTable.accessRow(theTable.row).itemObject;
	if obj = null then
		app.msgBox("You must select an item in the list","Job",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	self.clearErrors;
	app.myVehicleMountedRailGuiAgent.doAcceptTask( obj.CM_RTQueueEntry,null,allErrorMsgs);
	
	if self.checkErrors then
		return;
	endif;

	acceptedRow:=theTable.row;
	
	app.myVehicleMountedRailGuiAgent.getMoveDetails(_type,_containerId,_fromLoc,_toLoc,_ostow,_canEdit,_toIsVehicle,allErrorMsgs);
	if self.checkErrors then
		app.myVehicleMountedRailGuiAgent.doCancelTask( obj.CM_RTQueueEntry,allErrorMsgs);
		return;
	endif;
	self.setupMsgFrameNew(_type,_containerId,_fromLoc,_toLoc,_ostow,_canEdit,_toIsVehicle);


epilog
	app.mousePointer	:=	Idle;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCancelTask" id="b8be9702-fdc1-4e81-b53b-39001c53a3a7">
        <updating/>
        <source>doCancelTask() updating, protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
18 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	obj : Object;
	errorMsg : MobileHandHeldThin::DTO_HandHeldGateError;
	theTable 	: Table;
begin
	app.mousePointer	:=	Busy;
	theTable:=tblJobs;
	if acceptedRow &lt;= theTable.fixedRows 
	or acceptedRow &gt; theTable.rows then
		app.msgBox("You must select an item in the list","Job",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	obj := theTable.accessRow(acceptedRow).itemObject;
	if obj = null then
		app.msgBox("You must select an item in the list","Job",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	self.clearErrors;
	app.myVehicleMountedRailGuiAgent.doCancelTask( obj.CM_RTQueueEntry,allErrorMsgs);
	
	if self.checkErrors then
		return;
	endif;
	
	self.frmAccept.visible := false;
	self.changeDefaultButtons(btnMsgOK,btnAccept);
	self.changeCancelButtons(btnMsgCancel,btnLogoff);
	
	self.acceptedRow:=null;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doControlChangedQueue" id="7669a702-3bfd-4f0a-b0f7-fd467e07556f">
