    <JadeMethod name="getQueueTasks" id="c45e5880-ec59-4052-b498-42e1d93e787a">
        <source>getQueueTasks(arbiter: CM_RTQueueArbiter input; _isSource : Boolean);
//Returns the tasks required to do a unit of work. (move a TI)
//Called from the RTQueueArbiter.
vars
	//isSource : Boolean;
begin
	//Determine if the ti in the arbiter transient is here.
	
	//AJA 13/1/00 Check if we currently hold the TI's front end
//	if arbiter.ti.getPrimaryLocation(REAL_MODE) = self then
//		isSource := true;			//we must be the source locn
//	endif;

	if _isSource then
		//This lc is the source of all evil.
	//	if trackedItems.indexOf(arbiter.ti) &lt; numTIs then
			//We have to shift something(s) from the TOP.
	//		self.getQueueOverstowTasks(arbiter);
	//	endif;// AJA 1/12/99: We no longer handle overstows at queue time only at pickup time */
		//------------
		//Get the TI to provide its "pickup tasks"
		//------------
		
		if arbiter.entry = null or not arbiter.entry.isPlanOnPickup then
			self.getPickupTasks(arbiter, false);
		elseif not arbiter.entry.isPlanOnPickupNoTarget then	
			//dont want to create a pickup task here.
		else
			self.getPickupTasks(arbiter, false);
		endif;
		
	else
		//Target.
		//------------
		//Get the target to provide its "set-down tasks"
		//------------
		self.getSetdownTasks(arbiter, false);
	endif;
end;</source>
        <Parameter name="arbiter" type="CM_RTQueueArbiter" usage="input"/>
        <Parameter name="_isSource" type="Boolean"/>
    </JadeMethod>
