    <DbClassMap file="basehtml"/>
    <PrimAttribute name="inputIsChecked" id="c4ba092f-5f2a-4a9c-8624-5c758719ae95">
        <embedded/>
        <type name="Boolean"/>
        <text>If type is TYPE_CHECKBOX or TYPE_RADIO (see inputType property), then
this property determines whether the field is selected by default.</text>
    </PrimAttribute>
    <JadeMethod name="buildTagBody" id="f697a5a8-70da-42df-becc-ac1d3c4b3caf">
        <source>buildTagBody(): String protected;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	htmlString	: String;

begin
	htmlString	:=	inheritMethod() &amp; ' CHECKED="' &amp; self.inputIsChecked.String.toUpper &amp; '"';
	
	return htmlString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="37b33e0c-21a8-459a-862a-badb6135fa07">
        <updating/>
        <source>create() updating;
// -----------------------------------------------------------------------------
// Created:		30 November 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.inputType	:=	self.TYPE_CHECKBOX;
end;</source>
    </JadeMethod>
</Class>
