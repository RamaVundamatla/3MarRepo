    <JadeMethod name="jssFindStringColumn" id="87e67c56-3c9a-4e7c-86f0-5035fb2e2e84">
        <updating/>
        <source>jssFindStringColumn(pValue:String):JadeTableColumn updating;
// --------------------------------------------------------------------------------
// Created:		04 August 2001 by cnwdad1
//
// Purpose:		This method scans the receiver's columns and returns the first
//				JadeTableColumn with a cell who's text matches the pValue parameter.
//
// Parameters:	pValue - The string to search for.
//
// Returns:		The JadeTableColumn for the (first) column with a cell with text
//				matching pValue, or null if the string isn't found.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowIndex		: Integer;
	columnIndex		: Integer;
	startRow		: Integer;
	startColumn		: Integer;
	rowCount		: Integer;
	columnCount		: Integer;
	
begin
	startRow	:=	self.fixedRows + 1;
	startColumn	:=	self.fixedColumns + 1;
	rowCount	:=	self.rows;
	columnCount	:=	self.columns;
	
	foreach rowIndex in startRow to rowCount do
		foreach columnIndex in startColumn to columnCount do
			if self.getCellText(rowIndex, columnIndex) = pValue then
				return self.accessColumn(columnIndex);
			endif;
		endforeach;
	endforeach;
end;</source>
        <text>___________________________________________________________________________

