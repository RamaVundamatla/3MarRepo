    <JadeMethod name="shouldAuditProperty" id="2fbdd5b7-9adb-4685-83c9-23d09fb38aa9">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars
	propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_WorkOrderTI::mySource.name    						or 
		propName = CM_WorkOrderTI::allLinkedWorkOrderTISource.name 			
		then
		return false;
		
	endif;
	return inheritMethod(_rootClass, _property);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateCustomsExportEntryNum" id="dff350d6-9cdd-47ac-a801-dd9c8e35309c">
        <source>updateCustomsExportEntryNum(_passport : CM_Passport input);
/*

Purpose:			
	
	History :
	20.6.2018 cnwma1 TFS #38815
Parameters:			

Return Value:		

Date		Who		Reason
19 Jul 2022	navcs2	ChangeRequest 53932: MTN - Jobs Changes
24 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI

*/

vars
	wod : CM_WorkOrderDtl;
	ti	: CM_TrackedItem;
begin
	
	if self.myTerminal.isUseYardJobsForCargoWo then
		return;
	endif;
	
	foreach wod in self.allWoDtls do 
		if not wod.isKindOf(CM_WodReceive) then
			continue;
		endif;
		
		if wod.CM_WodReceive.customExportEntryNumber = null then
			continue;
		endif;
		
		foreach ti in wod.CM_WodReceive.allAvailableTIs do
			app.myUtilityUA.utlUpdateTICEDO (ti, wod.CM_WodReceive.customExportEntryNumber, null, true, _passport);
		endforeach;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateFromSourceTIlist" id="662f7902-2499-45e3-a1c8-63a88a1dddf4">
        <source>updateFromSourceTIlist(  _oldList: String; _newList : String );

/*

Purpose:			
User has updated the ti list on the work order source, this work order is approved or greater.
We need to check to see if any items on the old list are removed, if so remove them
And if any items on the new list dont already exist on the WO, if so we add.

Parameters:			

Return Value:		


Date		Who		Reason
08 Jan 2010	cnwrd1	Initial creation
19 Jun 2018 jlger1  wasn't adding prenotes and removing prenotes
02 Jul 2019	NDL		TFS 45336 - Not handling pre-notes correctly    		
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
*/

vars
	oldArray,
	newArray	: HugeStringArray;
	tiID 		: String;
	ti 			: CM_TrackedItem;
begin

	create oldArray transient;	
	_oldList.parseCSV(oldArray);
	
	create newArray transient;	
	_newList.parseCSV(newArray);
	
	
	//check to see if any of the old array is now not existant on the new array - dangerous? may be on one of the other sources?
	
	foreach tiID in oldArray do
		if not newArray.includes(tiID) then
			//remove			
			ti := self.myTerminal.lookupTrackedItem(tiID.trimBlanks(), self.mySource.cargoType, TI_STATE_NORMAL, null, false);
			if ti &lt;&gt; null and ti.id = tiID then
				self.removeTrackedItem(ti);
			endif;
			
			if self.getFirstTask.isWorkOrderForReceival
			or self.getFirstTask.isWorkOrderForNullVoyage	//22 Aug 2018	NDL	TFS 40157
			then
				ti := self.myTerminal.lookupTrackedItem(tiID.trimBlanks(), self.mySource.cargoType, TI_STATE_NOTIFIED, null, false);
				if ti &lt;&gt; null and ti.id = tiID then
					self.removeTrackedItem(ti);
				endif;
			endif;
					
		endif;
	endforeach;
	
	//now check the new string for new items.

	
	foreach tiID in newArray do
		//epr voyage work orders make sure added when at pending approval
		
		//add	
		if self.getFirstTask.isWorkOrderForReceival then
			//don't want anything on-site for a receival, only pre-notes.
		else
			ti := self.myTerminal.lookupTrackedItem(tiID.trimBlanks(), self.mySource.cargoType, TI_STATE_NORMAL, null, false);
			if ti &lt;&gt; null and ti.id = tiID then
				self.addTrackedItem(ti,self.getFirstTask);							//08.02.2023 navma1 #56457 Task#56458
				continue; // OK, got one on-site one, don't look for pre-notes
			endif;
		endif;		
		
		if self.getFirstTask.isWorkOrderForReceival
		or self.getFirstTask.isWorkOrderForNullVoyage	//22 Aug 2018	NDL	TFS 40157
		then
			//These guys are valid to be associated with pre-notes.
			ti := self.myTerminal.lookupTrackedItem(tiID.trimBlanks(), self.mySource.cargoType, TI_STATE_NOTIFIED, null, false);
			if ti &lt;&gt; null and ti.id = tiID then
				self.addTrackedItem(ti,self.getFirstTask);							//08.02.2023 navma1 #56457 Task#56458
			endif;
		endif;
		
	endforeach;
	
	
	
epilog
	delete oldArray;
	delete newArray;
end;

</source>
        <Parameter name="_oldList" type="String"/>
        <Parameter name="_newList" type="String"/>
    </JadeMethod>
    <JadeMethod name="useTIProforma" id="94c173e0-92a8-42f1-9b61-a00bfa95e70e">
        <source>useTIProforma(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2019	jlgndl1	Initial creation	TFS 43405

*/

vars

begin

	if self.isWorkOrderForReceival() or self.isWorkOrderForRelease then
		return true;
	endif;

	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForApproval" id="730411c7-7a26-472c-b3ae-a5e4e61c6fc9">
        <source>validateForApproval();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 Aug 2009	cnwrd1	Initial creation
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
06 Mar 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
*/

vars

begin

	inheritMethod();
	
	// validate source items - check if ti list exists and on site
	// check source items for (current)duplicates
	// check if we have a request by type, if so check if our first task is a move.
	
	/*
	12.01.2023 navma1 #56141 Task#56147
	// check source count = total required
	if self.totalRequired &gt; self.mySource.getTotalCargoCount() then
		app.raiseCMWarning(Cargo_items_reque_less_than_nu, null , null, self);		
	endif;
	*/
	
	/*
	//06.03.2023 navma1 #56457:[56458]
	if self.totalRequired = 0
	and not self.isWorkOrderForReleaseExtension	//15 Mar 2019	NDL	TFS 43405
	then
		app.raiseCMException(Total_cargo_require_zero,null,null);
	endif;
	*/
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="8f3e189e-8376-4754-8c7f-d73afa334b06">
        <source>validateForCreate();

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
11 Aug 2009		cnwmd1	Initial creation
18 May 2022		navcs2	ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
22 Jun 2022		navcs2	Bug 52489: MTN - Cargo Work Orders for ToDo Tasks Issue Cargo Types
12 Jan 2023		navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
08 Feb 2023		navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
*/

vars
	ti	 : CM_TrackedItem;
	task : CM_WorkOrderDtl;
begin
	
	//26.05.2022 navma1 #53038
	// TFS 53038 18/05/2022 navcs2
	/*
	08.02.2023 navma1 #56457 Task#56458
	if self.getTotalRequired &lt; 1 and not self.isWorkOrderForRelease then			//07.02.2023	navcs2	ChangeRequest 55440 (54990)	
		app.raiseCMException(Input_req_total_required_field, null, null);
	endif;
	*/
	
	if self.myTerminal.isUseYardJobsForCargoWo = true then
		if not self.requiredByDT.isValid then
			app.raiseCMException(Work_order_yard_req_date, null, null);
		endif;
	endif;
	
	/*
	12.01.2023 navma1 #56141 Task#56147
	if self.taskStatus = WO_STATUS_APPROVED or self.taskStatus = WO_STATUS_PARTCOMPLETE then
		if self.totalRequired &gt; self.mySource.getTotalCargoCount() then
		app.raiseCMWarning(Cargo_items_reque_less_than_nu, null , null, self);
		endif;
	endif;
	
	self.mySource.validateForCreate();
	*/
	inheritMethod();
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="3de283ea-4f44-4aac-b851-509f6467893a">
        <source>validateForDelete();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 Mar 2010	cnwrd1	Initial creation
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
26 Sep 2023 navhl20 Bug 60689: MTN - Validation required to stop deleting Work order if it has jobs
*/

vars
	wod  : CM_WorkOrderDtl;
begin
	if self.taskStatus &gt; WO_STATUS_NOTAPPROVED 	then  //do not allow deleting of approved or on
		foreach wod in self.allWoDtls do				//26.9.2023 navhl20 #60689
			if wod.getTotalActioned &gt; 0 or wod.CM_WorkOrderTIDtl.allJobs.isNotEmpty then
				app.raiseCMException(Work_order_canno_delet_with_st, null, null);
			endif;
		endforeach;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="e81f7829-b397-4ea0-8be5-ef50a8907afa">
        <source>validateForUpdate();

/*

Purpose:			

Parameters:			

Return Value:		


Date  		Who		Reason
11 Aug 2009	cnwmd1	Initial creation
14 May 2022	NAVCS2	ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
22 Jun 2022	navcs2	Bug 52489: MTN - Cargo Work Orders for ToDo Tasks Issue Cargo Types
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
07 Feb 2023	navcs2	ChangeRequest 55440: EUP - Cargo Work Order Enhancements (54990)
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task

*/

vars
	realWO : CM_WorkOrderTI;
	ti	   : CM_TrackedItem;
	task   : CM_WorkOrderDtl;
	wod    : CM_WorkOrderDtl;
begin

	if self.isTransient then
		realWO := self.pxyGetRealObject();
	else
		realWO := null;
	endif;

	
	/*
	//06.03.2023 navma1 #56457:[56458]
	if  realWO &lt;&gt; null then	
		if realWO.totalRequired &gt; self.totalRequired then	 
			if realWO.hasBeenApproved() then 
			// shouldnt allow decreasing total required once approved.		
				app.raiseCMException(Canno_reduc_total_requi_value, null, null);
			endif;
		endif;
	endif;
	*/
	
	/*
	08.02.2023 navma1 #56457:[56458]
	// TFS 53038 18/05/2022 navcs2
	if self.getTotalRequired &lt; 1 and not self.isWorkOrderForRelease then			//07.02.2023	navcs2	ChangeRequest 55440 (54990)								
		app.raiseCMException(Input_req_total_required_field, null, null);
	endif;
	*/
	
	/*
	/08.02.2023 navma1 #56457:[56458]
	// TFS 53038 18/05/2022 navcs2
	if self.allTIs.isEmpty and not self.isWorkOrderForRelease then 					//07.02.2023	navcs2	ChangeRequest 55440 (54990)
		app.raiseCMException(Work_order_must_have_least_ti, null, null);
	endif;
	*/
	
	// TFS 53038 30/05/2022 navcs2
	if self.myTerminal.isUseYardJobsForCargoWo = true then
		if not self.requiredByDT &lt;&gt; null then
			app.raiseCMException(Work_order_yard_req_date, null, null);
		endif;
	endif;
	
	/*
	12.01.2023 navma1 #56141 Task#56147
	if self.taskStatus = WO_STATUS_APPROVED or self.taskStatus = WO_STATUS_PARTCOMPLETE then
		if self.totalRequired &gt; self.mySource.getTotalCargoCount() then
		app.raiseCMWarning(Cargo_items_reque_less_than_nu, null , null, self);
		endif;
	endif;
	
	self.mySource.validateForUpdate();
	*/
	
	inheritMethod();
epilog

end;</source>
    </JadeMethod>
</Class>
