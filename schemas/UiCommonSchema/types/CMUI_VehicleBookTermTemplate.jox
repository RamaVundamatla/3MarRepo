    <JadeMethod name="translateForm" id="d3fd5eb5-df67-4dee-926e-22e2cec34135">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:44:50.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023343, locale);
	btnAddDay.translateCaption(Xlat_0023346, locale);
	btnClose1.translateCaption(Xlat_0023348, locale);
	btnDelDay.translateCaption(Xlat_0023344, locale);
	btnUpdDay.translateCaption(Xlat_0023345, locale);
	lblTerminal.translateCaption(Xlat_0023347, locale);
end;</source>
    </JadeMethod>
</GUIClass>
