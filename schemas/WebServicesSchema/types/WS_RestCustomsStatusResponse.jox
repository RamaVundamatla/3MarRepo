<Class name="WS_RestCustomsStatusResponse" id="0985c2ab-e3b0-4d56-8a37-9bf82892ee22">
    <superclass name="WS_Response"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="customsReferences" id="907c8744-4688-4f05-bf4c-9b80bd51b80c">
        <embedded/>
        <type name="WS_RestCustomsReferenceArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="stops" id="814a0a76-da91-4979-ba94-50cdd460c604">
        <embedded/>
        <type name="WS_RestStopArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="delete" id="f47d7d22-ce60-4019-88f9-32a80382666c">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 July 2024	navhn30	Initial  ChangeRequest 64906: CUX | EDBIC Stop type information on GET/ customs status

*/

vars

begin
	if self.stops &lt;&gt; null then
		self.stops.purge;
	endif;
	if self.customsReferences &lt;&gt;  null then
		self.customsReferences.purge;
	endif;
	
	delete self.stops;
	delete self.customsReferences;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="a9a7cddc-bf4a-4106-9db8-d873164584f8">
        <updating/>
        <source>setProxyFromObject(_realTrackedItem : CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 July 2024	navhn30	Initial creation 	ChangeRequest 64906: CUX | EDBIC Stop type information on GET/ customs status

*/

vars
	allCustomsReferences	: CM_CustomsReferenceDict;
	allStops				: CM_StopsByIdDict;
	stop					: CM_Stops;
	customsReference		: CM_CustomsReference;
	wsStop					: WS_RestStopObject;
	wsStops					: WS_RestStopArray;
	wsCustomsReferences		: WS_RestCustomsReferenceArray;
	wsCustomsReference		: WS_RestCustomsReferenceObject;
	theStopTable			: CM_StopsTable;

begin

	allCustomsReferences := _realTrackedItem.allCustomsReferences;
	if allCustomsReferences &lt;&gt; null and allCustomsReferences.isNotEmpty then
		create wsCustomsReferences transient;
		
		foreach customsReference in allCustomsReferences do
			create wsCustomsReference transient;
			wsCustomsReference.setProxyFromObject(customsReference);
			wsCustomsReferences.add(wsCustomsReference);
		endforeach;
		
		self.customsReferences := wsCustomsReferences;
		
	endif;
	// check stops exist first									
	allStops	:= _realTrackedItem.getAllStops;
	if allStops.isNotEmpty then
		create wsStops transient;
		foreach stop in allStops do
			create wsStop transient;
			theStopTable := app.myRoot.allStopsTable[stop.id];
			wsStop.setProxyFromObject(theStopTable);
			wsStops.add(wsStop);
		endforeach;
		
		self.stops := wsStops;
	endif;
	// stops end
epilog

end;</source>
        <Parameter name="_realTrackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
