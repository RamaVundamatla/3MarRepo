    <JadeMethod name="doComparePorts" id="a8bbf473-dbf5-4e29-bc7e-6a41c21e2b42">
        <source>doComparePorts(_rowName :String; _release :CM_BulkRelease; _ediTI :CM_EDIReleaseRequestTI):Boolean protected;
/*
Date		Who		Reason
05 Aug 2013	cnwcs5	CCMS POL 2221 / par 32094
*/
vars
	port	:CM_Port;
	ediPort	:String;
begin
	if _rowName = ETRow_DischargePort then
		ediPort := _ediTI.dischargePort;
		port	:= _release.myDischargePort;
		
	elseif _rowName = ETRow_LoadPort then
		ediPort := _ediTI.loadPort;
		port	:= _release.myLoadPort;
		
	elseif _rowName = ETRow_DestinationPort then
		ediPort := _ediTI.destinationPort;
		port	:= _release.myDestinationPort;
	endif;
	
	if port &lt;&gt; null and port.code = ediPort then
		// match
		return true;
	endif;

	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <Parameter name="_ediTI" type="CM_EDIReleaseRequestTI"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblDataContextMenu" id="543434c7-4501-4cd7-aa6b-3fafe4f97f5c">
        <updating/>
        <source>doTblDataContextMenu(_table: CM_DataTable input; _conwin: Window input; _mouse: Boolean; _x: Integer; _y: Integer): Boolean updating, protected;
/*
Date		Who		Reason
01 Aug 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
17 Aug 2017 cnwma1	TFs #4596 POL - Cannot ignore fields during EDI Release Request Update
*/
vars
	row			:Integer;
	obj			:Object;
	release		:CM_BulkRelease;
	type		:Integer;
	user		:CM_User;
	terminal	:CM_Terminal;
	canUpdate	:Boolean;	
begin
	row 		:= _table.row; 
	user 		:= app.getMyUser;
	terminal	:= self.myTerminal;
		
	if row &gt;= _table.fixedRows then
		obj := _table.accessRow (row).itemObject;
	endif; 
	
	//epr TFS 2606 19/9/16
	self.mnuLoadToDB.visible:=false;
	self.mnuVerify.visible:=false;
	self.mnuProcessEDI.visible 	:= false;
	self.mnuIgnoreEDI.visible	:= false;
	self.mnuUpdateAttribute.enabled :=false;

	canUpdate := user.canDo (terminal, PmAdmEdiopersMaint);
	
	if canUpdate then		
		self.mnuProcessEDI.enabled 	:= true;
		self.mnuIgnoreEDI.enabled	:= true;
		foreach obj in _table.allSelectedObjects do
			if not obj.isKindOf (CM_EDITrackedItem) then
				continue;
			endif;	
			if obj.isKindOf(CM_EDITrackedItem) then
				//epr TFS 2606 16/9/16
				if obj.CM_EDITrackedItem.status = CM_EDIFile.EDI_STATUS_VERIFIED then
					self.mnuLoadToDB.visible :=true;
				endif;
				if obj.CM_EDITrackedItem.canBeVerfied then
					self.mnuVerify.visible :=true;
				endif;
					self.mnuUpdateAttribute.visible := false;	// 17.8.2017 cnwma1 TFS #4596
			endif;
			
			if obj.CM_EDITrackedItem.status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING or
				obj.CM_EDITrackedItem.status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X then
					self.mnuProcessEDI.enabled 	:= true;
			endif;
			
			if obj.CM_EDITrackedItem.status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X then
				self.mnuIgnoreEDI.enabled	:= true;
			endif;			
		endforeach;
	else	
		
	endif;
	
	self.mnuViewRelease.enabled	:= false;
	
	if obj &lt;&gt; null and obj.isKindOf (CM_BulkRelease) then
		release := obj.CM_BulkRelease;
	endif;
	
	if obj.isKindOf (CM_ReserveDetail) then
		release := obj.CM_ReserveDetail.myReserveHeader;
	endif;
	
	if release &lt;&gt; null then
		type 		:= release.type;
		if release.allReserveDetails.size = 1 then
			self.mnuUpdateAttribute.enabled :=true;	// 17.8.2017 cnwma1 TFS #4596
		endif;
		if type = BR_TYPE_UNKNOWN and user.canDo (terminal, PmGteMTReleaseViewUnknown) then
			self.mnuViewRelease.enabled	:= true;
		elseif type = BR_TYPE_ROAD and user.canDo (terminal, PmGteMTReleaseViewRd) then
			self.mnuViewRelease.enabled	:= true;
		elseif type = BR_TYPE_RAIL and user.canDo (terminal, PmGteMTReleaseViewRail) then
			self.mnuViewRelease.enabled	:= true;
		elseif type = BR_TYPE_SHIP and user.canDo (terminal, PmGteMTReleaseViewShip) then
			self.mnuViewRelease.enabled	:= true;
		elseif type = BR_TYPE_PACKING and user.canDo (terminal, PmGteMTReleaseViewGen) then
			self.mnuViewRelease.enabled	:= true;
		endif;
	endif;
	
	
	return self.showContextMenu(self.mnuPopup, _table, _conwin, _mouse, _x, _y);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_conwin" type="Window" usage="input"/>
        <Parameter name="_mouse" type="Boolean"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblData_dblClick" id="df4c5ade-f60a-4de2-b646-75a5ad13cc0e">
        <source>doTblData_dblClick(_table: CM_DataTable) protected;
/*
Date		Who		Reason
05 Aug 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
*/
vars
	row	:Integer;
begin
	row	:= _table.row;
	
	if row &lt;= _table.fixedRows then
		return;
	endif;
	
	if _table.getCellText (row, 2) = self.SOURCE_DB then
		self.doViewDatabaseItem;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="doTblData_mouseDown" id="24c1d642-7898-42e7-9cf6-ada1f7880ca4">
        <source>doTblData_mouseDown(_table :CM_DataTable input)protected;
/*
Date		Who		Reason
21 Aug 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
*/
vars
	row	:Integer;
	obj						:Object;
begin
	
	if  self.btnSaveBase.enabled then
		return;
	endif;
	self.btnEdit.enabled:=false;
	
	// make sure all EDi TIs in the same group are selected
	row := _table.row;
	obj	:= _table.accessRow(row).itemObject;
	
	if obj = null then
		return;
	endif;
	
	if not obj.isKindOf (CM_EDIReleaseRequestTI) then
		// just select it
		return;
	endif;			
	
	_table.selectRow (row, false);
	self.btnEdit.enabled:=_table.allSelectedObjects.size = 1; //epr TFS 2606 10/3/17
	
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUpdateAttribute" id="9237fe20-292a-46ea-b818-e993d8ac8c83">
        <source>doUpdateAttribute(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Aug 2017 cnwma1	TFs #4596 POL - Cannot ignore fields during EDI Release Request Update

*/

vars
	pxyRelease : CM_BulkRelease;
	pxyReserveSelection : CM_ReserveSelection;
	result				: Integer;
	loadState           : Boolean;
begin
	
	if self.attributeName = null  then
		return false;
	endif;
	
	app.cmsBeginLoad(loadState);
	
	pxyRelease := self.myReserveSelection.myReserveHeader.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
	pxyReserveSelection := pxyRelease.allReserveDetails.first.CM_ReserveSelection;	
	pxyReserveSelection.setMyHeader(pxyRelease);
	
	
	pxyRelease.setProxyFromComparison(self.attributeName,self.updateValue);
	pxyReserveSelection.setProxyFromComparison(self.attributeName,self.updateValue);
	pxyRelease.requests.purge();

	while true do			

		app.myTrxUA.trxUpdateBulkRelease(pxyRelease, null, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Release Request update', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;
epilog
	app.cmsEndLoad(loadState);	
	delete pxyReserveSelection;
	delete pxyRelease;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doViewDatabaseItem" id="0514b13b-5341-4578-af3a-257293108678">
        <source>doViewDatabaseItem() protected;
/*
Date		Who		Reason
05 Aug 2013	cnwcs5	CCMS POL 2221 / par 32094
*/
vars
	table	:CM_DataTable;
	row		:Integer;
	obj		:Object;
	release	:CM_BulkRelease;
begin
	table 	:= self.tblData;
	row		:= table.row;
	
	if row &lt;= table.fixedRows then
		return;
	endif;
	
	obj	:= table.accessRow (row).itemObject;
	
	if not obj.isKindOf (CM_ReserveDetail) then
		return;
	endif;
	
	release := obj.CM_ReserveDetail.myReserveHeader;
	
	if release = null then 
		return;
	endif;
	
	self.myAssistant.releaseRequestView (release, self.myMasterMenuAction);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="findMatchesForEDI" id="f5cd86ec-2a10-4c9a-a02a-360311a89916">
        <source>findMatchesForEDI(_ediColl :ObjectArray; _dbColl :ObjectArray input; _release :CM_BulkRelease) protected;
/*
Parameters	_ediColl	- edi TIs in order of display
			_dbColl		- empty coll
			
Date		Who		Reason
02 August 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
*/
vars
	ediColl, dbColl	:ObjectSet;
	obj				:Object;
	ediTI			:CM_EDIReleaseRequestTI;
	detail			:CM_ReserveDetail;
	ti				:CM_TrackedItem;
	index		:Integer;
	isMatch, isTypeChange	:Boolean;
begin
	if _release = null then
		return;
	endif;
	
	create ediColl transient;
	
	_ediColl.copy (ediColl);
	
	if _dbColl.size &lt; _ediColl.size then
		_dbColl [_ediColl.size] := null;
	endif;
	
	// dbColl keeps a tracked of matched reserves
	create dbColl transient;
	
	_release.allReserveDetails.copy (dbColl); 
	
	// can we find an EXACT match for this item in the edi file
	foreach obj in ediColl do
		ediTI := obj.CM_EDIReleaseRequestTI;
		
		if ediTI.releaseByType &lt;&gt; _release.releaseByType then
			// change from/to release by type - no point looking for matches
			isTypeChange := true;
			
			ediColl.clear;
			
			break;
		endif;
	
		foreach obj in dbColl do
			if _release.releaseByType then
				detail := obj.CM_ReserveSelection;
				isMatch := detail.isEDIMatch (ediTI, true);
			else				
				detail 	:= obj.CM_ReserveTI;
				ti		:= detail.CM_ReserveTI.getTI;
				
				if ti &lt;&gt; null and ti.id = ediTI.id then
					isMatch := true;
				endif;
			endif;
				
			if isMatch then
				// add DB item to _dbColl at same index as EDI item is in _ediColl				
				index := _ediColl.indexOf (ediTI);
				
				_dbColl[index] := detail; 
				
				// removed EDI/DB items from collections as they are matched
				dbColl.remove (detail);
				ediColl.remove (ediTI);
				break;
			endif;
		endforeach;
	endforeach;
	
	if ediColl.size &gt; 0 and _release.releaseByType then
		// still some edi items not match - try for PARTIAL match
		foreach obj in ediColl do
			ediTI := obj.CM_EDIReleaseRequestTI;
				
			foreach obj in dbColl do
				detail := obj.CM_ReserveDetail; //epr TFS 2606 10/3/17
			
				if detail.isEDIMatch (ediTI, false) then
					// add DB item to _dbColl at same index as EDI item is in _ediColl				
					index := _ediColl.indexOf (ediTI);
					
					_dbColl[index] := detail; 
					// removed EDi/DB items from collections as they are matched
					dbColl.remove (detail);
					ediColl.remove (ediTI);
					break;
				endif;
			endforeach;
		endforeach;		
	endif;
	
	if ediColl.size &gt; 0 and dbColl.size &gt; 0 then
		// still some not matched - just allocate to any remaining reserves
		foreach obj in ediColl do 
			ediTI	:= obj.CM_EDIReleaseRequestTI;
			detail 	:= dbColl.first.CM_ReserveDetail; //epr TFS 2606 10/3/17
			
			if detail &lt;&gt; null then
				index 	:= _ediColl.indexOf (ediTI);
						
				_dbColl[index] := detail;
				
				dbColl.remove (detail);
				ediColl.remove (ediTI);
			else
				// all db items have been matched
				break;
			endif;
		endforeach;
	endif;		
	
	if dbColl.size &gt; 0 then	
		// soms db items that do not have corresponding items - just copy over
		dbColl.copy (_dbColl); 
	endif;
epilog
	delete ediColl;
	delete dbColl;
end;</source>
        <access>protected</access>
        <Parameter name="_ediColl" type="ObjectArray"/>
        <Parameter name="_dbColl" type="ObjectArray" usage="input"/>
        <Parameter name="_release" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="getAllAvailableFields" id="f92d2290-0ca6-469a-9456-5f0322188f20">
        <source>getAllAvailableFields(_coll :EntTableRowArray input) protected;
/*
Date		Who		Reason
31 July 2013	cnwcs5	CCMS POL 2221 / par 32094
*/
vars
	etDef	:EntTableDef;
begin
	etDef := app.myController.getEntTableDef (ETDef_EDITIReleaseRequest);
	
