    <JadeMethod name="displayPropData" id="30d5432a-eab8-4ff1-9a8f-c50f7edce467">
        <updating/>
        <source>displayPropData() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 29/3/22  jlier1	TFS 53286
//15 Dec 2023 navbs1  ChangeRequest 61770: SAL - Service Schedule Data
vars
	theForm : SelfType;
	idx	: Integer;
	cell	: JadeTableCell;
begin
	if self.updateMode = self.UpdateMode_New then
		self.loadGLCodes();
		self.fldProperties.topSheet := self.shtPropOne;
		self.tblProperties.clearValues();
		self.cmbGL.listIndex := 1;
		self.cmbTaxCode.listIndex := 1;
		self.cmbRateTypes.listIndex := 1;
		self.cmbRateTypes.lostFocus(self.cmbRateTypes);
		self.cmbGL.lostFocus(self.cmbGL);
		self.tblProperties.enableRowByName(ETRow_CalculationType);
		self.tblProperties.hideRowByName(ETRow_RateHookCode, false);

		if self.modePropertyNew = self.MODEPROPERTY_GROUP then
			self.tblProperties.hideRowByName(ETRow_CalculationType, false);
			self.tblProperties.hideRowByName(ETRow_TaxCode, false);
			self.tblProperties.hideRowByName(ETRow_RateType, false);
			self.tblProperties.hideRowByName(ETRow_IsNotAvailableForEntryCk, false);
			self.tblProperties.hideRowByName(ETRow_ExternalReference1, false);    		//15.12.2023 navbs1 #61770
			self.tblProperties.hideRowByName(ETRow_ExternalReference2, false);    		//15.12.2023 navbs1 #61770
		else
			self.tblProperties.showRowByName(ETRow_CalculationType, false);
			self.tblProperties.showRowByName(ETRow_TaxCode, false);
			self.tblProperties.showRowByName(ETRow_RateType, false);
			self.tblProperties.showRowByName(ETRow_IsNotAvailableForEntryCk, false);
		endif;
		
	else
		inheritMethod();
		theForm := self;
		self.fldProperties.topSheet := self.shtPropOne;
		self.showProperties(self.myCurrentServiceObject);
		if self.modePropertyUpdate = self.MODEPROPERTY_GROUP then
			self.tblProperties.hideRowByName(ETRow_CalculationType, false);
			self.tblProperties.hideRowByName(ETRow_TaxCode, false);
			self.tblProperties.hideRowByName(ETRow_RateType, false);
			self.tblProperties.hideRowByName(ETRow_IsNotAvailableForEntryCk, false);
			self.tblProperties.hideRowByName(ETRow_ExternalReference1, false);   		//15.12.2023 navbs1 #61770
			self.tblProperties.hideRowByName(ETRow_ExternalReference2, false);   		//15.12.2023 navbs1 #61770
		else
			self.tblProperties.showRowByName(ETRow_CalculationType, false);
			self.tblProperties.showRowByName(ETRow_TaxCode, false);
			self.tblProperties.showRowByName(ETRow_RateType, false);
			if self.myCurrentServiceObject.isKindOf(CM_Service) and
			   self.myCurrentServiceObject.CM_Service.isVoid() then			// don't allow the Void service to be made not available
				self.tblProperties.hideRowByName(ETRow_IsNotAvailableForEntryCk, false);
			else
				self.tblProperties.showRowByName(ETRow_IsNotAvailableForEntryCk, false);
			endif;
		endif;
	endif;
	
	idx := self.tblProperties.getRowByName(ETRow_Remarks);
	if idx &gt; 0 then
		self.tblProperties.accessRow(idx).height := 100;
		cell := self.tblProperties.accessCell(idx, 2);
		cell.alignment := Table.Alignment_Left_Top;
	endif;
	self.tblProperties.optimiseHeadingColumn();
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnPropNextClick" id="b991486b-8b85-446d-aff7-0796827876ca">
        <updating/>
        <source>doBtnPropNextClick() updating;
// cnwjre1	Apr 2014 save and restore the calc type to speed up repeated entry
vars
	savedCalcType	: CM_CalculationType;
	savedTaxCode : CM_TaxCode;
	savedGLCode : CM_GLCode;
begin
	savedCalcType := self.cmbCalcTypes.listObject.CM_CalculationType;
	savedTaxCode := self.cmbTaxCode.listObject.CM_TaxCode; // TFS 37454
	savedGLCode := self.cmbGL.listObject.CM_GLCode; // TFS 37454
	self.doSave();
	self.btnNew_click(self.btnNew);
//	set the calculation type to the one last used	
	self.cmbCalcTypes.listObject := savedCalcType;
	self.tblProperties.setValueByControlName(self.cmbCalcTypes.name, self.cmbCalcTypes.text);
	self.cmbTaxCode.listObject := savedTaxCode; // TFS 37454
	self.tblProperties.setValueByControlName(self.cmbTaxCode.name, self.cmbTaxCode.text); // TFS 37454
	self.cmbGL.listObject := savedGLCode; // TFS 37454
	self.tblProperties.setValueByControlName(self.cmbGL.name, self.cmbGL.text); // TFS 37454

end;
</source>
    </JadeMethod>
    <JadeMethod name="doBtnPropSaveClick" id="cfce1172-2f3e-4eef-9958-d67998494641">
        <updating/>
        <source>doBtnPropSaveClick() updating;

vars

begin

	self.doSave();
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnSearchClick" id="45f76e5c-0f0f-4384-9f0f-cab2e1506a46">
        <updating/>
        <source>doBtnSearchClick() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	priorBank	: CM_Bank;
	aService 	: CM_ServiceObject;
	searchName	: String;
	idx 		: Integer;
begin
	inheritMethod();
	priorBank := self.myCurrentBank;
	self.myCurrentBank := self.cmbBank.listObject.CM_Bank;
	if self.myCurrentBank = null then
		return;
	endif;
	if self.myCurrentBank &lt;&gt; priorBank then
		self.doBuildCmbGL();
		self.doBuildCmbRateType();
		self.doBuildCmbTax();
		self.doCmbCalcTypesBuild();
		self.loadServiceSchedule(false); // ### TFS 51912 14Sep2021 NAVPW1
//	TFS 2682		self.caption := self.myCurrentBank.code &amp; " Service Schedule";
		self.setCaption("Service Schedule " &amp; self.myCurrentBank.code);
		self.myCurrentServiceGroup := null;
		self.myCurrentServiceObject := null;
	endif;

	searchName := self.txtSearch.text.trimBlanks;
	if searchName &lt;&gt; null then
		aService := self.myCurrentBank.serviceObjects.getAtKeyGeq(searchName);
	endif;
	if aService = null then
		return;
	endif;
	
	idx := self.lstData.findObject(aService);
	if idx &gt; 0 then
		self.lstData.itemExpanded[idx] := true;
		self.lstData.listIndex := idx;
		self.lstData.topIndex := idx;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildCmbGL" id="6a3a8570-78c0-4882-bcfa-ddf5518bca03">
        <source>doBuildCmbGL();
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	gl : CM_GLCode;
begin
	self.cmbGL.clear;
	self.cmbGL.addItem("(none)");
	self.cmbGL.itemObject[self.cmbGL.newIndex] := null;
	foreach gl in self.myCurrentBank.glCodes where not gl.isNotAvailableForEntry do
		self.cmbGL.addItem(gl.code &amp; " - " &amp; gl.remarks);
		self.cmbGL.itemObject[self.cmbGL.newIndex] := gl;
	endforeach;
	self.cmbGL.listIndex := 1;


end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildCmbRateType" id="a0e1a555-30c7-4c64-aa63-ac74608d0d39">
        <source>doBuildCmbRateType();
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 26/03/2008	jlgdap1		TFS 37794 PEL1 Vessel Rates
//07 Jun 2018 cnwma1	ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
vars
	
begin
	self.cmbRateTypes.clear;

	self.cmbRateTypes.addItem(app.getErrorString(Default_rate));
	self.cmbRateTypes.itemData[self.cmbRateTypes.newIndex] := CM_Service.DEFAULT_RATE_TABLE;

	//ccms 1058 11/5/09 cnwer1
	if self.myTerminal.getConfig(ShipLinePortGroupsForInv).Boolean then
		self.cmbRateTypes.addItem(app.getErrorString(Shipping_line_rate));
		self.cmbRateTypes.itemData[self.cmbRateTypes.newIndex] := CM_Service.TRADE_RATE_TABLE;
	endif;
	
	//07.06.2018 cnwma1 ChangeRequest #38953
	self.cmbRateTypes.addItem(app.getErrorString(Berth_rate));									
	self.cmbRateTypes.itemData [self.cmbRateTypes.newIndex] := CM_Service.BERTH_RATE_TABLE;	
	
	self.cmbRateTypes.addItem(app.getErrorString(Vessel_rate));									// TFS 37794
	self.cmbRateTypes.itemData [self.cmbRateTypes.newIndex] := CM_Service.VESSEL_RATE_TABLE;	// TFS 37794
	
	//07.06.2018 cnwma1 ChangeRequest #38953
	self.cmbRateTypes.addItem(app.getErrorString(VesselType_rate));									
	self.cmbRateTypes.itemData [self.cmbRateTypes.newIndex] := CM_Service.VESSELTYPE_RATE_TABLE;	
	
	self.cmbRateTypes.addItem(app.getErrorString(VisitType_rate));									
	self.cmbRateTypes.itemData [self.cmbRateTypes.newIndex] := CM_Service.VISITTYPE_RATE_TABLE;	
	//07.06.2018 cnwma1 ChangeRequest #38953
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildCmbTax" id="272fb144-a29d-4420-bfdd-a286d36321a3">
        <source>doBuildCmbTax();
// ---------------------------------------------------------------------------
// Created:		May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tax : CM_TaxCode;
begin
	self.cmbTaxCode.clear;
	self.cmbTaxCode.addItem("(none)");
	self.cmbTaxCode.itemObject[self.cmbTaxCode.newIndex] := null;
	foreach tax in self.myCurrentBank.allTaxCodes 
		where tax.notAvailableForEntry = false do
		self.cmbTaxCode.addItem(tax.getDisplayDetails(false));
		self.cmbTaxCode.itemObject[self.cmbTaxCode.newIndex] := tax;
	endforeach;
	self.cmbTaxCode.listIndex := 1;


end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboGroups" id="61cb4b47-ee93-4297-b415-6668e740b9d5">
        <source>doBuildComboGroups();
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	serviceGroup : CM_ServiceGroup;
	serviceNode:   CM_ServiceObject;
	theBank : CM_Bank;
	rootSG : CM_ServiceGroup;
begin
	theBank := app.myRoot.myRootCompany;
	
	self.cmbGroups.clear;
	
	foreach serviceNode in theBank.serviceObjects 
		where serviceNode.isKindOf(CM_ServiceGroup) do

		if serviceNode = self.myCurrentServiceObject then
			// exclude possibility of assigning group to itself
			continue;
		endif;
		rootSG := theBank.getRootServiceGroup();
		if serviceNode = rootSG then
			self.cmbGroups.addItem("");
		else
			self.cmbGroups.addItem(serviceNode.name);
		endif;
		self.cmbGroups.itemObject[self.cmbGroups.newIndex] := serviceNode;
	endforeach;

	serviceGroup := self.myCurrentServiceObject.group;
	rootSG := self.myCurrentBank.getRootServiceGroup();
	if serviceGroup &lt;&gt; null and serviceGroup &lt;&gt; rootSG then
		self.cmbGroups.listObject := serviceGroup;
		self.cmbGroups.lostFocus(self.cmbGroups);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbBankBuild" id="037cf3b9-578a-4cdd-93cd-5c7667724e77">
        <source>doCmbBankBuild();
//	35874 build combo for business unit query
vars
	company			: CM_Bank;
	businessUnits	: CM_CompanyByCodeDict;
	currentBU		: CM_Bank;
	combo			: CMUI_ComboBox;
begin

	combo := self.cmbBank;
	create businessUnits transient;
	currentBU := self.myTerminal.getAvailableCompanies(businessUnits);
	foreach company in businessUnits do
		combo.addItem(company.code);
		combo.itemObject[combo.newIndex] := company;
	endforeach;
	if currentBU &lt;&gt; null then
		combo.listObject := currentBU;
	endif;
epilog
	delete businessUnits;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doCmbCalcTypesBuild" id="b05c1121-074f-431b-97a7-4d7846a8c309">
        <source>doCmbCalcTypesBuild();
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
// 11/09/2017	cnwma1  TFS #6897 JMT - Calculation Type Label Refactor
//06 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
// ---------------------------------------------------------------------------

vars
	tmpDesc : String;
	aCT : CM_CalculationType;
	haveVTMIS : Boolean;
	haveCARGO : Boolean;
begin
	haveVTMIS := app.myRoot.canDo(Mod_Harbour); // VTMIS License //06.10.2017	cnwma1  TFS #7257
	haveCARGO := app.myRoot.canDo(Mod_CargoHandling); // CONTAINER LICENSE
	
	self.cmbCalcTypes.clear;
	self.cmbCalcTypes.sorted := true;

	foreach aCT in app.myRoot.allCalculationTypesByCode discreteLock  where not aCT.isNotAvailableForEntry do
		if (aCT.isCargoCalcType and not haveCARGO) then
			continue;
		elseif (aCT.isVoyageCalcType and not haveVTMIS) then
			continue;
		endif;

		/* // ### TFS BUG 59913 31AUG2023 NAVAB1
		// PAR 30428
		tmpDesc := "";
		if aCT.isVoyageCalcType then  // TFS 39198
			tmpDesc := "HMS - ";
		elseif aCT.isCargoCalcType then // TFS 39198
			tmpDesc := "Cargo - ";
		elseif aCT.isEventCalcType then
			tmpDesc := "Event - ";
		elseif aCT.isWorkOrderType and not aCT.isStandardWorkOrder() then // TFS 39198
			tmpDesc := "Work Order - "; // TFS 39198
		endif;
		*/
		tmpDesc := aCT.getComboDescription(); // ### TFS BUG 59913 31AUG2023 NAVAB1  description;                //11/09/2017 cnwma1 TFS #6897
		
		self.cmbCalcTypes.addItemObject(tmpDesc,aCT);
	
	/* PAR 30428
		if aCT.isCargoCalcType then
			if haveCARGO then
				self.cmbCalcTypes.addItemObject(aCT.description,aCT);
			endif;
		elseif aCT.isVoyageCalcType then
			if haveVTMIS then
				self.cmbCalcTypes.addItemObject(aCT.description,aCT);
			endif;
		else
			self.cmbCalcTypes.addItemObject(aCT.description,aCT);
		endif;
		
		*/
		
		
	endforeach;
	self.addCurrentCT2Combo();
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="136359fa-af42-4f18-bd1b-60dbf1202418">
        <updating/>
        <source>doDelete() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aService : CM_ServiceObject;
	theReturn : Integer;
	label : String;
	
begin
	aService := self.myCurrentServiceObject;
	if aService = null then
		app.msgBox("Please select a service.", app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	label := "service '" &amp; aService.name &amp; "' ?"; 
	if app.msgBox(app.getErrorString1(Lit_Confirm_Delete,  label),app.getErrorString(Confirm_Delete),MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;


	while true do
	 	app.myTrxDA.trxDeleteServiceObject(aService, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			return ;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(INV_Service_Delete), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return ;
		endif;
		break;
	endwhile;
epilog

	self.myCurrentServiceGroup := null;
	self.myCurrentServiceObject := null;

end;</source>
    </JadeMethod>
    <JadeMethod name="doFilterTree" id="7fc5195c-21a8-4529-8806-fc0587b6af9a">
        <updating/>
        <source>doFilterTree() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2021	navpw1	Initial creation TFS: 51912

*/

vars
	
	filterText	: String;

begin

	filterText := self.txtFilterBox.text.toUpper();
	
	if (filterText &lt;&gt; "") then
		self.btnClearFilter.enabled := true;
	endif;

	if (filterText &lt;&gt; "") then
		self.loadServiceSchedule(true);
	else
		self.btnClearFilter.enabled := false;
		self.loadServiceSchedule(false);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doLstDataClick" id="1c4486f6-e041-48e9-a7b6-9e81fc89ddd8">
        <updating/>
        <source>doLstDataClick(listbox: ListBox input) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theForm : INV_ServiceSchedule;
begin
	inheritMethod(listbox);
	
	if listbox.listIndex &lt; 0 then
		return;
	endif;
	
	theForm := self;
	self.myCurrentServiceObject := listbox.itemObject[listbox.listIndex].CM_ServiceObject;
	if self.myCurrentServiceObject.isKindOf(CM_ServiceGroup) then
		self.myCurrentServiceGroup := self.myCurrentServiceObject.CM_ServiceGroup;
	else
		self.myCurrentServiceGroup := self.myCurrentServiceObject.group;
	endif;
//	self.myCurrentServiceObject.setEnableObjectsSub(theForm);
	self.setEnableControlsForObject(self.myCurrentServiceObject);

end;</source>
