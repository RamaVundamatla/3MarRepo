    <JadeMethod name="isMT" id="7de42962-54b0-4cd0-bbd9-ddcb022dd425">
        <source>isMT():Boolean;
// ---------------------------------------------------------------------------
// Created:     08 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	trx	:CM_TITransaction;
begin
	trx 	:= self.myMoveTransaction;
	
	if trx = null then
		// machine must be a crane
		trx := self.myShipReceiveReleaseTrx;
	endif;
	
	if trx &lt;&gt; null then
		return trx.isEmpty;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
