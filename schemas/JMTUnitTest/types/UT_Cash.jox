	self.deleteContainer("MTMU8099002");
	cargo := createContainerFromVoyage(voyage, "MTMU8099002", bs, '42G1', operator, 'MT', "NZPOE", "NZPOE", 2500, 3500).CM_Container;
	_containers.add(cargo);
	self.deleteContainer("MTMU8099003");
	cargo := createContainerFromVoyage(voyage, "MTMU8099003", bs, '42G1', operator, 'MT', "NZPOE", "NZPOE", 2500, 3500).CM_Container;
	_containers.add(cargo);
	self.deleteContainer("MTMU8099004");
	cargo := createContainerFromVoyage(voyage, "MTMU8099004", bs, '42G1', operator, 'MT', "NZPOE", "NZPOE", 2500, 3500).CM_Container;
	_containers.add(cargo);
	self.deleteContainer("MTMU8099005");
	cargo := createContainerFromVoyage(voyage, "MTMU8099005", bs, '42G1', operator, 'MT', "NZPOE", "NZPOE", 2500, 3500).CM_Container;
	_containers.add(cargo);

	// set transaction dates back the given number of days
	if _daysBack &lt;&gt; 0 then
		baseDate := now - _daysBack;	// cargo create date
		foreach obj in _containers do
			cargo := obj.CM_TrackedItem;
			self.setTransactionDate(cargo, baseDate);
		endforeach;
	endif;
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_daysBack" type="Integer"/>
        <Parameter name="_containers" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createCashCargoOnShip" id="ee48ef13-96f9-4554-95fe-16d0717bb93e">
        <source>createCashCargoOnShip(_voyage : CM_Voyage; _forTest : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     31 May 2010 by NAVAB1
//	set the _forTest parameter true from unit test and false from createCargoForCash, to use different cargo ids that don't get deleted in a subsequent test run.
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theSlot : CM_LocationsController;
	cargo : CM_TrackedItem;
	strs : StringArray;
	idx : Integer;
	idPrefix,
	reefPrefix	: String;
	aPort : CM_Port;
	oper	: CM_Operator;
	term	: CM_Terminal;
	bol1, bol2, bol3, bol4	: CM_BOL;
	association	: CM_Association;
begin

	aPort := app.myRoot.allPorts[_voyage.myTerminal.getConfig(PortDestCode).String];
	oper := self.getOperator(getProfileSetting(UT_Profile.P_OPERATOR).asString);
	term := self.getTerminal();
	if _forTest then
		idPrefix := "GXNU";
		reefPrefix := "RXXF";
	else
		idPrefix := "GENU";
		reefPrefix := "REEF";
	endif;

	// BOLs for payment by BOL
	self.deleteBOL("BOL001", null);
	bol1 := self.addBOL("BOL001", _voyage, oper, null, term );
	self.deleteBOL("BOL002", null);
	bol2 := self.addBOL("BOL002", _voyage, oper, null, term );
	self.deleteBOL("BOL003", null);
	bol3 := self.addBOL("BOL003", _voyage, oper, null, term );
	self.deleteBOL("BOL004", null);
	bol4 := self.addBOL("BOL004", _voyage, oper, null, term );
	
	create strs transient;
	// ### 20 GENERALS - BOL 1
	strs.clear;
	strs.add("010688");
	self.opts.addAssoc(UTTI_BOL, bol1.number);
	_voyage.findLocation(strs, false, theSlot, idx);
	self.deleteContainer(idPrefix &amp; "2022334");
	cargo := self.addContainerAtLocnDisch(idPrefix &amp; "2022334", "2200", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, aPort, _voyage);
	self.assertTrueMsg((cargo.getImExStatus() = TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	
	strs.clear;
	strs.add("010488");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.deleteContainer(idPrefix &amp; "2022335");
	cargo := self.addContainerAtLocnDisch(idPrefix &amp; "2022335", "2200", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, aPort, _voyage);
	strs.clear;
	strs.add("010288");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.deleteContainer(idPrefix &amp; "2022336");
	cargo := self.addContainerAtLocnDisch(idPrefix &amp; "2022336", "2200", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, aPort, _voyage);
	strs.clear;
	strs.add("010188");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.deleteContainer(idPrefix &amp; "2022337");
	cargo := self.addContainerAtLocnDisch(idPrefix &amp; "2022337", "2200", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, aPort, _voyage);
	strs.clear;
	strs.add("010388");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.deleteContainer(idPrefix &amp; "2022338");
	cargo := self.addContainerAtLocnDisch(idPrefix &amp; "2022338", "2200", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, aPort, _voyage);
	strs.clear;
	strs.add("010588");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.deleteContainer(idPrefix &amp; "2022331");
	cargo := self.addContainerAtLocnDisch(idPrefix &amp; "2022331", "2200", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, aPort, _voyage);

	// ### 40 GENERALS - BOL 1
	strs.clear;
	strs.add("010686");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.deleteContainer(idPrefix &amp; "4X22441");
	cargo := self.addContainerAtLocnDisch(idPrefix &amp; "4X22441", "4200", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, aPort, _voyage);

	strs.clear;
	strs.add("010486");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.deleteContainer(idPrefix &amp; "4X22442");
	cargo := self.addContainerAtLocnDisch(idPrefix &amp; "4X22442", "4200", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, aPort, _voyage);

	strs.clear;
	strs.add("010286");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.deleteContainer(idPrefix &amp; "4X22443");
	cargo := self.addContainerAtLocnDisch(idPrefix &amp; "4X22443", "4200", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, aPort, _voyage);

	strs.clear;
	strs.add("010186");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.deleteContainer(idPrefix &amp; "4X22444");
	cargo := self.addContainerAtLocnDisch(idPrefix &amp; "4X22444", "4200", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, aPort, _voyage);
	strs.clear;
	strs.add("010386");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.deleteContainer(idPrefix &amp; "4X22445");
	cargo := self.addContainerAtLocnDisch(idPrefix &amp; "4X22445", "4200", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, aPort, _voyage);

	strs.clear;
	strs.add("010586");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.deleteContainer(idPrefix &amp; "4X22446");
	cargo := self.addContainerAtLocnDisch(idPrefix &amp; "4X22446", "4200", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, aPort, _voyage);
	
	// ### 20 REEFERS - BOL 1
	strs.clear;
	strs.add("010684");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.deleteContainer(reefPrefix &amp; "2022334");
	cargo := self.addContainerAtLocnDisch(reefPrefix &amp; "2022334", "2232", "REEF", TI_IMEX_STATUS_IMPORT, theSlot, aPort, _voyage);
	strs.clear;
	strs.add("010484");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.deleteContainer(reefPrefix &amp; "2022335");
	cargo := self.addContainerAtLocnDisch(reefPrefix &amp; "2022335", "2232", "REEF", TI_IMEX_STATUS_IMPORT, theSlot, aPort, _voyage);
	strs.clear;
	strs.add("010284");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.deleteContainer(reefPrefix &amp; "2022336");
	cargo := self.addContainerAtLocnDisch(reefPrefix &amp; "2022336", "2232", "REEF", TI_IMEX_STATUS_IMPORT, theSlot, aPort, _voyage);
	strs.clear;
	strs.add("010184");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.deleteContainer(reefPrefix &amp; "2022337");
	cargo := self.addContainerAtLocnDisch(reefPrefix &amp; "2022337", "2232", "REEF", TI_IMEX_STATUS_IMPORT, theSlot, aPort, _voyage);
	strs.clear;
	strs.add("010384");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.deleteContainer(reefPrefix &amp; "2022338");
	cargo := self.addContainerAtLocnDisch(reefPrefix &amp; "2022338", "2232", "REEF", TI_IMEX_STATUS_IMPORT, theSlot, aPort, _voyage);
	strs.clear;
	strs.add("010584");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.deleteContainer(reefPrefix &amp; "2022339");
	cargo := self.addContainerAtLocnDisch(reefPrefix &amp; "2022339", "2232", "REEF", TI_IMEX_STATUS_IMPORT, theSlot, aPort, _voyage);
	
	// ### 40 REEFERS - BOL 2
	if self.opts.includesKey(UTTI_BOL) then
		association := self.opts[UTTI_BOL];
		association.setValue(bol2.number);
	endif;

	strs.clear;
	strs.add("010682");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.deleteContainer(reefPrefix &amp; "4022334");
	cargo := self.addContainerAtLocnDisch(reefPrefix &amp; "4022334", "4332", "REEF", TI_IMEX_STATUS_IMPORT, theSlot, aPort, _voyage);
	strs.clear;
	strs.add("010482");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.deleteContainer(reefPrefix &amp; "4022335");
	cargo := self.addContainerAtLocnDisch(reefPrefix &amp; "4022335", "4332", "REEF", TI_IMEX_STATUS_IMPORT, theSlot, aPort, _voyage);
	strs.clear;
	strs.add("010282");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.deleteContainer(reefPrefix &amp; "4022336");
	cargo := self.addContainerAtLocnDisch(reefPrefix &amp; "4022336", "4332", "REEF", TI_IMEX_STATUS_IMPORT, theSlot, aPort, _voyage);
	strs.clear;
	strs.add("010182");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.deleteContainer(reefPrefix &amp; "4022337");
	cargo := self.addContainerAtLocnDisch(reefPrefix &amp; "4022337", "4332", "REEF", TI_IMEX_STATUS_IMPORT, theSlot, aPort, _voyage);
	strs.clear;
	strs.add("010382");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.deleteContainer(reefPrefix &amp; "4022338");
	cargo := self.addContainerAtLocnDisch(reefPrefix &amp; "4022338", "4332", "REEF", TI_IMEX_STATUS_IMPORT, theSlot, aPort, _voyage);
	strs.clear;
	strs.add("010582");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.deleteContainer(reefPrefix &amp; "4022339");
	cargo := self.addContainerAtLocnDisch(reefPrefix &amp; "4022339", "4332", "REEF", TI_IMEX_STATUS_IMPORT, theSlot, aPort, _voyage);

epilog
	delete strs;
end;</source>
