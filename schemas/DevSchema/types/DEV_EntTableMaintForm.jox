    <JadeMethod name="deleteGroup" id="f53575c5-a5b7-41c4-97f0-b2fd65c86d9e">
        <updating/>
        <source>deleteGroup() updating;
// ---------------------------------------------------------------------------
// Created:     06 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.myCurrentGroup = null then
		app.msgBox('You must select a group first', 'Error', MsgBox_OK_Only);
		return;
	endif;

	self.disableGroupEdit();
	
	if app.msgBox('Are you sure you want to delete the ' &amp; self.myCurrentGroup.name &amp; ' group.', 'Delete Group', MsgBox_OK_Cancel) = MsgBox_Return_OK then
		beginTransaction;
		delete self.myCurrentGroup;
		commitTransaction;
		self.myCurrentGroup := null;
		self.myCurrentDef := null;
		self.myCurrentView := null;
		
		cmbGroup.text := null;
		self.setDefinition(self.myCurrentDef);
		self.setView(self.myCurrentView);
	endif;

end;</source>
    </JadeMethod>
