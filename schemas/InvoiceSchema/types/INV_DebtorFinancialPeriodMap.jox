    <JadeMethod name="doTblDataContextMenu" id="d4183510-6fb8-403d-add2-4da3ded90acb">
        <updating/>
        <source>doTblDataContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
// 09 Jan 2017	cnwma1	TFS #2643 :JMT - Audit of Invoice Maintenance Set-up
vars
	xLeft 	: Real;
	yTop	: Real;
	
begin
	// 09/01/2017 cnwma1 TFS #2712
	xLeft := x;
	yTop := y;
	
	self.mnuViewAudits.visible :=true;
	self.mnuAudits.visible :=true;
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);
	self.popupMenu(self.mnuAudits, xLeft.Integer, yTop.Integer);
	return false;
end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
