    <JadeMethod name="addVoyageCriteria" id="7f9eaf07-836d-4104-ad83-9f2aa6b98c0f">
        <source>addVoyageCriteria( _aVoyage : CM_Voyage);

/*

Purpose: for transient voyage alloc for testing against other yard aloocations.			

Parameters:			

Return Value:		


Date		Who		Reason
10 December 2012	cnwrd1	Initial creation

*/

vars
	newCriteria			: CM_YACriteria;
	objSet				: CM_ObjectSet;
begin

	if _aVoyage =  null then
		return;
	endif;
	
	create objSet transient;	
	
	objSet.add(_aVoyage);
	newCriteria := self.createCriteria(objSet, YACriteriaType_Voyage);
	if newCriteria &lt;&gt; null then
		newCriteria.setYardAllocation(self);
	endif;		
	

epilog
	delete objSet;
end;</source>
        <Parameter name="_aVoyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createCriteria" id="55e9a206-757d-48b4-a23a-7b2f8086dbe7">
        <source>createCriteria(_item : Any; _criteriaType : Integer) : CM_YACriteria protected;
// ---------------------------------------------------------------------------
// Created:     08 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	criteria		: CM_YACriteria;
	criteriaType	: CM_YACriteriaType;
//	criteriaData	: CM_YADataObjects;
begin
	criteriaType := app.myRoot.allYACriteriaTypes[_criteriaType];
	if criteriaType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Voyage Allocation criteria type (' &amp; _criteriaType.String &amp; ') not present');
		return null;
	endif;
	
	create criteria transient;
	criteria.setProxy(criteriaType, _item, null);

	return criteria;

end;</source>
        <access>protected</access>
        <Parameter name="_item" type="Any"/>
        <Parameter name="_criteriaType" type="Integer"/>
        <ReturnType type="CM_YACriteria"/>
    </JadeMethod>
    <JadeMethod name="doSetUserEnteredNumbers" id="ae7702da-e037-4bf9-a911-a13f1908ba2e">
