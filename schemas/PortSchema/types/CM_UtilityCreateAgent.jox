    <JadeMethod name="utlCreateDebtorAddress" id="a1950ccf-5d9d-4a8a-bb49-7db6e45d5204">
        <source>utlCreateDebtorAddress(_pxyAddress: CM_Address input;_realAddress : CM_Address output;_passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Jul 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
16 Jun 2021	jlika1	TFS 53679 - Delivery Party
*/

vars
	debtorBefore : String;

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	app.myValCA.valDebtorAddress( _pxyAddress );
	
	if not self.checkValidationWithPassport( _passport ) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	if _pxyAddress &lt;&gt; null and _pxyAddress.myDebtor &lt;&gt; null then		// 9/8/19 MAP TFS45577
		debtorBefore := _pxyAddress.myDebtor.getAuditText;
	endif;

	create _realAddress persistent;
	_realAddress.setForCreate( _pxyAddress);
			
	if _passport.noErrors  and _realAddress.myDebtor &lt;&gt; null then
		app.myAA.auditUpdateTrx(_realAddress.myDebtor, debtorBefore, _realAddress.myDebtor.getAuditText());
	endif;
	
end;</source>
        <Parameter name="_pxyAddress" type="CM_Address" usage="input"/>
        <Parameter name="_realAddress" type="CM_Address" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
