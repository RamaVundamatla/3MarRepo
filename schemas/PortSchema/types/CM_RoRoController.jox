    <JadeMethod name="accessDirectionToString" id="4651a0d0-d1b2-4c89-8e5d-3376726a7d76">
        <source>accessDirectionToString() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 November 2009	cnwjk3	ccms 1018

*/

vars
	leftLabel,
	rightLabel,
	direction 	: String;
begin
	
	leftLabel := self.myRoRoLaneArea.leftLabel;
	rightLabel := self.myRoRoLaneArea.rightLabel;

	if self.accessDirection = self.ACCESS_DIRECTION_NONE then
	elseif self.accessDirection = self.ACCESS_DIRECTION_BOTH then
		direction := self.myRoRoLaneArea.getLeftAndRightString(leftLabel, rightLabel);
	elseif self.accessDirection = self.ACCESS_DIRECTION_LEFT then
		direction := leftLabel;
	elseif self.accessDirection = self.ACCESS_DIRECTION_RIGHT then
		direction := rightLabel;
	endif;
	return direction;
epilog 

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="buildLocationStatsTranisent" id="3e8dbff8-1e99-4546-b10d-f69bd45bb30e">
        <source>buildLocationStatsTranisent(_ls : CM_LocationStatistics output);
// --------------------------------------------------------------------------------
// Created:		26 Janurary 2010 by cnwjo3
//
// Purpose:		instead of adding a new reference to CM_RoRoController we'll just create CM_LocationStatistics
//				transiently at this time.
//				CCMS 1018
vars
	//Decimal, who is giong to have a RoRoLane more than 1234567891.1234 metres!
	free			: Decimal[14,4];
	plannedIn		: Decimal[14,4];
	plannedOut		: Decimal[14,4];
	projected		: Decimal[14,4];
	queuedIn		: Decimal[14,4];
	queuedOut		: Decimal[14,4];
	total			: Decimal[14,4];
	used			: Decimal[14,4];

	fm				: CM_FutureMove;
	fmq				: CM_FutureMoveQueued;
	fmp				: CM_FutureMovePlanned;
	ti				: CM_TrackedItem;
	
	tmpTI			: CM_TrackedItem;
	
	ceuValue		: Decimal[5,2];  ///333.22
begin
	ceuValue := app.getCEUValue();

	if _ls = null then
		create _ls transient;
	endif;
	
	_ls.setParent(self);
	
	//count all TIs being queued out of the area
	foreach ti in self.allTrackedItems discreteLock do
		if ti.myPrimaryQueuedLocation &lt;&gt; null then
			if ti.myPrimaryQueuedLocation.myTerminalArea &lt;&gt; self.myTerminalArea then
				queuedOut := queuedOut + ti.length;
			endif;
		endif;	
		
		//count all TIs being planned out of the area
		if ti.myPrimaryPlannedLocation &lt;&gt; null then
			if ti.myPrimaryPlannedLocation.myTerminalArea &lt;&gt; self.myTerminalArea then
				plannedOut := plannedOut + ti.length;
			endif;
		endif;
	endforeach;	
	
	//count all TIs being queued in to the area
	foreach fm in self.allQueuedFutureMoves discreteLock do
		if fm.isKindOf(CM_FutureMoveQueued) then
			fmq := fm.CM_FutureMoveQueued;
			ti := fmq.myTrackedItem;
			if ti &lt;&gt; null then	//11 Apr 2018	NDL	TFS 37989
				queuedIn := queuedIn + ti.length;
			endif;
		endif;
	endforeach;

	//count all TIs being planned in to the area
	foreach fm in self.allPlannedFutureMoves discreteLock do
		if fm.isKindOf(CM_FutureMovePlanned) then
			fmp := fm.CM_FutureMovePlanned;
			ti := fmp.myTrackedItem;
			if ti &lt;&gt; null then	//11 Apr 2018	NDL	TFS 37989
				plannedIn := plannedIn + ti.length;
			endif;
		endif;
	endforeach;		

	//add up CEUs in RoRoLane
	total := (self.length-self.startOffset)/ceuValue;
	used := self.usedLengthActual/ceuValue;
	free := self.spareLengthActual/ceuValue;
	queuedIn := queuedIn/ceuValue;
	queuedOut := queuedOut/ceuValue;
	plannedIn := plannedIn/ceuValue;
	plannedOut := plannedOut/ceuValue;
	
	_ls.total := total.Integer;
	_ls.used := used.Integer;
	_ls.free := free.Integer;
	_ls.queuedIn := queuedIn.Integer;
	_ls.queuedOut := queuedOut.Integer;
	_ls.plannedIn := plannedIn.Integer;
	_ls.plannedOut := plannedOut.Integer;
	
	/*_ls.total := ((self.length-self.startOffset)/(self.myRoRoLaneArea.getSlotUnit())).Integer;
	_ls.used := (self.usedLength/self.myRoRoLaneArea.getSlotUnit()).Integer;
	_ls.queuedIn := c20QueuedIn + c30QueuedIn + c40QueuedIn + c45QueuedIn + c53QueuedIn + gcQueuedIn;
	_ls.queuedOut := c20QueuedOut + c30QueuedOut + c40QueuedOut + c45QueuedOut + c53QueuedOut + gcQueuedOut;
	_ls.free := (self.spareLength/self.myRoRoLaneArea.getSlotUnit()).Integer;
	_ls.plannedIn := c20PlannedIn + c30PlannedIn + c40PlannedIn + c45PlannedIn + c53PlannedIn + gcPlannedIn;
	_ls.plannedOut := c20PlannedOut + c30PlannedOut + c40PlannedOut + c45PlannedOut + c53PlannedOut + gcPlannedOut;*/
		

	
end;
</source>
        <Parameter name="_ls" type="CM_LocationStatistics" usage="output"/>
    </JadeMethod>
    <JadeMethod name="canFitCargo" id="71083d3d-d794-4452-9eb4-cd58e972578f">
        <source>canFitCargo(_ti : CM_TrackedItem; _checkQueuedPlanned: Boolean; _yaAgent : CM_YAAutoplanAgent; _cmif: CMIF_MoveController; _tiLen: Real output) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 January 2010	cnwjk3	Initial creation
28 October 2016	cnwmp6	TFS 2822
*/

vars
	//tiLen	: Real;
	num: Integer;
	spareLength: Decimal[6,2];
	tapNum : Integer;
	standardGap : Real;
	otherTI: CM_TrackedItem;
begin
	if _checkQueuedPlanned then
		num := self.getNumQueuedPlannedActualTIs;
		//spareLength := self.spareLength;
		spareLength := self.getSpareLengthWithTap( num, _yaAgent );
	else
		num := self.getNumActualTIs();
		spareLength := self.spareLengthActual;
	endif;

	_tiLen :=  self.getTILengthInMetres(_ti);

	if _cmif &lt;&gt; null then
		foreach otherTI in _cmif.allOtherTrackedItems do	// 28/10/16 cnwmp6 TFS 2822
			if otherTI = _ti then
				continue;
			endif;
			_tiLen := _tiLen + self.myRoRoLaneArea.standardGap;
			_tiLen := _tiLen + self.getTILengthInMetres(otherTI);
		endforeach;
	endif;

	if num &gt; 0 then
		// This location already has cargo in it so we need to account for 
		// the standard gap between the TIs
		_tiLen := _tiLen + self.myRoRoLaneArea.standardGap;
	endif;
//	write spareLength;
	return spareLength &gt;= _tiLen;
epilog
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_checkQueuedPlanned" type="Boolean"/>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent"/>
        <Parameter name="_cmif" type="CMIF_MoveController"/>
        <Parameter name="_tiLen" type="Real" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
