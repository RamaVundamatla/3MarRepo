    <JadeMethod name="setForCreateFromTemplate" id="f5690239-a7a1-4270-94fe-01aeb21cbc26">
        <updating/>
        <source>setForCreateFromTemplate(_yardAllocation : CM_InvoiceInventoryAllocation; _terminal : CM_Terminal) updating;
/*
Purpose:			

Date		Who		Reason
25MAY2021	NAVAB1	TFS 51219
*/

begin
	
	// Set terminal reference.
//	self.myTerminal	:=	_terminal;
	self.myTerminal := null;	//23 Jul 2021	NDL	TFS 49952 - should not be used

	// Standard set for update.	Builds blocks and primitives.
	self.setForUpdate(_yardAllocation);
	
	create self.myQuantityMap;
	self.myQuantityMap.initialise(self.myServiceBroker, self.myTransactionMap.myBank, true);
	
	
end;</source>
        <Parameter name="_yardAllocation" type="CM_InvoiceInventoryAllocation"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="04c8e4d8-4ea2-45c8-a3a1-a8387e521b7f">
        <updating/>
        <source>setForUpdate(_proxyObj: CM_InvoiceInventoryAllocation ) updating;
/*
Purpose:			

Date		Who		Reason
25MAY2021	NAVAB1	TFS 51219
*/

vars
	sb : CM_InventoryServiceBroker;
begin

   
	if self.myServiceBroker= null then
		create self.myServiceBroker as CM_InventoryServiceBroker;
		sb := self.myServiceBroker.CM_InventoryServiceBroker;
	endif;

	inheritMethod(_proxyObj);
	
	if self.myServiceBroker= null then
		self.myServiceBroker := sb;
	endif;
	self.myServiceBroker.CM_InventoryServiceBroker.initialiseYA();
	
	self.setPriority();
epilog

end;</source>
        <Parameter name="_proxyObj" type="CM_InvoiceInventoryAllocation"/>
    </JadeMethod>
    <JadeMethod name="setPriority" id="b15459c4-941f-44f6-8e24-1865a71997e4">
        <updating/>
        <source>setPriority() updating;

/*
Purpose:			

Date		Who		Reason
25MAY2021	NAVAB1	TFS 51219
20/04/2023	navkc1	Bug 57628: CUX-Adding Criteria to Transaction Mapping allocation configuration results in error
*/

vars
	criType 		: CM_YACriteriaType;
	critPriority,
	allocPriority, 
	cnt 			: Real; //20/04/2023	navkc1	Bug 57628 Needs to be the same type as receive
	opCritByType	: CM_YACritetriaTypeByTypeDict;
	crit			: CM_YACriteria;
	
begin
	// TFS #4542 - Need to remove any criteria types from the receiver that are no longer
	// valid in the owing transaction map configuration
	create opCritByType transient;
	self.myTransactionMap.myInvoiceAllocationConfig.allOpCriteria.copy(opCritByType);
	
	foreach crit in self.allCriteria do
		if opCritByType[crit.myYACriteriaType.type] = null then
			delete crit;
		endif;
	endforeach;	

	// Now go through the configured criteria, for this transaction map, in the configured order
	// If the criteria type is used by the allocation add to its priority value
	cnt := -1;
	
	foreach criType in self.myTransactionMap.myInvoiceAllocationConfig.allOpCriteria discreteLock, reversed do

		cnt := cnt + 1;

		crit := self.allCriteriaByType[criType.type];
		if crit &lt;&gt; null then
			critPriority := (2 ^ cnt);
			crit.setPriorityValue(critPriority);
			allocPriority := allocPriority + critPriority;
		endif;
	
	endforeach;

	if self.priorityValue &lt;&gt; allocPriority then
		self.priorityValue := allocPriority;
	endif;
	
epilog
	delete opCritByType;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateME" id="8d670613-659a-4d4e-bb07-e64aa6e3184b">
        <source>validateME(_allTransientCriteriaObj	: CMIF_Array;
		   _update : Boolean //12/05/2023 navmv20 Bug 57561
		   );
/*
Purpose:			

Date		Who		Reason
25MAY2021	NAVAB1	TFS 51219
May 12 2023 navmv20 Bug 57561: STWO - Code :79963. A Yard Allocation with this code () already exists- Issue 1 of 2
*/

vars
		c : CMIF_Object;
		found : Boolean;
		invInventoryAllocation : CM_InvoiceInventoryAllocation; //12/05/2023 navmv20 Bug 57561
begin

	if self.myTransactionMap = null then
		app.raiseCMException(Invoic_invent_alloca_requir_tr,null,null);
	endif;
	



	if _allTransientCriteriaObj.isEmpty() then
	
		app.raiseCMException(No_Criteria_values_selected,null,null);
	endif;
	
	foreach c in _allTransientCriteriaObj discreteLock do
		if c.CMIF_YACriteriaPriority.isChanged then
			if c.CMIF_YACriteriaPriority.myCriteriaPriority.myYACriteriaType.type = YACriteriaType_InventoryType then
				found := true;
			endif;
		endif;
		if c.CMIF_YACriteriaPriority.isNew then
			if c.CMIF_YACriteriaPriority.myProxy.myYACriteriaType.type = YACriteriaType_InventoryType then
				found := true;
			endif;
		endif;
	endforeach;
		
	if not found then
		app.raiseCMException(Please_select_some_invent_type,null,null);
	
	endif;

	//12/05/2023 navmv20 Bug 57561- start
		foreach invInventoryAllocation in self.myTransactionMap.allInvoiceInventoryAllocations as CM_InvoiceInventoryAllocation do
			if invInventoryAllocation.description = self.description then
				if ((_update and invInventoryAllocation &lt;&gt; self.pxyGetRealObject()) or (not _update)) then
					app.raiseCMException1(Err_YA_AlreadyExists, self.code, null, null);
					break;
				endif;
			endif;
		endforeach;
	//12/05/2023 navmv20 Bug 57561 - end
end;
</source>
        <Parameter name="_allTransientCriteriaObj" type="CMIF_Array"/>
        <Parameter name="_update" type="Boolean"/>
    </JadeMethod>
</Class>
