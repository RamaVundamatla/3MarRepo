    <JadeMethod name="addToolbarControls" id="d11ec7d8-ac15-435e-b79c-a9596142b5f8">
        <updating/>
        <source>addToolbarControls() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2010	#cnwdz2	 par21593

*/

vars
	toolbar : CMUI_Toolbar;
begin
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);	

	toolbar.positionToolbarControls();
	toolbar.visible := true;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
