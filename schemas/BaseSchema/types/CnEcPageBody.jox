    <JadeMethod name="buildTagBody" id="a87d8fd5-ed9d-4e7f-a881-13c5165bae22">
        <source>buildTagBody(): String protected;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	htmlTagObj	: CnEcHtmlBodyTag;
	htmlString	: String;
	
begin
	htmlString	:=	inheritMethod();
	
	foreach htmlTagObj in self.allHtmlTags do
		htmlString	:=	htmlString &amp; htmlTagObj.getHtml();
	endforeach;
	
	return htmlString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="createAnchor" id="07c6ff0c-9907-48ca-b290-a71606784c5b">
        <source>createAnchor():CnEcHtmlAnchorTag;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Create a new anchor tag object for the receiver.
//
// Parameters:	None
//
// Returns:		The newly created tag object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	anchorTagObj	: CnEcHtmlAnchorTag;
	
begin
	create anchorTagObj transient;
	anchorTagObj.setBody(self);
	
	return anchorTagObj;
end;</source>
        <ReturnType type="CnEcHtmlAnchorTag"/>
    </JadeMethod>
