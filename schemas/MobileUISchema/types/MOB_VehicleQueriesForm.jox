    <JadeMethod name="addCriteriaLine" id="3908cd1f-2ad3-4374-980e-af7bff440dd0">
        <source>addCriteriaLine(_criteriaLine : 	CM_SelectorCriteriaLine;
				_dynamicCriteriaLine	: JadeDynamicObject input;
				_parentFrame 			: Frame input) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwer1	Initial creation

*/
constants
	Margin = 2;
vars

	searchValueA,
	searchValueB		: String;
	searchValueBoolean,
	isStringProperty,
	isStringBetweenProperty,
	isBooleanProperty			: Boolean;
	newSearchA,
	newSearchB: TextBox;
	newLabel: Label;
	trueOptionBtn,
	falseOptionBtn: OptionButton;
	theWidth 				: Integer;
	rtScreenMode : CM_RTScreenConfig;
begin
	rtScreenMode:=app.myVMAgent.getMyScreenMode();
	_criteriaLine.myQueryOperator.getCriteriaLineDefinitionForRT( _criteriaLine.myQueryProperty, searchValueA, searchValueB, searchValueBoolean, isStringProperty, isStringBetweenProperty, isBooleanProperty );
	
	
	_dynamicCriteriaLine.addProperty(CriteriaDescriptor,Label);
	
	newLabel:=self.lblCriteria.loadControl(self.controlCount + 1).Label;
	newLabel.parent:=_parentFrame;
	newLabel.top:=Margin;
	newLabel.caption:=_criteriaLine.myQueryProperty.niceName &amp; ' ' &amp;
		   	_criteriaLine.myQueryOperator.description;
	newLabel.fontSize:=app.myVMAgent.getMyRTVehicleConfig.tableFontSize;
	newLabel.fontName:="Tahoma";
	newLabel.foreColor:=rtScreenMode.screenForeColour;
	newLabel.backColor:=rtScreenMode.screenBackColour;
	
	theWidth:=newLabel.getTextExtent(newLabel.caption);
	newLabel.left:=20;


	_parentFrame.height:=newLabel.clientHeight + (Margin*2);
	
	_dynamicCriteriaLine.setPropertyValue(CriteriaDescriptor,newLabel);
	_dynamicCriteriaLine.addProperty(CriteriaSearchA,TextBox);
	_dynamicCriteriaLine.addProperty(CriteriaSearchB,TextBox);
	_dynamicCriteriaLine.addProperty(CriteriaBoolTrue,OptionButton);
	_dynamicCriteriaLine.addProperty(CriteriaBoolFalse,OptionButton);
	
	if isStringProperty or isStringBetweenProperty then
	
		newSearchA:=self.txtSearchValueA.loadControl(self.controlCount + 1).TextBox;
		newSearchA.text:=searchValueA;
		
		newSearchA.parent:=_parentFrame;
		newSearchA.fontSize:=app.myVMAgent.getMyRTVehicleConfig.tableFontSize;
		newSearchA.fontName:="Tahoma";
		newSearchA.top:=Margin;
		newSearchA.backColor:=rtScreenMode.tableBackColour;
		newSearchA.foreColor:=rtScreenMode.tableForeColour;
		newSearchA.left:=newLabel.left+newLabel.clientWidth + 5;
		if newSearchA.text &lt;&gt; null then
			theWidth:=newSearchA.getTextExtent(newSearchA.text);
			if theWidth &gt; newSearchA.width then
				newSearchA.width:=theWidth;
			endif;	
		endif;
		_dynamicCriteriaLine.setPropertyValue(CriteriaSearchA,newSearchA);
	endif;
	
	if isStringBetweenProperty then
		newSearchB:=self.txtSearchValueB.loadControl(self.controlCount + 1).TextBox;
		newSearchB.text:=searchValueB;
		newSearchB.parent:=_parentFrame;
		newSearchB.fontSize:=app.myVMAgent.getMyRTVehicleConfig.tableFontSize;
		newSearchB.fontName:="Tahoma";
		newSearchB.top:=Margin;
		newSearchB.backColor:=rtScreenMode.tableBackColour;
		newSearchB.foreColor:=rtScreenMode.tableForeColour;
		newSearchB.left:=newSearchA.left + newSearchA.clientWidth + 5;
		if newSearchB.text &lt;&gt; null then
			theWidth:=newSearchB.getTextExtent(newSearchB.text);
			if theWidth &gt; newSearchB.width then
				newSearchB.width:=theWidth;
			endif;	
		endif;
		
		_dynamicCriteriaLine.setPropertyValue(CriteriaSearchB,newSearchB);
	endif;
	
	if isBooleanProperty then
		trueOptionBtn:=self.optTrue.loadControl(self.controlCount + 1).OptionButton;
		trueOptionBtn.parent:=_parentFrame;
		trueOptionBtn.top:=Margin;
		trueOptionBtn.fontSize:=app.myVMAgent.getMyRTVehicleConfig.tableFontSize;
		trueOptionBtn.fontName:="Tahoma";
		trueOptionBtn.left:=newLabel.left+newLabel.clientWidth + 10;
		trueOptionBtn.backColor:=rtScreenMode.screenBackColour;
		trueOptionBtn.foreColor:=rtScreenMode.screenForeColour;
		_dynamicCriteriaLine.setPropertyValue(CriteriaBoolTrue,trueOptionBtn);
		
		
		falseOptionBtn:=self.optFalse.loadControl(self.controlCount + 1).OptionButton;
		falseOptionBtn.parent:=_parentFrame;
		falseOptionBtn.top:=Margin;
		falseOptionBtn.fontSize:=app.myVMAgent.getMyRTVehicleConfig.tableFontSize;
		falseOptionBtn.fontName:="Tahoma";
		falseOptionBtn.left:=trueOptionBtn.left + trueOptionBtn.clientWidth;
		falseOptionBtn.backColor:=rtScreenMode.screenBackColour; 
		falseOptionBtn.foreColor:=rtScreenMode.screenForeColour;
		_dynamicCriteriaLine.setPropertyValue(CriteriaBoolFalse,falseOptionBtn);

	endif;

	

	

	
	//if isStringProperty
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <Parameter name="_dynamicCriteriaLine" type="JadeDynamicObject" usage="input"/>
        <Parameter name="_parentFrame" type="Frame" usage="input"/>
    </JadeMethod>
