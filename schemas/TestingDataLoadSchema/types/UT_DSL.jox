    </JadeMethod>
    <JadeMethod name="machineTerminalConfig" id="2187dec6-feaf-4372-ad67-d3a398151050">
        <source>machineTerminalConfig(_machineTerminal : Any);
/*

Purpose:			

Date		Who		Reason
07/12/2017	jlgmh5	Initial creation - Rewrite of the machine / terminal RTVehicleConfig.  
					Currently nothing for terminal

*/

vars
	pxyRTVehicleConfig			: CM_RTVehicleConfig;
	pxyTaskView 				: EntTableView;
	pxyCargoView				: EntTableView;
	pxyDirectorView				: EntTableView;
	entDef 						: EntTableDef;
	entTableRow					: EntTableRow;
	terminal					: CM_Terminal;
	machine						: CM_Machine;
	pxyScreenConfig				: CM_RTScreenConfig;
	
	entTableRowArray 			: EntTableRowArray;
	removeQueueViewArray 		: StringArray;
	
begin

	///if _machine.myRTVehicleConfig = null then
	///	///self.machineDefaultConfig(_machine);
	///	self.defaultRTVehicleConfig(_machine);
	///endif;
	
	///pxyRTVehicleConfig := app.createUpdateProxy(_machine.myRTVehicleConfig).CM_RTVehicleConfig;
	
	if _machineTerminal.isKindOf(CM_Machine) then
		machine := _machineTerminal.CM_Machine;
		if machine.myRTVehicleConfig = null then
			self.defaultRTVehicleConfig(machine);
			pxyRTVehicleConfig := app.createUpdateProxy(machine.myRTVehicleConfig).CM_RTVehicleConfig;
		endif;
	elseif _machineTerminal.isKindOf(CM_Terminal) then
		terminal := _machineTerminal.CM_Terminal;
		if terminal.myRTVehicleConfig = null then
			self.defaultRTVehicleConfig(terminal);
			pxyRTVehicleConfig := app.createUpdateProxy(terminal.myRTVehicleConfig).CM_RTVehicleConfig;
		endif;
	else
		self.assertTrue(_machineTerminal.isKindOf(CM_Machine) and _machineTerminal.isKindOf(CM_Terminal));
	endif;
	
	pxyRTVehicleConfig.setAutoResequenceJobs(self.opts.bool("AutoResequenceJobs"));
	pxyRTVehicleConfig.setPropertyValue("overstowMoveMode", self.opts.int("OverstowMoveMode"));							// 26/07/2011 cnwmh5
	pxyRTVehicleConfig.setPropertyValue("maxNumberOverstowForDriver", self.opts.int("MaxNumberOverstowForDriver"));  	// 26/07/2011 cnwmh5

	/*
	// 13/102/2018 jlgmh5 - Removed as should be copying from the terminal NOT everything
	create pxyCargoView transient;
	entDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_RTEnquiry];
	entDef.allEntTableRows.copy(pxyCargoView.allEntTableRows);
	create pxyDirectorView transient;
	entDef.allEntTableRows.copy(pxyDirectorView.allEntTableRows);
	create pxyTaskView transient;
	entDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_MachineRTFields];
	entDef.allEntTableRows.copy(pxyTaskView.allEntTableRows);
	pxyRTVehicleConfig.setViewDetails(pxyCargoView, pxyDirectorView, pxyTaskView);
	
	// 01/08/2014 cnwmh5 - remove supplied table rows
	if self.opts.includesKey("RemoveVisibleQueueEntry") then
		removeQueueViewArray := self.opts.obj("RemoveVisibleQueueEntry").StringArray;
		//create entTableRowArray transient;
		entTableRowArray := entDef.allEntTableRows;
		beginTransaction;
		foreach entTableRow in entTableRowArray do
			if removeQueueViewArray.includes(entTableRow.name) then
				pxyTaskView.allEntTableRows.remove(entTableRow);
			endif;
		endforeach;
		commitTransaction;
	endif;	
	*/
	
	// 13/102/2018 jlgmh5 - Copy from the terminal values else get all
	terminal := self.getTerminal();
	if terminal.myRTVehicleConfig &lt;&gt; null then
		create pxyCargoView transient;
		terminal.myRTVehicleConfig.myVisibleCargoFields.allEntTableRows.copy(pxyCargoView.allEntTableRows);
		create pxyDirectorView transient;
		terminal.myRTVehicleConfig.myVisibleDirectorFields.allEntTableRows.copy(pxyDirectorView.allEntTableRows);
		create pxyTaskView transient;
		terminal.myRTVehicleConfig.myVisibleTaskFields.allEntTableRows.copy(pxyTaskView.allEntTableRows);
		pxyRTVehicleConfig.setViewDetails(pxyCargoView, pxyDirectorView, pxyTaskView);
		
		
		beginLoad;
		pxyScreenConfig := terminal.myRTVehicleConfig.myNightScreenConfig.pxyCreateUpdateProxy();
		endLoad;
		pxyRTVehicleConfig.myNightScreenConfig.setForUpdate(pxyScreenConfig);
		delete pxyScreenConfig;
		
		beginLoad;
		pxyScreenConfig := terminal.myRTVehicleConfig.myDayScreenConfig.pxyCreateUpdateProxy();
		endLoad;
		pxyRTVehicleConfig.myDayScreenConfig.setForUpdate(pxyScreenConfig);
		delete pxyScreenConfig;
		
		pxyRTVehicleConfig.setPropertyValue("tableFontSize", terminal.myRTVehicleConfig.tableFontSize);
		pxyRTVehicleConfig.setPropertyValue("tableSelectedFontSize", terminal.myRTVehicleConfig.tableSelectedFontSize);
		
	else
		create pxyCargoView transient;
		entDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_RTEnquiry];
		entDef.allEntTableRows.copy(pxyCargoView.allEntTableRows);
		create pxyDirectorView transient;
		entDef.allEntTableRows.copy(pxyDirectorView.allEntTableRows);
		create pxyTaskView transient;
		entDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_MachineRTFields];
		entDef.allEntTableRows.copy(pxyTaskView.allEntTableRows);
		pxyRTVehicleConfig.setViewDetails(pxyCargoView, pxyDirectorView, pxyTaskView);
		
		// 01/08/2014 cnwmh5 - remove supplied table rows
		if self.opts.includesKey("RemoveVisibleQueueEntry") then
			removeQueueViewArray := self.opts.obj("RemoveVisibleQueueEntry").StringArray;
			//create entTableRowArray transient;
			entTableRowArray := entDef.allEntTableRows;
			beginTransaction;
			foreach entTableRow in entTableRowArray do
				if removeQueueViewArray.includes(entTableRow.name) then
					pxyTaskView.allEntTableRows.remove(entTableRow);
				endif;
			endforeach;
			commitTransaction;
		endif;	
	endif;
	
	if self.opts.includesKey("TaskViewMode") then
		pxyRTVehicleConfig.setPropertyValue("taskViewMode", self.opts.int("TaskViewMode"));	
	endif;
	if self.opts.includesKey("DefaultTaskViewMode") then
		pxyRTVehicleConfig.setPropertyValue("defaultTaskViewMode", self.opts.int("DefaultTaskViewMode"));	
	endif;
	
	if self.opts.includesKey("AllowDriverChangeSetdown") then
		pxyRTVehicleConfig.setPropertyValue("allowChangeSetdown", self.opts.bool("AllowDriverChangeSetdown"));	
	endif;
	
	if self.opts.includesKey("AcceptTimerInterval") then
		pxyRTVehicleConfig.setPropertyValue("acceptTimerInterval", self.opts.int("AcceptTimerInterval"));
	endif;
	
	if self.opts.includesKey("PickupTimerInterval") then
		pxyRTVehicleConfig.setPropertyValue("pickupTimerInterval", self.opts.int("PickupTimerInterval"));
	endif;
	
	if self.opts.includesKey("UseSeparatePickSetdown") then
		pxyRTVehicleConfig.setPropertyValue("useSeparatePickSetdown", self.opts.bool("UseSeparatePickSetdown"));	
	endif;
	
	
	app.myTrxUA.trxUpdateRTVehicleConfig(pxyRTVehicleConfig, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog	
	endLoad;
	delete pxyRTVehicleConfig;
end;</source>
        <Parameter name="_machineTerminal" type="Any"/>
    </JadeMethod>
    <JadeMethod name="machineZapTask" id="3a5bdede-c5eb-4204-aaa8-9a505997dee2">
        <source>machineZapTask(_machine: CM_Machine) protected;
// cnwdw1	
// Zap the RT queue entry for this machine
vars
	obj: Object;
	ti : CM_TrackedItem;
begin
	if _machine.currentQueueTask &lt;&gt; null then
		ti := _machine.currentQueueTask.ti;				// 23/05/2014 cnwmh5
		if ti &lt;&gt; null then
			self.unqueueTI(ti);
			self.unplanTI(ti);
		endif;	
		beginTransaction;
		if _machine.currentQueueTask &lt;&gt; null and _machine.currentQueueTask.myEntry &lt;&gt; null then		// 16/06/2014 cnwmh5
			obj := _machine.currentQueueTask.myEntry;
			delete obj;
		endif;
		commitTransaction;
	endif;
epilog
	abortTransaction;	
end;</source>
        <access>protected</access>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="makeTrackedItemTranship" id="1232b434-9c7f-439d-8479-ddb7e2def17c">
