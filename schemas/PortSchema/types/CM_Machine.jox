    <JadeMethod name="canIMVCompleteTask" id="5f48dcb1-8854-488a-b2a9-8cfb88c547df">
        <source>canIMVCompleteTask(_task : CM_RTQueueTask) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2022	jlier1	Initial creation 53288

*/

vars
	ti : CM_TrackedItem;
begin
	if not self.isIMV then
		return false;
	endif;
	if not _task.isMove then
		return false;
	endif;
	
	ti:=_task.ti;
	if ti = null then
		return false;
	endif;
	
	//needs to be on the IMV
	if ti.myPrimaryActualLocation &lt;&gt; self.myMachineController then
		return false;
	endif;
	
	return _task.queue.getLoadMachinesMode = CM_VoyageCraneQueue.ActAsShipLander and
							(_task.targetLocation &lt;&gt; null and _task.targetLocation.isKindOf(CM_VoyageController));
epilog

end;</source>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canIMVMoveTI" id="b887616a-3320-4bfb-af49-c4f540286198">
        <source>canIMVMoveTI(_ti : CM_TrackedItem;
				_toLocation : CM_LocationsController;
				_messageLogger : CM_MessageLogger ) : Boolean;
/*

Purpose:		


Return Value:		


Date		Who		Reason
01 Dec 2006	cnwer1	Initial creation - 

*/

vars
	ti : CM_TrackedItem;
	actualLocation : CM_LocationsController;
	aStr : String;
	remainingTEU,
	imvTEUCount,
	maxTEUCount : Integer;
begin
	
	
	maxTEUCount:=self.myTerminal.getConfig(NoIMVmoveTEUs).Integer;
	if maxTEUCount = 0 then //can put as many as they like on here
		return true; 
	endif;
	if _toLocation &lt;&gt; self.myMachineController then 
		//moving off the vehicle so no need to check anything else
		return true;
	else
		//are they taking off the machine and putting the ti back on the ti in this case no need for more validation
		actualLocation:=_ti.getPrimaryLocation(REAL_MODE);
		if actualLocation = _toLocation then
			return true;
		endif;
	endif;
	
	//cnwjo3, par 22073
	if self.myMachineController = null then  //IMV has just been created so nothing on it!!  Can fit 2x20' and 1x40'
		return true;
	endif;
	
	//epr 3/2/15 CCMS 2456 par 35635
	if _ti = null or not _ti.isKindOf(CM_Container) then
		return true;
	endif;
	
	foreach ti in self.myMachineController.allTrackedItems discreteLock do
		if not ti.isContainer then
			continue;
		endif;
		imvTEUCount:=imvTEUCount + ti.getNumTEU.Integer;	
	endforeach;
	
	remainingTEU:=maxTEUCount - imvTEUCount;
	if remainingTEU &lt;= 0 then
		//already full
		//raise exception
		aStr :=app.getErrorString2(MACH_IMV_FULL, self.id.trimRight,_ti.id);
		if _messageLogger &lt;&gt; null then
			_messageLogger.addLog(aStr, SEVERE_INFO, MACH_IMV_FULL);
		endif;
		return false;
	else
		if remainingTEU &lt;  _ti.getNumTEU() then
			//can't fix this ti on back 
			aStr:=app.getErrorString3(MACH_IMV_ALREADY_CONT,self.id.trimRight,_ti.id,remainingTEU.asStringJMT);
			if _messageLogger &lt;&gt; null then
				_messageLogger.addLog(aStr, SEVERE_INFO,MACH_IMV_ALREADY_CONT);
			endif;
			return false;
		else
			return true;
		endif;
	endif;	
	
	return true;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_toLocation" type="CM_LocationsController"/>
        <Parameter name="_messageLogger" type="CM_MessageLogger"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canLiftOverstowedTiViaWS" id="87f169e1-488d-4ba4-9b25-a4ee939c25db">
        <source>canLiftOverstowedTiViaWS(_ti : CM_TrackedItem) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 September 2019	jlgns1	Initial creation
Added to check if a TI is overstowed with a TI that the current machine is not explicitly lifting
6/09/2019 	JLGNS1	Bug 46173: PNL - Vehicle App Driver Initiated Move of overstowed container
*/

vars
	allOverstowTIs 		: CM_TIArray;
	sideAccessDirection : Integer;
	overstowTI 			: CM_TrackedItem;
	task 				: CM_RTQueueTask;
begin
	
	if  app.isWebService then
		create allOverstowTIs transient;
		_ti.getAllOverstowedTIs(allOverstowTIs,false,sideAccessDirection,null);
		foreach overstowTI in allOverstowTIs do : overLoop
			foreach task in  self.allCurrentWorkingQueueTasks do : taskLoop
				if task.ti = _ti then
					continue taskLoop;
				endif;
			
				if task.ti = overstowTI then
					continue overLoop; 
				endif;
			endforeach;
			return false;
			
		endforeach;
	endif;
	
	return true;
					
epilog
	delete allOverstowTIs;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canMachineAccessHeight" id="ac83dc10-2e53-4d21-9d68-32e57ea21ff7">
        <source>canMachineAccessHeight(pTI : CM_TrackedItem;_toLocation : CM_LocationsController; _messageLogger : CM_MessageLogger): Boolean protected;
/* ---------------------------------------------------------------------------
// Created:		August 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17 Feb 2011	cnwer1		PAR 27030 passed in the toLocation in multi machine moves only want to check the current _toLocation the 
							machine will be working not the final queued location
// ---------------------------------------------------------------------------*/

vars
	
	lHeight			: Real;
	primaryHeight	: Real;
	queuedHeight	: Real;
	lc				: CM_LocationsController;
	lISO			: CM_ISOType;
	lTI				: CM_TrackedItem;
	aStr			: String;
begin

	if self.maxHeightMT &lt;&gt; null or self.maxHeightFull &lt;&gt; null  then // only check the height restriction if there is one
	   
		//cnwjo3 par 25851.  Get the current height of stack.  Can machine access it.
		lc := pTI.getPrimaryLocation(REAL_MODE);
		if lc &lt;&gt; null then
			if lc.isKindOf(CM_GridController) then
				primaryHeight := lc.CM_GridController.getActualHeight();
			endif;
		endif;
		
		//get height of stack
		if _toLocation &lt;&gt; null then
			if _toLocation.isKindOf(CM_GridController) then
				queuedHeight := _toLocation.CM_GridController.getActualHeight() + pTI.getActualHeight();  //we are assuming our TI will always reach location first and override other queued items underneath
			endif;
		endif;
		
		if queuedHeight &gt; primaryHeight then
			lHeight := queuedHeight;
		else
			lHeight := primaryHeight;
		endif;
	else
		return true; // only check the height restriction if there is one, else everything is OK here
	endif;
	
	if pTI.isFull and self.maxHeightFull &gt; 0 then
		// If all the containers currently in this location plus the TI we 
		// are looking at add up to a height greater than our maximum then STOP
		if lHeight &gt; self.maxHeightFull then
			aStr := app.getErrorString3(MACH_MAX_LIFT_HEIGHT_FCL,self.id.trimRight,self.maxHeightFull.asStringJMT,lHeight.asStringJMT);
			if _messageLogger &lt;&gt; null then
				_messageLogger.addLog(aStr, SEVERE_INFO, MACH_MAX_LIFT_HEIGHT_FCL);
			endif;
			return false;
		endif;
	elseif pTI.isEmpty and self.maxHeightMT &gt; 0 then
		// If all the containers currently in this location plus the TI we 
		// are looking at add up to a height greater than our maximum then STOP
		if lHeight &gt; self.maxHeightMT then
			aStr := app.getErrorString3(MACH_MAX_LIFT_HEIGHT_MT,self.id.trimRight,self.maxHeightMT.asStringJMT,lHeight.asStringJMT);
			if _messageLogger &lt;&gt; null then
				_messageLogger.addLog(aStr, SEVERE_INFO, MACH_MAX_LIFT_HEIGHT_MT);
			endif;
			return false;
		endif;
	endif;

	return true;
end;</source>
        <access>protected</access>
        <Parameter name="pTI" type="CM_TrackedItem"/>
        <Parameter name="_toLocation" type="CM_LocationsController"/>
        <Parameter name="_messageLogger" type="CM_MessageLogger"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canMachineAccessLocInWorkzone" id="1933719a-b148-4f6e-87ee-22bb33bfe757">
        <source>canMachineAccessLocInWorkzone(	_location : CM_LocationsController;
								_messageLogger : CM_MessageLogger) : Boolean;


/*		

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2009	cnwer1	Initial creation

*/

vars
	gridController : CM_GridController;
begin
	if self.allWorkzoneLocations.isEmpty then
		return true;
	endif;
	
	if _location = null then
		return true;
	endif;
	
	if not _location.isKindOf(CM_GridController) then
		return true;
	endif;
	
	gridController:=_location.CM_GridController;
	if gridController.isKindOf(CM_GantryICAreaLaneController) then
		gridController:=gridController.CM_GantryICAreaLaneController.myGridColumn.CM_GantryICColumn.myRTGColumn.allControllersByRow.first;
	endif;
	
	if not self.allWorkzoneLocations.includes(gridController) then
		return false;
	endif;
	
	
	return true;
epilog

end;</source>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_messageLogger" type="CM_MessageLogger"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canMachineAccessRestrictedTA" id="220d1f5c-dd15-4934-9737-63ba8ce8d2f2">
        <source>canMachineAccessRestrictedTA(_ti : CM_TrackedItem;
								_toLocation 		: CM_LocationsController ;
								_messageLogger : CM_MessageLogger) : Boolean;
/*

Purpose:		


Return Value:		


Date		Who		Reason
01 Dec 2006	cnwer1	Initial creation - refactored out of canMachineMove	
13 Mar 2018	jlgmd1	TFS #37341 AAT - Machine Not Suitable Error
07 May 2018 cnwer1	TFS 37584 - new reach stacker overstow 
*/
vars
	tmpLC : CM_LocationsController;
	errStr : String;
	errNo : Integer;
	pickupTask,
	setdownTask : CM_RTQueueTask;
	overstowController : CMIF_OverstowController;
	checkTarget : Boolean;
begin
	tmpLC := _ti.getPrimaryLocation(REAL_MODE);
	
	if tmpLC.isKindOf(CM_GridController) then
		//epr TFS 37584 7/5/18
		create overstowController transient;
		overstowController.setParams(null,_ti,false,null,self);
		overstowController.getAllOverstows();
		if overstowController.isSideOverstowed then
			errNo := MACH_ACCESS_SOURCE_RESTRICT_FB;
			errStr := app.getErrorString2(errNo,self.id.trimRight,_ti.locationId.trimBlanks);
			
			if _messageLogger &lt;&gt; null then
				_messageLogger.addLog(errStr, SEVERE_INFO, errNo);
			endif;
			return false;
		endif;
	endif;
	
	//cnwrd1 par 29492 , in multi machine move we dont want to validate the ultimate target location if we arnt the last move
	pickupTask := self.findCurrentWorkingTaskForTI(TASK_PICKUP, _ti);

	if pickupTask &lt;&gt; null then
		setdownTask := pickupTask.getNextMachineTask();
		if setdownTask &lt;&gt; null then
			tmpLC := setdownTask.targetLocation;
			if tmpLC &lt;&gt; null then
				checkTarget:=true;
			endif;
		endif;
	endif;
	
	if tmpLC = null then
		tmpLC := _ti.getPrimaryLocation(QUEUE_MODE);
		if tmpLC &lt;&gt; null then
			checkTarget:=true;
		endif;
	endif;
	
	if pickupTask &lt;&gt; null and pickupTask.status &lt;&gt; TASK_COMPLETE and pickupTask.myEntry.isMachineInitiatedMove then
		if tmpLC = null then
				return true;
		endif;
	endif;
	
	if tmpLC = null then
		tmpLC := _toLocation;
		if tmpLC = null then
			//aStr := app.getErrorString2(MACH_DETERMINE_QD_LOC,self.id.trimRight,_ti.id);											//-TFS3923
			errStr := app.getErrorString3(MACH_DETERMINE_QD_LOC,self.id.trimRight,_ti.cargoBOLTypeDescr,_ti.id);					//+TFS3923
			if _messageLogger &lt;&gt; null then
				_messageLogger.addLog(errStr, SEVERE_INFO, MACH_DETERMINE_QD_LOC);
			endif;
			return false;
		else
			checkTarget:= true;
		endif;
	endif;
	
	if checkTarget and  tmpLC.isKindOf(CM_GridController) then
		delete overstowController;
		//epr TFS 37584 7/5/18
		create overstowController transient;
		overstowController.setGridLocation(tmpLC.CM_GridController);
		overstowController.setMachine(self);
		overstowController.setMode(QUEUE_MODE);
		overstowController.getAllOverstows();
		if overstowController.isSideOverstowed then
			errNo := MACH_ACCESS_TARGET_RESTRICT_FB;
			errStr := app.getErrorString2(errNo,self.id.trimRight,_ti.locationId.trimBlanks);
			
			if _messageLogger &lt;&gt; null then
				_messageLogger.addLog(errStr, SEVERE_INFO, errNo);
			endif;
			return false;
		endif;
	endif;
	
	return true;
epilog
	delete overstowController;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_toLocation" type="CM_LocationsController"/>
        <Parameter name="_messageLogger" type="CM_MessageLogger"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canMachineAccessTAObj" id="e2591490-6727-4359-83f7-1a36cb56394d">
        <source>canMachineAccessTAObj(ta	: CM_TerminalAreaMaster ; areaIsTarget	:	Boolean) : Boolean;
//
// Changed On 	By			Reason
// ----------	----------	------------------------------------------------------------
// 24/08/2011	cnwdap1		PAR #28047 CCMS POL 2095 if a machine can access a terminal area 
//							then by default it can access all that area's interchange areas too
vars
	taGroup : CM_TerminalAreaGroup;
	assocTA : CM_TerminalArea;		// PAR #28047
begin
	if ta = null then 
		return true;
	endif; 
	if ta.isKindOf(CM_SwapStack) and areaIsTarget then
		//-------------------
		//All machines can access a SwapStack if its a TargetLocation
		//but NOT if its a Source, we need to check the machine can actually get there.
		//-------------------
		return true;
	elseif ta.isKindOf(CM_RTGArea) then
		if areaIsTarget then 
			return true;
		endif;
	
	endif;		
	//epr par 22829 10/3/10 removed return true if area is target
	
	// Need to change this to terminal area master set
	if self.allowedTAMasters.includes(ta) then
		return true;
	endif;
	
	// PAR #28047 if ta is an interchange area, can the machine access any of its associated terminal areas?
	if CM_InterchangeArea.hasInstance(ta) then
		foreach assocTA in ta.CM_InterchangeArea.allAssociatedTerminalAreas discreteLock do
			if assocTA.allowedMachines.includes(self) then
				return true;
			endif;
		endforeach;
	endif;
	// PAR #28047 end
	
	return false;
end;</source>
        <Parameter name="ta" type="CM_TerminalAreaMaster"/>
        <Parameter name="areaIsTarget" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canMachineMove30s" id="723ed2db-22cf-4ee9-8830-7fe4c8f219fc">
        <source>canMachineMove30s(_ti : CM_TrackedItem;
					_messageLogger : CM_MessageLogger) : Boolean;
// ---------------------------------------------------------------------------
// Created:		May 2008 By Andrew Bishop cnwab1
//
// Purpose:		 // PAR 16415 CCMS 1029
//
// ---------------------------------------------------------------------------
vars
	aStr : String;		
begin
	if 	_ti.cargoType = TI_CargoType_Container and  
		_ti.CM_Container.is30 and 
		not self.canLift30Foot then
		
		aStr := app.getErrorString3(MACH_LIFT_FT_CONTAINER,self.id.trimRight,30.asStringJMT, _ti.id);
		if _messageLogger &lt;&gt; null then
			_messageLogger.addLog(aStr, SEVERE_INFO, MACH_LIFT_FT_CONTAINER);
		endif;
		return false;
	endif;
	return true;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_messageLogger" type="CM_MessageLogger"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
