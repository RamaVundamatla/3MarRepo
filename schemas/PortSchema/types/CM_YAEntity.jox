    <JadeMethod name="xInvalidObjectDisplayHandler" id="8b5f506e-9ea9-425b-b6ff-ae4013e30fe2">
        <source>xInvalidObjectDisplayHandler(_ex : Exception) : Integer;

// Created by cnwdvb1 on 10 April 2006

vars

