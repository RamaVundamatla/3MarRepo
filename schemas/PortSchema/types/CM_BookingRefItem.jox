    <JadeMethod name="getLengthForSummary" id="0ede0b7d-47bb-4800-80e1-c6e7a678ef3a">
        <source>getLengthForSummary():Integer;
// ---------------------------------------------------------------------------
// Created:     06 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cargoType	:CM_CargoType;
	type		:CM_ISOType;
	group		:CM_ISOTypeGroup;
begin
	cargoType := self.myCargoType;
		
	if cargoType &lt;&gt; null and cargoType.id = TI_CargoType_Container then
		type := self.myISOType;
		
		if type &lt;&gt; null then
			return type.getLengthInFeet;
		endif;
		
		group := self.getISOTypeGroupObject;
		
		if group &lt;&gt; null then
			return group.getLengthInFeet;
		endif;
	endif;
	// if we get to here it is not a container or it has not iso type/group
	return self.length.rounded;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMaximumTemperature" id="6fa29af5-0867-4e7a-906b-846f6f74b329">
        <source>getMaximumTemperature() : Real;
/*
Purpose:			

Date		Who		Reason
30 May 2022	navab1	TFS 53105
*/

vars
	commodity : CM_Commodity;
begin
	commodity := self.getCommodityObj();
	if commodity &lt;&gt; null then                        
		if commodity.hasTemp then
			return commodity.maxTemp;
		endif;
	elseif self.myCargoType &lt;&gt; null then
		return self.myCargoType.getMaximumTemperature();
	endif;
end;
</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="e7ce8493-cc57-4023-9dad-7acf72413850">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
/*
Date		Who		Reason
18/03/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
12/06/2013	cnwcs5	par 31670 - ventilation was missing
*/
vars

begin
	if _attrName = ETRow_MyLength then
		return app.convertMeasurementForDisplay(_measureType, self.length);
	elseif _attrName = ETRow_MyWidth then
		return app.convertMeasurementForDisplay(_measureType, self.width);
	elseif _attrName = ETRow_MyHeight then
		return app.convertMeasurementForDisplay(_measureType, self.height);
	elseif _attrName = ETRow_MyVolume then
		return app.convertMeasurementForDisplay(_measureType, self.productVolume);
	elseif _attrName = ETRow_MyDensity then
		return app.convertMeasurementForDisplay(_measureType, self.density);
	elseif _attrName = ETRow_MyWeight then
		return app.convertMeasurementForDisplay(_measureType, self.productWeight);
	elseif _attrName = ETRow_TotalWeight then
		return app.convertMeasurementForDisplay(_measureType, self.weight);
	elseif _attrName = ETRow_Ventilation then
		return app.convertMeasurementForDisplay(_measureType, self.ventilationMapping);
	elseif _attrName = ETRow_VolumeTotal then
		return app.convertMeasurementForDisplay(_measureType, self.volume);
	endif;

	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
