    <JadeMethod name="dragTrackedItem" id="06eafcc8-32ad-414b-b0bd-0db7a864d388">
        <updating/>
        <source>dragTrackedItem(_ti : CM_TrackedItem; _wle : CM_WorkListEntry; _table : CM_DataTable input) updating;
//--------------------------------------------------------------
//Created: 18 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	picture : Picture;
	wle : CM_WorkListEntry;
	obj : Object;
	tmpTi : CM_TrackedItem;
	origLocn : CM_LocationsController;
	moveController	: CMIF_MoveController;
begin
	delete app.myMoveController;

	create moveController transient;	
	app.myMoveController := moveController;
	moveController.setMoveMode(self.moveModeForm);			
	moveController.setMyTrackedItem(_ti);
	origLocn := _ti.getPrimaryLocation(REAL_MODE);	
	if origLocn &lt;&gt; null then
		moveController.setEffectiveTimeStampOverride(origLocn.getEffectiveTimeStamp());
	endif;

	//WLE could be null if drag from grid area			
	if _wle &lt;&gt; null then
		_wle.setMoveControllerAllOtherTIs(moveController);
	endif;
	

	if _wle &lt;&gt; null then
		if moveController.allOtherTrackedItems.isEmpty then
			moveController.setMyWorkListEntry(_wle);
		else
			moveController.setJobForMove(_wle.job);		
		endif;
	endif;

	_table.dragMode := DragMode_Drag;
	
	create picture transient;
	self.setPictureDragCursor(picture);
	if picture &lt;&gt; null then
		_table.dragCursor := picture.picture;
	endif;

epilog
	if picture &lt;&gt; null then
		delete picture;
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findIndexToAddVehicle" id="df7d868d-603f-4b1c-8bda-504e0f8a4099">
        <source>findIndexToAddVehicle(_vehicle :CM_Vehicle):Integer protected;
// ---------------------------------------------------------------------------
// Created:     07 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 4 Feb 2022 	NAVLW1 		TFS# 52789 Review of 52455 (1086 error when opening Road Operations)
// ---------------------------------------------------------------------------
constants
	VEHICLE_LEVEL = 1;
vars
	count		:Integer;
	int, index	:Integer;
	vehicle		:CM_Vehicle;
	invalid		:Boolean;
begin
	on Exception do app.handleDeletedObject (exception, vehicle, invalid);
	// start at end of list because that way if we are adding from
	// a collection in vehicle id order, it will be quicker, and
	// the code is a bit simpler
	count	:= lstJobs.listCount;
	
	if count = 0 then 
		return null;
	endif;
	
	foreach int in count to 1 step -1 do	 
		if not lstJobs.itemLevel[int] = VEHICLE_LEVEL then
			continue;
		endif;
		
		// 4 Feb 2022 NAVLW1 TFS# 52789 Need to check that we are a vehicle if not then we do not want to do the vehicle code
		if lstJobs.itemObject[int].isKindOf(CM_Vehicle) then
			// we have a vehicle
			vehicle := lstJobs.itemObject[int].CM_Vehicle;
		
			if vehicle.regNumber &gt; _vehicle.regNumber then
				// we have to keep looking back - save the position of the next vehicle
				// we may still need to insert our vehicle b4 it
				index := int;
			else
				// we have a place to add
				break;
			endif;
		endif;
		
		if invalid then	// vehicle is invalid
			self.lstJobs.clearBelowLevel(int);
			self.lstJobs.removeItem(int);
			// make sure index is still valid
			if int &gt; lstJobs.listCount then
				int := 0;
			endif;
			invalid := false;
		endif;
	endforeach; 
	// index will contain the last vehicle with an id greater than our vehicle
	return index; 
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
