        <Parameter name="status" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isImexStatus_Match" id="de683d97-5f36-4fee-9afb-aa2d3bf55de2">
        <source>isImexStatus_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
vars
	status : Integer;
begin

	// We let yard delivery requests through.
	if self.isDeliveryRequest and self.imexStatus = 0 then
		return true;
	endif;
	
	if _yaData.isEmpty() then
		return true;
	endif;
	
	if self.imexStatusArray.isEmpty then	//cnwrd1 par 25681 15.10.2010 -  need to test the imexStatusArray if its populated
		return _yaData.visitObjectsUntilTrue(self, CMIF_YARequest::isImexStatus_Compare, self.imexStatus);
	else
		//cnwrd1 par 25681 15.10.2010 -  need to test the imexStatusArray if its populated
		foreach status in self.imexStatusArray do
			if _yaData.visitObjectsUntilTrue(self, CMIF_YARequest::isImexStatus_Compare, status) then	
				return true;
			endif;
		endforeach;
	endif;
	
	return false;
end;</source>
