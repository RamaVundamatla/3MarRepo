    <JadeMethod name="calcClosestTidalWindow" id="be38ad1e-9e5d-4b68-acb3-ca3305efb5ba">
        <updating/>
        <source>calcClosestTidalWindow() updating, protected;

/*

Date		Who		Reason
27 Mar 2008	cnwkpd1	PAR #16289 - Change Drafts to Decimal[8,2]

*/

vars
	regionToCheck:		HMS_HarbourRegion;
	earliestTime:		TimeStamp;
	latestTime:			TimeStamp;
	currentLimitPosv:	Decimal[5,1];
	currentLimitNegv:	Decimal[5,1];
	draftLimit:			Decimal[8,2];			// PAR #16289
	offsetTime:			Integer;
	offsetAsTime:		Time;
	enterLeaveStatus:	String;
	moveTidalClass:		HMS_TidalClass;
	moveDT:				TimeStamp;
	current:			Real;
	draft:				Real;
begin
	// This method calculates the closest tidal window to the current movement time

	offsetTime:=0;
	enterLeaveStatus:=null;


	// Get region, offset to checkpoint and the harbour enterLeaveStatus for this movement
	regionToCheck := self.aMySelectedMovement.getFirstRegionWithChkPts(offsetTime,enterLeaveStatus,aMySelectedMovement.getMovementPrevious);


	if regionToCheck = null then 
		// No checkpoints to check - set tidal textboxes to 'N/A'
		txtPredictCurr.text:=app.getErrorString(NotApplicable);
		txtPredictDirect.text:=app.getErrorString(NotApplicable);
		txtPredictDepth.text:=app.getErrorString(NotApplicable);
		txtMoveEarliest.text:=app.getErrorString(NotApplicable);
		txtMoveLatest.text:=app.getErrorString(NotApplicable);
		txtTidalActTime.text:=app.getErrorString(NotApplicable);
		txtTidalRelative.text:=app.getErrorString(NotApplicable);
		txtRegionName.text:=app.getErrorString(NotApplicable);
	else	
   		// Display details for first checkpoint reached for the movement
		// Get current and draft limits
		moveTidalClass := self.cmbMoveTidalClas.listObject.HMS_TidalClass;
		
		if moveTidalClass = null then
			moveTidalClass := self.aMySelectedMovement.myMoveTidalClass;
		endif;
		
		if moveTidalClass &lt;&gt; null then
			if enterLeaveStatus = HMSMovementTypeEntering then
				currentLimitPosv := moveTidalClass.allMaximumCurrents[1];
				currentLimitNegv := (moveTidalClass.allMaximumCurrents[2])*-1;
			else
				currentLimitPosv := moveTidalClass.allMaximumCurrents[3];
				currentLimitNegv := (moveTidalClass.allMaximumCurrents[4])*-1;
			endif;
		endif;
		
		if aMySelectedMovement.myClonedVoyage.myHMSVoyageData.dim_DraftFore&lt;aMySelectedMovement.myClonedVoyage.myHMSVoyageData.dim_DraftAft then
			draftLimit:=aMySelectedMovement.myClonedVoyage.myHMSVoyageData.dim_DraftFore;
		else
			draftLimit:=aMySelectedMovement.myClonedVoyage.myHMSVoyageData.dim_DraftAft;
		endif;


		// Get moveDT 
		moveDT:=aMySelectedMovement.occursOnDT;


		// Get closest tidal window times

		if app.myHMSRvTide.getClosestWindow(earliestTime,latestTime,regionToCheck,moveDT,currentLimitPosv,currentLimitNegv,draftLimit,offsetTime,current,draft)=app.getErrorString(MoveUnrestricted) then
        	txtMoveEarliest.text:=app.getErrorString(MoveUnrestricted);
			txtMoveLatest.text:=app.getErrorString(MoveUnrestricted);
		else
			if offsetTime&lt;0 then
				offsetAsTime.setTime(0,((offsetTime)*-1),0,0);
				earliestTime:=earliestTime+offsetAsTime;
				latestTime:=latestTime+offsetAsTime;
				txtMoveEarliest.text:=earliestTime.date.shortFormatJMT() &amp; ", " &amp; (earliestTime).Time.userFormat($CM_HMS_Time24Hour);
				txtMoveLatest.text:=latestTime.date.shortFormatJMT() &amp; ", " &amp; (latestTime).Time.userFormat($CM_HMS_Time24Hour);
			else
				offsetAsTime.setTime(0,offsetTime,0,0);
				earliestTime:=earliestTime-offsetAsTime;
				latestTime:=latestTime-offsetAsTime;
				txtMoveEarliest.text:=earliestTime.date.shortFormatJMT() &amp; ", " &amp; (earliestTime).Time.userFormat($CM_HMS_Time24Hour);
				txtMoveLatest.text:=latestTime.date.shortFormatJMT() &amp; ", " &amp; (latestTime).Time.userFormat($CM_HMS_Time24Hour);
			endif;
		endif;

		txtTidalRelative.text:=offsetTime.String;

		if offsetTime&lt;0 then
			offsetAsTime.setTime(0,((offsetTime)*-1),0,0);
			txtTidalActTime.text:=(moveDT-offsetAsTime).Time.userFormat($CM_HMS_Time24Hour);
		else
			offsetAsTime.setTime(0,offsetTime,0,0);
			txtTidalActTime.text:=(moveDT+offsetAsTime).Time.userFormat($CM_HMS_Time24Hour);
		endif;

		if current&lt;0 then
			txtPredictCurr.text:=(current*-1).roundedTo(1).String;
			txtPredictDirect.text:=app.getErrorString(Ebb);
		else
			txtPredictCurr.text:=current.roundedTo(1).String;
			txtPredictDirect.text:=app.getErrorString(Flood);
		endif;

		txtPredictDepth.text:=draft.roundedTo(2).String;
		txtRegionName.text:=regionToCheck.description;
	endif;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="checkAndSetClearances" id="fba8c72e-13c3-481f-baed-f0ae1f374883">
        <updating/>
        <source>checkAndSetClearances(berthChanged: Boolean; orientationChanged: Boolean):Boolean updating, protected;
// 29 Sep 2022	navsj20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards
// 21 Sep 2023	navdap1	TFS 59472 EUP | FR 56588 Berth planning by bollards Remedial
// 10/07/2024	navcs2	Bug 64769: MSL- IMT- Unable to manage the movements in Harbor management
vars
	foreClearance,
	aftClearance,
	bowMark,
	sternMark:			Decimal[12,2];
	berthPosnInList,
	side:				Integer;	
	posnInvalid:		Boolean;
	oldBowToBollard:  Decimal[9,2];
	bridgeBollard : HMS_Resource;						// TFS 59472
	newBridgeMark, bridgeBollardMark : Decimal[9,2];	// TFS 59472
	bowToBridge : Decimal[9,2];							// TFS 59472
begin
	if self.aMySelectedMovement = null then
		// New postion is OK - Proceed with change of focus
		self.aTxtBowMark_LostFocus_Not_OK := false;	
	 	return posnInvalid; // Is the new position invalid
	elseif (not self.isFirstActivateComplete) then
		// Clearances OK - update form
		self.aLastValidBowMark := self.aMySelectedMovement.bowMarkTo;
		self.aLastValidSternMark := self.aMySelectedMovement.sternMarkTo;
		self.aLastValidForeClearance := self.aMySelectedMovement.foreClearanceTo;
		self.aLastValidAftClearance := self.aMySelectedMovement.aftClearanceTo;
		self.aMyLastValidBerth := self.aMySelectedMovement.myBerth;
		self.aLastValidOrientation := self.aMySelectedMovement.sideTo;
		// New postion is OK - Proceed with change of focus
		self.aTxtBowMark_LostFocus_Not_OK := false;	
		
	 	return posnInvalid; // Is the new position invalid				
	endif;
	// This method calculates the default stern (and bow marks if required) and the fore and aft clearances
	// Set selectedMovement with new parameters
	// ------------------------------------------------------------------------------------------------

	foreClearance := self.aMySelectedMovement.foreClearanceTo;
	aftClearance := self.aMySelectedMovement.aftClearanceTo;
	side := self.aMySelectedMovement.sideTo;
	bowMark := self.aMySelectedMovement.bowMarkTo;
		
	// Set Orientation
	if self.cmbOrientTo.listIndex &gt; 0 then
		if self.cmbOrientTo.text = app.getErrorString(PortSideTo) then
			side := OrientPortSideTo;
		else
			side := OrientStarboardSideTo;
		endif;
	endif;

	// Set 'To Berth'
	self.aMySelectedMovement.myBerth := self.myCmbBerthTo.listObject.HMS_Berth;	
	
	if self.aMySelectedMovement.myHMSVoyageData &lt;&gt; null then						// TFS 59472
		bowToBridge := self.aMySelectedMovement.myHMSVoyageData.dist_BridgeToBow;	// TFS 59472
	endif;																			// TFS 59472
	
	if self.aMySelectedMovement.myBerth = null then
		//Berth not found for supplied marks
		self.aMySelectedMovement.myBerth := self.aMyLastValidBerth;	
	elseif self.aMySelectedMovement.isBerthVisibleOnView() then			
		// Wharf is physical (ie. not logical - calculate marks &amp; clearances)
		// Calculate stern (and bow marks if reqd) &amp; clearances
		if berthChanged = true and orientationChanged = false then
	  		// Set default to be centred on the currently selected berth
 	  		//selectedMovement.clonedMove_CentreShip;
 	  		if self.aMySelectedMovement.check_Clearances(true, self.aMySelectedMovement.raiseClearanceWarnings()) = true then
 	  			// Clearances OK - update form				
				aLastValidBowMark		:=	self.aMySelectedMovement.bowMarkTo;
    			aLastValidSternMark		:=	self.aMySelectedMovement.sternMarkTo;
    			aLastValidForeClearance	:=	self.aMySelectedMovement.foreClearanceTo;
				aLastValidAftClearance	:=	self.aMySelectedMovement.aftClearanceTo;
				aMyLastValidBerth		:=	self.aMySelectedMovement.myBerth;
				aLastValidOrientation	:=	self.aMySelectedMovement.sideTo;
			else
				// Set position on selected movement back to last valid settings 
				bowMark := aLastValidBowMark;
    			sternMark := aLastValidSternMark;
    			foreClearance := aLastValidForeClearance;
				aftClearance := aLastValidAftClearance;
				self.aMySelectedMovement.myBerth:=aMyLastValidBerth;
				side := aLastValidOrientation;
				posnInvalid:=true;
			endif;
			
 	 	elseif berthChanged = false and orientationChanged = false then
 	 		// Bow mark already set - calc stern mark and clearances for selected berth
 	 		//bowMark := txtBowMarkTo.text.Decimal;
			bowMark := txtBowMarkTo.text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
			self.aMySelectedMovement.setBerthMark(bowMark, sternMark, side, foreClearance, aftClearance); 	 		
 	 		self.aMySelectedMovement.clonedMove_CalcSternPosn;
 	  		
 	  		if self.aMySelectedMovement.check_Clearances(false, self.aMySelectedMovement.raiseClearanceWarnings()) = true then
 	  			// Clearances OK - update form
 	  			aLastValidBowMark		:=	self.aMySelectedMovement.bowMarkTo;
    			aLastValidSternMark		:=	self.aMySelectedMovement.sternMarkTo;
    			aLastValidForeClearance	:=	self.aMySelectedMovement.foreClearanceTo;
				aLastValidAftClearance	:=	self.aMySelectedMovement.aftClearanceTo;
				aMyLastValidBerth		:=	self.aMySelectedMovement.myBerth;
				aLastValidOrientation	:=	self.aMySelectedMovement.sideTo;
			else
				// Set position on selected movement back to last valid settings 
				bowMark := aLastValidBowMark;
    			sternMark := aLastValidSternMark;
    			foreClearance := aLastValidForeClearance;
				aftClearance := aLastValidAftClearance;
				self.aMySelectedMovement.myBerth:=aMyLastValidBerth;
				side := aLastValidOrientation;
				posnInvalid:=true;
			endif;
 	 	elseif berthChanged = false and orientationChanged = true then
 	 		// Swap bow and stern marks and calc clearances for selected berth
 	 		//bowMark := self.txtSternMarkTo.text.Decimal;
			bowMark := self.txtSternMarkTo.text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
			// START 29 Sep 2022	navsj20	TFS 54739
			// TFS 59472 rejigged this bit
			oldBowToBollard	:= self.aMySelectedMovement.bowToBollard;
			if self.txtBowMarkTo.text.asDecimalJMT &gt; self.txtSternMarkTo.text.asDecimalJMT then
				newBridgeMark := bowMark + bowToBridge;		// the reverse of what you'd think, because we're flipping the boat
			else
				newBridgeMark := bowMark - bowToBridge;		// ditto here
			endif;
			self.aMySelectedMovement.myBerth.myWharf.getBollardForMark(newBridgeMark, bridgeBollardMark, bridgeBollard);
			self.aMySelectedMovement.setMyBollards(self.aMySelectedMovement.mySternBollard,self.aMySelectedMovement.myBowBollard, bridgeBollard);
			self.cmbBowMarkBollard.listIndex := self.cmbBowMarkBollard.findObject(self.aMySelectedMovement.myBowBollard);
			self.cmbBridgeMarkBollard.listIndex := self.cmbBridgeMarkBollard.findObject(self.aMySelectedMovement.myBridgeBollard);
			self.cmbSternMarkBollard.listIndex := self.cmbSternMarkBollard.findObject(self.aMySelectedMovement.mySternBollard);
			self.aMySelectedMovement.bowToBollard := self.aMySelectedMovement.sternToBollard;
			self.aMySelectedMovement.sternToBollard := oldBowToBollard;
			self.aMySelectedMovement.bridgeToBollard := bridgeBollardMark;
			self.txtBowMarkMeter.text := self.aMySelectedMovement.bowToBollard.asStringJMT;				// 10/07/2024	navcs2	Bug 64769
			self.txtSternMarkMeter.text := self.aMySelectedMovement.sternToBollard.asStringJMT;			// 10/07/2024	navcs2	Bug 64769
			self.txtBridgeMarkMeter.text := self.aMySelectedMovement.bridgeToBollard.asStringJMT;		// 10/07/2024	navcs2	Bug 64769
			// TFS 59472 end
			// END 29 Sep 2022	navsj20	TFS 54739
			self.aMySelectedMovement.setBerthMark(bowMark, sternMark, side, foreClearance, aftClearance);
 	 		self.aMySelectedMovement.clonedMove_CalcSternPosn;

 	  		if self.aMySelectedMovement.check_Clearances(false, self.aMySelectedMovement.raiseClearanceWarnings()) = true then
 	  			// Clearances OK - update form
 	  			aLastValidBowMark		:=	self.aMySelectedMovement.bowMarkTo;
    			aLastValidSternMark		:=	self.aMySelectedMovement.sternMarkTo;
    			aLastValidForeClearance	:=	self.aMySelectedMovement.foreClearanceTo;
				aLastValidAftClearance	:=	self.aMySelectedMovement.aftClearanceTo;
				aMyLastValidBerth		:=	self.aMySelectedMovement.myBerth;
				aLastValidOrientation	:=	self.aMySelectedMovement.sideTo;
			else
				// Set position on selected movement back to last valid settings 
				bowMark := aLastValidBowMark;
    			sternMark := aLastValidSternMark;
    			foreClearance := aLastValidForeClearance;
				aftClearance := aLastValidAftClearance;
				self.aMySelectedMovement.myBerth:=aMyLastValidBerth;
				side := aLastValidOrientation;
				posnInvalid:=true;
			endif;
 	 	endif;


 	 	// Update marks and clearances on form
 	 	if aLastValidAftClearance = ClearanceUnbounded then
 	 		txtAftClearTo.text	:=	app.getErrorString(Unlimited);
 	 	else 
 	 		txtAftClearTo.text	:=	aLastValidAftClearance.asStringJMT();	//#24363 18/06/2010
 		endif;

 		if aLastValidForeClearance = ClearanceUnbounded then
 	 		txtForeClearTo.text	:=	app.getErrorString(Unlimited);
 	 	else 
 			txtForeClearTo.text	:=	aLastValidForeClearance.asStringJMT();	//#24363 18/06/2010
 		endif;
		
 		self.txtBowMarkTo.text := self.aLastValidBowMark.asStringJMT();		//#24363 18/06/2010
 		self.txtSternMarkTo.text := self.aLastValidSternMark.asStringJMT();	//#24363 18/06/2010
 		berthPosnInList := self.myCmbBerthTo.findObject(self.aMyLastValidBerth);
		
 		if berthPosnInList &gt; 0 then
 			self.myCmbBerthTo.listIndex := berthPosnInList;
 			self.myCmbBerthTo.text := self.myCmbBerthTo.itemText[self.myCmbBerthTo.listIndex];
 		else
 			if self.myCmbBerthTo.listCount &gt; 0 then
 				self.myCmbBerthTo.listIndex := 1;
 				self.myCmbBerthTo.text := self.myCmbBerthTo.itemText[self.myCmbBerthTo.listIndex];
 			endif;
 		endif;

 		// Set orientation
 		if self.aLastValidOrientation &gt; 0 then
 			self.cmbOrientTo.listIndex := self.aLastValidOrientation;
 		else
 			self.cmbOrientTo.listIndex := 1;	
 		endif;	
		
 		self.cmbOrientTo.text := self.cmbOrientTo.itemText[self.cmbOrientTo.listIndex];
 	else
 		// Wharf is logical - set bow/stern marks &amp; clearances to "N/A"
 		self.txtBowMarkTo.text := app.getErrorString(NotApplicable);
 		self.txtSternMarkTo.text := app.getErrorString(NotApplicable);
 		self.txtForeClearTo.text := app.getErrorString(NotApplicable);
 		self.txtAftClearTo.text := app.getErrorString(NotApplicable);
 		self.txtBridgeMarkTo.text := app.getErrorString(NotApplicable); 		 		
 	endif;

	self.aMySelectedMovement.setBerthMark(aLastValidBowMark, aLastValidSternMark, aLastValidOrientation, aLastValidForeClearance, aLastValidAftClearance);	
	if self.txtBowMarkTo.text &lt;&gt; app.getErrorString(NotApplicable) then
		txtBridgeMarkTo.text := self.aMySelectedMovement.getBridgeMarkTo().asStringJMT();		//#24363 18/06/2010 		 			
	endif;

	if posnInvalid then
		// New postion is invalid
		self.aTxtBowMark_LostFocus_Not_OK := true;			
	else
		// New postion is OK - Proceed with change of focus
		self.aTxtBowMark_LostFocus_Not_OK := false;		
	endif;
		
 	return posnInvalid; // Is the new position invalid
end;</source>
        <access>protected</access>
        <Parameter name="berthChanged" type="Boolean"/>
        <Parameter name="orientationChanged" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkAndUpdateMoveDT" id="0c35df25-0afe-4a28-9522-9c88a32d140d">
        <updating/>
        <source>checkAndUpdateMoveDT(validForDT: Boolean io; berthChanged: Boolean; orientationChanged: Boolean):Boolean updating, protected;

vars
	lastValidDate	: Date;
	lastValidTime	: Time;
	//lastPlannedDT	: TimeStamp;
	//lastActualDT	: TimeStamp;
	lastMoveStatus	: Integer;
	newTime			: TimeStamp;
	
begin
	if self.aMySelectedMovement = null then
		return false;
	endif;

	lastValidDate := self.aMySelectedMovement.occursOnDT.date;
	lastValidTime := self.aMySelectedMovement.occursOnDT.time;
	//lastPlannedDT := mySelectedMovement.moveDTPlanned; // Mod 11/08/99
	//lastActualDT := mySelectedMovement.moveDTActual; // Mod 11/08/99
	lastMoveStatus := self.aMySelectedMovement.moveStatus; // Mod 11/08/99

	// Set new Date and Time for movement
	if self.aMySelectedMovement.occursOnDT.date &lt;&gt; self.myTxtMoveOnDate.getDate() 
	or self.aMySelectedMovement.occursOnDT.time &lt;&gt; self.myTxtMoveOnTime.getTime()
	then
		if (not self.checkDateIsValid) then
			// Set date and time back
			self.myTxtMoveOnDate.setDate(lastValidDate);
			self.myTxtMoveOnTime.setTime(lastValidTime);
			validForDT	:=	false;
			return false;
		else
			// Update date on selected movement
			// Modified by Russell 11/08/99
			// --------------------------------------------------------
			newTime.setDate(self.myTxtMoveOnDate.getDate());
			newTime.setTime(self.myTxtMoveOnTime.getTime());
			//selectedMovement.clonedMove_SetActOrPlanAsReqd(newTime);
			self.aMySelectedMovement.setInitialiseValues(	self.aMySelectedMovement.isAgentDefault,
															newTime,
															self.aMySelectedMovement.moveType);
			// --------------------------------------------------------
			//selectedMovement.occursOnDT:=(self.myTxtMoveOnDate.getValue.Date.String &amp; "," &amp; self.myTxtMoveOnTime.getValue.Time.String).TimeStamp;

			// Recheck clearances
			//if checkAndSetClearances(true,false)=true or checkFromClearances=true then
			// Modified by Russell 26/03/99
			// ---------------------------------------------------------------------------
			if self.checkAndSetClearances(berthChanged, orientationChanged) // Position is invalid
			or self.checkFromClearances() // Position is invalid
			then
			// ---------------------------------------------------------------------------
				// Postion is invalid for this Date and Time - reset DT
				// Set date and time back
				self.myTxtMoveOnDate.setDate(lastValidDate);
				self.myTxtMoveOnTime.setTime(lastValidTime);
				self.aMySelectedMovement.occursOnDT.setDate(lastValidDate);
				self.aMySelectedMovement.occursOnDT.setTime(lastValidTime);
				//mySelectedMovement.moveDTPlanned := lastPlannedDT; // Mod 11/08/99
				//mySelectedMovement.moveDTActual := lastActualDT; // Mod 11/08/99
				self.aMySelectedMovement.moveStatus := lastMoveStatus; // Mod 11/08/99

				// Set focus back to Date on General Sheet
				fldMovements.topSheet := shtGeneral;
				self.myTxtMoveOnDate.setFocus();
				validForDT := false;
				
				return true; // ie. clearances have already been checked. 
			else
				// Recalc Tidal Window Details
				self.calcClosestTidalWindow();
				// Recalc Actual Order Times
				self.setDefaultActOrderTimes();
				validForDT := true;
				
				return true; // ie. clearances have already been checked.
			endif;
		endif;
	else
		validForDT := true;
		return false;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="validForDT" type="Boolean" usage="io"/>
        <Parameter name="berthChanged" type="Boolean"/>
        <Parameter name="orientationChanged" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkDateIsValid" id="4e17c7ba-6725-405d-a2cb-721cc089e3ab">
        <updating/>
        <source>checkDateIsValid():Boolean updating, protected;

vars
 	moveType:	String;
 	moveDate:	Date;
 	moveTime:	Time;
	
begin
	moveType	:=	txtMoveType.text;
	moveDate	:=	self.myTxtMoveOnDate.getDate();
	moveTime	:=	self.myTxtMoveOnTime.getTime();
	
	if aMySelectedMovement = null then
		return false;
	endif;	
	
	// Check that the movement date is valid
	if self.aMySelectedMovement.check_DateIsValidForClone(moveType,moveDate,moveTime,aMySelectedVoyage) = true then
		// check is OK
		return true;
	else
		self.myTxtMoveOnDate.setFocus();
		return false;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkFromClearances" id="67619389-4e71-49e1-a1da-537fa2c48fec">
        <updating/>
        <source>checkFromClearances():Boolean updating, protected;

vars
 	posnInvalid: Boolean;
 	movePrev:	CMIF_HMS_WorkingMovement;
begin
	// This method is called when the move DT is changed - we now need to check the clearances at the 
	// last berth to see if they are still valid

	// Temporarily update DT on current movement in order to check previous movement's duration at 
	// a berth
	if self.aMySelectedMovement = null then
		return false;
	endif;
	
	if self.aMySelectedMovement.moveType &lt;&gt; HMSMovementTypeArrival then
		movePrev	:=	self.aMySelectedMovement.getMovementPrevious();
		
		if movePrev = null then
			posnInvalid := true;
		 	return posnInvalid;
		endif;
		
		// Modified by Russell 25/03/99
		// ---------------------------------------------
		// Make sure that we are working with the clone
		if movePrev.myClonedMovement = null then
			movePrev	:=	movePrev.myClone;
		endif;
		
		// --------------------------------------------
		if (not movePrev.isLogicalBerth()) then
			self.aLastValidForeClearFrom	:=	movePrev.foreClearanceTo;
			self.aLastValidAftClearFrom		:=	movePrev.aftClearanceTo;
			
			// Wharf is physical (ie. not logical - calculate marks &amp; clearances)
 			
 			if (not movePrev.check_Clearances(false, movePrev.raiseClearanceWarnings())) then // recalculates the clearances
 				// Set position on selected movement back to last valid settings 
				movePrev.setBerthMark(movePrev.bowMarkTo, movePrev.sternMarkTo, movePrev.sideTo, self.aLastValidForeClearFrom, self.aLastValidAftClearFrom);
				posnInvalid	:=	true;
			else 
				// set new clearances
				self.aLastValidForeClearFrom	:=	movePrev.foreClearanceTo;
				self.aLastValidAftClearFrom		:=	movePrev.aftClearanceTo;
				//movePrev.ofClonedMovement.foreClearanceTo:=lastValidForeClearFrom;
				//movePrev.ofClonedMovement.aftClearanceTo:=lastValidAftClearFrom;
				movePrev.setBerthMark(movePrev.bowMarkTo, movePrev.sternMarkTo, movePrev.sideTo, self.aLastValidForeClearFrom, self.aLastValidAftClearFrom);				
			endif;

			// Update marks and clearances on form
 		 	if self.aLastValidAftClearFrom = ClearanceUnbounded then
 		 		txtAftClearFrom.text	:=	app.getErrorString(Unlimited);
 		 	else 
 		 		txtAftClearFrom.text	:=	self.aLastValidAftClearFrom.asStringJMT();	//#24363 18/06/2010
 			endif;
			
			if self.aLastValidForeClearFrom = ClearanceUnbounded then
 				txtForeClearFrom.text	:=	app.getErrorString(Unlimited);
 			else 
 				txtForeClearFrom.text	:=	self.aLastValidForeClearFrom.asStringJMT();	//#24363 18/06/2010
 			endif;
 		endif;
 	endif;
	
 	return posnInvalid;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkOrientationHasChanged" id="1010e377-b6d8-4535-9258-b177a4ad72e7">
        <source>checkOrientationHasChanged() : Boolean protected;

/*

Purpose:	Check to see that the screen and selected movements ship orientation have changed		

Parameters:			

Return Value:		


Date			Who		Reason
02 July 2010	cnwmh5	Initial creation

*/

vars
	haveChanged	: Boolean;
begin

	if self.aMySelectedMovement = null or self.aMySelectedMovement.sideTo &lt;&gt; self.cmbOrientTo.listIndex then
		haveChanged := true;
	endif;
		
	return haveChanged;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkShipLOA" id="a7b0d7da-17e0-40e7-bfea-c6a68c820fb9">
        <updating/>
        <source>checkShipLOA() updating, protected;

vars

begin
	return; // This is redundant as marks are updated when the LOA is changed.
	if self.aMySelectedMovement = null then
		return;
	else
	 	// This method checks to see if the ship length has changed. If it has, the 
	 	// bow or stern mark is adjusted to reflect the new length of the ship
	 	if self.aMySelectedMovement.clonedMove_RefreshMarks() then
	 		// Marks have changed - set new bow and stern marks
	 		txtBowMarkTo.text := self.aMySelectedMovement.bowMarkTo.asStringJMT();				//#24363 18/06/2010
	 		txtSternMarkTo.text := self.aMySelectedMovement.sternMarkTo.asStringJMT();			//#24363 18/06/2010
			txtBridgeMarkTo.text := self.aMySelectedMovement.getBridgeMarkTo().asStringJMT();	//#24363 18/06/2010 				 		 		
	 		// Recalc and check clearances
	 		self.aMySelectedMovement.check_Clearances(false, self.aMySelectedMovement.raiseClearanceWarnings());
	 		// Update marks and clearances on form
	 	 	if self.aMySelectedMovement.aftClearanceTo=ClearanceUnbounded then
	 	 		txtAftClearTo.text := app.getErrorString(Unlimited);
	 	 	else 
	 	 		txtAftClearTo.text := self.aMySelectedMovement.aftClearanceTo.asStringJMT();	//#24363 18/06/2010
	 		endif;
	
	 		if self.aMySelectedMovement.foreClearanceTo=ClearanceUnbounded then
	 	 		txtForeClearTo.text := app.getErrorString(Unlimited);
	 	 	else 
	 			txtForeClearTo.text := self.aMySelectedMovement.foreClearanceTo.asStringJMT();	//#24363 18/06/2010
	 		endif;
	 	endif;
	 endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
