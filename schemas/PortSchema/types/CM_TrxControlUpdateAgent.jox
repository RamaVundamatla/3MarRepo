    <JadeMethod name="trxUpdateYardRequestRemarks" id="d9a29ba4-499e-45bb-9807-cb016aecdab6">
        <updating/>
        <source>trxUpdateYardRequestRemarks(	_yardRequest : CM_YardRequest input; 
								_remarks : String;
								_wle : CM_YardWLE input;
								_totalQuantity : Integer;
								_weight : Decimal;
								_passport : CM_Passport input) updating;
//-----------------------------------------
//Created: January 2003 By: cnwgd1
//-----------------------------------------
vars
	ct : CM_CargoType;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;

	app.myUtilityUA.utlUpdateYardRequestRemarks(_yardRequest, _remarks, _passport);

	
	if _passport.hasErrors then
		return;
	endif;
	
	ct:=_yardRequest.getCargoType();
	//epr par 32509 8/10/13
	if ct &lt;&gt; null and _wle &lt;&gt; null then
		if ct.isBreakBulkMulti and  _totalQuantity &gt; 0 then	
			app.myUtilityUA.utlUpdateYardRequestQuantity(_wle,_totalQuantity,_passport);
		endif;
		
		if ct.isBulkMulti and _weight &gt; 0  then
			app.myUtilityUA.utlUpdateYardRequestWeight(_wle,_weight,_passport);
		endif;
		
	endif;
	
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
