vars
	x1, y1, x2, y2, tiLen, numTier : Integer;
	xs1, ys1, xs2, ys2 : Real; // to scale
	xd1, yd1 : Real; // for drawing
	len, hite : Real;
	aTI : CM_TrackedItem;
	iconColour, aColour : Integer;
	obj : Object;
	locnDefn, aftLocnDefn : CM_ROROLocnDefnVoyage;
	deckItemLayout : CM_DeckItemLayout;
	slotDefn : CM_ROROSlotDefnVoyage;
	req : CM_RORORequest;
	myDrawingFrame : CMUI_PointDrawingFrame;
//	slotsToDraw : CM_ROROSlotDefnByOrdinalDict;
	slotsInOrder : ObjectArray;
begin




return;
/*




















	myDrawingFrame := self.myPointDrawingFrame;
	myDrawingFrame.drawTextRotation := 0;
	myDrawingFrame.drawTextCharRotation := 0;
	myDrawingFrame.drawWidth := 1; // PAR 28787
	if _deckItem = null then
		return;
	endif;

	if not _deckItem.isLocnContainer() then
		return;
	endif;

	create slotsInOrder transient;
	
	numTier := _numTier;
	locnDefn := _deckItem.CM_ROROLocnDefnVoyage;
	deckItemLayout := locnDefn.myLayout;

	x1 := 9999999;
	y1 := 9999999;
//	deckItemLayout.getExtremePoints(x1, y1, x2, y2);
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. locnDefn.isRotated() ' &amp; locnDefn.isRotated().String);
	if locnDefn.isRotated() then
		x1 := _tmpPoints[1].x;
		y1 := _tmpPoints[1].y;
		x2 := _tmpPoints[2].x;
		y2 := _tmpPoints[3].y;
	else
		x1 := _tmpPoints[1].x;
		y1 := _tmpPoints[1].y;
		x2 := _tmpPoints[2].x;
		y2 := _tmpPoints[3].y;
	endif;

	
	xs1 := x1 * self.scaleFactor;
	ys1 := y1 * self.scaleFactor;
	xs2 := x2 * self.scaleFactor;
	ys2 := y2 * self.scaleFactor;

		len := xs2-xs1;
		hite := ys2-ys1;
		if _has40s then
			numTier := numTier * 2;
		endif;

		self.drawSortReqs(slotsInOrder, locnDefn, _has40s, _isLoad, not locnDefn.isRotated()); // PAR 28883
/*		
		locnDefn.allROROSlotDefnByOrdinal.copyNoDuplicates(slotsToDraw,false); // PAR 28746 if had 40s was not drawing a small rectangle for any 20s in the aft slot.
		if _has40s then
			aftLocnDefn := locnDefn.myAdjacentSlotAft.CM_ROROLocnDefnVoyage;
			if aftLocnDefn &lt;&gt; null then
				aftLocnDefn.allROROSlotDefnByOrdinal.copyNoDuplicates(slotsToDraw,false); // PAR 28746
			
			endif;
		endif;
		
		// PAR 28900 sort 20s first then 40s in reverse
		
		// PAR 28900 sort 20s first then 40s in reverse
		// PAR 28986 FWD 20s FIRST and removed 'reverse'
		foreach slotDefn in slotsToDraw discreteLock  do
				if _isLoad then
					req := slotDefn.CM_ROROSlotDefnVoyage.mySlotController.myRORORequestLoad;
				else
					req := slotDefn.CM_ROROSlotDefnVoyage.mySlotController.myRORORequestDischarge;
				endif;
				if req &lt;&gt; null then
					if req.getAttrIs40() then
						continue;
					endif;
				endif;
				
				// Only 20s left
				
				// Get rid of the aft 20s
				if slotDefn.myROROLocnDen = aftLocnDefn then
					continue;
				endif;
				
				slotsInOrder.add(slotDefn);
		endforeach;
		// PAR 28986  AFT 20s SECOND
		foreach slotDefn in slotsToDraw discreteLock  do
		
				// Get rid of the 40s
				if _isLoad then
					req := slotDefn.CM_ROROSlotDefnVoyage.mySlotController.myRORORequestLoad;
				else
					req := slotDefn.CM_ROROSlotDefnVoyage.mySlotController.myRORORequestDischarge;
				endif;
				if req &lt;&gt; null then
					if req.getAttrIs40() then
						continue;
					endif;
				endif;
				
				// Only 20s left
				
				// Get rid of the forward 20s
				if slotDefn.myROROLocnDen = locnDefn then
					continue;
				endif;
				
				slotsInOrder.add(slotDefn);
		endforeach;
		
		// PAR 28900 sort 20s first then 40s in reverse
		foreach slotDefn in slotsToDraw discreteLock  do
				if _isLoad then
					req := slotDefn.CM_ROROSlotDefnVoyage.mySlotController.myRORORequestLoad;
				else
					req := slotDefn.CM_ROROSlotDefnVoyage.mySlotController.myRORORequestDischarge;
				endif;
				
				if req &lt;&gt; null then
					if req.isBackEndRequest() then 
						continue;
					endif;
					if req.getAttrIs40() then
						slotsInOrder.add(slotDefn);
					endif;
				endif;
		endforeach;
*/
/*
		// PAR 28849 - set the icon colour based on the current drawing fill. We have just drawn the rectangle for the request so this should be the colour of that request
		aColour := myDrawingFrame.drawFillColor;
		iconColour := aColour.getInverseColour();
		//iconColour := Black; // 29884 aColour.getInverseColour();
		
		// HORIZONTAL
		if len &gt; hite then

			len := (len / numTier);
			len := len - 3; // PAR 29164
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. ' &amp; _deckItem.code &amp; " _has40s: " &amp; _has40s.String &amp; " numTier: " &amp; numTier.String &amp; " len: " &amp; len.String);	
			
			xd1 := xs1 + 2;
			
			// PAR 28900 foreach slotDefn in slotsToDraw discreteLock do // PAR 28746 locnDefn.allROROSlotDefnByOrdinal discreteLock do
			foreach obj in slotsInOrder  discreteLock do
				slotDefn := obj.CM_ROROSlotDefnVoyage;
				if _isLoad then
					req := slotDefn.mySlotController.myRORORequestLoad;
				else
					req := slotDefn.mySlotController.myRORORequestDischarge;
				endif;
				
				// PAR 29897 - Always show actual Exports over discharge CC
				if not _isLoad 
				and (slotDefn.mySlotController.myRORORequestLoad &lt;&gt; null and slotDefn.mySlotController.myRORORequestLoad.isComplete) then
					req := null;
				endif;
				
				tiLen := (len).Integer;
				if req &lt;&gt; null then
					if req.allAllocations.isEmpty() then // PAR 28883
						 // PAR 29807 return; // PAR 28883
						continue; // PAR 29807
					endif;
					if req.isBackEndRequest() then // PAR 28746
						continue;
					endif;
					
					if req.getAttrIs40() then
						tiLen := (len * 2).Integer;
					else
					
					endif;
					aColour := req.getAllocationColour();
//	PAR 28900 				iconColour := aColour.getInverseColour();
					if req.isRehandle then
						aColour := self.COLOUR_DLR;
					elseif req.isSoB then
						aColour := self.COLOUR_SOB;
					endif;
				else
					// PAR 29050
					if slotDefn.mySlotController.hasROB() 
					// PAR 29897 - Always show actual Exports over discharge CC
					or (not _isLoad 
						and (slotDefn.mySlotController.myRORORequestLoad &lt;&gt; null and slotDefn.mySlotController.myRORORequestLoad.isComplete)) then
					
					
						aTI := slotDefn.mySlotController.allTrackedItems.first();
						if aTI.myPrimaryActualLocation = slotDefn.mySlotController then
							aColour := aTI.getDrawingColour(TI_ColourMode_DischargePort);
							myDrawingFrame.drawFillColor := aColour;
							myDrawingFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
							
							if not aTI.isTwenty() then
								tiLen := (len * 2).Integer;
							endif;
							if slotDefn.mySlotController.hasROB()  then
								myDrawingFrame.drawFilledRectangle(xd1, ys1 + 6, xd1 + tiLen + 2, ys1 + 15,aColour);
							// PAR 29897 - Always show actual Exports over discharge CC
							else
								myDrawingFrame.drawFilledRectangle(xd1, ys1 + 2, xd1 + tiLen + 2, ys2 -2,aColour);
							endif;
							xd1 := xd1 + tiLen + 4;
						endif;
					endif;

					continue; // PAR 28900
					aColour := White;
				endif;
				myDrawingFrame.drawFillColor := aColour;
				myDrawingFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
				
				myDrawingFrame.drawFilledRectangle(xd1, ys1 + 4, xd1 + tiLen, ys1 + 9,iconColour);// PAR 28990 added 2 pixels to put a gap if there is a job line
				
				
				if req &lt;&gt; null then
					aTI := req.getTrackedItem();
					self.drawIcons(aTI, req, myDrawingFrame, xd1, ys1 + 8, iconColour, true);
					if (self.modeView = ShpDisplayMode_ColCodeLoad or self.modeView = ShpDisplayMode_ColCodeDisch) then 
						// DRAW BLACK MARK FOR COMPLETED WLE
						if req.isComplete  then
							myDrawingFrame.drawFillColor := Black;
							myDrawingFrame.drawFilledRectangle(xd1 + 2, ys2 - 6, xd1+5, ys2-3, Black);
						endif;
					endif;
					// DRAW GREEN MARK FOR LINKED REQUEST
					if (self.modeView = ShpDisplayMode_ColCodeLoad) then
						if req.myRequestLinkedDischarge &lt;&gt; null  then
							myDrawingFrame.drawFillColor := LightGreen;
							myDrawingFrame.drawFilledRectangle(xd1 + 7, ys2 - 6, xd1+10, ys2-3, LightGreen);
						endif;
					endif;
					if (self.modeView = ShpDisplayMode_ColCodeDisch) then
						if req.myRequestLinkedLoad &lt;&gt; null  then
							myDrawingFrame.drawFillColor := LightGreen;
							myDrawingFrame.drawFilledRectangle(xd1 + 7, ys2 - 6, xd1+10, ys2-3, LightGreen);
						endif;
					endif;
				endif;
				xd1 := xd1 + tiLen + 2; // PAR 29133
			endforeach;
			
		
		else
			hite := (hite / numTier);
			hite := hite - 3; // PAR 29164
			
			// PAR 28900 yd1 := ys1 + 2;
			yd1 := ys2 - 2;
			xd1 := xs1 + 2;			
// PAR 28900			foreach slotDefn in slotsToDraw discreteLock do // PAR 28748 locnDefn.allROROSlotDefnByOrdinal discreteLock do
			foreach obj in slotsInOrder  discreteLock do
				slotDefn := obj.CM_ROROSlotDefnVoyage;
				if _isLoad then
					req := slotDefn.mySlotController.myRORORequestLoad;
				else
					req := slotDefn.mySlotController.myRORORequestDischarge;
				endif;
				
				// PAR 29897 - Always show actual Exports over discharge CC
				if not _isLoad 
				and (slotDefn.mySlotController.myRORORequestLoad &lt;&gt; null and slotDefn.mySlotController.myRORORequestLoad.isComplete) then
					req := null;
				endif;
				
				tiLen := (hite).Integer; // PAR 28748
				if req &lt;&gt; null then
					if req.allAllocations.isEmpty() then // PAR 28883 OOTL requests are craeted without an Allocation
						 // PAR 29807 return; // PAR 28883
						continue; // PAR 29807
					endif;
				
					if req.isBackEndRequest() then // PAR 28748
						continue;
					endif;
					if req.getAttrIs40() then
						tiLen := (hite * 2).Integer;
					endif;
					aColour := req.getAllocationColour();
					// PAR 28900 iconColour := aColour.getInverseColour();
					if req.isRehandle then
						aColour := self.COLOUR_DLR;
					elseif req.isSoB then
						aColour := self.COLOUR_SOB;
					endif;
				else
					aColour := White;
					// PAR 29050
					if slotDefn.mySlotController.hasROB() 
					// PAR 29897 - Always show actual Exports over discharge CC
					or (not _isLoad 
						and (slotDefn.mySlotController.myRORORequestLoad &lt;&gt; null and slotDefn.mySlotController.myRORORequestLoad.isComplete)) then

						aTI := slotDefn.mySlotController.allTrackedItems.first();
						if aTI.myPrimaryActualLocation = slotDefn.mySlotController then
							aColour := aTI.getDrawingColour(TI_ColourMode_DischargePort);
							myDrawingFrame.drawFillColor := aColour;
							myDrawingFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
							
							if not aTI.isTwenty() then
								tiLen := (hite * 2).Integer;
							endif;
							if slotDefn.mySlotController.hasROB()  then
								myDrawingFrame.drawFilledRectangle(xd1 + 6, yd1, xd1+15,yd1 - tiLen,aColour); 
							else
								myDrawingFrame.drawFilledRectangle(xd1 + 2, yd1, xs2-3,yd1 - tiLen,aColour); 
							endif;
							yd1 := yd1 - tiLen - 2; 
						endif;
					endif;
					continue; // PAR 28900
				endif;
				myDrawingFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
				myDrawingFrame.drawFillColor := aColour;
// PAR 28900				myDrawingFrame.drawFilledRectangle(xd1 + 2, yd1, xd1+7,yd1 + tiLen,iconColour); // PAR 28748
				myDrawingFrame.drawFilledRectangle(xd1 + 2, yd1, xd1+7,yd1 - tiLen,iconColour); // PAR 28748

				
				if req &lt;&gt; null then
					aTI := req.getTrackedItem();
// PAR 28900					self.drawIcons(aTI, req, myDrawingFrame, xd1 + 8, yd1, iconColour, true);
					self.drawIcons(aTI, req, myDrawingFrame, xd1 + 8, yd1 - tiLen, iconColour, false); //epr par 29647 31/5/12
					if (self.modeView = ShpDisplayMode_ColCodeLoad or self.modeView = ShpDisplayMode_ColCodeDisch) then 
						// DRAW BLACK MARK FOR COMPLETED JOB
						if req.isComplete  then
							myDrawingFrame.drawFillColor := Black;
							myDrawingFrame.drawFilledRectangle(xs2-4, yd1 - 6, xs2-7, yd1 - 9, Black); // PAR 29050
						endif;
					endif;
					// DRAW GREEN MARK FOR LINKED REQUEST
					if (self.modeView = ShpDisplayMode_ColCodeLoad) then
						if req.myRequestLinkedDischarge &lt;&gt; null  then
							myDrawingFrame.drawFillColor := LightGreen;
							myDrawingFrame.drawFilledRectangle(xs2-4, yd1 -1, xs2-7, yd1 - 4, LightGreen); // PAR 29050
						endif;
					endif;
					if (self.modeView = ShpDisplayMode_ColCodeDisch) then
						if req.myRequestLinkedLoad &lt;&gt; null  then
							myDrawingFrame.drawFillColor := LightGreen;
							myDrawingFrame.drawFilledRectangle(xs2-4, yd1 - 1, xs2-7, yd1 - 4, LightGreen); // PAR 29050
						endif;
					endif;
				endif;
// PAR 28900				yd1 := yd1 + tiLen + 1; // PAR 28748
 // PAR 29133				yd1 := yd1 - tiLen - 1; // PAR 28748
								yd1 := yd1 - tiLen - 2;  // PAR 29133
			endforeach;
			
		endif;

	// PAR 28886
	if locnDefn.isOOTL and locnDefn.isPlannedRotated then
		myDrawingFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
		myDrawingFrame.drawFillColor := Red;
		myDrawingFrame.drawEllipse(xs2 - 7, ys2 - 7, xs2 - 2, ys2 - 2,Red); 
	
	endif;
epilog
//	delete slotsToDraw;
	delete slotsInOrder;
*/
end;</source>
        <Parameter name="_deckItem" type="CM_DeckItem"/>
        <Parameter name="_numTier" type="Integer"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_has40s" type="Boolean"/>
        <Parameter name="_tmpPoints" type="PointArray"/>
    </JadeMethod>
    <JadeMethod name="drawSelectedObjects" id="9db1405d-4c81-4dab-982a-53975f9acc6d">
        <updating/>
        <source>drawSelectedObjects() updating;
/*
Purpose:			
Date		Who		Reason
11 August 2011	cnwab1	Initial creation
*/

vars
	allLocnDefn : ObjectSet;
	tmpLocnDefn : CM_ROROLocnDefn;
	tmpDeckItem : CM_DeckItem;
	obj : Object;
	aReq : CM_RORORequest;
	layer : CM_DeckLayerLayout;
	isLoad : Boolean;
	//cnwmc5 - par 29977
	tmpGCDefn : CM_ROROGCDefn;
	allGCDefn : ObjectSet;
begin
	self.myPointDrawingFrame := self.myPlanningForm.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame;
	self.myPointDrawingFrame.doBtnClearClick(true);
	
	create allLocnDefn transient;
	//cnwmc5 - par 29977
	create allGCDefn transient;
	
	foreach obj in self.allSelectedObjects where obj.isKindOf(CM_RORORequest) do 
		// Slot request have their own layout, however we are drawing  top down view so we only need to draw 1 of them.
		// If a location can stack 4 containers there may be 4 req layouts all with the same x/ys
		// ALso if we have a 40 foot request in the stack only pass through that to draw
		tmpLocnDefn := null;
		aReq := null;
		tmpGCDefn := null;
		
		tmpDeckItem := obj.CM_RORORequest.myROROController.getDefn();
		if tmpDeckItem.isKindOf(CM_ROROLocnDefn) then
			tmpLocnDefn := tmpDeckItem.CM_ROROLocnDefn;
			if tmpLocnDefn &lt;&gt; null then
				if allLocnDefn.includes(tmpLocnDefn) then
					continue; // already llooked at a request for this location
				endif;
				aReq := tmpLocnDefn.getFirst40Request(self.modeView = ShpDisplayMode_ColCodeLoad); // PAR 29055
				if aReq &lt;&gt; null then // We have a40 req in this location so use that
					if  aReq.isBackEndRequest() then
						continue;
					endif;
					//self.myPointDrawingFrame.doAddToArraysForProxy(aReq.myLayout);
					self.myPointDrawingFrame.doPointArrayAdd(Black,true, Frame.DrawFillStyle_Solid, 1, Grey, aReq.myLayout);
					
					isLoad := aReq.isLoad; // PAR 29055
					allLocnDefn.add(tmpLocnDefn);
					continue;
				else
					// PAR 30174
					if self.modeView = ShpDisplayMode_ColCodeLoad then
					// PAR 29893 no 40 so get the 20 and set the	 isLoad 
						aReq := tmpLocnDefn.hasColourCoding(LOAD_MOVETYPE); 
					else
						aReq := tmpLocnDefn.hasColourCoding(DISCHARGE_MOVETYPE); 
					endif;
					if aReq &lt;&gt; null then 
						isLoad := aReq.isLoad;
					endif;
				endif;
			endif;	
		//cnwmc5 - par 29977 - added the following 'elseif'
		elseif tmpDeckItem.isKindOf(CM_ROROGCDefn) then
			tmpGCDefn := tmpDeckItem.CM_ROROGCDefn;
			if tmpGCDefn &lt;&gt; null then
				if allGCDefn.includes(tmpGCDefn) then
					continue;
				endif;
				// PAR 30174
				if self.modeView = ShpDisplayMode_ColCodeLoad then
					aReq := tmpGCDefn.hasColourCoding(LOAD_MOVETYPE); 
				else
					aReq := tmpGCDefn.hasColourCoding(DISCHARGE_MOVETYPE); 
				endif;
				if aReq &lt;&gt; null then 
					isLoad := aReq.isLoad;
				endif;
			endif;
		endif;
		

		//self.myPointDrawingFrame.doAddToArraysForProxy(obj.CM_RORORequestLayout);
		self.myPointDrawingFrame.doPointArrayAdd(Black,true, Frame.DrawFillStyle_Solid, 1, Grey, obj.CM_RORORequest.myLayout);
		if tmpLocnDefn &lt;&gt; null then
			allLocnDefn.add(tmpLocnDefn);
		endif;
		if tmpGCDefn &lt;&gt; null then
			allGCDefn.add(tmpGCDefn);
		endif;
	endforeach;
	
	self.getAllPolygonsColourCoding(self.myPointDrawingFrame,null,isLoad, White);	 // PAR 29055 added isLoad
epilog
	//cnwmc5 - par 29977
	delete allLocnDefn;
	delete allGCDefn;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawSortReqs" id="75192959-c11e-45df-9b0c-19e75e46aa85">
        <source>drawSortReqs(_slotsInOrder : ObjectArray input; _locnDefn : CM_ROROLocnDefnVoyage; _has40s : Boolean; _isLoad : Boolean; _horiz : Boolean);
/*
Purpose:			
Date		Who		Reason
31 January 2012	cnwab1	Initial creation
*/
//18 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
vars
	req : CM_RORORequest;
	slotsToDraw : CM_ROROSlotDefnByOrdinalDict;
	aftLocnDefn : CM_ROROLocnDefnVoyage;
	slotDefn : CM_ROROSlotDefn;
	aTI : CM_TrackedItem;
	tis : CM_TIArray;
	is40 : Boolean;
begin
		create slotsToDraw transient;
	_locnDefn.allROROSlotDefnByOrdinal.copyNoDuplicates(slotsToDraw,false); // PAR 28746 if had 40s was not drawing a small rectangle for any 20s in the aft slot.
	if _has40s then
		aftLocnDefn := _locnDefn.myAdjacentSlotAft.CM_ROROLocnDefnVoyage;
		if aftLocnDefn &lt;&gt; null then
			aftLocnDefn.allROROSlotDefnByOrdinal.copyNoDuplicates(slotsToDraw,false); // PAR 28746
		else // PAR 29050
			create tis transient;
			_locnDefn.getAllTIsRoB(tis, true, false);	//15 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
			foreach aTI in tis discreteLock do
				if  (aTI.isForty() or aTI.is30 or aTI.is45 or aTI.is53) then // PAR 30022
//				if aTI.isForty() then
					if not aTI.myPrimaryActualLocation.CM_ROROSlotController.mySlotDefn.myROROLocnDen = _locnDefn then
						aftLocnDefn := _locnDefn.myAdjacentSlotFwd.CM_ROROLocnDefnVoyage;
						if aftLocnDefn &lt;&gt; null then
							aftLocnDefn.allROROSlotDefnByOrdinal.copyNoDuplicates(slotsToDraw,false); 
						endif;
					endif;
				endif;
			endforeach;
		endif;
	endif;
	
	// PAR 28900 sort 20s first then 40s in reverse
	
	// PAR 28900 sort 20s first then 40s in reverse
	// PAR 28986 FWD 20s FIRST and removed 'reverse'
	foreach slotDefn in slotsToDraw discreteLock  do
			if _isLoad then
				req := slotDefn.CM_ROROSlotDefnVoyage.mySlotController.myRORORequestLoad;
			else
				req := slotDefn.CM_ROROSlotDefnVoyage.mySlotController.myRORORequestDischarge;
			endif;
			if req &lt;&gt; null then
		//		is40 := (req.getAttrIs40() or req.getAttrIs30() or req.getAttrIs45() or req.getAttrIs53()); // PAR 30022 
				is40 := req.getAttrIsNOT20(); // PAR 30253
				if is40 then // PAR 30022 
//				if req.getAttrIs40() then
					continue;
				endif;
			else // PAR 29050
				if not slotDefn.CM_ROROSlotDefnVoyage.mySlotController.hasROB(false) then
					continue;
				endif;
				// no request but has Remain on Board
				aTI := slotDefn.CM_ROROSlotDefnVoyage.mySlotController.allTrackedItems.first();
//				if aTI.isForty() then
				if  (aTI.isForty() or aTI.is30 or aTI.is45 or aTI.is53) then // PAR 30022
					continue;
				endif;
			endif;
			
			// Only 20s left
			
			if _horiz then
				// Get rid of the fwd 20s
				if slotDefn.myROROLocnDen = _locnDefn then
					continue;
				endif;
			else
				// Get rid of the aft 20s
				if slotDefn.myROROLocnDen = aftLocnDefn then
					continue;
				endif;
			endif;
			_slotsInOrder.add(slotDefn);
	endforeach;
	// PAR 28986  AFT 20s SECOND
	foreach slotDefn in slotsToDraw discreteLock  do
	
			// Get rid of the 40s
			if _isLoad then
				req := slotDefn.CM_ROROSlotDefnVoyage.mySlotController.myRORORequestLoad;
			else
				req := slotDefn.CM_ROROSlotDefnVoyage.mySlotController.myRORORequestDischarge;
			endif;
			if req &lt;&gt; null then
	//			is40 := (req.getAttrIs40() or req.getAttrIs30() or req.getAttrIs45() or req.getAttrIs53()); // PAR 30022 
				is40 := req.getAttrIsNOT20(); // PAR 30253
				if is40 then // PAR 30022 
				//if req.getAttrIs40() then
					continue;
				endif;
			else // PAR 29050
				if not slotDefn.CM_ROROSlotDefnVoyage.mySlotController.hasROB(false) then
					continue;
				endif;
				// no request but has Remain on Board
				aTI := slotDefn.CM_ROROSlotDefnVoyage.mySlotController.allTrackedItems.first();
				if  (aTI.isForty() or aTI.is30 or aTI.is45 or aTI.is53) then // PAR 30022
			//	if aTI.isForty() then
					continue;
				endif;
			endif;
			
			// Only 20s left
			
			if _horiz then
				// Get rid of the aft 20s
				if slotDefn.myROROLocnDen = aftLocnDefn then
					continue;
				endif;
			else
				// Get rid of the forward 20s
				if slotDefn.myROROLocnDen = _locnDefn then
					continue;
				endif;
			endif;
			_slotsInOrder.add(slotDefn);
	endforeach;
	
	// PAR 28900 sort 20s first then 40s in reverse
	foreach slotDefn in slotsToDraw discreteLock  do
			if _isLoad then
				req := slotDefn.CM_ROROSlotDefnVoyage.mySlotController.myRORORequestLoad;
			else
				req := slotDefn.CM_ROROSlotDefnVoyage.mySlotController.myRORORequestDischarge;
			endif;
			
			if req &lt;&gt; null then
				if req.isBackEndRequest() then 
					continue;
				endif;
//				is40 := (req.getAttrIs40() or req.getAttrIs30() or req.getAttrIs45() or req.getAttrIs53()); // PAR 30022 
				is40 := req.getAttrIsNOT20(); // PAR 30253
				if is40 then // PAR 30022 
//				if req.getAttrIs40() then
					_slotsInOrder.add(slotDefn);
				endif;
			else // PAR 29050
				if not slotDefn.CM_ROROSlotDefnVoyage.mySlotController.hasROB(false) then
					continue;
				endif;
				// no request but has Remain on Board
				aTI := slotDefn.CM_ROROSlotDefnVoyage.mySlotController.allTrackedItems.first();
				if  (aTI.isForty() or aTI.is30 or aTI.is45 or aTI.is53) then // PAR 30022
//				if aTI.isForty() then
					_slotsInOrder.add(slotDefn);
				endif;
			endif;
	endforeach;
epilog
	delete slotsToDraw;
	delete tis;
end;</source>
        <Parameter name="_slotsInOrder" type="ObjectArray" usage="input"/>
        <Parameter name="_locnDefn" type="CM_ROROLocnDefnVoyage"/>
        <Parameter name="_has40s" type="Boolean"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_horiz" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawSortTIs" id="92b03c64-45fd-4442-abf1-7d834fa2b89b">
        <source>drawSortTIs(_allTIs : ObjectArray input; _has40s : Boolean; _horiz : Boolean);
/*
Purpose:		if the location has 20s and 40s we need to sort them so that we have 20s aft then 20s fwd then all 40s	
Date		Who		Reason
30 January 2012	cnwab1	Initial creation
*/

vars
	obj : Object;
	tmpTI : CM_TrackedItem;
	locnInOrder : ObjectArray;
	slotsInOrder : ObjectArray;
	theSlot : CM_ROROSlotController;
	theLCs : CM_LCArray;
begin


	if not _has40s then
		return; // no need to sort, we only have 20s
	endif;

	create locnInOrder transient;
	create slotsInOrder transient;
	
	// Get the forty so that we can get the 2 locations and use those to sort the 20s
	foreach obj in _allTIs  discreteLock do
		tmpTI := obj.CM_TrackedItem;
	
		if tmpTI.isTwenty() then
			continue;
		endif;
		
//		theLCs.clear();
		if self.modeView = ShpDisplayMode_Actual then
			theLCs := tmpTI.getLocationsArray(REAL_MODE, 0);
		elseif self.modeView = ShpDisplayMode_Proposed then
			theLCs := tmpTI.getLocationsArray(PLANNING_MODE, 1);
		endif;
		if theLCs = null then
			return;
		endif;
		
		// We only sort TIs in a stack
		if  theLCs.isEmpty() then
			return;
		endif;
		if  theLCs.size &lt; 2 then
			return;
		endif;
		
		if not theLCs[1].isROROVoyageSlot() then
			return;
		endif;
		
		theSlot := theLCs[1].CM_ROROSlotController;
		locnInOrder.add(theSlot.mySlotDefn.myROROLocnDen);
		theSlot := theLCs[2].CM_ROROSlotController;
		locnInOrder.add(theSlot.mySlotDefn.myROROLocnDen);
		break;
	endforeach;

	// if horizontal we draw left to right. We draw the aft 20s then the fwd 20s then the 40s
	// if vertical we draw bottom to top (the opposite). We draw the fwd 20s then the aft 20s then the 40s
	foreach obj in _allTIs  discreteLock do
		tmpTI := obj.CM_TrackedItem;
	
		if not tmpTI.isTwenty() then
			continue;
		endif;
		
		if self.modeView = ShpDisplayMode_Actual then
			theLCs := tmpTI.getLocationsArray(REAL_MODE, 0);
		elseif self.modeView = ShpDisplayMode_Proposed then
			theLCs := tmpTI.getLocationsArray(PLANNING_MODE, 1);
		endif;
		if theLCs = null then
			continue;
		endif;
		theSlot := theLCs[1].CM_ROROSlotController;
		
		if _horiz then
			if theSlot.mySlotDefn.myROROLocnDen &lt;&gt; locnInOrder[2] then // do not want fwd 20s
				continue;
			endif;
		else
			if theSlot.mySlotDefn.myROROLocnDen &lt;&gt; locnInOrder[1] then // do not want aft 20s
				continue;
			endif;
		endif;
		
		slotsInOrder.add(tmpTI);
	endforeach;
	

	foreach obj in _allTIs  discreteLock do
		tmpTI := obj.CM_TrackedItem;
	
		if not tmpTI.isTwenty() then
			continue;
		endif;
		
		if self.modeView = ShpDisplayMode_Actual then
			theLCs := tmpTI.getLocationsArray(REAL_MODE, 0);
		elseif self.modeView = ShpDisplayMode_Proposed then
			theLCs := tmpTI.getLocationsArray(PLANNING_MODE, 1);
		endif;
		if theLCs = null then
			continue;
		endif;
		theSlot := theLCs[1].CM_ROROSlotController;
		
		if _horiz then
			if theSlot.mySlotDefn.myROROLocnDen &lt;&gt; locnInOrder[1] then // do not want aft 20s
				continue;
			endif;
		else
			if theSlot.mySlotDefn.myROROLocnDen &lt;&gt; locnInOrder[2] then // do not want fwd 20s
				continue;
			endif;
		endif;
		
		slotsInOrder.add(tmpTI);
	endforeach;
	
	// ALL 40s NEXT 
	foreach obj in _allTIs  discreteLock do
		tmpTI := obj.CM_TrackedItem;
	
		// PAR 30022 if not tmpTI.isForty() then
		if tmpTI.isTwenty() then
			continue;
		endif;
		
		slotsInOrder.add(tmpTI);
	endforeach;
		
	if _allTIs.size &lt;&gt; slotsInOrder.size then
		return;
	endif;
	
	_allTIs.clear();
	slotsInOrder.copy(_allTIs);
epilog
	delete locnInOrder;
	delete slotsInOrder;
end;</source>
        <Parameter name="_allTIs" type="ObjectArray" usage="input"/>
        <Parameter name="_has40s" type="Boolean"/>
        <Parameter name="_horiz" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawTIDetailsInPolygon" id="8b39c7e5-0f1b-4e00-830d-cc7449b63683">
        <updating/>
        <source>drawTIDetailsInPolygon(_deckItemLayout : CM_DeckItemLayout; _tis : ObjectArray; _numTier : Integer) updating;
/*
Purpose:			
Date		Who		Reason
10 June 2011	cnwab1	Initial creation
11/03/2015		cnwmh5	Transient Leaks
*/

vars
	//cnwmc5
	xx1,yy1,xx2,yy2 : Real;
	
	x1, y1, x2, y2, idx, size, idxSt, idxEnd, textX, textY, theColour, textWidth, polyWidth, polyHeight : Integer;
	xs1, ys1, xs2, ys2 : Real; // to scale
	aPoint : Point;
	aTI : CM_TrackedItem;
	aColour : Integer;
	obj : Object;
	types : StringArray;
	nums : IntegerArray;
	type, text : String;
	myDrawingFrame : CMUI_PointDrawingFrame;
begin
	myDrawingFrame := self.myPointDrawingFrame;
	myDrawingFrame.drawTextRotation := 0;
	myDrawingFrame.drawTextCharRotation := 0;

	if _tis = null then
		return;
	endif;

	create types transient;
	create nums transient;
	nums[10] := 0;
	
	// Draw the TI Rectangles in side the polygon in the top left corner
	// Work out the top Y and draw to the lowest of the first 2 Ys
	
	aPoint := _deckItemLayout.getExtremePoint(CM_Graphic.Position_Left);
	x1 := aPoint.x;
	aPoint := _deckItemLayout.getExtremePoint(CM_Graphic.Position_Top);
	y1 := aPoint.y;

	xs1 := x1 * self.scaleFactor;
	ys1 := y1 * self.scaleFactor;
	xs2 := x2 * self.scaleFactor;
	ys2 := y2 * self.scaleFactor;
	textX := x1;
	textY := y1;
	
	//cnwmc5 - 16/01/2013
	aColour := NullColour;
	
	foreach obj in _tis discreteLock do
		aTI := obj.CM_TrackedItem;
		//cnwmc5 - 16/01/2013
		if aColour = NullColour then
			aColour := aTI.getDrawingColour(TI_ColourMode_DischargePort);
		endif;
		type := aTI.getPlannerReportDischGroupDesc();
		idx := types.indexOf(type);
		if idx = 0 then
			types.add(type);
			size := types.size;
			nums[size] := nums[size] + aTI.totalQuantity.max(1); //epr CCMS 2274 21/5/13
		else
			nums[idx] := nums[idx] + aTI.totalQuantity.max(1); //epr CCMS 2274 21/5/13
		endif;
	endforeach;

	idxSt := 1;
	//cnwmc5 - 16/01/2013 - PAR #30975
	if _deckItemLayout.myDeckItem.isLocnContainer() then
		idxEnd := types.size.min(2);
	else
		idxEnd := types.size;
	endif;
	
	//cnwmc5
	_deckItemLayout.myPolygonPixels.getExtremesForText(xx1,yy1,xx2,yy2);
	
	foreach idx in idxSt to idxEnd do
		aTI := _tis[1].CM_TrackedItem;
		if self.scaleFactor &lt; 0.5 then
			text := aTI.getShortDPortCode();

		else
			text := nums[idx].String &amp; "x" &amp; types[idx];
		endif;
		
		if self.scaleFactor &lt; 0.5 then
			textX := (textX* self.scaleFactor).Integer + 1;
			textY := (textY* self.scaleFactor).Integer;
			myDrawingFrame.drawFontSize := 6;
		else
			textX := (textX* self.scaleFactor).Integer + 3;
			textY := (textY* self.scaleFactor).Integer + 3;
			if self.scaleFactor &lt; 1.0 then
				myDrawingFrame.drawFontSize := 6;
			elseif self.scaleFactor &lt; 1.2 then
				myDrawingFrame.drawFontSize := 7;
			elseif self.scaleFactor &lt; 1.4 then
				myDrawingFrame.drawFontSize := 8;
			elseif self.scaleFactor &lt; 1.6 then
				myDrawingFrame.drawFontSize := 10;
			endif;
		endif;
		
		if myDrawingFrame.drawFillStyle = Frame.DrawFillStyle_Transparent then
			theColour := Black;
		elseif  myDrawingFrame.drawFillStyle =Frame.DrawFillStyle_Solid then
			theColour := myDrawingFrame.drawFillColor.getInverseColour();
		else
			theColour := Black;
		endif;
		myDrawingFrame.drawTextRotation := 0;
		myDrawingFrame.drawTextCharRotation := 0;
		
		textWidth := myDrawingFrame.getTextExtent(text)  - 10;
		polyWidth := x2-x1;
		polyHeight :=  y2-y1;
		
		//cnwmc5 - PAR 31375 - added in to multiply by scale factor
		myDrawingFrame.drawTextAt(text, xx1 * self.scaleFactor, yy1 * self.scaleFactor, aColour.getInverseColour());
		yy1 := yy1 + 10;
		
		//myDrawingFrame.drawTextAt(text,textX, textY, aColour.getInverseColour());		
		//textY := textY + 6;
	endforeach;
epilog
		myDrawingFrame.drawTextRotation := 0;
		myDrawingFrame.drawTextCharRotation := 0;
		
		delete types;
		delete nums;

end;</source>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
        <Parameter name="_tis" type="ObjectArray"/>
        <Parameter name="_numTier" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawTIDetailsInRectangle" id="39c6ddbb-d0e4-48b3-854c-aaf7daf087de">
        <updating/>
        <source>drawTIDetailsInRectangle(_deckItemLayout : CM_DeckItemLayout; _rect : PointArray; _tis : ObjectArray; _numTier : Integer; _tmpPoints : PointArray) updating;
/*
Purpose:			
Date		Who		Reason
10 June 2011	cnwab1	Initial creation
*/

vars
	x1, y1, x2, y2, idx, size,idxSt, idxEnd, textX, textY, theColour, textWidth, polyWidth, polyHeight, yOffset : Integer;
	xs1, ys1, xs2, ys2 : Real; // to scale
	xd1, yd1 : Real; // for drawing

	aTI : CM_TrackedItem;
	aColour : Integer;
	obj : Object;
	
	types : StringArray;
	nums : IntegerArray;
	type, text : String;
	myDrawingFrame : CMUI_PointDrawingFrame;
	
	//cnwmc5 - par 29952
	overThree : Boolean;
	count : Integer;
begin
	count := 0;
	myDrawingFrame := self.myPointDrawingFrame;
	myDrawingFrame.drawTextRotation := 0;
	myDrawingFrame.drawTextCharRotation := 0;

	if _tis = null then
		return;
	endif;
	create types transient;
	create nums transient;
	
	nums[10] := 0;
	
	x1 := 9999999;
	y1 := 9999999;
	_deckItemLayout.getExtremePoints(x1, y1, x2, y2);
	
	
	xs1 := x1 * self.scaleFactor;
	ys1 := y1 * self.scaleFactor;
	xs2 := x2 * self.scaleFactor;
	ys2 := y2 * self.scaleFactor;
	
	
	
	foreach obj in _tis discreteLock do
		aTI := obj.CM_TrackedItem;
		aColour := aTI.getDrawingColour(TI_ColourMode_DischargePort);
		if self.scaleFactor &gt;= 1.5 then
			type := aTI.id;
		else
			type := aTI.getPlannerReportDischGroupDesc();
		endif;
		idx := types.indexOf(type);
		if idx = 0 then
			types.add(type);
			size := types.size;
			nums[size] := nums[size] + 1;
		else
			nums[idx] := nums[idx] + 1;
		endif;
	endforeach;

	myDrawingFrame.getExtremePoints(CM_Graphic.Position_Left, CM_Graphic.Position_Top, _rect, textX, textY);
	idxSt := 1;
	if self.scaleFactor &gt;= 1.5 then
		//cnwmc5 - par 29952 - added if statement
		if types.size &gt; 3 then
			overThree := true;
		endif;
		idxEnd := types.size.min(3);
	else
		idxEnd := types.size.min(2);
	endif;
	textX := (textX* self.scaleFactor).Integer + 3;
	textY := (textY* self.scaleFactor).Integer + 1;	
	
	

	
	foreach idx in idxSt to idxEnd do
		aTI := _tis[1].CM_TrackedItem;
		
		if self.modeView = ShpDisplayMode_ColCodeDisch and self.modeViewSubSub = ShpDisplayModeSub_ExportsHide then // PAR 31073 
			//if aTI.isExport or aTI.isRehandle or aTI.isSOB   or aTI.isTranshipExport() then // PAR 31605
			if aTI.hasBeenLoadedToShip() then		//cnwmc5 - 11 March 2014 - PAR 33283
				continue;
			endif;
		endif;
		
		if self.scaleFactor &lt; 0.5 then
			text := aTI.getShortDPortCode();

		elseif self.scaleFactor &gt;= 1.5 then
			//cnwmc5 - par 29952 - added if statement
			if idx = idxEnd and overThree = true then
				text := types[idx].String &amp; "...";
			else
				text := types[idx];
			endif;
		else
			text := nums[idx].String &amp; "x" &amp; types[idx];
		endif;
		yOffset := 10;
		if self.scaleFactor &lt; 0.5 then
			myDrawingFrame.drawFontSize := 6;
		else
			if self.scaleFactor &lt; 0.9 then
				myDrawingFrame.drawFontSize := 6;
			elseif self.scaleFactor &lt; 1.2 then
				myDrawingFrame.drawFontSize := 8;
			elseif self.scaleFactor &lt; 1.4 then
				myDrawingFrame.drawFontSize := 10;
				yOffset := 12;
			elseif self.scaleFactor =1.4 then
				myDrawingFrame.drawFontSize := 12;
				yOffset := 14;
			else
				myDrawingFrame.drawFontSize := 8;
				yOffset := 14;
			endif;
		endif;
		yOffset := myDrawingFrame.drawFontSize.Integer + 2;
		
		if myDrawingFrame.drawFillStyle = Frame.DrawFillStyle_Transparent then
			aColour := Black;
		elseif  myDrawingFrame.drawFillStyle =Frame.DrawFillStyle_Solid then
			aColour := myDrawingFrame.drawFillColor; //.getInverseColour();
		else
			aColour := Black;
		endif;
		myDrawingFrame.drawTextRotation := 0;
		myDrawingFrame.drawTextCharRotation := 0;
		
		textWidth := myDrawingFrame.getTextExtent(text)  - 10;
		polyWidth := x2-x1;
		polyHeight :=  y2-y1;
		
		// VERTICAL
		if textWidth &gt; polyWidth and polyHeight &gt; polyWidth then
				myDrawingFrame.drawTextRotation := 270;
				myDrawingFrame.drawTextCharRotation := 270;
				textX := textX + yOffset;
				myDrawingFrame.drawTextAt(text,textX, textY, aColour.getInverseColour());		
		// HORIZONTAL
		else
			//cnwmc5 - par 29952 - original code before reversing stack order.
			//myDrawingFrame.drawTextAt(text,textX, textY, aColour.getInverseColour());		
			//textY := textY + yOffset;
			
			//cnwmc5 - par 29952 - reversing order of stack.
			if self.scaleFactor &gt;= 1.5 then
				myDrawingFrame.drawTextAt(text,textX, (textY + 20), aColour.getInverseColour());
				textY := textY - yOffset;
			else
		
				myDrawingFrame.drawTextAt(text,textX, textY, aColour.getInverseColour());
				textY := textY + yOffset;
			endif;
		endif;

	endforeach;
	
epilog
		myDrawingFrame.drawTextRotation := 0;
		myDrawingFrame.drawTextCharRotation := 0;

	delete types;
	delete nums;
end;</source>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
        <Parameter name="_rect" type="PointArray"/>
        <Parameter name="_tis" type="ObjectArray"/>
        <Parameter name="_numTier" type="Integer"/>
        <Parameter name="_tmpPoints" type="PointArray"/>
    </JadeMethod>
    <JadeMethod name="drawTIsInPolygon" id="c3d77e99-e43a-4f47-bd94-2bbf78bf2bc4">
        <updating/>
        <source>drawTIsInPolygon(_deckItemLayout : CM_DeckItemLayout; _tis : ObjectArray; _numTier : Integer) updating;
/*
Purpose:			
Date		Who		Reason
10 June 2011	cnwab1	Initial creation
*/

vars
	x1, y1, x2, y2 : Integer;
	xs1, ys1, xs2, ys2 : Real; // to scale
	xd1, yd1 : Real; // for drawing
	len, hite : Real;
	aPoint : Point;
	aTI : CM_TrackedItem;
	aColour : Integer;
	obj : Object;
	myDrawingFrame : CMUI_PointDrawingFrame;
begin
	myDrawingFrame := self.myPointDrawingFrame;
	myDrawingFrame.drawTextRotation := 0;
	myDrawingFrame.drawTextCharRotation := 0;

	if _tis = null then
		return;
	endif;
	
	// Draw the TI Rectangles in side the polygon in the top left corner
	// Work out the top Y and draw to the lowest of the first 2 Ys
	aPoint := _deckItemLayout.myPolygonPixels[1];
	x1 := aPoint.x;
	y1 := aPoint.y;
	aPoint := _deckItemLayout.myPolygonPixels[2];
	x2 := aPoint.x;
	y2 := aPoint.y;
	
	_deckItemLayout.myPolygonPixels.getExtremesForText(x1,y1,x2,y2);
	
	if y2 &gt; y1 then
		y1 := y2;
	endif;
//	aPoint := _deckItemLayout.myPolygonPixels[_deckItemLayout.myPolygonPixels.size - 1];
//	x2 := aPoint.x;
//	y2 := aPoint.y;
//	if x2 &gt; x1 then
//		x1 := x2;
//	endif;
	
	xs1 := x1 * self.scaleFactor;
	ys1 := y1 * self.scaleFactor;
	xs2 := x2 * self.scaleFactor;
	ys2 := y2 * self.scaleFactor;
	
	if self.scaleFactor &lt; 0.5 then
		aTI := _tis[1].CM_TrackedItem;
		
		if aTI &lt;&gt; null then
			aColour := aTI.getDrawingColour(TI_ColourMode_DischargePort);
			
			xs1 := xs1 + 1;
			ys1 := ys1 + 1;
			xs2 := xs2 - 1;
			ys2 := ys2 - 1;
			myDrawingFrame.drawFillColor := aColour;
			myDrawingFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
			myDrawingFrame.drawFilledRectangle(xs1, ys1, xs1 + 10, ys1 + 10,aColour);
		endif;
	else
			
			
			if _deckItemLayout.myDeckItem &lt;&gt; null and _deckItemLayout.myDeckItem.isLocnLane() then
				xd1 := xs2 - 2;
			else
				xd1 := xs1 + 2;
			endif;
			if _tis.size = 0 then
				return;
			endif;
			len := (((xs2 - xs1) / _tis.size ) - 3);
			foreach obj in _tis discreteLock do
				aTI := obj.CM_TrackedItem;
//				len := _deckItemLayout.getItemLength(aTI);
//				len := (len * ROROStructurePixelsPerMetre);
				
				aColour := aTI.getDrawingColour(TI_ColourMode_DischargePort);
				myDrawingFrame.drawFillColor := aColour;
				myDrawingFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
				
				// Draw Right to Left for Lanes
				if _deckItemLayout.myDeckItem &lt;&gt; null and _deckItemLayout.myDeckItem.isLocnLane() then
					myDrawingFrame.drawFilledRectangle(xd1, ys1 + 5, xd1 - len, ys1 + 25,White);
					xd1 := xd1 - len - 2;
				else
					myDrawingFrame.drawFilledRectangle(xd1, ys1 + 5, xd1 + len, ys1 + 25,White);
					xd1 := xd1 + len + 2;
				endif;
				
			endforeach;

	endif;

epilog

end;</source>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
        <Parameter name="_tis" type="ObjectArray"/>
        <Parameter name="_numTier" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawTIsInRectangle" id="1b9e3fb3-ee25-4137-8f27-b0e4d44d0552">
        <updating/>
        <source>drawTIsInRectangle(_deckItemLayout : CM_DeckItemLayout; _tis : ObjectArray; _numTier : Integer; _tmpPoints : PointArray; _has40s : Boolean) updating;
/*
Purpose:			
Date		Who		Reason
10 June 2011	cnwab1	Initial creation
26 Feb 2014  epr par 33066 for printing the scale is calculated to fit page, drawing Req was not considering the scale
*/

vars
	x1, y1, x2, y2, numTier : Integer;
	xs1, ys1, xs2, ys2 : Real; // to scale
	xd1, yd1 : Real; // for drawing
	len, hite,tiLen : Real;
	aTI : CM_TrackedItem;
	aColour : Integer;
	obj : Object;
	myDrawingFrame : CMUI_PointDrawingFrame;
	lastSlot : CM_ROROSlotController;
	scale : Real;
begin
	myDrawingFrame := self.myPointDrawingFrame;
	myDrawingFrame.drawTextRotation := 0;
	myDrawingFrame.drawTextCharRotation := 0;
	scale:=self.scaleFactor;

	if _tis = null then
		return;
	endif;
	
	x1 := 9999999;
	y1 := 9999999;
//	_deckItemLayout.getExtremePoints(x1, y1, x2, y2);
	x1 := _tmpPoints[1].x;
	y1 := _tmpPoints[1].y;
	x2 := _tmpPoints[3].x;
	y2 := _tmpPoints[3].y;
	
	xs1 := x1 * self.scaleFactor;
	ys1 := y1 * self.scaleFactor;
	xs2 := x2 * self.scaleFactor;
	ys2 := y2 * self.scaleFactor;
	
	//epr par 33066 draw all the tis not just one if scale small
	
	len := xs2-xs1;
	hite := ys2-ys1;
	numTier := _numTier;
	if _has40s then
		numTier := numTier * 2;
	endif;
	
	// HORIZONTAL
	if len &gt; hite then
		len := len - (_tis.size*2);
		len := (len / numTier);
		
		xd1 := xs1 + (2* scale);
		
		foreach obj in _tis discreteLock do
			aTI := obj.CM_TrackedItem;
			
			if self.modeView = ShpDisplayMode_ColCodeLoad then // PAR 29050 
				if aTI.isToBeDischargedHere()  then // PAR 31118
					if aTI.getVoyageWLEUnactioned(false) &lt;&gt; null then
						continue;
					endif;	
				endif;
				if (aTI.isRehandle or aTI.isSOB) then // PAR 29373 
			// PAR 31073 - removed this as we do not need to draw actual DLR TIs if we are then going to draw LOAD DLR CC over the top.
// PAR  31073						if aTI.getVoyageWLEUnactioned(false) &lt;&gt; null then
						continue;
//						endif;
				endif;
			else
				if self.modeView = ShpDisplayMode_ColCodeDisch and self.modeViewSubSub = ShpDisplayModeSub_ExportsHide then // PAR 31073 
					//if aTI.isExport or aTI.isRehandle or aTI.isSOB    or aTI.isTranshipExport() then // PAR 31605
					if aTI.hasBeenLoadedToShip() then		//cnwmc5 - 11 March 2014 - PAR 33283
						continue;
					endif;
				endif;

				// PAR 30245
				if lastSlot &lt;&gt; null and aTI.myPrimaryActualLocation = lastSlot then
					myDrawingFrame.drawWidth := 1;
					myDrawingFrame.drawFillColor := Red;
					myDrawingFrame.drawFilledRectangle(xd1 - tiLen, ys2 - (2* scale), xd1 - tiLen + (6* scale), ys2 - (8* scale), White);
					continue;
				endif;
			endif;

			// PAR 30245

			// PAR 30342
			if aTI.myPrimaryActualLocation.isKindOf(CM_ROROSlotController) then
				lastSlot := aTI.myPrimaryActualLocation.CM_ROROSlotController;
			elseif aTI.myPrimaryPlannedLocation.isKindOf(CM_ROROSlotController) then
				lastSlot := aTI.myPrimaryPlannedLocation.CM_ROROSlotController;
			endif;
			
			if not aTI.isTwenty() then
				tiLen := (len * 2);
			else
				tiLen := (len);
			endif;
//	29050			if self.modeView = ShpDisplayMode_Actual or self.modeView = ShpDisplayMode_Proposed  or self.modeView = ShpDisplayMode_ColCodeDisch  or self.modeView = ShpDisplayMode_ColCodeLoad then // PAR 29049
				aColour := aTI.getDrawingColour(TI_ColourMode_DischargePort);
				
				myDrawingFrame.drawWidth := 1;
				myDrawingFrame.drawFillColor := aColour;
				myDrawingFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
				if self.modeView = ShpDisplayMode_ColCodeDisch or self.modeView = ShpDisplayMode_ColCodeLoad then // PAR 29050
					myDrawingFrame.drawFilledRectangle(xd1, ys1 + (7* scale), xd1 + tiLen, ys2 - (7* scale),aColour);
				else
					myDrawingFrame.drawFilledRectangle(xd1, ys1 + (2* scale), xd1 + tiLen, ys2 -(1* scale),aColour);
				endif;
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. ' &amp; _deckItemLayout.code &amp; " " &amp; aTI.id &amp; " " &amp; aTI.getISOType);				
//				endif;
			if self.modeView &lt;&gt; ShpDisplayMode_ColCodeDisch and self.modeView &lt;&gt; ShpDisplayMode_ColCodeLoad then // PAR 29050
				self.drawIcons(aTI, null,myDrawingFrame, xd1, ys1 + (3* scale), aColour.getInverseColour(), true);
			endif;

			// PAR 31605 DRAW YELLOW MARK FOR TRANS SHIP
			if aTI.isTranshipItem  then
				myDrawingFrame.drawFillColor := Yellow;
				if self.modeView = ShpDisplayMode_ColCodeDisch  or self.modeView = ShpDisplayMode_ColCodeLoad then
					myDrawingFrame.drawFilledRectangle(xd1 + (8* scale), ys2 - (9* scale), xd1 + (13* scale), ys2 - (14* scale), Yellow);
				else
					myDrawingFrame.drawFilledRectangle(xd1 + (8* scale), ys2 - (2* scale), xd1 + (13* scale), ys2 - (7* scale), Yellow);
				endif;
			endif;

			xd1 := xd1 + tiLen + (2* scale);
		endforeach;
		
	// VERTICAL
	else
		hite := (hite / numTier);
		hite := hite - (2* scale);
		
//	PAR 28991		yd1 := ys1 + 2;
		yd1 := ys2 - (2* scale);
		
		foreach obj in _tis  discreteLock do
			aTI := obj.CM_TrackedItem;
			if self.modeView = ShpDisplayMode_ColCodeLoad then // PAR 29050 
				if aTI.isToBeDischargedHere()  then // PAR 31118
					if aTI.getVoyageWLEUnactioned(false) &lt;&gt; null then
						continue;
					endif;	
				endif;
				if (aTI.isRehandle or aTI.isSOB) then // PAR 29373 
			// PAR 31073 - removed this as we do not need to draw actual DLR TIs if we are then going to draw LOAD DLR CC over the top.
// PAR  31073						if aTI.getVoyageWLEUnactioned(false) &lt;&gt; null then
						continue;
//						endif;
				endif;
			else
				if self.modeView = ShpDisplayMode_ColCodeDisch and self.modeViewSubSub = ShpDisplayModeSub_ExportsHide then // PAR 31073 
					//if aTI.isExport or aTI.isRehandle or aTI.isSOB    or aTI.isTranshipExport() then // PAR 31605
					if aTI.hasBeenLoadedToShip() then		//cnwmc5 - 11 March 2014 - PAR 33283
						continue;
					endif;
				endif;

				// PAR 30245
				if lastSlot &lt;&gt; null and aTI.myPrimaryActualLocation = lastSlot then
					myDrawingFrame.drawWidth := 1;
					myDrawingFrame.drawFillColor := Red;
					myDrawingFrame.drawFilledRectangle(xs2 - (3* scale), yd1 + tiLen, xs2-(9* scale), yd1 + tiLen - (6* scale), White);
					continue;
				endif;
			endif;
			
			// PAR 30342
			if aTI.myPrimaryActualLocation.isKindOf(CM_ROROSlotController) then
				lastSlot := aTI.myPrimaryActualLocation.CM_ROROSlotController;
			elseif aTI.myPrimaryPlannedLocation.isKindOf(CM_ROROSlotController) then
				lastSlot := aTI.myPrimaryPlannedLocation.CM_ROROSlotController;
			endif;

			if not aTI.isTwenty() then
				tiLen := (hite * 2);
			else
				tiLen := (hite);
			endif;
			
// PAR 29050				if self.modeView = ShpDisplayMode_Actual or self.modeView = ShpDisplayMode_Proposed  or self.modeView = ShpDisplayMode_ColCodeDisch then // PAR 29049
				aColour := aTI.getDrawingColour(TI_ColourMode_DischargePort);
				myDrawingFrame.drawWidth := 1;
				myDrawingFrame.drawFillColor := aColour;
				myDrawingFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
//	PAR 28991				myDrawingFrame.drawFilledRectangle(xs1 + 2, yd1, xs2-2,yd1 + tiLen,aColour);
				if self.modeView = ShpDisplayMode_ColCodeDisch or self.modeView = ShpDisplayMode_ColCodeLoad then // PAR 29050
					myDrawingFrame.drawFilledRectangle(xs1 + (7* scale), yd1, xs2- (7* scale),yd1 - tiLen,aColour);
				else
					myDrawingFrame.drawFilledRectangle(xs1 + (2* scale), yd1, xs2-(2* scale),yd1 - tiLen,aColour);
				endif;
//	PAR 28991				self.drawIcons(aTI, null, myDrawingFrame, xs1 + 3, yd1, aColour.getInverseColour(), false);
//				endif;
			if self.modeView &lt;&gt; ShpDisplayMode_ColCodeDisch and  self.modeView &lt;&gt; ShpDisplayMode_ColCodeLoad then // PAR 29050
				self.drawIcons(aTI, null, myDrawingFrame, xs1 + (3* scale), yd1 - tiLen, aColour.getInverseColour(), false);
			endif;

			// PAR 31605 DRAW YELLOW MARK FOR TRANS SHIP
			if aTI.isTranshipItem  then
				myDrawingFrame.drawFillColor := Yellow;
				if self.modeView = ShpDisplayMode_ColCodeDisch  or self.modeView = ShpDisplayMode_ColCodeLoad then
					myDrawingFrame.drawFilledRectangle(xs2 - (9* scale), yd1 -(2* scale), xs2-(15* scale), yd1 - (6* scale), Yellow);
				else
					myDrawingFrame.drawFilledRectangle(xs2 - (4* scale), yd1 -(2* scale), xs2-(10* scale), yd1 - (6* scale), Yellow);
				endif;
			endif;

			//	PAR 28991				yd1 := yd1 + tiLen + 1;
			yd1 := yd1 - tiLen - (2* scale);
		endforeach;
		
	endif;

	
epilog


end;</source>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
        <Parameter name="_tis" type="ObjectArray"/>
        <Parameter name="_numTier" type="Integer"/>
        <Parameter name="_tmpPoints" type="PointArray"/>
        <Parameter name="_has40s" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllPolygonsActual" id="0b0cd585-4ed6-4d33-9362-44d07d279372">
        <updating/>
        <source>getAllPolygonsActual(_frame : CMUI_PointDrawingFrame;_layer : CM_DeckLayerLayout;_colour : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	pointerX : Integer;
	theColour : Integer;
	objTI, theObject : Object;
	theText : String;
	doFloodFill, has40s : Boolean;
	deckItemLayout : CM_DeckItemLayout;
	aftLocn : CM_ROROLocnDefn;
	rArray : RealArray;
	scale : Decimal[12,2];
	aTI, ti40 : CM_TrackedItem;
	allTIs : CM_TIArray;
	numTier : Integer;
	tmpPoints : PointArray;
is40 : Boolean;
	myDrawingFrame : CMUI_PointDrawingFrame;
	roroReq : CM_ROROSlotRequest;
begin
	self.myPointDrawingFrame := _frame;
	myDrawingFrame := self.myPointDrawingFrame;


	
	create tmpPoints transient;
	myDrawingFrame.autoRedraw := true;
	scale := self.scaleFactor;
	if scale &lt;= 0 then
		scale := 1;
	endif;
		
	create allTIs transient;
	
	if _layer &lt;&gt; null then
		numTier := _layer.getNumTiers();
	endif;
	if numTier = 0 then
		numTier := 3;
	endif;
	
	myDrawingFrame.endBatchDrawing();
	myDrawingFrame.beginBatchDrawing();

//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1.scale: ' &amp; scale.String &amp; " self.form: " &amp; self.form.String);	
	create rArray transient;
	pointerX := 0;
	
	foreach theObject in myDrawingFrame.allPointGraphics do

		pointerX := pointerX + 1;

		if pointerX &gt; myDrawingFrame.allFloodFill.size then
			break;
		endif;
		if theObject = null then
			continue;
		endif;
		deckItemLayout := theObject.CM_DeckItemLayout;
		if deckItemLayout.pointsPolygon.size = 0 then
			continue;
		endif;
		
		if not deckItemLayout.isPillar() and deckItemLayout.getObjectIRepresent() = null then
			continue;
		endif;
		
		// ########################################
		// ########################################
		// #### HAVE WE GOT A 40 FOOTER ?
		// ########################################
		// ########################################
		allTIs.clear();
		has40s := false;		
		ti40 := null;
		aTI := null;
		if self.modeView = ShpDisplayMode_Defn then
		else
			if deckItemLayout.isKindOf(CM_RORORequestLayout) then
				if not deckItemLayout.CM_RORORequestLayout.myRequest.isReqSlot then // PAR 31166
					continue;
				endif;
				if deckItemLayout.CM_RORORequestLayout.myRequest.isBackEndRequest() then
					continue; // ignore back end
				endif;
	//			deckItemLayout.CM_RORORequestLayout.myRequest.getAllTrackedItems(allTIs);
	
				roroReq := deckItemLayout.CM_RORORequestLayout.myRequest.CM_ROROSlotRequest; // PAR 30022 
			//	is40 := (roroReq.getAttrIs40() or roroReq.getAttrIs30() or roroReq.getAttrIs45() or roroReq.getAttrIs53()); // PAR 30022 
				is40 := roroReq.getAttrIsNOT20(); // PAR 30253
				if is40 then // PAR 30022 
	
				//if deckItemLayout.CM_RORORequestLayout.myRequest.getAttrIs40() then
				if roroReq.mySlotRequestAft &lt;&gt; null then
					aftLocn := roroReq.mySlotRequestAft.myROROController.getDefn().CM_ROROLocnDefn;
					has40s := true;
					endif;
				endif;
			elseif deckItemLayout.myDeckItem&lt;&gt; null then
				deckItemLayout.myDeckItem.getAllTIs(REAL_MODE,allTIs, true);
	/*
	if process.isCnwab1() then
	f deckItemLayout.myDeckItem.code = "D4058" then
	process.debug;
	endif; endif; 
		*/		
				if not allTIs.isEmpty() then
					foreach objTI in allTIs do
						if objTI.CM_TrackedItem.isContainer() and  not objTI.CM_TrackedItem.isTwenty() then
							has40s := true;
							ti40 := objTI.CM_TrackedItem;
							break;
						endif;
					endforeach;
					if has40s then
						if deckItemLayout.myDeckItem.isKindOf(CM_ROROLocnDefnVoyage) and not deckItemLayout.myDeckItem.CM_ROROLocnDefnVoyage.allROROSlotDefnByOrdinal.includes(ti40.myPrimaryActualLocation.CM_ROROSlotController.mySlotDefn) then
							continue;
						endif;
	//					if deckItemLayout.isKindOf(CM_RORORequestLayout) then
	//						aftLocn := deckItemLayout.CM_RORORequestLayout.myRequest.CM_ROROSlotRequest.mySlotRequestAft.myROROController.getDefn().CM_ROROLocnDefn;
						if deckItemLayout.myDeckItem.isKindOf(CM_ROROLocnDefnVoyage) then
							aftLocn := deckItemLayout.myDeckItem.CM_ROROLocnDefnVoyage.getAftLocnDefn();
	//						if aftLocn &lt;&gt; null then
	//							aftLocn.getAllTIs(REAL_MODE,allTIs);
	//						endif;
						endif;
					endif;
				endif;
				
			endif;
		endif;
		
		// ########################################
		// ########################################
		// #### SET UP COLOURS AND LINE STYLES ETC
		// ########################################
		// ########################################
		
		// DO NOT Draw the Locns under our General Cargo poly
		// Only Defined Container Positions get covered. They only get covered by GC polys
		if self.modeView = ShpDisplayMode_Actual then
			// if covered by an actual GC Location
			if deckItemLayout.isCovered(DeckItemLayoutType_GCDischarge,true)   // PAR 27749
			or deckItemLayout.isCoveredByOnLayer(DeckItemLayoutType_GCLoad, ROROLayerType_GC, true) then // PAR 32374
//	 PAR 32374		or deckItemLayout.isCoveredByDefnWithCCCompleted(DeckItemLayoutType_GCLoad, true) then // PAR 29807
				if not deckItemLayout.isPillar() then
					continue;
				endif;
			endif;
				
			// PAR 28990
			// PAR 29807if  _deckItemLayout.isCovered(DeckItemLayoutType_Locn,true)  then // hide any cargo positions that are under the OOTL cargo
			// PAR 29807	if _deckItemLayout.isCoveredByOOTL(DeckItemLayoutType_Locn) then
				//	return false;
			// PAR 29807	endif;
			// PAR 29807endif;
			// PAR 29807
			
			// PAR 29807 NOW
			if deckItemLayout.isCoveredByDefnWithCCCompleted(DeckItemLayoutType_Locn, true) then
				if deckItemLayout.isCoveredByOOTL(DeckItemLayoutType_Locn) then
					continue;
				endif;
			endif;

				// PAR 29178
			if  deckItemLayout.isCovered(DeckItemLayoutType_Graphic,true)  then // hide any cargo positions that are under the Equipment or General AREA
				continue;
			endif;

		endif;
		
		doFloodFill := myDrawingFrame.allFloodFill[pointerX];
		
		
		// LINE COLOUR
		if myDrawingFrame.showColour then
			// we are not always run from a scrollable drawing frame
			if myDrawingFrame.mySDF &lt;&gt; null and ( _colour = myDrawingFrame.mySDF.backColor) then
				theColour := _colour;
			else
				theColour := myDrawingFrame.allLineColours[pointerX];
			endif;
		else
			theColour:=Black;
		endif;

		
		if pointerX &lt;= myDrawingFrame.allFillStyles.size then
			myDrawingFrame.drawFillStyle := myDrawingFrame.allFillStyles[pointerX];
			//epr par 27626 25/5/2011 if solid fill make it transparent
			if not myDrawingFrame.showColour and  myDrawingFrame.drawFillStyle =Frame.DrawFillStyle_Solid  then		
				myDrawingFrame.drawFillStyle :=  Frame.DrawFillStyle_Transparent;
			endif;

		else
			myDrawingFrame.drawFillStyle :=  Frame.DrawFillStyle_Transparent;
		endif;
		
		if pointerX &lt;= myDrawingFrame.allDrawWidths.size then
			myDrawingFrame.drawWidth := myDrawingFrame.allDrawWidths[pointerX];
		else
			myDrawingFrame.drawWidth :=  1;
		endif;
	
		// ### FILL COLOUR
		if myDrawingFrame.showColour then
			if pointerX &lt;= myDrawingFrame.allFillColours.size then
				myDrawingFrame.drawFillColor := myDrawingFrame.allFillColours[pointerX];
			else
				myDrawingFrame.drawFillColor :=  theColour;
			endif;
		else
			myDrawingFrame.drawFillColor := Black;
		endif;
		
		if pointerX &lt;= myDrawingFrame.allDrawWidths.size then
			myDrawingFrame.drawStyle := myDrawingFrame.allLineStyles[pointerX];
		else
			myDrawingFrame.drawStyle :=  Frame.DrawStyle_Solid;
		endif;
		if myDrawingFrame.showText  then
			theText := myDrawingFrame.allTexts[pointerX];
		else
			theText := null;
		endif;
	
		
		
		// ########################################
		// ########################################
		// #### IF WE HAVE A 40 THEN ADJUST XYs
		// ########################################
		// ########################################
		tmpPoints.clear();
		deckItemLayout.pointsPolygon.copy(tmpPoints);
		
//		if deckItemLayout.myDeckItem &lt;&gt; null and deckItemLayout.myDeckItem.isKindOf(CM_ROROLocnDefn) then
/*
		ti40 := null;
			if not allTIs.isEmpty() then
				foreach objTI in allTIs do
					if not objTI.CM_TrackedItem.isTwenty() then
						has40s := true;
						ti40 := objTI.CM_TrackedItem;
						break;
					endif;
				endforeach;
			else
				aTI := null;
			endif;
			*/
			//if aTI &lt;&gt; null and aTI.isForty() then
			if has40s then
				// ignore back end
//				if deckItemLayout.myDeckItem.isKindOf(CM_ROROLocnDefnVoyage) and not deckItemLayout.myDeckItem.CM_ROROLocnDefnVoyage.allROROSlotDefnByOrdinal.includes(ti40.myPrimaryActualLocation.CM_ROROSlotController.mySlotDefn) then
//					continue;
//				endif;
		//		aftLocn := deckItemLayout.myDeckItem.CM_ROROLocnDefnVoyage.getAftLocnDefn();
				if aftLocn &lt;&gt; null then
					if aftLocn.isVerticalOrientation() then
				//	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. ROTATED');
						tmpPoints[1] := aftLocn.myLayout.pointsPolygon[1];
						tmpPoints[5] := aftLocn.myLayout.pointsPolygon[5];
						tmpPoints[2] := aftLocn.myLayout.pointsPolygon[2];
					else
						tmpPoints[1] := aftLocn.myLayout.pointsPolygon[1];
						tmpPoints[5] := aftLocn.myLayout.pointsPolygon[5];
						tmpPoints[4] := aftLocn.myLayout.pointsPolygon[4];
					endif;
				endif;
				
//	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 2. ' &amp; deckItemLayout.myDeckItem.code);
				
				myDrawingFrame.drawAPolygon(tmpPoints,doFloodFill,theColour, myDrawingFrame.drawWidth, myDrawingFrame.drawFillColor, scale, theText);
			else
				myDrawingFrame.drawAPolygon(deckItemLayout.pointsPolygon,doFloodFill,theColour, myDrawingFrame.drawWidth, myDrawingFrame.drawFillColor, scale, theText);
			endif;
//		else
	//		myDrawingFrame.drawAPolygon(deckItemLayout.pointsPolygon,doFloodFill,theColour, myDrawingFrame.drawWidth, myDrawingFrame.drawFillColor, scale, theText);
	//	endif;
		
		self.drawAPolygonAfter(deckItemLayout,allTIs, numTier, tmpPoints, has40s);
		
		// 31569 Is the rotation master, draw a red dot.
		if deckItemLayout.getDeckItem() &lt;&gt; null then
			deckItemLayout.getDeckItem().drawRotationMasterMark(myDrawingFrame,scale);
		endif;
	endforeach;
	
	// we are not always run from a scrollable drawing frame
	if myDrawingFrame.mySDF &lt;&gt; null then
		myDrawingFrame.mySDF.repositionAfterResize();
	endif;
epilog	
		
	myDrawingFrame.endBatchDrawing();
	delete allTIs;
	delete rArray;
	delete tmpPoints;
end;</source>
        <Parameter name="_frame" type="CMUI_PointDrawingFrame"/>
        <Parameter name="_layer" type="CM_DeckLayerLayout"/>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllPolygonsActualForCC" id="d23ce8f3-ff7c-44ed-bcfb-434ac935ce1b">
        <updating/>
        <source>getAllPolygonsActualForCC(_layer : CM_DeckLayerLayout;_colour : Integer; _isLoad : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 06/05/2016   cnwma1 		PAR #37833 TFS #1957 Roro planning - rotated cells
// ---------------------------------------------------------------------------

vars
	pointerX : Integer;
	theColour : Integer;
	theObject : Object;
	theText : String;
	doFloodFill, has40s, hideExport40 : Boolean;
	aGraphic : CM_DeckItemLayout;
	aftLocn, theLocn : CM_ROROLocnDefn;
	rArray : RealArray;
	scale : Decimal[12,2];
	aTI, ti40 : CM_TrackedItem;
	numTier : Integer;
	tmpPoints : PointArray;
		allTIs : CM_TIArray;
	myDrawingFrame : CMUI_PointDrawingFrame;
begin
	myDrawingFrame := self.myPointDrawingFrame;


	create tmpPoints transient;
	myDrawingFrame.autoRedraw := true;
	scale := self.scaleFactor;
	if scale &lt;= 0 then
		scale := 1;
	endif;
		
	
	if _layer &lt;&gt; null then
		numTier := _layer.getNumTiers();
	endif;
	if numTier = 0 then
		numTier := 3;
	endif;

	myDrawingFrame.endBatchDrawing();
	myDrawingFrame.beginBatchDrawing();

//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1.scale: ' &amp; scale.String &amp; " self.form: " &amp; self.form.String);	
	create rArray transient;
	create allTIs transient;
	
	
	pointerX := 0;
	foreach theObject in myDrawingFrame.allPointGraphics do
		pointerX := pointerX + 1;

		if pointerX &gt; myDrawingFrame.allFloodFill.size then
			break;
		endif;
		if theObject = null then
			continue;
		endif;
		aGraphic := theObject.CM_DeckItemLayout;
		if aGraphic.pointsPolygon.size = 0 then
			continue;
		endif;
		
		if aGraphic.myDeckItem = null then
			continue;
		endif;
		
		
		
		if _isLoad 													//06/05/2016 cnwma1 PAR #37833 TFS #1957 
		and aGraphic.myDeckItem.isKindOf(CM_ROROLocnDefn) 
		and aGraphic.myDeckItem.CM_ROROLocnDefn.myRotateLoad &lt;&gt; null then
			continue;
		endif;
		
		
		allTIs.clear();
		
		//epr par 31936 18/7/13
		has40s := false;	
		aGraphic.myDeckItem.getAllTIsForDisplayMode(self.modeView, self.modeViewSubSub,allTIs, true,has40s);
		
		doFloodFill := true;
		
		if myDrawingFrame.showColour then
			// we are not always run from a scrollable drawing frame
			if myDrawingFrame.mySDF &lt;&gt; null and ( _colour = myDrawingFrame.mySDF.backColor) then
				theColour := _colour;
			else
				theColour := myDrawingFrame.allLineColours[pointerX];
			endif;
		else
			theColour:=Black;
		endif;

		
		if pointerX &lt;= myDrawingFrame.allFillStyles.size then
			myDrawingFrame.drawFillStyle := myDrawingFrame.allFillStyles[pointerX];
			//epr par 27626 25/5/2011 if solid fill make it transparent
			if not myDrawingFrame.showColour then
				if  myDrawingFrame.drawFillStyle =Frame.DrawFillStyle_Solid  then		
					myDrawingFrame.drawFillStyle :=  Frame.DrawFillStyle_Transparent;
				endif;
			endif;

		else
			myDrawingFrame.drawFillStyle :=  Frame.DrawFillStyle_Transparent;
		endif;
		
		if pointerX &lt;= myDrawingFrame.allDrawWidths.size then
			myDrawingFrame.drawWidth := myDrawingFrame.allDrawWidths[pointerX];
		else
			myDrawingFrame.drawWidth :=  1;
		endif;
	
		if myDrawingFrame.showColour then
			if pointerX &lt;= myDrawingFrame.allFillColours.size then
				myDrawingFrame.drawFillColor := myDrawingFrame.allFillColours[pointerX];
			else
				myDrawingFrame.drawFillColor :=  theColour;
			endif;
		else
			myDrawingFrame.drawFillColor := Black;
		endif;
		
		if pointerX &lt;= myDrawingFrame.allDrawWidths.size then
			myDrawingFrame.drawStyle := myDrawingFrame.allLineStyles[pointerX];
		else
			myDrawingFrame.drawStyle :=  Frame.DrawStyle_Solid;
		endif;
		
		if myDrawingFrame.showText  then
 			theText := myDrawingFrame.allTexts[pointerX];
		else
			theText := null;
		endif;
		tmpPoints.clear();
		aGraphic.pointsPolygon.copy(tmpPoints);
		
		if aGraphic.myDeckItem &lt;&gt; null and aGraphic.myDeckItem.isKindOf(CM_ROROLocnDefn) then
			theLocn := aGraphic.myDeckItem.CM_ROROLocnDefn; // PAR 28990
			// PAR 29050				
			has40s :=false;
			if not allTIs.isEmpty() then
				foreach theObject in allTIs do
					// PAR 29050
					aTI := theObject.CM_TrackedItem;
					
					// PAR 29050 - in Load CC mode ignore any TIs that have been CCd for discharge
					if self.modeView = ShpDisplayMode_ColCodeLoad
					and ( (aTI.isToBeDischargedHere() and aTI.getVoyageWLEUnactioned(false) &lt;&gt; null)  // is colour coded
					      or (aTI.isRehandle or aTI.isSOB) ) then  // PAR 29477 (29771)
						continue;
					endif;
					if not aTI.isTwenty() then
						has40s := true;
						ti40 := aTI;
						break;
					endif;
				endforeach;
			else
				aTI := null;
			endif;
			if has40s and ti40 &lt;&gt; null then
				hideExport40 := false; // PAR 31073 
				if self.modeView = ShpDisplayMode_ColCodeDisch and self.modeViewSubSub = ShpDisplayModeSub_ExportsHide then // PAR 31073 
					//if ti40.isExport or ti40.isRehandle or ti40.isSOB  // PAR 31073 
					//  or aTI.isTranshipExport() then // PAR 31605
					if aTI.hasBeenLoadedToShip() then		//cnwmc5 - 11 March 2014 - PAR 33283
						hideExport40 := true; // PAR 31073 
					endif;
				endif;
		
				// ignore back end
				if not hideExport40 and not theLocn.allROROSlotDefnByOrdinal.includes(ti40.myPrimaryActualLocation.CM_ROROSlotController.mySlotDefn) then
					continue;
				endif;
				aftLocn := theLocn.getAftLocnDefn();
				if not hideExport40 and aftLocn &lt;&gt; null then
					if aftLocn.isVerticalOrientation() then
				//	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. ROTATED');
						tmpPoints[1] := aftLocn.myLayout.pointsPolygon[1];
						tmpPoints[5] := aftLocn.myLayout.pointsPolygon[5];
						tmpPoints[2] := aftLocn.myLayout.pointsPolygon[2];
					else
						tmpPoints[1] := aftLocn.myLayout.pointsPolygon[1];
						tmpPoints[5] := aftLocn.myLayout.pointsPolygon[5];
						tmpPoints[4] := aftLocn.myLayout.pointsPolygon[4];
					endif;
				endif;
//	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 2. ' &amp; aGraphic.myDeckItem.code);
				
				myDrawingFrame.drawAPolygon(tmpPoints,doFloodFill,theColour, myDrawingFrame.drawWidth, myDrawingFrame.drawFillColor, scale, theText);
			else
				myDrawingFrame.drawAPolygon(aGraphic.pointsPolygon,doFloodFill,theColour, myDrawingFrame.drawWidth, myDrawingFrame.drawFillColor, scale, theText);
			endif;
		else
			myDrawingFrame.drawAPolygon(aGraphic.pointsPolygon,doFloodFill,theColour, myDrawingFrame.drawWidth, myDrawingFrame.drawFillColor, scale, theText);
		endif;
		
		if self.modeView = ShpDisplayMode_ColCodeDisch or self.modeView = ShpDisplayMode_ColCodeLoad then	// PAR 29050
			self.drawAPolygonAfter(aGraphic,allTIs, numTier, tmpPoints, has40s);
		endif;
	
		// 31569 Is the rotation master, draw a red dot.
		if aGraphic &lt;&gt; null and aGraphic.getDeckItem() &lt;&gt; null then 
			aGraphic.getDeckItem().drawRotationMasterMark(myDrawingFrame,scale);
		endif;
	endforeach;
	
	// we are not always run from a scrollable drawing frame
	if myDrawingFrame.mySDF &lt;&gt; null then
		myDrawingFrame.mySDF.repositionAfterResize();
	endif;
epilog	
		
	myDrawingFrame.endBatchDrawing();
	delete allTIs;
	delete rArray;
	delete tmpPoints;
end;</source>
        <Parameter name="_layer" type="CM_DeckLayerLayout"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_isLoad" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllPolygonsColourCoding" id="2b9ee394-fb5f-4011-bd37-69cd0e5aa91f">
        <updating/>
        <source>getAllPolygonsColourCoding(_frame : CMUI_PointDrawingFrame;_layer : CM_DeckLayerLayout; _isLoad : Boolean;_colour : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//18 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
// ---------------------------------------------------------------------------

vars
	pointerX : Integer;
	theColour : Integer;
	theObject : Object;
	theText : String;
	doFloodFill, has40s, is40, showJobLine : Boolean;
	aGraphic : CM_DeckItemLayout; //CM_RORORequestLayout;
	aftLocn, tmpLocnDefn : CM_ROROLocnDefn;
	tmpDeckItem : CM_DeckItem;
	rArray : RealArray;
	scale : Decimal[12,2];
	aTI : CM_TrackedItem;
	numTier : Integer;
	tmpPoints : PointArray;
	layoutsToDraw : PointArray;
	allTIs : CM_TIArray;
	allLocnDefn : ObjectSet;
	aReq, aftReq : CM_RORORequest;
	myDrawingFrame : CMUI_PointDrawingFrame;
	invalidObject, check40s : Boolean;
begin
	self.myPointDrawingFrame := _frame;
	myDrawingFrame := self.myPointDrawingFrame;

	on Exception do app.handleDeletedObject(exception, theObject, invalidObject); // 31053 If this kicks off the next statement is a continue anyway so have not added any extra coding


	
	create tmpPoints transient;
	create allLocnDefn transient;
	create layoutsToDraw transient;
	create allTIs transient;
	
	myDrawingFrame.autoRedraw := true;
	myDrawingFrame.drawWidth :=  1;
	
	scale := self.scaleFactor;
	if scale &lt;= 0 then
		scale := 1;
	endif;
		
	
	if _layer &lt;&gt; null then
		numTier := _layer.getNumTiers();
	endif;
	
/* PAR 28746 try again below if zero
	if numTier = 0 then
		numTier := 3;
	endif;
*/	
	myDrawingFrame.endBatchDrawing();
	myDrawingFrame.beginBatchDrawing();

//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1.scale: ' &amp; scale.String &amp; " self.form: " &amp; self.form.String);	
	create rArray transient;
	

	
	pointerX := 0;
	foreach theObject in myDrawingFrame.allPointGraphics do //where theObject.isKindOf(CM_RORORequestLayout) do
		myDrawingFrame.drawWidth :=  1;
		pointerX := pointerX + 1;

		if pointerX &gt; myDrawingFrame.allFloodFill.size then
			break;
		endif;
		if theObject = null then
			continue;
		endif;
		aGraphic := theObject.CM_DeckItemLayout;
		if aGraphic.pointsPolygon.size = 0 then
			continue;
		endif;
		if not aGraphic.isPillar() and aGraphic.getObjectIRepresent() = null then
			continue;
		endif;
		
		// PAR 28746 
		if numTier = 0 then
			numTier := aGraphic.myDeckLayer.getNumTiers();
		endif;
	
		doFloodFill := true;
		
		if myDrawingFrame.showColour then
			// we are not always run from a scrollable drawing frame
			if myDrawingFrame.mySDF &lt;&gt; null and ( _colour = myDrawingFrame.mySDF.backColor) then
				theColour := _colour;
			else
				theColour := myDrawingFrame.allLineColours[pointerX];
			endif;
		else
			theColour:=Black;
		endif;

		
		if pointerX &lt;= myDrawingFrame.allFillStyles.size then
			myDrawingFrame.drawFillStyle := myDrawingFrame.allFillStyles[pointerX];
			if not myDrawingFrame.showColour then
				if  myDrawingFrame.drawFillStyle = Frame.DrawFillStyle_Solid  then		
					myDrawingFrame.drawFillStyle :=  Frame.DrawFillStyle_Transparent;
				endif;
			endif;

		else
			myDrawingFrame.drawFillStyle :=  Frame.DrawFillStyle_Transparent;
		endif;
		
		if pointerX &lt;= myDrawingFrame.allDrawWidths.size then
			myDrawingFrame.drawWidth := myDrawingFrame.allDrawWidths[pointerX];
/* PAR 28787			myDrawingFrame.drawWidth :=  1;
			
			// Draw a thicker red line around the items in the same job.
			if self.modeWork = SHP_ROROPlanningForm.WorkMode_Job then
				if aGraphic.isKindOf(CM_RORORequestLayout) then
					if self.allSelectedObjects.includes(aGraphic.CM_RORORequestLayout.myRequest) then
						myDrawingFrame.drawWidth := 1;
					endif;
				endif;
			endif;
			*/
		else
			myDrawingFrame.drawWidth :=  1;
		endif;
	
		if myDrawingFrame.showColour then
			if pointerX &lt;= myDrawingFrame.allFillColours.size then
				myDrawingFrame.drawFillColor := myDrawingFrame.allFillColours[pointerX];
			else
				myDrawingFrame.drawFillColor :=  theColour;
			endif;
		else
			myDrawingFrame.drawFillColor := Black;
		endif;
		
		if pointerX &lt;= myDrawingFrame.allDrawWidths.size then
			myDrawingFrame.drawStyle := myDrawingFrame.allLineStyles[pointerX];
		else
			myDrawingFrame.drawStyle :=  Frame.DrawStyle_Solid;
		endif;
		
		if myDrawingFrame.showText then
			theText := myDrawingFrame.allTexts[pointerX];
		else
			theText := null;
		endif;
		tmpPoints.clear();
		aGraphic.pointsPolygon.copy(tmpPoints);
		
		if aGraphic.isKindOf(CM_RORORequestLayout) then
			aReq := aGraphic.CM_RORORequestLayout.myRequest;

			// PAR 32021 When a rotated load becomes the actual, we create 'empty' discharge CC layouts for the unused slots in the discharge view.
			// These should draw as empty white rectangles.
			if aReq &lt;&gt; null 
			and aReq.myROROController.isKindOf(CM_ROROSlotController) then
				tmpLocnDefn := aReq.myROROController.CM_ROROSlotController.mySlotDefn.myROROLocnDen;
				if tmpLocnDefn.isPlannedRotated
				and aReq.allAllocations.isEmpty() then
					aReq := null;
				endif;
				
			endif;

			has40s := false;
			aftLocn := null;
			if aReq &lt;&gt; null and aReq.myROROController.isKindOf(CM_ROROSlotController) then
				
				tmpLocnDefn := aReq.myROROController.CM_ROROSlotController.mySlotDefn.myROROLocnDen;
				
				if self.modeViewSubSub = ShpDisplayModeSub_ExportsShow  // PAR 31162
				and tmpLocnDefn.hasTIs40Loaded(REAL_MODE, true, true) then  // PAR 31162
						is40 := true;
				else
		//			is40 := (aReq.getAttrIs40() or aReq.getAttrIs30() or aReq.getAttrIs45() or aReq.getAttrIs53()); // PAR 30022 
					is40 := aReq.getAttrIsNOT20(); // PAR 30253
				endif;
				
				if is40 then // PAR 30022 
			//	if aReq.getAttrIs40() then
					has40s := true;
					if aReq.getAttrIsBackend() then
						continue;
					endif;

					
					aftLocn := null; // PAR 31162
					if aReq.CM_ROROSlotRequest.mySlotRequestAft &lt;&gt; null then // PAR 31162
						aftLocn := aReq.CM_ROROSlotRequest.mySlotRequestAft.myROROController.getDefn().CM_ROROLocnDefnVoyage; // PAR 31162
					endif;
					if aftLocn = null then // PAR 31162
						aftLocn := tmpLocnDefn.getAftLocnDefn();
					endif;
					
				else // is a 20 req
					// PAR 29050 - 40' RoB so extend and draw a 40 foot location
					if aReq.myROROController.hasROB(false) then // - performance just check this LC
						//cnwmc5 - 3 March 2014 - PAR 33121 - check40's should always be true, other wise it causes 40's with CC'd 20 cells to be drawn incorrectly in CC Discharge mode..
						//check40s := (self.modeView = ShpDisplayMode_ColCodeDisch and self.modeViewSubSub = ShpDisplayModeSub_ExportsShow) or self.modeView = ShpDisplayMode_ColCodeLoad; // PAR 32199 only do the 40 ROB if in load mode or discahrge show exports
						check40s := true;
						
						if check40s then	 // PAR 32199
							aTI := aReq.myROROController.allTrackedItems.first();
							if  (aTI.isForty() or aTI.is30 or aTI.is45 or aTI.is53) then // PAR 30022
							// if aTI.isForty() then
								has40s := true;
								if not (aReq.myROROController = aTI.myPrimaryActualLocation) then // our 20' req in in the backend of RoB 40s
									tmpPoints.clear();
									aftLocn := tmpLocnDefn; // I am the Aft location
									aftLocn.myAdjacentSlotFwd.myLayout.pointsPolygon.copy(tmpPoints); // Get the fwd locn's points.
								else
									aftLocn := tmpLocnDefn.getAftLocnDefn();
								endif;
							endif;
						endif;
					elseif tmpLocnDefn.hasROB(false) then // OK now check all LCs in the position
						//cnwmc5 - 3 March 2014 - PAR 33121 - check40's should always be true, other wise it causes 40's with CC'd 20 cells to be drawn incorrectly in CC Discharge mode..
						//check40s := (self.modeView = ShpDisplayMode_ColCodeDisch and self.modeViewSubSub = ShpDisplayModeSub_ExportsShow) or self.modeView = ShpDisplayMode_ColCodeLoad; // PAR 32199 only do the 40 ROB if in load mode or discahrge show exports
						check40s := true;
						
						if check40s then	 // PAR 32199
							tmpLocnDefn.getAllTIsRoB(allTIs, true, false);	//15 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
							foreach aTI in allTIs discreteLock do : loop40
								if  (aTI.isForty() or aTI.is30 or aTI.is45 or aTI.is53) then // PAR 30022
							//	if aTI.isForty() then
									has40s := true;
									if not aTI.myPrimaryActualLocation.CM_ROROSlotController.mySlotDefn.myROROLocnDen = tmpLocnDefn then// our 20' req in in the backend of RoB 40s
										tmpPoints.clear();
										aftLocn := tmpLocnDefn; // I am the Aft location
										aftLocn.myAdjacentSlotFwd.myLayout.pointsPolygon.copy(tmpPoints); // Get the fwd locn's points.
									else
										aftLocn := tmpLocnDefn.getAftLocnDefn();
									endif;
									break loop40;
								endif;
							endforeach;
						endif;
					endif;
				endif;
				
				if aftLocn &lt;&gt; null then
		
					// PAR 30996	use the aft request's layout for drawing. if this is an OOTL the actual OOTL may have been moved so you get odd drawing in the load CC
					aftReq := aReq.CM_ROROSlotRequest.mySlotRequestAft; 
					layoutsToDraw.clear();
					if aftReq &lt;&gt; null then
						aftReq.myLayout.pointsPolygon.copy(layoutsToDraw);
					else
						aftLocn.myLayout.pointsPolygon.copy(layoutsToDraw);
					endif;
/* PAR 30996					
					if aftLocn.isRotated() then
						tmpPoints[1] := aftLocn.myLayout.pointsPolygon[1];
						tmpPoints[5] := aftLocn.myLayout.pointsPolygon[5];
						tmpPoints[2] := aftLocn.myLayout.pointsPolygon[2];
					else
						tmpPoints[1] := aftLocn.myLayout.pointsPolygon[1];
						tmpPoints[5] := aftLocn.myLayout.pointsPolygon[5];
						tmpPoints[4] := aftLocn.myLayout.pointsPolygon[4];
					endif;
					*/
					// PAR 31110 (during testing) if aftLocn.isVerticalOrientation() then
					// We have to use the request layout to determine was has happened.
					// The locndefn for this request may have been rotated or unrotated since the colour coding was created
					// The locndefn for this request may have been an OOTL that has since been moved.
					if (layoutsToDraw[2].x - layoutsToDraw[1].x) &lt; (layoutsToDraw[3].y - layoutsToDraw[2].y) then
						tmpPoints[1] := layoutsToDraw[1];
						tmpPoints[5] := layoutsToDraw[5];
						tmpPoints[2] := layoutsToDraw[2];
					else
						tmpPoints[1] := layoutsToDraw[1];
						tmpPoints[5] := layoutsToDraw[5];
						tmpPoints[4] := layoutsToDraw[4];
					endif;				
				endif;

			endif;
			if aReq &lt;&gt; null  then
				tmpDeckItem := aReq.myROROController.getDefn();
				if tmpDeckItem.isLocnGC() then
					if tmpDeckItem.isAllReqsInJob(_isLoad) then
						myDrawingFrame.drawWidth :=  3;
					endif;
				endif;
			endif;
			
			myDrawingFrame.drawAPolygon(tmpPoints,doFloodFill,theColour, myDrawingFrame.drawWidth, myDrawingFrame.drawFillColor, scale, theText);
			
			self.drawReqInRectangle(aGraphic.CM_RORORequestLayout.myRequest.myROROController.getDefn(), numTier, _isLoad, has40s, tmpPoints);
			self.drawReqInPolygon(aGraphic.CM_RORORequestLayout, numTier, _isLoad);
						
			// PAR 28544 ### Draw a thick line around the location IF all of the requests are in a job.
			if aReq &lt;&gt; null  then
				tmpDeckItem := aReq.myROROController.getDefn();			
				if tmpDeckItem.isLocnContainer() 
				or tmpDeckItem.isLocnLanePosition() then
					showJobLine := true; // PAR 31162
					if self.modeViewSubSub = ShpDisplayModeSub_ExportsShow then // PAR 31162
						if tmpDeckItem.hasTIs40Loaded(REAL_MODE, true, false) then  // PAR 31162
							showJobLine := false; // PAR 31162
						endif;
					endif;
					
					if showJobLine then // PAR 31162
						if tmpDeckItem.isAllReqsInJob(_isLoad) then
							self.drawRectangleFromPolygon(myDrawingFrame, tmpPoints);
						endif;
					endif;			
				endif;
			endif;
		else
			if not aGraphic.isPillar() then
				has40s := false;
				//epr par 31936 18/7/13 - moved all the conditions for load tis and discharge tis into method below
				aGraphic.myDeckItem.getAllTIsForDisplayMode(self.modeView, self.modeViewSubSub,allTIs, true,has40s);
				
				// PAR 29050				
				if has40s then
				
					aftLocn := aGraphic.myDeckItem.getAftLCFor40(REAL_MODE);
					if aftLocn &lt;&gt; null then
						if aftLocn.isVerticalOrientation() then
							tmpPoints[1] := aftLocn.myLayout.pointsPolygon[1];
							tmpPoints[5] := aftLocn.myLayout.pointsPolygon[5];
							tmpPoints[2] := aftLocn.myLayout.pointsPolygon[2];
						else
							tmpPoints[1] := aftLocn.myLayout.pointsPolygon[1];
							tmpPoints[5] := aftLocn.myLayout.pointsPolygon[5];
							tmpPoints[4] := aftLocn.myLayout.pointsPolygon[4];
						endif;
					endif;
				endif;
			endif;
			myDrawingFrame.drawAPolygon(tmpPoints,doFloodFill,theColour, myDrawingFrame.drawWidth, myDrawingFrame.drawFillColor, scale, theText);
			self.drawAPolygonAfter(aGraphic,allTIs, numTier, tmpPoints, has40s);
			self.drawReqInPolygon(null, numTier, _isLoad);	
		endif;

		// 31569 Is the rotation master, draw a red dot.
		if aGraphic &lt;&gt; null and aGraphic.getDeckItem() &lt;&gt; null then 
			aGraphic.getDeckItem().drawRotationMasterMark(myDrawingFrame,scale);
		endif;
		
	endforeach;
	// we are not always run from a scrollable drawing frame
	if myDrawingFrame.mySDF &lt;&gt; null then
		myDrawingFrame.mySDF.repositionAfterResize();
	endif;
epilog	
	myDrawingFrame.drawWidth :=  1;
		
	myDrawingFrame.endBatchDrawing();
	delete allTIs;
	delete rArray;
	delete layoutsToDraw;
	delete tmpPoints;
	delete allLocnDefn;
end;</source>
        <Parameter name="_frame" type="CMUI_PointDrawingFrame"/>
        <Parameter name="_layer" type="CM_DeckLayerLayout"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllPolygonsProposed" id="aa700a8c-afe2-4864-afaa-bd56d464062a">
        <updating/>
        <source>getAllPolygonsProposed(_frame : CMUI_PointDrawingFrame;_layer : CM_DeckLayerLayout;_colour : Integer) updating;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
06/05/2016   		cnwma1 		PAR #37833 TFS #1957 Roro planning - rotated cells
*/


vars
	pointerX : Integer;
	theColour : Integer;
	objTI, theObject : Object;
	theText : String;
	doFloodFill, has40s, plannedRehandle : Boolean;
	deckItemLayout : CM_DeckItemLayout;
	aftLocn : CM_ROROLocnDefn;
	rArray : RealArray;
	scale : Decimal[12,2];
	aTI, ti40 : CM_TrackedItem;
	allTIs : CM_TIArray;
	numTier : Integer;
	tmpPoints : PointArray;

	myDrawingFrame : CMUI_PointDrawingFrame;
begin
	self.myPointDrawingFrame := _frame;
	myDrawingFrame := self.myPointDrawingFrame;


	
	create tmpPoints transient;
	myDrawingFrame.autoRedraw := true;
	scale := self.scaleFactor;
	if scale &lt;= 0 then
		scale := 1;
	endif;
		
	create allTIs transient;
	
	if _layer &lt;&gt; null then
		numTier := _layer.getNumTiers();
	endif;
	if numTier = 0 then
		numTier := 3;
	endif;
	
	myDrawingFrame.endBatchDrawing();
	myDrawingFrame.beginBatchDrawing();

//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1.scale: ' &amp; scale.String &amp; " self.form: " &amp; self.form.String);	
	create rArray transient;
	pointerX := 0;
	foreach theObject in myDrawingFrame.allPointGraphics do

		pointerX := pointerX + 1;

		if pointerX &gt; myDrawingFrame.allFloodFill.size then
			break;
		endif;
		if theObject = null then
			continue;
		endif;
		deckItemLayout := theObject.CM_DeckItemLayout;
		
		
		
		if deckItemLayout.pointsPolygon.size = 0 then
			continue;
		endif;
		
		if not deckItemLayout.isPillar() and deckItemLayout.getObjectIRepresent() = null then
			continue;
		endif;
		
		if deckItemLayout.myDeckItem.isKindOf(CM_ROROLocnDefn)                       //06/05/2016 cnwma1 PAR #37833 TFS #1957 
		and deckItemLayout.myDeckItem.CM_ROROLocnDefn.myRotateLoad &lt;&gt; null then
			continue;
		endif;
		
	
		// ########################################
		// ########################################
		// #### HAVE WE GOT A 40 FOOTER ?
		// ########################################
		// ########################################
		allTIs.clear();
		has40s := false;		
		ti40 := null;
		aTI := null;
		if deckItemLayout.myDeckItem&lt;&gt; null then

			deckItemLayout.myDeckItem.getProposedTIs(allTIs, true);
			/*
	if process.isCnwab1() then
	if deckItemLayout.myDeckItem.code = "D4030" then
	process.debug;
	endif; endif; 
			*/
			if deckItemLayout.myDeckItem.isLocnContainer() then
				if not allTIs.isEmpty() then
					foreach objTI in allTIs do
						if objTI.CM_TrackedItem.isContainer() and  not objTI.CM_TrackedItem.isTwenty() then
							has40s := true;
							ti40 := objTI.CM_TrackedItem;
							break;
						endif;
					endforeach;
					if has40s then
						plannedRehandle := ((ti40.isSOB  or ti40.isRehandle) and ti40.isPlanned(PLANNING_MODE)); // PAR 31073
						// Ignore backends
						if ti40.myPrimaryActualLocation.isKindOf(CM_ROROSlotController) and not plannedRehandle then // PAR 31073 - not if the ti is a rehandle
							if deckItemLayout.myDeckItem.isKindOf(CM_ROROLocnDefnVoyage) and not deckItemLayout.myDeckItem.CM_ROROLocnDefnVoyage.allROROSlotDefnByOrdinal.includes(ti40.myPrimaryActualLocation.CM_ROROSlotController.mySlotDefn) then
								continue;
							endif;
						elseif ti40.myPrimaryPlannedLocation.isKindOf(CM_ROROSlotController) then
							if deckItemLayout.myDeckItem.isKindOf(CM_ROROLocnDefnVoyage) and not deckItemLayout.myDeckItem.CM_ROROLocnDefnVoyage.allROROSlotDefnByOrdinal.includes(ti40.myPrimaryPlannedLocation.CM_ROROSlotController.mySlotDefn) then
								continue;
							endif;
						endif;
						if deckItemLayout.myDeckItem.isKindOf(CM_ROROLocnDefnVoyage) then
							aftLocn := deckItemLayout.myDeckItem.CM_ROROLocnDefnVoyage.getAftLocnDefn();
						endif;
					endif;
				endif;
			endif;
		endif;

		
		// ########################################
		// ########################################
		// #### SET UP COLOURS AND LINE STYLES ETC
		// ########################################
		// ########################################
		
		// DO NOT Draw the Locns under our General Cargo poly
		// Only Defined Container Positions get covered. They only get covered by GC polys
			// if covered by an actual GC Location
	
	/* PAR 29979 covered by code in doDrawObjectproposed
		if deckItemLayout.isCovered(DeckItemLayoutType_GCDischarge,true) then // hide any cargo positions that are under the GC cargo
			if not deckItemLayout.isPillar() then
				continue;
			endif;
		endif;
*/
		// PAR 29178
		if  deckItemLayout.isCovered(DeckItemLayoutType_Graphic,true)  then // hide any cargo positions that are under the Equipment or General AREA
			continue;
		endif;
		theText := null;
		doFloodFill := myDrawingFrame.allFloodFill[pointerX];
		theColour := myDrawingFrame.allLineColours[pointerX];
		
		myDrawingFrame.drawFillStyle := myDrawingFrame.allFillStyles[pointerX];
		myDrawingFrame.drawWidth := myDrawingFrame.allDrawWidths[pointerX];
		myDrawingFrame.drawFillColor := myDrawingFrame.allFillColours[pointerX];
		myDrawingFrame.drawStyle := myDrawingFrame.allLineStyles[pointerX];
		if myDrawingFrame.showText  then
			theText := myDrawingFrame.allTexts[pointerX];
			
		endif;
		
		
		// ########################################
		// ########################################
		// #### IF WE HAVE A 40 THEN ADJUST XYs
		// ########################################
		// ########################################
		tmpPoints.clear();
		deckItemLayout.pointsPolygon.copy(tmpPoints);
		
		if has40s then
			if aftLocn &lt;&gt; null then
				if aftLocn.isVerticalOrientation() then
					tmpPoints[1] := aftLocn.myLayout.pointsPolygon[1];
					tmpPoints[5] := aftLocn.myLayout.pointsPolygon[5];
					tmpPoints[2] := aftLocn.myLayout.pointsPolygon[2];
				else
					tmpPoints[1] := aftLocn.myLayout.pointsPolygon[1];
					tmpPoints[5] := aftLocn.myLayout.pointsPolygon[5];
					tmpPoints[4] := aftLocn.myLayout.pointsPolygon[4];
				endif;
			endif;
			
			myDrawingFrame.drawAPolygon(tmpPoints,doFloodFill,theColour, myDrawingFrame.drawWidth, myDrawingFrame.drawFillColor, scale, theText);
		else

			myDrawingFrame.drawAPolygon(deckItemLayout.pointsPolygon,doFloodFill,theColour, myDrawingFrame.drawWidth, myDrawingFrame.drawFillColor, scale, theText);
		endif;
		if not allTIs.isEmpty() then
			self.drawAPolygonAfter(deckItemLayout,allTIs, numTier, tmpPoints, has40s);
		endif;
		
		// 31569 Is the rotation master, draw a red dot.
		if deckItemLayout.getDeckItem() &lt;&gt; null then
			deckItemLayout.getDeckItem().drawRotationMasterMark(myDrawingFrame,scale);
		endif;
	endforeach;
	
	// we are not always run from a scrollable drawing frame
	if myDrawingFrame.mySDF &lt;&gt; null then
		myDrawingFrame.mySDF.repositionAfterResize();
	endif;
epilog	
		
	myDrawingFrame.endBatchDrawing();
	delete allTIs;
	delete rArray;
	delete tmpPoints;
end;</source>
        <Parameter name="_frame" type="CMUI_PointDrawingFrame"/>
        <Parameter name="_layer" type="CM_DeckLayerLayout"/>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllSelectedTIs" id="803a93ff-c382-4df0-8849-32df6e3d4340">
        <source>getAllSelectedTIs(tiArray : CM_TIArray input);
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars
	obj : Object;
		theLCs : CM_LCSet;
		lc : CM_LocationsController;
		vlc : CM_VoyageROROController;
	defn : CM_DeckItem;
begin
	create theLCs transient;
	foreach obj in self.allSelectedObjects do
		if obj.isKindOf(CM_DeckItem) then
			defn := obj.CM_DeckItem;
			defn.getAllTIs(REAL_MODE, tiArray, false);
		endif;
	endforeach;


epilog
	delete theLCs;
end;</source>
        <Parameter name="tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getFrameForLayer" id="103757f9-3961-4960-b287-2a09f37ad8c3">
        <source>getFrameForLayer(_layer : CM_DeckLayerLayout) : CMUI_PointDrawingFrame;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 June 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	obj : Object;
begin
	foreach obj in self.allBackFrames do
		if obj.Frame.userObject = null then
			continue;
		endif;
		
		if obj.Frame.userObject = _layer then
			return obj.CMUI_PointDrawingFrame;
		endif;
	
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_layer" type="CM_DeckLayerLayout"/>
        <ReturnType type="CMUI_PointDrawingFrame"/>
    </JadeMethod>
    <JadeMethod name="getHazardClass" id="806e7d58-7ff9-4783-95b3-d588518f83de">
        <source>getHazardClass(_ti : CM_TrackedItem; _req : CM_RORORequest) : CM_HazardClass;
/*
Purpose:			PAR 37527
Date				Who			Reason
MARCH 2016		CNWAB1		Initial creation
*/
vars
	ti : CM_TrackedItem;
	request : CM_RORORequest;
	allocation : CM_YardAllocation;
	criteria : CM_YACriteria;
	hazardClass : CM_HazardClass;
	dataValue : String;						
	hazCode : String;						
	pos : Integer;							

begin
	// do we have a TI? - get the hazard class from there
	if _ti &lt;&gt; null then
		ti := _ti;
	else
//		ti := self.allTrackedItems.first;
	endif;
	if ti &lt;&gt; null and not ti.allTIHazards.isEmpty then
		hazardClass := app.myRoot.allHazardClasses[ti.allTIHazards.first.code];
		return hazardClass;
	endif;
		
	// if no TI, do we have a slot request with a voyage allocation for hazard class
		request := _req;
		if request &lt;&gt; null then
			criteria := request.getAttrByType(YACriteriaType_Hazardous);
			if criteria &lt;&gt; null then
				dataValue := criteria.myYAData.getDataValue.String;										
				if dataValue.pos(",", 1) &lt;&gt; null then													
					pos := 1;																			
					hazCode := dataValue.cnGetToken(pos, ",");											
				else																					
					hazCode := dataValue;																
				endif;																					
				hazardClass := app.myRoot.allHazardClasses[hazCode];
				return hazardClass;
			endif;
		endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_req" type="CM_RORORequest"/>
        <ReturnType type="CM_HazardClass"/>
    </JadeMethod>
    <JadeMethod name="getLCFromXYNoTI" id="96141564-1ddc-4f83-8ebf-15ff7fb6e8d8">
        <source>getLCFromXYNoTI(x,y : Real) : CM_LocationsController;
/*
Purpose:			
Date		Who		Reason
16 September 2011	cnwab1	Initial creation
*/

vars
	obj : Object;
	layerFrame : CMUI_PointDrawingFrame;
	theLC : CM_LocationsController;
begin

	layerFrame := self.myPlanningForm.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame;
	
	if layerFrame &lt;&gt; null then
		theLC:=self.checkLCFromXYNoTI(layerFrame,x.Integer,y.Integer);
		if theLC &lt;&gt; null then
			return theLC;
		endif;
	endif;

	foreach obj in self.allBackFrames discreteLock do
		layerFrame := obj.CMUI_PointDrawingFrame;
		theLC:=self.checkLCFromXYNoTI(layerFrame,x.Integer,y.Integer);
		if theLC &lt;&gt; null then
			return theLC;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getLCFromXYWithTI" id="fe912773-ea7a-4cec-acc4-9c94c995ddca">
        <source>getLCFromXYWithTI(x,y : Real; _mode : Integer) : CM_LocationsController;
/*
Purpose:			
Date		Who		Reason
16 September 2011	cnwab1	Initial creation
*/

vars
	obj : Object;
	layerFrame : CMUI_PointDrawingFrame;
	itemLayout : CM_DeckItemLayout;
	objectIndex : Integer;
	theLC : CM_LocationsController;
	defn : CM_DeckItem;
begin
	foreach obj in self.allBackFrames discreteLock do
		layerFrame := obj.CMUI_PointDrawingFrame;

		if layerFrame.detectIfInPolygon(x.Integer,y.Integer, objectIndex) then // this set 'TheGraphic' reference
			if layerFrame.theGraphic.isKindOf(CM_DeckItemLayout) then
				itemLayout := layerFrame.theGraphic.CM_DeckItemLayout;
				if not itemLayout.isVisible or not itemLayout.myDeckLayer.isVisible then
					continue;
				endif;
				
				layerFrame.theGraphic := null;
				defn := itemLayout.myDeckItem;
				if defn &lt;&gt; null then
					theLC := defn.getLCWithTI(_mode);
					if theLC &lt;&gt; null then
						return theLC;
					endif;
				elseif itemLayout.isKindOf(CM_RORORequestLayout) and  itemLayout.CM_RORORequestLayout.myRequest &lt;&gt; null then
					theLC := itemLayout.CM_RORORequestLayout.myRequest.myROROController;
					if theLC &lt;&gt; null then
						defn := theLC.CM_VoyageROROController.getDefn();
						if defn &lt;&gt; null then
							theLC := defn.getLCWithTI(_mode);
							if theLC &lt;&gt; null then
								return theLC;
							endif;
						endif;
					endif;
				endif;
				
			endif;
			layerFrame.theGraphic := null;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getSelectObjectsForMode" id="fbb2191f-03a0-4768-8a8f-dd4efab36b5f">
        <updating/>
        <source>getSelectObjectsForMode(_deckItemLayout : CM_DeckItemLayout; _selectedObjects : ObjectSet input)  updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 June 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	objectIRepresent,tmpObj : Object;
	aReq : CM_RORORequest;
	slotDefn : CM_ROROSlotDefn;
	is40 : Boolean;
begin
	objectIRepresent := _deckItemLayout.getObjectIRepresent();
	
	if self.modeView = ShpDisplayMode_Actual then
		if objectIRepresent.isKindOf(CM_ROROLocnDefnVoyage) then
			tmpObj := objectIRepresent.CM_ROROLocnDefnVoyage.getAftLCFor40(REAL_MODE);
			if tmpObj &lt;&gt; null then
				_selectedObjects.addNoDuplicates(tmpObj,false);
			endif;
		endif;
	elseif self.modeView =  ShpDisplayMode_Proposed then
		if objectIRepresent.isKindOf(CM_ROROLocnDefnVoyage) then
			tmpObj := objectIRepresent.CM_ROROLocnDefnVoyage.getAftLCFor40Proposed();
			if tmpObj &lt;&gt; null then
				_selectedObjects.addNoDuplicates(tmpObj,false);
			endif;
		endif;
	elseif self.modeView = ShpDisplayMode_ColCodeDisch 
	or self.modeView = ShpDisplayMode_ColCodeLoad then
		if objectIRepresent.isKindOf(CM_RORORequest) then
			aReq := objectIRepresent.CM_RORORequest;
//			is40 := (aReq.getAttrIs40() or aReq.getAttrIs30() or aReq.getAttrIs45() or aReq.getAttrIs53()); // PAR 30022 
			is40 := aReq.getAttrIsNOT20(); // PAR 30253
			if is40  // PAR 30022 
//			if  aReq.getAttrIs40 
			
			
			and not aReq.isBackEndRequest() then
				tmpObj := aReq.getAftLocnDefn();
			endif;
			
			if tmpObj &lt;&gt; null then
				_selectedObjects.addNoDuplicates(tmpObj,false);
			endif;
			// get the request's locn, then get all the requests for this locn
			 tmpObj := aReq.myROROController.getDefn();
			 if tmpObj &lt;&gt; null and tmpObj.CM_DeckItem.isLocnContainer() then
				if self.modeView = ShpDisplayMode_ColCodeLoad then
					foreach slotDefn in tmpObj.CM_ROROLocnDefnVoyage.allROROSlotDefnByOrdinal  discreteLock do
						aReq := slotDefn.CM_ROROSlotDefnVoyage.mySlotController.myRORORequestLoad ;
						if aReq &lt;&gt; null then
							if aReq &lt;&gt; objectIRepresent then
								_selectedObjects.addNoDuplicates(aReq,false);
							endif;
						endif;
					endforeach;
				elseif self.modeView = ShpDisplayMode_ColCodeDisch then
					foreach slotDefn in tmpObj.CM_ROROLocnDefnVoyage.allROROSlotDefnByOrdinal  reversed, discreteLock do
						aReq := slotDefn.CM_ROROSlotDefnVoyage.mySlotController.myRORORequestDischarge ;
						if aReq &lt;&gt; null then
							if aReq &lt;&gt; objectIRepresent then
								_selectedObjects.addNoDuplicates(aReq,false);
							endif;		
						endif;
					endforeach;
				endif;
			elseif  tmpObj.CM_DeckItem.isLocnGC() then
				if aReq &lt;&gt; null then
					_selectedObjects.addNoDuplicates(aReq,false);
				endif;
			elseif  tmpObj.CM_DeckItem.isLocnLanePosition() then
				if aReq &lt;&gt; null then
					_selectedObjects.addNoDuplicates(aReq,false);
				endif;
			endif;
		elseif objectIRepresent.isKindOf(CM_ROROLocnDefnVoyage) then
			aReq:=null;
			if self.modeView = ShpDisplayMode_ColCodeDisch then
				aReq := objectIRepresent.CM_ROROLocnDefnVoyage.getFirst40Request(false);
				if aReq &lt;&gt; null then
					if aReq.isBackEndRequest() then
						return;
					endif;
					tmpObj := objectIRepresent.CM_ROROLocnDefnVoyage.getAftLCFor40(REAL_MODE);
					if tmpObj &lt;&gt; null then
						_selectedObjects.addNoDuplicates(tmpObj,false);
					endif;
				endif;
			elseif  self.modeView = ShpDisplayMode_ColCodeLoad then
				// PAR 28336
				if not objectIRepresent.CM_ROROLocnDefnVoyage.myLayout.isSelectableByMode(ShpDisplayMode_ColCodeLoad) then
					return;
				endif;	
			endif;
			
			if aReq = null then
				tmpObj := objectIRepresent.CM_ROROLocnDefnVoyage.getAftLCFor40(REAL_MODE);
				if tmpObj &lt;&gt; null then
					_selectedObjects.addNoDuplicates(tmpObj,false);
				endif;
			endif;
		endif;
	endif;
	_selectedObjects.addNoDuplicates(_deckItemLayout,false);
	_selectedObjects.addNoDuplicates(objectIRepresent,false);
epilog

end;</source>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
        <Parameter name="_selectedObjects" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectedDLRGCSlots" id="d12c8849-21b1-46d9-bf05-03233d454825">
        <source>getSelectedDLRGCSlots(theSlots : CM_LCArray input) : Boolean;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars
	obj : Object;
		theLCs : CM_LCSet;
		lc : CM_LocationsController;
		vlc : CM_VoyageROROController;
begin
	create theLCs transient;
	foreach obj in self.allSelectedObjects do
		if obj.isKindOf(CM_ROROGCDefnVoyage) then
			theSlots.add(obj.CM_ROROGCDefnVoyage.myGCController);
			break; // ONLY ONE
		endif;
		if obj.isKindOf(CM_ROROGCRequest) then
			theSlots.add(obj.CM_ROROGCRequest.myROROController);
			break; // ONLY ONE
		endif;
	endforeach;

	// NO ALT SLOTS
	return true;

epilog
	delete theLCs;
end;</source>
        <Parameter name="theSlots" type="CM_LCArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSelectedDLRItems" id="c80268d2-0fbf-4717-9a5f-784965a43663">
        <source>getSelectedDLRItems(_theLeftRequests: CM_RequestArray input);
/*
Purpose:			
Date		Who		Reason
10 October 2011	cnwab1	Initial creation
*/

vars

	theForm : Form;
	tmpSlotController	: CM_VoyageROROController;
	aRequest, localReq : CM_RORORequest;
	tmpObj		: Object;
	has40s : Boolean;
	locnDefn : CM_ROROLocnDefnVoyage;
	allCC : CM_RORORequestSet;
begin
	app.mousePointer := Window.MousePointer_HourGlass;

	create allCC transient;
	
	foreach tmpObj in self.allSelectedObjects do
		if tmpObj.isKindOf(CM_RORORequest) then
			tmpSlotController := tmpObj.CM_RORORequest.myROROController;		
	
			aRequest := null;
			if self.modeView = ShpDisplayMode_ColCodeDisch then
				aRequest := tmpSlotController.myRORORequestDischarge;
			else
				aRequest := tmpSlotController.myRORORequestLoad;
			endif;
			//13/07/2010 cnwdz2 24599
			if aRequest = null then
				continue;
			endif;
			
			if aRequest.moveType &lt;&gt; DLR_MOVETYPE and aRequest.moveType &lt;&gt; SOB_MOVETYPE then
				aRequest := null;
			endif;
			if aRequest &lt;&gt; null then
				if not _theLeftRequests.includes(aRequest) then
					_theLeftRequests.add(aRequest);
				endif;
			endif;
		// PAR 32120 get aft if includes a 40
		elseif tmpObj.isKindOf(CM_ROROLocnDefnVoyage) then
			locnDefn := tmpObj.CM_ROROLocnDefnVoyage;
			
			locnDefn.getColourCoding(false,allCC,true);
			foreach localReq in allCC discreteLock do
				if localReq.getAttrIsBackend() then
					continue;
				endif;
				
				if not _theLeftRequests.includes(localReq) then
					_theLeftRequests.add(localReq);
				endif;
 
			endforeach;
			
		endif;
	endforeach;
	
epilog
	delete allCC;
end;</source>
        <Parameter name="_theLeftRequests" type="CM_RequestArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectedDLRSOBSlots" id="0cbc8057-9655-43ec-af79-f59146b1496d">
        <source>getSelectedDLRSOBSlots(theSlots,	theSlotsAlt : CM_LCArray input; _isLoad : Boolean) : Boolean;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars
	obj : Object;
	theLCs : CM_LCSet;
	lc : CM_LocationsController;
	vlc : CM_VoyageROROController;
	theTI : CM_TrackedItem;
begin
	create theLCs transient;
	foreach obj in self.allSelectedObjects do
		if obj.isKindOf(CM_DeckItem) then
			obj.CM_DeckItem.getLCs(theLCs, true);
			
			foreach lc in theLCs discreteLock do
				vlc :=  lc.CM_VoyageROROController;
				if _isLoad then // PAR 31144
					// PAR 32223 if vlc.myRORORequestLoad = null then
					if vlc.myRORORequestLoad &lt;&gt; null // PAR 32223
					and not vlc.myRORORequestLoad.getAttrIsBackend() then // PAR 32223
						if not theSlots.includes(vlc) then
							theSlots.add(vlc);
						endif;
					endif;
				else
					if vlc.myRORORequestDischarge = null and not vlc.allTrackedItems.isEmpty then
						theTI := vlc.allTrackedItems.first; // PAR 30113
						if theTI.myPrimaryActualLocation = vlc then // PAR 30113
							if not theSlots.includes(vlc) then
								theSlots.add(vlc);
							endif;
						endif;
					endif;
				endif;
			endforeach;

		else
		/* PAR 32223 WAS
			if obj.isKindOf(CM_RORORequest) then
				if _isLoad then // PAR 31652
					theSlots.add(obj.CM_RORORequest.myROROController);
				else
					if not vlc.allTrackedItems.isEmpty then // PAR 31652
						theSlots.add(obj.CM_RORORequest.myROROController); // PAR 31652
					endif;
				endif;
			endif;
			NOW */
			if obj.isKindOf(CM_RORORequest) then
				vlc := obj.CM_RORORequest.myROROController;
				if _isLoad then
					if not theSlots.includes(vlc) then
						theSlots.add(vlc);
					endif;
				else
					if not theSlots.includes(vlc) then
						theSlots.add(vlc);
					endif;
				endif;
			endif;
		endif;
	endforeach;
	// #### Get all the ALT key selected points
	if not _isLoad then // PAR 31144
		foreach obj in self.allSelectedAltObjects do : altLoop
			if obj.isKindOf(CM_DeckItem) then
				obj.CM_DeckItem.getLCs(theLCs, true);
				foreach lc in theLCs discreteLock do
					vlc :=  lc.CM_VoyageROROController;
					if vlc.myRORORequestLoad = null then
						if not theSlotsAlt.includes(vlc) then
							theSlotsAlt.add(vlc);
						endif;
					endif;
					if theSlotsAlt.size = theSlots.size then
						break altLoop;
					endif;
				endforeach;
			endif;
		endforeach;
	endif;
	return true;

epilog
	delete theLCs;
end;</source>
        <Parameter name="theSlots" type="CM_LCArray" usage="input"/>
        <Parameter name="theSlotsAlt" type="CM_LCArray" usage="input"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSelectedObjectsAndALT" id="6d0d3df4-7a20-45e5-bf8c-f2e30a1cfcdb">
        <source>getSelectedObjectsAndALT(theSlots,	theSlotsAlt : CM_LCArray input) : Boolean;
/*
Purpose:			
Date		Who		Reason
02 August 2011	cnwab1	Initial creation
*/

vars
	obj : Object;
		theLCs : CM_LCSet;
begin
	create theLCs transient;
	if not self.allSelectedObjects.isEmpty() then
		foreach obj in self.allSelectedObjects do
			if obj.isKindOf(CM_DeckItem) then
				obj.CM_DeckItem.getLCs(theLCs, true);
				theLCs.copy(theSlots);
			elseif obj.isKindOf(CM_RORORequest) then
				theSlots.add(obj.CM_RORORequest.myROROController);
			endif;
		endforeach;
		// #### Get all the ALT key selected points
		foreach obj in self.allSelectedAltObjects do
			if obj.isKindOf(CM_DeckItem) then
				obj.CM_DeckItem.getLCs(theLCs, true);
				theLCs.copy(theSlotsAlt);
			endif;
		endforeach;
		
		return true;
	else
		return false;
	endif;

epilog
	delete theLCs;
end;</source>
        <Parameter name="theSlots" type="CM_LCArray" usage="input"/>
        <Parameter name="theSlotsAlt" type="CM_LCArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSelectedTIsForMode" id="4b6f61d5-67f2-4996-9add-eafff04e2aa9">
        <source>getSelectedTIsForMode(_allTIs : CM_TIArray input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 April 2012	cnwer1	Initial creation CCMS MES 1033

*/

vars
	iter : Iterator;
	obj  : Object;
	req : CM_RORORequest;
	slotLC : CM_ROROSlotController;
	allTIs : CM_TIArray;
begin
	create allTIs transient;
	iter:= self.allSelectedObjects.createIterator;
	while iter.next(obj) do
		allTIs.clear;
		if obj.isKindOf(CM_ROROSlotController) then
			slotLC:= obj.CM_ROROSlotController;
			if self.modeView = ShpDisplayMode_ColCodeLoad then
				req := slotLC.myRORORequestLoad;
			elseif self.modeView = ShpDisplayMode_ColCodeDisch then
				req := slotLC.myRORORequestDischarge;
			endif;
			
			if self.modeWork = SHP_ROROPlanningForm.WorkMode_Plan then
				if self.modeView = ShpDisplayMode_ColCodeLoad then
					slotLC.getTIs(allTIs, PLANNING_MODE, true);
					if allTIs.isEmpty() then 
						slotLC.getTIs(allTIs, REAL_MODE, true);	
					endif;
				elseif self.modeView = ShpDisplayMode_Proposed then		//cnwas3 par 28401
					slotLC.getProposedTIs(allTIs);
					if allTIs.isEmpty() then
						slotLC.getTIs(allTIs, REAL_MODE, true);
					endif;
				endif;
			else
				if self.modeView = ShpDisplayMode_ColCodeDisch then
					if req &lt;&gt; null then
						req.getAllTrackedItems(allTIs);
					else
						slotLC.getTIs(allTIs, REAL_MODE, true);
					endif;
				elseif self.modeView = ShpDisplayMode_Proposed then		//cnwas3 par 28401
					slotLC.getProposedTIs(allTIs);
				elseif self.modeView = ShpDisplayMode_Actual then		// PAR 28991
					slotLC.getTIs(allTIs, REAL_MODE, true);			
		
				elseif self.modeView = ShpDisplayMode_ColCodeLoad then // PAR 29050
					slotLC.getTIs(allTIs, PLANNING_MODE, true); // PAR 28585
					if allTIs.isEmpty() then
						slotLC.getTIs(allTIs, REAL_MODE, true);	
					endif;
				endif;
			endif;			
		endif;
		
		allTIs.copy(_allTIs);
	endwhile;
		
epilog
	delete iter;
	delete allTIs;

end;</source>
        <Parameter name="_allTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSpecialStow" id="f2becb20-efdd-46cc-bead-9e94d6d76b93">
        <source>getSpecialStow(_ti : CM_TrackedItem; _req : CM_RORORequest) : CM_SpecialStow;
/*
Purpose:			PAR 37527
Date				Who			Reason
MARCH 2016	CNWAB1		Initial creation
*/

vars
	ti : CM_TrackedItem;
	request : CM_RORORequest;
	allocation : CM_YardAllocation;
	criteria : CM_YACriteria;
	specialStows : CM_ObjectSet;
	specialStow : CM_SpecialStow;

begin
	// do we have a TI? - get the hazard class from there
	if _ti &lt;&gt; null then
		ti := _ti;
	endif;
	if ti &lt;&gt; null then
		specialStow := app.myRoot.allSpecialStows[ti.specialStow];
		return specialStow;
	endif;
		
	// if no TI, do we have a slot request with a voyage allocation for hazard class
	request := _req;
	if request &lt;&gt; null then
		criteria := request.getAttrByType(YACriteriaType_SpecialStow);
		if criteria &lt;&gt; null then
			specialStows := criteria.myYAData.getDataValue.CM_ObjectSet;
			if not specialStows.isEmpty then
				return specialStows.first.CM_SpecialStow;
			endif;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_req" type="CM_RORORequest"/>
        <ReturnType type="CM_SpecialStow"/>
    </JadeMethod>
    <JadeMethod name="hasOnlyGCSelected" id="36d218c6-fb4a-4d3b-894a-89fb503541ae">
        <source>hasOnlyGCSelected() : Boolean;
/*
Purpose:		PAR 31116	
Date				Who			Reason
FEB 2013		CNWAB1		Initial creation
*/

vars
	obj : Object;
		theLCs : ObjectSet;
		lc : CM_LocationsController;
		vlc : CM_VoyageROROController;
begin
	create theLCs transient;
	foreach obj in self.allSelectedObjects do
		if not obj.isKindOf(CM_ROROGCDefnVoyage) then
			theLCs.add(obj);
		endif;
	endforeach;

	return theLCs.isEmpty();

epilog
	delete theLCs;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectObject" id="a9cffbcb-31da-4230-ad3a-7ff77d0534b0">
        <updating/>
        <source>selectObject(_obj : Object;_redraw : Boolean; _alt : Boolean) updating;
/*
Purpose:			
Date				Who			Reason
JULY 2011		CNWAB1		Initial creation
*/

vars
	theLCs : CM_LCSet;
	deckItem : CM_DeckItem;
	anLC : CM_LocationsController;
	col : ObjectArray;
begin
	if _obj = null then
		return;
	endif;
	
	if _alt then 
		col := self.allSelectedAltObjects;
	else
		col := self.allSelectedObjects;
	endif;
	
	if (not col.includes(_obj)) then
		col.add(_obj);
		self.allObjectEditions.add(_obj);
		
		
		create theLCs transient;
		if _obj.isKindOf(CM_DeckItem) then
			deckItem := _obj.CM_DeckItem;
			deckItem.getLCs(theLCs, true);
			
			foreach anLC in theLCs  discreteLock do
				self.allObjectEditions.addNoDuplicates(anLC, false);
			endforeach;
		elseif _obj.isKindOf(CM_RORORequest) then
			anLC := _obj.CM_RORORequest.myROROController;
			if anLC &lt;&gt; null then
				self.allObjectEditions.addNoDuplicates(anLC, false);
			endif;
		endif;
	else
	endif;
epilog
	delete theLCs;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_redraw" type="Boolean"/>
        <Parameter name="_alt" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectObjectsForJob" id="0e8aff7d-a645-4efc-95ed-f5c61f0c2f6f">
        <updating/>
        <source>selectObjectsForJob(_job : CM_VoyageJob; _inLoadMode, _clearFirst : Boolean) updating;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

vars
	tmpHatchLidJob	: CM_VoyageHatchLidJob;
	tmpHatchLid		: CM_HatchLid;
	tmpRequest		: CM_Request;
	tmpSlotRequest	: CM_RORORequest;
	tmpLC			: CM_LocationsController;
	tmpSlot			: CM_VoyageROROController;
	tmpTI			: CM_TrackedItem;
	tmpBay			: CM_Bay;
	tmpFrame		: SHP_BayDrawingFrame;
	aftLocn : CM_ROROLocnDefn;
	is40 : Boolean;
begin

	app.mousePointer := Window.MousePointer_HourGlass;
	beginLoad;

	if _clearFirst then
		self.clearAllSelectedObjects();
	endif;
	
	if _job.isKindOf(CM_VoyageDeckJob) then
		foreach tmpRequest in _job.allRequests do
			if (not CM_RORORequest.hasInstance(tmpRequest)) then
				continue;
			endif;
			tmpSlotRequest := tmpRequest.CM_RORORequest;
			if _inLoadMode then
				if tmpSlotRequest.isDischarge then
					continue;
				endif;
			else
				if tmpSlotRequest.isLoad then
					continue;
				endif;
			endif;
			if tmpSlotRequest.myLayout = null then
				continue;
			endif;
			if not tmpSlotRequest.isBackEndRequest() then
				self.selectObject(tmpSlotRequest, false, false);

//				is40 := (tmpSlotRequest.getAttrIs40() or tmpSlotRequest.getAttrIs30() or tmpSlotRequest.getAttrIs45() or tmpSlotRequest.getAttrIs53()); // PAR 30022 
				is40 := tmpSlotRequest.getAttrIsNOT20(); // PAR 30253
				if is40 then // PAR 30022 
//				if tmpSlotRequest.getAttrIs40() then
					aftLocn := tmpSlotRequest.getAftLocnDefn();
					if aftLocn &lt;&gt; null then
						self.selectObject(aftLocn, false, false);
					endif;
				endif;
			endif;
		endforeach;
		
		self.drawSelectedObjects();
	endif;

epilog
	endLoad;
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="_job" type="CM_VoyageJob"/>
        <Parameter name="_inLoadMode" type="Boolean"/>
        <Parameter name="_clearFirst" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectSlotsForJob" id="5bc84aa7-ac20-4411-b1d9-d6466b73c64e">
        <updating/>
        <source>selectSlotsForJob(_origController : CM_VoyageROROController) updating;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

vars
	tmpRequest	: CM_Request;
	tmpJob		: CM_VoyageJob;
	tmpSlot		: CM_VoyageROROController;
	inLoadMode	: Boolean;
	
begin

	if _origController = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_origController', null, null);
		return;
	endif;

	if self.modeWork &lt;&gt; SHP_ROROPlanningForm.WorkMode_Job then
		app.raiseUnexpectedProgramError(class.name, method.name,app.getErrorString1(Invalid_working_mode,self.modeWork.String)); 
		return;
	endif;

	if self.modeView = ShpDisplayMode_ColCodeLoad then
		inLoadMode := true;
		tmpRequest := _origController.myRORORequestLoad;
	elseif self.modeView = ShpDisplayMode_ColCodeDisch then
		tmpRequest := _origController.myRORORequestDischarge;
		inLoadMode := false;
	else
		app.raiseUnexpectedProgramError(class.name, method.name,app.getErrorString1(Invalid_display_mode,self.myPlanningForm.modeView.String));
		return;
	endif;
	
	if tmpRequest = null then
		// slot not marked up for discharge/load so
		// can just return
		return;
	endif;
	
	if inLoadMode and tmpRequest.isSOB then // PAR 33860 DO NOT INCLUDE LOAD SOB CC in LOAD JOB. Load SoB CC goes in the discharge job.  
		return;
	endif;
	
	tmpJob := tmpRequest.myJob.CM_VoyageJob;
	
	if tmpJob = null then
		// request not yet associated with a job
		return;
	endif;
	
	self.selectObjectsForJob(tmpJob, inLoadMode, false);

end;</source>
        <Parameter name="_origController" type="CM_VoyageROROController"/>
    </JadeMethod>
    <JadeMethod name="updateEditionForSelectedObjs" id="37ca83c7-322b-4bd4-8bc2-f8fcaaccd2a2">
        <source>updateEditionForSelectedObjs(_objs : Collection);
// ---------------------------------------------------------------------------
// Created:     09 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpAny	: Any;
	tmpObj	: Object;
	
begin

	foreach tmpAny in _objs do
		tmpObj := tmpAny.Object;
		if self.allObjectEditions.includes(tmpObj) then
			// this will update the edition in the dict
			self.allObjectEditions.add(tmpObj);
		endif;
	endforeach;

end;</source>
        <Parameter name="_objs" type="Collection"/>
    </JadeMethod>
</Class>
