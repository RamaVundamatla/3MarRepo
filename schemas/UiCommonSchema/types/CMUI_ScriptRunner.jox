    <JadeMethod name="doInspectOid" id="8e82dc1d-8a47-44c4-b3d4-14eecce05b22">
        <source>doInspectOid(_control : CMUI_TextBox input) protected;
/*

Purpose:			Added to stop logging simple oid checks, as well as having some quicker error checking

Parameters:			

Return Value:		

Date			Who		Reason
23 May 2024		navmd1	Initial creation

*/

vars
	oidText		: String;
	obj			: Object;
begin
	oidText := _control.text;
	if oidText = null then
		return;
	endif;
	
	obj := oidText.asOid();
	if obj = null or not app.isValidObject(obj) then
		app.msgBox("Invalid/Oid not found", "", MsgBox_OK_Only);
		return;
	endif;
	
	obj.inspect;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_control" type="CMUI_TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doRun" id="bd5a1e9f-2ebf-46ec-8413-578b02b02433">
        <source>doRun() protected;
// 	executeScript the editor source
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	completedOK		: Boolean;
	errorCode		: Integer;
	errorPosition	: Integer;
	errorLength		: Integer;
	result			: Any;
	str				: String;
	posNeg,
	numDays			: Integer;
	st				: TimeStamp;
	duration		: Time;		// TFS 51191
	
begin

	st := app.actualTimeServer;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.staMain.caption := 'Executing ....';
	self.staMain.refreshNow();

	str := self.txtJadeEditor.text;
	if str = null then
		app.msgBox('No code to run', 'Error', MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		self.staMain.caption := null;
		return;
	endif;

	result := process.executeScript('temp', self.class,
						currentSchema,
						str,
						true, null,
						errorCode, errorPosition, errorLength, self);


	if errorCode = 0 then
		duration := app.actualTimeServer.differenceAsTime(st, posNeg, numDays);
		self.staMain.caption := 'Execution complete - elapsed time ' &amp; duration.String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		CM_ScriptHistoryRecord@createRecordData(str, duration);	// TFS 51191 navmd1 07/05/2021
	else
		str := "Compiler error " &amp; errorCode.String &amp; " - " &amp; 
				process.getErrorText(errorCode);
		self.staMain.caption := str;
		
		str := str &amp; ' at position ' &amp;
				errorPosition.String;

		self.txtJadeEditor.selStart := errorPosition;
		self.txtJadeEditor.selLength := errorLength;

		app.msgBox(str, 'Error', MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		
	endif;
	completedOK := true;
epilog
	// update the status line when an exception has happened
	if not completedOK then
		self.staMain.caption := 'Execution completed with exception - elapsed time ' &amp; app.actualTimeServer.differenceAsTime(st, posNeg, numDays).String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="keyDown" id="a544f25e-0e98-4766-851e-ea7d90ec0290">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     24 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if keyCode = CMUI_Key_F9 then
		self.doRun();
		return;
	elseif keyCode = J_key_A and shift.isControlKeyPressed then
		self.txtJadeEditor.selStart := 0;
		self.txtJadeEditor.selLength := -1;
		return;
	endif;
	
	inheritMethod(keyCode, shift);
	
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="84c0d2a5-56d6-4b50-8a80-a2c82f925a18">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     24 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Date				Who		Reason
// 13 May 2021		navmd1	Initial creation TFS 51191 Record Script Runner history
vars
	stateData			: Any;
	isOk				: Boolean;
begin

	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.addRegisteredKey(CMUI_Key_F9);
	
	self.btnSaveBase.tabStop := false;
	self.btnCancelBase.tabStop := false;
	
	self.setupJadeEditor();
	
	inheritMethod();
	
	stateData := app.myRoot.getConfig(CM_ScriptHistoryRecord.StateDictName);
	
	if stateData = null then
		beginTransaction;
		create self.allScriptsRun persistent;
		app.myRoot.setConfig(CM_ScriptHistoryRecord.StateDictName, self.allScriptsRun, false);
		commitTransaction;
	else
		self.allScriptsRun := stateData.CM_ScriptHistoryByDT;
	endif;
	
	isOk := true;
epilog
	if not isOk then
		abortTransaction;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupJadeEditor" id="d48d1eaf-ce2d-4683-a11e-82d895ecc492">
        <source>setupJadeEditor()protected;
// use the Jade editor not just a text box
vars

begin
	self.txtJadeEditor.configureFor_Jade;				// Call before init to work around selected text appearing as just 'black' in JADE 2020
	self.txtJadeEditor.initializeJadeEditor(false);
	
	self.txtJadeEditor.tabWidth	:= 4;
	self.txtJadeEditor.fontSize := 12;	// has no effect ...
	
	// enable class name highlighting
	self.txtJadeEditor.setCurrentSchema(currentSchema);
	
	// For those of us who are lazy ;)
	self.txtJadeEditor.text := "vars" &amp; CrLf &amp; Tab &amp; CrLf &amp; "begin" &amp; CrLf &amp; Tab &amp; CrLf &amp; "epilog" &amp; CrLf &amp; Tab &amp; CrLf &amp; "end;";
	self.txtJadeEditor.currentPosition := 17;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="4afd6041-dc04-4761-b851-b8eb54db5568">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008067, locale);
	btnRun.translateBubbleHelp(Xlat_0000819, locale);
	btnRun.translateCaption(Xlat_0000820, locale);
 ////	lblHeading.translateCaption(Xlat_0000821, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtInspect_lostFocus" id="63c1f754-33fb-46c3-bbfc-bf3e9b281eeb">
