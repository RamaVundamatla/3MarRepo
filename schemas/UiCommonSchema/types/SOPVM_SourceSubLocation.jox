    <JadeMethod name="createEmptyChild" id="a59cb7bd-40e9-4efc-b59d-c092502ffba4">
        <updating/>
        <source>createEmptyChild(_parent: SOP_ViewModelObject) updating;
// -----------------------------------------------------------------------------
// Created:		12 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	create myObject as CM_SourceSubLocation transient;
	myObject.CM_SourceSubLocation.setForProxy(null, null, _parent.myObject.CM_SourceLocation.isFSC, false, _parent.myObject.CM_SourceLocation);
	myParent := _parent;
end;</source>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
    </JadeMethod>
    <JadeMethod name="createEmptyPeer" id="44f6e01e-7ad5-407e-aece-5e949758c7f6">
        <updating/>
        <source>createEmptyPeer(_parent: SOP_ViewModelObject) updating;
// -----------------------------------------------------------------------------
// Created:		30 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	proxySub : CM_SourceSubLocation;
begin
	create proxySub transient;
	proxySub.setForProxy(null, null, _parent.myObject.CM_SourceLocation.isFSC, false, _parent.myObject.CM_SourceLocation);
	self.myObject := proxySub;	
	self.myParent := _parent;
end;</source>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="78ce99f6-4266-4198-bfd6-cd80433ad6d9">
        <updating/>
        <source>doDelete() : Boolean updating;
// -----------------------------------------------------------------------------
// Created:		14 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	app.myTrxDA.trxDeleteSourceSubLocation(self.myObject.CM_SourceSubLocation,app.myPassport);
	return app.myPassport.trxCompletedOK();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="49c7732a-09d2-4988-ba93-e3cf76c72037">
        <updating/>
        <source>doSave(): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		12 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	proxyLocation, newLocation : CM_SourceSubLocation;
	tmpObj				: CM_SourceSubLocation;
	isFSCFromTbl		: Boolean;
	answer				: Integer;
	applyFscToChildren	: Boolean;

begin
	if self.myForm.mode = self.myForm.Mode_Add then
		if self.myForm.myProxyObject &lt;&gt; null then
			self.myForm.myProxyObject.erase(NORMAL_ERASE);
		endif;
		
		create self.myForm.myProxyObject as CM_SourceSubLocation transient;
	endif;
	
	proxyLocation := self.myForm.myProxyObject.CM_SourceSubLocation;
	
	isFSCFromTbl := self.myForm.tblInput1.getValueByName(ETRow_IsFSC).Boolean;
	// When FSC changed, need to ask whether apply FSC for all children. CCMC JML 1105, PAR 21535 Nov 2009
	if self.myForm.mode = self.myForm.Mode_Update then
		tmpObj := self.myObject.CM_SourceSubLocation;
		if tmpObj.isFSC &lt;&gt; isFSCFromTbl then
			answer := app.msgBox(app.getErrorString(ApplyFscToAllStands), "", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
			if answer = MsgBox_Return_Yes then
				applyFscToChildren := true;
			endif;
		endif;
	endif;
	
	proxyLocation.setForProxy(	self.myForm.tblInput1.getValueByName('code').String.removeTabCrLfs(),	// 18/04/2013 cnwar2 #27130
								self.myForm.tblInput1.getValueByName('description').String,
								isFSCFromTbl,
								self.myForm.tblInput1.getValueByName('notAvailableForEntry').Boolean,
								self.myObject.CM_SourceSubLocation.mySourceLocation);
								
	if self.myForm.mode = self.myForm.Mode_Add then
		app.myTrxCA.trxCreateSourceSubLocation(proxyLocation, newLocation, app.myPassport);
		if app.myPassport.trxCompletedOK then
			delete self.myObject;  // delete the transient holder
			self.myObject := newLocation;
		endif;
	elseif self.myForm.mode = self.myForm.Mode_Update then
		app.myTrxUA.trxUpdateSourceSubLocation(proxyLocation, applyFscToChildren, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; self.myForm.mode.String &amp; ')');
	endif;
	
	self.myForm.myProxyObject := proxyLocation;
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSelected" id="59a4f595-664a-4748-ab57-ee793306e450">
        <updating/>
