    <JadeMethod name="initMSG" id="d58dac76-e852-4040-82d9-0dd801668cd1">
        <source>initMSG(_theGroupBox : CMUI_MultiSelectGroupBox;_titleAvail, _titleSel, _methodName : String);
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theGroupBox : CMUI_MultiSelectGroupBox;
begin
	theGroupBox := _theGroupBox;
	theGroupBox.caption := null;
	theGroupBox.distanceFromBottom 	:= 5;
	theGroupBox.distanceFromRight 		:= 5;
	theGroupBox.lockBottom 				:= false;
	theGroupBox.lockRight				:= false;
	theGroupBox.stretchHeight 			:= false;
	theGroupBox.stretchWidth 			:= true;
	theGroupBox.multiSelect 	:= ListBox.MultiSelect_Extended;
	theGroupBox.formDisplayEntryMethodName := _methodName;
	theGroupBox.availableHeading := _titleAvail;
	theGroupBox.selectedHeading := _titleSel;
	theGroupBox.myBaseForm	:= self;
	theGroupBox.mySelectedListBox.sorted := false;
	theGroupBox.cnEcResizeContents();
	theGroupBox.readOnly := false;
	theGroupBox.enabled := true;

end;</source>
        <Parameter name="_theGroupBox" type="CMUI_MultiSelectGroupBox"/>
        <Parameter name="_titleAvail" type="String"/>
        <Parameter name="_titleSel" type="String"/>
        <Parameter name="_methodName" type="String"/>
