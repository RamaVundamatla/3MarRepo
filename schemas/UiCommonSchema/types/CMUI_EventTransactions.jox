    <JadeMethod name="translateForm" id="fb4793d8-dea3-41b1-b84e-b5c76d8ea264">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 01 August 2022 16:45:54.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020004, locale);
	btnDelete.translateBubbleHelp(Xlat_0020217, locale);
	btnDelete.translateCaption(Xlat_0020006, locale);
	btnEditEvent.translateBubbleHelp(Xlat_0020218, locale);
	btnEditEvent.translateCaption(Xlat_0020008, locale);
	btnExport.translateBubbleHelp(Xlat_0020009, locale);
	btnExport.translateCaption(Xlat_0020010, locale);
	btnInvoiceLine.translateBubbleHelp(Xlat_0020011, locale);
	btnInvoiceLine.translateCaption(Xlat_0020012, locale);
	btnNewEvent.translateBubbleHelp(Xlat_0020219, locale);
	btnNewEvent.translateCaption(Xlat_0020014, locale);
	btnPrint.translateCaption(Xlat_0020015, locale);
	lblAmount.translateCaption(Xlat_0020198, locale);
	lblCharge.translateCaption(Xlat_0020016, locale);
	lblDate.translateCaption(Xlat_0020017, locale);
	lblDebtor.translateCaption(Xlat_0023948, locale);
	lblEndDate.translateCaption(Xlat_0021748, locale);
	lblEndTime.translateCaption(Xlat_0021749, locale);
	lblEventType.translateCaption(Xlat_0020018, locale);
	lblRemarks.translateCaption(Xlat_0021750, locale);
	lblTime.translateCaption(Xlat_0020019, locale);
	lblTitle.translateCaption(Xlat_0021914, locale);
	lblWeight.translateCaption(Xlat_0024974, locale);
	mnuAudits.translateCaption(Xlat_0024158, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0020020, locale);
	mnuContext.translateCaption(Xlat_0020021, locale);
