	btnJobPriority.translateBubbleHelp(Xlat_0018061, locale);
	btnJobPriority.translateCaption(Xlat_0018062, locale);
	btnOOW.translateBubbleHelp(Xlat_0002995, locale);
	btnOOW.translateCaption(Xlat_0002998, locale);
	btnOpenVygConfig.translateBubbleHelp(Xlat_0018063, locale);
	btnOpenVygConfig.translateCaption(Xlat_0018064, locale);
	btnReset.translateBubbleHelp(Xlat_0002991, locale);
	btnReset.translateCaption(Xlat_0002993, locale);
	btnShowLift.translateBubbleHelp(Xlat_0006624, locale);
	btnShowLift.translateCaption(Xlat_0006625, locale);
	btnUserColours.translateBubbleHelp(Xlat_0002971, locale);
	btnUserColours.translateCaption(Xlat_0002973, locale);
	btnVoyageSave.translateBubbleHelp(Xlat_0002975, locale);
