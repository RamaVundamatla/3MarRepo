    <JadeMethod name="getAuditText" id="3a6fbb50-d526-4a94-8f7d-ad30713d577b">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2023 navtnr20	TFS CR 57983 Task 57984: EUP - INCO Terms TRX Layer

*/

vars
	txt,
	tmpStr		: String;
	invLineDesc : CM_InvoiceLineDesc;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	if self.allInvoiceLineTypes.size &gt; 0 then
		foreach invLineDesc in self.allInvoiceLineTypes do
			if invLineDesc &lt;&gt; null then
				tmpStr := invLineDesc.narration &amp;" "&amp; tmpStr ;
			endif;
		endforeach;
		txt := txt &amp; app.getErrorString(Mapping) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	tmpStr := null;
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="4cd39a79-e9f7-4178-96f9-0540fb0ba050">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2023 navtnr20	TFS CR 57983 Task 57984: EUP - INCO Terms TRX Layer

*/

vars
	invLineDesc			: CM_InvoiceLineDesc;
begin
	if _attrName = ETRow_Charge then
		return self.myDebtorType.description;
	elseif _attrName = ETRow_Lines then
		return self.allInvoiceLineTypes.size.String;
	else
		return null;
	endif;
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="b3bbfe22-3776-4f27-9d8e-bc9d8a186bd1">
        <source>pxyCreateUpdateProxy(): SelfType;
/*
Purpose:			

Date		Who		Reason
16 May 2023 navtnr20	TFS CR 57983 Task 57984: EUP - INCO Terms TRX Layer
*/

vars
	pxyME : SelfType;
begin
	pxyME :=  inheritMethod();
	
	pxyME.myDebtorType := self.myDebtorType;
	pxyME.myINCOTerm := self.myINCOTerm;
	self.allInvoiceLineTypes.copy(pxyME.allInvoiceLineTypes);
	
	return pxyME;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
