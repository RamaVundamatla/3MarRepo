    <JadeMethod name="valVoyageJobTIAssign" id="b721c1a9-bd0d-4531-b3f6-bf2f07797d13">
        <source>valVoyageJobTIAssign(_proxyVoyageJob :CM_VoyageJob; _theTI : CM_TrackedItem input);
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	aJob, realJob : CM_VoyageJob;
	jobString : String;
begin
	self.raiseExceptionIfNull(_proxyVoyageJob, 'Voyage Job Proxy assign TI');

	_proxyVoyageJob.raiseExceptionIfNotProxy(method);

	realJob := _proxyVoyageJob.pxyGetRealObject.CM_VoyageJob;
	
	if realJob &lt;&gt; null then
		if realJob.isSOB then
			foreach aJob in _theTI.allJobsShipSOB do
				if realJob = aJob then
					continue;
				endif;
				if not aJob.isJobComplete then
					jobString := jobString &amp; aJob.jobNum &amp; " ";
				endif;
			endforeach;
		elseif realJob.isRelease then
			foreach aJob in _theTI.allJobsShipRelease do
				if realJob = aJob then
					continue;
				endif;
				if not aJob.isJobComplete then
					jobString := jobString &amp; aJob.jobNum &amp; " ";
				endif;
			endforeach;
		else
			foreach aJob in _theTI.allJobsShipReceive do
				if realJob = aJob then
					continue;
				endif;
				if not aJob.isJobComplete then
					jobString := jobString &amp; aJob.jobNum &amp; " ";
				endif;
			endforeach;
		endif;
	endif;	
	if jobString &lt;&gt; null then
		app.raiseCMException2(ERR_INVALID_VALUE, "Job " &amp; _proxyVoyageJob.jobNum, "Tracked Item " 
				&amp;  _theTI.id &amp; " is part of incomplete job " &amp; jobString &amp; ". It cannot be added to another. Please manually unplan " &amp;  _theTI.id,null, null);
		
	endif;
end;</source>
        <Parameter name="_proxyVoyageJob" type="CM_VoyageJob"/>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
