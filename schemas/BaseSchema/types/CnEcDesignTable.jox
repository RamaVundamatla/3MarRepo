vars

begin
	if self.dropDown = Table.DropDown_Auto then
		if not myVerticalScrollBar.visible then
			myVerticalScrollBar.visible := true;
			positionScrollbar();
		endif;
	endif;

	inheritMethod(table);
end;</source>
