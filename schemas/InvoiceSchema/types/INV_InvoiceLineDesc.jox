    <JadeMethod name="populateEntDetailTable" id="0e1bb2a3-6a5b-45c2-a1fc-229f64ec3e3c">
        <updating/>
        <source>populateEntDetailTable() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 29/09/2015	cnwdap1		PAR #36909 CCMS ADP 2537 Minimum Charge changes
// 31/01/2023 	navvt20 	TFS CR 56132 Task 56134: UI - Invoice Line Type - UOM
vars
	entRow		: EntTableRow;
	invoiceType : CM_InvoiceLineDesc;
	calcType	: CM_CalculationType;
	displayValue	: String;	
	entDef		:EntTableDef;
	idx : Integer;
begin
	entDef := app.myController.getEntTableDef(ETDef_InvMaintInvLineEnt);

	invoiceType := self.myCurrentObject.CM_InvoiceLineDesc;
	if self.mode = Mode_Add then
		self.tblEntDetail.clearValues();
		return;
	endif;	
	if invoiceType = null then
		return;
	endif;
	
	foreach entRow in entDef.allEntTableRows do
		tblEntDetail.showRowByName(entRow.name, false);	// TFS 52495 jlizm1 17/06/2022
		if invoiceType &lt;&gt; null then
			displayValue := invoiceType.getDisplayStringForAttribute(entRow.name, false).String;
		else
			displayValue := null;
		endif;
		
		// 24024 show the hook code row only if the calc type has it, and change the text from view to edit
		// 31451 May 2013 drop the maintenance of calc type hook code - is view only now
		if entRow.name = ETRow_QuantityHookCode then
			tblEntDetail.hideRowByName(ETRow_QuantityHookCode, false);
		endif;
		tblEntDetail.setValueByName(entRow.name, displayValue);		
	endforeach;

	if invoiceType.invoiceType = null then
		self.cmbInvTypeInv.listIndex := -1;
		tblEntDetail.setValueByName(ETRow_InvoiceTypeCode, null);		
	else
		if self.cmbInvTypeInv.findObject(invoiceType.invoiceType ) &lt; 0 then
			self.cmbInvTypeInv.listIndex := -1;
			tblEntDetail.setValueByName(ETRow_InvoiceTypeCode, null);		
		else
			self.cmbInvTypeInv.listObject := invoiceType.invoiceType;
		endif;
	endif;
	
	//CP CCMS 1047 PAR 16666 cnwgb1 17 April 2008...
	if invoiceType.myDebtorType = null then
		self.cmbCharges.listIndex := -1;
		tblEntDetail.setValueByName( ETRow_Charges, null);
	else
		if self.cmbCharges.findObject(invoiceType.myDebtorType ) &lt; 0 then
			self.cmbCharges.listIndex := -1;
			tblEntDetail.setValueByName(ETRow_Charges, null);		
		else
			self.cmbCharges.listObject := invoiceType.myDebtorType;
		endif;
	endif;
	//...CP CCMS 1047 PAR 16666 cnwgb1 17 April 2008
	// Start 31 Jan 2023 navvt20 TFS 56134
	if invoiceType.myUOM = null then
		self.cmbUOM.listIndex := -1;
		tblEntDetail.setValueByName(ETRow_Uom,null);
	else
		if self.cmbUOM.findObject(invoiceType.myUOM ) &lt; 0 then
			self.cmbUOM.listIndex := -1;
			tblEntDetail.setValueByName(ETRow_Uom, null);		
		else
			self.cmbUOM.listObject := invoiceType.myUOM;
		endif;
	endif;
	// End 31 Jan 2023 navvt20 TFS 56134
	self.cmbUnits.listIndex := -1;	
	foreach idx in 1 to self.cmbUnits.listCount() do
		// 24024 use myCalculation type if set otherwise getChargeByUnits
		calcType := invoiceType.myCalculationType;
		if calcType &lt;&gt; null then
			if calcType = self.cmbUnits.itemObject[idx] then
				self.cmbUnits.listIndex := idx;
				self.tblEntDetail.setValueByControlName(self.cmbUnits.name,self.cmbUnits.text); // PAR 30428
				break;
			endif;
		else
			if invoiceType.getChargeByUnits = self.cmbUnits.itemData[idx] then
				self.cmbUnits.listIndex := idx;
				break;
			endif;
		endif;
	endforeach;
	
	idx := self.cmbGroupBy.findStringExact(1, invoiceType.getMinimumChargeGroupByAsStr);	// PAR #36909
	if idx &gt; 0 then																			// PAR #36909
		self.cmbGroupBy.listIndex := idx;													// PAR #36909
	else																					// PAR #36909
		self.cmbGroupBy.listIndex := -1;													// PAR #36909
	endif;																					// PAR #36909
	if invoiceType.minimumChargeInvoiceLineType &lt;&gt; null then								// PAR #36909
		idx := self.cmbChargeType.findObject(invoiceType.minimumChargeInvoiceLineType);		// PAR #36909
		if idx &gt; 0 then																		// PAR #36909
			self.cmbChargeType.listIndex := idx;											// PAR #36909
		else																				// PAR #36909
			self.cmbChargeType.listIndex := -1;												// PAR #36909
		endif;																				// PAR #36909
	else																					// PAR #36909
		self.cmbChargeType.listIndex := -1;													// PAR #36909
	endif;																					// PAR #36909

	self.tblEntDetail.setValueByName(ETRow_OneLinePerFP, invoiceType.bOneLinePerFinancialPeriod);		
	self.tblEntDetail.setValueByName(ETRow_PrintTIs, invoiceType.bPrintTrackedItems);
	self.tblEntDetail.setValueByName(ETRow_IsNotAvailableForEntry, invoiceType.isNotAvailableForEntry);
	self.tblEntDetail.setValueByName(ETRow_CurrConvNotReq, invoiceType.currencyConversionNotRequired); // TFS 41484
	self.tblEntDetail.setValueByName(ETRow_TaxAlwaysCharged, invoiceType.taxAlwaysCharged);	//07 May 2019	NDL	TFS 44651
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="ad80dcd7-5abe-4728-aaf8-b37eb1f9ff14">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_colorControl);
	self.setColorsForEntryTable(self.tblEntDetail);
	self.fldEntDetail.backColor := self.backColor;
	self.shtEntDetail.backColor := self.backColor;
	self.shtNarration.backColor := self.backColor;
	
	self.msgServices.backColor := self.backColor;
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="ee5ee29a-a2ad-4c8e-877e-2e0fb376d37b">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// 28 Oct 2021 	navma1 	ChangeRequest 52163: SAL - Unicode Arabic Support Business Requirements
// 17 Jun 2022 	jlizm1	TFS 52495 Disable editing of void service and invoice lines
// ---------------------------------------------------------------------------

vars

	invoiceType : CM_InvoiceLineDesc;
	entRow		: EntTableRow;
	entDef		: EntTableDef;
	
begin
	inheritMethod();
	

	self.fldEntDetail.visible := true;
	self.populateEntDetailTable();
	self.setOneLinePerFPEnable();
	self.setServicesAvailable();

	self.tblEntDetail.setFocus;
	self.tblEntDetail.goToRowByName(ETRow_Narration200);			//28.10.2021 navma1 #52163
	self.fldEntDetail.initSheetBackColors();
	self.tblEntDetail.hideRowByName(ETRow_Service,false);
	// 31451 don't show hook code for new ILD
	if self.myCurrentObject = null then
		self.tblEntDetail.hideRowByName(ETRow_QuantityHookCode, false);
	else
		self.tblEntDetail.showRowByName(ETRow_QuantityHookCode, false);
	endif;
	/*//25/06/2024	navkc1 CR 64823 Task 64824
	self.txtFilterBox.enabled		:=	false; 	// ### TFS 51912 14Sep2021 NAVPW1
	self.btnClearFilter.enabled		:=	false; 	// ### TFS 51912 14Sep2021 NAVPW1
	*/
	//05/06/2024	navkc1 CR 63736 Task 63770
	if self.frmTableFilter &lt;&gt; null then
		self.frmTableFilter.btnClearFilter.enabled := false;
		self.frmTableFilter.txtFilterBox.enabled := false;
	endif;
	
	invoiceType := self.myCurrentObject.CM_InvoiceLineDesc;									// TFS 52495
	if self.mode = Mode_Update and invoiceType &lt;&gt; null and invoiceType.isVoid then			// TFS 52495
		entDef := app.myController.getEntTableDef(ETDef_InvMaintInvLineEnt);				// TFS 52495
		foreach entRow in entDef.allEntTableRows where entRow.name &lt;&gt; ETRow_Narration200 do	// TFS 52495
			self.tblEntDetail.hideRowByName(entRow.name, false);							// TFS 52495
		endforeach;
	endif;
	self.fldEntDetail.cnEcResizeContents();	// TFS 52495
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="1ef3410b-bc83-4368-bc47-4f234669d753">
        <updating/>
        <source>setControlsForView() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	
	//25/06/2024	navkc1 CR 64823 Task 64824
	//self.txtFilterBox.enabled := true; // ### TFS 51912 14Sep2021 NAVPW1
	
	//05/06/2024	navkc1 CR 63736 Task 63770
	if self.frmTableFilter &lt;&gt; null then
		self.frmTableFilter.btnClearFilter.enabled := true;
		self.frmTableFilter.txtFilterBox.enabled := true;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyCurrentBank" id="a491dc8e-78d3-47e9-b5d2-904b879a8edc">
        <updating/>
        <source>setMyCurrentBank(_bank : CM_Bank ) updating;
/*

Date		Who		Reason
17 January 2017	cnwer1	Initial creation TFS 2903

*/

vars

begin
	if self.myCurrentBank &lt;&gt; _bank then
		self.myCurrentBank:= _bank;
		self.myAssistant.comboBoxInvoiceLineType(self.cmbChargeType,true,self.myCurrentBank);
		self.doCmbInvTypeInvBuild();
	endif;
epilog

end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="setMyDataClass" id="5617868d-c752-4a75-b2f1-2dd49d661f13">
        <updating/>
        <source>setMyDataClass() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.myDataClass := CM_InvoiceLineDesc;

end;</source>
    </JadeMethod>
    <JadeMethod name="setOneLinePerFPEnable" id="1cbaae3b-6811-4150-a39e-c52f0584afad">
        <source>setOneLinePerFPEnable();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//	Nov 2010	cnwjre1		par 26107 CCMS 2020 Invoice storage by first/last cargo item on/off voyage
//							add INV_CALC_TYPE_DAYSINCE_SHIP tests
// ---------------------------------------------------------------------------

vars
	listIndex : Integer;
	unitType : Integer;
begin
	listIndex := 	self.cmbUnits.listIndex;
	if listIndex &lt; 0 then
		listIndex := 1;
		self.cmbUnits.listIndex := listIndex;
	endif;
	unitType := self.cmbUnits.itemData[listIndex];

	if unitType = INV_CALC_TYPE_DAYS_SINCE_RECVL
	or unitType = INV_CALC_TYPE_DAYSINCE_SUBTERM 	//28 Jun 2018	NDL	TFS 39338
	or unitType = INV_CALC_TYPE_DAYSINCE_SHIP_ST
	or unitType = INV_CALC_TYPE_DAYSINCE_SHIP_EN
	or unitType = INV_CALC_TYPE_DAYS_ONSITE_AT then
		self.tblEntDetail.showRowByName(ETRow_OneLinePerFP,false);	
	else
		self.tblEntDetail.hideRowByName(ETRow_OneLinePerFP,false);	
		self.tblEntDetail.setValueByName(ETRow_OneLinePerFP,false);	
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setServicesAvailable" id="37bf35b4-0fcd-40cb-8c5f-bcd425cfd7dd">
        <source>setServicesAvailable();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//	17/06/2022	jlizm1	TFS 52495 Disable editing of void service and invoice lines
// ---------------------------------------------------------------------------

vars
	listIndex : Integer;
	unitType : Integer;
	col : ObjectSet;
	aService : CM_Service;
	aCT : CM_CalculationType;
	theLine : CM_InvoiceLineDesc;
begin
	
	theLine := self.myCurrentObject.CM_InvoiceLineDesc;
	if self.mode = self.Mode_Update and theLine.isVoid then	// TFS 52495
		self.shtNarration.visible := false;					// TFS 52495
		return;
	else
		self.shtNarration.visible := true;					// TFS 52495
	endif;

	listIndex := 	self.cmbUnits.listIndex;
	if listIndex &lt; 0 then
		listIndex := 1;
		self.cmbUnits.listIndex := listIndex;
	endif;
	unitType := self.cmbUnits.itemData[listIndex];

	create col transient;
	
	foreach aService in self.myCurrentBank.services where not aService.isNotAvailableForEntry do
		aCT := aService.myCalculationType;
		if aCT = null then
			continue;
		endif;
		
		if aCT.calculationType = unitType then
			col.add(aService);
		endif;
	endforeach;
	self.msgServices.setAvailable(col,true);
	
	if self.mode = self.Mode_Add then
		self.msgServices.setSelected(null);
	else
		self.msgServices.setSelected(theLine.services);
	endif;
	
epilog
	delete col;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="setServicesAvailableNEW" id="813619a2-92fc-4694-926d-308b0ba599c4">
        <source>setServicesAvailableNEW();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//	24024	Aug 2010 use the calculation type in the combo instead of the itemData
// ---------------------------------------------------------------------------

vars
	listIndex : Integer;
	col : ObjectSet;
	aService : CM_Service;
	aCT,
	theCT	: CM_CalculationType;
	theLine : CM_InvoiceLineDesc;
begin

	listIndex := 	self.cmbUnits.listIndex;
	if listIndex &lt; 0 then
		listIndex := 1;
		self.cmbUnits.listIndex := listIndex;
	endif;
	theCT := self.cmbUnits.itemObject[listIndex].CM_CalculationType;

	create col transient;
	
	foreach aService in self.myCurrentBank.services do
		aCT := aService.myCalculationType;
		if aCT = null then
			continue;
		endif;
		
		if aCT = theCT then
			col.add(aService);
		endif;
	endforeach;
	self.msgServices.setAvailable(col,true);
	
	theLine := self.myCurrentObject.CM_InvoiceLineDesc;
	if self.mode = self.Mode_Add then
		self.msgServices.setSelected(null);
	else
		self.msgServices.setSelected(theLine.services);
	endif;
	
epilog
	delete col;
	

end;
</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d91568e9-0b11-4ccc-a501-2d9f87abdf81">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 17/09/2015	cnwdap1		PAR #36909 CCMS ADP 2537 Minimum Charge Changes
// 31/01/2023 	navvt20 	TFS CR 56132 Task 56134: UI - Invoice Line Type - UOM
vars

begin
	self.doCmbBankBuild();

	inheritMethod();
	//epr TFS 2903 17/1/17
	self.setMyCurrentBank(self.myTerminal.getDefaultCompanyBank());

	beginClassNotification(CM_InvoiceLineDesc, false, Object_Create_Event, Response_Continuous, 0); 

	self.allowDelete := app.isDevelopmentSystem() or app.isSpecial(); // PAR 21142 // the delete has been written. But the invoice line type has many peer to peer inverses so need to check that ERASE method handles this.

	self.doCmbUnitsBuild();
	self.doCmbUOMBuild();	// 31 Jan 2023 navvt20 TFS 56134
	self.doCmbGroupByBuild();				// PAR #36909
	
	self.initMSG();
	self.msgServices.setAvailable(self.myCurrentBank.services, true);
	self.doResize();
	self.msgServices.bubbleHelp := "The available services are determined by the Invoice Line's 'Charge By Units'." &amp; Cr
								&amp; "If a service can not be seen please set the service's 'Calculation Type'";
	self.msgServices.myAvailableListBox.bubbleHelp := self.msgServices.bubbleHelp;							
	self.msgServices.mySelectedListBox.bubbleHelp := self.msgServices.bubbleHelp;	
	
	self.frmTableFilter.setCallbackMethod(INV_InvoiceLineDesc::doFilterTable.name); //25/06/2024	navkc1 CR 64823 Task 64824
end;</source>
    </JadeMethod>
    <JadeMethod name="setupPermissions" id="884813fe-6cbe-4ced-959b-c86c594d00c6">
        <updating/>
        <source>setupPermissions() updating;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if app.getMyUser.canDo(self.myTerminal, self.permissionMaint) then
		self.allowAdd	 := true;
		self.allowDelete := true;
		self.allowUpdate := true;
	else
		self.allowAdd	 := false;
		self.allowDelete := false;
		self.allowUpdate := false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="showHookCodeMaintForm" id="8b3e4312-bebb-4c0b-a773-207c5253a388">
        <updating/>
        <source>showHookCodeMaintForm() updating;
// 24024 CCMS 1151 Aug 2010 cnwjre1 user hook code for invoice quantity, allow edit
// 31451 May 2013 always read-only now - edit it in the calculation type
// 34489 CCMS 1327 hook code for HMS calc types as well
vars
	qtyHook		: Integer;
	hookType	: CM_HookType;
	calcType	: CM_CalculationType;
	source		: String;
	constantText	: String;
	methodName	: String;
	parentClass	: Class;
	formCaption	: String;
begin

	if self.myCurrentObject = null then
		return;
	endif;
	calcType := self.myCurrentObject.CM_InvoiceLineDesc.getCalcType();
	if calcType &lt;&gt; null and
	   calcType.myHookCodeQuantity &lt;&gt; null then
		source := calcType.myHookCodeQuantity.getCurrentJadeCode();
		if calcType.isVoyageCalcType then
			qtyHook := HookType_HMSInvoiceQuantity;
		else
			qtyHook := HookType_InvoiceQuantity;
		endif;
	else
		return;
	endif;

	hookType := app.myRoot.allHookTypes[qtyHook];
	if hookType = null then
		return;
	endif;

	// show the calculation type in the header to make it clear this is not hook code for the invoice line type
	formCaption := "Calculation Type '" &amp; calcType.description  &amp; "'";

	if calcType.isVoyageCalcType then
		constantText := app.getGlobalConstantText(HookTypes, "HookType_HMSInvoiceQuantity");
	else
		constantText := app.getGlobalConstantText(HookTypes, "HookType_InvoiceQuantity");
	endif;
	methodName := constantText.cnEcGetTagValueOfName('hookMethodName');
	parentClass := rootSchema.getSchema(PortSchemaName).getClass(constantText.cnEcGetTagValueOfName('hookClassType'));
	
	app.showHookCodeMaintForm2(hookType, source, true, methodName, parentClass, formCaption, false);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showInvLineTranslations" id="9561c84c-aca2-4153-95fb-e2f793e7254b">
        <source>showInvLineTranslations();
/*

Purpose:			Shows the invoice line translations form

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
31 August 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

vars
	form : INV_InvLineTypeTranslation;
	
begin
	if self.myCurrentObject = null then
		return;
		
	endif;
	
	form := app.loadForm(INV_InvLineTypeTranslation, self.myAssistant.class, false, false, false, self.myTerminal, null).INV_InvLineTypeTranslation;
	
	if form = null then
		return;
		
	endif;

	form.setMyObject(self.myCurrentObject.CM_InvoiceLineDesc);
	form.setParentForm(self);
	form.show();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="566ee5e5-ead8-40f0-ad06-7e894249e8c4">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	size,
	h		: Integer;
	row		: Integer;
	theInvoiceLineDesc, 
	realInv  : CM_InvoiceLineDesc;
	calcType : CM_CalculationType;

begin
	

	theInvoiceLineDesc := obj.CM_InvoiceLineDesc;
	if theInvoiceLineDesc.isTransient() then
		realInv := theInvoiceLineDesc.pxyGetRealObject();
	else
		realInv := theInvoiceLineDesc;
	endif;
	calcType := realInv.getCalcType();
	
	self.tblThumb.rows := 0;
	self.tblThumb.columns := 2;
	self.fldEntDetail.visible := false;
	self.showThumbnailForDef(ETDef_InvMaintInvLineEnt, theInvoiceLineDesc);
	// 24024 show the hook code row only if the calc type has it
	if calcType &lt;&gt; null and
	   calcType.myHookCodeQuantity &lt;&gt; null then
		self.tblThumb.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_QuantityHookCode));
	else
		self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_QuantityHookCode));
	endif;
	/* 31 Jan 2018	NDL	TFS 36900 - No good reason to prohibit editing the VOID one, might want to change its name..
	// 30872 if VOID, no edit or delete
	self.btnEditTV.enabled := not theInvoiceLineDesc.isVoid; */
	self.btnDeleteTV.enabled := not theInvoiceLineDesc.isVoid;

	// handle Service not being shown from 'Hide Thumbnail empty rows' option
	row := self.tblThumb.getRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Service));
	if row &gt; 0 then
		size := theInvoiceLineDesc.services.size;
		h := 16;	// TFS 2074 make the height less as the content gets bigger to minimise the blank space at top and bottom
		if size &gt; 30 then
			h := 13;
		elseif size &gt; 10 then
			h := 14;
		endif;
		self.tblThumb.accessRow(row).height := size * h;
	endif;
	self.doCmbChargesBuild(calcType);
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnEditTV.enabled := false;
		self.btnDeleteTV.enabled := false;
	endif;	

end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="tblEntDetail_dblClick" id="6a6aa9a1-7881-4534-83a5-ad39ae07d576">
        <controlMethod name="CM_EntryTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblEntDetail_dblClick(table: CM_EntryTable input) updating;

vars

begin
	self.doTblEntDetailDClick(table);
end;
</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblEntDetail_queryRowColChg" id="0e3e234a-2dcd-4a4f-9591-8c74447c5d40">
        <controlMethod name="CM_EntryTable::queryRowColChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblEntDetail_queryRowColChg(table: Table input; newSheet: Integer; newRow: Integer; newCol: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2019	jlgndl1	Initial creation	TFS 43687

*/

vars

	value : Real;
	msg : String;

begin

	if self.tblEntDetail.column = 2 then
		if self.tblEntDetail.row = self.tblEntDetail.getRowByName( ETRow_MinimumChargeAmount )
		then
			value := self.tblEntDetail.getCellText( self.tblEntDetail.row, self.tblEntDetail.column ).asRealJMT();
			if value &gt; CM_InvoiceTypeSurchargeExempt.HighValue_15_2 then	// rework 24 Jul 2019	NDL TFS 45509
				msg := app.getErrorString2(ERR_LOWER_GT_UPPER, app.getErrorString(Minimum_charge), CM_InvoiceTypeSurchargeExempt.HighValue_15_2.asStringJMT);
				app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
				return false;
			endif;
		endif;
	endif;

	return true;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="e40aa53c-7ec0-47d5-87ee-7192bca59555">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			Filters the table once the user finishes typing

Parameters:			eventTag	Integer	The event tag triggered

Return Value:		NONE

Date				Who		Reason
14 September 2021	navpw1	Initial creation TFS: 51912

*/

begin
	if eventTag = self.Timer_TableData_Filter then
		self.doFilterTable();
	endif;
	
	inheritMethod(eventTag);
	
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b251638d-c14a-4a3a-8618-1a499173bbbe">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 09 September 2022 08:54:45.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006202, locale);
	btnExportCSVTran.translateCaption(Xlat_0025025, locale);
	btnImportCSVTran.translateCaption(Xlat_0025026, locale);
	btnInvLineTranslations.translateCaption(Xlat_0025027, locale);
	msgServices.translateCaption(Xlat_0002105, locale);
	shtEntDetail.translateCaption(Xlat_0002096, locale);
	shtNarration.translateCaption(Xlat_0002099, locale);
end;</source>
    </JadeMethod>
</GUIClass>
