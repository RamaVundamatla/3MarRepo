    <JadeMethod name="getWeightMovedKgs" id="d98db547-c813-40af-9dfe-4c8d1ee1d4dc">
        <source>getWeightMovedKgs() : Decimal;
/*

Date		Who		Reason
19 March 2014	cnwer1	Initial creation PAR

*/

vars
	ct : CM_CargoType;
	kgValue, volume  : Decimal[14,4];

begin
	if self.myInitQueueTask.ti = null then
		return null;
	endif;
	
	ct:=self.myInitQueueTask.ti.myCargoType;
	if ct.isTrackByWeight then
		kgValue:=self.tblWeight.getConvertedValue();
		
	else
		volume:=self.tblWeight.getConvertedValue();
		kgValue:= volume * self.myInitQueueTask.ti.getDensity;

	endif;
	
	if kgValue = null then
		return self.myInitQueueTask.getWeightForMoveHistory;
	endif;
	return kgValue;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getWeightMovedKgsBySendMsg" id="22fbd120-584c-410d-a610-b079029e9b24">
        <source>getWeightMovedKgsBySendMsg(_weight : Decimal output);
//
