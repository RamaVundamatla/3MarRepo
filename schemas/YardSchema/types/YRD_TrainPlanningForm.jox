        <source>doMnuRemColourWagon( menuItem : MenuItem ) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 July 2009	cnwndl1	Initial creation

*/

vars

	wagon : CM_Wagon;
	wagonColl : ObjectSet;
	
begin

	wagon := menuItem.userObject.CM_Wagon;
	
	create wagonColl transient;
	
	if wagon &lt;&gt; null then
		wagonColl.add(wagon);
	else
		self.getSelectedWagons(wagonColl, null);
	endif;
	
	doWagonColourCodeRemove( wagonColl );
		
epilog

	delete wagonColl;
	
end;</source>
