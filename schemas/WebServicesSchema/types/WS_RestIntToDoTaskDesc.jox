<Class name="WS_RestIntToDoTaskDesc" id="646db7c9-79b2-4785-9a00-3156ee63e2d3">
    <superclass name="WS_RestInternalProxyObject"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <ImplicitInverseRef name="allResourceGroups" id="7c340029-a90c-4b19-9c56-4095dc46133d">
        <memberTypeInverse/>
        <type name="WS_RestIntResourceTypeGroupArr"/>
    </ImplicitInverseRef>
    <PrimAttribute name="code" id="ad5fb8c6-7e52-4cf4-922e-582d3501dd54">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="description" id="1f38ccc1-dc32-4c50-93da-379da1bcb048">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="type" id="d30affd3-cd13-418d-baf3-116c6f28794d">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="100628c2-2a8e-409d-b6bd-505585df142f">
        <updating/>
        <source>setProxyFromObject(_object: Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 June 2023		navma1	Initial creation

*/

vars
	terminal		: CM_Terminal;
	taskCriteria	: CM_TaskCriteria;
	
begin
	inheritMethod(_object);
	self.code 			:= _object.CM_ToDoTaskDesc.code;
	self.description	:= _object.CM_ToDoTaskDesc.description;
	self.type			:= _object.CM_ToDoTaskDesc.type;
	
	terminal := app.myPassport.myTerminal;
	
	if terminal = null then
		return;
	endif;
	
	taskCriteria := _object.CM_ToDoTaskDesc.allTaskCriteria.getAtKeyGeq(terminal, self.code);	// ### TFS 62186 (62196) 02Feb2024 NAVPW1
	
	// ### TFS 62186 (62196) 02Feb2024 NAVPW1
	if taskCriteria = null or terminal.code &lt;&gt; taskCriteria.myTerminal.code or taskCriteria.myToDoTaskDesc = null or taskCriteria.myToDoTaskDesc.code &lt;&gt; self.code then
		return;
	endif;
	// ### TFS 62186 (62196) 02Feb2024 NAVPW1
	
	if taskCriteria &lt;&gt; null then
		self.setResourceGroups(taskCriteria.allAvailableResourceGroups, taskCriteria.allMandatoryResourceGroups);
	endif;
	
end;</source>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setResourceGroups" id="73ca5485-8420-4710-ba52-e1a5c1303bd4">
        <source>setResourceGroups(_availableResourceGroups, _mandatoryResourceGroups : CM_ResourceTypeGroupByCode);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 November 2023	navpw1	Initial creation TFS: 58761 (60739)

*/

vars
	availableResourceGroups,
	mandatoryResourceGroups	: CM_ResourceTypeGroupByCode;
	resourceGroup			: CM_ResourceTypeGroup;
	wsResourceGroup			: WS_RestIntResourceTypeGroup;
	
begin
	availableResourceGroups := _availableResourceGroups;
	foreach resourceGroup in availableResourceGroups do
		create wsResourceGroup transient;
		wsResourceGroup.setProxyFromObject(resourceGroup);
		self.allResourceGroups.add(wsResourceGroup);
		
	endforeach;
	
	mandatoryResourceGroups := _mandatoryResourceGroups;
	foreach resourceGroup in mandatoryResourceGroups do
		foreach wsResourceGroup in self.allResourceGroups do
			if wsResourceGroup.code = resourceGroup.code then
				break;
			endif;
		endforeach;
		
		if wsResourceGroup.code = resourceGroup.code then
			wsResourceGroup.isMandatory := true;
		else
			create wsResourceGroup transient;
			wsResourceGroup.setProxyFromObject(resourceGroup);
			wsResourceGroup.isMandatory := true;
			self.allResourceGroups.add(wsResourceGroup);
		endif;
		
	endforeach;
	
end;</source>
        <Parameter name="_availableResourceGroups" type="CM_ResourceTypeGroupByCode"/>
        <Parameter name="_mandatoryResourceGroups" type="CM_ResourceTypeGroupByCode"/>
    </JadeMethod>
</Class>
