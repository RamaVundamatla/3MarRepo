    <JadeMethod name="doLock" id="f61be175-de19-4b2e-884c-c7ad95c3da92">
        <updating/>
        <source>doLock()  updating;
/*
----------   ----------  --------------------------------------------------
Created:	05 January 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	userCode : String;
begin


	userCode := app.doLogout(true, false);
	self.setLblUserName(null);
	self.setLockingUser(userCode);
	if app.doLock(userCode) then
		self.setLblUserName(app.getMyUserCode);
		self.handlePreShow();
		self.handlePostShowLock();
		self.doResize();
	else
		app.writeLog('Login failed - terminating', LogFATAL);	//26 Nov 2019	NDL	TFS 47053
		terminate;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doLogoutLogin" id="6dca9032-9902-46c3-afc2-3ee274cb30aa">
        <updating/>
        <source>doLogoutLogin() updating;
// ---------------------------------------------------------------------------
// Created:     19 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	app.doLogout(false, true);
	self.setLblUserName(null);
	
	if app.doLogin() then
		self.setLblUserName(app.getMyUserCode);
		self.handlePreShow();
		self.handlePostShow();
		self.doResize();
	else
		app.writeLog('Login failed - terminating', LogFATAL);	//26 Nov 2019	NDL	TFS 47053
		terminate;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doMenuUserToolbarClick" id="d21952b8-f375-4e00-a4b5-317adbe7e427">
        <updating/>
        <source>doMenuUserToolbarClick(_isControlKeyDown : Boolean; _menuUserToolbar : CM_MenuUserToolbar) updating;
// ---------------------------------------------------------------------------
// Created:     25 July 2003		cnwth2	
//
// Purpose:     	
//
// This method name has constant CM_BaseForm.DoMenuUserToolbarClick as it is
// called via a sendMsg from the main toolbar
// ----------   ----------  --------------------------------------------------
// 21/11/25 navsaa30 MTN-36586 MTN | Add a new Portia Assistant icon to the existing MTN application UI
vars
	term				: CM_Terminal;
	systemToolbar		: CM_MenuToolbar;
	user				: CM_User;
	ut		: CM_UserTerminal;
	invalidToolbar : Boolean;
	terminalCode : String;
	customer :String;
	userId :String;
begin
	if _menuUserToolbar = null then
		return;
	endif;
	
	/*
	Date		      Who		Reason
	14 Aug. 2008	cnwdz2	    Par17727 arm an exception handler for invalid object reference.
	*/
	on Exception do app.handleDeletedObject(exception, _menuUserToolbar, invalidToolbar);
	
	user := app.getMyUser();
	systemToolbar := _menuUserToolbar.mySystemToolbar.CM_MenuToolbar; 
	
	/*
	Date		      Who		Reason
	14 Aug. 2008	cnwdz2	    Par17727
	//18/09/2009 cnwdz2 20591
	*/
	if invalidToolbar then 
		app.msgBox(	app.getErrorString(Err_ToolbarNeedReload), null,
									MsgBox_OK_Only+ MsgBox_Exclamation_Mark_Icon);									
		return;
	endif;
	term := self.myCurrentTerminal;

	if term = null then
		term := self.myTerminal;
		if term = null then
			ut := user.allUserTerminals.first;
			if ut &lt;&gt; null then
				term := ut.myTerminal;
			endif;
		endif;
		self.myCurrentTerminal := term;
	endif;
		
	if systemToolbar = null then
		return;
	endif;
	
	userId := app.myPassport.userCode;				//navsaa30 #36586  21/11/25 
	customer := app.myRoot.licenseName;
	terminalCode := term.code;
	//handle special buttons
	if systemToolbar.menuId = CM_MenuToolbar.MENU_ID_EXIT then
		self.unloadForm();
	elseif systemToolbar.menuId = CM_MenuToolbar.MENU_ID_BOT then
		call _shellExecute(null, null, "http://localhost:3000/?customer="&amp;customer&amp;"&amp;terminal="&amp;terminalCode&amp;"&amp;userID="&amp;userId, null, null, 1);			//navsaa30 #36586  21/11/25 
	elseif systemToolbar.menuId = CM_MenuToolbar.MENU_ID_HELP then
		app.showHelp(self.hwnd, HelpFile_UsersGuide);
	elseif systemToolbar.menuId = CM_MenuToolbar.MENU_ID_NAV then
		self.showNavigatorForm();
	elseif systemToolbar.menuId = CM_MenuToolbar.MENU_ID_SEP then
		return;
	elseif systemToolbar.menuId = CM_MenuToolbar.MENU_ID_LOGOFF then
		self.mnuFileLogoff.click(self.mnuFileLogoff);
	else
		//handle with menu action
		systemToolbar.doClick(_isControlKeyDown, user, term);
	endif;
	
end;</source>
        <Parameter name="_isControlKeyDown" type="Boolean"/>
        <Parameter name="_menuUserToolbar" type="CM_MenuUserToolbar"/>
    </JadeMethod>
    <JadeMethod name="doResetFromJMTDefault" id="c8e888d5-eebe-4649-a38c-1f5e82d8b9b2">
