    <JadeMethod name="doSave" id="2cb2bc79-c53b-4b32-b0e4-19cd076a8dcb">
        <updating/>
        <source>doSave(): Boolean updating;
/*
----------   ----------  --------------------------------------------------
Created:	01 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	description 				: String;
	theForm 					: SOP_TableMaintForm;
	proxyDelayTypeGroup			: CM_DelayTypeGroup;
	theDelayTypes				: CM_DelayTypeSet;
	intDelayTypeGroup			: CMIF_DelayTypeGroup;
begin
	
	theForm := self.myForm; 
	description	:= theForm.tblInput1.getValueByName(ETRow_Description).String;

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_DelayTypeGroup transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	proxyDelayTypeGroup := theForm.myProxyObject.CM_DelayTypeGroup;
	create theDelayTypes transient;
	theForm.mulSelect1.getSelected(theDelayTypes);
	
	proxyDelayTypeGroup.setProxy(app.myRoot, description, theDelayTypes);

	/*create intDelayTypeGroup;
	intDelayTypeGroup.myProxyDelayTypeGroup := proxyDelayTypeGroup;
	theDelayType.copy(intDelayTypeGroup.allDelayTypes);*/
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateDelayTypeGroup(proxyDelayTypeGroup, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateDelayTypeGroup(proxyDelayTypeGroup, app.myPassport);
		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return app.myPassport.trxCompletedOK();
epilog
	delete theDelayTypes;
	delete intDelayTypeGroup;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
