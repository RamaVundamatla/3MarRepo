    <JadeMethod name="isRTDeviceValid" id="70e99431-a18e-4881-a42c-9d7aa73579f1">
        <source>isRTDeviceValid(_device: CM_RadioTelemetryDevice input; _computerName : String; _checkAlt: Boolean io): CM_RadioTelemetryDevice;
/*

Purpose:			


Return Value:		


Date		Who		Reason
12 June 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	index : Integer;
begin
	//return inheritMethod(_device, _computer, _checkAlt);
	_checkAlt:=false;
	if not _device.isKindOf(CM_RTDeviceHandHeld) then
		return null;
	endif;
	
	if _device.computerName.toUpper = _computerName.toUpper  then
		return _device;

	else
		if  app.isDevelopmentSystem then
			_checkAlt:=true;	
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_device" type="CM_RadioTelemetryDevice" usage="input"/>
        <Parameter name="_computerName" type="String"/>
        <Parameter name="_checkAlt" type="Boolean" usage="io"/>
        <ReturnType type="CM_RadioTelemetryDevice"/>
    </JadeMethod>
    <JadeMethod name="validateUserPermissions" id="9745ea7a-e50a-4d8a-af27-f1cf12be38a3">
        <updating/>
        <source>validateUserPermissions(_errorStr: String io): Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 April 2010	cnwer1	Initial creation

*/

vars
	allForms : ObjectArray;
begin

	if not inheritMethod(_errorStr) then
		return false;
	endif;

	if app.myMobileAgent &lt;&gt; null then
		
		if not self.findFormsForUser() then
			_errorStr := app.getErrorString1(NotLicensedToPerformAction, app.getLicenseName(Mod_WebApps) );
			return false;
		endif;
	
	else
		if not self.canDoHandHeldGate or
			not self.canDoHandHeldRail or 
			not self.canDoHandHeldShip then
			_errorStr := app.getErrorString1(NotLicensedToPerformAction, app.getLicenseName(Mod_WebApps) );
			return false;
		endif;
	endif;
	
	return true;

epilog
	delete allForms;
end;</source>
        <access>protected</access>
        <Parameter name="_errorStr" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
