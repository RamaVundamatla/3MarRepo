    <JadeMethod name="isColumnOrganiserTable" id="5fba9910-912c-4520-ab34-9d64ea25dfaf">
        <source>isColumnOrganiserTable(conwin: Window): Boolean;
/*
Date		Who		Reason
11 December 2006	cnwer1	Initial creation - PAR#11700

*/
vars

begin
	if inheritMethod(conwin) or self.isAnEDITITable( conwin ) then //cnwgb1 30.9.09 MES 1011 Par 20320 Handle cloned tables
		return true;
