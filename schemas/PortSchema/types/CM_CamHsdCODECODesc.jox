    <JadeMethod name="getMessageType" id="ba184fff-0be9-4d78-aa0b-949b06a6236d">
        <source>getMessageType(_transaction: CM_TITransaction;
				_messageTypeArray: IntegerArray input;
				_camProtocol: CM_CamProtocol;
				_camAgent : CM_CamControllerAgent input);
// ---------------------------------------------------------------------------
// Created:     10 February 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 10/02/2011	cnwcs5		Copied from same method in CM_CamColCODECODesc class
// ---------------------------------------------------------------------------
vars

begin
	_messageTypeArray.clear;
	
	if _transaction.type = TRANS_TYPE_DAMAGED then
		_messageTypeArray.add(CODECO_DAMAGED);
		
	elseif _transaction.type = TRANS_TYPE_REPAIR then
		_messageTypeArray.add(CODECO_REPAIRED);
		
	else
		inheritMethod(_transaction, _messageTypeArray, _camProtocol, _camAgent);
	endif;
epilog

end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_messageTypeArray" type="IntegerArray" usage="input"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
    </JadeMethod>
    <JadeMethod name="ignoreSingleTrxPerFile" id="4aee098f-90d0-400f-8fa8-b882ff4b268e">
        <source>ignoreSingleTrxPerFile():Boolean protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
vars

begin
	// true means output file should NOT check single transaction per file 
	return true;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="makeMessageLOC_GATEIN" id="4e498e27-c9ab-484a-8c3c-3f02e7d23210">
        <source>makeMessageLOC_GATEIN(_camProtocol :CM_CamProtocol; _group :HugeStringArray input;  _activity :Integer; _ti :CM_TrackedItem; _contentsStatus :String) protected;
/*	

Date		Who		Reason
19 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	code, pCode	:String;
begin
	inheritMethod (_camProtocol, _group, _activity, _ti, _contentsStatus);
	
	//get the destination code PAR2836 99/115
	code 	:= _ti.destinationPort;
	pCode 	:= self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, _camProtocol.terminal);
	
	if pCode = null then
		pCode := code;
	endif;
	
	pCode := pCode.trimRight;
	
	if pCode &lt;&gt; null then
		self.makeLOCSegment (_camProtocol, _group, '8', pCode, '139', '6', null, null, null);	// par 27460 09/05/2011 cnwcs5 		
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_contentsStatus" type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageRFF_BN" id="a83df22e-3719-4fdd-bdb9-68d70e2c8839">
        <source>makeMessageRFF_BN(_camProtocol :CM_CamProtocol; _group :HugeStringArray input; _activity :Integer;  _ti :CM_TrackedItem; _transaction :CM_TITransaction)protected;
/*
Purpose:	Refactored code	

Date		Who		Reason
19 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	ref	:String;
begin
	if _activity = CODECO_GATEIN then
		if _camProtocol.isUseCarrierRefForBooking then
			ref := _ti.getCarrierReference;
		else
			ref := _ti.bookingReference.trimRight;						
		endif;
		
		if ref &lt;&gt; null then											
			self.makeRFFSegment (_camProtocol, _group, "BN", ref);	
		endif;														
	endif;

	if _activity = CODECO_GATEOUT then
		if _camProtocol.isUseCarrierRefForBooking then
			ref := _ti.getCarrierReference;
		else
			ref := _ti.deliveryRelease.trimRight;
			if ref = null then
				if _ti.allBulkReleasesReleased.size &gt; 0 then
					ref := _ti.allBulkReleasesReleased.first.code.trimRight;
				endif;
			endif;
		endif;
		
		if ref &lt;&gt; null then											
			self.makeRFFSegment (_camProtocol, _group, "BN", ref);	
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="makeMessageTDT1Segment" id="9cd27494-10b5-44e2-b248-aac67fd67647">
        <source>makeMessageTDT1Segment(_protocol: CM_CamProtocol; _group: HugeStringArray input; _activity :Integer; _transaction: CM_TITransaction; _ti: CM_TrackedItem) protected;
/*
Purpose:	Build TDT+1 segments for HSD CODECO			

Date		Who		Reason
18 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//12 Jun 2015   cnwma1  Par 35260 - JH - TDT segment missing delivery release number
vars
	ref 	:String;
begin

	if _transaction.isCamsRailReceiveType()	or _transaction.isCamsRailReleaseType() then
		// 14/02/2011 cnwcs5 CCMS JMT 1977 /PAR 26531 - include booking reference/release
		if _transaction.isCamsRailReceiveType then
			ref := _ti.bookingReference.trimRight[1:17];
		else
			ref := _ti.deliveryRelease.trimRight[1:17];					  // 12/06/2015 cnwma1 PAR #35260
			if ref = null then											  // 12/06/2015 cnwma1 PAR #35260
				ref := self.getDeliveryRelease(_ti).trimRight[1:17];      // 12/06/2015 cnwma1 PAR #35260
			endif;
		endif;
		
		if _ti.wagonNumber.trimRight &lt;&gt; null then
			self.makeTDT1Segment (_protocol, _group, ref, '2', null, null, null, null, null, null, _ti.wagonNumber.trimRight, null, null, null); // par 27460 09/05/2011 cnwcs5
		else
			if _ti.wagon.trimRight &lt;&gt; null then
				self.makeTDT1Segment (_protocol, _group, ref, '2', null, null, null, null, null, null, _ti.wagon.trimRight, null, null, null); // par 27460 09/05/2011 cnwcs5
			endif;
		endif;
	endif;
	
	if _transaction.isCamsRoadReceiveType() then
		if _ti.vehicle &lt;&gt; "" then
			// 14/02/2011 cnwcs5 CCMS JMT 1977 /PAR 26531 - include booking reference
			self.makeTDT1Segment (_protocol, _group, _ti.bookingReference.trimRight[1:17], '3', null, _ti.carrier.trimRight[1:17], null, null, null, null, _ti.vehicle.trimRight, null, null, null); // par 27460 09/05/2011 cnwcs5
		endif;
	endif;
	
	if _transaction.isCamsRoadReleaseType() then
	   if _ti.releaseVehicle &lt;&gt;  "" then
			ref := _ti.deliveryRelease.trimRight[1:17];					  // 12/06/2015 cnwma1 PAR #35260
			if ref = null then											  // 12/06/2015 cnwma1 PAR #35260
				ref := self.getDeliveryRelease(_ti).trimRight[1:17];      // 12/06/2015 cnwma1 PAR #35260
			endif;
		// 14/02/2011 cnwcs5 CCMS JMT 1977 /PAR 26531 - include delivery release number
		//self.makeTDT1Segment (_protocol, _group, _ti.deliveryRelease.trimRight[1:17], '3', null, _ti.releaseCarrier.trimRight, null, null, null, null, _ti.releaseVehicle.trimRight, null, null, null); // par 27460 09/05/2011 cnwcs5
		  self.makeTDT1Segment (_protocol, _group, ref, '3', null,_ti.releaseCarrier.trimRight[1:17], null, null, null, null, _ti.releaseVehicle.trimRight, null, null, null); 															    // 12/06/2015 cnwma1 PAR #35260
		endif;
	endif;
	// 14/02/2011 cnwcs5 CCMS JMT 1977 /PAR 26531 - include internal moves
	if _transaction.isInternalReceive then
		self.makeTDT1Segment (_protocol, _group, _ti.bookingReference.trimRight[1:17], '3', null, "INTERNAL-MOVE", null, null, null, null, null, null, null, null); // par 27460 09/05/2011 cnwcs5
	endif;
	
	if _transaction.isInternalRelease then
		ref := _ti.deliveryRelease.trimRight[1:17];					  // 12/06/2015 cnwma1 PAR #35260
		if ref = null then											  // 12/06/2015 cnwma1 PAR #35260
			ref := self.getDeliveryRelease(_ti).trimRight[1:17];      // 12/06/2015 cnwma1 PAR #35260
		endif;
		//self.makeTDT1Segment (_protocol, _group, _ti.deliveryRelease.trimRight[1:17], '3', null, "INTERNAL-MOVE", null, null, null, null, null, null, null, null); // par 27460 09/05/2011 cnwcs5
		self.makeTDT1Segment (_protocol, _group, ref, '3', null, "INTERNAL-MOVE", null, null, null, null, null, null, null, null); 									 // 12/06/2015 cnwma1 PAR #35260
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="makeMessages" id="6cb4ac7c-d1ed-429f-a45f-c2b09c9f5a51">
        <source>makeMessages(_trackedItem: CM_TrackedItem; _transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; 
				_camMessage: CM_CamMessage input; _xlVoyageId: String; _terminal: CM_Terminal; _secondTrx : CM_TITransaction);
// ---------------------------------------------------------------------------
// Created:     10 February 2011 by cnwcs5 CCMS JMT 1977/PAR 26531
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 10/02/2011	cnwcs5		Copied from same method in CM_CamColCODECODesc class
//							Include conveyance reference number for internal moves between sub-terminals
// 10/05/2011	cnwcs5		CCMS SCT 2058/PAR 27460 - replace literals with 
//							protocol properties for seperators &amp; delimiters
//15 Nov 2012	cnwrs1		Par 30739 - all DTM 203 should call transDateTime 
// 30/05/2016	cnwdap1		TFS #2061 COPARN/CODECO/COARRI/EDI VGM Updates
// 15/07/2016   cnwma1  TFS #2376 POL - CODECO NAD lines in wrong segment and doubling up on information
// 07/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
//23/08/2017	cnwma1  TFS #5834-PNL - EDI Translation - ISO Code foreign out
// 19 Sep 2017	jlgrs1	TFS 6957 Codeco/Coarri VGM extra details
// 21 Jun 2022	jlizm1	TFS 53754 LNX Different local and server time zones causing incorrect edi outputs
// ---------------------------------------------------------------------------
vars
	ti 				: CM_TrackedItem;
	contentsStatus	: String;	// par 27460 09/05/2011 cnwcs5 
	remarks			: String;	//cnwmc5 - 24 April 2014 - PAR 33635
	isoCode,fIsoCode : String;
	includeVGM : Boolean;
begin
// HSD
	ti 				:= _transaction.myTrackedItem;
	if _camProtocol.useVGM and 
	   _camProtocol.getIncludeExtraVGM and
	   ti &lt;&gt; null and 
	   ti.isWeightCertified and 
	   not ti.isEmpty then		// TFS #2061
		includeVGM := true;
	endif;
	contentsStatus 	:= self.contentsStatusToString(_transaction.contentsStatus, _camMessage.activity, _transaction.type);
	
	if ti.CM_Container.getTemperature &lt;&gt; NULL_TEMPERATURE or ti.allTIHazards.isNotEmpty then
		// Goods Item Details
		self.makeGIDSegment (_camProtocol, _camMessage.group3, 1);	// par 27460 09/05/2011 cnwcs5 
		// TMP Segment
		self.makeTMPSegment (_camProtocol, _camMessage.group3, 2, ti.getTemperature, "CEL");	// par 27460 17/05/2011 cnwcs5 	
		// Split Goods Placement
		self.makeSGPSegment (_camProtocol, _camMessage.group3, ti.id.trimRight, null);		// par 27460 09/05/2011 cnwcs5 	
		// ie Dangerous Goods
		if not _camProtocol.dgsDetailsInGroup14  then							//JIRA-20814
			self.makeMessageHazardsData (ti, _camProtocol, _camMessage.group3);	// par 27460 09/05/2011 cnwcs5 	
		endif;																	//JIRA-20814	
	endif;
	// EQD+ segment
//	self.makeEQDSegment (_camProtocol, _camMessage.group5, "CN", ti.id.trimRight, ti.CM_Container.isoType, '102',
						//	'5', null, self.imExStatusToString(ti), contentsStatus); // par 27460 09/05/2011 cnwcs5 	 //23/08/2017 cnwma1 TFS #5834
	isoCode := ti.CM_Container.isoType;
	fIsoCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode, isoCode, XLATION_TYPE_ISOTYPE_BYOP, _terminal);
	self.makeEQDSegment (_camProtocol, _camMessage.group5, "CN", ti.id.trimRight, fIsoCode, '102',
							'5', null, self.imExStatusToString(ti), contentsStatus); 	 //23/08/2017 cnwma1 TFS #5834
							
	_camMessage.eqdCount := _camMessage.eqdCount + 1;

	if _camMessage.activity = CODECO_DAMAGED and _transaction.type = TRANS_TYPE_DAMAGED then
		self.makeRFFSegment (_camProtocol, _camMessage.group5, "R", null);	// par 27460 09/05/2011 cnwcs5 	

	endif;

	// RFF+BN
	self.makeMessageRFF_BN (_camProtocol, _camMessage.group5, _camMessage.activity, ti, _transaction);	// par 27460 cnwcs5

	// RFF+CN - special18 field
	self.makeMessageRFF_CN (_camProtocol, _camMessage.group5, ti);	// par 27460 cnwcs

	// DTM
	self.makeDTMSegment (_camProtocol, _camMessage.group5, '7', self.transDateTime(_transaction, _camMessage.activity, _camProtocol), '203');	// TFS 53754

	if includeVGM then
		self.makeMessageDTM_VGM(_camProtocol, _camMessage.group5, ti);					// TFS 4492
	endif;

	if _camMessage.activity = CODECO_DAMAGED then
	elseif _camMessage.activity = CODECO_REPAIRED then
	elseif _camMessage.activity = CODECO_GATEIN then
		// LOC segments
		self.makeMessageLOC_GATEIN (_camProtocol, _camMessage.group5, _camMessage.activity, ti, contentsStatus);	// par 27460, cnwcs5
		
	elseif _camMessage.activity = CODECO_GATEOUT then
		// LOC segments
		self.makeMessageLOC_GATEOUT (_camProtocol, _camMessage.group5, _camMessage.activity, ti, contentsStatus);	// par 27460, cnwcs5		
	endif;
	
	// MEA+ segment
	self.makeMEASegmentForTotalWeight(_camProtocol, _camMessage.group5,ti,null); //epr par 37551 TFS 1429 16/2/16
	
	// DIM+ segments
	self.makeMessageDimensionsData (_camProtocol, _camMessage.group5, ti);		// par 27460 09/05/2011 cnwcs5
	
	// FTX+AAI
	self.makeMessageFTX_DeliveryReason (_camProtocol, _camMessage.group5, ti);	// par 27460 cnwcs5	
	if includeVGM then
		self.makeMessageFTX_VGM(_camProtocol, _camMessage.group5, ti);					// TFS 4492
	endif;

	// EQA - the only attached equipment is a reefer generator
	self.makeEQASegment (_camProtocol, _camMessage.group5,'RG', ti);	// par 27460 09/05/2011 cnwcs5
	
	// DAM segment
	if _camMessage.activity = CODECO_DAMAGED and _transaction.type = TRANS_TYPE_DAMAGED then
		remarks := ti.remarks[1:30].escapeEDIInvalidChars(_camProtocol.elementSeparator, _camProtocol.subElementSeparator, _camProtocol.escapeCharacter);	//cnwmc5 - 24 April 2014 - PAR 33635
		self.makeDAMSegment (_camProtocol, _camMessage.group5, '1', null, null, null, ti.remarks[1:30]); // par 27460 09/05/2011 cnwcs5
	endif;
	
	// TDT+1
	self.makeMessageTDT1Segment (_camProtocol, _camMessage.group5, _camMessage.activity, _transaction, ti); // par 27460 09/05/2011 cnwcs5
	
	// TFS #2061 NDA for VGM																			// TFS #2061
	if includeVGM then				// TFS #2061
		self.makeMessageNAD_VGM(_camProtocol, _camMessage.group5, ti);									// 15/07/2016 cnwma1  TFS #2376
	endif;																								// TFS #2061

	// ie Dangerous Goods													//JIRA-20814
	if _camProtocol.dgsDetailsInGroup14  then								//JIRA-20814
		self.makeMessageHazardsData (ti, _camProtocol, _camMessage.group5);	//JIRA-20814
	endif;																	//JIRA-20814
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_xlVoyageId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_secondTrx" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_NAD" id="f200cde2-ca4e-4f15-ad33-5ff000aead47">
        <updating/>
        <source>outputHeader_NAD (_protocol :CM_CamProtocol; _camMessage :CM_CamMessage input; _camTaskHistory :CM_CamTaskHistory input; _coll :HugeStringArray input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	strLine : String;
begin
	strLine := strLine &amp; self.outputFileMessage (_camTaskHistory, self.makeNADSegment (_protocol, null, "SLS", self.getCamISOPortDesc (_protocol), '172', '20'), _coll);

	_camMessage.segmentCount := _camMessage.segmentCount + 1;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
