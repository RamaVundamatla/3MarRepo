        <source>setParent(_parent : CM_Object) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2008	conkc1	Initial creation

*/

vars

begin
	myParent := _parent;
epilog

end;</source>
        <Parameter name="_parent" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setUpdateTimestamp" id="c2c34482-0e43-4a33-a299-ac1a360620bb">
        <updating/>
        <source>setUpdateTimestamp() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2008	conkc1	Initial creation

*/

vars

begin
	self.updateTimestamp := app.serverTimestampAtTrxStart;
epilog

