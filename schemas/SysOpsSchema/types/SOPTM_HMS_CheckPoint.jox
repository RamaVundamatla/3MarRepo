    <JadeMethod name="loadDataForFirstTime" id="4e4b5ccf-bd08-4c96-9d13-0bf2a507a91c">
        <updating/>
        <source>loadDataForFirstTime() updating;
/* ---------------------------------------------------------------------------
Created:	08 June 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	theForm	: SOP_HMS_TableMaintForm;

begin

	inheritMethod();
	
	theForm	:= self.myForm.SOP_HMS_TableMaintForm;
	
	//PAR19113 June 2009
	theForm.myAssistant.comboBoxHMSRelativeToTide(theForm.tblInput1, ETRow_RelativeToTide, null);
	theForm.myAssistant.comboBoxHMSRelativeToTide(theForm.tblInput1, ETRow_RelativeToTide2, null);
	theForm.myAssistant.comboBoxHMSTideRange(theForm.tblInput1, ETRow_TideRangeReference, null);
	theForm.myAssistant.comboBoxHMSTideRange(theForm.tblInput1, ETRow_TideRangeReference2, null);

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="d2bde10e-a96c-4ce9-a97c-574031d8f375">
        <updating/>
        <source>setControlsForAddEdit() updating;
//-----------------------------------------------------------------------
//	Created:	30 January 2007 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	maintFormObj	: SOP_HMS_TableMaintForm;
	
begin
	inheritMethod();
	maintFormObj	:=	self.myForm.SOP_HMS_TableMaintForm;	

	// cnwdad1 20/03/2007 - Only do this when adding a new entry.
	if maintFormObj.mode = maintFormObj.Mode_Add then // or maintFormObj.mode = maintFormObj.Mode_Update then
		maintFormObj.tblInput1.showRowByName(ETRow_RelativeToTide, false);
		maintFormObj.tblInput1.showRowByName(ETRow_RelativeToTime, false);
		maintFormObj.tblInput1.showRowByName(ETRow_RelativeFromTime, false);
		maintFormObj.tblInput1.showRowByName(ETRow_RelativeToTide2, false);
		maintFormObj.tblInput1.showRowByName(ETRow_RelativeToTime2, false);
		maintFormObj.tblInput1.showRowByName(ETRow_RelativeFromTime2, false);
		maintFormObj.tblInput1.showRowByName(ETRow_MyTimeGapToCheckRegion, false);
		maintFormObj.tblInput1.showRowByName(ETRow_GapBetweenMovements, false);
		maintFormObj.tblInput1.showRowByName(ETRow_GapCheckArrivals, false); //epr par 16514 16/4/08
		maintFormObj.tblInput1.showRowByName(ETRow_GapCheckDepartures, false); //epr par 16514 16/4/08
		maintFormObj.tblInput1.showRowByName(ETRow_TideRangeReference, false);
		maintFormObj.tblInput1.showRowByName(ETRow_TideRangeAmount, false);
		maintFormObj.tblInput1.showRowByName(ETRow_TideRangeReference2, false);
		maintFormObj.tblInput1.showRowByName(ETRow_TideRangeAmount2, false);
		maintFormObj.tblInput1.showRowByName(ETRow_ShipsDepartTimings, false);
		maintFormObj.tblInput1.showRowByName(ETRow_TideState, false); //epr par 16884
		maintFormObj.cmbRegForTimeGap.text := null;
	endif;

	maintFormObj.tblInput1.cnEcResizeContents();
end;</source>
    </JadeMethod>
    <JadeMethod name="setTableFromObjectSpecial" id="d3a93cef-741a-4ced-b392-dec232eece24">
        <updating/>
        <source>setTableFromObjectSpecial(_tbl: CM_EntryTable input; _attrName: String; _row: Integer; _obj: Object): Boolean updating;
//--------------------------------------------------
// Created:	06 September 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_tbl, _attrName, _row, _obj);

	if _attrName = ETRow_RvTideLocation then
		return true;
	endif;	

end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="9add56ed-5359-464a-b564-0108259e9565">
        <updating/>
        <source>setupThumbnailDetails() updating;
// ---------------------------------------------------------------------------
// Created:     25 February 2008 by cnwrs2
//
// Purpose:     

// Changed On   Changed By  Reason
	
// 2 May 2015   cnwdb2      PAR 33977
// ---------------------------------------------------------------------------
vars
	theForm			: SOP_HMS_TableMaintForm;
begin

	inheritMethod();
	theForm := self.myForm.SOP_HMS_TableMaintForm;
	
	theForm.setTblDataEntRows(ETDef_HMSCheckPoint)  ; // cnwdb2 PAR  33977

	theForm.cmbRegForTimeGap.automaticCellControl := true;
	theForm.cmbRegForTimeGap.listCollection(app.myRoot.allHMSHarbourRegions, true, 0);
	theForm.myAssistant.comboBoxHMSTideState(self.myForm.SOP_HMS_TableMaintForm.cmbTideState,null);
	theForm.myAssistant.comboBoxHMSChkPointType(self.myForm.SOP_HMS_TableMaintForm.cmbChkPointType, null); //par 19086 cnwrs1 Mar 2009
	theForm.myAssistant.comboBoxHMSTidalModelDef(self.myForm.SOP_HMS_TableMaintForm.cmbTidalModel, null, null); //par 19086 cnwrs1 Mar 2009
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="5b976b76-7949-44f8-b51b-d99cd93d02b6">
        <updating/>
        <source>showThumbnail(pObj: HMS_CheckPoint) updating;
//--------------------------------------------------
// Created:	23 January 2004 By: cnwgd1
//--------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
22/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
============================================================================*/
vars
	maintFormObj		: SOP_HMS_TableMaintForm;
	tableObj			: CM_EntryTable;
	tidalModelObj		: HMS_TidalModelDefinition;
	
begin
    maintFormObj	:=	self.myForm.SOP_HMS_TableMaintForm;
	
	inheritMethod(pObj);
	tableObj	:=	maintFormObj.tblInput1;

	maintFormObj.myAssistant.comboBoxHMSHarbour(maintFormObj.cmbHarbour, pObj.myHarbour);
	maintFormObj.cmbHarbour.lostFocus(maintFormObj.cmbHarbour);	
	
	//theForm.myAssistant.comboBoxHMSRvTideLocation(theForm.tblInput1, ETRow_RvTideLocation, pObj.getTypeString(), theForm.myHarbour);
	self.myForm.SOP_HMS_TableMaintForm.myAssistant.comboBoxHMSChkPointType(maintFormObj.cmbChkPointType, pObj.checkPointType);
	maintFormObj.tblInput1.setValueByName(ETRow_CheckPointType, app.chkPointTypeEnumToString(pObj.checkPointType));
	
	tidalModelObj	:=	pObj.myTidalModel;
	self.myForm.SOP_HMS_TableMaintForm.myAssistant.comboBoxHMSTidalModelDef(maintFormObj.cmbTidalModel, pObj.checkPointType, tidalModelObj);
	maintFormObj.myAssistant.comboBoxHMSRelativeToTide(tableObj, ETRow_RelativeToTide, pObj.hiLoTideReference);
	maintFormObj.myAssistant.comboBoxHMSRelativeToTide(tableObj, ETRow_RelativeToTide2, pObj.hiLoTideReference2);
	maintFormObj.myAssistant.comboBoxHMSTideRange(tableObj, ETRow_TideRangeReference, pObj.tideRangeReference);
	maintFormObj.myAssistant.comboBoxHMSTideRange(tableObj, ETRow_TideRangeReference2, pObj.tideRangeReference2);

	if tidalModelObj &lt;&gt; null then
		maintFormObj.tblInput1.setValueByName(ETRow_TidalModel, tidalModelObj.description);
	else	
		maintFormObj.tblInput1.setValueByName(ETRow_TidalModel, null);
	endif;
	
	self.jadeCode := null;
	
	if pObj &lt;&gt; null then
		if pObj.checkPointType = HMS_ChkPointType_HiLo then
			maintFormObj.tblInput1.setValueByName(ETRow_RelativeFromTime, pObj.hiLoRelativeTimeFrom);
			maintFormObj.tblInput1.setValueByName(ETRow_RelativeToTime, pObj.hiLoRelativeTimeTo);
			maintFormObj.tblInput1.setValueByName(ETRow_RelativeFromTime2, pObj.hiLoRelativeTimeFrom2);
			maintFormObj.tblInput1.setValueByName(ETRow_RelativeToTime2, pObj.hiLoRelativeTimeTo2);
			
		elseif pObj.checkPointType = HMS_ChkPointType_TimeGap then
			maintFormObj.cmbRegForTimeGap.listObject := pObj.myTimeGapToCheckRegion;
			maintFormObj.tblInput1.setValueByName(ETRow_MyTimeGapToCheckRegion, maintFormObj.cmbRegForTimeGap.text);
			maintFormObj.tblInput1.setValueByName(ETRow_GapBetweenMovements, pObj.gapTimeDifference);
			maintFormObj.tblInput1.setValueByName(ETRow_GapCheckArrivals, pObj.gapCheckArrivals); //epr par 16514 16/4/08
			maintFormObj.tblInput1.setValueByName(ETRow_GapCheckDepartures, pObj.gapCheckDepartures);//epr par 16514 16/4/08
		//jlgka1 TFS 45620 --&gt;		
		/*elseif pObj.checkPointType = HMS_ChkPointType_TideRange then
			maintFormObj.tblInput1.setValueByName(ETRow_TideRangeAmount, pObj.tideRangeAmount);
			maintFormObj.tblInput1.setValueByName(ETRow_TideRangeAmount2, pObj.tideRangeAmount2);		
		elseif pObj.checkPointType = HMS_ChkPointType_ShipsDepart then
			maintFormObj.tblInput1.setValueByName(ETRow_ShipsDepartTimings, pObj.shipDepartTimings); // temp to avoid reorg
		
		elseif pObj.checkPointType = HMS_ChkPointType_UserHookCode then
			self.jadeCode := pObj.getJadeCode();
		
		elseif pObj.checkPointType = HMS_ChkPointType_TideState then
			maintFormObj.tblInput1.setValueByName(ETRow_TideState, pObj.getTideStateString); 
			self.myForm.SOP_HMS_TableMaintForm.myAssistant.comboBoxHMSTideState(maintFormObj.cmbTideState,pObj.tideState);//21/09/2009 cnwdz2 par19858
			*/
		//jlgka1 TFS 45620 &lt;--	
		endif;
	endif;
	
	// cnwdad1 20/03/2007 - Added the following method, and commented out show/hide of rows above.
	maintFormObj.showTidalTypeRows(pObj.checkPointType);
	
	maintFormObj.tblInput1.cnEcResizeContents();
end;</source>
        <Parameter name="pObj" type="HMS_CheckPoint"/>
    </JadeMethod>
</Class>
