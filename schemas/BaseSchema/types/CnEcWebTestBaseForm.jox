    <JadeMethod name="doStartTest" id="afa4b8d1-9243-4d3d-a0d3-932c8768c1ee">
        <source>doStartTest() protected;
// --------------------------------------------------------------------------------
// Created:		05 June 2000 by cnwdad1
//
// Purpose:		Initiates all of the selected Web Tests.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	testController	: CnEcWebTestController;
	webTestArray	: CnEcWebTestArray;
	webTest			: CnEcWebTest;
	listbox			: ListBox;
	testIndex		: Integer;
	testCount		: Integer;

begin
	create testController transient;
	create webTestArray transient;

	listbox		:=	lstRunSelected;
	testCount	:=	listbox.listCount();

	foreach testIndex in 1 to testCount do
		webTest	:=	listbox.itemObject[testIndex].CnEcWebTest;
		webTestArray.add(webTest);
	endforeach;

	testController.addWebTests(webTestArray);
	testController.doRunTest();
epilog
	delete testController;
	delete webTestArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getFilePathName" id="cc0f5c2b-8362-480d-b501-7f01231a1778">
        <source>getFilePathName(pCaption:String; pPathName:String io);
// --------------------------------------------------------------------------------
// Created:		07 July 2000 by cnwdad1
//
// Purpose:		Initiates a folder browser form, and returns the directory selected
//				by the user.
//
// Parameters:	pCaption - The browser dialog title.
//				pPathName - The default path to start browsing, and is updated with
//					the selected directory path name.
//
// Returns:		The selected directory path name, in the IO parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theFolder	: FileFolder;

begin
	create theFolder transient;

	pPathName	:=	theFolder.browseForFolder(pCaption, pPathName);
epilog
	delete theFolder;
end;</source>
        <Parameter name="pCaption" type="String"/>
        <Parameter name="pPathName" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getShareLockClientList" id="1b058eff-91ad-4b83-b475-009caf11f548">
        <source>getShareLockClientList(pTheObject:Object):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		14 June 2000 by cnwdad1
//
// Purpose:		Attempts to get a share lock on the requested object (a Node or
//				Process in this context).
//
//				If the objct is no longer valid (ie. it's been deleted, such as
//				when the remote clients are being closed down, then the object
//				will be ignored.
//
// Parameters:	pTheObject - The objct on which to get the share lock.
//
// Returns:		Boolean - True if we got the lock, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	isLocked	: Boolean;

begin
	on Exception do self.doLockExceptionClientList(exception);
	isLocked	:=	false;

	while not tryLock(pTheObject, Share_Lock, Transaction_Duration, LockTimeout_Server_Defined) do
 		// Wait 1 second and try again...
 		process.sleep(1000); 
 	endwhile; 

	isLocked	:=	true;
epilog
	return isLocked;
end;</source>
        <access>protected</access>
        <Parameter name="pTheObject" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSpawnInfoFat" id="82214017-0dbd-4a91-9810-bb33514bee09">
        <source>getSpawnInfoFat(pCopies:Integer; pPathBinaries:String; pPathIni:String):Binary protected;
// --------------------------------------------------------------------------------
// Created:		07 July 2000 by cnwdad1
//
// Purpose:		Assembles a binary image of fixed-length "parameters" required when
//				spawning a new web test via Standard (fat) Client.
//
// Parameters:	pCopies - The number of clients to spawn.
//				pPathBinaries - The directory name where the JADE binaries are located.
//				pPathIni - The directory name where the JADE INI file is located.
//
// Returns:		A binary image of the assembled parameters.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	spawnData		: Binary[513];

	// Fixed length strings are used because the String::padblanks will still return
	// the entire string even if it's longer than the requested pad length.

	copyCount		: String[3];
	binariesPath	: String[255];
	iniFilePath		: String[255];

begin
	copyCount		:=	pCopies.String.padLeadingZeros(3);
	binariesPath	:=	pPathBinaries.padBlanks(255);
	iniFilePath		:=	pPathIni.padBlanks(255);

//	spawnData		:=	copyCount.Binary &amp; binariesPath.Binary &amp; iniFilePath.Binary;
	spawnData		:=	copyCount.asANSI(0) &amp; binariesPath.asANSI(0) &amp; iniFilePath.asANSI(0) ;// 9/3/16  cnwns1 PAR 36286 unicode version
epilog
	return spawnData;
end;</source>
        <access>protected</access>
        <Parameter name="pCopies" type="Integer"/>
        <Parameter name="pPathBinaries" type="String"/>
        <Parameter name="pPathIni" type="String"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getSpawnInfoThin" id="90181c05-49cc-411b-971f-b3ed5f6c135a">
        <source>getSpawnInfoThin(pCopies:Integer io; pAppServerPort:String):Binary protected;
// --------------------------------------------------------------------------------
// Created:		07 July 2000 by cnwdad1
//
// Purpose:		Assembles a binary image of fixed-length "parameters" required when
//				spawning a new web test via Thin Client.
//
// Parameters:	pCopies - The number of clients to spawn.
//				pPathBinaries - The directory name where the JADE binaries are located.
//				pPathIni - The directory name where the JADE INI file is located.
//
// Returns:		A binary image of the assembled parameters.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	spawnData		: Binary[8];

	// Fixed length string are used because the String::padblanks will still return
	// the entire string even if it's longer than the requested pad length.

	copyCount		: String[3];
	appServerPort	: String[5];

begin
	copyCount		:=	pCopies.String.padLeadingZeros(3);
	appServerPort	:=	pAppServerPort.padBlanks(5);

	spawnData		:=	copyCount.asANSI(0) &amp; appServerPort.Binary;// 9/3/16  cnwns1 PAR 36286 unicode version
epilog
	return spawnData;
end;</source>
        <access>protected</access>
        <Parameter name="pCopies" type="Integer" usage="io"/>
        <Parameter name="pAppServerPort" type="String"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
