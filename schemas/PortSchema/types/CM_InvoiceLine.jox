        <source>zzGetDebtorConsol() : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2023	navpw1	Initial creation TFS: 60965

*/

vars
	mapDIL						: CM_InvoiceLineDesc;
	currentInvoiceLineDesc		: CM_InvoiceLineDesc;
	consolidatedDebtorInvLineD	: CM_InvoiceLineDescByNarrDict;
	
begin
	// CCMS 1125
	currentInvoiceLineDesc := self.invoiceLineDesc;
	
	if currentInvoiceLineDesc = null then
		return null;
	endif;
	
	consolidatedDebtorInvLineD := currentInvoiceLineDesc.allConsolidatedDebtorInvLineD;
	
	if consolidatedDebtorInvLineD.isEmpty then
		return null;
	endif;
	
	mapDIL := consolidatedDebtorInvLineD.first;
	if mapDIL &lt;&gt; null then
		return mapDIL.narration;
		
	endif;
	
	return null;
	
end;</source>
