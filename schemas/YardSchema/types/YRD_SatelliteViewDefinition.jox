    <JadeMethod name="addArea" id="8d5663fd-47ba-492d-afc8-fb1b1704e5a3">
        <updating/>
        <source>addArea( _area : CM_TerminalArea ) : Frame updating;

/*

Purpose:		Create proxy and display for given area.

Parameters:		

Return Value:	Frame created for area.


Date				Who		Reason
02 September 2008	consw1	Initial creation

*/

vars
	clonedFrame, 
	frame					: Frame;		// cnwmc5 - 20 May 2016 - TFS 2006
	origin					: Point;
	proxyAreaViewPosition, 
	avp						: CM_TerminalAreaViewPosition;	// cnwmc5 - 20 May 2016 - TFS 2006
	x1, x2, y1, y2			: Real;
	xOffset, yOffset		: Integer;
	obj 					: Object;		// cnwmc5 - 20 May 2016 - TFS 2006
	complete 				: Boolean;		// cnwmc5 - 20 May 2016 - TFS 2006

begin
	//  Calculate offset to allow for scrolling within the viewable display
	self.frmScrollingMain.parent.windowToScreen( x1, y1 );
	self.frmScrollingMain.windowToScreen( x2, y2 );
	xOffset := scrollingMainOffset.x + (x1 - x2).Integer;
	yOffset := scrollingMainOffset.y + ( y1 - y2).Integer;

	create proxyAreaViewPosition transient;
	proxyAreaViewPosition.setTerminalArea(_area);
	proxyAreaViewPosition.setTerminalAreaView(self.myProxyAreaView);
	proxyAreaViewPosition.setLabelDisplays(true,true,true,true,false,false);
	
	origin.setX( 1 + xOffset );
	origin.setY( 1 + yOffset );
	//proxyAreaViewPosition.setOrigin(origin);		// cnwmc5 - 20 May 2016 - TFS 2006
	
	// cnwmc5 - 20 May 2016 - TFS 2006 - check position hasn't been taken...
	while true do
		complete := true;
		foreach obj in self.allAreaFrames do
			if obj.isKindOf(Frame) then
				frame := obj.Frame;
				if frame.userObject &lt;&gt; null and frame.userObject.isKindOf(CM_TerminalAreaViewPosition) then
					avp := frame.userObject.CM_TerminalAreaViewPosition;
					if avp.origin.x = origin.x then
						origin.setX(origin.x + 10);
						complete := false;
						break;
					endif;
				endif;
			endif;
		endforeach;
		
		if complete then
			break;
		endif;
	endwhile;
	proxyAreaViewPosition.setOrigin(origin);
	// cnwmc5 - 20 May 2016 - TFS 2006 - end
	
	clonedFrame := self.cloneAreaFrame( proxyAreaViewPosition );
	self.drawArea( clonedFrame );

	return clonedFrame;

epilog

end;</source>
        <Parameter name="_area" type="CM_TerminalArea"/>
        <ReturnType type="Frame"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="b16b5504-d604-4550-aa4a-5e1076afd98e">
        <updating/>
        <source>addToolbarControls() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
01 September 2008	consw1	Initial creation

*/

vars
	toolbarObj	: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbarObj	:=	self.frmToolbar;	
	toolbarObj.addButton(self.btnSearch, CMUI_Toolbar.Control_Alignment_Left); //epr par 19083 CCMS 1109
	toolbarObj.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);
	toolbarObj.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);

	toolbarObj.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbarObj.addButton(self.btnFlipV, CMUI_Toolbar.Control_Alignment_Left);
	toolbarObj.addButton(self.btnFlipH, CMUI_Toolbar.Control_Alignment_Left);
	toolbarObj.addButton(self.btnRotate, CMUI_Toolbar.Control_Alignment_Left);	
	toolbarObj.addButton(self.btnAlignTop, CMUI_Toolbar.Control_Alignment_Left);
	toolbarObj.addButton(self.btnAlignLeft,CMUI_Toolbar.Control_Alignment_Left);
	toolbarObj.addButton(self.btnProperties, CMUI_Toolbar.Control_Alignment_Left);
		
	toolbarObj.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbarObj.addButton(self.btnAreaNew, CMUI_Toolbar.Control_Alignment_Left);
	toolbarObj.addButton(self.btnAreaDelete, CMUI_Toolbar.Control_Alignment_Left);

	toolbarObj.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

end;</source>
        <access>protected</access>
