    <JadeMethod name="getMyTerminal" id="5c208629-eaf4-464d-a2fa-8cc634ce8d46">
        <source>getMyTerminal(): CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 July 2016	cnwns1	Initial creation
//TFS2304 cnwns1	15/7/16	Multi-timezone issue - Date Picker defaults to System Date
*/

vars

begin
	return self.myTerminal;

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getToday" id="8a86b8c7-26cb-43c4-85ef-77d0269d446d">
        <source>getToday():Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 July 2016	cnwns1	Initial creation
//TFS2304 cnwns1	15/7/16	Multi-timezone issue - Date Picker defaults to System Date
*/

vars

begin
	return self.systemToLocalTime(app.actualTimeServer()).date();
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="setMyTerminal" id="bc9c8fa7-d673-4ace-9762-c00f09873240">
        <updating/>
        <source>setMyTerminal(_terminal : CM_Terminal)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 July 2016	cnwns1	Initial creation
//TFS2304 cnwns1	15/7/16	Multi-timezone issue - Date Picker defaults to System Date
*/

vars

begin
	if _terminal &lt;&gt; null then
		self.myTerminal := _terminal;
	endif;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="48aefbd0-b8b1-41c2-a40c-014ed5fcd50e">
