    <JadeMethod name="checkFilterOK" id="e36fedfd-bb09-4e84-987b-e68aa8370dc3">
        <source>checkFilterOK(_ti: CM_TrackedItem): Boolean;
//----------------------------------------------------------------
//	Created:	14 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	aOK		: Boolean;
	aTask	: CM_ToDoTask;
	ti		: CM_TrackedItem;
	taskDesc: CM_ToDoTaskDesc;
begin	

	ti := _ti;
	if self.lstVoyage.allSelectedObjects.isNotEmpty
	and (not self.lstVoyage.allSelectedObjects.includes(ti.myVoyage)) then
		//voyage doesn't match - don't include
		return false;
	endif; 

	if self.lstOperator.allSelectedObjects.isNotEmpty
	and (not self.lstOperator.allSelectedObjects.includes(ti.myOperator)) then
		//operator doesn't match - don't include
		return false;
	endif;	 
	
	if self.lstTermArea.allSelectedObjects.isNotEmpty
	and (not self.lstTermArea.allSelectedObjects.includes(ti.myTerminalArea)) then
		//area doesn't match - don't include
		return false;
	endif;	 
	
	if self.lstTasks.allSelectedObjects.isNotEmpty then
		aOK := false;
		foreach aTask in ti.allToDoTasksToDo do : taskLoop
			taskDesc := aTask.getMyToDoTaskDesc;
			if self.lstTasks.allSelectedObjects.includes(taskDesc) then
				aOK := true;	//at least one match - include this
				break taskLoop;
			endif;
		endforeach;
		if not aOK then
		//no tasks match - don't include
			return false;
		endif;
	endif;	 

	return true;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="6a9925e7-ee8c-4003-9c43-6f00839a3fe8">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	create self.myTIQueryFilter transient;
	self.permissionView  := PmAdmToDoTaskListView;
	self.permissionMaint := PmAdmToDoTaskListMaint;
	self.helpFileName := HelpFile_Yard;

end;</source>
    </JadeMethod>
    <JadeMethod name="displaySelectorResults" id="322dae59-4264-4e73-9b7b-261d741f9ddb">
        <updating/>
        <source>displaySelectorResults(_resultCollection: Collection; _mode: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     28 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _mode &gt; TI_CargoType_Max then
		app.msgBox('The Pack/Unpack screen cannot display item for the selected mode (' &amp; _mode.String &amp; ')', 'Invalid selector mode', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	self.myTIQueryFilter.allQryTrackedItems.clear();
	if _resultCollection.isEmpty then
		return;
	endif;
	
	_resultCollection.copy(self.myTIQueryFilter.allQryTrackedItems);
	self.frmQuery.visible := false;

	self.displayTIs(self.myTIQueryFilter.allQryTrackedItems);

	
	self.btnAddComplete.enabled := true;
	self.btnRemoveTasks.enabled := true;


end;</source>
        <Parameter name="_resultCollection" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="displayTIs" id="21a2d5cb-cbf9-49af-b311-826a88c56538">
        <updating/>
        <source>displayTIs(_tiArray : CM_TIArray) updating,  protected;
// ---------------------------------------------------------------------------
// Created:     09 April 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
//29 Jul 2022	navvt20 	Bug 54199: EUP - Tables with Operator/Stevedore not adhering to the configuration
vars
	taskArray				: CM_ToDoTaskArray;
	numItemsLoaded,
	totalItems,
	numColsOld,
	numColsSimple,
	numColsComplex,
	col,
	row,
	idx						: Integer;
	theDataLine				: String;
	tbl						: CM_DataTable;
	ti						: CM_TrackedItem;
	operatorCode			: String;		//29.07.2022 navvt20 TFS 54199
	
begin
	//### NOTE. ToDoTask TYPES can be deleted even though there are todotasks existing. There is no link.
	// ###			If A ToDoTask type has been deleted, AND some of the TIs displayed have todo tasks set
	//				from it then the column object will be null and only the TIs using that todo task will have a check box..
	//				Deleted todo task type columns are added automatically. So we must init each time.
	self.tblInfo.rows := 0;
	self.initTableData(null);
	self.endNotificationForSubscriber(self);

	totalItems := _tiArray.size;
	self.modalDialogReturnValue := self.ModalDialogReturn_Null;
	self.modalDialogShow(null, 'Cancel', null, null,
						'Loading data into table',
						"Loaded " &amp; numItemsLoaded.String &amp; ' of ' &amp; totalItems.String &amp; " Items");
	self.modalDialogProgressBar(numItemsLoaded);
	
	tbl := self.tblData;
	numColsOld := tbl.columns;
	tbl.rows := tbl.fixedRows;
	foreach ti in _tiArray do
		self.beginNotification(ti, Object_Update_Event, Response_Continuous , null);
		// ADD a line with just the ID and empty columns for each tas
		//theDataLine := ti.id &amp; Tab &amp; ti.locationId &amp; Tab &amp; ti.voyageCode &amp; Tab &amp; ti.operatorCode;		//29.07.2022 navvt20 TFS 54199
		//Start 29.07.2022 navvt20 TFS 54199
		if app.myRoot.getConfig(ComboByNameOperator).Boolean then
			operatorCode := ti.operatorDescription;
		else
			operatorCode := ti.operatorCode;
		endif;
		theDataLine := ti.id &amp; Tab &amp; ti.locationId &amp; Tab &amp; ti.voyageCode &amp; Tab &amp; operatorCode;
		//End 29.07.2022 navvt20 TFS 54199
		foreach idx in self.TaskStartColumn to numColsOld do
			theDataLine := theDataLine &amp; Tab; // &amp; "false" ;
		endforeach;
		row := tbl.addItem(theDataLine);
		tbl.accessRow(row).itemObject := ti;
		tbl.accessCell(row, 1).fontBold := false;
		tbl.accessedCell.backColor := self.colorHeadingColumn;
		foreach col in self.TaskStartColumn to numColsOld do
			tbl.accessCell(row, col).inputType := Table.InputType_CheckBox;
		endforeach;
		
		self.populateRowWithTasks(tbl, ti.allToDoTasksCompleted, row, false);
		self.populateRowWithTasks(tbl, ti.allToDoTasksToDo, row, true);
		numItemsLoaded := numItemsLoaded + 1;	
		if numItemsLoaded mod 100 = 0 then
			self.modalDialogUpdateInfo("Loaded " &amp; numItemsLoaded.String &amp; ' of ' &amp; totalItems.String &amp; " Items");
			self.pbProgressBar.partsDone := numItemsLoaded;
			self.frmModalDialog.refreshNow;
			self.btnModalDefault.doWindowEvents(0);
			if self.modalDialogReturnValue = self.ModalDialogReturn_Default then
				// Cancel
				break;
			endif;
		endif;
	endforeach;
	
	self.doShowHideUnusedAndFilterCols(); //02 Oct 2015	NDL	Par 37011

epilog
	self.frmModalDialog.visible := false;
end;</source>
        <access>protected</access>
        <Parameter name="_tiArray" type="CM_TIArray"/>
    </JadeMethod>
