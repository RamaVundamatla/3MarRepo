    <JadeMethod name="trxWebTestCreate" id="d4052b68-48df-41c4-9c1c-7c34446fd443">
        <updating/>
        <source>trxWebTestCreate(pTestName:String;
				pTestCycles:Integer;
				pIsStopOnMessageFail:Boolean;
				pIsCloneFields:Boolean;
				pCommonFieldColl:CnEcWebTestCommonFieldDict;
				pWebTest:CnEcWebTest output):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Transaction method to create a Web Test.
//
// Parameters:	The properties of the object to be created.
//              The newly created object is returned in the output parameter.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Always initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// Start the transaction.
	beginTransaction;

	// Perform the operation.
	pWebTest	:=	app.myBaseRoot.createWebTest(pTestName, pTestCycles, pIsStopOnMessageFail);

	if pWebTest &lt;&gt; null and pIsCloneFields then
		pWebTest.doCloneCommonFields(pCommonFieldColl);
	endif;

	// If the "create" raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error code to the caller (which will be zero if no errors)
	return self.lastError;
end;</source>
        <Parameter name="pTestName" type="String"/>
        <Parameter name="pTestCycles" type="Integer"/>
        <Parameter name="pIsStopOnMessageFail" type="Boolean"/>
        <Parameter name="pIsCloneFields" type="Boolean"/>
        <Parameter name="pCommonFieldColl" type="CnEcWebTestCommonFieldDict"/>
        <Parameter name="pWebTest" type="CnEcWebTest" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
