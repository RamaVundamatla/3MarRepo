    <JadeMethod name="doDelete" id="4affc3b3-e63f-45fe-bb29-2426aa78b538">
        <updating/>
        <source>doDelete(): Boolean updating;
//--------------------------------------------------
// Created:	20 August 2003 By: cnwgd1
//--------------------------------------------------
vars
	tiSet,
	tisWithWarnSet : CM_TISet;	
	result	: Integer;
begin

	//04 Nov 2013	NDL	Par 32837
	if not app.getMyUser.canDo( self.myTerminal, PmAdmCargoDelete ) then
		app.raiseCMException1(NoPermission, app.getErrorString(Logically_delete_cargo), null, null);
		return false;
	endif;
		
	app.mousePointer := MousePointer_HourGlass;
	
	create tiSet transient;
	if self.allowMultiSelectDelete = false then
		tiSet.add(self.myCurrentObject.CM_TrackedItem);
	else
		self.tblData.allSelectedObjects.copy(tiSet);
	endif;
	create tisWithWarnSet transient;

	while true do
		app.myTrxDA.trxDeleteTrackedItems(tiSet, tisWithWarnSet, true, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Delete LDA', app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnSkipErr);
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				// only reprocess the wles that had warnings.
				tiSet.clear;
				tisWithWarnSet.copy(tiSet);
				tisWithWarnSet.clear;	
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;	


epilog
	delete tisWithWarnSet;
	delete tiSet;
	self.myCurrentObject := null;
	app.myDraggedTrackedItem := null;
	
	app.mousePointer := MousePointer_Default;
	return app.myPassport.trxCompletedOK;	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDevCreateNewCargo" id="7af190eb-da87-4311-90ff-04ee7dff20da">
        <source>doDevCreateNewCargo();
/*
Purpose:			
Date		Who		Reason
10 January 2013	cnwab1	Initial creation
*/

vars

	numItems : Integer;
	is40 : Boolean;
	ct : CM_CargoType;
	ctType : String;
	mess, mess2 : String;
begin
	if not (self.filterTerminalArea.isKindOf(CM_BlockStack) or self.filterTerminalArea.isKindOf(CM_IrregularBlockArea)) then 
		return;
	endif;
	
	if (self.filterTerminalArea.isKindOf(CM_IrregularBlockArea) and not self.filterYardLocation.isKindOf(CM_IrregularBlockController) ) then
		app.msgBox("Please supply a GC Location", "No Location", MsgBox_OK_Only);
		return;
	endif;
	
	//epr TFS 47132 17/12/19
	if (  not self.filterTerminalArea.isKindOf(CM_BlockStack) ) then
		app.msgBox("Please supply a Block Stack", "No Location", MsgBox_OK_Only);
		return;
	endif;
	
	if app.msgBox("Create Containers (Yes) or GC (No)", "Cargo Type", MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
		is40 := app.msgBox("Create 40 foot?", "Quick Cargo", MsgBox_Yes_No) = MsgBox_Return_Yes;
		if is40 then
			mess := "40 Foot";
		else
			mess := "20 Foot";
		endif;

		numItems := 10;
		read numItems;
		mess2 := self.filterTerminalArea.id;

	
		if app.msgBox("Create " &amp; numItems.String &amp; " Quick Cargo " &amp; mess &amp; " Containers in " &amp; mess2  &amp; "?", "Quick Container Cargo", MsgBox_Yes_No) = MsgBox_Return_Yes then
	
			self.filterTerminalArea.CM_BlockStack.createQuickCargo(numItems, is40);

			if app.myPassport.hasErrorsOrWarnings() then
				app.myPassport.allErrorWarnings.inspectModal();
			endif;
			return;
		endif;
	else
		numItems := 10;
		read numItems;

		ct := app.myRoot.getFirstCargoTypeForTerminal(self.myTerminal,CM_BreakBulkGeneric.name);
		if ct &lt;&gt; null then
			ctType := ct.abbreviation;
		else
			ctType := "CANNONBALL";
		endif;

		read ctType;
		
		ct := app.myRoot.getCargoTypeFromAbbrev(ctType);
		
		if ct &lt;&gt; null then
			mess := ct.description;
		else
			app.msgBox("'" &amp; ctType &amp; "' Is An Invalid Cargo Type","ERROR",MsgBox_OK_Only);
			return;
			mess := "GC";
		endif;
		
		mess2 := self.filterTerminalArea.id;
		if self.filterYardLocation.isKindOf(CM_IrregularBlockController) then
			mess2 := self.filterYardLocation.getFullId();
		endif;
		
		if app.msgBox("Create " &amp; numItems.String &amp; " Quick Cargo " &amp; mess &amp; " Items " &amp; mess2 &amp; "?", "Quick GC Cargo", MsgBox_Yes_No) = MsgBox_Return_Yes then
			
			if self.filterTerminalArea.isKindOf(CM_BlockStack) then
				self.filterTerminalArea.CM_BlockStack.createQuickCargoGC(numItems, ct);
			elseif self.filterTerminalArea.isKindOf(CM_IrregularBlockArea) then
				self.filterTerminalArea.CM_IrregularBlockArea.createQuickCargoGC(self.filterYardLocation.CM_IrregularBlockController, numItems, ct);
			endif;

			if app.myPassport.hasErrorsOrWarnings() then
				app.myPassport.allErrorWarnings.inspectModal();
			endif;
			return;
			
		endif;

	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doLoadStockAdjustmentForm" id="77fdad79-0947-4099-a222-f6f37a5711e2">
