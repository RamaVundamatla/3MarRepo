    <JadeMethod name="init" id="c4d189de-5c6a-4a5e-a222-91b11ced7e7f">
        <updating/>
        <source>init(	_myBank 	   : CM_Bank;
		_myTrackedItem : CM_TrackedItem;
		_effDate 	   : Date;
		_isInwardGate  : Boolean
		) updating;

/*

Purpose:			Initialise

Parameters:			

Return Value:		


Date			Who		Reason
25 July 2012	cnwndl1	Initial creation	Par 29968
18 Oct 2024 	navlw1	JIRA-33107: Invoice Logging Use Levels
20 Feb 2025		navlw1	JIRA-33752: MTN | Cash Configuration Criteria Priority Issue
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	proformaCrit : CM_ProformaTransactionCriteria;
	canLogExtra	 : Boolean;	//26.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//26.02.2025 navah1	#34141
	self.allProformaCriteria.clear();
	self.selectedTrxCriteria 		  := null;
	self.myDebtor 					  := null;
	self.ignoreProformaForRoadRelease := _isInwardGate;
	self.effectiveDate                := _effDate;
	self.myTrackedItem 				  := _myTrackedItem;
	self.myBank 					  := _myBank;
	if canLogExtra then	//26.02.2025 navah1	#34141
		app.invLog(" ", LogINFO.String);
		app.invLog("** Create pro forma invoice lines for " &amp; self.myTrackedItem.cargoBOLTypeDescr &amp; " " &amp; self.myTrackedItem.id &amp; " **", LogINFO.String);
		app.invLog(" ", LogINFO.String);
		app.invLog("Find the Estimated Charges", LogINFO.String);
	endif;
	if self.myBank &lt;&gt; null then
		if self.myBank.allProformaCriteria &lt;&gt; null and not self.myBank.allProformaCriteria.isEmpty then
			self.myBank.allProformaCriteria.copy( self.allProformaCriteria );
		else
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("Business unit has no pro forma criteria defined", LogINFO.String);
			endif;
		endif;
	else
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("No business unit so no pro forma criteria", LogINFO.String);
		endif;
	endif;
	
	// START navlw1 #JIRA-33752 20/02/2025
	foreach proformaCrit in self.allProformaCriteria discreteLock, reversed do 
		if proformaCrit.type &lt;&gt; CM_ProformaTransactionCriteria.TypeCargo then 
			continue;
		endif;
		
		if proformaCrit.matches( self.myTrackedItem ) then
			self.selectedTrxCriteria := proformaCrit;
			break;
		endif;
	endforeach;
	// END navlw1 #JIRA-33752 20/02/2025
	if self.selectedTrxCriteria = null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("No matching pro forma criteria can be found for " &amp; _myTrackedItem.id, LogINFO.String);
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_myBank" type="CM_Bank"/>
        <Parameter name="_myTrackedItem" type="CM_TrackedItem"/>
        <Parameter name="_effDate" type="Date"/>
        <Parameter name="_isInwardGate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidDebtorRelease" id="a00624eb-883d-4f44-974e-84ba2b48ae5f">
        <source>isValidDebtorRelease(_intArray : IntegerArray): Boolean protected;
// 32416 copied from CMIF_MoveController
vars
	txnType		: Integer;
	isRelease	: Boolean;
begin

	foreach txnType in _intArray do
		if app.isReleaseTypeTransaction(txnType) then
			isRelease := true;
			break;
		endif;
	endforeach;
	
	return isRelease;
	
end;</source>
        <access>protected</access>
        <Parameter name="_intArray" type="IntegerArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDebtor" id="9128b009-f3d4-4131-a1dd-ce49b85b0cab">
        <updating/>
        <source>setDebtor() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 August 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	invLine : CM_InvoiceLine;
	terminal : CM_Terminal;
	cashDebtorType	: CM_DebtorType;
	debtor	: CM_Debtor;
begin

	if self.myTrackedItem = null then
		return;
	endif;	

	// 34260 only set it here if not already set from receipt screen
	if self.myDebtor &lt;&gt; null then
		return;
	endif;
	self.myDebtor := self.myTrackedItem.getCashDebtor();
	if self.myDebtor &lt;&gt; null then
		return;
	endif;
		
	terminal:=self.myTrackedItem.myTerminal;
	
	foreach invLine in self.allProformaInvLines do
		if invLine.debtor = null then
			continue;
		endif;
		
		if invLine.debtor.isCashOnlyDebtor(terminal) then
			self.myDebtor:=invLine.debtor;
			break;
		endif;
	endforeach;
	if self.myDebtor &lt;&gt; null then
		return;
	endif;

	// 34260 set debtor from the agent
	cashDebtorType := terminal.getConfig(CashDebtorType).CM_DebtorType;
	if cashDebtorType = null then
		return;
	endif;
	if cashDebtorType.code = "SDT2" then
		if self.myTrackedItem.getConsigneeObject &lt;&gt; null then
			debtor := self.myTrackedItem.getConsigneeObject.debtor;
		endif;
	elseif cashDebtorType.code = "SDT3" then
		if self.myTrackedItem.getConsignorObject &lt;&gt; null then
			debtor := self.myTrackedItem.getConsignorObject.debtor;
		endif;
	elseif cashDebtorType.code = "SDT6" then
		if self.myTrackedItem.myCustomsAgent &lt;&gt; null then
			debtor := self.myTrackedItem.myCustomsAgent.myDebtor;
		endif;
	elseif cashDebtorType.code = "SDT7" then
		if self.myTrackedItem.myFreightForwarder &lt;&gt; null then
			debtor := self.myTrackedItem.myFreightForwarder.debtor;
		endif;
	// ### TFS CR 65810 TASK 65811 27AUG2024 NAVAB1
	elseif cashDebtorType.code = "SDT1" then
		if self.myTrackedItem.myOperator &lt;&gt; null then
			debtor := self.myTrackedItem.myOperator.debtor;
		endif;
	endif;
	if debtor &lt;&gt; null and
	   debtor.isCashOnlyDebtor(terminal) then
		self.myDebtor := debtor;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDebtorFromAgent" id="4409fe58-bee0-4ae8-8f8f-449db44abce6">
        <updating/>
        <source>setDebtorFromAgent(_debtor : CM_Debtor) updating;
// 34260 set debtor directly from the agent entered in the cash receipt screen
vars

begin
	self.myDebtor := _debtor;
end;
</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="setEstimatedCashCharges" id="47a7d43e-1fee-4641-9de6-55991344955f">
        <updating/>
        <source>setEstimatedCashCharges()  updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	invLine : CM_InvoiceLine;
begin
	
	self.estimatedCashCharges := 0;
	foreach invLine in self.allProformaInvLines do
		self.estimatedCashCharges := self.estimatedCashCharges + invLine.totalAmount; // lineTotal;// ### JIRA 35502 18JUL2025 NAVAB1 use totalAmount (Static)
	endforeach;
		/*  TFS 45953 nothing was adding to allExtraProfInvLines, it is always empty
	foreach invLine in self.allExtraProfInvLines do
		self.estimatedCashCharges := self.estimatedCashCharges + invLine.lineTotal;
	endforeach;
*/
epilog

end;</source>
    </JadeMethod>
