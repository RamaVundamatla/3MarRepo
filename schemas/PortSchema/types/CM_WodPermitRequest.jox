    <JadeMethod name="pxyCreateUpdateProxy" id="a17bea08-f47a-49a1-8857-084e803c895a">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 October 2018	jlger1	Initial creation 41310

*/

vars
	pxyPermitRequest : CM_WodPermitRequest;
	completedOK : Boolean;
	pxyCargoDetail,
	cargoDetail : CM_WodCargoRequest;
	pxyMarineService : CM_WodMarineServiceDetail;
	marineService : CM_WodMarineServiceDetail;
begin
	pxyPermitRequest := inheritMethod();
	
	if pxyPermitRequest &lt;&gt; null then
		pxyPermitRequest.myOperator :=self.myOperator;
	endif;
	
	foreach cargoDetail in self.allCargoDetails discreteLock do
		pxyCargoDetail:=cargoDetail.pxyCreateUpdateProxy;
		pxyPermitRequest.allCargoDetails.add(pxyCargoDetail);
	endforeach;
	
	foreach marineService in self.allMarineServiceDetails discreteLock do
		pxyMarineService:= marineService.pxyCreateUpdateProxy;
		if pxyMarineService &lt;&gt; null then	
			pxyPermitRequest.allMarineServiceDetails.add(pxyMarineService);
		endif;
	endforeach;
	
	completedOK:=true;
	return pxyPermitRequest;
epilog
	if not completedOK then
		delete pxyPermitRequest;
	endif;	

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
