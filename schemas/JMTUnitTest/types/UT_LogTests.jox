    <JadeMethod name="createLocations_GH_GL" id="16d0396b-0ca6-409b-a4f1-6ddba9965ca5">
        <source>createLocations_GH_GL();
//09 September 2010	by cnwvu1

vars
	cmif_LogRow	: CMIF_LogRowRestriction;
	operator	: CM_Operator;
	obj			: CM_Object;
	
begin
	
	
	//--------------------------------------------------------------
	//		creating log row id = LogRowGHCode for Grade High
	//--------------------------------------------------------------
	
	create cmif_LogRow transient;

	operator:= self.getOperator(OperatorCode);
	
	cmif_LogRow.allOperators.add(operator);

	obj := operator.getLogSpecies(LogSpecsSpeciesOak);
	cmif_LogRow.allSpecies.add(obj);

	obj := operator.getLogGrade(LogSpecsSpeciesOak, LogSpecsGradeH);
	cmif_LogRow.allGrades.add(obj);

	obj := operator.getLogType(LogSpecsTypeBoff);
	cmif_LogRow.allTypes.add(obj);

	obj := operator.getLogTreatment(LogSpecsTreatmentUTT);
	cmif_LogRow.allTreatments.add(obj);

	//obj := self.myOperator.getLogLength(length);
	//cmif_LogRow.allLengths.add(obj);
	
	cmif_LogRow.myRowArea := self.getLogArea(LogAreaCode);
	cmif_LogRow.id := LocationGHCode;

	//cmif_LogRow.isMixedRow := false;
	cmif_LogRow.transport := 3;  // there is no constant
	
	cmif_LogRow.status := LC_Status_Open;
	
	cmif_LogRow.width := 12;  //see LOG_LogRowMaintForm :: setRowWidth();

	cmif_LogRow.user := app.getMyUserCode;
	
	self.addLogRow(cmif_LogRow);

	//--------------------------------------------------------------
	//		creating log row id = LogRowGLCode for Grade Low
	//--------------------------------------------------------------
	cmif_LogRow.allGrades.clear;
	obj := operator.getLogGrade(LogSpecsSpeciesOak, LogSpecsGradeL);
	cmif_LogRow.allGrades.add(obj);

	cmif_LogRow.allTypes.clear;
	obj := operator.getLogType(LogSpecsTypeBon);
	cmif_LogRow.allTypes.add(obj);

	cmif_LogRow.allTreatments.clear;
	obj := operator.getLogTreatment(LogSpecsTreatmentUTN);
	cmif_LogRow.allTreatments.add(obj);

	cmif_LogRow.id := LocationGLCode;

	self.addLogRow(cmif_LogRow);
	
epilog
	delete cmif_LogRow;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createLogs" id="8016e887-0455-4937-838c-b2476346255c">
        <source>createLogs(_locationID, _bolInCode, _logPrefix: String; _logNumber: Integer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 May 2014	cnwrd1	Initial creation

*/

vars
	operator	: CM_Operator;
	bolIn		: CM_BOLIn;
	logArray	: StringArray;
	tmpSED		: Integer;
	tmpPortion	: Real;
	portionSED	: Integer;
	i			: Integer;

begin
	//-------------------------------------------------------------------
	//								Creating logs
	//-------------------------------------------------------------------
		
	
	// prepare log info
	create logArray transient;
	//self.assertEqual(_logNumber, bolIn.numItems);
	
	tmpPortion := (100-10) / (_logNumber-1);
	portionSED := tmpPortion.rounded;
	
	foreach i in 1 to _logNumber do
		if i = 1 then 
			tmpSED := 10; // First log has SED = 10
		else
			tmpSED := tmpSED + portionSED;	// all other logs have SED growing
		endif;
		logArray.add( 	_logPrefix &amp; i.String &amp;Tab&amp;	// logId + i
						tmpSED.String &amp;Tab&amp;		// minSED
						tmpSED.String );		// maxSED
	endforeach;
	
	self.addLogsFromScaleData(_bolInCode, logArray, OperatorCode);	
	
epilog	
	delete logArray;
	
	
end;</source>
        <Parameter name="_locationID" type="String"/>
        <Parameter name="_bolInCode" type="String"/>
        <Parameter name="_logPrefix" type="String"/>
        <Parameter name="_logNumber" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createMixedRowLocation" id="60a847eb-4b00-4745-91db-b0ebc2dd3daa">
        <source>createMixedRowLocation(_locationId: String) : CM_LogController;
// Nov 2011 for par 28580
vars
	cmif_LogRow	: CMIF_LogRowRestriction;
	operator	: CM_Operator;
	obj			: CM_Object;

begin

	// creating log row for OAK, Grade High
	
	create cmif_LogRow transient;

	operator:= self.getOperator(OperatorCode);
	
	cmif_LogRow.allOperators.add(operator);

	obj := operator.getLogSpecies(LogSpecsSpeciesOak);
	cmif_LogRow.allSpecies.add(obj);

	obj := operator.getLogGrade(LogSpecsSpeciesOak, LogSpecsGradeH);
	cmif_LogRow.allGrades.add(obj);

	obj := operator.getLogType(LogSpecsTypeBoff);
	cmif_LogRow.allTypes.add(obj);

	obj := operator.getLogTreatment(LogSpecsTreatmentUTT);
	cmif_LogRow.allTreatments.add(obj);

	//obj := self.myOperator.getLogLength(length);
	//cmif_LogRow.allLengths.add(obj);
	
	cmif_LogRow.myRowArea := self.getLogArea(LogAreaCode);
	cmif_LogRow.id := _locationId;

	cmif_LogRow.isMixedRow := true;
	cmif_LogRow.transport := 3;  // there is no constant
	
	cmif_LogRow.status := LC_Status_Open;
	
	cmif_LogRow.width := 12;  //see LOG_LogRowMaintForm :: setRowWidth();

	cmif_LogRow.user := app.getMyUserCode;
	
	return self.addLogRow(cmif_LogRow);

	
epilog
	delete cmif_LogRow;

end;</source>
