    <JadeMethod name="adjustWeights" id="a1314679-354c-487e-b5ab-48a7e0731c88">
        <source>adjustWeights( _fromControl : Control );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 January 2018	jlgndl1	Initial creation	TFS 36697

*/

vars

	totalWeight : Decimal[14,4];
	cargoWeight : Decimal[14,4];
	tareWeight : Decimal[14,4];
	
begin

	if self.myTrackedItem = null or not self.myTrackedItem.myCargoType.useTareCargoWeight then
		return;
	endif;

	totalWeight := self.tblTotalWeight.getConvertedValue();
	cargoWeight := self.tblCargoWeight.getConvertedValue();
	tareWeight := self.tblTareWeight.getConvertedValue();

	self.adjustTotalCargoTareWeights(	self.myTrackedItem,	//_originalTi : CM_TrackedItem;
										_fromControl,	//_fromControl : Control;	// the one that just lost focus
										totalWeight,	//_totalWeightKgs : Decimal; // the current value in the table for total weight . May actually be populated with volume
										cargoWeight,	//_cargoWeightKgs : Decimal; // the current value in the table for cargo weight
										tareWeight,	//_tareWeightKgs : Decimal;// the current value in the table for tare weight
										self.tblTotalWeight,	//_tblWeight : CMUI_MeasurementTable io;
										self.tblCargoWeight, //_tblCargoWeight : CMUI_MeasurementTable io;
										self.tblTareWeight,	//_tblTareWeight : CMUI_MeasurementTable io;
										false	//_isSplitForm : Boolean
										);
	
epilog

end;</source>
        <Parameter name="_fromControl" type="Control"/>
    </JadeMethod>
    <JadeMethod name="displayWeight" id="76f3659e-1636-47a1-af9f-e654cb113615">
        <source>displayWeight();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/03/2010	cnwdap1	Initial creation PAR #23369
*/
vars

	toDo 	: CM_ToDoTask;
	measureType : CM_MeasurementType;	//08 Apr 2014	NDL	Par 33859

begin


	if self.myTrackedItem &lt;&gt; null then
		
		//self.txtWeight.text := self.myTrackedItem.totalWeight.asStringWeightJMT;
		
		//08 Apr 2014	NDL	Par 33859
		measureType := self.myTrackedItem.myCargoType.getMeasurementTypeFor( Type_Weight, true );
		self.tblTotalWeight.setup(Type_Weight, self.tblTotalWeight.backColor);
		self.tblTotalWeight.setValues(app.convertMeasurementForDisplay(measureType.shortName, self.myTrackedItem.totalWeight) &amp; Space &amp; measureType.shortName);
		
		//26 Jan 2018	NDL	TFS 36697
		self.tblCargoWeight.setup(Type_Weight, self.tblCargoWeight.backColor);
		self.tblCargoWeight.setValues(app.convertMeasurementForDisplay(measureType.shortName, self.myTrackedItem.weightCargo) &amp; Space &amp; measureType.shortName);
		self.tblTareWeight.setup(Type_Weight, self.tblTareWeight.backColor);
		self.tblTareWeight.setValues(app.convertMeasurementForDisplay(measureType.shortName, self.myTrackedItem.weightTare) &amp; Space &amp; measureType.shortName);
		
		self.chkIsCertified.value := self.myTrackedItem.isWeightCertified;
		if self.myCargoCheckItem &lt;&gt; null then
			foreach toDo in self.myTrackedItem.allToDoTasksToDo where toDo.toDoTaskDescCode = self.myCargoCheckItem.myToDoTaskDesc.code do
				self.chkToDo.value := true;
			endforeach;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="e8585876-c4e1-4284-a832-f0b8c20fc565">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation
04 Jan 2019 - NDL TFS 42495 - swap the field order to appease STWR

*/

vars

	stdHeight : Real;
	stdWidth : Real;
	thirdWidth : Real;
	twoThirdWidth : Real;
	vTop : Real;
	vLeft : Real;
	vWidth : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	stdHeight := self.getStdControlHeight;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
//	thirdWidth := ( stdWidth - self.resizedMargin ) * 1/3 ;
//	twoThirdWidth := 2 * thirdWidth;
	thirdWidth := ( stdWidth - self.resizedMargin ) * 4/10 ;
	twoThirdWidth := ( stdWidth - self.resizedMargin ) * 6/10 ;
	vTop := stdHeight;
	
	if self.myTrackedItem.myCargoType &lt;&gt; null and self.myTrackedItem.myCargoType.useTareCargoWeight then
		
		vWidth := thirdWidth;
		if _initialSetup then
			self.lblTareWeight.setAndIncrementTabIndex( tabIndex );
			self.lblTareWeight.visible := true;
		endif;
		self.lblTareWeight.move(	self.resizedMargin,
								vTop,
								vWidth,
								stdHeight);
		
		vLeft := thirdWidth + self.resizedMargin;
		vWidth := twoThirdWidth;
		if _initialSetup then
			self.tblTareWeight.setAndIncrementTabIndex( tabIndex );
			self.tblTareWeight.visible := true;
		endif;
		self.tblTareWeight.move(	vLeft,
									vTop,
									vWidth,
									stdHeight + self.resizedMargin // extra height to allow combo to be seen in measurement control
									);
									
		vTop := vTop + self.tblTareWeight.height + self.resizedMargin;
		
		vWidth := thirdWidth;
		if _initialSetup then
			self.lblCargoWeight.setAndIncrementTabIndex( tabIndex );
			self.lblCargoWeight.visible := true;
		endif;
		self.lblCargoWeight.move(	self.resizedMargin,
								vTop,
								thirdWidth,
								stdHeight);
		
		vLeft := thirdWidth + self.resizedMargin;
		vWidth := twoThirdWidth;
		if _initialSetup then
			self.tblCargoWeight.setAndIncrementTabIndex( tabIndex );
			self.tblCargoWeight.visible := true;
		endif;
		self.tblCargoWeight.move(	vLeft,
									vTop,
									vWidth,
									stdHeight + self.resizedMargin // extra height to allow combo to be seen in measurement control
									);
	
		vTop := vTop + self.tblCargoWeight.height + self.resizedMargin;
									
	else
		self.lblCargoWeight.visible := false;
		self.lblTareWeight.visible := false;
		self.tblCargoWeight.visible := false;
		self.tblTareWeight.visible := false;
		
	endif;
	
	vWidth := thirdWidth;
	
	if _initialSetup then
		self.lblWeight.setAndIncrementTabIndex( tabIndex );
		self.lblWeight.visible := true;
	endif;
	self.lblWeight.move(	self.resizedMargin,
							vTop,
							thirdWidth,
							stdHeight);
	
	vLeft := thirdWidth + self.resizedMargin;
	vWidth := twoThirdWidth;
	if _initialSetup then
		self.tblTotalWeight.setAndIncrementTabIndex( tabIndex );
		self.tblTotalWeight.visible := true;
	endif;
    self.tblTotalWeight.move(	vLeft,
								vTop,
								vWidth,
								stdHeight + self.resizedMargin // extra height to allow combo to be seen in measurement control
								);
	
	vTop := vTop + self.tblTotalWeight.height + self.resizedMargin;
	
	
	/*
	
	if _initialSetup then
		self.lblWeight.setAndIncrementTabIndex( tabIndex );
		self.lblWeight.visible := true;
	endif;
	self.lblWeight.move(	self.resizedMargin,
							vTop,
							thirdWidth,
							stdHeight);
	
	vLeft := thirdWidth + self.resizedMargin;
	vWidth := twoThirdWidth;
	if _initialSetup then
		self.tblTotalWeight.setAndIncrementTabIndex( tabIndex );
		self.tblTotalWeight.visible := true;
	endif;
    self.tblTotalWeight.move(	vLeft,
								vTop,
								vWidth,
								stdHeight + self.resizedMargin // extra height to allow combo to be seen in measurement control
								);
	
	vTop := vTop + self.tblTotalWeight.height + self.resizedMargin;
	
	if self.myTrackedItem.myCargoType &lt;&gt; null and self.myTrackedItem.myCargoType.useTareCargoWeight then
		
		vWidth := thirdWidth;
		if _initialSetup then
			self.lblCargoWeight.setAndIncrementTabIndex( tabIndex );
			self.lblCargoWeight.visible := true;
		endif;
		self.lblCargoWeight.move(	self.resizedMargin,
								vTop,
								thirdWidth,
								stdHeight);
		
		vLeft := thirdWidth + self.resizedMargin;
		vWidth := twoThirdWidth;
		if _initialSetup then
			self.tblCargoWeight.setAndIncrementTabIndex( tabIndex );
			self.tblCargoWeight.visible := true;
		endif;
		self.tblCargoWeight.move(	vLeft,
									vTop,
									vWidth,
									stdHeight + self.resizedMargin // extra height to allow combo to be seen in measurement control
									);
	
		vTop := vTop + self.tblCargoWeight.height + self.resizedMargin;
		
		vWidth := thirdWidth;
		if _initialSetup then
			self.lblTareWeight.setAndIncrementTabIndex( tabIndex );
			self.lblTareWeight.visible := true;
		endif;
		self.lblTareWeight.move(	self.resizedMargin,
								vTop,
								vWidth,
								stdHeight);
		
		vLeft := thirdWidth + self.resizedMargin;
		vWidth := twoThirdWidth;
		if _initialSetup then
			self.tblTareWeight.setAndIncrementTabIndex( tabIndex );
			self.tblTareWeight.visible := true;
		endif;
		self.tblTareWeight.move(	vLeft,
									vTop,
									vWidth,
									stdHeight + self.resizedMargin // extra height to allow combo to be seen in measurement control
									);
									
		vTop := vTop + self.tblTareWeight.height + self.resizedMargin;
									
	else
		self.lblCargoWeight.visible := false;
		self.lblTareWeight.visible := false;
		self.tblCargoWeight.visible := false;
		self.tblTareWeight.visible := false;
		
	endif;
	*/
	
	if self.myTrackedItem.myCargoType &lt;&gt; null and self.myTrackedItem.myCargoType.canWeightBeCertified then
		if _initialSetup then
			self.chkIsCertified.visible := true;
		endif;
		self.chkIsCertified.alignment := self.chkIsCertified.Alignment_Left;
		self.chkIsCertified.move(	vLeft,
									vTop,	
									twoThirdWidth,
									stdHeight);	
		vTop := vTop + self.chkIsCertified.height + self.resizedMargin;
		
	else
		self.chkIsCertified.visible := false;
	endif;
	
	
	vTop := vTop + (4*self.resizedMargin);					   
	self.chkToDo.alignment := self.chkIsCertified.Alignment_Left;
	self.chkToDo.move(	vLeft,
						vTop,	
						twoThirdWidth,
						stdHeight);	

	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="6b4f16de-438f-43ef-9ee8-02ca26f3fa2b">
        <source>doSave() : Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/03/2010	cnwdap1	Initial creation PAR #23369
31/03/2010	cnwdap1	PAR #23509 Stop 1090
*/
vars
	sessionAgent	: CM_MobileAgent;
	errors			: String;
//	container		: CM_Container;
	toDoTaskDesc	: CM_ToDoTaskDesc;
	addingToDo		: Boolean;
	prod : CM_Product;
	weight : Decimal [16,4];	//08 Apr 2014	NDL	Par 33859
	cargoWeight : Decimal [16,4];	//26 Jan 2018	NDL	TFS 36697
	tareWeight : Decimal [16,4];	//26 Jan 2018	NDL	TFS 36697

begin
	app.mousePointer := self.MousePointer_HourGlass;
	
	sessionAgent := self.getSessionAgent;
	
	if sessionAgent.getMyProxyObject = null then
		return false;
	endif;
	
	addingToDo := self.chkToDo.value;
	if self.myCargoCheckItem &lt;&gt; null then			// PAR #23509
		toDoTaskDesc := self.myCargoCheckItem.myToDoTaskDesc;
	endif;
	
	//if sessionAgent.updateWeight(	self.txtWeight.text.trimBlanks.Decimal,
	prod := sessionAgent.getMyProxyObject.CM_TrackedItem.getProductForMeasurementConv();
	weight := self.tblTotalWeight.getConvertedValue();	//08 Apr 2014	NDL	Par 33859
	
	if self.tblCargoWeight.visible and self.tblTareWeight.visible then	//26 Jan 2018	NDL	TFS 36697
		cargoWeight := self.tblCargoWeight.getConvertedValue();	//26 Jan 2018	NDL	TFS 36697
		tareWeight := self.tblTareWeight.getConvertedValue();	//26 Jan 2018	NDL	TFS 36697
	endif;
	
	if sessionAgent.updateWeight(	weight,	
									cargoWeight,
									tareWeight,
									self.chkIsCertified.value,
									toDoTaskDesc, 
									addingToDo	) then
		if errors &lt;&gt; null then
			self.msgBox(errors,"Error",MsgBox_OK_Only, false);
		endif;
		return true;
	else
		return false;
	endif;
epilog
	app.mousePointer := self.MousePointer_Default;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="9782dfbf-2e59-4696-8330-8dc1ab0b6a9b">
