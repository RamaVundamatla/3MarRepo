<Class name="BGP_AllocWSRequest" id="e90d2704-aaf3-411c-a956-27b96c511bb7">
    <superclass name="BGP_ExternalWSRequest"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;ALLOTRAC Web Service&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <ImplicitInverseRef name="myTITransaction" id="d5668cda-467d-49ba-8261-0628d35e2f95">
        <embedded/>
        <type name="CM_TITransaction"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTrackedItem" id="a4809122-9abc-4efd-917a-bdf4b487743f">
        <embedded/>
        <type name="CM_TrackedItem"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myWSDef" id="14f591ed-89d4-40ca-959b-419300da929c">
        <embedded/>
        <type name="CM_AllotracServiceDef"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="action" id="b22b618b-b371-4775-8059-5ef868b6943d">
        <updating/>
        <source>action(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 August 2020	jlgndl1	Initial creation	TFS 49869

*/

vars

	agent : CM_AllotracWSAgent;
	returnVal : Boolean;
	timeoutOccurred : Boolean;
	response : CMIF_ExternalWSResponse;
	logMessage: String;
	edition : Integer;
	invalid : Boolean;

begin

	if self.myWSDef = null then
		logMessage := "Allotrac Web Service Definition = null";
		app.writeLog(method.qualifiedName() &amp; Space &amp; logMessage, LogINFO);
		return false;
	endif;
	if self.myTrackedItem = null then
		logMessage := "Tracked Item = null";
		app.writeLog(method.qualifiedName() &amp; Space &amp; logMessage, LogINFO);
		return false;
	endif;
	if self.myTITransaction = null then
		logMessage := "Transaction = null";
		app.writeLog(method.qualifiedName() &amp; Space &amp; logMessage, LogINFO);
		return false;
	endif;
	
	
	on Exception do app.handleDeletedObject( exception, self.myWSDef, invalid );
	edition := self.myWSDef.edition;
	if invalid then
		logMessage := "Allotrac Web Service Definition has been deleted.";
		app.writeLog(method.qualifiedName() &amp; Space &amp; logMessage, LogINFO);
		return false;
	endif;

	create agent transient;
	agent.setupFromWebServiceDefinition( self.myWSDef );
	
	on Exception do app.handleDeletedObject( exception, self.myTrackedItem, invalid );
	edition := self.myTrackedItem.edition;
	if invalid then
		logMessage := "Tracked Item has been deleted.";
		app.writeLog(method.qualifiedName() &amp; Space &amp; logMessage, LogINFO);
		return false;
	endif;
	
	on Exception do app.handleDeletedObject( exception, self.myTITransaction, invalid );
	edition := self.myTITransaction.edition;
	if invalid then
		logMessage := "Transaction has been deleted.";
		app.writeLog(method.qualifiedName() &amp; Space &amp; logMessage, LogINFO);
		return false;
	endif;
	
	returnVal := agent.logonUpdateJobStatus(self.myTrackedItem, timeoutOccurred);
		
	// Handle timeout
	if timeoutOccurred then
		if self.doWebServiceTimeoutProcessing( self.myWSDef ) then
			returnVal := false;
		endif;
	endif;

	return returnVal;

epilog

	delete agent;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="6b17cb3f-994a-421e-8675-a6790d74e767">
        <source>getDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 August 2020	jlgndl1	Initial creation	TFS 49869

*/

vars

	extraData : String;
	invalid : Boolean;
	edition : Integer;

begin

	on Exception do app.handleDeletedObject( exception, self.myTrackedItem, invalid );
	on Exception do app.handleDeletedObject( exception, self.myTITransaction, invalid );
	
	if self.myTrackedItem &lt;&gt; null then
		if self.myTITransaction &lt;&gt; null then
			edition := self.myTITransaction.edition;
			if invalid then
				invalid := false;
				edition := self.myTrackedItem.edition;
				if invalid then
					extraData := Tab &amp; "TrackedItem and Transaction Deleted!";
				else
					extraData := Tab &amp; "TrackedItem Deleted!";
				endif;
			else
				if self.myTITransaction.isKindOf( CM_Receive ) then
					extraData := Tab &amp; self.myTrackedItem.id &amp; " - Job Id '" &amp; self.myTrackedItem.clientRef &amp; "' Received";
				else
					extraData := Tab &amp; self.myTrackedItem.id &amp; " - Job Id '" &amp; self.myTrackedItem.clientRef &amp; "' Released";
				endif;
			endif;
		endif;
	endif;
	
	return inheritMethod() &amp; extraData;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setDetails" id="2a1d8b2a-8c06-47c5-a2d2-9080ffb6406d">
        <updating/>
        <source>setDetails(	_ti : CM_TrackedItem;
			_tiTrx : CM_TITransaction;
			_wsDef : CM_AllotracServiceDef
			)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 August 2020	jlgndl1	Initial creation	TFS 49869

*/

vars

begin

	self.myTrackedItem := _ti;
	self.myTITransaction :=  _tiTrx;
	self.myWSDef :=  _wsDef;
	self.setTerminal( _ti.myTerminal );

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <Parameter name="_wsDef" type="CM_AllotracServiceDef"/>
    </JadeMethod>
</Class>
