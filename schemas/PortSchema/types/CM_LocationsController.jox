    <JadeMethod name="initializeForActivity" id="9e191c8b-54dc-401a-bacd-19b60e85818c">
        <updating/>
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable: CMIF_OpsViewTables) updating;
/*
Purpose:			

Date		Who		Reason
08 February 2022	navab1	TFS 51855
30MAY2022  navsp1 TFS#53700 - Refactoring changes
*/

vars
	opsviewtable 	: CMIF_SpatialBins;
	stack 			: CMIF_XpsStackStatus;
	terminal 		: CM_Terminal;
begin

	if _opsViewTable.isKindOf(CMIF_SpatialBins) then
		opsviewtable := _opsViewTable.CMIF_SpatialBins;
		
		
		opsviewtable.gkey := opsviewtable.generateFullGKey(self, "");
		
		opsviewtable.bin_level := opsviewtable.SpatialBinLevel_4; 
		opsviewtable.bin_subclass := "YST";
		opsviewtable.block_type_enum := ""; 
		opsviewtable.internal_pos_name := self.getFullId(); 
		opsviewtable.label_scheme_full_position := "";
		opsviewtable.life_cycle_state := opsviewtable.n4LifeCycleState(self); 
		opsviewtable.parent_bin_gkey := opsviewtable.generateFullGKey(self.myTerminalArea,"");
		

		
		opsviewtable.yard_gkey := 0;  
		opsviewtable.z_index_last := self.getMaxStackingHeight(); 
	elseif _opsViewTable.isKindOf(CMIF_XpsStackStatus) then
		stack := _opsViewTable.CMIF_XpsStackStatus;
		
		stack.pkey 				:= stack.generateFullGKey(self, "");
		stack.gkey 				:= stack.generateFullGKey(self, "");
		stack.bin 				:= stack.generateFullGKey(self, "");
		stack.bin_name 			:= self.getFullId();
		stack.status_chars 		:= stack.n4StackStatusChars(self); 	
		
		if self.hasPower() then 
			stack.reefer_limit 		:= self.getMaxStackingHeight().Integer; 			
		else
			stack.reefer_limit 		:= 0; 
		endif;
		
		stack.max_tier_limit 	:= self.getMaxStackingHeight().Integer; 			
		stack.is_temp_blocked 	:= self.isBlocked().Integer;						
		stack.is_men_working 	:= self.hasRestrictions(LABOUR_RESTRICTION).Integer;
		stack.is_active 		:= self.isBlocked();								
		
		terminal := self.getMyTerminal(); 
		if terminal &lt;&gt; null then  
			stack.yard_id := terminal.code; 
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
