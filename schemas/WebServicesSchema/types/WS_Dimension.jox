<Class name="WS_Dimension" id="ee99b621-43ea-4a80-a0da-8c64b92cfef7">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="description" id="6de8d19f-7332-46f2-b438-5382ee3cdacd">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="measurementType" id="029f26c5-d899-464b-bc98-864931d155ed">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="type" id="42973d2c-e8bd-4f79-8c2e-debd520fa0c2">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="value" id="1c7c284e-00bb-49f1-9b89-de0a03a94ea5">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="1df960c1-a768-48ec-bc75-a160080499bb">
        <updating/>
        <source>setProxyFromObject(_object: CM_ProductAttr) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2018	jlger1	Initial creation web portal 
14 Oct 2025 navtr3  MTN-36243 MSL - Pre-note Creation via Web Portal Populates the Dimension fields Width / Height / Length fields with a default value of 12
*/

vars

begin
	inheritMethod(_object);
	self.description:=_object.displayName;
	self.value:=_object.getDisplayValueString;					//navtr3 MTN-36243
	self.type:=_object.name;
	if _object.myMeasurementType &lt;&gt; null then
		self.measurementType:=_object.myMeasurementType.shortName;
	
	endif;
epilog

end;</source>
        <Parameter name="_object" type="CM_ProductAttr"/>
    </JadeMethod>
</Class>
