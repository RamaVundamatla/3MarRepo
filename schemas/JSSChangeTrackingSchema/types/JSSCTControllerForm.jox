    <JadeMethod name="btnPause_click" id="ca9aa98b-1fb8-4774-bc86-4fa42d0c86ef">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnPause_click(jadeMask: JadeMask input) updating;
/*
*/
begin
	if not self.theMonitorIsPaused then
		self.writeToMonitor("========== Monitor is Paused &gt;&gt;&gt;");
	endif;
	self.theMonitorIsPaused := not self.theMonitorIsPaused;
	if not self.theMonitorIsPaused then
		self.writeToMonitor("&lt;&lt;&lt; Monitor is Active ==========");
	endif;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnStopTracker_click" id="cd102cbe-c0cd-490b-aee5-c4e4ac67ce07">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnStopTracker_click(jadeMask: JadeMask input) updating;
/*
*/
begin
	//	notify this ListenManager to terminate
	self.myNotificationObject.myPersistentInstance.causeEvent(JSSCT_Nibbler_Note, true, self.myNotificationObject.buildNibbler_Terminate(null));
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnStop_click" id="c7e4d9ca-6016-4f26-99ce-cd9a9b1440a6">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnStop_click(jadeMask: JadeMask input) updating;
/*
*/
begin
	//	notify this ListenManager to terminate
	self.myNotificationObject.myPersistentInstance.causeEvent(JSSCT_Nibbler_Note, true, self.myNotificationObject.buildNibbler_Terminate(tblTracker.accessCell(tblTracker.row, 7).text));
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="displayTrackerRow" id="6f25c681-4d75-490a-9132-8f0de12f3ee6">
        <source>displayTrackerRow(pXmlString: String);
/*
		Display a row with all the necessary details of the ListenManager
		and put the ListenManager object in the rows itemObject for later
*/
vars
	theTable: Table;
	rowString: String;
	row: Integer;
	xmlDocument: JSSXmlDocument;
	rootElement: JSSXmlElement;
	processString: String;
begin
	create xmlDocument transient;
	xmlDocument.parseDocument(pXmlString);
	rootElement := xmlDocument.myRootElement;

	theTable := tblTracker;

	processString := rootElement.allChildElementsByName["process"].tagValue;
	row := self.findTrackerRow(processString);
	if row = 0 then
		row := theTable.addItem(rootElement.allChildElementsByName["title"].tagValue &amp; " (" &amp; processString[processString.pos(".",1)+1:end] &amp; ")");
	else
		theTable.accessCell(row, 1).text := rootElement.allChildElementsByName["title"].tagValue &amp; " (" &amp; processString[processString.pos(".",1)+1:end] &amp; ")";
	endif;
	theTable.accessCell(row, 2).text := rootElement.allChildElementsByName["journal"].tagValue;
	theTable.accessCell(row, 3).text := rootElement.allChildElementsByName["timestamp"].tagValue;
	theTable.accessCell(row, 4).text := rootElement.allChildElementsByName["complete"].tagValue;
	theTable.accessCell(row, 5).text := rootElement.allChildElementsByName["state"].tagValue;
	theTable.accessCell(row, 7).text := rootElement.allChildElementsByName["process"].tagValue;

	//	keep an object reference against the real (non-started) application(s)
	if rootElement.allChildElementsByName["startedApp"].tagValue = 'false' then
		theTable.accessRow(row).itemObject := self.myNotificationObject.myPersistentInstance;
	endif;
epilog
	delete xmlDocument;
end;</source>
        <Parameter name="pXmlString" type="String"/>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="c28daf01-213a-4de6-befc-26b0246b5995">
        <updating/>
        <source>doFormLoad() updating, protected;

vars
	notifier: JSSCTNotificationObject;
begin
	//	size the form to the desired default
	self.width := 800;
	self.height := 300;

	inheritMethod();

	//	set the initial monitor capture file name
	captureFileName := app.getProfileString(app.getIniFileName, "JSSChangeTracker", "MonitorFileName", app.getTempDir &amp; "JSSMonitor.log");
	create monitorFile transient;
	monitorFile.kind := File.Kind_Unknown_Text;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	monitorFile.fileName := captureFileName;
	if not monitorFile.isAvailable() then
		captureFileName := app.getTempDir &amp; "JSSMonitor.log";
		monitorFile.fileName := captureFileName;
	endif;
	monitorFile.mode := File.Mode_Append;

	self.caption := self.caption &amp; " ";

	self.setupTrackerTable();

	//	setup the Listen column headings, widths, alignment etc...
//	self.setupListenTable();

	self.resize();

	notifier := JSSCTNotificationObject.firstInstance;
	if notifier = null then
		beginTransaction;
		create notifier;
		commitTransaction;
	endif;
	//	we use the NotificationBuilder to formulate the userInfo parameters
	self.myNotificationObject := notifier.cloneSelf(true);
	self.myNotificationObject.setMyPersistentInstance(notifier);

	//	start listening for notifications on message host (root) to tell us to do something
	self.beginNotification(self.myNotificationObject.myPersistentInstance, JSSCT_Monitor_Note, Response_Continuous, 1);
	self.beginNotification(self.myNotificationObject.myPersistentInstance, JSSCT_Nibbler_Note, Response_Continuous, 2);

	//	cause the event to find out what ChangeTrackers are operating
	self.myNotificationObject.myPersistentInstance.causeEvent(JSSCT_Nibbler_Note, true, self.myNotificationObject.buildNibbler_Calling());

	//	start a timer to check, every 'nn' seconds, the state of the Trackers
	self.beginTimer(10 * 1000, Timer_Continuous, 5);

	self.writeToMonitor("JSS Change Tracking Controller started.");
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUnload" id="10c4aae0-a945-4657-b921-d94e2c8e0f99">
        <updating/>
        <source>doFormUnload() updating, protected;
/*
*/
vars

begin
	inheritMethod();

	//	turn off the timer(s)
	self.endTimer(5);

	//	turn off all the notifications
	self.endNotificationForSubscriber(self);

	//	wait and allow any notifications that got through the gap
	process.sleep(1000);

	delete self.monitorFile;
	self.monitorFile := null;
	delete self.myNotificationObject;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="findTrackerRow" id="f74d62a5-31df-4be1-8d47-a94a7d095cb5">
        <source>findTrackerRow(pProcessString: String): Integer;
/*
		Find the row with for this Change Tracker process
*/
vars
	theTable: Table;
	row: Integer;
begin
	theTable := tblTracker;

	foreach row in 3 to theTable.rows do
		if theTable.accessCell(row, 7).text = pProcessString then
			return(row);
		endif;
	endforeach;

	return(0);
end;</source>
        <Parameter name="pProcessString" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
