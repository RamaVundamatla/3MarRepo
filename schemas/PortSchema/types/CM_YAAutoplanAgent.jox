    <JadeMethod name="initialiseSearchForAutoPlan" id="d63536df-c4c7-45a3-b7f7-41f2a6a99957">
        <updating/>
        <source>initialiseSearchForAutoPlan(_currentTi		: CM_TrackedItem;
							_terminal		: CM_Terminal;
							_ta				: CM_TerminalArea;
							_gridRow		: CM_GridRow;
							_gridColumn		: CM_GridColumn ) updating;
vars
	cmifYA: CMIF_YAAutoPlanNormal;
begin
	self.initialise();
	
	self.myCurrentTerminal := _terminal;
	self.myCurrentSpecificTA := _ta;
	//epr CCMS 1025 - need to specify row or column
	if self.myCurrentSpecificTA &lt;&gt; null then
		if _gridColumn &lt;&gt; null then
			self.myCurrentSpecificColumn:=_gridColumn;
		elseif _gridRow &lt;&gt; null then
			self.myCurrentSpecificRow:=_gridRow;
		endif;
	endif;
	
	self.isFindLocationForBox := true;
	self.myFirstYAFailure := null;
	self.myCurrentJob := null;

	create cmifYA transient;
	self.setYAAutoPlan(cmifYA);
	self.setCurrentYAAutoPlan(cmifYA);

	self.addLogEntry(AP_Log_YA_Global,"Attempting auto plan of container " &amp; _currentTi.id, true);
end;</source>
