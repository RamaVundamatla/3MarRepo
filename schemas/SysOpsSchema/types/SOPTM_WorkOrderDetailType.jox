    <JadeMethod name="setControlsForAddEdit" id="237ada39-6cf2-4c85-a490-ea5137395c63">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders

*/

vars
	theForm 	: SOP_TableMaintForm;
	entTableRow	: EntTableRow;
	entTableDef	: EntTableDef;
begin
	theForm 						   := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	entTableDef 					   := app.myController.getEntTableDef(ETDef_WorkOrderTaskType);
	
	foreach entTableRow in entTableDef.allEntTableRows do
		theForm.tblInput1.enableRowByName(entTableRow.name);
	endforeach;
	
	theForm.tblInput1.disableRowByName(ETRow_Type);
	
	theForm.tblInput1.row := theForm.tblInput1.getRowByName(ETRow_RequiresApproval);
	theForm.tblInput1.setFocus;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDefaults" id="855bd693-9043-4f20-8817-85ea6f860cc1">
        <source>setupThumbnailDefaults();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
