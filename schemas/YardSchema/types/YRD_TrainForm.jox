    <JadeMethod name="handleNotifications" id="c62a51e9-6f61-4cfb-8340-398d49165a21">
        <updating/>
        <source>handleNotifications(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	07 November 2006 By cnwth2

Purpose:	

Changed On	Changed By	Reason
19/06/2009	consw1		Par 20001
// 12 Oct 2016	cnwrs1	TFS 2829 Cams processing failure with Train Events
12/12/2017 jlgns1 TFS 8179 ChangeRequest 8179: Copy Train button causes a 75768 error
01/08/2023	jlizm1		TFS 59215 Wagon maintenance notifications
----------	----------	--------------------------------------------------
*/
vars
	reloadWagons : Boolean;
	rowIdx, termEvent : Integer;
	selectedWagons : CM_WagonSet;
	theWagon : CM_Wagon;
	wagonClass : CM_WagonClass;	// 23 Jul 2009	NDL	CCMS 1067
	trackClearance : CM_TrackClearance;	// 23 Jul 2009	NDL	CCMS 1067
	doReCheckWarnings : Boolean;	// 23 Jul 2009	NDL	CCMS 1067
	invalidObject : Boolean;	//10 Nov 2009	NDL
	tmpPos, tmpCol : Integer;
	str : String;
begin
	on Exception do app.handleDeletedObject(exception, self.mySelectedTrain, invalidObject);
	on Exception do app.handleDeletedObject(exception, theObject, invalidObject);
	
	termEvent := self.myTerminal.getEventFromTerminalEvent(eventType);
	if not (eventType = Object_Delete_Event or termEvent = Wagon_Delete_Event) then
		str := theObject.creationTime.String;
		if self.mySelectedTrain &lt;&gt; null then
			str := self.mySelectedTrain.creationTime.String;
		endif;
		if invalidObject then
			return;
		endif;
	endif;

	if CM_Wagon.hasInstance(theObject) then
		if self.mySelectedTrain = null then
			return;
		endif;
		if eventType = Object_Delete_Event  or termEvent = Wagon_Delete_Event then
			reloadWagons := self.tblWagons.findObjectInRow(theObject, rowIdx);
		elseif eventType = Object_Create_Event or eventType = Object_Update_Event or termEvent = Wagon_Update_Event or termEvent = Wagon_Create_Event then
			theWagon := theObject.CM_Wagon;
		// to address error 4's during unit testing when trains deleted
			on Exception do app.handleDeletedObject( exception, theWagon, invalidObject);
		//	if (self.optDirInTB.value and theWagon.myTrainInwards = self.mySelectedTrain)
		//	or (self.optDirOutTB.value and theWagon.myTrainOutwards = self.mySelectedTrain) then
			if ( self.optDirInTB.value and self.mySelectedTrain.allWagonsByIdInward.includes(theWagon) )
			or ( self.optDirOutTB.value and self.mySelectedTrain.allWagonsByIdOutward.includes(theWagon) ) then
				reloadWagons := true;
			elseif termEvent = Wagon_Update_Event then
				reloadWagons := self.tblWagons.findObjectInRow(theWagon, rowIdx);
			elseif eventType = Object_Update_Event then
				reloadWagons := self.tblWagons.findObjectInRow(theWagon, rowIdx);
				
				// PAR 21740 Only need to update everything if the posiition has changed, else just update the wagon line.
				if reloadWagons then
					tmpCol := self.tblWagons.getColumnByRowName(ETRow_Train);
					if tmpCol &lt; 1 then
						reloadWagons := false;
					else
						tmpPos := self.tblWagons.accessCell(rowIdx,tmpCol).text.Integer;
						if theWagon.myTrainInwards.allWagonsByOrderInward.indexOf(theWagon) = tmpPos then
							reloadWagons := false;
						endif;
					endif;
					if not reloadWagons then
						self.updateWagonRow(theWagon, rowIdx);
						return;
					endif;
				endif;
				
			endif;
			if invalidObject then
				reloadWagons := true;
			endif;
			
			self.frmStatus.caption := self.mySelectedTrain.getStatusLineStats();
// PAR 21740 			self.doRefresh(); // PAR 21176
		endif;
		if reloadWagons then
			//need to refresh whole table as the position of the wagons on the train may have changed
			//rowIdx := tblWagons.topRow;
			create selectedWagons transient;
			self.tblWagons.allSelectedObjects.copy(selectedWagons);
			if not self.tblWagons.allSelectedRows.isEmpty then
				rowIdx := self.tblWagons.allSelectedRows.first;	//05 Oct 2009	NDL	Par 20796
			endif;
			self.loadWagons();	//05 Oct 2009	NDL	Par 20796 - change signature
			foreach theWagon in selectedWagons do
				tblWagons.selectObject(theWagon,false);
			endforeach;
			if rowIdx &gt; 0 and rowIdx &lt;=  tblWagons.rows then
				//tblWagons.topRow := rowIdx;
				tblWagons.selectRow(rowIdx, true);
			endif;
			
			self.loadStatsTables2(); // PAR 21740
			self.loadTblTrans(); // PAR 21740
		endif;
		return;
	elseif CM_WagonClass.hasInstance(theObject) then	// 23 Jul 2009	NDL	CCMS 1067
		wagonClass := theObject.CM_WagonClass;
		if self.mySelectedTrain &lt;&gt; null then
			create selectedWagons transient;
			self.mySelectedTrain.allWagonsByIdOutward.copy(selectedWagons);
			foreach theWagon in selectedWagons do
				if theWagon.myWagonMaster &lt;&gt; null then
					if theWagon.myWagonMaster.myWagonClass = wagonClass then
						// need to recheck the warnings.
						doReCheckWarnings := true;
						break;
					endif;
				endif;
			endforeach;
		endif;
		if not doReCheckWarnings then
			return;
		endif;
	elseif CM_TrackClearance.hasInstance(theObject) then	// 23 Jul 2009	NDL	CCMS 1067
		trackClearance := theObject.CM_TrackClearance;
		if self.mySelectedTrain &lt;&gt; null then
			if self.mySelectedTrain.myTrackClearance = trackClearance then
				// need to recheck the warnings.
				doReCheckWarnings := true;
			endif;
		endif;
		if not doReCheckWarnings then
			return;
		endif;
	endif;
	// 23 Jul 2009	NDL	CCMS 1067
	if doReCheckWarnings and self.isWarningsVisible then		// 18 Feb 2010 - RJS - PAR 21951
		getWarnings(self.mySelectedTrain);
		resize();
		return;
	endif;
	
	//handle getting a train note
	if eventType = Object_Create_Event and self.mode = self.Mode_View and CM_Train.hasInstance(theObject) then
		if self.cmbTrain.findObject(theObject.CM_Train) &lt; 1 then
			self.cmbTrain.itemObject[self.cmbTrain.addItem(self.myAssistant.displayEntryTrain(theObject.CM_Train))] := theObject.CM_Train;
		endif;
		
	elseif eventType = Object_Update_Event and self.mySelectedTrain = theObject then

		if self.mode = self.Mode_View then
			if theObject.CM_Train.isDeparted  and not self.chkIncDeparted.value then
				//app.msgBox('Another user has updated the train you are currently viewing so that it is now departed.','Train departed', MsgBox_Exclamation_Mark_Icon); //- cnwmd1, CCMS 1067, Par 19710
				app.msgBox(app.getErrorString(Anoth_user_updat_train_curre_v),app.getErrorString(Train_departed), MsgBox_Exclamation_Mark_Icon); //+ cnwmd1, CCMS 1067, Par 19710
				self.loadCmbTrain();
			endif;
			self.showTrainInfo(false,self.mode); //TFS 8179
		elseif	self.mode = self.Mode_Departure then
			//self.mode := self.Mode_View;
			self.setMode( self.Mode_View );	//18 Apr 2012	NDL	Par 27704
		else //must be editing
			//if app.msgBox('Another user has updated the train you are currently editing. Do you want to display the updated data?','Train updated', MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then //- cnwmd1, CCMS 1067, Par 19710
			if app.msgBox(app.getErrorString(Anoth_user_updat_train_curre_e),app.getErrorString(Train_updated), MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then //+ cnwmd1, CCMS 1067, Par 19710
				return;
			else
				self.showTrainInfo(false,self.mode);//TFS 8179
			endif;
		endif;
	elseif eventType = Object_Delete_Event then
		if self.mySelectedTrain = theObject then
			if self.mode = self.Mode_View then
				//app.msgBox('Another user has deleted the train you are currently viewing','Train deleted', MsgBox_Information_Icon); //- cnwmd1, CCMS 1067, Par 19710
				app.msgBox(app.getErrorString(Anoth_user_delet_train_curre_v),app.getErrorString(Train_deleted), MsgBox_Information_Icon); //+ cnwmd1, CCMS 1067, Par 19710
				self.mySelectedTrain := null;
				self.loadCmbTrain();
			else //must be editing
				//app.msgBox('Another user has deleted the train you are currently editing. The editing will now be cancelled.', 'Train deleted', MsgBox_Information_Icon); //- cnwmd1, CCMS 1067, Par 19710
				app.msgBox(app.getErrorString(Anoth_user_delet_train_curre_e), app.getErrorString(Train_deleted), MsgBox_Information_Icon);//+ cnwmd1, CCMS 1067, Par 19710
				self.mySelectedTrain := null;
				self.setControlsForView();
			endif;
		else
			self.loadCmbTrain();
		endif;
	endif;
epilog
	endLoad;
	delete selectedWagons;
end;


</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="hideShowAdvanced" id="74aa4e85-6fed-4e36-bd29-eaee9cb4bb7b">
        <updating/>
        <source>hideShowAdvanced( _show : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 May 2009	cnwrd1	Initial creation
cnwrd1 par 19710 20.5.09 -  ccms 1067
02 Oct 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
*/

vars
	statHalfWidth : Integer;
begin
	
	if  _show then
		
		self.fldAdvanced.visible := true;
		self.fldAdvanced.left := grpTrainDetails.left - 1;
		self.fldAdvanced.width := grpTrainDetails.width + 2;
		
		// 14 Aug 2009	NDL CCMS 1094
		self.tblTrans.width := shtTransactions.width - 2;
		self.tblTrans.height := shtTransactions.height - 2;
		statHalfWidth := ( shtStatistics.width / 2 ).Integer;
		self.tblCargoStat.width := statHalfWidth - 3;
		self.tblCargoStat.height := self.shtStatistics.height - self.tblCargoStat.top;
		
		self.tblWagonStat.left := statHalfWidth + 1;
		self.tblWagonStat.width := statHalfWidth - 3;
		self.tblWagonStat.height := self.shtStatistics.height - self.tblWagonStat.top;
		self.lblWagonStat.left := self.tblWagonStat.left;
		
		self.grpAdvancedOpt.parent := shtAdvanced;
		self.grpAdvancedOpt.top := 1;
		self.grpAdvancedOpt.left := 1;
		
	//	self.grpWagonDetails.top := self.grpAdvancedOpt.top  +  self.grpAdvancedOpt.height;		//+ cnwmd1, CCMS 1067, Par 19710
		self.grpWagonDetails.top := self.fldAdvanced.top  +  self.fldAdvanced.height + 10;
		self.grpWagonDetails.height := self.frmStatus.top - self.grpWagonDetails.top - 10;
		
		self.clColour.tabStop 			:= true;
	//	self.txtMaxHeight.tabStop 		:= true;
		self.tblHeight.tabStop := true;	//09 Sep 2013	NDL	Par 32172
	//	self.txtMaxWidth.tabStop 		:= true;
		self.tblWeight.tabStop := true;	//09 Sep 2013	NDL	Par 32172
	//	self.txtMaxWeight.tabStop 		:= true;
		self.txtScheduleCode.tabStop 	:= true;
		self.txtPortArrivalDt.tabStop 		:= true;
		self.txtPortArrivalTm.tabStop 		:= true;
		self.txtShunterInDt.tabStop 		:= true;
		self.txtShunterInTm.tabStop 		:= true;
		self.txtShunterOutDt.tabStop 		:= true;
		self.txtShunterOutTm.tabStop 		:= true;
		self.cmbCarrier.tabStop				:= true;
		self.cmbGaugeClear.tabStop			:= true;	//26 Jun 2009 NDL CCMS 1067 
		
		//+ 26/05/2009, cnwmd1, CCMS 1067, Par 19710
		self.txtArrivalDate.tabStop 		:= true;
		self.txtArrivalTime.tabStop			:= true;
		self.txtDepartureDate.tabStop		:= true;
		self.txtDepartureTime.tabStop		:= true;
		self.txtCargoXStartDt.tabStop 		:= true;
		self.txtCargoXStartTm.tabStop 		:= true;
		self.txtCargoXEndDt.tabStop 		:= true;
		self.txtCargoXEndTm.tabStop 		:= true;
		self.txtRemaks.tabStop 				:= true;
		self.cmbRecStevedore.tabStop		:= true;  //02.10.2020 cnwma1 TFS #50112
		self.cmbRelStevedore.tabStop        := true;  //02.10.2020 cnwma1 TFS #50112
		
	else
		//self.grpWagonDetails.top := self.grpWagonDetails.top  -  self.grpAdvancedOpt.height; 		//- cnwmd1, CCMS 1067, Par 19710
		self.grpWagonDetails.top := self.chkAdvanced.top + chkAdvanced.height + 5;					//+ cnwmd1, CCMS 1067, Par 19710
		self.grpWagonDetails.height := self.frmStatus.top - self.grpWagonDetails.top - 10;
		//self.grpWagonDetails.height :=  self.grpWagonDetails.height  + self.grpAdvancedOpt.height;

		self.fldAdvanced.visible := false;
		//self.grpAdvancedOpt.cnEcResizeContents();
		self.grpAdvancedOpt.height := 0;		
		
		self.clColour.tabStop 			:= false;
		//self.txtMaxHeight.tabStop 		:= false;
		self.tblHeight.tabStop := false;	//09 Sep 2013	NDL	Par 32172
		//self.txtMaxWidth.tabStop 		:= false;
		self.tblWidth.tabStop := false;	//09 Sep 2013	NDL	Par 32172
		//self.txtMaxWeight.tabStop 		:= false;
		self.tblWeight.tabStop := false;	//09 Sep 2013	NDL	Par 32172
		self.txtScheduleCode.tabStop 	:= false;
		self.txtPortArrivalDt.tabStop 		:= false;
		self.txtPortArrivalTm.tabStop 		:= false;
		self.txtShunterInDt.tabStop 		:= false;
		self.txtShunterInTm.tabStop 		:= false;
		self.txtShunterOutDt.tabStop 		:= false;
		self.txtShunterOutTm.tabStop 		:= false;
		self.cmbCarrier.tabStop				:= false;
		self.cmbGaugeClear.tabStop			:= false;	//26 Jun 2009 NDL CCMS 1067 
		
		//+ 26/05/2009, cnwmd1, CCMS 1067, Par 19710
		self.txtArrivalDate.tabStop 		:= false;
		self.txtArrivalTime.tabStop			:= false;
		self.txtDepartureDate.tabStop		:= false;
		self.txtDepartureTime.tabStop		:= false;
		self.txtCargoXStartDt.tabStop 		:= false;
		self.txtCargoXStartTm.tabStop 		:= false;
		self.txtCargoXEndDt.tabStop 		:= false;
		self.txtCargoXEndTm.tabStop 		:= false;
		self.txtRemaks.tabStop 				:= false;
		
	endif;

epilog

end;</source>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hideTableWarnings" id="0a86abe8-32f5-4d02-b444-767d2b3d4ab9">
        <source>hideTableWarnings() protected;
/* ---------------------------------------------------------------------------
Created:     18 February 2010 by cnwrs2

Purpose:    
        
Change Date	Who		Reason
18 Feb 2010- RJS PAR 21951 - initial creation

------------------------------------------------------------------------------*/
vars

begin
	self.tblWarnings.visible := false;
	self.chkAdvanced.top := 116;
	
	if not self.allWarnings.isEmpty then
		self.allWarnings.purge();
	endif;
	
	self.btnWarnings.value := false;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="7066893c-5bfa-46f4-b5c2-eeb8cba89c59">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2009	cnwmd1	Initial creation

*/

vars
	tmpTypeStr	: String;
begin
	inheritMethod(_userWindow);
	
	self.getTblDataXML(_userWindow);
	
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(ETDef_WagonTrans);
	self.xmlStrTblTrans := tmpTypeStr.trimCharacters(CrLf);

epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initStatsTables" id="27e2a5f1-657e-43d1-bb08-d86a14d7eae7">
        <updating/>
        <source>initStatsTables() updating, protected;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2009	cnwndl1	Initial creation

*/

vars

	entTableView1 : EntTableView;
	entTableDef1 : EntTableDef;
	theTable1 : CM_DataTable;
	entTableView2 : EntTableView;
	entTableDef2 : EntTableDef;
	theTable2 : CM_DataTable;
	
begin

	shtStatistics.caption := app.getErrorString(Statistics);
	lblCargoStat.caption := app.getErrorString(Cargo) &amp; " " &amp; app.getErrorString(Statistics);
	lblWagonStat.caption := app.getErrorString(Wagon) &amp; " " &amp; app.getErrorString(Statistics);
	
	theTable1 := self.tblCargoStat;
	theTable2 := self.tblWagonStat;
	theTable1.top := 17;
	theTable2.top := 17;
	theTable1.left := 1;
	theTable1.clear();
	theTable2.clear();
	
	theTable1.userInputEnabled := false;
	theTable2.userInputEnabled := false;
	theTable1.rows := theTable1.fixedRows;
	theTable2.rows := theTable2.fixedRows;
	theTable1.cnEcResizeContents();
	theTable2.cnEcResizeContents();

	theTable1.readOnly := false;
	theTable2.readOnly := false;	
	theTable1.fixedColumns := 0;
	theTable2.fixedColumns := 0;
	theTable1.show3D := Table.Show3D_Not3D;
	theTable2.show3D := Table.Show3D_Not3D;
	
	theTable1.selectMode := Table.SelectMode_Row;
	theTable2.selectMode := Table.SelectMode_Row;
	theTable1.accessMode := Table.AccessMode_Row;
	theTable2.accessMode := Table.AccessMode_Row;
	theTable1.multiSelect := CM_BaseTable.MultiSelect_Simple;
	theTable2.multiSelect := CM_BaseTable.MultiSelect_Simple;
	theTable1.selectionType := CM_BaseTable.SelectionType_Row;
	theTable2.selectionType := CM_BaseTable.SelectionType_Row;
	theTable1.defaultRowHeight := 17;
	theTable2.defaultRowHeight := 17;
	theTable1.allSelectedObjects.clear;
	theTable2.allSelectedObjects.clear;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initTblTrans" id="42215003-83a5-4899-8ebd-cda412e07a30">
        <updating/>
        <source>initTblTrans() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2009	cnwndl1	Initial creation

*/

vars

	entTableView	: EntTableView;
	entTableDef		: EntTableDef;
	theTable		: CM_DataTable;
	
begin

	theTable := self.tblTrans;
	theTable.top := 1;
	theTable.left := 1;
	theTable.clear();
	
	theTable.userInputEnabled := false;
	theTable.rows := theTable.fixedRows;
	theTable.cnEcResizeContents();
	
	entTableDef := app.myController.getEntTableDef(ETDef_WagonTrans);
	if entTableDef &lt;&gt; null then
		if self.xmlStrTblTrans.trimBlanks &lt;&gt; null then
			theTable.setTblDataEntRowsFromXML(entTableDef, self.xmlStrTblTrans);
		else
			theTable.setTblDataEntRowsFromDef(entTableDef);
		endif;
	endif;
	
	theTable.readOnly := false;	
	theTable.fixedColumns := 0;
	theTable.show3D := Table.Show3D_Not3D;
	
	theTable.selectMode := Table.SelectMode_Row;
	theTable.accessMode := Table.AccessMode_Row;
	theTable.multiSelect := CM_BaseTable.MultiSelect_Simple;
	theTable.selectionType := CM_BaseTable.SelectionType_Row;
	theTable.defaultRowHeight := 17;
	theTable.sortColumn[1] := 2;	//10 Apr 2014	NDL	CCMS 1366
	theTable.sortType[1] :=	Table.SortType_TimeStamp;	//10 Apr 2014	NDL	CCMS 1366
	theTable.allSelectedObjects.clear;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initTblWagon" id="84b7c52c-9333-46ff-b91a-ff1cf204db80">
        <updating/>
        <source>initTblWagon() protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	07 November 2006 By cnwth2

Purpose:	Get column data from either the users profile or default to the appropriate view obtained from the tableDef.  Different columns are displayed for either inward or outward trains.

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	//numColumns		: Integer;
	entTableDef		: EntTableDef;
	view			: String;
	xmlStrTblData	: String;
begin
	self.resize();
	
	self.tblWagons.rows := 1;
	self.tblWagons.fixedRows 	:= 1;
	//self.tblWagons.setColumnHeadingsFromDef(ETDef_WagonList, false);		//- cnwmd1, CCMS 1067, Par 19710
	
	entTableDef := app.myController.getEntTableDef(ETDef_WagonList);		//+ cnwmd1, CCMS 1067, Par 19710
	if entTableDef &lt;&gt; null then
		if self.optDirInTB.value then //+ cnwmd1, CCMS 1067, Par 19913 - Add views
			if self.xmlStrTblDataArray.size &gt;= 1 then //If size = 0 then no previously saved settings in CM_UserWindow.  Will use default view.
				xmlStrTblData := self.xmlStrTblDataArray[1];
			endif;
			view := ETView_TrainInward;
		elseif self.optDirOutTB.value then
			if self.xmlStrTblDataArray.size &gt;= 2 then
				xmlStrTblData := self.xmlStrTblDataArray[2];
			endif;
			view := ETView_TrainOutward;
		endif;
		//self.tblWagons.setTblDataEntRowsFromDef(entTableDef);				//- cnwmd1, CCMS 1067, Par 19913
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Def (' &amp; ETDef_WagonList &amp; ') not found'); //+ cnwmd1, CCMS 1067, Par 19913
	endif;
	
	if xmlStrTblData &lt;&gt; null then
		self.tblWagons.setTblDataEntRowsFromXML(entTableDef, xmlStrTblData);	
	else
		self.tblWagons.setTblDataEntRowsFromView(entTableDef, view);
	endif;
	
	self.tblWagons.multiSelect := CM_DataTable.MultiSelect_Simple;
	self.tblWagons.selectionType := CM_DataTable.SelectionType_Row;
	
	if not app.getMyTerminalConfigDO_NOT_USE(UseOutwardRailConfirm).Boolean then
		self.tblWagons.hideColumnByColName(ETRow_ConfirmOutward);
	endif;
	
	/* //- cnwmd1, CCMS 1067, Par 19913 - get column widths from tabledef.
	numColumns := self.tblWagons.columns;
	
	colWidth := (self.tblWagons.width / numColumns).Integer;
	//foreach col in 1 to numColumns do
	//	self.tblWagons.accessColumn(col).width := colWidth;
	endforeach;*/
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadCmbTrain" id="8630859e-1d98-4922-807d-f3c4832a0c7e">
        <updating/>
        <source>loadCmbTrain() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	07 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	
begin
	if self.mode &lt;&gt; self.Mode_View then
		return;
	endif;
		
	self.myAssistant.comboBoxTrain(self.cmbTrain, self.mySelectedTrain, false, false, self.chkIncDeparted.value);
	
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadStatsTables2" id="53b6ac7e-c51f-40fc-8cfd-e3a57dd0449e">
        <updating/>
        <source>loadStatsTables2() updating, protected;

/*

Purpose:			

Parameters:	
			// this version uses the new Messina CMIF objects.

Return Value:		


Date		Who		Reason
10 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	theTable1 : CM_DataTable;
	tmpSheet : JadeTableSheet;
	theDataLine : String;
	theTable2 : CM_DataTable;
	cmifTotals : CMIF_TrainStatTotalsObject;
	cmifCargoLine : CMIF_TrainStatCargoLine;
	cmifWagonLine : CMIF_TrainStatWagonLine;
	type : String;	
	itemsIn : String;
	teuIn : String;
	weightIn : String;
	itemsOut : String;
	teuOut : String;
	weightOut : String;
	idx : Integer;
	wagonClass : String;
	wagonsIn : String;
	tareWeightIn : String;
	wagonsOut : String;
	tareWeightOut : String;
	trainInwardWeight : String;
 	trainOutwardWeight : String;
	col : Integer;
	
	weightInStr : String;
	weightOutStr : String;
	tareWeightInStr : String;
	tareWeightOutStr : String;
	trainInwardWeightStr : String;
	trainOutwardWeightStr : String;
	
begin

	initStatsTables();
	
	// Cargo Stats table fixed column setup
	theTable1 := self.tblCargoStat;
	theTable1.fixedRows := 2;
	tmpSheet := theTable1.accessSheet(1);
	tmpSheet.fixed3D := false;
	theTable1.columns := 7;
	theDataLine := Tab &amp; app.getErrorString(Inward) &amp; Tab &amp; Tab &amp; Tab &amp; app.getErrorString(Outward);
	theTable1.setCellText(1,1,theDataLine);
	theTable1.accessCell(1,1).gridRight := false;
	theTable1.accessCell(1,2).mergeCells := Table.MergeCells_Merge;
	theTable1.accessCell(1,5).mergeCells := Table.MergeCells_Merge;	
	theDataLine := app.getErrorString(CM_Type) &amp; Tab &amp; app.getErrorString(Items) &amp; Tab &amp; app.getErrorString(TeuHeading) &amp; Tab &amp; app.getErrorString(CM_Weight) &amp; Tab &amp; app.getErrorString(Items) &amp; Tab &amp; app.getErrorString(TeuHeading) &amp; Tab &amp; app.getErrorString(CM_Weight);
	theTable1.setCellText(2,1,theDataLine);
	
	// Wagon Stats table fixed column setup
	theTable2 := self.tblWagonStat;
	theTable2.fixedRows := 2;
	tmpSheet := theTable2.accessSheet(1);
	tmpSheet.fixed3D := false;
	theTable2.columns := 5;
	theDataLine := Tab &amp; app.getErrorString(Inward) &amp; Tab &amp; Tab &amp; app.getErrorString(Outward);
	theTable2.setCellText(1,1,theDataLine);
	theTable2.accessCell(1,1).gridRight := false;
	theTable2.accessCell(1,2).mergeCells := Table.MergeCells_Merge;
	theTable2.accessCell(1,4).mergeCells := Table.MergeCells_Merge;
	theDataLine := app.getErrorString(IsoClass) &amp; Tab &amp; app.getErrorString(Wagons) &amp; Tab &amp; app.getErrorString(Tare_weight) &amp; Tab &amp; app.getErrorString(Wagons) &amp; Tab &amp; app.getErrorString(Tare_weight);
	theTable2.setCellText(2,1,theDataLine);
	
	if self.mySelectedTrain = null or self.initialLoadMode = Mode_Copy then
		return;
	endif;

	// All Stats data setup
	create cmifTotals;
	cmifTotals.setMyTrainAndCreateStats(self.mySelectedTrain);	// creates all of the 'line' data
	
	// Cargo Stats data display
	foreach cmifCargoLine in cmifTotals.allCMIF_TrainStatCargoLines do
		cmifCargoLine.getLineStrings( type, itemsIn, teuIn, weightIn, itemsOut, teuOut, weightOut, false );
		//theDataLine := type &amp; Tab &amp; itemsIn &amp; Tab &amp; teuIn &amp; Tab &amp; weightIn &amp; Tab &amp; itemsOut &amp; Tab &amp; teuOut &amp; Tab &amp; weightOut;
		
		//10 Sep 2013	NDL	Par 32172
		weightInStr := null;
		weightOutStr := null;
		if weightIn &lt;&gt; null then
			weightInStr := app.convertMeasurementForDisplay( self.weightType.shortName, weightIn.Decimal )  &amp; " " &amp; self.weightType.shortName;
		endif;
		if weightOut &lt;&gt; null then
			weightOutStr := app.convertMeasurementForDisplay( self.weightType.shortName, weightOut.Decimal ) &amp; " " &amp; self.weightType.shortName;
		endif;
		theDataLine := type &amp; Tab &amp; itemsIn &amp; Tab &amp; teuIn &amp; Tab &amp; weightInStr &amp; Tab &amp; itemsOut &amp; Tab &amp; teuOut &amp; Tab &amp; weightOutStr;
	
		idx := theTable1.addItem(theDataLine);
		foreach col in 2 to 7 do
			theTable1.accessCell(idx,col).alignment := Table.Alignment_Right;
		endforeach;
	endforeach;
	
	// Cargo Stats thin line between data and totals
	theDataLine := null;
	idx := theTable1.addItem(theDataLine);
	theTable1.accessRow(idx).height := 4;
	theTable1.accessCell(idx,2).mergeCells := Table.MergeCells_Merge;
	
	// Cargo Stats totals display
	cmifTotals.getCargoTotalStrings( type, itemsIn, teuIn, weightIn, itemsOut, teuOut, weightOut, false );
	
	//theDataLine := type &amp; Tab &amp; itemsIn &amp; Tab &amp; teuIn &amp; Tab &amp; weightIn &amp; Tab &amp; itemsOut &amp; Tab &amp; teuOut &amp; Tab &amp; weightOut;
	//10 Sep 2013	NDL	Par 32172
	weightInStr := null;
	weightOutStr := null;
	if weightIn &lt;&gt; null then
		weightInStr := app.convertMeasurementForDisplay( self.weightType.shortName, weightIn.Decimal )  &amp; " " &amp; self.weightType.shortName;
	endif;
	if weightOut &lt;&gt; null then
		weightOutStr := app.convertMeasurementForDisplay( self.weightType.shortName, weightOut.Decimal ) &amp; " " &amp; self.weightType.shortName;
	endif;
	theDataLine := type &amp; Tab &amp; itemsIn &amp; Tab &amp; teuIn &amp; Tab &amp; weightInStr &amp; Tab &amp; itemsOut &amp; Tab &amp; teuOut &amp; Tab &amp; weightOutStr;
	
	idx := theTable1.addItem(theDataLine);
	foreach col in 2 to 7 do
		theTable1.accessCell(idx,col).alignment := Table.Alignment_Right;
	endforeach;
	
	// Wagon Stats data display
	foreach cmifWagonLine in cmifTotals.allCMIF_TrainStatWagonLines do
		cmifWagonLine.getLineStrings( wagonClass, wagonsIn, tareWeightIn, wagonsOut, tareWeightOut, false );
		//theDataLine := wagonClass &amp; Tab &amp; wagonsIn &amp; Tab &amp; tareWeightIn &amp; Tab &amp; wagonsOut &amp; Tab &amp; tareWeightOut;
		
		//10 Sep 2013	NDL	Par 32172
		tareWeightInStr := null;
		tareWeightOutStr := null;
		if tareWeightIn &lt;&gt; null then
			tareWeightInStr := app.convertMeasurementForDisplay( self.weightType.shortName, tareWeightIn.Decimal )  &amp; " " &amp; self.weightType.shortName;
		endif;
		if tareWeightOut &lt;&gt; null then
			tareWeightOutStr := app.convertMeasurementForDisplay( self.weightType.shortName, tareWeightOut.Decimal ) &amp; " " &amp; self.weightType.shortName;
		endif;
		theDataLine := wagonClass &amp; Tab &amp; wagonsIn &amp; Tab &amp; tareWeightInStr &amp; Tab &amp; wagonsOut &amp; Tab &amp; tareWeightOutStr;
	
		idx := theTable2.addItem(theDataLine);
		foreach col in 2 to 5 do
			theTable2.accessCell(idx,col).alignment := Table.Alignment_Right;
		endforeach;
	endforeach;
	
	//Wagon Stats thin line	after data
	theDataLine := null;
	idx := theTable2.addItem(theDataLine);
	theTable2.accessRow(idx).height := 4;
	theTable2.accessCell(idx,2).mergeCells := Table.MergeCells_Merge;
	
	// Wagon Stats totals display
	cmifTotals.getWagonTotalStrings( wagonClass, wagonsIn, tareWeightIn, wagonsOut, tareWeightOut, false );
	//theDataLine := wagonClass &amp; Tab &amp; wagonsIn &amp; Tab &amp; tareWeightIn &amp; Tab &amp; wagonsOut &amp; Tab &amp; tareWeightOut;
	//10 Sep 2013	NDL	Par 32172
	tareWeightInStr := null;
	tareWeightOutStr := null;
	if tareWeightIn &lt;&gt; null then
		tareWeightInStr := app.convertMeasurementForDisplay( self.weightType.shortName, tareWeightIn.Decimal )  &amp; " " &amp; self.weightType.shortName;
	endif;
	if tareWeightOut &lt;&gt; null then
		tareWeightOutStr := app.convertMeasurementForDisplay( self.weightType.shortName, tareWeightOut.Decimal ) &amp; " " &amp; self.weightType.shortName;
	endif;
	theDataLine := wagonClass &amp; Tab &amp; wagonsIn &amp; Tab &amp; tareWeightInStr &amp; Tab &amp; wagonsOut &amp; Tab &amp; tareWeightOutStr;
		
	idx := theTable2.addItem(theDataLine);
	foreach col in 2 to 5 do
		theTable2.accessCell(idx,col).alignment := Table.Alignment_Right;
	endforeach;
		
	//Wagon Stats thin line	after data totals
	theDataLine := null;
	idx := theTable2.addItem(theDataLine);
	theTable2.accessRow(idx).height := 4;
	theTable2.accessCell(idx,2).mergeCells := Table.MergeCells_Merge;
		
	// get values for total train weight.
	cmifTotals.getTrainTotalWeightStrings( trainInwardWeight, trainOutwardWeight, false);
	//10 Sep 2013	NDL	Par 32172
	trainInwardWeightStr := null;
	trainOutwardWeightStr := null;
	if trainInwardWeight &lt;&gt; null then
		trainInwardWeightStr := app.convertMeasurementForDisplay( self.weightType.shortName, trainInwardWeight.Decimal )  &amp; " " &amp; self.weightType.shortName;
	endif;
	if trainOutwardWeight &lt;&gt; null then
		trainOutwardWeightStr := app.convertMeasurementForDisplay( self.weightType.shortName, trainOutwardWeight.Decimal )  &amp; " " &amp; self.weightType.shortName;
	endif;
							
	//Wagon stats total weight inwards
	theDataLine := "          " &amp; app.getErrorString(Total_train_weight) &amp; " (" &amp; app.getErrorString(Inwards) &amp; ") : " &amp; trainInwardWeightStr;
	idx := theTable2.addItem(theDataLine);
	theTable2.accessCell(idx,1).mergeCells := Table.MergeCells_Merge;
	
	//Wagon stats total weight outwards
	theDataLine := "          " &amp; app.getErrorString(Total_train_weight) &amp; " (" &amp; app.getErrorString(Outwards) &amp; ") : " &amp; trainOutwardWeightStr;
	idx := theTable2.addItem(theDataLine);
	theTable2.accessCell(idx,1).mergeCells := Table.MergeCells_Merge;
	
epilog

	delete cmifTotals;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTblTrans" id="a8a4361e-4623-47db-96ba-ad2544b2d77d">
        <updating/>
        <source>loadTblTrans() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2009	cnwndl1	Initial creation

*/

vars

	trans : CM_EventTransaction;
	idx	 : Integer;
	tmpUser : CM_User;
	iter : Iterator;
	wagon : CM_Wagon;
	loadStateSet : Boolean;
	theDataLine : String;
	inward : Boolean;
	
begin
	
	
	self.tblTrans.rows := self.tblWagons.fixedRows;
	self.tblTrans.allSelectedObjects.clear();
	shtTransactions.caption := app.getErrorString(Transactions);
	
	if self.mySelectedTrain = null or self.initialLoadMode = Mode_Copy then
		return;
	endif;
	
	app.cmsBeginLoad(loadStateSet);
	iter := self.mySelectedTrain.allWagonsByIdInward.createIterator;
	while iter.next(wagon) do
	
		foreach trans in wagon.allTransactions discreteLock do
			theDataLine := trans.getAttributeStringForDefArray(tblTrans.allTblDataEntRows);
			idx := tblTrans.addItem(theDataLine);
			tblTrans.accessRow(idx).itemObject := trans;
		endforeach;
			
	endwhile;
	delete iter;
	
	iter := self.mySelectedTrain.allWagonsByIdOutward.createIterator;
	while iter.next(wagon) do
	
		if self.mySelectedTrain.allWagonsByIdInward.includes(wagon) then
			//done this wagon.
			continue;
		endif;
	
		foreach trans in wagon.allTransactions discreteLock do
			theDataLine := trans.getAttributeStringForDefArray(tblTrans.allTblDataEntRows);
			idx := tblTrans.addItem(theDataLine);
			tblTrans.accessRow(idx).itemObject := trans;
		endforeach;
			
	endwhile;
	delete iter;
	
	//02 Nov 2009	NDL	Par 21519
	foreach trans in self.mySelectedTrain.allTransactions discreteLock do
		theDataLine := trans.getAttributeStringForDefArray(tblTrans.allTblDataEntRows);
		idx := tblTrans.addItem(theDataLine);
		tblTrans.accessRow(idx).itemObject := trans;
	endforeach;
	
epilog

	app.cmsEndLoad(loadStateSet);
	delete iter;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadWagons" id="1261c615-f280-49c3-867d-87bf6da8f0dd">
        <source>loadWagons() protected;
/*
----------   ----------  --------------------------------------------------
Created:	08 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	train		: CM_Train;
	wagon		: CM_Wagon;
	inward : Boolean;
begin

	inward := self.optDirInTB.value;	//05 Oct 2009	NDL	Par 20796

	train := self.mySelectedTrain;
	self.tblWagons.rows := self.tblWagons.fixedRows;
	self.tblWagons.allSelectedObjects.clear();
	if train = null or self.initialLoadMode = self.Mode_Copy then
		return;
	endif;

	if inward then
		foreach wagon in train.allWagonsByOrderInward do
			self.addWagonRow(wagon);		
		endforeach;
	else
		foreach wagon in train.allWagonsByOrderOutward do
			self.addWagonRow(wagon);		
		endforeach;
	endif;
end;


</source>
        <access>protected</access>
    </JadeMethod>
