<Class name="CMQF_ReeferVoltCoolingSum" id="d32144b6-8949-4492-bb4e-e095d28c2130">
    <superclass name="CMQF_TrackedItem"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="5334c736-df5e-4fcd-8dcb-95d22eb0c695">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
//-----------------------------------------
// Created: 2 June 2005 By: cnwgd1
//-----------------------------------------
vars
	tmpTI		: CM_TrackedItem;
	breakOut	: Boolean;
begin

	if self.getMyVoyage = null then
		return;
	endif;

	//notified cargo
	foreach tmpTI in self.getMyVoyage.allNotifiedTIsByCargoTypeId discreteLock where tmpTI.cargoType = TI_CargoType_Container do
		if self.checkStatusIncludesObject(tmpTI, _passport, breakOut) then
			if (not _collection.includes(tmpTI)) then
				_collection.add(tmpTI);
			endif;
		endif;
	endforeach;

	//onsite cargo
	foreach tmpTI in self.getMyVoyage.allOnsiteTIsByCargoTypeId discreteLock where tmpTI.cargoType = TI_CargoType_Container do
		if self.checkStatusIncludesObject(tmpTI, _passport, breakOut) then
			if (not _collection.includes(tmpTI)) then
				_collection.add(tmpTI);
			endif;
		endif;
	endforeach;
	
	// Report is for received/notified cargo
	//onship cargo
	/*foreach tmpTI in self.myVoyage.allOnshipTIsByCargoTypeId where tmpTI.cargoType = TI_CargoType_Container do
		if self.checkStatusIncludesObject(tmpTI, _passport, breakOut) then
			if (not _collection.includes(tmpTI)) then
				_collection.add(tmpTI);
			endif;
		endif;
	endforeach;*/

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="4ada7e25-9406-403b-ae7a-194edddd4cb4">
        <updating/>
        <source>includesObject(_ti: CM_Container; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
//--------------------------------------------------
// Created:	03 June 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _ti.requiresPower
	and inheritMethod(_ti, _passport, _breakOut) then
		return true;
	endif;

	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_Container"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
