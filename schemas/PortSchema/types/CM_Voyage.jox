    <JadeMethod name="getNumDLRsForVoyAllocation" id="0863a9e2-d36c-47e4-893d-fd2387d38d4c">
        <updating/>
        <source>getNumDLRsForVoyAllocation(_isLoadMode : Boolean; _allocTotals : CM_VoyAllocationByPriority input) updating;
/*

Date		    Who			Reason
24 January 2011	cnwas3	  par26773

*/


vars
	allocs : CM_VoyAllocationByPriority;
	voyAlloc : CM_VoyageAllocation;
	allTIs: CM_TISet;
	ti : CM_TrackedItem;
	totTIsNow : Integer;
	iter : Iterator;
	
begin
	
	iter := _allocTotals.createIterator();
	
	
	create allocs transient;
	self.populateAllocationsByPriority(allocs);
	
	create allTIs transient;

	foreach ti in self.allOnsiteTIsByCargoTypeId discreteLock do	
		if ti.isRehandle then 
			allTIs.addNoDuplicates(ti, false);		
		endif;
	endforeach;
	
	foreach ti in self.allOnshipTIsByCargoTypeId discreteLock do	
		if ti.isRehandle then 
			allTIs.addNoDuplicates(ti, false);		
		endif;
	endforeach;	
	
	if _isLoadMode then				
		foreach ti in allTIs discreteLock do
			voyAlloc := self.getTIsVoyageAllocation(ti,allocs);
			allTIs.remove(ti);
		
			if voyAlloc = null then
				continue;
			endif;
		
			if _allocTotals.includes(voyAlloc) then
				iter.startAtObject(voyAlloc);
				_allocTotals.getIteratorKeys(totTIsNow,iter);
				_allocTotals.removeKeyEntry(totTIsNow,voyAlloc);
				totTIsNow := totTIsNow + 1;
				_allocTotals.putAtKey(totTIsNow,voyAlloc);
			else
				_allocTotals.putAtKey(1,voyAlloc);
			endif;		
		endforeach;
	else
		foreach ti in allTIs discreteLock do
			voyAlloc := self.getTIsImportVoyageAllocation(ti,allocs);
			//allTIs.remove(ti);
		
			if voyAlloc = null then
				continue;
			endif;
		
			if _allocTotals.includes(voyAlloc) then
				iter.startAtObject(voyAlloc);
				_allocTotals.getIteratorKeys(totTIsNow,iter);
				_allocTotals.removeKeyEntry(totTIsNow,voyAlloc);
				totTIsNow := totTIsNow + 1;
				_allocTotals.putAtKey(totTIsNow,voyAlloc);
			else
				_allocTotals.putAtKey(1,voyAlloc);
			endif;		
		endforeach;
	endif;
epilog
	
	delete allocs;
	delete allTIs;
	delete iter;
end;</source>
        <Parameter name="_isLoadMode" type="Boolean"/>
        <Parameter name="_allocTotals" type="CM_VoyAllocationByPriority" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getNumExportsForVoyAllocation" id="cd5381d3-7940-4745-a36c-e12da73b0f67">
        <updating/>
        <source>getNumExportsForVoyAllocation(_allocTotals : CM_VoyAllocationByPriority input; _allTIs : CM_TISet input) updating;
// ---------------------------------------------------------------------------
// Created:     28 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 15/07/2010		cnwdap1			PAR #25021 review use of isImport/isExport for tranships
// ---------------------------------------------------------------------------

vars
	allocs : CM_VoyAllocationByPriority;
	voyAlloc : CM_VoyageAllocation;
	allTIs, pxyTIs : CM_TISet;
	ti, pxyTI : CM_TrackedItem;
	totTIs, totTIsNow : Integer;
	iter : Iterator;
	usesTS : Boolean;
begin
	usesTS := self.haveVoyAllocTranship(); // If the voyage does use istranship in the voyage allocations then the allocations for T/S will be an IMEX of TRANSHIP, else it will be IMEX of EXPORT


	iter := _allocTotals.createIterator();
	create allocs transient;
	self.populateAllocationsByPriority(allocs);
	
	create allTIs transient;
	create pxyTIs transient; // PAR 26133
	

	foreach ti in self.allNotifiedTIsByIdCargoType discreteLock do
		//if ti.isExport then							// PAR #25021
		if ti.isExport or ti.isTranshipOutbound then	// PAR #25021
			allTIs.addNoDuplicates(ti, false);
		endif;
	endforeach;
	foreach ti in self.allOnsiteTIsByCargoTypeId discreteLock do
		//if ti.isExport then							// PAR #25021
		if ti.isExport then // PAR 26133 or ti.isTranshipOutbound then	// PAR #25021
			allTIs.addNoDuplicates(ti, false);
		elseif  ti.isTranshipItem then
			// PAR 26133 - If the Voyage is configured for VoyAlloc to use IsTrashipItem then just use the actual TI
			//					else take a pxy and chnage the details so that it will match the non TS voyAlloc
			if usesTS then
				allTIs.addNoDuplicates(ti, false);
			else
				pxyTI := ti.pxyGetProxyObject();
				if pxyTI = null then // if not null then the user is editing it, so ignore
					pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
					pxyTIs.add(pxyTI);
					pxyTI.setImExStatus(TI_IMEX_STATUS_EXPORT);
					allTIs.addNoDuplicates(pxyTI, false);
				endif;
			endif;
		endif;
	endforeach;

	// PAR 25833
	foreach ti in self.allTranshipTIsExport discreteLock do
		// PAR 26133 - If the Voyage is configured for VoyAlloc to use IsTrashipItem then just use the actual TI
		//					else take a pxy and chnage the details so that it will match the non TS voyAlloc
		if usesTS then
			allTIs.addNoDuplicates(ti, false);
		else
			if not self.allOnsiteTIsByCargoTypeId.includes(ti) then // already done on site items
				pxyTI := ti.pxyGetProxyObject();
				if pxyTI = null then // if not null then the user is editing it, so ignore
					pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
					pxyTIs.add(pxyTI);
					pxyTI.setImExStatus(TI_IMEX_STATUS_EXPORT);
					// TFS 2122 add null test
					if ti.myTranshipDetail &lt;&gt; null then
						pxyTI.setDischargePort(ti.myTranshipDetail.dischargePort);	// 10 May 2012	NDL	Par 29514
					endif;
					allTIs.addNoDuplicates(pxyTI, false);
				endif;
			endif;
		endif;
	endforeach;


	
	
	foreach ti in allTIs discreteLock do
		voyAlloc := self.getTIsVoyageAllocation(ti,allocs);
		//allTIs.remove(ti);
		if voyAlloc = null then
			continue;
		endif;
		_allTIs.addNoDuplicates(ti,false);//cnwas3 par 26840a
		
		if _allocTotals.includes(voyAlloc) then
			iter.startAtObject(voyAlloc);
			_allocTotals.getIteratorKeys(totTIsNow,iter);
			_allocTotals.removeKeyEntry(totTIsNow,voyAlloc);
			totTIsNow := totTIsNow + 1;
			_allocTotals.putAtKey(totTIsNow,voyAlloc);
		else
			_allocTotals.putAtKey(1,voyAlloc);
		endif;
		
	endforeach;
epilog

	
	delete allocs;
	
	// PAR 26133
	pxyTIs.purge();
	delete pxyTIs;

	delete allTIs;
	delete iter;
end;</source>
        <Parameter name="_allocTotals" type="CM_VoyAllocationByPriority" usage="input"/>
        <Parameter name="_allTIs" type="CM_TISet" usage="input"/>
    </JadeMethod>
