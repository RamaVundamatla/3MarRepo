    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="1abd7f87-4bc8-417f-ac36-3c494a0efd46">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2020	jlgndl1	Initial creation	TFS 49202
04 Nov 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
*/

vars

	wagon : CM_Wagon;
	train : CM_Train;
	ti    : CM_TrackedItem;
begin

	inheritMethod(_tiTransCntrl, _passport);
	
	self.setLastYardLocationFromMoveTrx();
	self.locationRail := _tiTransCntrl.myTrackedItem.priorLocation;
	
	if _tiTransCntrl.myOriginatingLocation &lt;&gt; null then
		if _tiTransCntrl.myOriginatingLocation.isWagon then
			wagon := _tiTransCntrl.myOriginatingLocation.CM_WagonController.myWagon;
			if wagon &lt;&gt; null then
				self.wagonCode := wagon.id;
				train := wagon.myTrainInwards;
				if train &lt;&gt; null then
					trainCode := train.code;
				endif;
				
			//04.11.2020 cnwma1 TFS #50112
			if self.stevedoreCode = null then
				ti := self.myTrackedItem;
				if ti &lt;&gt; null then
					ti.updateStevedoreForRail(CM_Stevedore.STEVEDORE_RELEASE,wagon);
					self.stevedoreCode := ti.getStevedoreCodeRelease();
				endif;
			endif;
			//04.11.2020 cnwma1 TFS #50112
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setLastYardLocationFromMoveTrx" id="fec11a5f-91f9-4212-875c-8a113e199612">
        <updating/>
        <source>setLastYardLocationFromMoveTrx()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2020	jlgndl1	Initial creation	TFSD 49202

*/

vars

	trxDict : CM_TITransactionByTypeDateDict;
	trx : CM_TITransaction;
	lc : CM_LocationsController;
	ta : CM_TerminalArea;

begin

	create trxDict transient;
	
	self.myTrackedItem.allTransactions.getAllTransactionsOfClass( CM_Move, trxDict, false );
	self.myTrackedItem.allTransactions.getAllTransactionsOfClass( CM_Pickup, trxDict, false );
	
	foreach trx in trxDict discreteLock do
		if trx.CM_Move.mode &lt;&gt; REAL_MODE then
			continue;
		endif;
		lc := trx.CM_Move.getSourceLocationsController();
		if lc &lt;&gt; null and lc.isYardLocation then
			ta := trx.CM_Move.getSourceTA();
			if ta &lt;&gt; null and not ta.isTransferArea then
				self.locationYard := lc.getFullId;
				return;
			endif;
		endif;
	endforeach;

epilog

	delete trxDict;

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="db23f4e1-4e1c-45a1-bac8-11583b4cc4b9">
        <updating/>
