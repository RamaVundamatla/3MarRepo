	self.transferredVolume		:= _transferredVolume;
	self.remarks				:= _remarks;
	self.myFreightForwarder		:= _myFreightForward;
	self.myIncoterm				:= _myIncoTerm;
	self.myOperatorNew			:= _myOperatorNew;
	self.myOperatorOld			:= _myOperatoeOid;
	self.myOperatorOrig			:= _myOperatorOrig;
	self.myOperatorStorage		:= _myOperatorStorage;
	self.myOwnershipChangePrevious	:= _myOwnerShipChangePrevious;
	self.myTerminal				:= _myTerminal;	
