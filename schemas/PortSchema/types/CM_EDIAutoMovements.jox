    <JadeMethod name="setForUpdate" id="001f4045-051f-4585-8250-2b101e646fc5">
        <updating/>
        <source>setForUpdate(_pxy : SelfType) updating;
// ##### CR 64615 TASK 64646 NAVAB1 03JUL2024
vars
	voyStatus : CM_VoyageStatus;
begin

	self.minutesOffset := _pxy.minutesOffset;
	self.voyageDateType := _pxy.voyageDateType;
	self.myTranshipDischargeLC := _pxy.myTranshipDischargeLC;
	
	self.myVoyageStatusForClosure := _pxy.myVoyageStatusForClosure;
	
	if self.voyageDateType &lt;= 0 then
		self.voyageDateType := Voyage_Arrival;
	endif;
epilog

end;</source>
        <Parameter name="_pxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="7749d5d0-4741-403f-b4ad-1067f4890828">
        <updating/>
        <source>setProxy(_term : CM_Terminal; _minsOffset : Integer; _voyDateType : Integer; _tsDisLC : CM_LocationsController;  _voyStatus : CM_VoyageStatus)  updating;
// ##### CR 64615 TASK 64646 NAVAB1 03JUL2024
vars

begin

	self.myTerminal := _term;
	self.minutesOffset := _minsOffset;
	self.myTranshipDischargeLC := _tsDisLC;
	self.myVoyageStatusForClosure := _voyStatus;
	self.voyageDateType := _voyDateType;
epilog

end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_minsOffset" type="Integer"/>
        <Parameter name="_voyDateType" type="Integer"/>
        <Parameter name="_tsDisLC" type="CM_LocationsController"/>
        <Parameter name="_voyStatus" type="CM_VoyageStatus"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="cc83e2f3-803a-43d5-ae09-259484fa3937">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
// ##### CR 64615 TASK 64646 NAVAB1 03JUL2024
begin

	if _property.name = CM_EDIAutoMovements::minutesOffset.name 
	or _property.name = CM_EDIAutoMovements::voyageDateType.name 
	or _property.name = CM_EDIAutoMovements::myTerminal.name 
	or _property.name = CM_EDIAutoMovements::myVoyageStatusForClosure.name 
	or _property.name = CM_EDIAutoMovements::myTranshipDischargeLC.name then
		return false;
	endif;
	
	return inheritMethod(_rootClass, _property);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="b9867b36-ffac-43e4-8bc4-39d19384d5ba">
        <source>validateForCreate();
// ##### CR 64615 TASK 64646 NAVAB1 03JUL2024
vars

begin

	if self.myTerminal = null then
		app.raiseCMException(Auto_movem_confi_must_have_ter,null,null);
	endif;

	self.validateForUpdate();
epilog

end;</source>
    </JadeMethod>
