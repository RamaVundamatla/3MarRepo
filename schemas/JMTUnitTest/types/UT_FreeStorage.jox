	storageDetail := self.addStorageDetail(storageConfig,"UTREBAR", criteria, values, 5, 0, _chargedDaysWorking, _freeDaysWorking, 0,0,false,null);


	return storageConfig;
epilog
	delete criteriaTypes;
	delete criteria;
	delete values;
	if allTransients &lt;&gt; null then
		allTransients.purge();
		delete allTransients;
	endif;

