    <JadeMethod name="doConfigSave" id="53652991-d3d5-4538-a1b0-fc29258ec6f3">
        <source>doConfigSave();
// ---------------------------------------------------------------------------
// Created:     06 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	numRows,
	idx			: Integer;
	constant	: Constant;
	obj			: Object;
	lvlOperator,
	lvlRoot,
	lvlTerminal	: Boolean;
	textStr,
	oldStr,
	xmlStr		: String;

begin

	beginTransaction;

	numRows := tblData.rows;
	foreach idx in 1 to numRows do
		obj := tblData.accessRow(idx).itemObject;
		if obj = null then
			continue;
		endif;
		if (not obj.isKindOf(Constant)) then
			continue;
		endif;
		if tblData.accessCell(idx, 3).text = '0' then
			lvlRoot := false;
		else
			lvlRoot := true;
		endif;
		if tblData.accessCell(idx, 4).text = '0' then
			lvlTerminal := false;
		else
			lvlTerminal := true;
		endif;
		if tblData.accessCell(idx, 5).text = '0' then
			lvlOperator := false;
		else
			lvlOperator := true;
		endif;
		
		xmlStr := self.formatAsXML(CMIF_Config.XMLTag_LvlRoot, lvlRoot.String) &amp;
				  self.formatAsXML(CMIF_Config.XMLTag_LvlTerminal, lvlTerminal.String) &amp; 
				  self.formatAsXML(CMIF_Config.XMLTag_LvlOperator, lvlOperator.String);
				  
		textStr := obj.Constant.text;
		oldStr := textStr.cnEcGetTagValueOfName(CMIF_Config.XMLTag_ConstDtls);
		if oldStr &lt;&gt; null then
			// replace what was there
			textStr := textStr.replaceString(oldStr, CrLf &amp; xmlStr);
		else
			// append to existing as there maybe a comment in the text
			textStr := textStr &amp; CrLf &amp;
					  self.formatAsXMLPrefix(CMIF_Config.XMLTag_ConstDtls) &amp;
					  xmlStr &amp;
					  self.formatAsXMLSuffix(CMIF_Config.XMLTag_ConstDtls);
		endif;	  
		obj.Constant.setText(textStr);
	endforeach;
	
	commitTransaction;

end;</source>
    </JadeMethod>
    <JadeMethod name="doExportExceptions" id="9337360b-a536-4ffa-bfd2-ace63b4562b1">
        <source>doExportExceptions();

vars
	file 	: File;
	cmdSave	: CMDFileSave;
	category : ConstantCategory;
	constant : Constant;
	row, col	: Integer;
	header		: String;
	line		: String;
begin
	create cmdSave transient;
	cmdSave.initDir := app.getJadeLogDir;
	cmdSave.fileName := 'JMT_Exception_Export_' &amp; app.actualTimeServer.date.format('yyyyMMdd') &amp; '.csv';
//	cmdSave.defaultExt := '.csv';
	if cmdSave.open &lt;&gt; 0 then
		return;
	endif;

	create file transient;
	file.usePresentationFileSystem := true;
	file.fileName := cmdSave.fileName;
	
	// header row lists locales being exported
//	file.writeLine('JMT Label,JMT ID,Message,Short Message,Message,Short Message');
	
	// now export each message
	foreach row in 1 to tblData.rows do // NAVAB1 changed to include the headings
		line := null;
		foreach col in 1 to tblData.columns do
			line := line &amp; tblData.getCellText(row,col).csvFormat;
			if col &lt; tblData.columns then
				line := line &amp; ',';
			endif;
		endforeach;
		file.writeLine(line);
	endforeach;
	
	app.msgBox("Export to CSV file complete" &amp; CrLf &amp; file.fileName, 'Export Messages', MsgBox_Information_Icon);
	
epilog
	delete cmdSave;
	if file &lt;&gt; null then
		file.close;
	endif;
	delete file;
end;</source>
    </JadeMethod>
    <JadeMethod name="doFilterTable" id="a092e871-e127-4186-b433-27ea71064a10">
        <updating/>
        <source>doFilterTable() updating;
/*
Purpose:			

Date		Who		Reason
05 July 2023	navab1	 
*/

vars
	filterText 	: String;
	rowIdx,
	colIdx,
	start,
	rows		: Integer;
	cell 		: JadeTableCell;
	cellText 	: String;
	tbl			: Table;
	
begin
    rows		:= 0;
	filterText  := self.txtFilterBox.text.toUpper();
	tbl			:= self.tblData;
	
	if filterText = "" then
		self.clearFilter();
		return;
	else
		self.btnClearFilter.enabled := true;
	endif;

	start := tbl.fixedRows + 1;
	
	foreach rowIdx in start to tbl.rows do : rowLoop
		tbl.accessRow(rowIdx);
		
		foreach colIdx in 1 to tbl.columns do
			cell 	 := tbl.accessCell(rowIdx, colIdx);
			cellText := cell.text.toUpper;
			
			if cellText.length &gt; 0 and cellText.pos(filterText, 1) &gt; 0 then
				tbl.accessedRow.visible := true;
				rows := rows+1;
				continue rowLoop;
			endif;
		endforeach;
		
		tbl.accessedRow.visible := false;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doHandleInitializeException" id="8e5404e3-e1c8-4bf1-8c99-9fbcac692112">
        <updating/>
        <source>doHandleInitializeException(exObj : Exception; _error : Integer io) : Integer updating;
/*
Purpose:		catch any Exception on startup of Dev apps	

Parameters:		_error will be set if there is an error	

Return Value:	Ex_Resume_Next

Date		Who		Reason
12 June 2009	conkc1	Initial creation
*/
vars

begin
	_error := exObj.errorCode;
	return Ex_Resume_Next;
epilog

end;</source>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_error" type="Integer" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
