    <JadeMethod name="setForCreate" id="ddd499dd-dda9-45f9-a93f-043c40af3ceb">
        <updating/>
        <source>setForCreate(	_form : RadioTelemetryMainForm input; _name, _text : String;
				_parent : Control; _top : Real ) updating;
// -------------------------------------------
// Created 02 may 2008 by cnwvu1
// -------------------------------------------

vars

begin

	self.name	:= _name;
	self.text	:= _text;
	self.parent	:= _parent;
	self.top	:= _top;
	
	_form.addControl( self );
	
end;
</source>
        <Parameter name="_form" type="RadioTelemetryMainForm" usage="input"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_text" type="String"/>
        <Parameter name="_parent" type="Control"/>
        <Parameter name="_top" type="Real"/>
    </JadeMethod>
