/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2017	cnwns1	Initial creation
25/01/17 cnwns1 TFS3214 LNX - Voyage Operations Enhancements 
*/

vars

begin
	self.initialiseActivity();
	

	self.raiseExceptionIfNull(_voyage, 'Voyage');	
	self.raiseExceptionIfNull(_voyageEventTypes, 'VoyageEvents');	
	
	_voyage.setAllocatedEvents(_voyageEventTypes);
	
	
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
