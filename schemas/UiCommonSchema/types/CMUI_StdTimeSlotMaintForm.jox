        <updating/>
        <source>mnuInspect_click(menuItem: MenuItem input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
20 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	timeSlot : CM_TimeSlotEntity;

begin
	if menuItem.userObject &lt;&gt; null then
