    <JadeMethod name="setForProxy" id="b6b8facc-3a29-4865-ab49-9c8ac97f9155">
        <updating/>
        <source>setForProxy(pAvail: Integer; pUsage: Integer; pGridRow: Integer; pGridColumn: Integer; pName: String; pWidth: Real; pPower: Boolean; pPowerDamaged: Boolean; pRemarks: String; pGridArea: CM_GridArea; 
					_is45Ft : Boolean; _offset45 : Integer; _is30Ft : Boolean; _offset30 : Integer; _is53Ft : Boolean; _offset53 : Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	14 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	avail : Integer;
	
begin

	self.raiseExceptionIfNotTransient(method);
	
	avail := pAvail;
	pGridArea.getAvailUse(pGridRow, avail); 
	self.availability	:= avail;
	self.usage			:= pUsage;
	self.is45ft			:= _is45Ft;
	self.offset45 		:= _offset45;
	inheritMethod(pAvail, pUsage, pGridRow, pGridColumn, pName, pWidth, pPower,	pPowerDamaged, pRemarks, pGridArea, _is45Ft, _offset45, _is30Ft, _offset30, _is53Ft, _offset53);

end;</source>
        <Parameter name="pAvail" type="Integer"/>
        <Parameter name="pUsage" type="Integer"/>
        <Parameter name="pGridRow" type="Integer"/>
        <Parameter name="pGridColumn" type="Integer"/>
        <Parameter name="pName" type="String"/>
        <Parameter name="pWidth" type="Real"/>
        <Parameter name="pPower" type="Boolean"/>
        <Parameter name="pPowerDamaged" type="Boolean"/>
        <Parameter name="pRemarks" type="String"/>
        <Parameter name="pGridArea" type="CM_GridArea"/>
        <Parameter name="_is45Ft" type="Boolean"/>
        <Parameter name="_offset45" type="Integer"/>
        <Parameter name="_is30Ft" type="Boolean"/>
        <Parameter name="_offset30" type="Integer"/>
        <Parameter name="_is53Ft" type="Boolean"/>
        <Parameter name="_offset53" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="4e09de04-914e-4c69-a003-3b32371e496b">
        <updating/>
        <source>setForUpdate(pProxy: CM_RTGController; pGridArea: CM_GridArea) updating;
/*
----------   ----------  --------------------------------------------------
Created:	14 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason	
----------   ----------  --------------------------------------------------
09/03/2011	cnwcs5		CCMS CPL 2017/PAR 27126 - audit changes to usage
*/
vars
	previousGridColumn 					: CM_GridColumn;
	newLabel 							: String;
begin
	inheritMethod(pProxy, pGridArea);

	// CCMS CPL 2017/PAR 27126 - start
	self.createTALocationsAudits_Usage (pProxy, pGridArea);	// CCMS CPL 2017/PAR 27126	
	
	// audit change to location availability
	self.createTALocationsAudits_Avail (pProxy, pGridArea);
	// CCMS CPL 2017/PAR 27126 - end
	self.availability 	:= pProxy.availability;
	self.usage 			:= pProxy.usage;
	//epr par 20313
	//self.ident40ft		:= pProxy.ident40ft;
	//if self.ident40ft = null then
	/*
	// PAR 14387
	if app.myRoot.isClientGdansk() then
		self.ident40ft := (self.myGridColumn.label.Integer - 1).String;
	else
		self.ident40ft := (self.myGridColumn.label.Integer + 1).String;
	endif;
	//endif;*/
	
	if self.availability = PAD_AVAILABLE and self.usage = UNAVAILABLE_USE then
		self.usage := NORMAL_USE;
	endif;
	
end;</source>
        <Parameter name="pProxy" type="CM_RTGController"/>
        <Parameter name="pGridArea" type="CM_GridArea"/>
    </JadeMethod>
