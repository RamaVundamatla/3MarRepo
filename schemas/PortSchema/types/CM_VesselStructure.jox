    <JadeMethod name="validateCreate" id="c5316a5d-db0d-4d28-8d80-935e9c260932">
        <source>validateCreate(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	31 January 2006 By: cnwgd1
//--------------------------------------------------
vars

begin

	if self.myVessel = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Vessel), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Vessel), null, null); // cnwdb2	PAR 35364


	endif;	
	if self.myRoot = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Root), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Root), null, null); // cnwdb2	PAR 35364


	endif;

	if self.type &lt;= StructureTypeNull
	or self.type &gt;= StructureTypeMax then
	//	app.raiseCMException1(REQUIRED_FIELD,app.getErrorString(TYPE), null, null);
		app.raiseCMException1(Input_required_field_Required,app.getErrorString(TYPE), null, null);

	endif;	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="f11ae105-060d-4ad7-9ccb-17df7b2cf0f9">
        <source>validateMe(_passport: CM_Passport input) protected;
//--------------------------------------------------
// Created:	30 January 2006 By: cnwgd1
//--------------------------------------------------
vars

begin
	//root is never set from the proxy it is always set from app.myRoot no point in validating it 
	
	/*if self.myRoot = null then
		app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Root), null, null);
	endif;*/

	if self.type &lt;= StructureTypeNull
	or self.type &gt;= StructureTypeMax then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(TYPE), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(TYPE), null, null);// cnwdb2	PAR 35364
	endif;	
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
