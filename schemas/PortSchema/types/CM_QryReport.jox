    <JadeMethod name="canOutputToText" id="9f4de190-1eca-4f62-8ac2-9ca2370b31ba">
        <source>canOutputToText() : Boolean;
/*
Purpose:	

Date		Who		Reason
19 September 2024	navab1	CR 65813 TASK 65877
*/

vars

begin
	return self.reportFormats.includes(JadeReportWriterReport.XML)
			or self.reportFormats.includes(JadeReportWriterReport.CSV)
			or self.reportFormats.includes(JadeReportWriterReport.TEXT)
			or self.reportFormats.includes(JadeReportWriterReport.HTML)
			or self.reportFormats.includes(JadeReportWriterReport.RTF);
				

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
