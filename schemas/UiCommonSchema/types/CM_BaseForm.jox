    <JadeMethod name="doShowHelpFile" id="0923c626-5b47-4acc-92c1-56d0cde3ec6a">
        <updating/>
        <source>doShowHelpFile(_helpFileName : String) updating;
/*

Purpose:			Show the help file passed in, based on cofigured help format

Parameters:			Help file name

Return Value:		None

Date		Who		Reason
29 May 2014	cnwkpd1	PAR #34210 - CCMS SFW 1350 - Online Documentation

*/

vars

begin
	if app.helpIsHTMLFormat then
		self.frmToolbar.helpKeyword := '#resources/' &amp; _helpFileName &amp; '/title/title.htm';
		self.frmToolbar.showHelp();
	else
		app.showHelp(self.hwnd, _helpFileName);
	endif;
	
epilog

end;</source>
