    <JadeMethod name="create" id="3cf6ed2b-64ba-4c5e-a8bc-b57c686198b8">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     26 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.loadFromXML();
end;</source>
    </JadeMethod>
    <JadeMethod name="loadFromXML" id="00d8bada-69bf-4aa1-9fca-b27d701aa372">
        <updating/>
        <source>loadFromXML() updating;
// ---------------------------------------------------------------------------
// Created:     26 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	xmlText			: String;
	constant		: Constant;
	baseScm 		: Schema;
	category 		: ConstantCategory;
	constDict		: ConstantNDict;
	useColorStr		: String;
begin 
	baseScm := rootSchema.getSchema(PortSchemaName);
	category := baseScm.getCategory(WarehouseConstants);
	constDict := category.getConstants();
	constant := constDict['WH_RowColorDefinition'];
	
	xmlText := constant.text;

	useColorStr := xmlText.cnEcGetTagValueOfName('UseColors');
	if useColorStr.toUpper = 'TRUE' then
		self.useColors := true;
	else
		self.useColors := false;
	endif;
	
	self.alternateColorOne := xmlText.cnEcGetTagValueOfName('AlternateOne').Integer;
	self.alternateColorTwo := xmlText.cnEcGetTagValueOfName('AlternateTwo').Integer;
	self.fullyLoaded := xmlText.cnEcGetTagValueOfName('FullyLoaded').Integer;
	self.partiallyLoaded := xmlText.cnEcGetTagValueOfName('PartiallyLoaded').Integer;
	self.unallocated := xmlText.cnEcGetTagValueOfName('Unallocated').Integer;
end;</source>
    </JadeMethod>
    <JadeMethod name="saveToXML" id="1605d2b5-b313-494f-9fb6-b1abdcc0790f">
        <source>saveToXML(_useColors : Boolean;
	_alternateOne,
	_alternateTwo,
	_fullyLoaded,
	_partiallyLoaded,
	_unallocated : Integer);
// ---------------------------------------------------------------------------
// Created:     26 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	xmlText				: String;
	constant			: Constant;
	baseScm 			: Schema;
	category 			: ConstantCategory;
	constDict			: ConstantNDict;
	useColorsStr		: String;
begin

	baseScm := rootSchema.getSchema(PortSchemaName);
	category := baseScm.getCategory(WarehouseConstants);
	constDict := category.getConstants();
	constant := constDict['WH_RowColorDefinition'];
	if _useColors then
		useColorsStr := 'true';
	else
		useColorsStr := 'false';
	endif;
	xmlText := constant.text;
	xmlText.cnEcSetTagValueOfName(UseColors, useColorsStr);
	xmlText.cnEcSetTagValueOfName(AlternateOne, _alternateOne.String);
	xmlText.cnEcSetTagValueOfName(AlternateTwo, _alternateTwo.String);
	xmlText.cnEcSetTagValueOfName(FullyLoaded, _fullyLoaded.String);
	xmlText.cnEcSetTagValueOfName(PartiallyLoaded, _partiallyLoaded.String);
	xmlText.cnEcSetTagValueOfName(Unallocated, _unallocated.String);
	beginTransaction;
	constant.setText(xmlText);
	commitTransaction;
	
end;</source>
        <Parameter name="_useColors" type="Boolean"/>
        <Parameter name="_alternateOne" type="Integer"/>
        <Parameter name="_alternateTwo" type="Integer"/>
        <Parameter name="_fullyLoaded" type="Integer"/>
        <Parameter name="_partiallyLoaded" type="Integer"/>
        <Parameter name="_unallocated" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="set" id="b7a4a938-ff3b-4c0d-8c8b-decf28b1e040">
        <updating/>
        <source>set(_useColors : Boolean;
	_alternateOne,
	_alternateTwo,
	_fullyLoaded,
	_partiallyLoaded,
	_unallocated : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     26 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	xmlText				: String;
	constant			: Constant;
	baseScm 			: Schema;
	category 			: ConstantCategory;
	constDict			: ConstantNDict;
	useColorsStr		: String;
begin 
	beginTransaction;
	self.useColors := _useColors;
	self.alternateColorOne := _alternateOne;
	self.alternateColorTwo := _alternateTwo;
	self.fullyLoaded := _fullyLoaded;
	self.partiallyLoaded := _partiallyLoaded;
	self.unallocated := _unallocated;
	commitTransaction;
	
	self.saveToXML(self.useColors,
					self.alternateColorOne,
					self.alternateColorTwo,
					self.fullyLoaded,
					self.partiallyLoaded,
					self.unallocated);
end;</source>
        <Parameter name="_useColors" type="Boolean"/>
        <Parameter name="_alternateOne" type="Integer"/>
        <Parameter name="_alternateTwo" type="Integer"/>
        <Parameter name="_fullyLoaded" type="Integer"/>
        <Parameter name="_partiallyLoaded" type="Integer"/>
        <Parameter name="_unallocated" type="Integer"/>
    </JadeMethod>
</Class>
