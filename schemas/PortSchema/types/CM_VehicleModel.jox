	self.validateMe();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="c2facb15-c06d-4c07-83b0-abd9ddbb1a74">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	if self.model = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Model), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Model), null, null); // cnwdb2	PAR 35364
	endif;
epilog

end;</source>
    </JadeMethod>
