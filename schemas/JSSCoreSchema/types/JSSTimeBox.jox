    <JadeMethod name="alterField" id="29ae8b52-9280-4d58-aedc-bf625050e2a3">
        <updating/>
        <source>alterField(pIncrement: Boolean) updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Purpose:		Refer to the superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fieldNumber		: Integer;
	modValue		: Integer;
	originalTime	: Time;
	
begin
	fieldNumber		:=	self.getCurrentFieldNumber();
	originalTime	:=	self.getTime();
	
	if fieldNumber = 1 then
		modValue	:=	24;				// hour value
	elseif fieldNumber = 2 then
		modValue	:=	60;				// minute value
	else
		modValue	:=	60;				// second value
	endif;
	
	self.selectFieldNumber(fieldNumber);
	
	if pIncrement then		// Increment the value.
		self.selText	:=	(self.selText.Integer.jssAdd(1) mod modValue).String.padLeadingZeros(2);
	else					// Decrement the value.
		if self.selText.Integer &gt; 0 then
			self.selText	:=	(self.selText.Integer.jssTake(1) mod modValue).String.padLeadingZeros(2);
		else
			self.selText	:=	(modValue - 1).String.padLeadingZeros(2);
		endif;
	endif;
	
	self.thinClientUpdate();
	
	if self.getTime() &lt;&gt; originalTime then
		// Update changes...
		//self.setTime(self.getTime());
	endif;

	self.selectFieldNumber(fieldNumber);
end;</source>
        <access>protected</access>
        <Parameter name="pIncrement" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkAllSelected" id="2dcd75b8-5057-4508-9689-e977960a9a83">
        <updating/>
        <source>checkAllSelected() updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Purpose:		Kludge to fix a problem where the whole text becomes selected, not
//				just the field being edited - if the whole text is selected, then
//				field 1 will be reselected.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.selLength = (self.text.length - 4) then
		// somehow every field (i.e. the whole control contents) has become selected
		// this very bad - select just the hour portion
		self.selStart	:=	1;
		self.selectFieldNumber(self.getCurrentFieldNumber());
		self.thinClientUpdate();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getTime" id="03cf4abd-b2e5-4d50-954c-5e85760ec6be">
        <source>getTime():Time;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Purpose:		Returns the receiver's current time value.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	timeValue	: Time;
	
begin
	if self.formatString = self.FORMAT2 then
		timeValue.setTime(self.getFieldValue(1), self.getFieldValue(2), self.getFieldValue(3), 0);
	elseif self.formatString = self.FORMAT1 then
		timeValue.setTime(self.getFieldValue(1), self.getFieldValue(2), 0, 0);
	endif;
	
	return timeValue;
end;</source>
        <ReturnType type="Time"/>
    </JadeMethod>
