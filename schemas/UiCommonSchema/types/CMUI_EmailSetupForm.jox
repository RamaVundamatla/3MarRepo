    </JadeMethod>
    <JadeMethod name="translateForm" id="7c5e6156-b524-487d-9f89-cad4f6cd6080">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007420, locale);
	frSelector.translateCaption(Xlat_0000381, locale);
	lblBodyHdg.translateCaption(Xlat_0000382, locale);
	lblSubjectHdg.translateCaption(Xlat_0000380, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="zTranslateDONOTEDIT" id="c2b2c060-7fb3-4aea-8bc6-5e54f65cc8e2">
        <updating/>
        <source>zTranslateDONOTEDIT() updating, protected;

/* 
	IMPORTANT DEVELOPERS NOTE
	
	THIS METHOD HAS BEEN AUTOMATICALLY CREATED AS PART OF THE TEXT TRANSLATION PROCESS,
	AND ANY CHANGES WILL BE OVERWRITTEN DURING SUBSEQUENT JM TERMINAL RELEASES. 
	TRANSLATION-SPECIFIC CODE CAN BE IMPLEMENTED IN translateFormSpecial()
*/

	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars

begin
	frSelector.caption := app.getFormText(Xlat_0000381, frSelector, caption);
	lblBodyHdg.caption := app.getFormText(Xlat_0000382, lblBodyHdg, caption);
	lblSubjectHdg.caption := app.getFormText(Xlat_0000380, lblSubjectHdg, caption);

end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
