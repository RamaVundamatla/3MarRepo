    <JadeMethod name="cloneMySelf" id="cbd46afb-cc61-4362-9f5a-b29d0f408592">
        <source>cloneMySelf( _transient : Boolean) : SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 September 2013	cnwrd1	Initial creation

*/

vars
	newVessel : CM_VesselStructuralElements;
	aTank, newTank : CM_VesselTank;
	aSection, newSection : CM_VesselSection;
	aRamp , newRamp : CM_RORORampExternalVessel;
begin
	newVessel := self.cloneSelf(_transient);
	
	foreach aTank in self.allTanks do
		newTank := aTank.CM_VesselTankVessel.cloneMySelf(newVessel);
	endforeach;
	
	foreach aSection in self.allSections do
		newSection := aSection.CM_VesselSectionVessel.cloneMySelf(newVessel);
	endforeach;
	
	foreach aRamp in self.allRamps do
		newRamp := aRamp.CM_RORORampExternalVessel.cloneMySelf(newVessel);
	endforeach;

	return newVessel;
epilog

end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="doCreateProxySectionsFromXML" id="3f19cdf9-2710-42b5-8eb5-c035d950236c">
        <source>doCreateProxySectionsFromXML(_theXML : String) protected;
/*
Purpose:			
Date				Who			Reason
MAY 2011		CNWAB1		Initial creation
*/

vars
	code, remarks, theXML : String;
	 pos : Integer;
	maxAxel, maxM2, maxStack, maxTotal, position : Decimal[12,2];
	pxySection : CM_VesselSectionVessel;
begin
	pos := 1;
	
	while (pos &gt; 0) do
		theXML := _theXML.cnEcGetNextTagValueOfName("SECT",pos); 
		if theXML = null then
			break;
		endif;
		
		code := theXML.cnEcGetTagValueOfName("SECODE"); 
		maxAxel := theXML.cnEcGetTagValueOfName("SMAXAXEL").Decimal; 
		maxM2 := theXML.cnEcGetTagValueOfName("SMAXM2").Decimal; 
		maxStack := theXML.cnEcGetTagValueOfName("SMAXSTACK").Decimal; 
		
		maxTotal := theXML.cnEcGetTagValueOfName("SMAXTOTAL").Decimal; 
		position := theXML.cnEcGetTagValueOfName("SPOS").Decimal; 
		remarks := theXML.cnEcGetTagValueOfName("SREMARKS"); 


		create pxySection transient;
		pxySection.setProxy(code, position, remarks);
		pxySection.setMyVesselStructElements(self);
	endwhile;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_theXML" type="String"/>
    </JadeMethod>
    <JadeMethod name="doCreateProxyTanksFromXML" id="74db36e5-ff34-4a6f-a8f0-76cda8b51eab">
        <source>doCreateProxyTanksFromXML(_theXML : String) protected;
/*
Purpose:			
Date				Who			Reason
MAY 2011		CNWAB1		Initial creation
*/

vars
	typeCode, code, desc, remarks, theXML : String;
	 pos : Integer;
	voluume : Decimal[12,2];
	pxyTank : CM_VesselTankVessel;
	aType : CM_VesselTankContentsType;
begin
	pos := 1;
	
	while (pos &gt; 0) do
		theXML := _theXML.cnEcGetNextTagValueOfName("TANK",pos); 
		if theXML = null then
			break;
		endif;
		
		code := theXML.cnEcGetTagValueOfName("TCODE"); 
		typeCode := theXML.cnEcGetTagValueOfName("TTYPE"); 
		desc := theXML.cnEcGetTagValueOfName("TDESC"); 
		voluume := theXML.cnEcGetTagValueOfName("TVOL").Decimal; 
		remarks := theXML.cnEcGetTagValueOfName("TREMARKS"); 
	
		aType := app.myRoot.allVesselTankContentsTypes[typeCode];

		create pxyTank transient;
		pxyTank.setProxy(code, desc, remarks,voluume, aType);
		pxyTank.setMyVesselStructElements(self);
	endwhile;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_theXML" type="String"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLDocGetChildRefKey" id="5e37a0e7-22e9-4683-8277-a8f550596b94">
        <source>exportAsXMLDocGetChildRefKey(_property: Property input): Property;
/*

Date		Who		Reason
27 September 2013	cnwer1	Initial creation PAR

*/

vars

begin
	if _property = CM_VesselStructuralElements::myVessel then
		return CM_Vessel::code;
	endif;
	return inheritMethod(_property);

epilog

end;</source>
        <Parameter name="_property" type="Property" usage="input"/>
        <ReturnType type="Property"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLInverseRef" id="0610698e-fbb6-4b32-8e7c-c0417cb2f8c4">
        <source>exportAsXMLInverseRef(_property: Reference): Integer protected;
/*

Date		Who		Reason
27 September 2013	cnwer1	Initial creation PAR

*/

vars

begin
	if _property = CM_VesselStructuralElements::allTanks then
		return ExportAsParent;
	elseif _property = CM_VesselStructuralElements::allSections then
		return ExportAsParent;
	elseif _property = CM_VesselStructuralElements::allRamps then
		return ExportAsParent;
	elseif _property = CM_VesselStructuralElements::myVessel then
		return ExportAsChild;
	endif;

	return inheritMethod(_property);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Reference"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="a6877945-7749-4612-8831-989eafa5b5c0">
        <source>getAuditText(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 September 2013	cnwrd1	Initial creation

*/


vars
	auditText : String;
	tmpStr	 : String;
	section : CM_VesselSection;
	tank 	: CM_VesselTank;
	ramp 		: CM_RORORampExternalVessel;
begin
	auditText:= inheritMethod();

	tmpStr:=null;
	foreach section in self.allSectionsByPosition do
		if tmpStr = null then
			tmpStr := section.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; section.code;
		endif;
	endforeach;
	auditText := auditText &amp; 'Vessel Sections ' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	tmpStr:=null;
	
	foreach tank in self.allTanks do
		if tmpStr = null then
			tmpStr := tank.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; tank.code;
		endif;
	endforeach;
	auditText := auditText &amp; 'Vessel Tanks ' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;

	
	foreach ramp in self.allRamps do
		if tmpStr = null then
			tmpStr := ramp.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; ramp.code;
		endif;
	endforeach;
	auditText := auditText &amp; 'Vessel Ramps ' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	
	return auditText;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSectionByPosition" id="7e10f007-e318-444c-b0f7-e93f31d8a4a1">
        <source>getSectionByPosition(_pos : Decimal; _variance : Decimal) : CM_VesselSection;
/*
Purpose:			
Date		Who		Reason
28 April 2011	cnwab1	Initial creation
*/

vars
	tmpSect : CM_VesselSection;
	pos : Decimal[12,2];
begin
	pos := _pos - _variance;
	
	tmpSect := self.allSectionsByPosition.getAtKeyGeq(pos);
	
	if tmpSect &lt;&gt; null then
		if tmpSect.position &lt;= (_pos + _variance) then
			return tmpSect;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_pos" type="Decimal"/>
        <Parameter name="_variance" type="Decimal"/>
        <ReturnType type="CM_VesselSection"/>
    </JadeMethod>
    <JadeMethod name="getXMLDefinitionString" id="49064c51-1d7c-425f-84e5-f8e01e68659f">
        <source>getXMLDefinitionString() : String;

vars
	xml, hml, sml : String;
	aSect : CM_VesselSection;
	aTank : CM_VesselTank;
begin
	

	hml := "&lt;SECTIONS&gt;";
	foreach aSect in self.allSections do
		hml := hml &amp; aSect.getDefinitionXML();
	endforeach;
	hml := hml &amp; "&lt;/SECTIONS&gt;";
	xml := xml &amp; hml;	

	hml := "&lt;TANKS&gt;";
	foreach aTank in self.allTanks do
		hml := hml &amp; aTank.getDefinitionXML();
	endforeach;
	hml := hml &amp; "&lt;/TANKS&gt;";
	xml := xml &amp; hml;	

	
	return xml;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="importFromXMLDocReference" id="e8200208-6756-45f5-a547-b9aa22e7da59">
        <updating/>
        <source>importFromXMLDocReference(_property: Property; _xmlElement: JadeXMLElement input) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 September 2013	cnwrd1	Initial creation

*/

vars

	allChildElements 	: JadeXMLElementArray;
	childElement 		: JadeXMLElement;
	pxyTank  			: CM_VesselTankVessel;
	pxySection			: CM_VesselSectionVessel;
begin
	if _property = CM_VesselStructuralElements::allTanks then
		create allChildElements transient;
		_xmlElement.getAllElementsByTagName(CM_VesselTankVessel.name,allChildElements);
		foreach childElement in allChildElements do
			create pxyTank transient;
			pxyTank.setMyVesselStructure(self);
			pxyTank.importFromXMLDoc(childElement);
		endforeach;
	elseif _property = CM_VesselStructuralElements::allSections then
		create allChildElements transient;
		_xmlElement.getAllElementsByTagName(CM_VesselSectionVessel.name,allChildElements);
		foreach childElement in allChildElements do
			create pxySection transient;
			pxySection.setMyVesselStructure(self);
			pxySection.importFromXMLDoc(childElement);
		endforeach;
	else
		inheritMethod(_property, _xmlElement);
	endif;
	
epilog
	delete allChildElements;
end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="569454fa-64b0-418b-8902-2c34a76c23d3">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 September 2013	cnwrd1	Initial creation

*/

vars
	proxyVessel:CM_VesselStructuralElements;
	completedOK		: Boolean;
begin

	proxyVessel := inheritMethod();


	/*foreach aHold in self.allHolds do
		pHold := aHold.pxyCreateUpdateProxy();
		
		pHold.CM_VesselHold.setProxy(proxyVessel,pHold.ordinalHold);
	endforeach;*/
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyVessel;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyVessel;
	endif;
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
