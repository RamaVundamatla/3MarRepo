    <JadeMethod name="create" id="93e60811-47c6-4821-bffb-c86bc6e618dd">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if not shouldIShow then
		return;
	endif;
	self.permissionView  := PmAdmInvoicelinesView;
	self.permissionMaint := PmAdmInvoicelinesMaint;
	self.helpFileName := HelpFile_Invoicing;
	
	self.isDisplayingInvoiceLines := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="displayInvoiceLine" id="858f8f53-0df8-48ff-8a86-fabe4cb5b2ee">
        <source>displayInvoiceLine();
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
// 24 Sep 2019		jlgzm1			TFS 46054 STWO - Adding Extra Details to Manual Invoice Lines
// 27 Ceb 2020      cnwma1			Bug 48666: JMT - Class information is being shown in the 'Invoice Line' additional details {Cargo Terminal Area, Cargo Location, Cargo Operator, etc...}
// 05 May 2021		navdap1			TFS 51154 ASPA Manual Invoice Line Start Date
vars

	theTable   	: CM_EntryTable;
	theNarrRow, theRemRow 	: Integer;
	invLine     : CM_InvoiceLine; 
	ti          : CM_TrackedItem;
	canManualUpdateExtRef : Boolean; //08/12/2025	navkc1 JIRA 36262
begin

	if self.myCurrentInvoice = null then
		return;
	endif;
	
	if self.currentView = null then
		return;
	endif;
	
	if self.currentView =  ETView_InvListInvLinePropVoid then
		return;
	endif;
	
	theTable   := self.tblInvProperties;
	/* // ### JIRA 33007 03DEC2024 NAVAB1
	theNarrRow := theTable.getRowByName(ETRow_Narration300);	// par 24035 narration length to 300
	theTable.accessCell(theNarrRow,CM_EntryTable.ColumnValue).wordWrap := true;
	theTable.accessRow(theNarrRow).height := 50; 
	*/
	
	// ### JIRA 33007 03DEC2024 NAVAB1
	theRemRow := theTable.getRowByName(ETRow_Remarks300);
	theTable.accessCell(theRemRow,CM_EntryTable.ColumnValue).wordWrap := true;
	theTable.accessRow(theRemRow).height := 50; 

	// ### JIRA 33007 03DEC2024 NAVAB1 self.txtNarr.height 				  := 50;
	self.btnSearchCargo.visible 		  := true;               // TFS 46054
	self.btnSearchCargo.enabled 		  := true;	             // TFS 46054
 	
	if self.currentView = ETView_InvListInvLinePropNew then
		
		self.btnNext.enabled        := self.myCurrentInvoice &lt;&gt; null and	self.getStatusGood();
		self.btnSaveBase.enabled    :=  self.btnNext.enabled;
		theTable.setValueByName(ETRow_Quantity,"1.0000");
		theTable.setValueByName(ETRow_StartDate, self.systemToLocalTime(app.actualTimeServer).date);	
		
		theTable.enableRowByName(ETRow_InvoiceNumber);
		theTable.enableRowByName(ETRow_Debtor);	
		theTable.goToRowByName(ETRow_InvLineType); 
	else
		
		invLine := self.myCurrentInvoiceLine;
		if invLine &lt;&gt; null then
		
			
			// ### JIRA 33007 03DEC2024 NAVAB1 - self.txtNarr.text := invLine.remarks; 
			// ### JIRA 33007 03DEC2024 NAVAB1 theTable.setValueByName(ETRow_Narration300, invLine.remarks); // ### JIRA 33007 03DEC2024 NAVAB1
			theTable.setValueByName(ETRow_Remarks300, invLine.remarks); // ### JIRA 33007 03DEC2024 NAVAB1
			theTable.setValueByName(ETRow_InvoiceNumber,invLine.invoice.sequenceNum);	//18 May 2021	NDL	TFS 51194
			theTable.setValueByName(ETRow_InvoiceLineNumber,invLine.sequenceNum);	//18 May 2021	NDL	TFS 51194
			theTable.setValueByName(ETRow_Debtor,		invLine.debtor.name);
			theTable.disableRowByName(ETRow_InvoiceNumber);
			
			theTable.disableRowByName(ETRow_Debtor);
			theTable.hideRowByName(ETRow_Quantity,false);
			theTable.hideRowByName(ETRow_CargoType,false);
			theTable.hideRowByName(ETRow_CargoId,false);
			theTable.hideRowByName(ETRow_CargoOperator,false);	//12 Dec 2019	NDL	TFS 47954
			theTable.hideRowByName(ETRow_CargoTA,false);		//12 Dec 2019	NDL	TFS 47954
			theTable.hideRowByName(ETRow_CargoLocation,false);	//12 Dec 2019	NDL	TFS 47954
			theTable.hideRowByName(ETRow_QuantityTen, false); //19/05/2025	navkc1 JIRA EPIC-34131 STORY-34822

			theTable.setValueByName(ETRow_ExternalReference1, invLine.externalRef1); //08/12/2025	navkc1 JIRA 36262
			theTable.setValueByName(ETRow_ExternalReference2, invLine.externalRef2); //08/12/2025	navkc1 JIRA 36262
			theTable.setValueByName(ETRow_ExternalReference3, invLine.externalRef3); //08/12/2025	navkc1 JIRA 36262
			theTable.setValueByName(ETRow_ExternalReference4, invLine.externalRef4); //08/12/2025	navkc1 JIRA 36262
			
			canManualUpdateExtRef := self.myCurrentInvoice.isManUpdeExtRefAllowedForUser(); //08/12/2025	navkc1 JIRA 36262
			
			//08/12/2025	navkc1 JIRA 36262
			if canManualUpdateExtRef then
				theTable.enableRowByName(ETRow_ExternalReference1);
				theTable.enableRowByName(ETRow_ExternalReference2);
				theTable.enableRowByName(ETRow_ExternalReference3);
				theTable.enableRowByName(ETRow_ExternalReference4);
			else
				theTable.disableRowByName(ETRow_ExternalReference1);
				theTable.disableRowByName(ETRow_ExternalReference2);
				theTable.disableRowByName(ETRow_ExternalReference3);
				theTable.disableRowByName(ETRow_ExternalReference4);
			endif;
			
			if invLine.manual then
				if app.myRoot.isClientGhana() then
					theTable.setValueByName(ETRow_QuantityTen,invLine.quantity);
					theTable.showRowByName(ETRow_QuantityTen,false);
				else
					theTable.setValueByName(ETRow_Quantity,invLine.quantity);
					theTable.showRowByName(ETRow_Quantity,false);
				endif;
				
				if invLine.trackedItem &lt;&gt; null then
					ti := invLine.trackedItem;
					
					self.cmbCargoTypeInvP.listObject := ti.myCargoType;
					theTable.setValueByName(ETRow_CargoType,     ti.myCargoType.description);
					theTable.setValueByName(ETRow_CargoId,       ti.id);
					theTable.setValueByName(ETRow_CargoOperator, ti.myOperator.code);								//12 Dec 2019	NDL	TFS 47954
					self.cmbCargoOper.listObject :=			     ti.myOperator;
					if ti.myPrimaryActualLocation &lt;&gt; null then
						if  ti.myPrimaryActualLocation.isKindOf(CM_YardController) then
							theTable.setValueByName(ETRow_CargoTA, ti.myPrimaryActualLocation.getMyTerminalArea);	//12 Dec 2019	NDL	TFS 47954
							self.cmbCargoTA.listObject := 		   ti.myPrimaryActualLocation.getMyTerminalArea;
							self.cmbCargoTA.lostFocus(self.cmbCargoTA);
							
							theTable.setValueByName(ETRow_CargoLocation, ti.myPrimaryActualLocation);	  			//12 Dec 2019	NDL	TFS 47954
							self.cmbCargoLoc.listObject := 				 ti.myPrimaryActualLocation;
							self.cmbCargoLoc.lostFocus(self.cmbCargoLoc);
						endif;
					endif;
				endif;
				theTable.showRowByName(ETRow_CargoType,false);
				theTable.showRowByName(ETRow_CargoId,false);
				theTable.showRowByName(ETRow_CargoOperator,false);	//12 Dec 2019	NDL	TFS 47954
				theTable.showRowByName(ETRow_CargoTA,false);		//12 Dec 2019	NDL	TFS 47954
				theTable.showRowByName(ETRow_CargoLocation,false);	//12 Dec 2019	NDL	TFS 47954
				
				theTable.showRowByName(ETRow_StartDate, false);							// TFS 51154
				theTable.setValueByName(ETRow_StartDate, invLine.chargeTime.date);		// TFS 51154
			else																		// TFS 51154
				theTable.hideRowByName(ETRow_StartDate, false);							// TFS 51154
				theTable.setValueByName(ETRow_StartDate, invLine.chargeTime.date);		// TFS 51154
			endif;
			
		endif;

		self.btnSaveBase.enabled    := true; 
		self.btnNext.enabled        := false;
		theTable.goToRowByName(ETRow_Remarks300);	// 24035// ### JIRA 33007 03DEC2024 NAVAB1
 	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="displayOverrideExtRef" id="bcbef0bb-2344-4f85-b03b-f2a9d358d70a">
        <source>displayOverrideExtRef(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//08/12/2025	navkc1 JIRA 36262 ROS - 1 - External Reference updates in MTN 

*/

vars
	
begin
	
	return app.getMyUser().canDo(self.getMyTerminal(), PmAdmInvExtRefView);
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displaySelectorResults" id="31e3635c-27e1-44f5-a83d-eb615d8eefb2">
        <updating/>
        <source>displaySelectorResults(_resultCollection: Collection; _mode: Integer) updating;
/*
 
Purpose:			
 
Parameters:			
 
Return Value:		
 
Date		Who		Reason
10 December 2022	navmv20	CR 55301 Task 55555: UI - Invoice Line List changes for selector
29 Jul 2025	navbs1 	Story MTN-35314: MTN | Pagination - Invoice Line List
09 Sep 2025	navbs1 	Bug 35962: MTN | Invoice Lines Form displaying empty rows when rows are added from Selector form
*/
 
vars
	invName : String;
	invLine:       CM_InvoiceLine;
	payment		: CM_CashPayment;
	selectedRow, idx :             Integer;
	theTable:           Table;
	pd:               CMS_Progress;
	progressTime,
	newTime		: Integer;
	itemsToShow	: Integer;
begin
	on CM_ProgressException do haltProgress(exception);
	self.mousePointer := Window.MousePointer_HourGlass;
	self.myCurrentInvoiceLine := null;
	self.tblInfo.rows := 0;			
    self.allInvoiceLines.clear();
	_resultCollection.copy(self.allInvoiceLines);
	theTable := self.tblData;
	//START 04.08.2025 navbs1 #35314
	/*self.doQueryRemoveItem();
	theTable.rows := theTable.fixedRows;					
	theTable.clearAllSelected();
	theTable.CM_DataTable.allSelectedRows.clear;*/
	theTable.CM_DataTable.clearAllData();
	//END  04.08.2025 navbs1 #35314
	
	selectedRow := 0;
	//theTable.rows := theTable.fixedRows;														//29.07.2025 navbs1 #35314
	//itemsToShow := self.allInvoiceLines.size + self.allCashPayments.size;						//04.08.2025 navbs1 #35314
	itemsToShow := self.allInvoiceLines.size;													//04.08.2025 navbs1 #35314
 
	if not self.tblData.isPaginated and not self.doMaxTableSizeCheck(itemsToShow, null) then		//04.08.2025 navbs1 #35314		//09.09.2025 navbs1 #35962
		return;
	endif;
	//START 11.09.2025 navbs1 #35962
	/*create pd;
	pd.setBackground(self.backColor);
	pd.show;
	pd.setAction("Loading Invoices Lines...");
	if not self.tblData.isPaginated then 														//04.08.2025 navbs1 #35314
		pd.progress.partsInJob := itemsToShow.min(JadeTableRowLimit);		
	else
		pd.progress.partsInJob := itemsToShow;	
	endif;
	invName := caption &amp; ", " &amp; pd.progress.partsInJob.String &amp; " items.";
	pd.setAction(invName);
	progressTime := app.clock;
 
	foreach invLine in self.allInvoiceLines do		
		idx := idx + 1;																	
		newTime := app.clock;
		if newTime - progressTime &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then		
			progressTime := newTime;
            pd.progress.partsDone := idx;
			pd.doWindowEvents(0);
			pd.txtDetails.text := "Invoice Line : " &amp; invLine.sequenceNum.String;
		endif;
		self.doQueryAddLine(invLine);
		if not self.tblData.isPaginated and self.tblData.rows = JadeTableRowLimit then					//04.08.2025 navbs1 #35314
			break;
		endif;
	endforeach;
	//if self.tblData.rows &lt;&gt; JadeTableRowLimit then													//04.08.2025 navbs1 #35314
		foreach payment in self.allCashPayments do			
			if not self.tblData.isPaginated and self.tblData.rows = JadeTableRowLimit then				//04.08.2025 navbs1 #35314	
				break;
			endif;
			self.doQueryAddPayment(payment);
			//if self.tblData.rows = JadeTableRowLimit then												//04.08.2025 navbs1 #35314	
				//break;
			//endif;
		endforeach;
	//endif;*/
	self.tblData.getDataAndDisplayRowsPaginat(Table.DisplayCollection_Forward, null, self.allInvoiceLines,true);
	//END  11.09.2025 navbs1 #35962
	self.frmQuery.visible := (self.tblData.rows = self.tblData.fixedRows);
 
	// set up the info table from the new entries
	if self.tblData.rows &gt; self.tblData.fixedRows then
		self.tblData.selectRow(2,false);
		self.tblData.row := 2;
		self.doTblDataRowColChange(self.tblData);
	endif;
 
epilog
	self.showSelectedCount(self.tblData.allSelectedObjects.size, self.tblData.rows-self.tblData.fixedRows);
	self.setMyCaption();
	//delete pd;					//11.09.2025 navbs1 #35962
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_resultCollection" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="5b78d6ac-0a87-4194-b354-3914aa39dd84">
        <updating/>
        <source>doBaseFormSave() updating, protected;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 08/11/2017   cnwma1	TFS #7362 POL - [Fwd: ##6005## : JMT 111 - Edit Invoice Line Qty not updating]
// 27/02/2020   cnwma1	Bug 48666: JMT - Class information is being shown in the 'Invoice Line' additional details {Cargo Terminal Area, Cargo Location, Cargo Operator, etc...}
// 05/05/2021	navdap1	TFS 51154 ASPA Manual Invoice Line Start Date
// 06/08/2021   navma1  Bug 51617: ASPA - Manual Invoice Line Date Editing - US Format
// 10 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type
vars
	manController   : CMIF_InvoiceLineManual;
	theTable 		: CM_EntryTable;
	realInvLine,
	pxyInvLine 	    : CM_InvoiceLine;
	theReturn 	    : Integer;
	ls 			    : Boolean;
	tmpQty 			: Real;
	extRef1,
	extRef2,
	extRef3,
	extRef4,
	cargoId         : String;
	startTS			: TimeStamp;					// TFS 51154
	invLineType     : CM_InvoiceLineDesc;    //10/03/2023  navmv20 TFS 56128 Task 56129
	myTi            : CM_TrackedItem;   //10/03/2023  navmv20 TFS 56128 Task 56129
	
begin
 	theTable := self.tblInvProperties;
	cargoId  := theTable.getValueByName(ETRow_CargoId).String;
	
	if self.currentView = ETView_InvListInvLinePropNew then
		
		create manController transient;
		manController.quantity 			:= theTable.getValueByName(ETRow_Quantity).String.asRealJMT();
// ### JIRA 33007 10DEC2024 NAVAB1		manController.narration 		:= theTable.getValueByName(ETRow_Narration300).String;	
		manController.remarks 		:= theTable.getValueByName(ETRow_Remarks300).String;	// ### JIRA 33007 03DEC2024 NAVAB1
		manController.myInvoice 		:= self.cmbInvoice.listObject.CM_Invoice;
		//10/03/2023  navmv20 TFS 56128 Task 56129 - START
		//manController.myInvoiceLineType := self.cmbInvLineType.listObject.CM_InvoiceLineDesc;
		invLineType 					:= self.cmbInvLineType.listObject.CM_InvoiceLineDesc;
		manController.allInvoiceLineTypes.add(invLineType);
		//10/03/2023  navmv20 TFS 56128 Task 56129 - END
		manController.chargeTime.setDate(theTable.getValueAsDate(ETRow_StartDate));
		
		self.setMyCurrentTI();
		//10/03/2023  navmv20 TFS 56128 Task 56129 - START
		//manController.myTrackedItem := self.myCurrentTI;
		myTi :=self.myCurrentTI;
		manController.allTrackedItems.add(myTi);
		//10/03/2023  navmv20 TFS 56128 Task 56129 - END
		
		//Check if there are real TI
		//if cargoId &lt;&gt; null and  manController.myTrackedItem = null then          //27.02.2020 cnwma1 #48666 //10/03/2023  navmv20 TFS 56128 Task 56129
		if cargoId &lt;&gt; null and  manController.allTrackedItems.first = null then //10/03/2023  navmv20 TFS 56128 Task 56129
			if app.msgBox(app.getErrorString1(Cargo_item_not_found,cargoId) &amp; Cr &amp;
						  app.getErrorString(DoYouWantToContinue), 
						  app.getErrorString(Warning), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
				return;
			endif;
		endif;
		
		while true do
			app.myTrxCA.trxCreateInvoiceLineManual(manController,realInvLine, app.myPassport);
			if app.myPassport.trxCompletedOK then
				global.beep;
				break;
			else
				theReturn := app.showErrorWarningDialog("Manual Invoice Line", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				return;
			endif;
			
			break;
		endwhile;
	
		if self.doNext then
			theTable.setValueByName(ETRow_Quantity,1);
			theTable.setValueByName(ETRow_Narration300,null);	// 24035
			self.cmbInvLineType.listIndex := -1;
			self.cmbInvLineType.lostFocus(self.cmbInvLineType);
			self.cmbInvLineType.setFocus();
		else
			self.frmToolbar.enabled := true;
			theTable.clearValues;
			self.frmInvProperties.visible := false;
		endif;
	
	elseif self.currentView = ETView_InvListInvLinePropVoid then
		if self.myCurrentInvoiceLine.status = CM_InvoiceLine.STATUS_NORMAL then
			self.doSaveChangeStatus(CM_InvoiceLine.STATUS_VOIDED);
		else
			self.doSaveChangeStatus(CM_InvoiceLine.STATUS_NORMAL);
		endif;
		self.frmToolbar.enabled := true;
	else
		app.cmsBeginLoad(ls);
		pxyInvLine := app.createUpdateProxy(self.myCurrentInvoiceLine).CM_InvoiceLine;
		app.cmsEndLoad(ls);
		
		extRef1 := theTable.getValueByName(ETRow_ExternalReference1).String;  //08/12/2025	navkc1 JIRA 36262
		extRef2 := theTable.getValueByName(ETRow_ExternalReference2).String;  //08/12/2025	navkc1 JIRA 36262
		extRef3 := theTable.getValueByName(ETRow_ExternalReference3).String;  //08/12/2025	navkc1 JIRA 36262
		extRef4 := theTable.getValueByName(ETRow_ExternalReference4).String;  //08/12/2025	navkc1 JIRA 36262
		pxyInvLine.setExternalReferences(extRef1, extRef2, extRef3, extRef4); //08/12/2025	navkc1 JIRA 36262
		
		pxyInvLine.setRemarks(theTable.getValueByName(ETRow_Remarks300).String);		// 24035 // ### JIRA 32731 03DEC2024 NAVAB1
		self.setMyCurrentTI();
		pxyInvLine.setTrackedItemOnly(self.myCurrentTI);
		

		if not pxyInvLine.invoice.isPostedOrReversal then	 //08.11.2017 cnwma1 TFS #7362
			if app.myRoot.isClientGhana() then //19/05/2025	navkc1 JIRA EPIC-34131 STORY-34822
				tmpQty := theTable.getValueByName(ETRow_QuantityTen).String.asRealJMT();
			else
				tmpQty := theTable.getValueByName(ETRow_Quantity).String.asRealJMT();
			endif;
			pxyInvLine.setPropertyValue("quantity",tmpQty);
			
			//startTS.setDate(theTable.getValueByName(ETRow_StartDate).String.asDateJMT);				// TFS 51154 // 6.08.2021 navma1 #51617
			startTS.setDate(theTable.getValueAsDate(ETRow_StartDate));												 // 6.08.2021 navma1 #51617
			startTS.setTime(pxyInvLine.chargeTime.time);												// TFS 51154   
			pxyInvLine.setPropertyValue(CM_InvoiceLine::chargeTime.name, startTS);						// TFS 51154
		endif;
		
		if cargoId &lt;&gt; null and  self.myCurrentTI = null then                 //27.02.2020 cnwma1 #48666
			if app.msgBox(app.getErrorString1(Cargo_item_not_found,cargoId) &amp; Cr &amp; 
						  app.getErrorString(DoYouWantToContinue), 
						  app.getErrorString(Warning), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
				return;
			endif;
		endif;
		
		while true do
			app.myTrxUA.trxUpdateInvoiceLineRemarks(pxyInvLine, app.myPassport);
			if app.myPassport.trxCompletedOK then
				global.beep;
				self.frmToolbar.enabled := true;
				theTable.clearValues;
				self.frmInvProperties.visible := false;
				break;
			else
				theReturn := app.showErrorWarningDialog("Update Invoice Line", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				return;
			endif;
			break;
		endwhile;
	endif;
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	self.doNext := false;
	self.tblData.enabled:=true;
	self.btnQuery.enabled := true; // disabled earlier on edit as can cause problems when pressing enter
	delete manController;
	delete pxyInvLine;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnConvertClick" id="12dbad7a-c0da-4b82-b5ec-b9fbbcea4070">
