    <JadeMethod name="hasDelays" id="54cea1ac-4ec2-4a37-97de-a3390ecb04d1">
        <source>hasDelays(delayTypeGroup : CM_DelayTypeGroup) : Boolean protected;
// return true if there is at least one delay for the current voyage/machine and configured delay types
vars
	result	: Boolean;
	delay	: CM_Delay;
	filterDate	: TimeStamp;
begin
	filterDate := app.actualTimeServer().addHours(-24);	// 24 hours back

	if self.myVoyage &lt;&gt; null then
		foreach delay in self.myVoyage.allDelays where delay.myMachine = self.myMachine do
			if delayTypeGroup &lt;&gt; null then
				if not delayTypeGroup.allDelayTypes.includes(delay.myDelayType) then
					continue;
				endif;
			endif;
			result := true;
			break;
		endforeach;
	elseif self.myMachine &lt;&gt; null then
		foreach delay in self.myMachine.allDelays do
			if delayTypeGroup &lt;&gt; null then
				if not delayTypeGroup.allDelayTypes.includes(delay.myDelayType) then
					continue;
				endif;
			endif;
			if delay.endDT &lt;&gt; null and
			   delay.endDT &lt; filterDate then
				continue;
			endif;
			result := true;
			break;
		endforeach;
	endif;
	
	return result;
end;</source>
        <access>protected</access>
        <Parameter name="delayTypeGroup" type="CM_DelayTypeGroup"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateMachines" id="f777d5e9-184e-4e33-a929-bca38fa3c38a">
        <updating/>
        <source>populateMachines() updating, protected;
// if a voyage is selected, only show cranes otherwise show all machines
vars
	machine	: CM_Machine;
begin
	self.cmbMachine.clear();
	self.cmbMachine.addItem(lblMachine.caption);
	foreach machine in self.myTerminal.machines do
		if machine.isNotAvailableForEntry then
			continue;
		endif;
		if self.myVoyage &lt;&gt; null then
			if not machine.isCrane() then
				continue;
			endif;
		endif;
		self.cmbMachine.itemObject[self.cmbMachine.addItem(machine.code)] := machine;
	endforeach;
	self.cmbMachine.listIndex := 1;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setActionButtons" id="6c973060-92a2-4bf7-9aba-17b486c3b313">
        <updating/>
        <source>setActionButtons() updating, protected;
// called on change of voyage or machine.
//  enable Edit button if voyage or machine has existing delays for a delay type of the 'Delay Type Group for Hand Held' terminal config, if set
vars
	delayTypeGroup	: CM_DelayTypeGroup;
begin

	// get the terminal config delay type group, if any
	delayTypeGroup := self.myTerminal().getConfig(HhDelayTypeGroup).CM_DelayTypeGroup;

	self.btnEditDelay.enabled := self.hasDelays(delayTypeGroup);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupControls" id="052c4421-018f-4aa6-95eb-400a4f35848b">
        <updating/>
        <source>setupControls() updating, protected;
// set up the combos, position the controls
vars
	
begin
	
	self.doResizeControls(true);
	
	self.cmbVoyage.setFocus();
	
	self.setActionButtons();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="7ae7d063-0660-40bd-8a6e-acf9417b56f4">
        <updating/>
        <source>setupForm() updating, protected;
// main form setup code
vars

begin
	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	inheritMethod();
	
	self.setupCmdButtons( 1, app.getErrorString(Menu), null, null, null, null );
	
	self.setupControls();

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="c220a078-0d0d-4d93-bbd2-66393f82861b">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016602, locale);
	btnAddDelay.translateCaption(Xlat_0016603, locale);
	btnEditDelay.translateCaption(Xlat_0016604, locale);
	lblMachine.translateCaption(Xlat_0016605, locale);
	lblVoyage.translateCaption(Xlat_0016606, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
