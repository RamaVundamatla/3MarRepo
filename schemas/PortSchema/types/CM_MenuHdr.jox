    <JadeMethod name="isReportMenu" id="35a670e4-2ed5-45d0-aae6-e5e06c57bd56">
        <source>isReportMenu() : Boolean;
// ---------------------------------------------------------------------------
// Created:     28 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if self.menuId.length &gt;= 4 and
	   self.menuId[1:4] = '_rpt' then
		return true;
	endif;
	
	if self.myMenuReportRoot &lt;&gt; null then		// PAR 17779
		return true;							// PAR 17779
	endif;										// PAR 17779
	
	return false;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setChildrenFromXML" id="ebc6ae11-2eb5-4b6b-ba16-a46b11ff3d74">
        <updating/>
        <source>setChildrenFromXML(_str : String; _menuRoot : CM_MenuRoot) updating;
// ---------------------------------------------------------------------------
// Created:     11 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idStr,
	childStr	: String;
	pos			: Integer;
	tmpItem		: CM_MenuItem;
	dict		: CM_MenuItemByTypeMenuIdDict;
	
begin
/*
&lt;Children&gt;
&lt;Id&gt;GTE123&lt;/Id&gt;
&lt;Id&gt;GTE222&lt;/Id&gt;
&lt;Id&gt;GTE446&lt;/Id&gt;
&lt;/Children&gt;
*/

	self.allChildren.clear;

	childStr := _str.cnEcGetTagValueOfName(XMLTag_Children);

	if _menuRoot.isKindOf(CM_MenuRootForRoot) then
		dict := _menuRoot.CM_MenuRootForRoot.allMenuItems;
	elseif _menuRoot.isKindOf(CM_MenuRootReportForRoot) then
		dict := _menuRoot.CM_MenuRootReportForRoot.allMenuItems;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled root (' &amp; _menuRoot.String &amp; ')');
		return;
	endif;
	
	pos := 1;
	while (pos &lt;&gt; 0) do
		idStr := childStr.cnEcGetNextTagValueOfName(XMLTag_Id, pos);
		
		if idStr &lt;&gt; null then
			tmpItem := dict[MenuType_DetailSystem, idStr];
			if tmpItem = null then
				tmpItem := dict[MenuType_HeaderSystem, idStr];
			endif;
			
			if tmpItem &lt;&gt; null then
				tmpItem.setParent(self);
			
			else
				
				
			endif;
		endif;
	endwhile;
		
end;</source>
        <Parameter name="_str" type="String"/>
        <Parameter name="_menuRoot" type="CM_MenuRoot"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="3e01ecd5-dd42-419d-bef2-990fa20b067e">
        <updating/>
        <source>setForCreate(_proxy : SelfType; 
			_parent : CM_MenuEntity input; 
			_pos : Integer;
			_menuRoot : CM_MenuRoot input) updating;
vars

begin

	inheritMethod(_proxy, _parent, _pos, _menuRoot);

	if _menuRoot.isKindOf(CM_MenuRootForRoot) then
		self.myMenuReportRoot := null;
		self.myMenuRoot	:= _menuRoot.CM_MenuRootForRoot;		
	elseif _menuRoot.isKindOf(CM_MenuRootReportForRoot) then
		self.myMenuReportRoot := _menuRoot.CM_MenuRootReportForRoot;
		self.myMenuRoot	:= null;
	endif;
		
end;</source>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_parent" type="CM_MenuEntity" usage="input"/>
        <Parameter name="_pos" type="Integer"/>
        <Parameter name="_menuRoot" type="CM_MenuRoot" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="c2bcfa62-497b-43cd-842b-80c82b0f14aa">
        <updating/>
        <source>setForUpdate(_proxy : SelfType) updating;

vars

begin

	self.expandAtStart	:= _proxy.expandAtStart;
	inheritMethod(_proxy);
	
end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
