    <JadeMethod name="setHeaderDetails" id="4da4cbab-944e-4b91-ade1-886fb9556673">
        <updating/>
        <source>setHeaderDetails(_terminal: CM_Terminal;
				_debtor: CM_Debtor; 
				_bol: String;
				_voyage: CM_Voyage;
				_effectiveDate: Date;
				_tilte : String) updating;
/*

Date		Who		Reason
17 August 2015	cnwer1	Initial creation PAR 36778

*/

vars

begin
	self.myTerminal:=_terminal;
	self.myDebtor:=_debtor;
	self.billOfLading:=_bol;
	self.myVoyage:=_voyage;
	if self.myVoyage &lt;&gt; null then
		self.voyageArrivalDate := self.myVoyage.arrivedDT.date;
		self.voyageDepartureDate := self.myVoyage.departedDT.date;
		self.vesselName := self.myVoyage.vesselName;
		self.voyageCode := self.myVoyage.code;
	endif;
	self.effectiveDate:=_effectiveDate;
	self.invoiceTitle:=_tilte;
epilog

end;</source>
