        <source>resetScrollOffsets() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2010	cnwjk3	Initial creation

*/

vars

begin
	self.hScrollOffset := 0;
	self.vScrollOffset := 0;
