<Class name="CM_EventDataVoyage" id="f3b7b470-d9fd-4066-9949-cdac8f57a891">
    <superclass name="CM_EventData"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="backgroundprocess"/>
    <ImplicitInverseRef name="myVoyage" id="c87bf620-af2c-4164-8c35-5d5e0680c50e">
        <embedded/>
        <type name="CM_Voyage"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="nextPortOfCall" id="087fe0af-8f99-426b-84d7-5ec274761fc2">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="cloneReferences" id="2a1f235b-76db-4111-b112-fa9b36f2061e">
        <updating/>
        <source>cloneReferences(_realEventData : CM_EventDataVoyage input) updating;
// -------------------------------------------
// Created 28 June 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	_realEventData.myVoyage := self.myVoyage;

end;</source>
        <Parameter name="_realEventData" type="CM_EventDataVoyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getEventDataDesc" id="035e736e-2c94-4d9c-9bc6-5946ff202dc8">
        <source>getEventDataDesc(): String;

// Created by cnwdvb1 on 28 June 2006

vars


begin

	if self.myVoyage = null then
		return null;
	endif;
	
	return 'Voyage - ' &amp; self.myVoyage.code;
	

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyEventDataVoyage" id="5d22a82d-6691-4929-85e4-8f85e7eef716">
        <updating/>
        <source>setProxyEventDataVoyage(_voyage : CM_Voyage; _nextPortOfCall : String) updating;
// -------------------------------------------
// Created 28 June 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	self.raiseExceptionIfNotTransient(method);
	self.type := EventDataVoyage;
	self.myVoyage			:= _voyage;
	self.nextPortOfCall		:= _nextPortOfCall;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_nextPortOfCall" type="String"/>
    </JadeMethod>
</Class>
