    <JadeMethod name="getExtraInfo" id="44177cf0-4b39-4600-ad2b-4a1385b44471">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2021 navma1 ChangeRequest 51002: MTN - Web Portal Cargo Work Orders

*/

vars
	ta    : CM_TerminalArea;
	block : CM_DataContainerBlock;
begin
	inheritMethod(_dataContainer);
	
	if self.myUnpackToLocation &lt;&gt; null then
		ta := self.myUnpackToLocation.getMyTerminalArea();
		
		if ta &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(Unpack_location), DC_Label, 1, null);
			block.addNewItem(ta.id, DC_Data, 1, null);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getMyVoyageObject" id="82367454-4e82-491c-b98d-3755ebccd987">
        <source>getMyVoyageObject(): CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2021 navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
21 Mar 2023 navma1	Defect 57220: MTN - WO - Error 4 when searching for the work order
*/

vars
	ti  		  : CM_TrackedItem;
	voyage	      : CM_Voyage;
	invalidVoyage : Boolean;
	invalidTI	  : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, voyage, invalidVoyage);   //21.03.2023 navma1 #57220
	on Exception do app.handleDeletedObject(exception, ti, 		invalidTI);      //21.03.2023 navma1 #57220

	ti := self.allSelectedTIs.first();			//08.02.2023 navma1 #56457:[56458]
	
	if ti = null then
		return null;
	endif;

	ti.edition;
	if invalidTI then
		return null;
	endif;

	voyage := ti.myVoyage;
	
	if voyage &lt;&gt; null then						//13.03.2023 navma1 #57220
		voyage.edition;
		if invalidVoyage then
			return null;
		endif;
	endif;
	
	return voyage;
	
epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getProgressString" id="ff13fad6-e938-44a2-b148-152c1c8eaabc">
        <source>getProgressString(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Jul 2024 navhl20	ChangeRequest 64969: EUP | 53856 - New Scanning App - Unpack mode issue

*/

vars
	required,
	completed	: Integer;
begin
	if self.getMyTerminal.isUseYardJobsForCargoWo and app.myPassport.isVASEnabled then	
		required	:= self.getTotalRequest(true).Integer;
		completed	:= self.getTotalCompleted(true).Integer;
		return app.getErrorString2(N_of_n_Complete, completed.String, required.String);
	else
		return inheritMethod();
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
