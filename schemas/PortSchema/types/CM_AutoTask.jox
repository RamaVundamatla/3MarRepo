    <JadeMethod name="setValueForRow" id="815a7c8c-97d2-4ce1-9ecd-d3360707752a">
        <updating/>
        <source>setValueForRow(_rowName : String; _value : Any) updating;

// cnwdvb1 16 January 2003 

vars

begin

	if _value = null then
		return;
	endif;
	if _rowName = ETRow_BgpAutoDescription then
		self.description := _value.String;
	elseif _rowName = ETRow_BgpAutoTerminals then
		self.myTerminal := _value.CM_Terminal;
	elseif _rowName = ETRow_BgpAutoUser then
		self.myUser := _value.CM_User;
	endif;

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
