    <JadeMethod name="trxUpdateDocketError" id="56b4abc2-c648-4727-af6e-48912751f803">
        <updating/>
        <source>trxUpdateDocketError(_pxyDocketError:CM_DocketError; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwas3	Initial creation

*/

vars
		
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);

	//_pxyDocketError.raiseExceptionIfNotProxy(method);
	
	beginTransaction;

	app.myUtilityUA.utlUpdateDocketError(_pxyDocketError, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyDocketError" type="CM_DocketError"/>
