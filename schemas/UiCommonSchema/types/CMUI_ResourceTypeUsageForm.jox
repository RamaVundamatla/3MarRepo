    <JadeMethod name="purgeProxys" id="646b516c-89d1-458a-a0bd-70fbda279118">
        <source>purgeProxys();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2010	cnwndl1	Initial creation	CCMS MES 1006

*/

vars

begin

	 if self.myTransaction &lt;&gt; null 
	 or self.myToDoTransaction &lt;&gt; null then  // ### TFS CR 54345 TASK 58281 16JUN2023 NAVAB1
		if not self.allNewProxyResourceTypeUsages.isEmpty then
			self.allNewProxyResourceTypeUsages.purge;
		endif;
		if not self.allProxyResourceTypeUsages.isEmpty then
			self.allProxyResourceTypeUsages.purge;
		endif;
		if not self.allUpdProxyResourceTypeUsages.isEmpty then
			self.allUpdProxyResourceTypeUsages.purge;
		endif;
	 endif;
	 
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="queryUnload" id="2375f8c1-78b9-42e0-aca4-38bfd257f6b1">
