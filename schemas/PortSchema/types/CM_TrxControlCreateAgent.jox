    <JadeMethod name="trxCreateTermAreaHazDetail" id="f9b2f91c-60b7-4c59-8196-1105429a7552">
        <updating/>
        <source>trxCreateTermAreaHazDetail(	_pxyHazDetail : CM_TerminalAreaHazDetails input; 
							_newHazDetail : CM_TerminalAreaHazDetails output;
							_passport : CM_Passport input	) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/11/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars
	terminalArea : CM_TerminalArea;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Perform the operation
	app.myUtilityCA.utlCreateTermAreaHazDetail(_pxyHazDetail, _newHazDetail, _passport);
	
	if _passport.noErrors then
		terminalArea := _pxyHazDetail.myTerminalArea;
		terminalArea.causeEvent(terminalArea.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA), false, terminalArea);
		terminalArea.causeEvent(terminalArea.myTerminal.getTerminalEvent(Event_TALocation_Create), false,_newHazDetail);
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyHazDetail" type="CM_TerminalAreaHazDetails" usage="input"/>
        <Parameter name="_newHazDetail" type="CM_TerminalAreaHazDetails" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateTerminal" id="7d41d1c2-489e-4459-a2d1-5a7e123a4d91">
        <updating/>
        <source>trxCreateTerminal(_proxyTerminal : CM_Terminal input; pKeyValue : Any; _cmifConfig : CMIF_Config input; _newTerminal : CM_Terminal output; _passport : CM_Passport input) updating;
// -----------------------------------------------------------------------------
// Created:		19 February 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	beginTransaction;

	app.myUtilityCA.utlCreateTerminal(_proxyTerminal, pKeyValue, _cmifConfig, _newTerminal, _passport); 
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_proxyTerminal" type="CM_Terminal" usage="input"/>
        <Parameter name="pKeyValue" type="Any"/>
        <Parameter name="_cmifConfig" type="CMIF_Config" usage="input"/>
