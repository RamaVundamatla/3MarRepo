<GUIClass name="CMUI_FieldTimeBox" id="d4e80ff8-ec8c-40da-a399-4856465d031c">
    <superclass name="CMUI_FieldFrame"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="_usergui"/>
    <ExplicitInverseRef name="myTimeBox" id="5a1dc3f4-e280-4d3d-b1ab-e221aa8728d2">
        <kind>parent</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CMUI_FieldTimeMaskControl"/>
        <access>protected</access>
