    <JadeMethod name="doShowDeckSortingForm" id="8867d636-de6d-4d5c-bbac-e2d5bdcb821f">
        <source>doShowDeckSortingForm();
/*
Date		    Who			Reason
30 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

begin
	if self.myROROVoyageStructure &lt;&gt; null and not self.myROROVoyageStructure.allDecks.isEmpty() then
		self.myAssistant.SHP_Assistant.showROROVoyageDeckSortingForm(self,self.myROROVoyageStructure,null);	
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doUserNotify" id="b8835d82-18b7-40d7-b575-359dffd95a0a">
        <updating/>
        <source>doUserNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) protected, updating;

vars

begin
	inheritMethod(eventType, theObject, eventTag, userInfo);
	// from 28687 refresh after voyage deck re-order
	if eventType = EVENT_LOCATION_REFRESH and 
	   userInfo.isKindOf(CM_ROROVoyageStructure) and
	   userInfo.CM_ROROVoyageStructure = self.myROROVoyageStructure then
		self.doRefresh();
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
