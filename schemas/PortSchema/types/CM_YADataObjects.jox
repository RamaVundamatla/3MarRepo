end;</source>
        <Parameter name="pProxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="b09e39ab-1672-43cc-8680-c78858332976">
        <updating/>
        <source>setProxy(pAllDataObjects:Any) updating;
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Purpose:		Sets the receiver's property values when the receiver is a transient
//				proxy object.
//
// Parameters:	pAllDataObjects - A reference to a collction of data value objects.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.raiseExceptionIfNotTransient(method);

	self.allObjects.clear();
	pAllDataObjects.ObjectSet.copy(self.allObjects);
end;</source>
        <Parameter name="pAllDataObjects" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setValue" id="68a3cdf6-0018-4a1b-b2cf-20fb60caeb7b">
        <updating/>
        <source>setValue(pValue: Any) updating;
// --------------------------------------------------------------------------------
// Created:		29 March 2005 by cnwdad1
//
// Purpose:		Sets the receiver's data value.
//
// Parameters:	pValue - The receiver's data value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allObjects.clear();
	pValue.ObjectSet.copy(self.allObjects);
end;</source>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
    <JadeMethod name="visitObjectsUntilTrue" id="d996b2c5-87f0-4012-a81d-d5e7ff32e0ab">
        <source>visitObjectsUntilTrue(visitor: Object; callBack: Method; value: Any) : Boolean;
//01 August 2008	cnwdw1	
// Visit all the objects until the callBack method returns true.
vars
	dataObject: Object;
begin
	foreach dataObject in self.allObjects do
		if visitor.sendMsgWithParams(callBack.name, dataObject, value).Boolean then
			return true;
		endif;
	endforeach;
	return false;
end;</source>
        <Parameter name="visitor" type="Object"/>
        <Parameter name="callBack" type="Method"/>
        <Parameter name="value" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
