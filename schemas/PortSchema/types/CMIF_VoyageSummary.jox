    <JadeMethod name="setFromSR" id="02dc213e-cfd2-4859-be27-a23856e14b38">
        <updating/>
        <source>setFromSR(_slotRequest: CM_SlotRequest) updating;
//----------------------------------------------------------------
//	Created:	12 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	other	: Boolean;
	sob		: Boolean;
	dlr		: Boolean;
	reef	: Boolean;
	forty	: Boolean;
	empty	: Boolean;
	dry		: Boolean;
	wle		: CM_VoyageWLE;
begin

	// PAR 21746 if _slotRequest.fortyBack or _slotRequest.isBackend then // PAR 16415 CCMS 1029
	if _slotRequest.getAttrIsBackend() then
		//dont count
		return;
	endif;
	
	if _slotRequest.isLoad and _slotRequest.isSOB then
		//dont count sobs for load cc's (only once on the discharge)
		return;
	endif;
	
	//basic stuff
	self.dischargePort	:= _slotRequest.dischargePort;
	
	self.bayID := _slotRequest.myBay.id;

	if _slotRequest.cargoType &lt;&gt; TI_CargoType_Container then
		//if _slotRequest.cargoType = TI_CargoType_Null then
		//	return;
		//endif; 
		other := true;
		//
	else
		//container only stuff
		if _slotRequest.getAttrIs40() or _slotRequest.isOversizedFrontend() then // PAR 16415 CCMS 1029
			forty := true;
			self.num40ft := 1;
			self.bayID := _slotRequest.myBay.idBay40;	//overwrite bay id
		else
			self.num20ft := 1;
		endif;
		
		if _slotRequest.getAttrEmpty() then
			empty := true;
		else
			//full container stuff
			if _slotRequest.getAttrPowerRequired() then // PAR7496 AKB2004FEB	or _slotRequest.reefer then
				reef := true;
			else
				dry := true;
			endif;
			
		endif;
	endif;
	
	if _slotRequest.isSOB then
		sob := true;
	endif;
	
	if _slotRequest.isRehandle then
		dlr := true;
	endif;
	
	//dlr
	self.num20ftDLR		:= (dlr and (not forty) and (not other)).Integer;
	self.num40ftDLR		:= (dlr and forty and (not other)).Integer;
	self.numOtherDLR	:= (dlr and other).Integer;
	if empty then
		self.numDLRMT20		:= (dlr and (not forty) and (not other)).Integer;
		self.numDLRMT40		:= (dlr and forty and (not other)).Integer;
	elseif reef then
		self.numDLRReef20	:= (dlr and (not forty) and (not other)).Integer;
		self.numDLRReef40	:= (dlr and forty and (not other)).Integer;
	else
		self.numDLRGen20	:= (dlr and (not forty) and (not other)).Integer;
		self.numDLRGen40	:= (dlr and forty and (not other)).Integer;
	endif;
		
	//sob
	self.num20ftSOB		:= (sob and (not forty) and (not other)).Integer;
	self.num40ftSOB		:= (sob and forty and (not other)).Integer;
	self.numOtherSOB	:= (sob and other).Integer;
	if empty then
		self.numSOBMT20		:= (sob and (not forty) and (not other)).Integer;
		self.numSOBMT40		:= (sob and forty and (not other)).Integer;
	elseif reef then
		self.numSOBReef20	:= (sob and (not forty) and (not other)).Integer;
		self.numSOBReef40	:= (sob and forty and (not other)).Integer;
	else
		self.numSOBGen20	:= (sob and (not forty) and (not other)).Integer;
		self.numSOBGen40	:= (sob and forty and (not other)).Integer;
	endif;
	
	if sob or dlr then
		return;
	endif;
	
	//imex
	//non-containers
	self.numOther		:= (other and (not dlr) and (not sob)).Integer;
	//mt
	self.num20ftEmpty		:= (empty and (not forty)).Integer;
	self.num40ftEmpty		:= (empty and forty).Integer;
	//reef
	self.num20ftReeferPower		:= (reef and (not forty)).Integer;
	self.num40ftReeferPower		:= (reef and forty).Integer;
	
	//dry
	self.num20ftGeneral		:= (dry and (not forty)).Integer;
	self.num40ftGeneral		:= (dry and forty).Integer;
	
end;</source>
        <Parameter name="_slotRequest" type="CM_SlotRequest"/>
    </JadeMethod>
    <JadeMethod name="totalDescriptorsForAll" id="29e6b2e4-1985-4045-8ce6-8d6b16f6ebe4">
        <updating/>
        <source>totalDescriptorsForAll(_ti : CM_TrackedItem; _txn : CM_TITransaction; _only20sAnd40s : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 April 2010	cnwndl1	Initial creation	Par 23048 - New version to include 30's, 45's and 53's

*/

vars

	container : CM_Container;
	isoType : CM_ISOType;
	is20 : Boolean;
	is30 : Boolean;
	is40 : Boolean;
	is45 : Boolean;
	is53 : Boolean;
	isHazard : Boolean;
	isOverDim : Boolean;
	snapShot : CM_TISnapShot;
	
begin

	if _ti &lt;&gt; null then
		if _ti.cargoType = TI_CargoType_BreakBulk then
			self.numBreakBulk := self.numBreakBulk + 1;
			return;
			
		elseif _ti.cargoType = TI_CargoType_Timber then
			self.numTimber := self.numTimber + 1;
			return;
			
		elseif _ti.cargoType = TI_CargoType_Container then
			container := _ti.CM_Container;
			if container = null then
				return;
			else
				isHazard := container.isHazardous;
				isOverDim := container.isOverDimensions;
				if not isHazard and not isOverDim then
					// not interested in this one.
					return;
				endif;
				
				isoType := container.getISOTypeObject();
				if isoType &lt;&gt; null then			
					if isoType.is20ftLong then
						is20 := true;
					elseif isoType.is30ftLong then
						is30 := true;
					elseif isoType.is40ftLong then
						is40 := true;
					elseif isoType.is45ftLong then
						is45 := true;
					elseif isoType.is53ftLong then
						is53 := true;
					endif;
				else
					is20 := true; // default value;
				endif;
				
				if _only20sAnd40s then
					if is30 or is45 or is53 then
						// not interested in this one.
						return;
					endif;
				endif;
				
			endif;
		endif;
	
	elseif _txn &lt;&gt; null then
		snapShot := _txn.mySnapShot.CM_TISnapShot;
		if snapShot = null then
			return;
		endif;
		
		if snapShot.cargoType = TI_CargoType_BreakBulk then
			self.numBreakBulk := self.numBreakBulk + 1;
			return;
			
		elseif snapShot.cargoType = TI_CargoType_Timber then
			self.numTimber := self.numTimber + 1;
			return;
			
		elseif snapShot.cargoType = TI_CargoType_Container then
		
			isHazard := snapShot.isHazardous;
			isOverDim := snapShot.isOverDimensions;
			if not isHazard and not isOverDim then
				// not interested in this one.
				return;
			endif;
			
			isoType := snapShot.getIsoTypeObject();
			if isoType &lt;&gt; null then
				if isoType.is20ftLong then
					is20 := true;
				elseif isoType.is30ftLong then
					is30 := true;
				elseif isoType.is40ftLong then
					is40 := true;
				elseif isoType.is45ftLong then
					is45 := true;
				elseif isoType.is53ftLong then
					is53 := true;
				else
					is20 := true; // default
				endif;
			else
				is20 := true; // default
			endif;
			
		endif;
		
	else
		// no parameter
		return;
		
	endif;
	
	if is20 then
		if isHazard then
			self.numHazardous20 := self.numHazardous20 + 1;
		endif;
		if isOverDim then
			self.numOverdimension20 := self.numOverdimension20 + 1;
		endif;	
		
	elseif is30 then
		if isHazard then
			self.numHazardous30 := self.numHazardous30 + 1;
		endif;
		if isOverDim then
			self.numOverdimension30 := self.numOverdimension30 + 1;
		endif;	
	
	elseif is40 then
		if isHazard then
			self.numHazardous40 := self.numHazardous40 + 1;
		endif;
		if isOverDim then
			self.numOverdimension40 := self.numOverdimension40 + 1;
		endif;
		
	elseif is45 then
		if isHazard then
			self.numHazardous45 := self.numHazardous45 + 1;
		endif;
		if isOverDim then
			self.numOverdimension45 := self.numOverdimension45 + 1;
		endif;	
	
	elseif is53 then
		if isHazard then
			self.numHazardous53 := self.numHazardous53 + 1;
		endif;
		if isOverDim then
			self.numOverdimension53 := self.numOverdimension53 + 1;
		endif;	
	
	endif;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_txn" type="CM_TITransaction"/>
        <Parameter name="_only20sAnd40s" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="totalDescriptorsForTI" id="8df64c83-2d4b-4dd9-baff-5ce8f546af6b">
        <updating/>
        <source>totalDescriptorsForTI(_ti : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	container			: CM_Container;
begin
	if _ti.cargoType = TI_CargoType_BreakBulk then
		self.numBreakBulk := self.numBreakBulk + 1;
	elseif _ti.cargoType = TI_CargoType_Timber then
		self.numTimber := self.numTimber + 1;
	elseif _ti.cargoType = TI_CargoType_Container then
		container := _ti.CM_Container;
		if container.is40 then
			if container.isHazardous then
				self.numHazardous40 := self.numHazardous40 + 1;
			endif;
			
			if _ti.isOverDimensions then
				self.numOverdimension40 := self.numOverdimension40 + 1;
			endif;
		else
			if container.isHazardous then
				self.numHazardous20 := self.numHazardous20 + 1;
			endif;
			
			if _ti.isOverDimensions then
				self.numOverdimension20 := self.numOverdimension20 + 1;
			endif;	
		endif;
	endif;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="totalDescriptorsForTxn" id="6997d7ce-06f6-4402-a5dc-e80b9ea1514e">
        <updating/>
        <source>totalDescriptorsForTxn(_txn : CM_TITransaction) updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	snapShot 	: CM_TISnapShot;
begin
	snapShot := _txn.mySnapShot.CM_TISnapShot;
	if snapShot = null then
		return;
	endif;
	
	if snapShot.cargoType = TI_CargoType_BreakBulk then
		self.numBreakBulk := self.numBreakBulk + 1;
	elseif snapShot.cargoType = TI_CargoType_Timber then
		self.numTimber := self.numTimber + 1;
	elseif snapShot.cargoType = TI_CargoType_Container then
		if snapShot.is40 then
			if snapShot.isHazardous then
				self.numHazardous40 := self.numHazardous40 + 1;
			endif;
			
			if snapShot.isOverDimensions then
				self.numOverdimension40 := self.numOverdimension40 + 1;
			endif;
		else
			if snapShot.isHazardous then
				self.numHazardous20 := self.numHazardous20 + 1;
			endif;
			
			if snapShot.isOverDimensions then
				self.numOverdimension20 := self.numOverdimension20 + 1;
			endif;	
		endif;
	endif;

end;</source>
        <Parameter name="_txn" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="totalSelf" id="9585ffd0-1ec3-4fbf-afa8-c5c0b180ec5e">
        <updating/>
        <source>totalSelf(_ti : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:     06 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	container		: CM_Container;
	is40			: Boolean;
	lc					: CM_LocationsController;
	slotController		: CM_SlotController;
	containerWeight		: Decimal[14,4];
begin

	if (not CM_Container.hasInstance(_ti)) then
		if CM_Car.hasInstance(_ti) then
			self.carWeight := self.carWeight + _ti.totalWeight;
		elseif CM_BreakBulk.hasInstance(_ti) then
			self.bBulkWeight := self.bBulkWeight + _ti.totalWeight;
		elseif CM_Timber.hasInstance(_ti) then
			self.timberWeight := self.timberWeight + _ti.totalWeight;
		endif;
		
		self.numOther := self.numOther + 1;
		return;
	endif;

	container := _ti.CM_Container;
	containerWeight := container.totalWeight;
	self.weight := self.weight + containerWeight;
	
	is40 := container.is40 or container.isOverSizedContainer(); // PAR 16415 CCMS 1029
	self.totalContainers := self.totalContainers + 1;
	
	if is40 then
		self.num40ft := self.num40ft + 1;
		if container.requiresTemperature then
			self.num40ftReefer := self.num40ftReefer + 1;
			self.weight40Reefer := self.weight40Reefer + containerWeight;
			
		elseif container.isEmpty then
			self.num40ftEmpty := self.num40ftEmpty + 1;
			self.weight40Empty := self.weight40Empty + containerWeight;
			
		else
			self.num40ftGeneral := self.num40ftGeneral + 1;
			self.num40ftFull := self.num40ftFull + 1;
			self.weight40General := self.weight40General + containerWeight;
			
		endif;		
	else
		self.num20ft := self.num20ft + 1;
		if container.requiresTemperature then
			self.num20ftReefer := self.num20ftReefer + 1;
			self.weight20Reefer := self.weight20Reefer + containerWeight;
			
		elseif container.isEmpty then
			self.num20ftEmpty := self.num20ftEmpty + 1;
			self.weight20Empty := self.weight20Empty + containerWeight;
			
		else
			self.num20ftFull:= self.num20ftFull + 1;
			self.num20ftGeneral := self.num20ftGeneral + 1;
			self.weight20General := self.weight20General + containerWeight;
		endif;		
	endif;

	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="totalSelfForAnzecs" id="5624ffb5-aa4b-40a7-9ad8-b0974a0eb61f">
        <updating/>
        <source>totalSelfForAnzecs(_container : CM_Container; _dischargeGroupCode : String) updating;
// ---------------------------------------------------------------------------
// Created:     10 December 2003	cnwth2
//
// Purpose:     This is used for the weird and wonderful 'Anzecs' report
//				All counters are representing TEU
//				
//				Only reports on containers that have been loaded at PortDestCode
//			 
// ----------   ----------  --------------------------------------------------
vars
	teu						: Integer;
	dischargePortCode		: String;
	foundOne				: Boolean;
begin
	if _container = null then
		return;
	endif;
	
	if _container.is40 then
		teu := 2;
	else
		teu := 1;
	endif;
	
	dischargePortCode := _container.dischargePort.trimBlanks;
	
	if _container.requiresTemperature then
		if (_dischargeGroupCode = 'UK') or
		   (dischargePortCode = 'JED') then //(go figure)
			self.reeferJEDUK := self.reeferJEDUK + teu;
			foundOne := true;
			
		elseif _dischargeGroupCode = 'EUR' then
			self.reeferContinental := self.reeferContinental + teu;
			foundOne := true;
			
		elseif dischargePortCode = 'MIT' or
		   dischargePortCode = 'SAV' or
		   dischargePortCode = 'PHL' then
			self.reeferOther := self.reeferOther + teu;
			foundOne := true;
		endif;
		
		if foundOne then
			//self.reeferWeight := self.reeferWeight + _container.weight;				//-cnwml2 MSL CCMS 1017
			self.reeferWeight := self.reeferWeight + _container.totalWeight;			//+cnwml2 MSL CCMS 1017
			//self.totalWeight := self.totalWeight + _container.weight;					//-cnwml2 MSL CCMS 1017
			self.totalWeight := self.totalWeight + _container.totalWeight;				//+cnwml2 MSL CCMS 1017
			if _container.is40 then
				self.total40s := self.total40s + 1;
			endif;
		endif;
		
	else
		if _dischargeGroupCode = 'UK' or
		   dischargePortCode = 'JED' then //(go figure)
			self.generalJEDUK := self.generalJEDUK + teu;
			foundOne := true;
			
		elseif _dischargeGroupCode = 'EUR' then
			self.generalContinental := self.generalContinental + teu;
			foundOne := true;
			
		elseif (_dischargeGroupCode = 'NZ' and _container.isEmpty) then
			self.northBoundEmpties := self.northBoundEmpties + teu;
			foundOne := true;
			
		elseif dischargePortCode = 'MIT' or
		   dischargePortCode = 'SAV' or
		   dischargePortCode = 'PHL' then
			self.generalOther := self.generalOther + teu;
			foundOne := true;
		endif;
		
		if foundOne then
			//self.generalWeight := self.generalWeight + _container.weight;					//-cnwml2 MSL CCMS 1017
			//self.totalWeight := self.totalWeight + _container.weight;						//-cnwml2 MSL CCMS 1017
			self.generalWeight := self.generalWeight + _container.totalWeight;				//+cnwml2 MSL CCMS 1017
			self.totalWeight := self.totalWeight + _container.totalWeight;					//+cnwml2 MSL CCMS 1017
			if _container.is40 then
				self.total40s := self.total40s + 1;
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="_container" type="CM_Container"/>
        <Parameter name="_dischargeGroupCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="totalSelfForColourCode" id="ef4afe44-0421-4446-b21c-6479949bf21d">
        <updating/>
        <source>totalSelfForColourCode(_slotRequest : CM_SlotRequest; _jobType : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     06 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	moveType			: Integer;
	is40				: Boolean;
	lc					: CM_LocationsController;
	slotController		: CM_SlotController;
	isEmpty 			: Boolean;	//cnwas3 PAR 24273
begin
	moveType := _slotRequest.moveType;
	isEmpty := _slotRequest.getAttrEmpty();		//cnwas3 PAR 24273
	if (_slotRequest.cargoType &lt;&gt; TI_CargoType_Container) then
		self.numOther := self.numOther;
		if moveType = DLR_MOVETYPE then
			self.numOtherDLR := self.numOtherDLR + 1;
		elseif moveType = SOB_MOVETYPE and
		   _jobType = JOB_TYPE_SOB then
			self.numOtherSOB := self.numOtherSOB + 1; 
		endif;
		return;
	endif;
// PAR 21746 	is40 := (_slotRequest.fortyBack or _slotRequest.getAttrIs40() or _slotRequest.isOversizedFrontend()); // PAR 16415 CCMS 1029
	is40 := (_slotRequest.getAttrIsBackend() or _slotRequest.getAttrIs40() or _slotRequest.isOversizedFrontend()); // PAR 16415 CCMS 1029
	self.totalContainers := self.totalContainers +1;
	
	if moveType = DLR_MOVETYPE then
		if is40 then
			self.num40ftDLR := self.num40ftDLR + 1;
		else
			self.num20ftDLR := self.num20ftDLR + 1;
		endif;
		
	elseif moveType = SOB_MOVETYPE and
	   _jobType = JOB_TYPE_SOB then
		if is40 then
			self.num40ftSOB := self.num40ftSOB + 1;
		else
			self.num20ftSOB := self.num20ftSOB + 1;
		endif;
  	endif;
  	
	if is40 then
		self.num40ft := self.num40ft + 1;
// PAR7496 AKB2004FEB			if _slotRequest.reefer then
// PAR7496 AKB2004FEB				self.num40ftReefer := self.num40ftReefer + 1;
		if _slotRequest.getAttrPowerRequired() then
			self.num40ftReeferPower := self.num40ftReeferPower + 1;
// PAR7496 AKB2004FEB			else
// PAR7496 AKB2004FEB				self.num40ftPHoleReefer := self.num40ftPHoleReefer + 1;
// PAR7496 AKB2004FEB			endif;
		
		elseif isEmpty then		//cnwas3 PAR 24273
			self.num40ftEmpty := self.num40ftEmpty + 1;
		else
			self.num40ftGeneral := self.num40ftGeneral + 1;
		endif;
	else
		self.num20ft := self.num20ft + 1;
// PAR7496 AKB2004FEB			if _slotRequest.reefer then
// PAR7496 AKB2004FEB				self.num20ftReefer := self.num20ftReefer + 1;
		if _slotRequest.getAttrPowerRequired() then
			self.num20ftReeferPower := self.num20ftReeferPower + 1;
// PAR7496 AKB2004FEB				else
// PAR7496 AKB2004FEB					self.num20ftPHoleReefer := self.num20ftPHoleReefer + 1;
// PAR7496 AKB2004FEB				endif;
		
		elseif isEmpty then		//cnwas3 PAR 24273
			self.num20ftEmpty := self.num20ftEmpty + 1;
		else
			self.num20ftGeneral := self.num20ftGeneral + 1;
		endif;
	endif;


end;</source>
        <Parameter name="_slotRequest" type="CM_SlotRequest"/>
        <Parameter name="_jobType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="totalSelfForExchangeSummaryAll" id="8bc5f360-0193-4adc-a3de-11e8b909ac61">
        <updating/>
        <source>totalSelfForExchangeSummaryAll(_ti : CM_TrackedItem; _txn : CM_TITransaction; _only20sAnd40s : Boolean; _isSummaryTotal: Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 April 2010	cnwndl1	Initial creation	Par 23048 - New version to include 30's, 45's and 53's
14 July 2010	cnwdap1	PAR #25021 review use of isImport/isExport for tranships
04 Oct 2010		cnwdap1 PAR #25943 Tranship corrections, include Export MT Reefers in Export MTs
						(Voyage Exchange Summary report doesn't have a column for Export MT Reefers)
07 Oct 2010		cnwdap1	PAR #25982 Re-instate Restow totals code that added an extra 1 to the total for restows
23 Dec 2010		cnwdap1	PAR #26640 Include Import Tranship MT Reefers in the Import Tranship MTs count
						(Voyage Exchange Summary report doesn't have a column for Import Tranship MT Reefers)
21 Feb 2011		cnwjre1	PAR 27050 Include DLR and SOB empty reefers in the DLR and SOB MT counts
						(Voyage Exchange Summary report doesn't have a column for DLR and SOB MT Reefers)
						** now all of these cases are handled **
*/

vars

	
	isTransShip	: Boolean;
	monitorOrConnection : Boolean;	// i.e. is a reefer that is actually in use for reefer cargo
	isMT : Boolean;
	isEmptyReefer : Boolean;
	isFullReefer : Boolean;
	isEmptyGeneral : Boolean;
	isFullGeneral : Boolean;
	is20 : Boolean;
	is30 : Boolean;
	is40 : Boolean;
	is45 : Boolean;
	is53 : Boolean;
	isISOReefer	: Boolean;
	isoType : CM_ISOType;
	container : CM_Container;
	snapShot : CM_TISnapShot;
	
	isDLR : Boolean;
	isSOB : Boolean;
	isImport : Boolean;
	isExport : Boolean;
	incr : Integer;			// PAR #25982
	
begin

	if _ti &lt;&gt; null then
	
		if (not CM_Container.hasInstance(_ti)) then
			return;
		endif;
		container := _ti.CM_Container;
		
		isMT := container.isEmpty;
		//isImport := (container.isImport);									// PAR #25021
		//isImport := (container.isImport or container.isTranshipInbound);	// PAR #25021
		isImport := (container.isImport or (container.isTranshipItem and container.myImportVoyage = self.myVoyage));	// PAR #25943
		
		if isMT and (container.isStorage) then
			//safe to assume it was an import
			isImport := true;
		endif;
		
		isTransShip := container.isTranshipItem;
		monitorOrConnection := container.monitorConnection;
		isoType := container.getISOTypeObject();
		
		if container.getTransitStatus() = TI_TransitStatusDLR then
			isDLR := true;
		elseif container.getTransitStatus() = TI_TransitStatusSOB then
			isSOB := true;
		endif;

	
	elseif _txn &lt;&gt; null then
	
		snapShot := _txn.mySnapShot.CM_TISnapShot;
		if snapShot = null then
			return;
		endif;
		//not concerned with non-containerised cargo as yet
		if (not (snapShot.cargoType = TI_CargoType_Container))then
			return;
		endif;
		
		isMT := snapShot.isEmpty;
		if (snapShot.imExStatus = TI_IMEX_STATUS_IMPORT)
		or (snapShot.imExStatus = TI_IMEX_STATUS_STORAGE) 
		or (snapShot.imExStatus = TI_IMEX_STATUS_TRANSHIP and snapShot.myTrackedItem.myImportVoyage = self.myVoyage) then	// PAR #25943
			isImport := true;
		endif;
		
		isTransShip := snapShot.isTransship;
		monitorOrConnection := snapShot.requiresPower;
		isoType := snapShot.getIsoTypeObject;
		
		if snapShot.transitStatus = TI_TransitStatusDLR then
			isDLR := true;
		elseif snapShot.transitStatus = TI_TransitStatusSOB then
			isSOB := true;
		endif;
	
	else
		// no parameter
		return;
		
	endif;
	
	if isoType &lt;&gt; null then
		isISOReefer	:= isoType.isReefer;
		
		if isoType.is20ftLong then
			is20 := true;
		elseif isoType.is30ftLong then
			is30 := true;
		elseif isoType.is40ftLong then
			is40 := true;
		elseif isoType.is45ftLong then
			is45 := true;
		elseif isoType.is53ftLong then
			is53 := true;
		endif;	
	endif;
	
	if _only20sAnd40s then
		if is30 or is45 or is53 then
			// not interested in this one, we ar eonly doing 20's and 40's.
			return;
		endif;
	endif;
	
	isExport := not isImport;
	total := total + 1;
	
	if isMT then
		if isISOReefer then
			isEmptyReefer := true;
		else
			isEmptyGeneral := true;
		endif;
	else
		if monitorOrConnection then
			isFullReefer := true;
		else
			isFullGeneral := true; //( or reefer type, but has non reefer type cargo in it.)
		endif;
	endif;

	if isDLR then
	
		// The original methods that this one replaces used to add an extra 1 to the 'totals' here,
		// supposedly because the DLR is two moves. This meant the totals were NOT the sum of the columns of data.
		// DQ advises this was wrong, so it has now been removed..	NDL.
		// PAR #25982 This has now been put back in at Port Otago's request
		// PAR #25982 Restow TOTALS ONLY are doubled as it's two moves
		if _isSummaryTotal then		// PAR #25982
			total := total + 1;		// PAR #25982
			incr := 2;				// PAR #25982
		else						// PAR #25982
			incr := 1;				// PAR #25982
		endif;						// PAR #25982
		
		if isEmptyGeneral then
			if is20 then
				self.numDLRMT20 := self.numDLRMT20 + incr;//1;			// PAR #25982
			elseif is30 then
				self.numDLRMT30 := self.numDLRMT30 + incr;//1;			// PAR #25982
			elseif is40 then
				self.numDLRMT40 := self.numDLRMT40 + incr;//1;			// PAR #25982
			elseif is45 then
				self.numDLRMT45 := self.numDLRMT45 + incr;//1;			// PAR #25982
			elseif is53 then
				self.numDLRMT53 := self.numDLRMT53 + incr;//1;			// PAR #25982
			endif;
			
		elseif isEmptyReefer then
			// 27050 add to the empty general counts as well, as only these are reported
			if is20 then
				self.numDLRMTReef20 := self.numDLRMTReef20 + incr;//1;	// PAR #25982
				self.numDLRMT20 := self.numDLRMT20 + incr;
			elseif is30 then
				self.numDLRMTReef30 := self.numDLRMTReef30 + incr;//1;	// PAR #25982
				self.numDLRMT30 := self.numDLRMT30 + incr;
			elseif is40 then
				self.numDLRMTReef40 := self.numDLRMTReef40 + incr;//1;	// PAR #25982
				self.numDLRMT40 := self.numDLRMT40 + incr;
			elseif is45 then
				self.numDLRMTReef45 := self.numDLRMTReef45 + incr;//1;	// PAR #25982
				self.numDLRMT45 := self.numDLRMT45 + incr;
			elseif is53 then
				self.numDLRMTReef53 := self.numDLRMTReef53 + incr;//1;	// PAR #25982
				self.numDLRMT53 := self.numDLRMT53 + incr;
			endif;
			
		elseif isFullReefer then
			if is20 then
				self.numDLRReef20 := self.numDLRReef20 + incr;//1;		// PAR #25982
			elseif is30 then
				self.numDLRReef30 := self.numDLRReef30 + incr;//1;		// PAR #25982
			elseif is40 then
				self.numDLRReef40 := self.numDLRReef40 + incr;//1;		// PAR #25982
			elseif is45 then
				self.numDLRReef45 := self.numDLRReef45 + incr;//1;		// PAR #25982
			elseif is53 then
				self.numDLRReef53 := self.numDLRReef53 + incr;//1;		// PAR #25982
			endif;
			
		elseif isFullGeneral then
			if is20 then
				self.numDLRGen20 := self.numDLRGen20 + incr;//1;		// PAR #25982
			elseif is30 then
				self.numDLRGen30 := self.numDLRGen30 + incr;//1;		// PAR #25982
			elseif is40 then
				self.numDLRGen40 := self.numDLRGen40 + incr;//1;		// PAR #25982
			elseif is45 then
				self.numDLRGen45 := self.numDLRGen45 + incr;//1;		// PAR #25982
			elseif is53 then
				self.numDLRGen53 := self.numDLRGen53 + incr;//1;		// PAR #25982
			endif;
		endif;
		
	elseif isSOB then
		if isEmptyGeneral then
			if is20 then
				self.numSOBMT20 := self.numSOBMT20 + 1;
			elseif is30 then
				self.numSOBMT30 := self.numSOBMT30 + 1;
			elseif is40 then
				self.numSOBMT40 := self.numSOBMT40 + 1;			
			elseif is45 then
				self.numSOBMT45 := self.numSOBMT45 + 1;			
			elseif is53 then
				self.numSOBMT53 := self.numSOBMT53 + 1;			
			endif;
			
		elseif isEmptyReefer then
			// 27050 add to the empty general counts as well, as only these are reported
			if is20 then
				self.numSOBMTReef20 := self.numSOBMTReef20 + 1;
				self.numSOBMT20 := self.numSOBMT20 + 1;
			elseif is30 then
				self.numSOBMTReef30 := self.numSOBMTReef30 + 1;
				self.numSOBMT30 := self.numSOBMT30 + 1;
			elseif is40 then
				self.numSOBMTReef40 := self.numSOBMTReef40 + 1;			
				self.numSOBMT40 := self.numSOBMT40 + 1;
			elseif is45 then
				self.numSOBMTReef45 := self.numSOBMTReef45 + 1;			
				self.numSOBMT45 := self.numSOBMT45 + 1;
			elseif is53 then
				self.numSOBMTReef53 := self.numSOBMTReef53 + 1;			
				self.numSOBMT53 := self.numSOBMT53 + 1;
			endif;
		
		elseif isFullReefer then
			if is20 then
				self.numSOBReef20 := self.numSOBReef20 + 1;
			elseif is30 then
				self.numSOBReef30 := self.numSOBReef30 + 1;
			elseif is40 then
				self.numSOBReef40 := self.numSOBReef40 + 1;			
			elseif is45 then
				self.numSOBReef45 := self.numSOBReef45 + 1;			
			elseif is53 then
				self.numSOBReef53 := self.numSOBReef53 + 1;			
			endif;
			
		elseif isFullGeneral then
			if is20 then
				self.numSOBGen20 := self.numSOBGen20 + 1;
			elseif is30 then
				self.numSOBGen30 := self.numSOBGen30 + 1;
			elseif is40 then
				self.numSOBGen40 := self.numSOBGen40 + 1;			
			elseif is45 then
				self.numSOBGen45 := self.numSOBGen45 + 1;			
			elseif is53 then
				self.numSOBGen53 := self.numSOBGen53 + 1;			
			endif;
		endif;
		
	
	elseif isImport then
	
		if isTransShip then
			if isEmptyGeneral then
				if is20 then
					self.numImportTransMT20 := self.numImportTransMT20 + 1;
				elseif is30 then
					self.numImportTransMT30 := self.numImportTransMT30 + 1;
				elseif is40 then
					self.numImportTransMT40 := self.numImportTransMT40 + 1;			
				elseif is45 then
					self.numImportTransMT45 := self.numImportTransMT45 + 1;			
				elseif is53 then
					self.numImportTransMT53 := self.numImportTransMT53 + 1;			
				endif;
				
			elseif isEmptyReefer then
				if is20 then
					self.numImportTransMTReef20 := self.numImportTransMTReef20 + 1;
					self.numImportTransMT20		:= self.numImportTransMT20 + 1;		// PAR #26640
				elseif is30 then
					self.numImportTransMTReef30 := self.numImportTransMTReef30 + 1;
					self.numImportTransMT30		:= self.numImportTransMT30 + 1;		// PAR #26640
				elseif is40 then
					self.numImportTransMTReef40 := self.numImportTransMTReef40 + 1;			
					self.numImportTransMT40		:= self.numImportTransMT40 + 1;		// PAR #26640
				elseif is45 then
					self.numImportTransMTReef45 := self.numImportTransMTReef45 + 1;			
					self.numImportTransMT45		:= self.numImportTransMT45 + 1;		// PAR #26640
				elseif is53 then
					self.numImportTransMTReef53 := self.numImportTransMTReef53 + 1;			
					self.numImportTransMT53		:= self.numImportTransMT53 + 1;		// PAR #26640
				endif;
			
			elseif isFullReefer then
				if is20 then
					self.numImportTransReef20 := self.numImportTransReef20 + 1;
				elseif is30 then
					self.numImportTransReef30 := self.numImportTransReef30 + 1;
				elseif is40 then
					self.numImportTransReef40 := self.numImportTransReef40 + 1;			
				elseif is45 then
					self.numImportTransReef45 := self.numImportTransReef45 + 1;			
				elseif is53 then
					self.numImportTransReef53 := self.numImportTransReef53 + 1;			
				endif;
				
			elseif isFullGeneral then
				if is20 then
					self.numImportTransGen20 := self.numImportTransGen20 + 1;
				elseif is30 then
					self.numImportTransGen30 := self.numImportTransGen30 + 1;
				elseif is40 then
					self.numImportTransGen40 := self.numImportTransGen40 + 1;			
				elseif is45 then
					self.numImportTransGen45 := self.numImportTransGen45 + 1;			
				elseif is53 then
					self.numImportTransGen53 := self.numImportTransGen53 + 1;			
				endif;
			endif;
		
		else	
			if isEmptyGeneral then
				if is20 then
					self.numImportGenMT20 := self.numImportGenMT20 + 1;
				elseif is30 then
					self.numImportGenMT30 := self.numImportGenMT30 + 1;
				elseif is40 then
					self.numImportGenMT40 := self.numImportGenMT40 + 1;			
				elseif is45 then
					self.numImportGenMT45 := self.numImportGenMT45 + 1;			
				elseif is53 then
					self.numImportGenMT53 := self.numImportGenMT53 + 1;			
				endif;
				
			elseif isEmptyReefer then
				if is20 then
					self.numImportReefMT20 := self.numImportReefMT20 + 1;
				elseif is30 then
					self.numImportReefMT30 := self.numImportReefMT30 + 1;
				elseif is40 then
					self.numImportReefMT40 := self.numImportReefMT40 + 1;			
				elseif is45 then
					self.numImportReefMT45 := self.numImportReefMT45 + 1;			
				elseif is53 then
					self.numImportReefMT53 := self.numImportReefMT53 + 1;			
				endif;
				
			elseif isFullReefer then
				if is20 then
					self.numImportReef20 := self.numImportReef20 + 1;
				elseif is30 then
					self.numImportReef30 := self.numImportReef30 + 1;
				elseif is40 then
					self.numImportReef40 := self.numImportReef40 + 1;			
				elseif is45 then
					self.numImportReef45 := self.numImportReef45 + 1;			
				elseif is53 then
					self.numImportReef53 := self.numImportReef53 + 1;			
				endif;
				
			elseif isFullGeneral then
				if is20 then
					self.numImportGen20 := self.numImportGen20 + 1;
				elseif is30 then
					self.numImportGen30 := self.numImportGen30 + 1;
				elseif is40 then
					self.numImportGen40 := self.numImportGen40 + 1;			
				elseif is45 then
					self.numImportGen45 := self.numImportGen45 + 1;			
				elseif is53 then
					self.numImportGen53 := self.numImportGen53 + 1;			
				endif;
				
			endif;
				
		endif;
		
	elseif isExport then
	
		if isTransShip then
			if isEmptyGeneral then
				if is20 then
					self.numExportTransMT20 := self.numExportTransMT20 + 1;
				elseif is30 then
					self.numExportTransMT30 := self.numExportTransMT30 + 1;
				elseif is40 then
					self.numExportTransMT40 := self.numExportTransMT40 + 1;			
				elseif is45 then
					self.numExportTransMT45 := self.numExportTransMT45 + 1;			
				elseif is53 then
					self.numExportTransMT53 := self.numExportTransMT53 + 1;			
				endif;
				
			elseif isEmptyReefer then
				if is20 then
					self.numExportTransMTReef20 := self.numExportTransMTReef20 + 1;
					self.numExportTransMT20		:= self.numExportTransMT20 + 1;		// PAR #25943
				elseif is30 then
					self.numExportTransMTReef30 := self.numExportTransMTReef30 + 1;
					self.numExportTransMT30		:= self.numExportTransMT30 + 1;		// PAR #25943
				elseif is40 then
					self.numExportTransMTReef40 := self.numExportTransMTReef40 + 1;			
					self.numExportTransMT40		:= self.numExportTransMT40 + 1;		// PAR #25943
				elseif is45 then
					self.numExportTransMTReef45 := self.numExportTransMTReef45 + 1;			
					self.numExportTransMT45		:= self.numExportTransMT45 + 1;		// PAR #25943
				elseif is53 then
					self.numExportTransMTReef53 := self.numExportTransMTReef53 + 1;			
					self.numExportTransMT53		:= self.numExportTransMT53 + 1;		// PAR #25943
				endif;
			
			elseif isFullReefer then
				if is20 then
					self.numExportTransReef20 := self.numExportTransReef20 + 1;
				elseif is30 then
					self.numExportTransReef30 := self.numExportTransReef30 + 1;
				elseif is40 then
					self.numExportTransReef40 := self.numExportTransReef40 + 1;			
				elseif is45 then
					self.numExportTransReef45 := self.numExportTransReef45 + 1;			
				elseif is53 then
					self.numExportTransReef53 := self.numExportTransReef53 + 1;			
				endif;
				
			elseif isFullGeneral then
				if is20 then
					self.numExportTransGen20 := self.numExportTransGen20 + 1;
				elseif is30 then
					self.numExportTransGen30 := self.numExportTransGen30 + 1;
				elseif is40 then
					self.numExportTransGen40 := self.numExportTransGen40 + 1;			
				elseif is45 then
					self.numExportTransGen45 := self.numExportTransGen45 + 1;			
				elseif is53 then
					self.numExportTransGen53 := self.numExportTransGen53 + 1;			
				endif;
				
			endif;
			
		else // Export
			if isEmptyGeneral then
				if is20 then
					self.numExportMT20 := self.numExportMT20 + 1;
				elseif is30 then
					self.numExportMT30 := self.numExportMT30 + 1;
				elseif is40 then
					self.numExportMT40 := self.numExportMT40 + 1;			
				elseif is45 then
					self.numExportMT45 := self.numExportMT45 + 1;			
				elseif is53 then
					self.numExportMT53 := self.numExportMT53 + 1;			
				endif;
				
			elseif isEmptyReefer then
				if is20 then
					self.numExportMTReef20 := self.numExportMTReef20 + 1;
					self.numExportMT20 	   := self.numExportMT20 + 1;		// PAR #25943
				elseif is30 then
					self.numExportMTReef30 := self.numExportMTReef30 + 1;
					self.numExportMT30 	   := self.numExportMT30 + 1;		// PAR #25943
				elseif is40 then
					self.numExportMTReef40 := self.numExportMTReef40 + 1;			
					self.numExportMT40 	   := self.numExportMT40 + 1;		// PAR #25943
				elseif is45 then
					self.numExportMTReef45 := self.numExportMTReef45 + 1;			
					self.numExportMT45 	   := self.numExportMT45 + 1;		// PAR #25943
				elseif is53 then
					self.numExportMTReef53 := self.numExportMTReef53 + 1;			
					self.numExportMT53 	   := self.numExportMT53 + 1;		// PAR #25943
				endif;
			
			elseif isFullReefer then
				if is20 then
					self.numExportReef20 := self.numExportReef20 + 1;
				elseif is30 then
					self.numExportReef30 := self.numExportReef30 + 1;
				elseif is40 then
					self.numExportReef40 := self.numExportReef40 + 1;			
				elseif is45 then
					self.numExportReef45 := self.numExportReef45 + 1;			
				elseif is53 then
					self.numExportReef53 := self.numExportReef53 + 1;			
				endif;
				
			elseif isFullGeneral then
				if is20 then
					self.numExportGen20 := self.numExportGen20 + 1;
				elseif is30 then
					self.numExportGen30 := self.numExportGen30 + 1;
				elseif is40 then
					self.numExportGen40 := self.numExportGen40 + 1;			
				elseif is45 then
					self.numExportGen45 := self.numExportGen45 + 1;			
				elseif is53 then
					self.numExportGen53 := self.numExportGen53 + 1;			
				endif;	
				
			endif;		
			
		endif;
		
	endif;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_txn" type="CM_TITransaction"/>
        <Parameter name="_only20sAnd40s" type="Boolean"/>
        <Parameter name="_isSummaryTotal" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="totalSelfForExchangeSummaryTI" id="aeb83334-b584-49d7-b73d-b859987254b6">
        <updating/>
        <source>totalSelfForExchangeSummaryTI(_ti : CM_TrackedItem; _isSummaryTotal: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     30 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 14/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
vars
	isImport,
	isTransShip,
	isReefer,
	isEmpty,
	is40,
	isISOReefer	: Boolean;
	isoType		: CM_ISOType;
	container	: CM_Container;
	amtToAdd	: Integer;
begin
	
	if (not CM_Container.hasInstance(_ti)) then
		return;
	endif;
	
	container := _ti.CM_Container;
	total := total + 1;
	
	isEmpty := container.isEmpty;
	//isImport := (container.isImport);									// PAR #25021
	isImport := (container.isImport or container.isTranshipInbound);	// PAR #25021
	
	if isEmpty and (container.isStorage) then
		//safe to assume it was an import
		isImport := true;
	endif;
	
	isTransShip := container.isTranshipItem;
	isReefer := container.monitorConnection;
	isoType := container.getISOTypeObject();
	if isoType &lt;&gt; null then
		isISOReefer	:= isoType.isReefer;
	endif;
	is40 := container.is40;

	if container.getTransitStatus() = TI_TransitStatusDLR then
		//restow TOTALS are doubled ('cause it's two moves - note TOTALS ONLY)
		amtToAdd := 1;
		if _isSummaryTotal then
			amtToAdd := 2;
		endif;
		total := total + 1;	//add an extra 1 to total to make numbers balance
		
		if isEmpty then
			if (not is40) then
				self.numDLRMT20 := self.numDLRMT20 + amtToAdd;
			else
				self.numDLRMT40 := self.numDLRMT40 + amtToAdd;			
			endif;
		elseif isReefer then
			if (not is40) then
				self.numDLRReef20 := self.numDLRReef20 + amtToAdd;
			else
				self.numDLRReef40 := self.numDLRReef40 + amtToAdd;			
			endif;
		else //isGeneral
			if (not is40) then
				self.numDLRGen20 := self.numDLRGen20 + amtToAdd;
			else
				self.numDLRGen40 := self.numDLRGen40 + amtToAdd;			
			endif;
		endif;
		
	elseif container.getTransitStatus() = TI_TransitStatusSOB then
		if isEmpty then
			if (not is40) then
				self.numSOBMT20 := self.numSOBMT20 + 1;
			else
				self.numSOBMT40 := self.numSOBMT40 + 1;			
			endif;
		elseif isReefer then
			if (not is40) then
				self.numSOBReef20 := self.numSOBReef20 + 1;
			else
				self.numSOBReef40 := self.numSOBReef40 + 1;			
			endif;
		else //isGeneral
			if (not is40) then
				self.numSOBGen20 := self.numSOBGen20 + 1;
			else
				self.numSOBGen40 := self.numSOBGen40 + 1;			
			endif;
		endif;
		
	//Note that import non-tranship have an extra distinguishment for empties between and reefer and gen
	//all the rest do not - see CCMS#1273 attachment
	elseif isImport then
		if (not isTransShip) then
		/*	rearranged this to allow for a different isReefer rule for import empties - JC PAR 9901
			if (not isReefer) then
				if (not isEmpty) then
					if (not is40) then
						self.numImportGen20 := self.numImportGen20 + 1;
					else
						self.numImportGen40 := self.numImportGen40 + 1;			
					endif;
				else //isEmpty
					if (not is40) then
						self.numImportGenMT20 := self.numImportGenMT20 + 1;
					else
						self.numImportGenMT40 := self.numImportGenMT40 + 1;			
					endif;
				endif;
			else //isReefer
				if (not isEmpty) then
					if (not is40) then
						self.numImportReef20 := self.numImportReef20 + 1;
					else
						self.numImportReef40 := self.numImportReef40 + 1;			
					endif;
				else //isEmpty
					if (not is40) then
						self.numImportReefMT20 := self.numImportReefMT20 + 1;
					else
						self.numImportReefMT40 := self.numImportReefMT40 + 1;			
					endif;
				endif;
			endif;
			*/
			if (not isEmpty) then	//isFull
				if (not isReefer) then
					if (not is40) then
						self.numImportGen20 := self.numImportGen20 + 1;
					else
						self.numImportGen40 := self.numImportGen40 + 1;			
					endif;
				else //isReefer
					if (not is40) then
						self.numImportReef20 := self.numImportReef20 + 1;
					else
						self.numImportReef40 := self.numImportReef40 + 1;			
					endif;
				endif;
			else //isEmpty
				if (not isISOReefer) then	//different rule for MT reefer
					if (not is40) then
						self.numImportGenMT20 := self.numImportGenMT20 + 1;
					else
						self.numImportGenMT40 := self.numImportGenMT40 + 1;			
					endif;
				else //isReefer
					if (not is40) then
						self.numImportReefMT20 := self.numImportReefMT20 + 1;
					else
						self.numImportReefMT40 := self.numImportReefMT40 + 1;			
					endif;
				endif;
			endif;				
		else //isTransship
			if isEmpty then
				if (not is40) then
					self.numImportTransMT20 := self.numImportTransMT20 + 1;
				else
					self.numImportTransMT40 := self.numImportTransMT40 + 1;			
				endif;
			elseif isReefer then
				if (not is40) then
					self.numImportTransReef20 := self.numImportTransReef20 + 1;
				else
					self.numImportTransReef40 := self.numImportTransReef40 + 1;			
				endif;
			else //isGeneral
				if (not is40) then
					self.numImportTransGen20 := self.numImportTransGen20 + 1;
				else
					self.numImportTransGen40 := self.numImportTransGen40 + 1;			
				endif;
			endif;
		endif;
	else //isExport
		if (not isTransShip) then
			if isEmpty then
				if (not is40) then
					self.numExportMT20 := self.numExportMT20 + 1;
				else
					self.numExportMT40 := self.numExportMT40 + 1;			
				endif;
			elseif isReefer then
				if (not is40) then
					self.numExportReef20 := self.numExportReef20 + 1;
				else
					self.numExportReef40 := self.numExportReef40 + 1;			
				endif;
			else //isGeneral
				if (not is40) then
					self.numExportGen20 := self.numExportGen20 + 1;
				else
					self.numExportGen40 := self.numExportGen40 + 1;			
				endif;				
			endif;		
		else //isTransship
			if isEmpty then
				if (not is40) then
					self.numExportTransMT20 := self.numExportTransMT20 + 1;
				else
					self.numExportTransMT40 := self.numExportTransMT40 + 1;			
				endif;
			elseif isReefer then
				if (not is40) then
					self.numExportTransReef20 := self.numExportTransReef20 + 1;
				else
					self.numExportTransReef40 := self.numExportTransReef40 + 1;			
				endif;
			else //isGeneral
				if (not is40) then
					self.numExportTransGen20 := self.numExportTransGen20 + 1;
				else
					self.numExportTransGen40 := self.numExportTransGen40 + 1;			
				endif;
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_isSummaryTotal" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="totalSelfForExchangeSummaryTxn" id="e7fb83e0-408e-43ce-b235-e4ad0d84279d">
        <updating/>
        <source>totalSelfForExchangeSummaryTxn(_txn : CM_TITransaction; _isSummaryTotal: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     30 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	isImport,
	isTransShip,
	isReefer,
	isEmpty,
	is40		: Boolean;
	snapShot	: CM_TISnapShot;
	isoType		: CM_ISOType;
	amtToAdd	: Integer;
begin
	snapShot := _txn.mySnapShot.CM_TISnapShot;
	if snapShot = null then
		return;
	endif;
	
	//not concerned with non-containerised cargo as yet
	if (not (snapShot.cargoType = TI_CargoType_Container))then
		return;
	endif;
	
	total := total + 1;
	
	if (snapShot.imExStatus = TI_IMEX_STATUS_IMPORT)
	or (snapShot.imExStatus = TI_IMEX_STATUS_STORAGE) then
		isImport := true;
	endif;
	
	isEmpty := snapShot.isEmpty;
	isTransShip := snapShot.isTransship;
	
	if isEmpty then
		isoType := app.myRoot.allISOTypes[snapShot.isoType];
		if isoType &lt;&gt; null then
			isReefer := isoType.isReefer();
		endif;
	else
		isReefer := snapShot.requiresPower;
	endif;
	
	is40 := snapShot.is40;

	if snapShot.transitStatus = TI_TransitStatusDLR then
		//restow totals are doubled ('cause it's two moves - note totals only)
		amtToAdd := 1;
		if _isSummaryTotal then
			amtToAdd := 2;
		endif;
		total := total + 1;	//add an extra 1 to total to make sure numbers balance
		
		if isEmpty then
			if (not is40) then
				self.numDLRMT20 := self.numDLRMT20 + amtToAdd;
			else
				self.numDLRMT40 := self.numDLRMT40 + amtToAdd;			
			endif;
		elseif isReefer then
			if (not is40) then
				self.numDLRReef20 := self.numDLRReef20 + amtToAdd;
			else
				self.numDLRReef40 := self.numDLRReef40 + amtToAdd;			
			endif;
		else //isGeneral
			if (not is40) then
				self.numDLRGen20 := self.numDLRGen20 + amtToAdd;
			else
				self.numDLRGen40 := self.numDLRGen40 + amtToAdd;			
			endif;
		endif;
		
	elseif snapShot.transitStatus = TI_TransitStatusSOB then
		if isEmpty then
			if (not is40) then
				self.numSOBMT20 := self.numSOBMT20 + 1;
			else
				self.numSOBMT40 := self.numSOBMT40 + 1;			
			endif;
		elseif isReefer then
			if (not is40) then
				self.numSOBReef20 := self.numSOBReef20 + 1;
			else
				self.numSOBReef40 := self.numSOBReef40 + 1;			
			endif;
		else //isGeneral
			if (not is40) then
				self.numSOBGen20 := self.numSOBGen20 + 1;
			else
				self.numSOBGen40 := self.numSOBGen40 + 1;			
			endif;
		endif;
		
	//Note that import non-tranship have an extra distinguishment for empties between and reefer and gen
	//all the rest do not - see CCMS#1273
	elseif isImport then 
		if (not isTransShip) then
			if (not isReefer) then
				if (not isEmpty) then
					if (not is40) then
						self.numImportGen20 := self.numImportGen20 + 1;
					else
						self.numImportGen40 := self.numImportGen40 + 1;			
					endif;
				else //isEmpty
					if (not is40) then
						self.numImportGenMT20 := self.numImportGenMT20 + 1;
					else
						self.numImportGenMT40 := self.numImportGenMT40 + 1;			
					endif;
				endif;
			else //isReefer
				if (not isEmpty) then
					if (not is40) then
						self.numImportReef20 := self.numImportReef20 + 1;
					else
						self.numImportReef40 := self.numImportReef40 + 1;			
					endif;
				else //isEmpty
					if (not is40) then
						self.numImportReefMT20 := self.numImportReefMT20 + 1;
					else
						self.numImportReefMT40 := self.numImportReefMT40 + 1;			
					endif;
				endif;
			endif;		
		else //isTransship
			if isEmpty then
				if (not is40) then
					self.numImportTransMT20 := self.numImportTransMT20 + 1;
				else
					self.numImportTransMT40 := self.numImportTransMT40 + 1;			
				endif;
			elseif isReefer then
				if (not is40) then
					self.numImportTransReef20 := self.numImportTransReef20 + 1;
				else
					self.numImportTransReef40 := self.numImportTransReef40 + 1;			
				endif;
			else //isGeneral
				if (not is40) then
					self.numImportTransGen20 := self.numImportTransGen20 + 1;
				else
					self.numImportTransGen40 := self.numImportTransGen40 + 1;			
				endif;
			endif;
		endif;
	else //isExport
		if (not isTransShip) then
			if isEmpty then
				if (not is40) then
					self.numExportMT20 := self.numExportMT20 + 1;
				else
					self.numExportMT40 := self.numExportMT40 + 1;			
				endif;
			elseif isReefer then
				if (not is40) then
					self.numExportReef20 := self.numExportReef20 + 1;
				else
					self.numExportReef40 := self.numExportReef40 + 1;			
				endif;
			else //isGeneral
				if (not is40) then
					self.numExportGen20 := self.numExportGen20 + 1;
				else
					self.numExportGen40 := self.numExportGen40 + 1;			
				endif;				
			endif;		
		else //isTransship
			if isEmpty then
				if (not is40) then
					self.numExportTransMT20 := self.numExportTransMT20 + 1;
				else
					self.numExportTransMT40 := self.numExportTransMT40 + 1;			
				endif;
			elseif isReefer then
				if (not is40) then
					self.numExportTransReef20 := self.numExportTransReef20 + 1;
				else
					self.numExportTransReef40 := self.numExportTransReef40 + 1;			
				endif;
			else //isGeneral
				if (not is40) then
					self.numExportTransGen20 := self.numExportTransGen20 + 1;
				else
					self.numExportTransGen40 := self.numExportTransGen40 + 1;			
				endif;
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="_txn" type="CM_TITransaction"/>
        <Parameter name="_isSummaryTotal" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="totalSelfForLoadDisTxn" id="b2d57c6d-1a72-4eb0-8190-ad1a45951b90">
        <updating/>
        <source>totalSelfForLoadDisTxn(_txn : CM_TITransaction) updating;
/*
Date		Who		Reason
12 Apr 2010	cnwndl1	Initial creation	Par 23052 - rewritten to handle 30's, 45's and 53's.
27 Nov 2012	cnwcs5	par 30816
*/

vars
	terminal	: CM_Terminal;		// par 30816 cnwcs5 Nov 2012
	snapShot 	: CM_TISnapShot;
	isContainer : Boolean;
	isoType 	: CM_ISOType;
	is20, is30, is40, 
	is45, is53 	: Boolean;
	
begin
	snapShot := _txn.mySnapShot.CM_TISnapShot;
	
	if snapShot = null then
		return;
	endif;
	
	isContainer := (snapShot.cargoType = TI_CargoType_Container);
	
	// when a report is run as part of a package we cannot rely on terminal being set on app.myPassport
		terminal	:= app.myPassport.myTerminal;	// par 30816 cnwcs5 Nov 2012
	
	if terminal = null then							// par 30816 cnwcs5 Nov 2012
		terminal := self.getTerminal;				// par 30816 cnwcs5 Nov 2012
	endif;											// par 30816 cnwcs5 Nov 2012
	
	if isContainer then
		isoType := snapShot.getIsoTypeObject();
		
		if isoType &lt;&gt; null then
			if isoType.is20ftLong then
				is20 := true;
			elseif isoType.is30ftLong then
				is30 := true;
				
				if terminal.getConfig(Is30IncludedForReports).Integer = 0 then	// par 30816 cnwcs5 Nov 2012
					// explicitly ignore 30 footers
					return;
				endif;
				
			elseif isoType.is40ftLong then
				is40 := true;
				
			elseif isoType.is45ftLong then
				is45 := true;
				
				if terminal.getConfig(Is45IncludedForReports).Integer = 0 then	// par 30816 cnwcs5 Nov 2012
					// explicitly ignore 45 footers
					return;
				endif;
			elseif isoType.is53ftLong then
				is53 := true;
				
				if terminal.getConfig(Is53IncludedForReports).Integer = 0 then	// par 30816 cnwcs5 Nov 2012
					// explicitly ignore 53 footers
					return;
				endif;
			endif;
		else
			is20 := true;	// default value for conatiner....
		endif;
	endif;
	
	if snapShot.transitStatus = TI_TransitStatusDLR then
		self.totalDLR := self.totalDLR + 1;
		if isContainer then
			if is20 then
				if snapShot.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					self.num20ftDLRMT := self.num20ftDLRMT + 1;
				else
					self.num20ftDLR := self.num20ftDLR + 1;
				endif;
			elseif is30 then
				if snapShot.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					self.num30ftDLRMT := self.num30ftDLRMT + 1;
				else
					self.num30ftDLR := self.num30ftDLR + 1;
				endif;
			elseif is40 then
				if snapShot.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					self.num40ftDLRMT := self.num40ftDLRMT + 1;
				else
					self.num40ftDLR := self.num40ftDLR + 1;
				endif;
			elseif is45 then
				if snapShot.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					self.num45ftDLRMT := self.num45ftDLRMT + 1;
				else
					self.num45ftDLR := self.num45ftDLR + 1;
				endif;			
			elseif is53 then
				if snapShot.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					self.num53ftDLRMT := self.num53ftDLRMT + 1;
				else
					self.num53ftDLR := self.num53ftDLR + 1;
				endif;			
			
			endif;
		else
			self.numOtherDLR := numOtherDLR + 1;
		endif;
			
	elseif snapShot.transitStatus = TI_TransitStatusSOB then
		self.totalSOB := self.totalSOB + 1;
		if isContainer then
			if is20 then
				if snapShot.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					self.num20ftSOBMT := self.num20ftSOBMT + 1;
				else
					self.num20ftSOB := self.num20ftSOB + 1;
				endif;
			elseif is30 then
				if snapShot.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					self.num30ftSOBMT := self.num30ftSOBMT + 1;
				else
					self.num30ftSOB := self.num30ftSOB + 1;
				endif;
			elseif is40 then
				if snapShot.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					self.num40ftSOBMT := self.num40ftSOBMT + 1;
				else
					self.num40ftSOB := self.num40ftSOB + 1;
				endif;
			elseif is45 then
				if snapShot.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					self.num45ftSOBMT := self.num45ftSOBMT + 1;
				else
					self.num45ftSOB := self.num45ftSOB + 1;
				endif;
			elseif is53 then
				if snapShot.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					self.num53ftSOBMT := self.num53ftSOBMT + 1;
				else
					self.num53ftSOB := self.num53ftSOB + 1;
				endif;
			endif;
		else
			self.numOtherSOB := numOtherSOB + 1;
		endif;
		
	elseif _txn.type = TRANS_TYPE_REC_SHIP then
		self.totalDischarge := self.totalDischarge + 1;
		if isContainer then
			if is20 then
				if snapShot.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					self.numDischarge20ftEmpty := self.numDischarge20ftEmpty + 1;
				else
					self.numDischarge20ftFull := self.numDischarge20ftFull + 1;				
				endif;
			elseif is30 then
				if snapShot.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					self.numDischarge30ftEmpty := self.numDischarge30ftEmpty + 1;
				else
					self.numDischarge30ftFull := self.numDischarge30ftFull + 1;				
				endif;
			elseif is40 then
				if snapShot.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					self.numDischarge40ftEmpty := self.numDischarge40ftEmpty + 1;
				else
					self.numDischarge40ftFull := self.numDischarge40ftFull + 1;				
				endif;
			elseif is45 then
				if snapShot.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					self.numDischarge45ftEmpty := self.numDischarge45ftEmpty + 1;
				else
					self.numDischarge45ftFull := self.numDischarge45ftFull + 1;				
				endif;
			elseif is53 then
				if snapShot.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					self.numDischarge53ftEmpty := self.numDischarge53ftEmpty + 1;
				else
					self.numDischarge53ftFull := self.numDischarge53ftFull + 1;				
				endif;
			endif;
		else
			self.numDischargeOther := self.numDischargeOther + 1;
		endif;
		
	elseif _txn.type = TRANS_TYPE_REL_SHIP then
		self.totalLoad := self.totalLoad + 1;
		
		if isContainer then
			if is20 then
				if snapShot.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					self.numLoad20ftEmpty := self.numLoad20ftEmpty + 1;
				else
					self.numLoad20ftFull := self.numLoad20ftFull + 1;				
				endif;
			elseif is30 then
				if snapShot.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					self.numLoad30ftEmpty := self.numLoad30ftEmpty + 1;
				else
					self.numLoad30ftFull := self.numLoad30ftFull + 1;				
				endif;
			elseif is40 then
				if snapShot.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					self.numLoad40ftEmpty := self.numLoad40ftEmpty + 1;
				else
					self.numLoad40ftFull := self.numLoad40ftFull + 1;				
				endif;
			elseif is45 then
				if snapShot.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					self.numLoad45ftEmpty := self.numLoad45ftEmpty + 1;
				else
					self.numLoad45ftFull := self.numLoad45ftFull + 1;				
				endif;
			elseif is53 then
				if snapShot.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					self.numLoad53ftEmpty := self.numLoad53ftEmpty + 1;
				else
					self.numLoad53ftFull := self.numLoad53ftFull + 1;				
				endif;
			endif;
		else
			self.numLoadOther := self.numLoadOther + 1;
		endif;
	endif;

end;</source>
        <Parameter name="_txn" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="totalSelfForLoadDisTxnOLD" id="8caa2e88-4416-4b7a-a5b4-f43b009ac7bb">
        <updating/>
        <source>totalSelfForLoadDisTxnOLD(_txn : CM_TITransaction) updating;
// ---------------------------------------------------------------------------
// Created:     21 July 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	isContainer,
	is40		: Boolean;
	snapShot	: CM_TISnapShot;
begin
	
	snapShot := _txn.mySnapShot.CM_TISnapShot;
	if snapShot = null then
		return;
	endif;
	
	isContainer := (snapShot.cargoType = TI_CargoType_Container);
	if isContainer then
		is40 := snapShot.is40;
	endif;
	
	if snapShot.transitStatus = TI_TransitStatusDLR then
		self.totalDLR := self.totalDLR + 1;
		if isContainer then
			if (not is40) then
				if snapShot.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					self.num20ftDLRMT := self.num20ftDLRMT + 1;
				else
					self.num20ftDLR := self.num20ftDLR + 1;
				endif;
			else
				if snapShot.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					self.num40ftDLRMT := self.num40ftDLRMT + 1;
				else
					self.num40ftDLR := self.num40ftDLR + 1;
				endif;			
			endif;
		else
			self.numOtherDLR := numOtherDLR + 1;
		endif;
			
	elseif snapShot.transitStatus = TI_TransitStatusSOB then
		self.totalSOB := self.totalSOB + 1;
		if isContainer then
			if (not is40) then
				if snapShot.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					self.num20ftSOBMT := self.num20ftSOBMT + 1;
				else
					self.num20ftSOB := self.num20ftSOB + 1;
				endif;
			else
				if snapShot.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					self.num40ftSOBMT := self.num40ftSOBMT + 1;
				else
					self.num40ftSOB := self.num40ftSOB + 1;
				endif;
			endif;
		else
			self.numOtherSOB := numOtherSOB + 1;
		endif;
		
	elseif _txn.type = TRANS_TYPE_REC_SHIP then
		self.totalDischarge := self.totalDischarge + 1;
		if isContainer then
			if (not is40) then
				if snapShot.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					self.numDischarge20ftEmpty := self.numDischarge20ftEmpty + 1;
				else
					self.numDischarge20ftFull := self.numDischarge20ftFull + 1;				
				endif;
			else
				if snapShot.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					self.numDischarge40ftEmpty := self.numDischarge40ftEmpty + 1;
				else
					self.numDischarge40ftFull := self.numDischarge40ftFull + 1;				
				endif;
			endif;
		else
			self.numDischargeOther := self.numDischargeOther + 1;
		endif;
		
	elseif _txn.type = TRANS_TYPE_REL_SHIP then
		self.totalLoad := self.totalLoad + 1;
		
		if isContainer then
			if (not is40) then
				if snapShot.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					self.numLoad20ftEmpty := self.numLoad20ftEmpty + 1;
				else
					self.numLoad20ftFull := self.numLoad20ftFull + 1;				
				endif;
			else
				if snapShot.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
					self.numLoad40ftEmpty := self.numLoad40ftEmpty + 1;
				else
					self.numLoad40ftFull := self.numLoad40ftFull + 1;				
				endif;
			endif;
		else
			self.numLoadOther := self.numLoadOther + 1;
		endif;
	endif;

end;</source>
        <Parameter name="_txn" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="totalSelfForLoadSumByIsoGroup" id="452a12e9-aac7-40e4-809d-6005e95f3082">
        <updating/>
        <source>totalSelfForLoadSumByIsoGroup(_ti : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:     06 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	container		: CM_Container;
	
	isEmpty			: Boolean;
	isReef			: Boolean;
	isFull			: Boolean;
	lc					: CM_LocationsController;
	slotController		: CM_SlotController;
	containerWeight		: Decimal[14,4];
begin

	if (not CM_Container.hasInstance(_ti)) then
//if CM_Car.hasInstance(_ti) then
//	self.carWeight := self.carWeight + _ti.totalWeight;
//		elseif CM_BreakBulk.hasInstance(_ti) then
//			self.bBulkWeight := self.bBulkWeight + _ti.totalWeight;
//		elseif CM_Timber.hasInstance(_ti) then
//			self.timberWeight := self.timberWeight + _ti.totalWeight;
//		endif;
		
		self.numOther := self.numOther + 1;
		return;
	endif;

	container := _ti.CM_Container;
	containerWeight := container.totalWeight;
	self.totalWeight := self.totalWeight + containerWeight;
	
//	isEmpty := container.isEmpty();
//	isReef	:= container.isReefer();
	
//	is40 := container.is40;
	self.totalContainers := self.totalContainers + 1;
	
	if container.isEmpty() then
		self.numEmpty := self.numEmpty  + 1;
		self.weightEmpty := self.weightEmpty + containerWeight;
		
	elseif container.requiresTemperature then // should this be container.requiresTemperature ????
		self.numReefer := self.numReefer + 1;
		self.reeferWeight := self.reeferWeight + containerWeight;
		
	else
		self.numGeneral := self.numGeneral + 1;
		self.weightFull := self.weightFull + containerWeight;
	endif;
		
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="totalSelfForTEUSummary" id="36f89461-c799-4533-8773-bff8b122b502">
        <updating/>
        <source>totalSelfForTEUSummary(_ti : CM_TrackedItem) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 April 2010	cnwndl1	Initial creation	par 23051

*/

vars
	container : CM_Container;
	is20 : Boolean;
	is30 : Boolean;
	is40 : Boolean;
	is45 : Boolean;
	is53 : Boolean;
	containerWeight : Decimal[14,4];
begin

	if (not CM_Container.hasInstance(_ti)) then
		if CM_Car.hasInstance(_ti) then
			self.carWeight := self.carWeight + _ti.totalWeight;
		elseif CM_BreakBulk.hasInstance(_ti) then
			self.bBulkWeight := self.bBulkWeight + _ti.totalWeight;
		elseif CM_Timber.hasInstance(_ti) then
			self.timberWeight := self.timberWeight + _ti.totalWeight;
		endif;
		
		self.numOther := self.numOther + 1;
		return;
	endif;

	container := _ti.CM_Container;
	containerWeight := container.totalWeight;
	self.weight := self.weight + containerWeight;
	
	if container.is30 then
		is30 := true;
	elseif container.is40 then
		is40 := true;
	elseif container.is45 then
		is45 := true;
	elseif container.is53 then
		is53 := true;
	else
		is20 := true;
	endif;
	
	self.totalContainers := self.totalContainers + 1;
	
	if is20 then
		self.num20ft := self.num20ft + 1;
		if container.requiresTemperature then
			self.num20ftReefer := self.num20ftReefer + 1;
			self.weight20Reefer := self.weight20Reefer + containerWeight;
			
		elseif container.isEmpty then
			self.num20ftEmpty := self.num20ftEmpty + 1;
			self.weight20Empty := self.weight20Empty + containerWeight;
			
		else
			self.num20ftFull:= self.num20ftFull + 1;
			self.num20ftGeneral := self.num20ftGeneral + 1;
			self.weight20General := self.weight20General + containerWeight;
		endif;
		
	elseif is30 then
		self.num30ft := self.num30ft + 1;
		if container.requiresTemperature then
			self.num30ftReefer := self.num30ftReefer + 1;
			self.weight30Reefer := self.weight30Reefer + containerWeight;
			
		elseif container.isEmpty then
			self.num30ftEmpty := self.num30ftEmpty + 1;
			self.weight30Empty := self.weight30Empty + containerWeight;
			
		else
			self.num30ftFull:= self.num30ftFull + 1;
			self.num30ftGeneral := self.num30ftGeneral + 1;
			self.weight30General := self.weight30General + containerWeight;
		endif;	
	
	elseif is40 then
		self.num40ft := self.num40ft + 1;
		if container.requiresTemperature then
			self.num40ftReefer := self.num40ftReefer + 1;
			self.weight40Reefer := self.weight40Reefer + containerWeight;
			
		elseif container.isEmpty then
			self.num40ftEmpty := self.num40ftEmpty + 1;
			self.weight40Empty := self.weight40Empty + containerWeight;
			
		else
			self.num40ftGeneral := self.num40ftGeneral + 1;
			self.num40ftFull := self.num40ftFull + 1;
			self.weight40General := self.weight40General + containerWeight;
			
		endif;
		
	elseif is45 then
		self.num45ft := self.num45ft + 1;
		if container.requiresTemperature then
			self.num45ftReefer := self.num45ftReefer + 1;
			self.weight45Reefer := self.weight45Reefer + containerWeight;
			
		elseif container.isEmpty then
			self.num45ftEmpty := self.num45ftEmpty + 1;
			self.weight45Empty := self.weight45Empty + containerWeight;
			
		else
			self.num45ftFull:= self.num45ftFull + 1;
			self.num45ftGeneral := self.num45ftGeneral + 1;
			self.weight45General := self.weight45General + containerWeight;
		endif;	
		
	elseif is53 then
		self.num53ft := self.num53ft + 1;
		if container.requiresTemperature then
			self.num53ftReefer := self.num53ftReefer + 1;
			self.weight53Reefer := self.weight53Reefer + containerWeight;
			
		elseif container.isEmpty then
			self.num53ftEmpty := self.num53ftEmpty + 1;
			self.weight53Empty := self.weight53Empty + containerWeight;
			
		else
			self.num53ftFull:= self.num53ftFull + 1;
			self.num53ftGeneral := self.num53ftGeneral + 1;
			self.weight53General := self.weight53General + containerWeight;
		endif;
		
	endif;

	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
