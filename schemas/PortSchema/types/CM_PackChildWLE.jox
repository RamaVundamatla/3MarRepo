    <DbClassMap file="cmtrans"/>
    <JadeMethod name="getChildren" id="78393e68-2b5a-46f9-aeae-b15cc9c837ac">
        <source>getChildren(_childColl: CM_TISet input);
// -----------------------------------------------------------------------------
// Created:		27 July 2009 by consw1
//
// Purpose:		Get the cargo that is going to be packed into containers
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	workOrder : CM_WorkOrder;
	
begin
	if self.job = null then
		return;
	endif;

	workOrder := self.job.getWorkOrder();
	
	if workOrder &lt;&gt; null and workOrder.isKindOf(CM_WorkOrderTI) then
		workOrder.CM_WorkOrderTI.allTIs.copy(_childColl);
	endif;
	
epilog

end;</source>
        <Parameter name="_childColl" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="882f4dd1-d109-430a-ac19-d2080fa88184">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 July 2009	cnwrd1	Initial creation
26 Jun 2025 navbs1	Story 35185: MTN - Refactor Required to Stop Using getDisplayStringForAttribute() for Known Attributes 

*/

vars

	rtStr : String;
begin

	if _attrName = ETRow_WorkEntry then
		rtStr := "Pack Child";
		return rtStr;
	elseif _attrName = ETRow_Remarks then
		return null;			
	elseif _attrName = ETRow_RadioTelemetry then
		return '';
	else
		return inheritMethod(_attrName, _short);
	endif;
	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
