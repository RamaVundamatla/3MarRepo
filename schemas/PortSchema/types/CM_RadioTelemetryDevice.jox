    <JadeMethod name="getDisplayStringForAttribute" id="b1328b5b-f5e5-4dd2-a686-ee8678e80092">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     17 April 2014 by cnwdb2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17 Apr 2014	cnwdb2		PAR #33977  
// 16 Aug 2016 cnwrh7			TFS2501
// ---------------------------------------------------------------------------

vars
	
begin
	if _attrName = ETRow_MessageId then
		if lastMessageId &lt;&gt; null then
			return lastMessageId.String ;
		endif  ;
		return "" ; 
	elseif	_attrName = ETRow_CameraType then
		return app.cameraTypeEnumToString(self.cameraType);
	elseif _attrName = ETRow_PasswordRequired then
		if self.isPasswordCompulsory then
			return app.getErrorString(Yes);
		endif;
		return app.getErrorString(No);
	elseif _attrName =ETRow_UseTCPConnection then			//+TFS2501
			return self.useLocalTCPConnection.asStringJMT;
	endif  ;
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
