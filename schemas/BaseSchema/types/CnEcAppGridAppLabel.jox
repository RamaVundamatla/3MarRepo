    <JadeMethod name="dragDrop" id="8a7f1c42-8c52-4685-a518-3770e7f1d934">
        <updating/>
        <source>dragDrop(label: CnEcAppGridAppLabel input; win: Window input; x: Real; y: Real) updating;

vars

begin
	mousePointer := Window.MousePointer_Default;
	appGrid.appInfo.visible := false;
	if win = self then
		appGrid.appLabel := null;
	else
		appGrid.appLabel := label;
	endif;
	appGrid.dragDrop(appGrid, win, left + x, top + y);
end;</source>
        <Parameter name="label" type="CnEcAppGridAppLabel" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
