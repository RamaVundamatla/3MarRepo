    <JadeMethod name="doResize" id="56ec9fe0-d7b3-4c5d-84df-8357e3730117">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:	2 April 2008 By Graeme Black cnwgb1
// Resize the debtors MS Group box if the parent is resized
