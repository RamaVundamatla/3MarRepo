    <JadeMethod name="displayEntryStopsTableList" id="db31d77b-7d6d-4ca0-a9c8-dd399c2ed3f3">
        <source>displayEntryStopsTableList(_stopTable : CM_StopsTable; _selected : Boolean; _isForDisplay : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:		07 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
vars
	user		: CM_User;
	term		: CM_Terminal;
begin
	if _stopTable = null then
		return null;
	endif;

	if app.myPassport &lt;&gt; null then
		user := app.myPassport.myUser;
		term := app.myPassport.myTerminal;
	endif;
	
// cnwdad1 08/09/2010 - PAR #25653.
//	if user &lt;&gt; null
//	and (not user.canUpdateStop(term, _stopTable)) then
//		return null;
//	endif;
	if user &lt;&gt; null then
		if _isForDisplay then
			if (not user.canViewStop(term, _stopTable)) then
				return null;
			endif;
		else
			if (not user.canUpdateStop(term, _stopTable)) then
				return null;
			endif;
		endif;
	endif;
	
	if _selected then
		return TableCheckBox_Selected &amp; Tab &amp; _stopTable.code &amp; " - " &amp; _stopTable.heading;
	else
		// DVB CCMS 1235
		if app.myRoot.allAvailableStopsTables.includes(_stopTable) or _isForDisplay then
			return TableCheckBox_NotSelected &amp; Tab &amp; _stopTable.code &amp; " - " &amp; _stopTable.heading;
		else
			return null;
		endif;
	endif;
end;</source>
        <Parameter name="_stopTable" type="CM_StopsTable"/>
        <Parameter name="_selected" type="Boolean"/>
        <Parameter name="_isForDisplay" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
