    <JadeMethod name="addResourcesFromProxys" id="fd93656f-1fcf-49b4-8d49-9dab5819b278">
        <updating/>
        <source>addResourcesFromProxys(_resourceUsageProxys: CM_ResourceTypeUsageSet input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 December 2009	cnwndl1	Initial creation
13 Dec 2023 navlc30 ChangeRequest 60748: EUP | VAS Mobile App - [53813.070] [BackEnd] Automatic VAS Resources
24 Jun 2024 navlc30 Bug 64779: EUP | VAS - Automatic VAS resources not added in work order transactions
*/


	// re-implemented on CM_TITransaction
vars
	templateResourceUsageProxy : CM_ResourceTypeUsage;
	
	proxy : CM_ResourceTypeUsage;
	realResourceTypeUsage : CM_ResourceTypeUsage;
	
	ti : CM_TrackedItem;
	handlingType : CM_HandlingType;
	includePalletData : Boolean;
	autoApplyrealResourceType,
 	resourceType 				: CM_ResourceType;
	autoApplyProxy 				: CM_ResourceTypeUsage;	
begin

	if _resourceUsageProxys = null or _resourceUsageProxys.isEmpty then
		return;
	endif;
	
	if self.isTransient then
		return;
	endif;
	
	foreach templateResourceUsageProxy in _resourceUsageProxys do
		resourceType := templateResourceUsageProxy.myResourceType;	
		create proxy transient;
		if includePalletData then
			proxy.setProxy(	templateResourceUsageProxy.myResourceType,	//_resourceType : CM_ResourceType;
							self,	//_transaction : CM_TITransaction;
							templateResourceUsageProxy.noCharge,	//_noCharge : Boolean;
							templateResourceUsageProxy.quantity,	//_quantity : Decimal;
							templateResourceUsageProxy.remarks,	//_remarks : String;
							CM_InvoiceLine.STATUS_NORMAL,	//_status : Integer
							templateResourceUsageProxy.fromDateTime,		//cnwmc5 - 22 Sep 2015 - PAR 36920
							templateResourceUsageProxy.toDateTime,			//cnwmc5 - 22 Sep 2015 - PAR 36920
							templateResourceUsageProxy.myPalletType,	// 13 Apr 2017	NDL	TFS 3414
							templateResourceUsageProxy.isHeatTreated,	// 13 Apr 2017	NDL	TFS 3414
							templateResourceUsageProxy.isStoreOnPallet	// 13 Apr 2017	NDL	TFS 3414
							);
		else
			proxy.setProxy(	templateResourceUsageProxy.myResourceType,	//_resourceType : CM_ResourceType;
							self,	//_transaction : CM_TITransaction;
							templateResourceUsageProxy.noCharge,	//_noCharge : Boolean;
							templateResourceUsageProxy.quantity,	//_quantity : Decimal;
							templateResourceUsageProxy.remarks,	//_remarks : String;
							CM_InvoiceLine.STATUS_NORMAL,	//_status : Integer
							templateResourceUsageProxy.fromDateTime,		//cnwmc5 - 22 Sep 2015 - PAR 36920
							templateResourceUsageProxy.toDateTime,			//cnwmc5 - 22 Sep 2015 - PAR 36920
							null,	// 13 Apr 2017	NDL	TFS 3414
							false,	// 13 Apr 2017	NDL	TFS 3414
							false	// 13 Apr 2017	NDL	TFS 3414
							);
		endif;
		autoApplyrealResourceType := resourceType.myAutoApplyResourceType;																//24.06.2024 navlc30 #64779															
		if autoApplyrealResourceType &lt;&gt;  null and not _resourceUsageProxys.hasResourceType(autoApplyrealResourceType) then				//24.06.2024 navlc30 #64779
			create autoApplyProxy transient;
			autoApplyProxy.setProxy(autoApplyrealResourceType,	//_resourceType : CM_ResourceType;
									self,	//_transaction : CM_TITransaction;
									templateResourceUsageProxy.noCharge,	//_noCharge : Boolean;
									templateResourceUsageProxy.quantity,	//_quantity : Decimal;
									templateResourceUsageProxy.remarks,	//_remarks : String;
									CM_InvoiceLine.STATUS_NORMAL,	//_status : Integer
									templateResourceUsageProxy.fromDateTime,
									templateResourceUsageProxy.toDateTime,
									null,
									false,
									false
									);
		endif;					
		app.myUtilityCA.utlCreateResourceTypeUsage(	proxy,	//pProxyResourceTypeUsage : CM_ResourceTypeUsage;
													autoApplyProxy,	//pProxyAutoApplyResourceTypeUsage : CM_ResourceTypeUsage;					//13.12.2023 navlc30 #60748
													realResourceTypeUsage,	//pNewResourceTypeUsage : CM_ResourceTypeUsage output;
													app.myPassport	//_passport : CM_Passport input
													);
		delete proxy;
		delete autoApplyProxy;		
	endforeach;
	
epilog
	delete proxy;
	delete autoApplyProxy;	
end;</source>
        <Parameter name="_resourceUsageProxys" type="CM_ResourceTypeUsageSet" usage="input"/>
    </JadeMethod>
