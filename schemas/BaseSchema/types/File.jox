<Class name="File">
    <JadeMethod name="cnEcCopy" id="ba87ad8f-200c-4d9b-9591-ae1ef164d2ca">
        <updating/>
        <source>cnEcCopy(pTarget:String):Boolean updating;
// -----------------------------------------------------------------------------
// Created:		17 January 2002 by cnwdad1
//
// Purpose:		Copies the receiver's disk file to the specified file name.
//
// Parameters:	pTarget - The name of the file to copy the receiver to.
//
// Returns:		True if the copy was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	isSuccessful	: Boolean;
	copyResult		: Integer;
	
begin
	isSuccessful	:=	false;
	
	if app.isUnicode() then
		copyResult	:=	call cnEcCopyFileW(self.fileName, pTarget, true);
	else
		copyResult	:=	call cnEcCopyFileA(self.fileName, pTarget, true);
	endif;
	
	if copyResult = 0 then
		isSuccessful	:=	false;
	else
		isSuccessful	:=	true;
	endif;
epilog
	return isSuccessful;
end;</source>
        <Parameter name="pTarget" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcFileExceptionHandler" id="11493168-efec-4891-85d9-235592eed0b5">
        <source>cnEcFileExceptionHandler(pExceptionObj:Exception):Integer;

begin
	cnEcLog("File exception (" &amp; pExceptionObj.errorCode.String &amp; "): " &amp; pExceptionObj.text());
	return Ex_Pass_Back;	
end;</source>
        <Parameter name="pExceptionObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetAttributes" id="10fae3ba-ee66-4e8a-9777-59c8cbf9cb17">
        <source>cnEcGetAttributes():String;
// --------------------------------------------------------------------------------
// Created:		14 May 1999 - getAttributes
// By:			cnwdad1
//
// Purpose:		Returns a string of the files File System attributes.
//
// Parameters:	None
//
// Returns:		String - A string of one-character attributes.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	attributes	: String;

begin
	if (self.archive) then		
		attributes	:=	attributes &amp; 'A';
	endif;

	if (self.hidden) then
		attributes	:=	attributes &amp; 'H';
	endif;

	if (self.readOnly) then
		attributes	:=	attributes &amp; 'R';
	endif;

	if (self.systemFile) then
		attributes	:=	attributes &amp; 'S';
	endif;
epilog
	return attributes;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsFile" id="d9758b3f-39d4-4faf-ac19-637bd4d93419">
        <source>cnEcIsFile(): Boolean;
// -----------------------------------------------------------------------------
// Created:		22 January 2002 by cnwdad1
//
// Purpose:		Reimplementation of superclass method.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsNotEndOfFile" id="16885d4b-c9f9-4b14-ab47-364754273552">
        <source>cnEcIsNotEndOfFile():Boolean;
// --------------------------------------------------------------------------------
// Created:		12 April 2001 by cnwdad1
//
// Purpose:		This method returns a boolean flag to indicate whether the end of
//				the receiver (file) has been reached.  This method is the opposite
//				of the native "endOfFile" method.
//
// Parameters:	None
//
// Returns:		True if the end of the file has NOT been reached, or false if the
//				end of the file HAS been reached.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (not self.endOfFile());
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcMove" id="e032c077-0444-4501-a791-7884c909e6ea">
        <updating/>
        <source>cnEcMove(pTarget: String): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		17 January 2002 by cnwdad1
//
// Purpose:		Moves the receiver's disk file to the specified file name.
//
// Parameters:	pTarget - The name of the file to move the receiver to.
//
// Returns:		True if the move was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	isSuccessful	: Boolean;
	moveResult		: Integer;
	
begin
	isSuccessful	:=	false;
	
	if app.isUnicode() then
		moveResult	:=	call cnEcMoveFileW(self.fileName, pTarget);
	else
		moveResult	:=	call cnEcMoveFileA(self.fileName, pTarget);
	endif;
	
	if moveResult = 0 then
		isSuccessful	:=	false;
	else
		isSuccessful	:=	true;
	endif;
epilog
	return isSuccessful;
end;</source>
        <Parameter name="pTarget" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcOpenForLogging" id="5fea046c-cfb5-4ffc-9776-61ad52960023">
        <updating/>
        <source>cnEcOpenForLogging() updating;

begin
	if not self.isOpen() then
		self.mode			:=	File.Mode_Append;
		self.allowReplace	:=	true;
		self.shareMode		:=	File.Share_ReadWrite;
		self.kind			:=	File.Kind_Unknown_Text;	// 24/2/16 cnwmp6 PAR 36286 unicode version
		self.open;
	endif; 
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcReadBinary" id="2ee5a47c-a96b-4bc3-905b-79160c2093f6">
        <source>cnEcReadBinary(pSize:Integer):Binary;
// --------------------------------------------------------------------------------
// Created:		20 December 2007 by cnwdad1
//
// Purpose:		Reads the entire contents of the receiver in chunks, rather than as
//				a single blob.
//
// Parameters:	pSize - The size of each chunk (in bytes) to read.
//
// Returns:		The binary file data.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	pointer		: Integer;
	fileData	: Binary;
	binaryData	: Binary;
	fileLength	: Integer;
	readSize	: Integer;
	
begin
	pointer		:=	0;
	fileLength	:=	self.fileLength();
	
	if pSize &lt; fileLength then
		readSize	:=	fileLength;
	else
		readSize	:=	pSize;
	endif;
	
	while true do
		if pointer &gt; 0 then
			self.seek(pointer);
		endif;
		
		fileData	:=	self.readBinary(readSize);
		pointer		:=	pointer + readSize;
		
		if binaryData = null then
			binaryData	:=	fileData;
		else
			binaryData	:=	binaryData &amp; fileData;
		endif;
		
		if pointer &gt;= fileLength then
			break;
		else
			if (pointer + readSize) &gt; fileLength then
				// The next pass will be the last chunk of the file to be read, so adjust the readSize accordingly.
				readSize	:=	fileLength - pointer;
			endif;
		endif;
	endwhile;
	
	return binaryData;
end;</source>
        <Parameter name="pSize" type="Integer"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="cnEcReadCsv" id="60d30324-1ab8-4db4-a211-9971b6bfe5f8">
        <source>cnEcReadCsv(pRecordArray:ObjectArray io; pIsHuge:Boolean);
// --------------------------------------------------------------------------------
// Created:		12 May 1999 by cnwdad1
//
// Purpose:		Reads a comma-delimited file (quote-enclosed) into an array of arrays.
//
// Parameters:	pRecordArray (ObjectArray) - Accepts an ObjectArray.  The returned
//				array will contain a StringArray for each record (the StringArray
//				will contain one subscript for each field).
//
//				pIsHuge (Boolean) - Indicates whether to return records as a StringArray
//				or as a HugeStringArray.
//
// Returns:		See 'pRecordArray' Input-Output paramter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	COMMA			: String = ',';
	DOUBLE_QUOTE	: String = '"';

vars
	fieldNo		: Integer;
	fieldPos	: Integer;
	fieldLen	: Integer;
	record		: String;
	recordLen	: Integer;
	fieldArray	: Array;

begin
	pRecordArray.clear();		// Initialize the array of records.

	while (not self.endOfFile()) do
		record		:=	self.readLine;		// Get the (next) file record.
		recordLen	:=	record.length;		// Get the length of the record.
		fieldPos	:=	1;					// Initialize the field position.
		fieldNo		:=	1;					// Initialize the field number.

		// Create a new array of record fields.

		if (pIsHuge) then
			create fieldArray as HugeStringArray transient;
		else
			create fieldArray as StringArray transient;
		endif;

		// Now scan the record...

		while (fieldPos &lt; recordLen) do
			fieldLen	:=	record.pos(COMMA, fieldPos);		// Locate the next subsequent comma (field delimiter).
			fieldLen	:=	fieldLen - fieldPos;				// Get the length of this field.

			if (record.pos(COMMA, fieldPos) = 0) and (fieldPos &lt; recordLen) then
				// This must be the last field in the record.
				fieldLen	:=	recordLen - fieldPos + 1;
			endif;

			fieldArray[fieldNo]	:=	record[fieldPos:fieldLen];		// Add this field to the array of fields.

			// If the comma is inside double-quotes, scan ahead in the record for the next double-quote.

			while (fieldArray[fieldNo].String[1] = DOUBLE_QUOTE)
			and (fieldArray[fieldNo].String[fieldArray[fieldNo].String.length] &lt;&gt; DOUBLE_QUOTE)
			do
				fieldPos			:=	fieldPos + fieldLen + 1;
				fieldLen			:=	record.pos(COMMA, fieldPos);
				fieldLen			:=	fieldLen - fieldPos;
				fieldArray[fieldNo]	:=	fieldArray[fieldNo].String &amp; COMMA &amp; record[fieldPos:fieldLen];
			endwhile;

			// String any double-quotes that surround the field value.

			if (fieldArray[fieldNo].String[1] = DOUBLE_QUOTE)
			and (fieldArray[fieldNo].String[fieldArray[fieldNo].String.length] = DOUBLE_QUOTE)
			then
				fieldArray[fieldNo]	:=	fieldArray[fieldNo].String[2:(fieldArray[fieldNo].String.length - 2)];
			endif;

			// Increment positions to the next field position.

			fieldPos	:=	fieldPos + fieldLen + 1;
			fieldNo		:=	fieldNo + 1;
		endwhile;

		pRecordArray.add(fieldArray);
	endwhile;
end;</source>
        <Parameter name="pRecordArray" type="ObjectArray" usage="io"/>
        <Parameter name="pIsHuge" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcRemove" id="14805c00-b51f-4d5d-a049-026da02d3f06">
        <updating/>
        <source>cnEcRemove(): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		17 January 2002 by cnwdad1
//
// Purpose:		Deletes the receiver's file from disk.  The file is physically
//				deleted, and so cannot be restored from the Windows' Recycle Bin.
//
// Parameters:	None.
//
// Returns:		True if the delete was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	isSuccessful	: Boolean;
	
begin
	isSuccessful	:=	false;
	self.purge;
	isSuccessful	:=	true;
epilog
	return isSuccessful;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetOpenName" id="bedf8af6-5cf6-45b5-a06d-cced0d9145a1">
        <updating/>
        <source>cnEcSetOpenName(pMustExist:Boolean; pCreatePrompt:Boolean; pFileFilter:String):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		17 August 2001 by cnwdad1
//
// Purpose:		This method will prompt the user to select (or enter) a file name,
//				and will then use that name to set the receiver's file name.
//
// Parameters:	pMustExist - If true, then the file being opened must already exist.
//				pCreatePrompt - If true, the user will be prompted to create the
//					file if it doesn't already exist.
//				pFileFilter - The file-type filter string.
//
// Returns:		True if the file name was successfully set, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	isSuccessful	: Boolean;
	fileOpenObj		: CMDFileOpen;
	
begin
	isSuccessful	:=	false;
	create fileOpenObj;
	
	fileOpenObj.fileMustExist	:=	pMustExist;
	fileOpenObj.createPrompt	:=	pCreatePrompt;
	
	if pFileFilter &lt;&gt; null then
		fileOpenObj.filter	:=	pFileFilter;
	endif;
	
	if fileOpenObj.open() = 0 then
		self.kind := File.Kind_Unknown_Text; // 1/3/16  cnwns1 PAR 36286 unicode version
		self.fileName	:=	fileOpenObj.fileName;
		isSuccessful	:=	true;
	endif;
epilog
	delete fileOpenObj;
	
	return isSuccessful;
end;</source>
        <Parameter name="pMustExist" type="Boolean"/>
        <Parameter name="pCreatePrompt" type="Boolean"/>
        <Parameter name="pFileFilter" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetSaveName" id="1a818c15-c422-4e98-8040-1854f0132b33">
        <updating/>
        <source>cnEcSetSaveName(pDefaultName:String; pCreatePrompt:Boolean; pOverwritePrompt:Boolean; pFileFilter:String):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		17 August 2001 by cnwdad1
//
// Purpose:		This method will prompt the user to select (or enter) a file name,
//				and will then use that name to set the receiver's file name.
//
// Parameters:	pDefaultName - The default file name.
//				pCreatePrompt - If true, the user will be prompted to create the
//					file if it doesn't already exist.
//				pOverwritePrompt - If true, the user will be prompted to overwrite
//					the file if it already exists.
//				pFileFilter - The file-type filter string.
//
// Returns:		True if the file name was successfully set, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	isSuccessful	: Boolean;
	fileSaveObj		: CMDFileSave;
	
begin
	isSuccessful	:=	false;
	create fileSaveObj;
	
	fileSaveObj.fileName		:=	pDefaultName;
	fileSaveObj.fileMustExist	:=	false;
	fileSaveObj.createPrompt	:=	pCreatePrompt;
	fileSaveObj.overwritePrompt	:=	pOverwritePrompt;
	fileSaveObj.pathMustExist	:=	true;
	
	if pFileFilter &lt;&gt; null then
		fileSaveObj.filter	:=	pFileFilter;
	endif;
	
	if fileSaveObj.open = 0 then
		self.kind := File.Kind_Unknown_Text; // 1/3/16  cnwns1 PAR 36286 unicode version
		self.fileName	:=	fileSaveObj.fileName;
		isSuccessful	:=	true;
	endif;
epilog
	delete fileSaveObj;
	
	return isSuccessful;
end;</source>
        <Parameter name="pDefaultName" type="String"/>
        <Parameter name="pCreatePrompt" type="Boolean"/>
        <Parameter name="pOverwritePrompt" type="Boolean"/>
        <Parameter name="pFileFilter" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
