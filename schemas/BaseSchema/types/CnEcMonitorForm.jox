    <JadeMethod name="setMenuNameSetLogFile" id="eebb322e-a806-4f3f-ba8e-314035c599ed">
        <source>setMenuNameSetLogFile();
// --------------------------------------------------------------------------------
// Created:		26 May 2000 by cnwdad1
//
// Purpose:		Set the name of the "Log File Set" menu.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	menuName	: String;

begin
	menuName	:=	self.MENU_NAME_SET_LOG_FILE;

	if self.aMyLogFile = null then
		menuName	:=	menuName &amp; " (" &amp; self.NOT_SET &amp; ")";
	else
		menuName	:=	menuName &amp; " (" &amp; self.aMyLogFile.fileName &amp; ")";
	endif;
epilog
	mnuSettingsLogFileSet.caption	:=	menuName;
end;</source>
