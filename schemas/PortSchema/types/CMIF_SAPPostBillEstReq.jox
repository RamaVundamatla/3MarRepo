<Class name="CMIF_SAPPostBillEstReq" id="188ab4c2-0e49-4a77-b04d-227ed9ade977">
    <superclass name="CMIF_SAPWSRequest"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>37189.003 Perform Credit Check for Post-Billing Customer
WSDL 1.6: Post-Billing - Credit Limit
PaymentType_PostPay</text>
    <PrimAttribute name="amount" id="db972eb5-5d5e-4544-b490-910aaf9ba13a">
        <type name="String"/>
        <text>CM_CashReceipt.cashValue</text>
    </PrimAttribute>
    <PrimAttribute name="amountEstmtOpen" id="1e1874e2-8c2a-4c50-964c-6bcea3f64d38">
        <type name="String"/>
        <text>Total of CM_CashReceipt.cashValue with CM_CashReceipt.paymentStatus =  CREDIT_CHECK_APPROVED
on all terminal for PostPay Debtor.
CM_Debtor.getEstimateOpenAmountPostPay</text>
    </PrimAttribute>
    <PrimAttribute name="currency" id="b424a26c-62ce-4e0c-9b1e-a6b0449253e3">
        <type name="String"/>
        <text>if cashReceipt.getBank.isPelDomestic then
	value := "IDR";
else
	value := "USD";
endif;</text>
    </PrimAttribute>
    <PrimAttribute name="customerNo" id="3db18490-c6f0-4de7-b56c-c31e8ab1b714">
        <type name="String"/>
        <text>CM_Debtor.code</text>
    </PrimAttribute>
    <PrimAttribute name="estimationID" id="dbd3f92a-c66a-4934-9242-091ec0847d29">
        <type name="String"/>
        <text>CM_CashReceipt.externalInvoiceNumber</text>
    </PrimAttribute>
    <JadeMethod name="copyToRealWSObject" id="3654b94a-d264-4298-85eb-f369266cd87a">
        <source>copyToRealWSObject(_realRequest: SAP16_PostBillEstimationReq_DT input;
				   _createdObjects : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

begin
	inheritMethod(_realRequest, _createdObjects);
	
	_realRequest.amount := self.amount;
	_realRequest.amountEstmtOpen := self.amountEstmtOpen;
	_realRequest.currency := self.currency;
	_realRequest.customerNo := self.customerNo;
	_realRequest.estimationID := self.estimationID;

epilog

end;</source>
        <Parameter name="_realRequest" type="SAP16_PostBillEstimationReq_DT" usage="input"/>
        <Parameter name="_createdObjects" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="copyToSAPPostBillEstReq" id="8aa6007f-b8dc-4d41-a400-fd4b3ab87d71">
        <updating/>
        <source>copyToSAPPostBillEstReq(_cashRec : CM_CashReceipt) updating;
/*

Purpose:			
	37189.003 Perform Credit Check for Post-Billing Customer
	WSDL 1.6: Post-Billing - Credit Limit
	PaymentType_PostPay	

Return Value:		

Date		Who		Reason
12 Jul 2018	jlgrs1	ChangeRequest 38630: PEL1 - SAP Credit Check Interfaces
29 Jan 2019 cnwma1	Bug 43124: PEL1 - Container Services - SAP SIT issues
*/
vars

begin
	self.estimationID  		:= self.sapHelper(_cashRec,"estimationID");
	self.customerNo    		:= self.sapHelper(_cashRec,"customerNo"); 
	self.amount 			:= self.sapHelper(_cashRec,"amount"); 
	self.currency			:= self.sapHelper(_cashRec,"currency");
	self.amountEstmtOpen 	:= _cashRec.getDebtor.getEstimateOpenAmount(PaymentType_PostPay).String;  //29.01.2019 cnwma1 #43214
	
epilog

end;</source>
        <Parameter name="_cashRec" type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="getActivityHistoryExtraDetails" id="c3f69c5a-8377-4a26-a539-b885e1af80ff">
        <source>getActivityHistoryExtraDetails(_activityHistory: CM_ActivityHistoryExtInterface input): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2019	jlgndl1	Initial creation	TFS 46758

*/

vars

begin
	
	return self.getEstimationIdString( _activityHistory );

epilog

end;</source>
        <Parameter name="_activityHistory" type="CM_ActivityHistoryExtInterface" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWSDLType" id="9969f3d9-21fa-4ddd-9f94-94c1f572535a">
        <source>getWSDLType(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 September 2019	jlgndl1	Initial creation	TFS 46758

*/

vars

begin
	return BGP_SAPWSRequest.WSDL16;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleSAPResponse" id="a365d15c-a5b7-41a5-864b-5f96ef4d3fe7">
        <source>handleSAPResponse(	_response: CMIF_SAPWSResponse;
					_cashReceipt: CM_CashReceipt input;
					_invoice: CM_Invoice input;
					_invoiceLines: CM_InvoiceLineSet input;
					_activityHistory: CM_ActivityHistoryExtInterface input
					): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 September 2019	jlgndl1	Initial creation	TFS 46758

	Response for Perform Credit Check for Post-Billing Customer
	WSDL 1.6: Post-Billing - Credit Limit
	PaymentType_PostPay	

*/

vars

	cashRecNewStatus : Integer;
	woNewStatus : Integer;
	responseStatusStr : String;
	doApprove : Boolean;
	workOrder : CM_WorkOrder;

begin

	// Null Response
	if _response = null then 
		cashRecNewStatus := CM_CashReceipt.CREDIT_CHECK_PENDING;
		woNewStatus		 := WO_STATUS_PENDING_FIN;
	
	// Error Response
	elseif _response.status = "E" or _response.status = " "  or _response.status = null then
		
		cashRecNewStatus := CM_CashReceipt.CREDIT_CHECK_REJECTED;
		woNewStatus		 := WO_STATUS_REJECTED_FIN;
		responseStatusStr := _response.status;
	
	// Success Response
	elseif _response.status = "X" then
		
		cashRecNewStatus := CM_CashReceipt.CREDIT_CHECK_APPROVED;
		woNewStatus		 := WO_STATUS_APPROVED;
		doApprove 		 := true;
		responseStatusStr := _response.status;
	endif;
	
	if _cashReceipt &lt;&gt; null then
		workOrder := _cashReceipt.myWorkOrder;
	endif;
			
	self.updPaymentAndWorkOrderStatus(	_cashReceipt,
										workOrder,
										self.getWSDLType,	
										cashRecNewStatus,
										woNewStatus,
										doApprove,
										responseStatusStr
										);
										
										
	//Now do the updating of the activity history and create alerts / emails if required									
	return inheritMethod(_response, _cashReceipt, _invoice, _invoiceLines, _activityHistory);

epilog

end;</source>
        <Parameter name="_response" type="CMIF_SAPWSResponse"/>
        <Parameter name="_cashReceipt" type="CM_CashReceipt" usage="input"/>
        <Parameter name="_invoice" type="CM_Invoice" usage="input"/>
        <Parameter name="_invoiceLines" type="CM_InvoiceLineSet" usage="input"/>
        <Parameter name="_activityHistory" type="CM_ActivityHistoryExtInterface" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
