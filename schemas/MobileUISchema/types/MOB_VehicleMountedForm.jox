    <JadeMethod name="resizeButtonsFrameLandscape" id="6f8e3928-55e0-4259-afce-b10c1bcd7b78">
        <source>resizeButtonsFrameLandscape() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 June 2010	cnwjk3	Initial creation

*/
