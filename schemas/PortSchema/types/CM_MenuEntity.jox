    <JadeMethod name="sortChildren" id="86691a6e-1547-492f-9e73-c79978de8dcd">
        <source>sortChildren(pIsDescending:Boolean; pIsParentsFirst:Boolean);
// --------------------------------------------------------------------------------
// Created:		27 October 2005 by cnwdad1
//
// Purpose:		Sorts the receiver's array of children.
//
// Parameters:	pIsDescending - True if the children should be sorted in descending
//					order.
//				pIsParentsFirst - If true, the entities with children will be placed
//					at the top or the sort order (or bottom if descending order),
//					followed by entities with no children.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allChildren.sortEntities(pIsDescending, pIsParentsFirst);
end;</source>
        <Parameter name="pIsDescending" type="Boolean"/>
        <Parameter name="pIsParentsFirst" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateNewParent" id="3aa73ccc-a13c-41f5-afa2-7be371297dda">
        <source>validateNewParent( _newParent : CM_MenuEntity );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2015	cnwndl1	Initial creation	Par 36718
14/05/2018 	JLGNS1	Bug 38526: STWO - Report availability Security Roles - Kernel Stack overflow - Parsys B - JMT Production environment
*/

vars

	objArray : ObjectArray;
	parent : CM_MenuEntity;

begin

	if _newParent = null then
		app.raiseCMException(Targe_locat_move_this_item_inv, " No parent selected ", null);
		return;
	endif;
	
	if _newParent.isKindOf( CM_MenuUserHdr ) then
		
		parent := _newParent;
		
		create objArray transient;
		objArray.add(self);
		
		while parent.isKindOf( CM_MenuUserHdr ) do
			//if parent.CM_MenuUserHdr.myMenuRoot &lt;&gt; null then	//Bug 38526
			//	break;											//Bug 38526
			//endif;											//Bug 38526
			if objArray.includes(parent) then
				app.raiseCMException(Targe_locat_move_this_item_inv, " Circular reference ", null);
				return;
			endif;
			objArray.add(parent);
			parent := parent.myParent;
			if parent = null then
				break;
			endif;
		endwhile;
	endif;

epilog

	delete objArray;

end;</source>
        <Parameter name="_newParent" type="CM_MenuEntity"/>
    </JadeMethod>
</Class>
