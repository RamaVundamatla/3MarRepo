        <Parameter name="_split" type="Integer"/>
        <ReturnType type="CM_ROROLocnDefn"/>
    </JadeMethod>
    <JadeMethod name="importFromXMLDocReference" id="8996bec2-d97b-43f0-91ee-4b9c7e268444">
        <updating/>
        <source>importFromXMLDocReference(_property: Property; _xmlElement: JadeXMLElement input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2011	cnwer1	Initial creation CCMS 1031
28 Sep 2011 cnwer1	PAR 28276
*/

vars
	allHazardElements,
	allDSlotDefnElements : JadeXMLElementArray;
	hazardElement,
	slotDefnElement 	: JadeXMLElement;
	slotDefnVessel 		: CM_ROROSlotDefnVessel;
	slotAft : CM_ROROLocnDefn;
	slotAftCode : String;
	childElement : JadeXMLElement;
	roroHazard  : CM_ROROHazard;
begin

	if _property = CM_ROROLocnDefn::allROROSlotDefnByOrdinal then
		create allDSlotDefnElements transient;
		_xmlElement.getAllElementsByTagName(CM_ROROSlotDefnVessel.name,allDSlotDefnElements);
		foreach slotDefnElement in allDSlotDefnElements do
			create slotDefnVessel transient;
			slotDefnVessel.setRealLocnDefn(self);
			slotDefnVessel.importFromXMLDoc(slotDefnElement);
		
		endforeach;
	elseif  _property = CM_ROROLocnDefn::myAdjacentSlotAft then
		childElement:=_xmlElement.getElementByTagName(CM_ROROLocnDefn::code.name);	
		if childElement &lt;&gt; null then
			slotAftCode:= childElement.textData;
			slotAft:= self.myDeck.allROROLocnDefnByCode[slotAftCode];
			if slotAft &lt;&gt; null then
				self.myAdjacentSlotAft:=slotAft;
			endif;
		endif;
	//epr par 28276
	elseif  _property = CM_ROROLocnDefn::myAdjacentSlotFwd then
		childElement:=_xmlElement.getElementByTagName(CM_ROROLocnDefn::code.name);	
		if childElement &lt;&gt; null then
			slotAftCode:= childElement.textData;
			slotAft:= self.myDeck.allROROLocnDefnByCode[slotAftCode];
			if slotAft &lt;&gt; null then
				self.myAdjacentSlotFwd:=slotAft;
			endif;
		endif;
	
	elseif _property = CM_ROROLocnDefn::allHazardsAllowed then
		create allHazardElements transient;
		_xmlElement.getAllElementsByTagName(CM_ROROHazard.name,allHazardElements);
		foreach hazardElement in allHazardElements  do			
			create roroHazard transient;
			roroHazard.setROROLocn(self);
			roroHazard.importFromXMLDoc(hazardElement);
		endforeach;
	else	
		inheritMethod(_property, _xmlElement);
	endif;
epilog
	delete allDSlotDefnElements;
	delete allHazardElements;
end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isOOTL" id="3ed27d48-3d3e-4538-be11-6e7297e138cd">
