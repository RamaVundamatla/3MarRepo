    <JadeMethod name="setFontDefaults" id="204352fb-3546-4261-a4c4-2862c71f3cd7">
        <updating/>
        <source>setFontDefaults() updating;
// ---------------------------------------------------------------------------
// Created:		November 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	iAmPrinting : Boolean;
	lDisplayMode,
	lViewMode 	: Integer;
	lFactor 	: Real;
	theFontName	: String;
	theFontSize	: Real;
	thePrintStyle 	: Integer;

begin

	iAmPrinting := self.amPrinting;
	
	// reset so that the first redraw with frame will set for new font size
//	self.textExtent999 := 0;
	
	lFactor 	 	:= self.scaleFactor;
	lDisplayMode 	:= self.displayMode;
	lViewMode 	 	:= self.viewMode;
	thePrintStyle	:= self.printOutputStyle;

	theFontSize := (self.FontSize * self.scaleFactor.Integer);
/*	
	if self.tiHeight = Ti_Half_Height then
		if lFactor = 2 then
			theFontSize := theFontSize - 2;
		elseif lFactor = 3 then
			theFontSize := theFontSize - 5;
		elseif lFactor = 4 then
			theFontSize := theFontSize - 5;
		endif;
	endif;
*/	
	if lFactor = 1 then
		theFontSize := 8;
	elseif lFactor = 1.5 then
		theFontSize := 10;
	endif;	
	self.defaultFontSizeForAttributes	:= theFontSize * 2;

end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="37142fa2-136b-48f2-a7be-e17812af6053">
