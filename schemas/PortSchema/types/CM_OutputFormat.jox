    <JadeMethod name="getName" id="676bf3db-0406-4497-b8fd-008e14f7f16c">
        <source>getName(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2009	cnwndl1	Initial creation - Migrated up

*/

vars
	returnStr		: String;
	
begin
	returnStr	:=	inheritMethod() &amp; Tab &amp;
					name.padBlanks( 30 ) &amp; Tab &amp;
					creationTime.shortCurrentLocaleFormat &amp; Tab &amp;
					description;
	
	return returnStr;
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getQueryBOLType" id="bd523a79-b9fe-4ba9-bcb0-ddd12df11281">
        <source>getQueryBOLType(): CM_CargoBOLType;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2009	cnwndl1	Initial creation - Migrated up

*/

vars

begin
	return app.myRoot.getCargoBOLTypeForId(self.mode);
epilog

end;</source>
        <ReturnType type="CM_CargoBOLType"/>
    </JadeMethod>
    <JadeMethod name="getQueryDefinition" id="1c0117a1-2141-406d-a95b-dbb7ae9b24c2">
        <source>getQueryDefinition(): CM_QueryDefinition;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2009	cnwndl1	Initial creation - Migrated up

*/

vars

	root : CM_Root;
	qDef : CM_QueryDefinition;

begin

	root := app.myRoot;
	if root &lt;&gt; null then
		qDef := root.allQueryDefinitionObjects.getAtKey(self.type, self.mode);
	endif;
	return qDef;
	
epilog

end;</source>
        <ReturnType type="CM_QueryDefinition"/>
    </JadeMethod>
    <JadeMethod name="getQueryProperty" id="3b93311e-7702-4466-929e-ebe1102c224f">
        <source>getQueryProperty(_property: String): CM_QueryProperty;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2009	cnwndl1	Initial creation - Migrated up

*/

vars
	queryDef				: CM_QueryDefinition;
	property				: CM_QueryProperty;
	coll					: CM_QueryPropertyDict;
	
begin
	queryDef 	:= self.getQueryDefinition;
	
	if queryDef = null then
		return null;
	endif;
	
	coll		:= queryDef.allQueryProperties;
	property	:= coll[ _property ];
	
	return property;
	
epilog
	
end;</source>
        <Parameter name="_property" type="String"/>
        <ReturnType type="CM_QueryProperty"/>
    </JadeMethod>
