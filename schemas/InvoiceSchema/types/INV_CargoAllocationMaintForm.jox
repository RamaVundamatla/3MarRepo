epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="5cb331c8-a38f-45f8-b1cc-a5c61854777d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 30 May 2024 09:31:18.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020287, locale);
	//btnClearFilter.translateBubbleHelp(Xlat_0024555, locale);
	btnClose.translateCaption(Xlat_0020288, locale);
	btnConfig.translateCaption(Xlat_0020343, locale);
	btnDelete.translateCaption(Xlat_0020289, locale);
	btnMappings.translateCaption(Xlat_0020296, locale);
	btnNew.translateCaption(Xlat_0020290, locale);
	btnUpdate.translateCaption(Xlat_0020291, locale);
	btnViewAudit.translateCaption(Xlat_0026839, locale);
	//txtFilterBox.translateBubbleHelp(Xlat_0024556, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateFromNote" id="90dea817-b28f-4a1c-9d66-399c16b3e242">
        <source>updateFromNote(_alloc : CM_InvoiceCargoAllocation);
/*

Purpose:			// TFS 7496

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2017	jlgab1	Initial creation

*/

vars
	idx : Integer;
begin
	if self.tblData.findObjectInRow(_alloc, idx) then
		self.tblData.setCellText(idx, 1,_alloc.description  &amp; Tab &amp; 
										_alloc.getDescriptionTransaction() &amp; Tab  &amp;
										_alloc.priorityValue.asStringJMT()&amp; Tab &amp; 
										_alloc.getNumberOfMappings().asStringJMT()  ); 
		self.tblData.resort();
	endif;
epilog

end;</source>
        <Parameter name="_alloc" type="CM_InvoiceCargoAllocation"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="28e29807-92ce-496f-951d-b5a85de6e80e">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*
Purpose:			
Date		Who		Reason
18 March 2015	cnwab1	Initial creation
*/

vars

begin
	self.doUserNote(eventType,theObject,eventTag,userInfo);
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
