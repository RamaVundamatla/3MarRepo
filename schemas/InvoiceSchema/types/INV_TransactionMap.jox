    <JadeMethod name="setupForm" id="9e20625c-5263-4f6e-acfa-7b7fd024be28">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			
	Created:		May 2004 By Andrew Bishop cnwab1
Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
01 Dec 2021 navma1  Bug 52498: MTN - Work Order Based Transaction Map Missing
15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
*/

vars
	term : CM_Terminal;
begin
	term := self.myTerminal;	//01.12.2021 navma1 #52498
	
	inheritMethod();
	
	self.doCmbBankBuild;
	
	self.myCurrentBank := self.myTerminal.getDefaultCompanyBank();			// 35872
	
	self.setCaption(app.getErrorString(Transaction_Map) &amp; " " &amp;  self.myCurrentBank.code);
	
	self.initPropertyTable(ETDef_InvMaintTranMapEnt);
	
	self.setNavigatorHeading(self.caption);

	self.showSearchFrame();
	
	self.beginNotification(term, term.getTerminalEvent(EVENT_TRANSACTIONMAP_CREATE), Response_Continuous, null);
	self.beginNotification(term, term.getTerminalEvent(EVENT_TRANSACTIONMAP_DELETE), Response_Continuous, null);
	self.beginNotification(term, term.getTerminalEvent(EVENT_TRANSACTIONMAP_UPDATE), Response_Continuous, null);
	self.beginNotification(term, term.getTerminalEvent(EVENT_TRANSACTIONMAP_MOVEPURGE), Response_Continuous, null);
	self.beginNotification(term, term.getTerminalEvent(EVENT_TRANSACTIONMAP_NEWQRMS), Response_Continuous, null);
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(term, self.permissionMaint) then
		self.setViewOnly();
		return;
	endif;
	
	self.frmDebtors.visible := false; // TFS 2901
	
	// 15/05/2023	navkc1	CR 57927 Task 54268 - Always visible
	// TFS 39236
	//if term.isUsingDefaultProcessJMT() then    //01.12.2021 navma1 #52498
	//self.chkTranMapWO.visible := false;
	//endif;
	
		
	self.lstData.defaultLineHeight := 30;   // ### TFS 50421 27OCT2021 NAVAB1
	self.lstData.fontSize 		   := 10;   // ### TFS 50421 27OCT2021 NAVAB1

end;</source>
    </JadeMethod>
    <JadeMethod name="setupShowBubble" id="b2d03588-609e-405e-8320-1c47a40dbaa7">
        <updating/>
        <source>setupShowBubble() updating, protected;

vars
	btn	: CMUI_ButtonForToolbar;
begin
	btn := self.btnShowPopup;
	if self.showBubbleHelp then
		btn.caption := "Hide Bubble Help";
		btn.bubbleHelp := "Hide Bubble help";
		btn.myToolbarButton.changePicture(self.picBubble);
	else
		btn.caption := "Show Bubble Help";
		btn.bubbleHelp := "Show Bubble Help";
		btn.myToolbarButton.changePicture(self.picNoBubble);
	endif;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupShowPictures" id="e74621b6-c577-4d71-bfc3-0d51f59e7947">
        <updating/>
        <source>setupShowPictures() updating, protected;

vars
	btn	: CMUI_ButtonForToolbar;
begin
	btn := self.btnShowPics;
	if self.showPictures then
		btn.myToolbarButton.changePicture(self.picPictures);
		btn.caption := "Hide Pictures";
		btn.bubbleHelp := "Hide Pictures";
	else
		btn.myToolbarButton.changePicture(self.picNoPicture);
		btn.caption := "Show Pictures";
		btn.bubbleHelp := "Show Pictures";
	endif;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showCargoAllocationsForm" id="379284e6-9522-4d14-b306-846e628c71ff">
        <updating/>
        <source>showCargoAllocationsForm() updating;
/*
Purpose:			
Date				Who			Reason
MARCH 2015		CNWAB1		Initial creation
04/05/2023	navkc1	Bug 57484: EUP - Cargo Allocation Transaction Map Permissions
*/
vars
	newForm	: INV_CargoAllocationMaintForm;
begin

	//create newForm transient;
	// 04/05/2023	navkc1	Bug 57484
	newForm := app.loadForm(INV_CargoAllocationMaintForm, INV_Assistant, false, false, false, self.myTerminal, null).INV_CargoAllocationMaintForm;
	
	if newForm = null then
		return;
	endif;
	
	newForm.myCurrentTransactionMap := self.myCurrentMapTMCargoAllocation;
	newForm.myCurrentTanMapInventory := self.myCurrentMapTMInventory;  // ### TFS 51219 25MAY2021 NAVAB1
	newForm.setMyTerminal(self.myTerminal);
	newForm.createMyAssistant(INV_Assistant);

	newForm.show(); 
end;</source>
    </JadeMethod>
    <JadeMethod name="showCopyDebtorsFrame" id="d9da76cc-f4f3-4b34-9f15-cc6d1455becf">
        <updating/>
        <source>showCopyDebtorsFrame() updating;
// ---------------------------------------------------------------------------
vars
	theFrame : CMUI_MoveableFrame;
	newForm	: INV_TMCopyForm;
begin

		if self.myCurrentMapDebtor = null then
			return;
		endif;

		create newForm transient;
		newForm.myTranMapForm := self;
		newForm.setMyTerminal(self.myTerminal);
		self.lstData.enabled := false;
		self.frmToolbar.enabled := false;
		newForm.show();
		return;

		
		self.lstCopyDebtList.listIndex := self.lstCopyDebtList.findObject(self.myCurrentMapDebtor.myDebtorNode );

		if self.cmbCopyDebtTypes.findObject(self.myCurrentMapDebtor.myDebtorType ) &lt; 0 then
			self.cmbCopyDebtTypes.listIndex := -1;
		else
			self.cmbCopyDebtTypes.listObject := self.myCurrentMapDebtor.myDebtorType;
		endif;

	
	if self.myCurrentMapTM = null then
	//	hide the debtor type label and combo
		self.lblCopyDebtType.visible := false;
		self.frmCopyDebtors.height := 315;
	else
		self.lblCopyDebtType.visible := true;
		self.frmCopyDebtors.height := 405;
	endif;
	
	theFrame := self.frmCopyDebtors;
	self.lblCopyDebtor.caption := "Copy after Transaction";
	self.lblCopyDebtor2.caption := "Copy to new Debtor";
	// show the copy frame wide because the path list entries could be long
	theFrame.width := self.width - 200;
	self.frmCopyDebtTool.width := theFrame.width - 8;
	self.frmCopyDebtTool.positionToolbarControls();
	self.lstCopyDebtPath.width := theFrame.width - 20;
	theFrame.zOrder(1);
	theFrame.centreWindow();
	theFrame.visible := true;
	self.lstCopyDebtPath.setFocus();

	self.lstData.enabled := false;
	self.frmToolbar.enabled := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="showCopyFrame" id="73ebdc1d-6a6f-46bd-af12-7d8ec6fa9c40">
        <updating/>
        <source>showCopyFrame() updating;
// ---------------------------------------------------------------------------
// Created:		August 2013 cnwjre1 32311
//
// Purpose:		Show the Copy frame, disable the rest of the form to make the frame look modal
//
// ---------------------------------------------------------------------------
//08 June 2018	jlgsl4	TFS 38711 - STWO - exception when copying Move transactions

vars
	theFrame : CMUI_MoveableFrame;
	newForm	: INV_TMCopyForm;
begin
		create newForm transient;
		newForm.myTranMapForm := self;
		newForm.setMyTerminal(self.myTerminal);
		self.lstData.enabled := false;
		self.frmToolbar.enabled := false;
		if self.modePropertyUpdate = self.ModeProperty_Move then // TFS 38711
			newForm.minimumHeight := 220; // TFS 38711
		endif; // TFS 38711
		newForm.show();
		return;

	theFrame := self.frmCopy;
	// show the copy frame wide because the path list entries could be long
	theFrame.width := self.width - 200;
	self.frmCopyToolbar.width := theFrame.width - 8;
	self.frmCopyToolbar.positionToolbarControls();
	self.lstCopyPath.width := theFrame.width - 20;
	
	self.btnCopyCancel.cancel := true;
	theFrame.zOrder(1);
	theFrame.centreWindow();
	theFrame.visible := true;
	self.lstCopyPath.setFocus();
	self.lstData.enabled := false;
	self.frmToolbar.enabled := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="showDebtorsFrame" id="91dbcb7f-4b24-423d-a092-d4e294d097e3">
        <updating/>
        <source>showDebtorsFrame() updating;
// ---------------------------------------------------------------------------
// Created:		May 2010	cnwjre1	24051 add debtor type to debtor
//
// Purpose:		Allow entry and maintenance of debtor type for a debtor map,
//				but only for Cargo, not Event or Voyage maps
//
// ---------------------------------------------------------------------------
vars
	theFrame : CMUI_MoveableFrame;
begin
	// on update, show debtor and charge (debtor type) but only allow change of debtor type
	//  and only for Cargo
	// (change for 24051, debtor type is new, was no change of debtor itself before this)
	if self.updateMode = self.UpdateMode_Update then
		if self.myCurrentMapDebtor = null then
			return;
		endif;
		
		self.lstDebtorsList.listIndex := self.lstDebtorsList.findObject(self.myCurrentMapDebtor.myDebtorNode );
		self.lstDebtorsList.enabled := false;

		if self.cmbDebtorTypes.findObject(self.myCurrentMapDebtor.myDebtorType ) &lt; 0 then
			self.cmbDebtorTypes.listIndex := -1;
		else
			self.cmbDebtorTypes.listObject := self.myCurrentMapDebtor.myDebtorType;
		endif;
	else
		self.lstDebtorsList.enabled := true;
	endif;
	
//	if self.myCurrentMapTM = null then
	if self.myCurrentMapTM = null and self.myCurrentMapTMBOL = null then	//29 Nov 2019	NDL	TFS 47100
	//	hide the debtor type label and combo
		self.lblDebtorType.visible := false;
		self.frmDebtors.height := 260;
	else
		self.lblDebtorType.visible := true;
		self.frmDebtors.height := 350;
	endif;
	
	theFrame := self.frmDebtors;
	theFrame.zOrder(1);
	theFrame.centreWindow();
	theFrame.visible := true;
	self.lstDebtorsList.setFocus();
	
	self.lstData.enabled := false;
	self.frmToolbar.enabled := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="showListFrame" id="86a43aa5-b3f5-4ce8-b4be-1c97ac541c02">
        <updating/>
