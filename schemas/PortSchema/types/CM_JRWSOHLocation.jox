    <JadeMethod name="delete" id="096bb16c-4b29-45e3-9ded-a2f5cc219807">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     12 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.allSOHReporters.purge();

end;</source>
    </JadeMethod>
    <JadeMethod name="getEndDateLocalTZ" id="7e72cccd-72d9-43b4-a61f-aa8bd89e16dd">
        <source>getEndDateLocalTZ(): Date;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
01 Jun 2016	cnwmp6	TFS 488 - Multi Timezone Support

*/
vars
	ts: TimeStamp;
begin
	if self.endDate.isValid() then
		ts.setDate(self.endDate);
		ts.setTime("23:59:59.999".Time);
		return self.systemToLocalTime(ts).Date;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getStartDateLocalTZ" id="7e615da6-6747-43a8-97b6-ace55d6675d4">
        <source>getStartDateLocalTZ(): Date;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
01 Jun 2016	cnwmp6	TFS 488 - Multi Timezone Support

*/
vars
	ts: TimeStamp;
begin
	if self.startDate.isValid() then
		ts.setDate(self.startDate);
		ts.setTime("0:00:00".Time);
		return self.systemToLocalTime(ts).Date;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="noOutputReturned" id="0e8f3e6d-c56a-48c0-855c-8e5e874661f4">
        <source>noOutputReturned(): Boolean;
// -------------------------------------------
// Created 21 September 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.allSOHReporters.isEmpty() then
		return true;
	endif;
	return false;


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
