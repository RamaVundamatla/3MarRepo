    <JadeMethod name="copyReportItemsToCollection" id="62751635-107f-41d7-a6f5-402f454e748f">
        <updating/>
        <source>copyReportItemsToCollection(_collection: Collection; _collectionItem: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Aug 2025 navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes

*/

vars
	
begin
	self.allVehicleVisitRecords.clear();
	_collection.copy(self.allVehicleVisitRecords);
epilog

end;</source>
        <Parameter name="_collection" type="Collection"/>
        <Parameter name="_collectionItem" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDateFromLocalTZ" id="bb9bef66-cc4f-4d06-8a70-128c841ff423">
        <source>getDateFromLocalTZ(): String;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
03 Jun 2016	cnwmp6	TFS 488 - Multi Timezone Support

*/
vars
	ts: TimeStamp;
	dateString: String;
begin
	dateString := self.dateFrom;		// Date or "Any"
	if dateString.Date.isValid() then
		ts.setDate(dateString.Date);
		ts.setTime(TimeStartOfDay);
		return self.systemToLocalTime(ts).Date.asStringJMT();
	endif;
	return dateString;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDateToLocalTZ" id="9caec024-69ef-489c-83eb-52db5ce569d8">
        <source>getDateToLocalTZ(): String;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
03 Jun 2016	cnwmp6	TFS 488 - Multi Timezone Support

*/
vars
	ts: TimeStamp;
	dateString: String;
begin
	dateString := self.dateTo;		// Date or "Any"
	if dateString.Date.isValid() then
		ts.setDate(dateString.Date);
		ts.setTime(TimeEndOfDay);
		return self.systemToLocalTime(ts).Date.asStringJMT();
	endif;
	return dateString;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getErrorsAndWarningDisplay" id="4754ac26-7d6d-420d-89d9-bcb260b09806">
        <source>getErrorsAndWarningDisplay():String;
// ---------------------------------------------------------------------------
// Created:     15 October 2008 by concms1
// Purpose:     ccms 1035 - Gate ticket printing (APM)
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	error	: CM_ErrorPersistent;
	str		: String;
begin
	foreach error in self.allErrorsAndWarnings do
		if str = null then
			str := error.errorCode.String &amp; ':' &amp; error.getErrorText;
		else
			str := str &amp; CrLf &amp; error.errorCode.String &amp; ':' &amp; error.getErrorText;
		endif;
	endforeach;
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="noOutputReturned" id="e4121d76-a90c-4e87-bce7-08896c252ffc">
        <source>noOutputReturned(): Boolean;
//----------------------------------------------------------------
//	Created:	18 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.allVehicleVisitRecords.isEmpty and
	   self.allGateTickets.isEmpty then
		return true;
	endif;
	
	return false;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setGoToGateOfficeMessage" id="4c24c725-d9a0-4c8d-8c78-141a54244ea0">
        <updating/>
        <source>setGoToGateOfficeMessage() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
20 September 2023		jlizm1	Initial creation 59579 Kiosk error advice report

*/

vars

begin
	self.goToGateOfficeMessage := app.getErrorString(Go_To_Gate_office);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setTerminal" id="6e9e1e7c-3b7e-4950-9fe2-d564afabe71e">
        <updating/>
        <source>setTerminal(_terminal :CM_Terminal)updating;
// ---------------------------------------------------------------------------
// Created:     14 October 2008 by concms1
// Purpose:     CCMS 1035 - Gate ticket printing
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.allTerminals.clear;
	
	self.allTerminals.add (_terminal);
	
	self.setPortLogo();
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
</Class>
