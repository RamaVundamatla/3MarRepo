    <JadeMethod name="setPrevSealNum" id="ef67a81d-ef2a-4cf5-8668-5dc2218af4fa">
        <source>setPrevSealNum( _prevSealNum : String );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 September 2010	cnwndl1	Initial creation	NDL	Par 25608 - Use/update new seals data structure

*/

vars

	sealType : CM_SealType;
	theCargoType : CM_CargoType;
	sealTI : CM_SealTI;
	pxySealTI : CM_SealTI;
	now : TimeStamp;
	
begin
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	sealType := app.myRoot.getSealType( SealType_Operator );
	
	if sealType = null then
		app.raiseCMException(NO_Seal_type_selected, null, null);
		return;
	endif;
	
	theCargoType := app.myRoot.allCargoTypesById[self.cargoType];
	if theCargoType = null then
		app.raiseCMException2(Seal_type_not_valid_cargo_type, sealType.description, null, null, null);
		return;
	endif;
	
	if not sealType.allCargoTypes.includes( theCargoType ) then
		app.raiseCMException2(Seal_type_not_valid_cargo_type, sealType.description, theCargoType.description, null, null);
		return;
	endif;
	
	if sealType.notAvailableForEntry then
		app.raiseCMException1(NotAvailableForEntry, sealType.description, null, null);
		return;
	endif;

	sealTI := self.getSealTI( sealType );
	
	if sealTI &lt;&gt; null  then
		// we have found an existing sealTi of this type already on the CMIF,
		// update its value if its changed.
		// This will be OK for a real object update or a proxy update.
		
		if _prevSealNum &lt;&gt; sealTI.previousSeal then
		
			
			if sealType.savePreviousSeal then
				sealTI.setPreviousSeal(_prevSealNum);
			else
				sealTI.setPreviousSeal(null);
			endif;
			
		endif;
		
	else
	
		if not sealType.savePreviousSeal then
			return;
		endif;
		
		if sealTI = null and _prevSealNum.trimBlanks &lt;&gt; null then
			// so create it.
			
			//create a proxy to do the updating from, don't link it to the CMIF yet
			create pxySealTI transient;
			pxySealTI.setProxy(	null,	//_sealNum : String;
								null,	//_sealNumArray : StringArray;
								_prevSealNum,	//_prevSeal : String;
								sealType.sealType,	//_sealType : String;
								now,	//_sealedDT : TimeStamp;
								null	//_myTrackedItem : CM_TrackedItem
								);
			
			if self.isTransient then
				//The container is a proxy, just link the transient to me, all will be sorted in the transaction.
				self.allSeals.add( pxySealTI );
			
			else
				// this is a direct update to a real object, i.e. some lazy B#$%^ didn't follow the standard of
				// doing the updates via a proxy, so, create the real seal data from the transient and get rid of the transient
				create sealTI persistent;
				sealTI.setForCreate(pxySealTI);
				self.allSeals.add( sealTI );
				
				delete pxySealTI;
			
			endif;
			
		endif;
		
	endif;
	
	
	

epilog

end;</source>
        <Parameter name="_prevSealNum" type="String"/>
    </JadeMethod>
    <JadeMethod name="setSealNum" id="41421553-6fed-450b-bb83-401cb223f610">
