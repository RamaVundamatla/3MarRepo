    <JadeMethod name="initMultSelectSheet" id="c5ff8d89-1f92-4a3b-9e7b-ad795ac2fd19">
        <source>initMultSelectSheet(_mulSelectGroupBox : CMUI_MultiSelectFilterGroupBox;
						_selectedHeading : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 Jan 2009	cnwer1	Initial creation
19 Sep 2023 navhl20 ChangeRequest 60463: MTN - Adding Filter to column organizer screen
09 Jul 2024	navnk30	ChangeRequest 64536: MTN - Adding Filter to column organizer screen - Selected Columns. Task 64537.
*/

vars
	tmpMulSel : CMUI_MultiSelectFilterGroupBox;
begin
	tmpMulSel := _mulSelectGroupBox;
	tmpMulSel.availableHeading := 'Available';
	tmpMulSel.selectedHeading := _selectedHeading;
	//epr par 19690 15/5/09
	if tmpMulSel = self.mulColumns then
		tmpMulSel.formDisplayEntryMethodName :=CMUI_ColumnOrganiserForm::displayMultiSelectAvailable.name;
	elseif tmpMulSel = self.mulColumnSorter then
		tmpMulSel.formDisplayEntryMethodName:=CMUI_ColumnOrganiserForm::displayMultiSelectSorted.name;
	endif;
	tmpMulSel.myBaseForm := self;
	tmpMulSel.myAvailableListBox.sorted :=  self.allowShiftUpDown;
	tmpMulSel.mySelectedListBox.allowDragDrop:=self.allowShiftUpDown;
	tmpMulSel.mySelectedListBox.sorted := false;	
	tmpMulSel.displayOrderBtns(self.allowShiftUpDown, self.allowShiftUpDown);
	tmpMulSel.multiSelect := ListBox.MultiSelect_Extended;
	// cnwrl1 20/03/2009 PAR 19174 - start of coding
	// need to use integralHeight of false to make sure the vertical scrollbar(s) do not get corrupted.
	// ie going to the second sheet and back if integralHeight := true stuffs up the scrollbar(s) on the front sheet.
	// Available ListBox attributes
	tmpMulSel.myAvailableListBox.stretchHeight	:= true;
	tmpMulSel.myAvailableListBox.stretchWidth	:= false;
	tmpMulSel.myAvailableListBox.integralHeight	:= false;
	// Selected ListBox attributes
	tmpMulSel.mySelectedListBox.stretchHeight	:= true;
	tmpMulSel.mySelectedListBox.stretchWidth	:= false;
	tmpMulSel.mySelectedListBox.integralHeight	:= false;
	// cnwrl1 20/03/2009 PAR 19174 - end of coding
	tmpMulSel.txtFilterBoxLeft.hintText 			:= "Filter Available Columns...";			//19.9.2023 navhl20 #60463
	tmpMulSel.txtFilterBoxLeft.hintForeColor 		:= Grey;									//19.9.2023 navhl20 #60463
	tmpMulSel.txtFilterBoxRight.hintText 			:= "Filter Selected Columns...";			//09.07.2024 navnk30 #64536 Task 64537
	tmpMulSel.txtFilterBoxRight.hintForeColor		:= Grey;									//09.07.2024 navnk30 #64536 Task 64537
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_mulSelectGroupBox" type="CMUI_MultiSelectFilterGroupBox"/>
        <Parameter name="_selectedHeading" type="String"/>
    </JadeMethod>
