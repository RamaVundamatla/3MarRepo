	self.myRoot:=app.myRoot;
	self.myTerminal := _terminal;
	self.interfaceName := ExternalWebServiceAgGateway;
	self.sendRecvMessage := _sendRecvMessage;	
	self.description := CM_EWSActivityAgGateway.DIRECTION_RECEIVE &amp; "-" &amp; CM_EWSActivityAgGateway.MESSAGE_TYPE_ORDERCREATEUPD;
	self.direction := CM_EWSActivityAgGateway.DIRECTION_RECEIVE;
	self.messageType := CM_EWSActivityAgGateway.MESSAGE_TYPE_ORDERCREATEUPD;
	self.response := _response;																						//navra1 - MTN-35875- 5th Sep 2025-1
	self.responseCode := _responseCode;																				//navra1 - MTN-35875- 5th Sep 2025-1
epilog

end;</source>
