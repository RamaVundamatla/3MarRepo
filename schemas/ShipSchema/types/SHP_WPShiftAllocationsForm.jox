    <JadeMethod name="buildTransferTypeCombo" id="4f6b8186-01ec-4b99-b1b1-487357100c32">
        <source>buildTransferTypeCombo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 March 2018	jlgndl1	Initial creation	TFS 37444

*/

vars

	voyTfrType : CM_VoyageJobTransferType;
	defaultLOLO : CM_VoyageJobTransferType;
	index : Integer;

begin

	self.cmbTransferType.clear();
	foreach voyTfrType in app.myRoot.allVoyageJobTransferTypes do
		if voyTfrType.id = 0 then
			continue;
		elseif voyTfrType.id = 1 then
			defaultLOLO := voyTfrType;
		endif;
		index := self.cmbTransferType.addItem( voyTfrType.description );
		self.cmbTransferType.itemObject[ index ] := voyTfrType;
	endforeach;
	
	if defaultLOLO &lt;&gt; null then
		self.cmbTransferType.listIndex := self.cmbTransferType.findObject( defaultLOLO );
	else
		self.cmbTransferType.listIndex := -1;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="checkTIFullyAssigned" id="c7e2f48f-30ae-482f-b32b-d4a5a0856acd">
        <source>checkTIFullyAssigned(_ti : CM_TrackedItem; _onSite : Boolean) : Boolean protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/03/2017	cnwdap1		Initial creation TFS 3516 LNX Hold Planning Quantity
// 29/03/2017	cnwdap		TFS 3902 Hold Planning not finding all onsite cargo
// 07/11/2018	jlgdap1		TFS 41300 PEL1 Unable to load to vessel from truck in Job Lander
// 24/10/2019	jlgzm1		TFS 47085 Direct Release Ship to Ship
//
vars
	discharge, load, total, compare : Decimal [18,6];
	wle : CM_WorkListEntry;
	iter : Iterator;						// TFS 41300
	otherTI : CM_TrackedItem;				// TFS 41300
	received, prenoted : Decimal [18,6];	// TFS 41300

begin
	// check if the supplied TI has been fully assigned to load/discharge jobs
	if not _ti.canMergeBreakBulk then
		return true;
	endif;
	
	foreach wle in _ti.allWorklistEntries do
		if not wle.isKindOf(CM_VoyageWLE) then		// TFS 3902
			continue;								// TFS 3902
		endif;										// TFS 3902
		// for DLR and Tranship cargo we only want to count the WLEs going one way
		if _ti.getTransitStatus.isOneOf(TI_TransitStatusDLR, TI_TransitStatusSOB) or
		   _ti.isTranshipItem then	// TFS 47085
			if wle.isReceipt then
				if _ti.isBulkByQuantity then
					discharge := discharge + wle.quantity;
				else
					discharge := discharge + wle.weight;
				endif;
			else
				if _ti.isBulkByQuantity then
					load := load + wle.quantity;
				else
					load := load + wle.weight;
				endif;
			endif;
			continue;
		endif;
		if _ti.isBulkByQuantity then
			total := total + wle.quantity;
		else
			total := total + wle.weight;
		endif;
	endforeach;
	if _ti.isBulkByQuantity then
		compare := _ti.totalQuantity;
	else
		compare := _ti.totalWeight;
	endif;
	if _ti.getTransitStatus.isOneOf(TI_TransitStatusDLR, TI_TransitStatusSOB) or
	   _ti.isTranshipItem then // TFS 47085
		if (discharge = load or load = compare) and _onSite then 
			return true;
		elseif (discharge = compare or load = compare) and not _onSite then
			return true;
		endif;
	endif;
	
	// TFS 41300 Cater for prenotes that might have already been partially received
	if _ti.isNotified and _ti.getImExStatus = TI_IMEX_STATUS_EXPORT then
		// check on site
		iter := _ti.myVoyage.allOnsiteTIsByIdCargoType.createIterator;
		_ti.myVoyage.allOnsiteTIsByIdCargoType.startKeyGeq(_ti.id, _ti.cargoType, iter);
		while iter.next(otherTI) do
			if otherTI.id &lt;&gt; _ti.id or otherTI.cargoType &lt;&gt; _ti.cargoType then
				break;
			endif;
			if otherTI.isBulkByQuantity then
				received := received + otherTI.totalQuantity;
			elseif otherTI.isBulkByVolume or otherTI.isBulkByWeight then
				received := received + otherTI.totalWeight;
			endif;
		endwhile;
		compare := compare + received;
	elseif _ti.wasPrenotified and not _onSite then
		// check prenotified
		otherTI := _ti.myTerminal.allNotifiedTIsByIdCargoType[_ti.id, _ti.cargoType];
		if otherTI &lt;&gt; null then
			if otherTI.isBulkByQuantity then
				prenoted := _ti.totalQuantity;
			elseif otherTI.isBulkByVolume or otherTI.isBulkByWeight then
				prenoted := _ti.totalWeight;
			endif;
		endif;
	endif;
	// TFS 41300 end
	
	//if _ti.isBulkByQuantity and total = _ti.totalQuantity then
	if _ti.isBulkByQuantity then
		if _ti.isNotified and total = compare then
			return true;
		elseif total = _ti.totalQuantity then
			return true;
		endif;
	//elseif (_ti.isBulkByVolume or _ti.isBulkByWeight) and total = _ti.totalWeight then
	elseif (_ti.isBulkByVolume or _ti.isBulkByWeight) then
		if _ti.isNotified and total = compare then
			return true;
		elseif total = _ti.totalWeight then
			return true;
		endif;
	endif;
	
	return false;
epilog
	delete iter;				// TFS 41300
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_onSite" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
