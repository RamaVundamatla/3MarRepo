	self.initDataExtractField(_fields, CM_Container.name, "loadPort", fieldName, STRING, "Load Port", "Port code the container was registered as being loaded in", STRING, "Port code max length 5");

	fieldName := "loadSeqNumber";
	self.initDataExtractField(_fields, CM_Container.name, "loadSeqNumber", fieldName, STRING, "Load Seq Number", "Load sequence number", STRING, "Max length 4");

	fieldName := "loadJobNum";
	self.initDataExtractField(_fields, CM_Container.name, "loadJobNum", fieldName, STRING, "Load Job Num", "The ids of jobs that have been created to load a container to a vessel", STRING, "A string value of any length");

	fieldName := "billOfLading";
	self.initDataExtractField(_fields, CM_Container.name, "billOfLading", fieldName, STRING, "Bill Of Lading", "Bill of Lading or Docket Number a container is assigned to", STRING, "String field of max length 20 characters");

	fieldName := "driversLicense";
	self.initDataExtractField(_fields, CM_Container.name, "driversLicense", fieldName, STRING, "Receipt Driver License", "Driver license registered in the vehicle visit record of the delivery of a container to a terminal", STRING, "String field of max length 30 characters");

	fieldName := "driversName";
	self.initDataExtractField(_fields, CM_Container.name, "driversName", fieldName, STRING, "Receipt Driver", "Driver name registered on vehicle visit during a delivery of a container to the terminal", STRING, "String field of max length 50 characters");

	fieldName := "vehicle";
	self.initDataExtractField(_fields, CM_Container.name, "vehicle", fieldName, STRING, "Receipt Vehicle", "The vehicle used during the delivery of a container to the termainal", STRING, "String field of max length 12 characters");

	fieldName := "releaseVehicle";
	self.initDataExtractField(_fields, CM_Container.name, "releaseVehicle", fieldName, STRING, "Release Vehicle", "The vehicle used during the release of the container", STRING, "String field of max length 12 characters");

	fieldName := "releaseDriversLicense";
	self.initDataExtractField(_fields, CM_Container.name, "releaseDriversLicense", fieldName, STRING, "Release Driver License", "Driver license registered in vehicle visit during release of container", STRING, "String field of max length 30 characters");

