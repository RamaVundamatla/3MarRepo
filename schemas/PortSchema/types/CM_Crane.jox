    <JadeMethod name="addReceiveReleaseToHistory" id="a569f70d-5d80-484e-919a-16624ad60860">
        <updating/>
        <source>addReceiveReleaseToHistory(_trx :CM_TITransaction; _wle :CM_VoyageWLE):CM_MachineMoveHistory updating;
// ---------------------------------------------------------------------------
// Created:     08 December 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/12/2011	cnwcs5		par 28816 - correct ship/yard location for release to ship
// ---------------------------------------------------------------------------
vars
	voyage			:CM_Voyage;
	shipLocation,
	yardLocation	:String;
	ti				:CM_TrackedItem;
	lc				:CM_LocationsController;
	twinWLE			:CM_WorkListEntry;
	history,
	twinHistory		:CM_MachineMoveHistory;
	isRelease		:Boolean;	// par 28801
begin
	voyage 			:= _wle.getVoyage;
	
	if _trx.isKindOf (CM_ReleaseShip) then
		shipLocation 	:= _trx.CM_ReleaseShip.locationShip;
		isRelease		:= true;	// par 28816
	elseif _trx.isKindOf (CM_ReceiveShip) then
		shipLocation 	:= _trx.CM_ReceiveShip.locationShip;
	else
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid transaction type');
	endif;
	
	// we expcet the location to be a slot location to prepend the voyage code if
	// it is not already there
	if voyage &lt;&gt; null and not shipLocation.startsWith (voyage.code) then
		shipLocation := voyage.code &amp; ' ' &amp; shipLocation;
	endif;
		
	ti := _wle.myTrackedItem;
	lc := ti.myPrimaryActualLocation;
	
	// location Yard is the ultimate yard location for the cargo which is not what we wnt for a machine move
	if lc.isMachineController or lc.isCraneLaneController then
		// cargo is on a machine or in a crane lane so let's use that
		yardLocation := lc.getFullIdForTI(true)[1:30];
	else
		// I give up - use the crane transfer area 
		yardLocation := self.transferArea.id;
	endif;

	if self.isTwinLift then
		// need to know if the other lift from the ship has been completed
		twinWLE := _wle.getTwinLiftWLE;
		
		if twinWLE &lt;&gt; null then
			// do we already have a move for this TI in the history
			twinHistory := self.findPriorMoveHistoryForWLE (twinWLE.CM_VoyageWLE);
		endif;
	endif;

	if isRelease then	// par 28816
		history := self.addMoveToHistoryLoc (yardLocation, shipLocation, ti);	
	else
		history := self.addMoveToHistoryLoc (shipLocation, yardLocation, ti);
	endif;
	// if the other box has already been moved from the ship then link the two history
	// items to form a single lift
	if twinHistory &lt;&gt; null then
		history.setCraneTwinLiftHistory (twinHistory);
	endif;
	
	return history;
epilog

end;</source>
        <Parameter name="_trx" type="CM_TITransaction"/>
        <Parameter name="_wle" type="CM_VoyageWLE"/>
        <ReturnType type="CM_MachineMoveHistory"/>
    </JadeMethod>
    <JadeMethod name="canAddToQueue" id="5a631381-ca65-4177-9081-c10203b9165b">
        <source>canAddToQueue(_queue: CM_RadioTelemetryQueue);

// cnwdvb1 15 April 2003 

vars

begin

	if _queue.isKindOf(CM_MasterQueue) or _queue.isKindOf(CM_VoyageQueue) and
		_queue.canAddCraneToQueue() then
		return;
	endif;
	//Error, can only assign cranes to master and voyage queues!
	app.setContinueCMExceptions(false);
	app.raiseCMException(ERR_QUEUE_CRANE, null, null);


end;</source>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue"/>
    </JadeMethod>
    <JadeMethod name="canMachineMoveWeight" id="075d2865-a6b9-4da4-b080-a0ee30b79aec">
        <source>canMachineMoveWeight(_ti: CM_TrackedItem; _entry: CM_RTQueueEntry;  _messageLogger : CM_MessageLogger): Boolean;
// ---------------------------------------------------------------------------
// Created:		17 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpCargoType : CM_CargoType;
	otherWLE : CM_WorkListEntry;
	otherTI : CM_TrackedItem;
	totalWeight : Decimal[14,4];
	aStr: String;
	
begin
	return inheritMethod(_ti, _entry, _messageLogger);
	tmpCargoType := _ti.myCargoType;
	if tmpCargoType.isCheckMaxLift then
		//if self.canTwinLift then
		if self.machineLiftType = TWIN_LIFT then//ccms1595 27/11/07
			if _entry.myWorkListEntry.getIsTwinLift() then
				otherWLE := _entry.myWorkListEntry.CM_VoyageWLE.getTwinLiftWLE();
				if otherWLE &lt;&gt; null then
					otherTI := otherWLE.myTrackedItem;
					totalWeight := (_ti.totalWeight + otherTI.totalWeight);

					if totalWeight &gt; self.maxLiftWeight then 
						aStr := app.getErrorString5(MACH_MAX_LIFT_WEIGHT_TWIN,self.id.trimRight,maxLiftWeight.asStringWeightJMT,_ti.id,otherTI.id,totalWeight.asStringWeightJMT);
						
						if _messageLogger &lt;&gt; null then
							_messageLogger.addLog(aStr,SEVERE_INFO,MACH_MAX_LIFT_WEIGHT_TWIN);	
						endif;
						return false;  		
					endif;
				endif;
			endif;
		endif;
	endif;
	

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_entry" type="CM_RTQueueEntry"/>
        <Parameter name="_messageLogger" type="CM_MessageLogger"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
