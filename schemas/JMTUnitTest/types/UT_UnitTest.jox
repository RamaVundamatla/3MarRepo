//18 December 2008	cnwdw1	
//
vars

begin
	self.unitTestAfter(null);
	app.mySaveDataObjsToRestore.restoreStateData(method, self.currentMethodBeingRun, self);	// 12/12/2014 cnmwh5
end;</source>
