    <JadeMethod name="tblData_mouseDown" id="a43e99e1-cae5-4137-be94-d1bacffc84ea">
        <controlMethod name="CM_DataTable::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//--------------------------------------------------------------
//Created: 01 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if button = 1 then
		self.origXPos := x;
		self.origYPos := y;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
