    <JadeMethod name="holdDrawHeight" id="d5555f63-3dcd-4838-8ce6-ad5b95949a4a">
        <methodInvocation>mapping</methodInvocation>
        <source>holdDrawHeight(set: Boolean; _value: Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:     05 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpBayHeight	: Integer;
begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;

	tmpBayHeight := self.bayHeight;
	
	if self.drawHoldVertical then
		if self.myVoyage.myCellularVoyageStructure.hasTripleBays then
			_value := tmpBayHeight * 3;
		else
			_value := tmpBayHeight * 2;
		endif;
	else
		_value := tmpBayHeight;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="holdDrawWidth" id="cc54fea3-bb7b-4cba-b48f-97fc09e9892b">
        <methodInvocation>mapping</methodInvocation>
        <source>holdDrawWidth(set: Boolean; _value: Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:     05 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpBayWidth	: Integer;
begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;

	tmpBayWidth := self.bayWidth;
	
	if self.drawHoldVertical then
		_value := tmpBayWidth;
	elseif self.myVoyage.myCellularVoyageStructure.hasTripleBays then
		_value := tmpBayWidth * 3;
	else
		_value := tmpBayWidth * 2;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
