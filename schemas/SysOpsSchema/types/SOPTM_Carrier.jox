    <JadeMethod name="doResize" id="ccf2c633-2863-4df9-a07f-a6475249dd90">
        <source>doResize();
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 07 October 2003
//
//-----------------------------------------------------------------------

vars
	table 	:	CM_DataTable;
begin
	inheritMethod();
	table := self.myForm.tblData4;
	table.fitColumnWidths();
	table.accessColumn(3).width := table.width.Integer - table.accessColumn(1).width - table.accessColumn(2).width;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="1e78aff9-af35-484e-addb-84910ab81ad5">
        <updating/>
        <source>doSave(): Boolean updating;
//12/05/2022 navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
vars
	errObj						: CM_Error;
	idx							: Integer;
	tmpListBox					: ListBox;
	ignoreWarnings,rtnValue,
	isNotAvailableForEntry, isRail, isRoad, isSubCarrier : Boolean;
	debtor 						: CM_Debtor;
	proxyCarrier				: CM_Carrier;
	lCode,lDescription			: String;
	theForm 					: SOP_TableMaintForm;
	lEmailPINAddresses			: CM_EmailEntityByTypeNameDict;
	colour						: Integer;
	dacRel,
	dacRec						: CM_DataAccessController;
begin
    theForm := self.myForm;
	lCode := theForm.tblInput1.getValueByName(ETRow_Code).String;
	lDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;
	isNotAvailableForEntry := theForm.tblInput1.getValueByName(ETRow_IsNotAvailableForEntry).Boolean;
	isRail := theForm.tblInput1.getValueByName(ETRow_IsRail).Boolean; 	//+ cnwmd1, CCMS 1067, Par 19710
	isRoad := theForm.tblInput1.getValueByName(ETRow_IsRoad).Boolean; 	//+ cnwmd1, CCMS 1067, Par 19710
	isSubCarrier := theForm.tblInput1.getValueByName(ETRow_IsSubCarrier).Boolean;    //12/05/2022 navhl20 TFS 53430
	debtor := theForm.cmbDebtor.myObject.CM_Debtor; 					//+ cnwmd1, CCMS 1067
	colour := theForm.tblInput1.getValueByName(ETRow_Colour).Integer;
	
	create lEmailPINAddresses transient;
	theForm.mulSelect1.getSelected(lEmailPINAddresses);   
	
	dacRec := theForm.cmbDAOperatorRec.myObject.CM_DataAccessController;
	dacRel := theForm.cmbDAOperatorRel.myObject.CM_DataAccessController;
		
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_Carrier transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyCarrier := theForm.myProxyObject.CM_Carrier;
	//proxyCarrier.setProxy(lCode, lDescription, lEmailPINAddresses, isNotAvailableForEntry, isRail, isRoad, debtor, colour,dacRel,dacRec);					//12/05/2022 navhl20 TFS 53430
	proxyCarrier.setProxy(lCode, lDescription, lEmailPINAddresses, isNotAvailableForEntry, isRail, isRoad, isSubCarrier, debtor, colour,dacRel,dacRec);		//12/05/2022 navhl20 TFS 53430

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateCarrier(proxyCarrier, theForm.myCurrentObject, app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateCarrier(proxyCarrier, app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;
	endif;
	
	

epilog
	delete lEmailPINAddresses;
	return rtnValue;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
