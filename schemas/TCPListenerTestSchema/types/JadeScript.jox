<Class name="JadeScript">
    <JadeMethod name="createTestScripts" id="1a8134fb-81c0-4a2a-889e-315b42a85c0f">
        <source>createTestScripts();

/*

Purpose:			


Return Value:		


Date		Who		Reason
09 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars
	control			: TestAppControl;
	session			: TCPSessionScript;
	payload			: TCPMessagePayload;
	i, j			: Integer;
	
begin
	// Delete any old stuff lying around
	self.deleteAllData;

	// Now create scripts - Use SingleTCPTestForm "Generate Script Code" to build this code
	beginTransaction;
	create control;
		
	foreach i in 1 to 10 do
	
		create session;
		session.myTestAppControl := control;

		// Initialise
		create payload;
		payload.myTCPSessionScript	:= session;
		payload.operationName		:= 'Initialise';
		payload.message				:= 'CNWKPD1';
		
	endforeach;
	
	commitTransaction;
	

epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteAllData" id="0fec9e48-d15d-4467-93b3-6f0b1922bfe8">
        <source>deleteAllData();

/*

Purpose:			


Return Value:		


Date		Who		Reason
09 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars

begin
	beginTransaction;
	TestAppControl.instances.purge;
	commitTransaction;
	beginTransaction;
	TCPSessionScript.instances.purge;
	commitTransaction;
	beginTransaction;
	TCPMessagePayload.instances.purge;
	commitTransaction;
	

epilog

end;</source>
    </JadeMethod>
</Class>
