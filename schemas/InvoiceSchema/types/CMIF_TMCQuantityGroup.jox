    <JadeMethod name="initialise" id="5257836f-e21e-460d-8895-b1c5236df545">
        <updating/>
        <source>initialise(_groupCount : Integer io) updating;
//09/02/2017 cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time

vars
	qmr : CM_QuantityRangeMap;
	tmcQRM : CMIF_TMCQuantityRangeGroup;
	tmcQRSubM : CMIF_TMCQuantitySubRangeGroup;
begin
	self.myTMCController := self.myGroup.myTMCController;	// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
	self.hidePictures := self.myTMCController.hidePictures;
	foreach qmr in self.myQuantityMap.allQuantityRanges discreteLock do
		create tmcQRM;
		tmcQRM.myGroup := self;
		tmcQRM.itemName := qmr.getName();
		tmcQRM.extractName := qmr.getExtractDetails();	// 23659
		tmcQRM.myQuantityRangeMap := qmr;
		tmcQRM.initialise(_groupCount);
		
		//09/02/2017 cnwma1 TFS #2901
		if qmr.myChildQuantityMap &lt;&gt; null then    
			if qmr.myQuantityMap.myParentFinancialObject.isKindOf(CM_ServiceBroker)then //17/02/2017 cnwma1 TFS #2901
				create tmcQRSubM;
				tmcQRSubM.myGroup := tmcQRM;
				tmcQRSubM.itemName := self.getItemName;
				tmcQRSubM.extractName := tmcQRM.extractName;	
				tmcQRSubM.myQuantityRangeMap := qmr;
				tmcQRSubM.initialise(_groupCount);
			endif;
		//09/02/2017 cnwma1 TFS #2901
		endif;
	endforeach;
	_groupCount := _groupCount  + 1;
	
end;</source>
        <Parameter name="_groupCount" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isDefault" id="89963018-c69c-4456-983d-936edc885399">
