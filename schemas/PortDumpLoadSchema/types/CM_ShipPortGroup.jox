<Class name="CM_ShipPortGroup">
    <JadeMethod name="exportPDXMLMyCollections" id="c2eafe64-4b25-4d9b-ab2a-c268d2274792">
        <source>exportPDXMLMyCollections(_file: File; _objArray: ObjectArray io; _property: Property; _object: Object);

vars
	obj: Object;
begin
	if _property.name = CM_ShipPortGroup::shipPorts.name then
		_file.writeLine('&lt;'&amp;CM_ShipPortGroup::shipPorts.name&amp;'&gt;');
		foreach obj in self.shipPorts do
			_file.writeLine('&lt;class&gt;'&amp;obj.class.name&amp;'&lt;/class&gt;');
			obj.CM_ShipPort.exportPDXML(_file, _objArray, true, true);
		endforeach;
		_file.writeLine('&lt;/'&amp;CM_ShipPortGroup::shipPorts.name&amp;'&gt;');
	endif;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLCollections" id="3a190c5e-7ef6-4120-ab60-91d80000a633">
        <source>importPLXMLCollections(_name: String; _collectionsBlock: String);

vars
	proxyArray: ObjectArray;
	newObject: Object;
begin
	create proxyArray transient;
	if _name = CM_ShipPortGroup::shipPorts.name then
		self.importPLXMLNewCollectionWorker(_collectionsBlock, _name, proxyArray);
		foreach newObject in proxyArray do
			if newObject.CM_ShipPort.port &lt;&gt; null then //772
				self.shipPorts.add(newObject.CM_ShipPort);
			endif;
		endforeach;
	endif;
	
epilog
	delete proxyArray;		// PAR #27874
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLReference" id="34a36c09-b108-43ad-82a2-0fffc382b7db">
        <updating/>
        <source>importPLXMLReference(_name: String; _theCode: String; _referencesBlock: String): Object updating;

vars

begin
	if _name = CM_ShipPortGroup::shippingLine.name then
		return app.myRoot.allShippingLines[_theCode];
	elseif _name = CM_ShipPortGroup::lineGroupDebtors.name then
		return null;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="setShippingLine" id="4e19f073-09a4-403b-8ad6-24e70baf4e61">
        <updating/>
        <source>setShippingLine(_shippingLine: CM_ShippingLine) updating;

vars

begin
	self.shippingLine := _shippingLine;
end;</source>
        <Parameter name="_shippingLine" type="CM_ShippingLine"/>
    </JadeMethod>
</Class>
