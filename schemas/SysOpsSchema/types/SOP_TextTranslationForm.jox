    <JadeMethod name="setTableDataFromOrganiser" id="2b006293-ded2-48ce-9314-e48cafea047d">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_TextTranslationTable input) updating;
//--------------------------------------------------
// Created:	13 April 2005 By: RBarr
//--------------------------------------------------
vars
	rowIdx : Integer;
	partsDone : Integer;

begin
	self.displayTranslatableText(_theTable, partsDone);
	
	if _theTable.findObjectInRow(self.myTranslatableText, rowIdx) then
		_theTable.selectRow(rowIdx, false);
	endif;
end;</source>
