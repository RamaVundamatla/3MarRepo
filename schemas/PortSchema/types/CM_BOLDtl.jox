    <JadeMethod name="pxyCreateUpdateProxy" id="93c5a39a-53d9-48c4-8c2c-6615a1c9f170">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
28 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes
*/

vars

	proxyObj		: SelfType;
	completedOK		: Boolean;
	
begin

	proxyObj :=	inheritMethod();
	
	proxyObj.hsCode	:=  self.hsCode;
	
	completedOK := true;
	return proxyObj;

epilog

	if not completedOK then
		delete proxyObj;
	endif;	
	
