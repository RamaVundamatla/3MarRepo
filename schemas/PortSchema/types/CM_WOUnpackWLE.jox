    <JadeMethod name="getTotalWt" id="53926fa3-ac38-4961-ae77-d724f69d8120">
        <source>getTotalWt() : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Jul 2024 navhl20	Defect 65460: Some columns are missing on the Pack Unpack operation mode and the Quantity is not displaying the correct value

*/

vars
	ti,
	child		: CM_TrackedItem;
	weight 		: Decimal[14,4];
begin
	ti := self.myTrackedItem;
	if ti &lt;&gt; null and ti.allChildren.isNotEmpty() then
		foreach child in ti.allChildren do
			weight := weight + child.totalWeight;
		endforeach;
		return weight;
	endif;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
