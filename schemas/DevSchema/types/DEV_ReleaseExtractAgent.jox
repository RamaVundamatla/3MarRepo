    <JadeMethod name="changeDDBVersionNumber" id="4cfafa77-4385-4c47-a5f4-d4e24e2a4bc0">
        <source>changeDDBVersionNumber(_ddbFile : String;
					   _usePresentationFileSystem : Boolean;
					   _newVersion : String);

/*

Purpose:			Change the internal version number of the passed in schema file to the passed in
					new version
					

Return Value:		


Date		Who		Reason
13 Aug 2015	cnwkpd1	Automate release extract process

*/

constants
	JADEVersionNumber	= "JadeVersionNumber";
	Version6			= "Version 6/";
	BufferSize			= 50000;
	
vars
	inFile,
	outFile			: File;
	line,
	lineOut			: String;
	jadeVerLen,
	verLen,
	pos				: Integer;
	finishedHeader	: Boolean;
	
begin
	create inFile transient;
	inFile.usePresentationFileSystem := _usePresentationFileSystem;
	inFile.openInput(_ddbFile);

	jadeVerLen := JADEVersionNumber.length;
	verLen := Version6.length;
	
	self.log("Changing version number for " &amp; self.getFileNameDisplay(inFile));
	
	// Have to close file to rename
	inFile.close;
	inFile.rename(_ddbFile &amp; ".old");
	
	// Reopen old file
	inFile.kind := File.Kind_Unknown_Text;	// 24/2/16 cnwmp6 PAR 36286 unicode version
	inFile.openInput(_ddbFile &amp; ".old");
	
	// Create the new output file
	create outFile transient;
	outFile.usePresentationFileSystem := _usePresentationFileSystem;
	outFile.openOutput(_ddbFile);
	
	while not inFile.endOfFile() do
		line := inFile.readLine();
		lineOut := line;
		
		if line.length &gt; jadeVerLen and line[1:jadeVerLen] = JADEVersionNumber then
			lineOut := JADEVersionNumber &amp; " " &amp; _newVersion;
		elseif line.length &gt; verLen and line[1:verLen] = Version6 then
			lineOut := Version6 &amp; _newVersion;
			finishedHeader := true;
		endif;
		
		if line &lt;&gt; lineOut then
			self.log("Replaced |" &amp; line &amp; "| with |" &amp; lineOut &amp; "|");
		endif;
		
		outFile.writeLine(lineOut);
		
		if finishedHeader then 
			break;
		endif;
	endwhile;
	
	// Copy rest of file using readString to prevent maxRecordSize errors
	while not inFile.endOfFile() do
		outFile.writeString(inFile.readString(BufferSize));
	endwhile;
	
	inFile.close();
	outFile.close();
		
	self.log("Version number changed for " &amp; self.getFileNameDisplay(outFile));
	
epilog
	delete inFile;
	delete outFile;

end;</source>
        <Parameter name="_ddbFile" type="String"/>
        <Parameter name="_usePresentationFileSystem" type="Boolean"/>
        <Parameter name="_newVersion" type="String"/>
    </JadeMethod>
    <JadeMethod name="changeSCMVersionNumber" id="acd70d60-ccd8-440a-b0b6-5b2502bdcb98">
        <source>changeSCMVersionNumber(_schemaFile : String;
					   _usePresentationFileSystem : Boolean;
					   _newVersion : String);

/*

Purpose:			Change the internal version number of the passed in schema file to the passed in
					new version
					

Return Value:		


Date		Who		Reason
13 Aug 2015	cnwkpd1	Automate release extract process

*/

constants
	JADEVersionNumber	= "jadeVersionNumber";
	BufferSize			= 50000;
	
vars
	inFile,
	outFile			: File;
	line,
	lineOut			: String;
	verLen,
	pos				: Integer;
	finishedHeader	: Boolean;
	
begin
	create inFile transient;
	inFile.usePresentationFileSystem := _usePresentationFileSystem;
	inFile.openInput(_schemaFile);

	verLen := JADEVersionNumber.length;

	self.log("Changing version number for " &amp; self.getFileNameDisplay(inFile));
	
	// Have to close file to rename
	inFile.close;
	inFile.rename(_schemaFile &amp; ".old");
	
	// Reopen old file
	inFile.kind := File.Kind_Unknown_Text;	// 24/2/16 cnwmp6 PAR 36286 unicode version
	inFile.openInput(_schemaFile &amp; ".old");
		
	// And create a new output file
	create outFile transient;
	outFile.usePresentationFileSystem := _usePresentationFileSystem;
	outFile.openOutput(_schemaFile);
		
	while not inFile.endOfFile() do
		line := inFile.readLine();
		lineOut := line;

		if line.length &gt; verLen and line[1:verLen] = JADEVersionNumber then
			lineOut := JADEVersionNumber &amp; ' "' &amp; _newVersion &amp; '";';
			finishedHeader := true;
		endif;
		
		if line &lt;&gt; lineOut then
			self.log("Replaced |" &amp; line &amp; "| with |" &amp; lineOut &amp; "|");
		endif;
		
		outFile.writeLine(lineOut);
		
		if finishedHeader then 
			break;
		endif;
	endwhile;
	
	// Copy rest of file using readString to prevent maxRecordSize errors
	while not inFile.endOfFile() do
		outFile.writeString(inFile.readString(BufferSize));
	endwhile;
	
	inFile.close();
	outFile.close();
		
	self.log("Version number changed for " &amp; self.getFileNameDisplay(outFile));
		
epilog
	delete inFile;
	delete outFile;

end;</source>
        <Parameter name="_schemaFile" type="String"/>
        <Parameter name="_usePresentationFileSystem" type="Boolean"/>
        <Parameter name="_newVersion" type="String"/>
    </JadeMethod>
    <JadeMethod name="check30CharLimit" id="8b392270-49bc-4154-b394-0c1b25c7ee85">
        <source>check30CharLimit() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
03 October 2019		jlgmd1	Initial creation TFS 45294

*/

constants
	UTSchema 	: String = "JMTUnitTest";
	CertClass	: String = "UT_ZJMTLogicalCertify";
	ExClass		: String = "UT_TestFailureException";
vars
	utClass			: Object;
	hadException 	: Boolean;
	exMessage		: String;
	success			: Boolean;
begin
	on Exception do self.handleUTException(exception, hadException, exMessage);
	
	self.log("Checking Schema Entity Names for lengths longer than 30 characters...");
	
	create utClass as rootSchema.getSchema(UTSchema).getClass(CertClass) transient;
	utClass.sendMsg("tCheckSchemaEntityNames");
	
	if hadException then
		self.log(exMessage);
	else
		// Only return true if we had no exception
		self.log("No errors found");
		success := true;
	endif;	
	
epilog
	delete utClass;
	return success;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkBaseWSDLFeatures" id="22b1e4f5-c812-40ee-8c7b-a9875b7790b4">
        <source>checkBaseWSDLFeatures(_allBaseFeatures : HugeStringArray);
/*

Purpose:			Make sure we have some sensible parents set up for the children WSDL classes

Parameters:			

Return Value:		

Date			Who		Reason
08 May 2019		jlgmd1	Initial creation - TFS 39667 JMT - API Documentation

*/

vars
	oa						: ObjectArray;
	previousWSDLClasses		: DEV_REOWsdlClassDict;
	class					: DEV_REOWsdlClass;
	baseFeatName			: String;
begin
		// Get our WSDL Classes from last time (if we have any)
		create oa transient;
		DEV_REOWsdlClass.allInstances(oa, 0, false);
		
		create previousWSDLClasses transient;
		oa.copy(previousWSDLClasses);
		
		foreach baseFeatName in _allBaseFeatures do
			class := previousWSDLClasses[baseFeatName];
			if class = null then
				beginTransaction;
				create class persistent;
				class.set(baseFeatName, null);
				// No need to record methods or attributes on base classes
				commitTransaction;
			endif;
		endforeach;
epilog
	delete oa;
	delete previousWSDLClasses;
end;</source>
        <Parameter name="_allBaseFeatures" type="HugeStringArray"/>
    </JadeMethod>
    <JadeMethod name="checkRelMethForErr" id="b5c8484a-e786-4369-83f5-21c921b12e9f">
        <source>checkRelMethForErr() : Boolean;
/*

Purpose:	This script will list all methods in errors across all schemas.
			(Copied from DevSchema::JadeScript::releaseMthErrorsAcrossSchemas)

Parameters:			

Return Value:		

Date				Who		Reason
03 October 2019		jlgmd1	Initial creation TFS 45294

*/

vars
	oSchema				: Schema;
	oType				: Type;
	oMethod				: Method;
	oAllClasses			: ClassColl;
	oAllTypes			: PrimTypeNDict;
	oAllMethods			: MethodNDict;
	iErrorsFound		: Integer;
	iErrorsTotal		: Integer;
	isOk				: Boolean;
	
begin
	create oAllClasses transient;
	create oAllTypes transient;
	create oAllMethods transient;
 
	self.log("Starting checking for Methods in Error");
	
	foreach oSchema in Schema.instances do : schema_loop
		self.log("Checking Schema " &amp; oSchema.name);
		
		delete oAllClasses;
		oAllClasses	:= oSchema.getAllClasses( true );
		
		foreach oType in oAllClasses do : class_loop
			oAllMethods.clear;
			oType.getMethods( oAllMethods ) ;
			foreach oMethod in oAllMethods do : method_loop
				if oMethod.getSchema &lt;&gt; oSchema then
					continue method_loop;
				endif;
				// display if in error and this method is actually in this schema not a super schema
				if oMethod.inError or oMethod.notCompiled then
					iErrorsFound := iErrorsFound + 1;
					self.log(oSchema.name &amp; Tab &amp; oType.name &amp; Tab &amp; oMethod.name);
				endif;
			endforeach method_loop;
		endforeach class_loop;
		
		if iErrorsFound &lt;&gt; null then
			self.log('Number of errors for schema ' &amp; oSchema.name &amp; ' is ' &amp; iErrorsFound.display);
		endif;
		iErrorsTotal	:= iErrorsTotal + iErrorsFound;
		iErrorsFound	:= null;
	endforeach schema_loop;
	
epilog
	if iErrorsTotal = null then
		self.log(CrLf &amp; "Completed - No errors found" &amp; CrLf &amp; "Finished checking for Methods in Error");
		isOk := true;
	else
		self.log(CrLf &amp; "Completed - " &amp; iErrorsTotal.display &amp; " Errors Found" &amp; CrLf &amp; "Finished checking for Methods in Error");
	endif;

	delete oAllTypes;
	delete oAllClasses;
	delete oAllMethods;
	
	return isOk;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearDirectory" id="6f7fb325-4add-416d-b70c-82057b4aea51">
        <source>clearDirectory(_directory : String;
			   _usePresentation : Boolean;
			   _removeHiddenFiles : Boolean) : Boolean;

/*

Purpose:			Clear out the named directory, and all the files in it.  Optionally leave
					hidden files where they are (used by SVN).
					
Parameters:			Directory name
					Directory is presentation client relative?
					Remove hidden files?

Return Value:		True if all the files in the directory were deleted, false otherwise 
					(i.e. there were Hidden files not removed


Date		Who		Reason
24 Mar 2011	cnwkpd1	CCMS SFW 1223 - Prototyping code for new Release Mechanism

*/
	
vars
	inFolder		: FileFolder;
	inFile			: FileNode;
	msg				: String;
	
	returnVal		: Boolean;
	
begin
	msg := "Clearing directory " &amp; _directory &amp; self.getFileTypeString(_usePresentation);
	if _removeHiddenFiles then
		msg := msg &amp; ", including hidden files";
	else
		msg := msg &amp; ", leaving hidden files";
	endif;
	
	self.log(msg);
		
	create inFolder transient;
	inFolder.usePresentationFileSystem := _usePresentation;
	inFolder.fileName := _directory;
	
	returnVal := true;
	
	foreach inFile in inFolder.files do
		// Do not delete hidden files
		if not _removeHiddenFiles and inFile.hidden then
			self.log("Leaving hidden file " &amp; self.getFileNameDisplay(inFile));
			returnVal := false;
		else
			if inFile.isKindOf(FileFolder) then
				if self.clearDirectory(inFile.fileName, inFile.usePresentationFileSystem, _removeHiddenFiles) then
					self.log("Deleting folder " &amp; self.getFileNameDisplay(inFile));
					self.removeFile(inFile);
				else
					self.log("Leaving folder " &amp; self.getFileNameDisplay(inFile) &amp; ", contains hidden files");
				endif;
			else 
				self.log("Deleting file " &amp; self.getFileNameDisplay(inFile));
				self.removeFile(inFile);	
			endif;
		endif;
	endforeach;
	
	return returnVal;
	

epilog
	delete inFolder;
	
end;</source>
        <Parameter name="_directory" type="String"/>
        <Parameter name="_usePresentation" type="Boolean"/>
        <Parameter name="_removeHiddenFiles" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyDirectory" id="7435dd89-a1a0-48b8-9ff5-d12faa3465e0">
        <source>copyDirectory(_sourceDirectory : String;
			  _sourceUsePresentation : Boolean;
			  _targetDirectory : String;
			  _targetUsePresentation : Boolean;
			  _excludeFolders : StringArray) : Boolean;

/*

Purpose:			Copy the source directory, and all the files in it, to the target directory

Parameters:			

Return Value:		True if successful


Date		Who		Reason
24 Mar 2011	cnwkpd1	CCMS SFW 1223 - Prototyping code for new Release Mechanism
02 Feb 2018 jlgmd1	Exclude a list of directories from being copied

*/
	
vars
	inFolder,
	outFolder,
	newFolder		: FileFolder;
	
	inFile,
	outFile			: FileNode;
	
	returnVal		: Boolean;
	
begin
	self.log("Copying directory " &amp; _sourceDirectory &amp; self.getFileTypeString(_sourceUsePresentation) &amp;
			 " as " &amp; _targetDirectory &amp; self.getFileTypeString(_targetUsePresentation));
	
	create inFolder transient;
	inFolder.usePresentationFileSystem := _sourceUsePresentation;
	inFolder.fileName := _sourceDirectory;
	if not inFolder.isAvailable() then
		self.log("Error copying from directory " &amp; self.getFileNameDisplay(inFolder) &amp; ", not available");
		return false;
	endif;
	
	create outFolder transient;
	outFolder.usePresentationFileSystem := _targetUsePresentation;
	outFolder.fileName := _targetDirectory;
	if not outFolder.isAvailable() then
		self.log("Error copying to directory " &amp; self.getFileNameDisplay(outFolder) &amp; ", not available");
		return false;
	endif;
	
	returnVal := true;
	
	foreach inFile in inFolder.files do
		if inFile.isKindOf(FileFolder) then
			// Only copy the specified directory if its not in our exclude list
			if _excludeFolders &lt;&gt; null and _excludeFolders.includes(inFile.name) then
				continue;
			endif;
			
			create newFolder transient;
			newFolder.usePresentationFileSystem := _targetUsePresentation;
			newFolder.fileName := _targetDirectory &amp; "\" &amp; inFile.name;
			if newFolder.isAvailable() then
				self.log("Target directory " &amp; self.getFileNameDisplay(newFolder) &amp; " already exists, not created");
			else
				newFolder.make();
				self.log("Target directory " &amp; self.getFileNameDisplay(newFolder) &amp; " created");
			endif;
			returnVal := self.copyDirectory(inFile.fileName, _sourceUsePresentation, newFolder.fileName, _targetUsePresentation, _excludeFolders);
			delete newFolder;
			if not returnVal then
				break;
			endif;
		else
			self.copyFile(inFile.fileName, _sourceUsePresentation, _targetDirectory &amp; "\" &amp; inFile.name, _targetUsePresentation);
		endif;
	endforeach;

	return returnVal;
	

epilog
	delete inFolder;
	delete outFolder;
	delete newFolder;
	
end;</source>
        <Parameter name="_sourceDirectory" type="String"/>
        <Parameter name="_sourceUsePresentation" type="Boolean"/>
        <Parameter name="_targetDirectory" type="String"/>
        <Parameter name="_targetUsePresentation" type="Boolean"/>
        <Parameter name="_excludeFolders" type="StringArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyDirectoryExternal" id="9654785b-2b8c-4cfa-9f1f-c80fbf1dd6e1">
        <source>copyDirectoryExternal(_sourceDirectory : String;
			  _targetDirectory : String;
			  _usePresentationFS : Boolean) : Boolean;

/*

Purpose:			Copy the source directory, and all the files in it, to the target directory using robocopy

Parameters:			

Return Value:		True if successful


Date				Who		Reason
27 July 2018		jlgmd1	Initial creation
21 February 2019	jlgmd1	Changed to use robocopy instead
16 May 2019			jlgmd1	Drop the number of copy theads down a bit to better handle simultaneous calls

*/


vars
	inFolder		: FileFolder;
	
	command			: String;
	args			: StringArray512;
	
	procRes			: Integer;
	result			: Integer;
	
	logDir			: String;
	now				: TimeStamp;
	
begin
	self.log("Copying directory " &amp; _sourceDirectory &amp; self.getFileTypeString(_usePresentationFS) &amp;
			 " as " &amp; _targetDirectory &amp; self.getFileTypeString(_usePresentationFS) &amp; " using robocopy");
	
	create inFolder transient;
	inFolder.usePresentationFileSystem := _usePresentationFS;
	inFolder.fileName := _sourceDirectory;
	if not inFolder.isAvailable() then
		self.log("Error copying from directory " &amp; self.getFileNameDisplay(inFolder) &amp; ", not available");
		return false;
	endif;
	
	// Send the robocopy messages to their own file to speed up copying
	if _usePresentationFS and process.isUsingThinClient then
		logDir := process.getJadeHomeDirectory() &amp; "logs";
		logDir.replaceChar('/','\');
	else
		logDir	:= app.getJadeLogDir();
	endif;
	
	create args transient;	
	
	command := "robocopy";
	args[1] := '"' &amp; _sourceDirectory &amp; '"';
	args[2] := '"' &amp; _targetDirectory &amp; '"';
	args[3] := '/E';		// include empty directories
	args[4] := '/NP';		// don't show % progress
	args[5] := '/R:5';		// retry 5 times
	args[6] := '/W:5';		// waiting 5 seconds between eacy try
	args[7] := '/MT:12';	// create 12 copy threads
	//args[8] := '/LOG:"' &amp; logDir &amp; '\robocopy_' &amp; now.formatAsYYYYMMDDHHMMSSMMM.replace(":",".").replace(" ","_") &amp; '.log"';	// Redirect the log 
	
	procRes := node.createExternalProcess("", command, args, null, _usePresentationFS, false, result);
	//process.sleep(5);	// put an artifical delay in here so all robocopies go to their own logs

	// Can't check the result here, because we want robocopy to run in parallel to us
	
	return (procRes = node.ExternalProcess_InitiateOK);
	
epilog
	delete inFolder;	
	delete args;
end;</source>
        <Parameter name="_sourceDirectory" type="String"/>
        <Parameter name="_targetDirectory" type="String"/>
        <Parameter name="_usePresentationFS" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyFile" id="9ab9a208-830b-4124-b752-50db53aabe05">
        <source>copyFile(_sourceFileName : String;
		 _sourceUsePresentation : Boolean;
		 _targetFileName : String;
		 _targetUsePresentation : Boolean);

/*

Purpose:			Copy the source file as a new file with the target name, with retry capability
					to handle transient file system errors related to file share network issues

Parameters:			

Return Value:		


Date		Who		Reason
24 Feb 2010	cnwkpd1	Automation of release process

*/

constants
	MaxRetries		= 5;
	RetryInterval	= 10000;
	
vars
	retryCount		: Integer;
	excOccurred		: Boolean;
	
begin
	self.log("Copying file " &amp; _sourceFileName &amp; self.getFileTypeString(_sourceUsePresentation) &amp; 
			 " as " &amp; _targetFileName &amp; self.getFileTypeString(_targetUsePresentation));
			 
	while retryCount &lt; MaxRetries do
		retryCount := retryCount + 1;
		excOccurred := false;
		
		if retryCount &lt; MaxRetries then
			on FileException do self.handleFileException(exception, excOccurred, false);
		endif;
		
		self.copyFileEx(_sourceFileName,
						_sourceUsePresentation,
						_targetFileName,
						_targetUsePresentation);
						
		if retryCount &lt; MaxRetries then
			on FileException do null;
		endif;
		
		if not excOccurred then
			break;
		endif;
		
		self.log("Error copying file " &amp; _sourceFileName &amp; self.getFileTypeString(_sourceUsePresentation) &amp; 
			 " as " &amp; _targetFileName &amp; self.getFileTypeString(_targetUsePresentation) &amp; ", retryCount=" &amp; retryCount.String);
		
		process.sleep(RetryInterval);
		
	endwhile;
	
epilog
	
end;</source>
        <Parameter name="_sourceFileName" type="String"/>
        <Parameter name="_sourceUsePresentation" type="Boolean"/>
        <Parameter name="_targetFileName" type="String"/>
        <Parameter name="_targetUsePresentation" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyFileEx" id="25f358c3-3674-4bf2-a07c-d9f36474e7e7">
        <source>copyFileEx(_sourceFileName : String;
		   _sourceUsePresentation : Boolean;
		   _targetFileName : String;
		   _targetUsePresentation : Boolean) protected;

/*

Purpose:			Copy the source file as a new file with the target name
					
Parameters:			

Return Value:		


Date		Who		Reason
09 Feb 2016	cnwkpd1	Extend file exception handling to copy as well as remove

*/

constants
	FileChunkSize	= 500000;
	
vars
	inFile,
	outFile			: File;
	data			: Binary;
	excOccurred		: Boolean;
	
begin
	create inFile transient;
	inFile.kind := File.Kind_Binary;
	inFile.usePresentationFileSystem := _sourceUsePresentation;
	inFile.openInput(_sourceFileName);
	
	create outFile transient;
	outFile.kind := File.Kind_Binary;
	outFile.usePresentationFileSystem := _targetUsePresentation;
	outFile.openOutput(_targetFileName);
	
	while not inFile.endOfFile() do
		data := inFile.readBinary(FileChunkSize);
		outFile.writeBinary(data);
	endwhile;
	
	inFile.close();
	outFile.close();
	

epilog
	delete inFile;
	delete outFile;
	
end;</source>
        <access>protected</access>
        <Parameter name="_sourceFileName" type="String"/>
        <Parameter name="_sourceUsePresentation" type="Boolean"/>
        <Parameter name="_targetFileName" type="String"/>
        <Parameter name="_targetUsePresentation" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="6ca196b2-e152-4e4a-be68-8198f85f8029">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04/07/2019	jlgmd1	TFS Automation - Write to a log we can read again

*/

vars

begin
	if self.thinclientLog &lt;&gt; null then
		thinclientLog.close();
		delete thinclientLog;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildAutoDeployDirectory" id="0d38c3d2-b4d6-4d76-b32e-bcaa34a5c579">
        <source>doBuildAutoDeployDirectory(_serverDirectory,
						   _autoDeployDirectory,
						   _baseDirectory : String;
						   _isDevelopment : Boolean);

/*

Purpose:			Following a Daily Extract, create an Auto Deploy directory with the schema
					and ddb files in the passed in _serverDirectory
					
Parameters:			Server and Auto Deploy (client-relative) Directory to copy files from and to.
					Base directory to copy to the Auto Deploy directory (optional)
					Whether or not the target is a development environment.				

Return Value:		None


Date		Who		Reason
17 Jun 2015	cnwkpd1	Set up auto deployment for Unicode environment
26 Jul 2017	jlgkpd1	Add optional base directory
02 Feb 2018 jlgmd1	Copy htdocs while excluding the HTML5 directory
17 May 2018	jlgmd1	Create the SchemaFiles/ANSI directory if it doesn't already exist
22 May 2018	jlgkpd1	Add TestingDataLoadSchema to the CNWHMAST deploy
25 Sep 2019 jlgzm1	TFS 46543 app_upgrade.log created in wrong location
14 Aug 2020 jlgmd1	Create the htdocs directory if it doesn't already exist
12 Jul 2023 navmd1	Also copy any schema files from the baseDirectory that aren't release schemas
16 Jan 2025 navmd1	Added TestingDataLoad Schema to Zmast deploys for when its being used as daily

*/

constants
	AutoDeploySchemas	= "SchemaFiles";
	AutoDeployMisc		= "x64-msoft-win64\server\misc";
	RunReleaseCommand	= "#runjade schema=PortSchema app=JMTRelease";
	RunErrorLevelCheck = "if ERRORLEVEL 0 ( echo CompletedOK &gt; %env_logpath%\app_upgrade.log ) else ( echo UpgradeError &gt; %env_logpath%\app_upgrade.log )";
	
vars
	extractCommand,
	schemaName		: String;
	schemaDir		: String;
	targetArch		: String;
	archDir			: String;
	miscDir			: String;
	ff,
	filesInSchemaDir: FileFolder;
	file			: FileNode;
	
	allSchemas		: StringArray;
	i				: Integer;
	seq				: Integer;
	seqStr			: String;
	
	appUpgrade		: File;
	
	foldersToExclude : StringArray;
		
begin
	self.log('Building auto deploy directory ' &amp; _autoDeployDirectory);
	
	schemaDir := _autoDeployDirectory &amp; "\" &amp; AutoDeploySchemas;
	
	// Create the SchemaFiles directory if it doesn't exist (eg, the jugdeployment folder has been cleared out)
	create ff transient;
	ff.usePresentationFileSystem := true;
	ff.fileName := schemaDir;
	if not ff.isAvailable then
		ff.make();
	endif;
	
	create allSchemas transient;
	self.getReleaseSchemas(allSchemas);

	if _isDevelopment then
		allSchemas.add("DevSchema");
		allSchemas.add("JMTUnitTest");
	endif;
	
	// Special inclusion for HMAST only
	if _autoDeployDirectory.toLower().cnContains("hmast") or _autoDeployDirectory.toLower().cnContains("zmast") then
		allSchemas.add(self.TestingLoadDataSchema);
	endif;	
	
	// Copy all the required schemas
	foreach schemaName in allSchemas do
	
		seq := 100 + allSchemas.indexOf(schemaName) * 2;
		seqStr := seq.cnEcPad(2);
		
		self.copyFile(_serverDirectory &amp; "\" &amp; schemaName &amp; ".scm", false,
					  schemaDir &amp; "\" &amp; seqStr &amp; schemaName &amp; ".scm", true);
		self.copyFile(_serverDirectory &amp; "\" &amp; schemaName &amp; ".ddb", false,
					  schemaDir &amp; "\" &amp; seqStr &amp; schemaName &amp; ".ddb", true);

	endforeach;
	
	seq := 100 + (allSchemas.size + 2) * 2;
	seqStr := seq.cnEcPad(2);
	
	self.copyFile(_serverDirectory &amp; "\JMTReports.rwa", false,
				  schemaDir &amp; "\" &amp; seqStr &amp; "JMTReports.rwa", true);

	// Determine the target architecture
	targetArch := "unicode";
	archDir := _autoDeployDirectory &amp; "\" &amp; targetArch;
	ff.fileName := archDir;
	if not ff.isAvailable() then
		targetArch := "ansi";
		archDir := _autoDeployDirectory &amp; "\" &amp; targetArch;
		ff.fileName := archDir;
		// If the architecture folder does not exist, then break on purpose
		/*if not ff.isAvailable then
			// If there is no architecture folder, then create the ANSI one by default
			ff.fileName := ff.fileName.toUpper();
			ff.make();
		endif;*/
	endif;
	
	// If the base release directory has been specified, then copy the architecture files from it
	if _baseDirectory &lt;&gt; null then
		self.copyDirectory(_baseDirectory &amp; "\" &amp; targetArch, true,
						   archDir, true, null);
						   
		// Copy the htdocs folder too, but exclude the HTML5 directory
		create foldersToExclude transient;
		foldersToExclude.add("HTML5");
		
		ff.fileName := archDir &amp; "\" &amp; AutoDeployMisc &amp; "\htdocs";
		ff.usePresentationFileSystem := true;
		if not ff.isAvailable then
			ff.make();
		endif;
		
		self.copyDirectory(_baseDirectory &amp; "\jmt_htdocs", true, ff.fileName, true,	foldersToExclude);
		
		// Copy any schema files that aren't release schemas
		create filesInSchemaDir transient;
		filesInSchemaDir.fileName := _baseDirectory &amp; "\SchemaFiles";
		filesInSchemaDir.usePresentationFileSystem := true;
		if filesInSchemaDir.isAvailable then
			foreach file in filesInSchemaDir.files do
				seq := file.name[1:3].Integer;
				if seq &lt;= 100 or seq &gt;= 200 then
					self.copyFile(file.fileName, true, schemaDir &amp; "\" &amp; file.name, true);
				endif;
			endforeach;
		endif;
	endif;		

	// Create the live_app_upgrade file in the misc directory to run the JMT Release app
	miscDir := archDir &amp; "\" &amp; AutoDeployMisc;
	self.log("Creating live_app_upgrade.bat in " &amp; miscDir);
	
	create appUpgrade transient;
	appUpgrade.usePresentationFileSystem := true;
	appUpgrade.openOutput(miscDir &amp; "\live_app_upgrade.bat");
	appUpgrade.writeLine(RunReleaseCommand);
	appUpgrade.writeLine(RunErrorLevelCheck); // TFS 46543
	appUpgrade.close();
	
	
epilog
	delete allSchemas;
	delete appUpgrade;
	delete ff;
	delete foldersToExclude;
	delete filesInSchemaDir;
	
end;</source>
        <Parameter name="_serverDirectory" type="String"/>
        <Parameter name="_autoDeployDirectory" type="String"/>
        <Parameter name="_baseDirectory" type="String"/>
        <Parameter name="_isDevelopment" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDailyEncryptedExtracts" id="023e2dca-8024-43ab-8b4a-37f685257eae">
        <source>doDailyEncryptedExtracts(_serverDirectory : String);

/*

Purpose:			Run the daily extract of schemas for building auto-deployment to non-development
					environments

Parameters:			Server Directory to create files

Return Value:		None


Date		Who		Reason
07 Jul 2015	cnwkpd1	Auto deployment for BAs and Implementation teams
22 May 2018	jlgkpd1	Extract unencrypted TestingDataLoadSchema for CNWHMAST

*/

vars
	extractCommand,
	schemaName		: String;
	
	allSchemas		: StringArray;
	i				: Integer;
	
	scmFile,
	ddbFile			: String;
	
begin
	create allSchemas transient;
	self.getReleaseSchemas(allSchemas);

	// Extract all the required schemas
	foreach schemaName in allSchemas do
		scmFile := _serverDirectory &amp; "\" &amp; schemaName &amp; ".scm";
		ddbFile := _serverDirectory &amp; "\" &amp; schemaName &amp; ".ddb";
		
		extractCommand := "Single " &amp; scmFile &amp; " " &amp; ddbFile &amp; " " &amp; schemaName &amp; ' "&lt;encrypt&gt;"';
		
		self.runSchemaExtractCommand(extractCommand);
		self.removeJCFRef(scmFile, false);
		
	endforeach;
	
	// Extract unencrypted TestingDataLoadSchema
	schemaName := self.TestingLoadDataSchema;
	scmFile := _serverDirectory &amp; "\" &amp; self.TestingLoadDataSchema &amp; ".scm";
	ddbFile := _serverDirectory &amp; "\" &amp; self.TestingLoadDataSchema &amp; ".ddb";
		
	extractCommand := "Single " &amp; scmFile &amp; " " &amp; ddbFile &amp; " " &amp; schemaName;
	self.runSchemaExtractCommand(extractCommand);
	self.removeJCFRef(scmFile, false);
		
	// Extract all the JRW Views and Reports
	self.extractReports(_serverDirectory &amp; "\", "JMTReports");
	
epilog
	delete allSchemas;
	
end;</source>
        <Parameter name="_serverDirectory" type="String"/>
    </JadeMethod>
    <JadeMethod name="doDailyExtractsForSVN" id="5cdcbc2d-b1b3-4805-8cd4-73e33c830ee2">
        <source>doDailyExtractsForSVN(_serverDirectory,
					  _clientDirectory : String);

/*

Purpose:			Run the daily extract of schemas for checking in to SVN

Parameters:			Server and Client Directory to create and copy files

Return Value:		None


Date		Who		Reason
23 Mar 2011	cnwkpd1	CCMS SFW 1223 - Prototyping code for new Release Mechanism
30 Nov 2012	cnwkpd1	Add reports extract from JRW to the daily extract
05/02/2018	jlgmh5	Add TestingDataLoadSchema to the daily extract
19 Nov 2021 navmd1	Add JtdControllerSchema as we've made changes to it (a while ago, but better late than never ;) )
					Add JtdWebCommonSchema and JtdWebDriverSchema
*/

vars
	extractCommand,
	schemaName		: String;
	
	allSchemas		: StringArray;
	i				: Integer;
	
begin
	create allSchemas transient;
	self.getReleaseSchemas(allSchemas);

	allSchemas.add("WebSchema");			// No longer part of release (broken as of JADE2022)
	allSchemas.add("WebExampleSchema");		// But still needed for Source Compare
	allSchemas.add("DevSchema");
	allSchemas.add("HotFixesCommonSchema");
	allSchemas.add("ITSInterfaceTestSchema");
	allSchemas.add("TCPListenerTestSchema");
	allSchemas.add("WebServiceTestSchema");
	allSchemas.add("JSSExtensionSchema");
	allSchemas.add("JSSLicenseKeyMaintSchema");
	allSchemas.add("LicenseKeyTestSchema");
	allSchemas.add("SoapJavascriptGenerator");
	allSchemas.add("JMTUnitTest");
	allSchemas.add("JRWDocSchema");
	allSchemas.add("JtdCommonSchema");
	allSchemas.add("JtdControllerSchema");
	allSchemas.add("JtdDriverSchema");
	allSchemas.add("JtdMobileCommonSchema");
	allSchemas.add("JtdMobileDriverSchema");
	allSchemas.add("JtdWebCommonSchema");
	allSchemas.add("JtdWebDriverSchema");
	allSchemas.add("TestingDataLoadSchema");
		
	// Extract all the required schemas
	foreach schemaName in allSchemas do
		extractCommand := "Single " &amp; _serverDirectory &amp; "\" &amp; schemaName &amp; " " &amp;
									  _serverDirectory &amp; "\" &amp; schemaName &amp; ".ddb " &amp; 
									  schemaName &amp; ' &lt;sections&gt;';
		
		self.runSchemaExtractCommand(extractCommand);
		
	endforeach;
	
	// Extract all the JRW Views and Reports
	self.extractReports(_serverDirectory &amp; "\", "JMTReports");
	
	// Clear out the target directory, preserving hidden files
	self.clearDirectory(_clientDirectory, true, false);
	
	// Now copy all the files from the server to the client
	self.copyDirectory(_serverDirectory, false, _clientDirectory, true, null);
	
	
epilog
	delete allSchemas;
	
end;</source>
        <Parameter name="_serverDirectory" type="String"/>
        <Parameter name="_clientDirectory" type="String"/>
    </JadeMethod>
    <JadeMethod name="doDailySrcExtracts" id="3a4e6129-7dbe-4db9-b5b6-f8c16ac51040">
        <source>doDailySrcExtracts(_serverDirectory : String);

/*

Purpose:			Keep a copy of the non-encrypted schemas on the server

Parameters:			Server Directory to create files

Return Value:		


Date			Who		Reason
31/10/2018		jlgmd1	Initial creation

*/

vars
	extractCommand,
	schemaName		: String;
	
	allSchemas		: StringArray;
	i				: Integer;
	
	scmFile,
	ddbFile			: String;
	
begin
	create allSchemas transient;
	self.getReleaseSchemas(allSchemas);
	
	// Extract some non release schemas too (for Umast at the moment)
	allSchemas.add("DevSchema");
	allSchemas.add("JMTUnitTest");
	allSchemas.add("WebSchema");			// No longer part of release (broken as of JADE2022)
	allSchemas.add("WebExampleSchema");		// But still needed for Source Compare

	// Extract all the required schemas
	foreach schemaName in allSchemas do
		scmFile := _serverDirectory &amp; "\" &amp; schemaName &amp; ".scm";
		ddbFile := _serverDirectory &amp; "\" &amp; schemaName &amp; ".ddb";
		
		extractCommand := "Single " &amp; scmFile &amp; " " &amp; ddbFile &amp; " " &amp; schemaName;
		
		self.runSchemaExtractCommand(extractCommand);
		self.removeJCFRef(scmFile, false);
		
	endforeach;
		
	// Extract all the JRW Views and Reports
	self.extractReports(_serverDirectory &amp; "\", "JMTReports");
	
epilog
	delete allSchemas;
	
end;</source>
        <Parameter name="_serverDirectory" type="String"/>
    </JadeMethod>
    <JadeMethod name="doDevExtract" id="05c8caf0-f05b-4f0e-8eb8-69c3230b4f27">
        <updating/>
        <source>doDevExtract() : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2023	navpw1	Initial creation

*/

constants
	JAPVERSION		= "2.3.0";

	PublicAccess	= "public";
	PreLoadFile		= "JMTInstall_preLoad.txt";
	PreUpgradeFile	= "JMTInstall_preUpgrade.txt";
	PreCheckFile	= "JMTInstall_preSchemaCheck.txt";
	LiveAppUpgrade	= "live_app_upgrade.bat";
	RunReleaseCommand	= "%env_binpath%\jade.exe path=%env_systempath% ini=%env_inifile% server=singleuser schema=PortSchema app=JMTRelease";
	RunPatchCommand		= "%env_binpath%\jade.exe path=%env_systempath% ini=%env_inifile% server=singleuser schema=PortSchema app=JMTPatchRelease endJade version=&lt;version&gt; patch=&lt;patch&gt;";
	RunDDBLoadCommand	= "%env_binpath%\jadloadb.exe path=%env_systempath% ini=%env_inifile% ddbFile='%env_miscpath%\&lt;ddbfile&gt;' loadStyle=onlyStructuralVersioning displayTimes=true";
	RunErrorLevelCheck = "if ERRORLEVEL 0 ( echo CompletedOK &gt; %env_logpath%\app_upgrade.log ) else ( echo UpgradeError &gt; %env_logpath%\app_upgrade.log )";
	
vars
	folder			: FileFolder;
	command,
	dir,
	message,
	extractFolder,
	schemaName,
	scmFile,
	ddbFile,
	partSchemaFileName,
	partDDBFileName	: String;
	args			: StringArray512;
	schemaNames		: StringArray;
	result1,
	result2			: Integer;
	schema			: Schema;
	seq,
	ddbSeq,
	depth			: Integer;
	seqStr,
	ddbSeqStr		: String;
	mulStarterLoad1,
	mulStarterLoad1Source,
	mulStarterLoadPatches,
	mulStarterLoad2,
	mulFileAll,
	mulFileNonProd,
	unlFile,
	mulFile 		: File;
	jmtInstallFile 	: File;
	errorStr 		: String;
	schemaColl 		: SchemaColl;
	rwaFile			: String;
	jariSchemaFolder,
	jariMiscFolderAnsi,
	jariMiscFolderUnicode	: String;
	jariLiveAppUpgradeFile	: File;
	runPatch,
	runLoad			: String;
	version			: String;
	deferDDBLoad	: Boolean;
	versionStarterSkins : String;
	foldersToExclude : StringArray;
	isOk			: Boolean;
	jrwFile			: File;
	rwaMsg			: String;
	now				: TimeStamp;
	
begin
	// Now start extracts and file creation
	message:= "Error";
	
	// Start by validating parameters and setting up internal directory names
	// Set up target source and (optionally) encrypted directory names
	self.targetSourceDirectory := self.targetReleaseDirectory &amp; "\" &amp; "JadeMaster";
	
	// Set up server-side source and (optionally) encrypted directory names
	now := app.actualTimeServer();
	self.serverReleaseDirectory := self.tempServerDirectory &amp; "\" &amp; now.getNumeralString;
	self.serverSourceDirectory := self.serverReleaseDirectory &amp; "\" &amp; "JadeMaster";
	
	// All parameters OK, so can start release
	
	// Begin by renaming any existing target directories so we don't overwrite them
	create folder transient;
	folder.fileName := self.targetSourceDirectory;
	folder.usePresentationFileSystem := true;
	if folder.isAvailable() and not self.onlyContainsWSDocumentation(folder, depth) then
		if self.deleteExistingTargetDir then
			self.log("Target source directory " &amp; self.getFileNameDisplay(folder) &amp; " already exists, deleting");
			self.clearDirectory(folder.fileName, folder.usePresentationFileSystem, true);
			self.removeDirectoryName(folder.fileName, folder.usePresentationFileSystem);
		else
			self.log("Target source directory " &amp; self.getFileNameDisplay(folder) &amp; " already exists, renaming");
			folder.rename(folder.fileName &amp; "_" &amp; folder.createdTime.getNumeralString());
		endif;
	
		// If folder is still available after rename, then the rename failed, so stop
		if folder.isAvailable() then
			self.log("Unable to rename/remove directory " &amp; self.getFileNameDisplay(folder) &amp; ", terminating");
			return false;
		endif;
	endif;
	
	// Start by creating any required directories that do not exist
	folder.fileName := self.targetSourceDirectory &amp; "\schemas";
	folder.usePresentationFileSystem := true;
	if not folder.isAvailable() then
		self.log("Directory " &amp; self.getFileNameDisplay(folder) &amp; " does not exist, creating it");
		folder.make();
	endif;
	
	folder.fileName := self.serverSourceDirectory;
	folder.usePresentationFileSystem := false;
	if not folder.isAvailable() then
		self.log("Directory " &amp; self.getFileNameDisplay(folder) &amp; " does not exist, creating it");
		folder.make();
	endif;
	
	// Once the server source directory is created, can generate the extract time method
	if not self.doUpdateExtractTime() then
		self.log("Unable to update release extract timestamp method, terminating");
		return false;
	endif;
	
	create foldersToExclude transient;
	foldersToExclude[1] := "HTML5";
	
	// If base directory has been provided, then copy this to both source and encrypted target directories
	if self.baseReleaseDirectory &lt;&gt; null then
		self.log("Copying files from " &amp; self.baseReleaseDirectory &amp; self.getFileTypeString(true) &amp; " to target directories");
		if not self.copyDirectoryExternal(self.baseReleaseDirectory, self.targetSourceDirectory, true) then
			self.log("Unable to copy files, terminating");
			return false;
		endif;
		
	endif;

	// If base JARI directory has been provided, then copy this to the JARI target directory
	if self.createJMTInstallFile then
		create mulFile transient;
		mulFile.usePresentationFileSystem := true;
		mulFile.openOutput(self.targetSourceDirectory &amp; "\schemas\PrdnSchema.mul");
		self.writeLineToFile(mulFile, "#MULTIPLE_SCHEMA_EXTRACT");
		
		create mulFileNonProd transient;
		mulFileNonProd.usePresentationFileSystem := true;
		mulFileNonProd.openOutput(self.targetSourceDirectory &amp; "\schemas\NonPrdnSchemas.mul");
		self.writeLineToFile(mulFileNonProd, "#MULTIPLE_SCHEMA_EXTRACT");
		
		create mulFileAll transient;
		mulFileAll.usePresentationFileSystem := true;
		mulFileAll.openOutput(self.targetSourceDirectory &amp; "\schemas\AllSchemas.mul");
		self.writeLineToFile(mulFileAll, "#MULTIPLE_SCHEMA_EXTRACT");
		
		create jmtInstallFile transient;
		jmtInstallFile.usePresentationFileSystem := true;
		jmtInstallFile.openOutput(self.targetSourceDirectory &amp; "\JMTInstall.txt");
		self.writeLineToFile(jmtInstallFile, "SET::SERVER::SINGLEUSER");
		self.writeLineToFile(jmtInstallFile, "JAPVER::" &amp; JAPVERSION);
		
		// 09/12/2016 cnwmh5 - Add creation of the Starter Database mul's
		create mulStarterLoad1 transient;        // Direct Copy of PrdnSchema.mul
		mulStarterLoad1.usePresentationFileSystem := true;
		mulStarterLoad1.openOutput(self.targetSourceDirectory &amp; "\schemas\StarterSchemaLoad1.mul");
		self.writeLineToFile(mulStarterLoad1, "#MULTIPLE_SCHEMA_EXTRACT");
		
		// 09/12/2016 cnwmh5 TFS3121 - Add creation of the Starter Database mul's
		create mulStarterLoad1Source transient;        // Skins &amp; DevSchema
		mulStarterLoad1Source.usePresentationFileSystem := true;
		mulStarterLoad1Source.openOutput(self.targetSourceDirectory &amp; "\schemas\StarterSchemaLoad1_Source.mul");
		self.writeLineToFile(mulStarterLoad1Source, "#MULTIPLE_SCHEMA_EXTRACT");
		self.writeLineToFile(mulStarterLoad1Source, '200JMT_Skins' &amp; versionStarterSkins &amp; '.scm' &amp; ' 200JMT_Skins' &amp; versionStarterSkins &amp; '.ddb');
		
		// 09/12/2016 cnwmh5 TFS3121 - Add creation of the Starter Database mul's
		create mulStarterLoadPatches transient;        // For any patches that are created
		mulStarterLoadPatches.usePresentationFileSystem := true;
		mulStarterLoadPatches.openOutput(self.targetSourceDirectory &amp; "\schemas\StarterSchemaLoad3_Patches.mul");
		self.writeLineToFile(mulStarterLoadPatches, "#MULTIPLE_SCHEMA_EXTRACT");
		
		// 09/12/2016 cnwmh5 TFS3121 - Add creation of the Starter Database mul's
		create mulStarterLoad2 transient;        // Reloading of PortSchema as errors occur 1st time and this sorts them out
		mulStarterLoad2.usePresentationFileSystem := true;
		mulStarterLoad2.openOutput(self.targetSourceDirectory &amp; "\schemas\StarterSchemaLoad2.mul");
		self.writeLineToFile(mulStarterLoad2, "#MULTIPLE_SCHEMA_EXTRACT");
		
		// Insert Preload lines
		if self.baseReleaseDirectory &lt;&gt; null then
			self.insertFileContents(jmtInstallFile, self.baseReleaseDirectory  &amp; "\" &amp; PreLoadFile, true);
		endif;
	endif;
	
	extractFolder := self.serverSourceDirectory &amp; "/";

	// Set up the list of schemas to be extracted here
	create schemaNames transient;
	
	if self.extractSingleSchema then
		schemaNames.add(self.schemaToExtract);
	else
		create schemaColl transient;
		rootSchema.allSubschemas(schemaColl);
		
		foreach schema in schemaColl do
			if schema.name.length &gt; 4 and
			   schema.name[1:4] = "Jade" then		// Add any schemas to be skipped from the extract here
				continue;
			endif;
			
			schemaNames.add(schema.name);
		endforeach;
	endif;
	
	// Validation check - ensure all encrypted schemas are valid and included in the main list of schemas
	if self.extractAllSchemas then 
		self.log("Starting full schema extracts of " &amp; schemaNames.concatenate(" "));
	elseif self.extractSingleSchema then
		self.log("Starting single schema extract of " &amp; self.schemaToExtract);
	endif;
	
	// Now extract each of them both encrypted and unencrypted, and copy them to the target directories
	foreach schemaName in schemaNames do
		deferDDBLoad := false;
		
		seq := 100;
		
		if self.schemaNeedsDeferredDDBLoad(schemaName) then
			ddbSeq := seq + 1;
			deferDDBLoad := true;
		else
			ddbSeq := seq;
		endif;
		
		if self.extractAllSchemas or 
		   seq &gt; 100 or 
		   schemaName = "DevSchema" or
		   schemaName = "JMTUnitTest" or
		   schemaName = "TestingDataLoadSchema" or
		   schemaName = "JRWDocSchema" or
		   (schemaName.length &gt; 3 and schemaName[1:3] = "Jtd") then
		   
			seqStr := seq.cnEcPad(2);
			ddbSeqStr := ddbSeq.cnEcPad(2);
			
			partSchemaFileName := seqStr &amp; schemaName &amp; self.versionString;
			partDDBFileName := ddbSeqStr &amp; schemaName &amp; self.versionString;
			
			scmFile := extractFolder &amp; partSchemaFileName &amp; ".scm";
			ddbFile := extractFolder &amp; partDDBFileName &amp; ".ddb";
			self.runSchemaExtractCommand("Single " &amp; scmFile &amp; " " &amp; ddbFile &amp; " " &amp; schemaName);
			self.removeJCFRef(scmFile, false);
			
			self.copyFile(scmFile, false, self.targetSourceDirectory &amp; "\schemas\" &amp; partSchemaFileName &amp; ".scm", true);
			self.removeFileName(scmFile, false);
			self.copyFile(ddbFile, false, self.targetSourceDirectory &amp; "\schemas\" &amp; partDDBFileName &amp; ".ddb", true);
			self.removeFileName(ddbFile, false);
			
			// 09/12/2016 cnwmh5 TFS3121
			if schemaName = "DevSchema" then
				self.writeLineToFile(mulStarterLoad1Source, partSchemaFileName &amp; '.scm' &amp; ' ' &amp; partDDBFileName &amp; '.ddb');
			endif;
			
		endif;
		
	endforeach;	
	
	if self.createJMTInstallFile then
		// And now add all non-release schemas if we have extracted them all
		if self.extractAllSchemas then
			foreach schemaName in schemaNames do
				if schemaName[1:3] &lt;&gt; "RJS" then //cnwrs1 May 2009 cause problems reloading
					partSchemaFileName := "100" &amp; schemaName &amp; self.versionString;
					if self.schemaNeedsDeferredDDBLoad(schemaName) then
						partDDBFileName := "101" &amp; schemaName &amp; self.versionString;
					else
						partDDBFileName := partSchemaFileName;
					endif;
					self.writeLineToFile(mulFileAll, partSchemaFileName &amp; '.scm' &amp; ' ' &amp; partDDBFileName &amp; '.ddb');
					self.writeLineToFile(mulFileNonProd, partSchemaFileName &amp; '.scm' &amp; ' ' &amp; partDDBFileName &amp; '.ddb');
					
					// 09/12/2016 cnwmh5 TFS3121
					if schemaName = "DevSchema" then
						self.writeLineToFile(mulStarterLoad1Source, partSchemaFileName &amp; '.scm' &amp; ' ' &amp; partDDBFileName &amp; '.ddb');
					endif;
					
				endif;
			endforeach;
		endif;	
	endif;
	
	self.log("Full schema extracts complete");

	seq := 100;
	seqStr := seq.cnEcPad(2);
	
	rwaFile := seqStr &amp; "allJRW_" &amp; self.versionString;
	
	// Insert PreUpgrade lines into JMTInstall file
	if self.createJMTInstallFile then
		// JAP Installer 2.0.0 now sets the replaceReportView option to true
		jmtInstallFile.writeLine("RWA::" &amp; rwaFile &amp; "::REQ::NOERRORS");
		
		// Until the default is changed in JAPInstaller, need to specifically set replaceReportView to true to ensure load is correct
		// PAR #30760 - Quoted all the file names to correctly handle embedded spaces in file names
		//self.writeLineToFile(jmtInstallFile, 'JMTGEN::"%BINDIR%\jadloadb.exe" path="%DBPATH%" ini="%INIFILE%" reportLoadAllFile="%INSTALLDIR%\schemas\' &amp; rwaFile &amp; '.rwa" server=SINGLEUSER reportReplaceView=true::NOERRORS');
		
		if self.baseReleaseDirectory &lt;&gt; null then
			self.insertFileContents(jmtInstallFile, self.baseReleaseDirectory  &amp; "\" &amp; PreUpgradeFile, true);
		endif;
		
		// 23/03/2016 KPD - Need to copy any new binaries in place before running JMTRelease and JMTPatchRelease
		self.writeLineToFile(jmtInstallFile, 'JMTGEN::XCOPY "%INSTALLDIR%\bin\*.*" "%BINDIR%" /S /Y /EXCLUDE:%INSTALLDIR%\XCOPY_exclude.txt::NOERRORS');
		
		self.writeLineToFile(jmtInstallFile, "JMTMAJOR::" &amp; self.versionString[1:2] &amp; "." &amp; self.versionString[3] &amp; "." &amp; self.versionString[4:2] &amp; "::NOERRORS");
		
		// KPD 14/03/2014 - Added quotes to EXCLUDE file names to correctly handle embedded spaces in file names
		// jlgmd1 07/12/2017 - Moved Documentation into JMTInstall_preSchemaCheck.txt file instead (So the new report markers can go above it 
		//jmtInstallFile.writeLine('JMTGEN::XCOPY "%INSTALLDIR%\documentation\*.*" "%BINDIR%\..\Documentation\" /S /Y /EXCLUDE:%INSTALLDIR%\XCOPY_exclude.txt::NOERRORS');
	
		// Insert PreSchemaCheck lines
		if self.baseReleaseDirectory &lt;&gt; null then
			self.insertFileContents(jmtInstallFile, self.baseReleaseDirectory  &amp; "\" &amp; PreCheckFile, true);
		endif;	
		
		self.writeLineToFile(jmtInstallFile, "SCMCHK::NOERRORS");
		self.writeLineToFile(jmtInstallFile, "REM::All Done");
		
		if jmtInstallFile.isAvailable() then
			// If the network becomes unavailable right at this time, the entire extract blows up
			jmtInstallFile.close();
		endif;
		
	endif;

	// If base directory has been provided, then remove some unneeded files (on the assumption that the external file copy have finished by now)
	if self.baseReleaseDirectory &lt;&gt; null then
		
		// Remove any copied JMTInstall insert files from the target, as these are not required
		self.removeFileName(self.targetSourceDirectory &amp; "\" &amp; PreLoadFile, true);
		self.removeFileName(self.targetSourceDirectory &amp; "\" &amp; PreUpgradeFile, true);
		self.removeFileName(self.targetSourceDirectory &amp; "\" &amp; PreCheckFile, true);
		
		if self.extractEncryptedSchemas then			
			// Remove any copied JMTInstall insert files from the target, as these are not required
			self.removeFileName(self.targetEncryptedDirectory &amp; "\" &amp; PreLoadFile, true);
			self.removeFileName(self.targetEncryptedDirectory &amp; "\" &amp; PreUpgradeFile, true);
			self.removeFileName(self.targetEncryptedDirectory &amp; "\" &amp; PreCheckFile, true);
		endif;
	endif;
	
	// All good to here, so remove the temporary release directory on the server
	self.clearDirectory(self.serverReleaseDirectory, false, true);
	self.removeDirectoryName(self.serverReleaseDirectory, false);		// KPD 24/09/2014
	
	message:= "Finished";
	isOk := true;
	
epilog
	if self.resultEmailAddress &lt;&gt; null then
		self.log('Sending email to ' &amp; self.resultEmailAddress);
		command := 'c:\Cardinal\bin\blat.exe';
		create args transient;
		args.add('-');
		args.add('-to');
		args.add(self.resultEmailAddress);
		args.add('-s');
		args.add('"Release extract from ' &amp; app.getJadeInstallDirAppServer &amp; '"');
		args.add('-body');
		args.add('"Release extract completed; message is ' &amp; message &amp; '"');
		dir := null;
		result1 := node.createExternalProcess(dir, command, args, null, false, true, result2);
		if result1 &lt;&gt; Node.ExternalProcess_Successful or result2 &lt;&gt; 0 then
			self.log('Possible problem with email, result1: ' &amp; result1.String &amp; ', result2: ' &amp; result2.String);
		endif;
	endif;
	
	delete args;
	delete schemaNames;
	delete folder;
	if message &lt;&gt; null then
		self.log(message);
	endif;
	delete mulFile;
	delete mulFileNonProd;
	delete mulFileAll;
	delete jmtInstallFile;
	delete jariLiveAppUpgradeFile;
	delete unlFile;
	delete schemaColl;
	delete mulStarterLoad1;				
	delete mulStarterLoad1Source;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doExtractWSDLChanges" id="0f59eae3-3d9d-4d45-9705-d343661528ab">
        <source>doExtractWSDLChanges(_update : Boolean) : Boolean;
/*

Purpose:			Compares the current WSDL classes/objects with what they were at the time of the last cut, and outputs the differences

Parameters:			

Return Value:		true if successful

Date			Who		Reason
07 May 2019		jlgmd1	Initial creation - TFS 39667 - API Documentation

*/

constants
	WSSchemaName	: String = "WebServicesSchema";
	ProviderName	: String = "WS_WebServiceProvider";
	IFName			: String = "WS_InterfaceObject";
	PxyName			: String = "WS_ProxyObject";
	IFRequest		: String = "WS_Request";
	IFResponse		: String = "WS_Response";
vars
	oa 						: ObjectArray;
	previousWSDLClasses		: DEV_REOWsdlClassDict;
	allBaseFeatures			: HugeStringArray;
	allClasses,
	subClasses				: ClassColl;	
	allSchemas				: SchemaColl;
	schema,
	wsSchema				: Schema;
	checkTS					: TimeStamp;
	wsClass,
	wsSubClass				: Class;
	allChangedClasses,
	allNewClasses			: DEV_REOWsdlClassDict;
	isOk,
	checkMethods,
	checkClasses,
	checkAttributes,
	isNewClass				: Boolean;
	newWsdlClass,
	prevWsdlClass,
	pxyWsdlClass,
	parentWsdlClass			: DEV_REOWsdlClass;
	wsdlClassByOidDict		: DynaDictionary;
	obj						: Object;
begin
		// First run needs to set these up
		create allBaseFeatures transient;
		allBaseFeatures.add(ProviderName);
		allBaseFeatures.add(IFName);
		allBaseFeatures.add(PxyName);
		self.checkBaseWSDLFeatures(allBaseFeatures);
		
		// Get our WSDL Classes from last time (if we have any)
		create oa transient;
		DEV_REOWsdlClass.allInstances(oa, 0, false);
		create previousWSDLClasses transient;
		oa.copy(previousWSDLClasses);

		// Grab the Webservices schema
		create allSchemas transient;
		rootSchema.allSubschemas(allSchemas);
		foreach schema in allSchemas do
			if schema.name = WSSchemaName then
				wsSchema := schema;
				break;
			endif;
		endforeach;
		
		if wsSchema = null then
			write "Error, unable to find " &amp; WSSchemaName &amp; " schema.";
			return false;
		endif;
		
		// Only used during initial setup, this shouldn't normally be used. (Unless this is has to be re-run after the cut)
		//checkTS := "20/03/2019 15:00:00".TimeStamp;
		
		create allChangedClasses transient;
		create allNewClasses transient;
		
		create wsdlClassByOidDict transient;
		wsdlClassByOidDict.setMembership(DEV_REOWsdlClass);
		wsdlClassByOidDict.addMemberKey(DEV_REOWsdlClass::oidAsBin.name, false, false);
		wsdlClassByOidDict.endKeys(false);
		
		// Now go through all the classes in the WebServicesSchema
		allClasses := wsSchema.getAllClasses(false);
		foreach wsClass in allClasses do
			// Check WS_WebServiceProvider for any new methods
			// Check WS_InterfaceObject for new classes/attributes
			// Check WS_ProxyObject for new classes/attributes
			if wsClass.name = ProviderName or wsClass.name = IFName or wsClass.name = PxyName then
				create subClasses transient;
				wsClass.withAllSubclasses(subClasses);
				
				// Work out what we should check for
				checkMethods 	:= (wsClass.name = ProviderName);
				checkClasses 	:= (wsClass.name = IFName or wsClass.name = PxyName or wsClass.name = ProviderName);
				checkAttributes := (wsClass.name = IFName or wsClass.name = PxyName or wsClass.name = ProviderName);
				
				foreach wsSubClass in subClasses do
					// withAllSubclasses adds the wsClass into the collection too, so lets skip it
					if wsSubClass = wsClass then
						continue;
					endif;
					
					// Check for new classes
					if checkClasses then
						self.lookForNewWSDLClasses(wsSubClass, checkTS, previousWSDLClasses, allNewClasses, isNewClass);
						if isNewClass then
							// If this is an entire new class, then no point also checking for new attributes
							continue;
						endif;
					endif;
					
					// Check for new/removed methods
					if checkMethods then
						self.lookForNewWSDLMethods(wsSubClass, checkTS, previousWSDLClasses, allChangedClasses);
					endif;
					
					// Check for new/removed attributes
					if checkAttributes then
						self.lookForNewWSDLAttributes(wsSubClass, checkTS, previousWSDLClasses, allChangedClasses);
					endif;
				endforeach;
				
				delete subClasses;
			endif;
		endforeach;
		
		// Check for removed classes
		// TODO, need to keep track of what ones we've been through...
		// although, probably a difference between allClasses and previousWSDLClasses might suffice
		
		// Check for reparented classes, and move them to the changed collection
		foreach newWsdlClass in allNewClasses do
			prevWsdlClass := previousWSDLClasses[newWsdlClass.name];
			if prevWsdlClass &lt;&gt; null then
				allNewClasses.remove(newWsdlClass);
				allChangedClasses.add(newWsdlClass);
			endif;
		endforeach;
		
		// Now that we know whats changed, lets do something with it
		// print me ?
		// generate a nice html file
		// Use Helens css ?
		
		self.writeWSDLChangesDoc(allNewClasses, allChangedClasses, previousWSDLClasses, wsSchema);
		
		// Lastly convert our transient copies to persistent ones
		if _update then
			beginTransaction;
			
			foreach pxyWsdlClass in allChangedClasses do
				prevWsdlClass := previousWSDLClasses[pxyWsdlClass.name];
				prevWsdlClass.updateFromProxy(pxyWsdlClass);
			endforeach;
			
			// The order matters here, so lets go through starting with the lowest oid
			allNewClasses.copy(wsdlClassByOidDict);
			foreach obj in wsdlClassByOidDict do
				pxyWsdlClass := obj.DEV_REOWsdlClass;
				
				create newWsdlClass persistent;
				
				// Grab the real parent, not the transient proxy
				parentWsdlClass := previousWSDLClasses[pxyWsdlClass.myParent.name];
				
				newWsdlClass.set(pxyWsdlClass.name, parentWsdlClass);
				newWsdlClass.updateFromProxy(pxyWsdlClass);
				
				// Add our new real class to the list of existing ones
				previousWSDLClasses.add(newWsdlClass);
			endforeach;
			
			commitTransaction;
		endif;
		isOk := true;
		
		return isOk;
epilog
	if not isOk then
		abortTransaction;
	endif;

	delete oa;
	delete previousWSDLClasses;	
	delete allBaseFeatures;
	delete allClasses;
	delete allSchemas;
	delete subClasses;
	
	if allChangedClasses &lt;&gt; null then
		allChangedClasses.purge();
	endif;
	delete allChangedClasses;
	
	if allNewClasses &lt;&gt; null then
		allNewClasses.purge();
	endif;
	delete allNewClasses;
	delete wsdlClassByOidDict;
	
	app.cnCheckForTransients();
end;</source>
        <Parameter name="_update" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doReleaseExtract" id="a818c8be-7611-4722-8caf-d21e1a5ef013">
        <updating/>
        <source>doReleaseExtract() : Boolean updating;
/*

Purpose:			Initiate the release extract process

Return Value:		None

Date		Who		Reason
04 Nov 2011	cnwkpd1	CCMS SFW 1223 - Prototyping code for new Release Mechanism
19 Nov 2012	cnwkpd1	PAR #30760 - Prevent install errors when install path has embedded spaces
22 Aug 2013	cnwkpd1	CCMS SFW 1347 - JADE 7 Deployment
29 Jan 2014	cnwkpd1	Fix potential issue overwriting binary files in a JARI deploy
10 Feb 2014	cnwrs1	Par 33405 - Change to only user Japinstller version 1.0.22
11 Mar 2014	cnwkpd1	Add quotes around EXCLUDE filenames to handle install directories with embedded spaces
24 Sep 2014	cnwkpd1	Add in delete of temporary server directory to tidy up
18 Mar 2015	cnwkpd1	As per request from JadeCare - JADE PAR #62383 requires the Web schemas to be loaded 
					separately from their DDB files, so we need to split them
07 Jul 2015	cnwkpd1	Change JARI creation to remove need for JAPInstaller
21 Jul 2015	cnwkpd1	Changes to work around JADE PAR #62383 for online deploy - need to defer Web schema ddb file loads to 
					post transition for an online deploy (live_app_upgrade.bat)
30 Jul 2015	cnwkpd1	Change to JARI file structure to mirror the JSM repository, and to build Unicode as well as ANSI
17 Sep 2015	cnwkpd1	Monthly releases - need an extract timestamp embedded in the release
15 Dec 2015	cnwkpd1	Added functionality to delete existing target directories instead of renaming (for daily release build process)
23 Mar 2016	cnwkpd1	Change order of binary file deploy to before running JMTRelease
23 May 2016	cnwkpd1	Make source extract of DevSchema and JMTUnitTest mandatory
09 Dec 2016	cnwmh5	Add creating of Starter Database mul's
07 Feb 2017	cnwmh5	Fix issue with skins and devschema no being created correctly in their mul
06 Sep 2017 jlgmd1  Don't rename release folders, if they only contain the web service documentation (as that tends to be created before the release extract)
07 Dec 2017 jlgmd1	Moved the JMTInstall Documentation copy line into the JMTInstall_preSchemaCheck.txt file in the base folder (So the new report markers can go above it)
13 Dec 2017 jlgmd1	Extract the benchmark schemas to keep them inline with each release
05/02/2018	jlgmh5	Make source extract of TestingDataLoadSchema mandatory
06 Mar 2018 jlgmd1	Renumbered the starter schemas (and swapped the load order of the patches)
15 Mar 2018 jlgmd1	Added the EDI XSD files to the extract
27 Jul 2019 jlgmd1	Offload the copying of the HTML5 folders to an external process to run in parallel with the extract
28 Nov 2018	jlgmd1	TFS 41422 replaced all writeLine statements with self.writeLineToFile to handle any network errors
29 Mar 2019 jlgmd1	Changed copy directory calls to use robocopy to be (a lot) faster and surrive brief network glitches
16 May 2019	jlgmd1	TFS 39667 Added new checkbox to extract the WSDL changes between releases
19 Sep 2019 jlgzm1	TFS 46543 app_upgrade.log created in wrong location
23 Oct 2019 jlgmd1	TFS 46972 changed the order of when the rwa is loaded by JAPInstaller to match JSM/managed customers
19 Nov 2019 jlgmd1	TFS 45294 Return false if there is an error in extracting the schemas
30 Jan 2020 jlgmd1	TFS 48378 Continue the cut even if the RWA extract fails - as it can be (re)generated later
02 Dec 2020 jlgmd1	TFS 50459 Add JRWDocSchema to the list of Dev schemas to extract
27 Apr 2021 navmd1	TFS 50447 Bump required JAPInstaller level to 2.1 to handle copying .net apps
05 Nov 2021 navmd1	TFS 51086 Bump required JAPInstaller level to 2.2 to handle JADE2020 _validateMethods changes
29 Nov 2021 navmd1	Change the live_app_upgrade version string to use the CM_Root version, rather than trying to recreate it here
19 Jan 2022 navmd1	Require JAPInstaller 2.3.0 to prevent issues copying .net files
25 Jan 2024 navmd1	Required JAPInstaller 2.4.0 to preview issues copying JADE hotfixes
30 May 2024 navmd1	Bumped JRW archive version number by an extra 4 places now that Web/WebExample scheams are disabled
*/

constants
	JAPVERSION		= "2.4.0";

	PreLoadFile		= "JMTInstall_preLoad.txt";
	PreUpgradeFile	= "JMTInstall_preUpgrade.txt";
	PreCheckFile	= "JMTInstall_preSchemaCheck.txt";
	LiveAppUpgrade	= "live_app_upgrade.bat";
	RunReleaseCommand	= "%env_binpath%\jade.exe path=%env_systempath% ini=%env_inifile% server=singleuser schema=PortSchema app=JMTRelease";
	RunPatchCommand		= "%env_binpath%\jade.exe path=%env_systempath% ini=%env_inifile% server=singleuser schema=PortSchema app=JMTPatchRelease endJade version=&lt;version&gt; patch=&lt;patch&gt;";
	RunDDBLoadCommand	= "%env_binpath%\jadloadb.exe path=%env_systempath% ini=%env_inifile% ddbFile='%env_miscpath%\&lt;ddbfile&gt;' loadStyle=onlyStructuralVersioning displayTimes=true";
	RunErrorLevelCheck = "if ERRORLEVEL 0 ( echo CompletedOK &gt; %env_logpath%\app_upgrade.log ) else ( echo UpgradeError &gt; %env_logpath%\app_upgrade.log )";
	
vars
	folder			: FileFolder;
	command,
	dir,
	message,
	extractFolder,
	encryptedFolder,
	schemaName,
	scmFile,
	ddbFile,
	partSchemaFileName,
	partDDBFileName	: String;
	args			: StringArray512;
	mandatoryEncryptedSchemas,
	schemaNames		: StringArray;
	result1,
	result2			: Integer;
	schema			: Schema;
	seq,
	ddbSeq,
	depth			: Integer;
	seqStr,
	ddbSeqStr		: String;
	mulStarterLoad1,
	mulStarterLoad1Source,
	mulStarterLoadPatches,
	mulStarterLoad2,
	mulFileAll,
	mulFileNonProd,
	unlFile,
	mulFile 		: File;
	jmtInstallFile 	: File;
	errorStr 		: String;
	schemaColl 		: SchemaColl;
	rwaFile			: String;
	jariSchemaFolder,
	jariMiscFolderAnsi,
	jariMiscFolderUnicode	: String;
	jariLiveAppUpgradeFile	: File;
	runPatch,
	runLoad			: String;
	version			: String;
	deferDDBLoad	: Boolean;
	versionStarterSkins : String;
	foldersToExclude : StringArray;
	isOk			: Boolean;
	jrwFile			: File;
	rwaMsg			: String;
	
begin
	// Now start extracts and file creation
	message:= "Error";
	
	//epr TFS 336 - Monthly Releases 27/5/15
	if self.isMonthlyExtract then
		self.extractSingleSchema:=false;
		
		if self.monthlyVersion = null then
			self.log("Monthy version is null");
			return false;
		endif;
		self.versionString:=app.myRoot.getVersionString &amp; self.monthlyVersion;
	else
		self.versionString:=app.myRoot.getVersionString;
	endif;
	versionStarterSkins := app.myRoot.getVersionString();				// 07/02/2017
	
	// Start by validating parameters and setting up internal directory names
	if not self.validateReleaseExtractParams() then
		return false;
	endif;
	
	// All parameters OK, so can start release
	
	// Begin by renaming any existing target directories so we don't overwrite them
	create folder transient;
	folder.fileName := self.targetSourceDirectory;
	folder.usePresentationFileSystem := true;
	if folder.isAvailable() and not self.onlyContainsWSDocumentation(folder, depth) then
		if self.deleteExistingTargetDir then
			self.log("Target source directory " &amp; self.getFileNameDisplay(folder) &amp; " already exists, deleting");
			self.clearDirectory(folder.fileName, folder.usePresentationFileSystem, true);
			self.removeDirectoryName(folder.fileName, folder.usePresentationFileSystem);
		else
			self.log("Target source directory " &amp; self.getFileNameDisplay(folder) &amp; " already exists, renaming");
			folder.rename(folder.fileName &amp; "_" &amp; folder.createdTime.getNumeralString());
		endif;
	
		// If folder is still available after rename, then the rename failed, so stop
		if folder.isAvailable() then
			self.log("Unable to rename/remove directory " &amp; self.getFileNameDisplay(folder) &amp; ", terminating");
			return false;
		endif;
	endif;
	
	if self.extractEncryptedSchemas then
		folder.fileName := self.targetEncryptedDirectory;
		folder.usePresentationFileSystem := true;
		if folder.isAvailable() and not self.onlyContainsWSDocumentation(folder, depth) then
			if self.deleteExistingTargetDir then
				self.log("Target encrypted directory " &amp; self.getFileNameDisplay(folder) &amp; " already exists, deleting");
				self.clearDirectory(folder.fileName, folder.usePresentationFileSystem, true);
				self.removeDirectoryName(folder.fileName, folder.usePresentationFileSystem);
			else
				self.log("Target encrypted directory " &amp; self.getFileNameDisplay(folder) &amp; " already exists, renaming");
				folder.rename(folder.fileName &amp; "_" &amp; folder.createdTime.getNumeralString());
			endif;
		
			// If folder is still available after rename, then the rename failed, so stop
			if folder.isAvailable() then
				self.log("Unable to rename/remove directory " &amp; self.getFileNameDisplay(folder) &amp; ", terminating");
				return false;
			endif;
		endif;
	endif;

	if self.createJARIRelease then
		folder.fileName := self.targetJARIDirectory;
		folder.usePresentationFileSystem := true;
		if folder.isAvailable() and not self.onlyContainsWSDocumentation(folder, depth) then
			if self.deleteExistingTargetDir then
				self.log("Target JARI directory " &amp; self.getFileNameDisplay(folder) &amp; " already exists, deleting");
				self.clearDirectory(folder.fileName, folder.usePresentationFileSystem, true);
				self.removeDirectoryName(folder.fileName, folder.usePresentationFileSystem);
			else
				self.log("Target JARI directory " &amp; self.getFileNameDisplay(folder) &amp; " already exists, renaming");
				folder.rename(folder.fileName &amp; "_" &amp; folder.createdTime.getNumeralString());
			endif;
			
			// If folder is still available after rename, then the rename failed, so stop
			if folder.isAvailable() then
				self.log("Unable to rename/remove directory " &amp; self.getFileNameDisplay(folder) &amp; ", terminating");
				return false;
			endif;
		endif;
	endif;
	
	// Start by creating any required directories that do not exist
	folder.fileName := self.targetSourceDirectory &amp; "\schemas";
	folder.usePresentationFileSystem := true;
	if not folder.isAvailable() then
		self.log("Directory " &amp; self.getFileNameDisplay(folder) &amp; " does not exist, creating it");
		folder.make();
	endif;
	
	folder.fileName := self.serverSourceDirectory;
	folder.usePresentationFileSystem := false;
	if not folder.isAvailable() then
		self.log("Directory " &amp; self.getFileNameDisplay(folder) &amp; " does not exist, creating it");
		folder.make();
	endif;
	
	// Once the server source directory is created, can generate the extract time method
	if not self.doUpdateExtractTime() then
		self.log("Unable to update release extract timestamp method, terminating");
		return false;
	endif;
	
	if self.extractEncryptedSchemas then
		folder.fileName := self.targetEncryptedDirectory &amp; "\schemas";
		folder.usePresentationFileSystem := true;
		if not folder.isAvailable() then
			self.log("Directory " &amp; self.getFileNameDisplay(folder) &amp; " does not exist, creating it");
			folder.make();
		endif;
		folder.fileName := self.serverEncryptedDirectory;
		folder.usePresentationFileSystem := false;
		if not folder.isAvailable() then
			self.log("Directory " &amp; self.getFileNameDisplay(folder) &amp; " does not exist, creating it");
			folder.make();
		endif;
	endif;
	
	if self.createJARIRelease then
		jariSchemaFolder := self.targetJARIDirectory &amp; "\SchemaFiles";
		jariMiscFolderAnsi := self.targetJARIDirectory &amp; "\ansi\x64-msoft-win64\server\misc";
		jariMiscFolderUnicode := self.targetJARIDirectory &amp; "\unicode\x64-msoft-win64\server\misc";
		
		folder.fileName := jariSchemaFolder;
		folder.usePresentationFileSystem := true;
		if not folder.isAvailable() then
			self.log("Directory " &amp; self.getFileNameDisplay(folder) &amp; " does not exist, creating it");
			folder.make();
		endif;

		folder.fileName := jariMiscFolderAnsi;
		folder.usePresentationFileSystem := true;
		if not folder.isAvailable() then
			self.log("Directory " &amp; self.getFileNameDisplay(folder) &amp; " does not exist, creating it");
			folder.make();
		endif;

		folder.fileName := jariMiscFolderUnicode;
		folder.usePresentationFileSystem := true;
		if not folder.isAvailable() then
			self.log("Directory " &amp; self.getFileNameDisplay(folder) &amp; " does not exist, creating it");
			folder.make();
		endif;

	endif;
	
	create foldersToExclude transient;
	foldersToExclude[1] := "HTML5";
	
	// If base directory has been provided, then copy this to both source and encrypted target directories
	if self.baseReleaseDirectory &lt;&gt; null then
		self.log("Copying files from " &amp; self.baseReleaseDirectory &amp; self.getFileTypeString(true) &amp; " to target directories");
		if not self.copyDirectoryExternal(self.baseReleaseDirectory, self.targetSourceDirectory, true) then
			self.log("Unable to copy files, terminating");
			return false;
		endif;
		
		if self.extractEncryptedSchemas then
			if not self.copyDirectoryExternal(self.baseReleaseDirectory, self.targetEncryptedDirectory, true) then
				self.log("Unable to copy files, terminating");
				return false;
			endif;
		endif;
	endif;

	// If base JARI directory has been provided, then copy this to the JARI target directory
	if self.baseJARIDirectory &lt;&gt; null then
		self.log("Copying files from " &amp; self.baseJARIDirectory &amp; self.getFileTypeString(true) &amp; " to JARI target directory");
		if not self.copyDirectoryExternal(self.baseJARIDirectory, self.targetJARIDirectory, true) then
			self.log("Unable to copy files, terminating");
			return false;
		endif;
	endif;
	
	if self.createJMTInstallFile then

		create mulFile transient;
		mulFile.usePresentationFileSystem := true;
		mulFile.openOutput(self.targetSourceDirectory &amp; "\schemas\PrdnSchema.mul");
		self.writeLineToFile(mulFile, "#MULTIPLE_SCHEMA_EXTRACT");
	
		create mulFileNonProd transient;
		mulFileNonProd.usePresentationFileSystem := true;
		mulFileNonProd.openOutput(self.targetSourceDirectory &amp; "\schemas\NonPrdnSchemas.mul");
		self.writeLineToFile(mulFileNonProd, "#MULTIPLE_SCHEMA_EXTRACT");
	
		create mulFileAll transient;
		mulFileAll.usePresentationFileSystem := true;
		mulFileAll.openOutput(self.targetSourceDirectory &amp; "\schemas\AllSchemas.mul");
		self.writeLineToFile(mulFileAll, "#MULTIPLE_SCHEMA_EXTRACT");

		create jmtInstallFile transient;
		jmtInstallFile.usePresentationFileSystem := true;
		jmtInstallFile.openOutput(self.targetSourceDirectory &amp; "\JMTInstall.txt");
		self.writeLineToFile(jmtInstallFile, "SET::SERVER::SINGLEUSER");
		self.writeLineToFile(jmtInstallFile, "JAPVER::" &amp; JAPVERSION);
		
		// 09/12/2016 cnwmh5 - Add creation of the Starter Database mul's
		create mulStarterLoad1 transient;        // Direct Copy of PrdnSchema.mul
		mulStarterLoad1.usePresentationFileSystem := true;
		mulStarterLoad1.openOutput(self.targetSourceDirectory &amp; "\schemas\StarterSchemaLoad1.mul");
		self.writeLineToFile(mulStarterLoad1, "#MULTIPLE_SCHEMA_EXTRACT");
		
		// 09/12/2016 cnwmh5 TFS3121 - Add creation of the Starter Database mul's
		create mulStarterLoad1Source transient;        // Skins &amp; DevSchema
		mulStarterLoad1Source.usePresentationFileSystem := true;
		mulStarterLoad1Source.openOutput(self.targetSourceDirectory &amp; "\schemas\StarterSchemaLoad1_Source.mul");
		self.writeLineToFile(mulStarterLoad1Source, "#MULTIPLE_SCHEMA_EXTRACT");
		self.writeLineToFile(mulStarterLoad1Source, '200JMT_Skins' &amp; versionStarterSkins &amp; '.scm' &amp; ' 200JMT_Skins' &amp; versionStarterSkins &amp; '.ddb');
		
		// 09/12/2016 cnwmh5 TFS3121 - Add creation of the Starter Database mul's
		create mulStarterLoadPatches transient;        // For any patches that are created
		mulStarterLoadPatches.usePresentationFileSystem := true;
		mulStarterLoadPatches.openOutput(self.targetSourceDirectory &amp; "\schemas\StarterSchemaLoad3_Patches.mul");
		self.writeLineToFile(mulStarterLoadPatches, "#MULTIPLE_SCHEMA_EXTRACT");
		
		// 09/12/2016 cnwmh5 TFS3121 - Add creation of the Starter Database mul's
		create mulStarterLoad2 transient;        // Reloading of PortSchema as errors occur 1st time and this sorts them out
		mulStarterLoad2.usePresentationFileSystem := true;
		mulStarterLoad2.openOutput(self.targetSourceDirectory &amp; "\schemas\StarterSchemaLoad2.mul");
		self.writeLineToFile(mulStarterLoad2, "#MULTIPLE_SCHEMA_EXTRACT");
		
		//epr TFS 336 - Monthly Releases
		if self.isMonthlyExtract then
			self.writeLineToFile(jmtInstallFile, "JAPCHECKPATCH::" &amp; app.myRoot.versionString  &amp; "::-" &amp; self.monthlyVersion &amp;  "::NOERRORS");
		endif;
		
		// Insert Preload lines
		if self.baseReleaseDirectory &lt;&gt; null then
			self.insertFileContents(jmtInstallFile, self.baseReleaseDirectory  &amp; "\" &amp; PreLoadFile, true);
		endif;
	endif;
	
	if self.createJARIRelease then
		// create the live_app_upgrade.bat file to do any deferred DDB loads and run the JMTRelease app
		create jariLiveAppUpgradeFile transient;
		jariLiveAppUpgradeFile.usePresentationFileSystem := true;
		jariLiveAppUpgradeFile.openOutput(jariMiscFolderAnsi &amp; "\" &amp; LiveAppUpgrade);
	endif;
	
	extractFolder := self.serverSourceDirectory &amp; "/";
	if self.extractEncryptedSchemas &lt;&gt; null then
		encryptedFolder := self.serverEncryptedDirectory &amp; "/";
	endif;

	// Set up the list of schemas to be extracted here
	create schemaNames transient;
	
	if self.extractSingleSchema then
		schemaNames.add(self.schemaToExtract);
	else
		create schemaColl transient;
		rootSchema.allSubschemas(schemaColl);
		
		foreach schema in schemaColl do
			if schema.name.length &gt; 4 and
			   schema.name[1:4] = "Jade" then		// Add any schemas to be skipped from the extract here
				continue;
			endif;
			
			schemaNames.add(schema.name);
		endforeach;
	endif;
	
	// Set up the list of schemas which, if they are extracted (i.e. they are included in 'schemas'), must also have 
	// an encrypted version extracted
	create mandatoryEncryptedSchemas transient;
	self.getReleaseSchemas(mandatoryEncryptedSchemas);
	
	// Validation check - ensure all encrypted schemas are valid and included in the main list of schemas
	if not self.extractSingleSchema then
		foreach schemaName in mandatoryEncryptedSchemas do
			if not schemaNames.includes(schemaName) then
				self.log("Error: Encrypted schema " &amp; schemaName &amp; " is not included in the list of schemas");
				return false;
			endif;
		endforeach;
	endif;
	
	if self.extractAllSchemas then 
		self.log("Starting full schema extracts of " &amp; schemaNames.concatenate(" "));
	elseif self.extractSingleSchema then
		self.log("Starting single schema extract of " &amp; self.schemaToExtract);
	else
		self.log("Starting full schema extracts of " &amp; mandatoryEncryptedSchemas.concatenate(" "));
	endif;
	
	// Now extract each of them both encrypted and unencrypted, and copy them to the target directories
	foreach schemaName in schemaNames do
	
		deferDDBLoad := false;
	
		seq := 100 + mandatoryEncryptedSchemas.indexOf(schemaName)*2;
		
		if self.schemaNeedsDeferredDDBLoad(schemaName) then
			ddbSeq := seq + 1;
			deferDDBLoad := true;
		else
			ddbSeq := seq;
		endif;
		
		if self.extractAllSchemas or 
		   seq &gt; 100 or 
		   schemaName = "DevSchema" or
		   schemaName = "JMTUnitTest" or
		   schemaName = "TestingDataLoadSchema" or
		   schemaName = "JRWDocSchema" or
		   (schemaName.length &gt; 3 and schemaName[1:3] = "Jtd") then
		   
		   self.log("Starting Extract for " &amp; schemaName);
		   
			seqStr := seq.cnEcPad(2);
			ddbSeqStr := ddbSeq.cnEcPad(2);
			
			partSchemaFileName := seqStr &amp; schemaName &amp; self.versionString;
			partDDBFileName := ddbSeqStr &amp; schemaName &amp; self.versionString;
			
			scmFile := extractFolder &amp; partSchemaFileName &amp; ".scm";
			ddbFile := extractFolder &amp; partDDBFileName &amp; ".ddb";
			self.runSchemaExtractCommand("Single " &amp; scmFile &amp; " " &amp; ddbFile &amp; " " &amp; schemaName);
			self.removeJCFRef(scmFile, false);
			
			self.copyFile(scmFile, false, self.targetSourceDirectory &amp; "\schemas\" &amp; partSchemaFileName &amp; ".scm", true);
			self.removeFileName(scmFile, false);
			self.copyFile(ddbFile, false, self.targetSourceDirectory &amp; "\schemas\" &amp; partDDBFileName &amp; ".ddb", true);
			self.removeFileName(ddbFile, false);
			
			// 09/12/2016 cnwmh5 TFS3121
			if schemaName = "DevSchema" then
				self.writeLineToFile(mulStarterLoad1Source, partSchemaFileName &amp; '.scm' &amp; ' ' &amp; partDDBFileName &amp; '.ddb');
			endif;
			
			if encryptedFolder &lt;&gt; null then
				if mandatoryEncryptedSchemas.includes(schemaName) then
					scmFile := encryptedFolder &amp; seqStr &amp; schemaName &amp; self.versionString &amp; ".scm";
					ddbFile := encryptedFolder &amp; ddbSeqStr &amp; schemaName &amp; self.versionString &amp; ".ddb";
					self.runSchemaExtractCommand("Single " &amp; scmFile &amp; " " &amp; ddbFile &amp; " " &amp; schemaName &amp; ' "&lt;encrypt&gt;"');
					self.removeJCFRef(scmFile, false);
					
					self.copyFile(scmFile, false, self.targetEncryptedDirectory &amp; "\schemas\" &amp; partSchemaFileName &amp; ".scm", true);
					self.copyFile(ddbFile, false, self.targetEncryptedDirectory &amp; "\schemas\" &amp; partDDBFileName &amp; ".ddb", true);

					if self.createJARIRelease then
						self.copyFile(scmFile, false, jariSchemaFolder &amp; "\" &amp; partSchemaFileName &amp; ".scm", true);
						
						// If the DDB load needs to be deferred, then copy the DDB file to the misc folder instead of the schema folder
						if deferDDBLoad then
							self.copyFile(ddbFile, false, jariMiscFolderAnsi &amp; "\" &amp; partDDBFileName &amp; ".ddb", true);
							self.copyFile(ddbFile, false, jariMiscFolderUnicode &amp; "\" &amp; partDDBFileName &amp; ".ddb", true);
							runLoad := RunDDBLoadCommand;
							runLoad := runLoad.replace("&lt;ddbfile&gt;", partDDBFileName &amp; ".ddb");
							self.writeLineToFile(jariLiveAppUpgradeFile, runLoad);
						else
							self.copyFile(ddbFile, false, jariSchemaFolder &amp; "\" &amp; partDDBFileName &amp; ".ddb", true);
						endif;
					endif;
					
					self.removeFileName(scmFile, false);
					self.removeFileName(ddbFile, false);
				endif;
			endif;
		endif;
		
	endforeach;

	if self.createJARIRelease then
		self.writeLineToFile(jariLiveAppUpgradeFile, RunReleaseCommand);
		self.writeLineToFile(jariLiveAppUpgradeFile, RunErrorLevelCheck); // TFS 46543
	
		//epr TFS 336 - Monthly Releases 27/5/15
		if self.isMonthlyExtract then
			// If it's a monthly release then run the patch app as well
			runPatch := RunPatchCommand;
			
			//version := self.versionString[1] &amp; "." &amp; self.versionString[2] &amp; "." &amp; self.versionString[3];
			// self.versionString is just the concacenation of the system major version and the user-entered monthly one
			// As we only want the major version here, just use the system one instead, to get the dots in the right place!
			version := app.myRoot.versionString;
			
			runPatch := runPatch.replace("&lt;version&gt;", version);
			runPatch := runPatch.replace("&lt;patch&gt;", self.monthlyVersion);
			
			self.writeLineToFile(jariLiveAppUpgradeFile, runPatch);
		endif;	
	
		if jariLiveAppUpgradeFile.isAvailable() then
			// If the network becomes unavailable right at this time, the entire extract blows up
			jariLiveAppUpgradeFile.close();
		endif;
		
		self.copyFile(jariMiscFolderAnsi &amp; "\" &amp; LiveAppUpgrade, true, jariMiscFolderUnicode &amp; "\" &amp; LiveAppUpgrade, true);
		
	endif;	
	
	if self.createJMTInstallFile then
		foreach schemaName in mandatoryEncryptedSchemas do
			errorStr := "NOERRORS";
			if schemaName = "PortSchema" or
			   schemaName = "BaseSchema" or
			   schemaName = "UiCommonSchema" or 
			   schemaName = "MobileServerSchema" or 
			   schemaName = "LogSchema" or 
			   schemaName = "WebSchema" or 
			   schemaName = "JMMobileClientBaseSchema" or
			   schemaName = "JSSCoreSchema" then
				errorStr := "ERRORSOK";
			endif;
			seq := 100 + mandatoryEncryptedSchemas.indexOf(schemaName)*2;
			if self.schemaNeedsDeferredDDBLoad(schemaName) then
				ddbSeq := seq + 1;
			else
				ddbSeq := seq;
			endif;
			seqStr := seq.cnEcPad(2);
			ddbSeqStr := ddbSeq.cnEcPad(2);
			
			partSchemaFileName := seqStr &amp; schemaName &amp; self.versionString;
			partDDBFileName := ddbSeqStr &amp; schemaName &amp; self.versionString;
			
			self.writeLineToFile(mulFile, partSchemaFileName &amp; '.scm' &amp; ' ' &amp; partDDBFileName &amp; '.ddb');
			self.writeLineToFile(mulFileAll, partSchemaFileName &amp; '.scm' &amp; ' ' &amp; partDDBFileName &amp; '.ddb');
			self.writeLineToFile(mulStarterLoad1, partSchemaFileName &amp; '.scm' &amp; ' ' &amp; partDDBFileName &amp; '.ddb');	// 09/12/2016 cnwmh5 TFS3121
			
			// 09/12/2016 cnemh5 TFS3121
			if schemaName = "PortSchema" then
				self.writeLineToFile(mulStarterLoad2, partSchemaFileName &amp; '.scm' &amp; ' ' &amp; partDDBFileName &amp; '.ddb');
			endif;
			
			if partSchemaFileName = partDDBFileName then
				self.writeLineToFile(jmtInstallFile, 'SCMDDB::' &amp; partSchemaFileName &amp; '::REQ::' &amp; errorStr);
			else
				self.writeLineToFile(jmtInstallFile, 'SCM::' &amp; partSchemaFileName &amp; '::REQ::' &amp; errorStr);
				self.writeLineToFile(jmtInstallFile, 'DDB::' &amp; partDDBFileName &amp; '::REQ::' &amp; errorStr);
			endif;
		endforeach;

		// And now add all non-release schemas if we have extracted them all
		if self.extractAllSchemas then
			foreach schemaName in schemaNames where not mandatoryEncryptedSchemas.includes(schemaName) do
				if schemaName[1:3] &lt;&gt; "RJS" then //cnwrs1 May 2009 cause problems reloading
					partSchemaFileName := "100" &amp; schemaName &amp; self.versionString;
					if self.schemaNeedsDeferredDDBLoad(schemaName) then
						partDDBFileName := "101" &amp; schemaName &amp; self.versionString;
					else
						partDDBFileName := partSchemaFileName;
					endif;
					self.writeLineToFile(mulFileAll, partSchemaFileName &amp; '.scm' &amp; ' ' &amp; partDDBFileName &amp; '.ddb');
					self.writeLineToFile(mulFileNonProd, partSchemaFileName &amp; '.scm' &amp; ' ' &amp; partDDBFileName &amp; '.ddb');
					
					// 09/12/2016 cnwmh5 TFS3121
					if schemaName = "DevSchema" then
						self.writeLineToFile(mulStarterLoad1Source, partSchemaFileName &amp; '.scm' &amp; ' ' &amp; partDDBFileName &amp; '.ddb');
					endif;
					
				endif;
			endforeach;
		endif;	
	endif;
	
	self.log("Full schema extracts complete");

	seq := 100 + (mandatoryEncryptedSchemas.size + 2 + 1 + 1) * 2;		// 148 +1*2 for WebSchema +1*2 for WebExampleSchema +2*2 for ...?
	seqStr := seq.cnEcPad(2);									// 156
	
	rwaFile := seqStr &amp; "allJRW_" &amp; self.versionString;
	
	if self.extractJRWFiles then
		self.extractReports(extractFolder, rwaFile);
		
		create jrwFile transient;
		jrwFile.usePresentationFileSystem := false;
		jrwFile.mode := File.Mode_Input;
		jrwFile.fileName := extractFolder &amp; rwaFile &amp; ".rwa";
		
		if not jrwFile.isAvailable then
			rwaMsg := "Report Writer Archive not generated successfully. Please check jadereportwriter.log for errors.";
			self.log(rwaMsg);
			if app.applicationType = app.ApplicationType_GUI then
				app.msgBox(rwaMsg, "Error", MsgBox_OK_Only);
			endif;
		else
			// Copy both the unl file and the rwa file to the target source directory
			self.copyFile(extractFolder &amp; rwaFile &amp; ".unl", false, self.targetSourceDirectory &amp; "\schemas\" &amp; rwaFile &amp; ".unl", true);
			self.copyFile(extractFolder &amp; rwaFile &amp; ".rwa", false, self.targetSourceDirectory &amp; "\schemas\" &amp; rwaFile &amp; ".rwa", true);
			
			// If required, then copy the rwa file to the encrypted directory
			if self.extractEncryptedSchemas &lt;&gt; null then
				self.copyFile(extractFolder &amp; rwaFile &amp; ".rwa", false, self.targetEncryptedDirectory &amp; "\schemas\" &amp; rwaFile &amp; ".rwa", true);
			endif;
	
			// If required, then copy the rwa file to the JARI directory
			if self.createJARIRelease &lt;&gt; null then
				self.copyFile(extractFolder &amp; rwaFile &amp; ".rwa", false, jariSchemaFolder &amp; "\" &amp; rwaFile &amp; ".rwa", true);
			endif;
	
			// And then remove both files from the server
			self.removeFileName(extractFolder &amp; rwaFile &amp; ".unl", false);
			self.removeFileName(extractFolder &amp; rwaFile &amp; ".rwa", false);
		endif;
	endif;
		
	
	// Insert PreUpgrade lines into JMTInstall file
	if self.createJMTInstallFile then
		
		
		// JAP Installer 2.0.0 now sets the replaceReportView option to true
		jmtInstallFile.writeLine("RWA::" &amp; rwaFile &amp; "::REQ::NOERRORS");

		// Until the default is changed in JAPInstaller, need to specifically set replaceReportView to true to ensure load is correct
		// PAR #30760 - Quoted all the file names to correctly handle embedded spaces in file names
		//self.writeLineToFile(jmtInstallFile, 'JMTGEN::"%BINDIR%\jadloadb.exe" path="%DBPATH%" ini="%INIFILE%" reportLoadAllFile="%INSTALLDIR%\schemas\' &amp; rwaFile &amp; '.rwa" server=SINGLEUSER reportReplaceView=true::NOERRORS');
		
		if self.baseReleaseDirectory &lt;&gt; null then
			self.insertFileContents(jmtInstallFile, self.baseReleaseDirectory  &amp; "\" &amp; PreUpgradeFile, true);
		endif;
		
		// 23/03/2016 KPD - Need to copy any new binaries in place before running JMTRelease and JMTPatchRelease
		self.writeLineToFile(jmtInstallFile, 'JMTGEN::XCOPY "%INSTALLDIR%\bin\*.*" "%BINDIR%" /S /Y /EXCLUDE:%INSTALLDIR%\XCOPY_exclude.txt::NOERRORS');
		
		self.writeLineToFile(jmtInstallFile, "JMTMAJOR::" &amp; self.versionString[1:2] &amp; "." &amp; self.versionString[3] &amp; "." &amp; self.versionString[4:2] &amp; "::NOERRORS");
		
		//epr TFS 336 Monthly Releases- 27/5/15
		if self.isMonthlyExtract then
			//update the patch version
			self.writeLineToFile(jmtInstallFile, "JMTPATCH::" &amp; app.myRoot.versionString &amp; "::" &amp; self.monthlyVersion &amp; "::NOERRORS");
		endif;	
		
		// KPD 14/03/2014 - Added quotes to EXCLUDE file names to correctly handle embedded spaces in file names
		// jlgmd1 07/12/2017 - Moved Documentation into JMTInstall_preSchemaCheck.txt file instead (So the new report markers can go above it 
		//jmtInstallFile.writeLine('JMTGEN::XCOPY "%INSTALLDIR%\documentation\*.*" "%BINDIR%\..\Documentation\" /S /Y /EXCLUDE:%INSTALLDIR%\XCOPY_exclude.txt::NOERRORS');
	
		// Insert PreSchemaCheck lines
		if self.baseReleaseDirectory &lt;&gt; null then
			self.insertFileContents(jmtInstallFile, self.baseReleaseDirectory  &amp; "\" &amp; PreCheckFile, true);
		endif;	
		
		self.writeLineToFile(jmtInstallFile, "SCMCHK::NOERRORS");
		self.writeLineToFile(jmtInstallFile, "REM::All Done");
		
		if jmtInstallFile.isAvailable() then
			// If the network becomes unavailable right at this time, the entire extract blows up
			jmtInstallFile.close();
		endif;
		
		// And finally copy JMTInstall to encrypted directory if required
		if self.extractEncryptedSchemas then
			self.copyFile(self.targetSourceDirectory &amp; "\JMTInstall.txt", true, self.targetEncryptedDirectory &amp; "\JMTInstall.txt", true);
		endif;
	endif;

	// If base directory has been provided, then remove some unneeded files (on the assumption that the external file copy have finished by now)
	if self.baseReleaseDirectory &lt;&gt; null then
		
		// Remove any copied JMTInstall insert files from the target, as these are not required
		self.removeFileName(self.targetSourceDirectory &amp; "\" &amp; PreLoadFile, true);
		self.removeFileName(self.targetSourceDirectory &amp; "\" &amp; PreUpgradeFile, true);
		self.removeFileName(self.targetSourceDirectory &amp; "\" &amp; PreCheckFile, true);
		
		if self.extractEncryptedSchemas then			
			// Remove any copied JMTInstall insert files from the target, as these are not required
			self.removeFileName(self.targetEncryptedDirectory &amp; "\" &amp; PreLoadFile, true);
			self.removeFileName(self.targetEncryptedDirectory &amp; "\" &amp; PreUpgradeFile, true);
			self.removeFileName(self.targetEncryptedDirectory &amp; "\" &amp; PreCheckFile, true);
		endif;
	endif;
	
	// TFS 39667
	if self.extractWSDLChanges then
		self.log("Extracting WSDL Changes");
		// Extract the WSDL changes to the source directory
		self.doExtractWSDLChanges(true);
		// And then just copy to the other directories as required
		if self.extractEncryptedSchemas then
			self.copyFile(self.targetSourceDirectory &amp; "\documentation\JMTNewWSDLFeatures" &amp; self.versionString &amp; ".html", true, self.targetEncryptedDirectory &amp; "\documentation\JMTNewWSDLFeatures" &amp; self.versionString &amp; ".html", true);
		endif;
		if self.createJARIRelease then
			self.copyFile(self.targetSourceDirectory &amp; "\documentation\JMTNewWSDLFeatures" &amp; self.versionString &amp; ".html", true, self.targetJARIDirectory &amp; "\jmt_documentation\JMTNewWSDLFeatures" &amp; self.versionString &amp; ".html", true);
		endif;
	endif;
	
	// All good to here, so remove the temporary release directory on the server
	self.clearDirectory(self.serverReleaseDirectory, false, true);
	self.removeDirectoryName(self.serverReleaseDirectory, false);		// KPD 24/09/2014
	
	message:= "Finished";
	isOk := true;
	
epilog
	if self.resultEmailAddress &lt;&gt; null then
		self.log('Sending email to ' &amp; self.resultEmailAddress);
		command := 'c:\Cardinal\bin\blat.exe';
		create args transient;
		args.add('-');
		args.add('-to');
		args.add(self.resultEmailAddress);
		args.add('-s');
		args.add('"Release extract from ' &amp; app.getJadeInstallDirAppServer &amp; '"');
		args.add('-body');
		args.add('"Release extract completed; message is ' &amp; message &amp; '"');
		dir := null;
		result1 := node.createExternalProcess(dir, command, args, null, false, true, result2);
		if result1 &lt;&gt; Node.ExternalProcess_Successful or result2 &lt;&gt; 0 then
			self.log('Possible problem with email, result1: ' &amp; result1.String &amp; ', result2: ' &amp; result2.String);
		endif;
	endif;
	
	delete args;
	delete schemaNames;
	delete mandatoryEncryptedSchemas;
	delete folder;
	if message &lt;&gt; null then
		self.log(message);
	endif;
	delete mulFile;
	delete mulFileNonProd;
	delete mulFileAll;
	delete jmtInstallFile;
	delete jariLiveAppUpgradeFile;
	delete unlFile;
	delete schemaColl;
	delete mulStarterLoad1;				
	delete mulStarterLoad1Source;
	delete mulStarterLoadPatches;
	delete mulStarterLoad2;
	delete foldersToExclude;

	return isOk;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdateExtractTime" id="bbd900d8-ee42-4c00-b81a-ac626ee58e03">
        <source>doUpdateExtractTime() : Boolean;
/*

Purpose:			Update the PortSchema::getJMTReleaseExtractTime method with the current
					date and time (run prior to extracting the schemas)

Parameters:			None

Return Value:		True if the update completes OK, false otherwise

Date		Who		Reason
17 Sep 2015	cnwkpd1	Monthly releases - need an extract timestamp embedded in the release

*/

constants
	SchemaName		= "PortSchema";
	ClassName		= "PortSchema";
	MethodName		= "getJMTReleaseExtractTime";
	SchemaFileName	= "PortSchema_temp";
	
vars
	now				: TimeStamp;
	unlFile,
	scmFile,
	modScmFile		: File;
	result			: Boolean;
	scmName,
	ddbName,
	line			: String;
	
begin
	now := app.actualTimeServer();
	
	// Create a unl file for the method that need extracting
	create unlFile transient;
	unlFile.usePresentationFileSystem := false;
	unlFile.openOutput(self.serverSourceDirectory &amp; "\" &amp; SchemaName &amp; "_" &amp; MethodName &amp; ".unl");
	unlFile.writeLine("Method " &amp; ClassName &amp; " " &amp; MethodName);
	unlFile.close();
	
	// Run the extract command to extract the method
	scmName := self.serverSourceDirectory &amp; "\" &amp; SchemaFileName &amp; ".scm";
	ddbName := self.serverSourceDirectory &amp; "\" &amp; SchemaFileName &amp; ".ddb";
	self.runSchemaExtractCommand("File " &amp; scmName &amp; " " &amp; ddbName &amp; " " &amp; unlFile.fileName &amp; " " &amp; SchemaName);
	
	// Modify the source in the extracted scm file to change the timestamp
	create scmFile transient;
	scmFile.usePresentationFileSystem := false;
	scmFile.kind := File.Kind_Unknown_Text;	// 24/2/16 cnwmp6 PAR 36286 unicode version
	scmFile.openInput(scmName);
	
	create modScmFile transient;
	modScmFile.usePresentationFileSystem := false;
	modScmFile.openOutput(self.serverSourceDirectory &amp; "\" &amp; SchemaFileName &amp; "_new.scm");
	
	while not scmFile.endOfFile() do
		line := scmFile.readLine();
		
		if line.pos("return", 1) &lt;&gt; 0 and line.pos("TimeStamp", 1) &lt;&gt; 0 then
			modScmFile.writeLine(Tab &amp; 'return "' &amp; now.String &amp; '".TimeStamp;');
		else
			modScmFile.writeLine(line);
		endif;
	endwhile;
	
	scmFile.close();
	modScmFile.close();
	
	// Now load the modified schema file back in
	self.runLoadCommand("schemaFile=" &amp; modScmFile.fileName);
	
	// And tidy up all the temporary files
	self.removeFileName(unlFile.fileName, false);
	self.removeFileName(scmName, false);
	self.removeFileName(ddbName, false);
	self.removeFileName(modScmFile.fileName, false);
	
	result := true;
	
epilog
	return result;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
