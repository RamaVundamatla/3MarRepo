    <JadeMethod name="isSystemTransType" id="74ce3aa0-4fd5-4fee-8184-1d881b5d5898">
        <methodInvocation>mapping</methodInvocation>
        <source>isSystemTransType(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------
// Created:     10 March 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		_value := (self.trxType &lt; TransactionTypeJMTMax);
	endif;


end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="66b3d4b0-29e9-4877-9cd8-ff47d3384c0e">
        <updating/>
        <source>setForCreate(_proxyObj:SelfType) updating;
// --------------------------------------------------------------------------------
// Created:		25 November 2005 by cnwdad1
//
// Purpose:		Standard initialization method, from a proxy object.
//
// Parameters:	_proxyObj - A reference to the transient proxy object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	_proxyObj.raiseExceptionIfNotTransient(method);
	
	self.setForUpdate(_proxyObj);
	self.myRoot	:=	app.myRoot;
end;</source>
        <Parameter name="_proxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="4b51ac75-958b-4ad1-9fd1-be7206267e77">
        <updating/>
        <source>setForUpdate(_proxyObj:SelfType) updating;
// --------------------------------------------------------------------------------
// Created:		25 November 2005 by cnwdad1
//
// Purpose:		Standard update method, from a proxy object.
//
// Parameters:	_proxyObj - A reference to the transient proxy object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	_proxyObj.raiseExceptionIfNotTransient(method);
	
	// Set non-key attributes first.
	
// PAR 33570	self.canCompleteToDoTask	:= _proxyObj.canCompleteToDoTask;
	self.classNameToCreate		:= _proxyObj.classNameToCreate;
	self.description			:= _proxyObj.description;
	self.trxGroup				:= _proxyObj.trxGroup;

	// Set key attributes.

	self.trxType				:=	_proxyObj.trxType;
	
	// Finally, set any inverse references.
	
	// myRoot is set by the setForCreate method when the receiver is instantiated.
end;</source>
        <Parameter name="_proxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="b4717b6b-7857-4f90-bb45-4fcfd0854c81">
        <updating/>
        <source>setProxy(_description : String; _type, _group : Integer; _classNameToCreate : String;
		_canCompleteToDoTask : Boolean; _root : CM_Root) updating;
// ---------------------------------------------------------------------------
// Created:     10 March 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.description		:= _description;
	self.trxType			:= _type;
	self.trxGroup			:= _group;
	self.classNameToCreate	:= _classNameToCreate;
// PAR 33570	self.canCompleteToDoTask	:= _canCompleteToDoTask;
	
	self.myRoot		:= _root;

end;</source>
        <Parameter name="_description" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_group" type="Integer"/>
        <Parameter name="_classNameToCreate" type="String"/>
        <Parameter name="_canCompleteToDoTask" type="Boolean"/>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromConstant" id="e61da80b-b81b-4d8a-aac2-9199fb3035b9">
        <updating/>
        <source>setProxyFromConstant(_constant:Constant; _rootObj:CM_Root) updating;
// --------------------------------------------------------------------------------
// Created:		28 November 2005 by cnwdad1
//
// Purpose:		Updates the receiver's properties from an XML string.
//
// Parameters:	_constant - A reference to the global constant which contains the
//					property values.
//				_rootObj - A reference to the system root object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	str,
	xmlString	: String;
	constant	: GlobalConstant;
	translation : XLAT_Translation;
	
begin
/*
&lt;TrxType&gt;
&lt;ClassName&gt;CM_Attach&lt;/ClassName&gt;
&lt;TrxGroup&gt;3&lt;/TrxGroup&gt;
&lt;CanCompleteTask&gt;false&lt;/CanCompleteTask&gt;
&lt;/TrxType&gt;
*/
	xmlString					:=	_constant.text;
	self.trxGroup				:=	xmlString.cnEcGetTagValueOfName(self.XMLTag_TrxGroup).Integer;
	self.classNameToCreate		:=	xmlString.cnEcGetTagValueOfName(self.XMLTag_ClassName);
// PAR 33570	self.canCompleteToDoTask	:=	xmlString.cnEcGetTagValueOfName(self.XMLTag_CanCompleteTask).Boolean;
	self.trxType				:=	_constant.valueAsInteger();
	self.myRoot					:=	_rootObj;
	
	// get nice name from translatable string for type
	str := 'TransType_' &amp; self.trxType.String;
	constant := currentSchema.getConstant(str);
	if constant &lt;&gt; null then
		translation := app.zGetTranslatedText(XLAT_Exceptions, constant.valueAsInteger);
		if translation &lt;&gt; null then
			//self.description := app.currentLocale.getStringValue(str);
			self.description := translation.text;
			return;
		else
			
		endif;
	endif;
	
	self.description := 'Unknown Type';

end;</source>
        <Parameter name="_constant" type="Constant"/>
        <Parameter name="_rootObj" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="useInTodoTaskMaintenance" id="53178191-7eee-49ce-9988-2113959bb169">
        <source>useInTodoTaskMaintenance() : Boolean;
/*
Purpose:			
Date		Who		Reason
23 February 2015	cnwab1	Initial creation
*/

vars

begin
	if not isSystemTransType then
		return true;
	endif;
	
	if ValidTransactionTypes.pos(self.classNameToCreate,1) &gt; 0 then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="6ea7e8a0-e6cb-4a9d-8c6a-0ce8be90065a">
        <source>validateForCreate(_systemUpdate : Boolean);
// --------------------------------------------------------------------------------
// Created:		25 November 2005 by cnwdad1
//
// Purpose:		Validates an instance of the receiver when it is created.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 05/08/2016	cnwdap1		TFS #2447 Transaction Types are keyed by description as well as type
// --------------------------------------------------------------------------------
begin
	if app.myRoot.allTransactionTypes.includesKey( self.trxType ) then
//		app.raiseCMException3(ERR_DUPLICATE_KEY, 'A transaction with type (' &amp; self.trxType.String &amp;
//				')', '', 'Please enter another number', ETRow_TrxType, null);
		// error message replaced with translatable message.
		app.raiseCMException3(	ERR_DUPLICATE_KEY,
								app.getErrorString1( Duplicate_TransactionType, self.trxType.display ),
								null,
								app.getErrorString( Please_Enter_Another_Number ),
								ETRow_TrxType,
								null );
	endif;
	
	if app.myRoot.allTransactionTypesByDesc.includesKey(self.description) then															// TFS #2447
		app.raiseCMException1(Trans_type_description_exists, SingleQuote &amp; self.description &amp; SingleQuote, ETRow_Description, null);	// TFS #2447
	endif;																																// TFS #2447
	
	self.validateMe(_systemUpdate);
end;</source>
        <Parameter name="_systemUpdate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="388bd55d-4921-4197-9df5-4e1a0a358f6e">
        <source>validateForDelete();
// --------------------------------------------------------------------------------
// Created:		25 November 2005 by cnwdad1
//
// Purpose:		Validates an instance of the receiver when it is being deleted.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tmpTerminal	: CM_Terminal;
	errStr		: String;
	iter : Iterator;
	proformaCrit : CM_ProformaTransactionCriteria;
begin
	if self.isSystemTransType then
		app.raiseCMException1(Err_NoUpdDelForSysTransType, app.getErrorString(Delete), null, null);
	endif;
	
	foreach tmpTerminal in app.myRoot.allTerminals do
		if tmpTerminal.hasTransactionOfType(self) then
			if errStr = null then
				errStr := tmpTerminal.name;
			else
				errStr := errStr &amp; ', ' &amp; tmpTerminal.name;
			endif;
		endif;
	endforeach;

	if errStr &lt;&gt; null then
		app.raiseCMException2(Err_TransTypeInUse, self.description, errStr, null, null);
	endif;
	
	if not self.allTransactionMappings.isEmpty then
		errStr := " transaction map. Please remove the " &amp; self.allTransactionMappings.size.String &amp; " mappings first, then re-try.";
		app.raiseCMException2(Err_TransTypeInUse, self.description, errStr, null, null);
	
	endif;
	
	//12 Sep 2014	NDL	Par 33918
	iter := CM_ProformaTransactionCriteria.instances.createIterator;
	while iter.next( proformaCrit ) do
		if proformaCrit.allTransactionTypes.includes( self ) then
			errStr := " proforma criteria map. Please remove Porforma criteria first, then re-try.";
			app.raiseCMException2(Err_TransTypeInUse, self.description, errStr, null, null);
		endif;
	endwhile;

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="776b525c-b6ba-4a09-b866-b21dad927d12">
        <source>validateForUpdate(_realTransType : CM_TransactionType; _systemUpdate : Boolean);
// --------------------------------------------------------------------------------
// Created:		25 November 2005 by cnwdad1
//
// Purpose:		Validates an instance of the receiver when it is updated.
// --------------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------
// 05/08/2016	cnwdap1		TFS #2447 Prevent 1310 on duplicate descriptions
vars
	type : CM_TransactionType;
	
begin
	if _realTransType.trxType &lt;&gt; self.trxType and not _realTransType.allTransactionMappings.isEmpty then
		app.raiseCMException1(Invoi_trans_map_canno_chang_t, _realTransType.description ,null, null);
	endif;
	
	// cnwrl1 08/04/2009 PAR 19376 - start of coding
	// The user is not allowed to change the transaction type.
	if _realTransType.trxType &lt;&gt; self.trxType then
		// From the User Guide "The Type text box displays the system-generated value that is associated
		// with the transaction type. This value is automatically generated and you cannot change it."
		app.raiseCMException( SystemGen_TransType_NotBeChg, ETRow_TrxType, null );
	endif;
	// cnwrl1 08/04/2009 PAR 19376 - end of coding
	
	foreach type in app.myRoot.allTransactionTypes discreteLock where type &lt;&gt; _realTransType do												// TFS #2447
		if type.description = self.description then																							// TFS #2447
			app.raiseCMException1(Trans_type_description_exists, SingleQuote &amp; self.description &amp; SingleQuote, ETRow_Description, null);	// TFS #2447
		endif;																																// TFS #2447
	endforeach;																																// TFS #2447
	
	self.validateMe(_systemUpdate);
end;
</source>
        <Parameter name="_realTransType" type="CM_TransactionType"/>
        <Parameter name="_systemUpdate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="c93218b0-ef26-4021-9b73-f4f902d022c0">
        <source>validateMe(_systemUpdate : Boolean) protected;
// --------------------------------------------------------------------------------
// Created:		25 November 2005 by cnwdad1
//
// Purpose:		Does standard validation on an instance of the receiver.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 19/06/2013	cnwcs5		par 31657 - validation for 'Can complete todo task'
//23 Sept 2013	cnwrs1	Initialise MT DB failed
// --------------------------------------------------------------------------------
vars
	class	: Class;
	type	: CM_TransactionType;
	found	: Boolean;
begin
	if _systemUpdate then //cnwrs1 Aug 2006 par11655
		if self.trxType &gt; TransactionTypeJMTMax then
			app.raiseCMException1(Trans_type_must_less_than_plea, TransactionTypeJMTMax.String, null, null);
		endif;
	else
		if self.trxType &lt; TransactionTypeJMTMax then
			app.raiseCMException1(Trans_type_must_great_than_ple, TransactionTypeJMTMax.String, null, null);
		endif;
	endif;
	
	if self.trxType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Transaction Type", null, null);
		app.raiseCMException(Input_required_field_transType, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.trxGroup = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Transaction Group", null, null);
		app.raiseCMException(Input_required_field_transGrp, null, null); // cnwdb2	PAR 35364
	else
		if (not _systemUpdate) and
		   (self.trxGroup = TRANS_TYPE_GROUP_SOH or
		   self.trxGroup = TRANS_TYPE_GROUP_BOL or
 // ### TFS CR 60699 TASK 60700 28SEP2023 NAVAB1		   self.trxGroup = TRANS_TYPE_GROUP_WO or // TFS 39236
		   self.trxGroup = TRANS_TYPE_GROUP_HMS) then
			app.raiseCMException1(Err_TransTypeInvalidGroup, app.transactionTypeEnumToString(self.trxGroup), CM_TransactionType::trxGroup.name, null);
		endif;
	endif;
	
	if self.classNameToCreate = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Class Name (to create)", null, null);
		app.raiseCMException(Input_required_field_clsNmeCrt, null, null); // cnwdb2	PAR 35364
	else
		class := CM_Transaction.getSubclassByName(self.classNameToCreate);
		// par 31657 - GUI should have take care of this
		if class = null then
			app.raiseUnexpectedProgramError (self.class.name, method.name, self.classNameToCreate &amp;  " - Class not found");
			return;
		endif;
	endif;
	
	if _systemUpdate and (not self.isSystemTransType) then
		app.raiseCMException1(Err_InvalidType, self.trxType.String, CM_TransactionType::trxType.name, null);
		
	elseif (not _systemUpdate) and self.isSystemTransType then
		app.raiseCMException1(Err_InvalidType, self.trxType.String, CM_TransactionType::trxType.name, null);
	endif;
	
	/* PAR 33570
	
	// par 31657 - if canCompleteToDoTask is set then the class to create must be associated with a system
	// transaction type with canCompleteToDoTask set to true
	if not _systemUpdate then	//23 Sept 2013	cnwrs1	Initialise MT DB failed
		if self.canCompleteToDoTask then
			foreach type in app.myRoot.allTransactionTypes where (type.isSystemTransType and type.canCompleteToDoTask and type.classNameToCreate = self.classNameToCreate) do
				// there is a system transaction type with canCompleteToDotask that uses the same class
				found := true;
				break;
			endforeach;
			
			if not found then
				// we expect the GUI to take care of this
				app.raiseUnexpectedProgramError (self.class.name, method.name, classNameToCreate &amp; " cannot be used to complete todo tasks");
			endif;
		endif;
	endif;
	*/
end;</source>
        <access>protected</access>
        <Parameter name="_systemUpdate" type="Boolean"/>
    </JadeMethod>
</Class>
