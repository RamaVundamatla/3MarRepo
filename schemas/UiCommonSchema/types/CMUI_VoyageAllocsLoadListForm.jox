    <JadeMethod name="translateForm" id="07dffb94-8680-4775-9aa8-f78719b342b1">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018942, locale);
	btnCancelCC.translateCaption(Xlat_0018943, locale);
	btnDeleteVA.translateBubbleHelp(Xlat_0018944, locale);
	btnDeleteVA.translateCaption(Xlat_0018945, locale);
	btnDeleteVALL.translateBubbleHelp(Xlat_0018946, locale);
	btnDeleteVALL.translateCaption(Xlat_0018947, locale);
	btnEraseAlloc.translateBubbleHelp(Xlat_0018948, locale);
	btnEraseAlloc.translateCaption(Xlat_0018949, locale);
	btnExportCSV.translateBubbleHelp(Xlat_0018950, locale);
	btnExportCSV.translateCaption(Xlat_0018951, locale);
	btnPrintTable.translateBubbleHelp(Xlat_0018952, locale);
	btnPrintTable.translateCaption(Xlat_0018953, locale);
	btnRefresh.translateBubbleHelp(Xlat_0018954, locale);
	btnRefresh.translateCaption(Xlat_0018955, locale);
	btnSaveCC.translateCaption(Xlat_0018956, locale);
	btnSaveProj.translateBubbleHelp(Xlat_0018957, locale);
	btnSaveProj.translateCaption(Xlat_0018958, locale);
	btnSummBooking.translateBubbleHelp(Xlat_0018959, locale);
	btnSummBooking.translateCaption(Xlat_0018960, locale);
	btnSummCargo.translateBubbleHelp(Xlat_0018961, locale);
	btnSummCargo.translateCaption(Xlat_0018962, locale);
	mnuInspectObject.translateCaption(Xlat_0018963, locale);
	mnuViewContext.translateCaption(Xlat_0018964, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="4cce0374-7a70-4bd6-97b0-73453e988c19">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 Jan 2010	cnwas3	Initial creation
01 Mar 2011	cnwkpd1	PAR #27032 - Load Colour Code performance

*/

vars
	option,
	time			: Integer;

begin
	if self.myParentForm &lt;&gt; null then
		if self.myParentForm.isKindOf(CMUI_GridAreaForm2) then // PAR 27749
			self.myParentForm.CMUI_GridAreaForm2.hideCCP(false);
		elseif parentIsROROplanningForm then
			self.myParentForm.sendMsgWithParams("hideCCP", false);
		endif;
	endif;
	
	self.tblCCAllocation.clearSelfForDestruction();
	
	inheritMethod();
epilog

end;</source>
    </JadeMethod>
