    <JadeMethod name="doTblDataMouseMove" id="eed783d6-52e7-4e8b-81ff-f1c06474425e">
        <updating/>
        <source>doTblDataMouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin

	if button = Window.MouseButton_Left 
	and app.dragDetected(x, y, self.origXPos, self.origYPos) then
		if y &gt; 20 then
			if self.origYPos &gt; 20 then // ### PAR 9949 may be doing a column resize!
				self.dragMode := DragMode_Drag;
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doTblDataRowColChange" id="13de28eb-a114-4da9-bf6e-d1386924f4d7">
        <updating/>
        <source>doTblDataRowColChange(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	obj			: Object;
	
begin
	obj := self.tblData.accessRow(table.row).itemObject;
	if obj.isKindOf(CM_InvoiceLine) then
		self.myCurrentInvoiceLine := self.tblData.accessRow(table.row).itemObject.CM_InvoiceLine;
		//epr TFS 2079 3/8/16
		if self.myCurrentInvoiceLine &lt;&gt; null then
			self.myCurrentInvoice := self.myCurrentInvoiceLine.invoice;
		endif;
		self.myCurrentCashPayment := null;
	elseif obj.isKindOf(CM_CashPayment) then
		self.myCurrentCashPayment := self.tblData.accessRow(table.row).itemObject.CM_CashPayment;
		self.myCurrentInvoiceLine := null;
	endif;
	
	inheritMethod(table);
	
	if self.myCurrentInvoiceLine &lt;&gt; null then
		self.myCurrentInvoice := self.myCurrentInvoiceLine.invoice;
	elseif self.myCurrentCashPayment &lt;&gt; null then
		self.myCurrentInvoice := self.myCurrentCashPayment.myInvoice;
	endif;
	
	//epr par 37356 14/1/16
	if self.frmInvProperties.visible and self.currentView = ETView_InvListInvLinePropUpd then
		self.displayInvoiceLine();
		self.resizeInvPropFrame();
	endif;
	

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
