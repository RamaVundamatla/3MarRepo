    <JadeMethod name="setSplitterMain" id="4f0c55c2-00ae-4a7f-a5b1-ea58823298ac">
        <source>setSplitterMain();
// ---------------------------------------------------------------------------
// Created:     02 August 2002 by cnwth2
//
// Purpose:     sets the left to right ratio of the main splitter control based on the
//				size of the tblEntQuery - which varies depending on view
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	splitRatio		: Real;
begin
	splitRatio := ((tblEntQuery.top + (tblEntQuery.height + 30)) / sptMain.height) * 100;
	self.sptMain.setLeftToRightRatioAndResize(splitRatio.Integer);
	

end;</source>
    </JadeMethod>
    <JadeMethod name="setupControls" id="0b8fafa3-ae17-43a1-853e-a3f03177ead8">
        <source>setupControls();
// ---------------------------------------------------------------------------
// Created:     01 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.tblEntQuery.top := 5;
	self.tblEntQuery.setDistanceFromBottom(100);
	self.sptMain.left := 0;
	self.sptMain.setDistanceFromBottom(45);
	cbShowDetail.automaticCellControl := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="b7473a27-961e-42c1-86a4-fd04f23d970b">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:      29 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin

	self.setCaption(self.caption);

	if cmbQueryType.listCount &gt; 0 then // AKB I added this so that this form can be initialized from a context menu
		return;
	endif;

	self.setupControls();

	if app.getMyUser.canDo(self.myTerminal, PmAdmStockMoveMaint) then
		self.btnFixupStock.visible := true;
		self.btnFixupStock.enabled := true;	
		self.btnValidate.visible := true;
		self.btnValidate.enabled := true;
	else
		self.btnFixupStock.visible := false;
		self.btnValidate.visible := false;
		self.btnExecute.distanceFromBottom := self.btnFixupStock.distanceFromBottom;
	endif;	
	self.resize();

end;</source>
    </JadeMethod>
    <JadeMethod name="showItemDetailSheet" id="f9d5e15d-84cf-4418-9115-532af8bdd64a">
        <updating/>
        <source>showItemDetailSheet(_inItems : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     29 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	date		: Date;
	tmpSheet	: JadeTableSheet;
	stkMove		: CM_StockMovement;
	txn			: CM_TITransaction;
	stkMoveSet	: CM_StockMovementSet;
	idx			: Integer;
	tiTxnSet	: CM_TITransactionSet;
	sohTxn		: CM_SOHTransaction;	
	sohTxnDict	: CM_SOHTransactByDateTypeDict;
	rowObject	: Object;
	
begin
	tmpSheet		:=	tblData.accessSheet(TblDataSheet_ItemDetail);
	tmpSheet.rows	:=	tmpSheet.fixedRows;
	
// cnwdad1 05/07/2007 - 1086 exceptions were caused because some table rows contain a CMIF_StockMoveHelper object.
//	self.myCurrentStockMoveDtl := tblData.accessRow(tblData.row).itemObject.CMIF_StockMoveDtl;
//	if self.myCurrentStockMoveDtl = null then
//		return;
//	endif;
	//rowObject := tblData.accessRow(tblData.row).itemObject;
	//PAR 15659 
	//rowObject was an null object. The new code is to get the object from tblData.
	rowObject := tblData.accessRow(tblData.row).itemObject.CMIF_StockMoveDtl;//added
	if rowObject = null then
		return;
	elseif rowObject.isKindOf(CMIF_StockMoveDtl) then
		self.myCurrentStockMoveDtl := rowObject.CMIF_StockMoveDtl;
	else
		return;
	endif;
	
	if _inItems then
		stkMoveSet := self.myCurrentStockMoveDtl.allStockMovementsIn;
	else
		stkMoveSet := self.myCurrentStockMoveDtl.allStockMovementsOut;
	endif;

	foreach stkMove in stkMoveSet do
//		if stkMove.isKindOf(CM_StockMovementLocation) then
			tiTxnSet := stkMove.CM_StockMovementLocation.allTITransactions;
			
			foreach txn in tiTxnSet do
				idx := tmpSheet.addItem(txn.id &amp; Tab &amp; txn.typeString &amp; Tab &amp; txn.getDisplayString() &amp; Tab &amp; txn.userId &amp; Tab &amp; txn.createdTime.Time.currentLocaleFormatJMT());
				
				if idx mod 2 = 0 then
					tmpSheet.accessRow(idx).backColor := self.colorRow1;
				else
					tmpSheet.accessRow(idx).backColor := self.colorRow2;
				endif;
			endforeach;
/*
		elseif stkMove.isKindOf(CM_StockMovementTerminal) then
			sohTxnDict := stkMove.myStockMoveBucket.CM_StockMoveTerminal.mySOHTerminal.allSOHTransactions;
			date := stkMove.myStockMoveBucket.date;
			foreach sohTxn in sohTxnDict where sohTxn.dateTime.date = date do
				idx := tmpSheet.addItem(sohTxn.getID &amp; Tab &amp; sohTxn.typeString &amp; Tab &amp; sohTxn.getDisplayString());
				if idx mod 2 = 0 then
					tmpSheet.accessRow(idx).backColor := ColourYellowLight;
				else
					tmpSheet.accessRow(idx).backColor := ColourBlueLight;
				endif;
			endforeach;
			
		elseif stkMove.isKindOf(CM_StockMovementTerminalArea) then
			sohTxnDict := stkMove.myStockMoveBucket.CM_StockMoveTerminalArea.mySOHTerminalArea.allSOHTransactions;
			date := stkMove.myStockMoveBucket.date;
			foreach sohTxn in sohTxnDict where sohTxn.dateTime.date = date do
				idx := tmpSheet.addItem(sohTxn.getID &amp; Tab &amp; sohTxn.typeString &amp; Tab &amp; sohTxn.getDisplayString());
				if idx mod 2 = 0 then
					tmpSheet.accessRow(idx).backColor := ColourYellowLight;
				else
					tmpSheet.accessRow(idx).backColor := ColourBlueLight;
				endif;
			endforeach;
		endif;
*/
	endforeach;
end;</source>
        <Parameter name="_inItems" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showQueryView" id="6ca7453f-b0f8-4ac5-b233-bbae9beff0ec">
        <updating/>
        <source>showQueryView() updating;
// ---------------------------------------------------------------------------
// Created:     02 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entDef			: EntTableDef;
	entView			: EntTableView;
	sht				: JadeTableSheet;
	
begin
	entDef := self.getTblEntQueryDef();
	
	// Clear existing data from the table
	sht := tblData.accessSheet(tblData.topSheet);
	sht.rows := sht.fixedRows;
	
	if self.queryType = QueryType_StkMoveByLocation then
		self.switchMode(Mode_StockMove);
		entView := entDef.allEntTableViews['QryStkByLocView'];
	
	elseif self.queryType = QueryType_StkMoveByProduct then
		self.switchMode(Mode_StockMove);
		entView := entDef.allEntTableViews['QryStkByProView'];

	elseif self.queryType = QueryType_StkMoveFixups then
		self.switchMode(Mode_SOHFixups);
		if self.filtLocationType &lt;&gt; LocationType_Terminal then
			cmbLocationType.listIndex := cmbLocationType.findStringExact(1, LocationType_Terminal);
			self.doCmbLocationTypeClick(LocationType_Terminal);
			tblEntQuery.setValueByControlName(cmbLocationType.name, LocationType_Terminal);
		endif;
		entView := entDef.allEntTableViews['QryStkFixups'];
		
	endif;
	
	if entView &lt;&gt; null then
		tblEntQuery.showHideRowsByView(entView, CM_EntryTable.ShowHideRows, false);
	endif;
	if tblEntQuery.rows &gt; 0 then
		tblEntQuery.height := entView.allEntTableRows.size *  tblEntQuery.accessRow(1).height +5;
	endif;

	self.setSplitterMain();
end;</source>
    </JadeMethod>
    <JadeMethod name="showSOHFixupDetails" id="95a599b6-2bb5-4df5-8e34-bcea451a3fdb">
        <updating/>
        <source>showSOHFixupDetails() updating;
// ---------------------------------------------------------------------------
// Created:     29 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpSheet	: JadeTableSheet;
	idx			: Integer;
	hdr 		: CM_SOHFixupHdr;
	dtl			: CM_SOHTransaction;
begin

	tmpSheet := tblData.accessSheet(TblDataSheet_SOHFixups);
	hdr := tmpSheet.accessRow(tmpSheet.row).itemObject.CM_SOHFixupHdr;
	if hdr = null then
		return;
	endif;

	tmpSheet := tblData.accessSheet(TblDataSheet_ItemDetail);
	tmpSheet.rows := tmpSheet.fixedRows;

	foreach dtl in hdr.allSOHTransactions do
	
		idx := tmpSheet.addItem(dtl.getID &amp; Tab &amp; dtl.typeString &amp; Tab &amp; dtl.getDisplayString());
		if idx mod 2 = 0 then
			tmpSheet.accessRow(idx).backColor := self.colorRow1;
		else
			tmpSheet.accessRow(idx).backColor := self.colorRow2;
		endif;

	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="switchMode" id="1e3b625e-bfd2-4477-a26f-714e0f80465b">
        <updating/>
        <source>switchMode(_newMode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     29 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	origTopSheet, newTopSheet : Integer;
begin

	if self.mode = _newMode then
		return;
	endif;

	app.mousePointer := Busy;
	
	origTopSheet := self.tblData.topSheet;
		
	if _newMode = Mode_ItemDetailIn or _newMode = Mode_ItemDetailOut then
		newTopSheet := TblDataSheet_ItemDetail;
	elseif _newMode = Mode_StockMove then
		newTopSheet := TblDataSheet_StockMove;	
	elseif _newMode = Mode_ValidateStockTotals then
		newTopSheet := TblDataSheet_ValidateTotals;	
	elseif _newMode = Mode_SOHFixups then
		newTopSheet := TblDataSheet_SOHFixups;	
	elseif _newMode = Mode_SOHFixupDetails then
		newTopSheet := TblDataSheet_ItemDetail;	
	endif;
	
	if newTopSheet &lt;&gt; origTopSheet then
		self.tblData.accessSheet(newTopSheet).visible := true;	
		self.tblData.topSheet := newTopSheet;
		self.tblData.accessSheet(origTopSheet).visible := false;	
	endif;

	if _newMode = Mode_ItemDetailIn then
		self.showItemDetailSheet(true);
		btnBack.visible			:= false;
		btnItemDtlsIn.visible 	:= true;
		btnItemDtlsOut.visible 	:= true;
		btnStkMoves.visible		:= true;
		btnTransactions.visible	:= false;

		btnItemDtlsIn.enabled 	:= false;
		btnItemDtlsOut.enabled 	:= true;
		btnStkMoves.enabled		:= true;

	elseif _newMode = Mode_ItemDetailOut then
		self.showItemDetailSheet(false);
		btnBack.visible			:= false;
		btnItemDtlsIn.visible 	:= true;
		btnItemDtlsOut.visible 	:= true;
		btnStkMoves.visible		:= true;
		btnTransactions.visible	:= false;

		btnItemDtlsIn.enabled 	:= true;
		btnItemDtlsOut.enabled 	:= false;
		btnStkMoves.enabled		:= true;

	elseif _newMode = Mode_StockMove then
		btnBack.visible			:= false;
		btnItemDtlsIn.visible 	:= true;
		btnItemDtlsOut.visible 	:= true;
		btnStkMoves.visible		:= true;
		btnTransactions.visible	:= false;

		btnItemDtlsIn.enabled 	:= true;
		btnItemDtlsOut.enabled 	:= true;
		btnStkMoves.enabled		:= false;

	elseif _newMode = Mode_ValidateStockTotals then
		btnBack.visible			:= false;
		btnItemDtlsIn.visible 	:= true;
		btnItemDtlsOut.visible 	:= true;
		btnStkMoves.visible		:= true;
		btnTransactions.visible	:= false;

		btnItemDtlsIn.enabled 	:= false;
		btnItemDtlsOut.enabled 	:= false;
		btnStkMoves.enabled		:= false;		

	elseif _newMode = Mode_SOHFixups then
		btnBack.visible			:= false;
		btnItemDtlsIn.visible 	:= false;
		btnItemDtlsOut.visible 	:= false;
		btnStkMoves.visible		:= false;		
		btnTransactions.visible	:= true;

	elseif _newMode = Mode_SOHFixupDetails then
		self.showSOHFixupDetails();
		btnBack.visible			:= true;
		btnItemDtlsIn.visible 	:= false;
		btnItemDtlsOut.visible 	:= false;
		btnStkMoves.visible		:= false;		
		btnTransactions.visible	:= true;

	endif;

	self.mode := _newMode;

epilog
	app.mousePointer := Idle;

end;</source>
        <Parameter name="_newMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblData_contextMenu" id="d9cef37d-a789-46f1-8255-a98e7c18a5d1">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_contextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     29 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	x1 : Real;
	y1 : Real;
	obj : Object;
	theSheet : JadeTableSheet;
	idx	: Integer;

begin
	x1 := x;
	y1 := y;
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if cntrl.row &lt; 1 then
	        y1 := 5;
	    else
	        y1 := cntrl.positionTop();
	    endif;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form

	mnuInItemDetails.visible 	:= false;
	mnuOutItemDetails.visible 	:= false;
	mnuStockMoves.visible 		:= false;
	
	if self.mode = Mode_ItemDetailIn then
		mnuOutItemDetails.visible := true;
		mnuStockMoves.visible := true;
		
	elseif self.mode = Mode_ItemDetailOut then
		mnuInItemDetails.visible := true;
		mnuStockMoves.visible := true;

	elseif self.mode = Mode_StockMove then
		mnuInItemDetails.visible := true;
		mnuOutItemDetails.visible := true;
		
	endif;

	self.popupMenu(mnuTblDataContext, x1.Integer, y1.Integer);
	return false;                  // cancel further processing

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
