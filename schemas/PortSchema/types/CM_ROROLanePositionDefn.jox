    <JadeMethod name="getAllVoyageControllers" id="c6b40618-df4a-416e-aeba-c657abb43ce8">
        <source>getAllVoyageControllers(_allControllers: CM_VoyageROROControllerArray io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2022	jlier1	Initial creation TFS 50658

*/

vars

begin
	if self.myLanePositionController = null then
		return;
	endif;
	
	_allControllers.add(self.myLanePositionController);

