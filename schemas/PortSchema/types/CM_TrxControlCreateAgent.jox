        <source>trxCreatePackage(_terminal : CM_Terminal; _pxyPackage : CM_Package; _realPackage : CM_Package output; _passport : CM_Passport input) updating;
// 14 Sep 2018	jlgrh7 TFS40044 PEN - VVR Package Description too short?
vars
	desc	: String;
	pxySchedule		: CM_AutoSchedule;
	realSchedule	: CM_AutoSchedule;
	pxyTask			: CM_AutoTaskPackage;
	realTask		: CM_AutoTask;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	app.myUtilityCA.utlCreatePackage(_pxyPackage, _realPackage, _passport);
	// CPL CCMS 2120 invoice packages Oct 2011, create associated event task and schedule
	if _passport.noErrors and
	   (_pxyPackage.isKindOf(CM_PackageInvoice) or _pxyPackage.isKindOf(CM_PackageVVR)) then		// 8/3/18 MAP TFS37340
		if _pxyPackage.isKindOf(CM_PackageInvoice) then
			//desc := ("Invoice Package " &amp; _pxyPackage.description)[1:30];			//-TFS40044
			desc := "Invoice Package " &amp; _pxyPackage.description;		//+TFS40044
		else
			//desc := ("VVR Package " &amp; _pxyPackage.description)[1:30];		// 8/3/18 MAP TFS37340	//-TFS40044
			desc := "VVR Package " &amp; _pxyPackage.description;		//+TFS40044
		endif;
		create pxyTask transient;
		//pxyTask.setValueForRow(ETRow_BgpAutoDescription, desc);			//-TFS40044
		pxyTask.setValueForRow(ETRow_BgpAutoDescription, desc[1:30]);	//+TFS40044
		pxyTask.setValueForRow(ETRow_BgpAutoTerminals, _terminal);
		pxyTask.setValueForRow(ETRow_BgpAutoUser, _realPackage.myUser);
		pxyTask.setValueForRow(ETRow_BgpAutoPackages, _realPackage);
		app.myUtilityCA.utlCreateAutoTask(pxyTask, realTask, _passport);
		
		if _passport.noErrors then
			create pxySchedule transient;
			if _pxyPackage.isKindOf(CM_PackageInvoice) then
				pxySchedule.setForEvent(desc, EventDataInvoicing);
			else
				pxySchedule.setForEvent(desc, EventDataVVR);		// 8/3/18 MAP TFS37340
			endif;
			pxySchedule.allAutoTasks.add(realTask);
			app.myUtilityCA.utlCreateAutoSchedule(pxySchedule, realSchedule, _passport);
		endif;
	endif;
	
epilog
	delete pxyTask;
	delete pxySchedule;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_pxyPackage" type="CM_Package"/>
        <Parameter name="_realPackage" type="CM_Package" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
