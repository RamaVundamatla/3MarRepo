<Class name="CMIF_SAPAutoPreInvReq" id="3d8325be-43a3-46d9-b416-623c7d9bb575">
    <superclass name="CMIF_SAPWSRequest"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>37189.004 Send Release Hold and Debit for Auto-Collection Customer
WSDL 1.2: Auto-Collection - Release Hold/Debit
PaymentType_AutoCollection</text>
    <ImplicitInverseRef name="allEstimation" id="c79a8378-319a-49fa-8487-e6240c0660a4">
