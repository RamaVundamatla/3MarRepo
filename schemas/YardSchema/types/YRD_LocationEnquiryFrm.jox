    <JadeMethod name="loadDataForFirstTime" id="71de6d71-161b-4c11-bd6e-a41a63a26b2b">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//--------------------------------------------------
// Created:	01 October 2003 By: cnwgd1
//--------------------------------------------------
vars
	regKeys : IntegerArray;
begin
	inheritMethod();
	self.setFormHeading();
	
	create regKeys transient;
	regKeys.add(CMUI_Key_Esc);
	self.addRegisteredKeys(regKeys);
	if not myCurrentObject.isKindOf(CM_TrackedItem) then // adm 170708 Par 16867
		myCurrentObject	:= null;
	endif;
	
	self.amInitialisingWithObject := false; // PAR 35158. If drilling to this screen from GC Area Screen, this was stopping notes and F5 from working
epilog
	delete regKeys;
end;</source>
        <access>protected</access>
    </JadeMethod>
