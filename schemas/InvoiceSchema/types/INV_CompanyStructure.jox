        <source>btnDelete_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.setUpdateMode(self.UpdateMode_Delete);
	if self.myCurrentBU &lt;&gt; null then
		self.modePropertyUpdate := self.MODEPROPERTY_BU;
	elseif self.myCurrentCompany &lt;&gt; null then
		self.modePropertyUpdate := self.MODEPROPERTY_COMPANY;
	else
		global.beep;
		return;
	endif;
	self.doDelete();
end;</source>
