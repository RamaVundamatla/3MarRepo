    <JadeMethod name="getAllDrawingIconsArray" id="be1704bf-14b6-4988-b180-d92de52ea448">
        <source>getAllDrawingIconsArray(): String;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	rtnStr : String;
begin
	rtnStr := inheritMethod();
	rtnStr := rtnStr &amp; "," &amp; PicTIBreakBulk;
