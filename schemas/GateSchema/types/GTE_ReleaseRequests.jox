</source>
    </JadeMethod>
    <JadeMethod name="createRequests" id="3479becb-7043-4268-9d63-d233c57f552a">
        <source>createRequests();
// ---------------------------------------------------------------------------
// Created:     22 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	releaseRequest 			: CM_BulkRelease;
	pxyDeliveryRequest		: CM_DeliveryRequest;
	reserveDetail			: CM_ReserveDetail;
	operatorCode,
	remarks,
	releaseNum 				: String;
	totalRequested			: Integer;
	idMask 					: String;
	array					: StringArray;
	colour, mark			: String;
begin
	releaseRequest := self.myMasterProxyObject.CM_BulkRelease;
	reserveDetail := releaseRequest.allReserveDetails.first;
	if reserveDetail = null then
		return;
	endif;
	
	if releaseRequest.type = BR_TYPE_BOL then
		releaseNum := releaseRequest.code;
	endif;
	
	if releaseRequest.myOperator &lt;&gt; null then
		operatorCode := releaseRequest.myOperator.code;
	endif;
	
	if CM_ReserveSelection.hasInstance(reserveDetail) then
		totalRequested := reserveDetail.totalRequested;
		colour := reserveDetail.CM_ReserveSelection.colour;   // PAR 32190
		mark := reserveDetail.CM_ReserveSelection.markSelection;
	else
		totalRequested := 1;
	endif;
	//th2 PAR 14496 - Remarks missing from Road Ops
	if releaseRequest.releaseByType then
		remarks := reserveDetail.remarks;
	else
		remarks := releaseRequest.cargoRemarks;
	endif;
	
	create pxyDeliveryRequest transient;
	pxyDeliveryRequest.set(	releaseRequest.consigneeCode,
							releaseRequest.consignorVoyageCode,
							releaseNum,	// deliveryNumber, 
							null,			// eirNumber,
							reserveDetail.getISOTypeCode(),
							operatorCode,
							releaseRequest.myOperatorGroup, //tmpOperatorGroup,
							reserveDetail.getCargoType,
							reserveDetail.getClean(),
							reserveDetail.getDoISOGroupCheck,	// RDD 8/8/2001 Xpose 1231/POT 147
							TI_DOORSDIRN_NULL,
							reserveDetail.getHeavyRated,
							false,
							null,//needCOU
							null, //need generator
							false, // TFS 2686 reserveDetail.getRemoveStops,
							totalRequested,
							releaseRequest.deliveryReasonCode,
							releaseRequest.getAllAvailabilityGrades, 
							releaseRequest.deliveryReasonDescr,
							remarks,
							null,	//Ids
							null,	// pinNo
							releaseRequest.myTransferToTerminal,
							null,
							releaseRequest.mySubTerminal,		// cnwdad1 02/07/2009 - CCMS 1735.
							null, 								// MES1008 JMH 29/9/09 Add iso group
							0,		// imex
							colour,
							mark,
							reserveDetail.getBOLNumber //18 Feb 2014	NDL	Par 33524
							);
	
	idMask := releaseRequest.getMaskIdString;  			// dh 25/1/2008 par 15489 added back in
	if idMask &lt;&gt; null then		
		create array transient;
		idMask.convertToDelimitedArray(",", array);
		if array &lt;&gt; null then
			pxyDeliveryRequest.setIds(array);
		endif;
	endif;
														// dh end of change
	pxyDeliveryRequest.setBulkRelease(releaseRequest);

epilog
	delete array;	// PAR #18009

end;</source>
    </JadeMethod>
    <JadeMethod name="deletePinInfoForRemoved" id="f5cf3f50-2cfb-49ec-933c-9090974b5df6">
        <source>deletePinInfoForRemoved( _pxyrelease : CM_BulkRelease);
/*
Date		Who		Reason
10 December 2010	cnwrd1	Initial creation

*/

vars
	stringThing : CM_String;
	theTi			: CM_TrackedItem;
	stuffToKeep : CM_StringDict;
begin
	
	create stuffToKeep transient;

	foreach stringThing in self.allPinNumbers do
		theTi := stringThing.myObject.CM_TrackedItem;
		
		if _pxyrelease.allTrackedItemsAssigned.includes(theTi) then
		//	self.allPinNumbers.remove(stringThing);
		//	delete stringThing;
			stuffToKeep.add(stringThing);
		else
			delete stringThing;
		endif;	
	endforeach;
	
	 self.allPinNumbers.clear;
	
	if stuffToKeep.isEmpty  then
		return;
	endif;
	
	foreach  stringThing in stuffToKeep do
		self.allPinNumbers.add(stringThing);
	endforeach;

epilog
	delete stuffToKeep;
end;</source>
        <Parameter name="_pxyrelease" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="doApplyStopsMaint" id="3bcc81ab-3b45-40b9-81d3-c8417b80d77b">
        <source>doApplyStopsMaint();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2016	cnwndl1	Initial creation	TFS 2646 / 2001

*/

vars

	obj : Object;
	reserveTi : CM_ReserveTI;
	objs : CM_ReserveDetailSet;
	
	form : CMUI_DocumentActionsSelectForm;
	pxyDocActions : CM_ReserveDetailActions;
	updatedDocActions : CM_ReserveDetailActions;
	dispStr :String;
	modalResult : Integer;

begin

	create objs transient;

	obj := self.mnuStopsToApply.userObject;
	if obj &lt;&gt; null and obj.isKindOf(CM_ReserveTI) then
		reserveTi := obj.CM_ReserveTI;
	else	
		self.getReserveTis( objs );
	endif;
	
	if reserveTi = null and objs.isEmpty then
		return;
	endif;
	
	if reserveTi &lt;&gt; null then
		
		pxyDocActions := reserveTi.myReserveDetailActions;
		if pxyDocActions = null then
			create pxyDocActions transient;
			pxyDocActions.setMyReserveDetail( reserveTi );
		endif;
		
		create form transient;
		
		form.setMyTerminal(self.myTerminal);
		form.setBaseData( 	pxyDocActions,	//_documentActionsObj : CM_DocumentActions;
							false,	//_isTasks : Boolean;
							true	//_isStops : Boolean
							);
		
		form.showModal();
		
		if pxyDocActions &lt;&gt; null then
			dispStr := pxyDocActions.getStopsList(CrLf,false).trimBlanks;
		elseif reserveTi &lt;&gt; null and reserveTi.myReserveDetailActions &lt;&gt; null then
			dispStr := reserveTi.myReserveDetailActions.getStopsList(CrLf,false).trimBlanks;
		endif;
		
		tblEntry.setValueByName( ETRow_StopsToApply, dispStr );
		tblEntry.cnEcResizeContents;
		
		return;
	
	elseif not objs.isEmpty then
	
		foreach obj in objs do
			// make sure each one has a reserveDetails action obj.
			if obj.isKindOf(CM_ReserveTI) then
				reserveTi := obj.CM_ReserveTI;
				pxyDocActions := reserveTi.myReserveDetailActions;
				if pxyDocActions = null then
					create pxyDocActions transient;
					pxyDocActions.setMyReserveDetail( reserveTi );
				endif;
			endif;
			
		endforeach;
		
		//get the first one, and update it
		reserveTi := objs.first.CM_ReserveTI;
		pxyDocActions := reserveTi.myReserveDetailActions;
		
		create form transient;
		
		form.setMyTerminal(self.myTerminal);
		form.setBaseData( 	pxyDocActions,	//_documentActionsObj : CM_DocumentActions;
							false,	//_isTasks : Boolean;
							true	//_isStops : Boolean
							);
		
		modalResult := form.showModal();
		
		if pxyDocActions &lt;&gt; null then
			dispStr := pxyDocActions.getStopsList(CrLf,false).trimBlanks;
		elseif reserveTi &lt;&gt; null and reserveTi.myReserveDetailActions &lt;&gt; null then
			dispStr := reserveTi.myReserveDetailActions.getStopsList(CrLf,false).trimBlanks;
		endif;
		
		//now update the rest
		if modalResult = IDOK then
			updatedDocActions := pxyDocActions;
			foreach obj in objs do
				// make sure each one has a reserveDetails action obj.
				if obj.isKindOf(CM_ReserveTI) then
					reserveTi := obj.CM_ReserveTI;
					pxyDocActions := reserveTi.myReserveDetailActions;
					if pxyDocActions &lt;&gt; null and pxyDocActions &lt;&gt; updatedDocActions then
						pxyDocActions.setStopTablesToAdd( updatedDocActions.allStopTablesToAdd );
					endif;
				endif;
			endforeach;
		endif;
		
		tblEntry.setValueByName( ETRow_StopsToApply, dispStr );
		tblEntry.cnEcResizeContents;
		
	endif;
					

epilog

	delete objs;

end;</source>
    </JadeMethod>
    <JadeMethod name="doApplyTasksMaint" id="63fe87a8-8663-4a1c-9a06-e123cbfaab07">
        <source>doApplyTasksMaint();
