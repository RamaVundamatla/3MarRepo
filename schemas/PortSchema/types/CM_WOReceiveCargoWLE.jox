    <JadeMethod name="getLocationId" id="14994783-3376-45ec-b9fd-342d769a1781">
        <source>getLocationId():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	ti 		 : CM_TrackedItem;
	termArea : String;
	lc		 : CM_LocationsController;
begin
	
	ti := self.getTi();
	
	if ti &lt;&gt; null then
		
		termArea := ti.terminalAreaId;
		
		if termArea &lt;&gt; null then
			return termArea;
		endif;
		
		lc := ti.myPrimaryActualLocation;
		
		if lc &lt;&gt; null then
			return lc.getFullId();
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRequestType" id="35791c7a-ddf6-4969-81aa-c5c22d25f124">
        <source>getRequestType(): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who			Reason
14/06/2022 	navcs2 		ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema

*/

vars

begin

	if self.job.myWODtl &lt;&gt; null then
		return REQ_TI_WORKORDER;
	else
		return REQ_TI_RECEIPT;
	endif;


epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
