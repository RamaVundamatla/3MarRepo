<Class name="NumberFormat">
    <JadeMethod name="cnEcCopyInfo" id="b14dd6c1-47ed-4ed9-bb9a-8bcbccf0d9cd">
        <updating/>
        <source>cnEcCopyInfo(pNumberFormatObj: NumberFormat) updating;
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		Refer to LocaleFormat implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	inheritMethod(pNumberFormatObj);
	
	self.decimalPlaces		:=	pNumberFormatObj.decimalPlaces;
	self.decimalSeparator	:=	pNumberFormatObj.decimalSeparator;
	self.groupings			:=	pNumberFormatObj.groupings;
	self.negativeFormat		:=	pNumberFormatObj.negativeFormat;
	self.negativeSign		:=	pNumberFormatObj.negativeSign;
	self.positiveSign		:=	pNumberFormatObj.positiveSign;
	self.showLeadingZeros	:=	pNumberFormatObj.showLeadingZeros;
	self.thousandSeparator	:=	pNumberFormatObj.thousandSeparator;
end;</source>
        <Parameter name="pNumberFormatObj" type="NumberFormat"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetAllGroupings" id="9150609e-a745-4fee-869a-2b794926ea5f">
        <source>cnEcGetAllGroupings(pAllGroupings:IntegerArray input):Integer;
// --------------------------------------------------------------------------------
// Created:		23 August 2001 by cnwdad1
//
// Purpose:		This method populates an array of integers that determine the number
//				of digits in each group of numbers to the left of the decimal point.
//				For example, assume the number "123,456.00".  There are two groups
//				to the left of the decimal, each with three digits (in this case).
//				Whether or not the number actually has a decimal point is irrelevant.
//
//				The default number of digits for the number's groups is returned by
//				the method.  This default is derived by checking the last element in
//				the group array - if this last element is zero, then the preceding
//				value is considered to be the default for all groups, and this default
//				is returned by the method.  If the last element is not zero, then no
//				default group size is assumed, and value of zero is returned by the
//				method, in which case the number of digits in each individual group
//				must be determined from the integer array.
//
//				Refer to the NumberFormat class in the JADE Online Help for further
//				information.
//
// Parameters:	pAllGroupings - The array of numeric group sizes.
//
// Returns:		An array of integer grouping values, plus the default value (or
//				zero if there is no default).
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	defaultGrouping	: Integer;
	allGroupings	: StringArray;
	groupingValue	: String;
	groupingCount	: Integer;
	groupingIndex	: Integer;
	
begin
	pAllGroupings.clear();
	allGroupings	:=	self.groupings.getTokens();
	groupingCount	:=	allGroupings.size();
	groupingIndex	:=	groupingCount;
	
	foreach groupingValue in allGroupings reversed do
		if groupingIndex = groupingCount then
			defaultGrouping	:=	groupingValue.Integer;
		elseif defaultGrouping = 0 and groupingIndex = (groupingCount - 1) then
			defaultGrouping	:=	groupingValue.Integer;
		else
			defaultGrouping	:=	0;
		endif;
		
		pAllGroupings.insert(1, groupingValue.Integer);
	endforeach;
epilog
	delete allGroupings;
	return defaultGrouping;
end;</source>
        <Parameter name="pAllGroupings" type="IntegerArray" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcStripNonNumeric" id="8f614c9f-878b-4c7d-91a2-bb64ed820830">
        <source>cnEcStripNonNumeric(pValue:String):String;
// --------------------------------------------------------------------------------
// Created:		09 October 2001 by cnwdad1
//
// Purpose:		Strips all non-numeric characters from the specified value, and
//				returns the result.
//
// Parameters:	The values to be stripped.
//
// Returns:		The result of the stripped value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	workValue			: String;
	currentChar			: Character;
	charIndex			: Integer;
	valueLength			: Integer;
	decimalCharacter	: String;
	decimalLength		: Integer;			// Can be up-to three characters.
	decimalStart		: Integer;			// Starting position of decimal separator character(s).
	decimalEnd			: Integer;			// Starting position of decimal separator character(s).
	returnValue			: String;
	negativeSignString	: String;
	negativeSignLength	: Integer;			
	negativeSignStart	: Integer;			// Starting position of negative sign character(s).
	negativeSignEnd		: Integer;			// Starting position of negative sign character(s).
	positiveSignString	: String;
	positiveSignLength	: Integer;			
	positiveSignStart	: Integer;			// Starting position of negative sign character(s).
	positiveSignEnd		: Integer;			// Starting position of negative sign character(s).
	
begin
	workValue			:=	pValue;
	valueLength			:=	workValue.length;
	decimalCharacter	:=	self.decimalSeparator;
	negativeSignString	:=	self.negativeSign;
	positiveSignString	:=	self.positiveSign;
	
	if decimalCharacter &lt;&gt; null then
		if workValue.cnEcSubstringCount(decimalCharacter) &gt; 1 then
			// The can only be one decimal separator character(s).
			return null;
		endif;

		decimalLength		:=	decimalCharacter.length;
		decimalStart		:=	workValue.pos(decimalCharacter, 1);
		
		if decimalStart = 0 then
			decimalCharacter	:=	null;
		else
			decimalEnd			:=	(decimalStart + decimalLength) - 1;
		endif;
	endif;
	
	if negativeSignString &lt;&gt; null then
		if workValue.cnEcSubstringCount(negativeSignString) &gt; 1 then
			// The can only be one negaitive sign character(s).
			return null;
		endif;

		negativeSignLength		:=	negativeSignString.length;
		negativeSignStart		:=	workValue.pos(negativeSignString, 1);
		
		if negativeSignStart = 0 then
			negativeSignString	:=	null;
		else
			negativeSignEnd			:=	(negativeSignStart + negativeSignLength) - 1;
		endif;
	endif;
	
	if positiveSignString &lt;&gt; null then
		if workValue.cnEcSubstringCount(positiveSignString) &gt; 1 then
			// The can only be one positive sign character(s).
			return null;
		endif;

		positiveSignLength		:=	positiveSignString.length;
		positiveSignStart		:=	workValue.pos(positiveSignString, 1);
		
		if positiveSignStart = 0 then
			positiveSignString	:=	null;
		else
			positiveSignEnd		:=	(positiveSignStart + positiveSignLength) - 1;
		endif;
	endif;
	
	foreach charIndex in 1 to valueLength do
		currentChar	:=	workValue[charIndex];
		
		if currentChar.isNumeric then
			returnValue	:=	returnValue &amp; currentChar;
			
		elseif charIndex &gt;= decimalStart
		and charIndex &lt;= decimalEnd
		then
			// We're within the bounds of the decimal separator character(s).
			returnValue	:=	returnValue &amp; currentChar;
			
		elseif charIndex &gt;= negativeSignStart
		and charIndex &lt;= negativeSignEnd
		then
			// We're within the bounds of the negative sign character(s).
			returnValue	:=	returnValue &amp; currentChar;
			
		elseif charIndex &gt;= positiveSignStart
		and charIndex &lt;= positiveSignEnd
		then
			// We're within the bounds of the positive sign character(s).
			returnValue	:=	returnValue &amp; currentChar;
		else
		
		endif;
	endforeach;

	return returnValue;
end;</source>
        <Parameter name="pValue" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
