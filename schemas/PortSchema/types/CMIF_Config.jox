    <JadeMethod name="isPropertyToIgnore" id="f53e9653-d9b8-4e21-934f-1127e99821eb">
        <source>isPropertyToIgnore(_prop : Property) : Boolean;
// ---------------------------------------------------------------------------
// Created:     12 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _prop.virtual then
		return true;
	endif;
	
	return false;

end;</source>
        <Parameter name="_prop" type="Property"/>
