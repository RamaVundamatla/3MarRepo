    <JadeMethod name="getAttrIsNOT20" id="91e0a35e-f72b-42cf-b191-305cc35632b0">
        <source>getAttrIsNOT20() : Boolean;
/*
Purpose:			
Date		Who		Reason
27 August 2012	cnwab1	Initial creation
// 11/10/2022	navkc1	Bug 54935: MSL - Roro planning - Slow on big decks/large vessels
*/

vars
	isoTypeCriteria,
	isoGrpCriteria,	
	criteria 		: CM_YACriteria;	
	voyAlloc 		: CM_VoyageAllocation;
	yaData			: CM_YAData;
begin

	//return self.getAttrIs40() or self.getAttrIs30() or self.getAttrIs45() or self.getAttrIs53(); // PAR 30253
	
	voyAlloc := self.allAllocations.first().CM_VoyageAllocation;
	if voyAlloc &lt;&gt; null then
		
		/*
			Criteria Check
		*/
		//40FT
		criteria 			:= voyAlloc.getCriteriaOfTypeValue(YACriteriaType_IsForty);
		if criteria &lt;&gt; null then
			if criteria.myYAData.CM_YADataBoolean.getDataValue().Integer = CM_YADataBoolean.VALUE_TRUE then
				return true;
			endif;
		endif;
		//30FT
		criteria 			:= voyAlloc.getCriteriaOfTypeValue(YACriteriaType_IsThirty);
		if criteria &lt;&gt; null then
			if criteria.myYAData.CM_YADataBoolean.getDataValue().Integer = CM_YADataBoolean.VALUE_TRUE then
				return true;
			endif;
		endif;
		//45FT
		criteria 			:= voyAlloc.getCriteriaOfTypeValue(YACriteriaType_IsFortyFive);
		if criteria &lt;&gt; null then
			if criteria.myYAData.CM_YADataBoolean.getDataValue().Integer = CM_YADataBoolean.VALUE_TRUE then
				return true;
			endif;
		endif;
		//53FT
		criteria 			:= voyAlloc.getCriteriaOfTypeValue(YACriteriaType_IsFiftyThree);
		if criteria &lt;&gt; null then
			if criteria.myYAData.CM_YADataBoolean.getDataValue().Integer = CM_YADataBoolean.VALUE_TRUE then
				return true;
			endif;
		endif;
		
		/*
			Iso Group Check
		*/
		isoGrpCriteria		:= voyAlloc.getCriteriaOfTypeValue(YACriteriaType_ISOGroup); 
		if isoGrpCriteria &lt;&gt; null then
			
			yaData := isoGrpCriteria.myYAData;
			
			//40FT
			if self.getAttrCheckAllValuesCriteria(yaData.CM_YADataObjects.allObjects,CM_ISOTypeGroup,CM_ISOTypeGroup::is40ftLong.name) then
				return true;
			endif;
			//30FT
			if self.getAttrCheckAllValuesCriteria(yaData.CM_YADataObjects.allObjects,CM_ISOTypeGroup,CM_ISOTypeGroup::is30ftLong.name) then
				return true;
			endif;
			//45FT
			if self.getAttrCheckAllValuesCriteria(yaData.CM_YADataObjects.allObjects,CM_ISOTypeGroup,CM_ISOTypeGroup::is45ftLong.name) then
				return true;
			endif;
			//53FT
			if self.getAttrCheckAllValuesCriteria(yaData.CM_YADataObjects.allObjects,CM_ISOTypeGroup,CM_ISOTypeGroup::is53ftLong.name) then
				return true;
			endif;
		endif;
		
		/*
		Iso Type Check
		*/
		isoTypeCriteria		:= voyAlloc.getCriteriaOfTypeValue(YACriteriaType_ISO); 
		if isoTypeCriteria &lt;&gt; null then
			
			yaData := isoTypeCriteria.myYAData;
			
			//40FT
			if  self.getAttrCheckAllValuesCriteria(yaData.CM_YADataObjects.allObjects,CM_ISOType,CM_ISOType::is40ftLong.name) then
				return true;
			endif;
			//30FT
			if  self.getAttrCheckAllValuesCriteria(yaData.CM_YADataObjects.allObjects,CM_ISOType,CM_ISOType::is30ftLong.name) then
				return true;
			endif;
			//45FT
			if  self.getAttrCheckAllValuesCriteria(yaData.CM_YADataObjects.allObjects,CM_ISOType,CM_ISOType::is45ftLong.name) then
				return true;
			endif;
			//53FT
			if  self.getAttrCheckAllValuesCriteria(yaData.CM_YADataObjects.allObjects,CM_ISOType,CM_ISOType::is53ftLong.name) then
				return true;
			endif;
		endif;
	endif;
	
	return false;

	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAttrIsSpecialStow" id="1e8aca58-aae8-4026-a7a6-d76f064ecd8d">
        <source>getAttrIsSpecialStow() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 December 2009	cnwas3	Initial creation

*/

vars
	criteria : CM_YACriteria;	
begin
	
	criteria := self.getAttrByType(YACriteriaType_SpecialStow); 
	if criteria &lt;&gt; null then
		return not criteria.myYAData.CM_YADataObjects.allObjects.isEmpty();			// if it has any special object set then it is special stow
	endif;
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
