    <JadeMethod name="setForCreateInternal" id="8214bf84-39ec-4cf1-a1e6-38041e55927f">
        <updating/>
        <source>setForCreateInternal(_packInternalJobParam : CMIF_WorkOrderJobParams;_terminal : CM_Terminal) updating;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 Jul 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
18 Apr 2023 navma1  ChangeRequest 55442:[54989] EUP - Pack Cargo Work Order - Enhancement
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
02 Apr 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work
*/


vars
	req : CM_WOPackRequest;
begin

	inheritMethod(_packInternalJobParam, _terminal);											//02.06.2023 navma1 #58296

	self.isPackParentJob 	:= _packInternalJobParam.isPackParentJob;
	//---------------
	//Build a Request
	//---------------
	create req;	
	req.setForCreateInternal(self, _packInternalJobParam);
	
	if self.myWODtl.CM_WodPack.myReleaseRequest &lt;&gt; null then									//17.04.2023 navma1 #55442:[54989]
		req.setMyOriginatingBulkRelease( self.myWODtl.CM_WodPack.myReleaseRequest);
	endif;
	
	//---------------
	//Build the WLEs' from the request.
	//---------------
	self.createWLEs();
	//self.setJobPlannedLocation();																	//02.04.2024 navhl20 #63251
	self.setJobPlannedLocation(false); //26/08/2024	navkc1 CR 63588 Task 63589
end;</source>
        <Parameter name="_packInternalJobParam" type="CMIF_WorkOrderJobParams"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
