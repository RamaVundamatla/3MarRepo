<Class name="JSSChangeTrackingServiceMgr" id="95fc6845-e91a-4712-b6c5-bca8aa28ca64">
    <superclass name="JSSServiceManagerObject"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="jssct_transient"/>
    <JadeMethod name="finalize" id="043d5c95-b949-47a7-a53e-c83b3c458942">
        <updating/>
        <source>finalize() updating;

begin
	//	remove this application from the process dictionary
	if self.myTA &lt;&gt; null then
//		if self.myProcessObjectDict &lt;&gt; null and self.myProcessObject &lt;&gt; null then
			self.myTA.trxRemoveProcessObjectForApp(self);
//		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getPublicInterface" id="bfd6b0ff-95c7-47b0-bbee-5dc2af36c756">
        <source>getPublicInterface(): JSSCTChangeTrackingInterface;
/*
*/
vars
	serviceObject: JSSServiceObject;
begin
	foreach serviceObject in self.allServiceObjects do
		if serviceObject.isKindOf(JSSCTChangeTrackingInterface) then
			return serviceObject.JSSCTChangeTrackingInterface;
		endif;
	endforeach;
	//	nothing found
	return null;
end;</source>
        <ReturnType type="JSSCTChangeTrackingInterface"/>
    </JadeMethod>
    <JadeMethod name="getTAClass" id="4beea96a-7636-4991-98d7-e292b827dd3d">
        <source>getTAClass(): Class protected;

begin
	return(JSSCTNibblerManagerTA);
end;</source>
        <access>protected</access>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="initialize" id="cd0da568-fb8a-4026-8946-5e64118c39c3">
        <updating/>
        <source>initialize() updating;

vars

begin
	self.monitor(self.class.name&amp;'::'&amp;method.name);
	inheritMethod();
	if self.myProcessObjectDict = null then
		self.monitor("$$$$$ " &amp; self.String &amp; ".myProcessObjectDict is null - " &amp; process.String);
	endif;
	if self.myProcessObject = null then
		self.monitor("$$$$$ " &amp; self.String &amp; ".myProcessObject is null - " &amp; process.String);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="monitor" id="8efdb242-1b58-461b-9cf9-ca7cf70e485d">
        <source>monitor(pMessage: String);
/*
*/
vars
	serviceObject: JSSServiceObject;
	nibblerManager: JSSCTNibblerManager;
begin
	foreach serviceObject in self.allServiceObjects do
		if serviceObject.isKindOf(JSSCTChangeTrackingInterface) then
			nibblerManager := serviceObject.JSSCTChangeTrackingInterface.myNibblerManager;
			if nibblerManager &lt;&gt; null then
				nibblerManager.monitor(pMessage, JSSCTNibblerManager.MONITOR_ALWAYS);
			endif;
			break;
		endif;
	endforeach;
end;</source>
        <Parameter name="pMessage" type="String"/>
    </JadeMethod>
</Class>
