    <JadeMethod name="trxUpdateAddCntrctRtEntries" id="3e60f8b2-e96c-4ef6-9b23-396638c34933">
        <updating/>
        <source>trxUpdateAddCntrctRtEntries(_agent1,_agent2 : CMIF_InvoiceContractBulkRates;
							 _passport : CM_Passport input) updating;
/*
Purpose:			

Date		Who		Reason
// ### 25 October 2023 navmv20 CR 60503 Task 60505: UI - Contract Rate Entry UI Changes
*/
vars
	proxyRateEntry,
	realContractRateEntry : CM_InvoiceContractRateEntry;
begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;
	
	// ### TFS CR 61268 29NOV2023 NAVAB1
	app.myUtilityUA.utlUpdateInvContractRtEntryBlk(_agent1, _passport); 

	foreach proxyRateEntry in _agent2.allPxyRateEntries as CM_InvoiceContractRateEntry do
		app.myUtilityCA.utlCreateInvContractDtlRtEntry(proxyRateEntry,realContractRateEntry, _passport);
		if _passport.hasErrors then
			return;
		endif;
	endforeach;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_agent1" type="CMIF_InvoiceContractBulkRates"/>
        <Parameter name="_agent2" type="CMIF_InvoiceContractBulkRates"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateAgentDebtor" id="8159e431-5af6-44fa-bb0e-c8f89861218b">
        <updating/>
        <source>trxUpdateAgentDebtor(_cmif : CMIF_AgentDebtor; _realAgent : CM_Object; _realDebtor : CM_Debtor; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     20 February 2014 cnwjre1
//
// Purpose:     Update consignee/consignor/freight forwarder/customs agent and debtor together
//				CCMS GLT 2342 par 33497
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25/03/2015	cnwdap1		PAR #35895 CCMS PNL 2461 added isUsedForPacking attribute
// 03 Aug 2017	cnwma1		TFS #5209:PEN - Release Request Stop
// 09/08/2018	jlgdap1		TFS 40092 New parameter for CM_DebtorNode::setProxy
// 10/06/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
// ---------------------------------------------------------------------------
vars
	proxyConsignee	: CM_ConsigneeConsignor;
	proxyCustomsAgent	: CM_CustomsAgent;
	proxyStevedore		: CM_Stevedore;				// TFS 44554
	proxyDebtorNode		: CM_DebtorNode;
	debtorNodeController	: CMIF_DebtorNode;
	customsAgent	: CM_CustomsAgent;
	stevedore		: CM_Stevedore;					// TFS 44554
	consignee		: CM_ConsigneeConsignor;
	newDebtorNode			: CM_DebtorNode;
	newDebtor				: CM_Debtor;
	theBank : CM_Bank;
	rdg		: CM_RootDebtorGroup;
	term : CM_Terminal;
	debtorTermDetail : CMIF_DebtorTerminalDetail;
	paymenttype : Integer;
	drterm : CM_DebtorTerminal;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	// setup newDebtor as the agent debtor, defaults to current unless explicitly changed
	if _cmif.agentType = CUSTOMS_AGENT then
		customsAgent := _realAgent.CM_CustomsAgent;
		newDebtor := customsAgent.myDebtor;
	elseif _cmif.agentType = STEVEDORE then					// TFS 44554
		stevedore := _realAgent.CM_Stevedore;				// TFS 44554
		newDebtor := stevedore.myDebtor;					// TFS 44554
	else
		consignee := _realAgent.CM_ConsigneeConsignor;
		newDebtor := consignee.debtor;
	endif;

	if _cmif.myDebtor &lt;&gt; null then
		// change of debtor, do no setup here
		newDebtor := _cmif.myDebtor;
	elseif _realDebtor &lt;&gt; null then  // UPDATE
		if not _realDebtor.isRDT() then
			// changing the attributes of the current agent debtor unless it's the default debtor
			create debtorNodeController transient;
			debtorNodeController.setFromDebtor(_realDebtor);		// set from the debtor then override selectively here

			beginLoad;
			proxyDebtorNode := _realDebtor.pxyCreateUpdateProxy();
			endLoad;
			//proxyDebtorNode.setProxy(_cmif.debtorName);				// TFS 40092
			proxyDebtorNode.setProxy(_cmif.debtorName, null);			// TFS 40092
			debtorNodeController.myPxyDebtorNode := proxyDebtorNode;
			debtorNodeController.name := _cmif.debtorName;
			debtorNodeController.billingAddress := _cmif.debtorAddress;
			debtorNodeController.decfinName := _cmif.agentCode;
	
		endif;
	elseif _cmif.debtorName &lt;&gt; null then
	//	adding a debtor to an existing agent
		create debtorNodeController transient;

		theBank := app.myRoot.myRootCompany;
		rdg := theBank.getRootDebtorGroup();
	
		debtorNodeController.myBank := theBank;
		debtorNodeController.myParentDebtorNode := rdg;
		create proxyDebtorNode as CM_Debtor transient;
		//proxyDebtorNode.setProxy(_cmif.debtorName);				// TFS 40092
		proxyDebtorNode.setProxy(_cmif.debtorName, null);			// TFS 40092
		debtorNodeController.myPxyDebtorNode := proxyDebtorNode;		// this is used to get the class to create, nothing else
		debtorNodeController.name := _cmif.debtorName;
		debtorNodeController.billingAddress := _cmif.debtorAddress;
		debtorNodeController.decfinName := _cmif.agentCode;
		
		// ### TFS 52237 02NOV2021 NAVAB1 add debtor terminal for all terminals
		foreach term in app.myRoot.allTerminals do
			create debtorTermDetail transient;
			
			debtorTermDetail.setMyTerminal(term);
			
			drterm := _realDebtor.allDebtorTerminals[term];
			if drterm &lt;&gt; null then
				debtorTermDetail.setPaymentType(drterm.paymentType);
			else
				debtorTermDetail.setPaymentType(PaymentType_None);
			
			endif;
			
			if _cmif.isCashOnly then
				debtorTermDetail.setCashOnly(term.isCashOnlyEnabled());
			
			endif;
			debtorNodeController.allDebtorTerminalDetails.add(debtorTermDetail);
		endforeach;
		
		
		
		
		// assign to agent here
		if _realAgent.isKindOf(CM_ConsigneeConsignor) then
			debtorNodeController.allConsignors.add(_realAgent.CM_ConsigneeConsignor);
		elseif _realAgent.isKindOf(CM_CustomsAgent) then
			debtorNodeController.allCustomsAgents.add(_realAgent.CM_CustomsAgent);
		elseif _realAgent.isKindOf(CM_Stevedore) then									// TFS 44554
			debtorNodeController.allStevedores.add(_realAgent.CM_Stevedore);			// TFS 44554
		endif;
	endif;

	app.setContinueCMExceptions(false);
	// create and populate the proxies and debtor cmif
	if _cmif.agentType = CUSTOMS_AGENT then
		customsAgent := _realAgent.CM_CustomsAgent;
		beginLoad;
		proxyCustomsAgent := customsAgent.pxyCreateUpdateProxy();
		endLoad;
		proxyCustomsAgent.setProxy(_cmif.agentCode,
								   _cmif.agentDescription,
								   customsAgent.isNotAvailableForEntry,
								   newDebtor);
	
	// TFS 44554
	elseif _cmif.agentType = STEVEDORE then
		stevedore := _realAgent.CM_Stevedore;
		beginLoad;
		proxyStevedore := stevedore.pxyCreateUpdateProxy();
		endLoad;
		proxyStevedore.setProxy(	_cmif.agentCode,
									_cmif.agentDescription,
									stevedore.notAvailableForEntry,
									newDebtor	);
	// TFS 44554
	
	else
		consignee := _realAgent.CM_ConsigneeConsignor;
		beginLoad;
		proxyConsignee := consignee.pxyCreateUpdateProxy();
		endLoad;
		proxyConsignee.setProxy(_cmif.agentCode,
								_cmif.agentDescription,
								consignee.isNotAvailableForEntry,
								consignee.secureExportPartner,
								consignee.derogationNumber,
								consignee.emailAddress,
								consignee.colour,
								consignee.order,
								consignee.myConsignGroup,
								newDebtor,
								consignee.showOOWRemarks,
								_cmif.isConsignee,
								_cmif.isConsignor,
								_cmif.isFreightForwarder,
								consignee.allPINNotifyEmailAddresses,
								consignee.license,
								consignee.licenseExpiryDate,
								consignee.isUsedForPacking,				// PAR #35895
								consignee.isRestricted,
								consignee.isInternal);				// 3.8.2017 cnwma1 TFS #5209
	endif;
	
	// Start the transaction.  Do agent first as the debtor update unconditionally updates the agent debtor and the agent edition changes
	beginTransaction;
	if _cmif.agentType = CUSTOMS_AGENT then
		app.myUtilityUA.utlUpdateCustomsAgent(proxyCustomsAgent, _passport);
	elseif _cmif.agentType = STEVEDORE then										// TFS 44554
		app.myUtilityUA.utlUpdateStevedore(proxyStevedore, _passport);			// TFS 44554
	else
		app.myUtilityUA.utlUpdateConsigneeConsignor(proxyConsignee, _passport);
	endif;
	
	if debtorNodeController &lt;&gt; null then
		if _realDebtor &lt;&gt; null then		// change of debtor attributes
			app.myUtilityUA.utlUpdateDebtorNode(debtorNodeController, _passport);
			if not self.checkValidationWithPassport(_passport) then
				return;
			endif;
		else
			// add a debtor assigning to the agent
			app.myUtilityCA.utlCreateDebtorNode(debtorNodeController, newDebtorNode, _passport);
		endif;
	endif;

epilog
	endLoad;
	
	if debtorNodeController &lt;&gt; null then
		debtorNodeController.allDebtorTerminalDetails.purge(); // ### TFS 52237 27OCT2021 NAVAB1
	endif;
	
	delete debtorNodeController;
	delete proxyDebtorNode;
	delete proxyCustomsAgent;
	delete proxyConsignee;
	delete proxyStevedore;							// TFS 44554
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_cmif" type="CMIF_AgentDebtor"/>
        <Parameter name="_realAgent" type="CM_Object"/>
        <Parameter name="_realDebtor" type="CM_Debtor"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateAssignBulkOutRail" id="13c2c759-8dde-42e4-b74a-3e6e4e5767be">
        <updating/>
        <source>trxUpdateAssignBulkOutRail(_intFaceBP : CMIF_BuildPriority input;
							_targetIORake : CM_RailJSInOutRake; 
							_targetTrain : CM_Train input;
							_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Feb 2017	cnwndl1	Initial creation	TFS 3514
27 Apr 2023	jlier1 	TFS 56773
12 Sep 2024 navlc30 Bug 65971: When we assign bulk releases to a wagon to create rail jobs, the first warehouse and the number of warehouse locations are not updated.
19 May 2025	navbs1	Bug MTN-34762: MTN - Add Deferred Updates Rail Operation 
28 Oct 2025	navcs2	Bug MTN-35760: TPT Rail Planning error
*/

vars

	targetType : Integer;
	tmpRailJob : CM_RailJob;
	tmpRes : CM_ReserveDetail;
	cmifReq : CMIF_Request;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	
	app.setContinueCMExceptions(true);
		
	beginTransaction;
	
	_passport.useTIDictDeferUpdate := true;				//19.05.2025 navbs1 #34762
	_passport.useTITransactionDeferUpdate := true; 		//19.05.2025 navbs1 #34762
	
	app.myUtilityUA.utlBuildPriorityRailOps(_intFaceBP, _passport);
	
	if _passport.noErrors then				// 28 Oct 2025	navcs2	Bug MTN-3576
		_passport.doDeferredUpdates();		// 28 Oct 2025	navcs2	Bug MTN-3576		
	else									// 28 Oct 2025	navcs2	Bug MTN-3576
		return;								// 28 Oct 2025	navcs2	Bug MTN-3576
	endif;									// 28 Oct 2025	navcs2	Bug MTN-3576
	
	//jlier1 TFS 56773 27/7/23 
	if _targetTrain &lt;&gt; null then
		foreach cmifReq in _intFaceBP.allCMIFRequests  discreteLock do
			if cmifReq.myNewJob &lt;&gt; null and cmifReq.myNewJob.isKindOf(CM_RailJob) then
				app.myUtilityUA.utlUpdateJobTrains(cmifReq.myNewJob.CM_RailJob, _targetTrain, true,  _passport);				
			endif;
		endforeach;
	endif;
	
	if _targetIORake = null then
		return;
	endif;
	
	targetType := _targetIORake.inOut.outwards;

	foreach tmpRes in _intFaceBP.allReservesToProcess discreteLock do
		if _intFaceBP.myProxyRailJob = null then
			continue;
		endif;
		tmpRailJob := _intFaceBP.myProxyRailJob.pxyGetRealObject;
		if tmpRailJob = null then
			continue;
		endif;
		tmpRailJob.setJobPlannedLocation(true);		//16.09.2024 navlc30 #65971
		app.myUtilityUA.utlUpdateJobRailOps(tmpRailJob, _targetIORake, true, targetType, _passport);
		if _passport.hasErrors() then
			return;
		endif;

	endforeach;

epilog		
	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_intFaceBP" type="CMIF_BuildPriority" usage="input"/>
        <Parameter name="_targetIORake" type="CM_RailJSInOutRake"/>
