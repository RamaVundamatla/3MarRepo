    <JadeMethod name="createFromNote" id="9e51bfa6-427c-4373-9ef5-ae65fe989f1d">
        <source>createFromNote(_alloc : CM_InvoiceAllocation);
/*

Purpose:			// TFS 7496

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2017	jlgab1	Initial creation

*/

vars
	idx : Integer;
begin
		idx := self.tblData.addItemObject(_alloc,  _alloc.description  &amp; Tab &amp; 
										  _alloc.getInvoiceLineTypesString &amp; Tab &amp; 
										  _alloc.priorityValue.asStringJMT()&amp; Tab &amp; 
										  _alloc.myQuantityMap.allQuantityRanges.size.asStringJMT() 
										  ); 
epilog

end;</source>
        <Parameter name="_alloc" type="CM_InvoiceAllocation"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="af316792-4e6c-45fd-bc0b-5810e4ac9577">
        <updating/>
        <source>doDelete() updating;
/*
Purpose:			
Date		Who		Reason
17 March 2015	cnwab1	Initial creation
*/

vars

	result : Integer;
	mapping : CM_TranMapInvoiceLineMapping;
	invLineDesc : CM_InvoiceLineDesc;
	deletMessString : String;
	
begin	
	if self.myCurrentAllocation = null then
		return;
	endif;
	
	if self.myCurrentAllocation.isKindOf( CM_InvoiceCargoAllocation ) then
		deletMessString := self.myCurrentAllocation.description;
	elseif self.myCurrentAllocation.isKindOf( CM_InvoiceAllocation ) then	//04 Feb 2019	NDL	TFS 43153
		deletMessString := self.myCurrentAllocation.CM_InvoiceAllocation.getDisplayDescriptionString;
	endif;
	
	if app.msgBox(app.getErrorString1(Please_confirm_deletion, deletMessString), app.getErrorString(Confirm_Delete), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then 
		return;
	endif;

	while true do
		if self.myCurrentAllocation.isKindOf( CM_InvoiceCargoAllocation ) then
			app.myTrxDA.trxDeleteInvoiceCargoAlloc(self.myCurrentAllocation); // ### TFS 51219 25MAY2021 NAVAB1
		elseif self.myCurrentAllocation.isKindOf( CM_InvoiceAllocation ) then	//04 Feb 2019	NDL	TFS 43153
			if self.myQuantityRangeMap &lt;&gt; null then
				invLineDesc := self.myQuantityRangeMap.allInvoiceLineMaps.first;
			endif;
			app.myTrxDA.trxDeleteInvoiceAllocation(self.myCurrentAllocation.CM_InvoiceAllocation, self.myQuantityRangeMap, invLineDesc, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.myCurrentAllocation := null;
 // TFS 7496			self.populateTable();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Allocation), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);
		endif;
		
		break;
	endwhile;	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doUserNote" id="c54083cc-e72a-40f2-8c0c-0a936f3895f4">
        <updating/>
        <source>doUserNote(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*
Purpose:			
Date		Who		Reason
18 March 2015	cnwab1	Initial creation
*/

vars
	event : Integer;
	alloc : CM_InvoiceAllocation;
begin
	event := self.myTerminal.getEventFromTerminalEvent(eventType);

	if event = EVENT_TRANSACTIONMAP_UPDATE then // TFS 7496
			if userInfo.isKindOf(CM_InvoiceAllocation) then
				alloc := userInfo.CM_InvoiceAllocation;
				self.updateFromNote(alloc);
			else
				self.populateTable();
			endif;
	
	endif;
	
	if event = EVENT_TRANSACTIONMAP_CREATE then // TFS 7496
			if userInfo.isKindOf(CM_InvoiceAllocation) then
				alloc := userInfo.CM_InvoiceAllocation;
				self.createFromNote(alloc);
			else
				self.populateTable();
			endif;
	
	endif;
	
	if event = EVENT_TRANSACTIONMAP_DELETE then // TFS 7496
			if userInfo.isKindOf(CM_InvoiceAllocation) then
				alloc := userInfo.CM_InvoiceAllocation;
				self.tblData.removeDeletedObject(alloc);
			else
				self.populateTable();
			endif;
				

	endif;
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="initTable" id="a7e15662-209b-4008-8c49-2155b9e44bb3">
        <source>initTable();
/*
Purpose:			
Date		Who		Reason
17 Mar 2015	cnwab1	Initial creation
30 May 2017	cnwkpd1	TFS #4542 - Add Priority column to the table
*/

vars

begin
	self.tblData.rows := 0;
	self.tblData.columns := 4;// TFS 6536
	self.tblData.selectMode := Table.SelectMode_WholeRows; // TFS 7496

	// If you change this order you must change tblData_dblClick which sets the priority column to be numeric
	self.tblData.addItem(app.getErrorString(Allocation) &amp; Tab &amp; 
								app.getErrorString(Invoice_line_type) &amp; Tab &amp; 
								app.getErrorString(Priority) &amp; Tab &amp; 
								app.getErrorString(Mapping)
								);

	self.tblData.fixedRows := 1;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateTable" id="9c4a82b6-ffbd-4141-8e75-3b0cdf6fee6a">
        <source>populateTable();
/*

Purpose:			

Date		Who		Reason
17 Mar 2015	cnwab1	Initial creation
30 May 2017	cnwkpd1	TFS #4542 - Add Priority column to the table, and list in Priority order
15 Nov 2017 	CNWAB1	TFS 7496 - refactored whole table
*/

vars
	alloc : CM_InvoiceAllocation;
	ya : CM_YardAllocation;
	idx, size : Integer;
	
begin

	self.tblData.rows := self.tblData.fixedRows;
	
	foreach ya in self.mySnapShotBroker.allInvoiceAllocations discreteLock do
		alloc := ya.CM_InvoiceAllocation;	
		idx := self.tblData.addItemObject(alloc,  alloc.description  &amp; Tab &amp; 
										  alloc.getInvoiceLineTypesString &amp; Tab &amp; 
										  alloc.priorityValue.asStringJMT()&amp; Tab &amp; 
										  alloc.myQuantityMap.allQuantityRanges.size.asStringJMT() 
										  ); 
		
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="7b84e318-8a62-4c60-b47e-2f4c3bebe0a0">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			
Date		Who		Reason
11 March 2015	cnwab1	Initial creation
*/

vars

begin

	if self.myAssistant = null then
		create self.myAssistant as INV_Assistant transient;
		self.myAssistant.setMyTerminal( self.myTerminal );
	endif;	

	inheritMethod();
	
	if self.mySnapShotBroker &lt;&gt; null then
		self.setCaption(self.mySnapShotBroker.getDescription &amp; " - " &amp; app.getErrorString(Snapshot_allocation));
	else
		self.setCaption(app.getErrorString(Snapshot_allocation));
	endif;
	
	self.initTable();
	self.populateTable();
	
	self.beginNotification(self.mySnapShotBroker, self.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_UPDATE), Response_Continuous, null); 
	self.beginNotification(self.mySnapShotBroker, self.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_DELETE), Response_Continuous, null); 
	self.beginNotification(self.mySnapShotBroker, self.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_CREATE), Response_Continuous, null);
	
epilog

end;</source>
    </JadeMethod>
