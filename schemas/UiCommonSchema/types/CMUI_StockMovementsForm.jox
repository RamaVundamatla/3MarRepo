    <JadeMethod name="loadCargoTypes" id="8b9923ba-c3be-4e27-af69-ab68f466ab52">
        <updating/>
        <source>loadCargoTypes() updating;
// ---------------------------------------------------------------------------
// Created:     02 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cargoBOLTypeArray 	: CM_CargoBOLTypeArray;
	tmpCargoTypeDict	: CM_CargoTypesByIdDict;
	cargoBOLType		: CM_CargoBOLType;
	cargoType			: CM_CargoType;
begin
	create tmpCargoTypeDict transient;
	
	cargoBOLTypeArray := self.myTerminal.allCargoBOLTypes;
	foreach cargoBOLType in cargoBOLTypeArray do
		//2/11/2009 cnwdz2 par21498
		if cargoBOLType.isKindOf(CM_CargoType) and cargoBOLType.CM_CargoType.allProducts.size() &gt; 0 then
			tmpCargoTypeDict.add(cargoBOLType.CM_CargoType);
		endif;
	endforeach;
	
	// 28/05/2010 cnwar2 #24329
	if cmbCargoType.listObject &lt;&gt; null then
		cargoType := cmbCargoType.listObject.CM_CargoType;
	endif;
	
	if tmpCargoTypeDict.size &gt; 0 then
		cmbCargoType.listCollection(tmpCargoTypeDict, false,0);
		if cargoType = null then
			cargoType := tmpCargoTypeDict.first;
		endif;
		cmbCargoType.listObject := cargoType;
		self.myFiltCargoType := cargoType;
		self.loadProducts;
	endif;
epilog
	delete tmpCargoTypeDict;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadData" id="9e314224-ed66-44c7-8db4-dc3b3793ff04">
        <updating/>
        <source>loadData(_lc : CM_LocationsController) updating, protected;
// ---------------------------------------------------------------------------
// Created:      29 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
filtOpenLocalTS :TimeStamp;
filtCloseLocalTS : TimeStamp;


begin
	if cmbQueryType.listCount &gt; 0 then // AKB I added this so that this form can be initialized from a context menu
		return;
	endif;
	
	self.setColorsFromController(null);

	self.setNavigatorHeading(self.caption);

	self.loadQueryTypes();
	self.zInitTblEntQuery();
	self.zInitTblData();
	self.loadLocationTypes();
//	self.loadOperators;
	self.loadCargoTypes();
	self.loadDefaultDates();
	self.doQueryTypeClick(QueryType_StkMoveByLocation);
	self.doCmbLocationTypeClick(LocationType_LC);
	self.cbShowDetail.value := true;
	
	self.filtLocationType := self.cmbLocationType.text;
	self.myFiltLC := _lc;
	
	//set tblEntQuery row values
	tblEntQuery.setValueByName(ETRow_QueryType, cmbQueryType.text);
	tblEntQuery.setValueByName(ETRow_LocationType, cmbLocationType.text);
	if cmbLocation.findObject(_lc) &gt; 0 then
		cmbLocation.listIndex := cmbLocation.findObject(_lc);
	endif;
	tblEntQuery.setValueByName(ETRow_Location, cmbLocation.text);
	
	filtOpenLocalTS.cnEcSetDateAndTime(self.filtOpenDate,TimeStartOfDay);// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	filtOpenLocalTS := self.systemToLocalTime(filtOpenLocalTS);			// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	filtCloseLocalTS.cnEcSetDateAndTime(self.filtCloseDate,TimeEndOfDay);// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	filtCloseLocalTS := self.systemToLocalTime(filtCloseLocalTS);		// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	
	tblEntQuery.setValueByName(ETRow_OpenDate, filtOpenLocalTS.date().shortFormatJMT());
	tblEntQuery.setValueByName(ETRow_CloseDate, filtCloseLocalTS.date().shortFormatJMT());
	if self.myFiltOperator &lt;&gt; null then
		tblEntQuery.setValueByName(ETRow_TheOperator, self.myFiltOperator.code.String);	
	endif;
	
	if self.myFiltCargoType &lt;&gt; null then
		tblEntQuery.setValueByName(ETRow_CargoType, self.myFiltCargoType.description.String);	
	endif;
	
	if self.myFiltProduct &lt;&gt; null then
		tblEntQuery.setValueByName(ETRow_Product, self.myFiltProduct.code.String);
	endif;
	
	tblEntQuery.setValueByName(ETRow_ShowDetail, true);
	tblEntQuery.cnEcResizeContents();
	self.mode := Mode_StockMove;
	
	self.initItemDetailSheet();
	self.tblData.accessSheet(TblDataSheet_ValidateTotals).visible := false;	
	self.initSOHFixupSheet();		
	self.tblData.selectMode := Table.SelectMode_CurrentRow;
	
	self.executeQuery();
	self.tblEntQuery.moveFirst();
end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="9e82f41d-b097-4817-badd-3a6fdbdc5c42">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:      29 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	filtOpenLocalTS : TimeStamp;
	filtCloseLocalTS : TimeStamp;
begin

	// loadData method cut and paste into here as when opening form for first time from navigator was not setting myFilterLC properly 
	//filter is now set in new code below. Load data kept as seperate method for calls from other forms. 
	//	self.loadData(null);

	app.myPassport.myActivityCapture.startCaptureDebugMisc(class.name &amp; '::' &amp; method.name);
	
	if cmbQueryType.listCount &gt; 0 then // AKB I added this so that this form can be initialized from a context menu
		return;
	endif;
	
	self.setColorsFromController(null);

	self.setNavigatorHeading(self.caption);

	self.loadQueryTypes();
	self.zInitTblEntQuery();
	self.zInitTblData();
	self.loadLocationTypes();
//	self.loadOperators;
	self.loadCargoTypes();
	self.loadDefaultDates();
	self.doQueryTypeClick(QueryType_StkMoveByLocation);
	self.doCmbLocationTypeClick(LocationType_LC);
	self.cbShowDetail.value := true;
	
	self.filtLocationType := self.cmbLocationType.text;
//	self.myFiltLC := _lc;  // old code from loadData
	self.myFiltLC := self.cmbLocation.listObject.CM_LocationsController;
	
	//set tblEntQuery row values
	tblEntQuery.setValueByName(ETRow_QueryType, cmbQueryType.text);
	tblEntQuery.setValueByName(ETRow_LocationType, cmbLocationType.text);
//	if cmbLocation.findObject(_lc) &gt; 0 then  // old code from loadData
//		cmbLocation.listIndex := cmbLocation.findObject(_lc);
//	endif;
	tblEntQuery.setValueByName(ETRow_Location, cmbLocation.text);
	
	filtOpenLocalTS.cnEcSetDateAndTime(self.filtOpenDate,TimeStartOfDay);// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	filtOpenLocalTS := self.systemToLocalTime(filtOpenLocalTS);			// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	filtCloseLocalTS.cnEcSetDateAndTime(self.filtCloseDate,TimeEndOfDay);// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	filtCloseLocalTS := self.systemToLocalTime(filtCloseLocalTS);		// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	tblEntQuery.setValueByName(ETRow_OpenDate, filtOpenLocalTS.date().shortFormatJMT());
	tblEntQuery.setValueByName(ETRow_CloseDate, filtCloseLocalTS.date().shortFormatJMT());

	if self.myFiltOperator &lt;&gt; null then
		tblEntQuery.setValueByName(ETRow_TheOperator, self.myFiltOperator.code.String);	
	endif;
	
	if self.myFiltCargoType &lt;&gt; null then
		tblEntQuery.setValueByName(ETRow_CargoType, self.myFiltCargoType.description.String);	
	endif;
	
	if self.myFiltProduct &lt;&gt; null then
		tblEntQuery.setValueByName(ETRow_Product, self.myFiltProduct.code.String);
	endif;
	
	tblEntQuery.setValueByName(ETRow_ShowDetail, true);
	tblEntQuery.cnEcResizeContents();
	self.mode := Mode_StockMove;
	
	self.initItemDetailSheet();
	self.tblData.accessSheet(TblDataSheet_ValidateTotals).visible := false;	
	self.initSOHFixupSheet();		
	self.tblData.selectMode := Table.SelectMode_CurrentRow;
	
//	self.executeQuery(); // old code from loadData shouldnt run on form load from navigator.  
	self.tblEntQuery.moveFirst();
epilog
	app.myPassport.myActivityCapture.stopCaptureDebugMisc();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadDefaultDates" id="750c77e0-4e96-4eb2-b01a-d7d2e7839f3b">
        <updating/>
        <source>loadDefaultDates() updating;
// ---------------------------------------------------------------------------
// Created:     30 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	openDate,
	closeDate,
	today		: Date;
	year,
	month		: Integer;
begin
	//today
	openDate := self.systemToLocalTime(app.actualTimeServer()).date;// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	closeDate := openDate;

	tblEntQuery.setValueByName(ETRow_OpenDate, openDate);
//	txtOpenDate.setDate(openDate);
//	txtOpenDate.text := openDate.shortFormat;
//	txtOpenDate.lostFocus(txtOpenDate);
	
	tblEntQuery.setValueByName(ETRow_CloseDate, closeDate);
//	txtCloseDate.text := closeDate.shortFormat;
//	txtCloseDate.lostFocus(txtCloseDate);	
	self.filtOpenDate := openDate;
	self.filtCloseDate := closeDate;

end;</source>
    </JadeMethod>
    <JadeMethod name="loadLocationTypes" id="81ea7d74-c092-4ef2-a3b6-fed51e7b91f1">
        <updating/>
        <source>loadLocationTypes() updating;
// ---------------------------------------------------------------------------
// Created:     01 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	cmbLocationType.addItemAt(LocationType_LC,1);
	cmbLocationType.addItemAt(LocationType_TA,2);
	cmbLocationType.addItemAt(LocationType_Terminal,3);
	cmbLocationType.addItemAt(LocationType_Voyage,4);	
	cmbLocationType.listIndex := 1;
	self.loadLocations();
end;</source>
    </JadeMethod>
    <JadeMethod name="loadLocations" id="5acdf5a7-0d38-480f-bb20-5f0262353264">
        <updating/>
        <source>loadLocations() updating;
// ---------------------------------------------------------------------------
// Created:     30 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	ta					: CM_TerminalArea;
	locn				: CM_LocationsController;
	idx					: Integer;
	count				: Integer;	
	dac					: CM_DataAccessController;
	operatorSet			: CM_OperatorSet;
	object 				: CM_Object;
	cmb					: CMUI_ComboBox;
	str					: String;
	
begin
	create operatorSet transient;
	cmb := self.cmbLocation;
	cmb.clear;
	
	dac := self.getOperatorAccessController;

	foreach ta in self.myTerminal.allTerminalAreas where ta.isStockControlled do
		foreach locn in ta.allLocationsControllers do
			if not locn.canDataAccessGroupAccessSelf(dac, operatorSet) then
				continue;
			endif;

			count := count + 1;
			//th2 - changed after profiling this - cut initial load time in half
			//the displayEntryLocation is some bad code. Replaced.
			
			str := null;
			
			//cnwjo3, we have RTG with null myGridRow's.  Putting this here avoids exceptions
			//so development can continue for par 17383
			if locn.isKindOf(CM_GridController) then
				if locn.CM_GridController.myGridRow &lt;&gt; null then
					str := locn.getID &amp; ' / ' &amp; ta.id;
					//cmb.itemObject[cmb.addItem(locn.getID &amp; ' / ' &amp; ta.id)] := locn;
				endif;
			else
				str := locn.getID &amp; ' / ' &amp; ta.id;
				//cmb.itemObject[cmb.addItem(locn.getID &amp; ' / ' &amp; ta.id)] := locn;
			endif;
			
			// PAR 18081
			if str &lt;&gt; null then
				if locn.isArchived then
					str := str &amp; ' (Archived ' &amp; self.systemToLocalTime(locn.statusDateTime).asStringJMT &amp; ')';// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				endif;
				cmb.itemObject[cmb.addItem(str)] := locn;
				
				if count = 1 then
					if self.myFiltLC = null then
						self.myFiltLC := locn;
					endif;
				endif;
			endif;
			
			//idx := cmbLocation.addItem(self.displayEntryLocation(locn));
			//cmbLocation.itemObject[idx] := locn;
				
			/*if count = 1 then
				if self.myFiltLC = null then
					self.myFiltLC := locn;
				endif;
			endif;*/
		endforeach;
	endforeach;

//	if count &gt; 0 then  // isValid added to stop error if location had been deleted by other user. related to par 9773
	if count &gt; 0 and global.isValidObject(self.myFiltLC) then 
		cmb.listIndex := cmb.findObject(self.myFiltLC);
		if cmb.listIndex &gt; 0 then
//		cmbLocation.listObject := self.myFiltLC;
			self.tblEntQuery.setValueByName(ETRow_Location, self.myFiltLC.getID &amp; ' / ' &amp; self.myFiltLC.myTerminalArea.id);
		endif;
	else
		tblEntQuery.setValueByName(ETRow_Location, null);	
	endif;

epilog
	delete operatorSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadOperators" id="d024bae8-06b2-4301-afca-a48727501296">
        <updating/>
        <source>loadOperators() updating;
// ---------------------------------------------------------------------------
// Created:     02 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	opDict		: CM_OperatorByCodeDict;
	op			: CM_Operator;
	passport	: CM_Passport;
	idx			: Integer;
	count		: Integer;
	failedDAC  :CM_DataAccessController;
	
begin
	cmbOperator.clear;

	opDict := app.myRoot.allOperators;

	passport := app.myPassport;
	foreach op in opDict do
		count := count + 1;
		if not op.canUserAccessSelf(null, failedDAC, passport) then
			continue;
		endif;
		idx := cmbOperator.addItem(op.code);
		cmbOperator.itemObject[idx] := op;

		if count = 1 then
			if app.myCurrentOperator = null then
				app.setMyCurrentOperator(op);
			endif;
		endif;
	endforeach;
	
	if count &gt; 0 then
		op := app.myCurrentOperator;
		cmbOperator.setObject(op);
		self.myFiltOperator := op;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadProducts" id="1468559f-3d18-4baf-99f7-7b5f025d1530">
        <updating/>
        <source>loadProducts() updating;
// ---------------------------------------------------------------------------
// Created:     02 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cargoType	: CM_CargoType;
	product		: CM_Product;
	tmpOperator	: CM_Operator;
	iter		: Iterator;
	proDict		: CM_ProductByCargoTypeCodeDict;
	tempProDict2 : CM_ProductByOpCodeProCodeDict;

begin
	//cmbProduct1.clear();
	//cnwjo3 par 17383
	//cmbProduct1.setCargoType(self.cmbCargoType.listObject.CM_CargoType);
	//cmbProduct1.setOperator(null);  //ignoring operator at this point because of its a search
	//cmbProduct1.setObject(cmbProduct1.listObject.CM_Product); 

	//PAR24313 - cnwsh3.  An attempt to standardize JMT's approach to cargo sub types from PAR17383 meant the way C3 handle their cargo subtypes for this form was broken.
	//As it stands, (from what I can gather, this form is specific to C3's operations and should only be analysed for change if and when funding becomes available or when is necessary.
	//Thus, the code has been returned to it's previous state.
	self.cmbProduct.clear();
	
	create tempProDict2 transient;
	tmpOperator := self.myFiltOperator;
	cargoType := self.myFiltCargoType;
	
	//Filter by the selected operator
	if tmpOperator &lt;&gt; null  then
		proDict := tmpOperator.allProducts;
		iter := proDict.createIterator();
		proDict.startKeyGeq(cargoType.id, null, iter);
		while iter.next(product) do
			if product.cargoType &lt;&gt; cargoType.id then
				break;
			endif;
			
			if not product.isNotActive then
				tempProDict2.add(product);
			endif;
			
		endwhile;
	
	//No operator so filter by cargo type
	elseif cargoType &lt;&gt; null then
		// TFS 2198 cargoType.allProducts.copy(tempProDict2);
		
		// TFS 2198 remove not available for entry
		iter := cargoType.allProducts.createIterator();
		
		while iter.next(product) do
			if not product.isNotActive then
				tempProDict2.add(product);
			endif;
		endwhile;
		
		
	else
		return;
	endif;
	
	if tempProDict2.size &gt; 0 then
		cmbProduct.listCollection(tempProDict2, false, 0);
		product := tempProDict2.first;
 		cmbProduct.listObject := product;
		self.tblEntQuery.setValueByName(ETRow_Product, product.code);
		self.myFiltProduct := product;
	else
		self.tblEntQuery.setValueByName(ETRow_Product, null);
		
	endif;

epilog
	delete tempProDict2;
	delete iter;
end;</source>
    </JadeMethod>
