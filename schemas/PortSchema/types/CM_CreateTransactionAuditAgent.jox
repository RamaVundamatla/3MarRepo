    <JadeMethod name="audCreateGeneric" id="2412f9b1-16a9-4b8e-b903-c693b0b83b18">
        <source>audCreateGeneric(pSubject : CM_Object);
// ---------------------------------------------------------------------------
// Created:     12 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16 Oct 2019 cnwma1	Bug 46974: JMT - Auditing Transients while creating Proforma
// ---------------------------------------------------------------------------
vars
	s : String;
	
begin 
	if pSubject = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Subject for audit is null');
		return;
	endif;
	
	if pSubject.isTransient or app.isInProformaMode then //16.10.2019 cnwma1 #46974
		return;
	endif;
	
	s := pSubject.getAuditText();
	
	app.myAA.auditCreateTrx(pSubject, s, null);
end;</source>
        <Parameter name="pSubject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="audCreateGenericWithExtraInfo" id="f922f533-bbf9-4c24-84d6-5c3bafecbc6e">
        <source>audCreateGenericWithExtraInfo(pSubject : CM_Object; _extraInfo : String);
/* ---------------------------------------------------------------------------
Created:	23 February 2009	by cnwvu1

Purpose:	Create CM_AuditObjectInformation with info
   
Change Date		Who		Reason
16 Oct 2019 	cnwma1	Bug 46974: JMT - Auditing Transients while creating Proforma
------------------------------------------------------------------------------*/
vars
	s : String;

begin

	if pSubject = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Subject for audit is null');
		return;
	endif;
	
	if pSubject.isTransient  then //16.10.2019 cnwma1 #46974
		return;
	endif;
	
	s := pSubject.getAuditText();
	app.myAA.auditCreateTrx(pSubject, s, _extraInfo);

end;</source>
        <Parameter name="pSubject" type="CM_Object"/>
        <Parameter name="_extraInfo" type="String"/>
    </JadeMethod>
    <JadeMethod name="audCreateTALocation" id="13595bbd-c617-4ae6-b79f-d7cdddbad610">
        <source>audCreateTALocation(_subject :CM_TerminalAreaMaster; _locations :Any; _locType, _locMode :Integer; _details :String);
// ---------------------------------------------------------------------------
// Created:     02 March 2011 by cnwcs5  CCMS CPL 2027/PAR 27126
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16 Oct 2019 cnwma1	Bug 46974: JMT - Auditing Transients while creating Proforma
// ---------------------------------------------------------------------------
vars
	set		: CM_LCSet;
	any		: Any;
begin 
	if _subject = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Subject for audit is null');
		return;
	endif;
	
	if _subject.isTransient  then   //16.10.2019 cnwma1 #46974
		return;
	endif;
	
	if _locations.isKindOf (CM_LCSet) then
		app.myAA.auditCreateTALocationsTrx(_subject, _locations.CM_LCSet, _locType, _locMode, _details);
	else
		create set transient;
		
		if _locations &lt;&gt; null then
			if _locations.isKindOf (CM_LocationsController) then
				set.add (_locations.CM_LocationsController);
			elseif _locations.isKindOf (Collection) then
				foreach any in _locations.Collection do
					if any.isKindOf (CM_LocationsController) then
						set.add (any.CM_LocationsController);
					endif;
				endforeach;
			endif;
		endif;
		
		app.myAA.auditCreateTALocationsTrx(_subject, set, _locType, _locMode, _details);
	endif;
epilog
	delete set;
end;</source>
        <Parameter name="_subject" type="CM_TerminalAreaMaster"/>
        <Parameter name="_locations" type="Any"/>
        <Parameter name="_locType" type="Integer"/>
        <Parameter name="_locMode" type="Integer"/>
        <Parameter name="_details" type="String"/>
    </JadeMethod>
</Class>
