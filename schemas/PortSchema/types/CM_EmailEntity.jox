    <JadeMethod name="getDisplayStringForAttribute" id="1a8b2862-9ab4-4217-b3cd-8eb354049259">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	25 November 2003 By: cnwgd1
//--------------------------------------------------
vars
	cp	: CM_CamProtocol;
	str : String;
	
begin


	if _attrName = ETRow_Title then
		return name;
	elseif _attrName = ETRow_BusinessPhone then
		return null;		
	elseif _attrName = ETRow_CompanyName then
		return null;
	elseif _attrName = ETRow_FaxNumber then
		return null;
	elseif _attrName = ETRow_HomePhone then
		return null;
	elseif _attrName = ETRow_MobilePhone then
		return null;
	elseif _attrName = ETRow_EmailAddress then
		return self.getEmailAddress();																				
	elseif _attrName = ETRow_CamsProtocols then
		foreach cp in self.allCamProtocols do
			if str = null then
				str := cp.code;
			else
				str := str &amp; ", " &amp; cp.code;
			endif;
		endforeach; 
		return str;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
