    <JadeMethod name="setForCreateFromPxy" id="3e0f1202-1738-4b11-8145-321b8d407a37">
        <updating/>
        <source>setForCreateFromPxy(_proxy : CM_BulkRelease; _booking : CM_BookingRef; _cmifBooking :CMIF_BookingRef) updating;
/*
Purpose:		Trying to get to the point where we have signle utl to create a release request.

Parameters:		_proxy			- release proxy (required)
				_booking		- booking for which release is created (optional)
				_cmifBooking	- used to link booking items with reserve details (optional)

Return Value:		


Date				Who		Reason
18 November 2008	cnwer1	Initial creation
12 Feb 2012			cnwcs5	par 28756 - changed parameter usage from input to constant for _proxy
									  - add code to create assigned transactions so we can call from trxCreateBulkRelease
									  - link booking items with reserve details if cmifBooking &lt;&gt; null
14 Dec 2012			cnwdap1	PAR #30882 CCMS PNL 2244 When processing EDI files for bookings, the booking is created first,
							and it finds all the onsite or prenoted items that belong to itself, then the Bulk Release is
							created. We need to include all the TIs associated with the booking in the Bulk Release's
							allTrackedItemsAssigned collection if they're not already included
25 Feb 2012			cnwcs5	CCMS PNL 2243 / par 31185 - fix creation of assigned transactions
*/

vars
	reserve		: CM_ReserveDetail;
	pxyReserve	: CM_ReserveDetail;
	ti			: CM_TrackedItem;
	template	: CM_EmailTemplate;
begin
	// just so we know what we are expecting here
	self.raiseExceptionIfTransient (method);
	_proxy.raiseExceptionIfNotTransient (method);
	
	// create email template if necessary - this should probably be done in setForUpdate (will look at doing this later)
	if _proxy.myEmailTemplate &lt;&gt; null then
		create template persistent;
		
		template.setMyParent (self);
	endif;
	
	self.setForUpdate(_proxy);	
	
	if _booking &lt;&gt; null then
		self.setBookingRefStock(_booking);
	endif;
	
	self.totalRequested := null;
	
	foreach pxyReserve in _proxy.allReserveDetails do
		self.totalRequested := self.totalRequested + pxyReserve.totalRequested;
		
		reserve	:=	self.addReserveFromProxy(pxyReserve);	
		
		reserve.setBookingRefItemReference (pxyReserve, _cmifBooking);
	endforeach;

	foreach pxyReserve in _proxy.allReservePackingChildren do
		self.totalRequested := self.totalRequested + pxyReserve.totalRequested;
		
		reserve	:=	self.addReserveFromProxy(pxyReserve);
		
		reserve.setBookingRefItemReference (pxyReserve, _cmifBooking);
	endforeach;
	
	// PAR #30882 check to see if we have to assign any TIs 
	if _booking &lt;&gt; null then																	// PAR #30882
		foreach ti in _booking.allTIs where not self.allTrackedItemsAssigned.includes(ti) do	// PAR #30882
			if not ti.isPreNote then															// PAR #30882
				self.addTIAssigned(ti, null);													// PAR #30882
		//		self.createAssignedTransaction(ti, false); //16 May 2016 TFS 1995 - added trx create to addTIAssigned method										// PAR #30882
			endif;																				// PAR #30882
		endforeach;																				// PAR #30882
	endif;																						// PAR #30882
epilog

end;</source>
        <Parameter name="_proxy" type="CM_BulkRelease"/>
        <Parameter name="_booking" type="CM_BookingRef"/>
        <Parameter name="_cmifBooking" type="CMIF_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="99701c1b-5750-4a89-93d7-363c05567a12">
        <updating/>
        <source>setForUpdate(_proxy : CM_BulkRelease) updating;
/* Changes

Date		Name	TFS#			Description
============================================================================
18/11/2008	cnwer1					Initial creation
17/09/2009	consw1	SFW1035 		get info from ReserveDetail rather than Yard Request
01/11/2010	cnwdad1	PAR #25748. 	When assigning a TI, may need to look up persistent object first.
18/11/2010	cnwdap1	PAR #23794 		CCMS MES 1102 	Create an event to be detected by the rail load list screen
11/08/2011	cnwdap1	PAR #27972 		mark new objects as converted
24/11/2011	cnwcs5	CCMS POL 2122   / par 28696  	new property needs Review
07/11/2011  cnwrs1	CCMS POL 2122  	/ PAR 28696 	new property allEDIFiles
23/04/2012	cnwcs5	CCMS POL 2172   / par 29480 	Coparn release updates
06/07/2018  cnwma1	Bug 39270: 		Getting a 1090 when trying to remove an item from Ship Release Request
14/01/2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
24/01/2019	jlgka1	41708			Add new property myBOLIn.
08/02/2019	jlgrs1	TFS 43312 		More Deadlocking in Multiuser EDI
17/3/2023	navhl20 Defect 57171: MTN - Newly created Release Request is not visible on the Release Request dropdown
26/3/24	    navsaa30 ChangeRequest 62853: CUX | GET /releaseRequest API - Match response fields to POST/PUT message GoLCrit 02
14/05/2024	navnk30  ChangeRequest 63607: FR | 53127 - Additional Operational Instructions on the Order - Remedial
30/06/2025  navma1   MTN-34090  MTN | Dead lock (1081) on CM_TIByIdCargoTypeRelseDictRev
14 Oct 2025	navnk30	JIRA 36229: Yara New Discoveries | Special Instructions &amp; BOL Segment in OrderCreate Request XML
============================================================================*/
vars
	newReq					: CM_Request;
	tmpTI					: CM_TrackedItem;
	realTI					: CM_TrackedItem;
	subTermSource			: CM_SubTerminal;
	subTermTarget			: CM_SubTerminal;
	terminal				: CM_Terminal;
	originalAssignedItems 	: CM_TISet; 
	instructions			: CM_InstructionsIssued;
	extraData				: CM_StateData;
begin
	self.raiseExceptionIfTransient(method);
	_proxy.raiseExceptionIfNotTransient(method);
	
	//02 May 2018	TFS 38399 - to cater for the lunacy of changing multiple releases to the same name....
	// Remove from all of the existing inversed collections before changing the keys (changing one key at a time can give duplicate key errors) 
	// They get set again after the keys are changed
	if self.myTerminal &lt;&gt; null then
		/*
		Collections Should be locked in the right Oid Order
		30.06.2025 navma1 #MTN-34090
		*/
		self.exclusiveLock(self.myTerminal.allBulkReleasesByCodeDate);    //004 - CM_BulkReleaseByCodeDict
		self.exclusiveLock(self.myTerminal.allBulkReleasesByDelRelNo);    //021 - CM_BulkReleaseByDelRelNoDict
		self.exclusiveLock(self.myTerminal.allBulkReleaseByTypeByStByCd); //159 - CM_BulkReleaseByTypeStCodeDict
	endif;
	
	self.myTerminal 		:= null;
	self.myOperatorTerminal := null;
	self.mySubTerminal 		:= null;
	self.myVoyage 			:= null;
	self.myBOLIn 			:= null; //jlgka1 TFS 41708
	
	self.bookingConfirmation	:= _proxy.bookingConfirmation;
	self.carrierId				:= _proxy.carrierId;
	self.cargoRemarks			:= _proxy.cargoRemarks;
	self.remarksAdditional1		:= _proxy.remarksAdditional1;	//02 May 2018	NDL	TFS 37795
	self.remarksAdditional2		:= _proxy.remarksAdditional2;	//02 May 2018	NDL	TFS 37795
	self.code					:= _proxy.code.trimBlanks().toUpper();
	self.consigneeCode			:= _proxy.consigneeCode[1:5];
	self.consignorCode			:= _proxy.consignorCode[1:5];
	self.consignorVoyageCode 	:= _proxy.consignorVoyageCode;
	self.converted				:= true;												// PAR #27972
	self.dateEstimatedRequired 	:= _proxy.dateEstimatedRequired;
	self.dateRequested 			:= _proxy.dateRequested;
	self.deliveryReasonCode		:= _proxy.deliveryReasonCode;
	self.deliveryReasonDescr	:= _proxy.deliveryReasonDescr.trimBlanks();
	self.deliveryReleaseNumber	:= _proxy.deliveryReleaseNumber.trimBlanks();
	self.doorsDirection			:= _proxy.doorsDirection;
	self.expiryTimeStamp 	 	:= _proxy.expiryTimeStamp;	//13 Feb 2017	NDL	TFS 3368
	self.freightForwarderCode	:= _proxy.freightForwarderCode;		// PAR 20646
	self.freightPayerCode		:= _proxy.freightPayerCode;			// 26/3/24 navsaa30 #62853
	self.fullRelease 			:= _proxy.fullRelease;
	self.myLoadPort				:= _proxy.myLoadPort;
	self.myDischargePort 		:= _proxy.myDischargePort;
	self.myDestinationPort		:= _proxy.myDestinationPort;	// 04 Nov 2009	NDL	Par 21519
	self.myAssignedTrain		:= _proxy.myAssignedTrain;	// 04 Nov 2009	NDL	Par 21519
	self.myVoyage 				:= _proxy.myVoyage;  
	
	self.type					:= _proxy.type;
	self.myBusinessUnit			:= _proxy.myBusinessUnit; 		//PAR15456 Business Unit wasn't being saved on a Bulk Release. cnwsh3 4/12/2007
	self.consigneeDesc			:= _proxy.consigneeDesc; 		// dh 4/9/2008 new fields for APM bookings
	self.consignorDesc			:= _proxy.consignorDesc;		// dh 4/9/2008 new fields for APM bookings
	self.dispatchLocation		:= _proxy.dispatchLocation; 	// dh 4/9/2008 new fields for APM bookings
	self.myPoolPartner			:= _proxy.myPoolPartner; 		// dh 4/9/2008 new fields for APM bookings
	self.preventEquivTypes		:= _proxy.preventEquivTypes; 	// dh 4/9/2008 new fields for APM bookings
	self.numberWLECreated		:= _proxy.numberWLECreated;  	// cnwrd1 24.8.09 cms 1075 
	self.allowCargoOnMultipleReleases := _proxy.allowCargoOnMultipleReleases;//+ cnwml2 MSL CCMS 1012
	self.canBeHiLoCube			:= _proxy.canBeHiLoCube;		// May 2011 cnwjre1 27097 POL CCMS 2043
	self.needsReview			:= _proxy.needsReview;			// par 28696
	self.myBOLIn				:= _proxy.myBOLIn; 				// jlgka1 TFS 41708
	self.blockEDIUpdates 		:= _proxy.blockEDIUpdates;		// par 29481 May 2012
	
	// cnwrl1 17/02/2010 PAR 22393 - start of coding
	self.customsAgent			:= _proxy.customsAgent;
	self.customsAssistance		:= _proxy.customsAssistance;
	self.context				:= _proxy.context; 				//jlier1 TFS 53678 15/6/22
	self.allPackLocations.clear();
	_proxy.allPackLocations.copy(self.allPackLocations);

	self.allAvailabilityGrades.clear(); 							// PAR 9469 
	_proxy.allAvailabilityGrades.copy(self.allAvailabilityGrades); // PAR 9469 

	self.allEDIFiles.clear(); 										// CCMS POL 2122 / PAR 28696  cnwrs1 07/12/2011
	_proxy.allEDIFiles.copy(self.allEDIFiles);

	if _proxy.allReserveDetails.isEmpty() and _proxy.allReservePackingChildren.isEmpty() then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_BULKREL_MissingRequest, self.code, null, null);
	endif;
		
	// Note this MUST be done AFTER handling the TI request(s) above
	self.releaseByType			:= _proxy.releaseByType;
	
	foreach tmpTI in self.allTrackedItemsAssigned do  //cnwrd1 ccms 1075 28.1.2010
		if not _proxy.allTrackedItemsAssigned.includes(tmpTI) then
			self.removeTIFromWorkOrders(tmpTI);
		endif;
	endforeach;//cnwrd1 ccms 1075 28.1.2010
	
	//epr TFS 2329 26/7/16
	create originalAssignedItems transient;
	self.allTrackedItemsAssigned.copy(originalAssignedItems);
	
	self.allTrackedItemsAssigned.clear();
	

	foreach tmpTI in _proxy.allTrackedItemsAssigned do //cnwrd1 ccms 1075 28.1.2010
		// cnwdad1 01/11/2010 - PAR #25748.
		if tmpTI.pxyIsProxy() then
			realTI	:=	tmpTI.pxyGetRealObject();
		else
			realTI	:=	tmpTI;
		endif;
		self.addTIAssigned(realTI, null);
	endforeach;
	
	//06 Jul 2018 cnwma1	Bug 39270
	terminal					:= _proxy.myTerminal;
	//14 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
	/*
		Collection Should be locked in the right Oid Order
		30.06.2025 navma1 #MTN-34090
	*/
	self.exclusiveLock(terminal.allBulkReleasesByCodeDate);    //004 - CM_BulkReleaseByCodeDict
	self.exclusiveLock(terminal.allBulkReleasesByDelRelNo);    //021 - CM_BulkReleaseByDelRelNoDict
	self.exclusiveLock(terminal.allBulkReleaseByTypeByStByCd); //159 - CM_BulkReleaseByTypeStCodeDict
	self.myTerminal				:= terminal;
	
	foreach tmpTI in originalAssignedItems do
		if not self.allTrackedItemsAssigned.includes(tmpTI) then	// par 31185
			// unassigned from release request
			self.createAssignedTransaction(tmpTI, true);	
		endif;
	endforeach;	
	
	// Delete and re-add the request(s)
	self.requests.purge();
	
	foreach newReq in _proxy.requests do
		self.addRequestFromProxy(newReq);
	endforeach;	
	
	// Update collections
	if _proxy.myBookingRefStock &lt;&gt; null and				// cnwdad1 15/07/2009 - PAR #20289.
		_proxy.myBookingRefStock.isTransient() then
		self.myBookingRefStock		:=	_proxy.myBookingRefStock.pxyGetRealObject();
	else
		self.myBookingRefStock		:=	_proxy.myBookingRefStock;		// DJW Booking reference needs to be retained
	endif;
	
	self.myOperator				:= _proxy.myOperator;
	self.myOperatorGroup		:= _proxy.myOperatorGroup;
	self.myTransferToTerminal	:= _proxy.myTransferToTerminal;
	
	//cnwrd1 par 26664 16.5.2011
	if app.isSubTerminalsOn(self.myTerminal) then
		subTermSource				:= self.myTerminal.getDefaultSubTerminalForRel(self.type);						// cnwdad1 27/01/2010 - PAR #22205.
		subTermTarget   			:= self.myTerminal.getConfig(MySubTerminalForTargetBulk).CM_SubTerminal;
		self.setSubTerminalDefault(subTermSource, subTermTarget);
	endif;
	
	self.mySubTerminal 			:= _proxy.mySubTerminal; 

	if _proxy.mySubTerminalTarget &lt;&gt; null then  //cnwrd1 par 23219 17.3.2010
		self.mySubTerminalTarget 			:= _proxy.mySubTerminalTarget; 
	endif;

	if self.myOperator &lt;&gt; null then
		self.myOperatorTerminal := self.myOperator.getOperatorTerminal(self.myTerminal, true);
	endif;
	
	//set xfer terminal on any existing delivery requests
	foreach newReq in self.allRequestsBeingActioned where
		CM_YardRequest.hasInstance(newReq) do
		newReq.CM_YardRequest.setMyTransferToTerminal(self.myTransferToTerminal);
	endforeach;
	
	// Following removed for PAR 20646
	// need to do this AFTER setting self.myTerminal as actually sets self.myFreightForwarderTerminal
	//self.myFreightForwarder := _proxy.myFreightForwarder;
	
	// Email info is stored on the bulk release. Par19427 April 2009
	if self.myEmailTemplate &lt;&gt; null and _proxy.myEmailTemplate &lt;&gt; null then
		self.myEmailTemplate.setForUpdate(_proxy.myEmailTemplate);
	endif;

	// CCMS1412 set status after the type has been set as type needs to set before pin no is generated
	self.setStatus(_proxy.status, true, false);
	self.updateStatus();
	if _proxy.hasInstructionsForUpdate() then			//14.05.2024 navnk30 #63607
		if self.hasInstructionsForUpdate() then
			self.myInstructions.setForUpdate(_proxy.myInstructions);
		else
			create instructions persistent;
			instructions.setForUpdate(_proxy.myInstructions);
			instructions.setMyParent(self);
			
		endif;
	elseif self.hasInstructionsForUpdate() then
		self.myInstructions.erase(NORMAL_ERASE);
	endif;
	
	self.cleanUpReserveDetails(); //+ cnwmd1 Par 25953
	
	// PAR #23794 Create a note for the Rail Load List screen if a train was assigned/unassigned
	app.myEventManager.createSingleObjInfoNoteEvt(self, self.myTerminal.getTerminalEvent(BulkRelease_Update_Event), self);						// 07 February 2023	navcs2	 55440:[54990]
	//endif;																																	/17.3.2023 navhl20	#57171
	
	foreach extraData in _proxy.allExtraData do		//14.10.2025 navnk30 MTN-36229
		global.setExtraData(self.allExtraData, self, extraData.key, extraData.getValue());
	endforeach;
epilog
	delete originalAssignedItems;
end;</source>
        <Parameter name="_proxy" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateFromPxy" id="c9cb6faa-2215-4671-9b70-69e6b9169b7f">
        <updating/>
        <source>setForUpdateFromPxy(_pxyRelease : CM_BulkRelease) updating;
/*
Date				Who		Reason
18 November 2008	cnwer1	Initial creation
7 September 2009	cnwjo3	Need to remove (detach) TIs
28 September 2009	consw1	SFW1035 - Have applied fixes for issues found whilst testing similiar method setForUpdateFromCMIF.
25 Feb 2013			cnwcs5	CCMS PNL 2243 / par 31185 - use collection on receiver rather then proxy for creating assigned/unassigned transactions
*/

vars
	template				: CM_EmailTemplate;
	newReserve, realReserve	: CM_ReserveDetail;
	pxyReserve				: CM_ReserveDetail;
	deleteReserveDetails 	: CM_ReserveDetailSet;
begin 
	self.raiseExceptionIfTransient (method);
	_pxyRelease.raiseExceptionIfNotTransient (method);
	
	if self.myEmailTemplate = null and _pxyRelease.myEmailTemplate &lt;&gt; null then
		create template persistent;
		template.setMyParent (self);
	endif;

	//all current reserve details
	create deleteReserveDetails transient;
	
	self.allReserveDetails.copy(deleteReserveDetails);
	self.allReservePackingChildren.copy(deleteReserveDetails);
	 
	self.totalRequested := 0;
	
	foreach pxyReserve in _pxyRelease.allReserveDetails do
		self.totalRequested := self.totalRequested + pxyReserve.totalRequested;
		realReserve 		:= app.myProxyManager.getRealObject(pxyReserve).CM_ReserveDetail;

		if realReserve = null then
			newReserve	:=	self.addReserveFromProxy(pxyReserve);
		else
			//update it remove from delete set
			realReserve.setForUpdate(pxyReserve);
			realReserve.setMyHeader(self);
			deleteReserveDetails.removeIfPresent(realReserve);
		endif;
	endforeach;
	

	foreach pxyReserve in  _pxyRelease.allReservePackingChildren do  
		self.totalRequested := self.totalRequested + pxyReserve.totalRequested;
		realReserve 		:= app.myProxyManager.getRealObject(pxyReserve).CM_ReserveDetail;
		
		if realReserve = null then
			//self.totalRequested := self.totalRequested + pxyReserve.totalRequested;
			newReserve	:=	self.addReserveFromProxy(pxyReserve);
		else
			//update it remove from delete set
			realReserve.setForUpdate(pxyReserve);
			realReserve.setMyHeader(self);
			deleteReserveDetails.removeIfPresent(realReserve);
		endif;
	endforeach;
	
	//17 Oct 2017	NDL	TFS 7394
	foreach realReserve in deleteReserveDetails do
		realReserve.validateForDelete( true );
		if app.myPassport.hasErrors then
			return;
		endif;
	endforeach;
		
	deleteReserveDetails.purge;
	
	// setForUpdate may update status to complete so should be called now 
	// after totalRequested has been updated (see par 20273)
	self.setForUpdate(_pxyRelease);

	//epr TFS 2329 26/7/16 now done in set for update
	
epilog

	delete deleteReserveDetails;
end;</source>
        <Parameter name="_pxyRelease" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="setFromBookingReference" id="90b2bdd1-91b5-48cd-8085-5b97979bf834">
        <updating/>
        <source>setFromBookingReference(_bookingRefObj:CM_BookingRef) updating;
// --------------------------------------------------------------------------------
// Created:		30 May 2008 by cnwdad1
//
// Purpose:		Updates the receiver's details from the specified Booking Reference's
//				details.
//
// Parameters:	_bookingRefObj - A reference to the Booking Reference who's details to use.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 11/08/2011	cnwdap1		PAR #27972 new object - set converted to true
// 24/04/2012	cnwdap1		PAR #29475 CCMS PNL 2155 Update reserve ISO type and number from EDI booking
// 25/09/2012	cnwcs5		par 30390 - change of signature for setParentPackingLineFromCMIF
// 12/12/2012	cnwdap1		PAR #30882 CCMS PNL 2244 we can now re-use a bulk release, so transfer TIs attached to reserve details
// --------------------------------------------------------------------------------
vars
	rootObj			: CM_Root;
	dataRefObj		: CM_EDIDataBookingRef;
	consigneeObj	: CM_ConsigneeConsignor;
	consignorObj	: CM_ConsigneeConsignor;
	isoTypeObj		: CM_ISOType;
	operatorObj		: CM_Operator;
	ediBookingRef	: CM_EDIBookingRefTI;		// PAR #29475
	reserve			: CM_ReserveDetail;			// PAR #29475
	selection		: CM_ReserveSelection;		// PAR #29475
	idx				: Integer;					// PAR #29475
	isoTypeStr		: String;					// PAR #29475
	nbr				: Integer;					// PAR #29475
	tiSet			: CM_TISet;					// PAR #30882
	ti				: CM_TrackedItem;			// PAR #30882
	oldStatus		: Integer;					// PAR #30882
	
begin
	rootObj			:=	app.myRoot;
	
	if _bookingRefObj.myEDIBookingRefTI &lt;&gt; null then
		if _bookingRefObj.myEDIBookingRefTI.myEDIData &lt;&gt; null then
			dataRefObj		:=	_bookingRefObj.myEDIBookingRefTI.myEDIData.CM_EDIDataBookingRef;
			ediBookingRef	:=	_bookingRefObj.myEDIBookingRefTI;			// PAR #29475
		endif;
	endif;
	
	oldStatus := self.status;				// PAR #30882
	
	// Update general properties.
	
	//self.bookingConfirmation	:=	?
	//self.cargoRemarks			:=	?
	
	if _bookingRefObj.myCarrier &lt;&gt; null then
		self.carrierId				:=	_bookingRefObj.myCarrier.code;
	endif;
	
	self.consigneeCode			:=	_bookingRefObj.consigneeCode;
	self.consignorCode			:=	_bookingRefObj.consignorCode;
	self.consigneeDesc			:=	_bookingRefObj.consigneeDesc;
	self.consignorDesc			:=	_bookingRefObj.consignorDesc;
	self.converted				:=	true;							// PAR #27972
	
	//self.consignorVoyageCode	:=	?
	//self.dateEstimatedRequired	:=	?
	//self.dateRequested			:=	?
	//self.deliveryReasonCode		:=	?
	//self.doorsDirection			:=	?
	//self.freightPayerCode		:=	?
	
	self.fullRelease			:=	false;	// ???
	self.isReceipt				:=	false;	// ???
	self.isSystemGenerated		:=	true;	// ???			&lt;&lt;&lt;======
	//self.packLocation			:=	?
	//self.packProduct			:=	?
	//self.packQuantity			:=	?
//	self.quantityRemaining		:=	?					// This is a virtual.
	//self.releasedItemStrings		?	StringArray
// TFS 2686		self.removeStops			:=	false;	// ???
	self.releaseByType			:=	true;	// This needs to be true for EDI file loads.
	//self.statusDate				:=	?
	//self.statusString			:=	"Active";			// This is a virtual - set status on next line
	self.status					:=	BR_ACTIVE; 			

	if _bookingRefObj.isStockBookingRef then
		self.type := BR_TYPE_PACKING;
	else
		self.type := BR_TYPE_ROAD;
	endif;
	
	if dataRefObj &lt;&gt; null then
//		self.totalPacked			:=	dataRefObj.items;	// ???
		self.totalRequested			:=	dataRefObj.items;
	endif;
	
	// Update any references/inverses.
	
// This gets set in the transaction when the setForCreate method is called.
//	self.myBookingRefStock		:=	bookingRefObj;
	
	//self.myBusinessUnit		:=	?
	//self.myCargoType			:=	?			Can we look this up from the list of products (_bookRefTI.product) ?
	
	if _bookingRefObj.consigneeCode &lt;&gt; null then
		self.consigneeCode := _bookingRefObj.consigneeCode; //cnwgb1 par 17025
	endif;
	
	if _bookingRefObj.consignorCode &lt;&gt; null then
		self.consignorCode := _bookingRefObj.consignorCode; //cnwgb1 par 17025
	endif;
	
	self.myDischargePort		:=	rootObj.allPorts[_bookingRefObj.dischargePort];
	//self.myFreightForwarder	:=	?
	//self.myFreightForwarderTerminal	:=	?
	
	if _bookingRefObj.isoType &lt;&gt; null then
		isoTypeObj	:=	rootObj.allISOTypes[_bookingRefObj.isoType];
		
		if isoTypeObj &lt;&gt; null then
			self.myISOGroup		:=	isoTypeObj.myISOTypeGroup;
		endif;
	endif;
	
	//self.myLoadPort			:=	?
	
	if _bookingRefObj.operatorCode &lt;&gt; null then
		operatorObj	:=	rootObj.allOperators[_bookingRefObj.operatorCode];
		
		if operatorObj &lt;&gt; null then
			self.myOperator	:=	operatorObj;
		endif;
	endif;
	
	//self.myOperatorGroup			:=	?		Can't get this from Operator, because the Operator/Group is a many-to-many relationship.
	//self.myOperatorTerminal		:=	?		Can't get this from Operator, because the Operator/Terminal is a many-to-many relationship.
	//self.myPinNo					:=	?
	self.myTerminal					:=	app.getMyTerminalDO_NOT_USE();	// ???
	//self.myTransferToTerminal		:=	?
	
	if self.myTerminal &lt;&gt; null then
		self.myVoyage := self.myTerminal.allVoyagesNew.getAtKeyGeq(_bookingRefObj.voyageCode, null);
		
		if self.myVoyage.code &lt;&gt; _bookingRefObj.voyageCode then
			self.myVoyage	:=	null;
		endif;
	endif;
	
	// Update any dictionary keys.
	if _bookingRefObj.myEDIBookingRefTI &lt;&gt; null and 
	   self.code = null then	
		self.code	:=	_bookingRefObj.myEDIBookingRefTI.releaseRequestNumber; //AER 02/07/08 - Par17366;
	endif;
	
	// PAR #29475 EDI update of the container types and numbers on the reserves
	if ediBookingRef &lt;&gt; null then
		// PAR #30882 remember the release TIs associated with each reserve detail
		create tiSet transient;																	// PAR #30882
		if not oldStatus = BR_COMPLETE then														// PAR #30882
			foreach reserve in self.allReserveDetails do										// PAR #30882
				foreach ti in reserve.allTrackedItemsReleased where not tiSet.includes(ti) do	// PAR #30882
					tiSet.add(ti);																// PAR #30882
				endforeach;																		// PAR #30882
			endforeach;																			// PAR #30882
		endif;																					// PAR #30882
		self.allReserveDetails.purge;
		foreach idx in 1 to ediBookingRef.containerTypes.size do
			isoTypeStr 	:= ediBookingRef.containerTypes[idx];
			nbr 		:= ediBookingRef.containerNbrs[idx];
			
			if isoTypeStr &lt;&gt; null then
				create selection persistent;
				selection.setParentPackingLineFromCMIF(isoTypeStr, nbr);	// par 30390 sept 2012
				self.allReserveDetails.add(selection);
				// PAR #30882 Does this newly-created selection match any of the TIs we kept?
				foreach ti in tiSet where ti.getISOType = isoTypeStr do							// PAR #30882
					selection.addTIReleased(ti);												// PAR #30882
				endforeach;																		// PAR #30882
			endif;
		endforeach;
	endif;
	// PAR #29475 end
			
epilog																							// PAR #30882
	delete tiSet;																				// PAR #30882
end;</source>
        <Parameter name="_bookingRefObj" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIFBookRef" id="55b380c4-21cf-4e25-b5d3-8748129767db">
        <updating/>
        <source>setFromCMIFBookRef(_cmifBookRef : CMIF_BookingRef)updating;
//
// Changed on	By			Reason
// ----------	---------	----------------------------------------------
// 11/08/2011	cnwdap1		PAR #27972 mark new objects as converted
// 25/05/2016		cnwma1	PAR #37790 TFS#1880 MSL - EDI Bookings with Release Empties 
vars

begin
	self.cargoRemarks := _cmifBookRef.myProxyBookingRef.remarks;
	if _cmifBookRef.myCarrier &lt;&gt; null then
		self.carrierId := _cmifBookRef.myCarrier.code;
	endif;
	self.code := _cmifBookRef.myProxyBookingRef.bookingReference;
	if app.myRoot.getConfig(Consignor_ee_AsText).Boolean then
		self.consigneeDesc := _cmifBookRef.myProxyBookingRef.consigneeDesc;
		self.consignorDesc := _cmifBookRef.myProxyBookingRef.consignorDesc;
	else
		self.consigneeCode := _cmifBookRef.myProxyBookingRef.consigneeDesc;
		self.consignorCode := _cmifBookRef.myProxyBookingRef.consignorDesc;
	endif;
	self.converted := true;											// PAR #27972
//	deliveryReasonDescr := _cmifBookRef.
	self.dispatchLocation := _cmifBookRef.dispatchLocation;
	
	self.myBookingRefStock := _cmifBookRef.myRealBookingRef;
	self.myCargoType := _cmifBookRef.myProxyBookingRef.myCargoType;
	self.myDischargePort := app.myRoot.allPorts[_cmifBookRef.myProxyBookingRef.dischargePort];
	self.myLoadPort := _cmifBookRef.myLoadPort;
	self.myOperator := _cmifBookRef.myProxyBookingRef.myOperator;
	self.myPoolPartner := _cmifBookRef.myPoolPartner;
	self.myTerminal := _cmifBookRef.myProxyBookingRef.myTerminal;
	self.myVoyage := _cmifBookRef.myProxyBookingRef.myVoyage;
	self.preventEquivTypes := _cmifBookRef.preventEquivType;
	self.releaseByType :=_cmifBookRef.releaseByType;
	self.deliveryReasonDescr := _cmifBookRef.deliveryReleaseReason;
	if _cmifBookRef.myProxyBookingRef.isStockBookingRef then
		self.type := BR_TYPE_PACKING;
	else
		self.type := BR_TYPE_ROAD;
		self.releaseByType :=true;      //25/05/2016 cnwma1 PAR #37790 TFS#1880
	endif;
	self.status := BR_ACTIVE;
end;
</source>
        <Parameter name="_cmifBookRef" type="CMIF_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIFBulkRelease" id="8fafca68-a3fd-4366-81d9-d0ab1a2ff7c9">
        <updating/>
        <source>setFromCMIFBulkRelease(_cmifBR : CMIF_BulkRelease) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
// ---------------------------------------------------------------------------
// Changed on	By			Reason
// ----------	--------	--------------------------------------------------
// 11/08/2011	cnwdap1		PAR #27972 create new objects as converted
// 24/11/2011	cnwcs5		CCMS POL 2122 / par 28696 - new property needs Review

vars
	tmpOperator 	: CM_Operator;
	cm_SubTerminal	: CM_SubTerminal;

begin
	self.raiseExceptionIfNotTransient(method);

	if _cmifBR.operatorCode &lt;&gt; null then
		tmpOperator := app.myRoot.allOperators[_cmifBR.operatorCode];
		
		if tmpOperator = null then
			app.raiseCMException1(ERR_INVALID_OPERATOR, _cmifBR.operatorCode, 'operator', null);
		endif;
	endif;
	
	self.bookingConfirmation	:= _cmifBR.bookingConfirmation;
	self.canBeHiLoCube			:= _cmifBR.canBeHiLoCube;	// May 2011 cnwjre1 27097 POL CCMS 2043
	self.carrierId				:= _cmifBR.carrierCode;
	self.cargoRemarks			:= _cmifBR.remarks;
	self.remarksAdditional1		:= _cmifBR.remarksAdditional1;	//02 May 2018	NDL	TFS 37795
	self.remarksAdditional2		:= _cmifBR.remarksAdditional2;	//02 May 2018	NDL	TFS 37795
	self.code					:= _cmifBR.releaseNo.trimBlanks.toUpper;
	self.consigneeCode			:= _cmifBR.consigneeCode;
	self.consignorCode			:= _cmifBR.consignorCode;
	self.consignorVoyageCode 	:= _cmifBR.consignorVoyageCode;
	self.converted				:= true;							// PAR #27972
	self.dateEstimatedRequired 	:= _cmifBR.dateEstimatedRequired;
	self.dateRequested 			:= _cmifBR.dateRequested;
	self.deliveryReasonDescr	:= _cmifBR.deliveryReason.trimBlanks;
	self.deliveryReleaseNumber	:= _cmifBR.deliveryReleaseNumber.trimBlanks;
	self.doorsDirection			:= _cmifBR.doorDir;
	self.expiryTimeStamp		:= _cmifBR.expiryTimeStamp;	//13 Feb 2017	NDL	TFS 3368
	self.freightForwarderCode 	:= _cmifBR.freightForwarderCode;	// PAR 20646
	self.freightPayerCode		:= _cmifBR.freightPayerCode; 
	self.fullRelease 			:= _cmifBR.fullRelease;
	self.myLoadPort				:= _cmifBR.myLoadPort;
	self.myDischargePort 		:= _cmifBR.myDischargePort;
	self.myVoyage 				:= _cmifBR.myVoyage;
	self.myLoadPort 			:= _cmifBR.myLoadPort;
	self.myCargoType 			:= _cmifBR.myCargoType;
	self.myOperator				:= app.myRoot.allOperators[_cmifBR.operatorCode];
	self.myOperatorGroup		:= _cmifBR.myOperatorGroup;
	self.myTransferToTerminal	:= _cmifBR.myTransferToTerminal;
	self.myTerminal				:= _cmifBR.myTerminal;
	self.status					:= _cmifBR.status;
	self.releaseByType			:= _cmifBR.releaseByType;
// TFS 2686		self.removeStops			:= _cmifBR.removeStops;
	self.type					:= _cmifBR.type;
	self.needsReview			:= _cmifBR.needsReview;	// par 28696
	
	self.allowCargoOnMultipleReleases := _cmifBR.allowCargoOnMultipleReleases;  //PAR25759 cnwsh3 23/09/2010
	
	// cnwrl1 01/09/2009 PAR 20320 - MES 1011 New Messina Messages - start of coding
	if _cmifBR.myBusinessUnit &lt;&gt; null then
		self.myBusinessUnit := _cmifBR.myBusinessUnit;
	endif;
	
	if _cmifBR.mySubTerminal &lt;&gt; null then
		self.mySubTerminal	:= _cmifBR.mySubTerminal;
	elseif _cmifBR.subTerminalCode &lt;&gt; null then
		cm_SubTerminal	:= app.myRoot.allSubTerminals[ _cmifBR.subTerminalCode ];
		if cm_SubTerminal &lt;&gt; null then
			self.mySubTerminal	:= cm_SubTerminal;
		endif;
	endif;
	
	// cnwrl1 17/02/2010 PAR 22393 - start of coding
	self.customsAgent			:= _cmifBR.customsAgent;
	self.customsAssistance		:= _cmifBR.customsAssistance;	
	self.myBookingRefStock		:= _cmifBR.myBookingRefStock;		// cnwrl1 09/04/2010 PAR 23625
	
	self.allPackLocations.clear();
	_cmifBR.allPackLocations.copy(self.allPackLocations);
	
	// cnwrl1 06/05/2010 PAR 23847 - start of coding
	self.allTrackedItemsAssigned.clear();
	_cmifBR.allTrackedItems.copy( self.allTrackedItemsAssigned );
epilog
	
end;
</source>
        <Parameter name="_cmifBR" type="CMIF_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="setFromDeliveryRequest" id="13199e60-ef76-46a0-9218-037ff8f30812">
        <updating/>
        <source>setFromDeliveryRequest(_deliveryRequest : CM_DeliveryRequest) updating;
//-----------------------------------------
// Created: 11 June 2004 By: cnwgd1
//-----------------------------------------
// Changed on	By			Reason
// ----------	--------	-----------------------------------------------
// 11/08/2011	cnwdap1		PAR #27972 set new objects as converted
vars
	request 	: CM_DeliveryRequest;
	tmpOperator : CM_Operator;
begin
	self.raiseExceptionIfTransient(method);

	if _deliveryRequest = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_NO_OBJECT, '_deliveryRequest', null, null);
		return;
	endif;
	
	if CM_RoadJob.hasInstance(_deliveryRequest.myJob) then
		self.carrierId := _deliveryRequest.myJob.CM_RoadJob.carrierId;
		//Par14064
		self.setType(BR_TYPE_ROAD);
	endif;	

	self.code := _deliveryRequest.deliveryNumber.trimBlanks.toUpper;
	
	if self.code = null then
		self.code := _deliveryRequest.myTerminal.getBulkReleaseNextSeqNumber().toUpper;
		self.isSystemGenerated := true;
	endif;		
	
	self.releaseByType := true;

	//this is not right as it creates wles and associates new request with Job
	//self.addRequestFromProxy(_deliveryRequest);
	self.myTransferToTerminal := _deliveryRequest.myTransferToTerminal;
	
	// _deliveryRequest is the road job request (peristant transient) that is created for the job/WLE/request objects
	// request is the persistant copy which the bulk release requires
	// We have already validated the _deliveryRequest so just clone it.	
	request := _deliveryRequest.cloneSelf(false);
	
	request.cloneReferences(_deliveryRequest);
	request.setBulkRelease(self);	

	self.totalRequested := _deliveryRequest.totalRequested;
	
	self.setStatus(BR_ACTIVE, false, true);
	self.consigneeCode 			:= _deliveryRequest.consigneeCode;
	self.freightForwarderCode	:= _deliveryRequest.freightForwarderCode;	// PAR 20646
	self.canBeHiLoCube			:= _deliveryRequest.canBeHiLoCube;	// May 2011 cnwjre1 27097 POL CCMS 2043
	self.myCargoType 			:= _deliveryRequest.myCargoType;
	
	
	if _deliveryRequest.operatorCode &lt;&gt; null then
		tmpOperator := app.myRoot.allOperators[_deliveryRequest.operatorCode];
		if tmpOperator = null then
			app.raiseCMException1(ERR_INVALID_OPERATOR, _deliveryRequest.operatorCode, 'operator', null);
		endif;
	endif;
		
	// add into collections
	self.myOperator		:= tmpOperator;
	self.myOperatorGroup:= _deliveryRequest.myOperatorGroup;
	self.myTerminal		:= _deliveryRequest.myTerminal;
	self.mySubTerminal	:= _deliveryRequest.mySubTerminalSource;
	
	//28 June 2012	NDL	Par 29778
	if _deliveryRequest.commodity &lt;&gt; null then
		self.fullRelease :=  _deliveryRequest.commodity &lt;&gt; self.myTerminal.getDefaultEmptyCommodity;
	endif;
	
	// removed for PAR 20646
	/*This has to be done here*/
	//self.myFreightForwarder	:= _deliveryRequest.myFreightForwarder;
	
	if self.myOperator &lt;&gt; null then
		self.myOperatorTerminal := self.myOperator.getOperatorTerminal(self.myTerminal, true);
	endif;

	// need to do this AFTER setting self.myTerminal as actually sets self.myFreightForwarderTerminal
	//self.myFreightForwarder := _deliveryRequest.myFreightForwarder;				// PAR 20646 - removed
	
	self.converted 		:= true;			// PAR #27972

end;</source>
        <Parameter name="_deliveryRequest" type="CM_DeliveryRequest"/>
    </JadeMethod>
    <JadeMethod name="setFromEDIBookingRefTI" id="ebd2b9e1-b653-4267-9bf5-6f83a45195b4">
        <updating/>
        <source>setFromEDIBookingRefTI(_bookRefTI : CM_EDIBookingRefTI) updating;
// --------------------------------------------------------------------------------
// Created:		15 April 2008 by cnwdad1
//
// Purpose:		Updates the receiver's properties from those of the specified EDI
//				Booking Reference TI object.
//
// Parameters:	_bookRefTI - The Booking Reference TI who's data to use.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 11/08/2011	cnwdap1		PAR #27972 create new objects as converted
// --------------------------------------------------------------------------------
// 28 May 2013	cnwrs1	Par 31596 add freight forwarder to EDI booking
vars
	rootObj			: CM_Root;
	bookingRefObj	: CM_BookingRef;
	dataRefObj		: CM_EDIDataBookingRef;
//	consigneeObj	: CM_ConsigneeConsignor;
//	consignorObj	: CM_ConsigneeConsignor;
	consignObj : CM_ConsigneeConsignor;
	isoTypeObj		: CM_ISOType;
	operatorObj		: CM_Operator;
	subTerminalObj	: CM_SubTerminal;
	subTermSource	: CM_SubTerminal;
	subTermTarget	: CM_SubTerminal;
	today			: TimeStamp;
	
begin

	// this should only be called for a proxy/transient
	self.raiseExceptionIfNotTransient(method);

	rootObj			:=	app.myRoot;
	bookingRefObj	:=	_bookRefTI.myBookingRef;
	dataRefObj		:=	_bookRefTI.myEDIData.CM_EDIDataBookingRef;
	today 			:= app.actualTimeServer();	//app.actualTimeAppServer();  - should never use appServer time stamp
	
	// Update general properties.
	
	//self.bookingConfirmation	:=	?
	//self.cargoRemarks			:=	?
	self.carrierId				:=	_bookRefTI.carrierCode;
	if _bookRefTI.consignee &lt;&gt; null then
		consignObj := _bookRefTI.getConsign(_bookRefTI.consignee);
		if consignObj &lt;&gt; null then
			self.consigneeCode := consignObj.code;
		else
			self.consigneeCode := _bookRefTI.consignee[1:5];
		endif;
	endif;
//	self.consigneeCode			:=	_bookRefTI.consignee[1:5]; //par22366 cnwrs1 18 Mar 2010 to allow unit test to pass 
	if _bookRefTI.consignor &lt;&gt; null then
		consignObj := _bookRefTI.getConsign(_bookRefTI.consignor);
		if consignObj &lt;&gt; null then
			self.consignorCode := consignObj.code;
		else
			self.consignorCode := _bookRefTI.consignor[1:5];
		endif;
	endif;
//	self.consignorCode			:=	_bookRefTI.consignor[1:5];
	if _bookRefTI.freightForwarder &lt;&gt; null then
		consignObj := _bookRefTI.getConsign(_bookRefTI.freightForwarder);
		if consignObj &lt;&gt; null then
			self.freightForwarderCode := consignObj.code;
		else
			self.freightForwarderCode := _bookRefTI.freightForwarder[1:5];
		endif;
	endif;
	//self.consignorVoyageCode	:=	?
	self.converted				:= true;					// PAR #27972
	//self.dateEstimatedRequired	:=	?
	self.dateRequested			:=	today;
	//self.deliveryReasonCode		:=	?
	//self.doorsDirection			:=	?
	//self.freightPayerCode		:=	?
	self.fullRelease			:=	false;	// ???
	self.isReceipt				:=	false;	// ???
	self.isSystemGenerated		:=	true;	// ???			&lt;&lt;&lt;======
	//self.packLocation			:=	?
	//self.packProduct			:=	?
	//self.packQuantity			:=	?
//	self.quantityRemaining		:=	dataRefObj.items;	// THis is a virtual.
	//self.releasedItemStrings		?	StringArray
// TFS 2686		self.removeStops			:=	false;	// ???
	self.releaseByType			:=	true;	// This needs to be true for EDI file loads.
	self.status					:=	BR_ACTIVE;
	//self.statusDate				:=	?
	//self.statusString			:=	"Active";			// This is a virtual status set aboe
//	self.totalPacked			:=	dataRefObj.items;	// ???
	self.totalRequested			:=	dataRefObj.items;
	self.type					:=	BR_TYPE_PACKING;
	
	// Update any references/inverses.
	
// This gets set in the transaction when the setForCreate method is called.
//	self.myBookingRefStock		:=	bookingRefObj;
	
	//self.myBusinessUnit		:=	?
	//self.myCargoType			:=	?			Can we look this up from the list of products (_bookRefTI.product) ?
	
	/* MES 1008 cannot set virtual properties
	if _bookRefTI.consignee &lt;&gt; null then
		consigneeObj	:=	rootObj.allConsigneeConsignors[_bookRefTI.consignee];
		
		if consigneeObj &lt;&gt; null then
			self.myConsignee	:=	consigneeObj;
		endif;
	endif;
	
	if _bookRefTI.consignor &lt;&gt; null then
		consignorObj	:=	rootObj.allConsigneeConsignors[_bookRefTI.consignor];
		
		if consignorObj &lt;&gt; null then
			self.myConsignor	:=	consignorObj;
		endif;
	endif;
	*/
	
	self.myDischargePort		:=	rootObj.allPorts[_bookRefTI.dischargePort];
	//self.myFreightForwarder	:=	?
	//self.myFreightForwarderTerminal	:=	?
	
	if _bookRefTI.isoType &lt;&gt; null then
		isoTypeObj	:=	rootObj.allISOTypes[_bookRefTI.isoType];
		
		if isoTypeObj &lt;&gt; null then
			self.myISOGroup		:=	isoTypeObj.myISOTypeGroup;
		endif;
	endif;
	
	//self.myLoadPort			:=	?
	
	if _bookRefTI.operatorCode &lt;&gt; null then
		operatorObj	:=	rootObj.allOperators[_bookRefTI.operatorCode];
		
		if operatorObj &lt;&gt; null then
			self.myOperator	:=	operatorObj;
		endif;
	endif;
	
	self.myTerminal					:=	app.getMyTerminalDO_NOT_USE();	// ???
	//self.myTransferToTerminal		:=	?
	
	if self.myTerminal &lt;&gt; null then
//		self.myVoyage := self.myTerminal.allVoyagesNew.getAtKeyGeq(_bookRefTI.voyageCode, null);	// cnwrl1 09/06/2010 PAR 24299 - what it was
		self.myVoyage := self.myTerminal.allVoyagesNew.getAtKeyGeq(_bookRefTI.getVoyageCode(), null);
		
//		if self.myVoyage.code &lt;&gt; _bookRefTI.voyageCode then		// cnwrl1 09/06/2010 PAR 24299 - what it was
		if self.myVoyage.code &lt;&gt; _bookRefTI.getVoyageCode() then
			self.myVoyage	:=	null;
		endif;
	endif;
	
	self.code	:=	_bookRefTI.releaseRequestNumber;
	
// cnwdad1 05/08/2009 - PAR #20409. It's important that this is done last, so that the correct
// Sub-Terminal is set if a default is required.
	if _bookRefTI.subTerminalCode = null then
// cnwdad1 27/01/2010 - PAR #22205.
//		subTermSource	:=	self.myTerminal.getConfig(MySubTerminalForSourceBulkRoad).CM_SubTerminal;
		subTermSource	:=	self.myTerminal.getDefaultSubTerminalForRel(self.type);
		subTermTarget   :=	self.myTerminal.getConfig(MySubTerminalForTargetBulk).CM_SubTerminal;
		self.setSubTerminalDefault(subTermSource, subTermTarget);
	else
		subTerminalObj	:=	self.myTerminal.allSubTerminals[_bookRefTI.subTerminalCode];
		
		if subTerminalObj &lt;&gt; null then
			self.mySubTerminal	:=	subTerminalObj;
		endif;
	endif;
end;</source>
        <Parameter name="_bookRefTI" type="CM_EDIBookingRefTI"/>
    </JadeMethod>
    <JadeMethod name="setFromRestAPI" id="f276d92f-3f74-43ed-b5df-a80155bfd8d4">
        <updating/>
        <source>setFromRestAPI(	_releaseNumber					: String;
				_type							: Integer;
				_releaseByType					: Boolean;
				_status							: Integer;
				_carrierId,
				_consigneeCode,
				_consigneeDesc,
				_consignorCode,
				_consignorDesc,
				_consignorVoyageCode			: String;
				_dateTimeRequested,
				_estimatedRequired				: TimeStamp;
				_deliveryRequestNumber,
				_freightPayerCode				: String;
				_bookingRef						: CM_BookingRef;
				_dischargePort					: CM_Port;
				_freightForwarderCode			: String;
				_terminal,
				_transferTerminal				: CM_Terminal;
				_operator						: CM_Operator;
				_voyage							: CM_Voyage;
				_fullRelease					: Boolean;
				_subTerminal					: CM_SubTerminal;
				_allowCargoOnMultipleReleases	: Boolean;
				_remarks						: String
				) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 July 2024		navmd1	Initial creation TFS 63327 Only set values we know about from the API

*/

vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.carrierId 				:= _carrierId;
	self.consigneeCode			:= _consigneeCode;
	self.consignorCode			:= _consignorCode;
	self.consignorVoyageCode	:= _consignorVoyageCode;
	self.converted				:= true;
	self.dateEstimatedRequired	:= _estimatedRequired;
	self.deliveryReleaseNumber	:= _deliveryRequestNumber;
	self.freightForwarderCode	:= _freightForwarderCode;
	self.fullRelease			:= _fullRelease;
	self.myDischargePort		:= _dischargePort;
	self.releaseByType			:= _releaseByType;
	self.consigneeDesc			:= _consigneeDesc;
	self.consignorDesc			:= _consignorDesc;
	self.cargoRemarks			:= _remarks;
	
	// References
	self.myOperator				:= _operator;
	self.myTransferToTerminal	:= _transferTerminal;
	
	// Inverses	
	self.code					:= _releaseNumber.trimBlanks.toUpper;
	self.dateRequested			:= _dateTimeRequested;
	self.status					:= _status;
	self.type					:= _type;
	
	self.myVoyage				:= _voyage;			// needs to be after code, dateRequested, status and type
	self.mySubTerminal			:= _subTerminal;	// needs to be after code and dateRequested
	self.myBookingRefStock		:= _bookingRef;
	
	self.myTerminal				:= _terminal;		// should always be last
	
	// After myTerminal set
	if self.myOperator &lt;&gt; null then
		//now PAR16612 cnwsh3 Was causing a 1048 exception when using a newly created operator.  
		self.myOperatorTerminal := self.myOperator.getOperatorTerminal(self.myTerminal, false);
	endif;
	
epilog

end;</source>
        <Parameter name="_releaseNumber" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_releaseByType" type="Boolean"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_carrierId" type="String"/>
        <Parameter name="_consigneeCode" type="String"/>
        <Parameter name="_consigneeDesc" type="String"/>
        <Parameter name="_consignorCode" type="String"/>
        <Parameter name="_consignorDesc" type="String"/>
        <Parameter name="_consignorVoyageCode" type="String"/>
        <Parameter name="_dateTimeRequested" type="TimeStamp"/>
        <Parameter name="_estimatedRequired" type="TimeStamp"/>
        <Parameter name="_deliveryRequestNumber" type="String"/>
        <Parameter name="_freightPayerCode" type="String"/>
        <Parameter name="_bookingRef" type="CM_BookingRef"/>
        <Parameter name="_dischargePort" type="CM_Port"/>
        <Parameter name="_freightForwarderCode" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_transferTerminal" type="CM_Terminal"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_fullRelease" type="Boolean"/>
        <Parameter name="_subTerminal" type="CM_SubTerminal"/>
        <Parameter name="_allowCargoOnMultipleReleases" type="Boolean"/>
        <Parameter name="_remarks" type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromTIRequest" id="3d45edc5-6fe8-4ce3-bc26-480bb5593d5a">
        <updating/>
        <source>setFromTIRequest(_tiRequest : CM_TIRequest input) updating;
//-----------------------------------------
// Created: 11 June 2004 By: cnwgd1
//-----------------------------------------
// Changed on	By			Reason
// ----------	--------	---------------------------------------------
// 11/08/2011	cnwdap1		PAR #27972 create new objects as converted
vars
	request : CM_TIRequest;
begin

	self.raiseExceptionIfTransient(method);

	if _tiRequest = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_NO_OBJECT, '_tiRequest', null, null);
		return;
	endif;

	if CM_RoadJob.hasInstance(_tiRequest.myJob) then
		self.carrierId := _tiRequest.myJob.CM_RoadJob.carrierId;
		self.setType(BR_TYPE_ROAD);
	endif;	

	self.code := _tiRequest.deliveryNumber.trimBlanks.toUpper;
	if self.code = null then
		self.code := _tiRequest.myTerminal.getBulkReleaseNextSeqNumber();
		self.isSystemGenerated := true;
		//PAR 9284 - need this set so that the bulkrelease can be completed later
		///_tiRequest.deliveryNumber := self.code;		
		_tiRequest.deliveryNumber := self.getDeliveryReleaseNumber();			// 01/12/2010 cnwmh5 #26400
	endif;	
	
	self.myTransferToTerminal := _tiRequest.myTransferToTerminal;
	
	//We have already validated the request so just clone it.	
	request := _tiRequest.cloneSelf(false);
	request.setBulkRelease(self);

	//set the date to now if no date - to help with uniqueness
	if not self.dateRequested.isValid then
		self.dateRequested := app.serverTimestampAtTrxStart;
	endif;

	//Set TI ref last		
	request.setTrackedItem(_tiRequest.trackedItem);	

	//self.totalRequested := 1;
	self.setStatus(BR_ACTIVE, false, true);
	self.consigneeCode 			:= _tiRequest.consigneeCode;
	self.freightForwarderCode	:= _tiRequest.freightForwarderCode;		// PAR 20646
	self.myTransferToTerminal 	:= _tiRequest.myTransferToTerminal;
	//self.myFreightForwarder	:= _tiRequest.myFreightForwarder;		// removed for PAR 20646
	self.myTerminal		:= _tiRequest.myTerminal;
	
	//epr par 34174 bit of refactoring
	self.setDetailsFromTI(_tiRequest.trackedItem );
	
	self.converted := true;			// PAR #27972
	
end;</source>
        <Parameter name="_tiRequest" type="CM_TIRequest" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setIMEXStatusArrayDetails" id="3510fedd-d0f5-40d0-85b7-a8b7af4e0d03">
        <updating/>
        <source>setIMEXStatusArrayDetails(_request : CMIF_YARequest io) updating;

/*

Purpose:		Sets the IMEX Status Array (Request) for bulk release	

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2010	cnwmh5	Initial creation #25696

*/

vars

begin

	_request.imexStatusArray.add(TI_IMEX_STATUS_STORAGE); 
	if self.type = BR_TYPE_ROAD or self.type = BR_TYPE_RAIL then
		_request.imexStatusArray.add(TI_IMEX_STATUS_IMPORT); 	
	elseif self.type = BR_TYPE_SHIP then
		_request.imexStatusArray.add(TI_IMEX_STATUS_EXPORT); 	
	endif;

epilog

end;</source>
        <Parameter name="_request" type="CMIF_YARequest" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setInterfaceBP" id="7ab0e668-aa5c-472c-ad1c-a16638892d2f">
        <updating/>
        <source>setInterfaceBP(_intFaceBP : CMIF_BuildPriority input; _railIORake : CM_RailJSInOutRake) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
/* Changes

Date		Name	TFS#	Description
============================================================================
24 Jul 2023	navma1	Bug 59261: MTN - Issues while assigning Release Rail request to work orders
============================================================================*/

vars
	voyCode				: String;
	consignVoyCode		: String;
	deliveryNum			: String;
	tranAreaID			: String;
	str					: String;
	proxyJob			: CM_RailJob; 
	intFaceObj			: CMIF_Request;
	dateTime			: TimeStamp;
	request				: CM_Request;
	reserveSelection	: CM_ReserveSelection;
	reserveTI 			: CM_ReserveTI;
	reserveDetail 		: CM_ReserveDetail;
	tmpTI				: CM_TrackedItem;
	onSiteWithJob 		: Integer;
	
begin

	if _railIORake &lt;&gt; null then 
		tranAreaID := _railIORake.rake;
	endif;

	deliveryNum := self.code;
	if self.myVoyage &lt;&gt; null then
		voyCode := self.myVoyage.code;
	endif;
	consignVoyCode  := self.consignorVoyageCode;
	dateTime 		:= self.dateRequested;
	
	_intFaceBP.myReserveHeader := self;
	_intFaceBP.mode 		   := 1; // Mode_add 

	create proxyJob transient;
	proxyJob.setProxy(deliveryNum, null);
	proxyJob.setProxyRailJob(self.cargoRemarks, consignVoyCode, deliveryNum, voyCode, tranAreaID, null, Rail_JSIO_Type_Out, self.myTerminal, dateTime);
	
	_intFaceBP.myProxyRailJob := proxyJob;
	_intFaceBP.myPassport 	  := app.myPassport;
	
	if self.quantityRemainingRail &lt;= 0 and self.getWeightOutstanding &lt;= 0 then	//04 Sep 2020	NDL	TFS 49865	- Need to allow for Bulk too
		return;
	endif;
	
	foreach reserveDetail in _intFaceBP.allReservesToProcess do
		request := reserveDetail.getRequest();	//SFW1035
		if request &lt;&gt; null  and not request.isWorkOrderRequest then				//24.07.2023 navma1 #59261
			if request.isKindOf(CM_DeliveryRequest) then	
				//31 Jul 2009 NDL - count up those on site that are currently associated with a job.
				onSiteWithJob := request.CM_DeliveryRequest.totalRequested;
			//16 Sep 2013	NDL	Par 32452
			elseif request.isKindOf(CM_TIRequest) and reserveDetail.getTotalOutstanding &gt; 0 then	
				onSiteWithJob := reserveDetail.getNumItemsBeingActioned(null);
				if onSiteWithJob &gt; 1 and onSiteWithJob &lt; ( reserveDetail.totalRequested + reserveDetail.getTotalReleased ) then
					// more to relese yet, let it run
				else
					continue;
				endif;
			else
				continue;
			endif;
		endif;

		create intFaceObj transient;
		_intFaceBP.allCMIFRequests.add(intFaceObj);
		intFaceObj.myProxyJob 			:= proxyJob;		
		intFaceObj.mode 				:= 1; // Mode_add 
		intFaceObj.myTerminal			:= self.myTerminal;
		intFaceObj.myCargoBOLType 		:= reserveDetail.getCargoType();
		intFaceObj.myReserveDetail 		:= reserveDetail;
		intFaceObj.consigneeCode 		:= self.consigneeCode;
		intFaceObj.consignorVoyageCode 	:= self.consignorVoyageCode;
		intFaceObj.deliveryReason 		:= self.deliveryReasonDescr;
		intFaceObj.doorsForward 		:= (self.doorsDirection = TI_DOORSDIRN_FWD);
		intFaceObj.freightForwarderCode := self.freightForwarderCode;	// PAR 20646
		intFaceObj.freightPayerCode 	:= self.freightPayerCode;
		intFaceObj.myConsignee 			:= app.myRoot.allConsigneeConsignors[self.consigneeCode];
		intFaceObj.myTransferToTerminal := self.myTransferToTerminal;
		intFaceObj.releaseNo 			:= self.code;
		
		
		intFaceObj.requestDate 			:= self.dateRequested.date;
		intFaceObj.operatorCode 		:= self.getOperatorCode();
		intFaceObj.myOperatorGroup 		:= self.myOperatorGroup;
		if self.myVoyage &lt;&gt; null then
			intFaceObj.voyageCode := self.myVoyage.code;
		endif;
		
		if CM_ReserveSelection.hasInstance(reserveDetail) then
			reserveSelection := reserveDetail.CM_ReserveSelection;
			if _intFaceBP.allReservesToProcess.size &gt; 1 then // PAR 19913
				str := intFaceObj.releaseNo &amp; " (" &amp; reserveSelection.getISOCode &amp; ")";	// 22/02/2010 cnwar2 #22159
				intFaceObj.releaseNo := str[1:intFaceObj.releaseNo.maxLength];			// 22/02/2010 cnwar2 #22159
			endif;
			
			reserveSelection.allAvailabilityGrades.copy(intFaceObj.allMTGrades);
			//th2 PAR 14996 - Completed packing releases to be moved to Active rail
			if reserveSelection.totalRequested &lt; 0 then
				intFaceObj.quantityTxt 		:= reserveSelection.allTrackedItemsReleased.size;
			else		
				intFaceObj.quantityTxt 		:= reserveSelection.getQuantityRemaining();	
				intFaceObj.weight  			:= reserveSelection.getWeightOutstanding();	//03 Feb 2016	NDL	Par 37492	
				if onSiteWithJob &gt; 0 then
					//31 Jul 2009 NDL - getQuantityRemaining includes those that are 
					// currently associated with a job.
					intFaceObj.quantityTxt 		:= reserveSelection.getQuantityRemaining() - onSiteWithJob;
				endif;

			endif;
			
			intFaceObj.clean 			:= reserveSelection.clean;
			intFaceObj.heavyRated 		:= reserveSelection.heavyRated;
			intFaceObj.idMask 			:= reserveSelection.getIdsAsString();
			intFaceObj.isoType 			:= reserveSelection.getISOCode;
			intFaceObj.isTIRequest 		:= false;
			intFaceObj.isReceipt 		:= false;
			
		elseif CM_ReserveTI.hasInstance(reserveDetail) then
			reserveTI 					:= reserveDetail.CM_ReserveTI;
			intFaceObj.isTIRequest 		:= true;
			intFaceObj.quantityTxt 		:= 1;
			//th2 for PAR 14996 - Completed packing releases to be moved to Active rail
			tmpTI := reserveTI.getTI();				
			if tmpTI &lt;&gt; null then
				intFaceObj.myTrackedItem := tmpTI;
				intFaceObj.isoType 		:= tmpTI.getISOType();
				intFaceObj.operatorCode := tmpTI.operatorCode;
			endif;
		endif;
	endforeach;
end;</source>
        <Parameter name="_intFaceBP" type="CMIF_BuildPriority" usage="input"/>
        <Parameter name="_railIORake" type="CM_RailJSInOutRake"/>
    </JadeMethod>
