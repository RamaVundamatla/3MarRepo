    <JadeMethod name="updateMe" id="7b869ff6-fbd6-4272-9c84-06bd6d96ddfc">
        <updating/>
        <source>updateMe(pPropertyObj:Property; pAlias:String; pClassObj:CnEcDocModelClass) updating;
// --------------------------------------------------------------------------------
// Created:		01 November 2002 by cnwdad2
//
// Purpose:		Update the receiver's details.
//
// Parameters:	pPropertyObj - The property which this Documentation Property object represents.
//				pAlias - The alias name of the property.
//				pClassObj - The owner of this Documentation Property.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 23/01/2003	cnwdad1		Added support for an alias of the receiver's name.
// --------------------------------------------------------------------------------
begin
	self.alias			:=	pAlias;
	self.myProperty		:=	pPropertyObj;
	self.propertyName	:=	pPropertyObj.name;
	self.myDocClass		:=	pClassObj;
end;</source>
        <Parameter name="pPropertyObj" type="Property"/>
        <Parameter name="pAlias" type="String"/>
        <Parameter name="pClassObj" type="CnEcDocModelClass"/>
    </JadeMethod>
</Class>
