    <JadeMethod name="setControlsForAddEdit" id="c37d4292-d4e1-4f1f-9753-758b8c66800e">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:     02 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin

	if self.allowArchive then
		btnArchive.enabled := false;
	endif;

	if self.mode = self.Mode_Add then
		setVisibility(true);
		self.tblInput1.clearValues;
		self.tblInput1.moveFirst();
		self.myCurrentLogRestriction := null;
		self.myOperator := null;
		self.myCurrentLogArea := null;
		self.cmbLogSpecies.clear;
		self.cmbLogSpecies.setObjectAndOperator(null,null);
		self.isRowSplit := false;
		setTransportMode(CM_LocationRestrictLog.RESTRICTION_BOTH);
		self.tblInput1.enableRowByName(ETRow_TerminalAreaId);
		self.tblInput1.enableRowByName(ETRow_Id);
		self.tblInput1.hideRowByName(ETRow_RowToSplit, false);
		
		self.tblInput1.setValueByName(ETRow_Status, LC_StatusStr_Open);
		
		self.tblInput1.setValueByName(ETRow_IsExternallyVisible, true); //cnwrd1 ccms 1134 par 35101
		
		self.isMixedRow := self.tblInput1.getValueByName(ETRow_MixedRow).Boolean;
		self.setTblInput1ViewForLogs();
		
		
	elseif self.mode = self.Mode_Update then
		self.tblInput1.moveFirst();
		self.loadTblInput1(self.myProxyObject.CM_LogController);
		self.tblInput1.disableRowByName(ETRow_TerminalAreaId);
		self.tblInput1.disableRowByName(ETRow_Id);
	endif;
	self.doEnableControls(true);
	self.tblInput1.adjustHeight(1000);
	self.fldInput.initSheetBackColors();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="ee886108-1e66-470b-bb8a-6a63d7772ec8">
