    <JadeMethod name="trxDeleteStops" id="7364e095-4080-4266-bffe-89e2256b34f8">
        <updating/>
        <source>trxDeleteStops(_theTI : CM_TrackedItem input; _theStops : IntegerArray; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2002 By Andrew Bishop cnwab1
//
// Purpose:		This TRX is used to REMOVE stops on a TI. Whatever global constant
//				integers are in the passed in array will result in the matching CM_Stops being removed from the TI
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17 Oct 2024 	navhl20 	Bug 33084 CUX - 1081 Error When using MasterTerminalAPIService::postCustomsStatus
// ---------------------------------------------------------------------------
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	
	// do the validation here

	app.setContinueCMExceptions(false);
	 //jlier1 TFS 65868 28/8/24
	if _passport.myStateChangeController &lt;&gt; null then
		_passport.myStateChangeController.initForObject(_theTI);
	endif;
	
	_passport.useTIDictDeferUpdate 		  := true;										//17.10.2024 navhl20 #33084
	_passport.useTITransactionDeferUpdate := true;										//17.10.2024 navhl20 #33084
	
	beginTransaction;
 
	app.myUtilityDA.utlDeleteStops(_theTI, _theStops, _passport);
	
	if _passport.noErrors then															//17.10.2024 navhl20 #33084
		_passport.doDeferredUpdates();	
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_theStops" type="IntegerArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
