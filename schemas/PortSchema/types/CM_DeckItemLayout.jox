    <JadeMethod name="isMoveable" id="ce9c4ae5-b555-4501-95a1-4f065fd39de3">
        <source>isMoveable() : Boolean;
// ---------------------------------------------------------------------------
// Created:     15 August 2011 by cnwab1 PAR 28013
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if not self.myDeckLayer.myDeckLayout.myDeck.isVoyageDeck() then // on a vessel
		return true;
	endif;
	
	if self.isPillar()  then
		return false;
	endif;

	if self.myDeckItem = null then
		return true;
	endif;
	
	if self.myDeckItem.isKindOf(CM_ROROLaneDefn) then
		return false;
	endif;
	
	if self.myDeckItem.isKindOf(CM_ROROLocnDefn) then
		if not self.myDeckItem.CM_ROROLocnDefn.isOOTL() then

			return false;
		endif;
	endif;
	

	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
