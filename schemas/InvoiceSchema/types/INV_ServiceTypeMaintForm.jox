    <JadeMethod name="setServiceAvailable" id="bfb91901-55f8-4c60-999f-a7b568cf0b78">
        <source>setServiceAvailable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2022	navkc1	Initial creation

*/

vars
	service				: CM_ServiceObject;
	serviceSet			: ObjectSet;
	glCode				: CM_GLCode;
	theServiceType 		: CM_ServiceType;
	
begin
	theServiceType := self.myCurrentObject.CM_ServiceType;
	
	glCode := self.cmbGLCode.listObject.CM_GLCode;
	
	// Create Set
	create serviceSet transient;
	
	if glCode &lt;&gt; null then
		// Go through all the services of the GL code. Process only if it's Available and is a Service
		foreach service in glCode.services where not service.isNotAvailableForEntry and service.isKindOf(CM_Service) do
			// Add to Set
			serviceSet.add(service);
		endforeach;
		// If we have something to populate
		if serviceSet.size() &gt; 0 then
			// Populate them to the MSG, do not clear the Selected MSG
			self.msgServices.setAvailable(serviceSet, false);
		endif;
	else
		// Check if the we current bank set
		if self.myCurrentBank &lt;&gt; null then
			// Go through all available services in the bank
			foreach service in self.myCurrentBank.services where not service.isNotAvailableForEntry and service.isKindOf(CM_Service) do
				// Add to Set
				serviceSet.add(service);
			endforeach;
			self.msgServices.setAvailable(serviceSet, false);
		endif;
	endif;
	
epilog
	// Delete transient
	delete serviceSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="bd501109-1a3d-49fa-8116-4eac831387c9">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2022	navkc1	Initial creation

*/

vars
	businessUnits	: CM_CompanyByCodeDict;
	currentBU		: CM_Bank;
begin
	beginClassNotification(CM_ServiceType, false, Object_Create_Event, Response_Continuous, 0); 
	// Default to no search
	self.allowSearch := false;
	// Create dictionary 
	create businessUnits transient;
	// Get default bank and all available banks
	currentBU := self.myTerminal.getAvailableCompanies(businessUnits);
	// Set current to default bank
	self.setMyCurrentBank(currentBU);
	// If we have more than 1 bank/business unit, allow the search
	if businessUnits.size() &gt; 1 then
		// Set to allow search
		self.allowSearch := true;
	endif;
	
	self.useTblThumb := false;
	
	// Do Inhherit
	inheritMethod();
	
epilog
	// Delete
	delete businessUnits;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupPermissions" id="5bb49d90-7ce3-4ea8-bb72-cd7a446f3702">
        <updating/>
        <source>setupPermissions() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2022	navkc1	Initial creation
31 March 2023	navmk20	Bug 56983: FR | 53978 - EUP - Invoicing - Configuration Enhancements - Service Type Maint permission
*/

vars

begin
	inheritMethod();		// 31.3.2023 navmk20 TFS 56983
	
	// If don't have permission
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		// Disable these buttons
		btnNewTV.enabled	:= false;
		btnEditTV.enabled 	:= false;
		btnDeleteTV.enabled	:= false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="0405f626-05b1-4332-8a04-99a7ed9f8b8d">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2022	navkc1	Initial creation

*/

vars
	
	theServiceType,
	realServiceType		: CM_ServiceType;
	
begin
	
	theServiceType := obj.CM_ServiceType;
	
	if theServiceType.isTransient() then
		realServiceType := theServiceType.pxyGetRealObject();
	else
		realServiceType := theServiceType;
	endif;
	
	populateEntDetailTable();
	self.setServiceAvailable();
	self.msgServices.setSelected(realServiceType.allServices);
	
epilog

end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="56484f7d-a726-42c3-8faa-8c36a4410dc7">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 24 August 2022 11:30:19.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0024986, locale);
	lblGLCode.translateCaption(Xlat_0024987, locale);
	msgServices.translateCaption(Xlat_0024988, locale);
	shtEntDetail.translateCaption(Xlat_0024989, locale);
	shtServices.translateCaption(Xlat_0024990, locale);
end;</source>
    </JadeMethod>
