    <JadeMethod name="getDescription" id="c8466a6e-5fdf-460f-9f5a-33ed1b149df0">
        <source>getDescription() : String;
// reporting
vars

	typeString	: String;
	receipt		: CM_CashReceipt;

begin

	typeString := app.getErrorString(Credit);

	typeString := typeString &amp; " " &amp; self.externalId;
	receipt := self.myDerivedFromCashReceipt;
	if receipt &lt;&gt; null then
		typeString := typeString &amp; " " &amp; app.getErrorString(Receipt) &amp; " " &amp; receipt.getExternalInvoiceNumber();
	endif;
	if self.myUser &lt;&gt; null then
		typeString := typeString &amp; " " &amp; self.myUser.code;
	endif;

	return typeString;

epilog

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExportSequence" id="5d0a25ed-d6cb-43e9-9e72-27f1c6ea4b88">
        <source>getExportSequence() : Integer;
// Feb 2016 TFS 985 if the external id is in the Milaha format, return the
//	otherwise return the internal sequenceNum value.  Used to build the export extract file name.
vars
	id		: String;
	pos		: Integer;
	seq		: Integer;
begin
	// Milaha external sequence is 'JMT/CN/nnnnnn/yyyy' - return the nnnnnn portion if so
	id := self.externalId;
	if id.length &gt; 18 and 			// from TFS 1890 checking 22/04, was 718?? (typo?)
	   id[1:7] = "JMT/CN/" then
		seq := id[8:6].Integer;
	endif;
	// default value
	if seq = 0 then
		seq := self.sequenceNum;
	endif;
	return seq;
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
