    <JadeMethod name="loadSetMeasurementType" id="56da92c0-443e-4231-8d8d-f5148b8b62ce">
        <updating/>
        <source>loadSetMeasurementType(_load : Boolean; _entRowName : String) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/03/2013	cnwdap1	Initial creation PAR #31155 CCMS 1321 Imperial Measurement
11/06/2013	cnwdap1	PAR #31767 Correct combo interaction
20/03/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk
*/
vars
	measureType : CM_MeasurementType;
	entRowName	: String;								// PAR #31767

begin
	if _load then	//loading value for control on the screen
		if self.cmbMeasureType.listCount = null then
			self.cmbMeasureType.enabled := false;
		endif;
		if self.myCurrentProdAttr &lt;&gt; null and self.myCurrentProdAttr.myMeasurementType &lt;&gt; null then
			// PAR #31767 if listCount in measurement combo is null, we need to populate the combo
			if self.cmbMeasureType.listCount = null then
				entRowName := self.getEntRowNameFromCmbSystemName;
				//if not entRowName.isOneOf(ETRow_MyWeight, ETRow_MyVolume, ETRow_MyHeight, ETRow_MyLength, ETRow_MyWidth, ETRow_MyDensity) then						// PAR #33606
				if not entRowName.isOneOf(ETRow_MyWeight, ETRow_MyVolume, ETRow_MyHeight, ETRow_MyLength, ETRow_MyWidth, ETRow_MyDensity, ETRow_MyStowageFactor) then	// PAR #33606
					entRowName := null;
				endif;
				self.setCmbMeasureType(entRowName);
			endif;
			// PAR #31767 end
			self.cmbMeasureType.text := self.myCurrentProdAttr.getDisplayStringForAttribute(_entRowName, false);
			self.cmbMeasureType_click(self.cmbMeasureType);		//cnwmc5 - 28 Nov 2013 - PAR 33074
		else
			// cmbMeasureType text has already been set in form setup logic by the ent row name for the product attribute
		endif;
		if self.cmbMeasureType.listIndex &gt; 0 then
			self.cmbMeasureType.enabled := true;
		else
			self.cmbMeasureType.enabled := false;
		endif;
	else	//getting value from the screen
		if self.cmbMeasureType.listIndex &gt; 0 then
			measureType := self.cmbMeasureType.itemObject[self.cmbMeasureType.listIndex].CM_MeasurementType;
		endif;
		self.myCurrentProdAttr.setMyMeasurementType(measureType);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_load" type="Boolean"/>
        <Parameter name="_entRowName" type="String"/>
    </JadeMethod>
