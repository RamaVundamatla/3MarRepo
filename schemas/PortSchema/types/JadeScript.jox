    <JadeMethod name="diResetConstFormPermission" id="e1c810de-86c0-4eb7-8111-c05f231f0624">
        <source>diResetConstFormPermission();
/*

Purpose: Reset the the value of the new attribute 'formType' of the Constant Permissions

Parameters:			

Return Value:		

Date		Who		Reason
13 September 2019	jlgdi1	Initial creation

*/

constants
	PERMTYPE_SPECIAL : Integer = 2;
	
vars
	permAgent : CM_PermissionAgent;
	permObj : CM_PermissionObject;
	count : Integer;
	
begin
	create permAgent transient;
	permAgent.populatePermissionDict(true, false, 0);
	
	foreach permObj in permAgent.allPermissionsByName do
		if permObj.permType = PERMTYPE_SPECIAL then
			continue;
		endif;
				
		count := count + 1;
			
		permObj.formType := 0;
		permObj.constText := permObj.outputAsXML();
		permAgent.trxSaveDataToGlobalConstants(permObj);
	endforeach;
	
	write "Total count : " &amp; count.String;
	
epilog
	delete permAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="diResetMenuForJMTSupportUser" id="9967a697-609e-49e4-874f-4e00455f9bcb">
        <source>diResetMenuForJMTSupportUser();
/*

Purpose:	Test reset/regen menus for JMT Support user using release schema

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2019	jlgdi1	Initial creation

*/

vars
	user : CM_User;
	jmtSupportUser : CM_User;
	menuRootUserTerminal : CM_MenuRootUserTerminal;
	release : PortSchema_8_6_1;

begin
	app.initialize();
	
	// To test if resetting menu for JMT Support user works, let us first delete all menus for JMTSupport user, then call the reset method
	foreach user in app.myRoot.allUsers do 
		if user.code = JMTSUPPORT_Str then 
			jmtSupportUser := user;
			break;
		endif;
	endforeach;
	
	if jmtSupportUser &lt;&gt; null then
		foreach menuRootUserTerminal in jmtSupportUser.allUserMenuRoots do 
			beginTransaction;
			menuRootUserTerminal.allMenuUserItemsWithAMenuItem.purge;
			commitTransaction;
		endforeach;
		
		create release transient;
		release.resetMenuForJMTSupportUser();		
	endif;
	
epilog
	delete release;
end;</source>
    </JadeMethod>
    <JadeMethod name="diSetCashPaymentsToMerged" id="3a84c7e7-fe3b-4c90-82da-4c5a794ebf33">
        <source>diSetCashPaymentsToMerged();
/*

Purpose: An upgrade script as part of the Cash Review change request TFS# 45301.
         Set the status of CM_CashPayment to Status_Merged if the following conditions are met (as per Tech Specs):
		 1. CM_CashPayment status is "Void" (CM_CashPayment.status = 1)
		 2. CM_trackedItem.hasBeenMerged() = true (only means that the cash payment is linked to a 'zombie')

Parameters:			

Return Value:		

Date		Who		TFS		Reason
============================================================================
12 Jul 2019	jlgdi1	45301	Initial creation
============================================================================
*/

vars
	cashPayments : ObjectArray;
	object : Object;
	cashPayment : CM_CashPayment;
	trackedItem : CM_TrackedItem;
	hasBeenMerged : String;
	
begin
	create cashPayments transient;
	CM_CashPayment.allInstances(cashPayments, 0, true);
	
	foreach object in cashPayments do
		cashPayment := object.CM_CashPayment;
		trackedItem := cashPayment.myTrackedItem;
		
		if (cashPayment.status = CM_CashPayment.Status_Void) and 
		   (trackedItem &lt;&gt; null) and 
		   (trackedItem.hasBeenMerged())
		then 
		   write trackedItem.id &amp; " " &amp; cashPayment.cashValue.asCurrencyJMT &amp; " cash payment status is : " &amp; cashPayment.getStatusDescription(cashPayment.status);
		   /*
		   beginTransaction;
		   cashPayment.setStatus(CM_CashPayment.Status_Merged);
		   commitTransaction;
		   */
		endif;
	endforeach;
	
epilog
	delete cashPayments;
end;</source>
    </JadeMethod>
    <JadeMethod name="diSetFutureTimerToRun" id="19ea6e88-35b8-46e5-ba62-de627fcf4f46">
        <source>diSetFutureTimerToRun();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2019	jlgdi1	Initial creation

*/

vars
	isap : CM_InvoiceStatusAdvanceProcess;
	ts : TimeStamp;
	
begin
	isap := "14372.9".asObject.CM_InvoiceStatusAdvanceProcess;
	
	if isap &lt;&gt; null then		
		beginTransaction;
		ts := isap.actionTimeStamp.addDays(-2);
		isap.setPropertyValue("actionTimeStamp", ts);
		commitTransaction;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="diTestInvoicePeriod" id="70d1e2d4-9456-465a-909f-4415b83a1e5a">
        <source>diTestInvoicePeriod();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		TFS		Reason
22 January 2020	jlgdi1				Initial creation
*/

vars
	param : CMIF_InvoiceSelection;
	invoices : CM_InvoiceBySeqNumDict;
	invoice : CM_Invoice;
	inv : CM_Invoice;
	debtor : CM_Debtor;
	invoiceType : CM_InvoiceDesc;
	paymentType : Integer;
	_invLineType : CM_InvoiceLineDesc;
	tran: CM_TITransaction;	
	theToDate : TimeStamp;
	
begin
	debtor := "2206.63356".asOid.CM_Debtor;				// DI Cash Debtor
	//bank := "2202.8783".asOid.CM_Bank;					// T2B2
	invoiceType := "2735.282494".asOid.CM_InvoiceDesc;	// Storage Liner MAFI
	_invLineType := "2222.1562029".asOid.CM_InvoiceLineDesc;	// Future Storage
	tran := "12579.292191".asOid.CM_FutureStorage;		// Transaction on 01 Dec 2019
	
	paymentType := _invLineType.getPaymentType(debtor);	
	app.msgBox("Payment Type is " &amp; paymentType.asStringJMT, "",0);
	
	create invoices transient;
	create param transient;
	
	param.debtor := debtor;
	param.paymentType := paymentType;
	param.status := CM_Invoice.INVOICE_OPEN;
	param.checkManual := true;
	param.isManual := false;
	param.companyCode := debtor.code;
	
	invoiceType.initialiseSelectionParameter(param, tran, null, null, null, null);
	
	debtor.getOpenInvoices(invoices, param);
	
	app.msgBox("Transaction date is " &amp; tran.dateTime.asStringJMT,"",0);
	
	if invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then	
		app.msgBox("Invoice is accrual type", "", 0);
	endif;
	
	foreach invoice in invoices do				
		app.msgBox("Testing Invoice Sequence Num " &amp; invoice.sequenceNum.asStringJMT &amp; " Invoice cover dates " &amp; invoice.fromDT.asStringJMT &amp; " - " &amp; invoice.toDT.asStringJMT, "", 0);
		
		//app.msgBox("Is Invoice "&amp; invoice.sequenceNum.asStringJMT &amp;" Date FROM " &amp; invoice.fromDT.asStringJMT &amp; " valid ? " &amp; invoice.fromDT.isValid().asStringJMT, "", 0);
		//app.msgBox("Is Invoice "&amp; invoice.sequenceNum.asStringJMT &amp;" Date TO "  &amp; invoice.toDT.asStringJMT &amp;  " valid ? " &amp; invoice.toDT.isValid().asStringJMT, "", 0);
		
		if invoice.coversTimeStampTransaction(tran) then
				app.msgBox("Transaction date is " &amp; tran.dateTime.asStringJMT &amp; 
								   " MATCHED with Invoice " &amp; invoice.sequenceNum.asStringJMT &amp; 
								   " [" &amp; invoice.fromDT.asStringJMT &amp; " - " &amp; invoice.toDT.asStringJMT &amp; "]", "", 0);
				break;
		endif;
	endforeach;
	
epilog
	delete param;
	delete invoices;
end;	
/*
	loop := 15;
	transDate := "22 February 2020, 00:01:00".TimeStamp;	
	
	while loop &gt; 1 do 
		fromDT := bank.getPeriodEndDateInitialise(debtor, invoiceType, transDate, false);
		toDT := bank.getPeriodEndDateInitialise(debtor, invoiceType, transDate, true);
		write "Transation date : " &amp; transDate.asStringJMT &amp; " period [ " &amp; fromDT.asStringJMT &amp; " - " &amp; toDT.asStringJMT &amp; " ]";
		
		transDate := transDate.addDays(1);
		loop := loop - 1;
	endwhile;	
end;
*/</source>
    </JadeMethod>
    <JadeMethod name="diUpdatePermissionViewType" id="4f5dc40d-a287-48ed-b139-cd13a3285ad1">
        <source>diUpdatePermissionViewType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		TFS		Reason
04 September 2019	jlgdi1			Initial creation

*/

constants
	PERMTYPE_SPECIAL : Integer = 2;
	
vars
	permAgent : CM_PermissionAgent;
	permObj : CM_PermissionObject;
	count : Integer;
	identified : Boolean;
	niether : String;
	otherMaintPermissions : IntegerArray;
	otherViewPermissions : IntegerArray;
	identifiedCount : Integer;
	unidentifiedCount : Integer;
	
begin
	create otherMaintPermissions transient;
	create otherViewPermissions transient;
	
	self.diOtherMaintPermissionList(otherMaintPermissions);
	self.diOtherViewPermissionList(otherViewPermissions);

	create permAgent transient;
	permAgent.populatePermissionDict(true, false, 0);
	
	foreach permObj in permAgent.allPermissionsByName do
		if permObj.permType = PERMTYPE_SPECIAL then
			continue;
		endif;
				
		// Meaning permission hasn't been updated by the script nor PermissionApp
		if permObj.formType = 0 then
			count := count + 1;
			
			if (permObj.constName.pos("View", 1) &gt; 0) or (permObj.description.pos("View", 1) &gt; 0) then
				identified := true;
				permObj.formType := ViewType;
			elseif (permObj.constName.pos("Maint", 1) &gt; 0) or (permObj.description.pos("Maint", 1) &gt; 0) then
				identified := true;
				permObj.formType := MaintenanceType;
			elseif otherMaintPermissions.includes( permObj.constValue ) then
				identified := true;
				permObj.formType := MaintenanceType;
			elseif otherViewPermissions.includes( permObj.constValue ) then
				identified := true;
				permObj.formType := ViewType;
			else
				identified := false;
				niether := niether &amp; permObj.constName &amp; CrLf;
			endif;
			
			if identified then
				identifiedCount := identifiedCount + 1;
				permObj.constText := permObj.outputAsXML();
				permAgent.trxSaveDataToGlobalConstants(permObj);
			else
				unidentifiedCount := unidentifiedCount + 1;
			endif;
		endif;
	endforeach;
	
	if niether.length &gt; 0 then
		write niether;
	endif;
	
	write "Total count : " &amp; count.String;
	write "Total Identified : " &amp; identifiedCount.String;
	write "Total Unidentified : " &amp; unidentifiedCount.String;
	
epilog
	delete permAgent;
	delete otherMaintPermissions;
	delete otherViewPermissions;
end;</source>
    </JadeMethod>
    <JadeMethod name="di_DeleteArchivedVoyages" id="d3e785a3-a8f9-4254-a26b-48c349489cdf">
        <source>di_DeleteArchivedVoyages();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Mar 2019	jlgdi1	TFS# 43985 MSL - Delete Archived Voyages

*/

constants
	START_DATE : Date = "01Jan2015".Date;
	END_DATE : Date = "31Dec2015".Date;
	
vars	
	voyages : CM_VoyageArray;
	voyage : CM_Voyage;
	filteredVoyages : CM_VoyageArray;
	message : String;
	iterator : Iterator;
	count : Integer;
	size : String;
	invalid : Boolean;
	
begin
	app.initialize();
	app.myPassport.setMyTerminal(app.myRoot.allTerminals["T02"]);
	app.myPassport.setMyUserFromCode("JLGDI1");
	app.myPassport.clearErrorsWarnings();
	
	create voyages transient;
	CM_Voyage.allInstances(voyages, 0, true);
	create filteredVoyages transient;

	message := "Getting archived voyages that arrive between " &amp; START_DATE.asStringJMT &amp; " and " &amp; END_DATE.asStringJMT;
	write message;
	
	foreach voyage in voyages do
		if (voyage.archived) and
		   (voyage.arrivedDT.Date &gt;= START_DATE) and 
		   (voyage.arrivedDT.Date &lt;= END_DATE)
		then
			filteredVoyages.add(voyage);
		endif;
	endforeach;

	message := "There are " &amp; filteredVoyages.size.asStringJMT &amp; " item(s) to be deleted";
	write message;
	
	iterator := filteredVoyages.createIterator;

	on Exception do self.di_EraseExceptionHandler(exception);
	on Exception do app.handleDeletedObject(exception, voyage, invalid); 
	
	count := 0;
	size := filteredVoyages.size.asStringJMT;
	while iterator.next(voyage) do
		//message := "Erased Voyages: " &amp; count.asStringJMT &amp; " of "  &amp; size &amp; CrLf;
		//write message;
		
		write "Voyage Code : " &amp; voyage.code &amp; " | Arrived on : " &amp; voyage.arrivedDT.date.asStringJMT;
		
		/*		
		invalid := false;
		if not invalid then
			if not process.isInTransactionState then
				beginTransaction;
			endif;
			
			voyage.erase(NORMAL_ERASE);
			count := count + 1;
			if process.isInTransactionState then
				commitTransaction;
			endif;
		endif;
		*/
		count := count + 1;
	endwhile;

	//message := "Total deleted archived voyage(s) : " &amp; count.asStringJMT &amp; CrLf;
	//write message;

	message := "Task completed " &amp; CrLf;
	write message;

epilog
	delete iterator;
	delete filteredVoyages;
	delete voyages;
	on Exception do null;

end;</source>
    </JadeMethod>
    <JadeMethod name="di_EraseExceptionHandler" id="7424fcdf-c45c-44e2-8e46-8db2b2473ab0">
        <source>di_EraseExceptionHandler(_exception : Exception) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Mar 2019	jlgdi1	TFS# 43985 MSL - Delete Archived Voyages
*/

vars
    msg : String;
	stackDump: CnStackDump;
	
begin
	msg := "Error: " &amp; app.getErrorString(_exception.errorCode) &amp; ". Continuing with next object";

	if msg &lt;&gt; "" then
		app.writeLog(msg,0); 
	endif;
	
	create stackDump transient;
	stackDump.dumpStack(_exception);
	app.myPassport.clearErrorsWarnings();
	return Ex_Resume_Next;
end;</source>
        <Parameter name="_exception" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="di_RoadJob_AllRequest" id="39e593dd-df14-4389-81e4-1db55db361ef">
        <source>di_RoadJob_AllRequest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2019	jlgdi1	Initial creation

*/

vars
	terminal : CM_Terminal;
	roadJobSheet : CM_RoadJobSheet;
	roadJob : CM_Job;
	deliveryRequest : CM_Request;
	
	_operatorCode : String;
	_cargoType : Integer;
	_cargoSubType : String;
	_consignee : String;
	_commodity : String;
	_voyageCode : String;
	
	cmCargoType : CM_CargoType;
	cargoType : Integer;
	cmProduct : CM_Product;
	cargoSubType : String;
	consignee : String;
	commodity : String;	
	operatorCode : String;
	
	leavingOnSite : Integer;
	voyage : CM_Voyage;
	voyageCode : String;
	
	trackedItems : CM_TISet;
	dynaDict : DynaDictionary;
	cmifCargo : CMIF_CargoAvailability;
	
	workListEntry : CM_WorkListEntry;
	
	// DEBUG
	totalLeavingOnSite : Integer;
begin
	_operatorCode := "PERT" ;
	_cargoType := 10006;
	_cargoSubType := "Aluminium Ingots - Big Packs";
	_consignee := "ABDCF";
	_commodity := "";
	_voyageCode := "0IT1LS1MA";
	
	create trackedItems transient;
	create dynaDict transient;
	
	dynaDict.setMembership(CMIF_CargoAvailability);
	dynaDict.addMemberKey("voyageCode", false, false);
	dynaDict.addMemberKey("operatorCode", false, false);
	dynaDict.addMemberKey("cargoType", false, false);
	dynaDict.addMemberKey("cargoSubType", false, false);
	dynaDict.addMemberKey("commodity", false, false);	
	dynaDict.addMemberKey("consignee", false, false);
	dynaDict.endKeys(false);
		
	terminal := app.myRoot.allTerminals["T02"]; 
	roadJobSheet := terminal.myRoadJobSheet;
	foreach roadJob in roadJobSheet.allJobsByOrder do
		foreach deliveryRequest in roadJob.allRequests do
			voyage := deliveryRequest.getVoyage();
			if voyage &lt;&gt; null then
				voyageCode := voyage.code;
			endif;
		
			cmCargoType := deliveryRequest.getCargoType();
			if cmCargoType &lt;&gt; null then
				cargoType := cmCargoType.id;
			endif;
			
			cmProduct := deliveryRequest.getCargoSubType();
			if cmProduct &lt;&gt; null then
				cargoSubType := cmProduct.description;
			endif;
			
			operatorCode := deliveryRequest.getOperatorCode();
			
			/*
			consignee := deliveryRequest.getConsignorCode();
			commodity := deliveryRequest.getCommodity();
			*/
			
			if (voyageCode = _voyageCode) and 
			   (operatorCode = _operatorCode) and 
			   (cargoType = _cargoType) and 
			   (cargoSubType = _cargoSubType)
			then
				foreach workListEntry in deliveryRequest.allWorkListEntries do 
					commodity := null;
					consignee := null;
					leavingOnSite := workListEntry.getQuantity();
					
					if workListEntry.myTrackedItem &lt;&gt; null then 
						// Loaded onto truck
						commodity := workListEntry.myTrackedItem.commodity;
						consignee := workListEntry.myTrackedItem.consignee;
					endif;
					
					cmifCargo := dynaDict.getAtKey(voyageCode,
												   operatorCode,
												   cargoType,
												   cargoSubType,
												   commodity,
												   consignee).CMIF_CargoAvailability;
								
					if cmifCargo = null then 
						create cmifCargo transient;
						cmifCargo.voyageCode := voyageCode;
						cmifCargo.operatorCode := operatorCode;
						cmifCargo.cargoType := cargoType;
						cmifCargo.cargoSubType := cargoSubType;
						cmifCargo.commodity := commodity;
						cmifCargo.consignee := consignee;
						cmifCargo.totalQuantityLeaving := leavingOnSite;
						
						dynaDict.add(cmifCargo);			
					else
						cmifCargo.totalQuantityLeaving := cmifCargo.totalQuantityLeaving + 
							leavingOnSite;
					endif;
				endforeach;
				
				//leavingOnSite := leavingOnSite + deliveryRequest.getTotalRequested();
			endif;
		endforeach;
	endforeach;
	
	write leavingOnSite;
	
epilog
	delete trackedItems;
	delete dynaDict;
end;</source>
    </JadeMethod>
    <JadeMethod name="di_RoadJob_WorkListEntries" id="51b46aa7-2c72-47e9-b240-2b506b5a51ed">
        <source>di_RoadJob_WorkListEntries();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 March 2019	jlgdi1	Initial creation

*/

vars
	terminal : CM_Terminal;
	roadJobSheet : CM_RoadJobSheet;
	roadJob : CM_Job;
	deliveryRequest : CM_Request;
	
	_operatorCode : String;
	_cargoType : Integer;
	_cargoSubType : String;
	_consignee : String;
	_commodity : String;
	_voyageCode : String;
	
	cmCargoType : CM_CargoType;
	cargoType : Integer;
	cmProduct : CM_Product;
	cargoSubType : String;
	consignee : String;
	commodity : String;	
	operatorCode : String;
	
	leavingOnSite : Integer;
	voyage : CM_Voyage;
	voyageCode : String;
	
	trackedItems : CM_TISet;
	dynaDict : DynaDictionary;
	cmifCargo : CMIF_CargoAvailability;
	
	workListEntry : CM_WorkListEntry;
	
	// DEBUG
	totalLeavingOnSite : Integer;
	cmVoyage : CM_Voyage;
	
begin
	_operatorCode := "PERT" ;
	_cargoType := 10006;
	_cargoSubType := "ALIG_BIGPACKS";
	_consignee := "ABDCF";
	_commodity := "";
	_voyageCode := "0IT1LS1MA";
	
	_operatorCode := "SK" ;
	_cargoType := 25640;
	_cargoSubType := "Pineapple";
	_consignee := "ABDCF";
	_commodity := "";
	_voyageCode := "";
	
	create trackedItems transient;
	create dynaDict transient;
	
	dynaDict.setMembership(CMIF_CargoAvailability);
	dynaDict.addMemberKey("voyageCode", false, false);
	dynaDict.addMemberKey("operatorCode", false, false);
	dynaDict.addMemberKey("cargoType", false, false);
	dynaDict.addMemberKey("cargoSubType", false, false);
	dynaDict.addMemberKey("commodity", false, false);	
	dynaDict.addMemberKey("consignee", false, false);
	dynaDict.endKeys(false);
		
	terminal := app.myRoot.allTerminals["T02"]; 
	roadJobSheet := terminal.myRoadJobSheet;
	foreach roadJob in roadJobSheet.allJobsByOrder do
		foreach workListEntry in roadJob.workListEntries do
			if workListEntry.quantity = 0 then
				continue;
			endif;
			
			operatorCode := "";
			cargoType := 0;
			cargoSubType := "";
			voyageCode := "";
			consignee := "";
			commodity := "";
			leavingOnSite := workListEntry.quantity;
		
			if workListEntry.myTrackedItem &lt;&gt; null then
				operatorCode := workListEntry.myTrackedItem.operatorCode;
				cargoType := workListEntry.myTrackedItem.cargoType;
				cargoSubType := workListEntry.myTrackedItem.getCargoSubTypeCode();
				voyageCode := workListEntry.myTrackedItem.voyageCode;
				consignee := workListEntry.myTrackedItem.consignee;
				commodity := workListEntry.myTrackedItem.commodity;
			else
				// get details in myRequest
				deliveryRequest := workListEntry.myRequest;
				
				operatorCode := deliveryRequest.getOperatorCode();
				cmCargoType := deliveryRequest.getCargoType();
				if cmCargoType &lt;&gt; null then 
					cargoType := cmCargoType.id;
				endif;
				cmProduct := deliveryRequest.getCargoSubType();
				if cmProduct &lt;&gt; null then
					cargoSubType := cmProduct.code;
				endif;
				
				cmVoyage := deliveryRequest.getVoyage();
				if cmVoyage &lt;&gt; null then
					voyageCode := cmVoyage.code;
				endif;
				
				consignee := deliveryRequest.consigneeCode;
				commodity := deliveryRequest.getCommodity();
			endif;
			
			if (voyageCode = _voyageCode) and 
			   (operatorCode = _operatorCode) and 
			   (cargoType = _cargoType) and 
			   (cargoSubType = _cargoSubType)
			then
				write "match";
				
				cmifCargo := dynaDict.getAtKey(voyageCode,
											   operatorCode,
											   cargoType,
											   cargoSubType,
											   commodity,
											   consignee).CMIF_CargoAvailability;
				
				if cmifCargo = null then 
					create cmifCargo transient;
					cmifCargo.voyageCode := voyageCode;
					cmifCargo.operatorCode := operatorCode;
					cmifCargo.cargoType := cargoType;
					cmifCargo.cargoSubType := cargoSubType;
					cmifCargo.commodity := commodity;
					cmifCargo.consignee := consignee;
					cmifCargo.totalQuantityLeaving := leavingOnSite;
					
					dynaDict.add(cmifCargo);			
				else
					cmifCargo.totalQuantityLeaving := cmifCargo.totalQuantityLeaving + 
						leavingOnSite;
				endif;
			endif;
		endforeach;
	endforeach;
	
epilog
	delete trackedItems;
	delete dynaDict;
end;</source>
    </JadeMethod>
    <JadeMethod name="eprCCMS2265" id="3285b76c-4323-4b68-82b8-d612876cfae9">
        <source>eprCCMS2265();
/*

Date		Who		Reason
30 July 2013	cnwer1	Initial creation PAR

*/

vars
	aClass : Class;
	jrw : Schema;
	voyageDeckJob : CM_VoyageDeckJob;
	roroPrintForm : Form;
	frame : Frame;
	deckImage : Binary;
	 file  : File;
begin
	jrw := rootSchema.getSchema("ShipSchema");
	aClass := jrw.getClass("SHP_ROROPrint");
	app.initialize;
	create roroPrintForm as aClass transient;

	voyageDeckJob:="11489.6412".asOid.CM_VoyageDeckJob;
	deckImage:=roroPrintForm.sendMsgWithParams("getRORODeckImageForJob", voyageDeckJob).Binary;
	
	create file transient;
	file.fileName    := "C:\Temp\test.jpg";     // get selected name
	file.mode        := File.Mode_Append;
	file.allowCreate := true; 
	file.kind:=File.Kind_Binary;
	file.open;
	file.writeBinary( deckImage);
	file.close;
epilog
	delete roroPrintForm;
	delete file;
end;</source>
    </JadeMethod>
    <JadeMethod name="eprGetFormTranslateConstants" id="4461ce92-bfb4-4858-af55-4576fb7fc179">
        <source>eprGetFormTranslateConstants();
/*

Date		Who		Reason
23 September 2015	cnwer1	Initial creation PAR
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
constants
	Hdr	: String = 	'jadeVersionNumber "7.0.11";' &amp; CrLf &amp;
					'schemaDefinition' &amp; CrLf &amp;
					'PortSchema subschemaOf BaseSchema partialDefinition, patchVersion=802, patchVersioningEnabled = true;' &amp; CrLf &amp;
					'constantDefinitions';
vars
	fle		: File;
	formName : String;
	class : Class;
	portSchema,
	schema : Schema;
	translateMethod : Method;
	constName,
	methodLine,
	translateSource : String;
	commentPos,
	startIdx,
	endIdx,
	foundIdx: Integer;
	translateConstant : Constant;
	allConstants : ConstantNDict;
	methodLines : HugeStringArray;
	constantCategory : ConstantCategory;
	jadeScriptName : String;
begin
	

	
	/*jadeScriptName:= "rel" &amp; CM_Root.firstInstance.getVersionString &amp; process.userCode;
	write jadeScriptName;
	return;*/
	
	portSchema:=rootSchema.getSchema("PortSchema");
	formName:="MOB_HHTruckReleaseCargoSelect";
	if formName[1:4] = "CMUI" then
		schema:=rootSchema.getSchema("UiCommonSchema");
	elseif formName[1:3] = "MOB" then
		schema:=rootSchema.getSchema("MobileUISchema");
	elseif formName[1:3] = "GTE" then
		schema:=rootSchema.getSchema("GateSchema");
	elseif formName[1:3] = "INV" then
		schema:=rootSchema.getSchema("InvoiceSchema");
	elseif formName[1:3] = "SHP" then
		schema:=rootSchema.getSchema("ShipSchema");
	elseif formName[1:3] = "YRD" then
		schema:=rootSchema.getSchema("YardSchema");
	elseif formName[1:3] = "SOP" then
		schema:=rootSchema.getSchema("SysOpsSchema");
	elseif formName[1:3] = "HMS" then
		schema:=rootSchema.getSchema("HmsSchema");
	else
		write "not a GUI schema";
		return;
	endif;
	if schema = null then
		write "schema not found";
		return;
	endif;
	
	class:= schema.getClass(formName);
	
	if not class.inheritsFrom(Form) then
		write "class not a form !!";
		return;
	endif;
	
	translateMethod:=class.getMethod("translateForm");
	translateSource:=translateMethod.getSource();
	//write translateSource;
	create allConstants transient;
	create methodLines transient;
	translateSource.getTokensForDelimiterHugeNoNul(CrLf,methodLines);
	foreach methodLine in methodLines do
		startIdx:=1;
		foundIdx:=0;
		commentPos:=methodLine.pos("//",startIdx);
		foundIdx :=methodLine.pos("translateCaption(",startIdx);
		if foundIdx = 0 then
			continue;
		endif;
		if commentPos  &gt; 0 and commentPos &lt; foundIdx then
			continue;
		endif;
		endIdx:=methodLine.pos(", locale);",foundIdx);
		if endIdx = 0 then
			continue;
		endif;
		foundIdx:=foundIdx+"translateCaption(".length;
		constName:= methodLine[foundIdx:endIdx-foundIdx];
		translateConstant:=portSchema.getConstant(constName);
		if translateConstant = null then
			continue;
		endif;
		allConstants.add(translateConstant);
	
	endforeach;
	
	if allConstants.isEmpty then
		return;
	endif;
	
	constantCategory:=portSchema.getConstantCategory(XLAT_FormCaptions);
	
	create fle transient;
	fle.mode := File.Mode_Output; // 29/2/16  cnwns1 PAR 36286 unicode version
	fle.fileName := 'c:\temp\translateForm_' &amp; formName  &amp; app.actualTimeServer.Date.formatAsYYYYMMDD() &amp; app.actualTimeServer.Time.format('HHmmss') &amp; '.scm';// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	fle.writeLine(Hdr);
	constantCategory:=portSchema.getConstantCategory(XLAT_FormCaptions);
	foreach translateConstant in allConstants do	
		fle.writeLine(Tab &amp; 'categoryDefinition XLAT_FormCaptions');
		fle.writeLine(Tab &amp; "documentationText");
		fle.writeLine("'" &amp; constantCategory.text &amp; "'");
		fle.writeLine(Tab &amp; "setModifiedTimeStamp" &amp; ' "' &amp; constantCategory.getModifiedBy&amp; '"'  &amp; ' "' &amp; app.getSystemVersion()&amp; '" '  &amp; constantCategory.cnEcGetModifyTimeStamp.String  &amp; ";");
		
		fle.writeLine(Tab &amp; translateConstant.name &amp; ':' &amp; Tab &amp; translateConstant.type.name &amp;  ' = ' &amp; translateConstant.getSource &amp; "';" );
		fle.writeLine(Tab &amp; "documentationText");
		fle.writeLine("'" &amp; translateConstant.text &amp; "'");
	endforeach;
	
	
	fle.close;
epilog
	delete methodLines;
	delete allConstants;
end;</source>
    </JadeMethod>
