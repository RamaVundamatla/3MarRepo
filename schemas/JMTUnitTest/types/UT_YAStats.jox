    <JadeMethod name="tSetupTestArea" id="6bcb940f-f9d3-4e58-92f3-0f9766618911">
        <source>tSetupTestArea();
// cnwer1
// cnwjk3
/*

Purpose:   Set up a test area with different sized containers to aid manual testing through JMT			

Parameters:			

Return Value:		


Date		Who		Reason
13 March 2009	cnwjk3	Initial creation

*/

vars
	statsAgent: CMIF_StatisticsAgent;
	stradStack: CM_StraddleStack;
	row,
	column,
	numColumns,
	numRows,
	height,
	total : Integer;
	locations : CM_LCArray;
	container1 : CM_TrackedItem;
	container2 : CM_TrackedItem;
	container3 : CM_TrackedItem;
	container4 : CM_TrackedItem;
	container5 : CM_TrackedItem;
	container6 : CM_TrackedItem;
	container7 : CM_TrackedItem;
	container8 : CM_TrackedItem;
	container9 : CM_TrackedItem;
	container10 : CM_TrackedItem;
	container11 : CM_TrackedItem;
	container12 : CM_TrackedItem;
	container13 : CM_TrackedItem;
	container14 : CM_TrackedItem;
	container15 : CM_TrackedItem;
begin
	// 8 row * 8 columns * 3 high
	numColumns := 8;
	numRows := 8;
	height := 3;
	self.deleteContainer("TESTJK00001");
	self.deleteContainer("TESTJK00002");
	self.deleteContainer("TESTJK00003");
	self.deleteContainer("TESTJK00004");
	self.deleteContainer("TESTJK00005");
	self.deleteContainer("TESTJK00006");
	self.deleteContainer("TESTJK00007");
	self.deleteContainer("TESTJK00008");
	self.deleteContainer("TESTJK00009");
	self.deleteContainer("TESTJK00010");
	self.deleteContainer("TESTJK00011");
	self.deleteContainer("TESTJK00012");
	self.deleteContainer("TESTJK00013");
	self.deleteContainer("TESTJK00014");
	self.deleteContainer("TESTJK00015");

	deleteTerminalArea("JKSTRAD1");
	stradStack := addStraddleStack("JKSTRAD1", numRows, numColumns, height);

	container1 := self.addContainerOpts("TESTJK00001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container2 := self.addContainerOpts("TESTJK00002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container3 := self.addContainerOpts("TESTJK00003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	container4 := self.addContainerOpts("TESTJK00004", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container5 := self.addContainerOpts("TESTJK00005", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container6 := self.addContainerOpts("TESTJK00006", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	
	container7 := self.addContainerOpts("TESTJK00007", "4200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container8 := self.addContainerOpts("TESTJK00008", "4200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container9 := self.addContainerOpts("TESTJK00009", "4200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	
	container10 := self.addContainerOpts("TESTJK00010", "9400", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container11 := self.addContainerOpts("TESTJK00011", "9400", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container12 := self.addContainerOpts("TESTJK00012", "9400", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	

	container13 := self.addContainerOpts("TESTJK00013", "53FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container14 := self.addContainerOpts("TESTJK00014", "53FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container15 := self.addContainerOpts("TESTJK00015", "53FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	

	
	move(container1,  stradStack.allGridControllersByRowColumn[1, 1]);
	move(container2,  stradStack.allGridControllersByRowColumn[1, 1]);
	move(container3,  stradStack.allGridControllersByRowColumn[1, 1]);

	move(container4,  stradStack.allGridControllersByRowColumn[2, 1]);
	move(container5,  stradStack.allGridControllersByRowColumn[2, 1]);
	move(container6,  stradStack.allGridControllersByRowColumn[2, 1]);

	move(container7,  stradStack.allGridControllersByRowColumn[3, 1]);
	move(container8,  stradStack.allGridControllersByRowColumn[3, 1]);
	move(container9,  stradStack.allGridControllersByRowColumn[3, 1]);

	move(container10,  stradStack.allGridControllersByRowColumn[4, 1]);
	move(container11,  stradStack.allGridControllersByRowColumn[4, 1]);
	move(container12,  stradStack.allGridControllersByRowColumn[4, 1]);

	move(container13,  stradStack.allGridControllersByRowColumn[5, 1]);
	move(container14,  stradStack.allGridControllersByRowColumn[5, 1]);
	move(container15,  stradStack.allGridControllersByRowColumn[5, 1]);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tStatisticAgent" id="6153b339-34ba-42bd-8efb-6893cf9f9b07">
        <source>tStatisticAgent();
// cnwndl1
//01 September 2008	cnwdw1	
//
vars
	statsAgent: CMIF_StatisticsAgent;
	stradStack: CM_StraddleStack;
	ti: CM_TrackedItem;
	locations: CM_LCSet;
begin
	/*
	deleteContainer("TEST0000001");
	deleteContainer("TEST0000002");
	deleteTerminalArea("UTSTRD");
	stradStack := addStraddleStack("UTSTRD", 10, 10, 3);
	
	create locations transient;
	locations.add(stradStack.allGridControllersByRowColumn[1, 1]);
	locations.add(stradStack.allGridControllersByRowColumn[1, 2]);
	locations.add(stradStack.allGridControllersByRowColumn[1, 3]);
	locations.add(stradStack.allGridControllersByRowColumn[1, 4]);
	locations.add(stradStack.allGridControllersByRowColumn[1, 5]);
	locations.add(stradStack.allGridControllersByRowColumn[1, 6]);
	
	create statsAgent transient;
	total := statsAgent.totalSpaceIn(30, locations);
	assertEqual(total, 12)/;
*/
epilog
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tStatsAgentCalcFree20s" id="c124308e-a1e2-4158-a838-af62bca7d3fd">
        <source>tStatsAgentCalcFree20s();
// cnwer1
// cnwjk3
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 March 2009	cnwjk3	Initial creation

*/

vars
	statsAgent: CMIF_StatisticsAgent;
	stradStack: CM_StraddleStack;
	row,
	column,
	numColumns,
	numRows,
	height,
	total : Integer;
	locations : CM_LCArray;
	container1 : CM_TrackedItem;
	container2 : CM_TrackedItem;
	container3 : CM_TrackedItem;
	container4 : CM_TrackedItem;
begin
	create locations transient;
	create statsAgent transient;
	
	// 1 row * 6 columns * 2 high
	numColumns := 6;
	numRows := 1;
	height := 2;
	self.deleteContainer("TESTJK00001");
	self.deleteContainer("TESTJK00002");
	self.deleteContainer("TESTJK00003");
	self.deleteContainer("TESTJK00004");

	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	
	// Test 1  - No TIs
	total := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_20, locations, 1, height);
	self.assertEqual(total, 12);
		

	// Test 2			
	// |40|30|  |  |  |  |  |
	container1 := self.addContainerOpts("TESTJK00001", "4200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container2 := self.addContainerOpts("TESTJK00002", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(container1,  stradStack.allGridControllersByRowColumn[1, 1]);
	move(container2,  stradStack.allGridControllersByRowColumn[1, 3]);

	total := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_20, locations, 1, height);
	self.assertEqual(total, 4);

	// restrict max height
	total := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_20, locations, 1, height-1);
	self.assertEqual(total, 2);

	// restrict min height
	total := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_20, locations, 2, height);
	self.assertEqual(total, 2);

	// restrict min and max height
	total := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_20, locations, 2, height-1);
	self.assertEqual(total, 0);

	// Test 3			
	// |53|30|  |
	self.deleteContainer("TESTJK00001");
	self.deleteContainer("TESTJK00002");
	container1 := self.addContainerOpts("TESTJK00001", "53FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container2 := self.addContainerOpts("TESTJK00002", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(container1,  stradStack.allGridControllersByRowColumn[1, 1]);
	move(container2,  stradStack.allGridControllersByRowColumn[1, 3]);

	total := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_20, locations, 1, height);
	self.assertEqual(total, 2);

	// Test 4  - 2 rows
	//|53|30|  |
	//|  |  |  |  |  |  |
	locations.clear();
	numColumns := 6;
	numRows := 2;
	height := 2;
	self.deleteContainer("TESTJK00001");
	self.deleteContainer("TESTJK00002");
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;

	container1 := self.addContainerOpts("TESTJK00001", "53FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container2 := self.addContainerOpts("TESTJK00002", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(container1,  stradStack.allGridControllersByRowColumn[1, 1]);
	move(container2,  stradStack.allGridControllersByRowColumn[1, 3]);
	
	total := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_20, locations, 1, height);
	self.assertEqual(total,14);
	
	// Test 5  - 2 rows
	//|53|30|20|
	//|20|  |  |  |  |  |
	locations.clear();
	numColumns := 6;
	numRows := 2;
	height := 2;
	self.deleteContainer("TESTJK00001");
	self.deleteContainer("TESTJK00002");
	self.deleteContainer("TESTJK00003");
	self.deleteContainer("TESTJK00004");
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;

	container1 := self.addContainerOpts("TESTJK00001", "53FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container2 := self.addContainerOpts("TESTJK00002", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container3 := self.addContainerOpts("TESTJK00003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container4 := self.addContainerOpts("TESTJK00004", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(container1,  stradStack.allGridControllersByRowColumn[1, 1]);
	move(container2,  stradStack.allGridControllersByRowColumn[1, 3]);
	move(container3,  stradStack.allGridControllersByRowColumn[1, 5]);
	move(container4,  stradStack.allGridControllersByRowColumn[2, 1]);
	
	total := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_20, locations, 1, height);
	self.assertEqual(total,12);

	
	// Test 6  - 2 rows - height restriction on column 6  (should stop a 20 being placed on top of the TI at [1,5] (which would spill over to column 6)
	// Also, [2,6] is marked unavailable
	//|53|30|20|
	//|20|  |  |  |  |  |
	locations.clear();
	numColumns := 6;
	numRows := 2;
	height := 2;
	self.deleteContainer("TESTJK00001");
	self.deleteContainer("TESTJK00002");
	self.deleteContainer("TESTJK00003");
	self.deleteContainer("TESTJK00004");
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	beginTransaction;
	stradStack.allGridControllersByRowColumn[1, 6].CM_StackController.availability := PAD_HEIGHT_2_UNAVAIL;
	stradStack.allGridControllersByRowColumn[2, 6].CM_StackController.availability := PAD_UNAVAILABLE;
	commitTransaction;
	
	container1 := self.addContainerOpts("TESTJK00001", "53FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container2 := self.addContainerOpts("TESTJK00002", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container3 := self.addContainerOpts("TESTJK00003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container4 := self.addContainerOpts("TESTJK00004", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(container1,  stradStack.allGridControllersByRowColumn[1, 1]);
	move(container2,  stradStack.allGridControllersByRowColumn[1, 3]);
	move(container3,  stradStack.allGridControllersByRowColumn[1, 5]);
	move(container4,  stradStack.allGridControllersByRowColumn[2, 1]);
	
	total := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_20, locations, 1, height);
	self.assertEqual(total,9);
	
	
	// Test 7			
	// |40|30|  |  |  |  |  |
	locations.clear();
	numColumns := 6;
	numRows := 1;
	height := 5;
	self.deleteContainer("TESTJK00001");
	self.deleteContainer("TESTJK00002");
	self.deleteContainer("TESTJK00003");
	self.deleteContainer("TESTJK00004");
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;

	container1 := self.addContainerOpts("TESTJK00001", "4200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container2 := self.addContainerOpts("TESTJK00002", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(container1,  stradStack.allGridControllersByRowColumn[1, 1]);
	move(container2,  stradStack.allGridControllersByRowColumn[1, 3]);

	total := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_20, locations, 1, height);
	self.assertEqual(total, 10);
	
	// restrict max height
	total := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_20, locations, 1, height-1);
	self.assertEqual(total, 8);

	// restrict min height
	total := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_20, locations, 2, height);
	self.assertEqual(total, 8);

	// restrict min and max height
	total := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_20, locations, 2, height-1);
	self.assertEqual(total, 6);
	
epilog
	delete statsAgent;
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tStatsAgentCalcFree45s" id="54ba4b6f-9544-459a-9f68-ac170ed20fed">
        <source>tStatsAgentCalcFree45s();
// cnwer1
// cnwjk3
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 March 2009	cnwjk3	Initial creation

*/

vars
	statsAgent: CMIF_StatisticsAgent;
	stradStack: CM_StraddleStack;
	row,
	column,
	numColumns,
	numRows,
	height,
	total : Integer;
	locations : CM_LCArray;
	container1 : CM_TrackedItem;
	container2 : CM_TrackedItem;
	container3 : CM_TrackedItem;
	container4 : CM_TrackedItem;
begin
	create locations transient;
	create statsAgent transient;
	
	// 1 row * 8 columns * 2 high
	numColumns := 8;
	numRows := 1;
	height := 2;
	self.deleteContainer("TESTJK00001");
	self.deleteContainer("TESTJK00002");
	self.deleteContainer("TESTJK00003");
	self.deleteContainer("TESTJK00004");

	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	
	// Test 1  - No TIs
	total := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_45, locations, 1, height);
	self.assertEqual(total, 6);
		
			
	// Test 2			
	// |40|30|  |  |  |  |  |  |
	container1 := self.addContainerOpts("TESTJK00001", "4200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container2 := self.addContainerOpts("TESTJK00002", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(container1,  stradStack.allGridControllersByRowColumn[1, 1]);
	move(container2,  stradStack.allGridControllersByRowColumn[1, 3]);

	total := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_45, locations, 1, height);
	self.assertEqual(total, 4);
	
	
	// Test 3			
	// |53|30|  |  |  |
	self.deleteContainer("TESTJK00001");
	self.deleteContainer("TESTJK00002");
	container1 := self.addContainerOpts("TESTJK00001", "53FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container2 := self.addContainerOpts("TESTJK00002", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(container1,  stradStack.allGridControllersByRowColumn[1, 1]);
	move(container2,  stradStack.allGridControllersByRowColumn[1, 3]);

	total := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_45, locations, 1, height);
	self.assertEqual(total, 2);

	
	// Test 4  - 2 rows
	//|53|30|  |
	//|  |  |  |  |  |  |  |  |
	locations.clear();
	numColumns := 8;
	numRows := 2;
	height := 2;
	self.deleteContainer("TESTJK00001");
	self.deleteContainer("TESTJK00002");
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;

	container1 := self.addContainerOpts("TESTJK00001", "53FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container2 := self.addContainerOpts("TESTJK00002", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(container1,  stradStack.allGridControllersByRowColumn[1, 1]);
	move(container2,  stradStack.allGridControllersByRowColumn[1, 3]);
	
	total := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_45, locations, 1, height);
	self.assertEqual(total,8);

	
	// Test 5  - 2 rows
	//|53|30|45|  |...
	//|45|  |...
	locations.clear();
	numColumns := 8;
	numRows := 2;
	height := 2;
	self.deleteContainer("TESTJK00001");
	self.deleteContainer("TESTJK00002");
	self.deleteContainer("TESTJK00003");
	self.deleteContainer("TESTJK00004");
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;

	container1 := self.addContainerOpts("TESTJK00001", "53FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container2 := self.addContainerOpts("TESTJK00002", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container3 := self.addContainerOpts("TESTJK00003", "9400", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container4 := self.addContainerOpts("TESTJK00004", "9400", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(container1,  stradStack.allGridControllersByRowColumn[1, 1]);
	move(container2,  stradStack.allGridControllersByRowColumn[1, 3]);
	move(container3,  stradStack.allGridControllersByRowColumn[1, 5]);
	move(container4,  stradStack.allGridControllersByRowColumn[2, 1]);
	
	total := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_45, locations, 1, height);
	self.assertEqual(total,6);

	
	// Test 6  - 2 rows - height restriction on column 6  (should stop a 45 being placed on top of the TI at [1,5] (which would spill over to column 6)
	// Also, [2,1] is marked unavailable
	//|53|30|45|
	//|  |  |  |  |  |45|
	locations.clear();
	numColumns := 8;
	numRows := 2;
	height := 2;
	self.deleteContainer("TESTJK00001");
	self.deleteContainer("TESTJK00002");
	self.deleteContainer("TESTJK00003");
	self.deleteContainer("TESTJK00004");
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	beginTransaction;
	stradStack.allGridControllersByRowColumn[1, 6].CM_StackController.availability := PAD_HEIGHT_2_UNAVAIL;
	stradStack.allGridControllersByRowColumn[2, 1].CM_StackController.availability := PAD_UNAVAILABLE;
	commitTransaction;
	
	container1 := self.addContainerOpts("TESTJK00001", "53FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container2 := self.addContainerOpts("TESTJK00002", "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container3 := self.addContainerOpts("TESTJK00003", "9400", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container4 := self.addContainerOpts("TESTJK00004", "9400", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(container1,  stradStack.allGridControllersByRowColumn[1, 1]);
	move(container2,  stradStack.allGridControllersByRowColumn[1, 3]);
	move(container3,  stradStack.allGridControllersByRowColumn[1, 5]);
	move(container4,  stradStack.allGridControllersByRowColumn[2, 5]);
	
	total := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_45, locations, 1, height);
	self.assertEqual(total,3);
	
	
epilog
	delete statsAgent;
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tStatsAgentCalcTotals" id="7472935a-3f5e-46b7-bc27-d0ad1f2bab20">
        <source>tStatsAgentCalcTotals();
// CNWNDL1
// cnwjo3
/*

Purpose: Verify that new Total columns are correctly calculated in straddle stack and block stacks.  par 21189.  			

Date				Who			Reason
25 January 2010		cnwjo3		Initial creation

*/
constants
	JCONTAINER1 : String = "TESTCTJO001";
	JCONTAINER2 : String = "TESTCTJO002";
	JCONTAINER3 : String = "TESTCTJO003";
	JCONTAINER4 : String = "TESTCTJO004";
	JCARGO1		: String = "UTCARCTJO01";
	JSSNAME		: String = "UTJOSTRD";
	JBSNAME		: String = "UTJOBS0001";
vars
	statsAgent: CMIF_StatisticsAgent;
	stradStack: CM_StraddleStack;
	bs : CM_BlockStack;
	row,
	column,
	numColumns,
	numRows,
	height,
	total : Integer;
	locations : CM_LCArray;
	container1 : CM_TrackedItem;
	container2 : CM_TrackedItem;
	container3 : CM_TrackedItem;
	container4 : CM_TrackedItem;
	cargo : CM_TrackedItem;
	product : CM_Product;
	ti : CM_TrackedItem;
	lc : CM_LocationsController;
	gridRow : CM_GridRow;
	ls : CM_LocationStatistics;
	lsbs : CM_LocationStatistics;
begin
	create locations transient;
	create statsAgent transient;
	
	// 1 row * 6 columns * 2 high
	numColumns := 6;
	numRows := 1;
	height := 2;
	
	//delete any possible left over from previous tests where UE occured
	self.deleteContainer(JCONTAINER1);
	self.deleteContainer(JCONTAINER2);
	self.deleteContainer(JCONTAINER3);
	self.deleteContainer(JCONTAINER4);
	foreach ti in CM_BreakBulkGeneric.instances where ti.id = JCARGO1 do
		self.deleteTrackedItem(ti, false); // AKB added false
		break;
	endforeach;
	self.deleteTerminalArea(JSSNAME);
	self.deleteTerminalArea(JBSNAME);
	
	//create the straddle stack and block stack terminal areas used in this test
	stradStack := addStraddleStack(JSSNAME, numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	bs := self.addBlockStack(JBSNAME,99,null);
	
	// Test 1  - No TIs
	total := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_20, locations, 1, height);
	self.assertEqual(total, 12);

	// Test 2			
	// |40|30|  |  |  |  |  |
	container1 := self.addContainerOpts(JCONTAINER1, "4200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	container2 := self.addContainerOpts(JCONTAINER2, "30FT", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	foreach product in CM_Product.instances discreteLock do 
		if product.myCargoType &lt;&gt; null then
			break;
		endif;
	endforeach;
	
	cargo := self.addCargoAtLocation(JCARGO1, product, product.myOperator, stradStack.allGridControllersByRowColumn[1, 5]);
	
	move(container1,  stradStack.allGridControllersByRowColumn[1, 1]);
	move(container2,  stradStack.allGridControllersByRowColumn[1, 3]);

	total := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_20, locations, 1, height);
	self.assertEqual(total, 2);

	// restrict max height
	total := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_20, locations, 1, height-1);
	self.assertEqual(total, 1);

	// restrict min height
	total := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_20, locations, 2, height);
	self.assertEqual(total, 1);

	// restrict min and max height
	total := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_20, locations, 2, height-1);
	self.assertEqual(total, 0);

	//create statistics for straddle stack
	beginTransaction;
		foreach gridRow in stradStack.allGridRows do
			gridRow.buildLocationStatistics();
		endforeach;
	commitTransaction;
	beginTransaction;
		stradStack.buildLocationStatistics();
	commitTransaction;
	ls := stradStack.myLocationStatistics;

	
	//check straddle stack statistics
	self.assertEqual(ls.c20Free,2);
	self.assertEqual(ls.c30Free,1);
	self.assertEqual(ls.c20Total,12);
	self.assertEqual(ls.c30Total,8);
	self.assertEqual(ls.c40Total,6);
	self.assertEqual(ls.c30Used,1);
	self.assertEqual(ls.c20Free,2);
	self.assertEqual(ls.free,2);
	self.assertEqual(ls.projected,0);
	self.assertEqual(ls.queuedIn,0);
	self.assertEqual(ls.queuedOut,0);
	self.assertEqual(ls.total,12);
	self.assertEqual(ls.used,4);

	//move and queue things around
	self.move(container1, bs.myLocationsController);
	self.move(container2, bs.myLocationsController);	
	self.moveQueued(container1,stradStack.allGridControllersByRowColumn[1, 1]);
	self.movePlanned(container2,stradStack.allGridControllersByRowColumn[1, 3]);
	
	
	//update straddle stack statistics and produce block stack statistics
	beginTransaction;
		foreach gridRow in stradStack.allGridRows do
			gridRow.buildLocationStatistics();
		endforeach;
	commitTransaction;
	beginTransaction;
		stradStack.buildLocationStatistics();
	commitTransaction;
	ls := stradStack.myLocationStatistics;

	beginTransaction;
		bs.buildLocationStatistics();
	commitTransaction;
	lsbs := bs.myLocationStatistics;

	//verify ss stats
	self.assertEqual(ls.c20Free,10);
	self.assertEqual(ls.c30Free,4);
	self.assertEqual(ls.c45Free,2);
	self.assertEqual(ls.c20Total,12);
	self.assertEqual(ls.c30Total,8);
	self.assertEqual(ls.c40Total,6);
	self.assertEqual(ls.c30Used,0);
	self.assertEqual(ls.c20Free,10);
	self.assertEqual(ls.free,10);
	self.assertEqual(ls.projected,0);
	self.assertEqual(ls.queuedIn,1);
	self.assertEqual(ls.plannedIn,1);
	self.assertEqual(ls.queuedOut,0);
	self.assertEqual(ls.total,12);
	self.assertEqual(ls.used,1);	
	
	//verify block stack stats
	self.assertEqual(lsbs.c30Used,1);
	self.assertEqual(lsbs.c40Used,1);
	self.assertEqual(lsbs.free,97);
	self.assertEqual(lsbs.total,99);
	self.assertEqual(lsbs.used,2);
	self.assertEqual(lsbs.queuedOut,1);
	self.assertEqual(lsbs.plannedOut,1);

	//clean up any terminal areas
//	self.deleteTerminalArea(JBSNAME);
//	self.deleteTerminalArea(JSSNAME);
epilog
	delete statsAgent;
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tStatsAgentCalcTotals20s" id="9ddbfd77-dc96-4bb1-896b-ffa6bd898491">
        <source>tStatsAgentCalcTotals20s();
// cnwer1
// cnwjk3
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 March 2009	cnwjk3	Initial creation

*/

vars
	statsAgent: CMIF_StatisticsAgent;
	stradStack: CM_StraddleStack;
	row,
	column,
	numColumns,
	numRows,
	height,
	total : Integer;
	locations : CM_LCArray;
	gapController : CM_GapController;
	gridRow : CM_GridRow;
	gridColumn : CM_GridColumn;
	
begin
	create statsAgent transient;
	create locations transient;
	self.deleteContainer("TESTJK00001");
	self.deleteContainer("TESTJK00002");
	self.deleteContainer("TESTJK00003");
	self.deleteContainer("TESTJK00004");

	///// 20 footers
	
	// No locations
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_20, locations, 1, height);
	assertEqual(total, 0);
	
	
	// 1 row * 6 columns * 2 high
	numColumns := 6;
	numRows := 1;
	height := 2;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_20, locations, 1, height);
	assertEqual(total, 12);
	locations.clear();
	
		
	// 2 rows * 6 columns * 2 high
	numColumns := 6;
	numRows := 2;
	height := 2;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_20, locations, 1, height);
	assertEqual(total, 24);
	locations.clear();

	
	// 1 rows * 1 columns * 6 high
	numColumns := 1;
	numRows := 1;
	height := 6;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_20, locations, 1, height);
	assertEqual(total, 6);
	locations.clear();

	// 2 rows * 6 columns * 2 high, with one LC restricted in height
	numColumns := 6;
	numRows := 2;
	height := 2;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	beginTransaction;
	stradStack.allGridControllersByRowColumn[1, 1].CM_StackController.availability := PAD_HEIGHT_2_UNAVAIL;
	commitTransaction;
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_20, locations, 1, height);
	assertEqual(total, 23);
	locations.clear();

	
	// 2 rows * 6 columns * 3 high, with two LC restricted otdifferent heights 
	numColumns := 6;
	numRows := 2;
	height := 3;
	deleteTerminalArea("UTJKSTRD");
	stradStack := addStraddleStack("UTJKSTRD", numRows, numColumns, height);
	
	beginTransaction;
	// This LC can only go 1 high
	stradStack.allGridControllersByRowColumn[1, 1].CM_StackController.availability := PAD_HEIGHT_2_UNAVAIL;
	// This LC can only go 2 high
	stradStack.allGridControllersByRowColumn[2, 6].CM_StackController.availability := PAD_HEIGHT_3_UNAVAIL;
	commitTransaction;	
	foreach row in 1 to numRows do
		foreach column in 1 to numColumns do
			locations.add(stradStack.allGridControllersByRowColumn[row, column]);
		endforeach;
	endforeach;
	total := statsAgent.calcTotals(CMIF_StatisticsAgent.ContainerSize_20, locations, 1, height);
	assertEqual(total, 33);
	locations.clear();
	
		
epilog
	delete statsAgent;
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tStatsAgentCalcTotals30s" id="2b8368d8-4cc8-48ec-9cc1-e131d1a8cc5f">
