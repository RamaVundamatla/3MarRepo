    <JadeWebServicesMethod name="getCountries" id="5f425a57-6059-40a3-92a7-884195284af3">
        <source>getCountries() : WS_CountriesResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Nov 2022	navlw1	Initial creation TFS 55417 EUP - Country of Origin

*/

vars
	response 	: WS_CountriesResponse;
	completedOK : Boolean;
	country		: CM_Country;
	wsCountry	: WS_Country;
begin
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	foreach country in app.myRoot.allCountries discreteLock do
		if not country.isNotAvailableForEntry then
			create wsCountry transient;
			wsCountry.setProxyFromObject(country);
			response.allCountries.add(wsCountry);
		endif;
	endforeach;
	
	completedOK := true;
	return response;
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
