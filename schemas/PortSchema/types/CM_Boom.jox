    <JadeMethod name="boomUp" id="15d40b53-67c6-4713-93aa-a0faea614179">
        <executionLocation>server</executionLocation>
        <source>boomUp( userMessage : String output;
		debugMess : String output
		) serverExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2019	jlgndl1	Initial creation	TFS 43403

*/

constants

vars

	conn : JadeHTTPConnection;
	authString : String;
	authToken : String;
	headers : String;
	byte : Binary;
	returnVal : String;
	sendSuccess : Boolean;
	sendSuccess2 : Boolean;
	channelSetString : String;
	channelUnSetString : String;
	setPosition : Integer;
	
begin

	if self.userCode.trimBlanks = null then
		debugMess := debugMess &amp; "Boom User Code required for 'Open Boom'." &amp; CrLf;
	endif;
//	if self.password.trimBlanks = null then
	if self.getPwForUse(null).trimBlanks = null then	//24 Aug 2021	NDL	TFS 51632
		debugMess := debugMess &amp; "Boom Password required for 'Open Boom'." &amp; CrLf;
	endif;
	if self.ipAddress.trimBlanks = null then
		debugMess := debugMess &amp; "IP Address required for 'Open Boom'." &amp; CrLf;
	endif;
	if self.channel &lt; 1 or channel &gt; 6 then  // stored as one of 1 thru 6, but entered as one of 'DO0' thru thru "DO5"
		debugMess := debugMess &amp; "Channel Identifier must be one of 'DO0', 'DO1', 'DO2', 'DO3', 'DO4' or 'DO5' for 'Open Boom'." &amp; CrLf;
	endif;
	if debugMess &lt;&gt; null then
		userMessage := app.getErrorString1(Unabl_open_boom_not_fully_conf, self.code);
		return;
	endif;

//	authString := self.userCode &amp; ":" &amp; self.password;
	authString := self.userCode &amp; ":" &amp; self.getPwForUse(null);		//24 Aug 2021	NDL	TFS 51632
	byte := authString.Binary;
	authToken := byte.base64Encode();
	headers := "Authorization: Basic " &amp; authToken;
	
	channelSetString := "DO0=0&amp;DO1=0&amp;DO2=0&amp;DO3=0&amp;DO4=0&amp;DO5=0";
	channelUnSetString := channelSetString;
	setPosition := ( self.channel * 6 ) - 1;  // position in the string to substitute with a '1' meaning set
	channelSetString[setPosition] := "1";	//set it.
	
	create conn transient;
	conn.url := "http://" &amp; self.ipAddress &amp; "/digitaloutput/all/value";
	debugMess := debugMess &amp; "about to send to set channel" &amp; CrLf;
	sendSuccess := conn.sendRequest(JadeHTTPConnection.Verb_POST, headers, channelSetString);  // set the selected channel
	
	if sendSuccess then
		debugMess := debugMess &amp; "Successful send to set channel" &amp; CrLf;
		conn.readBody(100);
		returnVal := conn.responseBody.StringUtf8.String;
		debugMess := debugMess &amp; "sendfRequest returned: " &amp; returnVal &amp; CrLf;
		debugMess := debugMess &amp; "responseHeaders: " &amp; conn.responseHeaders &amp; CrLf;
		
		debugMess := debugMess &amp; "Waiting a second" &amp; CrLf;
		process.sleep(1000); //wait a second...
		debugMess := debugMess &amp; "about to send to reset the channels" &amp; CrLf;
		sendSuccess2 := conn.sendRequest(JadeHTTPConnection.Verb_POST, headers, channelUnSetString);	// reset all channels
		if sendSuccess2 then
			debugMess := debugMess &amp; "Successful send to reset the channels" &amp; CrLf;
		else
			userMessage := app.getErrorString1(Unable_reset_boom_not_respon, self.code );
			debugMess := debugMess &amp; "sendRequest to reset failed with " &amp; conn.state.String &amp; CrLf;
			if conn.state = conn.State_NeedConnection then
				debugMess := debugMess &amp; "'" &amp; conn.state.String &amp; " indicates the connection is not open" &amp; CrLf;
			elseif conn.state = conn.State_Failure then
				debugMess := debugMess &amp; "'" &amp; conn.state.String &amp; " indicates a failed HTTP connection" &amp; CrLf;
			elseif conn.state = conn.State_NeedRequest then
				debugMess := debugMess &amp; "'" &amp; conn.state.String &amp; " indicates waiting for a request" &amp; CrLf;
			elseif conn.state = conn.State_NoData then
				debugMess := debugMess &amp; "'" &amp; conn.state.String &amp; " indicates no data" &amp; CrLf;
			else
				debugMess := debugMess &amp; "'" &amp; conn.state.String &amp; " undocumented reason" &amp; CrLf;
			endif;
		endif;
	
	endif;
	
	if not sendSuccess then
		userMessage := app.getErrorString1(Unable_open_boom_not_respon, self.code);
		debugMess := debugMess &amp; "sendRequest to set failed with " &amp; conn.state.String &amp; CrLf;
		if conn.state = conn.State_NeedConnection then
			debugMess := debugMess &amp; "'" &amp; conn.state.String &amp; " indicates the connection is not open" &amp; CrLf;
		elseif conn.state = conn.State_Failure then
			debugMess := debugMess &amp; "'" &amp; conn.state.String &amp; " indicates a failed HTTP connection" &amp; CrLf;
		elseif conn.state = conn.State_NeedRequest then
			debugMess := debugMess &amp; "'" &amp; conn.state.String &amp; " indicates waiting for a request" &amp; CrLf;
		elseif conn.state = conn.State_NoData then
			debugMess := debugMess &amp; "'" &amp; conn.state.String &amp; " indicates no data" &amp; CrLf;
		else
			debugMess := debugMess &amp; "'" &amp; conn.state.String &amp; " undocumented reason" &amp; CrLf;
		endif;
	endif;

epilog

	delete conn;

end;</source>
        <Parameter name="userMessage" type="String" usage="output"/>
        <Parameter name="debugMess" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="delete" id="05ccd762-8161-479b-a168-88320b11180c">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     20 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2010	cnwcs5		par 23859 - stop boom being deleted if it is in use at a gate lane
// ---------------------------------------------------------------------------
vars

begin
	if not self.allLaneDevices.isEmpty then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Boom is in use so cannot be deleted');
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="f4d4fcdb-d8ba-436c-9cf2-58bb22222a8f">
        <source>getDisplayDetails(_short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2021	navndl1	Initial creation	TFS 51632

*/

vars

begin
	return self.code;

epilog

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="b2a7797c-e838-4296-be5e-32664aa497dd">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2019	jlgndl1	Initial creation	TFS 43043

*/

vars

begin

	if _attrName = ETRow_Channel then
		return self.getDisplayValueForChannel;
	elseif _attrName = ETRow_Password then
		if self.password = null then
			return "&lt;" &amp; app.getErrorString(Not_Set) &amp; "&gt;";
		else
			return self.PasswordStr;
		endif;
	elseif _attrName = ETRow_UserCode then
		return self.userCode;	
	endif;

	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayValueForChannel" id="f939f167-1b31-457a-a37d-26394879620b">
        <source>getDisplayValueForChannel():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 February 2019	jlgndl1	Initial creation	TFS 43240

*/

vars

begin

	if self.channel = 1 then
		return "DO0";
	elseif self.channel = 2 then
		return "DO1";
	elseif self.channel = 3 then
		return "DO2";
	elseif self.channel = 4 then
		return "DO3";
	elseif self.channel = 5 then
		return "DO4";
	elseif self.channel = 6 then
		return "DO5";
	else
		return null;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPwForUse" id="2c7f102b-ced1-48b8-8ef3-711d96c258c6">
        <source>getPwForUse(_context: String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2021	navndl1	Initial creation	TFS 51632

*/

vars

begin

	return app.pwDeCode( self, self.password );

epilog

end;</source>
        <Parameter name="_context" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="747357ad-78d2-4aec-8a0f-18aa2dabcc4b">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     22 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxy	:SelfType;
	completedOK		: Boolean;
begin
	proxy :=  inheritMethod();

	proxy.myTerminal	:= self.myTerminal;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setChannelFromDisplayValue" id="eed1a0d3-56e1-4d93-b4ad-8458e72bc0a4">
        <updating/>
        <source>setChannelFromDisplayValue( _str : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 February 2019	jlgndl1	Initial creation	TFS 43240

*/

vars

begin

	if _str = "DO0" then
		self.channel := 1;
	elseif _str = "DO1" then
		self.channel := 2;
	elseif _str = "DO2" then
		self.channel := 3;
	elseif _str = "DO3" then
		self.channel := 4;
	elseif _str = "DO4" then
		self.channel := 5;
	elseif _str = "DO5" then
		self.channel := 6;
	else
		self.channel := 0;
	endif;

epilog

end;</source>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="2a18aa1a-09de-485b-8316-4eb8e092fa8e">
        <updating/>
        <source>setForCreate(_proxy : CM_Boom) updating;
// ---------------------------------------------------------------------------
// Created:     22 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.myTerminal	:= _proxy.myTerminal;
	
	self.setForUpdate(_proxy);
end;</source>
        <Parameter name="_proxy" type="CM_Boom"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="d66c5177-77f1-40ea-b572-1c184e84a2bf">
        <updating/>
        <source>setForUpdate(_proxy : CM_Boom) updating;
// ---------------------------------------------------------------------------
// Created:     22 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.myTerminal = null then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Terminal is required');
	endif;
	
	self.code			:= _proxy.code;
	self.description	:= _proxy.description;
	self.ipAddress		:= _proxy.ipAddress;
	self.portNumber		:= _proxy.portNumber;
	self.channel		:= _proxy.channel;	//14 Feb 2019	TFS 43403
	self.userCode		:= _proxy.userCode;	//14 Feb 2019	TFS 43403
	self.password		:= _proxy.password;	//14 Feb 2019	TFS 43403
	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_Boom"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="3cf068fe-2b31-47b9-995c-791071ef8bf6">
        <updating/>
        <source>setProxy(	_code : String;
			_description : String;
			_ipAddress : String;
			_portNumber : Integer;
			_terminal : CM_Terminal;
			_channel : String;
			_userCode : String;
			_password : String
			) updating;
// ---------------------------------------------------------------------------
// Created:     22 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.code			:= _code;
	self.description	:= _description;
	self.ipAddress		:= _ipAddress;
	self.portNumber		:= _portNumber;
	
	self.setChannelFromDisplayValue( _channel );	//14 Feb 2019	TFS 43403
	self.userCode		:= _userCode;	//14 Feb 2019	TFS 43403
	self.password		:= _password;	//14 Feb 2019	TFS 43403
	
	self.myTerminal		:= _terminal;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_ipAddress" type="String"/>
        <Parameter name="_portNumber" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_channel" type="String"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_password" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyPw" id="3454070e-6ccb-4d7d-87c2-d51cb383e2ae">
        <updating/>
        <source>setProxyPw(_str: String; _context : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2021	navndl1	Initial creation	TFS 51632

*/

vars

begin
	
	self.password := _str;

epilog

end;</source>
        <Parameter name="_str" type="String"/>
        <Parameter name="_context" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateCreate" id="44dcebc8-01e0-4306-958e-cb5198c19832">
        <source>validateCreate(_passport: CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     22 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.validateUpdate (_passport);
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateDelete" id="2a68cae5-117e-480b-85f9-548f3242a0f9">
        <source>validateDelete(_passport: CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     20 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2010	cnwcs5		par 23859 - prevent dangling references
// ---------------------------------------------------------------------------
vars

begin
	if not self.allLaneDevices.isEmpty then
		app.raiseCMException2 (Lane_Device_Delete_Error, self.code, self.allLaneDevices.first.getLaneDescription, null, null);
	endif;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="9ff433c6-025e-49d3-a191-b863826e7c14">
        <source>validateUpdate(_passport: CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     22 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	boom	:CM_Boom;
begin
	if self.ipAddress = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'IP Address', ETRow_IpAddress, null);
		app.raiseCMException(Input_required_field_ipAddress, ETRow_IpAddress, null); // cnwdb2	PAR 35364
	endif;
	
	if self.portNumber = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Port Number', ETRow_PortNumber, null);
//		app.raiseCMException(Input_required_field_prtNumber, ETRow_PortNumber, null);// cnwdb2	PAR 35364

	endif;
	
	foreach boom in self.myTerminal.allBoomsByCode where boom.code &lt;&gt; self.code do
		if boom.ipAddress = self.ipAddress and boom.portNumber = self.portNumber then
			app.raiseCMException1(IPAddressPortInUse, boom.code, ETRow_PortNumber, null);
			break;
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
