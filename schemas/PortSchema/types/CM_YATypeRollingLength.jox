    <JadeMethod name="isCMIFDataMatch" id="35246db4-a81d-459a-b4ee-cec66993aeb8">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataString): Boolean;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 13 May 2022
TFS#		: 53316
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	return _yaData.value = null or _cmifAutoPlan.isRollingLength_Match(_yaData);
end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YADataString"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
