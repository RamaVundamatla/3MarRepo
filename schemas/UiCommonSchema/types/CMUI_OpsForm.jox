    <JadeMethod name="doNotableAdd" id="3765f26b-9d17-43db-b83c-896f67a49bce">
        <source>doNotableAdd(_ti : CM_TrackedItem);
//--------------------------------------------------
// Created:	13 January 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _ti = null then
		return;
	endif;
	
	if (not global.isValidObject(_ti)) then
		return;
	endif;
	
	if (not self.allNotableTIs.includes(_ti)) then
		self.allNotableTIs.add(_ti);
		beginNotification(_ti, Object_Update_Event, Response_Continuous, null);
	endif;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="3d4b3514-8c3f-4df8-b6e3-a370469b5e15">
        <source>doNotableClear();
//--------------------------------------------------
// Created:	13 January 2004 By: cnwgd1
//--------------------------------------------------
vars
	ti : CM_TrackedItem;
begin
	foreach ti in self.allNotableTIs do
		endNotification(ti, Object_Update_Event);
	endforeach;

	self.allNotableTIs.clear;
end;</source>
    </JadeMethod>
    <JadeMethod name="doNotableRemove" id="21441074-3f61-44aa-9b27-f80c111d16a5">
        <source>doNotableRemove(_ti : CM_TrackedItem);
//--------------------------------------------------
// Created:	13 January 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _ti = null then
		return;
	endif;
	if (not global.isValidObject(_ti)) then
		return;
	endif;
	if  self.allNotableTIs.includes(_ti) then
		self.allNotableTIs.remove(_ti);
		endNotification(_ti, Object_Update_Event);
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="c0d20213-8012-42df-96e7-6c87f0b25f1b">
        <updating/>
        <source>doRefresh() updating, protected;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	inheritMethod();
	self.lstJobsSaveSelected;
	self.tblWLESaveSelected();
	
	self.loadListJobsAll();

	if self.selectedListObject = null then
		selectedListObject := self.getDefaultObjectToSelect;
	endif;
	
	if self.selectedListObject &lt;&gt; null then
		self.lstJobsSetSelectedObject;			
	elseif self.lstJobs.listCount &gt; 0 then
		self.lstJobs.listIndex := 1;
		self.lstJobs.listObject := lstJobs.itemObject[1];
		self.lstJobs.itemSelected[1] := true;
		self.lstJobsChange(self.lstJobs.listObject.CM_Object);
		if not self.lstJobs.itemExpanded[1] then
			//self.lstJobs.expandItem(1);
			self.lstJobsExpandAllItems();
		endif;	
	endif;
	self.tblWLESetSelected();
	
	if (not self.timerRefreshActive) then
		self.beginTimerForRefresh();
	endif;			
end;</source>
        <access>protected</access>
    </JadeMethod>
