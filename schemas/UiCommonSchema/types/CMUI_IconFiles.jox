    <JadeMethod name="btnDeleteIcon_click" id="3c16b00e-8d6f-4820-abcf-420d4964babf">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDeleteIcon_click(btn: Button input) updating;
/*
Purpose:			

Date		Who		Reason
05 October 2021	navab1	TFS 51853
*/

vars

	icon : CMUI_IconFile;
	row : Integer;
begin
	if self.tblData.row &lt;= self.tblData.fixedRows then
		return;
	endif;
	
	row := self.tblData.row;
	icon := self.tblData.accessRow(row).itemObject.CMUI_IconFile;
	
	if icon = null then
		global.beep;
		return;
	endif;


	beginTransaction;
	
	delete icon;
	
	commitTransaction;
	
	
	self.populateTable();
	
	self.tblData.topRow := row;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
