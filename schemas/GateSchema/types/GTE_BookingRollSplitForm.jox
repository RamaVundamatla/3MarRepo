    </JadeMethod>
    <JadeMethod name="cmbDischargePort_displayEntry" id="db9e678d-dd02-4723-8509-8b7c01c85146">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbDischargePort_displayEntry(combobox: ComboBox input; obj: CM_Port; lstIndex: Integer):String updating;

