// ---------------------------------------------------------------------------
// Created:     02 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	voyageCombo	: ComboBox;
	tmpVoyage	: CM_Voyage;
	setPort		: CM_Port;
begin

	//discharge can default to the local port and so maybe set
	//if discharge is set, remember it and reset later
	//setPort := self.cmbDischarge.listObject.CM_Port;
	setPort := self.cmbDischarge.myObject.CM_Port;

	voyageCombo := self.cmbVoyage;
	if voyageCombo = null then
		return;
	endif;
/*
	pos := 1;
	voyageCode := voyageCombo.text;
	// strip off the description
	
	if voyageCode &lt;&gt; null then
		voyageCode := voyageCode.scanUntil(Tab, pos).trimRight;
	endif;
*/

	tmpVoyage := voyageCombo.listObject.CM_Voyage;
	if combobox.myVoyage = tmpVoyage then
		return;
	endif;

	// need to reset list
//	tmpVoyage := voyageCombo.listObject.CM_Voyage;
//	if tmpVoyage = null then
//		tmpVoyage := self.myAssistant.getVoyageFromCombo(voyageCode);
//	endif;
	
//	self.myAssistant.comboBoxDischarge(combobox, tmpVoyage, combobox.listObject.CM_Port);
//	combobox.selectAllText();
if setPort &lt;&gt; null then		// cnwvu1	4/12/2006	PAR12988
	combobox.clear;
	combobox.setObjectAndVoyage(setPort,tmpVoyage);
endif;	
//	combobox.gotFocus(combobox); // only called if voyage has changed
end;</source>
