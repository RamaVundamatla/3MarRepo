    <JadeMethod name="getIMEX" id="eac55750-2b52-4817-a19a-b221fa6b60f6">
        <source>getIMEX() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2010	cnwndl1	Initial creation	CCMS MES 1004

*/

vars

	imx : CM_IMEXStatus;
	
begin

	if self.myTrackedItem &lt;&gt; null then
		return self.myTrackedItem.getImExStatusString;
	elseif self.myBookingRef &lt;&gt; null then
		imx := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
	elseif self.myBOL &lt;&gt; null then
		if self.myBOL.isInward then
			imx := app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT];
		else
			imx := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
		endif;
	elseif self.myGateReceival &lt;&gt; null then
		imx := self.myGateReceival.imExStatus;
	elseif self.myGateReceivalByType &lt;&gt; null then		// 10/12/2010 cnwmh5 #26556
		imx := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
	endif;
	
	if imx &lt;&gt; null then
		return imx.description;
	endif;
	
	return " ";
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getImexStatus" id="4ee1f417-b188-48ee-a72c-68387fc4cbb9">
        <source>getImexStatus() : Integer;
// 37594 return the imex status numeric value for future processing
vars

	imx : CM_IMEXStatus;
	
begin

	if self.myTrackedItem &lt;&gt; null then
		return self.myTrackedItem.getImExStatus();
	elseif self.myBookingRef &lt;&gt; null then
		imx := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
	elseif self.myBOL &lt;&gt; null then
		if self.myBOL.isInward then
			imx := app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT];
		else
			imx := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
		endif;
	elseif self.myGateReceival &lt;&gt; null then
		imx := self.myGateReceival.imExStatus;
	elseif self.myGateReceivalByType &lt;&gt; null then
		imx := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
	endif;
	
	if imx &lt;&gt; null then
		return imx.code;
	endif;
	
	return TI_IMEX_STATUS_NULL;
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
