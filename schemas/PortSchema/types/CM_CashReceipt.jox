    <JadeMethod name="getCashInvoice" id="b7523907-8c62-4f80-8acb-5231549039c1">
        <source>getCashInvoice() : CM_Invoice;

/*

Purpose:		For enquiry	

Parameters:			

Return Value:		


Date		Who		Reason
07 July 2015	cnwjre1	Initial creation

*/

vars
	invoice		: CM_Invoice;
	ti			: CM_TrackedItem;
	localTiArray : CM_TIArray;		//30 Mar 2016	NDL	TFS 1726
begin
	invoice := self.myCashInvoice;
	if invoice = null then
	
		create localTiArray transient;	//30 Mar 2016	NDL	TFS 1726
		self.getAllGoodTrackedItems( localTiArray );		//30 Mar 2016	NDL	TFS 1726
		
		//foreach ti in self.allTrackedItems do
		foreach ti in localTiArray do		//30 Mar 2016	NDL	TFS 1726
			invoice := ti.getCashInvoice();
			if invoice &lt;&gt; null then
				break;
			endif;
		endforeach;
	endif;
	return invoice;
	
epilog

	delete localTiArray;	//30 Mar 2016	NDL	TFS 1726

end;</source>
        <ReturnType type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="getCashInvoiceType" id="caae185b-ea99-4bb3-928a-3cf85f3d50a0">
        <source>getCashInvoiceType(_isCreateInvoiceFromRec : Boolean) : CM_InvoiceDesc;
/*

Purpose:		TFS 39236 	

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2018	jlgab1	Initial creation

*/

vars
	cashInvoiceType : CM_InvoiceDesc;
	proforma : CM_InvoiceLine;
	terminal : CM_Terminal;
begin
	
	
	if self.myWorkOrder &lt;&gt; null then
		// TFS 41026
		// PEL1 Cash Receipts are used for estimation, PEL1 cash receipts do not need  cash invoice
		// If cash receipt for Work Order then DO NOT CREATE a cash invoice, simply return null will mean that a cash invoice is not created.
	
		//return null;       //11.01.2019 cnwma1
		/*proforma := self.allProformaInvoiceLines.first;
		if proforma &lt;&gt; null then
			if proforma.invoiceLineDesc &lt;&gt; null then
				cashInvoiceType := proforma.invoiceLineDesc.invoiceType;
			endif;
		endif;
		*/
		//11.01.2019 cnwma1 TFS #40202
		if _isCreateInvoiceFromRec  then
			cashInvoiceType:= self.getInvoiceType;
			if cashInvoiceType &lt;&gt; null then	//23 Oct 2019	NDL	TFS 47175 - allow for null return here to drop to the next bit.
				return cashInvoiceType;
			endif;
		else
			return null ;
		endif;
	endif;
	
	//11.01.2019 cnwma1 TFS #40202
	if cashInvoiceType = null then
		terminal := self.getDebtorTerminal().myTerminal;
		//cashInvoiceType := terminal.getConfig(CashInvoiceType).CM_InvoiceDesc;
		cashInvoiceType := terminal.getCashInvoiceType( self.getBank );	//08 Jan 2019	NDL	TFS 40010 
	endif;
	
	return cashInvoiceType;
epilog

end;</source>
        <Parameter name="_isCreateInvoiceFromRec" type="Boolean"/>
        <ReturnType type="CM_InvoiceDesc"/>
    </JadeMethod>
