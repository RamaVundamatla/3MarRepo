    <JadeMethod name="getMasterCargoRestrictColour" id="d790c0af-e75b-4017-9e2a-9f2bc76f9ace">
        <source>getMasterCargoRestrictColour() : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 February 2014	cnwndl1	Initial creation	Par 33439

*/

vars

	cargoRestrict : CM_CargoRestrictionCriteria;

begin

	if self.myWagonMaster &lt;&gt; null and self.myTerminal &lt;&gt; null then
		cargoRestrict := self.myWagonMaster.getMyObjectMatchCriteriaFor( self.myTerminal );
		if cargoRestrict &lt;&gt; null then
			if cargoRestrict.colour &lt;&gt; 0 then
				return cargoRestrict.colour;
			endif;
		endif;
	endif;
	
	return NullColour;


epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMaxCargoHeight" id="25844dc3-de91-4c28-8184-2f1b0b1aa751">
        <source>getMaxCargoHeight():Decimal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 February 2010	cnwndl1	Initial creation	Par 21924
08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/

vars

	maxHeight : Decimal [12,2];
	invalidObject : Boolean;
	wagonClass		: CM_WagonClass;
	wagonMaster		: CM_WagonMaster;
begin

	wagonClass := self.myWagonClass;
	if wagonClass &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, wagonClass, invalidObject);
		maxHeight := wagonClass.maxCargoHeight;
		if wagonClass.internalHeight &gt; maxHeight then
			maxHeight := wagonClass.internalHeight;
		endif;
		if not invalidObject then
			return maxHeight;
		endif;
	endif;
	wagonMaster := self.myWagonMaster;
	if wagonMaster &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, wagonMaster, invalidObject);
		maxHeight := wagonMaster.getMaxCargoHeight;
	endif;
	
	return maxHeight;
	
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getMaxCargoWeight" id="151254b1-9da1-4b96-9202-47e4dc1db5b5">
        <source>getMaxCargoWeight():Decimal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 February 2010	cnwndl1	Initial creation	Par 21924
08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
18 Aug 2022	jlika1	TFS 54562 - MTN - Cannot Confirm Empty Wagon in Rail Confirm React Version (We got a mapper method that will populate the fields as necessary)
*/
	
begin
	return self.maxCargoWeight;	
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getMyPosition" id="c5eb3fef-093c-439c-b03a-3857dacde1be">
        <source>getMyPosition() : Integer;
// ---------------------------------------------------------------------------
// Created:		July  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if self.myRailLine = null then
		return 0;
	endif;
	if self.myRailLine.allWagons.size = 0 then
		return 0;
	endif;
	return self.myRailLine.allWagons.indexOf(self);
end;</source>
