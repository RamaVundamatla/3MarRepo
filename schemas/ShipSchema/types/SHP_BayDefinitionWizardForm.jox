    <JadeMethod name="doResize" id="02b4e895-5804-4292-80e3-c64b2948eda2">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 May 2009	cnwer1	Initial creation

*/

constants
	Gap = 3;
vars
	layoutWidth : Integer;
	aW, aH : Real;
begin
	inheritMethod();
	layoutWidth:=(self.grpBayLayout.width - (Gap * 2)).Integer;
	self.frmBayLayoutTB.left:=Gap;
	self.frmBayLayoutTB.width:=layoutWidth;
	self.frmBayLayoutTB.top:=self.grpBayLayout.top +(Gap * 2);
	self.frmLayoutHint.left:=Gap;
	self.frmLayoutHint.width:=layoutWidth;
	self.frmLayoutHint.top:=self.frmBayLayoutTB.top + self.frmBayLayoutTB.height;
	
	if self.frmScrollDraw.allGridAreasByRowColumn.isEmpty then
		aW :=self.frmScrollDraw.width;
		aH := self.frmScrollDraw.height;
	else
		aW := self.frmScrollDraw.getWidthOfAllFrames();
		aH := self.frmScrollDraw.getHeightOfAllFrames();
	endif;

	self.frmScrollDraw.resizeDrawingFrame(aW,aH);
	self.frmScrollDraw.repositionScrollBars;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveWizard" id="b9ff8527-38e3-4736-891c-a70ea59ff302">
        <updating/>
        <source>doSaveWizard() updating;
// ---------------------------------------------------------------------------
// Created:		22 May 2008 By Andrew Bishop cnwab1
//
// Purpose:		 // PAR 17912
//
// ---------------------------------------------------------------------------
vars
	pxyVessel : CM_CellularVesselStructure;
	result : Integer;
	aBay : CM_BayDefn;
	tmpTxt : TextBox;
	use40ftId : Boolean;
	slotDefn,newSlotDefn : CM_SlotDefn;
	tierDefn : CM_TierDefn;
	cellDefn : CM_CellDefn;
	slotDefnVessel : CM_SlotDefnVessel;
begin
	tmpTxt := self.validateWizardData();
	if tmpTxt &lt;&gt; null then
		global.beep;
		tmpTxt.setFocus();
		return;
	endif;

	pxyVessel := app.createUpdateProxy(self.myCurrentCellularVessel).CM_CellularVesselStructure;
	
	if self.chkUse40.visible then
		use40ftId:=self.chkUse40.value;
	endif;
	pxyVessel.setProxyCellularVessel(null,use40ftId,true,false, 0); // PAR 32286
	pxyVessel.createProxyBaysFromString(self.txtBayOrder.text.trimBlanks());
	
	foreach aBay in pxyVessel.allBaysByOrdinal do
		self.doSetProxyCellsOD(self.txtOnDeckCells.text,aBay);
		self.doSetProxyCellsUD(self.txtUnderDeckCell.text,aBay);
		self.doSetProxyTiers(self.txtOnDeckTiers.text,aBay,DeckOnDeck);
		self.doSetProxyTiers(self.txtUnderDeckTier.text,aBay,DeckUnderDeck);
		self.doSetProxySlots(aBay,DeckOnDeck);
		self.doSetProxySlots(aBay,DeckUnderDeck);	
	endforeach;
		
	while true do
		app.myTrxUA.trxUpdateVesselStructure(pxyVessel, app.myPassport);
		if app.myPassport.trxCompletedOK then
			
			global.beep;
			
			// PAR 18145
			app.msgBox("The creation of the bay definitions for '" &amp; self.myCurrentCellularVessel.myVessel.code &amp; "' has been Successful!","Vessel Structure",MsgBox_Information_Icon);
			break;
		else
			
			result := app.showErrorWarningDialog('Vessel Definition Wizard', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		
		endif;
		return;
	endwhile;
	

epilog
	delete pxyVessel;
	app.mousePointer := Window.MousePointer_Default;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSetProxyCellsOD" id="7b3710cd-0036-4acc-86c1-818c5c920ed5">
        <updating/>
        <source>doSetProxyCellsOD(_theLabels : String; _proxyBayDefn : CM_Bay input) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aProxyCellDefn : CM_CellDefn;
	aLabel, cellLabels : String;
	theLabels : StringArray;
	theAlignment : Real;
	idx,theReturn : Integer;
	someCells : CM_CellDefnByIdDict;
begin


	aLabel := _theLabels;
	aLabel.replaceString(" ","|");
	theLabels := aLabel.getTokens;

	if not self.validateCellTierLabels(_theLabels, "On Deck Cell") then
		self.txtOnDeckCells.text := cellLabels;
		return;
	endif;


	create someCells transient;

	foreach aLabel in theLabels do
		if aLabel.trimBlanks = null then
			continue;
		endif;
		
		idx := idx + 1;
		aProxyCellDefn := _proxyBayDefn.allCellsOnDeck[aLabel.trimBlanks];
		
		if aProxyCellDefn = null then
			create aProxyCellDefn transient;
			// the alignment allows users to move a cell, graphically, away from its neighbour
			theAlignment := idx;
		else
			theAlignment := aProxyCellDefn.alignment;
		endif;
		aProxyCellDefn.setProxy(aLabel.trimBlanks,theAlignment,idx,_proxyBayDefn,null,null);
		if someCells[aLabel.trimBlanks] = null then
			someCells.add(aProxyCellDefn);
		endif;
	endforeach;


epilog
	delete someCells;
	delete theLabels;
	
end;</source>
        <Parameter name="_theLabels" type="String"/>
        <Parameter name="_proxyBayDefn" type="CM_Bay" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSetProxyCellsUD" id="5fedff3d-cdeb-4a1f-8dd4-51f3a70dce0c">
        <updating/>
        <source>doSetProxyCellsUD(_theLabels : String; _proxyBayDefn : CM_Bay input) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aProxyCellDefn 			: CM_CellDefn;
	aLabel,cellLabels		: String;
	someCells 				: CM_CellDefnByIdDict;
	theLabels : StringArray;
	idx, theCount,
	theReturn  				: Integer;
	theAlignment 			: Real;
begin
	aLabel := _theLabels;
	aLabel.replaceString(" ","|");
	theLabels := aLabel.getTokens();

	
	if not self.validateCellTierLabels(_theLabels, "Under Deck Cell") then
		self.txtUnderDeckCell.text := cellLabels;
		return;
	endif;

	idx := 0;
	create someCells transient;
	foreach aLabel in theLabels  do
		theCount := theCount + 1;
		if aLabel.trimBlanks = null then
			continue;
		endif;
		
		idx := idx + 1;
		
		aProxyCellDefn := _proxyBayDefn.allCellsUnderDeck[aLabel.trimBlanks];
		if aProxyCellDefn = null then
			create aProxyCellDefn transient;
			// the alignment allows users to move a cell, graphically, away from its neighbour
			theAlignment := idx;
		else
			theAlignment := aProxyCellDefn.alignment;
		endif;
		aProxyCellDefn.setProxy(aLabel.trimBlanks,theAlignment,idx,null,_proxyBayDefn,null);
		if someCells[aLabel.trimBlanks] = null then
			someCells.add(aProxyCellDefn);
		endif;
	endforeach;
	
epilog
	delete someCells;
	delete theLabels;
	
end;</source>
        <Parameter name="_theLabels" type="String"/>
        <Parameter name="_proxyBayDefn" type="CM_Bay" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSetProxySlots" id="725cab94-5788-44c2-a82f-18cfd5987f05">
        <source>doSetProxySlots(_bay : CM_BayDefn; _deckOrdinal : Integer );
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 May 2009	cnwer1	Initial creation

*/

vars
	slotDefn: CM_SlotDefn;
	cellDefn 	: CM_CellDefn;
	tierDefn 	: CM_TierDefn;
	cellColl : CM_CellDefnByOrdinalDict;
	tierColl : CM_TierDefnByOrdinalDict;
	slotDefnVessel,newSlotDefn : CM_SlotDefnVessel;
	slotColl :  CM_SlotDefnByCellIdTierIdDict;
begin


	if _deckOrdinal = DeckOnDeck then //ON Deck
		cellColl := _bay.allCellsOnDeckByOrdinal;
		tierColl := _bay.allTiersOnDeck;
		slotColl :=  self.myProxyBayDefn.allSlotsOnDeck;
	else
		cellColl := _bay.allCellsUnderDeckByOrdinal;
		tierColl := _bay.allTiersUnderDeck;
		slotColl :=  self.myProxyBayDefn.allSlotsUnderDeck;
	endif;
		// NOTE these cells and tiers are REAL
	foreach cellDefn in cellColl do
			foreach  tierDefn in tierColl do
	
				// only create if the slot is empty
				if cellDefn.allSlotDefinitions[_deckOrdinal,tierDefn.ordinal] &lt;&gt; null then
					continue;
				endif;
				slotDefn:= slotColl[cellDefn.id,tierDefn.id];
				
				if slotDefn &lt;&gt; null then
				//have to create the transient any way
					slotDefnVessel := slotDefn.CM_SlotDefnVessel;
					newSlotDefn := slotDefnVessel.cloneSelf(true);
					newSlotDefn.setProxyCellTierID( cellDefn.id, tierDefn.id);
					newSlotDefn.setForUpdateOrdinals(_deckOrdinal, cellDefn.ordinal,tierDefn.ordinal);
					if _bay.bayType = 	 BAY_TYPE_SINGLE then
						newSlotDefn.setFortyFrontBack(false,false);
					elseif _bay.bayType = BAY_TYPE_TWIN then
						if _bay.myHold.allBays.indexOf(_bay) &lt;&gt; 1 then	
							newSlotDefn.setFortyFrontBack(false,slotDefnVessel.fortyFront);
						endif;
					endif;
				else
					create newSlotDefn as CM_SlotDefnVessel transient;
					//got what to set by default from CM_SlotDefn internalCreateSlots
					newSlotDefn.setProxy( cellDefn.ordinal, _deckOrdinal, tierDefn.ordinal, 0, 0, 0, 0,0,
			                     true, false, false, false, false, false, false, false, false,false, false,false,
			                     cellDefn.id, tierDefn.id, false, false, false);
				endif;
				
				newSlotDefn.setCellAndTierDefn(cellDefn,tierDefn);
				newSlotDefn.setMyBay(_bay,slotDefnVessel.ordinalDeck = DeckOnDeck);
				
			endforeach;
		endforeach;
epilog

end;</source>
        <Parameter name="_bay" type="CM_BayDefn"/>
        <Parameter name="_deckOrdinal" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doSetProxyTiers" id="5529f5ff-a50c-459f-8374-6fe49650eefa">
        <updating/>
        <source>doSetProxyTiers(_theLabels : String; _proxyBayDefn : CM_Bay input; _deckOrdinal : Integer  ) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aProxyTierDefn : CM_TierDefn;
	aLabel,
	tierLabels,
	validateMsg 	: String;
	theLabels : StringArray;
	idx : Integer;
	tierColl : CM_TierDefnByIdDict;
	bayOnDeck,
	bayUnderDeck : CM_Bay;
begin
	if _deckOrdinal = DeckOnDeck then //ON Deck
		tierColl := _proxyBayDefn.allTiersOnDeckByLabel;
		validateMsg:="On Deck Tier";
		aLabel:=self.txtOnDeckTiers.text;
		bayOnDeck:=_proxyBayDefn;
	else
		tierColl := _proxyBayDefn.allTiersUnderDeckByLabel;
		validateMsg:="Under Deck Tier";
		aLabel:=self.txtUnderDeckTier.text;
		bayUnderDeck:=_proxyBayDefn;
	endif;
	
	if not self.validateCellTierLabels(aLabel, validateMsg) then
		return;
	endif;
	
	aLabel.replaceString(" ","|");
	theLabels := aLabel.getTokens;
	
	idx := 0;
	foreach aLabel in theLabels  do
		if aLabel.trimBlanks = null then
			continue;
		endif;
		idx := idx + 1;
		aProxyTierDefn := tierColl[aLabel.trimBlanks];
		if aProxyTierDefn = null then
			create aProxyTierDefn transient;
			aProxyTierDefn.setProxy(aLabel.trimBlanks,idx,idx,bayOnDeck,bayUnderDeck);
		endif;
	endforeach;

epilog
	delete theLabels;
end;</source>
        <Parameter name="_theLabels" type="String"/>
        <Parameter name="_proxyBayDefn" type="CM_Bay" usage="input"/>
        <Parameter name="_deckOrdinal" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doShowHideAdvanced" id="e7bedd21-961e-443a-a9da-7923da2cd7fe">
        <updating/>
        <source>doShowHideAdvanced() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 May 2009	cnwer1	Initial creation

*/
constants

vars
	show : Boolean;
	sideGap : Integer;
begin
	show:= self.btnAdvanced.caption= app.getErrorString(Show_advanced);
	
	
	self.btnReset.visible:=show;
	self.btnSaveDefault.visible:=show;
	self.grpBayLayout.visible:=show;
	self.grpVesselDetails.visible:=show;
	if self.windowState = self.WindowState_Normal then
		sideGap:= self.grpBayOrder.left.Integer;
		if show then
			self.width:= self.width + DefaultBayLayoutWidth + sideGap;
		
			self.height:= self.grpVesselDetails.top + self.grpVesselDetails.height + 200;
		else
			self.width:= self.grpBayOrder.left + self.grpBayOrder.width + (sideGap* 2);
			self.height:= self.grpCellsTiers.top + self.grpCellsTiers.height + 100;
		endif;
		self.doResize();
	endif;
	
	
	if show then
		self.btnAdvanced.caption:=app.getErrorString(Hide_advanced);
	else
		self.btnAdvanced.caption:=app.getErrorString(Show_advanced);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTierOrderLostFocus" id="bdb593be-8643-4153-a854-2eaf314376bb">
        <source>doTierOrderLostFocus(_text : TextBox input);
// ---------------------------------------------------------------------------
// Created:     18 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// // PAR 17912
// ---------------------------------------------------------------------------

vars
	hyphen, comma : Integer;
	allBays, ids, tmp, mess : String;
	holdOrd, bayID, bayID1, bayID2 : Integer;
begin
	ids := _text.text;
	tmp := ids;
	
	// PAR 18214
	mess := "Tier IDs can only be numeric IDs with space and comma separators." &amp;  // PAR 18147
						Cr &amp; "Tier IDs must be 2 characters in length." &amp; Cr &amp; "Alternatively a range can be entered with a hyphen.";
	
	tmp.replaceChar("-", " ");
	if not self.validateBayLabelsWizard(tmp, true) then
		app.msgBox(mess, "Tier ID Problem", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		_text.setFocus();
		return;
	endif;
	
	hyphen := ids.pos("-", 1);
	comma := ids.pos(CM_CellularVesselStructure.HoldSeperator, 1);
	
	// PAR 18214
	if hyphen &gt; 0 and comma &lt;= 0 then
		if hyphen = ids.length then
			app.msgBox(mess, "Tier ID Problem", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			_text.setFocus();
			return;
		endif;
	endif;

	if hyphen &gt; 0 and comma &lt;= 0 then
		bayID1 := ids[1:hyphen-1].Integer;
		bayID2 := ids[hyphen+1:end].Integer;
		
		foreach bayID in bayID1 to bayID2 do
			if bayID mod(2) = 0 then
				allBays := allBays &amp; bayID.padLeadingWith("0",2) &amp; CM_CellularVesselStructure.BaySeperator ;
			endif;
		endforeach;
		ids := allBays;
	endif;

	_text.text := ids;


end;
</source>
        <Parameter name="_text" type="TextBox" usage="input"/>
    </JadeMethod>
