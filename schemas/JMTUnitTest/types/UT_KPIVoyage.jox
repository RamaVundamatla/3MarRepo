    <JadeMethod name="tVoyageCargoCounter" id="bb81e31e-58df-41a2-8b7c-3911395e9756">
        <updating/>
        <source>tVoyageCargoCounter() updating;
// CNWMA1
/*
Purpose:			
Date		Who		Reason
17 February 2015	NAVAB1	Initial creation
*/

vars
	voyage : CM_Voyage;
	counter : CMIF_OutputFormatAgent_Counter;
	cargoTypes : CM_CargoTypeSet;
	bay : CM_Bay;
	deck : CM_Deck;
	objs : ObjectArray;
	subArray : CM_TISet;
	cannon : CM_CargoType;
	hold : CM_Hold;
begin

	self.opts.purge();
	self.opts.addAssoc("InwardCode","UTBISH1IN");
	voyage := self.createVesselVoyage("UTBISH1", null,null);

	self.opts.purge();
	self.createCargoOnSite("UTBISH1", "UTBISH");

	self.createCargoOnship(voyage);
	self.setOnshipRehandles("UTBISH1");

	create counter transient;
	create cargoTypes transient;
	
	cargoTypes.add(app.myRoot.getCargoTypeForID(1));
	
	cannon := self.getTerminal.getFirstNonSystemCargoType().CM_CargoType;
	cargoTypes.add(cannon);

	counter.unitTestGetNumbers(voyage,true,true,true,true,true,true,true,true,true,cargoTypes,false);
	
	bay := voyage.myCellularVoyageStructure.allBayVoyagesById["01"];
	
	
	// ### BAY 01 20 FOOT
	objs := counter.getContainerDetail(20,bay);

	subArray := objs[1].CM_TISet;
	assertTrueMsg(subArray.size = 6,"Bay 1 20' Import should be 6");

	subArray := objs[2].CM_TISet;
	assertTrueMsg(subArray.size = 2,"Bay 1 20' Tranship should be 2");

	subArray := objs[5].CM_TISet;
	assertTrueMsg(subArray.size = 2,"Bay 1 20' DLR should be 2");

	subArray := objs[6].CM_TISet;
	assertTrueMsg(subArray.size = 2,"Bay 1 20' SOB should be 2");

	
	
	// ### BAY 01 40 FOOT
	objs := counter.getContainerDetail(40,bay);

	subArray := objs[1].CM_TISet;
	assertTrueMsg(subArray.size = 10,"Bay 1 40' Import should be 10");

	subArray := objs[2].CM_TISet;
	assertTrueMsg(subArray.size = 2,"Bay 1 40' Tranship should be 2");

	
	
	// ### DECK 1 20 FOOT
	deck := voyage.myROROStructure.allDecksByCode["D1"];
	
	objs := counter.getContainerDetail(20,deck);

	subArray := objs[2].CM_TISet;
	assertTrueMsg(subArray.size = 3,"Deck 1 20' Tranship should be 3");

	subArray := objs[5].CM_TISet;
	assertTrueMsg(subArray.size = 3,"Deck 1 20' DLR should be 3");

	subArray := objs[6].CM_TISet;
	assertTrueMsg(subArray.size = 3,"Deck 1 20' SOB should be 3");

	subArray := objs[7].CM_TISet;
	assertTrueMsg(subArray.size = 99,"Deck 1 20' ROB should be 99");

	
	// ### DECK 1 CANNON BALLS
	objs := counter.getGeneralCargoDetail(cannon,deck);
	
	subArray := objs[2].CM_TISet;
	assertTrueMsg(subArray.size = 10,"Deck 1 GC Tranship should be 10");
	
	subArray := objs[5].CM_TISet;
	assertTrueMsg(subArray.size = 5,"Deck 1 GC DLR should be 5");
	
	subArray := objs[6].CM_TISet;
	assertTrueMsg(subArray.size = 5,"Deck 1 GC SOB should be 5");
	
	subArray := objs[7].CM_TISet;
	assertTrueMsg(subArray.size = 37,"Deck 1 GC ROB should be 37");
	
	counter.unitTestGetNumbers(null,true,true,true,true,true,true,true,true,true,null,true);
	
epilog
	delete counter;
	delete cargoTypes;
end;</source>
