/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2016	cnwkpd1	TFS 488 - Multi Timezone Support


*/

vars

begin
	return self.myTerminal;

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
