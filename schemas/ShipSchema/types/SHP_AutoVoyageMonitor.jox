    <JadeMethod name="btnManualCompare_click" id="58d1de5f-d03c-4998-9fbd-7f59501c2bfd">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnManualCompare_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2024	navra1	Initial creation for //navra1 - MTN-33017 - 11th Oct 2025

*/

vars
	form : SHP_LoadListComparison;
begin

	form := app.loadForm(SHP_LoadListComparison, SHP_Assistant, false, false, false, self.myTerminal, null).SHP_LoadListComparison;
	if form = null then
		return;
	endif;
	
	//navra1 - MTN-36125 - 24th Sep 2025
	form.context := "AUTO";
	
	form.show;

epilog

end;</source>
