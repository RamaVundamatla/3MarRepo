    <JadeMethod name="getYAColour" id="f9446e6d-d9cb-49be-b49b-5deb7e05d975">
        <source>getYAColour() : Integer;
/*
Purpose:			
Date		Who		Reason
06 September 2013	cnwab1	Initial creation
*/

vars
	ya : CM_YardAllocation;
	shelf : CM_RackShelfController;
begin

	if self.isRack then
		foreach shelf in self.allSubLocations discreteLock do
			ya := shelf.getYardAllocation();
			if ya &lt;&gt; null then
				return ya.color;
			endif;
		endforeach;
		return White;
	else
		ya := self.getYardAllocation();
		
		if ya = null then
			return White;
		endif;
	endif;
	return ya.color;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getYALocationCode" id="c912230a-c4cb-4c9f-9498-8a2d5751aeea">
        <source>getYALocationCode() : String;
/*
Purpose:			
Date		Who		Reason
06 September 2013	cnwab1	Initial creation
*/

vars
	shelf : CM_RackShelfController;
	tmpStr, shelfStr : String;
begin
	if self.allSubLocations.isEmpty() then
		return self.myTerminal.code &amp; " " &amp; self.ident &amp; "; ";
	else
		shelfStr := self.allSubLocations.first.ident &amp; "-" &amp; self.allSubLocations.last.ident;
		tmpStr := self.myTerminalArea.id &amp; " " &amp; self.ident &amp; " " &amp; shelfStr &amp; "; ";
	endif;

	return tmpStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isAvailForMultiMove" id="846eaeaa-3ca9-4d22-abda-fc7cd1b51205">
        <source>isAvailForMultiMove(): Boolean;
/* PAR 34865
Purpose:		determine if this location is available for
					a move during a multi cargo move ?	
	
Date				Who			Reason
SEPTEMBER 2014		CNWAB1		Initial creation
*/

vars
	
	itemCount : Integer; 
	capacity : Integer;
begin

	itemCount := self.getTrackedItemCount();
	itemCount := itemCount + self.allPlannedFutureMoves.size;
	itemCount := itemCount + self.allQueuedFutureMoves.size;

	
	capacity := self.getCurrentCapacity;	//28 Oct 2015	NDL	Par 36928
	if capacity &gt; 0 and itemCount &gt;= capacity then
		return false;
	endif;

	return true;

end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
