    <JadeMethod name="getID" id="28b960a9-c01c-45cc-8a78-4b43d10ba512">
        <source>getID(): String;
// ---------------------------------------------------------------------------
// Created:     14 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.myGridArea = null then
		return self.ident;
	endif;
	if self.myGridColumn = null or self.myGridRow  = null then
		return self.ident;
	endif;
	
	if self.myGridArea.areLocationIdsColThenRow  then
		return self.myGridColumn.label.trimBlanks &amp; self.myGridRow.label.trimBlanks;
	else
		return self.myGridRow.label.trimBlanks &amp; self.myGridColumn.label.trimBlanks;
	endif;
end;</source>
