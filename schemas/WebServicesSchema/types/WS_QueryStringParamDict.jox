<CollClass name="WS_QueryStringParamDict" id="b09a8440-c2e2-4283-bfd6-b2807a3a3d87">
    <loadFactor>66</loadFactor>
    <memberType name="WS_NameValuePair"/>
    <superclass name="MemberKeyDictionary"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <MemberKey>
        <property name="WS_NameValuePair::name"/>
        <caseInsensitive/>
        <sortOrder>5129</sortOrder>
    </MemberKey>
    <JadeMethod name="getValue" id="76e87beb-2c9f-453e-858f-2ac32e5111be">
        <source>getValue(_key : String) : String;
/*

Purpose:			
	Return the value of a name value pair parameter including existance check.
Parameters:			

Return Value:		

Date		Who		Reason
03 April 2023	navra1	Initial creation

*/

vars
	pair : WS_NameValuePair;	

begin
	pair := self.getAtKey(_key);
	if pair &lt;&gt; null then
		return pair.value;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_key" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="parseNameValuePair" id="874166b9-e45e-41d8-8a0c-a567b1089a36">
        <lockReceiver/>
        <updating/>
        <source>parseNameValuePair(nvpString : String) updating;
/*

Purpose:			
	Splits the passed in name value pair string into a name/value pair array for each parameter	
Parameters:			
	nvpDict(input): Name Value Pair Dictionary to populate from the nvpString
Return Value:		
	None

Date				Who			Reason
13 	May 	2020	jlgrr1		TFS 49227 - Initial creation
3	April 	2023 	navra1 		TFS 56641 Moved method from WS_RestWebServiceProvider
25 September 2024	navmd1		TFS 64610 Include parameters without values (ie, no '=')

*/

vars
	nvpArray	: HugeStringArray;
	nvp			: WS_NameValuePair;
	param		: String;
	pos			: Integer;
	name		: String;
	value		: String;
begin

	create nvpArray transient;
	nvpString.getTokensForDelimiterHuge("&amp;", nvpArray);
	//nvpString.getTokensForDelimiter("&amp;", nvpArray);
	
	foreach param in nvpArray do
		app.writeLog(method.qualifiedName &amp; " Param: " &amp; param, LogTRACE);
		pos := param.pos("=", 1);
		if pos &gt; 1 then
			create nvp transient;
			name := param[1 : pos-1];
			if param.length &gt; pos then
				value := param[ pos+1 : end];
			else
				value := null;
			endif;
			nvp.set(name, value.asStringRESTFUL);
			if self.getAtKey(name) = null then
				app.writeLog(method.qualifiedName &amp; " Adding Query Param: key=" &amp; nvp.name &amp; ",value=" &amp; nvp.value, LogTRACE);
				self.add(nvp);
			else
				delete nvp;
			endif;
		else
			if self.getAtKey(param) = null then
				create nvp transient;
				nvp.set(param, "true");
				app.writeLog(method.qualifiedName &amp; " Adding Query Param: key=" &amp; nvp.name &amp; ",value=" &amp; nvp.value, LogTRACE);
				self.add(nvp);
			endif;
		endif;
	endforeach;
		
epilog
	delete nvpArray;
end;</source>
        <Parameter name="nvpString" type="String"/>
    </JadeMethod>
</CollClass>
