    <JadeMethod name="tTSWDTRStopsCustomAction" id="e44956ae-1ee4-409a-ab03-dd5d780ab3fa">
        <source>tTSWDTRStopsCustomAction();
/*

Purpose:	This unit Verifies that the system correctly identifies and matches cargo items using the House Bill of Lading when the Voyage and Vessel details differ from the provided XML data. 
			Ensures that the system gracefully handles scenarios where the expected cargo count (&lt;packCount&gt;) is matched or mismatched		

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2025	naviv1	Initial creation JIRA-19185 - PNL - Custom Stops not Added/Cleared for Motor Vehicles - DTR
29 Aug 2025		navah1	Story 35274: MTN - Fix tTSWDTRStopsCustomAction Unit Test
*/
constants
	FINAL_VESSEL_CODE				: String	= 'UT_VES_' &amp; self.MTN19185;
	FINAL_VOYAGE_CODE				: String	= 'UT_VOY_' &amp; self.MTN19185;
	ORIGIN_VESSEL_CODE				: String 	= 'VES' &amp; self.MTN19185;
	ORIGIN_VOYAGE_CODE				: String 	= 'VOY' &amp; self.MTN19185;
	BLOCKSTACK						: String	= 'UT_BS_' &amp; self.MTN19185;
	HOUSE_BOL						: String	= "BOL19185";
	CARGO_TYPE						: String 	= "UTCOAL";
	STOP_ID_TT						: Integer	= 875;
	UT_STOP_HEADING					: String	= 'TSW TT HOLD B07';
	UT_STOP_CODE					: String 	= 'TSWTT';
	UT_CustomsActionName			: String	= 'TSW TT B07';
	UT_CustomsActionKeyword			: String 	= 'B07';
vars
	terminal 					: CM_Terminal;
	originVessel, 
	finalVessel					: CM_Vessel;
	originVoyage,
	finalVoyage					: CM_Voyage;
	operator					: CM_Operator;
	bulkCargo,
	cargoOnsite  				: CM_TrackedItem;
	ediData 					: String;
	ediFile						: CM_EDIFile;
	isProcOnSiteForBOLDTR,
	noImportStops				: Boolean;
	blockStack 					: CM_BlockStack;
	tempStr						: String;
	cargoType 					: CM_CargoType;
	lc							: CM_LocationsController;
	height						: Integer;
	bolList						: StringArray;
	bolNum, cargoId				: String;
	i							: Integer;
	iter						: Iterator;
	tiSet, cargoColl			: CM_TISet;
	ediTI						: CM_EDITrackedItem;
	stopsTableTT,
	realStopsTable,
	pxyStopsTable				: CM_StopsTable;
	pxyStopsTableTemplate		: CM_StopTableTemplate;
	processAreasArr,
	setAreasArr,
	checkAreasArr				: IntegerArray;
	cargoTypeSet,
	imexStatusSet				: ObjectSet;
	pxyStopCriteria				: CM_StopCriteria;
	realCustomsAction,
	pxyCustomsAction			: CM_EDIAction;
begin

	terminal := self.getTerminal;
	operator :=	self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString());
	cargoType := app.myRoot.getCargoTypeFromAbbrev(CARGO_TYPE);
	/*
	//This existing stop table id - 875 has the  as this is set as myActionObject of custom action with  responseStatus B07 and roleCode TT
	stopsTableTT := app.myRoot.getStopTableForId(STOP_ID_TT);
	
	//disabling the not available for entry for the stop table
	beginTransaction;
	realStopsTable.setPropertyValue(CM_StopsTable::isNotAvailableForEntry.name, false);
	commitTransaction;
	*/
	//28.08.2025 navah1 #35274 - Start
	//Delete TSW TT BACC Underbond STOP
	realStopsTable := self.getRoot.getStopTableForId(STOP_ID_TT);
	if realStopsTable &lt;&gt; null then
		self.deleteStopsTable(STOP_ID_TT);
		self.assertIsDeletedMsg(realStopsTable, "Global Setup - realStopsTable");
		self.logMessage("Deleted Stops Table: Id:'" &amp; STOP_ID_TT.String &amp; " Code: " &amp; UT_STOP_CODE);
	endif;
	
	//Create TSW TT BACC Underbond STOP
	create pxyStopsTable transient;
	pxyStopsTable.setProxy(false, UT_STOP_CODE, UT_STOP_HEADING, UT_STOP_CODE, null, STOP_ID_TT, null, false, false, app.myRoot, null, app.myPassport.myUser.code, null);
	
	create pxyStopsTableTemplate transient;
	pxyStopsTableTemplate.setKeys(app.getMyTerminalDO_NOT_USE, pxyStopsTable);
	
	create processAreasArr transient;
	
	create setAreasArr transient; 
	setAreasArr.add(StopApplyImport); 
	
	create checkAreasArr transient;	
	checkAreasArr.add(StopPreventDeliveryRequest);
	checkAreasArr.add(StopPreventReleaseRequest);
	checkAreasArr.add(StopPreventYardMove);
	checkAreasArr.add(StopPreventGateOut); 
	
	pxyStopsTableTemplate.setProxy(checkAreasArr,
									setAreasArr,
									processAreasArr,
									null,
									false,
									false,
									false,
									false,
									false,
									false,
									true,
									true);
	
	create cargoTypeSet transient;
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("BBLK"));
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("CAR"));
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("CONT")); 
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("MDF")); 
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation(CARGO_TYPE));
	
	create imexStatusSet transient;
	imexStatusSet.add(app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT]);
	
	create pxyStopCriteria transient;
	pxyStopCriteria.createStopCriteria(cargoTypeSet, YACriteriaType_CargoType, pxyStopCriteria);
	pxyStopCriteria.createStopCriteria(imexStatusSet, YACriteriaType_ImexStatus, pxyStopCriteria); 
	pxyStopCriteria.setProxyBaseData(pxyStopsTable);
	
	app.myTrxCA.trxCreateStopsTable(pxyStopsTable, realStopsTable, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realStopsTable, "Global Setup - realStopsTable");
	self.logMessage("Created Stops Table: Id:'" &amp; STOP_ID_TT.String &amp; " Code: " &amp; UT_STOP_CODE);
	
	//Delete Customs Action TSW TT BACC Underbond STOP
	realCustomsAction := app.myRoot.allEDIActions[UT_CustomsActionName];
	if realCustomsAction &lt;&gt; null then
		self.deleteEDIAction(UT_CustomsActionName, null, EDIKeyField_Clearance);
		self.assertIsDeleted(realCustomsAction);
		self.logMessage("Deleted Customs Action: Id:'" &amp; UT_CustomsActionName);
	endif;
	
	realCustomsAction := null;
	
	//Create Customs Action TSW TT BACC Underbond STOP
	create pxyCustomsAction transient;
	pxyCustomsAction.setProxy(UT_CustomsActionName, UT_CustomsActionKeyword, EDIKeyField_Clearance, EDIAction_Remove, realStopsTable, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, CM_EDIAction.RoleCode_TT);
	app.myTrxCA.trxCreateEDIAction(pxyCustomsAction, realCustomsAction, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realCustomsAction, "Global Setup - realCustomsAction");
	self.logMessage("Created Customs Action: Id:'" &amp; UT_CustomsActionName);
	self.logMessage("Global Setup: Finished" &amp; CrLf);
	
	//enabling import stops for the terminal
	noImportStops := terminal.getConfig(NoImportStops).Boolean;
    self.setTerminalConfig(NoImportStops, false);
	//29.08.2025 navah1 #35274 - End
	//enabling the new terminal config to check for onsite cargo matching house BOL for PNL
	isProcOnSiteForBOLDTR := terminal.getConfig(ProcOnSiteForBOLDTR).Boolean;
    self.setTerminalConfig(ProcOnSiteForBOLDTR, true);

	
	//deleting voyage and vessel
	self.deleteVoyage(ORIGIN_VOYAGE_CODE);
	self.deleteVessel(ORIGIN_VESSEL_CODE);
	self.deleteVoyage(FINAL_VOYAGE_CODE);
	self.deleteVessel(FINAL_VESSEL_CODE);
	
	//deleting block stack
	self.deleteTerminalArea(BLOCKSTACK);
	/*	29.08.2025 navah1 #35274
	//create originating vessel
	originVessel := self.addVesselWithHolds(ORIGIN_VESSEL_CODE, 2, 2);
	self.assertNotNull(originVessel);
	
	//create originating voyage
	originVoyage := self.addVoyageWithGeneralCargoStruc(ORIGIN_VOYAGE_CODE, originVessel.name, originVessel.myOperator.code,self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(originVoyage);
	*/
	//create final vessel
	finalVessel := self.addVesselWithHolds(FINAL_VESSEL_CODE, 2, 2);
	self.assertNotNull(finalVessel);
	
	//create final voyage
	finalVoyage := self.addVoyageWithGeneralCargoStruc(FINAL_VOYAGE_CODE, finalVessel.name, finalVessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(finalVoyage);
	
	//find the location in origin voyage for cargo creation
	//self.getTerminal.findLocationFromString(ORIGIN_VOYAGE_CODE &amp;" Hold1 Deck1", true, lc, height); //29.08.2025 navah1 #35274 
	self.getTerminal.findLocationFromString(FINAL_VOYAGE_CODE &amp;" Hold1 Deck1", true, lc, height);    //29.08.2025 navah1 #35274
	
	//create new blockstack terminal area
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	self.assertNotNull(blockStack);
	
	//create bolList with 7 items
	create bolList transient;
	foreach i in 1 to 7 do
		bolList.add(HOUSE_BOL &amp; '0' &amp; i.String);
	endforeach;
	
	create tiSet transient;
	
	foreach bolNum in bolList do
		foreach i in 1 to 2 do
			cargoId := bolNum &amp; '_0' &amp; i.String;
			self.deleteCargo(cargoId,cargoType);
			//create new cargo on vessel,assign the House BOL and discharge it to terminal area
			//bulkCargo := self.zCargoDischargeWithHouseBOL(cargoId,cargoType,lc,originVoyage,operator,bolNum,blockStack); //29.08.2025 navah1 #35274
			bulkCargo := self.zCargoDischargeWithHouseBOL(cargoId,cargoType,lc,finalVoyage,operator,bolNum,blockStack);    //29.08.2025 navah1 #35274
			tiSet.add(bulkCargo);
		endforeach;	
    endforeach;
	
	//self.assertEqualMsg(originVoyage.allTisByHouseBol.size, 14, "Test 1 - Voyage has incorrect number of House BOL TIs");//29.08.2025 navah1 #35274 
	self.assertEqualMsg(finalVoyage.allTisByHouseBol.size, 14, "Test 1 - Voyage has incorrect number of House BOL TIs");   //29.08.2025 navah1 #35274
	
	//29.08.2025 navah1 #35274 - Start
	//Check if the stop is applied to all the cargo onsite 
	iter := tiSet.createIterator;
    while iter.next(cargoOnsite) do
        tempStr	:= 'Stop ' &amp; STOP_ID_TT.display &amp; Space &amp; realStopsTable.heading.display &amp; ' not applied for cargo ' &amp; cargoOnsite.id;
		self.assertEqualMsg(cargoOnsite.isStopSet(STOP_ID_TT), true, tempStr);
    endwhile;
	//29.08.2025 navah1 #35274 - End
	
	//Loading the TSW EDI message
	//ediData := self.xmlData_CustomStops(FINAL_VESSEL_CODE,FINAL_VESSEL_CODE,CARGO_TYPE,HOUSE_BOL); //29.08.2025 navah1 #35274
	ediData := self.xmlData_CustomStops(ORIGIN_VESSEL_CODE,ORIGIN_VOYAGE_CODE,CARGO_TYPE,HOUSE_BOL); //29.08.2025 navah1 #35274
	//ediFile := self.ediLoadFileName(ediData, EDIFileType_XML, null, "TSW" &amp; method.name);
	ediFile := self.ediLoadFileName(ediData, EDIFileType_XML, "TSW", "TSW" &amp; method.name);
	self.assertNotNull(ediFile);
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 7, "Test 1 - EDI Data has incorrect number of EDI tracked items");
	
	create cargoColl transient;
	foreach bolNum in bolList do
		//self.getCargoByHouseBOL(originVoyage,bolNum,cargoColl); //29.08.2025 navah1 #35274
		self.getCargoByHouseBOL(finalVoyage,bolNum,cargoColl);    //29.08.2025 navah1 #35274	
		ediTI := ediFile.ediData.allEDITrackedItems[bolNum];
		self.assertNotNullMsg(cargoColl,"Test 1 - BOL has no tracked items");
		self.assertEqualMsg(cargoColl.size,ediTI.CM_EDICustomStopTI.packCount, "Pack count mismatch with House BOL cargo count");
		cargoColl.clear();
	endforeach;
	
	//verify EDI file
	self.ediVerify(ediFile);
	tempStr	:= 'Test 1 - Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);

	//DB Load the EDI file
	self.ediDBLoad(ediFile);
	tempStr	:= 'Test 1 - DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
	//Check if the stop is removed to all the cargo onsite with matching House BOL as in the TSW EDI messages
	//29.08.2025 navah1 #35274 - Start
	delete iter;
	iter := tiSet.createIterator;
    while iter.next(cargoOnsite) do
        //tempStr	:= 'Stop ' &amp; STOP_ID_TT.display &amp; Space &amp; stopsTableTT.heading.display &amp; ' not applied for cargo ' &amp; cargoOnsite.id;
		//self.assertEqualMsg(cargoOnsite.isStopSet(STOP_ID_TT), true, tempStr);
		tempStr	:= 'Stop ' &amp; STOP_ID_TT.display &amp; Space &amp; realStopsTable.heading.display &amp; ' still applied for cargo ' &amp; cargoOnsite.id;
		self.assertEqualMsg(cargoOnsite.isStopSet(STOP_ID_TT), false, tempStr);
    endwhile;
	realCustomsAction := app.myRoot.allEDIActions[UT_CustomsActionName];
	if realCustomsAction &lt;&gt; null then
		self.deleteEDIAction(UT_CustomsActionName, null, EDIKeyField_Clearance);
		self.assertIsDeleted(realCustomsAction);
		self.logMessage("Deleted Customs Action: Id:'" &amp; UT_CustomsActionName);
	endif;
	//29.08.2025 navah1 #35274 - End
	
epilog
	//reverting the stoptable changes
	/*
	beginTransaction;
	realStopsTable.setPropertyValue(CM_StopsTable::isNotAvailableForEntry.name, true);
	commitTransaction;
	*/
	delete bolList;
	delete iter;
	delete tiSet;
	delete cargoColl;
	delete imexStatusSet;
	delete pxyStopCriteria;
	delete processAreasArr;
	delete checkAreasArr;
	delete setAreasArr;
	delete pxyCustomsAction;
	delete pxyStopsTable; 
	delete cargoTypeSet;
	//disabling the config process onsite cargo matching house BOL for DTR 
	self.setTerminalConfig(ProcOnSiteForBOLDTR, isProcOnSiteForBOLDTR);
	self.setTerminalConfig(NoImportStops, noImportStops);
end;</source>
    </JadeMethod>
    <JadeMethod name="tTSWDTRTTB07" id="b0e85cfd-6713-4493-9439-5027c83655fa">
        <source>tTSWDTRTTB07();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
26 June 2023	navpw1	Initial creation TFS: 58831

*/

constants
	ROLE_CODE_TT					: String	= 'TT';
	ROLE_CODE_GC					: String	= 'GC';
	DECLARATION_PROCESSING_STATUS	: String	= 'B07';
	BLOCKSTACK						: String	= 'UTB' &amp; DECLARATION_PROCESSING_STATUS;
	MASTERBOL						: String	= "PMWLQ6952";		// Master BOL
	HOUSEBOL						: String	= "TLL014121";		// House BOL
	VESSEL							: String	= 'UTBOL' &amp; DECLARATION_PROCESSING_STATUS;
	VOYAGE							: String	= 'UT' &amp; self.TFS58831 &amp; "_" &amp; DECLARATION_PROCESSING_STATUS;
	OPERATOR						: String	= 'UTOP';
	USER_DEF_NAME					: String	= 'TSW';
	
	CONTAINERTEST1					: String	= self.TFS58831 &amp; "-" &amp; DECLARATION_PROCESSING_STATUS &amp; "-1";
	CONTAINERTEST2					: String	= self.TFS58831 &amp; "-" &amp; DECLARATION_PROCESSING_STATUS &amp; "-2";
	CONTAINERTEST3					: String	= self.TFS58831 &amp; "-" &amp; DECLARATION_PROCESSING_STATUS &amp; "-3";
	CONTAINERTEST4					: String	= self.TFS58831 &amp; "-" &amp; DECLARATION_PROCESSING_STATUS &amp; "-4";
	CONTAINER1						: String	= self.TFS58831 &amp; "-" &amp; DECLARATION_PROCESSING_STATUS &amp; "-5";
	CONTAINER2						: String	= self.TFS58831 &amp; "-" &amp; DECLARATION_PROCESSING_STATUS &amp; "-6";
	BOL1							: String	= "BOL120N28100-1";
	
	STOP_CODE_TT					: String	= "TSWTT";
	STOP_ID_TT						: Integer	= 875;
	STOP_HEADING_TT					: String	= "TSW TT HOLD " &amp; DECLARATION_PROCESSING_STATUS;
	CUSTOMS_ACTION_NAME_TT			: String	= "TSW TT " &amp; DECLARATION_PROCESSING_STATUS;
	CUSTOMS_ACTION_KEYWORD_TT		: String	= DECLARATION_PROCESSING_STATUS;
	
	STOP_CODE_GC					: String	= "TSWGC";
	STOP_ID_GC						: Integer	= 876;
	STOP_HEADING_GC					: String	= "TSW GC HOLD " &amp; DECLARATION_PROCESSING_STATUS;
	CUSTOMS_ACTION_NAME_GC			: String	= "TSW GC " &amp; DECLARATION_PROCESSING_STATUS;
	CUSTOMS_ACTION_KEYWORD_GC		: String	= DECLARATION_PROCESSING_STATUS;
	
vars
	blockStack						: CM_BlockStack;
	pxyStopsTableTT,
	realStopsTableTT,
	pxyStopsTableGC,
	realStopsTableGC,
	stopsTableMAF,
	stopsTableTT,
	stopsTableGC					: CM_StopsTable;
	vessel							: CM_Vessel;
	voyage							: CM_Voyage;
	operator						: CM_Operator;
	tiSet							: CM_TISet;
	ti1,
	ti2								: CM_TrackedItem;
	ediText, tempStr				: String;
	ediFile							: CM_EDIFile;
	ediTI							: CM_EDITrackedItem;
	ediStop							: CM_EDICustomStopTI;
	found1							: Boolean;
	pxyCustomsActionTT,
	realCustomsActionTT,
	pxyCustomsActionGC,
	realCustomsActionGC				: CM_EDIAction;
	
	pxyStopsTableTemplateTT,
	pxyStopsTableTemplateGC			: CM_StopTableTemplate;
	intArray						: IntegerArray;
	setArray						: IntegerArray;
	noImportStops,
	completedOk						: Boolean;
	
begin
	noImportStops := self.getTerminalConfig(NoImportStops).Boolean;
	self.setTerminalConfig(NoImportStops, true);
	self.assertTrueMsg(self.getTerminalConfig(NoImportStops).Boolean, "Terminal Config -&gt; Settings Tab -&gt; 'No Import Stops' should be set to true");
	
	// get rid of stuff - block stack, bols, voyage, vessel
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteVoyage(VOYAGE);
	self.deleteVessel(VESSEL);
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	
	//Get Operator
	operator := self.getOperator(OPERATOR);
	self.assertNotNull(operator);
	
	vessel := self.addVesselGeneralCargo(VESSEL, operator, 5);
	self.assertNotNull(vessel);
	
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL, OPERATOR, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 2);
	self.assertNotNull(voyage);
	
	//Delete TSW TT STOP
	stopsTableTT := self.getRoot.getStopTableForId(STOP_ID_TT);
	if stopsTableTT &lt;&gt; null then
		self.deleteStopsTable(STOP_ID_TT);
		self.assertIsDeletedMsg(stopsTableTT, "stopsTableTT");
	endif;
	
	//Delete TSW GC STOP
	stopsTableGC := self.getRoot.getStopTableForId(STOP_ID_GC);
	if stopsTableGC &lt;&gt; null then
		self.deleteStopsTable(STOP_ID_GC);
		self.assertIsDeletedMsg(stopsTableGC, "stopsTableGC");
	endif;
	
	//Get Stops Table MAF
	stopsTableMAF := self.getRoot.getStopTableForId(TI_Stop_MAF);
	
	//Create TSW TT STOP
	create pxyStopsTableTT transient;
	pxyStopsTableTT.setProxy(false, STOP_CODE_TT, STOP_HEADING_TT, STOP_CODE_TT, null, STOP_ID_TT, null, false, false, app.myRoot, null, app.myPassport.myUser.code, null);
	
	create pxyStopsTableTemplateTT transient;
	pxyStopsTableTemplateTT.setKeys( app.getMyTerminalDO_NOT_USE, pxyStopsTableTT );
	
	create intArray transient;
	create setArray transient;
	setArray.add(StopApplyExport);
	
	pxyStopsTableTemplateTT.setProxy(	intArray,
									setArray,
									intArray,
									null,									// Hold Voyages
									false,
									false,
									false,
									false,
									false,
									false,
									false,
									true);
	
	app.myTrxCA.trxCreateStopsTable(pxyStopsTableTT, realStopsTableTT, app.myPassport);
	self.assertNotNullMsg(realStopsTableTT, "realStopsTableTT");
	
	//Create TSW GC STOP
	create pxyStopsTableGC transient;
	pxyStopsTableGC.setProxy(false, STOP_CODE_GC, STOP_HEADING_GC, STOP_CODE_GC, null, STOP_ID_GC, null, false, false, app.myRoot, null, app.myPassport.myUser.code, null);
	
	create pxyStopsTableTemplateGC transient;
	pxyStopsTableTemplateGC.setKeys( app.getMyTerminalDO_NOT_USE, pxyStopsTableGC );
	
	delete intArray;
	delete setArray;
	
	create intArray transient;
	create setArray transient;
	setArray.add(StopApplyExport);
	
	pxyStopsTableTemplateGC.setProxy(	intArray,
									setArray,
									intArray,
									null,									// Hold Voyages
									false,
									false,
									false,
									false,
									false,
									false,
									false,
									true);
	
	app.myTrxCA.trxCreateStopsTable(pxyStopsTableGC, realStopsTableGC, app.myPassport);
	self.assertNotNullMsg(realStopsTableGC, "realStopsTableGC");
	
	//Delete Customs Action TT
	realCustomsActionTT := app.myRoot.allEDIActions[CUSTOMS_ACTION_NAME_TT];
	if realCustomsActionTT &lt;&gt; null then
		self.deleteEDIAction(CUSTOMS_ACTION_NAME_TT, null, EDIKeyField_Clearance);
		self.assertIsDeleted(realCustomsActionTT);
	endif;
	
	realCustomsActionTT := null;
	
	//Delete Customs Action GC
	realCustomsActionGC := app.myRoot.allEDIActions[CUSTOMS_ACTION_NAME_GC];
	if realCustomsActionGC &lt;&gt; null then
		self.deleteEDIAction(CUSTOMS_ACTION_NAME_GC, null, EDIKeyField_Clearance);
		self.assertIsDeleted(realCustomsActionGC);
	endif;
	
	realCustomsActionGC := null;
	
	//Create Customs Action TT
	create pxyCustomsActionTT transient;
	pxyCustomsActionTT.setProxy(CUSTOMS_ACTION_NAME_TT, CUSTOMS_ACTION_KEYWORD_TT, EDIKeyField_Clearance, EDIAction_Add, realStopsTableTT, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, "TT");
	app.myTrxCA.trxCreateEDIAction(pxyCustomsActionTT, realCustomsActionTT, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realCustomsActionTT, "realCustomsActionTT");
	
	//Create Customs Action GC
	create pxyCustomsActionGC transient;
	pxyCustomsActionGC.setProxy(CUSTOMS_ACTION_NAME_GC, CUSTOMS_ACTION_KEYWORD_GC, EDIKeyField_Clearance, EDIAction_Remove, realStopsTableTT, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, null);
	app.myTrxCA.trxCreateEDIAction(pxyCustomsActionGC, realCustomsActionGC, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realCustomsActionGC, "realCustomsActionGC");
	
	/*
	**	Test 1 Start - Test Role Code that is TT. Should add the TSW TT HOLD stop with stopId as 874
	*/
	
	/*
	** Setup
	*/
	create tiSet transient;
	
	// create cargo - two containers
	ti1 := self.addContainerAtLocation(CONTAINERTEST1, operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.myLocationsController);
	ti2 := self.addContainerAtLocation(CONTAINERTEST2, operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.myLocationsController);
	
	tiSet.add(ti1);
	tiSet.add(ti2);
	
	// assign house bol number and voyage
	beginTransaction;
	foreach ti1 in tiSet do
		ti1.setPropertyValue(CM_TrackedItem::houseBillOfLading.name, BOL1);
		ti1.setMyVoyage(voyage, app.myPassport);
	endforeach;
	commitTransaction;
	
	self.assertEqualMsg(voyage.allTisByHouseBol.size, 2, "Test 1 - Voyage has incorrect number of House BOL TIs");
	
	// edi text - one master BOL (which JMT ignores) and 1 house BOl (but 2 house BOL segments with the same BOL number)
	ediText := 
'&lt;DocumentMetaData xmlns="urn:wco:datamodel:WCO:DM:1"&gt;
  &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
  &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
  &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
  &lt;AgencyAssignedCustomizedDocumentName&gt;RESICR&lt;/AgencyAssignedCustomizedDocumentName&gt;
  &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.0&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
  &lt;CommunicationMetaData&gt;
  
    &lt;Recipient&gt;
      &lt;ID&gt;40513451K&lt;/ID&gt;
      &lt;RoleCode&gt;' &amp; ROLE_CODE_TT &amp; '&lt;/RoleCode&gt;
    &lt;/Recipient&gt;
  &lt;/CommunicationMetaData&gt;
  &lt;Response xmlns="urn:wco:datamodel:WCO:ResponseModel:1"&gt;
    &lt;IssueDateTime formatCode="204"&gt;20200120091629&lt;/IssueDateTime&gt;
    &lt;FunctionalReferenceID&gt;20414&lt;/FunctionalReferenceID&gt;
    &lt;FunctionCode&gt;24&lt;/FunctionCode&gt;
    &lt;AdditionalDocument&gt;
      &lt;CategoryCode&gt;BAC&lt;/CategoryCode&gt;
      &lt;ImageBinaryObject mimeCode="application/pdf" uri="idd_E41D6A50-4381-4388-B61B-445801BE6537" filename="PDF7-49861192-2020-01-20-0901194016.pdf"&gt;Attached&lt;/ImageBinaryObject&gt;
    &lt;/AdditionalDocument&gt;
    &lt;OverallDeclaration&gt;
    
      &lt;Declaration&gt;
        &lt;ID&gt;49861192&lt;/ID&gt;
        &lt;AcceptanceDateTime formatCode="204"&gt;20200120091629&lt;/AcceptanceDateTime&gt;
        &lt;FunctionalReferenceID&gt;468&lt;/FunctionalReferenceID&gt;
        &lt;VersionID&gt;1&lt;/VersionID&gt;
        &lt;Submitter&gt;
        
          &lt;Name&gt;Maersk A S&lt;/Name&gt;
        &lt;/Submitter&gt;
        &lt;BorderTransportMeans&gt;
          &lt;Name&gt;' &amp; VESSEL &amp; '&lt;/Name&gt;
          &lt;ID&gt;9297852&lt;/ID&gt;
          &lt;TypeCode&gt;1&lt;/TypeCode&gt;
