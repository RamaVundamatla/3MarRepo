    <JadeMethod name="includeObject" id="abf618ea-0e65-42cf-a883-7ffc2c67542c">
        <updating/>
        <source>includeObject(_ti : CM_TrackedItem; _passport: CM_Passport): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Mar 2025	navnk30	JIRA 14605: EUP | Implement Satellite View of Large Dataset Display using "displayCollection"

*/

vars
	filterCargoId	: String;
	filterCargoType	: CM_CargoType;
	filterProduct	: CM_Product;
	filterISOType	: CM_ISOType;
begin
	filterCargoId	:= tblSearch.getValueByName(ETRow_FilterId).String[1:20];
	filterCargoType	:= self.cmbCargoType.listObject.CM_CargoType;
	filterProduct	:= self.cmbCargoSubtype.listObject.CM_Product;
	filterISOType	:= self.cmbIsoType.listObject.CM_ISOType;
	if filterCargoId &lt;&gt; null and not _ti.id.startsWith(filterCargoId) and not _ti.id.endsWith(filterCargoId) then
		return false;
	elseif filterCargoType &lt;&gt; null and _ti.myCargoType &lt;&gt; filterCargoType then
		return false;
	elseif filterProduct &lt;&gt; null and _ti.myProduct &lt;&gt; filterProduct then
		return false;
	elseif filterISOType &lt;&gt; null and (not _ti.isContainer() or _ti.CM_Container.isoType &lt;&gt; filterISOType.code) then
		return false;
	else
		return true;
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initTblData" id="4ee04a19-8156-4839-b17a-cc74bf6a06c6">
        <source>initTblData();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Mar 2025	navnk30	JIRA 14605: EUP | Implement Satellite View of Large Dataset Display using "displayCollection"

*/

vars
	entDef		: EntTableDef;
	tbl			: CM_DataTable;
	form		: CM_BaseForm;
begin
	entDef := app.myController.getEntTableDef(ETDef_CargoEnqDefaultData);
	if entDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntDef ETDef_CargoQuickViewData not found');
		return;
	endif;
	
	form := self;
	tbl := self.tblData;
	tbl.accessRow(1).backColor := self.colorHeadingColumn;
	tbl.selectMode := Table.SelectMode_CurrentRow;
	tbl.selectionType := CM_DataTable.SelectionType_Row;
	tbl.colourRows(self.colorRow1, self.colorRow2);
	tbl.setMyEntTableDef(entDef);
	tbl.setTblDataEntRowsFromDef(entDef);
	tbl.selectionType := Table.SelectMode_FixedRow;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="rowPostprocess" id="c276716c-772c-400f-9efc-ff63bda9dfd5">
        <updating/>
        <source>rowPostprocess(_dataTable: CM_DataTable io; idx: Integer; _obj: Object) : Boolean  updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 July 2025	jlier1	Initial creation 34771

*/

vars

begin
	self.beginNotification(_obj, Any_System_Event, Response_Continuous, 0);
	
	return true;
epilog

end;</source>
        <Parameter name="_dataTable" type="CM_DataTable" usage="io"/>
        <Parameter name="idx" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
