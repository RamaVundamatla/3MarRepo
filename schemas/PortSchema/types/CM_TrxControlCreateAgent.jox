    <JadeMethod name="trxCreateReeferReadings" id="afa72ba4-e470-4d0e-b492-8e6d95ddff09">
        <updating/>
        <source>trxCreateReeferReadings(	_tempParams : CMIF_TempReading input; 
							_humidParams: CMIF_HumidReading input; 
							_ventParams : CMIF_VentReading input; 
							_co2Params : CMIF_CO2Reading input;
							_o2Params : CMIF_O2Reading input;
							_connectTime: TimeStamp; 
							_passport: CM_Passport input	) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/03/2015	cnwdap1		Initial creation PAR #35874 TFS 265 
// 18/09/2017	jlgmd1		TFS 6813 - QNS - Jade application slow
// 22/09/2017	cnwhl1		TFS 7067 - reefer temp discrepancy
// 16/01/2026	navdap1		MTN-36569 CPL | Reefer Runner Integration
//
vars
	tempController			: CMIF_TempTransController;
	tempDifference			: Real;
	realTi					: CM_TrackedItem;
	tempReading				: CM_TempReading;
	tempReadingTransaction	: CM_TITransaction;
	humidController			: CMIF_HumidTransController;
	humidReading			: CM_HumidReading;
	humidReadingTransaction	: CM_TITransaction;
	ventController			: CMIF_VentTransController;
	ventReading				: CM_VentReading;
	ventReadingTransaction	: CM_TITransaction;
	lastReading				: CM_TempReading;
	/// MTN-36569 variables
	co2Reading				: CM_CO2Reading;
	co2Controller			: CMIF_CO2TransController;
	co2ReadingTransaction	: CM_TITransaction;
	o2Reading				: CM_O2Reading;
	o2Controller			: CMIF_O2TransController;
	o2ReadingTransaction	: CM_TITransaction;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	
	_passport.useTITransactionDeferUpdate := true;		// TFS 6813
	_passport.useTIDictDeferUpdate := true;				// TFS 6813
	
	beginTransaction;
	//create temperature reading
	if _tempParams &lt;&gt; null then
	
		// tfs 7067 - if new temp is +- 10degC throw warning
		realTi := _tempParams.myTrackedItem.pxyGetRealObject();	
		lastReading := realTi.getLastTempReading;
		if lastReading &lt;&gt; null and lastReading.getTemperatureValue() &lt;&gt; NULL_TEMPERATURE then
			tempDifference := lastReading.getTemperatureValue() - _tempParams.temperature;
			if tempDifference &gt;= 10 or tempDifference &lt;= -10 then
				app.raiseCMWarning(Reefer_temp_difference, null, null, null);
			endif;
		endif;
	
		tempReading := app.myUtilityCA.utlCreateTempReading(_tempParams, _passport);
	
		if _passport.noErrors then
			//create temperature TItrans
			create tempController transient;
			_tempParams.setTITransController(tempController);
			tempController.myTempReading := tempReading;
			app.myUtilityCA.utlCreateTITransaction(tempController, tempReadingTransaction, _passport);
		endif;
	endif;
	
	if not _passport.noErrors then
		return;
	endif;
	
	// create humidity reading
	if _humidParams &lt;&gt; null then
		humidReading := app.myUtilityCA.utlCreateHumidityReading(_humidParams, _passport);
	
		if _passport.noErrors then
			//create humidity reading TItrans
			create humidController transient;
			_humidParams.setTITransController(humidController);
			humidController.myHumidReading := humidReading;
			app.myUtilityCA.utlCreateTITransaction(humidController, humidReadingTransaction, _passport);
		endif;
	endif;
	
	// create ventilation reading
	if _ventParams &lt;&gt; null then
		ventReading := app.myUtilityCA.utlCreateVentilationReading(_ventParams, _passport);
	
		if _passport.noErrors then
			//create ventilation reading TItrans
			create ventController transient;
			_ventParams.setTITransController(ventController);
			ventController.myVentReading := ventReading;
			app.myUtilityCA.utlCreateTITransaction(ventController, ventReadingTransaction, _passport);
		endif;
	endif;
	
	// MTN-36569 Create CO2 reading
	if _co2Params &lt;&gt; null then
		co2Reading := app.myUtilityCA.utlCreateCO2Reading(_co2Params, _passport);
		if _passport.noErrors() then
			// Create CO2 reading TI transaction
			create co2Controller transient;
			_co2Params.setTITransController(co2Controller);
			co2Controller.myCO2Reading := co2Reading;
			app.myUtilityCA.utlCreateTITransaction(co2Controller, co2ReadingTransaction, _passport);
		endif;
	endif;
	
	// MTN-36569 Create O2 reading
	if _o2Params &lt;&gt; null then
		o2Reading := app.myUtilityCA.utlCreateO2Reading(_o2Params, _passport);
		if _passport.noErrors() then
			// Create O2 reading TI transaction
			create o2Controller transient;
			_o2Params.setTITransController(o2Controller);
			o2Controller.myO2Reading := o2Reading;
			app.myUtilityCA.utlCreateTITransaction(o2Controller, o2ReadingTransaction, _passport);
		endif;
	endif;
	
	if _passport.noErrors then				// TFS 6813
		_passport.doDeferredUpdates();		// TFS 6813
	endif;									// TFS 6813
	
epilog
	self.finaliseActivityWithPassport(_passport);
	delete tempController;
	delete humidController;
	delete ventController;
	delete co2Controller;		// MTN-36569
	delete o2Controller;		// MTN-36569
end;</source>
        <Parameter name="_tempParams" type="CMIF_TempReading" usage="input"/>
        <Parameter name="_humidParams" type="CMIF_HumidReading" usage="input"/>
        <Parameter name="_ventParams" type="CMIF_VentReading" usage="input"/>
        <Parameter name="_co2Params" type="CMIF_CO2Reading" usage="input"/>
        <Parameter name="_o2Params" type="CMIF_O2Reading" usage="input"/>
        <Parameter name="_connectTime" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
