    <JadeMethod name="xDischCCDischLOLOSOB" id="bc2f3649-f22c-482b-b264-11d031a95bff">
        <source>xDischCCDischLOLOSOB(_voyage : CM_Voyage);

/*

Purpose:		Discharge CC, Discharge LOLO containers

Date			Who		Reason
04/03/2013		cnwmh5	Initial creation

*/

constants

	BlockStackId					: String = "UTMH11";
	CTAId							: String = "UTC1A1";
	CraneId							: String = "UTZ1";
	
vars

	tmpLoadCC						: CMIF_LoadColorCode;
	voyageDischJob					: CM_VoyageJob;
	voyageLoadJob					: CM_VoyageJob;
	crane							: CM_Machine;
	blockStack						: CM_BlockStack;
	cta								: CM_CraneTransferArea;
	cargo							: CM_TrackedItem;
	wle								: CM_WorkListEntry;
	request							: CM_Request;
	slot							: CM_SlotController;
	theSlot 						: CM_LocationsController;

	slotsFrom						: CM_SlotControllerArray;
	slotsTo							: CM_SlotControllerArray;
	allObjectEditions				: CM_ObjectByOidEditionDict;	
		
	strs	 						: StringArray;
	tas								: StringArray;
	requireDischarge				: CM_TISet;
	requireSOBMove					: CM_TISet;
	tis								: CM_TIArray;
	
	idx								: Integer;
	locationStr						: String;

begin

	// create the block stack
	self.deleteTerminalArea(BlockStackId);
	blockStack := addBlockStack(BlockStackId, 20, null);
	
	// create the crane transfer area
	self.deleteMachine(CraneId);
	self.deleteTerminalArea(CTAId);
	cta := self.addCraneTransferArea(CTAId);
	self.assertNotNull(cta);
	
	// add the crane
	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	crane := self.addCrane(CraneId, null, tas, null);
	self.assertNotNull(crane);

	// colour code the discharge slots
	create slotsFrom transient;
	self.getJobSlotControllers(_voyage.code, "01", DeckOnDeck, 1, 2, 1, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D40);
	
	self.getJobSlotControllers(_voyage.code, "01", DeckOnDeck, 2, 1, 3, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D40);
	
	self.getJobSlotControllers(_voyage.code, "01", DeckOnDeck, 3, 1, 3, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	
	self.getJobSlotControllers(_voyage.code, "01", DeckOnDeck, 4, 1, 2, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	
	voyageDischJob := self.addVoyageJob(_voyage, crane.id, slotsFrom, true);
	assertTrue(voyageDischJob &lt;&gt; null);
	
	// discharge the following slots
	self.loadAllJobsToOps(_voyage, true);
	
	// queue the cargo
	create requireDischarge transient;
	requireDischarge.add(_voyage.allOnshipTIsByCargoTypeId[1, "UTMDHDF0012"]);
	requireDischarge.add(_voyage.allOnshipTIsByCargoTypeId[1, "UTMDHDF0013"]);
	requireDischarge.add(_voyage.allOnshipTIsByCargoTypeId[1, "UTMDHDF0014"]);
	requireDischarge.add(_voyage.allOnshipTIsByCargoTypeId[1, "UTMDHDF0002"]);
	requireDischarge.add(_voyage.allOnshipTIsByCargoTypeId[1, "UTMDHDF0003"]);
	
	// Queue the required containers
	slotsFrom.clear();
	foreach request in voyageDischJob.allRequests do
		foreach wle in request.allWorkListEntries do
			if wle.CM_VoyageWLE.myRequest.CM_SlotRequest.isDischarge then
				if requireDischarge.includes(wle.myTrackedItem) then
					slotsFrom.add(wle.CM_VoyageWLE.myRequest.CM_SlotRequest.mySlotController);
					self.autoplanWLE(wle);
					self.deleteStops(wle.myTrackedItem);
					self.moveQueuedCargo(wle);
				endif;
			endif;
		endforeach;
	endforeach;
	
	// check that there are not ti's currently in the following slots
	create tis transient;
	foreach slot in slotsFrom do
		slot.getTIs(tis, REAL_MODE, true);
		self.assertEqualMsg(tis.size, 0, slot.ident &amp; " still has tis in it");
	endforeach;

	
	/********************************************************************
		Right time to colour code and move SOB's
	*********************************************************************/
	
	// colour code the load slots
	create slotsTo transient;
	self.getJobSlotControllers(_voyage.code, "01", DeckOnDeck, 1, 2, 1, slotsTo);
	self.markSlotsAsLoadJob(slotsTo, tmpLoadCC);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_D40);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_SOB);
	self.getJobSlotControllers(_voyage.code, "01", DeckOnDeck, 2, 2, 1, slotsTo);
	self.markSlotsAsLoadJob(slotsTo, tmpLoadCC);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_D40);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_SOB);
	self.getJobSlotControllers(_voyage.code, "01", DeckOnDeck, 3, 2, 1, slotsTo);
	self.markSlotsAsLoadJob(slotsTo, tmpLoadCC);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_SOB);
	self.getJobSlotControllers(_voyage.code, "03", DeckOnDeck, 2, 1, 1, slotsTo);
	self.markSlotsAsLoadJob(slotsTo, tmpLoadCC);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_SOB);
	
	// colour code the discharge slots
	slotsFrom.clear();
	self.getJobSlotControllers(_voyage.code, "01", DeckOnDeck, 1, 3, 1, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D40);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_SOB);
	self.getJobSlotControllers(_voyage.code, "01", DeckOnDeck, 5, 1, 3, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_SOB);
	voyageDischJob := self.addVoyageJob(_voyage, crane.id, slotsFrom, true);
	assertTrue(voyageDischJob &lt;&gt; null);
	
		// link the slots
	create allObjectEditions transient;
	foreach slot in slotsFrom do
		allObjectEditions.add(slot);
	endforeach;
	foreach slot in slotsTo do
		allObjectEditions.add(slot);
	endforeach;
	app.myTrxUA.trxUpdateSlotReqLinkSOBDLR2(slotsFrom, slotsTo, allObjectEditions, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// discharge the following slots
	self.loadAllJobsToOps(_voyage, true);
	
	// queue the cargo
	create requireSOBMove transient;
	requireSOBMove.add(_voyage.allOnshipTIsByCargoTypeId[1, "UTMDHDF0010"]);
	requireSOBMove.add(_voyage.allOnshipTIsByCargoTypeId[1, "UTMDHDF0009"]);
	requireSOBMove.add(_voyage.allOnshipTIsByCargoTypeId[1, "UTMDHDF0008"]);
	requireSOBMove.add(_voyage.allOnshipTIsByCargoTypeId[1, "UTMDHDF0007"]);
	
	// Queue the required containers
	slotsFrom.clear();
	create strs transient;
	foreach request in voyageDischJob.allRequests do
		foreach wle in request.allWorkListEntries do
			if wle.CM_VoyageWLE.myRequest.CM_SlotRequest.isDischarge then
				slotsFrom.add(wle.CM_VoyageWLE.myRequest.CM_SlotRequest.mySlotController);
				self.deleteStops(wle.myTrackedItem);
				self.move(wle.myTrackedItem, wle.CM_VoyageWLE.myRequest.CM_SlotRequest.myRequestLinkedLoad.CM_SlotRequest.mySlotController);
				beginTransaction;
				wle.setStatus(WLE_COMPLETED);
				commitTransaction;
			endif;
		endforeach;
	endforeach;
	
	// check that the sob's are now in the correct locations
	cargo := _voyage.allOnshipTIsByCargoTypeId[1, "UTMDHDF0010"];
	locationStr := cargo.getPrimaryLocationId(REAL_MODE).trimBlanks();
	self.assertEqualMsg(locationStr, "VOYLOLOSOB 021086", "Container (" &amp; cargo.id &amp; ") is not at location 021086 but at location " &amp; locationStr);
	cargo := _voyage.allOnshipTIsByCargoTypeId[1, "UTMDHDF0009"];
	locationStr := cargo.getPrimaryLocationId(REAL_MODE).trimBlanks();
	self.assertEqualMsg(locationStr, "VOYLOLOSOB 010886", "Container (" &amp; cargo.id &amp; ") is not at location 010886 but at location " &amp; locationStr);
	cargo := _voyage.allOnshipTIsByCargoTypeId[1, "UTMDHDF0008"];
	locationStr := cargo.getPrimaryLocationId(REAL_MODE).trimBlanks();
	self.assertEqualMsg(locationStr, "VOYLOLOSOB 010686", "Container (" &amp; cargo.id &amp; ") is not at location 010686 but at location " &amp; locationStr);
	cargo := _voyage.allOnshipTIsByCargoTypeId[1, "UTMDHDF0007"];
	locationStr := cargo.getPrimaryLocationId(REAL_MODE).trimBlanks();
	self.assertEqualMsg(locationStr, "VOYLOLOSOB 030884", "Container (" &amp; cargo.id &amp; ") is not at location 030884 but at location " &amp; locationStr);
	
epilog

	delete slotsFrom;
	delete slotsTo;
	delete tas;
	delete requireDischarge;
	delete tis;
	delete allObjectEditions;	
	delete requireSOBMove;
	delete strs;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="xDischCCDischSOBLOLOSOB" id="bdd9ba51-8e0a-4343-a197-ead08739bce5">
        <source>xDischCCDischSOBLOLOSOB(_voyage : CM_Voyage);

/*

Purpose:		Discharge CC, Discharge the SOB containers

Date			Who		Reason
04/03/2013		cnwmh5	Initial creation

*/

constants

	BlockStackId					: String = "UTMH11";
	CraneId							: String = "UTZ1";
	
vars

	tmpLoadCC						: CMIF_LoadColorCode;
	voyageDischJob					: CM_VoyageJob;
	crane							: CM_Machine;
	blockStack						: CM_BlockStack;
	wle								: CM_WorkListEntry;
	request							: CM_Request;
	slot							: CM_SlotController;

	slotsFrom						: CM_SlotControllerArray;
		
	strs	 						: StringArray;
	tas								: StringArray;
	requireDischarge				: CM_TISet;
	tis								: CM_TIArray;
	
begin

	// get block stack
	blockStack := self.getTerminal().allTerminalAreas[BlockStackId].CM_BlockStack;
	self.assertNotNull(blockStack);
	
	// get the crane previously used
	crane := self.getCrane(CraneId);
	self.assertNotNull(crane);

	// colour code the discharge slots
	create slotsFrom transient;
	self.getJobSlotControllers(_voyage.code, "01", DeckOnDeck, 1, 2, 1, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D40);
	
	self.getJobSlotControllers(_voyage.code, "01", DeckOnDeck, 2, 2, 1, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	
	self.getJobSlotControllers(_voyage.code, "01", DeckOnDeck, 3, 2, 1, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	
	self.getJobSlotControllers(_voyage.code, "03", DeckOnDeck, 2, 1, 1, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	
	voyageDischJob := self.addVoyageJob(_voyage, crane.id, slotsFrom, true);
	assertTrue(voyageDischJob &lt;&gt; null);
	
	// discharge the following slots
	self.loadAllJobsToOps(_voyage, true);
	
	// queue the cargo
	create requireDischarge transient;
	requireDischarge.add(_voyage.allOnshipTIsByCargoTypeId[1, "UTMDHDF0010"]);
	requireDischarge.add(_voyage.allOnshipTIsByCargoTypeId[1, "UTMDHDF0009"]);
	requireDischarge.add(_voyage.allOnshipTIsByCargoTypeId[1, "UTMDHDF0008"]);
	requireDischarge.add(_voyage.allOnshipTIsByCargoTypeId[1, "UTMDHDF0007"]);
	
	// Queue the required containers
	slotsFrom.clear();
	foreach request in voyageDischJob.allRequests do
		foreach wle in request.allWorkListEntries do
			if wle.CM_VoyageWLE.myRequest.CM_SlotRequest.isDischarge then
				if requireDischarge.includes(wle.myTrackedItem) then
					slotsFrom.add(wle.CM_VoyageWLE.myRequest.CM_SlotRequest.mySlotController);
					self.autoplanWLE(wle);
					self.deleteStops(wle.myTrackedItem);
					self.moveQueuedCargo(wle);
				endif;
			endif;
		endforeach;
	endforeach;
	
	// check that there are not ti's currently in the following slots
	create tis transient;
	foreach slot in slotsFrom do
		slot.getTIs(tis, REAL_MODE, true);
		self.assertEqualMsg(tis.size, 0, slot.ident &amp; " still has tis in it");
	endforeach;
	
	
epilog

	delete slotsFrom;
	delete tas;
	delete requireDischarge;
	delete tis;
	delete strs;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="xPlanningWarningOnOversize" id="259b501b-bff9-432e-bac6-4db7b9b70e48">
        <updating/>
        <source>xPlanningWarningOnOversize(_voyage : CM_Voyage io; _ti : CM_TrackedItem; _jobSlotContrDetails, _allocationDetails : String; _isLOLO, _isLoad : Boolean;
		_expectedError : Integer) updating;

/*

Purpose:		

Date			Who		Reason
23/07/2015		cnwmh5	Initial creation

*/

vars

	voyageJob					: CM_VoyageJob;
	realAlloc 					: CM_VoyageAllocation;
	request						: CM_Request;
	wle							: CM_WorkListEntry;
	ti							: CM_TrackedItem;
	lc 							: CM_ROROSlotController;
	deck						: CM_DeckVoyage;
	tempLoadCC					: CMIF_LoadColorCode;
	slot						: CM_LocationsController;
	
	detailsArray				: HugeStringArray;
	tiArray						: CM_TIArray;
	wles 						: CM_WLEArray;
	slots 						: CM_SlotControllerArray;
	altSlots					: CM_SlotControllerArray;
	slotsRORO					: CM_SlotControllerArray;
	theSlots					: CM_LCArray;
	theAltSlots					: CM_LCArray;
	
	breakout1					: Boolean;
	breakout2					: Boolean;
	breakout3					: Boolean;

begin

	self.assertNotNull(_jobSlotContrDetails);
	self.assertNotNull(_allocationDetails);

	breakout1 := self.opts.bool("BreakOut1");
	breakout2 := self.opts.bool("BreakOut2");
	breakout3 := self.opts.bool("BreakOut3");
	
	create detailsArray transient;
	_jobSlotContrDetails.getTokensForDelimiterHuge(",", detailsArray);
	self.assertFalse(detailsArray.size &lt; 5 and _isLOLO);
	self.assertFalse(detailsArray.size &lt; 3 and not _isLOLO);

	self.opts.purge();
	
	create slots transient;
	create altSlots transient;
	create theSlots transient;
	create slotsRORO transient;
	if _isLOLO then
		self.getJobSlotControllers(_voyage.code, 
								detailsArray[1], 				// Bay Number
								detailsArray[2].Integer, 		// Start Deck
								detailsArray[3].Integer, 		// Start Cell
								detailsArray[4].Integer, 		// Start Tier
								detailsArray[5].Integer, 		// Number to find
								slots);
	else
		deck := _voyage.myROROStructure.allDecksByCode[detailsArray[1]];
		self.assertNotNull(deck);
		self.getJobROROControllerByID(_voyage.code, deck.code, null, detailsArray[3], theSlots, _isLoad, 1);
		self.assertTrue(theSlots.size &gt; 0);
	endif;
	
	detailsArray.clear();
	_allocationDetails.getTokensForDelimiterHuge(",", detailsArray);
	self.assertFalse(detailsArray.size &lt; 6);
	
	realAlloc := self.addVoyageAllocation(_voyage, 
										   detailsArray[1], 			// Port
										   detailsArray[2],				// ISO Group Code
										   detailsArray[3],				// Commodity
										   detailsArray[4].Integer, 	// Cargo Type
										   detailsArray[5].Boolean,		// Requires Power
										   detailsArray[6].Boolean);	// Is OD
	self.assertNotNull(realAlloc);
											   
	if _isLOLO then
		if not _isLoad then
			self.markSlotsAsDischargeCC(slots, tempLoadCC, CM_SlotRequest.Attribute_D20);
		endif;
		self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);
		voyageJob := self.addVoyageJob(_voyage, "CRN1", slots, not _isLoad);
	else
		if not _isLoad then
			beginTransaction;
			foreach slot in theSlots do
				slot.CM_ROROSlotController.createDefaultDischargeCC(app.myPassport, true);
			endforeach;
			commitTransaction;
		endif;
		self.addLCsToROROAllocation(true, realAlloc, theSlots, theAltSlots, 1);
		voyageJob := self.addVoyageROROJob(_voyage, deck, "UTMHWPOD", theSlots, not _isLoad);
	endif;
	self.assertNotNull(voyageJob);
	
	if breakout2 then
		return;
	endif;
	
	create tiArray transient;
	tiArray.add(_ti);
	
	self.clearExpectedTrxErrors();
	if _expectedError &lt;&gt; null then
		self.expectedTrxErrors.add(_expectedError);
	endif;
	
	if _isLOLO then
		self.opts.purge();
		self.opts.addAssoc("DontIgnoreWarnings", true);
		self.planTIsLOLO(tiArray, slots, _voyage, true);
	else
		self.planTIsRORO(tiArray, theSlots, realAlloc.CM_VoyageAllocation.allRequests.first.CM_RORORequest);
	endif;
	
	self.clearExpectedTrxErrors();
	
	if breakout3 then
		return;
	endif;
	
	self.opts.purge();
	if _isLOLO then
		self.planTIsLOLO(tiArray, slots, _voyage, true);
	endif;
	
	if breakout1 then
		return;
	endif;
	
	create wles transient;
	
	self.clearExpectedTrxErrors();
	if _expectedError &lt;&gt; null then
		self.expectedTrxErrors.add(_expectedError);
	endif;
	
	request := voyageJob.allRequests.first;
	self.assertNotNull(request);
	wle := request.allWorkListEntries.first.CM_VoyageWLE;
	if _isLOLO then
		if wle.CM_VoyageWLE.myRequest.CM_SlotRequest.isLoad then
			wles.add(wle);
		endif;
	else
		if wle.CM_VoyageWLE.myRequest.CM_ROROSlotRequest.isLoad then
			wles.add(wle);
		endif;
	endif;
	self.queueWLE(wle);
	
	self.clearExpectedTrxErrors();
	
	app.myPassport.setWarningsAcknowledged(true);
	app.myPassport.setWarningsIgnored(true);
	self.queueWLE(wle);
	app.myPassport.setWarningsAcknowledged(false);
	app.myPassport.setWarningsIgnored(false);
	
	self.clearExpectedTrxErrors();
	if _expectedError &lt;&gt; null then
		self.expectedTrxErrors.add(_expectedError);
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("DontIgnoreWarnings", true);
	self.opts.addAssoc("ExpectErrors", self.expectedTrxErrors.size &gt; 0);
	if _isLOLO then
		self.move(_ti, slots.first);
	else
		self.move(_ti, theSlots.first);
	endif;
	
	self.clearExpectedTrxErrors();
	
	app.myPassport.setWarningsAcknowledged(true);
	app.myPassport.setWarningsIgnored(true);
	self.moveIT(_ti, REAL_MODE);
	app.myPassport.setWarningsAcknowledged(false);
	app.myPassport.setWarningsIgnored(false);

epilog

	app.myPassport.setWarningsAcknowledged(false);
	app.myPassport.setWarningsIgnored(false);

	delete detailsArray;
	delete slots;
	delete altSlots;
	delete tiArray;
	delete wles;
	delete theSlots;
	delete theAltSlots;
	delete tempLoadCC;
	delete slotsRORO;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="io"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_jobSlotContrDetails" type="String"/>
        <Parameter name="_allocationDetails" type="String"/>
        <Parameter name="_isLOLO" type="Boolean"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_expectedError" type="Integer"/>
    </JadeMethod>
</Class>
