    <JadeMethod name="getCheckTypeDescription" id="d66db315-48bd-4b05-9393-1f5c82da6361">
        <source>getCheckTypeDescription() : String;
/*
Purpose:			
Date		Who		Reason
14 September 2016	cnwab1	Initial creation
*/

vars

begin
	if self.checkType = CMIF_InvoiceHealthAgent.CheckType_Bank then
		return "Business Unit";
	elseif self.checkType = CMIF_InvoiceHealthAgent.CheckType_CalcType then
		return "Calculation Type";
	elseif self.checkType = CMIF_InvoiceHealthAgent.CheckType_InvoiceType then
		return "Invoice Type";
	elseif self.checkType = CMIF_InvoiceHealthAgent.CheckType_MinCharge then
		return "Minimum Charge";
	elseif self.checkType = CMIF_InvoiceHealthAgent.CheckType_Service then
		return "Services";
	elseif self.checkType = CMIF_InvoiceHealthAgent.CheckType_TranMapCargo then
		return "Cargo Transaction Map";
	elseif self.checkType = CMIF_InvoiceHealthAgent.CheckType_TranMapEvent then
		return "Event Transaction Map";
	elseif self.checkType = CMIF_InvoiceHealthAgent.CheckType_TranMapVoyage then
		return "HMS Transaction Map";
	elseif self.checkType = CMIF_InvoiceHealthAgent.CheckType_TranMapAlloc then
		return "Allocation Transaction Map";
	elseif self.checkType = CMIF_InvoiceHealthAgent.CheckType_TranMapSummary then
		return "Summary Transaction Map";
	elseif self.checkType = CMIF_InvoiceHealthAgent.CheckType_GLCode then
		return "GL Code";
	elseif self.checkType = CMIF_InvoiceHealthAgent.CheckType_Tax then
		return "Tax Code";
	elseif self.checkType = CMIF_InvoiceHealthAgent.CheckType_HookQuantity then
		return "Hook Code Quantity";
	elseif self.checkType = CMIF_InvoiceHealthAgent.CheckType_HookRate then
		return "Hook Code Rate";
	elseif self.checkType = CMIF_InvoiceHealthAgent.CheckType_Calendar then
		return "Calendar";
	elseif self.checkType = CMIF_InvoiceHealthAgent.CheckType_Measure then
		return "Measurement Type";
	elseif self.checkType = CMIF_InvoiceHealthAgent.CheckType_InvoiceLineType then
		return "Invoice Line Type";
	elseif self.checkType = CMIF_InvoiceHealthAgent.CheckType_FinancialPeriods then
		return "Financial Periods";
	elseif self.checkType = CMIF_InvoiceHealthAgent.CheckType_TermsTrade then
		return "Terms of Trade";
	endif;
	
	
	
	return "UNKNOWN";
		
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="c23259b9-68c4-42b9-bd59-2f64295dbb90">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:			
Date		Who		Reason
14 September 2016	cnwab1	Initial creation
*/

vars
	bu : CM_Bank;
begin

	if _attrName = ETRow_Terminal then
		if self.myTerminal = null then
			if self.itemType = CMIF_InvoiceHealthAgent.ItemType_CalculationType then
				return "System";
			else
				return "NULL";
			endif;
		else
			return self.myTerminal.code;
		endif;
	elseif _attrName = ETRow_ItemType then
		return self.getItemTypeDescription();
	elseif _attrName = ETRow_Description then
		return self.description;
	elseif _attrName = ETRow_CheckType then
		return self.getCheckTypeDescription();
	elseif _attrName = ETRow_ResultType then
		return self.getResultTypeDescription;
	elseif _attrName = ETRow_BusinessUnit then
		if self.itemType = CMIF_InvoiceHealthAgent.ItemType_CalculationType then
			return "System";
		else
			bu := self.mySubject.CM_FinancialObject.getBank();
			if bu &lt;&gt; null then
				return bu.code;
			endif;
			return "NULL";
		endif;
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getItemTypeDescription" id="f38332ef-1891-4b88-9260-79094e50f634">
        <source>getItemTypeDescription() : String;
/*
Purpose:			
Date		Who		Reason
14 September 2016	cnwab1	Initial creation
*/

vars
	tranmap : CM_TranMap;
	emap : CM_TranMapEvent;
	vmap : CM_TranMapVoyage;
	amap : CM_TranMapCargoAllocation;
	smap : CM_TranMapSSSummary;
	rmap : CM_ResourceType;
	mapname : String;
	pos : Integer;
begin
	if self.itemType = CMIF_InvoiceHealthAgent.ItemType_InvoiceLineType then
		return "Invoice Line Type";
	elseif self.itemType = CMIF_InvoiceHealthAgent.ItemType_Service then
		return "Service";
	elseif self.itemType = CMIF_InvoiceHealthAgent.ItemType_InvoiceType then
		return "Invoice Type";
	elseif self.itemType = CMIF_InvoiceHealthAgent.ItemType_CalculationType then
		return "Calculation Type";
	elseif self.itemType = CMIF_InvoiceHealthAgent.ItemType_TranMapCargo then
		if self.mySubject.isKindOf(CM_QuantityMap) then // SUB QUANTITY RANGE
		
			mapname := self.mySubject.CM_QuantityMap.getTranMapBreadCrumb();
			pos := mapname.pos("/",1);
			if pos &gt; 0 then
				mapname := mapname[1:pos-1];
			endif;
			return "Transaction Map For Cargo (" &amp; mapname &amp; ")";
		endif;
		
		if self.mySubject.isKindOf(CM_TranMap) then
			tranmap := self.mySubject.CM_TranMap;
			return "Transaction Map For Cargo (" &amp; tranmap.name &amp; ")";
		else
			return "Cargo Transaction Map";
		endif;
	elseif self.itemType = CMIF_InvoiceHealthAgent.ItemType_TranMapEvent then
		if self.mySubject.isKindOf(CM_TranMapEvent) then
			emap := self.mySubject.CM_TranMapEvent;
			return "Transaction Map For Event (" &amp; emap.name &amp; ")";
		else
			return "Event Transaction Map";
		endif;
	elseif self.itemType = CMIF_InvoiceHealthAgent.ItemType_TranMapHMS then
		if self.mySubject.isKindOf(CM_QuantityMap) then // SUB QUANTITY RANGE
			mapname := self.mySubject.CM_QuantityMap.getTranMapBreadCrumb();
			pos := mapname.pos("/",1);
			if pos &gt; 0 then
				mapname := mapname[1:pos-1];
			endif;
			return "Transaction Map For HMS (" &amp; mapname &amp; ")";
		endif;
		
		if self.mySubject.isKindOf(CM_TranMapVoyage) then
			vmap := self.mySubject.CM_TranMapVoyage;
			return "Transaction Map For HMS (" &amp; vmap.name &amp; ")";
		else
			return "HMS Transaction Map";
		endif;
	elseif self.itemType = CMIF_InvoiceHealthAgent.ItemType_TranMapAlloc then
		if self.mySubject.isKindOf(CM_TranMapCargoAllocation) then
			amap := self.mySubject.CM_TranMapCargoAllocation;
			return "Transaction Map For Allocation (" &amp; amap.name &amp; ")";
		else
			return "Allocation Transaction Map";
		endif;
	elseif self.itemType = CMIF_InvoiceHealthAgent.ItemType_TranMapSummary then
		if self.mySubject.isKindOf(CM_TranMapSSSummary) then
			smap := self.mySubject.CM_TranMapSSSummary;
			return "Transaction Map For Summary (" &amp; smap.name &amp; ")";
		else
			return "Summary Transaction Map";
		endif;

		
	elseif self.itemType = CMIF_InvoiceHealthAgent.ItemType_TaskResource then
		if self.mySubject.isKindOf(CM_ResourceType) then
			rmap := self.mySubject.CM_ResourceType;
			return "Mapping For Task Resource (" &amp; smap.name &amp; ")";
		else
			return "Task Resource Mapping";
		endif;
		
		endif;
	
	return "UNKNOWN";
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getResultTypeDescription" id="b0a67252-ef17-4525-a352-b4821a9a99cb">
        <source>getResultTypeDescription() : String;
/*
Purpose:			
Date		Who		Reason
14 September 2016	cnwab1	Initial creation
*/

vars

begin
	if self.resultType = CMIF_InvoiceHealthAgent.ResultType_Empty then
		return "Empty";
	elseif self.resultType = CMIF_InvoiceHealthAgent.ResultType_Invalid then
		return "Invalid";
	elseif self.resultType = CMIF_InvoiceHealthAgent.ResultType_Valid then
		return "Valid";
	elseif self.resultType = CMIF_InvoiceHealthAgent.ResultType_None then
		return "None";
	elseif self.resultType = CMIF_InvoiceHealthAgent.ResultType_Null then
		return "Null";
	elseif self.resultType = CMIF_InvoiceHealthAgent.ResultType_CalcTypeCargo then
		return "Calculation Type Not For Cargo";
	elseif self.resultType = CMIF_InvoiceHealthAgent.ResultType_CalcTypeEvent then
		return "Calculation Type Not For Event";
	elseif self.resultType = CMIF_InvoiceHealthAgent.ResultType_CalcTypeVoyage then
		return "Calculation Type Not For HMS";
	elseif self.resultType = CMIF_InvoiceHealthAgent.ResultType_TaskResource then
		return "Calculation Type Not For Resource Quantity";
	elseif self.resultType = CMIF_InvoiceHealthAgent.ResultType_QuantityMap then
		return "Calculation Type Not Suitable For Quantity Ranges (Has Block Units)";
	elseif self.resultType = CMIF_InvoiceHealthAgent.ResultType_QuantityRangeMap then
		return "Calculation Type Not Suitable For SUB Quantity Ranges (Has Block Units)";
	elseif self.resultType = CMIF_InvoiceHealthAgent.ResultType_CalcTypeSummary then
		return "Calculation Type Not For Cargo";
		
		
	endif;
		
	return "UNKNOWN";
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRowColour" id="c843b972-8d95-42d2-a222-9370de736cb2">
        <source>getRowColour() : Integer;
/*
Purpose:			
Date		Who		Reason
23 September 2016	cnwab1	Initial creation
*/

vars

begin
	if self.resultType = CMIF_InvoiceHealthAgent.ResultType_Valid then
		return "#DFF6B6".convertHexColourToJadeColor(); // green
	elseif self.resultType = CMIF_InvoiceHealthAgent.ResultType_QuantityMap then
		return "#F8F063".convertHexColourToJadeColor(); // yellow
	elseif self.resultType = CMIF_InvoiceHealthAgent.ResultType_QuantityRangeMap then
		return "#F8F063".convertHexColourToJadeColor(); // yellow
	elseif self.resultType = CMIF_InvoiceHealthAgent.ResultType_TaskResource then
		return "#F8F063".convertHexColourToJadeColor(); // yellow
	else
		return "#F7BBBC".convertHexColourToJadeColor(); // red
	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="93b158b5-e4e9-481f-9559-ec65d988d5b9">
        <updating/>
        <source>setForCreate(_agent : CMIF_InvoiceHealthAgent; _checktype : Integer; _description : String; _itemType : Integer; _terminal : CM_Terminal; _resultType : Integer; _subject : Object) updating;
/*
Purpose:			
Date		Who		Reason
14 September 2016	cnwab1	Initial creation
*/

vars

begin


	self.checkType := _checktype;
	self.description := _description;
	self.itemType := _itemType;
	self.myTerminal := _terminal;
	self.resultType := _resultType;
	mySubject := _subject;
	
	self.myInvoiceHealthAgent := _agent;
epilog

end;</source>
        <Parameter name="_agent" type="CMIF_InvoiceHealthAgent"/>
        <Parameter name="_checktype" type="Integer"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_itemType" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_resultType" type="Integer"/>
        <Parameter name="_subject" type="Object"/>
    </JadeMethod>
</Class>
