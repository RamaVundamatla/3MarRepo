    <JadeMethod name="doSectionDelete" id="4fa555dd-29b6-4517-927d-50e0cb755f07">
        <updating/>
        <source>doSectionDelete() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

	result : Integer;
	section : CM_VesselSectionVessel;
begin
	if self.tblSections.accessRow(self.tblSections.row) = null then
		return;
	endif;
	section:=self.tblSections.accessRow(self.tblSections.row).itemObject.CM_VesselSectionVessel;

	if section = null then
		return;
	endif;


	if app.msgBox(app.getErrorString2(ConfirmDelete,app.getErrorString(Vessel_section),section.code.String),app.getErrorString(Warning), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt;  MsgBox_Return_Yes then
		return;
	endif;

	while true do
	
		app.myTrxDA.trxDeleteVesselSection(section,app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Vessel_section), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
	endwhile;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSectionEdit" id="af0cd2c2-1a4a-484d-8523-5208c27242ad">
        <source>doSectionEdit() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	aStructure : CM_VesselStructuralElements;
	section : CM_VesselSection;
begin
	if self.myCurrentVessel = null then
		return;
	endif;
	
/*	if self.myCurrentVessel.myCellularVesselStructure = null then
		return;
	endif;*/
	
	//cnwrd1 par 31874
	aStructure := self.myCurrentVessel.getMyPrimaryVesselStructure;

	if aStructure = null then
		return;
	endif;
	
	
	
	// PAR 27469
	if self.tblSections.row &lt;= self.tblSections.fixedRows then
		return;
	endif;
	
	if self.tblSections.accessRow(self.tblSections.row).itemObject = null then // PAR 27469
		return;
	endif;
	section:=self.tblSections.accessRow(self.tblSections.row).itemObject.CM_VesselSection;

	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.myAssistant.SHP_Assistant.showVesselSectionForm(aStructure,section,SHP_ParentChildForm.Mode_View);
	else
		self.myAssistant.SHP_Assistant.showVesselSectionForm(aStructure,section,SHP_ParentChildForm.Mode_Edit);
	endif;
	
epilog

end;</source>
        <access>protected</access>
