    <JadeMethod name="setDrawStyleAndColors" id="d158d6cd-d157-4c79-8a36-22de50dbd221">
        <updating/>
        <source>setDrawStyleAndColors(_obj : Object; _frame : SHP_BayDrawingFrame input; _drawFillColor : Integer io;
		_outerColourUpper, _outerColourLower : Integer output) updating, protected;
// ---------------------------------------------------------------------------
// Created:     12 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpDisplayMode	: Integer;
	sltReq : CM_SlotRequest;
begin

	tmpDisplayMode := self.displayMode;

	_frame.drawFillStyle := Frame.DrawFillStyle_Solid;
	_frame.drawStyle := Frame.DrawFillStyle_Solid;
	_frame.drawWidth := 1;

	if self.allSelectedObjects.includes(_obj) then
		_outerColourUpper := DarkGray;
		_outerColourLower := White;

		if (tmpDisplayMode = ShpDisplayMode_ColCodeDisch or
		   tmpDisplayMode = ShpDisplayMode_ColCodeLoad) and
		   self.allSelectedObjectsAlt.includes(_obj) then
			_drawFillColor := Red;
		else
			// ### AKB DIFFERENT SELECT
			_drawFillColor := Gray;
		endif;

	elseif self.allSelectedObjectsAlt.includes(_obj) then
		_outerColourUpper := DarkGray;
		_outerColourLower := White;
		_drawFillColor := DarkGray;

	else
		_outerColourLower := DarkGray;
		if tmpDisplayMode = ShpDisplayMode_Defn or self.amPrinting then
			_outerColourUpper := Gray;
		else
			_outerColourUpper := White;
		endif;
	endif;
	
	
	
	self.theDrawFillColor := _drawFillColor;
	_frame.drawFillColor := _drawFillColor;

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_frame" type="SHP_BayDrawingFrame" usage="input"/>
        <Parameter name="_drawFillColor" type="Integer" usage="io"/>
        <Parameter name="_outerColourUpper" type="Integer" usage="output"/>
        <Parameter name="_outerColourLower" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setDrawingPositions" id="a2524eb4-ba99-477f-9385-22e210e7509e">
        <updating/>
        <source>setDrawingPositions() updating;
// ---------------------------------------------------------------------------
// Created:     13 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*
The drawing positions are:

    portLabelPosOD  portPosOD                            starboardPosOD  starboardLabelPosOD
yOnDeckPos     +------------------------------------------+
               |                                          |
               |             on deck containers           |
               |                                          |
               +------------------------------------------+

yHatchPos      |------------ hatch lids ------------------|

    portLabelPosUD  portPosUD                    starboardPosUD  starboardLabelPosUD
yUnderDeckPos  +------------------------------------------+
               +-+                                      +-+
                 +-+       under deck containers      +-+
                   +-+                              +-+
yUnderDeckEndPos     +------------------------------+

               ^
        sideDrawingMargin

*/
vars
	textHeight,
	theTopMargin	: Integer;
	theScaleFactor	: Real;
	theRowHeight,
	theColWidth,
	thePrintStyle,
	hatchLidHeight 	: Integer;
	tmpFrame		: SHP_BayDrawingFrame;
begin

	textHeight := 12;
	
	theScaleFactor 	:= self.scaleFactor;
	theRowHeight	:= self.rowHeight;
	theColWidth		:= self.columnWidth;
	thePrintStyle 	:= self.printOutputStyle;
	hatchLidHeight	:= HatchLidHeight_Screen;
	
	self.getYDrawingPositions(textHeight, self.maxTiersOnDeck, self.maxTiersUnderDeck, theTopMargin, self.bayHeight, self.yHatchPos, self.yOnDeckPos, self.yUnderDeckEndPos, self.yUnderDeckPos);

	if self.amPrinting then
		if thePrintStyle = PrintOutput_Small then
			self.hasLabels := false;
		else
			self.hasLabels := true;
		endif;
		hatchLidHeight := HatchLidHeight_Print;
	elseif theScaleFactor = ScaleFactor_1 then	
		self.hasLabels := false;
	else
		self.hasLabels := true;
	endif;

	self.topMargin := theTopMargin;
	
	if thePrintStyle = PrintOutput_Small then
		// at this scale we don't print labels on sides
		self.sideDrawingMargin := SideMargin;
	elseif thePrintStyle = PrintOutput_Medium then
		self.sideDrawingMargin := SideMargin + self.LabelCharacterWidth_X3;
	elseif theScaleFactor = ScaleFactor_1 then
		// at this scale we don't print labels on sides
		self.sideDrawingMargin := SideMargin;
	else
		self.sideDrawingMargin := SideMargin + self.LabelCharacterWidth_X3 + 6;
	endif;

	if self.displayMode = ShpDisplayMode_Defn or 
	   (theScaleFactor = ScaleFactor_1) or
	   (self.amPrinting and thePrintStyle &lt;= PrintOutput_Medium) then
		self.hasWeights := false;
	else
		self.hasWeights := true;
	endif;

	self.bayWidth := self.getFrameWidthForBay(self.maxCells, theColWidth);
	//self.bayWidth := self.sideDrawingMargin + (self.maxCells * theColWidth) + self.sideDrawingMargin;

	if self.amPrinting then
		if thePrintStyle = self.PrintOutput_Small then
			self.xAxisLabelOffset := 0;
			self.yAxisLabelOffset := 0;
		elseif thePrintStyle = self.PrintOutput_Medium then
			self.xAxisLabelOffset := 5;
			self.yAxisLabelOffset := 5;
		else
			self.xAxisLabelOffset := 15;
			self.yAxisLabelOffset := 10;
		endif;

	elseif theScaleFactor = ScaleFactor_1 then
		self.xAxisLabelOffset := 0;
		self.yAxisLabelOffset := 0;
	elseif theScaleFactor = ScaleFactor_1_5 then
		self.xAxisLabelOffset := 0;
		self.yAxisLabelOffset := 3;
	elseif theScaleFactor = ScaleFactor_2 then
		self.xAxisLabelOffset := 5;
		self.yAxisLabelOffset := 6;
	elseif theScaleFactor = ScaleFactor_3 then
		self.xAxisLabelOffset := 5;
		self.yAxisLabelOffset := 9;
	elseif theScaleFactor = ScaleFactor_4 then
		self.xAxisLabelOffset := 10;
		self.yAxisLabelOffset := 12;
	elseif theScaleFactor = ScaleFactor_6 then
		self.xAxisLabelOffset := 20;
		self.yAxisLabelOffset := 20;
	elseif theScaleFactor = ScaleFactor_9 then
		self.xAxisLabelOffset := 35;
		self.yAxisLabelOffset := 40;
	endif;
	
	foreach tmpFrame in self.allBayDrawingFramesById do
		tmpFrame.setDrawingPositions(self);
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="setDrawingPositionsForPrinting" id="b3d0761e-49e7-4b66-90aa-2b0636469dfa">
        <updating/>
        <source>setDrawingPositionsForPrinting(_bays : CM_BayVoyageArray) updating;
// ---------------------------------------------------------------------------
// Created:     09 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpBay	: CM_Bay;
	tmpMaxCells,
	tmpMaxUnder,
	tmpMaxOn	: Integer;

begin

	foreach tmpBay in _bays do
		tmpMaxCells := tmpBay.getNumCellsWide(self.displayMode).max(tmpMaxCells);	// tmpBay.getMaxCells.max(tmpMaxCells);
		// PAR 26760 
		if self.displayMode = ShpDisplayMode_Defn then
			tmpMaxOn := tmpBay.allTiersOnDeck.size.max(tmpMaxOn);
			tmpMaxUnder := tmpBay.allTiersUnderDeck.size.max(tmpMaxUnder);
		else
			tmpMaxOn := tmpBay.getNumTiersTotallyAvailable(true).max(tmpMaxOn);
			tmpMaxUnder := tmpBay.getNumTiersTotallyAvailable(false).max(tmpMaxUnder);
		endif;
	endforeach;

	self.maxCells := tmpMaxCells;
	self.maxTiersOnDeck := tmpMaxOn;
	self.maxTiersUnderDeck := tmpMaxUnder;

	self.setDrawingPositions();
end;</source>
        <Parameter name="_bays" type="CM_BayVoyageArray"/>
    </JadeMethod>
    <JadeMethod name="setFontDefaults" id="3f0105e8-b121-4106-a09f-75709e27a6f9">
        <updating/>
        <source>setFontDefaults() updating;
// ---------------------------------------------------------------------------
// Created:     08 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	iAmPrinting : Boolean;
	lDisplayMode,
	lViewMode 	: Integer;
	lFactor 	: Real;
	theFontName	: String;
	theFontSize	: Real;
	thePrintStyle 	: Integer;

begin

	iAmPrinting := self.amPrinting;
	
	// reset so that the first redraw with frame will set for new font size
	self.textExtent999 := 0;
	
	lFactor 	 	:= self.scaleFactor;
	lDisplayMode 	:= self.displayMode;
	lViewMode 	 	:= self.viewMode;
	thePrintStyle	:= self.printOutputStyle;

	if self.inPlaningOrSequenceMode then
		theFontName := Font_MicrosoftSansSerif;
		theFontSize := 8;
	else
		if iAmPrinting then
			if thePrintStyle = self.PrintOutput_Large then
				theFontName := Font_Helvetica;
				theFontSize := 6;				
			elseif thePrintStyle = self.PrintOutput_Medium then
				theFontName := Font_MicrosoftSansSerif;
				theFontSize := 5.5;
			elseif thePrintStyle = self.PrintOutput_Small then
				theFontName := Font_MicrosoftSansSerif;
				theFontSize := 6;
			endif;
		else
			if lFactor = ScaleFactor_9  then
				theFontName := Font_Helvetica;
				theFontSize := 8;
			elseif lFactor = 20  then
				theFontName := Font_Helvetica;
				theFontSize := 8;
	
			elseif lFactor = ScaleFactor_6 then
				theFontName := Font_Helvetica;
				theFontSize := 8;

			elseif lFactor = ScaleFactor_4 then
				theFontName := Font_Helvetica;
				theFontSize := 8;
	
			elseif lFactor = ScaleFactor_3 then
				theFontName := Font_Helvetica;
				theFontSize := 8;

			elseif lFactor = ScaleFactor_2 then
				theFontName := Font_MicrosoftSansSerif;
				theFontSize := 6;

			elseif lFactor = ScaleFactor_1_5 then
				theFontName := Font_MicrosoftSansSerif;
				theFontSize := 6;

			elseif lFactor = ScaleFactor_1 then
				theFontName := Font_MicrosoftSansSerif;
				theFontSize := 6;
			endif;
		endif;
	endif;
	
	self.defaultFontName	:= theFontName;
	self.defaultFontSize	:= theFontSize;

end;</source>
    </JadeMethod>
    <JadeMethod name="setFontSizeForAttribute" id="f19f069e-2797-4132-b362-1d43179295b9">
        <updating/>
        <source>setFontSizeForAttribute() updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theScale,
	theFontSize	: Real;
	printStyle	: Integer;
	
begin

	theScale := self.scaleFactor;
	printStyle := self.printOutputStyle;

	if self.amPrinting then
		if printStyle = self.PrintOutput_Small then
			theFontSize := 6;
		elseif printStyle = self.PrintOutput_Medium then
			theFontSize := 6;
		else
			theFontSize := 8;
		endif;

	elseif theScale = 1 or theScale = 1.5 then
		theFontSize := 8;

	elseif theScale = 2 then
		if self.displayMode = ShpDisplayMode_Actual 
		or self.displayMode = ShpDisplayMode_Proposed 
		or self.displayMode = ShpDisplayMode_ColCodeDisch
		or self.displayMode = ShpDisplayMode_ColCodeLoad 
		or self.displayMode = ShpDisplayMode_EDI then
			theFontSize := 7;
		else
			theFontSize := 12;
		endif;
	elseif theScale = 3 then
		if self.displayMode = ShpDisplayMode_Actual
		or self.displayMode = ShpDisplayMode_Proposed 
		or self.displayMode = ShpDisplayMode_ColCodeDisch
		or self.displayMode = ShpDisplayMode_ColCodeLoad 
		or self.displayMode = ShpDisplayMode_EDI then
			theFontSize := 8;
		else
			theFontSize := 9;
		endif;
	elseif theScale = 4 then
		if self.displayMode = ShpDisplayMode_Actual
		or self.displayMode = ShpDisplayMode_Proposed 
		or self.displayMode = ShpDisplayMode_ColCodeDisch
		or self.displayMode = ShpDisplayMode_ColCodeLoad  
		or self.displayMode = ShpDisplayMode_EDI then
			theFontSize := 10;
		else
			theFontSize := 10;
		endif;
	elseif theScale = 6 then
		if self.displayMode = ShpDisplayMode_Actual
		or self.displayMode = ShpDisplayMode_Proposed 
		or self.displayMode = ShpDisplayMode_ColCodeDisch
		or self.displayMode = ShpDisplayMode_ColCodeLoad  
		or self.displayMode = ShpDisplayMode_EDI then
			theFontSize := 16;
		else
			theFontSize := 20;
		endif;
	elseif theScale = 9 then
		if self.displayMode = ShpDisplayMode_Actual or 
		   self.displayMode = ShpDisplayMode_Proposed or 
		   self.displayMode = ShpDisplayMode_ColCodeDisch or 
		   self.displayMode = ShpDisplayMode_ColCodeLoad or 
		   self.displayMode = ShpDisplayMode_EDI then
			theFontSize := 20;
		else
			theFontSize := 24;
		endif;
	elseif theScale = 20 then
		if self.displayMode = ShpDisplayMode_Actual or 
		   self.displayMode = ShpDisplayMode_Proposed or 
		   self.displayMode = ShpDisplayMode_ColCodeDisch or 
		   self.displayMode = ShpDisplayMode_ColCodeLoad or 
		   self.displayMode = ShpDisplayMode_EDI then
			theFontSize := 35;
		else
			theFontSize := 30;
		endif;
	endif;
	
	self.defaultFontSizeForAttributes := theFontSize;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setFontSizeForAttributeMag" id="162bb996-a681-4fd1-8ad5-23e0e2f2bc3e">
        <updating/>
        <source>setFontSizeForAttributeMag() updating;
// ---------------------------------------------------------------------------
// Created:     11 December 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.setFontSizeForAttribute();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFromSlotDefn" id="fa698a27-4147-4176-9edb-98c7c034da84">
        <updating/>
        <source>setFromSlotDefn(_slotDefn : CM_SlotDefn; x1, y1, x2, y2 : Real) updating;
// ---------------------------------------------------------------------------
// Created:     07 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 14/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
// 04 Apr 2011	cnwkpd1		PAR #26792 - Performance improvements for Bay View form

vars
	tmpBay	: CM_Bay;
	tmpTI	: CM_TrackedItem;
	relSlot,
	tmpSlot	: CM_SlotController;
	tmpNumTIs,
	tmpDisplayMode	: Integer;
	tmpIsExport,
	tmpIsImport		: Boolean;
begin

	if _slotDefn = null then
		self.setToNULL();
		return;
	endif;

	self.x1	:= x1;
	self.y1	:= y1;
	self.x2	:= x2;
	self.y2	:= y2;

	tmpBay := _slotDefn.myBay;

	self.mySlotDefn := _slotDefn;

	// attributes from the slotDefn
	if self.displayMode = ShpDisplayMode_Defn then
		self.myCurrentObject := _slotDefn;
		return;
	endif;
	
	tmpDisplayMode := self.displayMode;
	
	tmpSlot := _slotDefn.CM_SlotDefnVoyage.mySlotController;
	self.myLocationsController := tmpSlot;
	self.myCurrentObject := tmpSlot;
	
	// we get all the trackeditems as we then use
	// these to calculate the pile weights
	self.allTrackedItems.clear;

	if tmpDisplayMode = ShpDisplayMode_Actual or
	   tmpDisplayMode = ShpDisplayMode_ColCodeDisch then
		
		tmpSlot.allTrackedItems.copy(self.allTrackedItems);
		tmpTI := self.allTrackedItems.first;
		if tmpTI &lt;&gt; null then
			self.myTrackedItem := tmpTI;
			tmpNumTIs := self.allTrackedItems.size;		// PAR #26792
			//tmpIsExport := (tmpTI.isExport or tmpTI.isRehandle or tmpTI.isSOB);							// PAR #25021
			tmpIsExport := (tmpTI.isExport or tmpTI.isTranshipOutbound or tmpTI.isRehandle or tmpTI.isSOB);	// PAR #25021
			//tmpIsImport := tmpTI.isImport;																// PAR #25021
			tmpIsImport := tmpTI.isImport or tmpTI.isTranshipInbound;										// PAR #25021
		
	/* 17 Nov 2020	NDl	TFS 49891 - Don't draw OS Backends any more
		//04 Jul 2012	NDL	Par 29316
		elseif not tmpSlot.allTrackedItemOSBackEnds.first = null then
			tmpTI := tmpSlot.allTrackedItemOSBackEnds.first;
			if tmpTI &lt;&gt; null then
				self.myTrackedItem := tmpTI;
				tmpNumTIs := self.allTrackedItems.size;
				tmpIsExport := (tmpTI.isExport or tmpTI.isTranshipOutbound or tmpTI.isRehandle or tmpTI.isSOB);	
				tmpIsImport := tmpTI.isImport or tmpTI.isTranshipInbound;
			endif; */
			
		else
		//	self.myTrackedItem := tmpSlot.allTrackedItemOSBackEnds.first; 
			self.myTrackedItem := null; //17 Nov 2020	NDl	TFS 49891
		endif;
		
	
	elseif tmpDisplayMode = ShpDisplayMode_EDI then
		tmpTI := tmpSlot.getTheEDITrackedItemsForIndex(self.currentEDIIndex);
		if tmpTI &lt;&gt; null then
			self.allTrackedItems.add(tmpTI);
			self.myTrackedItem := tmpTI;
			tmpNumTIs := 1;
			//tmpIsExport := (tmpTI.isExport or tmpTI.isRehandle or tmpTI.isSOB);							// PAR #25021
			tmpIsExport := (tmpTI.isExport or tmpTI.isTranshipOutbound or tmpTI.isRehandle or tmpTI.isSOB);	// PAR #25021
			//tmpIsImport := tmpTI.isImport;																// PAR #25021
			tmpIsImport := tmpTI.isImport or tmpTI.isTranshipInbound;										// PAR #25021
		else
			self.myTrackedItem := null;
		endif;

	elseif tmpDisplayMode = ShpDisplayMode_ColCodeLoad then
		// getAllPlannedTrackedItems clears the self.allTrackedItems array
		tmpSlot.getAllPlannedTrackedItems(self.allTrackedItems, true, false);
		tmpTI := self.allTrackedItems.first;
		if tmpTI &lt;&gt; null then
			self.myTrackedItem := tmpTI;
			tmpNumTIs := self.allTrackedItems.size;
			//tmpIsExport := (tmpTI.isExport or tmpTI.isRehandle or tmpTI.isSOB);							// PAR #25021
			tmpIsExport := (tmpTI.isExport or tmpTI.isTranshipOutbound or tmpTI.isRehandle or tmpTI.isSOB);	// PAR #25021
			//tmpIsImport := tmpTI.isImport;																// PAR #25021
			tmpIsImport := tmpTI.isImport or tmpTI.isTranshipInbound;										// PAR #25021
		else
			// for load if there is no load ti's we return the actual
			tmpSlot.allTrackedItems.copy(self.allTrackedItems);
			tmpTI := self.allTrackedItems.first;
			if tmpTI &lt;&gt; null then
				self.myTrackedItem := tmpTI;
				// leave numTIs here as 0 as we only want to count planned
				//tmpNumTIs := self.allTrackedItems.size;
				//tmpIsExport := (tmpTI.isExport or tmpTI.isRehandle or tmpTI.isSOB);							// PAR #25021
				tmpIsExport := (tmpTI.isExport or tmpTI.isTranshipOutbound or tmpTI.isRehandle or tmpTI.isSOB);	// PAR #25021
				//tmpIsImport := tmpTI.isImport;																// PAR #25021
				tmpIsImport := tmpTI.isImport or tmpTI.isTranshipInbound;										// PAR #25021
			// PAR 18682 PAR 18823 was not drawing the back end of a 53 foot discharge CC
/* 17 Nov 2020	NDL	TFS 49891 - No longer draw OS backends 	
			elseif not tmpSlot.allTrackedItemOSBackEnds.isEmpty() then
				tmpTI := tmpSlot.allTrackedItemOSBackEnds.first;
				if tmpTI &lt;&gt; null then
					self.myTrackedItem := tmpTI;
					tmpNumTIs := self.allTrackedItems.size;
					//tmpIsExport := (tmpTI.isExport or tmpTI.isRehandle or tmpTI.isSOB);							// PAR #25021
					tmpIsExport := (tmpTI.isExport or tmpTI.isTranshipOutbound or tmpTI.isRehandle or tmpTI.isSOB);	// PAR #25021
					//tmpIsImport := tmpTI.isImport;																// PAR #25021
					tmpIsImport := tmpTI.isImport or tmpTI.isTranshipInbound;										// PAR #25021 
				endif; */
			else
				self.myTrackedItem := null;
			endif;
		endif;

	elseif tmpDisplayMode = ShpDisplayMode_Proposed then
		tmpSlot.getProposedTIs(self.allTrackedItems);
		tmpTI := self.allTrackedItems.first;
		if tmpTI &lt;&gt; null then
			self.myTrackedItem := tmpTI;
			tmpNumTIs := self.allTrackedItems.size;
			//tmpIsExport := (tmpTI.isExport or tmpTI.isRehandle or tmpTI.isSOB);							// PAR #25021
			tmpIsExport := (tmpTI.isExport or tmpTI.isTranshipOutbound or tmpTI.isRehandle or tmpTI.isSOB);	// PAR #25021
			//tmpIsImport := tmpTI.isImport;																// PAR #25021
			tmpIsImport := tmpTI.isImport or tmpTI.isTranshipInbound;										// PAR #25021
		else
			self.myTrackedItem := null;
		endif;
	elseif tmpDisplayMode = ShpDisplayMode_VoyGlobActual 
	or tmpDisplayMode = ShpDisplayMode_VoyGlobProposed then
	//we're looking at ti's from another voyage
		if self.myVoyageInterTerminal &lt;&gt; null then
			tmpSlot.getTIsForOtherVoyage(tmpDisplayMode = ShpDisplayMode_VoyGlobProposed, self.myVoyageInterTerminal, self.allTrackedItems, relSlot);
			if relSlot &lt;&gt; null then
				self.myLocationsController := relSlot;
			else
				app.raiseUnexpectedProgramError(class.name, method.name, 'no matching slot in inter-terminal voyage');
			endif;
			tmpTI := self.allTrackedItems.first;
			if tmpTI &lt;&gt; null then
				self.myTrackedItem := tmpTI;
				//tmpIsExport := (tmpTI.isExport or tmpTI.isRehandle or tmpTI.isSOB);							// PAR #25021
				tmpIsExport := (tmpTI.isExport or tmpTI.isTranshipOutbound or tmpTI.isRehandle or tmpTI.isSOB);	// PAR #25021
				//tmpIsImport := tmpTI.isImport;																// PAR #25021
				tmpIsImport := tmpTI.isImport or tmpTI.isTranshipInbound;										// PAR #25021
			else
				self.myTrackedItem := null;
			endif;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'inter-terminal voyage required for this view mod');
		endif;
	endif;


	self.tiInfoNumTI := tmpNumTIs;
	self.isExport	 := tmpIsExport;
	self.isImport	 := tmpIsImport;

end;</source>
        <Parameter name="_slotDefn" type="CM_SlotDefn"/>
        <Parameter name="x1" type="Real"/>
        <Parameter name="y1" type="Real"/>
        <Parameter name="x2" type="Real"/>
        <Parameter name="y2" type="Real"/>
    </JadeMethod>
