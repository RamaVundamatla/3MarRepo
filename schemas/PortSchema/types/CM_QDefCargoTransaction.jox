	//create qProp as CM_QDecimalTotalWeightProperty persistent;																								// PAR #33235
	//qProp.set('Total Weight', CM_TITransaction::totalWeight.name, self.className);																			// PAR #33235
	//self.allQueryProperties.add(qProp);																														// PAR #33235
	self.createMeasurementProperties(CM_QDecimalTotalWeightProperty, Type_Weight, 'Total Weight', CM_TITransaction::totalWeight.name, self.className, null);	// PAR #33235

	//create qProp as CM_QDecimalVolumeProperty persistent;																										// PAR #33235
	//qProp.set('Total Volume', CM_TITransaction::totalVolume.name, self.className);																			// PAR #33235
	//self.allQueryProperties.add(qProp);																														// PAR #33235
	self.createMeasurementProperties(CM_QDecimalVolumeProperty, Type_Volume, 'Total Volume', CM_TITransaction::totalVolume.name, self.className, null);			// PAR #33235

	create qProp as CM_QRefTransactionTypeMethod persistent;
	qProp.set('Transaction Type', CM_TITransaction::getTransactionType.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
