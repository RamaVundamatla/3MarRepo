    <JadeMethod name="utlCreateXlationCopy" id="f810beee-8577-46b3-9373-c7d0eff26f42">
        <updating/>
        <source>utlCreateXlationCopy(_xlation: CM_Xlation;  _operator: CM_Operator; _terminal :CM_Terminal;
						_xlationTable: CM_XlationTable io; _opTerm: CM_OperatorTerminal io) updating;
//----------------------------------------------------------------
//	Created:	25 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
//12 Jun 2023	jlizm1	TFS 58500 add EDI Xlation for Operational Instruction and trailer type
vars
	type		: Integer;
	xlation		: CM_Xlation;
	root 		: CM_Root;
begin
	if _xlationTable = null then
		// need to create a new one
		type := _xlation.myXlationTable.type;

		if _operator = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'operator is null for new xlation table');
			return;
		endif;			

		create _xlationTable persistent;
		
		if type = XLATION_TYPE_VOYAGETERMINAL or
			type = XLATION_TYPE_INSTRUCTTERMINAL then
			if _opTerm = null then
				if _terminal = null then
					app.raiseUnexpectedProgramError(class.name, method.name, 'terminal is null for new xlation table');
					return;
				endif;	
				
				create _opTerm persistent;
				
				_opTerm.setMyOperator (_operator);
				_opTerm.setMyTerminal (_terminal);
			
			endif;
			
			_xlationTable.setProxy(type, app.myRoot, null, _opTerm, null,null);
		else
			_xlationTable.setProxy(type, app.myRoot, _operator, null, _xlationTable.myCargoType,null);
		endif;
	else
		if _xlationTable.hasXlation(_xlation) then
			// nothing to do - already there
			return;
		endif;
	endif;
	
	create xlation as _xlation.class;
	
	xlation.setXlationTable(_xlationTable);
	xlation.setForUpdate(_xlation);
	xlation.setSystemObject(_xlationTable.type, _terminal);

epilog
	
end;</source>
        <Parameter name="_xlation" type="CM_Xlation"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_xlationTable" type="CM_XlationTable" usage="io"/>
        <Parameter name="_opTerm" type="CM_OperatorTerminal" usage="io"/>
    </JadeMethod>
