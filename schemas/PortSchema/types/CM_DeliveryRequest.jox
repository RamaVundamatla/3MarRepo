    <JadeMethod name="createBulkRelease" id="51432946-ee72-4c8b-9994-899cccbbee78">
        <updating/>
        <source>createBulkRelease(_passport : CM_Passport input) : CM_BulkRelease updating, protected;
// ---------------------------------------------------------------------------
// Created:     05 August 2002 by cnwdf1
//
// Purpose:     for ccms 1048: if the Request is directly created in Raod in
//              without previously enter a empty release request, then make it
//              up by creating the empty release request(bulkRelease) 
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/06/2004	cnwgd1		Par 8380 
// 14/11/2019  cnwma1		Bug 47393: POL - [Fwd: ##RE-13305## : FW: Deliver Release Query]
// ---------------------------------------------------------------------------
vars
	newBulkRelease		: CM_BulkRelease;
	auditAgent          : CM_CreateTransactionAuditAgent;
begin
	inheritMethod(_passport);

	// Par 8380	- Now
	newBulkRelease := self.myTerminal.getBulkReleaseFromCode(self.deliveryNumber.trimBlanks.toUpper);
	if newBulkRelease = null then
		//epr 11/9/17 TFS 6723 deleted reference to method that did nothing
		create newBulkRelease persistent;
		newBulkRelease.setFromDeliveryRequest(self);
		
		if app.myPassport.noErrors and newBulkRelease &lt;&gt; null  then   //14.11.2019 cnwma1 #47393
			auditAgent := app.myUtilityCA.myCreateAuditAgent;
			auditAgent.audCreateGeneric(newBulkRelease);
		endif;
	endif;
	
	return newBulkRelease;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
