    <JadeMethod name="initSearcher" id="94ee92fa-de1f-4b5b-a2c0-c361adc736e9">
        <updating/>
        <source>initSearcher() updating, protected;
/*

Date		Who		Reason
06 Apr 2016	cnwkpd1	TFS 488 - Multi Timezone Support
	
*/

vars
	debtor			: CM_Debtor;
	coy				: CM_Bank;
	user			: CM_User;
	trxType			: CM_TransactionType;
	systemNow,
	localNow		: TimeStamp;
	tme : Time;
begin
	self.cmbSearchEnqType.itemData[self.cmbSearchEnqType.addItem(app.getErrorString(Cargo_Transactions))] := Mode_Cargo_Transaction_Enquiry;
	self.cmbSearchEnqType.itemData[self.cmbSearchEnqType.addItem(app.getErrorString(Event_Transactions))] := Mode_Event_Transaction_Enquiry;
	self.cmbSearchEnqType.itemData[self.cmbSearchEnqType.addItem(app.getErrorString(HMS_Transactions))] := Mode_HMS_Transaction_Enquiry;
	self.cmbSearchEnqType.itemData[self.cmbSearchEnqType.addItem(app.getErrorString(BOL_Transactions))] := Mode_BOL_Transaction_Enquiry;	//04 Nov 2019	NDL	TFS 47100
	self.cmbSearchEnqType.itemData[self.cmbSearchEnqType.addItem(app.getErrorString(Work_order_transactio))] := Mode_WO_Transaction_Enquiry; // TFS 39237
	self.setNavigatorHeading(app.getErrorString(Cargo_Transactions));
	
	// somewhat arbitrary choice of start date	
	systemNow := app.actualTimeServer();
	localNow := self.systemToLocalTime(systemNow);	
	
	 // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	if process.isJLGAB1() then
		self.mskSearchDateFrm.setDate(localNow.date());
		self.mskSearchTimeFrm.setTime(null);
		self.mskSearchDateTo.setDate(localNow.date());
		tme.setTime(23,59,59,999);
		localNow.setTime(tme);
		self.mskSearchTimeTo.setTime(localNow.time());
	else
		self.mskSearchDateFrm.setDate(localNow.date().cnEcAddDays(-7));
		self.mskSearchTimeFrm.setTime(null);
		self.mskSearchDateTo.setDate(localNow.date());
		self.mskSearchTimeTo.setTime(localNow.time());
	endif;
	
	self.populateTransactionTypes(self.Mode_Cargo_Transaction_Enquiry);
	
	self.populateVoyageCombo();
	
	self.cmbSearchUser.addItem("");
	foreach user in app.myRoot.allUsers where not user.isNotAvailableForEntry do
		if user.code.trimBlanks.toUpper = 'SUPERUSER' then
			continue;
		endif;
		self.cmbSearchUser.itemObject[self.cmbSearchUser.addItem(user.userName &amp; ' (' &amp; user.code &amp; ')')] := user;
	endforeach;

	self.cmbSearchBU.addItem("");
	foreach coy in self.myTerminal.companies where coy.isBusinessUnit do
		self.cmbSearchBU.itemObject[self.cmbSearchBU.addItem(coy.code &amp; " - " &amp; coy.mailingName)] := coy;
	endforeach;

	self.cmbSearchDebtor.addItem("");
	foreach debtor in app.myRoot.myRootCompany.debtors do
		self.cmbSearchDebtor.itemObject[cmbSearchDebtor.addItem(debtor.name)] := debtor;
	endforeach;

	self.cmbSearchCharged.addItem(" ");
	self.cmbSearchCharged.itemData[self.cmbSearchCharged.addItem(app.getErrorString(No))] := Not_Charged;
	self.cmbSearchCharged.itemData[self.cmbSearchCharged.addItem(app.getErrorString(Yes))] := Is_Charged;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initTblTrans" id="4564b8b8-2d0e-4fe6-ae19-56b03729260e">
        <updating/>
        <source>initTblTrans()updating, protected;
// ---------------------------------------------------------------------------
// Created:  May   2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/12/2009	cnwdap1		CCMS MES 1007 Reefer properties moved to separate class, other cargo can be reefers
// 11/03/2010	cnwdap1		PAR #23150 getAllTemperatureReadings may return null
// 30/05/2013	cnwdap1		CCMS 2274 Split/Merge Break Bulk Cargo
// 18/06/2013	cnwcs5		par 31686a - fix problem with expanding transactions as superuser
// 05/02/2020   cnwma1      Bug 48489: JMT- The Count of charges is not excluding Tax payments
// ---------------------------------------------------------------------------

vars
	tempReadings	: CM_TempReadingByDateTimeDict;
	nbrReadings		: Integer;
	entTableDef		: EntTableDef;
	row, detailCol	: Integer;							
	control			: Control;							
	table			: CM_DataTable;						
	cashPay         : CM_CashPayment;
	paymentCount	: Integer;
	ti              : CM_TrackedItem;
begin
	
	ti := self.myTrackedItem;
	
	if ti.requiresTemperature then
		self.shtTemperatures.visible := true;
		// PAR #23150 start
		tempReadings := ti.getAllTemperatureReadings;
		if tempReadings &lt;&gt; null then
			nbrReadings := tempReadings.size;
		else
			nbrReadings := null;
		endif;
		self.shtTemperatures.caption := "Reefer Temperatures (" &amp; nbrReadings.String &amp; ")";
		//PAR #23150 end
		self.showTemperatures();
	else
		self.shtTemperatures.visible := false;
	endif;
	foreach  cashPay in ti.allCashPayments discreteLock do 
		if cashPay.isTaxPayment then
			continue;
		endif;
		paymentCount := paymentCount +1;
	endforeach;
	
	self.shtTransactions.caption 	:= app.getErrorString(Transactions)         &amp; " (" &amp; ti.allTransactions.size.String &amp; ")";
	self.shtDiscrepancies.caption 	:= app.getErrorString(Over_ridden_warnings) &amp; " (" &amp; (ti.allOverriddenWarnings.size + ti.allBookingRefDiscreps.size).String &amp; ")";
	self.shtCharges.caption 		:= app.getErrorString(Charges)              &amp; " (" &amp; (ti.invoiceLines.size + paymentCount).String &amp; ")";  //05.02.2020 cnwma1 #48489
	
	self.tblCharges.alignment 		:= Table.Alignment_Left_Top;
	self.tblDiscrepances.alignment 	:= Table.Alignment_Left_Top;
	self.tblTemperatures.alignment 	:= Table.Alignment_Left_Top;
	
	table	:= self.tblTrans;
	
	table.alignment := Table.Alignment_Left_Top;
	table.autoSize 	:= Table.AutoSize_Both;
	
	table.getEntRowColumnByRowName(ETRow_Details, detailCol);			// par31686a
	
	// CCMS 2274 check for cell controls in the transaction details column
	if detailCol &gt; table.fixedRows then									// par 31686a
		foreach row in table.fixedRows + 1 to table.rows do
			control := table.accessCell(row, detailCol).cellControl;
			
			if control &lt;&gt; null then
				delete control;
				table.accessCell(row, detailCol).cellControl := null;	// par 31854a
			endif;
		endforeach;
	endif;
	// CCMS 2274 end
	
	//08 Jun 2010	NDL Par 23498 - Make use of ent table defs now...
	entTableDef := app.myController.getEntTableDef(ETDef_TransactionList);

	
	if app.isSpecial or app.getMyUser.isSuperUser or app.getMyUser.isJmtSupportUser then  //09 Sep 2021	NDL	TFS 50505 - Allows visibility of the form the trx was created on
		entTableDef := app.myController.getEntTableDef(ETDef_TransactionListSU);
	endif;
	
	if entTableDef &lt;&gt; null then
		if self.xmlStrTblTrans.trimBlanks &lt;&gt; null then
			table.setTblDataEntRowsFromXML(entTableDef, self.xmlStrTblTrans);
		else
			table.setTblDataEntRowsFromDef(entTableDef);
		endif;
	endif;
	
	table.readOnly 			:= false;	
	table.fixedColumns 		:= 0;
	table.show3D 			:= Table.Show3D_Not3D;
	table.selectMode 		:= Table.SelectMode_Row;
	table.accessMode 		:= Table.AccessMode_Row;
	table.multiSelect 		:= CM_BaseTable.MultiSelect_Simple;
	table.selectionType 	:= CM_BaseTable.SelectionType_Row;
	table.defaultRowHeight 	:= 17;
	
	table.allSelectedObjects.clear;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initTblTransactions" id="de81031e-5c10-4648-ae2f-c4eca54bbf0a">
        <updating/>
        <source>initTblTransactions()updating, protected;
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
vars
	entTableDef		: EntTableDef;
begin
	if self.tableInitialised then
		return;
	endif;

	self.tblTransactions.alignment 		:= Table.Alignment_Left_Top;
	self.tblTransactions.autoSize := Table.AutoSize_Both;

	entTableDef := app.myController.getEntTableDef(ETDef_TransactionCargoEnquiry);
	if entTableDef &lt;&gt; null then
		if self.xmlStrTblTransactions.trimBlanks &lt;&gt; null then
			self.tblTransactions.setTblDataEntRowsFromXML(entTableDef, self.xmlStrTblTransactions);
		else
			self.tblTransactions.setTblDataEntRowsFromDef(entTableDef);
		endif;
	endif;
	self.tblTransactions.readOnly := false;	
	self.tblTransactions.fixedColumns := 0;
	self.tblTransactions.show3D := Table.Show3D_Not3D;
	self.tblTransactions.selectMode := Table.SelectMode_Row;
	self.tblTransactions.accessMode := Table.AccessMode_Row;
	self.tblTransactions.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.tblTransactions.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblTransactions.defaultRowHeight := 17;
	self.tblTransactions.allSelectedObjects.clear;
	
	self.tableInitialised := true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="keyDown" id="6f3293ef-465a-48d7-89cc-d873d6eb19a3">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//11 June 2010	cnwml2
//+cnwml2 PAR23495

vars

begin
	if not app.isControlKeyDown() and app.isAltKeyDown() and not app.isShiftKeyDown() then
		if keyCode = J_key_D then 
	        self.doDelete();
		elseif keyCode = J_key_E then
			self.showTxnMaint(true);
		elseif keyCode = J_key_A then
			self.showTxnMaint(false);
		elseif keyCode = J_key_P then
			self.doPrint();
	    endif;
	endif;
	
	if keyCode = CMUI_Key_F3 and
	   self.mode &lt;&gt; self.Mode_CargoItem_Enquiry then
		self.doShowSearcherClick();
		return;
	endif;
	
	inheritMethod(keyCode, shift);
epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="8cedb4ab-771c-424b-8501-6284aca2c587">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// ---------------------------------------------------------------------------
// Created:     2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	app.mousePointer := MP_HOURGLASS;
	
	inheritMethod();
	self.doResize();
	
epilog
	app.mousePointer := MP_DEFAULT;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForAccumulation" id="8de12650-6bbf-4bdf-babf-ab6b4b6fe3a6">
        <updating/>
        <source>loadDataForAccumulation()updating;
/*
Purpose - 	
Who - NAVAB1
Date - 22NOV2024
ADO - JIRA 33348
*/

vars
	table			: CM_DataTable;		
	entTableDef		: EntTableDef;
	txn				: CM_TITransaction;
	idx 			: Integer;
	dateCol	 		: Integer;
	enqRow			: String;
begin
	if self.myAccumulation &lt;&gt; null then
		self.shtTransactions.caption 	:= app.getErrorString(Transactions) &amp; " (" &amp; self.myAccumulation.allContributingTransactions.size.String &amp; ")";
	endif;
	
	
	table	:= self.tblTransactions;	
	self.numItemsShown := 0;
	
	table.alignment := Table.Alignment_Left_Top;
	table.autoSize 	:= Table.AutoSize_Both;
	entTableDef := app.myController.getEntTableDef(ETDef_TransactionList);
	
	
	if entTableDef &lt;&gt; null then
		if self.xmlStrTblTransactions.trimBlanks &lt;&gt; null then
			table.setTblDataEntRowsFromXML(entTableDef, self.xmlStrTblTransactions);
		else
			table.setTblDataEntRowsFromDef(entTableDef);
		endif;
	endif;
	
	table.top := self.frmToolbar.height + 5;
	table.readOnly 			:= false;	
	table.fixedColumns 		:= 0;
	table.show3D 			:= Table.Show3D_Not3D;
	table.selectMode 		:= Table.SelectMode_Row;
	table.accessMode 		:= Table.AccessMode_Row;
	table.multiSelect 		:= CM_BaseTable.MultiSelect_Simple;
	table.selectionType 	:= CM_BaseTable.SelectionType_Row;
	table.defaultRowHeight 	:= 17;
	if dateCol &gt; 0 then
		table.sortColumn[1]:=dateCol;
		table.sortAsc[1]:=false;
	endif;
	
	table.allSelectedObjects.clear;
	
	if self.myAccumulation &lt;&gt; null then
		foreach txn in self.myAccumulation.allContributingTransactions do
			enqRow := txn.getAttributeStringForDefArray(table.allTblDataEntRows);	
			idx := table.addItem(enqRow);
			table.accessRow(idx).itemObject := txn;
			if (idx mod 2 = 0) then
				table.accessRow(idx).backColor := self.colorRow1;
			else
				table.accessRow(idx).backColor := self.colorRow2;
			endif;
		endforeach;
		self.numItemsShown := self.myAccumulation.allContributingTransactions.size;

	endif;
	self.showNumRowsShown();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForBOL" id="f88fe127-8b45-4c90-bfb1-70c13c1fa4cb">
        <updating/>
        <source>loadDataForBOL() protected, updating;
/*

Date		Who		Reason
29 January 2015	cnwer1	Initial creation PAR  35427

*/

vars
	table			: CM_DataTable;		
	entTableDef		: EntTableDef;
	txn					: CM_Transaction;
	idx : Integer;
	dateCol	 : Integer;
begin
	
	self.shtTransactions.caption 	:= app.getErrorString(Transactions) &amp; " (" &amp; self.myBOL.allBOLTransactions.size.String &amp; ")";
	table	:= self.tblTrans;
	
	table.alignment := Table.Alignment_Left_Top;
	table.autoSize 	:= Table.AutoSize_Both;
	//08 Jun 2010	NDL Par 23498 - Make use of ent table defs now...
	entTableDef := app.myController.getEntTableDef(ETDef_BOLTransactionList);
	
	
	if entTableDef &lt;&gt; null then
		if self.xmlStrTblTrans.trimBlanks &lt;&gt; null then
			table.setTblDataEntRowsFromXML(entTableDef, self.xmlStrTblTrans);
		else
			table.setTblDataEntRowsFromDef(entTableDef);
		endif;
	endif;
	
	table.readOnly 			:= false;	
	table.fixedColumns 		:= 0;
	table.show3D 			:= Table.Show3D_Not3D;
	table.selectMode 		:= Table.SelectMode_Row;
	table.accessMode 		:= Table.AccessMode_Row;
	table.multiSelect 		:= CM_BaseTable.MultiSelect_Simple;
	table.selectionType 	:= CM_BaseTable.SelectionType_Row;
	table.defaultRowHeight 	:= 17;
	table.getEntRowColumnByRowName(ETRow_Date, dateCol);			// par31686a
	if dateCol &gt; 0 then
		table.sortColumn[1]:=dateCol;
		table.sortAsc[1]:=false;
	endif;
	
	table.allSelectedObjects.clear;
	
	foreach txn in self.myBOL.allBOLTransactions  do
		
		idx := self.addTransactionToTblTrans( null, txn );
		
		if (idx mod 2 = 0) then
			self.tblTrans.accessRow(idx).backColor := self.colorRow1;
		else
			self.tblTrans.accessRow(idx).backColor := self.colorRow2;
		endif;
	endforeach;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadDataForCargo" id="df9695b1-1bbd-4300-b223-265397a0d60d">
        <updating/>
        <source>loadDataForCargo() updating, protected;

vars

begin
	self.initTblTrans();

	self.showTransactions;
	self.showCharges;
	self.showDiscrepancies;
	self.showEventRequests();

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="97b3e64e-8028-4989-b21b-87df54ed33ca">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:      29 May 2003 by cnwsgp1
// 25/10/2016    cnwma1 TFS # 2820:PAR38298 STWO-Transaction menu system fault
//20 Jan 2017	cnwrs1	TFS 3137 - resize the form when show captions is on
// 11 Jul 2023 	navhl20 Bug 59047: MTN - The Refresh button on the Transaction Enquiry is refreshing all the transactions.
// ---------------------------------------------------------------------------
vars
	showSearcher	: Boolean;
	showCaptions : Boolean;
begin
	if self.frmToolbar.showCaptions then
		showCaptions := self.frmToolbar.showCaptions;
		self.frmToolbar.showCaptions := false;
		self.toolbarShowCaptions(showCaptions);
	endif;
	inheritMethod();
	showSearcher := true;
	// if run from another form such as invoices or selector, via method displaySelectorResults, allTransactions will already be populated
	//  so just show the contents
	if self.allTransactions.size &gt; 0 then
		showSearcher := false;
	endif;

	if self.mode = self.Mode_CargoItem_Enquiry then
		self.loadDataForCargo();
	elseif self.mode = self.Mode_BOLItem_Enquiry then //epr par 35427
		if self.myBOL &lt;&gt; null then     // 25/10/2016 cnwma1 TFS #25/10/2016
			self.loadDataForBOL();
		endif;
	elseif self.mode = self.Mode_WO_Transaction_Enquiry then		//11.7.2023 navhl20 #59047
		self.loadDataForWO();
	// ### JIRA 33348 22NOV2024 NAVAB1
	elseif self.mode = self.Mode_ContractAccumulation then	
		self.loadDataForAccumulation();
	else
		self.loadDataForTransaction(showSearcher);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadDataForTransaction" id="b648eebc-9456-4eab-b035-5ff8594394f6">
        <updating/>
        <source>loadDataForTransaction(_showSearcher : Boolean) updating, protected;

vars

begin
	self.initTblTransactions();
	self.initSearcher();
	
	// searcher not shown when run from selector or invoices
	if _showSearcher then
		self.doShowSearcherClick();
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_showSearcher" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadDataForWO" id="45d73a0b-8c1e-4c7b-8b0d-1ecc6818a045">
        <updating/>
        <source>loadDataForWO()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Jul 2023	navhl20	Bug 59047: MTN - The Refresh button on the Transaction Enquiry is refreshing all the transactions.
11 Jul 2023 navhl20 Defect 59116: MTN - The Resync option is not working on the Work Order Transactions form
14 Aug 2023 navhl20 ChangeRequest 59284:[59669] EUP | FR - VAS Work Order Transactions
*/

vars
	table			: CM_DataTable;		
	entTableDef		: EntTableDef;
	txn				: CM_Transaction;
	idx 			: Integer;
	dateCol	 		: Integer;
	enqRow			: String;
begin
	if self.myWorkOrder &lt;&gt; null then
		self.shtTransactions.caption 	:= app.getErrorString(Transactions) &amp; " (" &amp; self.myWorkOrder.allTransactions.size.String &amp; ")";
	elseif self.myWorkOrderDtl &lt;&gt; null then
		self.shtTransactions.caption 	:= app.getErrorString(Transactions) &amp; " (" &amp; self.myWorkOrderDtl.allWODtlTransactions.size.String &amp; ")";
	endif;
	table	:= self.tblTransactions;													//11.7.2023 navhl20 #59116
	self.numItemsShown := 0;
	
	table.alignment := Table.Alignment_Left_Top;
	table.autoSize 	:= Table.AutoSize_Both;
	entTableDef := app.myController.getEntTableDef(ETDef_TransactionWOEnquiry);
	
	
	if entTableDef &lt;&gt; null then
		if self.xmlStrTblTransactions.trimBlanks &lt;&gt; null then							//14.8.2023 navhl20 #59284[59669]
			table.setTblDataEntRowsFromXML(entTableDef, self.xmlStrTblTransactions);	//14.8.2023 navhl20 #59284[59669]
		else
			table.setTblDataEntRowsFromDef(entTableDef);
		endif;
	endif;
	
	table.readOnly 			:= false;	
	table.fixedColumns 		:= 0;
	table.show3D 			:= Table.Show3D_Not3D;
	table.selectMode 		:= Table.SelectMode_Row;
	table.accessMode 		:= Table.AccessMode_Row;
	table.multiSelect 		:= CM_BaseTable.MultiSelect_Simple;
	table.selectionType 	:= CM_BaseTable.SelectionType_Row;
	table.defaultRowHeight 	:= 17;
	if dateCol &gt; 0 then
		table.sortColumn[1]:=dateCol;
		table.sortAsc[1]:=false;
	endif;
	
	table.allSelectedObjects.clear;
	
	if self.myWorkOrder &lt;&gt; null then
		foreach txn in self.myWorkOrder.allTransactions do
			enqRow := txn.getAttributeStringForDefArray(table.allTblDataEntRows);				//11.7.2023 navhl20 #59116
			idx := table.addItem(enqRow);
			table.accessRow(idx).itemObject := txn;
			if (idx mod 2 = 0) then
				table.accessRow(idx).backColor := self.colorRow1;
			else
				table.accessRow(idx).backColor := self.colorRow2;
			endif;
		endforeach;
		self.numItemsShown := self.myWorkOrder.allTransactions.size;
	elseif self.myWorkOrderDtl &lt;&gt; null then
		foreach txn in self.myWorkOrderDtl.allWODtlTransactions do
			enqRow := txn.getAttributeStringForDefArray(table.allTblDataEntRows);				//11.7.2023 navhl20 #59116
			idx := table.addItem(enqRow);
			table.accessRow(idx).itemObject := txn;
			if (idx mod 2 = 0) then
				table.accessRow(idx).backColor := self.colorRow1;
			else
				table.accessRow(idx).backColor := self.colorRow2;
			endif;
		endforeach;
		self.numItemsShown := self.myWorkOrderDtl.allWODtlTransactions.size;
	endif;
	self.showNumRowsShown();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="lstMergeSplit_click" id="42f1b8ef-d2fd-419c-a3bd-4b40a3975554">
        <controlMethod name="CMUI_ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstMergeSplit_click(listbox: ListBox input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 30 May 2013	cnwdap1		Initial creation CCMS 2274
//
vars

begin
	if listbox.listIndex = 1 then
		self.tblTrans.column := self.tblTrans.column - 1;
		self.tblTrans.setFocus;
		return;
	endif;
	self.tblTrans.accessRow(self.tblTrans.row).height := listbox.listCount * listbox.defaultLineHeight + 5;
epilog

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstMergeSplit_lostFocus" id="89571fe7-fcae-48bb-b5ed-132566f042b2">
        <controlMethod name="ListBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstMergeSplit_lostFocus(_listbox: ListBox input) updating;
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 29/05/2013	cnwdap1		Initial creation CCMS 2274 Split/Merge Break Bulk Cargo
// 19/06/2013	cnwcs5		par 31686a - fix problem with cellControl and superusers
// 08/11/2019	jlgzm1		TFS 47428 Scrolling with merge/split open causing weird scrolling issue
vars
	table			: CM_DataTable;
	row, detailCol 	: Integer;
begin
	table := self.tblTrans;
	
	table.getEntRowColumnByRowName(ETRow_Details, detailCol);	// par 31686a
	
	if detailCol &gt; table.fixedColumns then
		foreach row in table.fixedRows + 1 to table.rows do
			if table.accessCell(row, detailCol).cellControl = _listbox then			
				if table.row &lt;&gt; row then	// TFS 47428
					// if we've lost focus because we changed row then adjust size back to normal
					table.accessRow(row).height := table.accessRow(1).height;
				endif;
				break;
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstMergeSplit_pictureClick" id="4af00e4e-5ed2-4005-9c22-b9e17d3eb584">
        <controlMethod name="ListBox::pictureClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstMergeSplit_pictureClick(listbox: ListBox input; picIndex: Integer; whatClicked: Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 29/05/2013	cnwdap1		Initial creation CCMS 2274 Split/Merge Break Bulk Cargo
//
vars

begin
	if listbox.itemHasSubItems(picIndex) then
		listbox.itemExpanded[picIndex] := (not listbox.itemExpanded[picIndex]);
	endif;
	self.tblTrans.accessRow(self.tblTrans.row).height := listbox.listCount * listbox.defaultLineHeight + 5;
epilog

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="picIndex" type="Integer"/>
        <Parameter name="whatClicked" type="Integer"/>
    </JadeMethod>
