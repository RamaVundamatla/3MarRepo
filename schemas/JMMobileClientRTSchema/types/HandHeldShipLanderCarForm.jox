    <JadeMethod name="doSendAlertToControl" id="f44ea68f-49d3-4e4a-bad9-66cfd3b6daf2">
        <updating/>
        <source>doSendAlertToControl() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	15 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	errorDescr			: String;
begin
	errorDescr := self.txtWrongData.text.trimBlanks();
	app.myHandHeldCarGuiAgent.doSendAlertToControl(self.txtVehicle.text.trimBlanks.toUpper, errorDescr);
	app.msgBox('"' &amp; errorDescr &amp; '" has been sent to control', 'Error sent', MsgBox_OK_Only);
