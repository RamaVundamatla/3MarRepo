    <JadeMethod name="getDisplayStringForAttribute" id="d9d91df4-5907-4040-af44-5f89c38f468f">
        <source>getDisplayStringForAttribute( _attrName : String; _short : Boolean ) : String;
//----------------------------------------------------------------
//	Created:	
//----------------------------------------------------------------
//
/*
----------   ----------  --------------------------------------------------
Created:	02 September 2003	by Jason Chapman  (cnwjc2)

Purpose:	

Changed On   Changed By  Reason
05 Apr 2012	 cnwrs1		 Par 29391 - EDI RORO Stowage Advice hazard codes
21 Nov 2022  navma1	 	 ChangeRequest 55424: MTN - Improve the performance of Edi file loading
11 Jan 2023	 navkc1		 TFS CR 55625 TASK 55660 Task 55660: Jade - Contract Id EDI TRX
*/

vars
	cType	: CM_CargoType;
begin
	
	if _attrName = ETRow_Ignore or 									//21.11.2022 navma1 #55424
	   _attrName = ETRow_YardLocation then
	   
	   return null;
	elseif _attrName = ETRow_CargoType then							//21.11.2022 navma1 #55424
		cType := app.myRoot.allCargoTypesById[self.cargoType];
		if cType &lt;&gt; null then
			return cType.description;
		endif;
		return null;
	elseif _attrName = ETRow_CargoTypeDescr then
		return self.cargoTypeDescr;
	//elseif _attrName = ETRow_ImCodes or _attrName = ETRow_Hazards or _attrName = ETRow_Hazardous then			//21.11.2022 navma1 #55424
	//	return self.getHazardsAsString();																		//21.11.2022 navma1 #55424
	elseif _attrName = ETRow_HasChanged then
		return false.String;
	elseif _attrName = ETRow_Status then
		return self.displayStatus;
	elseif _attrName = ETRow_Any then
		return null;
	elseif _attrName = ETRow_VoyageCode then			// cnwrl1 14/07/2010 PAR 23499
		return self.getVoyageCode();					// cnwrl1 14/07/2010 PAR 23499
	elseif _attrName = ETRow_HsCode then										
		return self.hsCode;
	elseif _attrName = ETRow_ContractIdForTIstring then // 11/01/2023	navkc1	TFS CR 55625 TASK 55660
		return self.contractIdForTIstring;
	endif;
		
	return inheritMethod(_attrName, _short);

end;
</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
