    <JadeMethod name="doReturnWagon" id="af628cb8-db3c-4899-b037-f744b9e7c214">
        <updating/>
        <source>doReturnWagon(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars
	wagon : CM_Wagon;
begin
	if menuItem.userObject &lt;&gt; null and menuItem.userObject.isKindOf(CM_Wagon) then
		wagon := menuItem.userObject.CM_Wagon;
	endif;
	
	if wagon = null or not wagon.isDeparted then
		return;
	endif;
	
	lblReturnTo.caption := app.getErrorString1(Return_wagon_to,wagon.id);
	
	self.frmToolbar.enabled := false;
	self.buildComboAreas;
	self.cmbReturnPos.clear;
	if self.cmbReturnAreas.listObject &lt;&gt; null then
		self.buildComboPosition(self.cmbReturnAreas.listObject.CM_Rail);
	endif;
	
	self.frmReturnWagon.zOrder(1);
	self.frmReturnWagon.visible := true;
	self.frmReturnWagon.centreHorizontallyInParent();
	self.frmReturnWagon.top := 100;
		
epilog

end;</source>
