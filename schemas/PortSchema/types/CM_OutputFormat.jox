    <JadeMethod name="setForUpdate" id="0321700f-0c0b-4e91-bf45-bd29492079d0">
        <updating/>
        <source>setForUpdate( _proxy : CM_OutputFormat ) updating;
// ---------------------------------------------------------------------------
// Created:     02 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 13/01/2009	cnwrl1		Add myCM_Root (CCMS SFW 1047 - Totals Only Lists)
// 15/12/2009	cnwcs5		ccms 1023 - snapshot summaries
// ---------------------------------------------------------------------------
vars

begin
	self.name			:= _proxy.name;
	self.description	:= _proxy.description;	
epilog
	
end;</source>
        <Parameter name="_proxy" type="CM_OutputFormat"/>
    </JadeMethod>
    <JadeMethod name="setModeAndType" id="9c479aba-6a9d-4a14-8049-ad00e83126ac">
        <updating/>
        <source>setModeAndType(_value: Integer; _type: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2009	cnwndl1	Initial creation - Migrated up

*/

vars
	
begin
	if self.mode = _value and self.type = _type then	// because this is being called on lost focus when not real updating is being done.
		return;
	endif;
	
	self.raiseExceptionIfNotTransient(method);
	
	self.mode := _value;
	self.type := _type;	//24 Nov 2009	NDL	CCMS 1028
epilog
	
end;</source>
        <Parameter name="_value" type="Integer"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMyCM_Root" id="ea9c6af1-bafe-4364-97d4-686b83f5c4a5">
        <updating/>
        <source>setMyCM_Root( _value : CM_Root ) updating;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
12 January 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	
begin
	if self.myCM_Root &lt;&gt; _value then
		self.myCM_Root	:= _value;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_value" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="setName" id="372a70ad-c26a-4f25-9840-5488b1aac3a1">
        <updating/>
        <source>setName( _value : String ) updating;
// ---------------------------------------------------------------------------
// Created:     02 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09/01/2009	cnwrl1		Stop exception when not actually doing any updating (CCMS SFW 1047 - Totals Only Lists)
// ---------------------------------------------------------------------------
vars
	
begin
//	if self.name = _value then	// because this is being called on lost focus when not real updating is being done.	// cnwrl1 15/09/2009 PAR 20203 - what it was
	// because this is being called on lost focus when not real updating is being done.
	if self.name = _value[ 1 : self.name.maxLength ] then
		return;
	endif;
	
	self.raiseExceptionIfNotTransient( method );
	
//	self.name	:= _value;				// cnwrl1 15/09/2009 PAR 20203 - what it was
	self.name	:= _value[ 1 : self.name.maxLength ];
	
epilog
	
end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="a85b52a9-29d7-4ec7-a5f3-728fac5185ac">
        <source>validateForDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 November 2020	jlgndl1	Initial creation	TFS 50279

*/

vars

	whereUsed : String;

begin

	if self.isUsedinConfig( whereUsed ) then
		app.raiseCMException2(ERR_CANNOT_DELETE, self.name, whereUsed, null, self);
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
