    <JadeMethod name="importFromXMLDoc" id="9038efc3-f1dc-40be-a6b5-24630c525e82">
        <updating/>
        <source>importFromXMLDoc(_jadeXMLElement: JadeXMLElement input) updating;
/*

Purpose:			Populate the receiver proxy from the incoming XML document

Parameters:			XML document representing the new Vessel

Return Value:		None


Date		Who		Reason
20 Apr 2012	cnwer1	Initial creation CCMS MES 1035
21 Sep 2012	cnwkpd1	PAR #30392 - Problem importing Vessel from HMS system into non-HMS system

*/

vars

begin
	inheritMethod(_jadeXMLElement);
	
	//blank out the code for import forcing user to enter the code
	self.code := null;

	// PAR #30392 - If the current system has different licences to the system where the file
	// was created, then there may be data created that should not be allowed, so delete it
	// from the proxy before trying to create the real Vessel
	
	// Harbour Details
	if self.myHMSVesselData &lt;&gt; null then
		if not app.myRoot.canDo(Mod_Harbour)  then
			delete self.myHMSVesselData;
		endif;		
	endif;

	// General Cargo Details
	if self.myGeneralCargoVesselStructure &lt;&gt; null then
		if not app.myRoot.canDo(Mod_GeneralCargo) then
			delete self.myGeneralCargoVesselStructure;
		endif;
	endif;
	
	// Cellular Structure
	// ### JIRA 33505 30DEC2024 NAVAB1 (Mod_CargoShip in part of base now)	
	/*
	if self.myCellularVesselStructure &lt;&gt; null then
	//	if not app.myRoot.canDo(PmShipPlanning) then
		if not app.myRoot.canDo(PmCargoShipMod) then//07 Oct 2019	NDL	TFS 46169
			delete self.myCellularVesselStructure;
		endif;
	endif;
	*/
	
	// RORO Structure
	if self.myROROVesselStructure &lt;&gt; null then
		if not app.myRoot.canDo(Mod_VesselRORO) then
			delete self.myROROVesselStructure;
		endif;
	endif;
	
	
epilog

end;</source>
        <Parameter name="_jadeXMLElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="importFromXMLDocReference" id="f18435a5-6fb5-416e-a9b7-aa0575d2a162">
        <updating/>
        <source>importFromXMLDocReference(_property: Property; _xmlElement: JadeXMLElement input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	childElement : JadeXMLElement;
	
begin
	if  _property = CM_Vessel::myDefaultTrade then
		childElement:=_xmlElement.getElementByTagName(CM_Trade::description.name);	
		if childElement &lt;&gt; null then
			self.myDefaultTrade:=app.myRoot.allTradesByDescription[childElement.textData];
		endif;
	elseif  _property = CM_Vessel::myOperator then
		childElement:=_xmlElement.getElementByTagName(CM_Operator::code.name);	
		if childElement &lt;&gt; null then
			self.myOperator:=app.myRoot.allOperators[childElement.textData];
		endif;
	elseif _property = CM_Vessel::myHMSVesselData then
		create self.myHMSVesselData transient;
		self.myHMSVesselData.importFromXMLDoc(_xmlElement);
	elseif _property  = CM_Vessel::myCellularVesselStructure then
		create self.myCellularVesselStructure transient;
		self.myCellularVesselStructure.importFromXMLDoc(_xmlElement);
	elseif _property  = CM_Vessel::myROROVesselStructure then
		create self.myROROVesselStructure transient;
		self.myROROVesselStructure.importFromXMLDoc(_xmlElement);
	elseif _property  = CM_Vessel::myStructuralElements then
		create self.myStructuralElements transient;
		self.myStructuralElements.importFromXMLDoc(_xmlElement);		
	elseif _property = CM_Vessel::myGeneralCargoVesselStructure  then
		create self.myGeneralCargoVesselStructure transient;
		self.myGeneralCargoVesselStructure.importFromXMLDoc(_xmlElement);
	elseif _property = CM_Vessel::myVoyageAllocationConfig then
		create self.myVoyageAllocationConfig transient;
		self.myVoyageAllocationConfig.importFromXMLDoc(_xmlElement);
	else
		inheritMethod(_property, _xmlElement);
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initializeForActivity" id="0f5edd71-e110-40f7-899d-2a453cc63980">
        <updating/>
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables) updating;
/*
Purpose:			

Date		Who		Reason
14 September 2022	navab1	TFS 53105
*/

vars
	vesClass : CMIF_VslVesselClasses;
	vesVessel : CMIF_VslVessels;
	canCarryCargo : Boolean;
begin

	if _opsViewTable.isKindOf(CMIF_VslVesselClasses) then // ### TFS 53105 14SEP2022 NAVAB1
		vesClass := _opsViewTable.CMIF_VslVesselClasses;
		
		vesClass.gkey 			:= vesClass.generateFullGKey(self, ""); 	//The vesselClasse will have the same gkey as the vsl_vessel it would describe
		vesClass.id				:= self.code; 
		vesClass.name			:= self.name; 
		
		canCarryCargo := false;
		if self.structureIncludesHolds or self.structureIncludesRORO then
			canCarryCargo := true;
		endif;
		
		if canCarryCargo and self.structureIncludesLOLO then
			vesClass.basic_class := "MIXED";
		elseif canCarryCargo = true then
			vesClass.basic_class := "BBULK";	
		elseif self.structureIncludesLOLO then
			vesClass.basic_class := "CELL"; 
		else
			vesClass.basic_class := "UNKNOWN";
		endif;
		
		if self.canCreateVoyages then
			vesClass.is_active := true;
			vesClass.life_cycle_state := "ACT";
		else
			vesClass.is_active := false;
			vesClass.life_cycle_state :="OBS";
		endif;
	elseif _opsViewTable.isKindOf(CMIF_VslVessels) then // ### TFS 53105 14SEP2022 NAVAB1
		vesVessel := _opsViewTable.CMIF_VslVessels;
		vesVessel.gkey := vesVessel.generateFullGKey(self, ""); 
		vesVessel.id	:= self.code; 
		vesVessel.name	:= self.name; 
		vesVessel.vesclass_gkey := vesVessel.generateFullGKey(self, ""); // navra1 - 8th Sep 2022 - TFS53105
	endif;
	
epilog

end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
