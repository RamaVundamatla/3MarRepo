    <JadeMethod name="configureForkLiftStack" id="0ca5817f-a4c5-4c7f-9cfd-75d7a6a4ec6f">
        <updating/>
        <source>configureForkLiftStack(_exportClass: CM_ExportImportClass io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation

*/

vars
    builder: CM_ExportPropertyConfigBuilder;
begin
    create builder transient;
    
    builder.forClass(_exportClass)
        .property(CM_ForkLiftStack::id, "Terminal Area ID").asKey()
        .property(CM_ForkLiftStack::type, "Terminal Area Type")
        .property(CM_ForkLiftStack::comment, "Comment")
        .property(CM_ForkLiftStack::numberOfRows, "Width Rows")
        .property(CM_ForkLiftStack::numberOfColumns, "Length Cols")
        .property(CM_ForkLiftStack::heightOfStack, "Height Positions")
        .property(CM_ForkLiftStack::topLabel, "Top Label")
        .property(CM_ForkLiftStack::bottomLabel, "Bottom Label")
        .property(CM_ForkLiftStack::leftLabel, "Left Label")
        .property(CM_ForkLiftStack::rightLabel, "Right Label")
        .property(CM_ForkLiftStack::maxHeightFull, "Maximum Height Full ft")
        .property(CM_ForkLiftStack::maxHeightMT, "Maximum Height MT ft")
        .property(CM_ForkLiftStack::maxHeightPower, "Maximum Height Power ft")
        .property(CM_ForkLiftStack::use40ftIds, "Use 40ft IDs")
        .property(CM_ForkLiftStack::accessBack, "Access Stack From Top")
        .property(CM_ForkLiftStack::accessFront, "Access Stack From Bottom")
        .property(CM_ForkLiftStack::actAsReleasePoint, "Act As Release Point")
        .property(CM_ForkLiftStack::isStockControlled, "Stock Controlled")
        .property(CM_ForkLiftStack::hideFromOverView, "Hide From Overview")
        .property(CM_ForkLiftStack::staggerHeights, "Staggering Heights")
