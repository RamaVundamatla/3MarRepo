    <JadeMethod name="getCurrentState" id="49112712-63fd-42ef-8357-db83a17732e4">
        <source>getCurrentState(): String;

/*
Date			Who		Reason
08 July 2016	cnwar2	Initial creation

*/
vars
	state : DEV_SupportState;
begin
	
	state := self.allStates.last;
	
	if state = null then
		return "no state";
	else
		return state.type;
	endif;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getKPI1Report" id="4f4e8fc6-7af9-4871-bec2-a0cca02c15ab">
        <source>getKPI1Report(): String;

/*
Date			Who		Reason
03 August 2016	cnwar2	Initial creation

*/
vars

begin
	if self.kpi1FailedBy &lt;&gt; '' then
		return self.kpi1FailedBy;
	else
		return self.getRemainingTimeKPI1();
	endif;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
