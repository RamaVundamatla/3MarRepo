    <JadeMethod name="doBtnCargoUnplanCLick" id="b461b361-bfd0-4b38-9eb4-f71e5c4f8b97">
        <updating/>
        <source>doBtnCargoUnplanCLick() updating;
/*
Purpose:			
Date				Who			Reason
OCTOBER 2011		CNWAB1		Initial creation
*/

vars
	anObj : Object;
	tmpWLE : CM_WorkListEntry;
	aTI : CM_TrackedItem;
	str : String;
	idx : Integer;
	ls : Boolean;
	wles : CM_WLEArray;
	aReq : CM_RORORequest;
begin
	if self.myROROLocnDrawingController.allSelectedObjects.isEmpty then
		return;
	endif;

	create wles transient;
	
	foreach anObj in self.myROROLocnDrawingController.allSelectedObjects do
		idx := idx + 1;
		
		if anObj.isKindOf(CM_VoyageROROController) then
			if self.myROROLocnDrawingController.modeView = ShpDisplayMode_ColCodeLoad then
				aReq := anObj.CM_VoyageROROController.myRORORequestLoad.CM_RORORequest;
			else
				aReq := anObj.CM_VoyageROROController.myRORORequestDischarge.CM_RORORequest;
			endif;
			if aReq &lt;&gt; null then
				if aReq.myJob = null then
					continue;
				endif;
				foreach tmpWLE in aReq.allWorkListEntries discreteLock do
					if tmpWLE.myFutureMove = null then
						continue;
					endif;
					aTI := tmpWLE.myTrackedItem;
					if aTI &lt;&gt; null then
						if str = null then
							str := aTI.id;
						else
							if idx mod 3 = 0 then
								str := str &amp; ", " &amp; Cr &amp; aTI.id;
							else
								str := str &amp; ", " &amp; aTI.id;
							endif;
						endif;
						wles.add(tmpWLE);
					endif;
				endforeach;
			endif;
		endif;
	endforeach;
	
	// PAR 18695
	if wles.isEmpty() then
		app.msgBox("Please select some cargo to unplan.","Problem",MsgBox_OK_Only);
		return;
	else
		if app.msgBox(app.getErrorString(Unplan_GC) &amp; str &amp; "?", app.getErrorString(SHP_Confirm_Unplan_Cargo),MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			global.beep;
			return;
		endif;
	endif;
	
	app.cmsBeginLoad(ls);

	self.doUnplanTIs(wles, PLANNING_MODE);	// Dec 2011 cnwjre1 28636 RORO unplanning of queued load moves
	
epilog
	app.cmsEndLoad(ls);
	delete wles;
end;</source>
    </JadeMethod>
