    <JadeMethod name="uDeleteOldInvoices" id="68ab8636-b144-4193-9873-972555a3e91b">
        <source>uDeleteOldInvoices();
// delete old empty invoices, posted or not
vars
	date		: Date;
	count		: Integer;
	terminal	: CM_Terminal;
	company		: CM_Bank;
	invoice		: CM_Invoice;
begin
	date := "01/01/2014".Date;
	
	foreach terminal in CM_Root.firstInstance.allTerminals do
		count := 0;
		beginTransaction;
		foreach company in terminal.companies do
			foreach invoice in company.allInvoices do
				if invoice.invoiceLines.isEmpty() and
				   invoice.allCashPayments.isEmpty() and
				   invoice.toDT.date &lt; date then
					invoice.zDeleteLine();
					count := count + 1;
				endif;
			endforeach;
		endforeach;
		commitTransaction;
		write terminal.code &amp; " " &amp; count.String &amp; " old empty invoices deleted";
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="uExternalInterfaceADP" id="94203ffb-d7c5-4782-a955-420eb81cb922">
        <source>uExternalInterfaceADP();
/*
Purpose:			
Date				Who			Reason
APRIL 2015		NAVAB1		Initial creation
*/
constants
	CONTID = "ADPU0002276";
vars
	lineCount	: Integer;
	calcType	: CM_CalculationType;
	service		: CM_Service;
	ild			: CM_InvoiceLineDesc;
	invType		: CM_InvoiceDesc;
	services	: CM_ServiceByNameDict;
	allServices	: CM_ServiceByNameDict;
	operator	: CM_Operator;
	start,
	expiry : TimeStamp;
	ignoreEntry : Boolean;
	costValue	: Decimal[8,2];
	costs : DecimalArray;
	debtor : CM_DebtorNode;
	debtorRate : CM_DebtorRate;
	rateEntry : CM_RateEntry;
	ti: CM_TrackedItem;
	invoice	: CM_Invoice;
	selectedTypes: CM_CargoBOLTypeSet;
	stopsTable: CM_StopsTable;
	processAreas: IntegerArray;
	opts : CM_AssociationDict;
	trans : CM_TransactionSet;
	tran : CM_TITransaction;
	transients	: ObjectArray;
	glCode : CM_GLCode;
	ioClassActual : CM_ExtFinanceIO;
	ioClassForTest : CM_ADPInterface;
	origPath : String;
	
begin


	// delete any old objects
	self.deleteContainer(CONTID);
	self.deleteStopsTable(99);
	self.deleteStopsTable(78);
	self.deleteInvoiceLineType("UT_ADPInvLineType1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_ADPInvLineType2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_ADPInvLineType3", FORCED_ERASE);
	self.deleteInvoiceService("UT_ADPService1", FORCED_ERASE);
	self.deleteInvoiceService("UT_ADPService2", FORCED_ERASE);
	self.deleteInvoiceService("UT_ADPService3", FORCED_ERASE);
	self.deleteInvoiceGLCode("UT_ADP1-0001");
	self.deleteInvoiceGLCode("UT_ADP1-0002");
	self.deleteInvoiceGLCode("UT_ADP1-0003");
	self.deleteInvoiceGLCode("UT_ADP1-0004");
	self.deleteInvoiceGLCode("UT_ADP1-0005");
	self.deleteInvoiceGLCode("UT_ADP1-0006");
	
	
	self.deleteFolderContents(app.cnGetClientMiscPath(true), "Inv"); // &amp; "..\c_misc\");
		

	ioClassActual := self.getTerminalConfig(FinancialIOClass).CM_ExtFinanceIO;

	// We are going to write out 3 files as part of the normal ADP export, but we should not use the configured export path, instead we will use c_misc on the server
	ioClassForTest := CM_ADPInterface.firstInstance().CM_ADPInterface;
	if ioClassForTest = null then	
		ioClassForTest := app.myTrxCA.trxCreateExternalFinanceClass(CM_ADPInterface).CM_ADPInterface;
	endif;
	if ioClassForTest &lt;&gt; null then	
		self.setTerminalConfig(FinancialIOClass,ioClassForTest);
		origPath := ioClassForTest.exportPath;
		beginTransaction;
		ioClassForTest.exportPath := "..\c_misc\";
		commitTransaction;
	endif;
	
	
	
	create transients transient;
	// create new instances
	create services transient;
	create allServices transient;
	
	invType := self.getInvoiceType("UT_ADPINVTYPE");
	if invType = null then
		self.assertNotNullMsg(invType, "Invoice type UT_InvType not created");
	endif;

	// three services and invoice line descs, for calc type of Quantity, Weight and Weight (tonnes)
	calcType := app.myRoot.allCalculationTypesByCode['CCT01'];		// Units (Qty)
	self.assertNotNullMsg(calcType, "Calculation type CCT01 not found");

	glCode := self.createInvoiceGLCode("UT_ADP1-0004", "UnitTest ADP 1");
	service := self.createInvoiceService("UT_ADPService1", "1235", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	allServices.add(service);
	
	services.add(service);
	ild := self.createInvoiceLineType("UT_ADPInvLineType1", calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	calcType := app.myRoot.allCalculationTypesByCode['CCT04'];		// Weight (kilos)
	self.assertNotNullMsg(calcType, "Calculation type CCT04 not found");

	glCode := self.createInvoiceGLCode("UT_ADP1-0005", "UnitTest ADP 2");
	service := self.createInvoiceService("UT_ADPService2", "9823", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	allServices.add(service);
	
	services.clear();
	services.add(service);
	ild := self.createInvoiceLineType("UT_ADPInvLineType2", calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	calcType := app.myRoot.allCalculationTypesByCode['CCT08'];		// Weight (tonnes)
	self.assertNotNullMsg(calcType, "Calculation type CCT08 not found");

	glCode := self.createInvoiceGLCode("UT_ADP1-0006", "UnitTest ADP 3");
	service := self.createInvoiceService("UT_ADPService3", "4451", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	allServices.add(service);
	
	services.clear();
	services.add(service);
	ild := self.createInvoiceLineType("UT_ADPInvLineType3", calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	self.tranMapLoadADPInterface();

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	
	debtor := operator.debtor;
	
	// set rates such that a known invoice line value is the lowest or highest 
	self.cargoADPInterfaceRates(allServices);

	
	// create a container
	self.opts.addAssoc(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	self.opts.addAssoc(UTTI_CustomsEntryNumber, "ADPCLEAR9");
	self.opts.addAssoc(UTTI_Remarks, "This better Bloody Work");
	self.opts.addAssoc(UTTI_Consignee,"UTXE2" );	//24 Jun 2015	NDL	Par 36514
	
	ti := self.addContainerOpts(CONTID, "22G1", "GENL", operator);	
	create selectedTypes transient;
	selectedTypes.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	create processAreas transient;
	processAreas.add(StopProcessCopyToChild);
	create opts transient;
	opts.addAssoc(ETRow_ProcessStopAreas, processAreas);
	stopsTable := addStopsTable(99, "UT", "Unit Test", selectedTypes, opts);

	self.addStop(ti, stopsTable);
	stopsTable := addStopsTable(78, "UT2", "Unit Test2 ", selectedTypes, opts);
	self.addStop(ti, stopsTable);

	
	// ##########################
	// ##########################
	// ##########################
	// ##########################
	// ### If need to manually test  uncomment this 'return'
	//return;
	
	invoice := ti.invoiceLines.first.invoice;
	
	self.postInvoice(invoice, true, false);
	
	self.validateADPInvoiceFiles(invoice, self.getTerminal().code &amp; invoice.sequenceNum.String);
	
epilog
	self.resetDefaultTranMap();
	// delete this tran map so following tests can delete the invoice line descs etc
	self.deleteInvoiceTransactionMap(1, 'UT_CargoADP');
	if ioClassForTest &lt;&gt; null then	
		beginTransaction;
		ioClassActual.exportPath := origPath;
		commitTransaction;
	endif;
	
	delete services;
	delete allServices;
	delete costs;
	if transients &lt;&gt; null then
		transients.purge();
		delete transients;
	endif;
	delete selectedTypes;
	delete processAreas;
	delete opts;
	delete trans;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="uExternalInterfaceDPH" id="4bfe1af1-eddd-44d1-9bbf-5d40af80e55c">
        <source>uExternalInterfaceDPH();
/*
Purpose:			
Date		Who		Reason
21 May 2013	NAVAB1	Initial creation
*/
constants
	CONTID = "DPHU0002276";
vars
	lineCount	: Integer;
	calcType	: CM_CalculationType;
	service		: CM_Service;
	ild			: CM_InvoiceLineDesc;
	invType		: CM_InvoiceDesc;
	services	: CM_ServiceByNameDict;
	allServices	: CM_ServiceByNameDict;
	operator	: CM_Operator;
	start,
	expiry : TimeStamp;
	ignoreEntry : Boolean;
	costValue	: Decimal[8,2];
	costs : DecimalArray;
	debtor : CM_DebtorNode;
	debtorRate : CM_DebtorRate;
	rateEntry : CM_RateEntry;
	ti: CM_TrackedItem;
	invoice	: CM_Invoice;
	selectedTypes: CM_CargoBOLTypeSet;
	stopsTable: CM_StopsTable;
	processAreas: IntegerArray;
	opts : CM_AssociationDict;
	trans : CM_TransactionSet;
	tran : CM_TITransaction;
	transients	: ObjectArray;
	glCode : CM_GLCode;
	ioClassActual : CM_ExtFinanceIO;
	ioClassForTest : CM_DPHPortusJax;
	origPath : String;
begin


	// delete any old objects
	self.deleteContainer(CONTID);
	self.deleteStopsTable(99);
	self.deleteStopsTable(78);
	self.deleteInvoiceLineType("UT_DPHInvLineType1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_DPHInvLineType2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_DPHInvLineType3", FORCED_ERASE);
	self.deleteInvoiceService("UT_DPHService1", FORCED_ERASE);
	self.deleteInvoiceService("UT_DPHService2", FORCED_ERASE);
	self.deleteInvoiceService("UT_DPHService3", FORCED_ERASE);
	self.deleteInvoiceGLCode("1235-55654");
	self.deleteInvoiceGLCode("9823-56543");
	self.deleteInvoiceGLCode("4451-66100");
	
	

	ioClassActual := self.getTerminalConfig(FinancialIOClass).CM_ExtFinanceIO;

	// We are going to write out 3 files as part of the normal DPH export, but we should not use the configured export path, instead we will use c_misc on the server
	ioClassForTest := CM_DPHPortusJax.firstInstance().CM_DPHPortusJax;
	if ioClassForTest = null then	
		ioClassForTest := app.myTrxCA.trxCreateExternalFinanceClass(CM_DPHPortusJax).CM_DPHPortusJax;
	endif;
	if ioClassForTest &lt;&gt; null then	
		self.setTerminalConfig(FinancialIOClass,ioClassForTest);
		origPath := ioClassForTest.exportPath;
		beginTransaction;
		ioClassForTest.exportPath := "..\c_misc\";
		commitTransaction;
	endif;
	
	
	
	create transients transient;
	// create new instances
	create services transient;
	create allServices transient;
	invType := self.getInvoiceType("UT_DPHINVTYPE");
	self.assertNotNullMsg(invType, "Invoice type UT_InvType not created");

	// three services and invoice line descs, for calc type of Quantity, Weight and Weight (tonnes)
	calcType := app.myRoot.allCalculationTypesByCode['CCT01'];		// Units (Qty)
	self.assertNotNullMsg(calcType, "Calculation type CCT01 not found");

	glCode := self.createInvoiceGLCode("1235-55654", "UnitTest DPH 1");
	service := self.createInvoiceService("UT_DPHService1", "1235", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	allServices.add(service);
	
	services.add(service);
	ild := self.createInvoiceLineType("UT_DPHInvLineType1", calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	calcType := app.myRoot.allCalculationTypesByCode['CCT04'];		// Weight (kilos)
	self.assertNotNullMsg(calcType, "Calculation type CCT04 not found");

	glCode := self.createInvoiceGLCode("9823-56543", "UnitTest DPH 2");
	service := self.createInvoiceService("UT_DPHService2", "9823", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	allServices.add(service);
	
	services.clear();
	services.add(service);
	ild := self.createInvoiceLineType("UT_DPHInvLineType2", calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	calcType := app.myRoot.allCalculationTypesByCode['CCT08'];		// Weight (tonnes)
	self.assertNotNullMsg(calcType, "Calculation type CCT08 not found");

	glCode := self.createInvoiceGLCode("4451-66100", "UnitTest DPH 3");
	service := self.createInvoiceService("UT_DPHService3", "4451", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	allServices.add(service);
	
	services.clear();
	services.add(service);
	ild := self.createInvoiceLineType("UT_DPHInvLineType3", calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	self.tranMapLoadDPHInterface();

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	
	debtor := operator.debtor;
	// set rates such that a known invoice line value is the lowest or highest 
	self.cargoDPHInterfaceRates(allServices);

	
	// create a container
	self.opts.addAssoc(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	ti := self.addContainerOpts(CONTID, "22G1", "GENL", operator);	
	create selectedTypes transient;
	selectedTypes.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	create processAreas transient;
	processAreas.add(StopProcessCopyToChild);
	create opts transient;
	opts.addAssoc(ETRow_ProcessStopAreas, processAreas);
	stopsTable := addStopsTable(99, "UT", "Unit Test", selectedTypes, opts);

	self.addStop(ti, stopsTable);
	stopsTable := addStopsTable(78, "UT2", "Unit Test2 ", selectedTypes, opts);
	self.addStop(ti, stopsTable);

	
	// ##########################
	// ##########################
	// ##########################
	// ##########################
	// ### If need to manually test  uncomment this 'return'
	//return;
	
	invoice := ti.invoiceLines.first.invoice;
	self.postInvoice(invoice, true, false);
	
	self.validateDPHInvoiceFiles(invoice, self.getTerminal().code &amp; invoice.sequenceNum.String);
	
epilog
	self.resetDefaultTranMap();
	// delete this tran map so following tests can delete the invoice line descs etc
	self.deleteInvoiceTransactionMap(1, 'UT_CargoDPH');
	if ioClassForTest &lt;&gt; null then	
		beginTransaction;
		ioClassActual.exportPath := origPath;
		commitTransaction;
	endif;
	
	delete services;
	delete allServices;
	delete costs;
	if transients &lt;&gt; null then
		transients.purge();
		delete transients;
	endif;
	delete selectedTypes;
	delete processAreas;
	delete opts;
	delete trans;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="uHMSInvoicing" id="173ef837-3402-42fb-abbb-e801762cfe72">
        <updating/>
        <source>uHMSInvoicing() updating;
// cnwjre1	from CCMS 1264 non-virtual rate and quantity
// 		set up for HMS invoicing of resources
//	Still in-progress ...
vars
	term		: CM_Terminal;
	calcType	: CM_CalculationType;
	service		: CM_Service;
	services	: CM_ServiceByNameDict;
	invType		: CM_InvoiceDesc;
	ild			: CM_InvoiceLineDesc;
	resourceType	: HMS_ResourceType;
	origHarbour,
	harbour		: HMS_Harbour;
	wharf		: HMS_Wharf;
	berth		: HMS_Berth;
	resource	: HMS_Resource;
	tug			: HMS_Tug;
	voyage		: CM_Voyage;
	oa			: ObjectArray;
begin
	term := self.getTerminal();
	origHarbour := term.myHarbour;
	// clear terminal harbour so can add new one
	beginTransaction;
	origHarbour.allTerminalsByCode.remove(term);
	commitTransaction;

	// TUGS calculation type
	self.deleteInvoiceService("UTTugs Shift", FORCED_ERASE);
	self.deleteInvoiceCalcType("UTTUGS");	
	calcType := self.createInvoiceCalcType(null, INV_CALC_TYPE_VESSEL_TON, "UTTUGS", "Tugs", 
										  0, 0, 0, 0, null, false,
										  null, null, 600.00, 0, 0,
										  null, null, null, null,
										  false, true, false,
										  null, null, null, null);
	
	// TUGS service
	service := self.createInvoiceService("UTTugs Shift","Tugs", calcType, null);
	
	// Marine invoice type
	self.deleteInvoiceType("UTMarine");
	invType := self.createInvoiceType("UTMarine", InvoiceTypeGeneral);

	// Tugs Shift invoice line description
	self.deleteInvoiceLineType("UTTugs - Shift", FORCED_ERASE);
	create services transient;
 	services.add(service);
	
	// invoice type
	ild := self.createInvoiceLineType("UTTugs - Shift", calcType, invType, services, "SDT1");
	
	// harbour
	create oa transient;
	oa.add(term);
	self.opts.purge();
	self.opts.addAssoc("IgnoreWarnings", true);
	self.opts.addAssoc("Terminals", oa);
	harbour := app.myRoot.allHarbours["UTHAVEN"];
	if harbour = null then
		harbour := self.addHarbour("UTHAVEN", "Test harbour").HMS_Harbour;
	endif;
	
	// wharf
	wharf := harbour.allWharves["UTWHARF"].HMS_Wharf;
	if wharf = null then
		wharf := self.addWharf("UTWHARF","Test wharf", harbour, 100, 10);
	endif;
	
	// berth
	berth := harbour.allBerths["UTBERTH"];
	if berth = null then
		berth := self.addBerth("UTBERTH", "Test berth", harbour, 1, 50, 2.5, false, wharf);
	endif;
	
	// resource type - delete used resource first
	self.deleteHarbourResource("UTTUGSH", harbour);
	resourceType := self.addHMSResourceType("UTTUGS", "Test Tugs", null, 0, true, false,
											false, false, true, false);

	// resource
	resource := self.addHarbourResource("UTTUGSH", "Tugs - Shift", harbour, resourceType, null, 
										0, 0, false);
										
	// tug
	tug := self.addHMSTug("UTHM", "Test harbour tug", harbour);
	
	// vessel and voyage with HMS data
	self.opts.purge();
	self.opts.addAssoc("useHMSData", true);
	self.opts.addAssoc("berth", berth);
	voyage := self.createVesselVoyage(null,null,null);
	self.updateVoyageHMS(voyage, 11111, 12222, 20.0, 5.0, 60000, 0);

epilog
	delete services;
	delete oa;
	// restore original harbour
	if term &lt;&gt; null and origHarbour &lt;&gt; null and
	   global.isValidObject(origHarbour) then
		beginTransaction;
		if harbour &lt;&gt; null and harbour.allTerminalsByCode &lt;&gt; null and 
				harbour.allTerminalsByCode.includes(term) then
			harbour.allTerminalsByCode.remove(term);
		endif;
		origHarbour.allTerminalsByCode.add(term);
		commitTransaction;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="uHMSQtyMinMax" id="40ae0c5f-b92c-4921-9837-d90c04dc6895">
        <updating/>
        <source>uHMSQtyMinMax() updating;
// cnwjre1	general HMS water usage - as in Appendix A of the Invoicing User Manual
//	Variant using a calculation type with min and max rates set
vars
	now			: Date;
	time		: Time;
	count		: Integer;
	start		: TimeStamp;
	fromDateTime, 
	toDateTime	: TimeStamp;
	costs		: DecimalArray;
	term		: CM_Terminal;
	calcType	: CM_CalculationType;
	service		: CM_Service;
	services	: CM_ServiceByNameDict;
	invType		: CM_InvoiceDesc;
	ild			: CM_InvoiceLineDesc;
	resourceType	: HMS_ResourceType;
	harbour		: HMS_Harbour;
	berth		: HMS_Berth;
	wharf		: HMS_Wharf;
	resource	: HMS_Resource;
	resUsed		: HMS_ResourceUsed;
	operator	: CM_Operator;
	debtor		: CM_Debtor;
	pxyDebtorRate,
	debtorRate	: CM_DebtorRate;
	rateEntry	: CM_RateEntry;
	voyage		: CM_Voyage;
	movement	: HMS_VoyageMovement;
	transSet	: CM_TransactionSet;
	invoice		: CM_Invoice;
	invoiceLines : ObjectArray;
	bank		: CM_Bank;

begin
	term := self.getTerminal();
	harbour := term.myHarbour;
	berth := harbour.allBerths.last;
	wharf := berth.myWharf;
	bank := self.getTerminal().getDefaultCompanyBank();

	// Water calculation type
	service := bank.services["UTWater"];
	//  delete any invoice (lines, charges) using the service first so can delete the service
	if service &lt;&gt; null then
		self.deleteInvoicesUsingService(service);
	endif;
	// delete the service so can delete the calculation type
	self.deleteInvoiceService("UTWater", FORCED_ERASE);
	self.deleteInvoiceCalcType("UTH2O");	
	calcType := self.createInvoiceCalcType(null, INV_CALC_TYPE_RESOURCE_QTY, "UTH2O", "Water usage", 
										  0, 0, 0, 0, null, false,
										  null, null, 6, 12, 0,		// min and max rates
										  null, null, null, null,
										  false, true, false,		// is voyage type=true
										  null, null, null, null);
	
	// Water service
	service := self.createInvoiceService("UTWater","Water Used", calcType, null);
	
	// Voyage invoice type
	self.deleteInvoiceType("UTVoyage");
	invType := self.createInvoiceTypeFull(CM_InvoiceDesc.Accrue_Until_Manually_Closed,
											null,
											"UTVoyage",
											CM_InvoiceDesc.Key_Voyage,
											InvoiceTypeGeneral,
											null,
											null,
											true,
											InvTypeTrigger_Release,
											now,
											now,
											0,
											"");

	// delete transaction map
	self.deleteInvoiceTransactionMap(3, 'UT_VTMIS1');
	
	// Water usage invoice line description
	self.deleteInvoiceLineType("UTWaterUsage", FORCED_ERASE);
	create services transient;
 	services.add(service);
	
	// invoice type
	ild := self.createInvoiceLineType("UTWaterUsage", calcType, invType, services, "SDT4");	// charge ship operator
	
	// resource type - delete used resource first
	self.deleteHarbourResource("UTWATER01", harbour);
	resourceType := self.addHMSResourceType("UTWATER", "Water Usage", "m3", 0, true, true,
											false, false, false, false);

	// resource
	resource := self.addHarbourResource("UTWATER01", "Water meter 1 usage", harbour, resourceType, wharf, 
										0, 0, false);
										
	// vessel and voyage with HMS data
	self.opts.purge();
	self.opts.addAssoc("useHMSData", true);
	self.opts.addAssoc("berth", berth);
	voyage := self.createVesselVoyage3();
	self.updateVoyageHMS(voyage, 11111, 12222, 20.0, 5.0, 60000, 0);
	
	// load HMS transaction map
	self.tranMapLoadVTMIS1();
	
	// movement maintenance, add resource usage (1200 units)
	fromDateTime.setDate(now);
	fromDateTime.setTime(time);
	movement := voyage.myHMSVoyageData.allVoyageMovements.first;
	self.addHMSResourceToMovement(resourceType, resource, null, fromDateTime, toDateTime,  1200, false, movement);
	// set the move status so invoicing will take place
	beginTransaction;
	foreach movement in voyage.myHMSVoyageData.allVoyageMovements do
		movement.setPropertyValue("moveStatusNEW", MovementStatus_Actual);
	endforeach;
	commitTransaction;

	create costs transient;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	
	debtor := operator.debtor;
// set a rate ($3.00) for the service and actual debtor
//	NOTE: this should be overriden by the calculation type minimum
	create pxyDebtorRate transient;
	pxyDebtorRate.setProxy(service, debtor);
	costs.add(3.00);
	start.setDate("01/05/2010".Date);
	start.setTime("00:00".Time);
	rateEntry := self.addInvoiceRateEntry(pxyDebtorRate, start, null, false, costs, 0, 0, null, null);

	// generate invoice
	self.generateVoyageInvoicing(voyage);
	
	// test invoice - should be one, with one line
	foreach invoice in voyage.allInvoices do
		count := count + 1;
		validateHMSInvoice2(invoice, count);
	endforeach;
	self.assertEqualMsg(count, 1, "Voyage Invoices, test 1");
	
	// do a resync of the VTMIS transactions - should stay the same
	create transSet transient;
	foreach movement in voyage.myHMSVoyageData.allVoyageMovements do
		foreach resUsed in movement.allResourceUsed do
			if resUsed.myVTMISTransaction &lt;&gt; null then
				transSet.add(resUsed.myVTMISTransaction);
			endif;
		endforeach;
	endforeach;
	///self.updateInvoiceReevaluate(transSet, null);	//uncomment once par 29833 has been fixed
	// test invoice - should still be one, with one line ** ARE TWO **
	count := 0;
	foreach invoice in voyage.allInvoices do
		count := count + 1;
		validateHMSInvoice2(invoice, count);
	endforeach;
	self.assertEqualMsg(count, 1, "Voyage Invoices, test 3");
	
	// do a re-evaluate on the invoice line - should stay the same
	create invoiceLines transient;
	foreach invoice in voyage.allInvoices do
		invoice.invoiceLines.copy(invoiceLines);
	endforeach;
	self.invoiceLineReevaluate(invoiceLines);
	// test invoice - should still be one, with one line ** THIS DOES WORK **
	count := 0;
	foreach invoice in voyage.allInvoices do
		count := count + 1;
		validateHMSInvoice2(invoice, count);
	endforeach;
	self.assertEqualMsg(count, 1, "Voyage Invoices, test 4");

	// change the rate to $24.00
	debtorRate := rateEntry.rate.CM_DebtorRate;
	costs.clear();
	costs.add(24.00);
	self.updateInvoiceRateEntry(debtorRate, rateEntry, start, null, false, costs, 0, 0, null,null);
	
	// re-test for the new invoice value - the rate should now be the calc type max of 12
	count := 0;
	foreach invoice in voyage.allInvoices do
		count := count + 1;
		validateHMSInvoice2a(invoice, count);
	endforeach;
	self.assertEqualMsg(count, 1, "Voyage Invoices, test 5");
	
	// change the resource usage units from 1200 to 600 and re-evaluate the invoice lines
	beginTransaction;
	foreach movement in voyage.myHMSVoyageData.allVoyageMovements do
		foreach resUsed in movement.allResourceUsed do
			resUsed.setPropertyValue("unitsUsed", 600.Real);
		endforeach;
	endforeach;
	commitTransaction;

	invoiceLines.clear();
	foreach invoice in voyage.allInvoices do
		invoice.invoiceLines.copy(invoiceLines);
	endforeach;
	self.invoiceLineReevaluate(invoiceLines);

	// re-test for the new quantity and value
	count := 0;
	foreach invoice in voyage.allInvoices do
		count := count + 1;
		validateHMSInvoice2b(invoice, count);
	endforeach;
	self.assertEqualMsg(count, 1, "Voyage Invoices, test 6");
	
epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	delete services;
	delete costs;
	delete pxyDebtorRate;
	delete transSet;
	delete invoiceLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="uInvoiceCargoAllocations01" id="b0eabc44-be55-4b76-a0d7-c59b37816b38">
        <updating/>
        <source>uInvoiceCargoAllocations01() updating;
/*
Purpose:			
Date		Who		Reason
26 March 2015	NAVAB1	Initial creation
*/

vars
	pxyTM,realTM : CM_TranMapCargoAllocation;
	aCode, aDesc : String;
	pxyYAConfig, realYAConfig : CM_InvoiceAllocationConfig;
	opCriteriaColl : CM_YACriteriaTypeArray;
	proxyYAObj, realAlloc : CM_InvoiceCargoAllocation;
	allTransientCriteriaObj	: CMIF_Array;
	objs : ObjectSet;
	now			: Date;
	baseDate	: Date;
	bs: CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	obj	: Object;
	aPort : CM_Port;
	bank	: CM_Bank;

begin
	self.setTerminalConfig(InvUseInvoiceCargoAlloc, true);

	create opCriteriaColl transient;
	
	bank := self.getTerminal().getDefaultCompanyBank();
	aCode := "UTALLOC";
	aDesc := "UT Invoice Allocation";
	
	create objs transient;
	// ### TRANSACTION MAP
	realTM := bank.allCargoAllocTranMaps[aCode];
	app.myTrxUA.trxUpdateBankTMCAActive(null); 
	
	if realTM &lt;&gt; null then
		app.myTrxDA.trxDeleteInvoiceTranMapCA(realTM);
	endif;
	
	create pxyTM transient;
	pxyTM.setProxy(bank, aCode, aDesc);
		
	app.myTrxCA.trxCreateInvoiceTranMapCAlloc(pxyTM,realTM);
	self.assertTrueTrxOKShowPassport("Create TM");
	
	app.myTrxUA.trxUpdateBankTMCAActive(realTM); 
	
	// ### TRAN MAP ALLOC CONFIG
	realYAConfig := realTM.myInvoiceAllocationConfig;
	
	self.assertTrueMsg(realYAConfig &lt;&gt; null, "Invoice Allocation Config is NUll");
	
	pxyYAConfig := app.createUpdateProxy(realYAConfig).CM_InvoiceAllocationConfig;
	
	opCriteriaColl.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	opCriteriaColl.add(app.myRoot.allYACriteriaTypes[YACriteriaType_ImexStatus]);
	
	pxyYAConfig.setProxyInvoiceAllocation(opCriteriaColl, null, realTM, null);
	
	app.myTrxUA.trxUpdateYAIMEXConfig(pxyYAConfig, app.myPassport);	
	
	
	// invoice allocations for Move, Import then UT_ILT1 and UT_ILT2
	// ### Invoice Cargo Allocation
	realAlloc := self.addInvoiceCargoAllocation(realTM,TI_CargoType_Container,TI_IMEX_STATUS_IMPORT,TRANS_TYPE_MOVE, null, null, "UTICA1", "CONT IMP MOVED", null, null);

	// #### UPDATE LINE MAPPINGS
	self.addInvoiceCargoAllocationLines(realAlloc,"CCT01","UT_ILT1","UT_ILT2",0,CM_QuantityRangeMap.MAX_RANGE.Integer, false);
	
	// invoice allocations for Move, Null imex (??) then UT_ILT3 and UT_ILT4
	// ### Invoice Cargo Allocation
	realAlloc := self.addInvoiceCargoAllocation(realTM,TI_CargoType_Container,TI_IMEX_STATUS_NULL,TRANS_TYPE_MOVE, null, null, "UTICA11", "CONT MOVED", null, null);  // NAVAB1 03AUG2023 Fixing UTs duplicate YA code


	// #### UPDATE LINE MAPPINGS
	self.addInvoiceCargoAllocationLines(realAlloc,"CCT01","UT_ILT3","UT_ILT4",0,CM_QuantityRangeMap.MAX_RANGE.Integer, false);
	
	
	
	
	// #### MOVE CARGO
	voy := self.getVoyage("UTBISH1");

	aPort := app.myRoot.allPorts["NZAKL"];

	
	bs:= self.getTerminalArea("UTINVBS").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	deleteTerminalArea("UTINVBS");
	bs:= addBlockStack("UTINVBS", 100, null);

	// ### 20 GENERALS
	self.deleteContainer("ALLC1503271");
	cargo := self.addContainerAtLocnDisch("ALLC1503271", "2200", "GENL", TI_IMEX_STATUS_IMPORT, bs.myLocationsController, aPort, voy);	
	
	bs:= self.getTerminalArea("UTINV").CM_BlockStack;
	self.move(cargo,bs);
	// 'cargo' has 4 invoice lines for the two Moves, each for UT_ILT1 and UT_ILT2
epilog
	self.setTerminalConfig(InvUseInvoiceCargoAlloc, false);

	delete pxyTM;
	delete pxyYAConfig;
	delete proxyYAObj;
	delete opCriteriaColl;
	delete allTransientCriteriaObj;
	delete objs;
end;</source>
    </JadeMethod>
    <JadeMethod name="uMHinvoiceExportForAllExternal" id="bd350f84-c09b-4c10-bc01-54394fe562db">
        <updating/>
        <source>uMHinvoiceExportForAllExternal() updating;
// ---------------------------------------------------------------------------
// Created:     15 January 2014 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	ioClassActual, ioClassForTest : CM_ExtFinanceIO;
	origPath : String;
	clsCol : ClassNDict;
	cls : Class;
begin

	

	ioClassActual := self.getTerminalConfig(FinancialIOClass).CM_ExtFinanceIO;
	if ioClassActual &lt;&gt; null then
		origPath := ioClassActual.exportPath;
	endif;

	create clsCol transient;
	cls := currentSchema.getClass(CM_ExtFinanceIO.name);
	cls.getAllSubclassesAnywhere(clsCol); 

	foreach cls in clsCol do
		if not cls.abstract then
			if cls.name = "CM_Nimbus" then
				continue;
			endif;
		
			ioClassForTest := cls.firstInstance().CM_ExtFinanceIO;
			if ioClassForTest = null then	
				ioClassForTest := app.myTrxCA.trxCreateExternalFinanceClass(cls);
			endif;
			if ioClassForTest &lt;&gt; null then	
				self.setTerminalConfig(FinancialIOClass,ioClassForTest);
				beginTransaction;
				ioClassForTest.exportPath := "..\c_misc\";
				commitTransaction;
			endif;
			
			if app.computerName = "CNWMH5A" then
				write cls.name &amp; Tab &amp; LogINFO.String &amp; Tab &amp; app.logLevel.String;
				app.writeLog(cls.name &amp; Tab &amp; LogINFO.String &amp; Tab &amp; app.logLevel.String, LogINFO);
			endif;
			

			///self.tCreateStorageInvoiceLineTypes(); // check for transient leaks - from File, CM_GLSumary, CM_InvoiceStat etc
			
		endif;
	endforeach;
	

epilog

	if ioClassActual &lt;&gt; null then	
		beginTransaction;
		ioClassActual.exportPath := origPath;
		commitTransaction;
	endif;

	delete clsCol;


end;</source>
    </JadeMethod>
    <JadeMethod name="uOtagoStorage" id="51519430-d218-4367-bd5d-b3327ff07ae0">
        <updating/>
        <source>uOtagoStorage() updating;
// cnwma1
/* cnwjre1 Test Port Otago empty storage (uses the MTsByDebtor and MTsByDebtorExport options)
	The expected invoice line quantities come from par 7593 (entry 18 of the contact section) and the comments of CM_Storage::getStartDateTimePreFSD.
	Otago empty storage uses the Days Onsite Since 00:00 calculation type, which is hard-coded to be inclusive of both start and end days.
*/
constants

vars
	now			: TimeStamp;
	cargoId		: String;
	msg			: String;
	transCount	: Integer;
	lineCount	: Integer;
	tranTS		: TimeStamp;
	doStorageMT	: Boolean;
	doExportMT	: Boolean;
	
	terminal	: CM_Terminal;

	onsiteTi1,
	onsiteTi2,
	onsiteTi3	: CM_TrackedItem;
	trans	: CM_TITransaction;
	invLine		: CM_InvoiceLine;
	transSet	: CM_TransactionSet;

	nowDate,
	baseDate,
	endDate : Date;
	operator	: CM_Operator;
	services	: CM_ServiceByNameDict;
	invType		: CM_InvoiceDesc;
	calcType	: CM_CalculationType;
	invLineType	: CM_InvoiceLineDesc;
	service		: CM_Service;
	
	voyage		: CM_Voyage;
	taType 		: CM_TerminalAreaType;
	blockStack1,
	blockStack2	: CM_BlockStack;
	
begin
	msg := method.name;
	terminal := self.getTerminal();
	
	//  save the current values and set them
	doStorageMT := terminal.getConfig(MTsByDebtor).Boolean;
	doExportMT := terminal.getConfig(MTsByDebtorExport).Boolean;
	beginTransaction;
	terminal.setConfig(MTsByDebtor, true);
	terminal.setConfig(MTsByDebtorExport, true);
	commitTransaction;

	taType := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack1 := terminal.allTerminalAreasByTypeId.getAtKey( taType.type, "UT_BS1").CM_BlockStack;
	self.assertTrueMsg(blockStack1 &lt;&gt; null, "Block Stack UT_BS1 not found...");
	blockStack2 := terminal.allTerminalAreasByTypeId.getAtKey( taType.type, "UT_BS2").CM_BlockStack;
	self.assertTrueMsg(blockStack2 &lt;&gt; null, "Block Stack UT_BS2 not found...");
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	voyage:=self.createVesselVoyage3();
	
	// create an invoice line type for Days Onsite at 00:00, which is what Otago use for empty storage
	self.deleteInvoiceType("UT_InvTypeStore5");
	self.deleteInvoiceService("UT_ServiceStore5", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore5", FORCED_ERASE);

	create services transient;
	invType := self.createInvoiceType("UT_InvTypeStore5", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore5 not created");

	calcType := app.myRoot.allCalculationTypesByCode['CCT07'];	// Days onsite at
	self.assertNotNullMsg(calcType, "Calculation type CCT07 (Days onsite at) not found");
	
	service := self.createInvoiceService("UT_ServiceStore5","UT Store5", calcType, null);
	self.assertNotNullMsg(service, "UT_ServiceStore13 not created");
 	services.add(service);
	
	invLineType := self.createInvoiceLineType("UT_LineTypeStore5", calcType, invType, services,"SDT1");
	self.assertNotNullMsg(invLineType, "Invoice line type UT_LineTypeStore5 not created");
	
	self.deleteInvoiceTransactionMap(1, 'UT_Storage');
	self.tranMapLoadSimpleStorage3();

	// import three empty containers
	cargoId := "MTMU112233";
	onsiteTi1 := self.createContainerFromVoyage(voyage, cargoId, blockStack1, "22G1", operator, "MT", "NZPOE", "NZPOE", 2200, 4500).CM_Container;
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, msg &amp; " On Site Cargo 1 '" &amp; cargoId &amp; "' not created...");
	cargoId := "MTMU112234";
	onsiteTi2 := self.createContainerFromVoyage(voyage, cargoId, blockStack1, "22G1", operator, "MT", "NZPOE", "NZPOE", 2200, 4500).CM_Container;
	self.assertTrueMsg(onsiteTi2 &lt;&gt; null, msg &amp; " On Site Cargo 2 '" &amp; cargoId &amp; "' not created...");
	cargoId := "MTMU112235";
	onsiteTi3 := self.createContainerFromVoyage(voyage, cargoId, blockStack1, "22G1", operator, "MT", "NZPOE", "NZPOE", 2200, 4500).CM_Container;
	self.assertTrueMsg(onsiteTi3 &lt;&gt; null, msg &amp; " On Site Cargo 3 '" &amp; cargoId &amp; "' not created...");

	// Container received day 1, storage for 1 day as import empty, imex changed to storage
	//	Released on day 2, storage for 2 days as stored empty
	baseDate := "01/05/2016".Date;
	self.setTransactionDate(onsiteTi1, baseDate);
	// create a storage at day 2 then back-date to 1 (creating it at days 1 doesn't seem to work)
	// set the transaction imex to Export to match a supplied example of storage from Otago
	tranTS.setDate("02/05/2016".Date);
	trans := self.createDatedChargedTransaction(onsiteTi1, tranTS, TRANS_TYPE_STORAGE, true);
	beginTransaction;
	tranTS.setDate("01/05/2016".Date);
	tranTS.setTime(trans.dateTime.time);
	trans.setPropertyValue("dateTime", tranTS);
	trans.setPropertyValue("imExStatus", 1);
	commitTransaction;
	// resync it after the date change to fix the invoice line quantity
	create transSet transient;
	transSet.add(trans);
	self.updateInvoiceReevaluate(transSet, onsiteTi1, null);

	// create storage transactions from release day 2
	tranTS.setDate("02/05/2016".Date);
	trans := self.createDatedChargedTransaction(onsiteTi1, tranTS, TRANS_TYPE_STORAGE, true);
	// each ti has a storage invoice line for 1 day and a storage invoice line for 2 days
	transCount := 0;
	foreach trans in onsiteTi1.allTransactions do
		if trans.isKindOf(CM_Storage) then
			transCount := transCount + 1;
			lineCount := 0;
			foreach invLine in trans.allInvoiceLines do
				lineCount := lineCount + 1;
				if transCount = 1 then
					self.assertEqualMsg(invLine.quantity.Integer, 1, "TI1 Storage 1 invoice line quantity");
				elseif transCount = 2 then
					self.assertEqualMsg(invLine.quantity.Integer, 2, "TI1 Storage 2 invoice line quantity");
				endif;
			endforeach;
			self.assertEqualMsg(lineCount, 1, "TI1 Storage invoice lines");
		endif;
	endforeach;
	self.assertEqualMsg(transCount, 2, "TI1 Storage transactions");
	
	// second example:
 	//		CM_Receive 	date 2/11
	//		CM_Storage	date 7/11 - inclusive, the number of full days equals 6
	//		CM_Storage	date 15/11 - exclusive, we have already charged for the 7th so we are exclusive and start at the 8th, the number of full days equals 8
	//		CM_Storage	date 20/11 - exclusive, we have already charged for the 15th so we are exclusive and start at the 16th, the number of full days equals 5
	baseDate := "02/11/2015".Date;
	self.setTransactionDate(onsiteTi2, baseDate);

	// create each storage transactions as above
	tranTS.setDate("07/11/2015".Date);
	trans := self.createDatedChargedTransaction(onsiteTi2, tranTS, TRANS_TYPE_STORAGE, true);
	tranTS.setDate("15/11/2015".Date);
	trans := self.createDatedChargedTransaction(onsiteTi2, tranTS, TRANS_TYPE_STORAGE, true);
	tranTS.setDate("20/11/2015".Date);
	trans := self.createDatedChargedTransaction(onsiteTi2, tranTS, TRANS_TYPE_STORAGE, true);

	// check the invoice lines
	transCount := 0;
	foreach trans in onsiteTi2.allTransactions do
		if trans.isKindOf(CM_Storage) then
			transCount := transCount + 1;
			lineCount := 0;
			foreach invLine in trans.allInvoiceLines do
				lineCount := lineCount + 1;
				if transCount = 1 then
					self.assertEqualMsg(invLine.quantity.Integer, 6, "TI2 Storage 1 invoice line quantity");
				elseif transCount = 2 then
					self.assertEqualMsg(invLine.quantity.Integer, 8, "TI2 Storage 2 invoice line quantity");
				elseif transCount = 3 then
					self.assertEqualMsg(invLine.quantity.Integer, 5, "TI2 Storage 3 invoice line quantity");
				endif;
			endforeach;
			self.assertEqualMsg(lineCount, 1, "TI2 Storage invoice lines");
		endif;
	endforeach;
	self.assertEqualMsg(transCount, 3, "TI2 Storage transactions");

	// third example, same dates but the last two storage are for a different operator, the middle charge should be inclusive
 	//		CM_Receive 	date 2/11
	//		CM_Storage	date 7/11 - inclusive, the number of full days equals 6
	//		CM_Storage	date 15/11 - inclusive, the number of full days equals 9
	//		CM_Storage	date 20/11 - exclusive, we have already charged for the 15th so we are exclusive and start at the 16th, the number of full days equals 5
	baseDate := "02/11/2015".Date;
	self.setTransactionDate(onsiteTi3, baseDate);

	// create each storage transactions as above
	tranTS.setDate("07/11/2015".Date);
	trans := self.createDatedChargedTransaction(onsiteTi3, tranTS, TRANS_TYPE_STORAGE, true);
	tranTS.setDate("15/11/2015".Date);
	trans := self.createDatedChargedTransaction(onsiteTi3, tranTS, TRANS_TYPE_STORAGE, true);
	beginTransaction;
	trans.setPropertyValue("operatorCode", "UTO2");
	commitTransaction;
	// resync it after the operator change to fix the invoice line quantity
	transSet.clear();
	transSet.add(trans);
	self.updateInvoiceReevaluate(transSet, onsiteTi3, null);
	tranTS.setDate("20/11/2015".Date);
	trans := self.createDatedChargedTransaction(onsiteTi3, tranTS, TRANS_TYPE_STORAGE, true);
	beginTransaction;
	trans.setPropertyValue("operatorCode", "UTO2");
	commitTransaction;
	// resync it after the operator change to fix the invoice line quantity
	transSet.clear();
	transSet.add(trans);
	self.updateInvoiceReevaluate(transSet, onsiteTi3, null);

	// check the invoice lines
	transCount := 0;
	foreach trans in onsiteTi3.allTransactions do
		if trans.isKindOf(CM_Storage) then
			transCount := transCount + 1;
			lineCount := 0;
			foreach invLine in trans.allInvoiceLines do
				lineCount := lineCount + 1;
				if transCount = 1 then
					self.assertEqualMsg(invLine.quantity.Integer, 6, "TI3 Storage 1 invoice line quantity");
				elseif transCount = 2 then
					self.assertEqualMsg(invLine.quantity.Integer, 9, "TI3 Storage 2 invoice line quantity");
				elseif transCount = 3 then
					self.assertEqualMsg(invLine.quantity.Integer, 5, "TI3 Storage 3 invoice line quantity");
				endif;
			endforeach;
			self.assertEqualMsg(lineCount, 1, "TI3 Storage invoice lines");
		endif;
	endforeach;
	self.assertEqualMsg(transCount, 3, "TI3 Storage transactions");
epilog

	self.resetDefaultTranMap();
	
	// restore the options
	beginTransaction;
	terminal.setConfig(MTsByDebtor, doStorageMT);
	terminal.setConfig(MTsByDebtorExport, doExportMT);
	commitTransaction;
	delete services;
	delete transSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="uStorageConfigOptions" id="c60ec8af-1ca0-42d7-a484-399abcf49dc8">
        <source>uStorageConfigOptions();
// cnwjre1 check the first/last days options of CM_StorageConfig
vars

	storageConfig	: CM_StorageConfig;
	criteriaTypes : CM_YACriteriaTypeArray;
	firstDayTimeCutoff	: Time;
	lastDayTimeCutoff	: Time;
	zeroTime		: Time;
	triggers	: CM_StorageTriggerByType;
	includeFirstDay,
	includeLastDay	: Boolean;

	ti		: CM_TrackedItem;
	transParams: CMIF_StorageTransController;
	tran : CM_TITransaction;
	terminal	: CM_Terminal;
	tranTS : TimeStamp;
	tranDate : Date;
	now		: Date;
	tranTime	: Time;
	type : CM_TerminalAreaType;
	blockStack : CM_BlockStack;
	operator	: CM_Operator;
	cargoType	: CM_CargoType;
	voyage		: CM_Voyage;
	invLine		: CM_InvoiceLine;
	msg			: String;

begin
	self.deleteStorageConfig( false );
	
	// set up the storage config
	zeroTime := "00:00".Time;
	firstDayTimeCutoff := zeroTime;
	lastDayTimeCutoff := zeroTime;
	create criteriaTypes transient;
	create triggers transient;

	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, firstDayTimeCutoff, includeFirstDay, includeLastDay,
											  lastDayTimeCutoff, 0, 0, null,null, null, -1, -1, -1);
	terminal := self.getTerminal();
	operator := app.myRoot.allOperators["MSC"];
	type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack := terminal.allTerminalAreasByTypeId.getAtKey( type.type, "BS2").CM_BlockStack;

	self.deleteContainer("HJCU8141306");

	ti := self.addContainerOpts("HJCU8141306", "2200", "GENL", operator);
	beginTransaction;
	ti.setPropertyValue( "totalWeight", "23100".Decimal );
	commitTransaction;
	
	self.move(ti, self.getLocationsController(blockStack.allLocationsControllers.first));

	tranDate.setDate(1,3,2016);
	tranTS.setDate(tranDate);
	self.resetTransactionDate(ti, tranTS);

	tranDate.setDate(1,3,2016);
	tranTS.setDate(tranDate);
	self.createDatedTransaction(ti, tranTS, TRANS_TYPE_REC_SHIP);
	
	// delete the CM_Receive (is replaced with CM_ReceiveRoad)
	beginTransaction;
	foreach tran in ti.allTransactions do
		if tran.class.name = CM_Receive.name then
			delete tran;
		endif;
	endforeach;
	commitTransaction;

	self.deleteInvoiceTransactionMap(1, 'UT_Storage');
	self.tranMapLoadSimpleStorage();

	self.xCreateStorage(2, false, false, storageConfig, ti);
	self.xCreateStorage(2, false, true, storageConfig, ti);
	self.xCreateStorage(2, true, false, storageConfig, ti);
	self.xCreateStorage(2, true, true, storageConfig, ti);

	self.xCreateStorage(3, false, false, storageConfig, ti);
	self.xCreateStorage(3, false, true, storageConfig, ti);
	self.xCreateStorage(3, true, false, storageConfig, ti);
	self.xCreateStorage(3, true, true, storageConfig, ti);

	self.xCreateStorage(4, false, false, storageConfig, ti);
	self.xCreateStorage(4, false, true, storageConfig, ti);
	self.xCreateStorage(4, true, false, storageConfig, ti);
	self.xCreateStorage(4, true, true, storageConfig, ti);

	// this produces one storage at 2 days and another at 4 days
	self.xCreateTwoStorages(2, false, false, storageConfig, ti);
	self.xCreateTwoStorages(2, false, true, storageConfig, ti);
	self.xCreateTwoStorages(2, true, false, storageConfig, ti);
	self.xCreateTwoStorages(2, true, true, storageConfig, ti);
	
	self.resetDefaultTranMap();
	self.deleteInvoiceTransactionMap(1, 'UT_Storage');
	self.tranMapLoadSimpleStorage2();

	self.xCreateStorage(4, false, false, storageConfig, ti);
	self.xCreateStorage(4, false, true, storageConfig, ti);
	self.xCreateStorage(4, true, false, storageConfig, ti);
	self.xCreateStorage(4, true, true, storageConfig, ti);

	self.xCreateStorage(5, false, false, storageConfig, ti);
	self.xCreateStorage(5, false, true, storageConfig, ti);
	self.xCreateStorage(5, true, false, storageConfig, ti);
	self.xCreateStorage(5, true, true, storageConfig, ti);

	self.xCreateStorage(6, false, false, storageConfig, ti);
	self.xCreateStorage(6, false, true, storageConfig, ti);
	self.xCreateStorage(6, true, false, storageConfig, ti);
	self.xCreateStorage(6, true, true, storageConfig, ti);

	self.xCreateStorage(7, false, false, storageConfig, ti);
	self.xCreateStorage(7, false, true, storageConfig, ti);
	self.xCreateStorage(7, true, false, storageConfig, ti);
	self.xCreateStorage(7, true, true, storageConfig, ti);

	// this produces one storage at 2 days and another at 6 days
	self.xCreateTwoStorages2(2, 6, false, false, storageConfig, ti);
	self.xCreateTwoStorages2(2, 6, false, true, storageConfig, ti);
	self.xCreateTwoStorages2(2, 6, true, false, storageConfig, ti);
	self.xCreateTwoStorages2(2, 6, true, true, storageConfig, ti);

	// this produces one storage at 2 days and another at 7 days
	self.xCreateTwoStorages2(2, 7, false, false, storageConfig, ti);
	self.xCreateTwoStorages2(2, 7, false, true, storageConfig, ti);
	self.xCreateTwoStorages2(2, 7, true, false, storageConfig, ti);
	self.xCreateTwoStorages2(2, 7, true, true, storageConfig, ti);


epilog
	self.deleteStorageConfig( true );
	delete criteriaTypes;
	delete triggers;
	delete transParams;
end;</source>
    </JadeMethod>
    <JadeMethod name="uStorageProcessor" id="4c2717de-1b8d-49df-90eb-3b9e1f8390db">
        <updating/>
        <source>uStorageProcessor() updating;
// for SCT contact 31000
//08 Mar 2016	cnwrs1	TFS 1479 create storage for inclusive dates over EOP
vars
	bs		: CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	dateTime	: TimeStamp;

	agent	: CM_AutoStorageTransactionAgent;
	term	: CM_Terminal;
	user	: CM_User;
	selectorQuery	: CM_MenuUserQuery;
	financialPeriod	: CM_FinancialPeriodEnd;
	taskDescription	: String;
	queryName	: String;
	userQuery	: CM_MenuUserQuery;
	iter		: Iterator;

begin
	// block stack
	bs:= self.getTerminalArea("UTSTORE").CM_BlockStack;
	// create a container with retrospective transactions
	self.createVesselVoyage(null,null,null);
	voy := self.getVoyage("UTSTOR1");
	aPort := app.myRoot.allPorts["NZAKL"];

	// test container
	cargo := self.addContainerAtLocnDisch("UTMTSTORE01", "22G1", "MT", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	dateTime.setDate("22/06/2012".Date);
	self.resetTransactionDate(cargo, dateTime);

	queryName := "UT_SingleCargoQuery";
	
	iter := app.myRoot.myQueryMenuRoot.allMenuUserItemsWithAMenuItem.createIterator;
	while iter.next(userQuery) do
		if queryName = userQuery.heading then
			selectorQuery := userQuery;
			break;
		endif;
	endwhile;

	term := self.getTerminal();
	user := app.getMyUser();
	foreach financialPeriod in CM_FinancialPeriodEnd.instances do
		if financialPeriod.isDefault then
			break;
		endif;
	endforeach;
	
	create agent transient;

	taskDescription := "Storage Processor";
	agent.initialise(term, user, financialPeriod, selectorQuery, taskDescription, null, app.myPassport);
	agent.effectiveRunDate := "30/06/2012".Date;
	agent.runProcess();
	agent.effectiveRunDate := "31/07/2012".Date;
	agent.runProcess();
	agent.effectiveRunDate := "31/08/2012".Date;
	agent.runProcess();
epilog
	delete iter;
	delete agent;
end;</source>
    </JadeMethod>
    <JadeMethod name="uTFS39305" id="bc459e1c-1af8-483c-aa2d-32e6e3a093c9">
        <source>uTFS39305();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
