<CollClass name="CM_TAMasterByIdDict" id="8ce0fba0-7271-4d34-b6a9-f862ed974fdc">
    <memberType name="CM_TerminalAreaMaster"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <MemberKey>
        <property name="CM_TerminalAreaMaster::id"/>
    </MemberKey>
    <JadeMethod name="getAreaAsString" id="d8669a7e-bfe4-4c4f-a95b-16b7e1f9807e">
        <source>getAreaAsString() : String;

// Created by cnwdvb1 on 30 July 2007

vars

	taMaster	: CM_TerminalAreaMaster;
	str			: String;

begin

	foreach taMaster in self do
		str := str &amp; ',' &amp; taMaster.getID();
	endforeach;
	
	if str.length &gt; 1 then
		return str[2:end];
	endif;
	
	return null;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isSimilarQueueArea" id="6d534ef0-8643-4873-a94a-2fe9d6a6172b">
        <source>isSimilarQueueArea(_location	:	CM_LocationsController)	:	Boolean;

// Created by cnwdvb1 on 30 July 2007

vars

	taMaster : CM_TerminalAreaMaster;

begin

	foreach taMaster in self do
		if taMaster.isSimilarQueueArea(_location) then
			return true;
		endif;
	endforeach;
	
	return false;

end;</source>
        <Parameter name="_location" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
