    <JadeMethod name="checkCanRemoveFromQueue" id="ba2d3563-6dc1-4016-86e1-6b262c53cd75">
        <source>checkCanRemoveFromQueue(_queue : CM_RadioTelemetryQueue) : Boolean;
vars
	
begin
	
	if not inheritMethod(_queue) then
		return false;
	endif;
	
	if _queue &lt;&gt; null then
		if _queue.allEntries.isEmpty = false then
			if _queue.isCraneQueue() then
				app.setContinueCMExceptions(false);
				app.raiseCMException2(ERR_QUEUE_ENTRIES, _queue.CM_VoyageCraneQueue.id, _queue.allEntries.size.String, null, null);
				return false;
			endif;
		endif;
	endif;
	return true;
	
end;</source>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deQueue" id="3bd5b3f0-36c1-4a82-a40a-4c0117839485">
        <updating/>
        <source>deQueue() updating;
//Called from the C++ deleteMachine code. Erases this machine from the
//current queue (if its OK to do so).
vars
	tmpMach	:	CM_Machine;
	cq : CM_VoyageCraneQueue;

begin
	inheritMethod;	//Dequeue wherever we are.
	if self.allCraneQueues.isEmpty() then // PAR 20474
//	if self.craneQueue = null then
		return;
	endif;
	reserveLock(self);
	tmpMach := self;
	foreach cq in self.allCraneQueues discreteLock do // PAR 20474
		//self.craneQueue.releaseMachine(tmpMach);
		cq.releaseMachine(tmpMach);
	endforeach;
epilog
	unlock (self);
end;</source>
    </JadeMethod>
    <JadeMethod name="erase" id="de5efb5b-c553-4c5f-86bb-8a7cb3bd07d9">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

vars
	voyage	:	CM_Voyage;
begin
	//----------------
	//Remove ourselves from any voyages that know about us
	//----------------
	if self.isTransient then
		inheritMethod(_eraseLevel);
		return;
	endif;
	
	
	if self.myTerminal &lt;&gt; null then
		foreach voyage in self.myTerminal.allVoyagesByCode do
			voyage.removeCrane(self);
		endforeach;	
	endif;
	
	inheritMethod(_eraseLevel);

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findPriorMoveHistoryForWLE" id="831274dc-a75c-49be-8117-0b91d3e14bd2">
        <source>findPriorMoveHistoryForWLE(_wle :CM_VoyageWLE):CM_MachineMoveHistory;
// ---------------------------------------------------------------------------
// Created:     07 December 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08 Dec 2011	cnwkpd1		PAR #28816 - 1210 exception during DLR load back
//							onto the ship
// ---------------------------------------------------------------------------

vars
	ti			: CM_TrackedItem;
	moveHistory,
	result 		: CM_MachineMoveHistory;
	history		: CM_MachineHistory;
	iter 		: Iterator;
	wleCreated	: TimeStamp;
	cargoType	: Integer;
	cargoId		: String;
	
begin
	iter 	:= self.history.createIterator();
	ti		:= _wle.myTrackedItem;
	
	if ti = null then // AKB UnitTest Cleanup
		return null;
	endif;
	
	cargoType := ti.cargoType;
	cargoId := ti.id;
	wleCreated := _wle.createdTime;
		
	while iter.back (history) do
		// no point looking back before the wle was created
		if history.dateTime &lt; wleCreated then
			break;
		endif;
		
		if not history.isKindOf(CM_MachineMoveHistory) then
			continue;
		endif;
		
		// look for a move - that's all cranes have right now
		if  history.type &lt;&gt; CM_MachineHistory.Type_Move then	
			continue;
		endif;
		
		moveHistory := history.CM_MachineMoveHistory;
		
		if moveHistory.cargoType = cargoType and 
		   moveHistory.tiId = cargoId then
			if moveHistory.myNextLiftHistory = null then		// PAR #28816 - Don't return previously linked history
				// found it
				result := moveHistory;
			endif;
			break;
		endif;
	endwhile;

	return result;
	
epilog
	delete iter;
end;
</source>
        <Parameter name="_wle" type="CM_VoyageWLE"/>
        <ReturnType type="CM_MachineMoveHistory"/>
    </JadeMethod>
