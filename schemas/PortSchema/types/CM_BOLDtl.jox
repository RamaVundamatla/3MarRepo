    <JadeMethod name="cargoTypeDescr" id="fc4c275b-9ae8-46fb-b7bc-196b74b2f8f9">
        <methodInvocation>mapping</methodInvocation>
        <source>cargoTypeDescr(set : Boolean; _value : String io) mapping;
/*
	Created on 11 January 2008
	
	by Debby Hutchison
	
	Purpose: Copied from CM_BookingRef for CCMS 1618
*/
vars
	tmpCargoType : CM_CargoType;

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	tmpCargoType := app.myRoot.allCargoTypesById[self.cargoType];
	if tmpCargoType &lt;&gt; null then
		_value := tmpCargoType.description;
	else
		_value := null;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doesCargoMatch" id="c57a04a6-b325-4e3d-a8ac-c013762033cc">
        <source>doesCargoMatch(	_cargo : CM_CargoBOLType;
				_commodCode : String) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2022	navhl20	ChangeRequest 54979: EUP - Cargo Work Orders Enhancements

*/

vars

begin
	if  (_cargo = null or self.myCargoType = _cargo) and 
		(_commodCode = null or self.commodity = null or self.commodity = _commodCode) then
			return true;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_cargo" type="CM_CargoBOLType"/>
        <Parameter name="_commodCode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
