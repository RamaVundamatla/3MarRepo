    <JadeMethod name="aTrxSample" id="7d2e6193-7323-4c86-8119-cae0d48129f0">
        <updating/>
        <source>aTrxSample(_pxyObject : CM_TrxTestObject; 
		_controller : CM_TrxTestController; 
		_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     11 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;

	app.myUtilityUA.aUtlSample(_pxyObject, _controller, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyObject" type="CM_TrxTestObject"/>
        <Parameter name="_controller" type="CM_TrxTestController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMoveTrackedItemsWithSplit" id="2273eb2b-d69e-4702-a731-6936582bfaf2">
        <updating/>
        <source>doMoveTrackedItemsWithSplit(_tis : CM_TISet; _errTis : CM_TISet input; 
			_control : CMIF_MoveController input; _passport : CM_Passport input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	ti		: CM_TrackedItem;
	tiSet	: CM_TISet;
	error	: CM_Error;
	setNo,
	totStart,
	startTime,
	endTime	: Integer;
	foundError : Boolean;
	
begin

	app.setContinueCMExceptions(false);

	startTime := app.clock;
	totStart := startTime;

	// Copy all the tis into the error set initially.  These will be removed
	// from this set as they are moved
	_errTis.clear;
	_tis.copy(_errTis);
	
	_control.setupSplitMove(_tis, 100);
	
	endTime := app.clock;
	app.writeLog('Move of ' &amp; _tis.size.String &amp; ' items - doing in ' &amp; 
				_control.allTISets.size.String &amp; ' splits - time = ' &amp; 
				(endTime - startTime).String, LogINFO);
	
	startTime := endTime;
	
	foreach tiSet in _control.allTISets do
		setNo := setNo +1;
		ti := tiSet.first;
		if ti = null then
			continue;
		endif;
		_control.setMyTrackedItem(ti);
		tiSet.remove(ti);
		
		_control.setAllOtherTrackedItems(tiSet);

		// need to reset each time as doDefferedUpdates resets for false
		_passport.useTITransactionDeferUpdate := true;
		_passport.useTIDictDeferUpdate := true;
	
		beginTransaction;
		if _passport.hasMonitor then
			_passport.myCMIFMonitor.partsDone := _passport.myCMIFMonitor.partsDone + tiSet.size;
			
	   		_passport.myCMIFMonitor.updateProgress('Moving Tracked Items set #' &amp; setNo.String,
	   												_passport.myCMIFMonitor.partsInJob,
	   												_passport.myCMIFMonitor.partsDone);		// PAR 17765			
		endif;
		
		app.myUtilityUA.utlUpdateMoveTrackedItem(_control, _passport);
		
		// ### TFS 52572 21Jan2022 NAVPW1
		if _control.isLogMovement then
			foreach error in _passport.allErrors do
				_passport.errorsToIgnore.add(error.errorCode); //Ignore all errors as this a web call for C3
			endforeach;
		endif;
		// ### TFS 52572 21Jan2022 NAVPW1
		
		_passport.doDeferredUpdates();
		
		//epr par 36720 31/8/15
		//if not _passport.isOkToCommit(false) then
		if not _passport.isOkToCommit(false) and not _control.isLogMovement then // ### TFS 52572 21Jan2022 NAVPW1
			app.writeLog(Tab &amp; 'Move failed ... ' &amp; _passport.allErrorWarnings.first.errorCode.String, LogINFO);
			app.cmsAbortTransaction();
			continue;
		endif;
		
		app.cmsCommitTransaction(_passport);
		endTime := app.clock;
		app.writeLog(Tab &amp; 'Move ' &amp; (tiSet.size + 1).String &amp; ' - time = ' &amp; (endTime - startTime).String, LogINFO);
		
		// remove the tis that have been moved from the _errTis and release their session lock
		// ### TFS 52572 21Jan2022 NAVPW1
		if _control.isLogMovement then
			foreach error in _passport.allErrors do
				if error.text.cnContains(ti.id) then
					foundError := true;
				endif;
			endforeach;
			
			if not foundError then
				_errTis.remove(ti);				// remove the master
				unlock(ti);
			else
				unlock(ti);
			endif;

			foreach ti in tiSet do
				foundError := false;
				foreach error in _passport.allErrors do
					if error.text.cnContains(ti.id) then
						foundError := true;
					endif;
				endforeach;
			
				if not foundError then
					_errTis.remove(ti);			// remove all the others
					unlock(ti);
				else
					unlock(ti);
				endif;
			endforeach;
			
		else
			_errTis.remove(ti);				// remove the master
			unlock(ti);
			foreach ti in tiSet do
				_errTis.remove(ti);			// remove all the others
				unlock(ti);
			endforeach;
			
		endif;
		// ### TFS 52572 21Jan2022 NAVPW1
		
		//_errTis.remove(ti);				// remove the master
		//unlock(ti);
		//foreach ti in tiSet do
		//	_errTis.remove(ti);			// remove all the others
		//	unlock(ti);
		//endforeach;
		
		//epr par 36720 31/8/15
		if setNo &lt;&gt; _control.allTISets.size then
			// changed from 200 12Nov03 to allow other users more time to
			// get in between locks
			process.sleep(1500);
			startTime := app.clock;
		endif;
	endforeach;

	if _passport.noErrors and (not process.isInTransactionState) then
		// Done so that finaliseActivityWithPassport will commit correctly
		beginTransaction;
	endif;

epilog
	// moved following line to calling methods as need to do this when outside transaction state
	//_control.doSessionUnlockForAll();	// belts and braces here
	app.writeLog('Move complete - time = ' &amp; (app.clock - totStart).String, LogINFO);

end;</source>
        <access>protected</access>
        <Parameter name="_tis" type="CM_TISet"/>
        <Parameter name="_errTis" type="CM_TISet" usage="input"/>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doRORORequestDLRGCALT" id="9e4f7667-7bdd-47f1-b979-bc14921b3007">
        <updating/>
        <source>doRORORequestDLRGCALT(_theSlots : CM_LCArray; 
									_isLoad : Boolean; 
									_moveType : Integer; 
									_theEditions : CM_ObjectByOidEditionDict; 
									_deck : CM_DeckVoyage; 
									_xMetres,_yMetres : Decimal; 
									_passport : CM_Passport input) updating;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	self.doValidateRORORequestVA(_theSlots, null, _isLoad, _theEditions,null, _passport);

	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	beginTransaction;
	
	self.doUpdateRORORequestDLRGCALT(_theSlots, _isLoad, _moveType, _deck, _xMetres,_yMetres, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_theSlots" type="CM_LCArray"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_theEditions" type="CM_ObjectByOidEditionDict"/>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
        <Parameter name="_xMetres" type="Decimal"/>
        <Parameter name="_yMetres" type="Decimal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doRORORequestDLRSoB" id="7df5560e-355c-476e-a3c8-de64a682c53e">
        <updating/>
        <source>doRORORequestDLRSoB(_theSlots, _theSlotsAlt : CM_LCArray; _isLoad : Boolean; _moveType : Integer; _theEditions : CM_ObjectByOidEditionDict; _passport : CM_Passport input) updating;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	self.doValidateRORORequestVA(_theSlots, _theSlotsAlt, _isLoad, _theEditions,null, _passport);

	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	beginTransaction;
	
	self.doUpdateRORORequestDLRSob(_theSlots, _theSlotsAlt, _isLoad, _moveType, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_theSlots" type="CM_LCArray"/>
        <Parameter name="_theSlotsAlt" type="CM_LCArray"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_theEditions" type="CM_ObjectByOidEditionDict"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doRebuildTerminalBRXref" id="e16ad1d6-d55d-4606-be23-1d1ee344080c">
        <updating/>
        <source>doRebuildTerminalBRXref(_terminal : CM_Terminal;
						_brXref : CM_TerminalTIsByBR input;
						_passport : CM_Passport input) updating, protected;

/*

Purpose:			Rebuild the passed in Booking Reference cross reference, in multiple
					database transactions if required to prevent locking contention

Parameters:			Terminal cross reference is for, cross reference parent

Return Value:		None


Date		Who		Reason
28 Aug 2009	cnwkpd1	PAR #20398 - Add Booking Reference cross reference functionality

*/

constants
	MaxTransactionTime	= 2000;
	
vars
	lastCommit,
	now				: Decimal[20];
	collIterators	: ObjectArray;
	coll			: Collection;
	iter,
	voyageIter,
	collIter		: Iterator;
	voyage			: CM_Voyage;
	ti				: CM_TrackedItem;
	processedTIs	: CM_TISet;
	totalToProcess,
	processedCount,
	updateCount		: Integer;
	cmifMonitor 	: CMIF_Monitor;
	
begin
	app.writeLog("Rebuilding Booking Ref cross reference for Terminal " &amp; _terminal.displayForXlation(false), LogINFO);

	// Commit header change/create first, to ensure we are not unnecessarily locking terminal voyages collection
	_passport.doDeferredUpdates();
	app.cmsCommitTransaction(_passport);
	
	// Create a collection of the colleection Iterators to process - need to do this because collections are exclusive,
	// and we can't store exclusive references in the array
	create collIterators transient;
	collIterators.add(_terminal.allOnsiteTIsByIdCargoType.createIterator());		// Onsite
	collIterators.add(_terminal.allOffsiteTIsByIdCargoType.createIterator());		// Offsite
	collIterators.add(_terminal.allNotifiedTIsByIdCargoType.createIterator());		// Notified
	collIterators.add(_terminal.allDeletedTIsByIdCargoType.createIterator());		// Deleted
	collIterators.add(_terminal.allTbaTIsByIdCargoType.createIterator());			// TBA
	collIterators.add(_terminal.allRRPTIsByIdCargoType.createIterator());	// RRP    16 Mar 2020	NDL	TFS 47004
	
	// Include all the voyage TI collIterators
	voyageIter := _terminal.allVoyagesSet.createIterator;
	while voyageIter.next(voyage) do
		collIterators.add(voyage.allOnshipTIsByIdCargoType.createIterator());		// On Ship
		collIterators.add(voyage.allOffloadedTIsByIdCargoType.createIterator());	// Offloaded
		collIterators.add(voyage.allDeletedTIsByIdCargoType.createIterator());		// Deleted
		collIterators.add(voyage.allNotifiedTIsByIdCargoType.createIterator());	// Notified
		collIterators.add(voyage.allTbaTIsByIdCargoType.createIterator());			// TBA
		collIterators.add(voyage.allRRPTIsByIdCargoType.createIterator());	//RRP 16 Mar 2020	NDL	TFS 47004
	endwhile;

	collIter := collIterators.createIterator();
	cmifMonitor := _passport.myCMIFMonitor;
	if cmifMonitor &lt;&gt; null then
		// Get the total number of TIs to process
		while collIter.next(iter) do
			totalToProcess := totalToProcess + iter.getCollection.size();
		endwhile;
		collIter.reset();
	endif;
	
	lastCommit := app.relativeMachineTime();
	beginTransaction;
	
	// Now process all the collIterators
	create processedTIs transient;
	
	while collIter.next(iter) do
	
		app.writeLog("Processing collection " &amp; iter.getCollection.String, LogINFO);
		
		while iter.next(ti) do
			// Check for commit first
			now := app.relativeMachineTime();
			if now - lastCommit &gt; MaxTransactionTime then
				_passport.doDeferredUpdates();
				app.cmsCommitTransaction(_passport);
				
				// Check for cancel outside transaction state
				if cmifMonitor &lt;&gt; null then
					if not cmifMonitor.updateProgress(cmifMonitor.message, totalToProcess, processedCount) then
						app.writeLog("Rebuild Booking Ref cross reference for Terminal " &amp; _terminal.displayForXlation(false) &amp; " cancelled", LogINFO);
						app.raiseCMException(VB_USER_CANCELED_TRANS, null, null);
						return;
					endif;
				endif;
				
				lastCommit := app.relativeMachineTime();
				beginTransaction;
			endif;
			
			// Ensure each TI is only processed once
			if processedTIs.includes(ti) then
				continue;
			endif;
			
			processedTIs.add(ti);
			processedCount := processedCount + 1;
			
			if ti.rebuildBookingRefXref(_brXref) then
				updateCount := updateCount + 1;
			endif;
		endwhile;
	endwhile;
	
	// Finally, once rebuild is complete, set the header to complete
	_brXref.setXrefComplete(true);
	
	app.writeLog("Rebuild Booking Ref cross reference for Terminal " &amp; _terminal.displayForXlation(false) &amp; " complete", LogINFO);
	app.writeLog(processedCount.String &amp; " Tracked Items processed, " &amp; updateCount.String &amp; " cross reference objects updated", LogINFO);
	
	
epilog
	if collIterators &lt;&gt; null then
		collIterators.purge();
		delete collIterators;
	endif;
	delete collIter;
	delete voyageIter;
	delete processedTIs;
	
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_brXref" type="CM_TerminalTIsByBR" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSlotRequestAttribute" id="db9c7696-546b-42a3-86ba-aa46aaf8b9cd">
        <updating/>
        <source>doSlotRequestAttribute(_theSlots, _theSlotsAlt : CM_SlotControllerArray; _isLoad : Boolean; _loadCC : CMIF_LoadColorCode input; _theEditions : CM_ObjectByOidEditionDict; _attribute : String; _passport : CM_Passport input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// code taken from CM_UtilityUpdateAgent::utlUpdateSlotRequestController
// ---------------------------------------------------------------------------
vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	self.doValidateSlotRequestAttribute(_theSlots, _theSlotsAlt, _isLoad, _loadCC, _theEditions, _attribute, _passport);

	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	beginTransaction;
	
	self.doUpdateSlotRequestAttribute(_theSlots, _theSlotsAlt, _isLoad, _loadCC, _attribute, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <access>protected</access>
        <Parameter name="_theSlots" type="CM_SlotControllerArray"/>
        <Parameter name="_theSlotsAlt" type="CM_SlotControllerArray"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_loadCC" type="CMIF_LoadColorCode" usage="input"/>
        <Parameter name="_theEditions" type="CM_ObjectByOidEditionDict"/>
        <Parameter name="_attribute" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUpdateRORORequestDLRGCALT" id="a6a956b0-3812-463d-a454-b04a6ff943c2">
        <updating/>
        <source>doUpdateRORORequestDLRGCALT(_theSlots : CM_LCArray; 
											_isLoad : Boolean; 
											_moveType : Integer; 
											_deck : CM_DeckVoyage; 
											_xMetres,
											_yMetres : Decimal; 
											_passport : CM_Passport input) updating;
/*
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
*/

vars
	tmpSlot,
	tmpSlotAlt				: CM_VoyageROROController;
	gcDefn					: CM_ROROGCDefn;
	loadAlloc 				: CM_VoyageAllocation;
	aSlotReqDisch,
	aSlotReqLoad, pxySR 	: CM_RORORequest;
	tmpTI 					: CM_TrackedItem;
begin

	app.setContinueCMExceptions(false);
	
	
	// ### DISCHARGE DLR GC POSITION
	tmpSlot := _theSlots[1].CM_VoyageROROController;
	tmpSlot.updateSlotRequestDLRSOB(_isLoad, _moveType, _passport);
	
	self.updateObjectEdition(tmpSlot);	// par 30292
	
	aSlotReqDisch := tmpSlot.myRORORequestDischarge;
	
	// ### LOAD DLR GC, AUTO CREATE THE LOAD CC AND POLY
	if aSlotReqLoad = null then
	
		// create Load CC from Discharge CC
		
		// ### CREATE A GC LC, GC DEFN &amp; GC LOAD CC with a default POLY
		gcDefn := app.myUtilityCA.utlCreateROROGCLoadCC(null,4, _xMetres,_yMetres,_deck, _passport);
		tmpSlotAlt := gcDefn.CM_ROROGCDefnVoyage.myGCController;
		
		aSlotReqLoad := tmpSlotAlt.myRORORequestLoad;

		// ### Get the TI from the Discharge DLR part and use it to create a LOAD Voyage Allocation for the new LOAD DLR part
		tmpTI := aSlotReqDisch.getTrackedItem();
		aSlotReqLoad.setFromTI(tmpTI); // AND ALLOCATION !!!
		
		// ### Set the colour
		loadAlloc := aSlotReqLoad.allAllocations.first().CM_VoyageAllocation;
		aSlotReqLoad.setColourFromAllocation(loadAlloc, tmpSlot.allTrackedItems.size);
		aSlotReqLoad.myLayout.setFromRequest(aSlotReqLoad); // PAR 31144

		// ### SET DLR on new load CC
		tmpSlotAlt.updateSlotRequestDLRSOB(true, _moveType, _passport);
		
		// ### SET POLY FROM DISCHARGE POLY
		aSlotReqLoad.myLayout.setPointsPolygon(aSlotReqDisch.myLayout.pointsPolygon);
		aSlotReqLoad.myLayout.setPointsPolygonMove(_xMetres,_yMetres);
	endif;
			
			
	if _passport.hasErrors then
		return;
	endif;

	if aSlotReqDisch.isLinked() then
		app.raiseCMException1(ErrSlotRequestAlreadyLinked, tmpSlot.getID, null, null);
		return;
	endif;

	if aSlotReqDisch &lt;&gt; null and aSlotReqLoad &lt;&gt; null then
		aSlotReqDisch.setLinkedRequest(aSlotReqLoad);
	endif;
	if _passport.hasErrors then
		return;
	endif;
	

epilog
	delete pxySR;
end;</source>
        <Parameter name="_theSlots" type="CM_LCArray"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
        <Parameter name="_xMetres" type="Decimal"/>
        <Parameter name="_yMetres" type="Decimal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUpdateRORORequestDLRSob" id="0b28cb1a-0a30-4e75-ab5c-42e02d08d7f3">
        <updating/>
        <source>doUpdateRORORequestDLRSob(_theSlots, _theSlotsAlt : CM_LCArray; _isLoad : Boolean; _moveType : Integer; _passport : CM_Passport input) updating;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
30 Aug 2012			cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
*/

vars
	tmpSlot			: CM_VoyageROROController;
	voyLC 			: CM_VoyageController;
	pxySR		 	: CM_RORORequest;
	idx				: Integer;
	lc 				: CM_LocationsController;
	tmpLOLOSlot 	: CM_SlotController;
	theMaster, theCloneMaster : CM_ROROLocnDefn;
	allMasters : ObjectSet;
begin

	app.setContinueCMExceptions(false);
	create allMasters transient;	
	// ### DISCHARGE DLR SLOTS
	foreach	lc in _theSlots do
	
		if lc.isKindOf(CM_VoyageROROController) then
			tmpSlot := lc.CM_VoyageROROController;
			if not _isLoad then // PAR 29054
				if tmpSlot.allTrackedItems.isEmpty() then
					app.raiseCMException1(SlotHasNoTIsToDischarge, tmpSlot.getFullId(), null, tmpSlot);
				endif;
			endif;
			
			tmpSlot.updateSlotRequestDLRSOB(_isLoad, _moveType, _passport);
			if _passport.hasErrors then
				return;
			endif;
			
			self.updateObjectEdition(tmpSlot);	// par 30292
	
			if not _isLoad then // PAR 32021
				// PAR 31110 - CCMS 1320
				theMaster := tmpSlot.getRotationMaster();
				if theMaster &lt;&gt; null and not theMaster.isOOTL() then
					allMasters.addNoDuplicates(theMaster, false);
				endif;
			endif;
			
		elseif lc.isKindOf(CM_SlotController) then// PAR 28968
			tmpLOLOSlot := lc.CM_SlotController;
			if not _isLoad then // PAR 29054
				if tmpLOLOSlot.allTrackedItems.isEmpty() then
					app.raiseCMException1(SlotHasNoTIsToDischarge, tmpLOLOSlot.getFullId(), null, tmpSlot);
				endif;
			endif;
			
			tmpLOLOSlot.updateSlotRequestDLRSOB(_isLoad, _moveType, _passport);
			if _passport.hasErrors then
				return;
			endif;
			
			self.updateObjectEdition(tmpLOLOSlot);	// par 30292
			
		endif;
	endforeach;
	
	
	if not _isLoad then // DISCHARGE ONLY FOR ALT STUFF
		// ### LOAD DLR SLOTS
		// #### Are there any auto link slot requests? If yes then link them together!
		if _passport.noErrors and _theSlotsAlt &lt;&gt; null then
			idx := 0;
			foreach lc in _theSlotsAlt do
				idx := idx + 1;
				voyLC := _theSlots[idx].CM_VoyageController;
				lc.CM_VoyageController.setAltSlotDLRALT(voyLC, _moveType);

			endforeach;
		endif;
	endif;
	if _passport.hasErrors then
		return;
	endif;
	
	// PAR 31110 - CCMS 1320 if everything in the rotated actual is colour coded for discharge then clone and unrotated the load view.
	app.myUtilityCA.utlCreateRORORotateSwitchLoad(allMasters, _passport);

epilog
	delete allMasters;
	delete pxySR;
end;</source>
        <Parameter name="_theSlots" type="CM_LCArray"/>
        <Parameter name="_theSlotsAlt" type="CM_LCArray"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUpdateRORORequestVA" id="703b5459-c8c0-4d0a-b9bc-b464d67aece0">
        <updating/>
        <source>doUpdateRORORequestVA(_theSlots, _theSlotsAlt : CM_LCArray; _isLoad : Boolean; _voyAlloc : CM_VoyageAllocation; _numItems : Integer; _moveType : Integer; _passport : CM_Passport input) updating;

/*
Purpose:			
Date			Who			Reason
JULY 2011		CNWAB1		Initial creation
30 Aug 2012		cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 

*/
vars
	tmpSlot,
	tmpSlotAlt			: CM_VoyageROROController;
	tmpSlotRequest,
	tmpSlotRequestAlt	: CM_RORORequest;
	idx					: Integer;
	tmpSortDict 		: CM_ROROSlotLCByOrd1AOrd2D;
	roroLocnDefn 		: CM_DeckItem;
	theVoyage 			: CM_Voyage;
	theTerminal			: CM_Terminal;
	locnDefns 			: ObjectSet;
	locnDefn 			: Object;
	lanePosLC 			: CM_ROROLanePositionController;
	lc 					: CM_LocationsController;
begin

	app.setContinueCMExceptions(false);
	create locnDefns transient;
	foreach	lc in _theSlots do
		tmpSlot := lc.CM_VoyageROROController;
		
		tmpSlotRequest := tmpSlot.updateRORORequestVA(_isLoad, _voyAlloc, _numItems, _moveType, _passport);
		if _passport.hasErrors then
			return;
		endif;
		
		self.updateObjectEdition(tmpSlot);	// par 30292
		
		theVoyage := tmpSlot.myVoyage;
		theTerminal := theVoyage.myTerminal;
		
		roroLocnDefn := tmpSlot.getDefn();
		locnDefns.addNoDuplicates(roroLocnDefn,false);
		
	endforeach;
	
	// #### Are there any auto link slot requests? If yes then link them together!
	if _passport.noErrors and _theSlotsAlt &lt;&gt; null then
		idx := 0;
		foreach lc in _theSlotsAlt do
			tmpSlotAlt := lc.CM_VoyageROROController;
			// here we update using (not _isLoad) as these linked requests
			// will be the opposite of the orig requests.
			tmpSlotRequestAlt := tmpSlotAlt.updateRORORequestVA((not _isLoad), _voyAlloc, _numItems, _moveType, _passport);			
			roroLocnDefn := tmpSlotAlt.getDefn();
			locnDefns.addNoDuplicates(roroLocnDefn,false);
		
		endforeach;
	endif;

	if _passport.hasErrors then
		return;
	endif;
	
	foreach locnDefn in locnDefns discreteLock do
		roroLocnDefn := locnDefn.CM_DeckItem;
		tmpSlot := roroLocnDefn.getFirstLC();
		if tmpSlot &lt;&gt; null then
			if tmpSlot.isKindOf(CM_ROROLaneController) then
				// ## We do not currently actually use the main lane controller, we create lane position controllers instead, 
				//		these are temp for this voyage and are simliar in use as the GC LCs
				foreach lanePosLC in tmpSlot.CM_ROROLaneController.allLanePositionsLCs discreteLock do
					app.myEventManager.createSingleObjInfoNoteEvt(
								theVoyage,
								theTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA),
								lanePosLC);		
				
				endforeach;
			else
				// 28747 Dec 2011 now done in add/update utl
			/*
				app.myEventManager.createSingleObjInfoNoteEvt(
								theVoyage,
								theTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA),
								tmpSlot);
			*/
			endif;
		endif;
	endforeach;

	
	if theVoyage &lt;&gt; null 
	and _passport.noErrors then
		theVoyage.myROROStructure.causeEvent(theTerminal.getTerminalEvent(EVENT_OOWCREATION_UPDATE), false, theVoyage.myROROStructure); // PAR 33860 changed to myROROStructure
	endif;

epilog
	delete tmpSortDict;
	delete locnDefns;
end;</source>
        <Parameter name="_theSlots" type="CM_LCArray"/>
        <Parameter name="_theSlotsAlt" type="CM_LCArray"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_voyAlloc" type="CM_VoyageAllocation"/>
        <Parameter name="_numItems" type="Integer"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUpdateSlotRequestAttribute" id="938d2a1e-cc0b-4069-aa96-72f48adbb423">
        <updating/>
        <source>doUpdateSlotRequestAttribute(_theSlots, _theSlotsAlt : CM_SlotControllerArray; _isLoad : Boolean; _loadCC : CMIF_LoadColorCode input; _attribute : String; _passport : CM_Passport input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// code taken from CM_UtilityUpdateAgent::utlUpdateSlotRequestController
// ---------------------------------------------------------------------------
// 30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 

vars
	tmpSlot,
	tmpSlotAlt		: CM_SlotController;
	tmpSlotRequest,
	tmpSlotRequestAlt,
	otherRequest,
	aSlotReqDisch,
	aSlotReqLoad 	: CM_SlotRequest;
	tmpVoyage		: CM_Voyage;
	eventUpdateVoyageArea,
	order, idx				: Integer;
	aBay : CM_Bay;
	allBays : CM_BaySet;
	cvs : CM_CellularVoyageStructure;
begin

	app.setContinueCMExceptions(false);
	
	foreach	tmpSlot in _theSlots do
	
		tmpSlotRequest := tmpSlot.updateSlotRequestAttribute(_isLoad, _attribute, _loadCC, _passport);
		if _passport.hasErrors then
			return;
		endif;
		self.updateObjectEdition(tmpSlot);	// par 30292
	endforeach;
	
	// 27 Mar 2012	NDL	Par 29070
	if not _passport.checkValidation then
		return;
	endif;
	

	// #### Are there any auto link slot requests? If yes then link them together!
	if _passport.noErrors and _theSlotsAlt &lt;&gt; null then
		idx := 0;
		foreach tmpSlotAlt in _theSlotsAlt do
			// here we update using (not _isLoad) as these linked requests
			// will be the opposite of the orig requests.
			tmpSlotRequestAlt := tmpSlotAlt.updateSlotRequestAttribute((not _isLoad), _attribute, _loadCC, _passport);
			if _passport.hasErrors then
				return;
			endif;
			if _attribute = CM_SlotRequest.Attribute_Erase then
				continue;
			endif;

			idx := idx + 1;
			tmpSlot := _theSlots[idx];

			if _isLoad then
				otherRequest := tmpSlot.mySlotRequestLoad;
			else
				otherRequest := tmpSlot.mySlotRequestDischarge;
			endif;
			// PAR 21746 if otherRequest.fortyBack then // never link to a 40 backend
			if otherRequest.getAttrIsBackend() then // never link to a 40 backend// PAR 21746

				app.raiseCMException1(SlotRequestUpdateFromBack, tmpSlot.getID, null, null);
				return;
			endif;

			if otherRequest.isLinked() then
				app.raiseCMException1(ErrSlotRequestAlreadyLinked, tmpSlot.getID, null, null);
				return;
			endif;

			aSlotReqDisch := null;
			aSlotReqLoad := null;

			if _isLoad then
				aSlotReqDisch := tmpSlotRequestAlt;
				aSlotReqLoad := otherRequest;
			else
				aSlotReqLoad := tmpSlotRequestAlt;
				aSlotReqDisch := otherRequest;
			endif;

			if aSlotReqDisch &lt;&gt; null and aSlotReqLoad &lt;&gt; null then
				app.myUtilityUA.utlUpdateSlotRequestLinkSOBDLR(aSlotReqLoad, aSlotReqDisch, _passport);
				if _passport.hasErrors then
					return;
				endif;
			endif;
		
		endforeach;
	endif;

	if _passport.hasErrors then
		return;
	endif;
	
	
	// update ok so send out notes for updated objects

	eventUpdateVoyageArea := _passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA);

	tmpVoyage := _theSlots.first.myVoyage;
	
	create allBays transient;

	foreach	tmpSlot in _theSlots do
		tmpVoyage := tmpSlot.myVoyage;
		if cvs = null then
			cvs := tmpVoyage.myCellularVoyageStructure;
		endif;
		tmpVoyage.causeEvent(eventUpdateVoyageArea, false, tmpSlot);
		aBay := tmpSlot.myBayVoyage;
		allBays.addNoDuplicates(aBay,false);		
	endforeach;

	if _theSlotsAlt &lt;&gt; null then
		foreach	tmpSlotAlt in _theSlotsAlt do
			tmpVoyage := tmpSlotAlt.myVoyage;
			tmpVoyage.causeEvent(eventUpdateVoyageArea, false, tmpSlotAlt);

			aBay := tmpSlot.myBayVoyage;
			allBays.addNoDuplicates(aBay,false);		
		endforeach;
	endif;
	
	foreach aBay in allBays do
		order := cvs.getOOWCreationOrder(aBay.CM_BayVoyage);
		if order = 0 then
			order := CM_OOWCreation.OOWCreationIncrement;
		endif;
		aBay.CM_BayVoyage.getOOWCreation(order);
	endforeach;
	
	
	if tmpVoyage &lt;&gt; null 
	and _passport.noErrors then
		tmpVoyage.myCellularVoyageStructure.causeEvent(tmpVoyage.myTerminal.getTerminalEvent(EVENT_OOWCREATION_UPDATE), false, tmpVoyage.myCellularVoyageStructure);
	endif;

epilog
	delete allBays;
end;</source>
        <access>protected</access>
        <Parameter name="_theSlots" type="CM_SlotControllerArray"/>
        <Parameter name="_theSlotsAlt" type="CM_SlotControllerArray"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_loadCC" type="CMIF_LoadColorCode" usage="input"/>
        <Parameter name="_attribute" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUpdateSlotRequestVA" id="9e57a672-7998-4778-9d95-21d16cebd34d">
        <updating/>
        <source>doUpdateSlotRequestVA(_theSlots, _theSlotsAlt : CM_SlotControllerArray; _isLoad : Boolean; _voyAlloc : CM_VoyageAllocation; _passport : CM_Passport input) updating, protected;
/*
Date		Who		Reason
30 Dec 2009	cnwas3	Initial creation
30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
*/

vars
	tmpSlot,
	tmpSlotAlt				: CM_SlotController;
	tmpSlotRequest,
	tmpSlotRequestAlt 		: CM_SlotRequest;
	tmpVoyage				: CM_Voyage;
	eventUpdateVoyageArea,
	order, idx				: Integer;
	aBay 					: CM_Bay;
	allBays 				: CM_BaySet;
	cvs 					: CM_CellularVoyageStructure;
begin

	app.setContinueCMExceptions(false);
	
	foreach	tmpSlot in _theSlots do
	
		tmpSlotRequest := tmpSlot.updateSlotRequestVA(_isLoad, _voyAlloc, _passport);
		if _passport.hasErrors then
			return;
		endif;
		
		self.updateObjectEdition(tmpSlot);	// par 30292
	endforeach;

	// #### Are there any auto link slot requests? If yes then link them together!
	if _passport.noErrors and _theSlotsAlt &lt;&gt; null then
		idx := 0;
		foreach tmpSlotAlt in _theSlotsAlt do
			// here we update using (not _isLoad) as these linked requests
			// will be the opposite of the orig requests.
			tmpSlotRequestAlt := tmpSlotAlt.updateSlotRequestVA((not _isLoad), _voyAlloc, _passport);			
		
		endforeach;
	endif;

	if _passport.hasErrors then
		return;
	endif;
	
	
	// update ok so send out notes for updated objects

	eventUpdateVoyageArea := _passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA);

	tmpVoyage := _theSlots.first.myVoyage;
	
	create allBays transient;

	foreach	tmpSlot in _theSlots do
		tmpVoyage := tmpSlot.myVoyage;
		if cvs = null then
			cvs := tmpVoyage.myCellularVoyageStructure;
		endif;
		tmpVoyage.causeEvent(eventUpdateVoyageArea, false, tmpSlot);
		aBay := tmpSlot.myBayVoyage;
		allBays.addNoDuplicates(aBay,false);		
	endforeach;

	if _theSlotsAlt &lt;&gt; null then
		foreach	tmpSlotAlt in _theSlotsAlt do
			tmpVoyage := tmpSlotAlt.myVoyage;
			tmpVoyage.causeEvent(eventUpdateVoyageArea, false, tmpSlotAlt);

			aBay := tmpSlot.myBayVoyage;
			allBays.addNoDuplicates(aBay,false);		
		endforeach;
	endif;
	
	foreach aBay in allBays do
		order := cvs.getOOWCreationOrder(aBay.CM_BayVoyage);
		if order = 0 then
			order := CM_OOWCreation.OOWCreationIncrement;
		endif;
		aBay.CM_BayVoyage.getOOWCreation(order);
	endforeach;
	
	
	if tmpVoyage &lt;&gt; null 
	and _passport.noErrors then
		tmpVoyage.myCellularVoyageStructure.causeEvent(tmpVoyage.myTerminal.getTerminalEvent(EVENT_OOWCREATION_UPDATE), false, tmpVoyage.myCellularVoyageStructure);
	endif;

epilog
	delete allBays;
end;</source>
        <access>protected</access>
        <Parameter name="_theSlots" type="CM_SlotControllerArray"/>
        <Parameter name="_theSlotsAlt" type="CM_SlotControllerArray"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_voyAlloc" type="CM_VoyageAllocation"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUpdateTIConnectDisconnect" id="c8648be1-6cc1-45f1-b3f8-57d0312e13db">
        <updating/>
        <source>doUpdateTIConnectDisconnect(_params : CMIF_ConnectParams io; _agent : CMIF_MobileGenericAgent io; _passport : CM_Passport input) updating, protected;
//
// Purpose:				Deal with connections and disconnections fron NReefer or MasterTerminal APIs
//
// Parameters:			_params - connect or disconnect details
//
// Return Value:		None
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/12/2025	navdap1		Initial creation MTN-36569 CPL | Reefer Runner Integration
//
vars
	pxyTI : CM_TrackedItem;
	power : CM_GapController;

begin
	// then connections 
	foreach pxyTI in _params.allTrackedItems do
		if pxyTI.myTerminalArea.isKindOf(CM_ForkLiftStack) and not pxyTI.myPrimaryActualLocation.hasPower then
			power := _agent.findClosestPowerPoint(pxyTI);
			if power = null then
				app.raiseCMException(No_power_avail, null, null);
				return;
			endif;
		endif;
		
		// don't connect if it's already connected - reefer API can work in offline mode
		if not pxyTI.isConnected and _params.action = ACTION_CONNECT then
			app.myUtilityUA.utlUpdateConnect(_params, pxyTI, _passport);
			
		// don't disconnect if already disconnected - reefer app can work in offline mode 
		elseif pxyTI.isConnected and _params.action = ACTION_DISCONNECT then
			app.myUtilityUA.utlUpdateDisconnect(_params, pxyTI, _passport);
		endif;
		
		if _passport.hasErrors() then
			return;
		endif;
	endforeach;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_params" type="CMIF_ConnectParams" usage="io"/>
        <Parameter name="_agent" type="CMIF_MobileGenericAgent" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doValidateRORORequestVA" id="7b5c0ab0-8d41-4274-84ef-fbad40025da4">
        <updating/>
        <source>doValidateRORORequestVA(_theSlots, _theSlotsAlt : CM_LCArray; _isLoad : Boolean;_theEditions : CM_ObjectByOidEditionDict; _voyAlloc : CM_VoyageAllocation; _passport : CM_Passport input) updating, protected;

/*
Purpose:			PAR 27749
Date				Who			Reason
JULY 2011		CNWAB1		Initial creation
*/


vars
	tmpSlot,
	tmpSlotAlt		: CM_VoyageROROController;
	tmpLoLoSlot, tmpLoLoSlotAlt : CM_SlotController;
	tmpLoLoSlotDefn	: CM_SlotDefn;
	tmpSlotDefn	: CM_ROROSlotDefn;
	tmpSlotRequest	: CM_RORORequest;
	tmpLoLoSlotRequest	: CM_SlotRequest;
	expectedEdition : Integer;
	tmpPort : CM_Port;
	roroSlots : CM_VoyageROROControllerArray;
	lc : CM_LocationsController;
		numSlots : Integer;
		tmpTI : CM_TrackedItem;
begin

	if _theSlots = null then
		app.raiseCMException1(MethodWithNullParam, '_theSlots', null, null);
		return;
	endif;
	
	if _theEditions = null then
		app.raiseCMException1(MethodWithNullParam, '_theEditions', null, null);
		return;
	endif;
	
	
	
	if _theSlots.isEmpty then
		// nothing to do
		app.raiseCMException2(PleaseSelectAnObject, app.getErrorString(Slot), app.getErrorString(Update), null, null);
		return;
	endif;

	app.setContinueCMExceptions(true);
	create roroSlots transient;
	// ========================================
	// Do validation
	// ========================================
	foreach	lc in _theSlots do
		expectedEdition := _theEditions.getEditionForObject(lc);
		if expectedEdition &lt; 0 then
			app.raiseExNoEditionForUpdateObj(lc);
			continue;
		endif;
		exclusiveLock(lc);
		if lc.edition &lt;&gt; expectedEdition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(Slot) &amp; ' ' &amp; lc.getFullId(), null, null);
			return;
		endif;
		
		if _voyAlloc &lt;&gt; null then
			if lc.isKindOf(CM_ROROSlotController) then

				// PAR 28968
				if roroSlots.isEmpty() then
					_theSlots.copy(roroSlots);
				endif;
				tmpSlot := lc.CM_ROROSlotController;
				
				if _voyAlloc.isHiCubed() then
					tmpSlot.testPileColourHeightUnderDeck(roroSlots.getHeightOfSlots(tmpSlot,true),true);
				else
					if _theSlots.size() &gt; 1 then
						tmpSlot.testPileColourHeightUnderDeck(roroSlots.getHeightOfSlots(tmpSlot,false),false);
					else
						tmpSlot.testPileColourHeightUnderDeck(0,false);
					endif;
				endif;	
				tmpSlotDefn := tmpSlot.CM_ROROSlotController.mySlotDefn;
				if not tmpSlotDefn.isAvailable then
					app.raiseCMException2(SlotIsUnavailable, tmpSlot.getFullId(), app.getErrorString(UpdateIt), null, null); // PAR 26684 was using ident attribute
					continue;
				endif;	
				
				// PAR 27749 this is a container location, so VA must have that cargo type.
				if not _voyAlloc.hasCargoType(TI_CargoType_Container) then
					app.raiseCMException3(Canno_creat_load_colou_codin_l, tmpSlot.getFullId(), tmpSlot.getFullId(), app.getErrorString(Container), null, null); 
					continue;
				endif;
				// #################
				// #################
				// ### PORT  ROTATION
				// #################
				// #################
				if (not _isLoad) then
					// if discharging and we have no tracked items then raise an error
					if tmpSlot.allTrackedItems.isEmpty then
						app.raiseCMException1(SlotHasNoTIsToDischarge, tmpSlot.getFullId(), null, null);
						continue;
					endif;
					tmpSlotRequest := tmpSlot.myRORORequestDischarge;
					
					// PAR 30373 - if updating check the job status
					if tmpSlotRequest &lt;&gt; null and tmpSlotRequest.isComplete then
						if not (tmpSlotRequest.getAttrIsBackend()) then
							if tmpSlotRequest.myJob &lt;&gt; null and tmpSlotRequest.myJob.isJobComplete = false then
								app.raiseCMException2(CannotRecolourCodeJobDischarge,tmpSlot.getFullId,tmpSlotRequest.myJob.jobId, null, null);
								return;
							endif;
						endif;
					endif;
				else
					tmpSlotRequest := tmpSlot.myRORORequestLoad;
					numSlots := 	numSlots +1;
					// PAR 30373 - if updating check the job status
					if tmpSlotRequest &lt;&gt; null and tmpSlotRequest.isComplete then
						if not (tmpSlotRequest.getAttrIsBackend()) then
							if tmpSlotRequest.myJob &lt;&gt; null and tmpSlotRequest.myJob.isJobComplete = false then
// PAR 30985								app.raiseCMException2(CannotRecolourCodeJobLoad,tmpSlot.getFullId,tmpSlotRequest.myJob.jobId, null, null);
// PAR 30985								return;
								app.raiseCMWarning2(Tryin_colou_code_slot_exist_co,tmpSlot.getFullId,tmpSlotRequest.myJob.jobId, null, null, null);
							endif;
						endif;
					endif;
					
					if _voyAlloc &lt;&gt; null then
					
						// PAR 28922 validate changing allocations on an existing request
						if tmpSlotRequest &lt;&gt; null then
							tmpSlotRequest.validateForUpdateAllocation(_voyAlloc);
						endif;
		
						tmpPort := _voyAlloc.getDischargePort();
			
						if tmpPort &lt;&gt; null  then
							if tmpSlotDefn &lt;&gt; null then
								//validate that any containers in cells below are for ports on correct port rotation
								tmpSlotDefn.CM_ROROSlotDefnVoyage.validateLoadCCDischargePort(tmpPort);
							endif;
							
							//validate that any containers on this deck are for ports on correct port rotation
							// assumes that the ramp is the only access and that it is AFT
							if not app.myPassport.hasErrorsOrWarnings() then
								tmpSlot.myDeck.validatePortRotationForLoadCC(tmpSlot, _voyAlloc);
							endif;
						endif;
						
						tmpSlot.testHazardLoadCC(_voyAlloc);	
					endif;
				endif;
		
				if tmpSlotRequest &lt;&gt; null then
					if tmpSlotRequest.isComplete then
						tmpSlotRequest := null;
					endif;
					
					if tmpSlotRequest &lt;&gt; null then
						if tmpSlotRequest.getAttrIsBackend() then // 40 backs are not included in jobs so do not get completed, so check the forward slot
							if tmpSlotRequest.CM_ROROSlotRequest.mySlotRequestForward &lt;&gt; null and tmpSlotRequest.CM_ROROSlotRequest.mySlotRequestForward.isComplete then
								tmpSlotRequest := null;
							endif;
						endif;
					endif;
				endif;
			elseif lc.isKindOf(CM_SlotController) then// PAR 28968
				tmpLoLoSlot := lc.CM_SlotController;
				tmpLoLoSlotDefn := tmpLoLoSlot.mySlotDefnVoyage;
				if tmpLoLoSlotDefn.unavailable then
					app.raiseCMException2(SlotIsUnavailable, tmpLoLoSlot.getFullId(), app.getErrorString(UpdateIt), null, null); // PAR 26684 was using ident attribute
					continue;
				endif;
				if _isLoad then
					tmpLoLoSlotRequest := tmpLoLoSlot.mySlotRequestLoad;				
				else
					tmpLoLoSlotRequest := tmpLoLoSlot.mySlotRequestDischarge;
				endif;
	
				if tmpLoLoSlotRequest &lt;&gt; null and tmpLoLoSlotRequest.getAttrIsBackend() then
					app.raiseCMException1(SlotRequestUpdateFromBack, tmpLoLoSlot.getFullId(), null, null);
				endif;
			else
				// PAR 27749  this is not a container location, so VA must not be for containers.
				if _voyAlloc.hasCargoType(TI_CargoType_Container) then
					//cnwmc5 - 20 Jan 2014 - PAR 32270 - if this code path gets taken, then 'tmpSlot' never gets set...
					//app.raiseCMException3(Canno_creat_load_colou_codin_l, tmpSlot.getFullId(), tmpSlot.getFullId(), app.getErrorString(GeneralCargo), null, null); 
					app.raiseCMException3(Canno_creat_load_colou_codin_l, lc.getFullId(), lc.getFullId(), app.getErrorString(GeneralCargo), null, null); 
					continue;
				endif;
			endif;
		endif;
	endforeach;

	if _theSlotsAlt &lt;&gt; null and _theSlotsAlt.size &gt; 0 then
		if _theSlots.size &lt;&gt; _theSlotsAlt.size then
			app.raiseCMException2(ErrNumSlotsAndAltSlotsNoEqual, _theSlots.size.String, _theSlotsAlt.size.String, null, null);
			return;
		endif;

		foreach	lc in _theSlotsAlt do
			expectedEdition := _theEditions.getEditionForObject(lc);
			if expectedEdition &lt; 0 then
				app.raiseExNoEditionForUpdateObj(lc);
				continue;
			endif;
			
			exclusiveLock(lc);
			if lc.edition &lt;&gt; expectedEdition then
				app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(Slot) &amp; ' ' &amp; lc.ident, null, null);
				return;
			endif;
			
			if lc.isKindOf(CM_ROROSlotController) then
				tmpSlot := lc.CM_VoyageROROController;
				tmpSlotDefn := tmpSlot.CM_ROROSlotController.mySlotDefn;
				if not tmpSlotDefn.isAvailable then
					app.raiseCMException2(SlotIsUnavailable, tmpSlotAlt.getFullId(), app.getErrorString(UpdateIt), null, null); // PAR 26684 was using ident attribute
					continue;
				endif;
				if _isLoad then
					tmpSlotRequest := tmpSlot.myRORORequestLoad;				
				else
					tmpSlotRequest := tmpSlot.myRORORequestDischarge;
				endif;
	
				if tmpSlotRequest &lt;&gt; null and tmpSlotRequest.getAttrIsBackend() then
					app.raiseCMException1(SlotRequestUpdateFromBack, tmpSlot.getFullId(), null, null);
				endif;
			elseif lc.isKindOf(CM_SlotController) then // PAR 28968
				tmpLoLoSlotAlt := lc.CM_SlotController;
				tmpLoLoSlotDefn := tmpLoLoSlotAlt.mySlotDefnVoyage;
				if tmpLoLoSlotDefn.unavailable then
					app.raiseCMException2(SlotIsUnavailable, tmpLoLoSlotAlt.getFullId(), app.getErrorString(UpdateIt), null, null); // PAR 26684 was using ident attribute
					continue;
				endif;
				if not _isLoad then // PAR 35038 this is ALT slots so use the opposite
					tmpLoLoSlotRequest := tmpLoLoSlotAlt.mySlotRequestLoad;				
				else
					tmpLoLoSlotRequest := tmpLoLoSlotAlt.mySlotRequestDischarge;
				endif;
				
				if tmpLoLoSlotRequest &lt;&gt; null and tmpLoLoSlotRequest.getAttrIsBackend() then
					app.raiseCMException1(SlotRequestUpdateFromBack, tmpLoLoSlotAlt.getFullId(), null, null);
				endif;
			endif;

		endforeach;
	endif;
	
	//epr par 32300 23/1/14
	if _isLoad and _voyAlloc &lt;&gt; null and _voyAlloc.projected20 &lt;&gt; 0 then
		if _voyAlloc.projected20 &lt; _voyAlloc.getNumLoadCC + numSlots then
			app.raiseCMWarning3(Load_CC_Projected,_voyAlloc.description,(_voyAlloc.getNumLoadCC + numSlots).asStringJMT,_voyAlloc.projected20.asStringJMT,null,null,null);
		endif;
	endif;
epilog
	delete roroSlots;
end;</source>
        <access>protected</access>
        <Parameter name="_theSlots" type="CM_LCArray"/>
        <Parameter name="_theSlotsAlt" type="CM_LCArray"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_theEditions" type="CM_ObjectByOidEditionDict"/>
        <Parameter name="_voyAlloc" type="CM_VoyageAllocation"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doValidateSlotRequestAttribute" id="808216a7-4d1f-4ad8-a72e-1e6f8025587d">
        <updating/>
        <source>doValidateSlotRequestAttribute(_theSlots, _theSlotsAlt : CM_SlotControllerArray; _isLoad : Boolean; _loadCC : CMIF_LoadColorCode input; _theEditions : CM_ObjectByOidEditionDict; _attribute : String; _passport : CM_Passport input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// code taken from CM_UtilityUpdateAgent::utlUpdateSlotRequestController
// ---------------------------------------------------------------------------
vars
	tmpSlot,
	tmpSlotAlt		: CM_SlotController;
	tmpSlotDefn,
	nextSlotDefn	: CM_SlotDefn;
	tmpSlotRequest	: CM_SlotRequest;
	theTI, plnTI : CM_TrackedItem;
	expectedEdition : Integer;
	slotIter : Iterator;
	otherDisPort : CM_Port;
	currentDischargePortIndex,
	otherDischargePortIndex : Integer;
	numSlots : Integer;
	outstanding : Integer;
	reserveDetail : CM_ReserveDetail;
	bulkRelease : CM_BulkRelease;
begin

	if _theSlots = null then
		app.raiseCMException1(MethodWithNullParam, '_theSlots', null, null);
		return;
	endif;
	
	if _theEditions = null then
		app.raiseCMException1(MethodWithNullParam, '_theEditions', null, null);
		return;
	endif;
	
	if _loadCC &lt;&gt; null then
		_loadCC.validateReferences(_passport);
		if _passport.hasErrors then
			return;
		endif;
	endif;
	
	if _theSlots.isEmpty then
		// nothing to do
		app.raiseCMException2(PleaseSelectAnObject, app.getErrorString(Slot), app.getErrorString(Update), null, null);
		return;
	endif;

	app.setContinueCMExceptions(true);

	// ========================================
	// Do validation
	// ========================================
	foreach	tmpSlot in _theSlots do
		expectedEdition := _theEditions.getEditionForObject(tmpSlot);
		if expectedEdition &lt; 0 then
			app.raiseExNoEditionForUpdateObj(tmpSlot);
			continue;
		endif;
		
		if _attribute = CM_SlotRequest.Attribute_Hicubed then		//cnwas3 PAR 20927 ccms 1048	begin
				tmpSlot.testPileColourHeightUnderDeck(_theSlots.getHeightOfSlots(tmpSlot,true),true);			
		elseif _attribute = CM_SlotRequest.Attribute_ColourCode then
			if _theSlots.size() &gt; 1 then
				tmpSlot.testPileColourHeightUnderDeck(_theSlots.getHeightOfSlots(tmpSlot,false),false);
			else
				tmpSlot.testPileColourHeightUnderDeck(0,false);
			endif;
		endif;															//cnwas3 PAR 20927 ccms 1048	end
		
		exclusiveLock(tmpSlot);
		if tmpSlot.edition &lt;&gt; expectedEdition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(Slot) &amp; ' ' &amp; tmpSlot.ident, null, null);
			return;
		endif;
		tmpSlotDefn := tmpSlot.mySlotDefnVoyage;
		if tmpSlotDefn.unavailable then
			app.raiseCMException2(SlotIsUnavailable, tmpSlot.getFullId(), app.getErrorString(UpdateIt), null, null); // PAR 26684 was using ident attribute
			continue;
		endif;
		
				
		if (not _isLoad) then
			if _attribute &lt;&gt; CM_SlotRequest.Attribute_Erase then
				// if discharging and we have no tracked items then raise an error
				if tmpSlot.allTrackedItems.isEmpty then
					app.raiseCMException1(SlotHasNoTIsToDischarge, tmpSlot.ident, null, null);
					continue;
				endif;
			endif;
			tmpSlotRequest := tmpSlot.mySlotRequestDischarge;
		else
			tmpSlotRequest := tmpSlot.mySlotRequestLoad;
			//ccms 1058 cnwer1 11/5/09 
			if _attribute &lt;&gt; CM_SlotRequest.Attribute_Erase then
				//epr par 19982 19/6/09
				if _loadCC &lt;&gt; null and _loadCC.myDischargePort &lt;&gt; null then
					//validate that any containers in cells below 
					tmpSlotDefn.validateLoadCCDischargePort(_loadCC.myDischargePort);
					
				endif;
			endif;
			
		endif;
		
		// PAR 22290
		if tmpSlotRequest &lt;&gt; null then
			if tmpSlotRequest.isComplete then
				tmpSlotRequest := null;
			elseif tmpSlotRequest.isCompletedBackend then	//cnwmc5 - PAR 31050
				tmpSlotRequest := null;
			endif;
		endif;

		if _attribute = CM_SlotRequest.Attribute_Erase 
		and tmpSlotRequest &lt;&gt; null then
			if tmpSlotRequest.myJob &lt;&gt; null then
				if tmpSlotRequest.myJob.CM_VoyageJob.isLoadedToOperations then
					app.raiseCMException1(ERR_JOB_LOADED, tmpSlotRequest.myJob.jobId, null, null);
					return;
				elseif tmpSlotRequest.isLoad then	// PAR 25517 par 24149 is about items that are loaded, so need to ask that question
					plnTI := tmpSlotRequest.getTIofMode(PLANNING_MODE);	// PAR 25517																					// 17/05/2010 cnwmh5 #24149
					if plnTI &lt;&gt; null then	// PAR 25517
						app.raiseCMWarning1(Colour_coding_being_erased_pla,plnTI.id , null, null, null);		// 17/05/2010 cnwmh5 #24149
					endif;
				endif;
			endif;
		endif;

		if (not _isLoad) // DISCHARGE
		and  _attribute &lt;&gt; CM_SlotRequest.Attribute_Erase then // Discharge, DLR or SOB // PAR 13332
			theTI := tmpSlot.allTrackedItems.first;// PAR 13332
			
			/* WAS PAR 22076 this mixes up 40s 30s 45s and 53s, it should be asking whether the TI is a 40 or a 45 etc.
			if theTI &lt;&gt; null and (theTI.isForty() // PAR 13332
			or theTI.isOverSizedContainer())  then // PAR 20733
				if tmpSlot.isFortyBack  // PAR 13332 
				or tmpSlot.mySlotDefnVoyage.isBackend then// PAR 20733
					app.raiseCMException1(SlotRequestUpdateFromBack, tmpSlot.ident, null, null); // PAR 13332
					return; // PAR 13332
				endif;
			endif;
			NOW PAR 22076 from here */
			if theTI &lt;&gt; null then
				if _attribute = CM_SlotRequest.Attribute_ColourCode and //cnwas3 par 23524 begin				   
				   theTI.dischargePort &lt;&gt; null and
				   theTI.dischargePort &lt;&gt; theTI.myTerminal.getConfig(PortDestCode).String.trimBlanks and
				   not theTI.isTranshipItem then
					app.raiseCMException2(Cannot_disch_cargo_diff_port, theTI.id, theTI.dischargePort, null, null); 
					return;
				endif;	//cnwas3 par 23524 end
				if (theTI.isForty() and tmpSlot.isFortyBack and not tmpSlot.isFortyFront) then
					app.raiseCMException1(SlotRequestUpdateFromBack, tmpSlot.myBayVoyage.id &amp; tmpSlot.ident, null, null); 
					return; 
				elseif (theTI.isOverSizedContainer() and tmpSlot.mySlotDefnVoyage.isBackend) then
					app.raiseCMException1(SlotRequestUpdateFromBack, tmpSlot.myBayVoyage.id &amp; tmpSlot.ident &amp; "*", null, null); 
					return; 
				endif;
			endif;
			// PAR 22076 to here 
		endif;
		
		
// PAR 21746		if tmpSlotRequest &lt;&gt; null and tmpSlotRequest.fortyBack then
		if tmpSlotRequest &lt;&gt; null 
		and tmpSlotRequest.getAttrIsBackend() // PAR 21746	
		and not tmpSlotRequest.isCompletedBackend then 	//cnwmc5 - PAR 31050
			if tmpSlotRequest.mySlotDefinition.myBay.bayType = BAY_TYPE_TWIN then // PAR 25636 
				 // PAR 13332 if erasing and the slot req says it is a backend, but it is actually a front end then allow to erase.
				if _attribute = CM_SlotRequest.Attribute_Erase then // PAR 13332
					if tmpSlot.isFortyBack then // PAR 13332
						app.raiseCMException1(SlotRequestUpdateFromBack, tmpSlot.myBayVoyage.id &amp; tmpSlot.ident, null, null); // PAR 13332
					endif; // PAR 13332
				else // PAR 13332
					app.raiseCMException1(SlotRequestUpdateFromBack, tmpSlot.myBayVoyage.id &amp; tmpSlot.ident, null, null);
				endif;
			endif;
		endif;
		
	endforeach;
	
	//10 May 2012	NDL	Par 29512
	
	if _isLoad and _attribute = CM_SlotRequest.Attribute_AssignRelease then
		if _loadCC &lt;&gt; null and _theSlots.size &gt; 0 then
			reserveDetail := _loadCC.myBulkReleaseReserveDetail;
			if reserveDetail &lt;&gt; null and reserveDetail.isKindOf( CM_ReserveSelection ) then
				bulkRelease := reserveDetail.myReserveHeader;
				outstanding := bulkRelease.getTotalOutstanding();
				foreach tmpSlot in _theSlots do
					tmpSlotRequest := tmpSlot.mySlotRequestLoad;
					if tmpSlotRequest = null then
						continue;
					endif;
					if not bulkRelease.allRequestsBeingActioned.includes( tmpSlotRequest ) then
						numSlots := numSlots + 1;	// slots not already selected for this release
					endif;
				endforeach;
				numSlots := numSlots + bulkRelease.allRequestsBeingActioned.size; // total of slots that would be assigned for the outstanding cargo
				
				//epr par 35187 11/11/14
				reserveDetail.CM_ReserveSelection.validateLoadCC(_loadCC.myVoyageAllocation);
			
			
			endif;
			if numSlots &gt; outstanding then
				app.raiseCMWarning2(Too_Many_Slots_Assigned, outstanding.String, numSlots.String, null, null, null);
			endif;
		endif;
	endif;

	if _theSlotsAlt &lt;&gt; null and _theSlotsAlt.size &gt; 0 then
		if _theSlots.size &lt;&gt; _theSlotsAlt.size then
			app.raiseCMException2(ErrNumSlotsAndAltSlotsNoEqual, _theSlots.size.String, _theSlotsAlt.size.String, null, null);
			return;
		endif;

		foreach	tmpSlotAlt in _theSlotsAlt do
			expectedEdition := _theEditions.getEditionForObject(tmpSlotAlt);
			if expectedEdition &lt; 0 then
				app.raiseExNoEditionForUpdateObj(tmpSlotAlt);
				continue;
			endif;
			
			exclusiveLock(tmpSlotAlt);
			if tmpSlotAlt.edition &lt;&gt; expectedEdition then
				app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(Slot) &amp; ' ' &amp; tmpSlotAlt.ident, null, null);
				return;
			endif;
			tmpSlotDefn := tmpSlot.mySlotDefnVoyage;
			if tmpSlotDefn.unavailable then
				app.raiseCMException2(SlotIsUnavailable, tmpSlotAlt.getFullId(), app.getErrorString(UpdateIt), null, null); // PAR 26684 was using ident attribute
				continue;
			endif;

			if _isLoad then
				tmpSlotRequest := tmpSlot.mySlotRequestLoad;

				if _attribute = CM_SlotRequest.Attribute_SOB then
					// if isLoad then the alt slots are the discharge part so if no tracked items then raise an error
					if tmpSlotAlt.allTrackedItems.isEmpty then
						app.raiseCMException1(SlotHasNoTIsToDischarge, tmpSlotAlt.ident, null, null);
						continue;
					endif;
				endif;
			else
				tmpSlotRequest := tmpSlot.mySlotRequestDischarge;
			endif;
			
			// PAR 22290 from here
			if tmpSlotRequest &lt;&gt; null then
				if tmpSlotRequest.isComplete then
					tmpSlotRequest := null;
				endif;
				
				if tmpSlotRequest &lt;&gt; null then
					if tmpSlotRequest.fortyBack then // 40 backs are not included in jobs so do not get completed, so check the forward slot
						if tmpSlotRequest.mySlotRequestForward &lt;&gt; null and tmpSlotRequest.mySlotRequestForward.isComplete then
							tmpSlotRequest := null;
						endif;
					endif;
				endif;
			endif;
			// PAR 22290 from here

// 22076			if tmpSlotRequest &lt;&gt; null and tmpSlotRequest.fortyBack then
			if tmpSlotRequest &lt;&gt; null then
// PAR 21746				if tmpSlotRequest.fortyBack or tmpSlotRequest.isBackend then
				if tmpSlotRequest.getAttrIsBackend() then // PAR 21746
					app.raiseCMException1(SlotRequestUpdateFromBack, tmpSlot.myBayVoyage.id &amp; tmpSlot.ident, null, null);
				endif;
			endif;

		endforeach;
	endif;
epilog
	delete slotIter;
end;</source>
        <access>protected</access>
        <Parameter name="_theSlots" type="CM_SlotControllerArray"/>
        <Parameter name="_theSlotsAlt" type="CM_SlotControllerArray"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_loadCC" type="CMIF_LoadColorCode" usage="input"/>
        <Parameter name="_theEditions" type="CM_ObjectByOidEditionDict"/>
        <Parameter name="_attribute" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doValidateSlotRequestVA" id="9f648433-0921-41d3-83c7-fa8836cdf436">
        <updating/>
        <source>doValidateSlotRequestVA(_theSlots, _theSlotsAlt : CM_SlotControllerArray; _isLoad : Boolean;_theEditions : CM_ObjectByOidEditionDict; _voyAlloc : CM_VoyageAllocation; _passport : CM_Passport input) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 December 2009	cnwas3	Initial creation #25632

*/

vars
	tmpSlot,
	tmpSlotAlt		: CM_SlotController;
	tmpSlotDefn,
	nextSlotDefn	: CM_SlotDefn;
	tmpSlotRequest	: CM_SlotRequest;
	theTI : CM_TrackedItem;
	expectedEdition : Integer;
	slotIter : Iterator;
	tmpPort, otherDisPort : CM_Port;
	currentDischargePortIndex,
	otherDischargePortIndex : Integer;
	numSlots : Integer;
begin

	if _theSlots = null then
		app.raiseCMException1(MethodWithNullParam, '_theSlots', null, null);
		return;
	endif;
	
	if _theEditions = null then
		app.raiseCMException1(MethodWithNullParam, '_theEditions', null, null);
		return;
	endif;
	
	
	
	if _theSlots.isEmpty then
		// nothing to do
		app.raiseCMException2(PleaseSelectAnObject, app.getErrorString(Slot), app.getErrorString(Update), null, null);
		return;
	endif;

	app.setContinueCMExceptions(true);
	
	
	
	// ========================================
	// Do validation
	// ========================================
	foreach	tmpSlot in _theSlots do
		expectedEdition := _theEditions.getEditionForObject(tmpSlot);
		if expectedEdition &lt; 0 then
			app.raiseExNoEditionForUpdateObj(tmpSlot);
			continue;
		endif;
		if _voyAlloc.isHiCubed() then
			tmpSlot.testPileColourHeightUnderDeck(_theSlots.getHeightOfSlots(tmpSlot,true),true);
		else
			if _theSlots.size() &gt; 1 then
				tmpSlot.testPileColourHeightUnderDeck(_theSlots.getHeightOfSlots(tmpSlot,false),false);
			else
				tmpSlot.testPileColourHeightUnderDeck(0,false);
			endif;
		endif;															//cnwas3 PAR 20927 ccms 1048	end

		exclusiveLock(tmpSlot);
		if tmpSlot.edition &lt;&gt; expectedEdition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(Slot) &amp; ' ' &amp; tmpSlot.getFullId(), null, null);
			return;
		endif;
		tmpSlotDefn := tmpSlot.mySlotDefnVoyage;
		if tmpSlotDefn.unavailable then
			app.raiseCMException2(SlotIsUnavailable, tmpSlot.getFullId(), app.getErrorString(UpdateIt), null, null); // PAR 26684 was using ident attribute
			continue;
		endif;	
		
		if (not _isLoad) then
			// if discharging and we have no tracked items then raise an error
			if tmpSlot.allTrackedItems.isEmpty then
				app.raiseCMException1(SlotHasNoTIsToDischarge, tmpSlot.getFullId(), null, null);
				continue;
			endif;
			tmpSlotRequest := tmpSlot.mySlotRequestDischarge;
			
			// PAR 30373 - if updating check the job status
			if tmpSlotRequest &lt;&gt; null and tmpSlotRequest.isComplete  then
				if not (tmpSlotRequest.getAttrIsBackend()) then
					if tmpSlotRequest.myJob &lt;&gt; null and tmpSlotRequest.myJob.isJobComplete = false then
						app.raiseCMException2(CannotRecolourCodeJobDischarge,tmpSlot.getFullId,tmpSlotRequest.myJob.jobId, null, null);
						return;
					endif;
				endif;
			
			endif;
			
		else
		
			
			tmpSlotRequest := tmpSlot.mySlotRequestLoad;
			
			if tmpSlotRequest &lt;&gt; null and not tmpSlotRequest.isBackEndRequest then
				numSlots:=numSlots+1;
			endif;
			if tmpSlotRequest = null then						
				numSlots:=numSlots+1;
			endif;
			
			// PAR 30373 - if updating check the job status
			if tmpSlotRequest &lt;&gt; null and tmpSlotRequest.isComplete 		 then
				if not (tmpSlotRequest.getAttrIsBackend()) then
					if tmpSlotRequest.myJob &lt;&gt; null and tmpSlotRequest.myJob.isJobComplete = false then
// PAR 30985								app.raiseCMException2(CannotRecolourCodeJobLoad,tmpSlot.getFullId,tmpSlotRequest.myJob.jobId, null, null);
// PAR 30985						return;
						app.raiseCMWarning2(Tryin_colou_code_slot_exist_co,tmpSlot.getFullId,tmpSlotRequest.myJob.jobId, null, null, null);
					endif;
				endif;
			
			endif;
			
			tmpPort := _voyAlloc.getDischargePort();

			if tmpPort &lt;&gt; null  then
				//validate that any containers in cells below 
				tmpSlotDefn.validateLoadCCDischargePort(tmpPort);
			endif;
			
			tmpSlot.testHazardLoadCC(_voyAlloc);			// 14/10/2010 cnwmh5 #25632
			
		endif;
		// PAR 22290 from here
		if tmpSlotRequest &lt;&gt; null then
			if tmpSlotRequest.isComplete then
				tmpSlotRequest := null;
			endif;
			
			if tmpSlotRequest &lt;&gt; null then
				if tmpSlotRequest.getAttrIsBackend then // 40 backs are not included in jobs so do not get completed, so check the forward slot
					if tmpSlotRequest.mySlotRequestForward &lt;&gt; null and tmpSlotRequest.mySlotRequestForward.isComplete then
						tmpSlotRequest := null;
					endif;
				endif;
			endif;
		endif;
		// PAR 22290 to here
		
		if (not _isLoad) then // DISCHARGE
			theTI := tmpSlot.allTrackedItems.first;// PAR 13332
			
			if theTI &lt;&gt; null then
				if (theTI.isForty() and tmpSlot.isFortyBack) then
					app.raiseCMException1(SlotRequestUpdateFromBack, tmpSlot.getFullId(), null, null); 
					return; 
				elseif (theTI.isOverSizedContainer() and tmpSlot.mySlotDefnVoyage.isBackend) then
					app.raiseCMException1(SlotRequestUpdateFromBack, tmpSlot.getFullId() &amp; "*", null, null); 
					return; 
				endif;
			endif;
			// PAR 22076 to here 
		endif;
	endforeach;

	//epr par 32300 23/1/14
	if _isLoad and _voyAlloc.projected20 &lt;&gt; 0 then
		if _voyAlloc.projected20 &lt; _voyAlloc.getNumLoadCC + numSlots then
			app.raiseCMWarning3(Load_CC_Projected,_voyAlloc.description,(_voyAlloc.getNumLoadCC + numSlots).asStringJMT,_voyAlloc.projected20.asStringJMT,null,null,null);
		endif;
	endif;
	
	
	if _theSlotsAlt &lt;&gt; null and _theSlotsAlt.size &gt; 0 then
		if _theSlots.size &lt;&gt; _theSlotsAlt.size then
			app.raiseCMException2(ErrNumSlotsAndAltSlotsNoEqual, _theSlots.size.String, _theSlotsAlt.size.String, null, null);
			return;
		endif;

		foreach	tmpSlotAlt in _theSlotsAlt do
			expectedEdition := _theEditions.getEditionForObject(tmpSlotAlt);
			if expectedEdition &lt; 0 then
				app.raiseExNoEditionForUpdateObj(tmpSlotAlt);
				continue;
			endif;
			
			exclusiveLock(tmpSlotAlt);
			if tmpSlotAlt.edition &lt;&gt; expectedEdition then
				app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(Slot) &amp; ' ' &amp; tmpSlotAlt.getFullId(), null, null);
				return;
			endif;
			tmpSlotDefn := tmpSlot.mySlotDefnVoyage;
			if tmpSlotDefn.unavailable then
				app.raiseCMException2(SlotIsUnavailable, tmpSlotAlt.getFullId(), app.getErrorString(UpdateIt), null, null); // PAR 26684 was using ident attribute
				continue;
			endif;

			if _isLoad then
				tmpSlotRequest := tmpSlot.mySlotRequestLoad;				
			else
				tmpSlotRequest := tmpSlot.mySlotRequestDischarge;
			endif;

// PAR 21746			if tmpSlotRequest &lt;&gt; null and tmpSlotRequest.fortyBack then
			if tmpSlotRequest &lt;&gt; null and tmpSlotRequest.getAttrIsBackend() then // PAR 21746
				app.raiseCMException1(SlotRequestUpdateFromBack, tmpSlot.getFullId(), null, null);
			endif;

		endforeach;
	endif;
epilog
	delete slotIter;
end;</source>
        <access>protected</access>
        <Parameter name="_theSlots" type="CM_SlotControllerArray"/>
        <Parameter name="_theSlotsAlt" type="CM_SlotControllerArray"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_theEditions" type="CM_ObjectByOidEditionDict"/>
        <Parameter name="_voyAlloc" type="CM_VoyageAllocation"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxActivateStopRequests" id="12790029-07d7-4bea-b580-ec59d314b475">
        <updating/>
        <source>trxActivateStopRequests(_coll :ObjectArray; _passport :CM_Passport input)updating;
// ---------------------------------------------------------------------------
// Created:     14 December 2010 by cnwcs5 ccms mes 1112 / par 24464
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj : Object;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	// Start the transaction
	beginTransaction;
	
	foreach obj in _coll do
		self.exclusiveLock(obj);
		// note: following type-cast will cause exception
		app.myUtilityUA.utlActivateStopRequest(obj.CM_EventRequestStops, _passport);
	endforeach;

epilog		
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_coll" type="ObjectArray"/>
