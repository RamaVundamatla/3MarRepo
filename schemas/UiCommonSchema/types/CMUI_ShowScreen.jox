Date		Who		Reason
08 Apr 2008	cnwkpd1	PAR #16487 - Remove transaction state check

*/

vars
//	localTrans	: Boolean;
	
begin

	self.endNotificationForSubscriber(self);
	
//	localTrans := (not process.isInTransactionState());
