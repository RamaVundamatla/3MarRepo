    <JadeMethod name="getYardSourceText" id="09984691-bb82-4b39-b602-cc79b7c2b759">
        <source>getYardSourceText():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 July 2015	cnwma1	PAR # 36555 CCMS 2509 TFS - Multi-location selection for MTs for vessel release

*/

vars
	ta 		: CM_TerminalArea;
	sep 	: String;
	result 	: String;
begin	

	foreach ta in self.allTerminalAreas do
		result := result &amp; sep &amp; ta.id;
		sep := ', ';
	endforeach;
	
	return result;
epilog

end;</source>
