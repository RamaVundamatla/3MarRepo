    <JadeMethod name="doOK" id="21d43cc9-dab2-44f2-a635-57cf0f214175">
        <updating/>
        <source>doOK() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/01/2012	cnwdap1	Initial creation
*/
vars

begin
	// if I'm a no-info form, has the user chosen an option
	if self.isNoInfo and not self.optFull.value and not self.optLimited.value then
		return;
	endif;
	
	if self.myCurrentBookingRef = null then
		return;
	endif;
	
	if self.doValidateBookingForCargo() then
		self.modalResult := ModalResultOK;
		self.unloadForm();
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectBooking" id="3e635e42-577f-4742-8cae-774510268d77">
        <updating/>
        <source>doSelectBooking() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/01/2012	cnwdap1	Initial creation PAR #28962 CCMS CPL 2100
*/
vars
	bookingRef	: CM_BookingRef;
	brItem		: CM_BookingRefItem;
	row			: Integer;
	
begin
	if self.tblBookingRef.row &lt;= self.tblBookingRef.fixedRows then
		return;
	endif;
	
	self.tblBookingRef.accessRow(self.tblBookingRef.row).selected := true;
	if self.isNoInfo then
		brItem := self.tblBookingRef.accessRow(self.tblBookingRef.row).itemObject.CM_BookingRefItem;
		bookingRef := brItem.myBookingReference;
	else
		bookingRef := self.tblBookingRef.accessRow(self.tblBookingRef.row).itemObject.CM_BookingRef;
	endif;
	
	self.myCurrentBookingRef 		:= bookingRef;
	self.myCurrentBookingRefItem	:= brItem;
	self.lblVoyageDet.caption 		:= self.myCurrentBookingRef.myVoyage.code;
	self.lblDischDet.caption		:= self.myCurrentBookingRef.dischargePort;
	self.lblDestDet.caption			:= self.myCurrentBookingRef.destinationPort;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doValidateBookingForCargo" id="997ab2d8-7827-428d-b1e2-d504a2e72c8c">
        <updating/>
        <source>doValidateBookingForCargo() : Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/01/2012	cnwdap1	Initial creation
*/
vars
	bookingItem : CM_BookingRefItem;
	result 		: Integer;
	reason		: String; //05/04/2024	navkc1 Bug 63509
begin
	if self.myCurrentTrackedItem &lt;&gt; null then				//+cnwml2 PAR22785
		bookingItem := self.myCurrentBookingRef.getMatchingItemForTI( self.myCurrentTrackedItem, reason);
	
		if bookingItem = null then // havnt found a booking item show a warning.
			//result :=  app.msgBox(app.getErrorString2( Error_No_Booking_Ref_Item, self.myCurrentBookingRef.bookingReference, self.myCurrentTrackedItem.id), 'No Booking Item Found', MsgBox_OK_Cancel );
			result :=  app.msgBox(app.getErrorString3( Error_No_Booking_Ref_Item, self.myCurrentBookingRef.bookingReference, self.myCurrentTrackedItem.id, reason), 'No Booking Item Found', MsgBox_OK_Cancel ); //05/04/2024	navkc1 Bug 63509
			
			if result = MsgBox_Return_OK then
				return true;
			else
				return false;
			endif;
		else
			return true;
		endif;
		
		return bookingItem &lt;&gt; null;
	else
		return true;
	endif;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getBRItemDisplay" id="6251589e-89c6-4ef2-9f8a-26b57e55264a">
        <updating/>
        <source>getBRItemDisplay(_brItem : CM_BookingRefItem) : String updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/01/2012	cnwdap1	Initial creation PAR #28962 CCMS CPL 2100
*/
vars
	viewName : String;
	etView : EntTableView;
	etDef : EntTableDef;
	etRow : EntTableRow;
	strDisplay, strObj : String;
	allDisplayEntTableRows : EntTableRowArray;

begin
	viewName := _brItem.getViewName;
	etDef := app.myRoot.myEntTableDataRoot.allEntTableDefs["BookRefText"];
	if viewName &lt;&gt; null then
		etView := etDef.allEntTableViews[viewName];
	endif;
	
	create allDisplayEntTableRows transient;
	etDef.allEntTableRows.copy(allDisplayEntTableRows);

	foreach etRow in allDisplayEntTableRows do
		if etView &lt;&gt; null and not etView.allEntTableRows.includes(etRow) then
			continue; // the field is not in this view
		endif;
		strObj := self.getTextTableDisplay(_brItem, etRow);
		if strObj = null then
			continue;
		endif;
		if strDisplay = '' then
			strDisplay := strObj;
		else
			strDisplay := strDisplay &amp; '; ' &amp; strObj;
		endif;
	endforeach;
	
	return strDisplay;
	
epilog
	delete allDisplayEntTableRows;
end;</source>
        <Parameter name="_brItem" type="CM_BookingRefItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTextTableDisplay" id="03f2994a-2bea-4535-9c2d-b636c2e1c02b">
        <source>getTextTableDisplay(_obj: Object; _etRow: EntTableRow): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/01/2012	cnwdap1	Initial creation
19/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars
	rowName : String;
	str 	: String;
	brItem	: CM_BookingRefItem;
	measure	: String;							// PAR #31155

begin
	brItem := _obj.CM_BookingRefItem;
	rowName := _etRow.name;
	
	if rowName = "cargoType" and brItem.cargoType = null then
		return null;
	elseif rowName = "isoType" and brItem.isoType = null then
		return null;
	elseif rowName = "isoTypeGroup" and brItem.isoTypeGroup = null then
		return null;
	elseif rowName = "commodity" and brItem.commodity = null then
		return null;
	elseif rowName = "allTIHazards" and brItem.allTIHazards.isEmpty then
		return null;
	elseif rowName = "description" and brItem.description = null then
		return null;		
	elseif rowName = "remarks" and brItem.remarks = null then
		return null;		
	elseif rowName = "weightTotal" and brItem.weight = null then
		return null;		
	elseif rowName = "quantity" and brItem.quantity = null then
		return null;		
	elseif rowName = "humidity" and brItem.getHumidity = null then
		return null;		
	elseif rowName = "carriageTempC" and brItem.getTemperature = NULL_TEMPERATURE then
		return null;		
	elseif rowName = "carriageTempF" and brItem.getTemperature = NULL_TEMPERATURE then
		return null;		
	elseif rowName = "ventilation" and brItem.getVentilation = null then
		return null;		
	elseif rowName = "isControlledAtmosphere" and brItem.isControlledAtmosphere = null then
		return null;		
	elseif rowName = "oxygen" and brItem.getOxygen = null then
		return null;		
	elseif rowName = "carbonDioxide" and brItem.getCarbonDioxide = null then
		return null;		
	elseif rowName = "curtainsIn" and brItem.getCurtainsIn = null then
		return null;		
	elseif rowName = "clean" and brItem.clean = null then
		return null;		
	elseif rowName = "inspected" and brItem.inspected = null then
		return null;		
	elseif rowName = "numOnsiteTIs" and brItem.getNumOnsiteItemsUnpacked = null then
		return null;		
	elseif rowName = "tiReceived" and brItem.getRecievedCount = null then
		return null;		
	elseif rowName = "allLinkedExpBookingsInfo" and brItem.myBookingReference.allLinkedStockBookingItems.isEmpty = null then
		return null;		
	endif;
	
	if rowName = "weightTotal" then
		rowName := "weight";
	endif;
	str := brItem.getDisplayStringForAttribute(rowName, true);
	if str &lt;&gt; null then
		if _etRow.measurementType &lt;&gt; null then													// PAR #31155
			measure := brItem.getDefaultMeasurementForType(_etRow.measurementType).shortName;	// PAR #31155
			measure := Space &amp; Left_Round_Bracket &amp; measure &amp; Right_Round_Bracket;				// PAR #31155
		endif;																					// PAR #31155
		//str := _etRow.getHeading(null, null, app.myCurrentLocale) &amp; ': ' &amp; str;
		str := _etRow.getHeading(null, null, app.myCurrentLocale) &amp; measure &amp; ': ' &amp; str;		// PAR #31155
	endif;
	return str;
	
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_etRow" type="EntTableRow"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setupBookingRefTable" id="2f1aabf8-ecfa-490c-95e3-974e3227a3f6">
        <updating/>
        <source>setupBookingRefTable() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/01/2012	cnwdap1	Initial creation PAR #28962 CCMS CPL 2100
*/
vars
	booking : CM_BookingRef;
	brItem	: CM_BookingRefItem;
	str		: String;
	brStr	: String;
	idx		: Integer;
	
begin
	// set up heading row
	self.tblBookingRef.rows := self.tblBookingRef.fixedRows;
	if self.isNoInfo then
		self.tblBookingRef.columns := 8;
		self.tblBookingRef.accessCell(1, 1).text := "Booking" &amp; Tab &amp; "Operator" &amp; Tab &amp; "Voyage" &amp; Tab &amp; "Vessel" &amp; Tab &amp; "Arrives" &amp; Tab &amp; "Discharge" &amp; Tab &amp; "Dest" &amp; Tab &amp; "Item Dtls";
	else
		self.tblBookingRef.columns := 7;
		self.tblBookingRef.accessCell(1, 1).text := "Booking" &amp; Tab &amp; "Operator" &amp; Tab &amp; "Voyage" &amp; Tab &amp; "Vessel" &amp; Tab &amp; "Arrives" &amp; Tab &amp; "Discharge" &amp; Tab &amp; "Dest";
	endif;
	self.tblBookingRef.autoSize := Table.AutoSize_Row;
	self.tblBookingRef.selectMode := Table.SelectMode_Row;
	self.tblBookingRef.accessColumn(1).width := 80;
	self.tblBookingRef.accessColumn(2).width := 70;
	self.tblBookingRef.accessColumn(3).width := 80;
	self.tblBookingRef.accessColumn(4).width := 100;
	self.tblBookingRef.accessColumn(5).width := 115;
	self.tblBookingRef.accessColumn(6).width := 70;
	self.tblBookingRef.accessColumn(7).width := 50;
	if self.isNoInfo then
		self.tblBookingRef.accessColumn(8).width := 250;
	endif;
	
	foreach booking in self.allBookingRefs do
		if booking.myVoyage &lt;&gt; null then
			str := booking.bookingReference 							&amp; Tab &amp;
					booking.myOperator.code 							&amp; Tab &amp;
					booking.myVoyage.code								&amp; Tab &amp;
					booking.myVoyage.vesselName							&amp; Tab &amp;
					booking.myVoyage.arrivedDT.shortCurrentLocaleFormat	&amp; Tab &amp;
					booking.dischargePort								&amp; Tab &amp;
					booking.destinationPort								&amp; Tab;
					
			if self.isNoInfo then
				foreach brItem in booking.allBookingRefItems do
					brStr := str &amp; self.getBRItemDisplay(brItem);
					idx := self.tblBookingRef.addItemObject(brItem, brStr);
					self.tblBookingRef.accessCell(idx, self.tblBookingRef.columns).wordWrap := true;
				endforeach;
			else
				self.tblBookingRef.addItemObject(booking, str);
			endif;
		endif;
	endforeach;
	
	self.tblBookingRef.selectRow(self.tblBookingRef.fixedRows + 1, false);
	self.doSelectBooking;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e478eb3c-1c26-450c-819e-2ae6d5de08ca">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/01/2012	cnwdap1	Initial creation PAR #28962 CCMS CPL 2100
*/
vars

begin
	inheritMethod();
	
	self.centreWindow();
	self.setupBookingRefTable();
	
	if self.isNoInfo then
		self.optFull.visible 		:= true;
		self.optLimited.visible 	:= true;
		self.lblVoyage.visible 		:= false;
		self.lblVoyageDet.visible	:= false;
		self.lblDisch.visible		:= false;
		self.lblDischDet.visible	:= false;
		self.lblDest.visible		:= false;
		self.lblDestDet.visible		:= false;
	else
		self.optFull.visible 		:= false;
		self.optLimited.visible 	:= false;
		self.lblVoyage.visible 		:= true;
		self.lblVoyageDet.visible	:= true;
		self.lblDisch.visible		:= true;
		self.lblDischDet.visible	:= true;
		self.lblDest.visible		:= true;
		self.lblDestDet.visible		:= true;
	endif;

epilog

end;</source>
    </JadeMethod>
