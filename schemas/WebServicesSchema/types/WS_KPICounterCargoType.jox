    <JadeMethod name="setFromCMIFKPICounterCargoType" id="33348ce5-86fd-47d2-b6f2-4ce5829795c6">
        <updating/>
        <source>setFromCMIFKPICounterCargoType( _kpiCargoType : CMIF_KPICounterCargoType input) updating;
/*

Date		Who		Reason
15 July 2015	cnwer1	Initial creation PAR

*/

vars	
	ct : CM_CargoType;
begin
	
	create myCargoType transient;
	myCargoType.setProxyFromObject(_kpiCargoType.myCargoType);
	self.totalQuantity:=_kpiCargoType.getTotalQuantity();
	self.totalTEU:=_kpiCargoType.getTotalTEU();
	self.totalWeight:=_kpiCargoType.getTotalWeight();
	
epilog

end;</source>
        <Parameter name="_kpiCargoType" type="CMIF_KPICounterCargoType" usage="input"/>
