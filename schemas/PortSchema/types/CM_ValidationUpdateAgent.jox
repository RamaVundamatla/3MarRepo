    <JadeMethod name="valCAMLog" id="5ed3055b-f635-4746-85a3-fa6a401d0ef6">
        <source>valCAMLog(_logFile: File);
// ---------------------------------------------------------------------------
// Created:		26 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	if _logFile = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'expected log file was null');
