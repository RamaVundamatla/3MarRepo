    <JadeMethod name="getConsigneeDesc" id="84f9d423-ceee-4640-929f-15ac960be323">
        <source>getConsigneeDesc() : String;
// ---------------------------------------------------------------------------
// Created:     26 August 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	conseeDesc	: String;
	root		: CM_Root;
	conseeCons	: CM_ConsigneeConsignor;
begin
	if self.consignee &lt;&gt; null then
		root := self.getRoot();	//can't use app.myRoot =&gt; reports
		if root &lt;&gt; null then
			conseeCons := root.allConsigneeConsignors[self.consignee];
			if conseeCons &lt;&gt; null then
				conseeDesc := conseeCons.description;
			endif;	
		endif;
	endif;
	
	return conseeDesc;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getConsignorDesc" id="bf5b36e3-0425-47b9-90f8-7cca49fe6ee4">
        <source>getConsignorDesc() : String;
// ---------------------------------------------------------------------------
// Created:		13 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	consDesc	: String;
	root		: CM_Root;
	consCons	: CM_ConsigneeConsignor;
begin
	if self.consignor &lt;&gt; null then
		root := self.getRoot();	//can't use app.myRoot =&gt; reports
		if root &lt;&gt; null then
			consCons := root.allConsigneeConsignors[self.consignor];
			if consCons &lt;&gt; null then
				consDesc := consCons.description;
			endif;	
		endif;
	endif;
	
	return consDesc;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCreatedByUser" id="6d78c26c-cfc2-4eb0-8db1-946703e0b385">
        <source>getCreatedByUser():CM_User;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Mar 2024	navma1  Bug 62810: MTN - Notifications causing updates to combo box in cargo work order

*/

vars
	audit : CM_AuditObject;
begin
	audit := self.allAuditObjects.first;
	
	if audit &lt;&gt; null then
