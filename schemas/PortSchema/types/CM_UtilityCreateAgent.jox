        <source>utlCreateMeasurementType(	_proxyMeasure : CM_MeasurementType; 
							_realMeasure : CM_MeasurementType output; 
							_passport : CM_Passport input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 February 2013	cnwdap1	Initial creation
*/
vars

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	app.myValCA.valMeasurementType(_proxyMeasure);
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	app.setContinueCMExceptions(false);

	create _realMeasure persistent;
	_realMeasure.setForCreate(_proxyMeasure);
	
	if _passport.noErrors then
		_realMeasure.checkForDefault();
	endif;
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_realMeasure);
	endif;
	//navsp1 01Jun2022 TFS#53104
	if _passport.noErrors then
		if _passport.isOpsViewEnabled(null) then
			_realMeasure.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE, BGP_OpsViewWSRequest.OPS_TYPE_MEASUREMENTTYPE, _realMeasure);
		endif;
	endif;

epilog

end;</source>
