    <JadeMethod name="addNotableObject" id="c1738fab-bd8d-4b60-a574-f1a51def5b63">
        <source>addNotableObject(_obj : CM_Object);
//--------------------------------------------------
// Created:	19 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	vesselData 	: HMS_VesselData;
 	tmpData		: HMS_VesselDataHarbour;	
begin

	if _obj = null then
		return;
	endif;
	
	if self.allNotableObjects.includes(_obj) then
		return;
	endif;
	
	self.beginNotification(_obj, Object_Update_Event, Response_Continuous, 0);
	self.beginNotification(_obj, Object_Delete_Event, Response_Continuous, 0);	
	
	if CM_Vessel.hasInstance(_obj) then
		vesselData := _obj.CM_Vessel.myHMSVesselData;
	endif;
	
	if vesselData &lt;&gt; null then
		if (not self.allNotableObjects.includes(vesselData)) then
			self.beginNotification(vesselData, Object_Update_Event, Response_Continuous, 0);
			self.allNotableObjects.add(vesselData);					
		endif;
		tmpData := vesselData.allVesselDataForHarbour[self.myHarbour];
		if tmpData &lt;&gt; null then
			if (not self.allNotableObjects.includes(tmpData)) then
				self.beginNotification(tmpData, Object_Update_Event, Response_Continuous, 0);
				self.allNotableObjects.add(tmpData);					
			endif;
		endif;		
	endif;
	
	self.allNotableObjects.add(_obj);					
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="c1a738ca-33f2-4071-af8e-dc6709a27bfb">
        <updating/>
        <source>addToolbarControls() updating, protected;
