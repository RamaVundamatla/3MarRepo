    <JadeMethod name="availabilityDescription" id="4da56b3c-eab1-496b-875c-740da8753768">
        <methodInvocation>mapping</methodInvocation>
        <source>availabilityDescription(set: Boolean; value: String io) mapping;

vars
	avail:   CM_MachineAvailability;
begin
	value := "";
	if set then 
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if self.availabilityCode.trimBlanks = null then
		value := null;
		return;
	endif;
	avail := app.myRoot.allMachineAvailabilities[availabilityCode];
	if avail &lt;&gt; null then
		value := avail.description.trimBlanks;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="goneIdle" id="4080fafc-e6b3-406b-8bd9-e5ae1ec68af1">
        <updating/>
        <source>goneIdle(_userCode : String; _mach : CM_Machine) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/09/2020	jlgdap1		Initial creation TFS 49316 MTN Machine Idle Time
//
vars

begin
	self.setDetails(CM_MachineHistory.Type_Idle, _mach, _userCode);
epilog

end;</source>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_mach" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="goneOffLine" id="2719edd6-ea02-4a87-b570-35f15abae7ec">
        <updating/>
        <source>goneOffLine(availability: String; userCode: String; mach: CM_Machine) updating;

begin
	self.setDetails(CM_MachineHistory.Type_GoOffline,mach,userCode);
	
	setAvailabilityCode(availability);
end;</source>
        <Parameter name="availability" type="String"/>
        <Parameter name="userCode" type="String"/>
        <Parameter name="mach" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="goneOnLine" id="797d5859-2bfd-4c5f-8e1c-83969cc4b4cc">
