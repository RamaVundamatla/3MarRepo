    <JadeMethod name="getJMTIndex" id="6c0712b9-186d-4720-8842-a4bf614d9dd7">
        <source>getJMTIndex(_localDocPath : String; _serverDocPath : String; _serverSize : Integer io);

constants
	INDEX_FOLDER : String = "JMTIndex";
	INDEX_FILE1 : String = "index.idx";
	INDEX_FILE2 : String = "index1.idx";
vars
	ff : FileFolder;
begin
	if self.getFolderStatus(INDEX_FOLDER, _localDocPath, _serverDocPath, _serverSize) = FileStatus_AbsentClient then
		global.checkFileFolderExists(_localDocPath &amp; INDEX_FOLDER, true, true);
		global.copyServerFileToClient(global.getJMTDocumentationDirServer()  &amp; INDEX_FOLDER &amp; "\" &amp; INDEX_FILE1, global.getJMTDocumentationDir() &amp; INDEX_FOLDER &amp; "\" &amp; INDEX_FILE1, null);
		global.copyServerFileToClient(global.getJMTDocumentationDirServer()  &amp; INDEX_FOLDER &amp; "\" &amp; INDEX_FILE2, global.getJMTDocumentationDir() &amp; INDEX_FOLDER &amp; "\" &amp; INDEX_FILE2, null);
	else
		create ff transient;
		ff.fileName := global.getJMTDocumentationDir() &amp; INDEX_FOLDER;
		ff.mask := "*.idx";
		if ff.files.size &lt;&gt; 2 then  //expected 2 *.idx files for JMTIndex
			global.copyServerFolderToClient(global.getJMTDocumentationDirServer() &amp; INDEX_FOLDER, global.getJMTDocumentationDir() &amp; INDEX_FOLDER, null);
		endif;
	endif;
epilog
	delete ff;
end;
</source>
        <Parameter name="_localDocPath" type="String"/>
        <Parameter name="_serverDocPath" type="String"/>
        <Parameter name="_serverSize" type="Integer" usage="io"/>
    </JadeMethod>
