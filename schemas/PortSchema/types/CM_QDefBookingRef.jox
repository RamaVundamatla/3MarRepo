    <JadeMethod name="createProperties" id="f36f3793-cc42-4baf-af13-1a50d2d84653">
        <source>createProperties();
/*

Date				Who		Reason
23 November 2009	cnwndl1	Initial creation	CCMS 1028
23/05/2011			CNWCS5	CCMS SCT 2058 / par 27460 - new carrier reference property
21/08/2014			cnwdap1	PAR #33235 Measurement types in Summaries
*/

vars
	tmpProp		: CM_QueryProperty;
begin
	inheritMethod();
	
	create tmpProp as CM_QIntegerProperty persistent;
	tmpProp.set('# Cargo Items', CM_BookingRef::numTIs.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QIntegerMethod persistent;
	tmpProp.set('# Onsite Cargo Items', CM_BookingRef::numOnsiteTIs.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QIntegerMethod persistent;
	tmpProp.set('# Overs/Unders', CM_BookingRef::getOverunderCount.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QIntegerMethod persistent;
	tmpProp.set('# Prenoted', CM_BookingRef::getPrenotedCount.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QIntegerMethod persistent;
	tmpProp.set('# Received', CM_BookingRef::getRecievedCount.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QIntegerMethod persistent;
	tmpProp.set('# Released', CM_BookingRef::getReleasedCount.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QIntegerMethod persistent;
	tmpProp.set('# Reserved', CM_BookingRef::getReservedCount.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Booking', CM_BookingRef::getBookingRefString.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Booking Remarks', CM_BookingRef::getBookingRefRemarks.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	// par 27460 - carrier reference
	create tmpProp as CM_QStringMethod persistent;	// par 27460 cnwcs5
	tmpProp.set('Carrier Reference', CM_BookingRef::getCarrierReference.name, self.className);	// par 27460 cnwcs5
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);			// par 27460 cnwcs5

	create tmpProp as CM_QStrCommodityMethod persistent;
	tmpProp.set('Commodity', CM_BookingRef::getCommodity.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);

	create tmpProp as CM_QStrCommodityGroupMethod persistent;
	tmpProp.set('Commodity Group', CM_BookingRef::getCommodityGroupDesc.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrConsignProperty persistent;
	tmpProp.CM_QStrConsignProperty.type := CONSIGNEE;
	tmpProp.set('Consignee', CM_BookingRef::consigneeCode.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrConsignProperty persistent;
	tmpProp.CM_QStrConsignProperty.type := CONSIGNEE;
	tmpProp.set('Consignee Name', CM_BookingRef::consigneeDesc.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);

	create tmpProp as CM_QStrConsignProperty persistent;
	tmpProp.CM_QStrConsignProperty.type := CONSIGNOR;
	tmpProp.set('Consignor', CM_BookingRef::consignorCode.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrConsignProperty persistent;
	tmpProp.CM_QStrConsignProperty.type := CONSIGNOR;
	tmpProp.set('Consignor Name', CM_BookingRef::consignorDesc.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Consignor Reference', CM_BookingRef::getConsignorReference.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Customer Priority', CM_BookingRef::getCustomerPriorityDesc.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Customer Reference', CM_BookingRef::getCustomerReference.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrPortMethod persistent;
	tmpProp.set('Destination', CM_BookingRef::getDestinationPort.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrPortMethod persistent;
	tmpProp.set('Discharge Port', CM_BookingRef::getDischargePort.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanProperty persistent;
	tmpProp.set('Fumigation Needed', CM_BookingRef::fumigationNeeded.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanMethod persistent;
	tmpProp.set('Hazardous', CM_BookingRef::getIsHazardous.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanMethod persistent;
	tmpProp.set('Military', CM_BookingRef::getIsMilitary.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanMethod persistent;
	tmpProp.set('Multi-Item', CM_BookingRef::getIsMultiItemBookingRef.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanProperty persistent;
	tmpProp.set('No Empties Out', CM_BookingRef::noEmptiesOut.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanProperty persistent;
	tmpProp.set('No Fulls', CM_BookingRef::noFullIsAllowedIn.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Operator', CM_BookingRef::getOperatorCode.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanMethod persistent;
	tmpProp.set('Over Dimension', CM_BookingRef::getIsOverDimension.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanProperty persistent;
	tmpProp.set('Override Voyage Cut-off', CM_BookingRef::overrideCutoff.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Pack As', CM_BookingRef::getPackAsString.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanMethod persistent;
	tmpProp.set('Reconciled', CM_BookingRef::getReconciliation.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Shipping Reference', CM_BookingRef::getShippingReference.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Special Lift', CM_BookingRef::getSpecialLiftDesc.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Special Stow', CM_BookingRef::getSpecialStowDesc.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Status', CM_BookingRef::getStatusString.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanMethod persistent;
	tmpProp.set('Stock', CM_BookingRef::getIsStockBookingRef.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanMethod persistent;
	tmpProp.set('Stopped', CM_BookingRef::getIsStopped.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QIntegerMethod persistent;														
	tmpProp.set('Total Qty', CM_BookingRef::getTotalQuantity.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);

	//create tmpProp as CM_QDecimalProperty persistent;																								// PAR #33235
	//tmpProp.set('Total Weight', CM_BookingRef::totalWeightMap.name, self.className);																// PAR #33235
	//self.allQueryProperties.add(tmpProp);																											// PAR #33235
	self.createMeasurementProperties(CM_QDecimalProperty, Type_Weight, 'Total Weight', CM_BookingRef::totalWeightMap.name, self.className, null);	// PAR #33235
	
	create tmpProp as CM_QBooleanMethod persistent;
	tmpProp.set('Tranship', CM_BookingRef::getTranship.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrPortMethod persistent;
	tmpProp.set('Tranship To Port', CM_BookingRef::getMyTranshipToPort.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Tranship Voyage', CM_BookingRef::getMyTranshipVoyage.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('V Num', CM_BookingRef::getVNumber.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Vessel Code', CM_BookingRef::getVesselCode.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Vessel Name', CM_BookingRef::getVesselName.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//create tmpProp as CM_QIntegerMethod persistent;																					// PAR #33235
	//tmpProp.set('Volume', CM_BookingRef::getVolume.name, self.className);																// PAR #33235
	//self.allQueryProperties.add(tmpProp);																								// PAR #33235
	self.createMeasurementProperties(CM_QIntegerMethod, Type_Volume, 'Volume', CM_BookingRef::getVolume.name, self.className, null);	// PAR #33235
	
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Voyage', CM_BookingRef::getVoyageCode.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);

epilog

end;</source>
    </JadeMethod>
