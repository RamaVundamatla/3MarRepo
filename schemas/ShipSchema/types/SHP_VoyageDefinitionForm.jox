Date		Who		Reason
09 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	xLeft 	: Real;
	yTop	: Real;
	section	: CM_VesselSection;
begin

	xLeft := x;
	yTop := y;


	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form

	
	self.mnuSectionAudit.visible:=false;
	if table.row &gt; 1 and table.accessRow(table.row) &lt;&gt; null then
		section:=table.accessRow(table.row).itemObject.CM_VesselSection;
		self.mnuSectionAudit.visible:= section.hasAudits; //14 Jan 2021	NDL	TFS 50152
	endif;
	

	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuSectionAdd.visible := false;
		self.mnuSectionDelete.visible := false;

	endif;
	
	self.popupMenu(self.mnuSectionContext, xLeft.Integer, yTop.Integer);

	return false;

epilog

end;</source>
