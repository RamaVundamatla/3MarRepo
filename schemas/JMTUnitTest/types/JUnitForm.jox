    <JadeMethod name="lbxTests_contextMenu" id="be034542-11d0-4690-a262-bfef06b1d073">
        <controlMethod name="ListBox::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lbxTests_contextMenu(listbox: ListBox input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 March 2025	NAVRV30	JIRA 33943 MTN | Unit Test Runner Select Failed Tests

*/

vars

begin
	if self.txtFilter.text.trimWhiteSpace().length &gt; 0 then
		return true;
	endif;
	self.doContextMenuEntity(listbox, conwin, mouse, x, y);
	return true;
epilog

end;</source>
