    <JadeMethod name="populateAllocationsByPriority" id="3955d2db-77a1-40b2-95d1-14feff0955bc">
        <source>populateAllocationsByPriority(_allocs : CM_VoyAllocationByPriority input);
// ---------------------------------------------------------------------------
// Created:     28 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	voyAlloc : CM_VoyageAllocation;
	alloc : CM_YardAllocation;
	voyPrioirity : Integer;
begin
	foreach alloc in self.allVoyageAllocations discreteLock do
		voyAlloc := alloc.CM_VoyageAllocation;
		voyPrioirity := voyAlloc.getPriority();
//	write voyAlloc.description	&amp; " " &amp; voyPrioirity.String;	
		_allocs.putAtKey(voyPrioirity,voyAlloc);
	endforeach;
epilog

end;</source>
        <Parameter name="_allocs" type="CM_VoyAllocationByPriority" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processStopsEDIOnShip" id="816b3f00-c6c4-4cbd-b37c-88a5a2eab4bd">
        <updating/>
        <source>processStopsEDIOnShip(_passport: CM_Passport) updating;
//----------------------------------------------------------------
//	Created:	15 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 10 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	ediConfig			: CM_EDIConfig;
	terminal			: CM_Terminal;
	ediRequest			: BGP_EdiRequest;
	added				: Boolean;
begin
	terminal := self.myTerminal;
	ediConfig := terminal.myEdiConfig;
	
	if ediConfig = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'cannot continue with ediConfig not set');
		return;
	endif;
	
	//all we need to do here is add this voyage to the ediConfigs voyage list...
	added := ediConfig.addVoyageToProcessing(self, self.code); //PAR24219 - cnwsh3 duplicate object entries and invalid refs in dict issues.
	
	//...and create a bgp request to process edi
	create ediRequest persistent;
	ediRequest.initEDIFromVoyage(self);	// 21/06/2011 cnwcs5 par27167 - new parameter

	if added then
		self.setRemarks("Voyage added to EDI Customs processing " &amp; app.serverTimestampAtTrxStart.shortCurrentLocaleSystemUTC, true);// 10 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	else
		self.setRemarks("Voyage already added to EDI Customs processing.", true);
	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="pxyChangeVesselAttribs" id="c905b63f-a9f1-4f73-af99-51444a63838b">
        <updating/>
        <source>pxyChangeVesselAttribs( _vessel : CM_Vessel ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2020	jlgndl1	Initial creation	TFS 49417

*/

vars

	tmpGlobalVoyage	: CM_VoyageGlobal;
	
	vesselCellularStructure : CM_CellularVesselStructure;
	pxyCellStructure : CM_CellularVoyageStructure;
	pxyGCVoyage : CM_GeneralCargoVoyageStructure;
	pxyROROVoyage 		: CM_ROROVoyageStructure;
	pxyVoyageStruct 	: CM_VoyageStructuralElements;

	bridgeAfterBay : String;
	isoHalfHeights, 
	use40Id,
	useBayCellTierNumbering  : Boolean;
	
	pxyHMSVoyage : HMS_VoyageData;

begin

	//delete existing structures
	
	delete self.myCellularVoyageStructure;
	delete self.myROROStructure;
	delete self.myGeneralCargoVoyage;
	delete self.myStructuralElements;
	
	//Now re-populate all teh vessel type data
	
	self.setForCreateInternal(_vessel, app.myPassport);
	
	if _vessel.structureIncludesLOLO then
		create pxyCellStructure transient;
		
		self.setProxyVoyageCellullStructure(pxyCellStructure);
		vesselCellularStructure := _vessel.myCellularVesselStructure;
		useBayCellTierNumbering := true;
		if vesselCellularStructure &lt;&gt; null then
			bridgeAfterBay:=vesselCellularStructure.bridgeAfterBay;
			isoHalfHeights:= vesselCellularStructure.isoHalfHeights;
			use40Id:=vesselCellularStructure.use40Id;
			useBayCellTierNumbering:= vesselCellularStructure.useBayCellTierNumbering;
		endif;
		
		pxyCellStructure.setProxyCellularVoyage( bridgeAfterBay, isoHalfHeights,
									 use40Id, useBayCellTierNumbering );
		
	endif;
	if _vessel.structureIncludesRORO then
		create pxyROROVoyage transient;
		self.setMyROROStructure( pxyROROVoyage );
	endif;
	if _vessel.structureIncludesHolds then
		create pxyGCVoyage transient;
		self.setProxyVoyageGeneralCargo( pxyGCVoyage );
	endif;
	if _vessel.myStructuralElements &lt;&gt; null then
		create pxyVoyageStruct transient;
		self.setProxyStructuralElement( pxyVoyageStruct );
	endif;
	
	self.updateVoyageFromVessel(_vessel, app.myPassport);
	
	self.yearOfBuild := _vessel.yearOfBuild;
//	if _vessel.myDefaultTrade &lt;&gt; null then
//		self.myTrade := _vessel.myDefaultTrade;
//	endif;
//	if _vessel.myHMSVesselData &lt;&gt; null then
//		self.myShippingLine := _vessel.myHMSVesselData.myDefaultShippingLine;
//	endif;
//	if _vessel.myOperator &lt;&gt; null then
//		self.myOperator := _vessel.myOperator;
//	endif;
	
	self.setAllocatedEvents(self.allAllocatedEvents);
	
	tmpGlobalVoyage := app.myRoot.allVoyagesGlobal[self.code];
	if tmpGlobalVoyage = null then
		create tmpGlobalVoyage transient;
		tmpGlobalVoyage.setProxy( self.code, _vessel.name, null, null, null, null, null, 0, null, app.myRoot);
	endif;
	self.setMyVoyageGlobalArrival(tmpGlobalVoyage);
	
	self.voyageCodeExternal := self.myTerminal.getNextVoyageExternalCode(_vessel);
	
	if _vessel.hasHarbourDetails then
		pxyHMSVoyage := self.myHMSVoyageData;
		if pxyHMSVoyage = null then
			create self.myHMSVoyageData transient;
			pxyHMSVoyage := self.myHMSVoyageData;
		endif;
		_vessel.myHMSVesselData.setProxyVoyageHMSData( pxyHMSVoyage,false, self.myTerminal );	
	endif;
	

epilog

end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="2c92b6f5-e3a1-4d3b-9a51-2bdd0776c397">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------------
//Created: 11 July 2002 By: cnwgd1
/* Changes

Date		Name	TFS#		Description
============================================================================
20/04/2011	cnwmh5	PAR #27401 	Add code to handle prossible exceptions occurring when
								trying to create the proxy
23/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
============================================================================*/

vars
	pxyVoyage 		: CM_Voyage;
	pxyPOC, realPOC	: CM_PortRotation;
	port			: CM_Port;
	completedOK		: Boolean;
	
begin
	pxyVoyage := inheritMethod();
	pxyVoyage.myOperator := self.myOperator;
	pxyVoyage.myShippingLine := self.myShippingLine;
	pxyVoyage.myDefaultLineGroupDebtor := self.myDefaultLineGroupDebtor;
	
	if self.myShipBlockStack &lt;&gt; null then
		pxyVoyage.myShipBlockStack := self.myShipBlockStack.pxyCreateUpdateProxy();
	endif;
	
	//09 Sep 2011	NDL	Par 28173
	if self.myNotNotifiedStack &lt;&gt; null then
		pxyVoyage.myNotNotifiedStack := self.myNotNotifiedStack.pxyCreateUpdateProxy();
	else
		create pxyVoyage.myNotNotifiedStack transient;
		pxyVoyage.myNotNotifiedStack.setProxy(pxyVoyage);
	endif;
	
	pxyVoyage.setMyTerminal(self.myTerminal);
	pxyVoyage.setMyVoyageGlobalArrival(self.myVoyageGlobalArrival);
	pxyVoyage.setMyVoyageGlobalDeparture(self.myVoyageGlobalDeparture);
	pxyVoyage.myTrade := self.myTrade;
	pxyVoyage.myCusresAltVoyage := self.myCusresAltVoyage;
	pxyVoyage.myDefaultLineGroupDebtor := self.myDefaultLineGroupDebtor;
	pxyVoyage.myDischargeCompany := self.myDischargeCompany;
	pxyVoyage.myVoyagePlanningCode := self.myVoyagePlanningCode;
	pxyVoyage.myMMReceival := self.myMMReceival;
	pxyVoyage.myMMRelease := self.myMMRelease;
	
	pxyVoyage.myVoyageProcess := self.myVoyageProcess; // TFS 40029
	
	self.allOperators.copy(pxyVoyage.allOperators);
		
	if self.myHMSVoyageData &lt;&gt; null then
		pxyVoyage.myHMSVoyageData := self.myHMSVoyageData.pxyCreateUpdateProxy();
	endif;
	
	if self.myGeneralCargoVoyage &lt;&gt; null then
		pxyVoyage.myGeneralCargoVoyage := self.myGeneralCargoVoyage.pxyCreateUpdateProxy();
	endif;
	
	if self.myLogVoyageStructure &lt;&gt; null then
		pxyVoyage.myLogVoyageStructure := self.myLogVoyageStructure.pxyCreateUpdateProxy();
	endif;
	
	if self.myCellularVoyageStructure &lt;&gt; null then
		pxyVoyage.myCellularVoyageStructure := self.myCellularVoyageStructure.pxyCreateUpdateProxy();
	endif;
	
	//04 Sep 2014	NDL	Par 33670
	if self.myROROStructure &lt;&gt; null then
		pxyVoyage.myROROStructure := self.myROROStructure.pxyCreateUpdateProxy();
	endif;
	
	if self.myStructuralElements &lt;&gt; null then
		pxyVoyage.myStructuralElements := self.myStructuralElements.pxyCreateUpdateProxy();
	endif;
	//jlgka1 TFS 45620 --&gt;
	//self.allDischgVoyCommodPlanningObjs.copy(pxyVoyage.allDischgVoyCommodPlanningObjs);
	//self.allLoadVoyCommodPlanningObjs.copy(pxyVoyage.allLoadVoyCommodPlanningObjs);
	//jlgka1 TFS 45620 &lt;--	
	
	// Do not create proxy Path Segment Duration objects - these will be created afresh with each update.
	
	// 24/08/2009 cnwar2 #20509
	foreach realPOC in self.allPortRotations do
		pxyPOC := realPOC.pxyCreateUpdateProxy();
		pxyPOC.setProxy(realPOC.myPort, pxyVoyage);
		pxyVoyage.allPorts.add(realPOC.myPort);
	endforeach;

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyVoyage;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyVoyage;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="pxyFromBargeUsingVesselAndCode" id="e1cbbd8b-4cb8-4ecb-b987-b6ad7395dd01">
        <updating/>
        <source>pxyFromBargeUsingVesselAndCode( _vessel : CM_Vessel; _code : String; _terminal : CM_Terminal ):CM_Voyage updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2020	jlgndl1	Initial creation	TFS 49417

*/

vars

	pxyVoyage : CM_Voyage;
	pxyShipBlockController : CM_ShipBlockController;
	pxyShipNoNoteController : CM_ShipNotNotifiedController;
	tmpGlobalVoyage	: CM_VoyageGlobal;
	
	vesselCellularStructure : CM_CellularVesselStructure;
	pxyCellStructure : CM_CellularVoyageStructure;
	pxyGCVoyage : CM_GeneralCargoVoyageStructure;
	pxyROROVoyage 		: CM_ROROVoyageStructure;
	pxyVoyageStruct 	: CM_VoyageStructuralElements;

	bridgeAfterBay : String;
	isoHalfHeights, 
	use40Id,
	useBayCellTierNumbering  : Boolean;
	
	pxyHMSVoyage : HMS_VoyageData;
	
	portRotation : CM_PortRotation;
	pxyPortRotation : CM_PortRotation;

begin

	pxyVoyage := self.cloneSelf(true);
	pxyVoyage.voyageCodeExternal := null;	//01 Jul 2020	NDL	TFS 49691
	
	pxyVoyage.code := _code;
	if pxyVoyage.inwardCode &lt;&gt; null then
		//if its null its OK, but if its already populated, it has to be unique.
		pxyVoyage.inwardCode := _code;
	endif;
	pxyVoyage.setForCreateInternal(_vessel, app.myPassport);
	pxyVoyage.setArrivalDepartureDT( self.arrivedDT, self.departedDT, false);
	pxyVoyage.myTrade := _vessel.myDefaultTrade;
	pxyVoyage.setMyTerminal( _terminal );
	if _vessel.myHMSVesselData &lt;&gt; null and _vessel.myHMSVesselData.myDefaultShippingLine &lt;&gt; null then
		pxyVoyage.setForShippingLineOperators(_vessel.myHMSVesselData.myDefaultShippingLine);
	else
		pxyVoyage.setForShippingLineOperators(self.myShippingLine);
	endif;
	
	if _vessel.structureIncludesLOLO then
		create pxyCellStructure transient;
		
		pxyVoyage.setProxyVoyageCellullStructure(pxyCellStructure);
		vesselCellularStructure:=_vessel.myCellularVesselStructure;
		useBayCellTierNumbering := true;
		if vesselCellularStructure &lt;&gt; null then
			bridgeAfterBay:=vesselCellularStructure.bridgeAfterBay;
			isoHalfHeights:= vesselCellularStructure.isoHalfHeights;
			use40Id:=vesselCellularStructure.use40Id;
			useBayCellTierNumbering:= vesselCellularStructure.useBayCellTierNumbering;
		endif;
		
		pxyCellStructure.setProxyCellularVoyage( bridgeAfterBay, isoHalfHeights,
									 use40Id, useBayCellTierNumbering );
		
	endif;
	if _vessel.structureIncludesRORO then
		create pxyROROVoyage transient;
		pxyVoyage.setMyROROStructure( pxyROROVoyage );
	endif;
	if _vessel.structureIncludesHolds then
		create pxyGCVoyage transient;
		pxyVoyage.setProxyVoyageGeneralCargo( pxyGCVoyage );
	endif;
	if _vessel.myStructuralElements &lt;&gt; null then
		create pxyVoyageStruct transient;
		pxyVoyage.setProxyStructuralElement( pxyVoyageStruct );
	endif;
	
	
	pxyVoyage.myDefaultLineGroupDebtor := self.myDefaultLineGroupDebtor;
	pxyVoyage.myDischargeCompany := self.myDischargeCompany;
	pxyVoyage.myOperator := self.myOperator;	
	if self.myHMSVoyageData &lt;&gt; null then
		pxyVoyage.myHMSVoyageData := self.myHMSVoyageData.cloneMySelf(true);
		//29 Jun 2020	NDL	TFS 49681
		if not self.myHMSVoyageData.allStevedoresDischarge.isEmpty then
			self.myHMSVoyageData.allStevedoresDischarge.copy( pxyVoyage.myHMSVoyageData.allStevedoresDischarge );
		endif;
		//29 Jun 2020	NDL	TFS 49681
		if not self.myHMSVoyageData.allStevedoresLoad.isEmpty then
			self.myHMSVoyageData.allStevedoresLoad.copy( pxyVoyage.myHMSVoyageData.allStevedoresLoad );
		endif;
	endif;
	
	pxyVoyage.setRemarks( self.remarks, false );	//29 Jun 2020	NDL	TFS 49681
	
	pxyVoyage.updateVoyageFromVessel(_vessel, app.myPassport);
	
	pxyVoyage.yearOfBuild := _vessel.yearOfBuild;
//	if _vessel.myDefaultTrade &lt;&gt; null then
//		pxyVoyage.myTrade := _vessel.myDefaultTrade;
//	endif;
	pxyVoyage.myTrade := self.myTrade;	//11 Jun 2020	NDL	TFS 49555
//	if _vessel.myHMSVesselData &lt;&gt; null then
//		pxyVoyage.myShippingLine := _vessel.myHMSVesselData.myDefaultShippingLine;
//	endif;

	//18 Jun 2021	NDL	TFS 51306
	if self.myTrade &lt;&gt; null then
		foreach portRotation in self.myTrade.allPortRotations do
			create pxyPortRotation transient;
			pxyPortRotation.setProxy(portRotation.myPort, pxyVoyage);
			pxyVoyage.allPorts.add(portRotation.myPort);	
		endforeach;
	endif;
	
	pxyVoyage.myShippingLine := self.myShippingLine;	//11 Jun 2020	NDL	TFS 49555
//	if _vessel.myOperator &lt;&gt; null then
//		pxyVoyage.myOperator := _vessel.myOperator;
//	endif;
	pxyVoyage.myOperator := self.myOperator;	//11 Jun 2020	NDL	TFS 49555
	
	pxyVoyage.setAllocatedEvents(self.allAllocatedEvents);
	
	tmpGlobalVoyage := app.myRoot.allVoyagesGlobal[_code];
	if tmpGlobalVoyage = null then
		create tmpGlobalVoyage transient;
		tmpGlobalVoyage.setProxy( _code, _vessel.name, null, null, null, null, null, 0, null, app.myRoot);
	endif;
	pxyVoyage.setMyVoyageGlobalArrival(tmpGlobalVoyage);
	
	if _vessel.hasHarbourDetails then
		pxyHMSVoyage := pxyVoyage.myHMSVoyageData;
		if pxyHMSVoyage = null then
			create pxyVoyage.myHMSVoyageData transient;
			pxyHMSVoyage := pxyVoyage.myHMSVoyageData;
		endif;
		_vessel.myHMSVesselData.setProxyVoyageHMSData( pxyHMSVoyage,false, _terminal );	
	endif;
	
	return pxyVoyage;

epilog

end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="pxySetBaseBarge" id="783b5f8d-7a7c-495d-88aa-c599cdd8e290">
        <updating/>
        <source>pxySetBaseBarge(	_operator : CM_Operator;
					_shipLine : CM_ShippingLine;
					_bank : CM_Bank;
					_extReference : String;
					_vessel : CM_Vessel
					)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2020	jlgndl1	Initial creation	TFS 49417

*/

vars

begin
	if not self.isTransient then
		return;
	endif;

	self.myShippingLine := _shipLine;
	self.myDischargeCompany := _bank;
	self.myOperator := _operator;
	self.externalRef := _extReference; 
	if _vessel &lt;&gt; null then
		self.yearOfBuild := _vessel.yearOfBuild;
		self.isBarge := _vessel.isBarge;
		self.myTrade := _vessel.myDefaultTrade;
		
		if self.myHMSVoyageData = null then
			create self.myHMSVoyageData transient;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_shipLine" type="CM_ShippingLine"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_extReference" type="String"/>
        <Parameter name="_vessel" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="removeCrane" id="1f478cf3-790e-4821-b053-03b7ebf54025">
        <updating/>
        <source>removeCrane(_crane: CM_Crane) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     Called from the machine erase method. Checks the machine can be deleted.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	voyageJobsheet : CM_VoyageJobSheet;

begin

	exclusiveLock(self);
	if self.archived = true then
		return;
	endif;
	if self.departedDT &lt;&gt; null then
		//Its worked, let it go, they wont be doing anything else on it.
		return;
	endif;
	voyageJobsheet := self.allJobSheets[_crane.id];
	if voyageJobsheet = null then
		return;
	endif;	
	voyageJobsheet.validateForDelete();
	
	voyageJobsheet.erase(NORMAL_ERASE);
end;</source>
        <Parameter name="_crane" type="CM_Crane"/>
    </JadeMethod>
    <JadeMethod name="removeFromGlobalAllVoyages" id="84e596ff-b753-4470-859e-f23cb2776b03">
        <source>removeFromGlobalAllVoyages() protected;

/*

Purpose:			Remove the receiver from the manual collections of all voyages on its
					parent Global Voyages


Return Value:		None


Date		Who		Reason
10 Apr 2008	cnwkpd1	PAR #16378 - Initial creation

*/

vars
	arrivalGlbVoy,
	departGlbVoy	: CM_VoyageGlobal;
	
begin
	arrivalGlbVoy := self.myVoyageGlobalArrival;
	if arrivalGlbVoy &lt;&gt; null and self.isTransient = arrivalGlbVoy.isTransient then
		arrivalGlbVoy.allVoyages.removeObject(self);
	endif;
	
	departGlbVoy := self.myVoyageGlobalDeparture;
	if departGlbVoy &lt;&gt; null and departGlbVoy &lt;&gt; arrivalGlbVoy and self.isTransient = departGlbVoy.isTransient then
		departGlbVoy.allVoyages.removeObject(self);
	endif;
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="removeFromGlobalVoyage" id="650c3912-25d8-4d99-ad02-c9d241b53eed">
        <updating/>
        <source>removeFromGlobalVoyage(_voyageGlobal : CM_VoyageGlobal) updating;
//-----------------------------------------------------------------------
//	Created:	23 August 2007 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars

begin

	if self.myVoyageGlobalArrival = _voyageGlobal then
		self.myVoyageGlobalArrival := null;
	endif;
	if self.myVoyageGlobalDeparture = _voyageGlobal then
		self.myVoyageGlobalDeparture := null;
	endif;

epilog

end;</source>
        <Parameter name="_voyageGlobal" type="CM_VoyageGlobal"/>
    </JadeMethod>
    <JadeMethod name="runImportTasksOnShip" id="49a7d878-9192-4f9b-8cef-fc32c9812372">
        <updating/>
        <source>runImportTasksOnShip(_passport: CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	15 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
vars
	iter			: Iterator;
	ti				: CM_TrackedItem;
	updtCounter		: Integer;
begin

	iter := self.allOnshipTIsByIdCargoType.createIterator();
	
	beginLoad;
	while iter.next(ti) do
		if ti.isImport or ti.isTranshipInbound then		// PAR #25021
			updtCounter := updtCounter + 1;
			//even if the empty will become a 'Storage MT' always treat as 'Import' (normal for receive from ship)
			ti.assignToDoTasks(true,_passport);
			
			//set stops - test for storage
			if ti.isAttributeTrue(TI_Attrib_IsEmpty) then
				//test import empties for "intended offsite" setting 
				//	cnwrs1 may 2007 PAR13378 Stops	
				if ti.isStopSetToBeProcessed(StopProcessEmptyImport)
				and _passport.myTerminal.getConfig(MTImportIfIntendedOffsite).Boolean then
					//will stay as import
					ti.setStopsForImport();			
				else
					//will become a storage
					//do nothing
				endif;
			else
				//always do for fulls
				ti.setStopsForImport();			
			endif;
			if updtCounter mod 20 = 0 then
				endLoad;
				beginLoad;
			endif;
		endif;

	endwhile;
	
	//set the last run time
	self.importTasksLastRunDT := app.serverTimestampAtTrxStart;
	self.setRemarks("Import tasks run onship " &amp; self.importTasksLastRunDT.shortCurrentLocaleFormat, true);
epilog
	endLoad;
	delete iter;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="searchForOnShipOrQTI" id="54d80b15-2c2a-443d-a11f-2dc96b04b3f7">
        <source>searchForOnShipOrQTI(_tiId : String; _tis : CM_TISet input; _includeCraneQ : Boolean) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 December 2010	cnwndl1	Initial creation	Par 26471

*/

vars

	retValue, foundTI : Boolean;
	craneQTis : CM_TISet;
	queues : CM_RTQueueArray;
	queue : CM_RadioTelemetryQueue;
	ti : CM_TrackedItem;
	crane : CM_Crane;
	wp : CM_WorkPoint;
begin

	retValue := self.searchForOnShipTI(_tiId, _tis);

	if not _includeCraneQ then
		// just look at the tis still on the ship
		return retValue;
		
	else
		// add to this list any we find that belong to this voyage
		// and have been landed in the crane queues belonging to this voyage.
		
		if self.myQueue &lt;&gt; null then	// Voyage Queue
		
			create queues transient;
			self.myQueue.getAllQueues(queues);
			
			foreach queue in queues do
				foundTI := false;
				foreach ti in queue.allTrackedItems do
					if ti.myPrimaryActualLocation = null then
						continue;
					endif;
					if not ti.myPrimaryActualLocation.isCraneLaneController then
						continue;
					endif;
					if ti.id.startsWith(_tiId) or ti.idReversed.startsWith(_tiId.reverse) then
						_tis.addNoDuplicates(ti, false);
						retValue := true;
					endif;
				endforeach;
				
				// PAR 35091 has been put to ground on wharf?
				if not foundTI then
					crane := queue.getCraneForQueue();
					if crane &lt;&gt; null then
						if crane.transferArea &lt;&gt; null then
							ti:= crane.transferArea.getTiById(_tiId);
							if ti &lt;&gt; null then
								_tis.addNoDuplicates(ti, false);
								retValue := true;
								foundTI := true;
							endif;
						endif;	
					endif;
				endif;
				if not foundTI then
					wp := queue.getWorkPointForQueue();
					if wp &lt;&gt; null then
						if wp.myWorkPointInterchangeArea &lt;&gt; null then
							ti:= wp.myWorkPointInterchangeArea.getTiById(_tiId);
							if ti &lt;&gt; null then
								_tis.addNoDuplicates(ti, false);
								retValue := true;
								foundTI := true;
							endif;
						endif;	
					endif;
				endif;
			endforeach;
			
		endif;
		
		return retValue;
		
	endif;

epilog

	delete queues;

end;</source>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_tis" type="CM_TISet" usage="input"/>
        <Parameter name="_includeCraneQ" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="searchForOnShipTI" id="b9fd2b51-08c3-4b8d-9229-d9c8cee1a35a">
        <source>searchForOnShipTI(_tiId : String; _tis : CM_TISet input) : Boolean;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
// ---------------------------------------------------------------------------

vars

begin
	//return self.lookupTrackedItem(_tiId, TI_CargoType_Null, true);
	_tis.clear();
	self.lookupAllTrackedItems(_tiId, TI_CargoType_Null, false, false, _tis, null);
	
	return not _tis.isEmpty();
end;</source>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_tis" type="CM_TISet" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="searchForOnShipTIType" id="cd23895f-266a-4aeb-a84f-489148ffc7ee">
        <source>searchForOnShipTIType(_tiId : String;
					  _cargoType : Integer;
					  _tis : CM_TISet input) : Boolean;

/*

Purpose:			Find Tracked Items on ship for the receiver matching the 
					passed in (partial) ID

Parameters:			ID, Cargo Type to search, and Collection to pass matches back

Return Value:		True if matces are found
					Also _tis updated with matches


Date		Who		Reason
04 Dec 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
*/

vars

begin
	_tis.clear();
	self.lookupAllTrackedItems(_tiId, _cargoType, false, false, _tis, null);
	
	return not _tis.isEmpty();
	
	
epilog

end;</source>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_tis" type="CM_TISet" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
