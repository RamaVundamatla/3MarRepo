    </ExplicitInverseRef>
    <ExplicitInverseRef name="myRoot" id="554912b0-f7a3-4455-970f-8ace02b42ee7">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Root"/>
        <access>readonly</access>
        <Inverse name="CM_Root::allWorkOrderSchedulesByDate"/>
    </ExplicitInverseRef>
