//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin

/*
	if self.tmTime.getTime &lt;&gt; null then
		self.doAddTime();
	endif;
	*/
	self.myParentForm.YRD_WorkOrderScheduleForm.doAddDatesNext(self);

	inheritMethod();

epilog

end;</source>
