    <JadeMethod name="trxRelReqEstDateRollover" id="8b881c3e-72ed-4fe9-b413-ec03bdc3ac94">
        <updating/>
        <source>trxRelReqEstDateRollover(_terminal : CM_Terminal; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 Dec 2010	cnwndl1	Initial creation	Par 26650
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks
11 Feb 2011	NDL	Par 26983 - Change of rules to be applied.
			"For every Release Request  which has a status of 'Active' or a status of 'Pending' check the
			'estimated required date', and if that date is 'any date earlier than today',
			then update the 'estimated required by date' to be the 'current date'."

*/

vars

	iter : Iterator;
	type : Integer;
	activeStatus : Integer;
	pendingStatus : Integer;
	types : IntegerArray;
	bulkReleases : CM_BulkReleaseByTypeStCodeDict;
	startBulkRelease : CM_BulkRelease;
	bulkRelease : CM_BulkRelease;
	now : TimeStamp;
	today : Date;


begin
	// Always initialize the activity first.
	self.initialiseActivityWithPassport(_passport, method);
	
	// Arm our base exception handlers.
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	create types transient;
	bulkReleases := _terminal.allBulkReleaseByTypeByStByCd;
	
	beginTransaction;
	
	if bulkReleases = null or bulkReleases.isEmpty then
		return;
	endif;
	
	types.add(BR_TYPE_ROAD);
	types.add(BR_TYPE_RAIL);
	types.add(BR_TYPE_PACKING);
	types.add(BR_TYPE_SHIP);
	
	pendingStatus := BR_PENDING;
	activeStatus := BR_ACTIVE;
	
	today := app.actualTimeServer().date();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	now.setDate( today );
	now.setTime( "23:59:59.999".Time );

	iter := bulkReleases.createIterator;

	foreach type in types do
	
		// check all the pending ones...
		startBulkRelease := bulkReleases.getAtKeyGeq( type, pendingStatus, null, null ).CM_BulkRelease;
		if startBulkRelease &lt;&gt; null then
			iter.reset();
			iter.startAtObject(startBulkRelease);
			while iter.next( bulkRelease ) do
				if bulkRelease.type &lt;&gt; type then
					break;
				endif;
				if bulkRelease.status &lt;&gt; pendingStatus then
					break;
				endif;
				//11 Feb 2011	NDL	Par 26983
				if bulkRelease.dateEstimatedRequired.Date &gt;= today then
					continue;
				endif;
				bulkRelease.setEstDate( now );
			endwhile;
		endif;
		
		// check all the active ones...
		startBulkRelease := bulkReleases.getAtKeyGeq( type, activeStatus, null, null ).CM_BulkRelease;
		if startBulkRelease &lt;&gt; null then
			iter.reset();
			iter.startAtObject(startBulkRelease);
			while iter.next( bulkRelease ) do
				if bulkRelease.type &lt;&gt; type then
					break;
				endif;
				if bulkRelease.status &lt;&gt; activeStatus then
					break;
				endif;
				//11 Feb 2011	NDL	Par 26983
				if bulkRelease.dateEstimatedRequired.Date &gt;= today then
					continue;
				endif;
				bulkRelease.setEstDate( now );
			endwhile;
		endif;
	
	endforeach;
	
epilog

	delete iter;
	delete types;
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxRemoveReserveSelections" id="d7aa0d01-af8c-4269-b3c9-9cc8b02b5a9a">
        <updating/>
        <source>trxRemoveReserveSelections(_bulkRelease : CM_BulkRelease input; _ti : CM_TrackedItem input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 September 2014	cnwndl1	Initial creation	Par 34717 / CCMS 2384

*/

vars

	reserveDetail : CM_ReserveDetail;
	reserveSelection : CM_ReserveSelection;
	
begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	beginTransaction;
	foreach reserveDetail in _bulkRelease.allReserveDetails do
		if not reserveDetail.isKindOf( CM_ReserveSelection ) then
			continue;
		endif;
		reserveSelection := reserveDetail.CM_ReserveSelection;
		app.myUtilityUA.utlRemoveReserveDetail( reserveSelection, _ti, _passport);
		if _passport.hasErrors then
			break;
		endif;
	endforeach;

epilog
	
	self.finaliseActivityWithPassportEW(_passport, true);
end;</source>
        <Parameter name="_bulkRelease" type="CM_BulkRelease" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
