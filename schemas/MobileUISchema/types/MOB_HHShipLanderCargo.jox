    <JadeMethod name="setupForm" id="d99cba58-03dc-4332-af8a-9f9f498d0651">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08/02/2010	cnwndl1	Initial creation	CCMS MES 1005
08/03/2010	cnwdap1	PAR #22656 hide Cargo Check table if no checks configured
10/03/2010	cnwdap1	PAR #22960 Position cargo check table below location text box
*/

vars


begin
	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;
	self.myTrackedItem := app.myMobileCargoFindAgent.myTrackedItemToProcess; // populated if returning from a search.
	if self.myTrackedItem = null then
		self.myTrackedItem := self.myMobileGenericAgent.myNextTiToAction;	// populated if returning from cargo checks
	endif;
	app.myMobileCargoFindAgent.clearHistory(true);
	
	inheritMethod();
	
	self.setupCmdButtons( 2, app.getErrorString(Complete), app.getErrorString(Back), null, null, null );
	
	setupControls();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tblCargoChecks_click" id="e2547b19-b466-46df-8451-d5de45dcbdce">
        <controlMethod name="CM_MobEntryTable::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCargoChecks_click(table: Table input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16/02/2010	cnwdap1	Initial creation
10/03/2010	cnwdap1	PAR #22960 set next ti to process on checker agent
*/
vars
	errMess	: String;

begin
	if self.myTrackedItem = null then
		errMess := app.getErrorString(No_Cargo_identified);
		self.msgBox( errMess, app.getErrorString(Warning), MsgBox_OK_Only, true );
		return;
	endif;
	self.myMobileGenericAgent.setMyNextTiToAction( self.myTrackedItem );
	self.doHandleTblCargoChecksClick(self.myHandHeldCheckerAgent, table.CM_MobEntryTable, false, null );
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="669437f9-71c3-47ec-9ddd-402652e099c4">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014426, locale);
	btnAutoPlan.translateCaption(Xlat_0014427, locale);
	lblCargoType.translateCaption(Xlat_0013970, locale);
	lblId.translateCaption(Xlat_0013971, locale);
	lblLocation.translateCaption(Xlat_0013972, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtId_gotFocus" id="581afe67-d984-4552-a0cd-cc8546df4c37">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtId_gotFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin
	if self.txtId.text = self.lblId.caption.toUpper then
		//self.txtId.text := null;
		self.txtId.selStart := 0;
		self.txtId.selLength := self.lblId.caption.length;
	endif;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtId_lostFocus" id="058f64ae-87ec-4c6d-8066-6752103cbb45">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtId_lostFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin

	app.convertScannedCargoId( self.myTerminal, textbox, false, null );	//06 Jul 2016	NDL	TFS 2275

	if self.txtId.text.trimBlanks = null then
		self.txtId.text := self.lblId.caption.toUpper;
	else
		self.selectCargoItem( false );
	endif;
	
	self.txtId.selStart := 0;
	self.txtId.selLength := 0;
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
