    <JadeMethod name="buildComboDayTypes" id="dc65e106-dc63-4f6e-bc5b-2032f38b5405">
        <source>buildComboDayTypes();
/*
Purpose:			
Date		Who		Reason
30 November 2012	cnwab1	Initial creation
*/

vars
	dt : CM_DayType;
begin
	self.cmbCalExclusion.clear;
	self.cmbCalExclusion.sorted := true;
	self.cmbCalNormal.clear;
	self.cmbCalNormal.sorted := true;
	
	foreach dt in app.myRoot.allDayTypes  discreteLock do
		self.cmbCalExclusion.addItemObject(dt.description, dt);
		self.cmbCalNormal.addItemObject(dt.description, dt);
	endforeach;
	
	self.cmbCalExclusion.sorted := false;
	self.cmbCalNormal.sorted := false;
	
	self.cmbCalNormal.addItemAt("",1);
	self.cmbCalExclusion.addItemAt("",1);
	
epilog

end;</source>
    </JadeMethod>
