    <JadeMethod name="initializeConnectionDetails" id="435f23a0-66e5-4cf1-9167-8e4b4f3c041b">
        <source>initializeConnectionDetails(): Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	iniFileName : String;
	comName : String;
	speedBps,
	dataBits,
	parity,
	stopBits,
	flowControl,
 	timeout: Integer;
	hasErrors : Boolean;
	terminalCode,
	deviceName : String;
begin
	
	iniFileName := app.getIniFileName();
	terminalCode		:= app.getProfileString(iniFileName, VehicleMountedIniSection, Key_VehicleMountedTerminal, null);
	deviceName				:= app.getProfileString(iniFileName, VehicleMountedIniSection, Key_VehicleMountedDevice, null);
	
	self.writeLog("Initialized for terminal - " &amp; terminalCode &amp; " and device " &amp; deviceName);
	
	return self.myTwistLockReaderAgent.initializeConnection(	terminalCode,deviceName);


epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="myHandHeldAgent" id="183c7831-6b7f-43e5-a04e-801b43822e19">
        <methodInvocation>mapping</methodInvocation>
        <source>myHandHeldAgent(set: Boolean; _value: HandHeldAgent io) mapping;
/*

Purpose:			


