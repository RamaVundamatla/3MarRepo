    <JadeMethod name="delete" id="897db492-3acd-4acf-aec9-1ce947ad72fa">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2014	cnwmc5	Initial creation

*/

vars

begin
	
	self.allTicketSequences.purge();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="6eddfe76-ea58-40c0-935d-cd929334ddc5">
        <updating/>
        <source>setProxyFromObject(_bolExt : CM_BOLExtension) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2014	cnwmc5	Initial creation

*/

vars
	bolExtLog 	: CM_BOLExtLogIn;
	ticket		: CM_TicketSequence;
	wsTicket	: WS_TicketSequence;
begin
	inheritMethod(_bolExt);
	
	if not _bolExt.isKindOf(CM_BOLExtLogIn) then
		return;
	endif;
	
	bolExtLog := _bolExt.CM_BOLExtLogIn;
	
	self.activity 				:= bolExtLog.activity;
	self.actualPieceCountError 	:= bolExtLog.actualPieceCountError;
	self.backload 				:= bolExtLog.backload;
	self.chhSupplier 			:= bolExtLog.chhSupplier;
	self.customer 				:= bolExtLog.customer;
	self.fellDate 				:= bolExtLog.fellDate.asStringForWebInterface;			//cnwmc5 - 26 Jan 2016 - PAR 37326
	self.gangNumber 			:= bolExtLog.gangNumber;
	self.isFSC 					:= bolExtLog.isFSC;
	self.jasScaled 				:= bolExtLog.jasScaled;
	self.jasVolume 				:= bolExtLog.jasVolume;
	self.lengthCode 			:= bolExtLog.lengthCode;
	self.loaderNumber 			:= bolExtLog.loaderNumber;
	self.logGradeCode 			:= bolExtLog.logGradeCode;
	self.logSpeciesCode 		:= bolExtLog.logSpeciesCode;
	self.logTreatmentCode 		:= bolExtLog.logTreatmentCode;
	self.logTypeCode 			:= bolExtLog.logTypeCode;
	self.nightshift 			:= bolExtLog.nightshift;
	self.numberTicketed 		:= bolExtLog.numberTicketed;
	self.percentScaled 			:= bolExtLog.percentScaled;
	self.pickupPoint 			:= bolExtLog.pickupPoint;
	self.scalerCode 			:= bolExtLog.scalerCode;
	self.weighbridge 			:= bolExtLog.weighbridge;
	
	foreach ticket in bolExtLog.allTicketSequences do
		create wsTicket transient;
		wsTicket.setProxyFromObject(ticket);
		self.allTicketSequences.add(wsTicket);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_bolExt" type="CM_BOLExtension"/>
    </JadeMethod>
</Class>
