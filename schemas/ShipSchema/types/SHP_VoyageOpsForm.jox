        <source>tblOffsite_dragDrop(table: Table input; win: Window input; x: Real; y: Real) updating;
/*--------------------------------------------------
  Created:	17 October 2003 By: cnwgd1
  --------------------------------------------------
  
Changed On	By		TFS		Reason
----------	-----	-----	---------------------------------------
03 Oct 2019	jlgdi1	45802	Added permission check
*/
begin
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then 
		app.raiseCMException(NoPermission2, null, null);	//07 Oct 2019	NDL	TFS 46169
		return;
	endif;
	self.tableDragDropEvent(table, win, x, y);
end;</source>
