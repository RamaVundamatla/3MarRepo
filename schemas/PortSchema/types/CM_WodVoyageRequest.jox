    <JadeMethod name="getExtraInfo" id="299738de-48cf-4beb-b0ff-af0d8ca466f8">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Jul 2018	jlgndl1	Initial creation	TFS 39813
15 Feb 2023 navma1  ChangeRequest 56561: FR 53944 | EUP - Simplified Voyage Work Order
*/

vars

	block : CM_DataContainerBlock;
	str   : String;
	tmpTS : TimeStamp;

begin

	inheritMethod(_dataContainer);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(VoyageCode), DC_Label, 1, null);
	block.addNewItem(self.voyageCode, DC_Data, 1, null);
	
	if self.voyageCodeIn &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Voyage_code_in), DC_Label, 1, null);
		block.addNewItem(self.voyageCodeIn, DC_Data, 1, self.getMyVoyageObject);			//15.02.2023 navma1 #56561
	endif;
	
	if self.voyageCodeOut &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Voyage_code_out), DC_Label, 1, null);
		block.addNewItem(self.voyageCodeOut, DC_Data, 1, self.getMyVoyageObject);			//15.02.2023 navma1 #56561
	endif;
	
	if self.vesselCode &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Vessel_GC), DC_Label, 1, null);
		block.addNewItem(self.vesselCode, DC_Data, 1, null);
	endif;
	
	str := self.portCode1;
	str := str.trimBlanks &amp; " " &amp; self.portCode2.trimBlanks;
	str := str.trimBlanks &amp; " " &amp; self.portCode4.trimBlanks;
	str := str.trimBlanks &amp; " " &amp; self.portCode5.trimBlanks;
	
	
	if str.trimBlanks &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Ports), DC_Label, 1, null);
		block.addNewItem(str.trimBlanks, DC_Data, 1, null);
	endif;
	
	if self.commodityCode &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Commodity), DC_Label, 1, null);
		block.addNewItem(self.commodityCode, DC_Data, 1, null);
	endif;
	
	if self.voyageOperatorCode &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Voyage_operator), DC_Label, 1, null);
		block.addNewItem(self.voyageOperatorCode, DC_Data, 1, null);
	endif;
	
	if self.cargoOperatorCodeDischarge &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Cargo_operator_discharge), DC_Label, 1, null);
		block.addNewItem(self.cargoOperatorCodeDischarge, DC_Data, 1, null);
	endif;
			
	if self.cargoOperatorCodeLoad &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Cargo_operator_load), DC_Label, 1, null);
		block.addNewItem(self.cargoOperatorCodeLoad, DC_Data, 1, null);
	endif;
	
	if self.estimatedArrivalTS.date.isValid then
		tmpTS := self.systemToLocalTime(self.estimatedArrivalTS); // PEL UAT WP testing 30SEP18
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Estimated_arrival), DC_Label, 1, null);
		block.addNewItem(tmpTS.asStringJMT, DC_Data, 1, null);
	endif;
	
	if self.estimatedDepartureTS.date.isValid then
		tmpTS := self.systemToLocalTime(self.estimatedDepartureTS); // PEL UAT WP testing 30SEP18
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Estimated_departure), DC_Label, 1, null);
		block.addNewItem(tmpTS.asStringJMT, DC_Data, 1, null);
	endif;
	
	if self.vesselCategoryCode &lt;&gt; null then// TFS 40029
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Vessel_category_code), DC_Label, 1, null);
		block.addNewItem(self.vesselCategoryCode, DC_Data, 1, null);// TFS 40029
	endif;
	
	if self.visitTypeCode &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Visit_type_code), DC_Label, 1, null);
		block.addNewItem(self.visitTypeCode, DC_Data, 1, null);
	endif;
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getMyBerth" id="a7da76bf-b15d-48ab-96f9-82c076640d41">
        <source>getMyBerth(): HMS_Berth;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 September 2021	jlizm1	Initial creation TFS 51963 SAL Voyage Request Changes

*/

vars

	voyage : CM_Voyage;
	
begin

	voyage := self.getMyVoyageObject();
	if voyage &lt;&gt; null then
		return voyage.getMyCurrentBerth;
	endif;
	
	return inheritMethod();
	
epilog

end;</source>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
