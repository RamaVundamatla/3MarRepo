<Class name="Method">
    <JadeMethod name="getMethodCreator" id="b7973507-5f54-47e7-87df-38eddb710390">
        <source>getMethodCreator() : String;

/*

Purpose:		Get the Methods Creator	

Date			Who		Reason
08/09/2015		cnwmh5	Initial creation

*/

vars

	tokens				: StringArray512;

	linePos				: Integer;
	line				: String;
	testOwner			: String;
	token				: String;
	pos					: Integer;

begin

	create tokens transient;
	
	linePos := 1;
	while linePos &gt; 0 do : weAreDone
		line :=  self.getSource.cnEcGetNextLine(linePos);
		if (line[1:9] = 'constants' and line.trimBlanks().length = 9) or 		
				(line[1:4] = "vars" and line.trimBlanks().length = 4) then
			break;
		endif;
		line.replaceChar(Tab, ' ');
		tokens.clear;
		line.getTokensForDelimiter(" ", tokens);
		foreach token in tokens do
			if token.toUpper().cnContains("CNW") then
				pos := 1;
				pos := token.toUpper().pos("CNW", pos);
				if pos = 0 then
					testOwner := token;
				else	
					testOwner := token[pos:end];
				endif;
				break weAreDone;
			endif;
		endforeach;
	endwhile;

	return testOwner;
	
epilog

	delete tokens;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
