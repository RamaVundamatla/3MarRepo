    <JadeMethod name="setFilterDefaults" id="b6ce9d4f-a62e-49dd-8d28-9d107d5e12da">
        <updating/>
        <source>setFilterDefaults() updating;
// ---------------------------------------------------------------------------
// Created:		04 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//09.May.2025 navsp1 JIRA-34514 MTN - Reefer Monitoring Screen Code Changes
//06 Jan 2026 navah1 MTN-35878: PEN | Please change the Is Connected and Requires Power filters from Check Boxes to a dropdown
vars
	tmpCombo : ComboBox;
begin

	self.origValueStr		:= null;

	self.filterCargoID 		:= null;
	self.filterISOType		:= null;
	self.filterCmdtyGroup	:= null;
	self.filterVoyage 		:= null;
	self.filterOperator 	:= null;
	self.filterTerminalArea	:= null;
	self.filterHasExternalMonitoring	:= null;		//cnwmc5 - 20 Oct 2015 - PAR 37057
    self.filterCommodity    := null;    //JIRA-34514
	//06.01.2026 navah1 #MTN-35878 Start
    //self.filterIsConnected  := false;   //JIRA-34514
    //self.filterRequiresPower:= false;   //JIRA-34514
	self.filterIsConnected  := null;
	self.filterRequiresPower := null;
	//06.01.2026 navah1 #MTN-35878 End
end;</source>
    </JadeMethod>
    <JadeMethod name="setFilterTblDef" id="9b5859f2-1e1f-43dc-82a0-d2dc9b655c34">
        <source>setFilterTblDef(): Boolean;
// ---------------------------------------------------------------------------
// Created:		03 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
vars
	entTableDef		: EntTableDef;
begin
	entTableDef := app.myController.getEntTableDef(ETDef_ContReefFind);
	if entTableDef &lt;&gt; null then
		self.tblSearch.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef (' &amp; ETDef_ContReefFind &amp; ') not found');
		return false;
	endif;
		
	return true;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFilterValues" id="97c60607-4c33-4afb-ac2a-6e794f6c43aa">
        <updating/>
        <source>setFilterValues() updating;
// ---------------------------------------------------------------------------
// Created:		04 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//09.May.2025 navsp1 JIRA-34514 MTN - Reefer Monitoring Screen Code Changes
//06 Jan 2026 navah1 MTN-35878: PEN | Please change the Is Connected and Requires Power filters from Check Boxes to a dropdown
vars
	obj	: Object;
	
begin

	self.filterOperator 	:= self.cmbFiltOperator.myObject.CM_Operator;
	self.filterTerminalArea := self.cmbFiltTermArea.listObject.CM_TerminalArea;
	self.filterVoyage		:= self.myAssistant.getVoyageFromCombo(cmbFiltVoyage.text);
	self.filterCargoID		:= self.tblSearch.getValueByName(ETRow_FilterId).String[1:20]; //cnwrd1 par 24107 10.5.2010 mutli cargo search extended but not here so clip
	self.filterCmdtyGroup	:= self.cmbFiltCmdtyGrp.listObject.CM_CommodityGroup;
	self.filterHasExternalMonitoring	:= self.cmbFiltExternal.listData;		//cnwmc5 - 20 Oct 2015 - PAR 37057
	self.filterCommodity    := self.cmbFiltCommodity.listObject.CM_Commodity;                       //JIRA-34514
	//06.01.2026 navah1 #MTN-35878 Start
    //self.filterIsConnected  := self.tblSearch.getValueByName(ETRow_FilterIsConnected).Boolean;      //JIRA-34514
    //self.filterRequiresPower:= self.tblSearch.getValueByName(ETRow_FilterRequiresPower).Boolean;    //JIRA-34514
	self.filterIsConnected	:= self.cmbFiltConnected.listData;
	self.filterRequiresPower:= self.cmbFiltPower.listData;
	//06.01.2026 navah1 #MTN-35878 End
	obj := cmbFiltISOType.listObject;
	if obj &lt;&gt; null then
		self.filterISOType := obj.CM_ISOType.code;
	else
		self.filterISOType := null;
	endif;
	
end;</source>
    </JadeMethod>
