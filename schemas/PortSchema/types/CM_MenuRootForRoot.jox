<Class name="CM_MenuRootForRoot" id="3fe2ee04-98b7-43fe-9608-7e0fe6c691d0">
    <superclass name="CM_MenuRoot"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Default Navigator menu provided by JADE Master</text>
    <DbClassMap file="cmenu"/>
    <ExplicitInverseRef name="allMenuDtlsByPermValue" id="e0459884-e2e6-4e84-b1d0-fe257ec96682">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_MenuDtlsByConstantValueDict"/>
        <access>readonly</access>
        <Inverse name="CM_MenuItem::myMenuRoot"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="allMenuItems" id="c8b54a7a-0d5a-496e-8bf2-97164086f116">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_MenuItemByTypeMenuIdDict"/>
        <access>readonly</access>
        <Inverse name="CM_MenuItem::myMenuRoot"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myRoot" id="1cc39724-d807-4b75-bd88-3bbdff823812">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_Root"/>
        <access>readonly</access>
        <Inverse name="CM_Root::myMenuRoot"/>
        <Inverse name="CM_Root::myMenuRootForSysEntities"/>
    </ExplicitInverseRef>
    <JadeMethod name="cloneFromSource" id="e54bdc3e-5223-40cf-a99a-2220144a178e">
        <updating/>
        <source>cloneFromSource(_parent : CM_MenuEntity; 
				_source : SelfType; 
				_terminal : CM_Terminal;
				_targetMenuRoot : CM_MenuRoot input;
				_user : CM_User;
				_clearFirst : Boolean;
				_deleteSet : CM_MenuEntitySet input) updating;
// ---------------------------------------------------------------------------
// Created:     13 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.myRoot := _source.myRoot;
	inheritMethod(_parent, _source, _terminal, _targetMenuRoot, _user, _clearFirst, _deleteSet);
	
end;</source>
        <Parameter name="_parent" type="CM_MenuEntity"/>
        <Parameter name="_source" type="SelfType"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_targetMenuRoot" type="CM_MenuRoot" usage="input"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_clearFirst" type="Boolean"/>
        <Parameter name="_deleteSet" type="CM_MenuEntitySet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getExpandedDefault" id="04682c87-fbff-48ab-8027-997e26d2e226">
        <source>getExpandedDefault(): Boolean;
// ---------------------------------------------------------------------------
// Created:     05 December 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	return true;


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getMenuHdrSystem" id="0aea20de-57c5-4ee3-91d9-242e4840c735">
        <source>getMenuHdrSystem(_id: String): CM_MenuHdrSystem;
// ---------------------------------------------------------------------------
// Created:     16 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return self.allMenuItems[MenuType_HeaderSystem, _id].CM_MenuHdrSystem;

end;</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_MenuHdrSystem"/>
    </JadeMethod>
    <JadeMethod name="getMenuItemsDict" id="b5004cad-19ee-4ad7-be43-05615f521dfd">
        <source>getMenuItemsDict(): CM_MenuItemByTypeMenuIdDict;
// ---------------------------------------------------------------------------
// Created:     16 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return self.allMenuItems;

end;</source>
        <ReturnType type="CM_MenuItemByTypeMenuIdDict"/>
    </JadeMethod>
    <JadeMethod name="isOnNavSystemMenu" id="cc7fda08-7600-4428-91d5-9e7b3f5ac81c">
        <source>isOnNavSystemMenu(): Boolean;
// ---------------------------------------------------------------------------
// Created:     13 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if self.myRoot = null then
		return false;
	endif;
	
	return (self.myRoot.myMenuRootForSysEntities = self);

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOnNavTerminalMenu" id="c613768b-16a5-4e74-a2f6-f84a5f4bb6ed">
        <source>isOnNavTerminalMenu(): Boolean;
// ---------------------------------------------------------------------------
// Created:     13 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if self.myRoot = null then
		return false;
	endif;
	
	return (self.myRoot.myMenuRoot = self);

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
