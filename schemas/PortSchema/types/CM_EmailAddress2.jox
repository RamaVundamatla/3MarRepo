    <JadeMethod name="setForUpdate" id="04c8c06a-fe74-447a-abd1-91a7e5421f31">
        <updating/>
        <source>setForUpdate(_proxyEmailAddress : CM_EmailAddress2 ) updating;
// -------------------------------------------
// Created 17 September 2003 by cnwdvb1
// -------------------------------------------
vars
	obj 			: CM_Object;
	user			: CM_User;
begin
	self.address := _proxyEmailAddress.address;
	self.businessPhone := _proxyEmailAddress.businessPhone;
	self.companyName := _proxyEmailAddress.companyName;
	self.emailAddress := _proxyEmailAddress.emailAddress;
	self.faxNumber := _proxyEmailAddress.faxNumber;
	self.homePhone := _proxyEmailAddress.homePhone;
	self.mobilePhone := _proxyEmailAddress.mobilePhone;
	self.autoReplyOption := _proxyEmailAddress.autoReplyOption;
	
	//Conversion only
	if app.isConverting then
		foreach obj in _proxyEmailAddress.allAssociatedEntities do
			if (not obj.isTransient) then
				if obj.isKindOf(CM_ShippingAgent) then
					self.allAssociatedEntities.add(obj.CM_ShippingAgent);
				elseif obj.isKindOf(CM_Stevedore) then
					self.allAssociatedEntities.add(obj.CM_Stevedore);
				elseif obj.isKindOf(CM_ShippingLine) then
					self.allAssociatedEntities.add(obj.CM_ShippingLine);
				else
				endif;
			endif;
		endforeach;
	endif;
	user := app.myPassport.myUser;
	if user &lt;&gt; null and (not user.allEmailsICanSee.includes(self)) then
		user.allEmailsICanSee.add(self);
	endif;
	
	if not self.isTransient then	//20 Jan 2014	NDL	Par 33264
		//15 Jan 2014	NDL	Par 33264
		foreach user in self.allUsers do
			self.updateObjectEdition(user);
		endforeach;
	endif;
	
	
	inheritMethod(_proxyEmailAddress);


end;</source>
        <Parameter name="_proxyEmailAddress" type="CM_EmailAddress2"/>
    </JadeMethod>
    <JadeMethod name="setProxyForEmailAddress" id="d6af230b-9b93-4fcc-898e-008f03315945">
        <updating/>
        <source>setProxyForEmailAddress(_name, _emailAddress : String; _autoReplyOption: Integer) updating;
// -------------------------------------------
// Created 17 September 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	self.raiseExceptionIfNotTransient(method);
	self.emailAddress	:= _emailAddress;
	self.setForProxy(_name, Email_Address);
	self.autoReplyOption := _autoReplyOption;


end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_emailAddress" type="String"/>
        <Parameter name="_autoReplyOption" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validate" id="231b5155-dd0f-49a3-baa4-7e51058959b7">
        <source>validate();
// -------------------------------------------
// Created 24 September 2003 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod();
	if (not app.isConverting) then
		if self.emailAddress = null then
			//PAR9841 not required
	 	//	app.raiseCMWarning1(REQUIRED_FIELD, 'email Address', null, null, self);
			app.raiseCMWarning(Input_required_field_emlAddres, null, null, self); // cnwdb2	PAR 35364
	 		return;
		endif;
	endif;
	
	// this is to stop more than 1 email address being entered
	if self.emailAddress.pos(';', 1) &lt;&gt; 0 then
		app.raiseCMException(SemiColonInvalid, null, null);
	endif;
	
	app.validateEmailAddress(self.emailAddress);


end;</source>
    </JadeMethod>
</Class>
