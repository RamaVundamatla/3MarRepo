    <JadeMethod name="cloneMySelf" id="fdee893f-fc91-4b21-b83e-4b2641168367">
        <source>cloneMySelf(_transient : Boolean) : SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	newMvmntPilotDetails : HMS_MovementPilotDetails;
begin
	newMvmntPilotDetails := self.cloneSelf(_transient);
	newMvmntPilotDetails.setMyPilot(self.myPilot);
	newMvmntPilotDetails.setMyPilotLaunch(self.myPilotLaunch);
	return newMvmntPilotDetails;
epilog

end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="4a3b6861-4112-4020-8b20-f3b15fdcc3be">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars

begin
	if _attrName = ETRow_MyPilot then
		if self.myPilot &lt;&gt; null then
			return self.myPilot.description;		
		endif;
		return null;
	elseif _attrName = ETRow_MyPilotLaunch then
		if self.myPilotLaunch &lt;&gt; null then
			return self.myPilotLaunch.description;
		endif;	
		return null;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="04f17cbe-ace5-48ad-9fd2-7c078f15f552">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	proxy : HMS_MovementPilotDetails;
	completedOK : Boolean;
begin
	proxy := inheritMethod();
	proxy.myPilot := self.myPilot;
	proxy.myPilotLaunch := self.myPilotLaunch;
	completedOK := true;
	return proxy;
epilog
	if not completedOK then
		delete proxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
