    <JadeMethod name="contentsName" id="8a56f5ff-4d2f-4868-9da1-260eebab0f51">
        <methodInvocation>mapping</methodInvocation>
        <source>contentsName(set: Boolean; _value: String io) mapping;

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;

	if contentsType = TI_CONTENTS_STATUS_NULL then
		_value := "Default CS";
	elseif contentsType = TI_CONTENTS_STATUS_EMPTY  then
		_value := "MT";
	elseif contentsType = TI_CONTENTS_STATUS_FCL then
		_value := "FCL";
	elseif contentsType = TI_CONTENTS_STATUS_LCL then
		_value := "LCL";
	else
		_value := "Unknown!";
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="copyFrom" id="05e9b3d3-3298-4f69-a72a-55d30b63206a">
        <updating/>
        <source>copyFrom(_map : CM_ContentsMap; _contentsType : Integer; _parent : CM_ImexServiceMap) updating;
// 32311 set up self from the parameter plus the new contents status, copy all of the parameter map children under self.
vars
	cm			: CM_CommodityMap;
	newChild	: CM_CommodityMap;
begin
	self.contentsType := _contentsType;
	if _parent = null then
		self.imexMap := _map.imexMap;
	else
		self.imexMap := _parent;
	endif;
	foreach cm in _map.commoditiesMap do
		create newChild persistent;
		newChild.copyFrom(cm, cm.commodityCode, self);
	endforeach;
end;
</source>
        <Parameter name="_map" type="CM_ContentsMap"/>
        <Parameter name="_contentsType" type="Integer"/>
        <Parameter name="_parent" type="CM_ImexServiceMap"/>
    </JadeMethod>
