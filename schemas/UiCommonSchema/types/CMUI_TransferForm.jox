    <JadeMethod name="doSave" id="64390566-12b9-4fda-9411-a9fc5fdb277f">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     27 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

	rtnValue : Boolean;

begin
	self.allTrackedItems.clear();
	// Get tracked items from appropriate reference.
	app.mousePointer := MousePointer_HourGlass;	
	
	if self.selection = ITEMID then
		if self.myTrackedItem &lt;&gt; null then
			self.allTrackedItems.add(self.myTrackedItem);
		endif;
	elseif self.selection = DOCKET then
		if self.myDocketLocationHelper &lt;&gt; null then
			self.myDocketLocationHelper.allTIs.copy(self.allTrackedItems);
		endif;
	elseif self.selection = LOCATION then
		if self.mySOHLocation &lt;&gt; null then
			self.mySOHLocation.allTrackedItems.copy(self.allTrackedItems);
		endif;
	endif;
	
	if self.allTrackedItems.size &gt; 0 then 
		rtnValue := saveTrackedItems();
		if rtnValue then
			zDoRefresh();
		endif;
	else
		app.msgBox('You must select item to action first.','Error',0);
	endif;
	
epilog
	
	app.mousePointer := MousePointer_Default;	
	return rtnValue;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAvailableToLocations" id="73fd9c01-3160-478d-885f-1ba531a8c1a1">
        <source>getAvailableToLocations(_taType : CM_TerminalAreaType) protected;
// ---------------------------------------------------------------------------
// Created:     16 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	operator		: CM_Operator;
	tmpLCSearch		: CMIF_SearchTypes;

begin

	self.allToLocations.clear;
	self.cmbToLocation.clear;
	self.tblActionData.setValueByName(ETRow_Location, null);
	operator := zGetOperator();
	
	create tmpLCSearch transient;
	tmpLCSearch.myOperator := operator;
	if _taType &lt;&gt; null then
		self.myTerminal.availableLocationsForType(tmpLCSearch, self.allToLocations, _taType.type);
	endif;
	
	self.cmbToLocation.clear();
	self.cmbToLocation.listCollection(self.allToLocations, false, 0);

epilog
	
	delete tmpLCSearch;

end;</source>
        <access>protected</access>
        <Parameter name="_taType" type="CM_TerminalAreaType"/>
    </JadeMethod>
