    <JadeMethod name="getWorkPoint" id="24968133-0ccd-47f5-8374-b0530b449e03">
        <source>getWorkPoint(_trans : CM_TITransaction):CM_WorkPoint;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 September 2018	cnwma1	ChangeRequest 41132: PEL1 - SAP Integration : Additional Changes

*/

vars
	wp : CM_WorkPoint;
begin
	
	if _trans = null then
		return null;
	endif;
	if _trans.getJob &lt;&gt; null then
		if _trans.getJob.myJobSheet &lt;&gt; null then
			if _trans.getJob.myJobSheet.myWorkPoint &lt;&gt; null then
				wp := _trans.getJob.myJobSheet.myWorkPoint;
			endif;
		endif;
	endif;

	return wp;

epilog

end;</source>
        <Parameter name="_trans" type="CM_TITransaction"/>
        <ReturnType type="CM_WorkPoint"/>
    </JadeMethod>
    <JadeMethod name="handleSAPResponse" id="5a42ec4f-26b3-4b6d-8538-49b29bb65256">
        <source>handleSAPResponse(	_response : CMIF_SAPWSResponse;
					_cashReceipt : CM_CashReceipt input;
					_invoice : CM_Invoice input;
					_invoiceLines : CM_InvoiceLineSet input;
					_activityHistory : CM_ActivityHistoryExtInterface input) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2019	jlger1	Initial creation

*/

vars
	item 			  : CMIF_SAPReturnItem;
	tmp 			  : String;
	reassons 		  : String;
	
begin
	//01 Jul 2019	NDL	TFS 45330
	if not app.myPassport.trxCompletedOK then
		app.createAlert( "SAP " &amp; getWSDLType &amp; " response handling failed " &amp; app.myPassport.getErrorsAndWarningsAsString, true);
	endif;
	//Update Activity History
	self.updateActivityHistory(_response,_cashReceipt,_invoice,_invoiceLines,_activityHistory);
	//Send Rejection Reason TFS #41462
	if _response &lt;&gt; null then
		if _response.status = "E" or _response.status = " "  or _response.status = null then
			foreach item in _response.allItems do
				tmp := item.type&amp; Tab&amp;item.message &amp;Cr;
				reassons := reassons &amp; tmp;
			endforeach;
			if _cashReceipt &lt;&gt; null then
				_cashReceipt.sendRejectionEmail(reassons);
			elseif _invoice &lt;&gt; null then
				_invoice.sendRejectionEmail(reassons);
			endif;
		endif;
	endif;
		
	return  _response &lt;&gt; null;	
epilog

end;</source>
        <Parameter name="_response" type="CMIF_SAPWSResponse"/>
        <Parameter name="_cashReceipt" type="CM_CashReceipt" usage="input"/>
        <Parameter name="_invoice" type="CM_Invoice" usage="input"/>
        <Parameter name="_invoiceLines" type="CM_InvoiceLineSet" usage="input"/>
        <Parameter name="_activityHistory" type="CM_ActivityHistoryExtInterface" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sapHelper" id="31821765-419f-43c8-8be6-fc835143b1d9">
        <source>sapHelper(_obj : CM_Object;_field : String) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 Jul 2018 jlgma1 ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
27 Sep 2018 cnwma1 ChangeRequest 41132: PEL1 - SAP Integration : Additional Changes
01 Oct 2018 cnwma1 Bug 41186: PEL1 - SAP Integration - Unit Test issues
22 Nov 2018 cnwma1 Bug 42151: PEL1 - Currency for all WSDLs - IDR
27 Nov 2018 cnwma1 ChangeRequest 42118: PEL1 - Generate tax number and invoice date
30 Oct 2018 cnwma1 Bug 41658: PEL1 - Domestic Rates for International Tariff - Estimation
21 Jan 2019 cnwma1 Bug 42690: PEL1 - Exchange Rate field in WSDLs for INT Invoices
22 Jan 2019 cnwma1 ChangeRequest 41980: PEL1 - SAP Equipment Details
23 Jan 2019	cnwma1 ChangeRequest 42942: PEL1 - Container Services - SAP Process
14 Feb 2019	cnwma1 Bug 43223: PEL1 - Container Services - WSDL 1.12 FacilityID/Name
28 Feb 2019 cnwma1 Bug 43557: PEL1 - SAP WSDL 1.7 not sent on Re-check Finance/ No Invoice restrictions
04 Mar 2019 cnwma1 ChangeRequest 43558: PEL1 - SAP - Profit center for a NULL voyage
23 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
*/

vars
	value  		      : String;
	voyage 		  	  : CM_Voyage;
	hmsVoyageData 	  : HMS_VoyageData;
	hmsVslType	  	  : HMS_VesselType;
	vessel            : CM_Vessel;
	berth,
	movementBerth	  : HMS_Berth;
	glCode		  	  : CM_GLCode;
	debtor        	  : CM_Debtor;
	invline		  	  : CM_InvoiceLine;
	invoice     	  : CM_Invoice;
	hmsPilotLaunch    : HMS_PilotLaunch;
	hmsVoyageMovement : HMS_VoyageMovement;
	hmsResourceUsed   : HMS_ResourceUsed;
	cashReceipt		  : CM_CashReceipt;
	craneOpr          : CM_User;
	workPoint         : CM_WorkPoint;
	crane             : CM_Machine;
	isPilotLaunchRes,
	isTugRes,
	isEquipmentRes	  : Boolean;
	transMovement     : HMS_VoyageMovement;
	pilotDescs		  : String;	//31 Oct 2018	NDL	TFS 41662
	pilotCodes		  : String;	//31 Oct 2018	NDL	TFS 41662
	equipmentRes      : HMS_Resource;
	ti                : CM_TrackedItem;
	termArea          : CM_TerminalArea;
begin
	if _obj.isKindOf(CM_InvoiceLine) then
		invline		 := _obj.CM_InvoiceLine;
		invoice 	 := invline.invoice;	
		debtor  	 := invoice.getDebtor;
	elseif _obj.isKindOf (CM_Invoice) then
		invoice 	 := _obj.CM_Invoice;
		debtor  	 := invoice.getDebtor;
	elseif _obj.isKindOf (CM_CashReceipt) then
		cashReceipt  := _obj.CM_CashReceipt;
		debtor       := cashReceipt.getDebtor;
	endif;
	
	/*Constants Start*/
	if _field = "currencyGL"         or 
		_field = "currencyAR"        or
		_field = "arItem.currencyAR" or 
		_field = "currency"          then		//22.11.2018 cnwma1 Bug #42151
			return "IDR";
	endif;
	
	if _field = "compCode" then
		return "1000";
	endif;
	
	if _field  = "shipItem.dataSource"      or 
	   _field  = "equipmentItem.dataSource" or 
	   _field  = "serviceItem.dataSource"   or 
	   _field  = "facilityItem.dataSource"  then
		return "MT";
	endif;
	/*Constants End*/
	
	/***********************Invoice Data Start **********************************/
	if invoice &lt;&gt; null then
		if invoice.myVoyage &lt;&gt; null then
			voyage := invoice.myVoyage;
			//04.03.2019 cnwma1 #43558
			berth := self.getVoyageBerth(voyage);
			if voyage.myHMSVoyageData &lt;&gt; null then
				hmsVoyageData := voyage.myHMSVoyageData;
				if hmsVoyageData.myVesselType &lt;&gt; null then
					hmsVslType := hmsVoyageData.myVesselType;
				endif;
				if hmsVoyageData.getMyVessel &lt;&gt; null then
					vessel :=  hmsVoyageData.getMyVessel;
				endif;
			endif;
		endif;
		
		/* Mapping*/
		if _field = "invoiceID"          		or 
		   _field=  "billingInfo.bINFO4" 		or 
		   _field=  "billingInfo.bINF04" 		then
			return  invoice.exportCurrencyCode;
		endif;
		
		if _field = "preInvoiceID" then
			if self.getRefDocNo(invoice, _field) &lt;&gt; Space then
				return self.getRefDocNo(invoice, _field);
			else
				return invoice.exportCurrencyCode;
			endif;
		endif;
		
		if _field = "docDate"		   or 
		   _field = "arItem.bLineDate" then
			if invoice.taxDT.isValid   then
				return invoice.taxDT.Date.format("yyyyMMdd").String;
			endif;
		endif;
		
		if _field = "refDocNo"         then
			return getRefDocNo(invoice,_field);
		endif;
		
		if _field  = "headerText" then
			return invoice.externalTaxNumber;
		endif;
		
		/*WSDL 1.7*/
		if _field  = "getTotalAmtDPP" 	  then                   //21.01.2019 cnwma1 Bug #42945
				return self.getTotalAmtDPP(invoice).String;         		    
		endif;
		/*WSDL 1.4 , WSDL 1.2*/
		if _field  = "getTotalAmtDocCurAR" then                 //21.01.2019 cnwma1 Bug #42945
			return self.getTotalAmtDocCurAR(invoice).String;
		endif;
		
		if _field  = "paymentCode"     or
		   _field  = "arItem.paymentRef"  then
			return invoice.paymentCode;
		endif;
		
		if _field = "billingInfo.bINFO6"  or
		   _field = "billingInfo.bINF06" then
			return invoice.invoiceType.description;
		endif;
		
		if _field  = "postingDate" then
			return app.actualTimeServer.Date.format("yyyyMMdd").String;
		endif;
		
		if _field = "arItem.exRateAR" or  //21.12.2018 cnwma1 Bug #42690
		   _field = "glItem.exRateGL"  then
				return "0";
		endif;
	endif;	
	/***********************Invoice Data End **********************************/
	
	/***********************Cash Receipt Start*********************************/
	if cashReceipt &lt;&gt; null then
		voyage := cashReceipt.myVoyage;
		if voyage &lt;&gt; null then	//20 May 2019	NDL	TFS 44651 - 1090
			if voyage.getMyBerth &lt;&gt; null then
				berth := voyage.getMyBerth;
			endif;
			if voyage.myHMSVoyageData &lt;&gt; null then
				hmsVoyageData := voyage.myHMSVoyageData;
				if hmsVoyageData.myVesselType &lt;&gt; null then
					hmsVslType := hmsVoyageData.myVesselType;
				endif;
			endif;
		endif;
		
		if _field = "estimationID"  then
			return cashReceipt.externalInvoiceNumber;
		endif;
		
		/*WSDL 1.1 , WSDL 1.6*/
		if _field = "amount"  then  //30.10.2018 cnwma1 #41658
			return cashReceipt.getAmountForCurrencyCode("USD",cashReceipt.createdTime).truncatedTo(0).String;   //30.11.2018 cnwma1 Bug #42218
		endif;		
	
		if  _field = "docDate" then
			return  cashReceipt.effectiveDate.Date.format("yyyyMMdd").String;
		endif;
		if voyage &lt;&gt; null and berth &lt;&gt; null  then
			if	_field  = "profitCenter" then
				return berth.externalReference1;
			endif;
		endif;
	endif;
	/***********************Cash Receipt Start*********************************/

	/***********************Voyage Data Start**********************************/
	if voyage &lt;&gt; null then
		if _field = "basePort" then							
			if voyage.getFirstPortInRotation &lt;&gt; null then
				value := voyage.getFirstPortInRotation.code;
			endif;
			if voyage.getPreviousPortInRotation &lt;&gt; null then
				if value &lt;&gt; null then
					value := value &amp;',' &amp; voyage.getPreviousPortInRotation.code;
				endif;
			endif;
			return value;
		endif;
		
		if _field = "destinationPort" then     			
			if voyage.getNextPortInRotation &lt;&gt; null then
				value := voyage.getNextPortInRotation.code;
			endif;
			if voyage.getLastPortInRotation &lt;&gt; null then
				if value &lt;&gt; null then
					value := value &amp;',' &amp; voyage.getLastPortInRotation.code;
				endif;
			endif;
			return value;
		endif;
		
		if _field = "callSign" then
			return voyage.callSign;
		endif;
		
		if _field = "shipCode" then
			if vessel &lt;&gt; null then 
				return vessel.code;   
			else
				if voyage.myVessel &lt;&gt; null then
					return voyage.myVessel.code;  
				endif;
			endif;
		endif;
		
		if _field = "shipItem.lineType" then
			//jlier1 TFS 51963 15/10/21
			if voyage.myDischargeCompany &lt;&gt; null and voyage.myDischargeCompany.code.toUpper.cnContains("DOM") then
				return "Domestic";
			else
				return "International";
			endif;
		endif;
		
		if _field = "billingInfo.bINFO5" or _field = "billingInfo.bINF05" then
			if voyage.myVessel &lt;&gt; null then
				return voyage.myVessel.name;
			endif;
		endif;
	
		//08.10.2018
		if berth &lt;&gt; null then
			if  _field  = "profitCtr"               or 
				_field  = "profitCenter"            then
				value := berth.externalReference1;
				return value;
			endif;
		endif;
	endif;
	/***********************Voyage Data End**********************************/
	
	/***********************HMS Voyage Data Start****************************/
	if hmsVoyageData &lt;&gt; null then
		if _field = "shipName" then
			return hmsVoyageData.vesselName;
		endif;
		
		if _field = "countryID" then
			return hmsVoyageData.countryCode;
		endif;
		
		if _field = "shipGT" then
			return hmsVoyageData.dim_GrossRegTonnes.String;
		endif;
		if _field = "shipLOA" then
			return hmsVoyageData.dim_LengthOverall.truncatedTo(0).String;
		endif;
		
		if _field = "comm" then
			return hmsVoyageData.getCommodityDischargeString;
		endif;
		
		if hmsVslType &lt;&gt; null then
			if _field = "shipType" then
				return hmsVslType.code;
			endif;
		endif;
	endif;
	/***********************HMS Voyage Data End****************************/
	
	/***********************Debtor Info Start******************************/
	if debtor &lt;&gt; null then
		if _field = "glItem.itemText" then
			return debtor.name;
		endif;
		if _field = "billingInfo.bINFO1" or _field = "billingInfo.bINF01" then
			return debtor.name;
		endif;
		if _field = "billingInfo.bINFO2" or _field = "billingInfo.bINF02" then
			return debtor.additionalInformation1;
		endif;	
		if _field = "arItem.customerNo"  or _field = "customerNo" then
			return debtor.code;
		endif;
		if _field = "arItem.paymentTerms" then
			if debtor.myTermsOfTrade &lt;&gt; null then
				return 'Z' &amp; debtor.myTermsOfTrade.code; 
			endif;
		endif;
	endif;
	/***********************Debtor Info End*******************************/
	
	/***********************Invoice Line Start****************************/
	if invline &lt;&gt; null then
			
		if _field = "facilityItem.uOM"   or
		   _field = "serviceItem.uOM"    or 
		   _field = "equipmentItem.uOM"  then  					 //01.10.2018 cnwma1 BuG #41186
			if invline.invoiceLineDesc.unitNarration &lt;&gt; null then
				return invline.invoiceLineDesc.unitNarration;
			else
				return Space;
			endif;
		endif;
		
		if _field =  "arItem.itemText" then
			return invline.invoice.getInvoiceTypeDescription();   //27.09.2018 cnwma1 TFS #41132
		endif;
		
		if _field = "facilityItem.qTYRealization"  or
		   _field = "serviceItem.qTYProduction"    or 
		   _field = "equipmentItem.qTYRealization"	then  
			return invline.quantity.String;
		endif;
				
		if invline.getGLCode &lt;&gt; null then
			glCode := invline.getGLCode;
			if glCode &lt;&gt; null then
				if _field = "gLAccount" then
					return glCode.code[1:glCode.code.findNextNonIntegerPos(0)-1];
				endif;
			endif;
		endif;
		
		/*Tracked Item &gt;&gt; SubFrom InvoiceLine Start*/
		if invline.getTrackedItem &lt;&gt; null then
			if _field = "serviceItem.comodityName" then
				return self.getCommodityName(invline.getTrackedItem);
			endif;	
			if _field = "serviceItem.itemCode" then
				if invline.getTrackedItem.getCommodityObject &lt;&gt; null then
					return invline.getTrackedItem.getCommodityObject.shortDescription;
				else
					return Space;  //28.02.2019 cnwma1 #43557
				endif;
			endif;		
		else
			if _field = "serviceItem.comodityName" or
			   _field = "serviceItem.itemCode"     then
				return Space;
			endif;		
		endif;
		/*Tracked Item &gt;&gt; SubFrom InvoiceLine End*/
		
		/*InvLine Transaction Start */
		/*InvLine Transaction Start &gt;&gt;HMS Transaction */
		if invline.myTransactionHMS &lt;&gt; null then
			if invline.myTransactionHMS.myResourceUsed &lt;&gt; null then
				hmsResourceUsed := invline.myTransactionHMS.myResourceUsed;
			endif;
			hmsVoyageMovement := self.getVoyageMovement(invline.myTransactionHMS);
			
			if hmsVoyageMovement &lt;&gt; null then
				pilotDescs := hmsVoyageMovement.getPilotsString(true);	//31 Oct 2018	NDL	TFS 41662
				pilotCodes := hmsVoyageMovement.getPilotsString(false);	//31 Oct 2018	NDL	TFS 41662
				hmsPilotLaunch := self.getPilotLaunch(hmsVoyageMovement);
				movementBerth  := hmsVoyageMovement.getMyBerth();
			endif;
			
			if movementBerth &lt;&gt; null then
				if _field = "facilityItem.facilityName"  then
					value :=  movementBerth.description;
					return value;
				endif;
				
				if  _field = "copaItem.character" then // WW011
					value := movementBerth.externalReference3;
					return value;
				endif;
				
				if  _field = "facilityItem.facilityID" then 
					value := movementBerth.externalReference4;
					return value;
				endif;
			endif;
				
			if hmsResourceUsed &lt;&gt; null then
				if hmsResourceUsed.myResource.isResourceForClass(HMS_ResourceForPilot) then
					isPilotLaunchRes :=true;
				elseif hmsResourceUsed.myResource.isResourceForClass(HMS_ResourceForTug) then
					isTugRes := true;
				endif;
				//22.01.2019 cnwma1 TFS #41980
				if hmsResourceUsed.myVTMISTransaction.hasResourceTypeForEquipment then
					isEquipmentRes := true;
					equipmentRes   := hmsResourceUsed.myResource;
				endif;
			
				//22.01.2019 cnwma1	TFS #41980
			endif;
			
			//22.01.2019 cnwma1	TFS #41980
			if isEquipmentRes then
				if equipmentRes &lt;&gt; null then
				   if _field = "equipmentItem.deviceID" then	
						return equipmentRes.externalReference1;
					endif;
					if _field = "equipmentItem.deviceName" then	
						return  equipmentRes.description;
					endif;
				else
					if _field = "equipmentItem.deviceID" or 
					   _field = "equipmentItem.deviceName" then	
						return Space;
					endif;
				endif;
			endif;
			//22.01.2019 cnwma1	TFS #41980
			
			
			//27.09.2018 cnwma1 TFS #41132
			if isPilotLaunchRes then
				if hmsPilotLaunch &lt;&gt; null then
				   if _field = "equipmentItem.deviceID" then	
						return hmsVoyageMovement.getPilotLaunchString(false); //hmsPilotLaunch.code; // TFS 44438
					endif;
					if _field = "equipmentItem.deviceName" then	
						return hmsVoyageMovement.getPilotLaunchString(true); //hmsPilotLaunch.description; // TFS 44438
					endif;
				else
					if _field = "equipmentItem.deviceID" or 
					   _field = "equipmentItem.deviceName" then	
						return Space;
					endif;
				endif;
				//31 Oct 2018	NDL	TFS 41662
				if _field = "equipmentItem.employeeID" then	
					if pilotCodes &lt;&gt; null then
						return pilotCodes;
					else
						return Space;
					endif;
				endif;
				//31 Oct 2018	NDL	TFS 41662
				if _field = "equipmentItem.name" then
					if pilotDescs &lt;&gt; null then
						return pilotDescs;
					else
						return Space;
					endif;
				endif;
			endif;
			
			if isTugRes then
			    if _field = "equipmentItem.deviceID" then	
					return hmsVoyageMovement.getTugsString(false,",");
				endif;
				if _field = "equipmentItem.deviceName" then	
					return hmsVoyageMovement.getTugsString(true,",");
				endif;
				if _field = "equipmentItem.employeeID" then	
					return "0";
				endif;
				if _field = "equipmentItem.name" then	
					return Space;
				endif;
			endif;

			if hmsResourceUsed &lt;&gt; null then
				if hmsResourceUsed.fromDateTime.isValid then
					if _field = "equipmentItem.startDate" then
						return hmsResourceUsed.fromDateTime.Date.format("yyyyMMdd").String;
					endif;
					if _field = "equipmentItem.startTime" then
						return hmsResourceUsed.fromDateTime.Time.formatAsHHMMSS();
					endif;
				endif;
				if hmsResourceUsed.toDateTime.isValid then
					if _field = "equipmentItem.endDate" then
						return hmsResourceUsed.toDateTime.Date.format("yyyyMMdd").String;
					endif;
					if _field = "equipmentItem.endTime" then
						value := hmsResourceUsed.toDateTime.Time.formatAsHHMMSS();
						return value;
					endif;
				endif;
			endif;
		/*InvLine Transaction Start &gt;&gt;HMS Transaction */
		
		/*InvLine Transaction Start &gt;&gt;TI Transaction */
		elseif invline.myTransactionTI &lt;&gt; null then
			craneOpr := invline.myTransactionTI.getOperatingUser;
			workPoint := self.getWorkPoint(invline.myTransactionTI);
			transMovement :=self.getMovementForDateTime(voyage,invline.myTransactionTI.dateTime);
			if transMovement &lt;&gt; null then
				movementBerth := transMovement.getMyBerth;
				
				//08.10.2018
				if movementBerth &lt;&gt; null then
					if  _field  = "profitCtr"               or 
						_field  = "profitCenter"            or 
						_field  = "equipmentItem.prodCode"  then
							
						value := movementBerth.externalReference1;
						return value;
					endif;
			
					if _field = "facilityItem.facilityName"  then
						value :=  movementBerth.description;
						return value;
					endif;
					
					if  _field = "copaItem.character" then // WW011
						value := movementBerth.externalReference3;
						return value;
					endif;
					
					if  _field = "facilityItem.facilityID" then 
						value := movementBerth.externalReference4;
						return value;
					endif;
				endif;
			
			else 
				//04.03.2019 cnwma1 TFS #43558
				if voyage.isNullVoyage then                               
					if berth &lt;&gt; null then
						if  _field  = "profitCtr"               or 
							_field  = "profitCenter"            or 
							_field  = "equipmentItem.prodCode"  then
								
							value := berth.externalReference1;
							return value;
						endif;
				
						if _field = "facilityItem.facilityName"  then
							value :=  berth.description;
							return value;
						endif;
						
						if  _field = "copaItem.character" then // WW011
							value := berth.externalReference3;
							return value;
						endif;
						
						if  _field = "facilityItem.facilityID" then 
							value := berth.externalReference4;
							return value;
						endif;
					endif;
				endif;
			endif;
			if invline.myTransactionTI.isKindOf(CM_ReceiveShip) then
				crane := invline.myTransactionTI.CM_ReceiveShip.getCrane();
			elseif invline.myTransactionTI.isKindOf(CM_ReleaseShip) then
				crane := invline.myTransactionTI.CM_ReleaseShip.getCrane();
			elseif invline.myTransactionTI.isKindOf(CM_Storage) then
				/*Pending */
			endif;
			
			if craneOpr &lt;&gt; null then
				if _field = "equipmentItem.employeeID" then	
					return craneOpr.code;
				endif;
				if _field = "equipmentItem.name" then	
					return craneOpr.userName;
				endif;
			else
				if _field = "equipmentItem.employeeID" or 
				   _field = "equipmentItem.name"       then	
					return Space;
				endif;
			endif;
			
			if crane &lt;&gt; null then
				if _field = "equipmentItem.deviceID" then	
					return crane.externalRef;
				endif;
				if _field = "equipmentItem.deviceName" then	
					return crane.description;
				endif;
			elseif workPoint &lt;&gt; null then
				if _field = "equipmentItem.deviceID" then	
					return workPoint.externalRef;
				endif;
				if _field = "equipmentItem.deviceName" then	
					return workPoint.description;
				endif;
			else
				if _field = "equipmentItem.deviceID"  or 
				   _field = "equipmentItem.deviceName" then
					return Space;
				endif;
			endif;
			
			if _field = "equipmentItem.startDate" then
				return invline.myTransactionTI.dateTime.Date.format("yyyyMMdd").String;
			endif;
			if _field = "equipmentItem.startTime" then 
				return invline.myTransactionTI.dateTime.Time.formatAsHHMMSS(); 
			endif;
			if _field = "equipmentItem.endDate" or 
			   _field = "equipmentItem.endTime" then
				return Space;
			endif;
		/*InvLine Transaction End &gt;&gt;TI Transaction */
		
		elseif invline.myTransactionEvent &lt;&gt; null then
			/*Pending*/
		elseif invline.myTransactionVTMIS &lt;&gt; null then
			/*Pending*/
		elseif invline.myTransactionWO  &lt;&gt; null then
			/* Pening*/
		/*InvLine Transaction Start &gt;&gt;Null Transaction */
		else
			/*InvLine Transaction Start &gt;&gt;Null Transaction &gt;&gt;Manual*/
			if invline.manual  then
				if _field = "equipmentItem.employeeID" then
					return "0";
				endif;
				
				if _field = "equipmentItem.startDate" then
					return invline.createdTime.Date.format("yyyyMMdd").String;
				endif;
				
				if _field = "equipmentItem.startTime" then
					return invline.createdTime.Time.formatAsHHMMSS();
				endif;
				
				if _field = "equipmentItem.name"      or 
				   _field = "equipmentItem.deviceID"  or
				   _field = "equipmentItem.deviceName"or
				   _field = "equipmentItem.endDate"   or
				   _field = "equipmentItem.endTime"   then
					return Space;
				endif;
				
				
				/*
				31.01.2019 cnwma1
				Map PrePay
				*/
				if invoice.paymentType = PaymentType_PrePay then
					
					termArea := self.getTerminalAreaForWorkOrderTI(invline);
					if termArea &lt;&gt; null then
						if  _field = "facilityItem.facilityID" then 
							value := termArea.comment;
							return value;
						endif;
						
						if _field = "facilityItem.facilityName"  then
							value :=  termArea.id;
							return value;
						endif;
					else
						if  _field = "facilityItem.facilityID" or 
							_field = "facilityItem.facilityName" then 
							return Space;
						endif;
					endif;
					
					if berth &lt;&gt; null then
						if  _field  = "profitCtr"               or 
							_field  = "profitCenter"            or 
							_field =  "equipmentItem.prodCode"  then
								
							value := berth.externalReference1;
							return value;
						endif;
					else	
						return Space;
					endif;
				endif;
				
			endif;
		endif;
		
		if movementBerth &lt;&gt; null then
			if  _field  = "profitCtr"               or 
				_field  = "profitCenter"            or 
				_field =  "equipmentItem.prodCode"  then
					
				value := movementBerth.externalReference1;
				return value;
			endif;
			if _field = "facilityItem.facilityName" or
			   _field = "facilityItem.facilityID"   then
				return Space;
			endif;
			
			if  _field = "copaItem.character" then // WW011
				value := movementBerth.externalReference3;
				return value;
			endif;
		else
			/*No Berth*/
			if berth &lt;&gt; null then
				if  _field  = "profitCtr"                or 
					_field  = "profitCenter"             or 
					_field =  "equipmentItem.prodCode"   or 
					_field = "facilityItem.facilityName" or
					_field =  "facilityItem.facilityID" then
					return Space;
				endif;
				if  _field = "copaItem.character" then // WW011
					 value := berth.externalReference3;
					return value;
				endif;
			endif;	
		endif;
	endif;
	/***********************Invoice Line End****************************/
	return value;
epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_field" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="sapHelperCashReceipt" id="ddc4191a-5d47-4e59-8500-7f0c49a3c663">
        <source>sapHelperCashReceipt(_cashReceipt : CM_CashReceipt ; _field : String):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 March 2019	jlgma1	Initial creation

*/

vars
	voyage 		  : CM_Voyage;
	berth  	      : HMS_Berth;
	hmsVoyageData : HMS_VoyageData;
	hmsVslType    : HMS_VesselType;
	cashReceipt   : CM_CashReceipt;
begin
	voyage := _cashReceipt.myVoyage;
	
	if voyage.getMyBerth &lt;&gt; null then
		berth := voyage.getMyBerth;
	endif;
		
	if voyage.myHMSVoyageData &lt;&gt; null then
		hmsVoyageData := voyage.myHMSVoyageData;
		
		if hmsVoyageData.myVesselType &lt;&gt; null then
			hmsVslType := hmsVoyageData.myVesselType;
		endif;
	endif;
	
	
	if _field = "estimationID"  then
		return _cashReceipt.externalInvoiceNumber;
	endif;
	
	/*WSDL 1.1 , WSDL 1.6*/
	if _field = "amount"  then  //30.10.2018 cnwma1 #41658
		cashReceipt := _cashReceipt;
		return cashReceipt.getAmountForCurrencyCode("USD",cashReceipt.createdTime).truncatedTo(0).String;   //30.11.2018 cnwma1 Bug #42218
	endif;		

	if  _field = "docDate" then
		return  _cashReceipt.effectiveDate.Date.format("yyyyMMdd").String;
	endif;
	if voyage &lt;&gt; null and berth &lt;&gt; null  then
		if	_field  = "profitCenter" then
			return berth.externalReference1;
		endif;
	endif;
		
epilog

end;</source>
        <Parameter name="_cashReceipt" type="CM_CashReceipt"/>
        <Parameter name="_field" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="sapHelperConstant" id="9bfbabba-bc84-4906-8e0b-78d2978c20aa">
        <source>sapHelperConstant(_field : String): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 March 2019	jlgma1	Initial creation

*/

vars

begin
	if _field  = "currencyGL"        or 
		_field = "currencyAR"        or
		_field = "arItem.currencyAR" or 
		_field = "currency"          then		//22.11.2018 cnwma1 Bug #42151
			return "IDR";
	endif;
	
	if _field = "compCode" then
		return "1000";
	endif;
	
	if _field  = "shipItem.dataSource"      or 
	   _field  = "equipmentItem.dataSource" or 
	   _field  = "serviceItem.dataSource"   or 
	   _field  = "facilityItem.dataSource"  then
		return "MT";
	endif;
epilog

end;</source>
        <Parameter name="_field" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="sapHelperDebtor" id="379ea5cf-0842-4ff5-9a10-47b6cb73b544">
        <source>sapHelperDebtor(_debtor : CM_Debtor;_field : String):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 March 2019	jlgma1	Initial creation

*/

vars

begin
	if _field = "glItem.itemText" then
		return _debtor.name;
	endif;
	
	if _field = "billingInfo.bINFO1" or _field = "billingInfo.bINF01" then
		return _debtor.name;
	endif;
	
	if _field = "billingInfo.bINFO2" or _field = "billingInfo.bINF02" then
		return _debtor.additionalInformation1;
	endif;	
	
	if _field = "arItem.customerNo"  or _field = "customerNo" then
		return _debtor.code;
	endif;
	
	if _field = "arItem.paymentTerms" then
		if _debtor.myTermsOfTrade &lt;&gt; null then
			return 'Z' &amp; _debtor.myTermsOfTrade.code; 
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_field" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="sapHelperInvoice" id="2fa3ff0a-268c-4eb3-89be-2ad674b3d7c8">
        <source>sapHelperInvoice(_invoice : CM_Invoice ; _field : String):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2019	jlgma1	Initial creation

*/

vars

begin
	
	if _invoice = null then
		return Space;
	endif;

	if _field = "invoiceID"          		or 
	   _field=  "billingInfo.bINFO4" 		or 
	   _field=  "billingInfo.bINF04" 		then
		return  _invoice.exportCurrencyCode;
	endif;
	
	if _field = "preInvoiceID" then
		if self.getRefDocNo(_invoice, _field) &lt;&gt; Space then
			return self.getRefDocNo(_invoice, _field);
		else
			return _invoice.exportCurrencyCode;
		endif;
	endif;
	
	if _field = "docDate"		   or 
	   _field = "arItem.bLineDate" then
		if _invoice.taxDT.isValid   then
			return _invoice.taxDT.Date.format("yyyyMMdd").String;
		endif;
	endif;
	
	if _field = "refDocNo"         then
		return getRefDocNo(_invoice, _field);
	endif;
	
	if _field  = "headerText" then
		return _invoice.externalTaxNumber;
	endif;
	
	/*WSDL 1.7*/
	if _field  = "getTotalAmtDPP" 	  then                   //21.01.2019 cnwma1 Bug #42945
		return self.getTotalAmtDPP(_invoice).String;         		    
	endif;
	/*WSDL 1.4 , WSDL 1.2*/
	if _field  = "getTotalAmtDocCurAR" then                 //21.01.2019 cnwma1 Bug #42945
		return self.getTotalAmtDocCurAR(_invoice).String;
	endif;
	
	if _field  = "paymentCode"     or
	   _field  = "arItem.paymentRef"  then
		return _invoice.paymentCode;
	endif;
	
	if _field = "billingInfo.bINFO6"  or
	   _field = "billingInfo.bINF06" then
		return _invoice.invoiceType.description;
	endif;
	
	if _field  = "postingDate" then
		return app.actualTimeServer.Date.format("yyyyMMdd").String;
	endif;
	
	if _field = "arItem.exRateAR" or  //21.12.2018 cnwma1 Bug #42690
	   _field = "glItem.exRateGL"  then
			return "0";
	endif;
	return Space;
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_field" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="sapHelperVoyage" id="6dac17b5-a7e7-47d8-b53e-0d8971012afc">
        <source>sapHelperVoyage(_voyage : CM_Voyage ; _field : String):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 March 2019	jlgma1	Initial creation

*/

vars
	value         : String;
	berth 		  : HMS_Berth;
	hmsVoyageData : HMS_VoyageData;
	hmsVslType	  : HMS_VesselType;
	vessel        : CM_Vessel;
begin
	
	berth := self.getVoyageBerth(_voyage);
	
	if _voyage.myHMSVoyageData &lt;&gt; null then
		hmsVoyageData := _voyage.myHMSVoyageData;
	
		if hmsVoyageData.myVesselType &lt;&gt; null then
			hmsVslType := hmsVoyageData.myVesselType;
		endif;
		
		if hmsVoyageData.getMyVessel &lt;&gt; null then
			vessel :=  hmsVoyageData.getMyVessel;
		endif;
	endif;
	
	
	if _field = "basePort" then							
		if _voyage.getFirstPortInRotation &lt;&gt; null then
			value := _voyage.getFirstPortInRotation.code;
		endif;
		
		if _voyage.getPreviousPortInRotation &lt;&gt; null then
			if value &lt;&gt; null then
				value := value &amp;',' &amp; _voyage.getPreviousPortInRotation.code;
			endif;
		endif;
		return value;
	endif;
	
	if _field = "destinationPort" then     			
		if _voyage.getNextPortInRotation &lt;&gt; null then
			value := _voyage.getNextPortInRotation.code;
		endif;
		if _voyage.getLastPortInRotation &lt;&gt; null then
			if value &lt;&gt; null then
				value := value &amp;',' &amp; _voyage.getLastPortInRotation.code;
			endif;
		endif;
		return value;
	endif;
	
	if _field = "callSign" then
		return _voyage.callSign;
	endif;
	
	if _field = "shipCode" then
		if vessel &lt;&gt; null then 
			return vessel.code;   
		else
			if _voyage.myVessel &lt;&gt; null then
				return _voyage.myVessel.code;  
			endif;
		endif;
	endif;
	
	if _field = "shipItem.lineType" then
		//jlier1 TFS 51963 15/10/21
		if _voyage.myDischargeCompany &lt;&gt; null and _voyage.myDischargeCompany.code.toUpper.cnContains("DOM") then
			return "Domestic";
		else
			return "International";
		endif;
	endif;
	
	if _field = "billingInfo.bINFO5" or _field = "billingInfo.bINF05" then
		if _voyage.myVessel &lt;&gt; null then
			return _voyage.myVessel.name;
		endif;
	endif;

	//08.10.2018
	if berth &lt;&gt; null then
		if  _field  = "profitCtr"               or 
			_field  = "profitCenter"            then
			value := berth.externalReference1;
			return value;
		endif;
	endif;
	
	if hmsVoyageData &lt;&gt; null then
		if _field = "shipName" then
			return hmsVoyageData.vesselName;
		endif;
		
		if _field = "countryID" then
			return hmsVoyageData.countryCode;
		endif;
		
		if _field = "shipGT" then
			return hmsVoyageData.dim_GrossRegTonnes.String;
		endif;
		if _field = "shipLOA" then
			return hmsVoyageData.dim_LengthOverall.truncatedTo(0).String;
		endif;
		
		if _field = "comm" then
			return hmsVoyageData.getCommodityDischargeString;
		endif;
		
		if hmsVslType &lt;&gt; null then
			if _field = "shipType" then
				return hmsVslType.code;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_field" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="updPaymentAndWorkOrderStatus" id="c0bc77db-b19f-4893-a217-057127129def">
        <source>updPaymentAndWorkOrderStatus(	_cashReceipt : CM_CashReceipt input; 
								_workOrder : CM_WorkOrder input;
								_wsdlType : String;
								_cashRecNewStatus : Integer; // Cash Receipt payment status
								_woNewStatus : Integer;
								_doApprove : Boolean;
								_responseStatus : String
								);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 September 2019	jlgndl1	Initial creation	TFS 46758
7/3/25 navsaa30 14818 MTN | Silent Deadlock Retry Technical Debt

*/

vars

	msg : String;
	wasLockError : Boolean;
	lockCount : Integer;

begin

	app.myPassport.setupForDeadlockReplay(-100, 2000);

	while true do

		app.myTrxUA.trxSapWSDL11_14_16Update( 	_cashReceipt,
												_workOrder,
												_wsdlType,
												_cashRecNewStatus,
												_woNewStatus,
												_doApprove,
												_responseStatus,
												app.myPassport
												);
		
		wasLockError := ( app.myPassport.allErrors.includesErrorCode( 1027 ) and app.myPassport.allErrors.size = 1 );
		if wasLockError then
			lockCount := lockCount + 1;
		endif;
		
		if app.myPassport.hadDeadlock = false  and not wasLockError then
			if app.myPassport.silentDeadlockRetryCount &gt; 0 or lockCount &gt; 0 then
				msg := method.qualifiedName &amp; " got past lock while processing " &amp; _wsdlType &amp; " response.";
				app.writeLog(msg ,LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
			endif;
			break;
		endif;
		
		if app.myPassport.hadDeadlock then
			msg := method.qualifiedName &amp; " deadlock (" &amp; app.myPassport.silentDeadlockRetryCount.String &amp; ") encountered while processing " &amp; _wsdlType &amp; " response.";
			app.writeLog(msg ,LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
			
			if app.myPassport.silentDeadlockRetryCount &gt; app.myPassport.silentDeadlockLimit then
				break;
			endif;
		elseif wasLockError then
			msg := method.qualifiedName &amp; " lock (" &amp; lockCount.String &amp; ") encountered while processing " &amp; _wsdlType &amp; " response.";
			app.writeLog(msg ,LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
			
			if lockCount &gt; app.myPassport.silentDeadlockLimit then
				break;
			endif;
		endif;

		app.myPassport.hadDeadlock := false;
		wasLockError := false;
		
		process.sleep (app.myPassport.silentDeadlockSleepTime);

	endwhile;

epilog
	app.myPassport.resetSilentDeadlockHandler;	//7/3/25 navsaa30 #14818
end;</source>
        <Parameter name="_cashReceipt" type="CM_CashReceipt" usage="input"/>
        <Parameter name="_workOrder" type="CM_WorkOrder" usage="input"/>
        <Parameter name="_wsdlType" type="String"/>
        <Parameter name="_cashRecNewStatus" type="Integer"/>
        <Parameter name="_woNewStatus" type="Integer"/>
        <Parameter name="_doApprove" type="Boolean"/>
        <Parameter name="_responseStatus" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateActivityHistory" id="f7606c1b-4077-476f-afc3-ddf70515805d">
        <source>updateActivityHistory(	_response : CMIF_SAPWSResponse;
						_cashReceipt : CM_CashReceipt input;
						_invoice : CM_Invoice input;
						_invoiceLines : CM_InvoiceLineSet input;
						_activityHistory : CM_ActivityHistoryExtInterface input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 September 2019	jlger1	Initial creation

*/

vars

desc,
	respStatus: String;
	pxyActivityHistory : CM_ActivityHistoryExtInterface;
	success : Boolean;	//21 Nov 2018	NDL	 TFS 42116
	activityExtraDetails  : String;
	msg		: String;
	responseUpdateErrors : String;
begin
	responseUpdateErrors := app.myPassport.getErrorsAndWarningsAsString;

	if _activityHistory &lt;&gt; null then
		beginLoad;
			pxyActivityHistory :=_activityHistory.pxyCreateUpdateProxy().CM_ActivityHistoryExtInterface;
		endLoad;
		success := false;	//21 Nov 2018	NDL	 TFS 42116
		respStatus := "Error";
		if _response &lt;&gt; null and _response.status = "X" then
			respStatus := "Success";
			success:=true;
		endif;
		pxyActivityHistory.setErrors(responseUpdateErrors);
		//21 Nov 2018	NDL	 TFS 42116
		pxyActivityHistory.setSuccess( success );
		if success then
			pxyActivityHistory.setReferenceID( _response.getReferenceId() );
		endif;
		
		//12.11.2018 cnwma1 TFS #41945
		if _invoice &lt;&gt; null then
			pxyActivityHistory.setMyInvoice(_invoice);
		elseif _cashReceipt &lt;&gt; null then
			pxyActivityHistory.setMyCashReceipt(_cashReceipt);
		endif;	
		
		activityExtraDetails:=self.getActivityHistoryExtraDetails(pxyActivityHistory);
		
		desc  := _activityHistory.interfaceName  &amp; " " &amp; self.getWSDLType &amp; " ["&amp;respStatus &amp;'] ' &amp;  activityExtraDetails;
		pxyActivityHistory.setDescription(desc);
		
		
		app.myTrxUA.trxUpdateActivityHistory(pxyActivityHistory, app.myPassport);
		if app.myPassport.hasErrors then
			msg := method.qualifiedName &amp; 
			'  ' &amp; "**SAP**Update Activity History"    &amp;
			'  ' &amp; activityExtraDetails &amp;
			'  ' &amp; "ERRORS : "  &amp; app.myPassport.getErrorsAndWarningsAsString;
			app.writeLog(msg,LogINFO);
			app.createAlert(app.myPassport.getErrorsAndWarningsAsString, true);
		endif;
	endif;
	
epilog
	delete pxyActivityHistory;

end;</source>
        <Parameter name="_response" type="CMIF_SAPWSResponse"/>
        <Parameter name="_cashReceipt" type="CM_CashReceipt" usage="input"/>
        <Parameter name="_invoice" type="CM_Invoice" usage="input"/>
        <Parameter name="_invoiceLines" type="CM_InvoiceLineSet" usage="input"/>
        <Parameter name="_activityHistory" type="CM_ActivityHistoryExtInterface" usage="input"/>
    </JadeMethod>
</Class>
