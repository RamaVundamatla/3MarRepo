    <JadeMethod name="uDamageInstance" id="26fe06ba-523a-4277-a813-399fa88fb5dd">
        <updating/>
        <source>uDamageInstance() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2022	navds20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/
vars
	di : CM_DamageInstance;	
	cargoType				: CM_CargoType;
	bs						: CM_BlockStack;
	pxyTi,ti : CM_TrackedItem;
begin
	bs := self.addBlockStack("BSLTR1", 99, null);
	self.assertNotNull(bs);
	
	ti := self.getTrackedItem("UT_MAT001").CM_TrackedItem;
	self.deleteTrackedItem(ti, true);
	
	//create the cargo
	cargoType := self.getCargoType("CANNON");
	self.deleteCargo("UT_MAT001", cargoType);
	
	//Create Tracked item
	ti := self.createTrackedItem("UT_MAT001", cargoType.id, null, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), false, bs.myLocationsController);
	
	//Create Damage Instance
	di := self.createDamageInstance(ti);
	self.assertNotNull(di);
	self.assertEqual(di.damageSize, 25.Decimal);
	
	//Update Damage Instance
	self.updateDamageInstance(di);
	self.assertNotNull(di);
	self.assertEqual(di.damageSize, 35.Decimal);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uInstructionEntry" id="fbf1d5b8-d4f4-46eb-bdf1-42ba4e1de4ea">
        <updating/>
        <source>uInstructionEntry() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions

*/

constants
	Code : String = "2345678";
	Description : String = "TestInstructionEntry";
	NotAvblForENtry : Boolean = true;
vars
	iType,iTypenew,iTypeUpdate : CM_InstructionType;
begin
		//Creation
	iTypenew := self.createInstructionType(Code, Description, false, NotAvblForENtry);
	self.assertNotNull(iTypenew);
	self.assertEqual(iTypenew.code, Code);
	
	//Updation
	self.updateInstructionType(iTypenew,Description);
	self.assertNotNull(iTypenew);
	self.assertEqual(iTypenew.description, Description);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uRepairReason" id="2f1227f7-5cda-40ec-bce4-2494ac3dad4d">
        <updating/>
        <source>uRepairReason() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2022	navds20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

constants
	CodeRR : String = "12344";
	DescriptionDRR : String = "Damage Updated one"; 
	DescriptionRR : String = "Damage one";
	IsNotAvailableForEntryRR : Boolean = false;
vars
	drr,drrnew,drrUpdate : CM_RepairReason;
begin
	//Creation
	drrnew := self.createRepairReason(CodeRR,DescriptionRR,IsNotAvailableForEntryRR);
	self.assertNotNull(drrnew);
	self.assertEqual(drrnew.code, CodeRR);
	
	//Updation
	self.updateRepairReason(drrnew,DescriptionRR);
	self.assertNotNull(drrnew);
	self.assertEqual(drrnew.description, DescriptionRR);
end;</source>
    </JadeMethod>
