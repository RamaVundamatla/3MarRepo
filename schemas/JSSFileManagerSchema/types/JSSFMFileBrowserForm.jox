    <JadeMethod name="activate" id="dfe05ac9-9ceb-4de1-b44c-2bbce32b7b9f">
        <controlMethod name="Form::activate"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>activate() updating;
// --------------------------------------------------------------------------------
// Created:		30 July 2002 by cnwdad1
//
// Purpose:		Passes this event on to the Form Interface class for processing.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aMyFormInterface &lt;&gt; null then
		self.aMyFormInterface.sendMsg(method.name);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="clearMonitorForm" id="812e6aa3-6e76-4b93-8334-764fbe73d66a">
        <updating/>
        <source>clearMonitorForm() updating;
// --------------------------------------------------------------------------------
// Created:		20 September 2002 by cnwdad1
//
// Purpose:		Clears the reference to the Background Copy Monitor form, so that
//				we don't try to unload a non-existant form when this form unloads.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMyMonitorForm	:=	null;
end;</source>
    </JadeMethod>
