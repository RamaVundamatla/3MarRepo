// ---------------------------------------------------------------------------
// Created:     28 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	txn	: CM_Transaction;
	
begin
	if set then
		// set code here
		app.raiseSetVirtualError(class.name, method.name);
	else
		// get code here
		txn := self.getMyTransaction();
		if CM_TITransaction.hasInstance(txn) then
			_value := txn.CM_TITransaction.myTrackedItem;
		endif;
	endif;


end;</source>
        <Parameter name="set" type="Boolean"/>
