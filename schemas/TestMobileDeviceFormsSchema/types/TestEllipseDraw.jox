    <JadeMethod name="paint" id="161df5a4-8945-4c1c-93ed-9adb3f241e68">
        <controlMethod name="Form::paint"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>paint() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 August 2011	cnwkpd1	Test JADE PAR #56912

*/

vars

begin
	drawFillStyle := DrawFillStyle_Transparent;
	drawFillColor := Black;
	drawWidth := 1;
	drawRectangle(99, 99, 110, 110, Black);

	drawFillStyle := DrawFillStyle_Transparent;
	drawFillColor := Black;
	drawWidth := 1;
	drawRectangle(78, 78, 131, 131, Black);

	drawFillStyle := DrawFillStyle_Solid;
	drawFillColor := Green;
	drawWidth := 1;
	drawEllipse(100, 100, 110, 110, Green);

	// Pie
	drawFillStyle := DrawFillStyle_Transparent;
	drawFillColor := Black;
	drawWidth := 1;
	drawRectangle(199, 99, 210, 110, Black);

	drawFillStyle := DrawFillStyle_Transparent;
	drawFillColor := Black;
	drawWidth := 1;
	drawRectangle(178, 78, 231, 131, Black);

	drawFillStyle := DrawFillStyle_Solid;
	drawFillColor := Green;
	drawWidth := 1;
	drawPie(200, 100, 210, 110, null, null, null, null, Green);

	// Big ellipse
	drawFillStyle := DrawFillStyle_Solid;
	drawFillColor := Green;
	drawWidth := 1;
	drawEllipse(100, 200, 140, 240, Green);

	// Big pie
	drawFillStyle := DrawFillStyle_Solid;
	drawFillColor := Green;
	drawWidth := 1;
	drawPie(200, 200, 240, 240, null, null, null, null, Green);

epilog

end;</source>
