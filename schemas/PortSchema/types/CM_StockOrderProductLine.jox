    <JadeMethod name="getExtraInfoLogVoyOps" id="7e282198-b06f-4d34-ba3c-35f4499b9bd1">
        <source>getExtraInfoLogVoyOps(_array: HugeStringArray input; _terminalForTerminology : CM_Terminal);
//--------------------------------------------------------------
//Created: 07 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	_array.add("Required Quantity" &amp; Tab &amp; self.reqdQuantity.String);
	self.myProduct.getExtraInfoOLD(_array);		
	inheritMethod(_array,_terminalForTerminology);
end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
        <Parameter name="_terminalForTerminology" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getLineAllocationObject" id="bdb46517-fe97-40d4-a53f-e61dddb2ed55">
        <source>getLineAllocationObject(_sohLocn : CM_SOHLocation) : CM_StockOrderLineAlloc;
//--------------------------------------------------------------
//Created: 05 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	allocation : CM_StockOrderLineAlloc;
begin
	foreach allocation in self.allStockAllocations do
		if allocation.mySOHLocation = _sohLocn then
			return allocation;
		endif;
	endforeach;
	return null;
end;</source>
        <Parameter name="_sohLocn" type="CM_SOHLocation"/>
        <ReturnType type="CM_StockOrderLineAlloc"/>
    </JadeMethod>
