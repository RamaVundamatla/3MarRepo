    <JadeMethod name="getDefaultValueString" id="264fc02c-6968-4c4d-9beb-c01997383ac8">
        <source>getDefaultValueString(_attrName: String): String;
// ---------------------------------------------------------------------------
// Created:     17 October 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.validationType = ValidationType_Codes then
		if self.myCode &lt;&gt; null then
			return self.myCode.code;
		else
			return Any_String;
		endif;
	elseif self.validationType = ValidationType_Value then
		return self.value;
	endif;



end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="672adc21-3a72-407f-a7b2-032c5b54b7b2">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     09 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	if _attrName = ETRow_ColumnCode then
		if self.validationType = ValidationType_Codes then
			if self.myCode &lt;&gt; null 
			and self.allCodes &lt;&gt; null and self.allCodes.includes(self.myCode)	//Code can be deleted in CMUI_CodeMaintForm. CCMS1080 PAR19704. July 2009
			then
				return self.myCode.code;
			else
				return Any_String;
			endif;
		else
			return null;
		endif;	
		
	elseif _attrName = ETRow_Multiplier then
		return null;
	
	elseif _attrName = ETRow_Range then
		return null.String;
	
	elseif _attrName = ETRow_Value then
		if self.value &lt;&gt; null then
			return self.value;
		else
			return null.String;
		endif;
	endif;
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayValueString" id="8308f07f-e5e8-4a33-8e67-8711e78e49ef">
        <source>getDisplayValueString(): String;
// ---------------------------------------------------------------------------
// Created:     24 October 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.validationType = ValidationType_Codes then
		if self.myCode &lt;&gt; null 
		and self.allCodes &lt;&gt; null and self.allCodes.includes(self.myCode)	//Code can be deleted in CMUI_CodeMaintForm. CCMS1080 PAR19704. July 2009
		then
			return self.myCode.code &amp; ' - ' &amp; self.myCode.description;
		else
			return Any_String;
		endif;	
	else
		return self.value;
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
