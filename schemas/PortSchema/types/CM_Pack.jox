    <JadeMethod name="saveVersionCopyRefs" id="75f7b8eb-903e-4bf2-b250-93bacbae8a7b">
        <source>saveVersionCopyRefs(toClone: CM_Pack input) protected;
/*
 ------------------------------------------------------------------------
Created:			13 September 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	inheritMethod(toClone);
	toClone.otherTrackedItem := self.otherTrackedItem;

