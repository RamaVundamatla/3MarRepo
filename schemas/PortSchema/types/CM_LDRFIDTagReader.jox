<Class name="CM_LDRFIDTagReader" id="e00fac3a-d833-497f-a73a-5ae364e0d3f1">
    <superclass name="CM_LaneDevice"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="location"/>
    <ExplicitInverseRef name="myRFIDTagReader" id="d2b85127-b418-4f50-802e-bb22870bcf29">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_RFIDTagReader"/>
        <access>readonly</access>
        <Inverse name="CM_RFIDTagReader::allLaneDevices"/>
