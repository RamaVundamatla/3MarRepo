*/
	
constants
	JMTDecimalSeperator = ".";
vars
	pos		: Integer;
	sTemp : String;
	decimalSeperator,
	localeFormat: String;
begin
	return self.truncatedTo(0).asStringJMT();	
	//return self.Integer.asStringJMT;
