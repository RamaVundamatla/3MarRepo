    <JadeMethod name="doAddPolygonToFrame" id="19db52e0-7681-454c-b943-b3e8e05fc54a">
        <updating/>
        <source>doAddPolygonToFrame(_theFrame : CMUI_PointDrawingFrame input;_thePoints : PointArray;_theColour : Integer;_floodFill : Boolean;_anObject : Object) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	aPoint, thePoint :Point;
	pntX1,pntY1, maxX, maxY : Integer;
	thePoints : PointArray;
	theScaleFactor : Real;
	isTerminal : Boolean;
	aGL : CM_LayoutGraphic;
begin
	// Terminal Area points are 15 times bigger than required. This is so that the location controller polygon can be more accurate
	isTerminal := CM_Terminal.hasInstance(_anObject);
	
	if isTerminal then
		theScaleFactor := self.xmlScaleFactor;
	else
		theScaleFactor := (TWIPsPerPixel / self.xmlScaleFactor);
	endif;
	
	create thePoints transient;
	
	foreach aPoint in _thePoints do
		if isTerminal then
			pntX1 := (((aPoint.x) * theScaleFactor )).Integer;
			pntY1 := (((aPoint.y) * theScaleFactor)).Integer;
		else
			pntX1 := (((aPoint.x) / theScaleFactor )).Integer;
			pntY1 := (((aPoint.y) / theScaleFactor)).Integer;
		endif;
		
		maxX := maxX.max(pntX1);
		maxY := maxY.max(pntY1);
		
		thePoint.set(pntX1,pntY1);
		thePoints.add(thePoint);
	endforeach;
	create aGL transient;
	aGL.setProxy(null,null,null,_theColour,null,null,null,thePoints,null,null); //cnwrd1 par 28802 6.12.2011
	_theFrame.doPointArrayAdd(_theColour,_floodFill, Frame.DrawFillStyle_Transparent, 1, _theColour, aGL);
	
	// only the terminal areas
	if not CM_Terminal.hasInstance(_anObject) then
		if _anObject.CM_TerminalArea.myLayoutGraphic.pointsPolygon.isEmpty = false then
			self.allAreaObjects.add(_anObject);
		endif;
	endif;
	
	self.frameHeight := self.frameHeight.max(maxY);
	self.frameWidth := self.frameWidth.max(maxX);
epilog
	//delete aGL; //cnwrd1 par 28802 6.12.2011 deleted later as its used later!!
end;</source>
        <Parameter name="_theFrame" type="CMUI_PointDrawingFrame" usage="input"/>
        <Parameter name="_thePoints" type="PointArray"/>
        <Parameter name="_theColour" type="Integer"/>
        <Parameter name="_floodFill" type="Boolean"/>
        <Parameter name="_anObject" type="Object"/>
    </JadeMethod>
