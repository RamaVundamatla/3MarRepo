    <JadeMethod name="tblMessages_displayRow" id="c0a29128-3078-4c19-b4bb-c0ab58d50fbb">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMessages_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;

/*

Purpose:			

Parameters:			None

Return Value:		None


Date		Who		Reason
07 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	despatchNow	: String;
	message		: CMIF_ITSInterfaceMsg;
	type		: String;
	
begin
	if obj.isKindOf(CM_ITSInterfaceResponse) then
		type := "  Send";
		if obj.CM_ITSInterfaceResponse.despatchNow then
			despatchNow := "  Now";
		endif;
	elseif obj.isKindOf(CM_ITSInterfaceRequestMessage) then
		type := "  Receive";
	else
		type := "  Internal";
	endif;

	create message transient;
	message.setMessage(obj.CM_ITSInterfaceMessage, false);
	
	return	message.myMessage.createdTS.asStringJMT() &amp; type &amp; Tab &amp;
			message.messageType &amp; Tab &amp;
			message.machineId &amp; Tab &amp;
			message.queueEntryId.asStringJMT() &amp; despatchNow &amp; Tab &amp;
			message.containerId &amp; Tab &amp;
			message.messageNumber.asStringJMT() &amp; Tab &amp;
			message.originalMsgNo.asStringJMT() &amp; Tab &amp;
			message.errorText;
	
epilog
	delete message;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
