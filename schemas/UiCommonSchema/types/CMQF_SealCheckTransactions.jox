<Class name="CMQF_SealCheckTransactions">
    <JadeMethod name="setFromAgent" id="5de30e17-b71e-4614-98db-fc6cbade1f71">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 September 2010	cnwndl1	Initial creation	Par 25608

*/

vars

	imexColl : CM_IMEXStatusByCodeDict;
	imex : CM_IMEXStatus;

begin
	inheritMethod(_agent);
	
	self.unMatchedOnly := _agent.getValueByNameIfVisible(ETRow_UnMatchedOnly).Boolean;
	
	create imexColl transient;
	_agent.CMUI_ReportAgentStd.getSelectedIMEXStatuses( imexColl );
	if not imexColl.isEmpty then
		foreach imex in imexColl do
			self.allQryImexStatus.add( imex.code );
		endforeach;
	endif;

	if _agent.CMUI_ReportAgentStd.myCmbReceiptMode.listIndex &gt; 0 then
		self.receiptTransportMode := _agent.CMUI_ReportAgentStd.myCmbReceiptMode.itemData[_agent.CMUI_ReportAgentStd.myCmbReceiptMode.listIndex];
	else
		self.receiptTransportMode := 0;
	endif;

	if _agent.CMUI_ReportAgentStd.myCmbSealType.listIndex &gt; 0 then
		self.sealType := _agent.CMUI_ReportAgentStd.myCmbSealType.text;
		if self.sealType = app.getErrorString(AnyString) then
			self.sealType := null;
		endif;
	else
		self.sealType := null;
	endif;

epilog

	delete imexColl;
	
end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
