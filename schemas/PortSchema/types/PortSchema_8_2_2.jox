    <JadeMethod name="convertCountryData" id="0a4e8917-1985-4ed4-9d98-44895ce6bba5">
        <source>convertCountryData();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 August 2013	cnwndl1	Initial creation	Par 32033

*/

vars

	country : CM_Country;
	pxyCountry : CM_Country;
	cmif : CMIF_Country;
	codeISO3 : String;
	unNum : String;

begin

	app.writeLog( method.qualifiedName &amp; 'Populating new fields on Country Codes 8.2.2', LogINFO);
	
	create cmif transient;
	
	foreach country in CM_Country.instances do
		
		codeISO3 := country.getIsoCountryCodeForConversion;
		unNum := country.getUnNumForConverison;
				
		pxyCountry := app.createUpdateProxy(country).CM_Country;
		pxyCountry.setProxy(country.code, country.description, codeISO3, unNum, country.isNotAvailableForEntry, null);
		cmif.myProxyCountry := pxyCountry;
		cmif.allRealPorts.clear();
		country.ports.copy(cmif.allRealPorts);
		
		app.myTrxUA.trxUpdateCountry(cmif, app.myPassport);
		
		delete pxyCountry;
					
	endforeach;

	app.writeLog( method.qualifiedName &amp; ' Finished Populating new fields on Country Codes in 8.2.2', LogINFO);

epilog

	delete pxyCountry;
	delete cmif;

end;</source>
    </JadeMethod>
    <JadeMethod name="convertGCvesselVoyageStructs" id="66743594-0b07-4e29-94af-0add547bab52">
        <source>convertGCvesselVoyageStructs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2013	cnwndl1	Initial creation	Par 31965

*/

vars

	vessel : CM_Vessel;
	voyage : CM_Voyage;

begin

	app.writeLog( method.qualifiedName &amp; ' Upgrading Vessel GC Structures from 8.2.1 to 8.2.2', LogINFO);

	foreach vessel in CM_Vessel.instances do
		if vessel.myGeneralCargoVesselStructure &lt;&gt; null then
			vessel.myGeneralCargoVesselStructure.convertToUseHoldLocnDefns();
		endif;	
	endforeach;
	
	app.writeLog( method.qualifiedName &amp; ' Finished Vessel GC Structure upgrades from 8.2.1 to 8.2.2', LogINFO);
	app.writeLog( method.qualifiedName &amp; ' Upgrading Voyage GC Structures from 8.2.1 to 8.2.2', LogINFO);
	
	foreach voyage in CM_Voyage.instances do
		if voyage.myGeneralCargoVoyage &lt;&gt; null then
			voyage.myGeneralCargoVoyage.convertToPopulateLocnDefnNames();
		endif;	
	endforeach;
	
	app.writeLog( method.qualifiedName &amp; ' Finished Voyage GC Structure upgrades from 8.2.1 to 8.2.2', LogINFO);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="convertLOLOTEUCapacity" id="0a6e92e2-b8d5-41cd-b165-404e803c665c">
        <source>convertLOLOTEUCapacity();
/*
Purpose:			
Date		Who		Reason
19 August 2013	cnwab1	Initial creation
05/03/2015		cnwmh5	Transient Leaks
16/03/2015		cnwmh5	Tranisent Leaks
*/

vars
	iter01 : Iterator;
	theVesselStructure : CM_CellularVesselStructure;
	oArray : ObjectArray; 
	idx, teu : Integer;
begin
	app.writeLog( method.qualifiedName &amp; 'Populating LOLO TEU Capacity 8.2.2', LogINFO);

	create oArray transient;
	CM_CellularVesselStructure.allInstances(oArray,0,false);
	iter01 := oArray.createIterator;
	theVesselStructure := CM_CellularVesselStructure.lastInstance;
	iter01.startAtObject(theVesselStructure);
	
	while iter01.back(theVesselStructure) do
		idx := idx + 1;
		
		teu := theVesselStructure.getTEUCapacity();
		beginTransaction;
			if theVesselStructure.numSlotsExpected = 0 then
				theVesselStructure.setPropertyValue("numSlotsExpected", teu);
			endif;
			theVesselStructure.setPropertyValue("numSlotsDefined",teu);
		commitTransaction;
	endwhile;
write idx;

epilog
	delete oArray;
	delete iter01;
end;




</source>
    </JadeMethod>
