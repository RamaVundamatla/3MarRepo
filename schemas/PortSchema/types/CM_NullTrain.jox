<Class name="CM_NullTrain" id="62ce7e7b-152b-4a99-a51c-c06bb5def76a">
    <superclass name="CM_Train"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="voyages"/>
    <JadeMethod name="departureProcess" id="5e329cc0-f717-4954-ad92-4e7c95c043df">
        <updating/>
        <source>departureProcess(_cmifRakeRegion : CMIF_RakeRegion; _trainDepartEvent : CMEVT_TrainTransaction output) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 December 2009	cnwndl1	Initial creation	Par 21923 - not allowed to depart a null train.
//16 Dec 2013	cnwrs1	Par 33035 - add CamsDateTime to CM_EventTransaction
*/

vars

begin

	app.raiseCMException1(No_terminal_departure, app.getErrorString(Default_train), null, self);

epilog

end;</source>
        <Parameter name="_cmifRakeRegion" type="CMIF_RakeRegion"/>
        <Parameter name="_trainDepartEvent" type="CMEVT_TrainTransaction" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getCodeDateString" id="fe327765-b187-4c51-b704-4fe9a2f8c746">
        <source>getCodeDateString() : String;
// ---------------------------------------------------------------------------
// Created:     11 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	str : String;
begin

	str := self.code &amp; " " &amp; self.description &amp; " (" &amp; self.myTerminal.code &amp; ")";

	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="init" id="5bd5d997-9a99-411a-b812-8ee3e5132a67">
        <updating/>
        <source>init(_terminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     11 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.code := NULL_TRAIN_CODE;
	self.description := app.getErrorString(Default_train);
	//07 Oct 2013 NDL	Par 32604
	if self.description.pos( UnknownMessage, 1 ) &gt; 1 then
		self.description := "Default Train";
	endif;
	self.myTerminal := _terminal;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="isNullTrain" id="efab041d-0331-412c-b14d-02a1b07941ac">
        <source>isNullTrain(): Boolean;
// ---------------------------------------------------------------------------
// Created:     11 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
