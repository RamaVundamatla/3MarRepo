    <JadeMethod name="clearTblResults" id="56373ddd-4352-4dce-ad78-44bac04625be">
        <source>clearTblResults();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 December 2019	jlgmd1	Initial creation
10 January 2020		jlgmd1	Fixed my dumb ordering of events

*/

vars
	obj			: Object;
	allObjects	: ObjectSet;
	numRows,
	numCols,
	i, j		: Integer;
begin		
		numRows := self.tblResults.rows;
		numCols := self.tblResults.columns;
		
		create allObjects transient;
		foreach i in 1 to numRows do
			foreach j in 1 to numCols do
				self.tblResults.accessCell(i, j);
				obj := self.tblResults.accessedCell.itemObject;
				if obj &lt;&gt; null then
					allObjects.add(obj);
				endif;
			endforeach;
			obj := self.tblResults.accessRow(i).itemObject;
			if obj &lt;&gt; null then
				allObjects.add(obj);
			endif;
		endforeach;
		
		allObjects.purge();
		
		self.tblResults.clear();
		self.tblResults.rows := 0;
		self.tblResults.refreshNow();
epilog
	delete allObjects;
end;</source>
    </JadeMethod>
