    <JadeMethod name="logRowMntRgUpdate" id="c44095b0-774a-47e3-ab77-4f8b5c3a801c">
        <source>logRowMntRgUpdate();
/* ---------------------------------------------------------------------------
Created:	04/05/2011	by cnwvu1

Purpose:	ccms 1119, PAR 27433
   
------------------------------------------------------------------------------*/
vars
	workerObj	: CM_XMLWorker;
	xmlMsg		: String;
	
begin
	app.initialize();
	app.myPassport.setMyUserFromCode("superuser");
	//app.isVoyageCommodityPlanning := false;	need to do this when using tcp listener app.
	create workerObj transient;
	workerObj.init();
	
	xmlMsg	:=	'&lt;msg&gt;
&lt;hdr&gt;
&lt;msgtype&gt;LogRowMntRq&lt;/msgtype&gt;
&lt;msgid&gt;11516&lt;/msgid&gt;
&lt;deviceid&gt;10&lt;/deviceid&gt;
&lt;userid&gt;SUPERUSER&lt;/userid&gt;
&lt;pswd&gt;&lt;/pswd&gt;
&lt;terminal&gt;T01&lt;/terminal&gt;
&lt;version&gt;8&lt;/version&gt;
&lt;time&gt;20110501204641&lt;/time&gt;
&lt;/hdr&gt;
&lt;bdy&gt;
&lt;logrowmntrq class="LOG"&gt;
&lt;logarea&gt;QLOG&lt;/logarea&gt;
&lt;logrow&gt;C3A&lt;/logrow&gt;
