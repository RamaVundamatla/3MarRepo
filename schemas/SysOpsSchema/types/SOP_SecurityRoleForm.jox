// ---------------------------------------------------------------------------
// Created:     27 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	return true;
/*	
	return (not self.chkAvailCS.value)  and
		   (not self.chkAvailCSP.value) and
		   (not self.chkAvailGen.value) and
