*/

vars

	ct : CM_CargoType;
begin
	ct:= self.getCargoType;
	if ct &lt;&gt; null and ct.isBulkMulti then
		return ct.getBulkTrackByDisplayForWeight(self.getWeightPacked(),self.getDensity,true); 
	elseif ct &lt;&gt; null and self.byTypeByWeight then													// 11/01/2024	navcs2	ChangeRequest 61549
		return ct.getConvertedWeightDisplay(self.getWeightReleased(), true);						// 11/01/2024	navcs2	ChangeRequest 61549
	else																							// 11/01/2024	navcs2	ChangeRequest 61549
		return self.getTotalPacked().asStringJMT;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
