<Class name="WS_NValidationDefinition" id="6a637b49-7ae0-44c8-badc-9aba7f5ff1fe">
    <superclass name="WS_NFormObject"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <Constant name="TemperaturePattern" id="83eef185-7703-4a01-a321-8b028c46b373">
        <source>"(^-0\\.[0-9]{1,2}$)|(^((0)|((-)?[1-9][0-9]{0,5}))(\\.[0-9]{1,2})?$)"</source>
        <type name="String"/>
    </Constant>
    <PrimAttribute name="isRequired" id="df3648c4-3d27-40ab-80b8-e98e1ead5714">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="letterCase" id="50e87fcb-eb52-4707-98ff-ace9ef3e8df5">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="maxLength" id="6ec2dcf6-3831-47e6-b0a8-5d520f58b708">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="maxValue" id="3d465228-705e-406d-a40a-3ea2dbb88110">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="minLength" id="a2e99a05-543d-4977-8f2f-6af2e390c384">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="minValue" id="21ac3c8d-c4dc-4146-9586-2019a2c6a351">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="pattern" id="ae83f5d7-3245-4988-9552-03eaaf27f892">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setDetails" id="0b037091-8078-41d3-80e0-39e6f1c51b04">
        <updating/>
        <source>setDetails(_entRow : EntTableRow) : Boolean updating;
//
// Purpose:			Set up any validation requirements - return true if any requirements set,
//						otherwise return false so the calling method can delete me (not required)
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 06/10/2020	jlgdap1		Initial creation TFS 49227 MTN Navis API - nReefer API
// 17/12/2020	jlgdap1		TFS 50508 MTN Reefer App - Job List
//
vars

begin
	if _entRow.name = ETRow_Temperature then
		//self.isRequired := true;						// TFS 50508
		self.pattern := self.TemperaturePattern;
		if _entRow.myEntTableCellControl &lt;&gt; null then
			self.maxLength := _entRow.myEntTableCellControl.getMaxLength;
		endif;
		return true;
	elseif _entRow.name = ETRow_Ventilation then
		self.minLength := 1;
		if _entRow.myEntTableCellControl &lt;&gt; null then
			self.maxLength := _entRow.myEntTableCellControl.getMaxLength;
		endif;
		return true;
	else
		if _entRow.myEntTableCellControl &lt;&gt; null then
			self.maxLength := _entRow.myEntTableCellControl.getMaxLength;
			return true;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_entRow" type="EntTableRow"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
