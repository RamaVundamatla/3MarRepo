	self.raiseExceptionIfNull(_pxySortingMethod, 'SortingMethod Proxy');
	self.raiseExceptionIfNull(_realSortingMethod, "SortingMethod Existing");
	_pxySortingMethod.raiseExceptionIfNotProxy(method);
	if _realSortingMethod.code = _pxySortingMethod.code then
		_pxySortingMethod.validateForUpdate;
	else
		_pxySortingMethod.validateForCreate;
	endif;
	
