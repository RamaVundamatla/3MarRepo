    <JadeMethod name="getDescription" id="1ecafec4-3814-48e7-9f9e-32d46ca07463">
        <source>getDescription() : String;

vars
	locationStr : String;
begin
	
	// Non-ISO, print current bay (FCF 1433)
	locationStr := self.bayId.trimBlanks &amp; " " ;
	
		
	if self.isPort then
		locationStr := locationStr &amp; "P";
	elseif self.isCentre then
		locationStr := locationStr &amp; "C";
	elseif self.isStarboard then
		locationStr := locationStr &amp; "S";
	endif;

	if self.jobType = JOB_TYPE_LOAD
	or self.jobType = JOB_TYPE_DISCHARGE
	or self.jobType = JOB_TYPE_SOB then
	
		if self.ordinalDeck = DeckOnDeck then
			locationStr := locationStr &amp; " OD";
		elseif self.ordinalDeck = DeckUnderDeck then
			locationStr := locationStr &amp; " UD";
		endif;
	endif;
	return locationStr;
end;
	</source>
        <ReturnType type="String"/>
    </JadeMethod>
