        <Parameter name="_pxyCargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="setReeferPropsOnSystemProduct" id="ed822c54-8741-448b-918b-b279975928ba">
        <updating/>
        <source>setReeferPropsOnSystemProduct() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/02/2010	cnwdap1	Initial creation PAR #22938
*/
vars

begin
	if self.pxySystemProductType = null then
		return;
	endif;
	
	self.pxySystemProductType.setReeferProperties(	self.tblEntDetail.getValueByName(ETRow_Reefer).Boolean,
													self.tblEntDetail.getValueByName(ETRow_Powered).Boolean,
