    <JadeMethod name="getFullIdAndLevel" id="586fc31e-1bd7-4a22-bf18-cfed65daa4f8">
        <source>getFullIdAndLevel(_ti : CM_TrackedItem ; _mode : Integer ; _isTarget : Boolean):String;

// Returns location id plus reimplementations can return stack level if applicable

// Created: RBarr	24/7/2006	PAR 11955	Add indication of TI level in stack

vars
	tmpLevel	: Integer;
	str : String;
begin 
	if _isTarget then
		if _ti &lt;&gt; null then
			if _mode = REAL_MODE then
				return self.getFullIdTI(_ti) &amp; " " &amp; (self.allTrackedItems.size + 1).String;
			elseif _mode = PLANNING_MODE then // PAR 16535
				return self.getFullIdTI(_ti) &amp; " " &amp; (self.numTIs + self.numQueuedTIs + 1).String; // PAR 16535
			else
				if self.includesTI(_ti,_mode) then
					return self.getFullIdTI(_ti) &amp; " " &amp; (self.numTIs + self.numQueuedTIs).String; // PAR 15133 no need to add 1 as the Qd items is already in the numQueuedTIs
				else
					return self.getFullIdTI(_ti) &amp; " " &amp; (self.numTIs + self.numQueuedTIs + 1).String;
				endif;
			endif;
		else
			if _mode = REAL_MODE then
				return self.getFullId &amp; " " &amp; (self.allTrackedItems.size + 1).String;
			elseif _mode = PLANNING_MODE then // PAR 16535
				return self.getFullId &amp; " " &amp; (self.numTIs + self.numQueuedTIs + 1).String;
			else
				return self.getFullId &amp; " " &amp; (self.numTIs + self.numQueuedTIs).String;
			endif;
		endif;
	else
		if _ti &lt;&gt; null then
			/*
			str := self.allTrackedItems.indexOf(_ti).String;// PAR 14387
			if str = "0" then// PAR 14387
				str := null;// PAR 14387
			endif;
			*/
			
			// rework to avoid comparison with converted string
			tmpLevel := self.allTrackedItems.indexOf(_ti);
			if tmpLevel &gt; 0 then
				str := tmpLevel.asStringJMT;
			endif;
			
			return self.getFullIdTI(_ti) &amp; " " &amp; str; // PAR 14387 changed to use 'getFullIdTI'
		else
			return self.getFullId();
		endif;
	endif;
	
	return null;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_isTarget" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFullIdForTI" id="d114007f-87b0-499b-88eb-9817cc3c5024">
        <source>getFullIdForTI(_isTarget : Boolean) : String;
//Basically, same as getFullId, but also returns the height of a possible drop.
vars
	numInTarget	:	Integer;
	aStr	:	String;
begin

	return inheritMethod(_isTarget);

end;</source>
        <Parameter name="_isTarget" type="Boolean"/>
