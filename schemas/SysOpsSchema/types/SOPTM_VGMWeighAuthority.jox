    <JadeMethod name="initShtDataTable1" id="b0aa99d1-435d-4503-9828-c498375ba9bc">
        <updating/>
        <source>initShtDataTable1() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/06/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars
	form : SOP_TableMaintForm;
	table : Table;

begin
	inheritMethod();
	
	form := self.myForm;
	table := form.tblData1;
	
	form.shtDataTable1.visible := true;
	form.shtDataTable1.caption := app.getErrorString(Terminals);
	
	table.clear;
	table.rows			:= 0;
	table.columns		:= 2;
	table.fixedRows		:= 0;
	table.selectMode 	:= Table.SelectMode_None;
	
	table.accessColumn(1).inputType	:= Table.InputType_None;
	table.wordWrap					:= true;
	table.columnWidth[1]			:= 200;
	table.columnWidth[2]			:= table.clientWidth - table.columnWidth[1];
	table.autoSize					:= Table.AutoSize_Row;
	table.top						:= form.frmTBDataTable1.height + 1;
	
	self.showThumbnail_Terminal(null);
	
	table.userInputEnabled := false;
epilog

end;</source>
    </JadeMethod>
