    <JadeMethod name="addObjectsToTable" id="c7162df6-1fc0-440c-b1b9-22f6e5d75ffb">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Mar 2025	navnk30	JIRA 14605: EUP | Implement Satellite View of Large Dataset Display using "displayCollection"
12 May 2025	navnk30 JIRA 34841: Total items displayed was not shown in Cargo List View form

*/

vars
	ti				: CM_TrackedItem;
	filteredColl	: CM_TrackedItemArray;
	form			: CM_BaseForm;
begin
	create filteredColl transient;
	foreach ti in self.allTIs where self.includeObject(ti, app.myPassport) do
		filteredColl.add(ti);
		self.armNotesForObject(ti);
	endforeach;
	form := self;
	self.tblData.getDataAndDisplayRowsPaginat(Table.DisplayCollection_Forward, null, filteredColl, true);
	//self.staMain.caption := self.tblData.getCollection().size.String &amp; " items displayed";	//12.05.2025 navnk30 JIRA 34841
	_numItems := self.tblData.getCollection().size();											//12.05.2025 navnk30 JIRA 34841
epilog
	delete filteredColl;
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="adjustSearcherHeight" id="2200a65a-2057-4f46-9570-0f24b713b51a">
        <source>adjustSearcherHeight() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Mar 2025	navnk30	JIRA 14605: EUP | Implement Satellite View of Large Dataset Display using "displayCollection"

*/

vars

begin
	self.tblSearch.optimiseHeadingColumn();
	self.tblSearch.adjustHeight(self.clientHeight);
	self.frmSearch.height := tblSearch.height + tblSearch.top;
	self.tblSearch.scrollBars := Table.ScrollBars_None;
	self.sptDataFilter.cnEcResizeContents();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
