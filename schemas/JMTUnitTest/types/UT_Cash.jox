	endforeach;
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	// #### MERGE
	app.myTrxUA.trxMergeBreakBulk(origTI.CM_Cargo,	//_targetTi : CM_BreakBulkGeneric;
										allTisToMerge,	//_allItemsToBeMerged : CM_TISet;
