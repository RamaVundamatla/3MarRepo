    <JadeMethod name="comboBoxBusinessUnit" id="d8378ca2-d755-4653-8a23-4c0932269ffb">
        <source>comboBoxBusinessUnit(_cmb : ComboBox input; _bank : CM_Bank);
//-----------------------------------------
// Created: January 2004 By: cnwgd1
//-----------------------------------------
vars
	bank	: CM_Bank;
	found	: Boolean;
	str		: String;
begin
	_cmb.clear();

	foreach bank in self.myTerminal.companies where (not bank.isSuspended) and (bank.isBusinessUnit) do
		str := self.displayEntryBank(bank);
		if str &lt;&gt; null then	 			
			_cmb.itemObject[_cmb.addItem(str)] := bank;
			if bank = _bank then
				found := true;
			endif;
		endif;
	endforeach;


	if found then
		_cmb.text := self.displayEntryBank(_bank);
		_cmb.listObject := _bank;
	endif;
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
