    <JadeMethod name="tblQueueEntries_click" id="8a6b3ae3-d620-490f-84e9-d72a5d212f9c">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblQueueEntries_click(table: Table input) updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
14 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars

begin
	app.mousePointer := Busy;
	self.doQueueEntriesTableClick;
	
	
epilog
	app.mousePointer := Idle;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblResults_dblClick" id="6fb715d4-030b-49ff-9d4b-8c54aba0e956">
