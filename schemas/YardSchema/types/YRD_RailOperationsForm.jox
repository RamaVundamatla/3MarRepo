    <JadeMethod name="setDefaultRetrospectiveTS" id="5bdd596a-e6b6-4edc-985d-604fae724343">
        <updating/>
        <source>setDefaultRetrospectiveTS() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2021	navndl1	Initial creation	TFS 51199

*/

vars

	showEffectiveDate : Boolean;
	now : TimeStamp;

begin

	now := app.actualTimeServer;
	showEffectiveDate := self.chkRetrospect.value;

	self.lblEffectiveDate.visible := showEffectiveDate;
	self.txtEffectiveDate.visible := showEffectiveDate;
	self.lblEffectiveTime.visible := showEffectiveDate;
	self.txtEffectiveTime.visible := showEffectiveDate;
	
	self.txtEffectiveDate.enabled := true;
	self.txtEffectiveTime.enabled := true;

	if showEffectiveDate then
		//15 May 2021	NDL	TFS 51199
		if self.myTerminal.getConfig(RailRetroDefault).Boolean
		and self.myCurrentTrain &lt;&gt; null
		and self.myCurrentTrain.cargoExchangeEndTS.date.isValid
		and self.myCurrentTrain.cargoExchangeEndTS &lt;= now
		then
			self.retrospectiveDate := self.systemToLocalTime( self.myCurrentTrain.cargoExchangeEndTS );
			self.txtEffectiveDate.enabled := false;
			self.txtEffectiveTime.enabled := false;
		else
			self.retrospectiveDate := app.actualTimeAppServer;
		endif;
		self.txtEffectiveDate.setDate( self.retrospectiveDate.date );
		self.txtEffectiveTime.setTime( self.retrospectiveDate.time );
	else
		self.retrospectiveDate := null;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setDirCaption" id="213d3784-f4c3-4808-9d83-eb6ca00051a6">
