<Class name="CM_VoyageDeckJob" id="480e0f83-a54d-4696-94ac-374362858aec">
    <superclass name="CM_VoyageJob"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>

#################
#################

These jobs are for RORO DECK vessel that are using the RORO Planning &amp; Operations screens for RORO work. 
These jobs do have a CM_VoyageDeckJobSheet job sheet

#################
#################
</text>
    <DbClassMap file="operatn"/>
    <JadeMethod name="autoLinkSlotsSOB" id="4cb719ea-7fd0-4923-a135-4346f695d432">
        <source>autoLinkSlotsSOB( 	_theJobParams :CMIF_VoyageJobParams input;
					_passport : CM_Passport input) protected;
/*
Purpose:			
Date				Who			Reason
FEB 2012		CNWAB1		Initial creation
*/
 // PAR 31144 refactored to plann all the WLEs, not just the first - ALWAYS DISCHARGE TO LOAD, NEVER LOAD TO DISCHARGE


vars
	theTerminal : CM_Terminal;
	moveControl : CMIF_MoveController;
	aSlotReq,aLinkedSlotReq	: CM_Request;
	theTI : CM_TrackedItem;
	tmpWLE, lWLE, dWLE : CM_WorkListEntry;
	theSource, theTarget : CM_LocationsController;
	idx, numWLE : Integer;
	loadWLEArray, dischargeWLEArray : CM_WLEArray;
begin
	if _theJobParams.allRORORequests.isEmpty then
		return;
	endif;

	theTerminal := _passport.myTerminal;
	// if this baby is linked to another request, cos of  SOB, then do the planning
	if not theTerminal.getConfig(AutoLinkSlotPlanSOB).Boolean then
		return;
	endif;
	
	create loadWLEArray transient;
	create dischargeWLEArray transient;
	
	create moveControl transient;
	moveControl.setMoveMode(PLANNING_MODE);
	
	
	// ALWAYS DISCHARGE TO LOAD, NEVER LOAD TO DISCHARGE
	foreach aSlotReq in _theJobParams.allRORORequests do
		aLinkedSlotReq := aSlotReq.getDLRSOBRequestLink();
		if aLinkedSlotReq &lt;&gt; null then
			aSlotReq.setSequenced(true);
			aLinkedSlotReq.setSequenced(true);

			// PAR 31652 - was only ever doing thr first request since thr COPY just added the subsequent Reqs into the collection, that got bigger, and then only ever looked at the first one.
			dischargeWLEArray.clear(); // !!!!!!!!!!!!!!!!!
			loadWLEArray.clear(); // !!!!!!!!!!!!!!!!!

			aSlotReq.allWorkListEntries.copy(dischargeWLEArray);
			aLinkedSlotReq.allWorkListEntries.copy(loadWLEArray);
			
			numWLE := aSlotReq.allWorkListEntries.size;
			foreach idx in 1 to numWLE do : innerLoop
				
				dWLE := dischargeWLEArray[idx];
				lWLE := loadWLEArray[idx];
				
				if lWLE = null or dWLE = null then
					break innerLoop;
				endif;
				
				theTI := dWLE.myTrackedItem;
				if theTI.myPrimaryPlannedLocation &lt;&gt; null then // already done
					continue;
				endif;
				lWLE.setMyTrackedItem(theTI);
				
				theSource := aSlotReq.getLC();
				theTarget := aLinkedSlotReq.getLC();

				moveControl.setMyTrackedItem(theTI);
				
				if aLinkedSlotReq.isVoyageRequest then
					moveControl.myVoyageRequest := aLinkedSlotReq.CM_VoyageRequest;
				else
					moveControl.mySlotRequest := aLinkedSlotReq.CM_SlotRequest;
				endif;
				
				moveControl.setMyWorkListEntry(lWLE); 
				moveControl.setMyOriginatingLocation(theSource);
				moveControl.setMyToPrimaryLocation(theTarget); 
				app.myUtilityUA.utlUpdateMoveTrackedItem(moveControl, _passport);
				dWLE.setLocations(lWLE.locationSource, lWLE.locationTarget); // PAR 13937
			endforeach;
		endif;
	endforeach;
	
epilog
	delete moveControl;
	delete dischargeWLEArray;
	delete loadWLEArray;
end;</source>
        <access>protected</access>
        <Parameter name="_theJobParams" type="CMIF_VoyageJobParams" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
