    <JadeMethod name="tblView2_mouseMove" id="468f9624-1949-464b-ba4d-e8060028fb8d">
        <controlMethod name="Table::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblView2_mouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 April 2023	navkc1	Initial creation CR 57036 Task 57589: UI - Cargo Enquiry Drag Drop

*/

vars
	entDef		: EntTableDef;
	tmpHeight 	: Real;
	ti			: CM_TrackedItem;
begin
	if not self.myCurrentObject.isKindOf(CM_TrackedItem) then // ### BUG 58170 29MAY2023 NAVAB1
		return; // ### BUG 58170 29MAY2023 NAVAB1
	endif;

	entDef := table.CM_DataTable.myEntTableDef;
	
	ti := self.myCurrentObject.CM_TrackedItem;
	
	if ti = null or not ti.isMAFI() then
		return;
	endif;
	
	if table.fixedRows &gt; 0 then
		tmpHeight := table.accessRow(table.fixedRows).height;
		if self.origYPos &lt;= tmpHeight then
			return;
		endif;
	endif;
	
	if button = 1 then
		if app.dragDetected(x, y, self.origXPos, self.origYPos) then
			self.doMAFILoadDragTI(table);
			self.origXPos := 0;
			self.origYPos := 0;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
