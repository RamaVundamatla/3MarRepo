<Class name="HMS_ResourceForPilot" id="d0d366b7-7723-4053-a89b-6c77eba69590">
    <superclass name="HMS_ResourceForObject"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="harbour"/>
    <ExplicitInverseRef name="allPilots" id="a50c0f6f-21f8-41d3-9f61-fdd35ca5c756">
        <updateMode>manual</updateMode>
        <type name="HMS_PilotByCodeDict"/>
        <access>readonly</access>
        <Inverse name="HMS_Pilot::allResourcesForPilot"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="myPilot" id="7e86b76c-f258-464c-904d-a0ccf2eea7a8">
        <embedded/>
        <type name="HMS_Pilot"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="getObjectDescription" id="72c5976d-7494-4057-84c2-4be6babd01f2">
        <source>getObjectDescription() : String;
// ---------------------------------------------------------------------------
// Created:     22 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	return 	self.myPilot.getDisplayString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setPilot" id="6ef4c592-83ab-4b2e-81dc-25f019d6bddb">
        <updating/>
        <source>setPilot(_pilot	: HMS_Pilot)updating;
// ---------------------------------------------------------------------------
// Created:     21 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	self.myPilot := _pilot;
	self.myHMSObject := _pilot;
	
	if _pilot &lt;&gt; null and not self.allPilots.includes(_pilot) then 
		self.allPilots.add(_pilot);
	endif;
end;</source>
        <Parameter name="_pilot" type="HMS_Pilot"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="fc76e4e1-498c-49b3-a2d4-a0c2e149e970">
        <updating/>
        <source>setProxy(_obj : HMS_Object; _harbour: HMS_Harbour; _arrivalResource: HMS_Resource; _departResource: HMS_Resource; _shiftResource: HMS_Resource) updating;
// ---------------------------------------------------------------------------
// Created:     18 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	pilot	: HMS_Pilot;
begin
	inheritMethod(_obj, _harbour, _arrivalResource, _departResource, _shiftResource);
	
	pilot := _obj.HMS_Pilot;
		
	self.myPilot := pilot;
	self.myHMSObject := pilot;
	
	if pilot &lt;&gt; null and not self.allPilots.includes(pilot) then 
		self.allPilots.add(pilot);
	endif;
end;</source>
        <Parameter name="_obj" type="HMS_Object"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_arrivalResource" type="HMS_Resource"/>
        <Parameter name="_departResource" type="HMS_Resource"/>
        <Parameter name="_shiftResource" type="HMS_Resource"/>
    </JadeMethod>
</Class>
