    <JadeMethod name="displayJob" id="39f31b6b-3c66-4d84-85f4-64a52df10538">
        <source>displayJob() protected;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
begin
	self.myLegendTable.rows := 0;
	self.addRow("Jobs",Red,null,true);
	self.myLegendTable.fixedRows := 1;

	// TFS 42872 JLGAB1 - changed descriptions
	/* WAS
	self.addRow("Release",CM_Job.Colour_ReleaseUnactioned,null,true);
	self.addRow("Receipt",CM_Job.Colour_ReceiptUnactioned,null,true);
	self.addRow("Rel.Comp",CM_Job.Colour_ReleaseComplete,null,true);
	self.addRow("Rec. Comp",CM_Job.Colour_ReceiptComplete,null,true);
	self.addRow("Rel. P/Comp",CM_Job.Colour_ReleasePartComplete,null,true);
	self.addRow("Rec. P/Comp",CM_Job.Colour_ReceiptPartComplete,null,true);
	
	NOW */
	self.addRow(app.getErrorString(ReleaseJob),CM_Job.Colour_ReleaseUnactioned,null,true); 
	self.addRow(app.getErrorString(ReceiptJob),CM_Job.Colour_ReceiptUnactioned,null,true); 
	self.addRow(app.getErrorString(Release_complete),CM_Job.Colour_ReleaseComplete,null,true); 
	self.addRow(app.getErrorString(Receipt_complete),CM_Job.Colour_ReceiptComplete,null,true); 
	self.addRow(app.getErrorString(Release_part_complete),CM_Job.Colour_ReleasePartComplete,null,true); 
	self.addRow(app.getErrorString(Receipt_part_complete),CM_Job.Colour_ReceiptPartComplete,null,true);
	self.addRow(app.getErrorString(OtherJob),White,null,false);
end;</source>
        <access>protected</access>
    </JadeMethod>
