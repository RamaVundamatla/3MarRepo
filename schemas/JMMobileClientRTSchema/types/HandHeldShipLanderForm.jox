    <JadeMethod name="doKeyDown" id="b3ff30c1-aada-438d-aa7f-b45bcfe7e622">
        <updating/>
        <source>doKeyDown(keyCode: Integer io; shift: Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if keyCode = J_key_F2 then
		if self.fldMain.topSheet = self.shtError then
			self.fldMain.topSheet := self.shtJobs;
			return;
		endif;
		
		if self.frmFowardCont.visible then
			self.doShowFrmMain;
		else
			//epr par 17544 15/7/08
			if self.frmTI1.enabled then
				self.doShowFrmFowardCont();
			endif;
		endif;
	elseif keyCode = J_key_F3 then
		if self.fldMain.topSheet = self.shtError then
			self.fldMain.topSheet := self.shtJobs;
			return;
		endif;
		
		if self.frmAftCont.visible then
			self.doShowFrmMain;
		else
			//epr par 17544 15/7/08
			if self.frmTI2.enabled then
				self.doShowFrmAftCont();
			endif;
		endif;
		
	elseif keyCode = J_key_F4 then
		if self.fldMain.topSheet = self.shtError then
			self.fldMain.topSheet := self.shtJobs;
			return;
		endif;
		
		if self.frmFowardCont.visible or
		   self.frmAftCont.visible then
			self.doShowFrmDamage();
		elseif self.frmDamage.visible then
			if self.showingFowardContainer then
				self.doShowFrmFowardCont();
			elseif self.showingAftContainer then
				self.doShowFrmAftCont();
			endif;
		endif;
	elseif keyCode = J_key_F5 then
		if self.fldMain.topSheet = self.shtJobs then
			self.fldMain.topSheet := self.shtError;
		else
			self.fldMain.topSheet := self.shtJobs;
		endif;
		self.setLogicalFocus();
		
	elseif keyCode = J_key_Delete then
		if self.frmMain.visible then
			self.btnReject.click(self.btnReject);
		endif;
	elseif keyCode = J_key_N or  keyCode = J_key_n then
		if  self.idTextHasFocus then
			return;
		endif;
		if self.frmAftCont.visible and self.grpAftSeals.visible then
			self.btnAftSealNo.click(self.btnAftSealNo);
		elseif self.frmFowardCont.visible and  self.grpFwdSeals.visible then
			self.btnFwdSealNo.click(self.btnFwdSealNo);
		endif;
	elseif keyCode = J_key_Y or  keyCode = J_key_y  then
		if  self.idTextHasFocus then
			return;
		endif;
		
		if self.frmAftCont.visible and  self.grpAftSeals.visible then
			self.btnAftSealYes.click(self.btnAftSealYes);
		elseif self.frmFowardCont.visible and self.grpFwdSeals.visible then
			self.btnFwdSealYes.click(self.btnFwdSealYes);
		endif;
	else
		inheritMethod(keyCode, shift);
	endif;
	

end;


</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doLogOff" id="59d03dcc-123c-44be-a005-74c11bac6246">
