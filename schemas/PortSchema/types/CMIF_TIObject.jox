    <JadeMethod name="setSubTerminalDefault" id="4a173a48-c773-449f-9163-0b63fa561abe">
        <updating/>
        <source>setSubTerminalDefault() updating;
// --------------------------------------------------------------------------------
// Created:		30 April 2009 by cnwdad1
//
// Purpose:		This is the default implementation for setting the receiver's default
//				Sub-Terminal reference.  This method will be re-implemented as
//				necessary.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	terminalObj		: CM_Terminal;
	defaultObj		: CM_SubTerminal;
	
begin
	terminalObj	:=	self.myTerminal;
	
	if terminalObj = null then
		// Do nothing.
	else
		defaultObj	:=	terminalObj.getDefaultSubTerminal(	self.getSubTerminalType(),
															self.getBulkReleaseType(),	// cnwdad1 27/01/2010 - PAR #22205.
															self.getImexStatus(),
															self.getCommodityCode(),
															self.isContainer());
		
		self.mySubTerminal	:=	defaultObj;
	endif;
end;</source>
    </JadeMethod>
