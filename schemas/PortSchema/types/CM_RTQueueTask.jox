    <JadeMethod name="addTIToDirectorTask" id="452108d1-36dc-4b6f-896c-43ba9bd93002">
        <updating/>
        <source>addTIToDirectorTask(_ti	:	CM_TrackedItem input) updating;
//Adds a TI to the director task.

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/10/2008	consw1		SFW1030 - Remove unused auto plan flags
//17 Feb 2009	cnwkpd1		PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
//							Renamed as part of refactoring methods

vars
	job					: CM_Job;
	lc,
	taLocation			: CM_LocationsController;
	alert				: CM_SystemAlert;
	wle					: CM_WorkListEntry;
	deliveryRequest		: CM_DeliveryRequest;
	tmpTargetLocation	: String;
	ta					: CM_TerminalArea;
	request				: CM_Request;
	foundHeight			: Integer;
	terminal 			: CM_Terminal;
begin

	
	if self.status &lt;&gt; TASK_ACCEPTED then
		// jler1 TFS 51580 9/9/21 if  accepted it could be because  it is doing a best pick which is OK
		if not self.checkAssignBestPickTIToWLE then
			app.setContinueCMExceptions(false);
			app.raiseCMException2(ERR_TASK_NOT_STATUS, taskTypeId, "Add task to director", null, null);
			return;
		endif;
	endif;
	if _ti = null then
		app.raiseCMException1(ERR_NO_OBJECT, "No TI", null, null);
		return;
	endif;
	//This is a release of a TI, check that the TI has no release job!
	job := self.myEntry.myJob;
	if job = null then
		app.raiseCMException1(ERR_NO_OBJECT, "No Job", null, null);
		return;
	endif;
	
	terminal :=job.getMyTerminal();
	
	request := self.myEntry.getMyRequest;
	wle := self.myEntry.myWorkListEntry;
	// CCMS 1309 DVB 15/02/2005
	
	//cnwrd1 par 25681 18.11.2010 multi machine director moves
	//note we maybe should look at the ultimate target location here
	if self.targetLocation = null and self.targetLocationId &lt;&gt; null then
		if self.isMultiMachineDirector then		
			taLocation := self.myEntry.getMultiDirectorUltimateTarget();
			if taLocation = null then
				taLocation:=self.myEntry.getUltimateTargetLocation();
			endif;
		else
			terminal.findLocationFromString(self.targetLocationId, false, taLocation , foundHeight);  //does the request point to a blockstack		
		endif;
	endif;
	
	// CCMS 1309 DVB 15/02/2005
	if self.targetLocation = null and taLocation = null 
		and not request.isKindOf(CM_SlotRequest)  then  //if we have ablockstack controller we dont need to autoplan
		
		if request &lt;&gt; null and request.isKindOf(CM_YardRequest) then
			ta :=  request.CM_YardRequest.myTargetTA;
		endif;
		
		app.autoPlanAlertOverride(terminal);
		lc := app.autoPlanTiYA(terminal, ta, _ti);
		
		if lc = null then
			//------------------
			//Couldnt autoplan!
			//------------------
			create alert;
			alert.details := app.getErrorString1(ERR_NO_AUTOPLAN, _ti.id.trimBlanks &amp; " in Job " &amp; job.jobId);
			alert.setSeverity(SEVERE_ERROR);
			//-----------
			//Tell alert to add itself to system
			//-----------
			alert.add;
			app.setContinueCMExceptions(false);
			app.raiseCMException1(ERR_NO_AUTOPLAN, _ti.id.trimBlanks &amp; " in Job " &amp; job.jobId, null, null);
			return;
		endif;
		
		self.setTargetLocation( lc);
	endif;
	
	if app.myYAAgent &lt;&gt; null then
		_ti.createInfomationTransaction(YardAllocationDirTaskPlan, app.myYAAgent.getLoggingArray(true), null, app.myPassport);
	endif;

	if self.ti &lt;&gt; null then
		//Have one already, Remove it!
		wle.setMyTrackedItem(null);
		job.CM_YardJob.removeTI(self.ti, request);	
	endif;
	//--------------
	//Set references to WLE, job and TI!
	//--------------
	wle.setMyTrackedItem(_ti);	

	// CCMS 1028
	if request &lt;&gt; null then
		request.setBulkReleaseTI(_ti);
	endif;
	
	job.addTI(_ti, request);
	//---------------
	//Lastly, set the reference in this task to the TI
	//---------------
	self.ti := _ti;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addTIToDirectorTaskForBP" id="9cb61f75-ea3b-4a76-ad61-a0081acca66f">
        <updating/>
        <source>addTIToDirectorTaskForBP(_ti	:	CM_TrackedItem input; _terminal : CM_Terminal) updating;

/*

Purpose: Adding a best pick TI to a Director which is done before the task is accepted! So the old addTIToDirectorTask doesnt work.

Parameters:			

Return Value:		


Date		Who		Reason
21 November 2011	cnwrd1	Initial creation

*/


vars
	job					: CM_Job;
	lc,
	taLocation			: CM_LocationsController;
	alert				: CM_SystemAlert;
	wle					: CM_WorkListEntry;
	deliveryRequest		: CM_DeliveryRequest;
	tmpTargetLocation	: String;
	ta					: CM_TerminalArea;
	request				: CM_Request;
	foundHeight			: Integer;
begin

	
	if _ti = null then
		app.raiseCMException1(ERR_NO_OBJECT, "No TI", null, null);
		return;
	endif;
	//This is a release of a TI, check that the TI has no release job!
	job := self.myEntry.myJob;
	if job = null then
		app.raiseCMException1(ERR_NO_OBJECT, "No Job", null, null);
		return;
	endif;
	
	
	request := self.myEntry.getMyRequest;
	wle := self.myEntry.myWorkListEntry;
	// CCMS 1309 DVB 15/02/2005
	
	//cnwrd1 par 25681 18.11.2010 multi machine director moves
	//note we maybe should look at the ultimate target location here
	if self.targetLocation = null and self.targetLocationId &lt;&gt; null then
		if self.isMultiMachineDirector then		
			taLocation := self.myEntry.getMultiDirectorUltimateTarget();
		else
			_terminal.findLocationFromString(self.targetLocationId, false, taLocation , foundHeight);  //does the request point to a blockstack		
		endif;
	endif;
	
	// CCMS 1309 DVB 15/02/2005
	if self.targetLocation = null and taLocation = null 
		and not request.isKindOf(CM_SlotRequest)  then  //if we have ablockstack controller we dont need to autoplan
		
		if request &lt;&gt; null and request.isKindOf(CM_YardRequest) then
			ta :=  request.CM_YardRequest.myTargetTA;
		endif;
		
		app.autoPlanAlertOverride(_terminal);
		lc := app.autoPlanTiYA(_terminal, ta, _ti);
		
		if lc = null then
			//------------------
			//Couldnt autoplan!
			//------------------
			create alert;
			alert.details := app.getErrorString1(ERR_NO_AUTOPLAN, _ti.id.trimBlanks &amp; " in Job " &amp; job.jobId);
			alert.setSeverity(SEVERE_ERROR);
			//-----------
			//Tell alert to add itself to system
			//-----------
			alert.add;
			app.setContinueCMExceptions(false);
			app.raiseCMException1(ERR_NO_AUTOPLAN, _ti.id.trimBlanks &amp; " in Job " &amp; job.jobId, null, null);
			return;
		endif;
		
		self.setTargetLocation( lc);
	endif;
	
	if app.myYAAgent &lt;&gt; null then
		_ti.createInfomationTransaction(YardAllocationDirTaskPlan, app.myYAAgent.getLoggingArray(true), null, app.myPassport);
	endif;

	if self.ti &lt;&gt; null then
		//Have one already, Remove it!
		wle.setMyTrackedItem(null);
		job.CM_YardJob.removeTI(self.ti, request);	
	endif;
	//--------------
	//Set references to WLE, job and TI!
	//--------------
	wle.setMyTrackedItem(_ti);	

	// CCMS 1028
	if request &lt;&gt; null then
		request.setBulkReleaseTI(_ti);
	endif;
	
	job.addTI(_ti, request);
	//---------------
	//Lastly, set the reference in this task to the TI
	//---------------
	self.ti := _ti;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="alertRequired" id="d66cc3b6-ef6a-468e-a764-dd05da917993">
        <source>alertRequired(_origLocn : CM_LocationsController) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 Nov 2010	cnwmh5	Initial creation #26186
28 Mar 2013 cnwer1	PAR 31244
*/

vars
	alertRequired	: Boolean;
	craneQueue		: CM_VoyageCraneQueue;
	queue			: CM_VoyageQueue;
	object			: Object;
	cta 			: CM_CraneTransferArea;
begin

	alertRequired := true;
	
	if _origLocn.isKindOf(CM_SlotController) then
		if self.taskType = TASK_SETDOWN then
			if _origLocn.CM_SlotController.myVoyage &lt;&gt; null then
				queue := _origLocn.CM_SlotController.myVoyage.myQueue;
				if queue &lt;&gt; null then
					foreach object in queue.allSubQueuesById where object.isKindOf(CM_VoyageCraneQueue) do
						craneQueue := object.CM_VoyageCraneQueue;
						cta:=craneQueue.crane.transferArea;
						if cta = null then
							continue;
						endif;
						if cta.loadLanes.includes(self.targetLocation) then
							alertRequired := false;
						endif;
					endforeach;
				endif;
			endif;
		endif;
	endif;

	return alertRequired;
	
epilog

end;</source>
        <Parameter name="_origLocn" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="allocateMachineToTask" id="852d2933-d7de-4be0-ab56-fcc030be96df">
        <updating/>
        <source>allocateMachineToTask(pMachine	:	CM_Machine input; _sendNote, _logHistory : Boolean) updating;
//Allocates (basically queues up) the passed in machine directly to the task,
//when  the machine next asks for a task, its ALWAYS given this.
//We set a property in the machine for the task.
//See self.removeMachine to nuke the machine allocation.

// 25/11/2010	cnwcs5	par 23714/ccms 1132 - record machine history (new parameter)
vars
	currentQEntry	: CM_RTQueueEntry;
	firstTask		: CM_RTQueueTask;
	term			: CM_Terminal;
	allOverstowedTIs : CM_TIArray;
	overstowingTI 	: CM_TrackedItem;
	sideAccessDirection : Integer;
	vehicleConfig	: CM_RTVehicleConfig;
	
begin
	exclusiveLock(self);
	if pMachine = null then
		//We need a machine
		app.raiseCMException1(ERR_NO_OBJECT, "No Machine", null, null);
		return;
	endif;
	firstTask := self;

	//if IMV don't worry about overstow stuff we can't move it anyway //EPR PAR 20698 28/9/09
	sideAccessDirection:=null;

	if self.ti &lt;&gt; null and pMachine.machineType &lt;&gt; MACHINETYPE_IMV  then
	 	currentQEntry := self.myEntry;
		vehicleConfig:=pMachine.myTerminal.getRTVehicleConfigForObject(pMachine);
		if vehicleConfig.overstowMoveMode = CM_RTVehicleConfig.OSTOW_AUTOPLAN then
			if self.ti.myTerminal.isAutoPlanOverstowsUsingYA or (pMachine.machineType = MACHINETYPE_RTG or pMachine.machineType = MACHINETYPE_RMG) then
				create allOverstowedTIs transient;
				self.getAllOverstowedTIs(allOverstowedTIs,sideAccessDirection,pMachine); //EPR CCMS 1099 12/5/10 added sideAccessDirection io parameter
				if allOverstowedTIs.size &gt; 0 then
					app.myUtilityUA.utlAutoPlanOverstowedCargo(self.ti,allOverstowedTIs,self.ti.myTerminalArea,null,null,null,false,app.myPassport);
					if app.myPassport.hasErrors then
						return;
					endif;
					overstowingTI:=allOverstowedTIs.first;
					currentQEntry:=overstowingTI.getQueueEntry;
					if currentQEntry &lt;&gt; null then
						firstTask := currentQEntry.getTaskOfType(TASK_PICKUP, null);
					else
						app.raiseCMException1(Could_find_overst_move_locati,overstowingTI.id,null,null);
					endif;
				endif;
			else
				//epr TFS 37584 4/5/18
				self.ti.moveOverstowingBoxes(currentQEntry, null,pMachine,null);
				firstTask := currentQEntry.getTaskOfType(TASK_PICKUP, null);
				
			endif;
		endif;
	endif;	

	//-----------------
	//Set the reference to the machine
	//-----------------
	
	if firstTask = null then //cnwrd1 par 28407 10.10.2011
		firstTask := currentQEntry.getTaskOfType(TASK_PICKUP, TASK_USER_HELD);	//22 Apr 2015	NDL	Par 36014
	endif;
	
	if firstTask = null then
		//thow exp
		app.raiseCMException1(Err_QueueTaskUpdate, self.myEntry.id, null, null);
	endif;
	
	//epr CCMS 1395 
	if pMachine.allAllocatedQueueTasks.includes(firstTask) then
		return; //already allocated
	endif;
	

	if firstTask.intendedMachine &lt;&gt; null then
		firstTask.removeMachine();
	endif;
	
	firstTask.intendedMachine := pMachine;		//Establishes inverse with nextAllocatedQueueTask on mchine

// 	25/11/2010 cnwcs5  par 23714/ccms 1132 - start
	if _logHistory then
		pMachine.addInfoToHistory (CM_MachineInfoHistory.InfoType_Allocate_Machine, firstTask, null,null);
	endif;

	firstTask.setStatus(TASK_ALLOCATED);

	
	if currentQEntry &lt;&gt; null then
		term := currentQEntry.myQueue.getMyTerminal();
		if term &lt;&gt; null then
			app.myEventManager.createSingleObjInfoNoteEvt(currentQEntry.myQueue,term.getTerminalEvent(Event_New_Queue_Entry),currentQEntry);
		endif;
	endif;
	if _sendNote  then
		pMachine.sendBroadcastMessage("Control have ALLOCATED NEXT TASK.", false);
	endif;
	
epilog
	delete allOverstowedTIs;
end;</source>
        <Parameter name="pMachine" type="CM_Machine" usage="input"/>
        <Parameter name="_sendNote" type="Boolean"/>
        <Parameter name="_logHistory" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="assignTIConvertToDirectorTask" id="f9353a0c-2e2d-4114-9ad0-775c653d9dd1">
        <updating/>
        <source>assignTIConvertToDirectorTask(_ti : CM_TrackedItem input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2013	cnwer1	Initial creation PAR 30908

*/

vars
	control : CMIF_MoveController;
	wle : CM_WorkListEntry;
begin

	
	if self.taskType &lt;&gt; TASK_DIRECTOR then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_DIRECTOR_CONVERT, null, null);
		return;
	endif;
	//-------------------
	//OK, get directors stuff, and build moveTasks
	//-------------------
	//The director's ti is the one we are going to do the moves on...
	//it was set by RTQueueTask's "addTIToDirector" method.
	//We QUEUE move it, and adds tasks to this entry..\
	if self.ti &lt;&gt;  null then
		//already linked return
		//app.raiseCMException1(ERR_NO_OBJECT, "No TI to link to director", null, null);
		return;
	endif;
	
	self.ti:=_ti;
	//-------------------
	//Queue move the TI to the Target location
	//-------------------
	
	wle:=self.myEntry.myWorkListEntry;
	// NEED TO MAKE SURE THAT ALL THIS WORKS WITH MULTIPLE MACHINES.
	create control transient;
	control.setMoveMode(QUEUE_MODE);
	control.isSystemMove := true;
	control.myRTQueueEntry := self.myEntry;
	control.setMyTrackedItem(self.ti);
	control.setMyToPrimaryLocation(self.targetLocation);
	control.isDirectorMove := true;
	control.setMyWorkListEntry(self.myEntry.myWorkListEntry);
	
	app.myUtilityUA.utlUpdateMoveTrackedItem(control, _passport);

	if (not app.myPassport.noErrors) then
		app.convertErrorsWarningsToAlert(app.getErrorString1(Failed_Queue_Director,self.myEntry.id), _passport.allErrorWarnings);
		app.raiseCMException1(Failed_Queue_Director_Alerts, self.myEntry.id,null,null); //epr 13/3/13 not an unexpected error just failed to queue
		return;
	endif;
	
	self.ti.copyReleaseJobToTI(wle);	

	//-------------------
	//Destroy the directorTask BEFORE we create the new tasks
	//-------------------
	self.ti := null;	//Remove this ref. If we dont do this,											//then the TI gets unqueued before we get a chance to work it!!!
	//-------------
	//Leave the director task here, we may need to deassign later											
	//At this point, the director task is back to its original condition, apart from
	//being complete.
	//-------------
	
	//should have multiple director tasks on multiple entries here.
	self.myEntry.setMutliDirectorComplete();
	

epilog
	delete control;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="changeSourceForced" id="50621f92-7a85-401a-bc08-f73b15752417">
        <updating/>
        <source>changeSourceForced(_location : CM_LocationsController) updating;
//Forces the source location to change, called from within
//other code only eg overstow moves. AJA 2/12/99
vars
	newSource	: CM_LocationsController;
	origLocn	: CM_LocationsController;
	task,pickupTask		: CM_RTQueueTask;
	alert		: CM_SystemAlert;
	terminal	: CM_Terminal; 
	cargoItem   : CM_TrackedItem;
	cargoId 	: String;
	voyage      : CM_Voyage;
	voyageCode : String;
	queuedLocationId : String;
begin
	
	terminal := self.getMyTerminal();
	newSource := _location;
	if newSource = null or terminal = null then
		return;		
	endif;

	if newSource.isKindOf(CM_SlotController) then
	
		cargoItem := self.ti; // TFS# 52118 NAVLW1
		queuedLocationId := cargoItem.myPrimaryQueuedLocation.getFullSourceId(); // TFS# 52118 NAVLW1 8 Nov 2021
		voyage := newSource.CM_SlotController.myVoyage; // TFS# 52118 NAVLW1 8 Nov 2021
		
		// TFS# 52118 NAVLW1 8 Nov 2021
		if voyage &lt;&gt; null then	
			voyageCode := voyage.code;
		else 
			voyageCode := "";
		endif;
		// TFS# 52118 NAVLW1 8 Nov 2021
		if cargoItem &lt;&gt; null then
			cargoId := cargoItem.id;
		else
			cargoId := "";
		endif;
		
		app.setContinueCMExceptions(false);
		// TFS# 52118 NAVLW1 8 Nov 2021
		if (queuedLocationId = null) then
			//This errors isnt correct, but will do in the interim. DQ 02/08/2002
			app.raiseCMException(VB_SHIP_INV_SLOT, null, null);
		else
			app.raiseCMException3(Canno_moved_voyag_becau_queue_,cargoId, voyageCode, queuedLocationId, null, null); // TFS# 52118 NAVLW1 8 Nov 2021
		endif;
		return;		
	endif;

	if self.ti &lt;&gt; null and self.ti.getPrimaryLocation(REAL_MODE) &lt;&gt; newSource then
		//Hmm, there already a TI here! Invalid....
		return;		
	endif;

	//----------------
	//Whats the status of our entry?
	//----------------
	//This MUST BE UNACTIONED
	//----------------
	if self.status = TASK_COMPLETE then
		return;
	endif;
	
	//CCMS 1100 epr 10/2/10
	pickupTask:=self.myEntry.findTaskOfType(TASK_PICKUP,NULL_INTEGER);
	if pickupTask &lt;&gt; null then
		if pickupTask.machineTypeGroup = MACHINETYPEGRP_IMV then
			if not _location.isKindOf(CM_MachineController) then
				return;
			endif;
		elseif	pickupTask.machineTypeGroup = MACHINETYPEGRP_SOURCEIC or
								pickupTask.machineTypeGroup = MACHINETYPEGRP_TARGETIC  then
			//doesn't matter that the ti has changed location still expecting to pick it up from IMV or an Interchange Area
			//do not override the source location
			return;
		endif;
	endif;
	
	origLocn := self.sourceLocation;
	foreach task in relatedTasks do
		exclusiveLock(task);
		//Only change tasks for the target location
		if task.status &lt;&gt; TASK_COMPLETE then
			if task.sourceLocation = origLocn then
				task.setSourceLocation( newSource);
			endif;
		endif;
	endforeach;
	
	self.myEntry.causeEvent(terminal.getTerminalEvent(RTQueueEntry_Update_Event), false, null);
	//Par 14363 2/8/07
	self.myEntry.sendNotesForRelatedEntry();
	
	//Thats the end of it...	
	create alert;
	alert.details := "Entry's  " &amp; self.myEntry.id.trimRight &amp; " queued source location altered to " &amp; newSource.getFullId &amp; " from " ;
	if origLocn &lt;&gt; null then
		alert.details:=alert.details &amp; origLocn.getFullId &amp; " (forced)";
	endif;
	alert.setSeverity(SEVERE_INFO);
	alert.add;
end;</source>
        <Parameter name="_location" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="changeSourceLocationNextEntry" id="4cd0f941-97c5-4ae3-914d-41afef51c42a">
        <source>changeSourceLocationNextEntry(	_sourceLocation : CM_LocationsController;
								_sendBroadcastMessage : Boolean) : String protected;
/*

Purpose:		To change the source Interchange area of the next entry i.e. changing forklift to setdown in IC B then
				have to change the straddle to now pickup the container in  IC B

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2011	cnwer1	Initial creation

*/

vars
	task : CM_RTQueueTask;
	thisAlertString,sourceChangedString : String;
	sentMachineMessage : Boolean;
	nextEntry 	: CM_RTQueueEntry;
begin

	// should be going to either a source interchange area or a target interchange area
	if self.machineTypeGroup &lt;&gt; MACHINETYPEGRP_SOURCEIC and self.machineTypeGroup &lt;&gt; MACHINETYPEGRP_TARGETIC then
		return null;
	endif;
	
	nextEntry:=self.myEntry.getNextRelatedEntry(); //epr par 35702 CCMS 2457 17/2/15
	
	//check if we have next related entry if there is need to update the expected source location of that entry
	if nextEntry &lt;&gt; null then
		foreach task in nextEntry.allTasks  do
			if task.status = TASK_COMPLETE then
				break;
			endif;
			if task.ti = self.ti then
				exclusiveLock(task);	
				if thisAlertString = null then	
					sourceChangedString:=app.getErrorString1(Source_location_changed,_sourceLocation.getFullId);
					thisAlertString:=nextEntry.entryDescription &amp; sourceChangedString;
				endif;
				task.setSourceLocation(_sourceLocation);
				if task.machine &lt;&gt; null then
					//epr TFS 4620 16/6/17
					task.machine.addInfoToHistory(CM_MachineInfoHistory.InfoType_ChangeSource,task,null,null);
					if _sendBroadcastMessage and not sentMachineMessage  then
						//not immediately wait till the transaction has committed
						task.machine.sendBroadcastMessage(sourceChangedString, false);
						sentMachineMessage:=true;
					endif;	
				endif;
			endif;
		endforeach;
	endif;
	
	return thisAlertString;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_sourceLocation" type="CM_LocationsController"/>
        <Parameter name="_sendBroadcastMessage" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="changeTargetLocation" id="a809191c-bf36-48f8-9bab-4b9855b7cb84">
        <updating/>
        <source>changeTargetLocation(_moveController : CMIF_MoveController input; _sendBroadcastMessage : Boolean) updating;
//Called from the Queue window, the users have entered a location
//that they wish this move to goto. We check it out, if ok, then we
//let em do it.
/*

Date		Who		Reason
17 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					Renamed as part of refactoring methods
24 Feb 2009 cnwer1 CCMS 1032 - added _sendBroadcast message parameter. We don't always want this note sent especially if
								we change the location the complete the task in the same transaction. And if called from a
								trx in mobile server schema we are the ones changing the location so the message is pointless
31 Jan 2011 cnwer1 	PAR 26495 - Messina with multi machine queued items if we change the target location may have to change the 
								previous entries source location. Also if they change a tasks interchange target location need to change
								the next entries source location
13 Sep 2021	navdap1	TFS 51941 MTN Driver Mode creating Incomplete edit transaction when doing setdown
20 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
*/

vars
	lcs : CM_LCSet;
	origLocn			: CM_LocationsController;
	task				: CM_RTQueueTask;
	alert				: CM_SystemAlert;
	origLocnID,theAlertString,thisAlertString	: String;
	thisMachine 		: CM_Machine;
	nextTask			: CM_RTQueueTask;
	futureMovePlanned	: CM_FutureMove;
	futureMoveQueued	: CM_FutureMoveQueued;
	qFM : CM_FutureMoveQueued;
	terminal			: CM_Terminal;
	lastTask : CM_RTQueueTask;				// TFS 51941

begin

	// PAR 18970
	create lcs transient;
	if self.myEntry.myWorkListEntry.myFutureMove.isKindOf(CM_FutureMoveQueued) then
		qFM := self.myEntry.myWorkListEntry.myFutureMove.CM_FutureMoveQueued;
	endif;
	

	//epr par 25285
	if (not self.isOverstowTaskAuto and self.isOverstowTask) or not self.isOverstowTask then
		//futureMoveQueued := self.ti.getFutureMoveOfType(_moveController.moveMode, TI_FutureMoveQueued);
		futureMoveQueued:=qFM.CM_FutureMoveQueued;
	else
		futureMoveQueued := self.ti.getFutureMoveOfType(_moveController.moveMode, TI_FutureMoveOverstow).CM_FutureMoveQueued;			
	endif;

	
	//cnwrd1 par 27551 16.5.2011
	if futureMoveQueued &lt;&gt; null then
		futureMoveQueued.allLocationsControllers.copy(lcs);
	endif;	
	
	
	if self.targetLocation.isKindOf(CM_MachineController) and self.taskType = TASK_PICKUP then
		nextTask := getNextMachineTask();
		if nextTask = null then
			origLocn := self.targetLocation;		//(Should never happen, but is reasonably harmless)
			origLocnID:=self.targetLocationId;
		else
			//So the original target location of the move is the target of the set down task	
			origLocn := nextTask.targetLocation;
			origLocnID:=nextTask.targetLocationId;
		endif;
	else
		origLocn := self.targetLocation;
		origLocnID:=self.targetLocationId; //epr CCMS 1099 origLocn can be null i.e. to be autoplanned or to an IMV
	endif;
		
	foreach task in relatedTasks do
		exclusiveLock(task);
		if task.ti = self.ti then
			//Only change tasks for the target location
			if task.status &lt;&gt; TASK_COMPLETE then
				if task.targetLocation = origLocn then
					// get the description of entry before we change the target
					if theAlertString = null and _moveController.myToPrimaryLocation &lt;&gt; null then //epr par 34634 3/9/14 myToPrimaryLocation can be null
						lastTask := self.myEntry.getDirectorOrSetDownTask;					// TFS 51941
						if lastTask &lt;&gt; null and lastTask.targetLocation = null then			// TFS 51941
							task.setTargetLocation(	_moveController.myToPrimaryLocation);	// TFS 51941
						endif;																// TFS 51941
						theAlertString:=  self.myEntry.entryDescription  &amp; app.getErrorString1(Target_location_changed, _moveController.myToPrimaryLocation.getFullId);
					endif;
					task.setTargetLocation(	_moveController.myToPrimaryLocation);
				endif;
				//PAR 3296 AJA 17/1/00: Get the machine for this set of tasks
				if thisMachine = null and task.machine &lt;&gt; null then
					thisMachine := task.machine;
				endif;			
			endif;
		endif;
	endforeach;
	
	
	/*31/1/2011 epr par 26495 check if we have next related entry if there is need to update the expected source location of the previous entry
		if no next related entry - we know that this is the final target being set
		only reset the ti's future locations and queued future moves location in this case
		- if we do this when changing a interchange area when it gets set down in that interchange area it causes the wle to get completed
		
	*/
	//epr par 35702 CCMS 2457 17/2/15
	if self.myEntry.getNextRelatedEntry() = null then
		
		if  futureMoveQueued &lt;&gt; null then
			
			futureMovePlanned:= futureMoveQueued.myFutureMovePlanned;
					
			futureMoveQueued.resetLocations(_moveController);
			ti.refreshMyFutureLocations(QUEUE_MODE,null);
			//epr par 32256 change planned location aswell so this is tidied up
			if	futureMoveQueued.myFutureMovePlanned &lt;&gt; null then
				ti.refreshMyFutureLocations(PLANNING_MODE,null);
			endif;
		endif;
		
		thisAlertString:=self.changeTargetLocationPrevEntry(_moveController.myToPrimaryLocation,_sendBroadcastMessage);
		if thisAlertString &lt;&gt; null then
			theAlertString:=thisAlertString &amp; CrLf &amp; theAlertString;
		endif;
	else
		// if there is a next related entry we should be changing the interchange area
		thisAlertString:=self.changeSourceLocationNextEntry(_moveController.myToPrimaryLocation,_sendBroadcastMessage);
		if thisAlertString &lt;&gt; null then
			theAlertString:=theAlertString &amp; CrLf &amp; thisAlertString;
		endif;
	endif;	
	
	// PAR #18743 - Notify Queue form that my entry needs refresshing
	terminal := self.myEntry.myQueue.getMyTerminal();
	
	//10 July 2014	NDL	Par 34137 - Edit trx with no details
	if theAlertString = null then
		theAlertString := app.getErrorString1(Target_location_changed, "null");
		if self.ti &lt;&gt; null then
			theAlertString := theAlertString &amp; " [cargo id = " &amp; self.ti.id &amp; "]";
		endif;
	endif;

	if self.alertRequired(origLocn) then							// 03/11/2010 cnwmh5 #26186
		create alert;
		alert.details :=theAlertString;
		alert.setSeverity(SEVERE_INFO);
		alert.myTerminal := terminal;
		alert.add;
	endif;
	
	//regardless of whether the alert is sent create the edit transaction
	if self.ti &lt;&gt; null then
		app.createEditTransaction(self.ti,theAlertString,null,_moveController.myPassport); // AKB2003DEC added			//20.02.2024 navhl20 #62525
		
		//epr par 37225 26/11/15
		self.ti.unsetTaskSystemHeldStatus();
		
		
	endif;
	self.myEntry.causeEvent(terminal.getTerminalEvent(RTQueueEntry_Update_Event), false, null);
	
	//epr 21/4/10 CCMS 1099 need to know when target source changes for related entries
	self.myEntry.sendNotesForRelatedEntry();
	
	//3296: Now tell the machine that his task has changed
	if thisMachine &lt;&gt; null then
		//epr par 33401 19/2/14
		thisMachine.causeEvent(Event_Machine_Target_Changed,false,self.myEntry);
		//epr TFS 4620 Vehicle App changes 17/6/17
		thisMachine.addInfoToHistory(CM_MachineInfoHistory.InfoType_ChangeTarget,  self,null,null);
	endif;
	
	_moveController.doUpdateDisplayEvent(_moveController.myToPrimaryLocation);
 	// PAR 18970_moveController.doUpdateDisplayEvent(origLocn);
	
	// PAR 18970 now
	if not lcs.isEmpty() then
		foreach origLocn in lcs discreteLock do
			_moveController.doUpdateDisplayEvent(origLocn);
		endforeach;
	else
		_moveController.doUpdateDisplayEvent(origLocn);
	endif;
epilog
	delete lcs;
end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_sendBroadcastMessage" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="changeTargetLocationPrevEntry" id="e49e3d05-162f-4466-a3d7-1091f94bc9c8">
        <source>changeTargetLocationPrevEntry(	_targetLocation : CM_LocationsController;
								_sendBroadcastMessage : Boolean) : String protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2011	cnwer1	Initial creation

*/

vars
	task : CM_RTQueueTask;
	theAlertString, targetChangedString : String;
	sentMachineMessage : Boolean;
	prevEntry 	: CM_RTQueueEntry;
begin
		
	prevEntry:=self.myEntry.getPreviousRelatedEntry(); //epr par 35702 CCMS 2457 17/2/15

	// 31/1/2011 epr par 26495 check if we have next related entry if there is need to update the expected source location of that entry
	if prevEntry &lt;&gt; null  then
		//epr par 29301 12/4/2012 if the targe is a machine then return leave the target as null to be worked out 
		if prevEntry.isTargetAMachine then
			return null;
		endif;
	
		foreach task in prevEntry.allTasks reversed do
			if task.status = TASK_COMPLETE then
				break;
			endif;
			if task.taskType = TASK_MOVE or task.taskType = TASK_SETDOWN then
				if task.machineTypeGroup = MACHINETYPEGRP_TARGETIC or
					task.machineTypeGroup = MACHINETYPEGRP_SOURCEIC then
					break;
				endif;
			endif;
			if task.ti = self.ti then
				exclusiveLock(task);	
				if theAlertString = null then	
					targetChangedString:=app.getErrorString1(Target_location_changed, _targetLocation.getFullId);
					theAlertString:=prevEntry.entryDescription &amp; targetChangedString ;
				endif;
				task.setTargetLocation(_targetLocation);
				if  not sentMachineMessage and task.machine &lt;&gt; null then
					//not immediately wait till the transaction has committed
					//epr par 33401 19/2/14
					task.machine.causeEvent(Event_Machine_Target_Changed,false,prevEntry);
					sentMachineMessage:=true;
				endif;	
				
			endif;
		endforeach;
	endif;
	
	return theAlertString;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
        <Parameter name="_sendBroadcastMessage" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="checkAssignBestPickTIToWLE" id="7000db9d-50eb-4e97-a61d-33e9a788f97f">
        <source>checkAssignBestPickTIToWLE() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 Nov 2011	cnwrd1	Initial creation
04 Mar 2025 navma1	MTN - [Performance Issue] - 1081 with multiple gate in/gate out processes running
*/

vars
	queueEntry : CM_RTQueueEntry;
begin
	
	queueEntry := self.myEntry;															//04.03.2024 navma1	MTN-33569
	
	if not queueEntry.myQueue.getMyTerminal().isAutoPlanUseBestPickDirector then		//04.03.2024 navma1	MTN-33569
		return false;
	endif;
	
	if queueEntry.myWorkListEntry.myTrackedItem &lt;&gt; null then							//04.03.2024 navma1	MTN-33569
		return false;
	endif;
	
	if self.isFirstTask then		 //only want to assign a ti on the first task!?
		return true;
	else
		return false;
	endif;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkVoyageOutOfOrderLoad" id="b9a59bff-793b-4ebb-a1c3-85997c5514a5">
        <updating/>
        <source>checkVoyageOutOfOrderLoad() : String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 October 2012	cnwrd1	Initial creation

*/

vars
	voyageCraneQueue : CM_VoyageCraneQueue;
	workPointQueue 	: CM_VoyageWorkPointQueue;
	aJob 			: CM_Job;
	voyageJob		: CM_VoyageJob;
	request 		: CM_VoyageRequest;
	slots			: ObjectArray;
	foundLocation	: CM_LocationsController;
begin
	if self.targetLocation = null then
		return null;
	endif;
	
	aJob := self.myEntry.myJob;
	
	if not aJob.isKindOf(CM_VoyageJob) then // only for voyage jobs
		return null;
	endif;
	
	voyageJob := aJob.CM_VoyageJob;
	
	//epr par 33070 30/12/13
	if voyageJob.isDischarge then
		return null;
	endif;
	
	if not voyageJob.allowOutOfOrderLoading then //only resequence if we are allowed
		return null;
	endif;
	
	
	//check if we are using the lander app , if so we dont want to resequence here
	if self.targetLocation.isKindOf(CM_SlotController) then
		voyageCraneQueue:= self.getVoyageCraneQueue;
		if voyageCraneQueue &lt;&gt; null and voyageCraneQueue.loadMachinesMode =CM_VoyageCraneQueue.UseShipLanderApp then
			return null;
		endif;
	endif;
	//and for workpoints
	if self.targetLocation.isKindOf(CM_VoyageROROController) then
		workPointQueue:= self.getVoyageWorkPointQueue;
		if workPointQueue &lt;&gt; null and workPointQueue.loadMachinesMode =CM_VoyageCraneQueue.UseShipLanderApp then
			return null;
		endif;
	endif;
	
	// ok if we are here we want to look at where we are being loaded and what the next empty slot on the jobs sequence is.
	create slots transient;
	voyageJob.getEmptySlotLocIDInSequence(slots);

	if slots.isEmpty then //shouldnt be but..
		return null;
	endif;
	//first in the list should be the one we want.
	
	foundLocation := slots.first.CM_LocationsController;
	
	if self.targetLocation &lt;&gt; foundLocation and foundLocation &lt;&gt; null then
		self.setTargetLocation(foundLocation);
		return foundLocation.getFullId();
	endif;
	
	return null;
	
epilog
	delete slots;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="completeReplacedNextRelated" id="9eaf93c2-79a3-4b6b-9368-ca7f653a0afb">
        <source>completeReplacedNextRelated();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2020	jlgndl1	Initial creation	TFS 49174/48549
					Twin Lift Director task for multi machine move still need to sort out the other related legs.

*/

vars

	entry : CM_RTQueueEntry;
	nextEntry : CM_RTQueueEntry;
	nextDirTask : CM_RTQueueTask;
	replacementTask : CM_RTQueueTask;

begin

	entry := self.myEntry;
	if entry &lt;&gt; null then
		nextEntry := entry.myNextRelatedEntry;
		if nextEntry &lt;&gt; null then
			nextDirTask := nextEntry.getFirstUncompletedTaskOfType( TASK_DIRECTOR );	// the original director task for the subsequent leg of the move
			replacementTask :=  nextEntry.getFirstUncompletedTaskOfType( TASK_MOVE );  // one just created and linked to the ti to replace the nextDirTask
			if replacementTask = null then
				replacementTask :=  nextEntry.getFirstUncompletedTaskOfType( TASK_PICKUP );
			endif;
			if nextDirTask &lt;&gt; null and nextDirTask.ti = null and replacementTask &lt;&gt; null and replacementTask.ti &lt;&gt; null then
				nextDirTask.setStatusComplete();
				nextDirTask.completeReplacedNextRelated();  // and potentially downstream again...
			endif;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="cc320cde-3128-4608-94ae-40e9bf5ce0b6">
        <updating/>
        <source>create() updating;
//Constructor
vars

begin
	//-----------
	//Set the current backupstatus to null value
	//-----------
	statusToRestoreTo := TASK_NULL;
end;</source>
    </JadeMethod>
    <JadeMethod name="createEditTransaction" id="0a3cd402-cc4d-4d7b-8f99-1a403ab582be">
        <source>createEditTransaction(_theTI : CM_TrackedItem input;_details : String; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	txnParams : CMIF_TITransactionController;
	trans : CM_Edit;
	userStr : String;
begin
	if _passport = null then
		return;
	endif;
	if _theTI = null then
		return;
	endif;
	
	if _details = null then
		return;
	endif;

	if _passport.userCode = null then
		userStr := app.getErrorString(UnknownUser);
	else
		userStr := _passport.userCode;
	endif;
	create txnParams transient;
	txnParams.userId := userStr;
	txnParams.dateTime := app.serverTimestampAtTrxStart;
	txnParams.noCharge := false; //TFS 3844 changed to false
	txnParams.type := TRANS_TYPE_EDIT;
	//------------------
	//Create the edited transaction
	//------------------
	trans := _theTI.createTransaction(txnParams, _passport).CM_Edit;
	trans.fieldsValues.add(_details);
epilog
	delete txnParams;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_details" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="deleteTask" id="a00993bd-835d-4fb2-b973-7405046633a7">
        <updating/>
        <source>deleteTask() : Boolean updating;
//Called from the Entry, nukes us, removes our references etc as needed.
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
15 Jul 2010	cnwdap1	PAR #25021 - review use of isImport/isExport for tranships
14 Mar 2011	cnwkpd1	PAR #27142 - Correct handleDeletedObject exception arming
29 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
12 Mar 2015 cnwmc5	PAR 35309 - Removed validation to check if task is Complete or Unactioned before deleting
17 Aug 2020 cnwma1  Bug 49923: Problems to delete 3 tasks queued from the Radio Telemetry Queue
*/

vars
	task			:	CM_RTQueueTask;
	runStatus		: Integer;
	controller1,
	controller2		: CM_LocationsController;
	invalidMachine,
	invalid 		: Boolean;
	id				: String;
	lMoveControl	: CMIF_MoveController;
	theTI 			: CM_TrackedItem;
	edition         : Integer;
	mach	        : CM_Machine;
begin
	//JLGNS1 17/12/2019	ChangeRequest 47394: PNL - Tandem Move Enhancements
	on Exception do app.handleDeletedObject(exception,task,invalid);	
	on Exception do app.handleDeletedObject(exception,mach,invalidMachine);	            //17.08.2020 cnwma1 #49923
	
	//if status &lt;&gt; TASK_COMPLETE and status &lt;&gt; TASK_UNACTIONED and status &lt;&gt; TASK_HELD then
	//AJA 06/01/00: Prevent users deleting any task by setting it to held !
	//To delete a held task, it must be OK to delete it if it were running
	exclusiveLock(self);
	
	if status = TASK_USER_HELD 
	or status = TASK_SYS_HELD then	// 16/04/2013 cnwar2 #31436
		runStatus := self.statusToRestoreTo;
	else
		runStatus := self.status;
	endif;
	
	// cnwmc5 - 12 March 2015 - PAR 35309 - see PAR for more details..
	//if not app.isSpecial then
	//	if runStatus &lt;&gt; TASK_COMPLETE and  runStatus &lt;&gt; TASK_UNACTIONED then	
	//		app.setContinueCMExceptions(false);
	//		app.raiseCMException1(ERR_TASK_STATUS, taskTypeId &amp; " for " &amp; tiId, null, null);
	//		return false;
	//	endif;
	//endif;

	//-------------
	//Remove references
	//-------------
	
	 //epr TFS 3272 changed queue while working a task
	if self.myMachine &lt;&gt; null then                         //13.08.2020 cnwma1 TFS #49906
		mach	:= self.myMachine;
		edition := mach.edition;
	endif;

	if not invalidMachine then								//13.08.2020 cnwma1 TFS #49906
		if mach &lt;&gt; null
		and  self.myEntry.myQueue &lt;&gt; null
		and mach.myPrimaryQueue &lt;&gt; null	//12 Aug 2020	NDL	TFS 49894
		and mach.myPrimaryQueue &lt;&gt; self.myEntry.myQueue
		then
			app.myEventManager.createSingleObjInfoNoteEvt(mach.myPrimaryQueue,getMyTerminal.getTerminalEvent(Event_Delete_Queue_Entry),self.myEntry);
		endif;
	endif;
	
	self.setMachine(null);
	

	//Queue has no back reference to us...

	foreach task in relatedTasks do
		if task &lt;&gt; self then
			exclusiveLock(task);
			if task.relatedTasks.includes(self) then
				task.relatedTasks.remove(self);
			endif;
		endif;
	endforeach;
	//source/TargetLocation have no back references to us..
	//Ti has a back reference to Queue ONLY.
	if ti &lt;&gt; null then
		theTI:=self.ti; //epr par 34257 16/6/14
		on Exception do app.handleDeletedObject(exception, theTI, invalid);
		id := ti.id;		// PAR @27142 - dereference ti to check it's valid
		if not invalid then
			//-------------------------------------------------------
			// ti.location &lt;&gt; null test was added by stg 22 feb to prevent 1090 when deleting ship tasks that
			// had gone off site.
			//-------------------------------------------------------
			if 	self.taskType = TASK_SETDOWN 
			and	self.status = TASK_COMPLETE then
				controller1 := self.ti.getPrimaryLocation(REAL_MODE);
				controller2 := self.ti.getPrimaryLocation(QUEUE_MODE);
				if controller1 &lt;&gt; null 
				and controller1.myTerminalArea &lt;&gt; null 
				and controller1.myTerminalArea.isA(CM_CraneTransferArea) 
				and	controller2 &lt;&gt; null 
				and controller2.isA(CM_SlotController) then
					if (self.ti.isExport or self.ti.isTranshipOutbound) then		// PAR #25021
						// Box is not on the boat.
						return false;
					endif;
				endif;
	
			endif;
	
			ti.updateObjectEdition(ti);	// par 30292
		endif;
	endif;
	//--------------
	//Remove parent reference
	//--------------
	self.setMyEntry(null);
	//--------------
	//OK, destroy ourselves
	//--------------

	delete self;
	return true;
epilog
	delete lMoveControl;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="executeMove" id="9667e0b0-f82a-4707-b95c-e9f5e9092daa">
        <updating/>
        <source>executeMove( inFlags : Integer; _passport : CM_Passport input) updating;
//Called from the Completion method here, does the actual move!

vars
	shipLC : CM_LocationsController;
	rjob : CM_RailJob;
	control : CMIF_MoveController;
begin
	//--------------
	//Store off the planned location
	//--------------
	if self.taskType = TASK_PICKUP then
		if not self.targetLocation.isKindOf(CM_MachineController) then
			//-----------------
			//Completing a pickup task, but the box is NOT going to a machine.
			//They must be manually completing. The move WILL blatt the planned
			//location, as its going direct to the ship. (if its a ship job)
			//-----------------
			shipLC := ti.getPrimaryLocation(PLANNING_MODE);
		endif;
	elseif self.taskType = TASK_SETDOWN then
		shipLC := ti.getPrimaryLocation(PLANNING_MODE);
	endif;
	//-----------------
	//Do the move
	//-----------------
	create control transient;
	control.setMyToPrimaryLocation(self.targetLocation);
	control.setMoveMode(REAL_MODE);
	control.setMyTrackedItem(self.ti);
	control.setJobForMove(self.myEntry.myJob);	
	control.setMyWorkListEntry(self.myEntry.myWorkListEntry);				
	control.setMyMachine(self.machine);
	control.isSystemMove := true;
	control.isOverstowMove := self.isOverstowTask;
	control.executeMove(_passport);

	//The cleanup of the queued and planned moves is done from C++
	//by calling  ti.doMoveCleanup();

  //PAR 3329 AJA 31/1/00: Do not unplan DLRs when doing an overstow move !
	if not self.isOverstowTask then // rs22/08/2000 was mediator.task
		if self.myEntry.myJob.isKindOf(CM_VoyageJob) then
			//------------------------
			//Irrespective of the task type, do the transaction processing
			//This arises because the users manually complete the PICKUP task from
			//the Queue window. (douh!) The shipLC will be null in one of the
			//circumstances, thereby not actually doing anything!
			//------------------------
			if self.myEntry.myJob.CM_VoyageJob.isDischarge = false then
				//------------------
				//Move the box to the ship if this is a load job
				//------------------
				control.setMyToPrimaryLocation(shipLC);
				control.setMoveMode(REAL_MODE);
				control.setMyTrackedItem(self.ti);
				control.setMyMachine(self.machine);
				control.isSystemMove := true;
				control.isOverstowMove := self.isOverstowTask;
				control.executeMove(_passport);
			endif;
		endif;

		if self.myEntry.myJob.isKindOf(CM_RailJob) then
			//------------------------
			//Undo any queued moves to the RTA if placed on a Wagon Controller
			//This should please andrea! STG 07 Apr 2000
			//------------------------
			rjob := self.myEntry.myJob.CM_RailJob; // rs22/08/2000 was mediator.task
			if ti.getPrimaryLocation(REAL_MODE).isKindOf(CM_WagonController) and rjob.isRelease then
				//------------------
				//Move the box to the ship if this is a load job
				//------------------
				//flags := flags.bitOr(MP_RT_AUTOPLAN );
				//flags := flags.bitOr(MP_RT_IGNORE_WARNINGS );
				//ti.undoQueuedMove(flags, false);
				create control transient;
				control.setMoveMode(QUEUE_MODE);
				control.setMyTrackedItem(self.ti);
				control.executeUndoMove(_passport);
			endif;
		endif;

	endif;		//overstow task
epilog
	delete control;
end;</source>
        <Parameter name="inFlags" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="formatLocationExtraInfo" id="93c66d2b-230a-4487-8051-079f543b237c">
        <source>formatLocationExtraInfo(_nextTarget : CM_TerminalArea; _finalTarget : CM_LocationsController) : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/08/2011	cnwdap1	Initial creation PAR #28047 CCMS POL 2095
06 Mar 2025  navma1 MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/
vars
	str					: String;
	finalTargetTermArea	: CM_TerminalArea;
begin
	
	finalTargetTermArea := _finalTarget.myTerminalArea;
	
	if finalTargetTermArea = null then
		if CM_VehicleController.hasInstance(_finalTarget) then
			return _nextTarget.id &amp; " (" &amp; _finalTarget.CM_VehicleController.getID &amp; ")";
		else
			return _nextTarget.id;
		endif;
	endif;

	// Start with the terminal area's description
	str := _nextTarget.id;
	
	if finalTargetTermArea.type = TA_TYPE_FORK_LIFT_STACK then
		str := str &amp; " (";
		// For gridded block stacks, terminal area and bay will be displayed
		str := str &amp; finalTargetTermArea.id &amp; " ";
		if finalTargetTermArea.CM_GridArea.areLocationIdsColThenRow then
			str := str &amp; _finalTarget.CM_GridController.myGridColumn.label;
		else
			str := str &amp; _finalTarget.CM_GridController.myGridRow.label;
		endif;
		str := str &amp; ")";	
	elseif finalTargetTermArea.type = TA_TYPE_BLOCK_STACK then
		// For block and sub-block stacks, just the terminal area will be displayed
		str := str &amp;  " (" &amp; finalTargetTermArea.id &amp; ")";
	endif;
	
	return str;
epilog

end;</source>
        <Parameter name="_nextTarget" type="CM_TerminalArea"/>
        <Parameter name="_finalTarget" type="CM_LocationsController"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAVGradeDesc" id="cdf1995f-5c71-4ce3-89ec-5733176f0358">
        <source>getAVGradeDesc() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Dec 2021	jlier1	Initial creation 52595
*/

vars

	wle 		: CM_WorkListEntry;
	request  	: CM_Request;
begin

	if self.ti &lt;&gt; null then
		if self.ti.canSetAvailabilityGrade then
			return self.ti.getAvailabilityGradeDesc;
		endif;
	else
		wle:=self.myEntry.myWorkListEntry;
		if wle &lt;&gt; null then
			request :=wle.myRequest;
			if request &lt;&gt; null then
				return request.getAVGrade();
			endif;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllOtherTIs" id="5bec9035-54e7-428d-afde-0669be8cc4ca">
        <source>getAllOtherTIs(_tiColl : CM_TISet input)protected;
//--------------------------------------------------------------
//Created: 29 May 2002 By: cnwgd1
//--------------------------------------------------------------
//if self.ti is being used as a master ti on a bol then allTrackedItems on the bol will need updating
vars
	tmpTI : CM_TrackedItem;
	bol : CM_BOL;
	coll	: Collection;
	obj		: Any;
begin

	if self.myEntry &lt;&gt; null and self.myEntry.myWorkListEntry &lt;&gt; null and self.myEntry.myWorkListEntry.myBOL &lt;&gt; null then
		bol := self.myEntry.myWorkListEntry.myBOL;
		coll := bol.getTICollectionForTerminal(self.myEntry.myWorkListEntry.myRequest.myTerminal);
		//foreach tmpTI in bol.allTrackedItems do
		foreach obj in coll do
			tmpTI := obj.CM_TrackedItem;
			if tmpTI &lt;&gt; self.ti then
				_tiColl.add(tmpTI);
			endif;
		endforeach;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_tiColl" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllOverstowedTIs" id="baed09fd-3218-49c5-90bf-b45c8b7e97b8">
        <source>getAllOverstowedTIs(_allOverstowedTIs 		: CM_TIArray input;
					_sideAccessDirection	: Integer io;
					_machine 				: CM_Machine);
/*
Purpose:	Based on method isOverstowedRTQueue - basically a copy but doesn't break when it finds the first overstowed ti
			adds it to the passed in collection

Parameters:			

Return Value:		

Date		Who		Reason
21/12/2009	cnwer1	Initial creation
25/05/2010	cnwdap1	CCMS 1116 Tranship changes
07/05/2018 	jlger1	TFS 37584 reach stacker overstow changes
16/10/2024 	navma1	MTN-33090 MTN - Error 1239 when calling MTNInternalAPIService::getTasks
*/
vars

	overstowController 		 : CMIF_OverstowController;
	pimaryActualLocation	 : CM_LocationsController;
begin
	
	if self.ti = null then
		return;
	endif;
	
	pimaryActualLocation := self.ti.myPrimaryActualLocation;		//16.10.2024 navma1 #MTN-33090		
	
	if pimaryActualLocation = null then
		return;
	endif;
	
	if not pimaryActualLocation.isGridLocation then
		return;
	endif;
	//epr TFS 37584 4/5/18
	create overstowController transient;
	overstowController.setParams(_sideAccessDirection,self.ti,true,self.myEntry,_machine);
	overstowController.getAllOverstows();
	
	_sideAccessDirection := overstowController.accessDirection;
	overstowController.allOverstowTIs.copy(_allOverstowedTIs);

epilog
	delete overstowController;

end;</source>
        <Parameter name="_allOverstowedTIs" type="CM_TIArray" usage="input"/>
        <Parameter name="_sideAccessDirection" type="Integer" usage="io"/>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="getAreaIsTarget" id="da25e1a9-1aa6-4f81-8838-454a00cbb860">
        <source>getAreaIsTarget() :Boolean protected;
/*

Purpose:	If RTG or RMG we only care about the source if we are picking up from the source
			like wise we only care about the target when we are picking up from the imv/truck and setting down in 
			the target

Parameters:			

Return Value:		


Date		Who		Reason
10 Sep 2009	cnwer1	Initial creation
19 Feb 2010 cnwer1	PAR 27065 - wasn't checking workzones if the target was the truck
*/

vars
	target : CM_LocationsController;
begin

	if self.myEntry = null then
		return true;
	endif;
		
	
	if self.myEntry.machineTypeGroup &lt;&gt; MACHINETYPEGRP_RTG 	then
		return true;
	endif;
	
	//epr par 27065 19/2/2011
	//its an RTG move if no previous or next entry we must be picking up from a truck or setting down to a truck
	if  not self.myEntry.isMultiMachineMove then
			target:=self.myEntry.getTargetLocation;
		// if target is a truck then return true 
		if target &lt;&gt; null and target.isKindOf(CM_VehicleController) then
			return true;
		else
			return false;
		endif;
	
	endif;
	
	//if next related entry then this is the set down in the target area
	// set to false so we check terminal area access
	if self.myEntry.getNextRelatedEntry() = null then //epr par 35702 CCMS 2457 17/2/15
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCargoSubTypeDesc" id="fcb8a7cb-9f33-4bbe-a572-2eff60ac3d5e">
        <source>getCargoSubTypeDesc() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Dec 2021	jlier1	Initial creation 52595
 
*/

vars

	wle 		: CM_WorkListEntry;
	request  	: CM_Request;
	cargoSubType 	: CM_Product;
begin

	if self.ti &lt;&gt; null then
		return self.ti.getCargoSubTypeDescr();
	else
		wle:=self.myEntry.myWorkListEntry;
		if wle &lt;&gt; null then
			request :=wle.myRequest;
			if request &lt;&gt; null  then
				cargoSubType:= request.getCargoSubType;
				if cargoSubType &lt;&gt; null then
					 return cargoSubType.description;
				endif;
			endif;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCargoTypeDesc" id="52332525-85a9-4725-b6c9-1d5a52da3edc">
        <source>getCargoTypeDesc() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Dec 2021	jlier1	Initial creation 52595

*/

vars
	wle 		: CM_WorkListEntry;
	request  	: CM_Request;
	cargoType 	: CM_CargoType;
begin

	if self.ti &lt;&gt; null then
		return self.ti.cargoTypeDescr;
	else
		wle:=self.myEntry.myWorkListEntry;
		if wle &lt;&gt; null then
			request :=wle.myRequest;
			if request &lt;&gt; null  then
				cargoType:= request.getCargoType;
				if cargoType &lt;&gt; null then
					 return cargoType.description;
				endif;
			endif;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCarrier" id="40c5cd66-023e-4301-8443-7e1b7c7f77dd">
        <source>getCarrier() : String;
/*

Date		Who		Reason
21 Jun 2017	cnwer1	Initial creation TFS
25 Aug 2022 jlier1 TFS 54490 
16 Oct 2024 navma1	MTN-33090 MTN - Error 1239 when calling MTNInternalAPIService::getTasks
*/

vars
	job 		: CM_Job;
	relCarrier  : CM_Carrier;
	carrierCode : String;
begin
	job := self.myEntry.myJob;
	
	if job.isRoadJob then
		if job.CM_RoadJob.isRelease then
			relCarrier := job.CM_RoadJob.myCarrier;
			if relCarrier &lt;&gt; null then
				carrierCode := relCarrier.code;
			else
				carrierCode := job.CM_RoadJob.carrierId;
			endif;
		endif;
	endif;
	
	if carrierCode = null and self.ti &lt;&gt; null then
		carrierCode:= self.ti.carrier;
	endif;
	
	if carrierCode &lt;&gt; null then										//16.10.2024 navma1 #MTN-33090						
		if app.myRoot.getConfig(CarrierCmbOrdDescr).Boolean then  
			relCarrier := app.myRoot.allCarriers[carrierCode];
			if relCarrier&lt;&gt; null then
				return relCarrier.description;
			endif;
		endif;
	endif;
	
	return carrierCode;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getColour" id="b4c8ab3d-2bfb-4a87-af9b-c04e182088ef">
        <source>getColour() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Dec 2021	jlier1	Initial creation 52595

*/

vars
	wle 		: CM_WorkListEntry;
	request  	: CM_Request;
begin

	if self.ti &lt;&gt; null then
		return self.ti.getColour;
	else
		wle:=self.myEntry.myWorkListEntry;
		if wle &lt;&gt; null then
			request :=wle.myRequest;
			if request &lt;&gt; null and request.isDeliveryRequest then
				return request.CM_DeliveryRequest.colour;
			endif;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getConsignee" id="9662a0ad-b82a-4042-a7fb-6af8bf54c0c1">
        <source>getConsignee(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2022	jlier1	Initial creation TFS 54490

*/

vars
	consignee : CM_ConsigneeConsignor;
begin
	if self.ti &lt;&gt; null and  ti.consignee &lt;&gt; null then
		if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then  
			consignee := ti.getConsigneeObject();
			if consignee &lt;&gt; null then
				return consignee.description;
			endif;
		else
			return ti.consignee;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
