    <JadeMethod name="utlQueueOnsiteMAFIsToVoyage" id="445494ef-21c9-4985-98f5-df50031103fc">
        <source>utlQueueOnsiteMAFIsToVoyage(_voyage : CM_Voyage; _passport : CM_Passport input);
/*

Purpose:			Queue all onsite export MAFIs that are cleard of all stops and not currently planned or queued

Parameters:			_voyage: the voyage to queue for

Return Value:		

Date				Who		Reason
29 September 2022	jlizm1	Initial creation TFS 54702 CUX MAFI Auto Queueing

*/

vars
	iter 	: Iterator;
	ti 		: CM_TrackedItem;
	moveController: CMIF_MoveController;
	
begin

	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_voyage, app.getErrorString(Voyage));
	
	iter := _voyage.allOnsiteTIsByCargoTypeId.createIterator;
	
	while iter.next(ti) do
		if ti.isMAFI and ti.isExport then
			if ti.myPrimaryPlannedLocation = null and ti.myPrimaryQueuedLocation = null then
				if not ti.CM_TILC.hasStopsForOnboardTIs() then

					delete moveController;
					create moveController transient;
					moveController.setMyTrackedItem(ti);
					moveController.setMyToPrimaryLocation(_voyage.myShipBlockStack);
					moveController.setMoveMode(QUEUE_MODE);
					app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, app.myPassport);
					
				endif;
			endif;
		endif;
	endwhile;
	
epilog

	delete moveController;
	delete iter;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlQueueOverstowCargoToICArea" id="a6827f89-b66c-4846-bcee-7cfae8966e07">
        <source>utlQueueOverstowCargoToICArea(	_ti : CM_TrackedItem input;
								_allOverstowedCargo : CM_TIArray input;
								_interchangeArea : CM_InterchangeArea input; 
								_laneID : Integer;
								_tryToMoveExisting : Boolean;
								_passport : CM_Passport input);
/*

Purpose:			

Parameters:			_tryToMoveExisting if this is set before it does any overstow autoplanning it will try and
					see if moving any existing rt queue entries will solve the overstow problem. I realise this is always
					false at the moment but left as parameter because in future we may want to do this

Return Value:		


Date		Who		Reason
07 Jan 2010	cnwer1	Initial creation
14 Sep 2010 cnwer1  Par 25285
09 Nov 2010	cnwkpd1	PAR #26113 - Send event to ITS Queue Monitor if successful 

*/

vars
	yardICLaneController: CM_LaneController;
	gridRow				: CM_GridRow;
	moveController		: CMIF_MoveController; 
	laneID				: Integer;
	rtQueueEntry,
	qEntry				: CM_RTQueueEntry;
	allRestrictingLCs	: CM_LCSet;
	iter				: Iterator;
	ti 					: CM_TrackedItem;
	futureMove			: CM_FutureMove;
	futureQueuedMove	: CM_FutureMoveQueued;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_ti,app.getErrorString(Cargo));
	self.raiseExceptionIfNull(_interchangeArea,app.getErrorString(Interchange_area));
	laneID:=_laneID;
	if _interchangeArea.laneCount &gt; 0 then
		if  laneID &gt; _interchangeArea.laneCount then
			app.raiseCMException2(Invalid_lane_IC_Area,laneID.asStringJMT,_interchangeArea.id,null,null);
		endif;
	endif;
	
	if	_allOverstowedCargo = null then
		return;
	endif;
	
	
	rtQueueEntry:=_ti.getQueueEntry;

	//need to get all locations we don't want stuff queued to
	create allRestrictingLCs transient;
	_ti.getSideAccessRestrictingLCs(allRestrictingLCs);
	
	
	if _interchangeArea.laneCount = 0 or _laneID = null then
		laneID:=1;
	endif;
	
	gridRow:=_interchangeArea.allGridRows[laneID];
	yardICLaneController:=gridRow.allControllersByColumn.first.CM_LaneController; //epr par 22943
		
	
	iter:=_allOverstowedCargo.createIterator;
	while iter.next(ti) do : outerLoop
		if ti = _ti then
			continue;
		endif;
		if _tryToMoveExisting then
			if ti.allQueuedFutureMoves.size &gt; 0 then
				//want to see if we could  move any of the queue entries above the current one to avoid overstowing
				foreach futureMove in ti.allQueuedFutureMoves do
					futureQueuedMove:=futureMove.CM_FutureMoveQueued;
					if futureQueuedMove.moveQueueEntryAbove(rtQueueEntry,allRestrictingLCs) then
						continue outerLoop;
					endif;
				endforeach;
			endif;
		endif;
		
		delete moveController;														// 12/05/2014 cnwmh5
		create moveController transient;
		moveController.setMyTrackedItem(ti);
		moveController.setMyToPrimaryLocation(yardICLaneController);
		moveController.setMoveIndex(1); //epr Par 25285 force the overstow move to be first future move
		moveController.setMoveMode(QUEUE_MODE);
		//For Queue and Planned moves
		moveController.setMyOriginatingLocation(ti.myPrimaryActualLocation);
	
		self.utlUpdateMoveTrackedItem(moveController, _passport);
		
		if _passport.hasErrors then
			break;
		endif;
		if app.myYAAgent &lt;&gt; null then
			ti.createInfomationTransaction(YardAllocationLogging, app.myYAAgent.getLoggingArray(true), null, _passport);		
		endif;
		//really want to try to reposition the container in the queue again
		if moveController.myWorkListEntry &lt;&gt; null and
			 moveController.myWorkListEntry.myFutureMove &lt;&gt; null then
			futureQueuedMove:=moveController.myWorkListEntry.myFutureMove.CM_FutureMoveQueued;
			futureQueuedMove.moveQueueEntryAbove(rtQueueEntry,allRestrictingLCs);
			foreach qEntry in futureQueuedMove.allRTQueueEntries discreteLock do
				if not rtQueueEntry.allOverstowQueueEntries.includes(qEntry) then
					rtQueueEntry.allOverstowQueueEntries.add(qEntry);
				endif;
			endforeach;
		else
			if not _tryToMoveExisting then
				app.raiseCMWarning1(Unable_find_overst_move_locati,ti.id &amp; " " &amp; app.getErrorString(Check_Yard_Allocation_Logging),null,null,null);
			endif;
		endif;
	endwhile;
	
	// PAR #26113 - Send notification of successful move overstow for ITS Queue Monitor
	if rtQueueEntry &lt;&gt; null and not _passport.hasErrorsOrWarnings then
		rtQueueEntry.causeEvent(_ti.myTerminal.getTerminalEvent(EVENT_RTQUEUE_MOVE_OVERSTOW), false, null);
	endif;

	
epilog
	delete allRestrictingLCs;
	delete iter;
	delete moveController;										// 12/05/2014 cnwmh5
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_allOverstowedCargo" type="CM_TIArray" usage="input"/>
        <Parameter name="_interchangeArea" type="CM_InterchangeArea" usage="input"/>
        <Parameter name="_laneID" type="Integer"/>
        <Parameter name="_tryToMoveExisting" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlROROControlerUpdateRelease" id="bacb247a-701d-4997-bc75-37063545611f">
        <updating/>
        <source>utlROROControlerUpdateRelease(_theSlots : CM_LCArray; _reserveDetail : CM_ReserveDetail ; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 December 2012	cnwrd1	Initial creation
26/04/2013			cnwmh5 #31460 - If not 20ft then don't require backend details
*/

vars
	bulkRelease 	: CM_BulkRelease;
	aSlot			: CM_LocationsController;
	tmpSlot			: CM_VoyageROROController;
	tmpSlotRequest	: CM_RORORequest;
	trans 			: Boolean;
	theTI			: CM_TrackedItem;
	wle				: CM_WorkListEntry;
	aVoyage			: CM_Voyage;
begin

	if _theSlots.size = 0 then
		return;
	endif;
		
	if _reserveDetail &lt;&gt; null then  //we have one so we are setting it
		if _reserveDetail.isKindOf( CM_ReserveSelection ) then
		bulkRelease := _reserveDetail.myReserveHeader;
		
			foreach aSlot in _theSlots do
				if not aSlot.isKindOf(CM_VoyageROROController) then
					continue;  //wrong kind of controller.
				endif;
				
				tmpSlot := aSlot.CM_VoyageROROController;
				tmpSlotRequest := tmpSlot.myRORORequestLoad;
				if tmpSlotRequest = null then
					continue;
				endif;
		
				if not tmpSlotRequest.getAttrIs20 and tmpSlotRequest.getAttrIsBackend() then									// 26/04/2013 cnwmh5 #31460
					continue;
				endif;
				
				trans:=not bulkRelease.myTerminal.getConfig(ShowRelReqOnShipLoadList).Boolean;
				
				theTI := _reserveDetail.createPlanningTrackedItem(aSlot.getStowageId(null), tmpSlot, trans);	
				// PAR #26426 if we have a wle attached, assign the TBA TI to it, and set bulk release details
				if tmpSlotRequest.allWorkListEntries.size = 1 then
					wle := tmpSlotRequest.allWorkListEntries.first;
					// only asign the TBA TI if its persitent
					if not trans then
						wle.assignTIandBOL(theTI, null);
					endif;	
					// and update wle planned location
					wle.setLocations(null, aSlot.getStowageId(null));
				endif;
				// we're planned, so add request to bulk release "being actioned" collection
				if _reserveDetail &lt;&gt; null then
					tmpSlotRequest.setMyOriginatingBulkRelease(bulkRelease);
					tmpSlotRequest.setMyBulkReleaseReserveDetail(_reserveDetail);
				endif;				

			endforeach;			
		endif;
			
	else 
	// its null so we are removing it
	
			foreach aSlot in _theSlots do
				if not aSlot.isKindOf(CM_VoyageROROController) then
					continue;  //wrong kind of controller.
				endif;
				
				tmpSlot := aSlot.CM_VoyageROROController;
				tmpSlotRequest := tmpSlot.myRORORequestLoad;
				if tmpSlotRequest = null then
					continue;
				endif;
				tmpSlotRequest.setMyBulkReleaseReserveDetail(null);
				tmpSlotRequest.setMyOriginatingBulkRelease(null);
			endforeach;			
	endif;

	//epr par 31265 8/3/12 send notes for all the slots
	foreach aSlot in _theSlots do
		if aSlot.isKindOf(CM_VoyageROROController) then
			aVoyage := aSlot.CM_VoyageROROController.myVoyage;	
			app.myEventManager.createSingleObjInfoNoteEvt(
								aVoyage,
								_passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA),
								aSlot);
		endif;
	endforeach;
	

epilog

end;</source>
        <Parameter name="_theSlots" type="CM_LCArray"/>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlReceiveFromShip" id="338d3001-cb51-467b-b816-5042c02ee50e">
        <updating/>
        <source>utlReceiveFromShip(_tiSet : CM_TISet; _toLocn : CM_LocationsController input; _passport : CM_Passport input) updating;
//
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
//
vars
	
	cloneTI,
	ti 				: CM_TrackedItem;
	bol				: CM_BOL;
	bolExt			: CM_BOLExtension;
	bolSet			: CM_BOLSet;
	moveCntrl		: CMIF_MoveController;
	updCntrl		: CMIF_TIUpdateController;
	voyage			: CM_Voyage;
	firstTime,
	checkLocation	: Boolean;
	dupTIs			: CM_TISet;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(false);
	
	if _tiSet = null then	
	//	app.raiseCMException1(REQUIRED_FIELD, 'Tracked Items', null, null);
		app.raiseCMException(Input_required_field_trkdItems, null, null); // cnwdb2	PAR 35364
	endif;
	if _passport.userCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'userCode', null, null);
		app.raiseCMException(Input_required_field_userCode, null, null); // cnwdb2	PAR 35364	
	endif;
	
	foreach ti in _tiSet do
		if (not ti.isNoNumber) then
			checkLocation := true;
			break;
		endif;
	endforeach;
	
	if _toLocn = null and checkLocation then
	//	app.raiseCMException1(REQUIRED_FIELD, 'To Location', null, null);
		app.raiseCMException(Input_required_field_toLocn, null, null); // cnwdb2	PAR 35364
	endif;
	
	if _passport.noErrors then
	
		create bolSet transient;
		create moveCntrl transient;
		firstTime := true;		
		moveCntrl.isSystemMove 	:= true;
		moveCntrl.isForcedMove 	:= true;
		moveCntrl.setEffectiveTimeStampOverride(app.serverTimestampAtTrxStart);
		moveCntrl.setMyToPrimaryLocation(_toLocn);
		moveCntrl.setMoveMode(REAL_MODE);
		
		updCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
		updCntrl.transactionType 	:= TRANS_TYPE_Offload;
		
		create dupTIs transient;
		
		foreach ti in _tiSet do
			exclusiveLock(ti);
			
			if ti.myMoveCloneToTI &lt;&gt; null then
				app.raiseCMWarning3(Err_TINoLongerOnTerminal, ti.id, ti.myTerminal.code, ti.myMoveCloneToTI.myTerminal.code, null, null, ti);
				continue;
			endif;				

			if ti.isNoNumber and ti.isKindOf(CM_LogNoNumber) then
				// Do not receive no-numbers back into the any terminal, Can just delete
				updCntrl.transactionType 	:= TRANS_TYPE_NULL;
				ti.CM_LogNoNumber.createStockMovementForOffload(updCntrl, _passport);
				ti.erase(NORMAL_ERASE);
				continue;
			endif;

			if ti.myTerminal = _toLocn.myTerminal then
				//moving from voyage back into same terminal
				ti.receiveFromShip(null, _toLocn,null,null,null,  _passport); // ### TFS 51988 17SEP2021 NAVAB1
				bol := ti.myReleaseBOL;
				exclusiveLock(bol);
				if bol &lt;&gt; null then
					if (not bolSet.includes(bol)) then
						bolSet.add(bol);
					endif;
					ti.detachFromBOL(bol);
				endif;
			else 
				
				dupTIs.clear;
				_toLocn.myTerminal.lookupAllOnsiteTrackedItems(ti.myCargoType.id, ti.id, dupTIs, false, null);
				if not dupTIs.isEmpty then
					app.raiseCMException1(ERR_ALREADY_ONSITE,ti.id,null,null);
					return;
				endif;
				// This is an inter-terminal transfer
				cloneTI := ti.getCloneForInterTerminalMove(_toLocn.myTerminal, _passport);
				if _passport.hasErrors then
					break;
				endif;

				// setup cloned TI for moving off the voyage
				if firstTime then
					moveCntrl.setMyTrackedItem(cloneTI);
					firstTime := false;		
				else
					moveCntrl.allOtherTrackedItems.add(cloneTI);
				endif;
				
				// move the existing TI to the offloaded dict on the from terminal voyage
				updCntrl.transactionType 	:= TRANS_TYPE_Offload;
				ti.offloadForInterTerminal(updCntrl, _passport);

			endif;
			if _passport.hasErrors then
				break;
			endif;
		endforeach;

		if _passport.noErrors then
			foreach bol in bolSet do
				bolExt := bol.myExtension;
				if bolExt &lt;&gt; null then
					bolExt.setJasVolume(_passport.myTerminal);
				endif;
			endforeach;
			if (not firstTime) then //must be an Inter-Terminal move
				self.utlUpdateMoveTrackedItem(moveCntrl, _passport);
			endif;
		endif;
	endif;
	
epilog
	delete dupTIs;
	delete bolSet;
	delete moveCntrl;
	delete updCntrl;
end;</source>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_toLocn" type="CM_LocationsController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlRegradeLog" id="0a594665-5d23-4a95-a511-6b3e3336d8d3">
        <source>utlRegradeLog(_logRegrade : CMIF_LogRegrade;  _userCode : String; _location : CM_LocationsController; 
			_isMove : Boolean; _passport : CM_Passport input);
			//
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	ti				: CM_TrackedItem;
	proxyLog,
	realLog			: CM_Log;
	isValidated	,
	isFirstTime,
	cancelSave		: Boolean;
	moveController	: CMIF_MoveController;
	tiUpdateCntrlr	: CMIF_TIUpdateController;
//	transaction		: CM_TITransaction;
//	txnParams		: CMIF_TITransactionController;
	search		: CMIF_SearchTypes;
	tmpProduct	: CM_ProductLog;
	tiAuditCntrl	: CM_TIAuditController;
	sa				: StringArray;
	partsDone,
	jobSize			: Integer;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	tmpProduct := _logRegrade.myProduct;
	
	tiAuditCntrl := _passport.getTIAuditController();

	create sa transient;
	//sa.add(CM_TrackedItem::consignor.name);	//ccms 1116, #26786 27/01/2011. Now, Consignor has been removed from Regrading screen.
	sa.add(CM_TrackedItem::myOperator.name);
	sa.add(CM_TrackedItem::operatorCode.name);
	sa.add(CM_TrackedItem::productCode.name);
	sa.add(CM_TrackedItem::volume.name);
	//added for par12154 by cnwyl1 07/02/2008
	sa.add(CM_TrackedItem::totalVolume.name);
	sa.add(CM_TrackedItem::totalWeight.name);
	//////////////////////////////////////////
	if _logRegrade.isLogId then
		sa.add(CM_Log::sedMin.name);
		sa.add(CM_Log::sedMax.name);
		sa.add(CM_Log::sedMean.name);
		//added for par12154 by cnwyl1 07/02/2008
		sa.add(CM_Log::jasVolume.name);
		/////////////////////////////////////////
	endif;
	tiAuditCntrl.setAuditSpecific(CM_TrackedItem, sa);
	
	exclusiveLock(_location);
	// ensure that regraded logs can go into location
	create search transient;
	search.myOperator 	:= _logRegrade.myOperator;
	search.mySpecies	:= tmpProduct.myLogSpecies;
	search.myGrade		:= tmpProduct.myLogGrade;
	search.myType		:= tmpProduct.myLogType;
	search.myTreatment	:= tmpProduct.myLogTreatment;
	search.myLength		:= tmpProduct.myLogLength;
	
	_location.setToAllowType(search);
	
	create moveController transient;
	tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _userCode, null);
	tiUpdateCntrlr.reasonCode := _logRegrade.myRegradeCode.code;
	jobSize := _logRegrade.allTrackedItems.size;
	
	foreach ti in _logRegrade.allTrackedItems do
		//quicker to increment an integer, and perform mod calculation, than 
		//to test a monitor reference for null
		partsDone := partsDone + 1;
		if partsDone mod MONITOR_RETURN_REGRADE = 0 then
			if _passport.hasMonitor then
				_passport.myCMIFMonitor.updateProgress('Regrading', jobSize, partsDone);
			endif;
			progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
				
		if (not isValidated) then
			proxyLog := app.createUpdateProxy(ti).CM_Log;
			proxyLog.setFromCMIF_Regrade(_logRegrade, null, _passport);
			app.myValUA.valRegradeLog(proxyLog, _location, _passport);
			if not _passport.noErrors then
				return;
			endif;
			app.setContinueCMExceptions(false);
			isValidated := true;
		endif;
		
		realLog := ti.CM_Log;
		exclusiveLock(realLog);
		
		//if (_logRegrade.consignorCode = null or realLog.consignor = _logRegrade.consignorCode) and // commented by ccms 1116, #26786 27/01/2011
		if realLog.myOperator = _logRegrade.myOperator and
		   realLog.productCode = _logRegrade.productCode and 
		   realLog.sedMax = _logRegrade.sedMax and 
		   realLog.sedMin = _logRegrade.sedMin then
		   	// no work to do
			continue;
		endif;
				
		//transaction and stock movement will be created here as well
		if _passport.noErrors then
			realLog.setFromCMIF_Regrade(_logRegrade, tiUpdateCntrlr, _passport);
		endif;

	endforeach;	
	
	if _isMove and _passport.noErrors then
		moveController.setMoveMode(REAL_MODE);
		moveController.isSystemMove := true;
		moveController.setMyToPrimaryLocation(_location);
		isFirstTime := true;
		foreach ti in _logRegrade.allTrackedItems do
			if isFirstTime then
				isFirstTime := false;
				moveController.setMyTrackedItem(ti);
			else
				moveController.allOtherTrackedItems.add(ti);
			endif;
		endforeach;
		app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
	endif;
epilog
	if tiAuditCntrl &lt;&gt; null then
		tiAuditCntrl.resetIsAudited(true);
	endif;
	delete moveController;
	delete proxyLog;
	delete tiUpdateCntrlr;
	delete search;
	delete sa;
	
end;</source>
        <Parameter name="_logRegrade" type="CMIF_LogRegrade"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_isMove" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlRegradeLogRemote" id="24ef4f86-7bdb-4bf1-8c0b-04b1a138f014">
        <source>utlRegradeLogRemote(_remoteRegradingDtlExt : CM_RemoteRegradingDtlExt; _passport : CM_Passport input);

vars

	extra			: CM_RemoteDataExtra;
	extraRegrade	: CM_RemoteRegradingExtra;
	realLog			: CM_Log;
	cancelSave		: Boolean;
	moveController	: CMIF_MoveController;
	tiUpdateCntrlr	: CMIF_TIUpdateController;
	location		: CM_LocationsController;
	terminal		: CM_Terminal;
	area			: CM_TerminalArea;
	tiAuditCntrl	: CM_TIAuditController;
	sa				: StringArray;

begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	terminal := _passport.myTerminal;

	if 	_remoteRegradingDtlExt.area &lt;&gt; null then
		area := terminal.allTerminalAreas[_remoteRegradingDtlExt.area];
		if area = null then
			app.raiseCMException1(Err_InvalidTerminalArea, _remoteRegradingDtlExt.area, null, null);
			return;
		endif;
	
		location := area.getLocationsControllerFromId(_remoteRegradingDtlExt.location);
		if location = null then
			app.raiseCMException1(Err_InvalidLocation, _remoteRegradingDtlExt.location, null, null);
			return;
		endif;
	endif;

	create moveController transient;
	tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _remoteRegradingDtlExt.myRemoteDataHdr.userId, null);
	
	tiAuditCntrl := _passport.getTIAuditController();
	create sa transient;
	sa.add(CM_TrackedItem::id.name);
	sa.add(CM_TrackedItem::myOperator.name);
	sa.add(CM_TrackedItem::operatorCode.name);
	sa.add(CM_TrackedItem::productCode.name);
	sa.add(CM_TrackedItem::volume.name);
	sa.add(CM_Log::sedMin.name);
	sa.add(CM_Log::sedMax.name);
	sa.add(CM_Log::sedMean.name);
	tiAuditCntrl.setAuditSpecific(CM_TrackedItem, sa);
	
	foreach extra in _remoteRegradingDtlExt.allRemoteDataExtra do
		extraRegrade := extra.CM_RemoteRegradingExtra;
		realLog := terminal.lookupTrackedItem(extraRegrade.itemId, TI_CargoType_Log, TI_STATE_NORMAL, null, false).CM_Log;
		if realLog = null then
			app.raiseCMWarning1(Err_TrackedItemsNotFound, extraRegrade.itemId, null,null, extraRegrade);
			continue;
		endif;
		self.exclusiveLock(realLog);
		if realLog.myOperator.code = _remoteRegradingDtlExt.supplier and
		   realLog.productCode = _remoteRegradingDtlExt.productCode and 
		   realLog.sedMax = extraRegrade.sedMax and 
		   realLog.sedMin = extraRegrade.sedMin and
		   (location = null or realLog.getPrimaryLocation(REAL_MODE) = location) and
		   (extraRegrade.newItemId = null or realLog.id = extraRegrade.newItemId) then
		   	// no work to do
		   	app.writeLog('Continue', LogINFO);
			continue;
		endif;	

		// If we aren't moving we still need a location to get past validation.
		if location = null then
			location := realLog.getPrimaryLocation(REAL_MODE);
		endif;
		self.exclusiveLock(location);
		tiUpdateCntrlr.reasonCode := extraRegrade.reasonCode;
		if not realLog.setFromRegradeExt(extraRegrade, tiUpdateCntrlr, _passport) then
			return;
		endif;
		app.myValUA.valRegradeLog(realLog, location, _passport);
		if not _passport.noErrors then
			app.raiseCMException1(Err_RemoteRegrading, realLog.id, null,null);
			return;		// note that this gets "ignored" in the eplog
		endif;
		
		if location &lt;&gt; realLog.getPrimaryLocation(REAL_MODE) and _passport.noErrors then
			moveController.setMoveMode(REAL_MODE);
			moveController.isSystemMove := true;
			moveController.setMyToPrimaryLocation(location);
			moveController.setMyTrackedItem(realLog);
			app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
		endif;
	endforeach;
			
	
epilog
	if tiAuditCntrl &lt;&gt; null then
		tiAuditCntrl.resetIsAudited(true);
	endif;
	delete moveController;
	delete tiUpdateCntrlr;
	delete sa;
end;</source>
        <Parameter name="_remoteRegradingDtlExt" type="CM_RemoteRegradingDtlExt"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlReinstateRejectTrackedItems" id="d32add74-4342-45ed-adb5-06e9b44729f1">
        <source>utlReinstateRejectTrackedItems(pTISet : CM_TISet; _reason : String; _location : CM_LocationsController;
			_passport : CM_Passport input);

// cnwdvb1 29 November 2002 

vars
	ti  : CM_TrackedItem;	
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);

	app.myValUA.valReinstateReject(_reason, TRANS_TYPE_ReinstateReject);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
		
	app.setContinueCMExceptions(false);
	
	foreach ti in pTISet do
		if ti.state = TI_STATE_DELETED then
			if (not self.reinstateRejectTrackedItem(ti, _reason, _location, _passport)) then
				break;
			endif;
		endif;
	endforeach;

end;</source>
        <Parameter name="pTISet" type="CM_TISet"/>
        <Parameter name="_reason" type="String"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlRejectTask" id="1a48a801-d190-4476-9f62-1da125c20a83">
        <source>utlRejectTask(	_machine : CM_Machine input; 
				_task	: CM_RTQueueTask input;
				_addToRejectList : Boolean;
				_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     30 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
// 27/07/2021	navdap1	TFS 51409 PNL Queued Driver Moves
// ---------------------------------------------------------------------------
vars
	setdownTask,
	currTask			: CM_RTQueueTask;
	entry	:		 CM_RTQueueEntry;
	job						: CM_Job;
	moveControl			: CMIF_MoveController;
	invalidTask,
	addToRejectList 	: Boolean;
	wle 				: CM_WorkListEntry;
	allEntriesToDelete	: CM_RTQueueEntrySet;
	lcS : CM_LocationsController;
	lcT : CM_LocationsController;
	rtConfig : CM_RTVehicleConfig;			// TFS 51409
	allowQueuedMoves : Boolean;				// TFS 51409
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(false);
	on Exception do app.handleDeletedObject(exception, _task, invalidTask);
	exclusiveLock(_task);
	if invalidTask then
		return;
	endif;
	currTask := _task;
	entry := currTask.myEntry;
	exclusiveLock(entry);

	currTask.setStatus(TASK_UNACTIONED);
	
	self.updateObjectEdition(entry);	// par 30292
	
	job := entry.myJob;
	job.updateStatus();
	
	addToRejectList:=_addToRejectList;
	
	if _machine.myRTVehicleConfig &lt;&gt; null then										// TFS 51409
		allowQueuedMoves := _machine.myRTVehicleConfig.allowNonRTQMoves;			// TFS 51409
	endif;																			// TFS 51409
	if entry.myQueue &lt;&gt; _machine.myPrimaryQueue and allowQueuedMoves then		// TFS 51409
		app.writeLog("Machine " &amp; _machine.id &amp; " rejected move '" &amp; entry.entryDescription &amp; "' in queue " &amp; entry.myQueue.id
					 &amp; ", machine is in queue " &amp; _machine.myPrimaryQueue.id &amp; " - task NOT deleted", LogINFO);
	endif;
	
	if 	entry.isMachineInitiatedMove  and  entry.myOverstowOfEntry = null then
		// Machine Initiated move - so unqueue the TI
		// TFS 51409 but not if the task is for a different queue 
		// and the machine is allowed to access different queues
		if entry.myQueue &lt;&gt; _machine.myPrimaryQueue and allowQueuedMoves then		// TFS 51409
			app.writeLog("Machine " &amp; _machine.id &amp; " rejected move '" &amp; entry.entryDescription &amp; "' in queue " &amp; entry.myQueue.id
						 &amp; ", machine is in queue " &amp; _machine.myPrimaryQueue.id &amp; " - task NOT deleted", LogINFO);
		else																		// TFS 51409
			create moveControl transient;
			moveControl.setMoveMode(QUEUE_MODE);
			moveControl.setMyTrackedItem(currTask.ti);
			moveControl.setMyWorkListEntry(entry.myWorkListEntry);
				
			app.myUtilityUA.utlUpdateMoveTIUndo(moveControl,_passport);
			
			return;
		endif;																		// TFS 51409
	endif;
	
	wle:=entry.myWorkListEntry;
	//epr par 34634 3/9/14
	if entry.isPlanOnPickup and wle.locationTarget &lt;&gt; null then
		//if it was a plan on pickup do something different
		//delete the setdown task of first entry 
		
		//delete any other entrys that were created
		
		//set current task target location to null
		//set wle location target to null
		
		create allEntriesToDelete transient;
		wle.allRTQueueEntries.copy(allEntriesToDelete);
		allEntriesToDelete.removeIfPresent(entry);
		allEntriesToDelete.purge;
		
		setdownTask:=entry.getTaskOfType(TASK_SETDOWN,null);
		if setdownTask &lt;&gt; null then
			delete setdownTask;
		endif;
		currTask.relatedTasks.clear;
		currTask.relatedTasks.add(currTask);
		wle.setNewLocationTarget(null);
		
	endif;
	
	
	//   epr par 32194 4/8/13 only delete if is breakbulk move and not the master break bulk item
	if not entry.isBreakBulkGenericMaster  and currTask.isBreakBulkMove then //cnwrd1 2274 ccms break bulk
		//epr par 35702 CCMS 2457 17/2/15
		delete entry;
		addToRejectList := false;
	endif;
	
	if addToRejectList then	
		_machine.addRejectedRTQueueTask(currTask);
		//epr CCMS 1391 - 11/8/14 refacted block below into  machine.addRejectedRTQueueTask
		entry.sendNotesForRelatedEntry();	
	else
		_machine.addRejectedMoveToHistory(currTask); //update machine history that it has rejected it
	endif;
	
	//epr TFS 3272 31/3/17
	if _machine.myPrimaryQueue &lt;&gt; currTask.myEntry.myQueue then
		app.myEventManager.createSingleObjInfoNoteEvt(_machine.myPrimaryQueue , _machine.myTerminal.getTerminalEvent(Event_Update_Queue_Entry), currTask.myEntry );		
	endif;
	//------------------
	//Revert task's pickup target to setdowns' target
	//and pickups source to setDowns Source.
	//------------------
	if currTask.taskType &lt;&gt; TASK_DIRECTOR  and currTask.taskType &lt;&gt; TASK_BREAKBULK then
		entry.revertLocnsToUnactionedState;
	endif;
	
	//16 Mar 2021	NDL	TFS 50845
	lcS := currTask.sourceLocation;
	lcT := currTask.targetLocation;
	if lcS &lt;&gt; null and lcS.hasRestrictions(LABOUR_RESTRICTION) or lcT &lt;&gt; null and lcT.hasRestrictions(LABOUR_RESTRICTION) then
		//source and/or target location got LOB added after task initially accepted, so when rejected needs to become 'sys held', not 'unactioned'
		currTask.setStatus(TASK_SYS_HELD);
	endif;
	
	_machine.doDelayedMoveToQueue();
	
epilog
	
	if not _passport.hasErrors and _machine.allCurrentQueueTasks.size = null then
			// Update machine status
		_machine.setMachineStatus(STATUS_IDLE  , "", false);
	endif;
	delete moveControl;
	delete allEntriesToDelete;
end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_task" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_addToRejectList" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlRejectTrackedItems" id="82a4a363-ac34-4167-8aa2-4846b92ddb1c">
        <source>utlRejectTrackedItems(pTISet : CM_TISet; _reason, _recovery, _comment, _description : String; _passport : CM_Passport input);
//
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	ti			: CM_TrackedItem;	
	cancelSave	: Boolean;
	bulkReject	: CM_BulkReject;
	updCntrl 	: CMIF_TIUpdateController; 
	jobSize,
	partsDone	: Integer;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);

	app.myValUA.valRejectTrackedItems(_reason, _recovery, TRANS_TYPE_REJECT, _passport.myTerminal);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	updCntrl := app.createTIUpdateControl(TI_UPDMODE_REJECT, _passport.userCode, null);
	updCntrl.transactionType 	:= TRANS_TYPE_REJECT;
	updCntrl.reasonCode 		:= _reason;
	updCntrl.recoveryCode 		:= _recovery;
	updCntrl.comment 			:= _comment;
	updCntrl.isAuditTextRequired := false;

	create bulkReject persistent;
	bulkReject.setForCreateBulkReject(_description, _passport.myTerminal, TRANS_TYPE_REJECT, _passport.userCode);
	jobSize := pTISet.size();
	foreach ti in pTISet do
		partsDone := partsDone + 1;
		if partsDone mod MONITOR_RETURN_REJECT = 0 then
			if _passport.hasMonitor then
				_passport.myCMIFMonitor.updateProgress(null, jobSize, partsDone);
			endif;
			progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		if (not self.rejectTrackedItem(ti, updCntrl, _passport)) then
			break;
		endif;
		bulkReject.addTi(ti);
	endforeach;
epilog
	delete updCntrl;
end;</source>
        <Parameter name="pTISet" type="CM_TISet"/>
        <Parameter name="_reason" type="String"/>
        <Parameter name="_recovery" type="String"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlRemoveReserveDetail" id="0080a23d-7fc2-4d48-991c-82d6a98c0bde">
