    <JadeMethod name="updateTI" id="06987ad8-4b9c-4d4e-bb40-2e6ef23c03ef">
        <updating/>
        <source>updateTI(_passport : CM_Passport input) updating;
/*
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/
vars
	ti : CM_TrackedItem;
begin
	ti := self.myTrackedItem;		//28.05.2024 navma1 #64224
	
	
	if ti = null or ti.myTerminal = null then
		return;
	else
		ti.myTerminal.actionEventRequestNotification(self.myTrackedItem, self, _passport); 
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="userGenerated" id="4223a4d7-4b9f-450c-b49a-956737e194a2">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>userGenerated(set: Boolean; _value: Boolean io) mapping, updating;
/*
 ------------------------------------------------------------------------
Created:			05 April 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if set then
		if _value then
			flags := flags.bitOr(UserGeneratedFlag);
		else
			flags := flags.getValueWithBitUnset(UserGeneratedFlag);
		endif;
	else
		_value := (flags.bitAnd(UserGeneratedFlag) &lt;&gt; 0);
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="validateCMIF_TITransCntrl" id="cdbe3ba4-76b6-4f06-a4da-8b4ebb59ff9b">
        <source>validateCMIF_TITransCntrl(_tiTransCntrl: CMIF_TITransactionController) : Boolean;
//--------------------------------------------------------------
//Created: 02 October 2002 By: cnwgd1
//--------------------------------------------------------------
// 04/08/2011	cnwmh5	#27888 - Add validation to check that type (transaction) hasn't been changed.  If it has cause exception
vars
	rtnCode			: Boolean;
	tmpTS			: TimeStamp;
begin
	if _tiTransCntrl = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null CMIF_TITransactionController passed to method.');
		return false;
	endif;
	
	// 04/08/2011 cnwmh5 #27888
	if self.type &lt;&gt; 0 and _tiTransCntrl.type &lt;&gt; self.type then
		app.raiseCMException2(Transa_type_cannot_change_from, self.typeString, _tiTransCntrl.typeString, null, null);
	endif;	
	
	rtnCode := true;
	
epilog
	return rtnCode;
end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateCMIF_TIUpdateCntrlr" id="4a113159-23f6-4d76-aa4c-6fba5867102c">
        <source>validateCMIF_TIUpdateCntrlr(_tiUpdateCntrlr: CMIF_TIUpdateController; _passport : CM_Passport input) : Boolean;
//--------------------------------------------------------------
//Created: 02 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	ti			: CM_TrackedItem;
	now			: Date;
	tmpTS		: TimeStamp;
begin
	if _tiUpdateCntrlr = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null CMIF_TIUpdateController passed to method.');
		return false;
	endif;
	if _tiUpdateCntrlr.transactionType = TRANS_TYPE_NULL then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid Transaction type.');
	endif;
	
	
epilog
	return _passport.noErrors();
end;</source>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
