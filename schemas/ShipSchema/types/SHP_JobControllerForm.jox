    <JadeMethod name="doOpenShipJobOperationsForm" id="f831a1aa-bba6-41fa-8317-894f63aa639e">
        <source>doOpenShipJobOperationsForm(_crane : CM_Crane input; _job : CM_VoyageJob input);
// ---------------------------------------------------------------------------
// Created:     23 January 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpForm	: SHP_VoyageOperationsForm;
	found : Boolean;
	i : Integer;
	f : Form;
	sf : SHP_VoyageOperationsForm;
begin
	if _crane = null then
		return;
	endif;
	
	found := false;
	if _job = null then
		foreach i in  1 to app.formsCount do
			f := app.forms(i);
			if f.name = SHP_VoyageOperationsForm.name then
				sf := f.SHP_VoyageOperationsForm;
				if sf.myInitVoyage = self.myVoyage then
					if sf.myInitCrane = _crane then
						if sf.myInitJob = null then
							sf.zOrder(1);
							found := true;
							break;
						endif;
					endif;
				endif;
			endif;
		endforeach;
	endif;

	
	if not found then
		tmpForm := self.myAssistant.SHP_Assistant.showVoyageJobOps(self.myVoyage, _crane, _job);
	endif;
	
	
end;</source>
        <Parameter name="_crane" type="CM_Crane" usage="input"/>
        <Parameter name="_job" type="CM_VoyageJob" usage="input"/>
    </JadeMethod>
