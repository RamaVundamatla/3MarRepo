    <JadeMethod name="isReEditable" id="296bae7d-09c8-4e34-bbbd-0522a7e98ce3">
        <source>isReEditable(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 February 2010	cnwjk3	Initial creation
11 February 2011	cnwdap1	PAR #26929 general Road Gate screen tidy-up
							We shouldn't be allowed to edit a CMGTE_ReceivalByType if its Vehicle Visit Record is not updatable
*/

vars

begin
	// PAR #26929 start
	if self.myVehicleVisitRecord &lt;&gt; null and not self.myVehicleVisitRecord.isUpdatable then
		return false;
	endif;
	// PAR #26929 end
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
