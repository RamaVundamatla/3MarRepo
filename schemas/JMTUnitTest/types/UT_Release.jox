										targetLocation,	//_targetLocation : CM_LocationsController;
										stwRuleNum,	//_stwRuleNum : Integer;
										tiArray	//_tiArray : CM_TIArray io
										);
										
	self.assertTrueMsg( stwRuleNum = 0, " Agent method 'getCargoStagingDispRuleSTW' should have returned Rule = 0, (truck load testing 5) but got '" &amp; stwRuleNum.String &amp; "'.");
	self.assertTrueMsg( tiArray.size = 0, " Agent method 'getCargoStagingDispRuleSTW' should have returned 0 items, (truck load testing 5) but got '" &amp; tiArray.size.String &amp; "'.");
	
	//now check with NO reserve detail selected when all loaded
	selectedResDetail := null;
	autoSelectedStageArea := null;
	stwRuleNum := 0;
	tiArray.clear();
	agent.getCargoBasedOnSTW12Rules(	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//_stagedYardLocation : CM_LocationsController io;
										targetLocation,	//_targetLocation : CM_LocationsController;
										stwRuleNum,	//_stwRuleNum : Integer;
										tiArray	//_tiArray : CM_TIArray io
										);
										
	self.assertTrueMsg( stwRuleNum = 0, " Agent method 'getCargoStagingDispRuleSTW' should have returned Rule = 0, (truck load testing 6) but got '" &amp; stwRuleNum.String &amp; "'.");
	self.assertTrueMsg( tiArray.size = 0, " Agent method 'getCargoStagingDispRuleSTW' should have returned 0 items, (truck load testing 6) but got '" &amp; tiArray.size.String &amp; "'.");

	app.myTrxUA.trxUpdateWagonConfirmTrain(null, false, train, true, app.myPassport);  //out
	
	create trainSet transient;  //everyone loves train sets.
	trainSet.add(train);
	app.myTrxUA.trxUpdateTrainsDeparture(trainSet, app.myPassport);  //lets use the transaction thing
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Depart Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	
	//If we got this far all is good get rid of the data.
	//clean up
	foreach index in 1 to 9 do
		self.deleteContainer( BaseTiId &amp; index.String );
	endforeach;
	
	self.deleteRailArea(RailAreaId);
	
	self.deleteTerminalArea(BlockStack);
	bs := self.addBlockStack(BlockStack, 100, null);
	self.assertTrueMsg( bs &lt;&gt; null , " Block Stack not found pre-test");
	
	self.deleteTerminalArea(ICArea &amp; "1");
	self.deleteTerminalArea(ICArea &amp; "2");
	ic1 := self.addInterchangeArea(ICArea &amp; "1",null);
	ic2 := self.addInterchangeArea(ICArea &amp; "2",null);
	self.assertTrueMsg( ic1 &lt;&gt; null , " Inter change 1 not found pre-test");
	self.assertTrueMsg( ic2 &lt;&gt; null , " Inter change 2 not found pre-test");
	
	self.deleteReleaseRequest(ReleaseCode);
	
	//setup
	railArea := self.addRailArea(RailAreaId, 4, 10);
	railLine := railArea.allRailLinesByIndex.first;
	
	foreach obj in railArea.allRailJSInOut discreteLock do
		railIORake := obj.CM_RailJSInOutRake;
		if railIORake.getIoType() = Rail_JSIO_Type_Out then
			break;
		endif;
		railIORake := null;
	endforeach;
	
	train := terminal.allTrainsDeparted.getAtKeyGeq(TrainCode, null);
	self.assertEqual(train.code, TrainCode);
	
	foreach wagon in train.allWagonsByIdInward do
		if wagon.confirmed then
			beginTransaction;
			wagon.erase(0);
			commitTransaction;
			continue;
		endif; 
		app.myTrxDA.trxDeleteWagon(wagon, false, app.myPassport);
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());	
	endforeach;
	
	self.deleteTrain(TrainCode,null);
	
epilog

	self.setTerminalConfig(UseAltSelectRulesTL, false);
	delete agent;
	delete tiArray;
	delete trainSet;

end;</source>
    </JadeMethod>
    <JadeMethod name="tSTWORelease" id="957f0f76-87a3-4599-bfb0-2bf4a3145ff2">
        <source>tSTWORelease();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2021	navndl1	Initial creation	TFS 50940

*/

constants

	BS_Id : String = "UTBS1";
	Cargo_Type : String = "UTREBAR";
	VehicleID : String = 'VEH50940';
	Cargo_Id : String = 'REBAR50940';
	RoadReleaseId : String = "REL50940";
	
vars

	bs : CM_BlockStack;
	oper : CM_Operator;
	cargoTypeObj : CM_CargoType;
	ti : CM_TrackedItem;
	bulkRelease : CM_BulkRelease;
	vehicle : CM_Vehicle;
	vvr : CM_VehicleVisitRecord;
	subTerm : CM_SubTerminal;
	job : CM_Job;
	wle : CM_WorkListEntry;
	loadedTi : CM_TrackedItem;
	correctExcRaised : Boolean;
		
begin

	self.setTerminalConfig( UseTotReqAllowedFld, true );
	cargoTypeObj :=	app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	oper := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	subTerm := self.getTerminal.allSubTerminals["UT_DEPOT"];
	
	//cleasn up 
	deleteReleaseRequest(RoadReleaseId);
	deleteVehicle(VehicleID);
	deleteTerminalArea(BS_Id);
	self.deleteAllCargo( Cargo_Id, cargoTypeObj );
	
	//setup base data
	bs := self.addBlockStack(BS_Id,200,null);
	self.assertTrueMsg(bs &lt;&gt; null, "Failed to create " &amp; BS_Id &amp; " Block stack in set up");
	
	//create on site cargo of 6 items
	ti := self.addCargoAtLocation( Cargo_Id, cargoTypeObj, oper, bs.myLocationsController);
	self.assertTrueMsg(ti &lt;&gt; null, "Failed to create " &amp; Cargo_Id &amp; " cargo in set up");
	beginTransaction;
	ti.setTotalQuantity(6);
	ti.setMyTotalVolume(600);
	ti.setTotalWeightWithoutTrans(6000);
	commitTransaction;
	
	
	//create a release by id for 4 with allowed of 2
	self.opts.purge();
	self.opts.addAssoc("TotalRequested", 4);
	self.opts.addAssoc("AnyAmtAnyIdAllowedAmount", 2);
	bulkRelease := self.addReleaseById( RoadReleaseId, BR_TYPE_ROAD, ti );
	self.assertTrueMsg(bulkRelease &lt;&gt; null, "Failed to create " &amp; RoadReleaseId &amp; " bulk release in set up");
	
	//bring in a truck for gating out, using the 'release by id' with 'any id any amount' wle
	self.opts.purge();
	self.opts.addAssoc("AnyAmtAnyId", true);
	self.gateOutPinRelease(bulkRelease.myPinNo.pinNo, VehicleID);
	vehicle := self.getVehicle( VehicleID );
	vvr := vehicle.visitRecords.first;
	self.assertTrueMsg(vvr &lt;&gt; null, "Failed to create VVR in set up");
	job := vvr.getMyJob;
	self.assertTrueMsg(vvr &lt;&gt; null, "Failed to find Job in set up");
	
	
	//load one item to truck using the equivalent of the Web based TruckLoader
	wle := job.workListEntries.getFirstUnactionedWLE();
	self.assertTrueMsg(wle &lt;&gt; null, "Failed to find 1st WLE");
	self.assertTrueMsg(wle.isAnyAmount, "WLE is NOT 'Any Id Any Amout' wle");
	
	self.opts.purge();
	self.opts.addAssoc("quantity", 1.Integer);
	self.doSimulateWebTruckLoad( vehicle, wle, ti, false );
	
	loadedTi := vehicle.locationsController.allTrackedItems.first;
	self.assertTrueMsg(loadedTi &lt;&gt; null, "First cargo item failed to load " &amp; app.myPassport.getErrorsAndWarningsAsString);
	self.assertTrueMsg(loadedTi.totalQuantity = 1, "First load incorrect quantity loaded, s/be 1 but got " &amp; loadedTi.totalQuantity.String);
	
	//load a second item - will merge
	wle := job.workListEntries.getFirstUnactionedWLE();
	self.assertTrueMsg(wle &lt;&gt; null, "Failed to find 2nd WLE");
	self.assertTrueMsg(wle.isAnyAmount, "2nd WLE is NOT 'Any Id Any Amout' wle");
	
	self.opts.purge();
	self.opts.addAssoc("quantity", 1.Integer);
	self.doSimulateWebTruckLoad( vehicle, wle, ti, false );
	self.assertTrueMsg(loadedTi.totalQuantity = 2, "Second load incorrect quantity loaded, s/be 2 but got " &amp; loadedTi.totalQuantity.String);
	
	//attempt to load a third - should get an error, because on supposed to be a maximum of 2 at the moment.
	wle := job.workListEntries.getFirstUnactionedWLE();
	self.assertTrueMsg(wle &lt;&gt; null, "Failed to find 3rd WLE");
	self.assertTrueMsg(wle.isAnyAmount, "3rd WLE is NOT 'Any Id Any Amout' wle");
	
	self.opts.purge();
	self.opts.addAssoc("quantity", 1.Integer);
	
	on Exception do app.handleSpecificException( exception, WarningGreaterThanEqualAllowed, correctExcRaised );
	
	self.doSimulateWebTruckLoad( vehicle, wle, ti, false );
	
	self.assertTrueMsg(correctExcRaised = true, "Failed to raise correct exception when trying to load 3rd item");
	self.assertTrueMsg(loadedTi.totalQuantity = 2, "After third load attempt, incorrect quantity loaded, s/be 2 but got " &amp; loadedTi.totalQuantity.String);
	
	// simulate the  complete (i.e. delete the last any id any amount)
	self.doSimulateWebTruckLoad( vehicle, null, null, true );
	
	//actually gate out the truck.
	self.roadExit(vvr);
	
	//clean up.
	deleteReleaseRequest(RoadReleaseId);
	deleteVehicle(VehicleID);
	deleteTerminalArea(BS_Id);
	self.deleteAllCargo( Cargo_Id, cargoTypeObj );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tTwoRelWithMultiCargoWithWaybi" id="ace43153-d61f-4358-84ba-4c2b021dc72f">
        <updating/>
        <source>tTwoRelWithMultiCargoWithWaybi()updating;
// cnwdap1
//05 November 2009	cnwml2
//+cnwml2 MSL CCMS 1012
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items

vars
	releaseRequest, releaseRequest1 : CM_BulkRelease;
	ti, ti1 : CM_TrackedItem;
	bs : CM_BlockStack;
begin
	
	self.deleteReleaseRequest("UTRRRoad");
	self.deleteReleaseRequest("UTRRRoad1");
	self.deleteContainer("UUT00000001");
	self.deleteContainer("UUT00000002");
	self.deleteTerminalArea("UTBS1");

	bs := self.addBlockStack("UTBS1", 100, null);

	
	releaseRequest := addReleaseByTypeRequest("UTRRRoad", BR_TYPE_ROAD, TI_CargoType_Container, "2200");
	assertEqual(releaseRequest.status, BR_ACTIVE);
	
	ti := self.addContainer("UUT00000001", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti, bs);
	self.releaseAssignCargoWithWaybill(releaseRequest, ti);
	assertEqual(releaseRequest.allTrackedItemsAssigned.size, 1);
	assertEqual(releaseRequest.allReserveDetails.size, 1);
	//assertEqual(releaseRequest.allReserveDetails.first.CM_ReserveSelection.allTrackedItems.size, 1);
	assertEqual(releaseRequest.allReserveDetails.first.CM_ReserveSelection.getAllTrackedItemsSize(false), 1); //23/06/2023	navkc1	CR 58406 Task 58408
		
	ti1 := self.addContainer("UUT00000002", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti1, bs);
	self.releaseAssignCargoWithWaybill(releaseRequest, ti1);
	assertEqual(releaseRequest.allTrackedItemsAssigned.size, 2);
	assertEqual(releaseRequest.allReserveDetails.size, 1);
	//assertEqual(releaseRequest.allReserveDetails.first.CM_ReserveSelection.allTrackedItems.size, 2);
	assertEqual(releaseRequest.allReserveDetails.first.CM_ReserveSelection.getAllTrackedItemsSize(false), 2); //23/06/2023	navkc1	CR 58406 Task 58408
	assertEqual(releaseRequest.status, BR_ACTIVE);
	
	releaseRequest1 := addReleaseByTypeRequest("UTRRRoad1", BR_TYPE_ROAD, TI_CargoType_Container, "2200");
	assertEqual(releaseRequest1.status, BR_ACTIVE);
	
	self.releaseAssignCargoWithWaybill(releaseRequest1, ti);
	assertEqual(releaseRequest1.allTrackedItemsAssigned.size, 1);
	assertEqual(releaseRequest1.allReserveDetails.size, 1);
	//assertEqual(releaseRequest1.allReserveDetails.first.CM_ReserveSelection.allTrackedItems.size, 1);
	assertEqual(releaseRequest1.allReserveDetails.first.CM_ReserveSelection.getAllTrackedItemsSize(false), 1); //23/06/2023	navkc1	CR 58406 Task 58408

	self.releaseAssignCargoWithWaybill(releaseRequest1, ti1);
	assertEqual(releaseRequest1.allTrackedItemsAssigned.size, 2);
	assertEqual(releaseRequest1.allReserveDetails.size, 1);
	//assertEqual(releaseRequest1.allReserveDetails.first.CM_ReserveSelection.allTrackedItems.size, 2);
	assertEqual(releaseRequest1.allReserveDetails.first.CM_ReserveSelection.getAllTrackedItemsSize(false), 2); //23/06/2023	navkc1	CR 58406 Task 58408
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tTwoRelWithMultiCargoWithoutWa" id="a4ae3df5-be00-4d7b-a729-fb0ad1adf289">
