    <JadeMethod name="isFunctionForItem" id="ac8cddb1-da12-45bd-bc27-1a27afba0d0f">
        <source>isFunctionForItem(_item :String) : Boolean;
//
// 14 Jun 2018	jlgrs1	TFS 39018 SNO Cargo Operator in COPRAR
//
vars
	rule : CM_EDIRule;
	result : Boolean;
begin
	foreach rule in self.allEDIPartyRules do
		if rule.getItem &lt;&gt; _item  then
			continue;
		endif;
		result := true;
		break;
	endforeach;
	return result;
epilog

end;</source>
        <Parameter name="_item" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMatchForFunction" id="80670409-90ec-4cda-bc40-a9ec1cee8916">
        <source>isMatchForFunction(_item :String; _value :String; _function :Integer; _ruleValue, _segmentValue :String output):Boolean;
/*
Purpose		We are looking for a particular rule

Date		Who		Reason
04 Jul 2013	cnwcs5	Initial Creation - par 31942 CCMS POL 2220 - FTX segment processing for Coparn/IFTMCS bookings
*/
vars
	rule	:CM_EDIRule;
	result	:Boolean;
begin
	foreach rule in self.allEDIPartyRules do
		if rule.getItem &lt;&gt; _item or rule.getFunction &lt;&gt; _function then
			continue;
		endif;
		
        if rule.isMatch( _item, _value, _ruleValue, _segmentValue) then
            result := true;
            break;
        endif;
	endforeach;
	
	return result;
epilog

end;</source>
        <Parameter name="_item" type="String"/>
        <Parameter name="_value" type="String"/>
        <Parameter name="_function" type="Integer"/>
        <Parameter name="_ruleValue" type="String" usage="output"/>
        <Parameter name="_segmentValue" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processBookingFTXSegment" id="e26cdc14-d0ba-4179-8cd6-9bca500a1fe0">
        <source>processBookingFTXSegment(_segment :String; _ediTI :CM_EDIBookingItemTI input):Boolean;
/*
Date		Who		Reason
04 Jul 2013	cnwcs5	Initial Creation - par 31942 CCMS POL 2220 - FTX segment processing for Coparn/IFTMCS bookings
*/
constants
	WILDCARD 	= '*';
vars
	ftxString, ruleItem, ruleValue, ruleElement,
	remarks			:String;
	ftxArray, ruleArray, ignoreColl		:StringArray512;
	obj									:Object;
	rule, remarksRule					:CM_EDIEDIFactRule;
	result, ignoreSegment				:Boolean;
	int, size							:Integer;
	vent								:Decimal [14,4];
	specialStow : String;
begin
	if not _segment.startsWith ('FTX+') then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid segment value - expecting FTX');
	endif;
	
	// strip off FTX+
	ftxString := _segment [5:end];
	
	if ftxString.endsWith ("'") then
		ftxString := ftxString[1:ftxString.length()-1];	// strip off "'"
	endif;
	
	// populate array with all elements in the segment
	create ftxArray transient;

	ftxString.getTokensForDelimiter ('+', ftxArray);
	
	size := ftxArray.size;
	
	if size &lt; 1 then
		// something VERY wrong
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid segment - expecting FTX1.1');
		
	elseif size &lt; 4 then
		// don't expect this to happen but will save us checking size later
		ftxArray[4] := null;
	endif;
	
	// we need to find any 'Booking - Ignore Text' rules 1st for when we are processing 'Booking - Remarks'
	create ignoreColl transient;
	create ruleArray transient;

	foreach obj in self.allEDIPartyRules do	:outerLoop
		rule 		:= obj.CM_EDIEDIFactRule;
		ruleItem 	:= rule.item;
		
		if ruleItem &lt;&gt; CM_EDIEDIFactRule.Item_FTX_1_1
		and ruleItem &lt;&gt; CM_EDIEDIFactRule.Item_FTX_3_1	//07 Jun 2017	NDL	TFS 4454
		and ruleItem &lt;&gt; CM_EDIEDIFactRule.Item_FTX_4_1
		then
			// not an FTX rule
			continue;
		endif;
		
		if ruleItem = CM_EDIEDIFactRule.Item_FTX_1_1 then
			if rule.function = CM_EDIEDIFactRule.Function_FTX_1_1_BookingRemark then
				ruleArray.clear;
				// get rule values for all segments
				rule.value.getTokensForDelimiter ('+', ruleArray);
		
				if ruleArray.isEmpty or ftxArray[1] &lt;&gt; ruleArray[1] then
					// 010 - text subject qualifier does not match
					continue outerLoop;
				endif;
			
				// we need to process remarks for this segment but not till we know
				// all the text we need to ignore
				remarksRule	:= rule;
			endif;
			
		elseif ruleItem = CM_EDIEDIFactRule.Item_FTX_3_1 then	//07 Jun 2017	NDL	TFS 4454
		
			if rule.function = CM_EDIEDIFactRule.Function_FTX_3_1_Stowage then
				if ftxArray[1] = rule.value then
					specialStow := rule.getFTXSpecialStowage(ftxArray);
					if specialStow &lt;&gt; null then
						_ediTI.specialStowage := specialStow;
					endif;
				endif;
			endif;
				
		elseif ruleItem = CM_EDIEDIFactRule.Item_FTX_4_1 then 
						
			if rule.function = CM_EDIEDIFactRule.Function_FTX_4_1_BookingIgnore then 
				if not ignoreSegment then
					ruleElement := rule.getFTXBookingIgnoreText (ftxArray, ignoreSegment);
					
					if ignoreSegment then
						continue outerLoop;
					endif;
					
					// rule element will be used later to determine which sub-elements to ignore
					ignoreColl.add (ruleElement);
				endif;
				
			elseif rule.function = CM_EDIEDIFactRule.Function_FTX_4_1_BookingVent then	 					
				vent  := rule.getFTXBookingVentilation (ftxArray);
								
				if vent &lt;&gt; NULL_VENTILATION then
					_ediTI.vent := vent;	// CBM/H
				endif;
				
			endif;
		endif;
	endforeach;
	
	// this last section records bookinmg remarks if necessary while taking into account any text
	// that should be ignored
	if remarksRule &lt;&gt; null then
		if not ignoreSegment then
			// remarks are in 040
			remarks := remarksRule.getFTXBookingRemarks (ftxArray[4], ignoreColl); 
				
			if remarks &lt;&gt; null then  
				if _ediTI.remarks = null then
					_ediTI.remarks := remarks;
				else
					_ediTI.remarks := _ediTI.remarks &amp; ' ' &amp; remarks; 
				endif;
			endif;
		endif;
		
		result := true;
	endif;
			
	return result;
epilog
	delete ignoreColl;
	delete ruleArray;
	delete ftxArray;
end;</source>
        <Parameter name="_segment" type="String"/>
        <Parameter name="_ediTI" type="CM_EDIBookingItemTI" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="1f5958b7-fead-4b29-a9e8-063a6b6b953d">
        <source>pxyCreateUpdateProxy(): SelfType;
/*
Date		Who		Reason
16/11/2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	proxy			:CM_EDIPartyRules;
	rule, pxyRule	:CM_EDIRule;
begin
	proxy := inheritMethod();
	
	proxy.myEDIConfig	:= self.myEDIConfig;
	proxy.myEDIFileType	:= self.myEDIFileType;

	foreach rule in self.allEDIPartyRules do
		pxyRule := rule.pxyCreateUpdateProxy;
		
		pxyRule.setMyEDIPartyRules (proxy);
	endforeach;

	return proxy;
epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="3f4a9290-bd39-4066-a266-121f478ee025">
        <updating/>
        <source>setForCreate(_proxy :CM_EDIPartyRules)updating;
/*
Date		Who		Reason
16/11/2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars

begin
	self.raiseExceptionIfTransient (method);
		
	self.setForUpdate (_proxy);
	
	self.myEDIConfig	:= _proxy.myEDIConfig;		// never changes
	self.myEDIFileType	:= _proxy.myEDIFileType;	// never changes	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_EDIPartyRules"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="26bc1536-12da-43f7-8a80-db9cd6e47dfe">
        <updating/>
        <source>setForUpdate(_proxy :CM_EDIPartyRules)updating;
/*
Date		Who		Reason
16/11/2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	rule, pxyRule	:CM_EDIRule;
begin
	self.raiseExceptionIfTransient (method);
	
	self.emailAddress	:= _proxy.emailAddress;
	
	self.allCopyEmailAddresses.clear;
	
	_proxy.allCopyEmailAddresses.copy (self.allCopyEmailAddresses);
	
	// replace all the rules (if any)	
	self.allEDIPartyRules.purge;
	
	foreach pxyRule in _proxy.allEDIPartyRules do
		create rule as pxyRule.class persistent;
			
		rule.setForCreate (pxyRule);
			
		rule.setMyEDIPartyRules (self);
	endforeach;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_EDIPartyRules"/>
    </JadeMethod>
    <JadeMethod name="setMyEDIConfig" id="45b3bbac-c629-42a7-9675-13fa95fdd1a1">
        <updating/>
        <source>setMyEDIConfig(_value :CM_EDIConfig)updating;
/*
Date		Who		Reason
16/11/2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars

begin
	self.myEDIConfig := _value;
epilog

end;</source>
        <Parameter name="_value" type="CM_EDIConfig"/>
    </JadeMethod>
