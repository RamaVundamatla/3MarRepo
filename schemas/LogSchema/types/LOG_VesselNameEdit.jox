    <JadeMethod name="btnCancel_click" id="8d7278a3-a1ca-443f-9e0c-b68b6c7641fa">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;

vars

begin
	self.doCancel();
end;
</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnSave_click" id="52e3684e-48c6-49e4-9fd7-37d6afab57ca">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSave_click(btn: Button input) updating;

vars

begin
	if self.doSave() then
		self.unloadForm();
	endif;
end;
</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCancel" id="eedf7ca0-f993-4d12-b910-78179a7cd525">
        <updating/>
        <source>doCancel() updating, protected;

vars

begin
	self.vesselName := null;
	self.unloadForm();
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="fb9eb6e2-4d91-47bb-8f42-96d9a01d89c2">
        <updating/>
        <source>doSave() : Boolean updating, protected;
// add or update a CM_CurrencyCode for the IMO with the vessel name as description
vars
	theReturn	: Integer;
	description	: String;
	code		: CM_CurrencyCode;
	proxyCode	: CM_CurrencyCode;
	
begin
	code := app.myRoot.allCurrencyCodes[self.imo];
	if code = null then
		create proxyCode transient;
	else
		beginLoad;
		proxyCode := code.pxyCreateUpdateProxy();
		endLoad;
	endif;
	
	description := self.txtVesselName.text.trimBlanks();
	proxyCode.setProxy(self.imo, description);
	
	while true do
		if code = null then
			app.myTrxCA.trxCreateCurrencyCode(proxyCode, code, app.myPassport);
		else
			app.myTrxUA.trxUpdateCurrencyCode(proxyCode, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.vesselName := description;
			self.clearErrorWarnings();
			return true;
		else
			theReturn := app.showErrorWarningDialog("Vessel Name Edit", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
			return false;
		endif;
		break;
	endwhile;

epilog
	delete proxyCode;
end;
</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="fcb283b6-e000-4968-b9e3-221a7b8da981">
        <updating/>
        <source>setupForm() updating;

vars
	code	: CM_CurrencyCode;
begin
	inheritMethod();
	
	self.lblIMOValue.caption := self.imo;
	code := app.myRoot.allCurrencyCodes[self.imo];
	if code &lt;&gt; null then
		self.txtVesselName.text := code.description;
	endif;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="71eab666-9da7-4b8d-b627-c97ce4b2b791">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 21 February 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019485, locale);
	btnCancel.translateCaption(Xlat_0019486, locale);
	btnSave.translateCaption(Xlat_0019487, locale);
	lblIMO.translateCaption(Xlat_0019488, locale);
	lblVesselName.translateCaption(Xlat_0019489, locale);
end;</source>
    </JadeMethod>
</GUIClass>
