    <JadeMethod name="verifyEDIDataTIs" id="697cf8b3-055d-46b3-867c-bd26a65d7388">
        <updating/>
        <source>verifyEDIDataTIs(_passport: CM_Passport input): Integer updating;
/*

Date		Who		Reason
02 June 2015	cnwer1	Initial creation PAR
// 12 Nov 2018	jlgrs1	TFS 41659 STWR Make EDI MultiThreaded Stage 6
*/

vars

begin
	app.myTrxUA.trxProcessEDIData(self, true, false, _passport);
	return _passport.allErrorWarnings.size;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
