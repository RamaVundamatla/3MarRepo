<Class name="CM_RemoteJobListQueryHdr" id="799fe14c-9c07-42e3-ad9a-bdf555500aca">
    <superclass name="CM_RemoteDataHdr"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Job List Query&lt;/display&gt;</text>
    <DbClassMap file="remoteDataProcessing"/>
    <CompAttribute name="allQueues" id="52e70036-3fee-4ae1-90a0-0c1425066759">
        <type name="StringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <JadeMethod name="buildQueueResponse" id="c869b721-4453-4612-88e5-1a740b4b1b99">
        <source>buildQueueResponse(_subQueue : CM_RadioTelemetryQueue) : String protected;
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars

	response	: String;
	isFirst		: Boolean;
	entry		: CM_RTQueueEntry;
	type,
	oldType		: String;
	isFound		: Boolean;

begin

	response := response &amp; self.formatAsXMLPrefix(XML_QUEUEDTLS) &amp; 
	self.formatAsXML(XML_ID, _subQueue.id) &amp; self.formatAsXMLPrefix(XML_JOBLST);
	isFirst := true;
	//foreach entry in _subQueue.allEntries do
	foreach entry in _subQueue.allEntries discreteLock do	//15 Feb 2011	NDL	Par 26994
		type := entry.myJob.getXMLType();
		if type &lt;&gt; oldType then
			if not isFirst then
				response := response &amp; self.formatAsXMLSuffix(XML_JOBDTL);
			endif;
			response := response &amp; '&lt;' &amp; XML_JOBDTL &amp; ' class="' &amp; type &amp; '" type=' &amp; 
			CM_RemoteDataObject.Type_Summary &amp; '&gt;' &amp; CrLf;
		endif;
		response := response &amp; self.formatAsXML(XML_JOB, entry.getDetailForRemoteQuery(CM_RemoteDataObject.Type_Summary));
		oldType := type;
		isFirst := false;
		isFound	:= true;
	endforeach;
	if not isFirst then
		response := response &amp; self.formatAsXMLSuffix(XML_JOBDTL);
	endif;
	response := response &amp; self.formatAsXMLSuffix(XML_JOBLST);
	response := response &amp; self.formatAsXMLSuffix(XML_QUEUEDTLS);
	if isFound then
		return response;
	endif;
	return null;

end;</source>
        <access>protected</access>
        <Parameter name="_subQueue" type="CM_RadioTelemetryQueue"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getJobListQueryResponse" id="76d5a1ec-a2af-49e7-b5ff-d3da19843e2d">
        <source>getJobListQueryResponse(_error : Integer output; _errorTxt : String output) : String protected;


vars
	
	queue,
	errStr,
	response		: String;
	isFound			: Boolean;
	userMsg			: String;
	myTerminal		: CM_Terminal;
	masterQueue		: CM_MasterQueue;
	subQueue		: CM_RadioTelemetryQueue;
	isFirst			: Boolean;
	tempResponse	: String;
	
begin

	response := self.formatAsXMLPrefix(XML_BDY);
	userMsg := self.getUserMsg();
	if userMsg &lt;&gt; null then
		response := response &amp; self.formatAsXML(XML_USRMSG, userMsg);
	endif;
	
	
	myTerminal := app.myRoot.allTerminals[self.terminal];
	if myTerminal = null then
		_error 		:= Err_InvalidTerminal;
		_errorTxt	:= app.getErrorString1(Err_InvalidTerminal, self.terminal);
		return null;
	endif;
	
	masterQueue := myTerminal.radioTelemetry.masterQueue;
	if self.allQueues.size &gt; 0 then
		foreach queue in self.allQueues do
			subQueue := masterQueue.allSubQueuesById[queue];
			if subQueue = null then
				errStr := errStr &amp; ', ' &amp; queue;
			else
				tempResponse := buildQueueResponse(subQueue);
				if tempResponse &lt;&gt; null then
					response := response &amp; tempResponse;
					isFound := true;
				endif;
			endif;
		endforeach;
	else
		foreach subQueue in masterQueue.allSubQueuesById do
			tempResponse := buildQueueResponse(subQueue);
			if tempResponse &lt;&gt; null then
				response := response &amp; tempResponse;
				isFound := true;
			endif;	
		endforeach;
	endif;
	

	if errStr.length &gt; 2 then
		_error := Err_InvalidQueue;
		_errorTxt := app.getErrorString1(Err_InvalidQueue, null) &amp; ' ' &amp; errStr[3 : end];
	endif;

	if isFound then
		return response &amp; self.formatAsXMLSuffix(XML_BDY);
	endif;
	return null;	
end;</source>
        <access>protected</access>
        <Parameter name="_error" type="Integer" usage="output"/>
        <Parameter name="_errorTxt" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMessageResponseType" id="d4c5a72e-bb1d-4caf-aa00-620e1821850f">
        <source>getMessageResponseType(): String;

vars

begin
	return CM_RemoteDataManager.JOBLSTQRYRSP;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUserMsg" id="43d99538-4b60-4c2b-be10-aa0ebdc145c3">
        <source>getUserMsg() : String protected;

vars

begin

	return null;

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processExternal" id="c6042199-e3c4-4fa2-afd0-a7ecfb3acd7c">
        <updating/>
        <source>processExternal(_parseAgent: CM_RemoteParseAgent io): String updating;

vars

	err			: Integer;
	errTxt		: String;
	response	: String;
	headerCast	: CM_RemoteDataHdr;

begin

	response := inheritMethod(_parseAgent);
	if response = null then
		if _parseAgent.createJobListQueryDetail(self) then
			response := self.getJobListQueryResponse(err, errTxt);
			return self.doBuildMessage(self.xmlResponse(err, errTxt) &amp; response);
		endif;
		response := app.getErrorString1(Err_XML, 'Job list query');
		return self.doBuildMessage(self.xmlResponse(Err_XML , response));
	endif;
	headerCast := self;
	return self.doBuildMessage(self.xmlDefaultResponse(headerCast, Err_XML , response));
			
end;</source>
        <Parameter name="_parseAgent" type="CM_RemoteParseAgent" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyForJobListQueryHdr" id="92a780db-5a15-464d-8286-1d96275a1521">
        <updating/>
        <source>setProxyForJobListQueryHdr(_allQueues	: HugeStringArray) updating;

vars

begin

	self.raiseExceptionIfNotTransient(method);
	_allQueues.copy(self.allQueues);

end;</source>
        <Parameter name="_allQueues" type="HugeStringArray"/>
    </JadeMethod>
</Class>
