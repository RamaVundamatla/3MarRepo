    <JadeMethod name="resizeOnMove" id="dcef1e5b-483d-4344-9c05-d012e89ea531">
        <updating/>
        <source>resizeOnMove() updating;
// ---------------------------------------------------------------------------
// Created:     09 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	DockMargin	: Integer = 50;

vars
	dockTop,
	dockBottom,
	dockLeft	: Boolean;
	theFrame	: Form;
	frameHeight	: Real;
	
begin

	self.savedTop := self.top;

	// deimplemented as can new set by menu.
	return;

/*
	
	theFrame := self.getMdiFrame();
	if theFrame.isKindOf(CM_MDIFrame) then
		frameHeight := theFrame.CM_MDIFrame.clientWindowHeight;
	else
		frameHeight := theFrame.clientHeight;
	endif;

	if self.left &lt; DockMargin then
		dockLeft := true;
	endif;
	
	if self.top &lt; DockMargin then
		dockTop := true;
	elseif (self.top + self.height &gt; frameHeight) or self.lockType then
		dockBottom := true;
	endif;
	
	if dockLeft then
		self.left := 0;
		if dockTop then
			self.top := 0;
			self.width := 250;
		elseif dockBottom then
			self.top := frameHeight - self.height;
			self.width := theFrame.clientWidth;
		else
			self.width := 250;
		endif;
	elseif dockTop then
		self.left := 0;
		self.top := 0;
		self.width := theFrame.clientWidth;
	elseif dockBottom then
		self.left := 0;
		self.top := frameHeight - self.height;
		self.width := theFrame.clientWidth;
	endif;
	
	self.positionControls();

	self.savedTop := self.top;
*/
end;</source>
    </JadeMethod>
    <JadeMethod name="setCollection" id="09fccf75-b12e-456f-9692-170ee628fdd6">
        <source>setCollection(pAllErrorWarnings : CM_ErrorSet);
// ---------------------------------------------------------------------------
// Created:     26 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.tblData.clear;
	if pAllErrorWarnings.isEmpty then
		return;
	endif;

	self.tblData.displayCollection(pAllErrorWarnings, false, Table.DisplayCollection_Forward, null);
	self.tblData.cnEcResizeContents();

end;</source>
        <Parameter name="pAllErrorWarnings" type="CM_ErrorSet"/>
    </JadeMethod>
    <JadeMethod name="setCurrentForm" id="988d981b-3c46-4f40-bb0b-91769c159d3c">
        <updating/>
        <source>setCurrentForm(pForm : CM_BaseForm) updating;
// ---------------------------------------------------------------------------
// Created:     07 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpCaption	: String;

begin

	if pForm = self then
		// We never want to set the current form to be this form
		return;
	endif;

	tmpCaption := "Errors and Warnings";

	if self.myCurrentForm &lt;&gt; pForm then
		self.myCurrentForm := pForm;
	endif;
	if pForm &lt;&gt; null then
		self.setCollection(pForm.allErrorWarnings);
		tmpCaption := tmpCaption &amp; ' for ' &amp; pForm.caption;
	else
		self.tblData.clear;
	endif;

	if tmpCaption.length &gt; 255 then  //cnwrd1 14.7.2008 par #17328
		tmpCaption := tmpCaption[1:255];
	endif;
	self.caption := tmpCaption;

end;</source>
        <Parameter name="pForm" type="CM_BaseForm"/>
    </JadeMethod>
    <JadeMethod name="setFromLockType" id="c1fe0211-cf88-4c71-8bf9-3d0e892b8d1c">
        <updating/>
        <source>setFromLockType() updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 24 February 2004
//
//********************************************************************
vars

begin
	if self.lockType = LockType_Bottom then
		self.doLockBottom;
	elseif self.lockType = LockType_Left then
		self.doLockLeft;
	elseif self.lockType = LockType_Right then
		self.doLockRight;
	else 
		self.doFloating;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="show" id="fa55834b-01cf-4927-a1c7-05eec88c03f7">
