    <JadeMethod name="populateEntDetailTable" id="17a75b04-e689-4af3-8585-5d088f9305e1">
        <source>populateEntDetailTable();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	entRow			: EntTableRow;
	invoiceType : CM_DebtorInvoiceLineDesc;
	displayValue	: String;	
	entDef		:EntTableDef;
begin
	entDef := app.myController.getEntTableDef(ETDef_InvMaintLineDebtorEnt);

	invoiceType := self.myCurrentObject.CM_DebtorInvoiceLineDesc;
	if self.mode = Mode_Add then
		self.tblEntDetail.clearValues();
		return;
	endif;	
	if invoiceType = null then
		return;
	endif;
	
	foreach entRow in entDef.allEntTableRows do
		if invoiceType &lt;&gt; null then
			displayValue := invoiceType.getDisplayStringForAttribute(entRow.name, false).String;
		else
			displayValue := null;
		endif;
		
		tblEntDetail.setValueByName(entRow.name, displayValue);		
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="setAvailableDebtors" id="b8e0cb09-50f3-45dd-b30b-ff7552605eec">
        <source>setAvailableDebtors(_theConsol : CM_DebtorInvoiceLineDesc);
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theDebtors : CM_DebtorByNameDict;
	aDebtor : CM_Debtor;
begin
	create theDebtors transient;
	foreach aDebtor in app.myRoot.myRootCompany.debtors do
		if not aDebtor.allConsolidatedInvoiceLineDesc.includes(_theConsol) then
			theDebtors.add(aDebtor);
		endif;
	endforeach;
	
	if _theConsol &lt;&gt; null then
		foreach aDebtor in _theConsol.allConsolidatingDebtor do
			theDebtors.add(aDebtor);
		endforeach;
	endif;
	self.msgDebtors.setAvailable(theDebtors,true);
epilog
	delete theDebtors;
end;</source>
        <Parameter name="_theConsol" type="CM_DebtorInvoiceLineDesc"/>
    </JadeMethod>
    <JadeMethod name="setAvailableLines" id="1f290de7-9fc3-4cd9-b35c-e17876ff2422">
        <source>setAvailableLines(_theGroup : CM_DebtorInvoiceLineDesc);
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theLines : CM_InvoiceLineDescByNarrDict;
	ldsc : CM_InvoiceLineDesc;
begin
	create theLines transient;
	foreach ldsc in self.myCurrentBank.invoiceLineDescriptors do
		if ldsc.allConsolidatedDebtorInvLineD.isEmpty then
			theLines.add(ldsc);
		endif;
	endforeach;
	
	if _theGroup &lt;&gt; null then
		foreach ldsc in _theGroup.allConsolidatingInvLineDesc do
			theLines.add(ldsc);
		endforeach;
	endif;
	self.msgLines.setAvailable(theLines,true);
epilog
	delete theLines;
end;</source>
        <Parameter name="_theGroup" type="CM_DebtorInvoiceLineDesc"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="5dd801bf-7a56-4696-93da-ef4fbe120204">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_colorControl);
	self.setColorsForEntryTable(self.tblEntDetail);
	self.fldEntDetail.backColor := self.backColor;
//	self.shtEntDetail.backColor := self.backColor;
//	self.shtLines.backColor := self.backColor;
	
	self.msgLines.backColor := self.backColor;
	self.msgDebtors.backColor := self.backColor;
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="413c725b-3440-4e22-a6bb-f6d763f5524c">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theLine : CM_DebtorInvoiceLineDesc;
begin
	inheritMethod();
	
	theLine := self.myCurrentObject.CM_DebtorInvoiceLineDesc;

//	self.setAvailableLines(theLine); // PAR 11827
	self.setAvailableDebtors(theLine);

	if self.mode = self.Mode_Add then
		self.msgLines.setSelected(null);
		self.msgDebtors.setSelected(null);
	else
		self.msgLines.setSelected(theLine.allConsolidatingInvLineDesc);
		self.msgDebtors.setSelected(theLine.allConsolidatingDebtor);
	endif;
	self.fldEntDetail.visible := true;
	self.populateEntDetailTable();
	self.tblEntDetail.setFocus;
	self.tblEntDetail.goToRowByName(ETRow_Narration);
	self.fldEntDetail.initSheetBackColors();
end;</source>
    </JadeMethod>
