    <JadeMethod name="doSetCaption" id="0dff4eed-8999-4d22-aa7e-c3f1c0bb1511">
        <updating/>
        <source>doSetCaption() updating;
/*
Purpose:			
Date				Who			Reason
SEPT 2013		CNWAB1		Initial creation
*/
vars
	flipString, accessString, naviString : String;
	theCaption : String;
	aTA : Object;
	tmpDC :	YRD_GCRackDrawingController;
begin
	tmpDC := self.myCurrentDrawingController;

	if tmpDC = null then
		return;
	endif;
	
	naviString := theCaption;
	theCaption := null;

	
	theCaption := theCaption &amp; self.myCurrentTerminalArea.id &amp; " Warehouse Area.";

	theCaption := theCaption &amp; " " &amp; self.myTerminal.code;
	naviString := naviString[1:naviString.length - 2];
	
	// PAR #26983 truncate theCaption to 255 characters (maximum valud allowed) if it exceeds this
	if theCaption.length &gt; 255 then
		theCaption := theCaption[1:252] &amp; "...";
	endif;
	// PAR 26983 end
	self.caption := theCaption;
	// Update the navigator
	self.setNavigatorHeading(naviString); 

end;</source>
    </JadeMethod>
    <JadeMethod name="doSetSelectorCriteria" id="73717c0f-befc-474c-9966-b302a0f097f4">
        <source>doSetSelectorCriteria(_queryParams: CM_QueryCriteriaLineHolder input;_queryDef	: CM_QueryDefinition;_property : String; _operator : String; _value : Any);
// ---------------------------------------------------------------------------
// Created:		22 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	criteria: CM_SelectorCriteriaLine;
	queryProperty,clonedProp			: CM_QueryProperty;
	queryOperator,clonedOp			: CM_QueryOperator;
	queryValue				: Any;
begin
	create criteria transient;
	queryProperty := _queryDef.allQueryProperties[_property];
	queryOperator := queryProperty.allAllowedOperators[_operator];
	queryValue := queryProperty.translateToSearchValue(_value); 
	clonedProp := queryProperty.cloneSelf(true);
	clonedOp := queryOperator.cloneSelf(true);

	clonedOp.setSearchValue(queryValue);	
	criteria.set(clonedProp, clonedOp, false);
	criteria.setMyCriteriaLineHolder(_queryParams);

end;</source>
        <Parameter name="_queryParams" type="CM_QueryCriteriaLineHolder" usage="input"/>
        <Parameter name="_queryDef" type="CM_QueryDefinition"/>
        <Parameter name="_property" type="String"/>
        <Parameter name="_operator" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doShowHideSubMainCol" id="0b115ed0-61e8-4d8f-9d7a-c765e189c613">
        <updating/>
        <source>doShowHideSubMainCol() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

begin

	if not self.xmlSelector or not self.xmlLegend then
		if not self.dkcSubMainCol.visible then
			//at least one is trying to be visible
			self.dkcSubMainCol.visible := true;
			
			//Don't be clever and consolidate this, it doesn't work without resetting it twice.
			//(Adds the dock bar back on the wrong side with neither.)
			//(Leaves out the splitter without the second one.)
			self.dkcSubMainCol.alignContainer := JadeDockBar.AlignContainer_Left;
			self.dkcSubMainCol.alignContainer := JadeDockBar.AlignContainer_AllVertical;
		
		endif;
		
	else
		//neither visible
		self.dkcSubMainCol.visible := false;
	endif; 

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTableClick" id="21744311-b492-4838-b334-38cac0f80233">
        <updating/>
        <source>doTableClick(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		DO NOT DELETE Call back from CMUI_ColourLegendFrame
//
// ---------------------------------------------------------------------------
vars
	anObject : CM_Object;
begin


	if table = null then
		return;
	endif;
	if table.row &lt;= table.fixedRows then
		return;
	endif;

	if table.CM_ColourLegendTable.myCaller.CMUI_ColourLegendFrame.viewMode &lt;&gt; VIEW_YARD_ALLOC then
		return;
	endif;
	anObject := table.accessRow(table.row).itemObject.CM_Object ;

	self.doDisplayYardAllocation(anObject.CM_YardAllocation);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTableDblClick" id="57171367-2e46-4c61-b903-151aaac7212e">
        <updating/>
        <source>doTableDblClick(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		DO NOT DELETE Call back from CMUI_ColourLegendFrame
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	anObject : CM_Object;
	aForm 	: Form;
	menuAction 		: CMUI_MenuAction;
begin

	if table = null then
		return;
	endif;
	if table.row &lt;= table.fixedRows then
		return;
	endif;

	anObject := table.accessRow(table.row).itemObject.CM_Object;
	if anObject &lt;&gt; null then
		if anObject.isKindOf(CM_Voyage) then
			self.myAssistant.showVoyageDefForm(anObject.CM_Voyage, self.myMasterMenuAction, false, false);
		elseif anObject.isKindOf(CM_Train) then
			self.myAssistant.showTrainMaintenance(anObject.CM_Train, self.myMasterMenuAction, null, self);
		elseif anObject.isKindOf(CM_CargoType) then
			self.myAssistant.showCargoTypeForm(anObject.CM_CargoType, self.myMasterMenuAction, true, false);
		else
			self.myAssistant.showTableMaintForm(anObject, self.myMasterMenuAction, false, false);
		endif;
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblPopupInfoDbClick" id="b64fcf31-e810-410a-aad4-6532ae4051e9">
        <updating/>
        <source>doTblPopupInfoDbClick(table : Table input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	obj	: Object;
begin
	if table.row &lt;= table.fixedRows or 
	   table.column &lt;= table.fixedColumns then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	obj := table.accessCell(table.row, table.column).itemObject.Object;
	if obj &lt;&gt; null then

		if obj.isKindOf(CM_GridController) then
			self.myAssistant.showTerminalAreaForm(obj.CM_LocationsController.myTerminalArea, self.myMasterMenuAction);
		elseif obj.isKindOf(CM_TrackedItem)  then
			self.myAssistant.showCargoEnquiryForm(obj.CM_TrackedItem, self.myMasterMenuAction, true, false);	
		elseif obj.isKindOf(CM_Voyage) then
			self.myAssistant.showVoyageDefForm(obj.CM_Voyage, self.myMasterMenuAction, false, false);

		elseif obj.isKindOf(CM_LocationsController) 
		or  obj.isKindOf(CM_TerminalArea) 
		or  obj.isKindOf(CM_IrregularBlockController) 
		or  obj.isKindOf(CM_Voyage) 
		or  obj.isKindOf(CMUI_GridDrawingController) 
		or  obj.isKindOf(CM_RackShelfController)  // TFS 43424
		or  obj.isKindOf(CM_IrregularBlockController)  // TFS 43424
		or  obj.isKindOf(CMUI_GridPoint) then
			if app.isAllowedToInspect then
				obj.inspect;
			endif;

		elseif obj.isKindOf(CM_Object) then
			self.myAssistant.showTableMaintForm(obj.CM_Object, self.myMasterMenuAction, true, true);
		endif;
	endif;

epilog
	app.mousePointer := MousePointer_Default;


end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
