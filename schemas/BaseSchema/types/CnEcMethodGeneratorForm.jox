    <JadeMethod name="generateFile" id="a6dfe967-ef61-4fb0-b6b3-4dab20cbac25">
        <updating/>
        <source>generateFile() updating;

vars
	classCollObj	: ClassColl;
	dbFileObj		: File;
	trxFileObj		: File;

begin
	txtOutcome.text := "";
	btnBack.enabled := false;

	create classCollObj transient;
	self.populateTheClassColl(classCollObj);
	
	if chkCreateTrx.value
	or chkDeleteTrx.value
	or chkUpdateTrx.value
	then
		create dbFileObj;
		
		dbFileObj.fileName := txtOutputNameTrx.text;
		
		self.trxMethodsCreate(	classCollObj,
								dbFileObj,
								optReplaceTrx.value,
								chkCreateTrx.value,
								chkDeleteTrx.value,
								chkUpdateTrx.value);
		
		txtOutcome.text := txtOutcome.text &amp; CrLf &amp; dbFileObj.fileName &amp; "  created." &amp; CrLf;
		txtOutcome.text := txtOutcome.text &amp; CrLf;
		dbFileObj.close();
	endif;
	
	if	chkInitializeMe.value
	or 	chkUpdateMe.value
	or	chkValidateMe.value
	or chkObjectCreate.value
	then
		create trxFileObj;
		
		trxFileObj.fileName := txtOutputNameM.text;
		
		self.classMethodsCreate(classCollObj,
								trxFileObj,
								optReplaceMeth.value,
								chkInitializeMe.value,
								chkUpdateMe.value,
								chkValidateMe.value,
								chkObjectCreate.value);
		
		txtOutcome.text := txtOutcome.text &amp; CrLf &amp; trxFileObj.fileName &amp; "  created.";
		trxFileObj.close();
	endif;
	
	if txtOutcome.text = "" then
		txtOutcome.text := txtOutcome.text &amp; "No selections made, nothing generated." &amp; CrLf;
		btnBack.enabled := true;
		self.doWindowEvents(0);
	endif;
epilog
	delete classCollObj;
	delete dbFileObj;
	delete trxFileObj;
end;</source>
    </JadeMethod>
    <JadeMethod name="getMyParentProperty" id="6a328592-5678-4a8c-a466-ad734c7cccab">
        <source>getMyParentProperty(pSchemaObj:Schema; pClassObj:Class):Property;
		// used alongside getParentClass
vars
	arrayPointer	: Integer;
	propertyObj		: Property;
	propertyName	: String;
	
begin
	arrayPointer	:=	self.aMyParentArray.indexOf(pClassObj.name);
	
	if arrayPointer &lt;&gt; 0 then
		propertyName := self.aMyParentPropertyArray[arrayPointer];
		
		if propertyName &lt;&gt; "" then
			propertyObj	:=	pClassObj.getProperty(propertyName);
		endif;
	endif;
	
	return propertyObj;
end;</source>
        <Parameter name="pSchemaObj" type="Schema"/>
        <Parameter name="pClassObj" type="Class"/>
        <ReturnType type="Property"/>
    </JadeMethod>
    <JadeMethod name="getParameterName" id="5a9fa91e-9c59-42e9-8547-f8e954887f7c">
        <source>getParameterName(pPropertyObj : Property):String;

vars
	retValue		: String;
	
begin
	retValue := "p" &amp; pPropertyObj.name;
	retValue[2:1]	:= retValue[2:1].toUpper();
	
	return retValue;
end;</source>
        <Parameter name="pPropertyObj" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getParentClass" id="d32ce511-e199-4056-b92f-8d6fd198682b">
        <source>getParentClass(pSchemaObj:Schema; pClassObj:Class):Class;

vars
	arrayPointer	: Integer;
	retValueObj		: Class;
	className		: String;
	parentName		: String;
	
begin
	arrayPointer	:=	self.aMyParentArray.indexOf(pClassObj.name);
	
	if arrayPointer &lt;&gt; 0 then
		self.aMyParentArray.cnEcGet(className, parentName, arrayPointer);
		
		if parentName &lt;&gt; "" then
			retValueObj	:=	pSchemaObj.getClass(parentName);
		endif;
	endif;
	
	return retValueObj;
end;</source>
        <Parameter name="pSchemaObj" type="Schema"/>
        <Parameter name="pClassObj" type="Class"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getPropertyList" id="d304f53b-73e0-4979-8df7-c5c221040835">
        <source>getPropertyList(pClassObj : Class; pAllClassProperties : PropertyNDict io);

vars
	propertyCollObj	: PropertyNDict;
	propertyObj		: Property;
	superClassObj	: Class;
	
begin
	pAllClassProperties.clear();
	propertyCollObj	:=	pClassObj.getProperties();

	foreach propertyObj in propertyCollObj do
		if self.checkExplicit(propertyObj) then
			continue;
		endif;
		
		pAllClassProperties.add(propertyObj);
	endforeach;
	
// cnwdad1 28/02/2003.
//	delete propertyCollObj;
	
	superClassObj	:=	pClassObj.getSuperclass();
	
	while superClassObj &lt;&gt; Object do
		propertyCollObj	:=	superClassObj.getProperties();
		
		foreach propertyObj in propertyCollObj do
			//if not theClassProperties.includes(propertyObj) then
				pAllClassProperties.add(propertyObj);
			//endif;
		endforeach;
		
// cnwdad1 28/02/2003.
//		delete propertyCollObj;
		superClassObj := superClassObj.getSuperclass();
	endwhile;
end;</source>
        <Parameter name="pClassObj" type="Class"/>
        <Parameter name="pAllClassProperties" type="PropertyNDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="hasErrorsDB" id="0d9a631b-2189-4c7a-8762-385823b4f0a0">
        <source>hasErrorsDB(): Boolean;

vars
	error	: String;
	isError	: Boolean;
	fileObj	: File;
	
begin
	if lblOutputNameTrx.caption = "" then
		error := error &amp; "Must enter an Output File name.  ";
	else
		create fileObj;
		fileObj.fileName := txtOutputNameM.text;
		fileObj.close();
	endif;
	
	if cmbModelSchema.text = "" then
		error := error &amp; "Must select a schema.  ";
	endif;

	if error &lt;&gt; null then
		app.msgBox(error, "Error", MsgBox_OK_Only);
		isError := true;
	endif;
epilog
	delete fileObj;
	return isError;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasErrorsTA" id="d63536e2-32ee-4096-be1f-2af41e769d4b">
        <source>hasErrorsTA(): Boolean;

vars
	error	: String;
	isError	: Boolean;
	fileObj	: File;
	
begin
	if cmbTrxAgent.text = "" then
		error := error &amp; "Must select a Transaction Agent.  ";
	endif;
	
	if lblOutputNameTrx.caption = "" then
		error := error &amp; "Must enter an Output File name.  ";
	else
		create fileObj;
		fileObj.fileName := txtOutputNameTrx.text;
		fileObj.close();
	endif;

	if cmbTrxSchema.text = "" then
		error := error &amp; "Must select a schema.  ";
	endif;

	if error &lt;&gt; null then
		app.msgBox(error, "Error", MsgBox_OK_Only);
		isError := true;
	endif;
epilog
	delete fileObj;
	return isError;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isClassValid" id="3d3adc23-3ee9-4c63-9de8-944d87ca5e8c">
        <source>isClassValid(pClassObj:Class):Boolean;

begin
	if pClassObj.cnEcIsGUI() then
		return false;
	endif;
	
	if pClassObj.inheritsFrom(Application)
	or pClassObj.inheritsFrom(Collection)
	or pClassObj.inheritsFrom(Global)
	or pClassObj.inheritsFrom(Schema)
	or pClassObj.inheritsFrom(WebSession)
	or pClassObj.inheritsFrom(CollClass)
	or pClassObj.name = "JadeScript"
	or pClassObj.name = "Node"
	or pClassObj.name = "Process"
	or pClassObj.name = "Feature"
	or pClassObj.name = "Class"
	or pClassObj.name = "ExplicitInverseRef" then
		return false;
	endif;
	
	return true;
end;</source>
        <Parameter name="pClassObj" type="Class"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadForm" id="b5da5a05-92f7-4076-8193-77bf0168e47d">
        <updating/>
        <source>loadForm() updating;

vars
	parentArrayObj	: CnEcDualStringArray;
	preamble		: String;
	
begin
	app.mousePointer	:=	Busy;
	inheritMethod();
	
	create parentArrayObj transient;
	self.aMyParentArray := parentArrayObj;
	
	self.setButtonState();
	self.setSheetState(1);

	preamble	:=	"This application will generate an .scm file(s) that may be loaded via the Jade Schema Load facility." &amp; CrLf &amp; CrLf &amp;
					"The contents of the file(s) will be a series of automatically created methods defined by the options that you choose."  &amp; CrLf &amp; CrLf &amp;
					"If you create Database and Transaction Agent methods, load the the database methods first, to avoid syntax errors." &amp; CrLf &amp; CrLf &amp;
					"The methods created are essentially only templates, but in many cases will provide all of the functionality that is required." &amp; CrLf &amp; CrLf &amp;
					"It is advisable to verify that they perform the task you desire.  Additional validation etc. is likely to be required in some cases.";

	lblPreamble.caption		:=	preamble;
	lblPreamble.borderStyle	:=	Window.BorderStyle_None;

	self.populateModelSchema();
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
