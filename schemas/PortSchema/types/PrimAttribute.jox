<Class name="PrimAttribute">
    <JadeMethod name="getLengthForString" id="76425286-8be1-4097-b0ce-a46558f784a0">
        <source>getLengthForString() : Integer;

/*
Purpose:		Because of a known Jade issue (Jade PAR 48540) the getLength statement for a string
				returns a length 1 too long, JADE will not change it, because existing customers
				might depend on it being wrong!
				ie should not use the following type of syntax
				&lt;class eg CM_TrackedItem&gt;::&lt;fieldName&gt;.getLength(); or
				&lt;class eg CM_TrackedItem&gt;::&lt;fieldName&gt;.length;
				Note: maxLength is OK but cannot be used in the above type of syntax
				ie you need to have an object to do the maxLength on.
				
Return Value:	This method will return the real length of the string.

Date				Who		Reason
15 January 2010		cnwrl1	Initial creation as part of PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
*/

vars
	propertyLength		: Integer;
	
begin
	propertyLength	:= self.length;
	if propertyLength = -1 then		// ie length is maximum.
		return propertyLength;
	else
		return propertyLength - 1;
	endif;
	
epilog
	
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
