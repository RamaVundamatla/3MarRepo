    <JadeMethod name="btnUpdateReport_click" id="c193c5f1-75c9-4ae5-9a8a-e919c335a7de">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnUpdateReport_click(btn: Button input) updating;

vars
	reportDetailsForm	: CnEcReportEditSuper;

begin
	app.mousePointer	:=	Busy;

	if (cmbReport.listObject = null) then
		return;
	endif;

	create reportDetailsForm as global.cnEcGetReportModuleForm(CnEcReportEditSuper);
	reportDetailsForm.setIsNewEntry(false);
	
	// Reports that have active queue entries cannot have parameters changed.
	reportDetailsForm.setParamsReadOnly(self.hasReportAnyQueueEntries());
	
	reportDetailsForm.setReport(cmbReport.listObject.CnEcReportDefinition);
	reportDetailsForm.showModal();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="chkAllPrinters_click" id="cc3e6777-f9af-422d-b56e-8e60c94e648e">
        <controlMethod name="CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkAllPrinters_click(checkbox: CheckBox input) updating;

begin
	app.mousePointer	:=	Busy;

	if (checkbox.value) then
		cmbPrinter.listIndex	:=	CNEC_NULL_INDEX;
		cmbPrinter.enabled		:=	false;
	else
		cmbPrinter.enabled		:=	true;
	endif;

	self.doSetupListReportQueue();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
