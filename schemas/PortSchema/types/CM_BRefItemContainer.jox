    <JadeMethod name="doesTIMatchMe" id="3e0c5349-9a8b-40c5-9ac8-1e9ace2e7257">
        <source>doesTIMatchMe(_ti : CM_TrackedItem; _exact : Boolean) : Boolean;
// ---------------------------------------------------------------------------
// Created:     07 November 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	match, blnCommodity : Boolean;
	realTemp : Real;
	tempMatches : Boolean;
begin

	if _ti = null then
		return true;
	endif;

	match := inheritMethod(_ti, _exact);
	
	if not match then
		return false;
	endif;
	
	realTemp := self.getTemperature();
	tempMatches := getTemperature = realTemp;

	if _exact then
		return tempMatches;
//		and _ti.bolType = self.bolType
	else  // if file has a null value but real item has data entered, this is ok
		return 
		(self.getTemperature = null or getTemperature = realTemp);
		//and (self.bolType = null or _ti.bolType = self.bolType)
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_exact" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
