    <JadeMethod name="trxUpdSubTermForCargoItem" id="23e67e12-7df6-4bd9-b0ad-359ea87a1836">
        <updating/>
        <source>trxUpdSubTermForCargoItem(	_ti : CM_TrackedItem input;
							_passport : CM_Passport input
							) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2015	cnwndl1	Initial creation	Par 36181

*/

vars

	term : CM_Terminal;
	ti : CM_TrackedItem;

begin

	if _passport.myTerminal = null or not _passport.myTerminal.getConfig(IsSubTerminalAreaDefined).Boolean then
		return;
	endif;

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);

	beginTransaction;

	
	app.myUtilityUA.utlUpdSubTermForCargoItem(	_ti, _passport );
		

epilog

	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdSubTermForCargoItems" id="d7a5beb3-8f5e-407c-af2a-d7c05077cacb">
        <updating/>
        <source>trxUpdSubTermForCargoItems(	_processAllOffsite : Boolean;
							_processAllOnsite : Boolean;
							_singleDefArea : CM_SubTerminalAreaDef input;
							_preUpdateTiSet : CM_TISet input;
							_passport : CM_Passport input
							) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2015	cnwndl1	Initial creation	Par 36181

*/

vars

	tisNeedingReset : CM_TISet;
	term : CM_Terminal;
	ti : CM_TrackedItem;

begin

	if _passport.myTerminal = null or not _passport.myTerminal.getConfig(IsSubTerminalAreaDefined).Boolean then
		return;
	endif;

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	
	create tisNeedingReset transient;
	
	if _singleDefArea &lt;&gt; null then
		//we are trying to update the sub terminal and or bank details of the cargo associated with
		// a single subterm area definition
		_singleDefArea.getTIsNeedingSubTermOrBUReset( _preUpdateTiSet, tisNeedingReset );
	
	elseif ( _processAllOffsite or _processAllOnsite ) then
		// we are trying to update the sub terminal and or bank details of all cargo on site
		// based on ALL subterm area definitions AND/OR  clearing the sub terminal attrib of ALL off site and on voyage cargo. 
		term := _passport.myTerminal;
		term.getTIsNeedingSubTermOrBUReset( _processAllOffsite, _processAllOnsite, tisNeedingReset );
	
	endif;

	beginTransaction;

	foreach ti in tisNeedingReset do
		app.myUtilityUA.utlUpdSubTermForCargoItem(	ti, _passport );
		if (not _passport.noErrors) then
			break;
		endif;
	endforeach;

epilog

	delete tisNeedingReset;
	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_processAllOffsite" type="Boolean"/>
        <Parameter name="_processAllOnsite" type="Boolean"/>
        <Parameter name="_singleDefArea" type="CM_SubTerminalAreaDef" usage="input"/>
        <Parameter name="_preUpdateTiSet" type="CM_TISet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
