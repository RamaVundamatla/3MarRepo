    <JadeMethod name="doCriteriaChanged" id="9f2d1dda-ee1f-4fcb-a956-92e3bd46a8b4">
        <updating/>
        <source>doCriteriaChanged() updating;

/*

Purpose:		Call back method for change of criteria value (refer frmCriteria::formCriteriaChangeMethodName)

Parameters:			

Return Value:		


Date			Who		Reason
06 August 2008	consw1	Initial creation

*/

vars
	control : CMUI_YACriteriaCntl;
	tabIndex : Integer;
	min,max,smallChg,largeChg : Integer;
begin
	if self.myCurrentYAControl = null then
		return;
	endif;

	control := self.myCurrentYAControl;
	if self.allClonedFrames.indexOf(control) = self.allClonedFrames.size then
		
		if control.getValue &lt;&gt; null then
			tabIndex := control.btnValuePicker.tabIndex;	
			control:=self.addCriteriaFrame(self.allClonedFrames.size + 1, tabIndex);	
			control.parentRightOffset:=20;
		endif;
	endif;	
	

epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doWhatIf" id="9253380d-4fd9-4066-abbe-4afc898f83c3">
        <updating/>
        <source>doWhatIf() updating, protected;
// --------------------------------------------------------------------------------
// Created:		12 May 2005 by cnwdad1
//
// Purpose:		Using the selected "What If" criteria, test for Locations where a
//				(proxy) Tracked Item may potentially be placed.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 10/09/2009	cnwkpd1		PAR #19112 - New IsAvailable YA Criteria
// 01/06/2010	cnwdap1		CCMS 1116 Tranship changes - new VoyageInbound and VoyageOutbound YA criteria
// 10/06/2013	cnwdap1		PAR #31721 CCMS SFW 1321 Imperial Measurements in Yard Allocation What If
// 18/09/2013	cnwdap1		PAR #32215 DPH CCMS 2290 New Car Attributes in Yard Allocation What If
// 05/03/2015	cnwmh5		Transient Leak
// --------------------------------------------------------------------------------
vars
	
	cargoTypeObj		: CM_CargoType;
	subType				: CM_Product;
	tiProxyObj			: CM_TrackedItem;
	cmif				: CMIF_YAAutoPlanSenario;
	allTIs				: ObjectArray;
	itemCode : String;
	proxyCriteria: CM_YACriteria;
	control 			: Object;
	criteriaCtrl		: CMUI_YACriteriaCntl;
	value				: Any;
	criteriaType 		: CM_YACriteriaType;
	iter : Iterator;
	result : CM_TestAutoPlanResult;
	failColour,
	passColour   : Integer;
begin
	
	failColour:=241 + (218 * 256) + (220 * 256 * 256);
	passColour:= 213 + (255 * 256) + (213 * 256 * 256);
	self.lstWhatIfResults.clear();
	create cmif transient;
	
	foreach control in self.allClonedFrames do
		criteriaCtrl:=control.CMUI_YACriteriaCntl;
		criteriaType:=criteriaCtrl.getCriteriaType;
		if criteriaType = null then
			continue;
		endif;
		
		if criteriaCtrl.visible and criteriaCtrl.hasValue() then
			//epr TFS 1822 28/4/16
			value := criteriaCtrl.getValue().String;
			
			create proxyCriteria transient;
			itemCode := criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
			proxyCriteria.setProxy(criteriaType, value, itemCode);
			cmif.allScenarioCriteria.add(proxyCriteria);
			
			if criteriaType.type = YACriteriaType_CargoType then
				cargoTypeObj:=proxyCriteria.myYAData.CM_YADataObjects.allObjects.first.CM_CargoType;
			endif;
			
			if  criteriaType.type = YACriteriaType_Product then
				subType :=proxyCriteria.myYAData.CM_YADataObjects.allObjects.first.CM_Product;
			endif;
			
		endif;
	endforeach;
	
	if cargoTypeObj = null then
		
	//	app.msgBox( app.getErrorString1( REQUIRED_FIELD, app.getErrorString(CM_Cargo_Type )) , app.getErrorString(Error), MsgBox_OK_Only );
		app.msgBox( app.getErrorString1( Input_required_field_Required, app.getErrorString(CM_Cargo_Type )) , app.getErrorString(Error), MsgBox_OK_Only ); // cnwdb2	PAR 35364
		delete cmif;
		return;
	endif;
	
	
	create tiProxyObj as cargoTypeObj.myClassToCreate transient;
	tiProxyObj.setCargoType(cargoTypeObj.id);
	tiProxyObj.setMyProduct(subType);		// 27/05/2010 cnwar2 #23885
	
	cmif.attachTI(tiProxyObj);
	

	create allTIs transient;
	allTIs.add(cmif);
	
	self.myTestAutoPlanRoot.doTestAutoPlan( null,	//_tblSelected : Table input;
											allTIs,	//_alternateSelection : CM_TIArray input;
											self.myTerminal,	//_terminal : CM_Terminal;
											null,	//_terminalArea : CM_TerminalArea
											false
											);
	
	self.tblResults.rows:=1;								
	iter := self.myTestAutoPlanRoot.allTestAutoPlanResults.createIterator;	
	while iter.next( result ) do
		self.tblResults.addItemObject( result, result.getAttributeStringForDefArray(self.tblResults.allTblDataEntRows) );		
		
		if result.isFailed then
			self.tblResults.accessedRow.backColor:=failColour;
		else
			self.tblResults.accessedRow.backColor:=passColour;	
		endif;

	endwhile;
	
	
	
epilog
	delete tiProxyObj;
	delete allTIs;
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadResults" id="1b7abb75-2cd9-47b0-afb0-828ddfb8e07b">
        <source>loadResults(_result : CM_TestAutoPlanResult input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 July 2013	cnwndl1	Initial creation	Par 31706

*/

vars
	
begin
	
	self.loadResultsCriteria(_result);
	self.loadResultsLog(_result.log);
	

epilog

end;</source>
        <Parameter name="_result" type="CM_TestAutoPlanResult" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadResultsCriteria" id="4c4d94af-dca8-48fb-a74d-ce3df0f5053e">
        <source>loadResultsCriteria(_result : CM_TestAutoPlanResult input) protected;
/*

Date		Who		Reason
27 January 2014	cnwer1	Initial creation PAR

*/

vars
	scenarioCriteria: CM_YACriteria;
	i 				: Integer;
	criteriaFrame: CMUI_YACriteriaCntl;
begin
	
	foreach scenarioCriteria in _result.myCMIF_YAAutoPlanScenario.allScenarioCriteria do
		i := i + 1;
		criteriaFrame:=null;
		if self.allClonedFrames.size &gt;= i then
			criteriaFrame := self.allClonedFrames[i].CMUI_YACriteriaCntl;
		endif;
		
		if criteriaFrame &lt;&gt; null then
			//criteriaFrame.setCriteriaType(scenarioCriteria.myYACriteriaType);
			criteriaFrame.setCriteria(scenarioCriteria);
		else
			
		endif;
		
		
	endforeach;
	
	if self.allClonedFrames.size &gt; i then
		
		while i &lt; self.allClonedFrames.size do
			i := i + 1;
			criteriaFrame :=self.allClonedFrames[i].CMUI_YACriteriaCntl;
			if criteriaFrame &lt;&gt; null then
				criteriaFrame.setCriteria(null);
			endif;
		endwhile;
		
		
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_result" type="CM_TestAutoPlanResult" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadResultsLog" id="a9ad304b-bb5b-42e2-83de-e8e8aa9d774c">
        <source>loadResultsLog(_results : StringArray512 input) protected;
/*

Date		Who		Reason
27 January 2014	cnwer1	Initial creation PAR

*/

vars
rawStr : String;
	pos : Integer;
	logLevel : Integer;
	logString : String;
	lastLevel : Integer;
	newIndex : Integer;
	parentIndex : Integer;
	turnOffLines : Boolean;

begin

	self.lstWhatIfResults.clear();
	lastLevel := 1;
	
	turnOffLines := true;
	foreach rawStr in _results do
		pos := rawStr.pos(",",1);
		if pos &lt; 1 or pos &gt; 5 then
			logLevel := 99;
			logString  := rawStr.trimBlanks;
		else
			logLevel := rawStr[1: pos - 1].trimBlanks.Integer;
			logString  := rawStr[pos + 1:end].trimBlanks;
			turnOffLines := false;
		endif;
		
		if logLevel = AP_Log_YA_Default then	//99
			// default behaviour, i.e. which means add at the same level as the last add.
			newIndex := self.lstWhatIfResults.addItem( logString );
			self.lstWhatIfResults.itemLevel[newIndex] := lastLevel;
		elseif logLevel = AP_Log_YA_Global then	//0
			//Unconditionally at the top level.
			newIndex := self.lstWhatIfResults.addItem( logString );
			self.lstWhatIfResults.itemLevel[newIndex] := 1;
			lastLevel := 1;
		elseif logLevel = AP_Log_YA_Match then	//2
			//At level 2 , these are the match details and should be under the Allocation name
			newIndex := self.lstWhatIfResults.addItem( logString );
			self.lstWhatIfResults.itemLevel[newIndex] := 2;
			lastLevel := 2;
		elseif logLevel = AP_Log_YA_No_Match then	//3
			//At level 2 , these are the non match details and should be under the Allocation name
			newIndex := self.lstWhatIfResults.addItem( logString );
			self.lstWhatIfResults.itemLevel[newIndex] := 2;
			self.lstWhatIfResults.itemForeColor[newIndex] := Red;
			parentIndex := self.lstWhatIfResults.getParentRow(newIndex);
			self.lstWhatIfResults.itemForeColor[parentIndex] := Black;
			lastLevel := 2;
		elseif logLevel = AP_Log_YA_No_Space then	//4
			//At level 2 , these are the non match details and should be under the Allocation name
			newIndex := self.lstWhatIfResults.addItem( logString );
			self.lstWhatIfResults.itemLevel[newIndex] := 2;
			self.lstWhatIfResults.itemForeColor[newIndex] := Red;
			parentIndex := self.lstWhatIfResults.getParentRow(newIndex);
			if self.lstWhatIfResults.itemText[parentIndex].pos("No Space",1) &lt; 1 then
				self.lstWhatIfResults.itemText[parentIndex] := self.lstWhatIfResults.itemText[parentIndex] &amp; " - No Space";
			endif;
			lastLevel := 2;
		elseif logLevel = AP_Log_YA_Name then	//1
			//At the top level.  (Allocation name)
			newIndex := self.lstWhatIfResults.addItem( logString );
			self.lstWhatIfResults.itemLevel[newIndex] := 1;
			self.lstWhatIfResults.itemForeColor[newIndex] := Green;
			lastLevel := 1;
		else
			// default behaviour, i.e. which means add at the same level as the last add.
			newIndex := self.lstWhatIfResults.addItem( logString );
			self.lstWhatIfResults.itemLevel[newIndex] := lastLevel;
		endif;
	endforeach;
	
	if turnOffLines then
		self.lstWhatIfResults.hasTreeLines := false;
	endif;
	
	if self.lstWhatIfResults.listCount &gt; 0 then
		self.lstWhatIfResults.topIndex := self.lstWhatIfResults.listCount;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_results" type="StringArray512" usage="input"/>
    </JadeMethod>
