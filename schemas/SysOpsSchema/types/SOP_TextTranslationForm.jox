    <JadeMethod name="loadWithEntTableDef" id="528173d6-25bd-4532-99f2-80cfa2278a21">
        <updating/>
        <source>loadWithEntTableDef() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	
	partsDone : Integer;
	category : XLAT_Category;
	searchResults : XLAT_SearchResults;
	entTableRow  : EntTableRow;
begin
	if self.initEntTableDef = null then
		return;
	endif;
	
	self.chkTableEntities.value:=true;
	self.chkFormCaptions.value:=false;
	self.chkPermissions.value:=false;
	self.chkReportNames.value:=false;
	self.chkTextMessages.value:=false;
	
	category := self.myRoot.allXLAT_Categories[EntTableRows];
	// populate each table
	// get search results for the category
	searchResults := self.myAgent.allSearchResults[category.constantCategoryName];
	foreach entTableRow in self.initEntTableDef.allEntTableRows do
		searchResults.allTranslatableText.add(entTableRow.myEntTableText);
	endforeach;
	
	self.displayTranslatableText(self.tblTableEnts, partsDone);
	
	frmSearch.visible := false;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
