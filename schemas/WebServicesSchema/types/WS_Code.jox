    <JadeMethod name="setProxyDetails" id="ef0dcf26-860e-487f-a42f-83bf4fc46808">
        <updating/>
        <source>setProxyDetails(_object : Object input;
				_code : String;
				_description : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2018	jlger1	Initial creation 37654

*/

vars

begin
	self.setOidDetails(_object);
	self.code:=_code;
	self.description:=_description;
epilog

end;</source>
        <Parameter name="_object" type="Object" usage="input"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="50834203-af8f-4f54-9455-e8daa3c6261c">
        <updating/>
        <source>setProxyFromObject(_object: CM_Code) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 September 2008	cnwkao1	Initial creation

*/

vars

begin
	inheritMethod(_object);
	
	self.code			:= _object.code;
	self.description	:= _object.description;
	self.notAvailableForEntry := _object.notAvailableForEntry;
	
epilog

end;</source>
        <Parameter name="_object" type="CM_Code"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObjectBase" id="1387ce00-551c-45e8-9820-8511c7b57bf2">
        <updating/>
        <source>setProxyFromObjectBase(_object: CM_Code) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2015	cnwmc5	Initial creation

*/

vars

begin
	
	self.cmObjectEdition		:= _object.edition();
	self.cmObjectId				:= _object.getOidAsString();
	self.code					:= _object.code;
	self.description			:= _object.description;
	self.notAvailableForEntry 	:= _object.notAvailableForEntry;

epilog

end;</source>
        <Parameter name="_object" type="CM_Code"/>
    </JadeMethod>
