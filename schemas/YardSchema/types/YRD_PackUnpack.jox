    <JadeMethod name="resortDataTable" id="4c1d5793-58ef-4968-a21e-d602bf8df012">
        <updating/>
        <source>resortDataTable(_tbl : CM_DataTable)updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 28 September 2004
//
//********************************************************************
vars
	startRow,
	endRow,
	idx2	 : Integer;
	obj : Object;
	theTable : CM_DataTable;
begin
	theTable := _tbl;
	
	theTable.resortTableByColumn(theTable.column);
	
	startRow := theTable.fixedRows + 1;
	endRow := theTable.rows;
	foreach idx2 in startRow to endRow do
			if (idx2 mod 2 = 0) then
				theTable.accessRow(idx2).backColor := self.colorRow1;
			else
				theTable.accessRow(idx2).backColor := self.colorRow2;
			endif;
	endforeach;

end;</source>
        <Parameter name="_tbl" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="setCMIFPackUnpackFromTbl" id="2a74cd5f-9aff-4262-9e01-ccd8c8e1a582">
        <source>setCMIFPackUnpackFromTbl(_cmifPack : CMIF_PackUnpack input; _pxyTI : CM_TrackedItem);
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 05/03/2010	cnwmh5		Par 22755 - Add sealNumVent
// 12/04/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 22/07/2014	cnwma1		PAR #34021 - Unpack does not clear data from previous voyage
// 09/10/2017	jlgdap1		TFS 7204 STWR Correct real handling for non-standard locales
// 14/11/2022	navkc1		Bug 55397: PNL - 'Pack Unpack' Window adds unnecessary data to fields when packing export reefers
// ---------------------------------------------------------------------------
vars
	intRow : Integer;
	entRowTrans : EntTableRowTransient;
	rowName : String;
	rowValue : String;
	row : JadeTableRow;
	sealTypeCode : String;
	seal : CM_SealTI;
	str : String;
	strSeal : String;
	foundSeal : Boolean;
	newSeal : CM_SealTI;
	contentStatus : CM_ContentsStatus;
	o2, co2, humidity : String;
begin
	_cmifPack.myBulkRelease := self.cmbBR.listObject.CM_BulkRelease; // CCMS 1288 AKB2005APR
	
	if self.cmbVoyageRight.listObject &lt;&gt; null then
		_cmifPack.voyageCode := self.cmbVoyageRight.listObject.CM_Voyage.code;
	endif;

	if self.cmbOperatorRight.listObject &lt;&gt; null then
		_cmifPack.operatorCode :=  self.cmbOperatorRight.listObject.CM_Operator.code;
	endif;

	if self.cmbDisPortRight.listObject &lt;&gt; null then
		_cmifPack.dischargePort :=   self.cmbDisPortRight.listObject.CM_Port.code;
	else
		_cmifPack.dischargePort := null;
	endif;

	//+cnwml2 PAR24740
	if self.cmbDestPortRight.listObject &lt;&gt; null then
		_cmifPack.destinationPort :=   self.cmbDestPortRight.listObject.CM_Port.code;
	else
		_cmifPack.destinationPort := null;
	endif;
	
	if self.cmbCommodity.myObject &lt;&gt; null then
		_cmifPack.commodity :=   self.cmbCommodity.myObject.CM_Commodity.code;
	endif;
	
	if self.cmbConsignee.myObject &lt;&gt; null then
		_cmifPack.consigneeCode := self.cmbConsignee.myObject.CM_ConsigneeConsignor.code;
	endif;

	if self.cmbConsignor.myObject &lt;&gt; null then
		_cmifPack.consignorCode := self.cmbConsignor.myObject.CM_ConsigneeConsignor.code;
	endif;

	//_cmifPack.totalVolume := self.tblContainer.getValueByName(ETRow_VolumeTotal).String.asDecimalJMT();			// #25592 3/11/2010 **
	//_cmifPack.volume := self.tblContainer.getValueByName(ETRow_Volume).String.asDecimalJMT();			// 27868
	//_cmifPack.containerVolume := self.tblContainer.getValueByName(ETRow_ContainerVolume).String.asDecimalJMT();	// #25592 3/11/2010 **
	//_cmifPack.weightTotal := self.tblContainer.getValueByName(ETRow_WeightTotal).Decimal;	
	//_cmifPack.weightTare := self.tblContainer.getValueByName(ETRow_WeightTare).Decimal;						//+cnwml2 MSL CCMS 1017
	//_cmifPack.weightCargo := self.tblContainer.getValueByName(ETRow_CargoWeight).Decimal;					//+cnwml2 MSL CCMS 1017
	_cmifPack.totalVolume := self.tblContainer.getMeasurementValueByName(ETRow_VolumeTotal).Decimal;			// PAR #31155
	_cmifPack.volume := self.tblContainer.getMeasurementValueByName(ETRow_Volume).Decimal;						// PAR #31155
	_cmifPack.containerVolume := self.tblContainer.getMeasurementValueByName(ETRow_ContainerVolume).Decimal;	// PAR #31155
	_cmifPack.weightTotal := self.tblContainer.getMeasurementValueByName(ETRow_WeightTotal).Decimal;			// PAR #31155
	_cmifPack.weightTare := self.tblContainer.getMeasurementValueByName(ETRow_WeightTare).Decimal;				// PAR #31155
	_cmifPack.weightCargo := self.tblContainer.getMeasurementValueByName(ETRow_CargoWeight).Decimal;			// PAR #31155
	
	if self.cmbImEx.listObject &lt;&gt; null then
		_cmifPack.imExStatus := self.cmbImEx.listObject.CM_IMEXStatus;
	endif;
	_cmifPack.bookingReference := self.tblContainer.getValueByName(ETRow_BookingReference).String.toUpper;
	
	if self.myTI.isKindOf(CM_Container) then				//+cnwml2 PAR23045
		//_cmifPack.contentsStatus := self.cmbContentsStat.listObject.CM_ContentsStatus.code;
		//25/10/2011 cnwdz2 par28505
		contentStatus := self.cmbContentsStat.listObject.CM_ContentsStatus;
		if contentStatus &lt;&gt; null then
			_cmifPack.contentsStatus := contentStatus.code;
		endif;
		
		_cmifPack.customExportEntryNumber := self.tblContainer.getValueByName(ETRow_CustomExportEntryNumber).String;
	endif;

//Par7150 19122003 cnwsh3 To allow for a container that has been set in Create New Cargo with a different load port.  
//If the container has been emptied and the readied for export then the load port will become the loading port and not 
//the load port it was allocated when it was created.  
	if _cmifPack.imExStatus.code = TI_IMEX_STATUS_EXPORT /*and _cmifPack.contentsStatus = TI_CONTENTS_STATUS_EMPTY*/ then
		_cmifPack.loadPort := self.myTerminal.getConfig(PortDestCode).String;
	endif;
	
	//working on par 19515 found this.  cnwjo3. will not be included in hotfix though
	_cmifPack.mySubTerminal := self.cmbSubTerminal.listObject.CM_SubTerminal;
	_cmifPack.deliveryReleaseNo := self.tblContainer.getValueByName(ETRow_DeliveryReleaseNo).String;			//+cnwml2 PAR24347

	//+cnwml2 PAR23715 SFW CCMS1131
	foreach intRow in 1 to self.tblContainer.rows do
		row := self.tblContainer.accessRow(intRow);
		entRowTrans := row.itemObject.EntTableRowTransient;
		rowName := entRowTrans.name;
		if rowName.startsWith("DtRow_") then
			rowValue := self.tblContainer.getValueByName(rowName).String;
			sealTypeCode := rowName[7:end];
			if not sealTypeCode.startsWith("PreviousSeal_") or sealTypeCode.startsWith("DateTime_") then
				foreach seal in _pxyTI.allSeals do
					if seal.sealType = sealTypeCode then
						//found existing seal in ti
						foreach str in seal.allSealNums do
							if strSeal &lt;&gt; null then
								strSeal := strSeal &amp; ", " &amp; str;
							else
								strSeal := str;
							endif;
						endforeach;
						if rowValue &lt;&gt; strSeal then
							seal.setPreviousSeal(strSeal);
						endif;
						
						seal.allSealNums.clear();
						seal.allSealNums.add(rowValue);
						foundSeal := true;
						break;
					endif;
				endforeach;
				
				if not foundSeal and rowValue &lt;&gt; null then	//25 Nov 2010	NDL Par 26409
					//create new seal
					create newSeal transient;
					newSeal.setPreviousSeal(null);
					newSeal.setSealType(rowName[7:end]);
					newSeal.allSealNums.add(rowValue);
					newSeal.setMyTrackedItem(_pxyTI);	//23 Nov 2010	NDL	Par 26388
				endif;
			endif;
		endif;
	endforeach;
	
	_cmifPack.createSealsFromTi( _pxyTI );	//23 Nov 2010	NDL	Par 26388
	
	//+cnwml2 SFW CCMS 1063 PAR25852
	//set Reefer Details
	if self.tblContainer.isRowVisible(ETRow_AllowableTimeOffPower) then		//must mean that it is a reefer
		_cmifPack.allowableTimeOffPower := self.tblContainer.getValueByName(ETRow_AllowableTimeOffPower).Decimal;
		//_cmifPack.carriageTempC := self.tblContainer.getValueByName(ETRow_CarriageTemp).Real;						// TFS 7204
		_cmifPack.carriageTempC := self.tblContainer.getValueByName(ETRow_CarriageTemp).String.asRealJMT;			// TFS 7204
		_cmifPack.packDate := self.tblContainer.getValueByName(ETRow_PackDate).Date;
		_cmifPack.packTime := self.tblContainer.getValueByName(ETRow_PackTime).Time;
		//_cmifPack.packTempC := self.tblContainer.getValueByName(ETRow_PackTemp).Real;								// TFS 7204
		_cmifPack.packTempC := self.tblContainer.getValueByName(ETRow_PackTemp).String.asRealJMT;					// TFS 7204
		//_cmifPack.setCarbonDioxide( self.tblContainer.getValueByName(ETRow_CO2).String.asDecimalJMT );			// navkc1	14/11/2022	#55397
		co2 := self.tblContainer.getValueByName(ETRow_CO2).String;													// navkc1	14/11/2022	#55397
		if co2 = '' then co2 := NULL_CARBON_DIOXIDE.String; endif;													// navkc1	14/11/2022	#55397
		_cmifPack.setCarbonDioxide(co2.asDecimalJMT());																// navkc1	14/11/2022	#55397
		//_cmifPack.setOxygen( self.tblContainer.getValueByName(ETRow_O2).String.asDecimalJMT );					// navkc1	14/11/2022	#55397
		o2 := self.tblContainer.getValueByName(ETRow_O2).String;													// navkc1	14/11/2022	#55397
		if o2 = '' then o2 := NULL_OXYGEN.String; endif;															// navkc1	14/11/2022	#55397
		_cmifPack.setOxygen(o2.asDecimalJMT());																		// navkc1	14/11/2022	#55397
		_cmifPack.curtainsIn := self.tblContainer.getValueByName(ETRow_CurtainsIn).Boolean;
		//_cmifPack.setHumidity( self.tblContainer.getValueByName(ETRow_Humidity).String.asDecimalJMT );			// navkc1	14/11/2022	#55397
		humidity := self.tblContainer.getValueByName(ETRow_Humidity).String;										// navkc1	14/11/2022	#55397
		if humidity = '' then humidity := NULL_HUMIDITY.String; endif;												// navkc1	14/11/2022	#55397
		_cmifPack.setHumidity(humidity.asDecimalJMT());
		//_cmifPack.ventilation := self.tblContainer.getValueByName(ETRow_Ventilation).Decimal;				// PAR #31155
		_cmifPack.ventilation := self.tblContainer.getMeasurementValueByName(ETRow_Ventilation).Decimal;	// PAR #31155
		_cmifPack.coolingType := app.coolingTypeStringToENum(self.tblContainer.getValueByName(ETRow_CoolingType).String);
		_cmifPack.voltageType := app.voltageTypeStringToENum(self.tblContainer.getValueByName(ETRow_VoltageType).String);
		
		if  _cmifPack.contentsStatus = TI_CONTENTS_STATUS_EMPTY then			// 22/07/2014	cnwma1		PAR #34021
			_cmifPack.carriageTempC := NULL_TEMPERATURE;
			_cmifPack.setOxygen( NULL_OXYGEN );
			_cmifPack.setCarbonDioxide( NULL_CARBON_DIOXIDE );
		endif;																	// 22/07/2014	cnwma1		PAR #34021
	endif;

	// 16/07/2014 cnwar2 #34025
	_cmifPack.alternativeId := self.tblContainer.getValueByName(ETRow_AlternativeId).String;
	_cmifPack.remarks 		:= self.tblContainer.getValueByName(ETRow_Remarks).String;
	_cmifPack.description 	:= self.tblContainer.getValueByName(ETRow_Description).String;
	
end;</source>
        <Parameter name="_cmifPack" type="CMIF_PackUnpack" usage="input"/>
        <Parameter name="_pxyTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setCMIF_RepackFromTblObject" id="5c37fcfb-fe11-4ed3-bac2-7e8c3bbd46d8">
        <source>setCMIF_RepackFromTblObject( _cmifRepack : CMIF_Repack input);
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 25 November 2003
//
//********************************************************************
vars
	ti	 : CM_TrackedItem;
	child	: CM_TrackedItem;
	
begin
	ti := self.myTIToEmpty;
	
	_cmifRepack.myOperator 		:= ti.myOperator; 
	_cmifRepack.billOfLading 	:= ti.billOfLading;
	_cmifRepack.cargoGroupId 	:= ti.getMyCargoGroupId;	//15 Feb 2016	NDL	Par 37544
	_cmifRepack.commodity 		:= ti.commodity;
	_cmifRepack.consigneeCode 	:= ti.consignee;
	_cmifRepack.consignorCode 	:= ti.consignor;
	_cmifRepack.description 	:= ti.description;
	_cmifRepack.destinationPort := ti.destinationPort;
	_cmifRepack.eirNumber 		:= ti.eirNumber;
	_cmifRepack.temperature 	:= ti.getTemperature;
	_cmifRepack.remarks 		:= ti.remarks;
	
	_cmifRepack.carrier 		:= ti.carrier;
	//_cmifRepack.weight			:= container.weight;			//-cnwml2 MSL CCMS 1017
	_cmifRepack.weight			:= ti.totalWeight;					//+cnwml2 MSL CCMS 1017
	_cmifRepack.dischargePort 	:= ti.dischargePort;
	_cmifRepack.myTranshipToPort:=	ti.myTranshipToPort;
	_cmifRepack.mark 			:= ti.mark;
	if ti.isKindOf(CM_Container) then
		_cmifRepack.isToBeInspected	:= ti.CM_Container.isToBeInspected;
	endif;
	_cmifRepack.myVoyage 		:= ti.myVoyage;
	
	_cmifRepack.imexStatus := ti.getImExStatus;
	
	//ti.getAllChildren(children);//PAR 22954
	//foreach child in children do
	foreach child in ti.allChildren do//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
		_cmifRepack.allChildren.add(child);
		
	endforeach;
	
epilog

end;</source>
        <Parameter name="_cmifRepack" type="CMIF_Repack" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="ca268bc8-5c63-44a2-9dc9-af2187fa47a6">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     03 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tmpBackColor	: Integer;
begin
	inheritMethod(_colorControl);

	tmpBackColor	:= self.backColor;
	
	self.frmContainer.backColor		:= tmpBackColor;
	self.frmPacked.backColor		:= tmpBackColor;
	self.frmUnpacked.backColor		:= tmpBackColor;
	self.frmQuery.backColor			:= tmpBackColor;
	
	self.setColorsForEntryTable(self.tblQuery);
	self.setColorsForEntryTable(self.tblContainer);
	
	self.setColorsForTable(self.tblPacked);
	self.setColorsForTable(self.tblUnpacked);

end;</source>
