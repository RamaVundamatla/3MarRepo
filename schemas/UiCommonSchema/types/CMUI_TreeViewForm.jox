----------   ----------  --------------------------------------------------
*/
vars
	cloneMenu			: MenuItem;
	mnuIdx				: Integer;
	showMainMenu 		: Boolean;
begin
	self.mnuShowFrame.visible := false;
	
	mnuIdx := mnuIdx + 1;
	cloneMenu := self.zCloneFrameMenuItem(self.dkbTopLeft, self.mnuShowFrameSub, mnuIdx);
	if self.allowFrameTopLeft and (not self.dkbTopLeft.visible) then
		cloneMenu.visible := true;
		showMainMenu := true;
	endif;
	
	mnuIdx := mnuIdx + 1;
	cloneMenu := self.zCloneFrameMenuItem(self.dkbBottomLeft, self.mnuShowFrameSub, mnuIdx);
	if self.allowFrameBottomLeft and (not self.dkbBottomLeft.visible) then
		cloneMenu.visible := true;
		showMainMenu := true;
	endif;
	
	mnuIdx := mnuIdx + 1;
	cloneMenu := self.zCloneFrameMenuItem(self.dkbBottomRight, self.mnuShowFrameSub, mnuIdx);
	if self.allowFrameBottomRight and (not self.dkbBottomRight.visible) then
		cloneMenu.visible := true;
		showMainMenu := true;
	endif;
	
	mnuIdx := mnuIdx + 1;
	cloneMenu := self.zCloneFrameMenuItem(self.dkbTopRight, self.mnuShowFrameSub, mnuIdx);
	if self.allowFrameTopRight and (not self.dkbTopRight.visible) then
		cloneMenu.visible := true;
		showMainMenu := true;
	endif;
	/*
	mnuIdx := mnuIdx + 1;
	cloneMenu := self.zCloneMenuItem(self.dkcLeftMain, self.mnuShowFrameSub, mnuIdx);
	if (not self.dkcLeftMain.visible) then
		cloneMenu.visible := true;
		showMainMenu := true;
	endif;
	
	mnuIdx := mnuIdx + 1;
	cloneMenu := self.zCloneMenuItem(self.dkcRightMain, self.mnuShowFrameSub, mnuIdx);
	if (not self.dkcRightMain.visible) then
		cloneMenu.visible := true;
		showMainMenu := true;
	endif;
	*/
	if showMainMenu then
		self.mnuShowFrame.visible := true;
	endif;
	
	
	
end;


</source>
