    <JadeMethod name="validateForUpdate" id="4914849f-d87b-4b48-8c1f-d904ca265fc2">
        <source>validateForUpdate( _configOpts : CMIF_YAConfig );

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
29 July 2008	consw1	Initial creation

*/

vars

begin
	self.validate(_configOpts);

	//  Check link to terminal is not being changed
	if self.myTerminal.myYAConfig.myTerminal &lt;&gt; self.myTerminal then
		app.raiseCMException2(ERR_INVALID_VALUE,"Terminal"," ",null,null);
	endif;

epilog

end;</source>
