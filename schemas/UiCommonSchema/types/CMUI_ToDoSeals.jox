    <JadeMethod name="populateTblSeals" id="641bd371-2155-4ef7-b585-9a123ac451b2">
        <source>populateTblSeals();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2012	cnwrd1	Initial creation

*/


vars

	ti : CM_TrackedItem;
	context : Integer;
	cargoType : CM_CargoType;
	mess : String;
	sealType : CM_SealType;
	allSealTypes : CM_SealTypeSet;
	sealTi : CM_SealTI;
	idx : Integer;
	oneHalf : Integer;
	baseColour : Integer;

begin

	tblSeals.clear();
	
	ti := self.myTrackedItem;
	//context := self.myHandHeldCheckerAgent.checksState;
/*
	if context = 0 then
		mess := "No context set. " &amp; app.getErrorString(Contact_developer);
		self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		return;
	endif;
	*/
	/*if ti = null then
		mess := "ti = null. " &amp; app.getErrorString(Contact_developer);
		app.   ( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		return;
	endif;
		
	
	if cargoType = null then
		mess := app.getErrorString(CouldNotFindCargoType);
		self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		return;
	endif;
	*/
	
	cargoType := ti.myCargoType;
	
	create allSealTypes transient;
	foreach sealType in cargoType.allSealTypes do
		if sealType.notAvailableForEntry then
			continue;
		endif;
		allSealTypes.add(sealType);
	endforeach;
	
	if allSealTypes.isEmpty then
	//	mess := app.getErrorString(No_Seal_types_for_cargo_type);//"No Seal types declared for cargo type that are available for entry.";
	//	self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		return;
	endif;
	
	self.setTableForFullMode( allSealTypes, ti ); // type and value columns only

//	self.sealCheckType := ti.getSealCheckTypeForContext( self.myHandHeldCheckerAgent.getCargoChkContextFromChkState );
	
/*	if sealCheckType = SEAL_CHECK_NONE then // 1
		self.setTableForNoneMode();

	elseif self.sealCheckType = SEAL_CHECK_VIEW then	// 2
		self.setTableForViewMode( allSealTypes, ti );	// sealName column and Yes / No  columns only
	
	elseif self.sealCheckType = SEAL_CHECK_FULL then	// 3
		self.setTableForFullMode( allSealTypes, ti );	// type and value columns only
	
	elseif self.sealCheckType = SEAL_CHECK_STRICT then	//4
		self.setTableForStrictMode( allSealTypes, ti );	// type and value columns only
	
	else
		mess := app.getErrorString(Invalid_seal_check_type) &amp; " [" &amp; self.sealCheckType.String &amp; "]" &amp; CrLf &amp; app.getErrorString(Contact_developer);
		self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		
	endif;
	*/

epilog

	delete allSealTypes;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setTableForFullMode" id="358229f6-82c5-4638-b468-5bc97fd507bb">
        <source>setTableForFullMode( allSealTypes : CM_SealTypeSet; ti : CM_TrackedItem );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2012	cnwrd1	Initial creation

*/


vars

	sealType : CM_SealType;
	index : Integer;
	sealTi : CM_SealTI;

begin

	tblSeals.selectMode := Table.SelectMode_None;
	tblSeals.columns := 2;
	tblSeals.rows := 1;
	
	tblSeals.fixedRows := 1;
	tblSeals.fixedColumns := 1;
	
	//tblSeals.accessCell(1,1).mergeCells := Table.MergeCells_Merge;

	//tblSeals.setCellText(1,1,app.getErrorString1(Seal_check_mode, app.sealCheckTypeEnumToString(SEAL_CHECK_FULL) ) );
	//tblSeals.accessCell(1,1).alignment := Table.Alignment_Center_Middle;
	
	tblSeals.accessRow(1).alignment := Table.Alignment_Left_Middle;
	tblSeals.accessRow(1).fontBold := true;
	tblSeals.setCellText(1,1,app.getErrorString(CM_Type) );
	tblSeals.setCellText(1,2,app.getErrorString(Value) );
	
	foreach sealType in allSealTypes do
	
		index := tblSeals.addItem(sealType.description);
		sealTi := ti.getSealTI(sealType);
		
		if sealTi = null then
			tblSeals.accessRow(index).itemObject := sealType;
		else
			tblSeals.setCellText(index,2,sealTi.getSealValueAsString);
			tblSeals.accessRow(index).itemObject := sealTi;
		endif;
		tblSeals.accessCell(index,2).inputType := Table.InputType_TextBox;
		tblSeals.accessRow(index).height := 24;
		
	endforeach;
	
epilog

end;</source>
        <Parameter name="allSealTypes" type="CM_SealTypeSet"/>
        <Parameter name="ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setTableForStrictMode" id="d5242d59-f6a9-4b81-b8b5-06122f327ea3">
        <source>setTableForStrictMode( allSealTypes : CM_SealTypeSet; ti : CM_TrackedItem );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2012	cnwrd1	Initial creation

*/

// not used on this form yet
vars

	sealType : CM_SealType;
	index : Integer;
	sealTi : CM_SealTI;

begin

	tblSeals.selectMode := Table.SelectMode_None;
	tblSeals.columns := 2;
	tblSeals.rows := 2;
	
	tblSeals.fixedRows := 2;
	tblSeals.fixedColumns := 1;
	
	tblSeals.accessCell(1,1).mergeCells := Table.MergeCells_Merge;

	tblSeals.setCellText(1,1,app.getErrorString1(Seal_check_mode, app.sealCheckTypeEnumToString(SEAL_CHECK_STRICT) ) );
	tblSeals.accessCell(1,1).alignment := Table.Alignment_Center_Middle;
	
	tblSeals.accessRow(2).alignment := Table.Alignment_Left_Middle;
	tblSeals.accessRow(2).fontBold := true;
	tblSeals.setCellText(2,1,app.getErrorString(CM_Type) );
	tblSeals.setCellText(2,2,app.getErrorString(Value) );
	
	foreach sealType in allSealTypes do
	
		index := tblSeals.addItem(sealType.description);
		sealTi := ti.getSealTI(sealType);
		
		if sealTi = null then
			tblSeals.accessRow(index).itemObject := sealType;
		else
			tblSeals.accessRow(index).itemObject := sealTi;
		endif;
	
		tblSeals.accessCell(index,2).inputType := Table.InputType_TextBox;

		tblSeals.accessRow(index).height := 24;
		
	endforeach;
	
epilog

end;</source>
        <Parameter name="allSealTypes" type="CM_SealTypeSet"/>
        <Parameter name="ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setTableForViewMode" id="754fa29f-fb6b-482b-aae7-114141aeefc5">
        <source>setTableForViewMode( allSealTypes : CM_SealTypeSet; ti : CM_TrackedItem );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2012	cnwrd1	Initial creation

*/


// currently not used **

vars

	sealType : CM_SealType;
	index : Integer;
	sealTi : CM_SealTI;

begin

	tblSeals.selectMode := Table.SelectMode_None;
	tblSeals.columns := 3;
	tblSeals.rows := 2;
	
	tblSeals.fixedRows := 2;
	tblSeals.fixedColumns := 1;
	
	tblSeals.accessColumn(1).width := (tblSeals.width * 3 / 5).Integer;
	tblSeals.accessColumn(2).width := (tblSeals.width / 5).Integer;
	tblSeals.accessColumn(3).width := (tblSeals.width / 5).Integer;
	
	tblSeals.accessCell(1,1).mergeCells := Table.MergeCells_Merge;

	tblSeals.setCellText(1,1,app.getErrorString1(Seal_check_mode, app.sealCheckTypeEnumToString(SEAL_CHECK_VIEW) ) );
	tblSeals.accessCell(1,1).alignment := Table.Alignment_Center_Middle;
	tblSeals.accessRow(2).alignment := Table.Alignment_Center_Middle;
	tblSeals.accessRow(2).fontBold := true;
	tblSeals.accessCell(2,2).mergeCells := Table.MergeCells_Merge;
	tblSeals.setCellText(2,1,app.getErrorString(CM_Type) );
	tblSeals.accessCell(2,1).alignment := Table.Alignment_Center_Middle;
	tblSeals.setCellText(2,2,"Viewed");
	
	foreach sealType in allSealTypes do
		index := tblSeals.addItem(sealType.description);
		sealTi := ti.getSealTI(sealType);
		if sealTi &lt;&gt; null then
			tblSeals.accessRow(index).itemObject := sealTi;
		else
			tblSeals.accessRow(index).itemObject := sealType;
		endif;
		//self.myHandHeldCheckerAgent.setupCargoCheckTableYesNoBtns(tblSeals, index, self.btnTick, self.btnCross);
		tblSeals.accessRow(index).height := 24;
	endforeach;

epilog

end;</source>
        <Parameter name="allSealTypes" type="CM_SealTypeSet"/>
        <Parameter name="ti" type="CM_TrackedItem"/>
    </JadeMethod>
