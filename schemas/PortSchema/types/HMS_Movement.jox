    <JadeMethod name="lookupMovementNext" id="ec74ea03-6ba0-4b27-9208-d0f11d415de6">
        <source>lookupMovementNext():HMS_Movement;
// ---------------------------------------------------------------------------
// Created:     13 March 2008 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
 	// Returns next movement in a perm voyage global
	if self.myVoyageGlobal &lt;&gt; null then
		return self.myVoyageGlobal.allHMSMovements.getAtKeyGtr(self.occursOnDTNEW).HMS_Movement;
	else
		return null;
	endif;
end;</source>
        <ReturnType type="HMS_Movement"/>
    </JadeMethod>
    <JadeMethod name="lookupMovementPrevious" id="0f7e08e9-92be-4b52-9d77-9fd515ce32a8">
        <source>lookupMovementPrevious(): HMS_Movement;
//-----------------------------------------------------------------------
//	Created:	27 October 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
begin
	
  	// Returns next movement in a perm voyage global
	if self.myVoyageGlobal &lt;&gt; null then
		return self.myVoyageGlobal.allHMSMovements.getAtKeyLss(self.occursOnDTNEW).HMS_Movement;
	else
		return null;
	endif;
end;</source>
        <ReturnType type="HMS_Movement"/>
    </JadeMethod>
    <JadeMethod name="maintainLinkedList" id="a739b3c1-62e7-45fc-b1ae-1141724c30d4">
        <updating/>
        <source>maintainLinkedList() updating;
//-----------------------------------------------------------------------
//	Created:	05 December 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
//
// IMPORTANT: This should only be called from 
//		CM_Voyage::maintainMovementLinkedList or
// 		CM_VoyageGlobal::maintainMovementLinkedList 
// refer to comments in the above methods for why
// This method should only be called once all updates to
// occursOnDT have been completed.

vars
	prevMovement,
	nextMovement	: HMS_Movement;
begin

	if self.myVoyageGlobal &lt;&gt; null then
	
		if self.myVoyageGlobal.allHMSMovements.first = self then
			self.isFirstMovementForGlobalVoyage := true;
		else
			self.isFirstMovementForGlobalVoyage := false;
		endif;
	
		prevMovement := self.myVoyageGlobal.allHMSMovements.getAtKeyLss(self.occursOnDTNEW).HMS_Movement;
		if prevMovement &lt;&gt; null then
			self.myPreviousMovement := null;
			prevMovement.myNextMovement := null;
			self.myPreviousMovement := prevMovement;
		else
			if self.isFirstMovementForGlobalVoyage and 
			   self.myVoyageGlobal.myPriorVoyageGlobal &lt;&gt; null then
				prevMovement := self.myVoyageGlobal.myPriorVoyageGlobal.allHMSMovements.last;
				self.myPreviousMovement := null;
				prevMovement.myNextMovement := null;
				self.myPreviousMovement := prevMovement;
			else
				self.myPreviousMovement := null;
			endif;
		endif;
		
		nextMovement := self.myVoyageGlobal.allHMSMovements.getAtKeyGtr(self.occursOnDTNEW).HMS_Movement;
		if nextMovement &lt;&gt; null then
			self.myNextMovement := null;
			nextMovement.myPreviousMovement := null;
			self.myNextMovement := nextMovement;
		else
			if self.myVoyageGlobal.allHMSMovements.last = self and self.myVoyageGlobal.mySubsVoyageGlobal &lt;&gt; null then
				nextMovement := self.myVoyageGlobal.mySubsVoyageGlobal.allHMSMovements.first;
				self.myNextMovement := null;
				nextMovement.myPreviousMovement := null;
				self.myNextMovement := nextMovement;
			else
				self.myNextMovement := null;
			endif;
		endif;
	endif;
	
	self.setMyBerthPrevious();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="6a6aab41-cfe5-4a44-a8ef-7574358c35e6">
        <source>pxyCreateUpdateProxy(): SelfType;
//-----------------------------------------------------------------------
//	Created:	18 October 2006 Lorcan Bolster  (cnwlb1/lorcan)
/* Changes

Date		Name	TFS#		Description
============================================================================
20/04/2011	cnwmh5	PAR #27401 	Add code to handle prossible exceptions occurring when trying to create the proxy
23/09/2019 	jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
============================================================================*/
vars
	proxy : HMS_Movement;
	completedOK		: Boolean;
	
begin

	proxy := inheritMethod();
	proxy.setMyBerth( self.getMyBerth);
	proxy.myTidalClass := self.myTidalClass;
	
	// PAR 12295 We never copied the movement status correctly 
	proxy.moveStatusNEW := self.moveStatusNEW;
	
	// lorcan PAR 13319 - the sorting out of movements in the save needs prev and next movement
	proxy.myPreviousMovement := self.myPreviousMovement;
	proxy.myNextMovement := self.myNextMovement;
	
	if self.myPreviousMovement &lt;&gt; null then
		proxy.myBerthPrevious := self.myPreviousMovement.getMyBerth;		
	endif;
	
	proxy.myVoyageGlobal := self.myVoyageGlobal;
	
	//19 Jun 2018	NDL	TFS 39296
	if self.myMarineServiceTimings &lt;&gt; null then
		self.myMarineServiceTimings.cloneOnto( proxy );
	endif;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setBerthForFinalDeparture" id="8c43af09-a00a-4e4d-946a-8714b630bb94">
        <updating/>
        <source>setBerthForFinalDeparture(_berth : HMS_Berth) updating;
// ---------------------------------------------------------------------------
// Created:     26 October 2006 by cnwrs2
//
// Purpose:     Used to set the final departure berth on on Global Voyage if
//				the GLobal voyage is being linked to another voyage
// ---------------------------------------------------------------------------
vars

begin

	if _berth = null then
		app.raiseCMException2(MethodWithNullParam, class.name &amp; '::' &amp; method.name, '_berth', null, null);
		return;
	endif;
	
	self.setMyBerth(_berth);
	
	// now called in above method
	//self.setNextMovementBerthPrevious(_berth);
	//if self.myNextMovement &lt;&gt; null then
	//	self.myNextMovement.myBerthPrevious := _berth;
	//endif;

end;</source>
        <Parameter name="_berth" type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="23fa25e6-cc4a-4401-b255-d62081725009">
        <updating/>
        <source>setForCreate(_pxyObj: HMS_Object; _passport: CM_Passport input) updating;
//-----------------------------------------------------------------------
//	Created:	25 October 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars

begin
	app.raiseUnexpectedProgramError (class.name, '::' &amp; method.name, '-' &amp; " HMSMovement::setForCreate should be calling setForCreateMovement");
	inheritMethod(_pxyObj, _passport);

epilog

end;</source>
        <Parameter name="_pxyObj" type="HMS_Object"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreateMovement" id="9bc6fe1b-9396-4ae9-94db-faec3b38837a">
        <updating/>
        <source>setForCreateMovement(_pxyObj:HMS_Movement; _prevMovement : HMS_Movement; _calculateSteamingTime : Boolean; _passport: CM_Passport input) updating;
//--------------------------------------------------
// Created:	08 April 2004 By: cnwgd1
//--------------------------------------------------
vars
	newPreviousObj	: HMS_Movement;
	nextMoveObj		: HMS_Movement;
	
begin

	newPreviousObj	:=	_prevMovement;
	
	if newPreviousObj &lt;&gt; null then
		// This is a 1-to-1 inverse, so we need to nullify the other side of the relationship
		// before we assign this to a new previous Movement refererence.
		nextMoveObj	:=	newPreviousObj.myNextMovement;
		newPreviousObj.myNextMovement	:=	null;
		self.myNextMovement				:=	null;
		
		self.myPreviousMovement := newPreviousObj;
		self.myNextMovement		:=	nextMoveObj;
	else
		// try and lookup
		if self.myVoyageGlobal &lt;&gt; null then
			self.myPreviousMovement := self.getMovementPreviousGlobal();
		else
			self.myPreviousMovement := _pxyObj.getMovementPrevious();
		endif;
	endif;
	
	self.setForUpdateMovement(_pxyObj, _passport, true, _calculateSteamingTime);
end;</source>
        <Parameter name="_pxyObj" type="HMS_Movement"/>
        <Parameter name="_prevMovement" type="HMS_Movement"/>
        <Parameter name="_calculateSteamingTime" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a02cb7f2-a455-4cb7-8272-53cb1a662a71">
        <updating/>
        <source>setForUpdate(_pxyHarbour: HMS_Object; _passport: CM_Passport input) updating;
//-----------------------------------------------------------------------
//	Created:	25 October 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars

begin
	app.raiseUnexpectedProgramError (class.name, '::' &amp; method.name, '-' &amp; " HMSMovement::setForUpdate should be calling setForUpdateMovement");
	inheritMethod(_pxyHarbour, _passport);

epilog

end;</source>
        <Parameter name="_pxyHarbour" type="HMS_Object"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateMovement" id="5d5f1a09-71bf-42d1-8382-7807ae47f6b0">
        <updating/>
        <source>setForUpdateMovement(_proxy: HMS_Movement; _passport: CM_Passport input; _validateTimes : Boolean; _calculateSteamingTime : Boolean) updating;
//-----------------------------------------------------------------------
//	Created:	10 October 2006 Lorcan Bolster  (cnwlb1/lorcan)
/* Changes

Date		Name	TFS#		Description
============================================================================
21/09/2011	cnwcs5	CCMS RIO 2041/PAR 28220
27/09/2011	cnwcs5	CCMS 2130 / par 28261 - Minimum residence time
04/12/2018	jlgdap1	TFS 42252 	PEL1 Issues with voyages with no tug or pilot
18/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
11 Oct 2021 jlier1	TFS 51963 removed inaportnet
28/09/2023	jlika1	TFS 60540	POB - STATUS_TYPE_NAME "CANC" shown as Planned in MTN
============================================================================*/
vars
	coll		: CM_TimeStampIntervalByStartDT;
	pxyInterval	: CM_TimeStampInterval;
	newInterval	: CM_CargoOperationsInterval;
	marineTimings : HMS_MarineServicesTimings;
	makeActual : Boolean;	//16 Oct 2018	NDL	TFS 41412
	status : CM_VoyageStatus;
	voyage : CM_Voyage;
	realCancelled : HMS_Movement;	//19 Nov 2018	NDL	TFS 42043
	serviceTimings : HMS_MarineServicesTimings;				// TFS 42252
begin

	self.allCargoOperationsIntervals.purge;
	
	foreach pxyInterval in _proxy.allCargoOperationsIntervals do
		if self.isTransient then
			create newInterval transient;
		else
			create newInterval;
		endif;
		
		newInterval.setForUpdate (pxyInterval);
		newInterval.setMyHMSMovement (self);
	endforeach;
	
	//16 Oct 2018	NDL	TFS 41412
	if self.moveStatusNEW &lt;&gt; MovementStatus_Actual and _proxy.moveStatusNEW = MovementStatus_Actual then
		makeActual := true;
	endif;
		
	//self.cargoOperation				:= _proxy.cargoOperation; // jlgka1 TFS 45620
	self.isFirstMovementForGlobalVoyage	:= _proxy.isFirstMovementForGlobalVoyage;
	self.moveType 					:=	_proxy.moveType;
	self.moveStatusNEW				:=	_proxy.moveStatusNEW;
	//self.isBerthLocked				:=	_proxy.isBerthLocked;   // jlgka1 TFS 45620	
	self.remarks					:=	_proxy.remarks;
	//self.departureTimeLocked		:=	_proxy.departureTimeLocked; // jlgka1 TFS 45620	
	//self.minWaitingTime				:=	_proxy.minWaitingTime;  // jlgka1 TFS 45620
	self.starboardBerthed			:=	_proxy.starboardBerthed;
	
	//self.arrivalTimeAtFromRegionLocked	:=	_proxy.arrivalTimeAtFromRegionLocked; // jlgka1 TFS 45620
	
	//self.steamingTimeLocked			:=	_proxy.steamingTimeLocked; 	// jlgka1 TFS 45620
	//self.isArrivalDirect			:=	_proxy.isArrivalDirect;			// jlgka1 TFS 45620
	self.vesselDraft				:=	_proxy.vesselDraft;
	//self.autoCalculateMinWaitingTime:= _proxy.autoCalculateMinWaitingTime; // jlgka1 TFS 45620
	// arrivalTimeAtFromRegion is set by a mapping method on occursOnDTNEW
	//self.arrivalTimeAtFromRegion	:= _proxy.arrivalTimeAtFromRegion;
	
	//self.setOccursOnDT(_proxy.occursOnDTNEW, null, _filterTimesForward, _filterTimesForward ); //set after the moveStatus
	
	self.myTidalClass 				:=	_proxy.myTidalClass;
	self.setMyBerth(_proxy.getMyBerth);

	self.setTimings(_proxy.occursOnDTNEW, _proxy.steamingTime, _calculateSteamingTime); //jlgka1 TFS 45620
	
	//19 Jun 2018	NDL	TFS 39296
	if _proxy.myMarineServiceTimings &lt;&gt; null then
		if self.myMarineServiceTimings = null then 
			create marineTimings persistent;
		else
			marineTimings := self.myMarineServiceTimings;
		endif;
		marineTimings.setForUpdate( _proxy.myMarineServiceTimings, _passport );
		marineTimings.setMyVoyageMovement( self );
	endif;
	
	//19 Nov 2018	NDL	TFS 42043
	if _proxy.myCancelledMovement &lt;&gt; null then
		if _proxy.myCancelledMovement.isTransient then
			realCancelled := _proxy.myCancelledMovement.pxyGetRealObject();
		else
			realCancelled := _proxy.myCancelledMovement;
		endif;
		if realCancelled &lt;&gt; null then
			self.setMyCancelledMovement( realCancelled );
		elseif _proxy.myCancelledMovement.isKindOf(HMS_VoyageMovement) and _proxy.myCancelledMovement.moveType = HMSMovementTypeCanceledDepart then	//jlika1 - Add a persistent TFS 60540
			realCancelled := _proxy.myCancelledMovement.copySelfAs(_proxy.myCancelledMovement.class, false).HMS_VoyageMovement;				
			realCancelled.setMyBerth(_proxy.myCancelledMovement.myBerth);
			realCancelled.HMS_VoyageMovement.setPropertyValue("myHarbour", _proxy.myCancelledMovement.HMS_VoyageMovement.myHarbour);
			if realCancelled &lt;&gt; null then
				self.setMyCancelledMovement( realCancelled );
			endif;
		endif;		
	endif;
	
	//16 Oct 2018	NDL	TFS 41412
	if makeActual and self.isKindOf(HMS_VoyageMovement) then
		if self.myMarineServiceTimings = null then		// TFS 42252
			if self.isTransient then					// TFS 42252
				create serviceTimings transient;		// TFS 42252
			else										// TFS 42252
				create serviceTimings persistent;		// TFS 42252
			endif;										// TFS 42252
			serviceTimings.setMyVoyageMovement(self);	// TFS 42252
		endif;											// TFS 42252
		if self.myMarineServiceTimings &lt;&gt; null then
			self.myMarineServiceTimings.setMovementDateTimes( self.occursOnDTNEW, false, false , true, false );
		endif;
		
		// TFS 41539
		voyage := self.getVoyage();
		if voyage.myVoyageProcess &lt;&gt; null then// UNIT TESTS this is null
			if voyage.myVoyageProcess.isMTNWOProcess then //jlier1 TFS 51963 1/10/21
				if self.isMovementTypeArrival() then
					status := app.myRoot.allVoyageStatuses[Voyage_Status_VoyageArrived];	
					voyage.setStatusFromObject(status);
				elseif self.isMovementTypeDeparture() then
					status := app.myRoot.allVoyageStatuses[Voyage_Status_VesselDeparted];	
					voyage.setStatusFromObject(status);
				endif;
			endif;
			
		endif;
			
		
		
	endif;
	
	// should NOT call this here as can only maintain list
	// once all updates are complete
	//self.maintainLinkedList();
end;</source>
        <Parameter name="_proxy" type="HMS_Movement"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_validateTimes" type="Boolean"/>
        <Parameter name="_calculateSteamingTime" type="Boolean"/>
    </JadeMethod>
