    <JadeMethod name="delete" id="c8a73870-9e69-489b-8021-6cc2e44922c3">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 October 2014	cnwmc5	Initial creation

*/

vars

begin

	self.allLogIDs.purge();					//cnwmc5 - 13 April 2015 - PAR 36033
	
	delete self.myExtension;
	delete self.myLogDocketData;
	delete self.myOperator;
	delete self.myTerminal;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="6286df80-a183-4ab1-9875-d75e3096d7a4">
        <updating/>
        <source>setProxyFromObject(_realBOL : CM_BOLIn) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2014	cnwmc5	Initial creation

*/

vars
	bolExt 			: WS_BOLExtension;
	logDocketData 	: WS_LogDocket;
	operator		: WS_Operator;
	terminal		: WS_Terminal;
	
	//cnwmc5 - 16 April 2015 - CCMS 1138
	ti				: CM_TrackedItem;
	wsLogID			: WS_LogID;
	
begin
	inheritMethod(_realBOL);
	
	self.carrierCode 				:= _realBOL.carrierCode;
	self.consignee 					:= _realBOL.consignee;
	self.consignor 					:= _realBOL.consignor;
	self.driversPieceCount 			:= _realBOL.getDriversPieceCount();
	self.earliestScalingStartTs 	:= _realBOL.getEarliestScalingStartTs().asStringForWebInterface;		//cnwmc5 - 26 Jan 2016 - PAR 37326
	self.isPieceCountError 			:= _realBOL.getIsPieceCountError();
	self.lastestScalingEndTs 		:= _realBOL.getLastestScalingEndTs().asStringForWebInterface;			//cnwmc5 - 26 Jan 2016 - PAR 37326
	self.loggingOperation 			:= _realBOL.loggingOperation;
	self.loggingOrganisation 		:= _realBOL.loggingOrganisation;
	self.matchTime 					:= _realBOL.matchTime.asStringForWebInterface;							//cnwmc5 - 26 Jan 2016 - PAR 37326
	self.numItems 					:= _realBOL.numItems;
	self.numTIs 					:= _realBOL.numTIs;
	self.number 					:= _realBOL.number;
	self.opid 						:= _realBOL.opid;
	self.origLocationControllerId 	:= _realBOL.origLocationControllerId;
	self.remarks 					:= _realBOL.remarks;
	self.sourceLocation 			:= _realBOL.sourceLocation;
	self.sourceSubLocation 			:= _realBOL.sourceSubLocation;
	self.sourceSubSubLocation 		:= _realBOL.sourceSubSubLocation;
	self.status 					:= _realBOL.status;
	self.statusDescription 			:= _realBOL.statusDescription;
	self.trailerNumber 				:= _realBOL.trailerNumber;
	self.unloadPoint 				:= _realBOL.unloadPoint;
	self.vehicle 					:= _realBOL.vehicle;
	self.weightGrossTonnes 			:= _realBOL.weightGrossTonnes;
	self.weightNetTonnes 			:= _realBOL.weightNetTonnes;
	self.weightTareTonnes 			:= _realBOL.weightTareTonnes;
	// cnwmc5 - 19 August 2016 - TFS 2584
	self.truckNumber				:= _realBOL.truckNumber;
	
	if _realBOL.myExtension &lt;&gt; null then
		create bolExt transient;
		bolExt.setProxyFromObject(_realBOL.myExtension);
		self.myExtension := bolExt;
	endif;
	
	if _realBOL.myLogDocketData &lt;&gt; null then
		create logDocketData transient;
		logDocketData.setProxyFromObject(_realBOL.myLogDocketData);
		self.myLogDocketData := logDocketData;
	endif;
	
	if _realBOL.myOperator &lt;&gt; null then
		create operator transient;
		operator.setProxyFromObject(_realBOL.myOperator);
		self.myOperator := operator;
	endif;
	
	if _realBOL.myTerminal &lt;&gt; null then
		create terminal transient;
		terminal.setProxyFromObject(_realBOL.myTerminal);
		self.myTerminal := terminal;
	endif;
	
	//cnwmc5 - 16 April 2015 - CCMS 1138
	foreach ti in _realBOL.allTrackedItems do
		if ti.isKindOf(CM_Log) then
			create wsLogID transient;
			wsLogID.setProxyFromObject(ti.CM_Log);
			self.allLogIDs.add(wsLogID);
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_realBOL" type="CM_BOLIn"/>
    </JadeMethod>
</Class>
