    <JadeMethod name="isCompleteForJob" id="cf1c8739-a913-43ab-afbf-42ed3afde054">
        <source>isCompleteForJob(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 Feb 2011	cnwer1	Initial creation PAR 25573 - refactored out of rebuild status
02 Sep 2016	cnwrs1	TFS 2639 Par 38194 see self.job.isWLEMissingTIComplete in CM_Job and CM_VoyageROROJob
26 Sep 2016	cnwrs1	TFS 2748 did not allow for no job
23 Oct 2019	jlgzm1	TFS 47085 Direct Release Ship to Ship
15 Oct 2021	navdap1	TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
15 Nov 2021	navdap1	TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
*/

vars
	currentLocation : CM_LocationsController;
	isForRelease : Boolean;
	aFM : CM_FutureMove;
	fmMoveType		: Integer;
	currentVoyage 	 : CM_Voyage;
	result 			: Boolean;
begin
	result := inheritMethod();
	if self.myTrackedItem = null then
		if self.job &lt;&gt; null then
			return self.job.isWLEMissingTIComplete();
		else
			return false;
		endif;
	endif;
	
	currentLocation := self.myTrackedItem.getPrimaryLocation(REAL_MODE);
	isForRelease:= self.isReleaseTypeRequest;

	if 	currentLocation = null then
		//28 Oct 2011	NDL	 PAR 28586
		if self.myTrackedItem.isTBAorIsRRP then
			return false;
		endif;
		// PAR 28522
		if self.myTrackedItem.state = TI_STATE_NOTIFIED then
			return false;
		endif;
		//no location and state is deleted  then wle must be complete
		if self.myTrackedItem.state = TI_STATE_DELETED then
			return true;
		endif;
		//offsite come 
		if self.myTrackedItem.isOffSite then
			return true;		
		endif;
	
		// return the inherited result based on rt tasks
		return result;
	endif;
	
	if currentLocation.getParent().isKindOf(CM_Voyage) then
		currentVoyage:=currentLocation.getParent().CM_Voyage;
		if  ( self.myRequest.getIsRehandle or  self.myRequest.isSOB)   then
			if   self.myRequest.isSequenced then
		
				if  self.myRequest.isSOB then
						fmMoveType:=TI_FutureMoveSOB;
				else
					if self.isReleaseTypeRequest then // It's a Load job	
						fmMoveType:=TI_FutureMoveDLRLoad;
					else
						// Discharge job	- if this is a discharge DLR WLE then to be complete the TI will not have its DISCHARGE DLR future move
						fmMoveType:=TI_FutureMoveDLRDischarge;
					endif;
				endif;

				aFM:= myTrackedItem.getFutureMoveOfType(PLANNING_MODE,fmMoveType);
				//rehandle or sob and no futuren move then must be complete

				if aFM = null then 
					if self.myRequest.getIsRehandle then
						if (currentLocation.getFullId() = self.locationTarget)
						or (currentLocation.getFullId() = currentVoyage.code &amp; " " &amp; self.locationTarget) then // PAR 28968 testing RORO/LOLO DLRs
							return true;
						endif;
					else
						return true;
					endif;
				endif;
			elseif not self.allRTQueueEntries.isEmpty then
				//return status based on rt tasks
			
				return self.getStatusBasedOnRTTasks() = WLE_COMPLETED;
			else
				//no rt tasks and has not been sequenced must be unactioned
				return false;	
			endif;
		else
			//is on the voyage and is for a release/load job and on the correct voyage is ok to complete the job
			if isForRelease and self.getVoyage = currentVoyage then
				return true;
			elseif self.myTrackedItem.directDelivery and currentLocation.getFullId = self.locationTarget then	//07 Feb 2013	NDL	Par 31102
				return true;
			elseif self.isReceipt and self.myTrackedItem.isTranshipItem and // TFS 47085
			   self.getVoyage = self.myTrackedItem.myImportVoyage and 		// TFS 47085
			   currentVoyage = self.myTrackedItem.myExportVoyage then		// TFS 47085
				// if self is the receipt (import) part of a tranship, and the cargo is on the other (export) ship
				return true;	// TFS 47085
			endif;
	
		endif;
	else
		if currentLocation.isCraneLaneController() // 35091
		or currentLocation.isWorkPointLaneController() then // 35091
			if self.job.isVoyageROROJob() then // 35091
				return false; // 35091
			endif; // 35091
			
			if self.isHoldRecSplitWLE() then // ### TFS 51988 17SEP2021 NAVAB1
				return false;
			endif;
		endif; // 35091
		
		// tfs42840 jlgzm1 06/06/2019
		// is the first wle of a direct release
		if self.myFutureMoveDR &lt;&gt; null then
			return false;
		endif;
		
		// not on the voyage and is a discharge into the terminal then is completed
		if not isForRelease then
			return true;
		endif;
		
		// TFS 51935 if I'm the child of a DD yard WLE, just check my job for COMPLETE status
		//if self.myDirectDeliveryParentWLE &lt;&gt; null and self.job &lt;&gt; null and self.job.status = JOB_COMPLETE then	// TFS 52360
		if self.myDirectDeliveryParentWLE &lt;&gt; null and 																// TFS 52360
		(self.status = WLE_COMPLETED or (self.isKindOf(CM_VoyageWLE) and self.CM_VoyageWLE.subSeqNum = null))		// TFS 52360
		and self.job &lt;&gt; null and self.job.status = JOB_COMPLETE then												// TFS 52360
			return true;
		endif;
		// TFS 51935 end
	endif;
	
	
	return false;
	

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCompletedBulkRelease" id="0cb5890b-11f7-4b06-90fa-47f9da6e3b99">
