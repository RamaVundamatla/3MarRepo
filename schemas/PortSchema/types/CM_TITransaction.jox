    <JadeMethod name="getShippingLineStatus" id="46756936-d4b5-4433-80f9-54bd14a05917">
        <source>getShippingLineStatus() : CM_ShippingLineStatus;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/08/2023	navkc1	CR 59594  Task 59584: Jade - CustDocs New YA Criteria

*/

vars
	shippingLineStatus		: CM_ShippingLineStatus;
	criteria				: CM_ShippingLineStatusCriteria;
	allCriteria				: CM_ShipLineStatusCriteriaByPri;
begin
	
	allCriteria := self.myTerminal.allShippingLineStatusCriteria;
	
	foreach criteria in allCriteria discreteLock, reversed do 
		if not criteria.matches(self.myTrackedItem) then
			continue;
		endif;
		
		shippingLineStatus := criteria.myShippingLineStatus;
		if shippingLineStatus = null or shippingLineStatus.notAvailForEntry then
			continue;
		else
			return shippingLineStatus;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_ShippingLineStatus"/>
    </JadeMethod>
