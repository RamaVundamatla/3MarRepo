// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		if self.useTblThumb &lt;&gt; _value then
			self.useTblThumb := _value;
			
			if _value then
				self.useThumbArea := true;
