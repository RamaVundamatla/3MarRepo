//								cmifConsist);
	
//	if _passport.hasErrors() then
//		app.myTrxUA.trxSetEDIDataStatus(self, CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS);
//		return;
//	endif;
	
	// Finally, invoke the transaction to process the data.
	app.myTrxUA.trxProcessEDITrainConsist(self, false, _passport);
	
epilog
//	delete cmifConsist;
end;</source>
