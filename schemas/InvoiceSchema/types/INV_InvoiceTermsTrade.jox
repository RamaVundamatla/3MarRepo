    <JadeMethod name="doSave" id="4a89f548-65f7-4c47-87d8-47e137c8c238">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	pxyInvoiceTermsOfTrade, realInvoiceTermsOfTrade		: CM_InvoiceTermsOfTrade;
	rtnValue			: Boolean;
	errObj				: CM_Error;
	navObject			: CMUI_NavigatorObject;
	id, theReturn					: Integer;
	table				: CM_EntryTable;
	dueRules			: Integer;
begin

	table := self.tblEntDetail;

	if self.mode = Mode_Add then
		create pxyInvoiceTermsOfTrade transient;
	elseif self.mode = Mode_Update then
		pxyInvoiceTermsOfTrade := self.myProxyObject.CM_InvoiceTermsOfTrade;
	else
		return false;
	endif;
	
	if self.cmbDueRule.listIndex &gt; 0 then
		dueRules := self.cmbDueRule.itemData[self.cmbDueRule.listIndex];
	endif;
	
	pxyInvoiceTermsOfTrade.setProxy(self.tblEntDetail.getValueByName(ETRow_Code3).String,
							self.tblEntDetail.getValueByName(ETRow_Description30).String,
							self.tblEntDetail.getValueByName(ETRow_DueDays).Integer,	//15/01/2023	navkc1 ChangeRequest 59145 Task 61328
							dueRules			//15/01/2023	navkc1 ChangeRequest 59145 Task 61328
							);

	while true do
		if self.mode = Mode_Add then
			app.myTrxCA.trxCreateInvTermsOfTrade(pxyInvoiceTermsOfTrade,  self.myCurrentObject, app.myPassport);
		elseif self.mode = Mode_Update then
			app.myTrxUA.trxUpdateInvTermsOfTrade(self.myTerminal,pxyInvoiceTermsOfTrade, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			return true;
		else
			theReturn := app.showErrorWarningDialog("Terms Of Trade", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;
	
epilog
	if self.mode = Mode_Add then
		delete pxyInvoiceTermsOfTrade;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
