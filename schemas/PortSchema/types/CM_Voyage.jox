    <JadeMethod name="getLastMovementShift" id="c0113e02-149a-4741-8b79-5dea6623cbe3">
        <source>getLastMovementShift() : HMS_VoyageMovement;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 August 2018	jlger1	Initial creation

*/

vars
	move : HMS_VoyageMovement;
begin

	if self.myHMSVoyageData = null then
		return null;
	endif;
	
	foreach move in self.myHMSVoyageData.allVoyageMovements  reversed do
		if move.moveType = HMSMovementTypeShift then
			return move;
		endif;
	endforeach;

	return null;
epilog

end;</source>
        <ReturnType type="HMS_VoyageMovement"/>
    </JadeMethod>
    <JadeMethod name="getLastPortInRotation" id="5b844c62-3ebf-43b8-9a85-e45259b821ca">
        <source>getLastPortInRotation():CM_Port;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18/08/2018	jlgma1	Bug 40102: PEL1 - Voyage Request Report (PKK) - Expose fields request
21/11/2018	jlgdap1	TFS 42024 PEL1 Incorrect Ports in Voyage Request
1/10/2021	jlier1	TFS 51963 
*/

vars
	lastPort : CM_Port;
	wod : CM_WodVoyageRequest;			// TFS 42024
begin
	if not self.isDefaultVoyageProcess then		// TFS 42024
		wod := self.getWorkOrderForVoyageRequest();							// TFS 42024
		if wod &lt;&gt; null and wod.portCode2 &lt;&gt; null then						// TFS 42024
			return app.myRoot.allPorts[wod.portCode2];						// TFS 42024
		endif;																// TFS 42024
	endif;																	// TFS 42024
	
	if self.allPortRotations.isEmpty() then
		return null;
	endif;
	
	lastPort := self.allPortRotations.last.CM_PortRotation.myPort;
	return lastPort;
epilog

end;</source>
        <ReturnType type="CM_Port"/>
    </JadeMethod>
    <JadeMethod name="getLatestMovement" id="6eccc0fa-d871-4279-b118-1cedc25c9dcd">
