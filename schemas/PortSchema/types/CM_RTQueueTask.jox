    <JadeMethod name="isOverStowedRTQueue" id="9206c800-873a-4ba6-bc82-5266d392d362">
        <source>isOverStowedRTQueue(_isOverstowed : Boolean output;
					_isOverstowedAtMoveTime : Boolean output;
					_sideAccessDirection : Integer io);
/*
Purpose:			Changed now required to return 2 values 
						if the the container is overstowed regardless of whether the containers overstowing it are queued to move before it
							and
						if container is overstowed at move time i.e. will the overstowing containers be moved by the time it is picked up. This is
							determined by the order of the RT queue entries

Parameters:			

Return Value:		

Date		Who		Reason
16/12/2009	cnwer1	Initial creation
25/05/2010	cnwdap1	CCMS 1116 Tranship changes
//15 May 2014	cnwrs1	Par 34154 - handle invalid object for ti
*/
vars
	theTI		: CM_TrackedItem;
	invalid : Boolean;
	overstowController : CMIF_OverstowController;
begin

	_isOverstowed:=false;
	_isOverstowedAtMoveTime:=false;
	if self.ti = null then
		return;
	endif;	
	
	theTI:=self.ti; //epr par 34257 16/6/14
	on Exception do app.handleDeletedObject(exception, theTI, invalid);
	if self.ti.myPrimaryActualLocation = null then
		return;
	endif;
	if invalid then
		return;
	endif;
	
	//if multi machine move entry check previous entry if IMV can ignore because overstow will be handled by source pickup task
	if	self.myEntry.machineTypeGroup = MACHINETYPEGRP_IMV then
		return;
	endif;

	//We are only concerned with overstowed at the source location 
	// if there is a previous entry then it is to be picked up by another machine
	if self.myEntry.getPreviousRelatedEntry() &lt;&gt; null then
		return;
	endif;
	//epr TFS 37584 4/5/18
	create overstowController transient;
	overstowController.setParams(_sideAccessDirection,self.ti,true,self.myEntry,null);
	overstowController.getAllOverstows;
	_isOverstowed:=overstowController.isOverstowed;
	_isOverstowedAtMoveTime:=overstowController.isOverstowedAtMoveTime;
	
epilog
	delete overstowController;
end;</source>
        <Parameter name="_isOverstowed" type="Boolean" usage="output"/>
        <Parameter name="_isOverstowedAtMoveTime" type="Boolean" usage="output"/>
        <Parameter name="_sideAccessDirection" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isOverstowTask" id="5eebca9b-7585-445f-a2a4-1859f4c5c40e">
        <methodInvocation>mapping</methodInvocation>
        <source>isOverstowTask(set : Boolean; _value : Boolean io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2010	cnwer1	Initial creation

*/

vars

begin
	if not set then
		_value:=self.isOverstowTask;
		if self.isOverstowTask then
			_value:=true;
		else
			if self.myEntry.myOverstowOfEntry &lt;&gt; null then
				_value:=true;
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isOverstowTaskAuto" id="4c8aad33-3df0-4de6-8e99-b3cf733862c3">
        <source>isOverstowTaskAuto() : Boolean;

/*

Purpose:			Determine whether or not the receiver task is an automatically generated 
					oevrstow move.

Parameters:			None

Return Value:		True if it is, false otherwise


Date		Who		Reason
30 Jun 2010	cnwkpd1	PAR #24495 - ITS interface can not be sent automatic overstow moves,
					but can be sent manual ones

*/

vars
	entry			: CM_RTQueueEntry;
	
begin
	entry := self.myEntry;
	if entry &lt;&gt; null and entry.myOverstowOfEntry &lt;&gt; null then		// This is a task for a manually created overstow
		return false;												// so it is not a manual one
	endif;
	
	// Otherwise, just return value of isOverstoTask
	return self.isOverstowTask;
	
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
