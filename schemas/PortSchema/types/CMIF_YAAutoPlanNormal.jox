        <source>isTranshipToPort_Match(_yaData: CM_YADataObjects): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwas3	Initial creation

*/
vars

	transhipPort	: Object;
	port			: String;

begin
	if _yaData.isEmpty() then
		return true;
	endif;

	if self.myTrackedItem.myTranshipToPort = null then
		return false;
	endif;
	port := self.myTrackedItem.myTranshipToPort.code.trimBlanks();
	
	if port = null then
		return false;
	endif;
	
	return _yaData.visitObjectsUntilTrue(self, CMIF_YAAutoPlanNormal::isTranshipToPort_Compare, port);
end;</source>
