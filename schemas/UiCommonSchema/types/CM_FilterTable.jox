    <JadeMethod name="tblFilterHeaders_mouseDown" id="983b2f32-d788-4d43-a076-ac7c598369a4">
        <updating/>
        <source>tblFilterHeaders_mouseDown(table: CM_FilterTableHeaders input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2015	cnwndl1	Initial creation

*/

vars

	colIndex : Integer;
	cloneListTable : CM_FilterTableList;
	msg : String;
	rowIndex : Integer;
	cloneString : String;
	textValue : String;
	allSet : Boolean;
	visibleCount : Integer;
	selectedValues : StringArray;
	newIndex : Integer;

begin

	colIndex := table.column;
	
	if colIndex &lt;= self.fixedColumns then
		// do not allow filtering on fixed columns
		return;
	endif;
	
	cloneListTable := self.lstFilterValues.getControl(colIndex).CM_FilterTableList;
	if cloneListTable = null or cloneListTable.rows &lt; 1 then
		self.frmUpdFilter.visible := false;
		return;
	endif;
	
	if self.frmUpdFilter.visible then
		if cloneListTable = self.myProxiedFilterToUpdate then
			//they have clicked the same one as they have open, just close it.
			self.btnCancelFilterChg.click(self.btnCancelFilterChg);
			return;
		endif;
		msg := app.getErrorString(Must_apply_cance_curre_filte_c);
		app.msgBox( msg, app.getErrorString(Error) , MsgBox_OK_Only );
		return;
	endif;
	
	if button = 2 then
		//trying to get context menu
		return;
	endif;
	
	self.frmUpdFilter.parent := self;
	self.myProxiedFilterToUpdate := cloneListTable;
	self.lstFilterProxy.rows := 0;
	
	// Populate a stringArray with the currently selected values, or find that everything is selected.
	create selectedValues transient;
	foreach rowIndex in 1 to cloneListTable.rows do
		textValue := cloneListTable.getCellText(rowIndex,2);
		if textValue = self.AllValues then
			allSet := cloneListTable.getCellText(rowIndex,1) = TableCheckBox_Selected;
		endif;
		if allSet then
			break;
		else
			if cloneListTable.getCellText(rowIndex,1) = TableCheckBox_Selected then
				selectedValues.add( textValue );
			endif;
		endif;
	endforeach;
	
	// re-populate the cloneListTable with all possible values
	self.columnFilterGetValues( colIndex );
	
	//setup the one we are using based on the updated values, with the current selections applied wher they still exist
	if allSet then
		foreach rowIndex in 1 to cloneListTable.rows do
			textValue := cloneListTable.getCellText(rowIndex,2);
			cloneString := TableCheckBox_Selected &amp; Tab &amp; textValue;
			newIndex := self.lstFilterProxy.addItem( cloneString );
			if textValue = self.AllValues then
				self.lstFilterProxy.accessRow(newIndex).visible := false;
			endif;
		endforeach;
	else
		// set the selection, based on what we have now
		foreach rowIndex in 1 to cloneListTable.rows do
			textValue := cloneListTable.getCellText(rowIndex,2);
			if selectedValues.includes(textValue) then
				cloneString := TableCheckBox_Selected &amp; Tab &amp; textValue;
			else
				cloneString := TableCheckBox_NotSelected &amp; Tab &amp; textValue;
			endif;
			newIndex := self.lstFilterProxy.addItem( cloneString );
			if textValue = self.AllValues then
				self.lstFilterProxy.accessRow(newIndex).visible := false;
			endif;
		endforeach;
	endif;
	visibleCount := cloneListTable.rows - 1;
	
	if self.frmUpdFilter.makePositionAndSizeRelative( colIndex, visibleCount ) then
		//we are displaying it.
		self.frmUpdFilter.visible := true;
		self.frmUpdFilter.zOrder(1);
	
	else
		// probably not enough space to display it
		self.myProxiedFilterToUpdate := null;
		self.frmUpdFilter.visible := false;
	
	endif;

epilog

	delete selectedValues;

end;</source>
        <Parameter name="table" type="CM_FilterTableHeaders" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="width" id="25a0670f-767d-469b-817e-0962faf0b343">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>width(set: Boolean; value: Real io) updating, mapping, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2015	cnwndl1	Initial creation

*/

vars

begin

	inheritMethod(set, value);
	
	if set then
		if self.frmParentFilterTableFrame &lt;&gt; null then
			self.frmParentFilterTableFrame.width := value;
		endif;
		if self.tblFilterHeaders &lt;&gt; null then
			self.tblFilterHeaders.width := value;
		endif;
		if self.btnShowHide &lt;&gt; null then
			self.btnShowHide.left := value - self.btnShowHide.width;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Real" usage="io"/>
