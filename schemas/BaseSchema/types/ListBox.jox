    <JadeMethod name="cnEcAddBranch" id="96834ed5-c8da-4c10-a8dd-caaf1b9f6d6a">
        <source>cnEcAddBranch(pText : String; pPosition : Integer):Integer;
// --------------------------------------------------------------------------------
// Created:		25 January 2001 by cnwdad2
//
// Purpose:		Creates a new branch in the list hierarchy.  It's assumed that for
//				this method to be called then the "hasPictures" attribute for this
//				listbox will have been set.
//
//				NOTE - If a position is not passed in then an item will be simply added.
//
// Parameters:	pText - 
//				pPosition - 
//
// Returns:		The index of the newly created branch.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	newItemPointer	: Integer;

begin
	if pPosition = null then
		newItemPointer	:=	addItem(pText);
	else
		addItemAt(pText, pPosition);
		newItemPointer	:=	pPosition;
	endif;
	
	return newItemPointer;
end;</source>
        <Parameter name="pText" type="String"/>
        <Parameter name="pPosition" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcAddItemDataObject" id="254ac7cb-e26c-4e07-acf5-d2b2c24052d6">
        <source>cnEcAddItemDataObject(pNewItem:String; pItemData:Integer; pItemObject:Object):Integer;
// --------------------------------------------------------------------------------
// Created:		12 February 2007 by cnwdad1
//
// Purpose:		Adds a new item to the receiver, and optionally sets an ItemData
//				value, and an ItemObject reference.
//
// Parameters:	pNewItem - The display text of the new item.
//				pItemData - An optional ItemData value.
//				pItemObject - An optional ItemObject reference.
//
// Returns:		The index at which the new item was added.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	
begin
	rowPointer	:=	self.addItem(pNewItem);
	
	if pItemData &lt;&gt; 0 then
		self.itemData[rowPointer]	:=	pItemData;
	endif;
	
	if pItemObject &lt;&gt; null then
		self.itemObject[rowPointer]	:=	pItemObject;
	endif;
	
	return rowPointer;
end;</source>
        <Parameter name="pNewItem" type="String"/>
        <Parameter name="pItemData" type="Integer"/>
        <Parameter name="pItemObject" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcAddItemDataObjectAt" id="4044061d-177d-450b-868c-eeab30642c91">
        <source>cnEcAddItemDataObjectAt(pIndex:Integer; pNewItem:String; pItemData:Integer; pItemObject:Object):Boolean;
// --------------------------------------------------------------------------------
// Created:		12 February 2007 by cnwdad1
//
// Purpose:		Adds a new item to the receiver, and optionally sets an ItemData
//				value, and an ItemObject reference.
//
// Parameters:	pIndex - The index at which to add the new item.
//				pNewItem - The display text of the new item.
//				pItemData - An optional ItemData value.
//				pItemObject - An optional ItemObject reference.
//
// Returns:		True if the item was successfully added, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	entryCount	: Integer;
	
begin
	entryCount	:=	self.listCount;
	
	if pIndex &gt; (entryCount + 1) then
		return false;
	endif;
	
	self.addItemAt(pNewItem, pIndex);
	
	if pItemData &lt;&gt; 0 then
		self.itemData[pIndex]	:=	pItemData;
	endif;
	
	if pItemObject &lt;&gt; null then
		self.itemObject[pIndex]	:=	pItemObject;
	endif;
	
	return true;
end;</source>
        <Parameter name="pIndex" type="Integer"/>
        <Parameter name="pNewItem" type="String"/>
        <Parameter name="pItemData" type="Integer"/>
        <Parameter name="pItemObject" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcAddLeaf" id="1ba242fe-d742-475f-b968-2834e0599e54">
        <source>cnEcAddLeaf(pText : String; pPosition : Integer):Integer;
// --------------------------------------------------------------------------------
// Created:		25 January 2001 by cnwdad2
//
// Purpose:		Adds a new leaf to a branch of the list hierarchy.  Its assumed that for this method to be called then the "hasPictures" attribute for this listbox will have been set.
//
//				NOTE - If a position is not included then an item will be simply added.
//
// Parameters:	pText - 
//				pPosition - 
//
// Returns:		The index of the newly created leaf.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	newItemPointer	: Integer;

begin
	if pPosition = null then
		newItemPointer	:=	addItem(pText);
	else
		addItemAt(pText, pPosition);
		newItemPointer	:=	pPosition;
	endif;	

	self.itemPictureType[newItemPointer]	:=	ListBox.ItemPictureType_Leaf;
	return newItemPointer;
end;</source>
        <Parameter name="pText" type="String"/>
        <Parameter name="pPosition" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcAddTreeObject" id="ff256820-f4ec-45a3-af6b-e7802481503d">
        <source>cnEcAddTreeObject(pText:String; pObject:Object; pLevel:Integer; pIsExpanded:Boolean):Integer;
// --------------------------------------------------------------------------------
// Created:		05 April 2005 by cnwdad1
//
// Purpose:		Inserts a node into a tree structure.
//
// Parameters:	pText - The text for the item entry.
//				pObject - A reference to the object for the item entry.
//				pLevel - The item entry's level in the tree hierarchy.
//				pIsExpanded - True if the node is to be expanded.
//
// Returns:		A pointer to the new item entry.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	
begin
	rowPointer	:=	self.addItem(pText);
	self.itemLevel[rowPointer]		:=	pLevel;
	self.itemExpanded[rowPointer]	:=	pIsExpanded;
	self.itemObject[rowPointer]		:=	pObject;
	
	return rowPointer;
end;</source>
        <Parameter name="pText" type="String"/>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="pLevel" type="Integer"/>
        <Parameter name="pIsExpanded" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcExpandItem" id="057a1b5c-16de-4454-b2bd-06f3821e78fd">
        <source>cnEcExpandItem(pRowPointer:Integer; pIsExpandAll:Boolean):Boolean;
// --------------------------------------------------------------------------------
// Created:		05 April 2005 by cnwdad1
//
// Purpose:		Expands the specified tree node of the receiver, and optionally all
//				of the child nodes.
//
// Parameters:	pRowPointer - The index of the node to expand.
//				pIsExpandAll - If true, then all child nodes will also be expanded.
//
// Returns:		True if the node was successfully expended, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 23/12/2007	cnwdad1		Fixed bug where an open node would close and fail to
//							expand the remainder of the tree.
// 05/11/2009	cnwrl1		The recursive call below is unnecessary and is being called 8194
//							times for a single tree with 16 levels expanded at the top!
// --------------------------------------------------------------------------------
vars
	parentLevel	: Integer;
	startRow	: Integer;
	childRow	: Integer;
	rowCount	: Integer;
	
begin
	if pRowPointer = CNEC_NULL_INDEX then
		return false;
	endif;
	
	if self.itemHasSubItems(pRowPointer) then
		self.itemExpanded[pRowPointer]	:=	true;
		
		if pIsExpandAll then
			parentLevel	:=	self.itemLevel[pRowPointer];
			startRow	:=	pRowPointer + 1;
			rowCount	:=	self.listCount();
			
			foreach childRow in startRow to rowCount do
				if self.itemLevel[childRow] &lt;= parentLevel then
					break;
				endif;
				
//				self.cnEcExpandItem(childRow, true);	// cnwrl1 05/11/2009 - what it was - this is doing too many recusive calls
				self.itemExpanded[childRow]	:=	true;
			endforeach;
		endif;
	endif;
	
	return true;
end;</source>
        <Parameter name="pRowPointer" type="Integer"/>
        <Parameter name="pIsExpandAll" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcFindItemData" id="eb624803-f782-4df0-9826-709a3b88162a">
        <source>cnEcFindItemData(pItemData:Integer; pStartIndex:Integer):Integer;
// --------------------------------------------------------------------------------
// Created:		12 August 2005 by cnwdad1
//
// Purpose:		Scans the receiver for the first entry who's itemData matches the
//				specified pItemData value.
//
// Parameters:	pItemData - The itemData value to match.
//				pStartIndex - The list index at which to begin the scan.
//
// Returns:		The index of the matching list item, or CNEC_NULL_INDEX if none of
//				the item data values matched the parameter value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listPointer	: Integer;
	itemCount	: Integer;
	startIndex	: Integer;
	
begin
	itemCount	:=	self.listCount();
	
	if pStartIndex &gt; 0 then
		startIndex	:=	pStartIndex;
	else
		startIndex	:=	1;
	endif;
	
	foreach listPointer in startIndex to itemCount do
		if self.itemData[listPointer] = pItemData then
			return listPointer;
		endif;
	endforeach;
	
	return CNEC_NULL_INDEX;
end;</source>
        <Parameter name="pItemData" type="Integer"/>
        <Parameter name="pStartIndex" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcFindParent" id="fed1790e-9c81-4816-93a0-91a39cb07d18">
        <source>cnEcFindParent(pStartIndex:Integer):Integer;
// --------------------------------------------------------------------------------
// Created:		26 July 2000 by cnwdad1
//
// Purpose:		This method will search backwards through the listbox, and return
//				the parent list item in the list hierarchy.
//
//				The index position of the parent item will be returned.
//
//				If the starting index position (pStartIndex) is 0 or 1, then zero
//				will be returned.  Likewise, if a parent is not found, then a zero
//				will also be returned.
//
// Parameters:	pStartIndex (Integer) - The starting item index.
//
// Returns:		The item index of the parent.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	entryIndex	: Integer;	// Current list item index.
	entryLevel	: Integer;	// Current list item level.
	childLevel	: Integer;	// Item Level of the child list item.

begin
	if (pStartIndex = 0) or (pStartIndex = 1) or (self.listCount = 0) then
		return 0;
	endif;

	childLevel	:=	self.itemLevel[pStartIndex];
	entryIndex	:=	pStartIndex - 1;

	while (entryIndex &gt; 0) do
		if (not entryLevel &gt; self.listCount) then
			entryLevel		:=	self.itemLevel[entryIndex];

			if (entryLevel = (childLevel - 1)) then
				// The parent item level should be 1 less than that of it's child.
				return entryIndex;
			endif;
		endif;

		entryIndex	:=	entryIndex - 1;	// We're stepping backwards through the list.
	endwhile;

	return 0;
end;</source>
        <Parameter name="pStartIndex" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcFindWhere" id="cd0b7081-0f95-4084-9672-f979739b0de6">
        <source>cnEcFindWhere(pString : String; pParent : Integer) : Integer;
// --------------------------------------------------------------------------------
// Created:		25 January 2001 by cnwdad2
//
// Purpose:		Find the right insertion point in listbox pTargetListbox for
//				pString.  If pParent = 0, the string is a Category (level 1) item.
//				If pParent not = 0, the string is a level 2 item and we need to
//				find the insertion point within its category, identified by location
//				pParent in the listbox.
//
// Parameters:	pString - 
//				pTargetListBox - 
//				pParent - 
//
// Returns:		The target list index.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	targetListSize	: Integer;
	lastLevel1Pos 	: Integer;

begin
	if pParent = 0 then													// It's a category item.
    	targetListSize	:=	self.listCount;
    	lastLevel1Pos	:=	targetListSize + 1;
    	
    	while targetListSize &gt; 0 do
    		if self.itemLevel[targetListSize] = 1 then
    			if self.itemText[targetListSize] &lt; pString then
    				return lastLevel1Pos;								// Found the right spot for it.
    			endif;
    			
    			lastLevel1Pos	:=	targetListSize;		
    		endif;
    		
    		targetListSize	:=	targetListSize - 1;						// Work backwards through listbox.
    	endwhile;
    	
		return 1;														// Needs to go at top of listbox.
	else
		targetListSize := pParent;										// An individual item - category address.
		
		while targetListSize &lt; self.listCount do
			targetListSize := targetListSize + 1;						// Work forward through listbox.
			
			if self.itemLevel[targetListSize] = 1 then					// Reached next category ?
				return targetListSize;									// Then put at end of this category.
			elseif self.itemText[targetListSize] &gt; pString then
				return targetListSize;									// Found the spot.
			endif;
		endwhile;
		
		return targetListSize + 1;										// Put at end of listbox.
	endif;				
end;</source>
        <Parameter name="pString" type="String"/>
        <Parameter name="pParent" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetChildNodes" id="f72266d5-e996-4085-91cb-9f504dc65fe1">
        <source>cnEcGetChildNodes(pParentIndex:Integer; pAllChildNodes:CnEcTreeNodeArray input):Boolean;
// --------------------------------------------------------------------------------
// Created:		11 November 2005 by cnwdad1
//
// Purpose:		Populates the array parameter with object representing each of the
//				parent's child nodes.
//
// Parameters:	pParentIndex - The index of the list item who's child nodes to get.
//				pAllChildNodes - A reference to an array of child nodes.
//
// Returns:		True if the child nodes were successfully fetched, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	lastIndex		: Integer;
	startIndex		: Integer;
	listPointer		: Integer;
	currentLevel	: Integer;
	parentLevel		: Integer;
	childLevel		: Integer;
	childNodeObj	: CnEcTreeNode;
		
begin
	lastIndex	:=	self.listCount();
	
	if pParentIndex &lt; 1 or pParentIndex &gt; lastIndex then
		return false;
	endif;
	
	if not self.itemHasSubItems(pParentIndex) then
		return true;
	endif;
	
	startIndex	:=	pParentIndex + 1;
	parentLevel	:=	self.itemLevel[pParentIndex];
	childLevel	:=	self.itemLevel[startIndex];
	
	foreach listPointer in startIndex to lastIndex do
		currentLevel	:=	self.itemLevel[listPointer];
		
		if currentLevel &lt;= parentLevel then
			break;
		endif;
		
		if currentLevel = childLevel then
			create childNodeObj transient;
			
			childNodeObj.updateMe(	self.itemText[listPointer],
									listPointer,
									self.itemLevel[listPointer],
									self.itemForeColor[listPointer],
									self.itemBackColor[listPointer],
									self.itemData[listPointer],
									self.itemPicture[listPointer],
									self.itemObject[listPointer]);
			
			pAllChildNodes.add(childNodeObj);
			
			if self.itemHasSubItems(listPointer) then
				if not childNodeObj.getChildNodesList(self) then
					return false;
				endif;
			endif;
		endif;
	endforeach;
	
	return true;
end;</source>
        <Parameter name="pParentIndex" type="Integer"/>
        <Parameter name="pAllChildNodes" type="CnEcTreeNodeArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetCurrentItemData" id="e029b3e2-fdd9-4d27-a8e5-486fa6d443a3">
        <source>cnEcGetCurrentItemData():Integer;
// --------------------------------------------------------------------------------
// Created:		15 March 2005 by cnwdad1
//
// Purpose:		Returns the item data for the currently selected list item.
//
// Parameters:	None
//
// Returns:		The item data value of the currently selected list item.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listPointer	: Integer;
	
begin
	listPointer	:=	self.listIndex;
	
	if listPointer &lt;= 0 then
		return 0;
	endif;
	
	return self.itemData[listPointer];
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetItemData" id="54fbd2e6-1130-4159-9bec-2dc6a34d6e11">
        <source>cnEcGetItemData(pListIndex:Integer):Integer;
// --------------------------------------------------------------------------------
// Created:		15 March 2005 by cnwdad1
//
// Purpose:		Returns the item data for the specified index.
//
// Parameters:	pListIndex - The index of the item data to return.
//
// Returns:		The requested item data value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pListIndex &lt;= 0 or pListIndex &gt; self.listCount then
		return 0;
	else
		return self.itemData[pListIndex];
	endif;
end;</source>
        <Parameter name="pListIndex" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetNodeWithChildren" id="d934ca4f-753d-4d30-b3e2-c8764c8d7b7c">
        <source>cnEcGetNodeWithChildren(pParentIndex:Integer; pParentNodeObj:CnEcTreeNode output):Boolean;
// --------------------------------------------------------------------------------
// Created:		11 November 2005 by cnwdad1
//
// Purpose:		Returns a reference to a tree node object for the specified parent
//				list item index.  The tree object will include all of its child node
//				objects.
//
// Parameters:	pParentIndex - The index of the list item who's child nodes to get.
//				pParentNodeObj - A reference to the parent node tree object.
//
// Returns:		True if the child nodes were successfully fetched, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	parentNodeObj	: CnEcTreeNode;
		
begin
	if pParentIndex &lt; 1 or pParentIndex &gt; self.listCount() then
		return false;
	endif;
	
	create parentNodeObj transient;
	
	parentNodeObj.updateMe(	self.itemText[pParentIndex],
							pParentIndex,
							self.itemLevel[pParentIndex],
							self.itemForeColor[pParentIndex],
							self.itemBackColor[pParentIndex],
							self.itemData[pParentIndex],
							self.itemPicture[pParentIndex],
							self.itemObject[pParentIndex]);
	
	parentNodeObj.getChildNodesList(self);
	pParentNodeObj	:=	parentNodeObj;
	
	return true;
end;</source>
        <Parameter name="pParentIndex" type="Integer"/>
        <Parameter name="pParentNodeObj" type="CnEcTreeNode" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsInScrollZone" id="06e01178-69b3-4d8e-bc0d-0948956f715e">
        <source>cnEcIsInScrollZone(pXPos:Real; pYPos:Real; pBorder:Integer output):Boolean;
// --------------------------------------------------------------------------------
// Created:		19 May 2006 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the specified coordinates
//				are within an estimated scroll zone, i.e. within a certain distance
//				from the edge of the receiver.
//
// Parameters:	pXPos - The x coordinate.
//				pYPos - The y coordinate.
//				pBorder - Returns a value indicating which border the coordinates
//					are near.
//
// Returns:		True if the coordinate is near the scroll zone, otherwise false.
//				The output parameter indicates which border the coordinates are near.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	ScrollMargin	: Integer = 25;
	
begin
	if pXPos &lt;= ScrollMargin then
		pBorder	:=	self.CNEC_LEFT;
		return true;
	elseif pYPos &lt; ScrollMargin then
		pBorder	:=	self.CNEC_TOP;
		return true;
	endif;
	
	if pXPos &gt;= (self.clientWidth - ScrollMargin) then
		pBorder	:=	self.CNEC_RIGHT;
		return true;
	elseif pYPos &gt;= (self.clientHeight - ScrollMargin) then
		pBorder	:=	self.CNEC_BOTTOM;
		return true;
	endif;
	  
	return false;
end;</source>
        <Parameter name="pXPos" type="Real"/>
        <Parameter name="pYPos" type="Real"/>
        <Parameter name="pBorder" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcMoveAll" id="1954b421-0f56-484c-8721-74488425130a">
        <updating/>
        <source>cnEcMoveAll(pTargetListObj:ListBox input) updating;
// --------------------------------------------------------------------------------
// Created:		26 July 2000 by cnwdad1
//
// Purpose:		Moves all items from the receiver listbox into the listbox
//				specified as the input parameter.
//
// Parameters:	pTargetListObj - The control to which the items will be moved.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 13/11/2005	cnwdad1		Added support for an hierarchical item list.
// --------------------------------------------------------------------------------
vars
	entryCount		: Integer;
	listPointer		: Integer;
	allChildNodes	: CnEcTreeNodeArray;
	childNodeObj	: CnEcTreeNode;
	
begin
	entryCount	:=	self.listCount();
	
	if listCount = 0 then
		return;
	endif;
	
	if self.hasPlusMinus or self.hasTreeLines then
		create allChildNodes transient;
		listPointer	:=	1;
		
		while listPointer &lt;= entryCount do
			pTargetListObj.addItem(itemText[listPointer]);
			pTargetListObj.itemObject[pTargetListObj.newIndex]	:=	self.itemObject[listPointer];
			
			if self.itemHasSubItems(listPointer) then
				self.cnEcGetChildNodes(listPointer, allChildNodes);
				
				foreach childNodeObj in allChildNodes do
					listPointer	:=	childNodeObj.addToList(	pTargetListObj.listCount() + 1,
															pTargetListObj);
				endforeach;
				
				allChildNodes.purge();
			endif;
			
			listPointer	:=	listPointer + 1;
		endwhile;
	else
		foreach listPointer in 1 to entryCount do
			pTargetListObj.addItem(itemText[listPointer]);
			pTargetListObj.itemObject[pTargetListObj.newIndex]	:=	self.itemObject[listPointer];
		endforeach;
	endif;
	
	self.clear();
epilog
	delete allChildNodes;
end;</source>
        <Parameter name="pTargetListObj" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cnEcMoveAllTreesByName" id="c0ffd62d-c83a-4d19-9867-475944e3bf7b">
        <updating/>
        <source>cnEcMoveAllTreesByName(pTargetListObj:ListBox input) updating;
// --------------------------------------------------------------------------------
// Created:		26 July 2000 by cnwdad1
//
// Purpose:		Moves all items from the receiver listbox into the listbox
//				specified as the input parameter, using the tree names.
//
// Parameters:	pTargetListObj - The control to which the items will be moved.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listPointer	: Integer;

begin
	listPointer			:=	listCount;

	while self.listCount &gt; 0 do
		self.itemSelected[1]	:=	true;
		self.cnEcMoveTreeByName(pTargetListObj);
	endwhile;
end;</source>
        <Parameter name="pTargetListObj" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cnEcMoveSelected" id="627c3bee-33a2-43b4-8a3d-4c6d98b6b97e">
        <updating/>
        <source>cnEcMoveSelected(pTargetListObj:ListBox input) updating;
// --------------------------------------------------------------------------------
// Created:		26 July 2000 by cnwdad1
//
// Purpose:		Moves all selected items from the current listbox into the listbox
//				specified as the input parameter.
//
// Parameters:	pTargetListObj - The control to which the selected items will be moved.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 19/11/2005	cnwdad1		Added support for an hierarchical item list.  Mid-tier
//							items will go to item-level 1 in the target listbox
//							control. Use the cnEcMoveSelectedToSelected method to
//							move an item to a deeper level item in the target
//							listbox control.
// --------------------------------------------------------------------------------
vars
	entryCount		: Integer;
	listPointer		: Integer;
	parentNodeObj	: CnEcTreeNode;

begin
	entryCount	:=	self.listCount();
	
	if self.hasPlusMinus or self.hasTreeLines then
		listPointer	:=	1;
		
		while listPointer &lt;= entryCount do
			if itemSelected[listPointer] then
				if not self.cnEcGetNodeWithChildren(listPointer, parentNodeObj) then
					return;
				endif;
				
				if parentNodeObj.itemLevel &gt; 1 then
					parentNodeObj.adjustItemLevel((parentNodeObj.itemLevel * -1) + 1);
				endif;
				
				parentNodeObj.addToList((pTargetListObj.listCount() + 1), pTargetListObj);
				self.cnEcRemoveSubItems(listPointer, false);
				self.removeItem(listPointer);
				
				entryCount	:=	self.listCount();
			else
				listPointer	:=	listPointer + 1;
			endif;
		endwhile;
	else	
		//cnwrd1 this was broke, copying, removing the item then incrementing the counter skiped items 7.8.09
		
		// so now copy the selected
		listPointer	:=	1;
		
		while listPointer &lt;= entryCount do
			if itemSelected[listPointer] then
				pTargetListObj.itemObject[pTargetListObj.addItem(itemText[listPointer])]	:=	itemObject[listPointer];
				//removeItem(listPointer); // dont do this here
				entryCount	:=	self.listCount();
			endif;
			
			listPointer	:=	listPointer + 1;
			
			if listPointer &gt; entryCount then
				break;
			endif;
		endwhile;
		
		// then remove all the selected from self.
		listPointer	:=	1;		
		while listPointer &lt;= entryCount do
			if itemSelected[listPointer] then				
				removeItem(listPointer);
				entryCount	:=	self.listCount();
			else
				listPointer	:=	listPointer + 1;
			endif;
		
			if listPointer &gt; entryCount then
				break;
			endif;
		endwhile;
		
		
	endif;
epilog
	delete parentNodeObj;
end;</source>
        <Parameter name="pTargetListObj" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cnEcMoveSelectedToSelected" id="52b37960-0a4c-40bd-bbf6-7462da6d05ec">
        <updating/>
        <source>cnEcMoveSelectedToSelected(pTargetListObj:ListBox input):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		16 November 2004 by cnwdad1
//
// Purpose:		Moves all selected items from the current listbox to the currently
//				selected index in the specified listbox parameter.
//
//				Note: The target listbox control must be configured for an hierarcical
//				style list.
//
// Parameters:	pTargetListObj - The control to which the selected items will be moved.
//
// Returns:		True if the move was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listPointer		: Integer;
	parentNodeObj	: CnEcTreeNode;
	targetIndex		: Integer;
	targetLevel		: Integer;

begin
	targetIndex	:=	pTargetListObj.listIndex;
	
	if targetIndex = CNEC_NULL_INDEX then
		return false;
	endif;
	
	if self.hasPlusMinus or self.hasTreeLines then
		listPointer	:=	self.listIndex;
		targetLevel	:=	pTargetListObj.itemLevel[targetIndex];
		
		if not self.cnEcGetNodeWithChildren(listPointer, parentNodeObj) then
			return false;
		endif;
		
//		if parentNodeObj.itemLevel &gt; targetLevel then
			parentNodeObj.adjustItemLevel(targetLevel - parentNodeObj.itemLevel + 1);
//		else
//			parentNodeObj.adjustItemLevel(parentNodeObj.itemLevel - targetLevel);
//		endif;
		
		parentNodeObj.addToList((pTargetListObj.listIndex + 1), pTargetListObj);
		self.cnEcRemoveSubItems(listPointer, false);
		self.removeItem(listPointer);
		
		delete parentNodeObj;
	else
		return false;
	endif;
	
	return true;
epilog
	delete parentNodeObj;
end;</source>
        <Parameter name="pTargetListObj" type="ListBox" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcMoveTree" id="3d8d8af4-9415-4622-a727-9f07b94607c0">
        <source>cnEcMoveTree(pTargetListObj:ListBox);
// --------------------------------------------------------------------------------
// Created:		26 July 2000 by cnwdad1
//
// Purpose:		Moves all selected tree items from current listbox into listbox
//				specified as input parameter
//
// Features:	- Handles multiselect list boxes
//				- Selecting a 'parent' item is equivalent to selecting all of the 'children' items
//
// Limitations:	- Handles only basic (two level deep) list tree
//				- Requires that itemObject pseudo array is populated
//				- Cannot handle duplicate item object references in a single list
//
// Parameters:	pTargetListObj - The target listbox control.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	targetListObj	: ListBox;
	entryIndex		: Integer;
	subEntryIndex	: Integer;
	targetIndex		: Integer;
	parentIndex		: Integer;

begin
	targetListObj	:=	pTargetListObj;
	entryIndex		:=	self.listCount;

	while entryIndex &gt;= 1 and entryIndex &lt;= self.listCount do
		if self.itemSelected[entryIndex] then
			if self.itemHasSubItems(entryIndex) then
				subEntryIndex := entryIndex + 1;

				while subEntryIndex &lt;= self.listCount and self.itemLevel[subEntryIndex] &gt; self.itemLevel[entryIndex] do
					targetIndex	:=	targetListObj.findObject(self.itemObject[entryIndex]) + 1;

					if targetIndex = 0 then
						targetListObj.itemObject[targetListObj.addItem(self.itemText[entryIndex])] := self.itemObject[entryIndex];
						targetIndex	:=	targetListObj.newIndex + 1;
					endif;

					while targetIndex &lt;= targetListObj.listCount do
						if targetListObj.itemLevel[targetIndex] = 1 then
							break;
						endif;
						targetIndex	:=	targetIndex + 1;
					endwhile;

					if targetIndex &lt;= targetListObj.listCount then
						targetListObj.addItemAt(self.itemText[subEntryIndex], targetIndex);
					else
						targetListObj.addItem(self.itemText[subEntryIndex]);
					endif;

					targetListObj.itemObject[targetListObj.newIndex] := self.itemObject[subEntryIndex];
					targetListObj.itemLevel[targetListObj.newIndex] := 2;
					subEntryIndex	:=	subEntryIndex + 1;
				endwhile;

                subEntryIndex := subEntryIndex - 1;

                while subEntryIndex &gt;= entryIndex do
					self.removeItem(subEntryIndex);
					subEntryIndex	:=	subEntryIndex - 1;
				endwhile;
			else
				parentIndex	:=	self.cnEcFindParent(entryIndex);
				targetIndex	:=	targetListObj.findObject(self.itemObject[parentIndex]) + 1;

				if targetIndex = 0 then
					targetListObj.itemObject[targetListObj.addItem(self.itemText[parentIndex])] := self.itemObject[parentIndex];
					targetIndex	:=	targetListObj.newIndex + 1;
				endif;

				while targetIndex &lt;= targetListObj.listCount do
					if targetListObj.itemLevel[targetIndex] = 1 then
						break;
					endif;
					targetIndex	:=	targetIndex + 1;
				endwhile;

				if targetIndex &lt;= targetListObj.listCount then
					targetListObj.addItemAt(self.itemText[entryIndex], targetIndex);
				else
					targetListObj.addItem(self.itemText[entryIndex]);
				endif;

				targetListObj.itemObject[targetListObj.newIndex] := self.itemObject[entryIndex];
				targetListObj.itemLevel[targetListObj.newIndex] := 2;
				self.removeItem(entryIndex);

				if not self.itemHasSubItems(parentIndex) then
					self.removeItem(parentIndex);
				endif;
			endif;
		endif;

		entryIndex	:=	entryIndex - 1;
	endwhile;
end;</source>
        <Parameter name="pTargetListObj" type="ListBox"/>
    </JadeMethod>
    <JadeMethod name="cnEcMoveTreeByName" id="6f2885e4-dd33-4a30-97e1-d5e7de3c1bd6">
        <updating/>
        <source>cnEcMoveTreeByName(pTargetListObj:ListBox) updating;
// --------------------------------------------------------------------------------
// Created:		25 January 2001 by cnwdad2
//
// Purpose:		Moves all selected tree items from the receiver listbox into 2nd
//				listbox.  Uses branch and leaf pictures!
//
// Features:	- Handles multiselect list boxes
//				- Selecting a 'parent' item is equivalent to selecting all of the 'children' items
//				- only moves a category when all its subitems can be updated
//
// Limitations:	- Handles only basic (two level deep) list tree
//				- Requires that itemObject pseudo array is populated
//				- Cannot handle duplicate item object references in a single list 
//
// Parameters:	pTargetListObj
//
// Returns:		The index of the newly created branch.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fromListSize		: Integer;
	subItemPointer		: Integer;
	foundItemPointer	: Integer;
	parentItemPointer	: Integer;
	insertPointer		: Integer;

begin
	fromListSize	:=	self.listCount;
	
	while (fromListSize &gt;= 1 and fromListSize &lt;= self.listCount) do
		if self.itemSelected[fromListSize] then
			if self.itemHasSubItems(fromListSize)then
			  	subItemPointer	:=	fromListSize + 1;
			  	
				while subItemPointer &lt;= self.listCount and self.itemLevel[subItemPointer] &gt; self.itemLevel[fromListSize] do
//					foundItemPointer	:=	pTargetListObj.findObject(self.itemObject[fromListSize]);
					foundItemPointer	:=	pTargetListObj.findStringExact(1, self.itemText[fromListSize]);
					
					if foundItemPointer = CNEC_NULL_INDEX then
                        insertPointer		:=	pTargetListObj.cnEcFindWhere(self.itemText[fromListSize], 0);  // where should it go?
               			pTargetListObj.cnEcAddBranch(self.itemText[fromListSize], insertPointer);     		    // was null
						pTargetListObj.itemObject[pTargetListObj.newIndex]	:=	self.itemObject[fromListSize];
						foundItemPointer	:=	pTargetListObj.newIndex;
					endif;

					if foundItemPointer &lt;= pTargetListObj.listCount then
						insertPointer	:=	pTargetListObj.cnEcFindWhere(self.itemText[subItemPointer], foundItemPointer);
						pTargetListObj.cnEcAddLeaf(self.itemText[subItemPointer], insertPointer);    // was intInd
					else
						insertPointer	:=	pTargetListObj.cnEcFindWhere(self.itemText[subItemPointer], pTargetListObj.listCount);
						pTargetListObj.cnEcAddLeaf(self.itemText[subItemPointer], insertPointer);    // was null
					endif;
					
					pTargetListObj.itemObject[pTargetListObj.newIndex]	:=	self.itemObject[subItemPointer];
					pTargetListObj.itemLevel[pTargetListObj.newIndex]		:=	2;
					pTargetListObj.itemText[pTargetListObj.newIndex]		:=	pTargetListObj.itemText[pTargetListObj.newIndex].cnEcStripAtEnd("Read Only");
					subItemPointer									:=	subItemPointer + 1;
				endwhile;
				
                subItemPointer := subItemPointer - 1;
                
                while subItemPointer &gt;= fromListSize do
                	self.removeItem(subItemPointer);
					subItemPointer := subItemPointer - 1;
				endwhile;
		   	else
				parentItemPointer	:=	self.cnEcFindParent(fromListSize);
//				foundItemPointer	:=	pTargetListObj.findObject(self.itemObject[parentItemPointer]);
				foundItemPointer	:=	pTargetListObj.findStringExact(1, self.itemText[parentItemPointer]);
				
				if foundItemPointer = CNEC_NULL_INDEX then
					insertPointer		:=	pTargetListObj.cnEcFindWhere(self.itemText[parentItemPointer], 0);
					pTargetListObj.cnEcAddBranch(self.itemText[parentItemPointer], insertPointer);         // was null
					pTargetListObj.itemObject[pTargetListObj.newIndex]	:=	self.itemObject[parentItemPointer];
					foundItemPointer	:=	pTargetListObj.newIndex;
				endif;

				if foundItemPointer &lt;= pTargetListObj.listCount then
					insertPointer	:=	pTargetListObj.cnEcFindWhere(self.itemText[fromListSize], foundItemPointer);
					pTargetListObj.cnEcAddLeaf(self.itemText[fromListSize], insertPointer);  // was intInd
				else
					insertPointer	:=	pTargetListObj.cnEcFindWhere(self.itemText[fromListSize], pTargetListObj.listCount);
					pTargetListObj.cnEcAddLeaf(self.itemText[fromListSize], insertPointer);   // was null
				endif;
				
				pTargetListObj.itemObject[pTargetListObj.newIndex]	:=	self.itemObject[fromListSize];
				pTargetListObj.itemLevel[pTargetListObj.newIndex]		:=	2;
				pTargetListObj.itemText[pTargetListObj.newIndex]		:=	pTargetListObj.itemText[pTargetListObj.newIndex].cnEcStripAtEnd("Read Only");
				self.removeItem(fromListSize);
				
				if (not self.itemHasSubItems(parentItemPointer)) then
					self.removeItem(parentItemPointer);
					fromListSize	:=	fromListSize - 1;       /// XPOSE 1454 allow for removing parent
				endif;
			endif;
		endif;
		
		fromListSize	:=	fromListSize - 1;
	endwhile;
end;</source>
        <Parameter name="pTargetListObj" type="ListBox"/>
    </JadeMethod>
    <JadeMethod name="cnEcMoveTreeInSelf" id="aa940b70-37ff-400a-a3f2-e53de05dbfe3">
        <source>cnEcMoveTreeInSelf(pIndexFrom:Integer; pIndexTo:Integer; _changeLevel : Boolean; _toLevel : Integer);
// --------------------------------------------------------------------------------
// Created:		26 October 2005 by cnwdad1
//
// Purpose:		Moves an hierarchical structure from one index to another within
//				the receiver.
//
// Parameters:	pIndexFrom - The index to move the tree from.
//				pIndexTo - The index to move the tree To.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	startingEntry	: Integer;
	fromIndex	 	: Integer;
	toIndex			: Integer;
	toLevel			: Integer;
	fromLevel		: Integer;
	startingLevel	: Integer;
	isAddingPrior	: Boolean;
	itemsMoved 		: Integer;
	moveCount		: Integer;
	originalCount	: Integer;
	
begin
	startingEntry	:=	pIndexFrom;
	startingLevel   :=	self.itemLevel[startingEntry];
	fromIndex 		:=	startingEntry;
	fromLevel		:=	self.itemLevel[fromIndex];
	toIndex			:=	pIndexTo;
	originalCount 	:=	self.listCount();
	
	if _changeLevel then
		toLevel			:=	self.itemLevel[pIndexTo] + 1;
	else
		toLevel			:=	_toLevel;

	endif;
	// We also need to determine if we are adding prior to the point we are taking from.
	// If so the  we have to allow for this as we move the items.

	if toIndex &lt; startingEntry then
		isAddingPrior	:=	true;
	endif;

    while (fromIndex &lt;= self.listCount())
    and ((fromIndex = startingEntry)
    or (self.itemLevel[fromIndex] &gt; startingLevel))
    do
	  	toIndex		:=	toIndex + 1;
	  	itemsMoved	:=	itemsMoved - 1;

		self.addItemAt(itemText[fromIndex], toIndex);

		// This additem may now have mucked up the position of the from item.

		if isAddingPrior then 
			startingEntry	:=	startingEntry + 1;
			fromIndex		:=	fromIndex + 1;
		endif; 

		self.itemObject[toIndex]	:=	self.itemObject[fromIndex];
		self.itemPicture[toIndex]	:=	self.itemPicture[fromIndex];
		self.itemData[toIndex]	:=	self.itemData[fromIndex]; // PAR 34655
		self.itemLevel[toIndex]		:=	(toLevel + (self.itemLevel[fromIndex] - fromLevel));

		// Expand these entries as we go along.

		self.itemExpanded[toIndex]	:=	true;

		// If the items that we are moving are below the point that we are adding them then we
		// are screwing up our 'starting entry value' - so we correct that now.

		fromIndex	:=	fromIndex + 1;
	endwhile;

	// Before we delete the items, change the selected value.

	self.itemSelected[startingEntry]	:=	false;
	self.itemSelected[pIndexTo]			:=	true;


end;</source>
        <Parameter name="pIndexFrom" type="Integer"/>
        <Parameter name="pIndexTo" type="Integer"/>
        <Parameter name="_changeLevel" type="Boolean"/>
        <Parameter name="_toLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcOpenDownTo" id="c4c9d0f1-8dba-4339-9dfb-2ffe8b063efb">
        <source>cnEcOpenDownTo(pListIndex:Integer);
// --------------------------------------------------------------------------------
// Created:		24 November 2001 by cnwdad1
//
// Purpose:		Opens the receiver's tree nodes to reveal the node at the specified
//				item index.
//
// Parameters:	pListIndex - The index of the list item to reveal.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listboxObj	: ListBox;
	parentIndex	: Integer;
	openedIndex	: Integer;
	
begin
	listboxObj	:=	self;
	openedIndex	:=	pListIndex;
	
	while true do
		parentIndex	:=	listboxObj.cnEcFindParent(openedIndex);
		
		if parentIndex = 0 then
			break;
		else
			listboxObj.itemExpanded[parentIndex]	:=	true;
			openedIndex	:=	parentIndex;
		endif;
	endwhile;
end;</source>
        <Parameter name="pListIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcOpenFirstNode" id="2dabffe7-7ea3-4bfd-a389-57f317c1f150">
        <source>cnEcOpenFirstNode():Boolean;
// --------------------------------------------------------------------------------
// Created:		17 June 2006 by cnwdad1
//
// Purpose:		If the first node of the tree has any children, then open it.
//
// Parameters:	None
//
// Returns:		True if the first node was successfully opened, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.listCount() &gt; 0
	and self.itemHasSubItems(1)
	and not self.itemExpanded[1]
	then
		self.itemExpanded[1]	:=	true;
		return true;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcRemoveObject" id="140721fb-b835-4cc9-b72a-dc688b61ac91">
        <source>cnEcRemoveObject(pObject:Object):Boolean;
// --------------------------------------------------------------------------------
// Created:		05 April 2005 by cnwdad1
//
// Purpose:		Removes the item entry for the specified object.
//
// Parameters:	pObject - A reference to the object who's entry to remove.
//
// Returns:		True if the remove was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	
begin
	rowPointer	:=	self.findObject(pObject);
	
	if rowPointer &lt;&gt; CNEC_NULL_INDEX then
		self.removeItem(rowPointer);
		return true;
	else
		return false;
	endif;
end;</source>
        <Parameter name="pObject" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcRemoveSelected" id="5422e4eb-5269-4b1b-8408-a0109778fd26">
        <source>cnEcRemoveSelected(pIsAllSelected:Boolean):Boolean;
// --------------------------------------------------------------------------------
// Created:		05 April 2005 by cnwdad1
//
// Purpose:		Removes the currently selected item entry from the receiver.
//
// Parameters:	pIsAllSelected - True if all selected entries should be removed,
//					otherwise false.  If false, only the last selected entry will
//					be removed.
//
// Returns:		True if the remove was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	rowCount	: Integer;
	
begin
	if pIsAllSelected then
		rowCount	:=	self.listCount;
		
		foreach rowPointer in 1 to rowCount do
			if self.itemSelected[rowPointer] then
				self.removeItem(rowPointer);
			endif;
		endforeach;
	else
		rowPointer	:=	self.listIndex;
		
		if rowPointer = CNEC_NULL_INDEX then
			return false;
		endif;
		
		self.removeItem(rowPointer);
	endif;
	
	return false;
end;</source>
        <Parameter name="pIsAllSelected" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcRemoveSubItems" id="6aeedb03-7ce5-4a0a-b02a-e057c60c995c">
        <source>cnEcRemoveSubItems(pParentIndex:Integer; pIsDeleteItemObjects:Boolean);
// --------------------------------------------------------------------------------
// Created:		19 August 2000 by cnwdad1
//
// Purpose:		Removes all subitems from a tree hierarchy in the listbox.
//
// Parameters:	pParentIndex (Integer) - The index of the parent item whose subitems
//					are to be removed.
//				pIsDeleteItemObjects (Boolean) - A flag used to indicate whether
//					any objects of the "itemObject" property of child list entries
//					are to be deleted when the child item entry is removed.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	parentIndex	: Integer;
	parentLevel	: Integer;
	entryCount	: Integer;
	childLevel	: Integer;
	childIndex	: Integer;
	theObject	: Object;
	
begin
	parentIndex	:=	pParentIndex;
	entryCount	:=	self.listCount;
	parentLevel	:=	self.itemLevel[parentIndex];
	
	if parentIndex &lt; entryCount then	// If parent is last, it mustn't have any children.
		childIndex	:=	parentIndex + 1;
		
		// Must use "listCount" here because the size of the list
		// items will be changing as list entries are removed.
		
		while childIndex &lt;= self.listCount do
			childLevel	:=	self.itemLevel[childIndex];
			
			if childLevel &lt;= parentLevel then
				break;
			endif;
			
			if pIsDeleteItemObjects then
				theObject	:=	self.itemObject[childIndex];
				
				if theObject &lt;&gt; null then
					delete theObject;
				endif;
			endif;
			
			self.removeItem(childIndex);
		endwhile;
	endif;
end;</source>
        <Parameter name="pParentIndex" type="Integer"/>
        <Parameter name="pIsDeleteItemObjects" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcScrollMe" id="500249f8-6fa9-4104-9e27-09988cffe2fc">
        <updating/>
        <source>cnEcScrollMe(pIsDown:Boolean; pIsPage:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		19 May 2006 by cnwdad1
//
// Purpose:		Scrolls the receiver.
//
// Parameters:	pIsDown - True if the receiver is to scroll down, otherwise it will
//					scroll up.
//				pIsPage - True if the receiver is to scroll one whole page, otherwise
//					the receiver will scroll just one row.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	scrollSize	: Integer;
	newTopPos	: Integer;
	
begin
	if pIsPage then
		scrollSize	:=	self.lines();
	else
		scrollSize	:=	1;
	endif;
	
	if pIsDown then
		newTopPos	:=	self.topIndex + scrollSize;
		
		if newTopPos &gt; self.listCount() then
			newTopPos	:=	self.listCount() - self.lines();
		endif;
	else
		newTopPos	:=	self.topIndex - scrollSize;
		
		if newTopPos &lt; 1 then
			newTopPos	:=	1;
		endif;
	endif;
	
	self.topIndex	:=	newTopPos;
end;</source>
        <Parameter name="pIsDown" type="Boolean"/>
        <Parameter name="pIsPage" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcSet" id="182a696c-7c07-4d13-9434-a33a81298824">
        <updating/>
        <source>cnEcSet(pValue:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		13 August 2002 by cnwdad1
//
// Purpose:		Updates the receiver's listIndex with the specified value.
//
// Parameters:	pValue - The string value to set the text to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.listIndex &lt;&gt; pValue then
		self.listIndex	:=	pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetItemData" id="253244c0-f25e-4dbc-b090-f9c76ac83abc">
        <updating/>
        <source>cnEcSetItemData(pItemData:Integer):Integer updating;
// --------------------------------------------------------------------------------
// Created:		22 March 2005 by cnwdad1
//
// Purpose:		Sets the receiver's listIndex for the first entry which matches the
//				specified itemData value.
//
// Parameters:	pItemData - The itemData value to match.
//
// Returns:		The index of the new list item, or CNEC_NULL_INDEX if none of the
//				item datas matched the parameter value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listPointer	: Integer;
	itemCount	: Integer;
	
begin
	itemCount	:=	self.listCount();
	
	foreach listPointer in 1 to itemCount do
		if self.itemData[listPointer] = pItemData then
			self.listIndex	:=	listPointer;
			return listPointer;
		endif;
	endforeach;
	
	return CNEC_NULL_INDEX;
end;</source>
        <Parameter name="pItemData" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetObjectIndex" id="a6602574-e2c7-4882-bacd-902ebe5a2e56">
        <updating/>
        <source>cnEcSetObjectIndex(pObject:Object) updating;
// --------------------------------------------------------------------------------
// Created:		25 January 2001 by cnwdad2
//
// Purpose:		Sets the list index of the receiver to the index that contains the
//				specified object.
//
// Parameters:	pObject
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.listIndex	:=	self.findObject(pObject);
end;</source>
        <Parameter name="pObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetObjectSelected" id="0d6e2c4a-23fd-4dd5-940c-a38a869c60ee">
        <source>cnEcSetObjectSelected(pObject:Object);
// --------------------------------------------------------------------------------
// Created:		02 October 2003 by cnwdad1
//
// Purpose:		Sets the selected item of the receiver at the index that contains the
//				specified object.
//
// Parameters:	pObject - A reference to the object who's index to select.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	
begin
	rowPointer	:=	self.findObject(pObject);
	
	if rowPointer &lt;&gt; CNEC_NULL_INDEX then
		self.itemSelected[rowPointer]	:=	true;
	endif;
end;</source>
        <Parameter name="pObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetTextIndex" id="b7c6f130-c878-45e0-b1bd-9a46beea53f8">
        <updating/>
        <source>cnEcSetTextIndex(pTextValue:String) updating;
// --------------------------------------------------------------------------------
// Created:		25 January 2001 by cnwdad2
//
// Purpose:		Sets the list index of the receiver to the index that contains the
//				specified text.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.listIndex	:=	self.findStringExact(1, pTextValue);
end;</source>
        <Parameter name="pTextValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcSortBranch" id="fab0ac13-abeb-42b6-9ef6-486a51491bd1">
        <updating/>
        <source>cnEcSortBranch(pParentIndex:Integer; pIsDescending:Boolean):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		26 October 2005 by cnwdad1
//
// Purpose:		Alphabetically sorts the child nodes of the specified parent node.
//
// Parameters:	pParentIndex - The index of the parent node.
//				pIsDescending - If true, the items will be sorted in descending order.
//
// Returns:		True if the sort succeeded, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	sorterObj			: CnEcSorter;
	keyObj				: Object;
	listPointer			: Integer;
	isExpanded			: Boolean;
	associatedObj		: Object;
	keyValue			: String;
	allChildNodes		: CnEcTreeNodeArray;
	childNodeObj		: CnEcTreeNode;
		
begin
	// Do preliminary checks.
	
	if pParentIndex &lt; 1 or pParentIndex &gt; self.listCount() then
		return false;
	endif;
	
	if not self.itemHasSubItems(pParentIndex) then
		return true;
	endif;
	
	// Fetch the child list item nodes to be sorted.
	
	isExpanded	:=	self.itemExpanded[pParentIndex];
	
	create allChildNodes transient;
	
	if not self.cnEcGetChildNodes(pParentIndex, allChildNodes) then
		return false;
	endif;
	
	// Sort the list items.
	
	create sorterObj transient;
	sorterObj.setSortType(CnEcSorter.AS_STRING, pIsDescending);
	
	// Load the entries to sort, removing the list items as we go.
	// We do this in reverse order to preserve list indexes as we
	// remove each child node.
	
	foreach childNodeObj in allChildNodes reversed do
		sorterObj.addKeyWithObject(	childNodeObj.itemText, childNodeObj);
		
		if childNodeObj.hasChildNodes() then
			self.cnEcRemoveSubItems(childNodeObj.listIndex, false);
		endif;
		
		self.removeItem(childNodeObj.listIndex);
	endforeach;
	
	// Now reload the entries in sorted order.
	
	listPointer	:=	pParentIndex + 1;
	
	foreach keyObj in sorterObj.allKeys reversed do
		keyValue		:=	keyObj.CnEcSortKey.getKeyWithObject(associatedObj).String;
		childNodeObj	:=	associatedObj.CnEcTreeNode;
		
		if childNodeObj.addToList(listPointer, self) = 0 then
			return false;
		endif;
	endforeach;
	
	if isExpanded then
		self.itemExpanded[pParentIndex]	:=	true;
	endif;
	
	return true;
epilog
	delete sorterObj;
	delete allChildNodes;
end;</source>
        <Parameter name="pParentIndex" type="Integer"/>
        <Parameter name="pIsDescending" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
