    <JadeMethod name="setForUpdate" id="b8997041-3c22-4d4d-9545-d768ef54608e">
        <updating/>
        <source>setForUpdate( _proxy : CM_WeighBridgeObj ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 March 2014	cnwndl1	Initial creation	Par 33268
//22/01//17 cnwns1 TFS3153:PKT - Bulk Process - WeighBridge Integration
*/

vars
	gateALaneController : CM_GateAreaLaneController;
	needsRefresh		: Boolean;
	
begin

	self.name 				:= _proxy.name;
	self.ipAddress 			:= _proxy.ipAddress;
	self.portNumber 		:= _proxy.portNumber;
	self.timeOutSeconds		:= _proxy.timeOutSeconds;
	self.autoRequest 		:= _proxy.autoRequest;
	self.myWeighBridgeType	:= _proxy.myWeighBridgeType;
	self.myTerminal   		:= _proxy.myTerminal;
	self.computerName 		:= _proxy.computerName;//TFS3153

	gateALaneController := _proxy.myGateLane;
	self.setGateLane(gateALaneController);

	//	self.myGateLane   := _proxy.myGateLane;	 //TFS3153
	
	self.myWeightType 		:= _proxy.myWeightType;//TFS3153
	self.deviceAddress 		:= _proxy.deviceAddress;	//25 May 2017	NDL	TFS 4383
	
	self.updateCargoMode	:= _proxy.updateCargoMode;	//05 Jul 2019	NDL	TFS 44965
	
	self.canUpdateRTS 		:= _proxy.canUpdateRTS;	//11 May 2020	NDL	TFS 49296
	
	// ### TFS 52773 1APR2022 NAVPW1
	if self.deviceId &lt;&gt; _proxy.deviceId then
		self.deviceId	:= _proxy.deviceId;
		needsRefresh	:= true;
	endif;
	
	if needsRefresh then
		if app.myAlternateDict &lt;&gt; null then
			app.myAlternateDict.setGnrcIfaceDvcDictNeedRefresh();
		endif;
	endif;
	// ### TFS 52773 1APR2022 NAVPW1
	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_WeighBridgeObj"/>
    </JadeMethod>
    <JadeMethod name="setGateLane" id="a0582606-3ad4-496e-972f-f4908a76405e">
        <updating/>
        <source>setGateLane(_gateALaneController : CM_GateAreaLaneController input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2017	cnwns1	Initial creation
27 May 2022	navpw1	Cleaned up method

*/

vars
	gate 			: CM_Gate;
	objectSet 		: CM_ObjectSetActual;
	gateLaneCont 	: CM_GateAreaLaneController;
	allGates 		: CM_GateNameDict; // ### TFS 52773 30May2022 NAVPW1
	
begin
	create objectSet transient;
	
	if self.myTerminal = null then // ### TFS 52773 30May2022 NAVPW1 - In case a Logical Certify unit test gets in here with a null terminal
		return;
	endif;
	
	allGates := self.myTerminal.allGates;
	
	foreach gate in allGates do
		gate.getAllGALaneControllers(objectSet, Both);
		
		foreach gateLaneCont in objectSet as CM_GateAreaLaneController do
			if gateLaneCont.getWeighBridge = self then
				gateLaneCont.setWeighbridgeSerial(null);
				
			endif;
			
		endforeach;
		
	endforeach;
	
	delete objectSet;

	//set to Value
	if _gateALaneController &lt;&gt; null then
		_gateALaneController.setWeighbridgeSerial(self);
		
	endif;
	
	self.myGateLane   := _gateALaneController;
	
epilog
	if objectSet &lt;&gt; null then
		delete objectSet;
	endif;
	
end;</source>
        <Parameter name="_gateALaneController" type="CM_GateAreaLaneController" usage="input"/>
    </JadeMethod>
