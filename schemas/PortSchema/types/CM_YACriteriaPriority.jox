    <JadeMethod name="setForCreate" id="6dc5d4fb-35ed-4579-88ae-bc239f1eed96">
        <updating/>
        <source>setForCreate(pProxyObj: SelfType) updating;
// --------------------------------------------------------------------------------
// Created:		23 March 2005 by cnwdad1
//
// Purpose:		Standard set method when creating an instance of the receiver.
//
// Parameters:	pProxyObj - A reference to a proxy of the receiver.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.setForUpdate(pProxyObj);
end;</source>
        <Parameter name="pProxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="32fd0cee-ff9b-4e41-85eb-d369195833ad">
        <updating/>
        <source>setForUpdate(pProxyObj: SelfType) updating;
// --------------------------------------------------------------------------------
// Created:		23 March 2005 by cnwdad1
//
// Purpose:		Standard set method when updating the receiver.
//
// Parameters:	pProxyObj - A reference to a proxy of the receiver.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	oldDataObj	: CM_YAData;
	
begin
	// Set any attribute values.
	
	self.code				:=	pProxyObj.code;
	
	// Set any key attribute values.
	
	self.priorityValue		:=	pProxyObj.priorityValue;
	
	// Set any inverse references.
	
	if self.myYAData &lt;&gt; null then
		oldDataObj	:=	self.myYAData;
	endif;
	
	self.myYACriteriaType	:=	pProxyObj.myYACriteriaType;
	self.myYAData			:=	self.createDataValue(	pProxyObj.myYACriteriaType,
														pProxyObj.myYAData.getDataValue()
													);
	
	// Finally, we need to discard the old YA Data value object, so that we don't leave
	// any orphaned objects behind.
	
	delete oldDataObj;
end;</source>
        <Parameter name="pProxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setPriorityValue" id="8778e678-2a83-4553-b1ce-f034c17af236">
        <updating/>
        <source>setPriorityValue(pPriorityValue: Real) updating;
// --------------------------------------------------------------------------------
// Created:		23 March 2005 by cnwdad1
//
// Purpose:		Sets the receiver's priority value.
//
// Parameters:	pPriorityValue - The receiver's priority.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 30 May 2017	cnwkpd1		TFS #4542 - Invoicing performance changes
// --------------------------------------------------------------------------------
begin
	if self.priorityValue &lt;&gt; pPriorityValue then
		self.priorityValue	:=	pPriorityValue;
	endif;
end;</source>
        <Parameter name="pPriorityValue" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="ac3e1566-6cb0-4a56-affa-7913b21f4b9c">
        <updating/>
        <source>setProxy(pCriteriaTypeObj:CM_YACriteriaType; pDataValue:Any; pCode:String) updating;
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1:2
//
// Purpose:		Initializes the receiver by setting up its data value(s).
//
// Parameters:	pCriteriaTypeObj - A reference to the Criteria Type object.
//				pDataValue - A primitive value, used where object data values
//					are not used, or a set of object data values.
//				pCode - A Criteria Code - generally a short version of the Criteria
//					Attribute name.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dataValueObj	: CM_YAData;
	
begin
	self.raiseExceptionIfNotTransient(method);
	
	delete self.myYAData;
	
	self.myYACriteriaType	:=	pCriteriaTypeObj;
	dataValueObj	:=	self.createDataValue(pCriteriaTypeObj, pDataValue);
	dataValueObj.setYAParent(self);
	
	
//	self.priorityValue		:=	self.myYACriteriaType.getYAPriorityValueForCriteria(self, app.getMyTerminal());
	self.code				:=	pCode;
	
end;</source>
        <Parameter name="pCriteriaTypeObj" type="CM_YACriteriaType"/>
        <Parameter name="pDataValue" type="Any"/>
        <Parameter name="pCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="stripThousandsSeparators" id="1e3afc96-75a1-41a7-9e96-7054d2f55fb2">
        <source>stripThousandsSeparators(_sourceString : String io) protected;
//
// Purpose:			Remove the system thousands separator from a weight flexi string
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/08/2024	navdap1		Initial creation TFS 65510 PEN - Weight Flexi field no longer allows use of decimals
// 21/01/2025	navbs1		Bug MTN-33645: MTN - (Minor) Weight Flexi (kg) in Yard Allocation not save correctly in some circumstances
// 20/09/2025	navbs1		Bug MTN-36099: TPT | Error (1300). Array index out of bounds
vars
	sourceLength, charPos, sepPos, rangePos, nextRangePos, sepCount : Integer;
	thousands, char : String;
	tempStr : String;
	ranges : StringArray;

begin
	if _sourceString = null then
		return;
	endif;
	if not self.myYACriteriaType.type = YACriteriaType_TotalWeight then			//20.09.2025 navbs1 #36099
		return;
	endif;
	
	_sourceString := _sourceString.trimBlanks;
	_sourceString := _sourceString.stripTrailingChar(Comma);
	sourceLength := _sourceString.length;
	
	thousands := app.getMyLocaleInfoJMT.numericInfo.thousandSeparator;
	
	if thousands = "." then
		_sourceString := _sourceString.cnRemoveChars(thousands);
	else
		if _sourceString.pos(thousands,1) = null then
			return;
		endif;
		
		create ranges transient;
		
		// Go through the supplied string looking hyphens
		charPos := 1;
		while charPos &lt;= sourceLength do
			char := _sourceString[charPos];
			if char = Hyphen then
				rangePos := charPos;
				
				// Found a hyphen - how many thousands separators are there before the next hyphen
				// 1 means we have 12300,23400- or similar
				// 2 means we have 12,300,23400- or 12300,23,400- or similar
				// 3 means we have 12,300,23,400- or similar
				nextRangePos := _sourceString.pos(Hyphen, rangePos+1);
				if nextRangePos = null then
					nextRangePos := _sourceString.length;
				endif;
				if nextRangePos = _sourceString.length then
					// we're the last "range" type entry - just remove the separators
					//_sourceString := _sourceString[1:rangePos-5] &amp; _sourceString[rangePos-4:end].cnRemoveChars(thousands);	//21.01.2025 navbs1 #33645
					_sourceString := _sourceString[1:rangePos] &amp; _sourceString[rangePos+1:end].cnRemoveChars(thousands);		//21.01.2025 navbs1 #33645
					break;
				else
					sepCount := _sourceString[rangePos:nextRangePos-rangePos].countOccurrences(thousands);
					if sepCount = 1 then
						//do nothing
					elseif sepCount = 3 then
						// remove the first and last thousands separators
						sepPos := _sourceString.pos(thousands, rangePos);
						_sourceString := _sourceString[1:sepPos-1] &amp; _sourceString[sepPos+1:end];
						sepPos := _sourceString.pos(thousands, rangePos);
						sepPos := _sourceString.pos(thousands, sepPos+1);
						_sourceString := _sourceString[1:sepPos-1] &amp; _sourceString[sepPos+1:end];
					else
						ranges.clear;
						tempStr := _sourceString[rangePos+1:nextRangePos-1-rangePos];
						tempStr.getTokensForDelimiter(Comma, ranges);
						if ranges[1].Integer &gt; ranges[2].Integer then
							// there is a non-separated number at the start
							tempStr := ranges[1] &amp; Comma &amp; ranges[2] &amp; ranges[3];
						else
							// there is a non-separated number at the end
							tempStr := ranges[1] &amp; ranges[2] &amp; Comma &amp; ranges[3];
						endif;
						_sourceString := _sourceString[1:rangePos] &amp; tempStr &amp; _sourceString[nextRangePos:end];
					endif;
				endif;
			endif;
			
			charPos := charPos + 1;
			sourceLength := _sourceString.length;
			
		endwhile;
		
		// Double check - sometimes there is a thousands separator left before the first range character
		sepPos := _sourceString.pos(thousands, 1);
		rangePos := _sourceString.pos(Hyphen, 1);
		if sepPos &gt; 0 and rangePos &gt; sepPos then
			_sourceString := _sourceString[1:sepPos-1] &amp; _sourceString[sepPos+1:end];
		endif;
	endif;
	
epilog
	delete ranges;
end;</source>
        <access>protected</access>
        <Parameter name="_sourceString" type="String" usage="io"/>
    </JadeMethod>
