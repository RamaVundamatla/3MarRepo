    <JadeMethod name="setMyDataClassForCargoType" id="a022932c-c6be-48e7-b540-4d4e43fe5183">
        <updating/>
        <source>setMyDataClassForCargoType(_typeId : Integer) updating;
//-----------------------------------------
//Created: March 2003 By: cnwgd1
//-----------------------------------------
vars
	theType	: CM_CargoBOLType;
	
begin
	theType := app.myRoot.getCargoBOLTypeForId(_typeId);	
	
	self.tblData.setTerminologyRelevant(theType, self.myTerminal);
	
	if theType &lt;&gt; null then
		if theType.isKindOf(CM_BOLType) then
			self.myDataClass := CM_BOL;
		else
			self.myDataClass := currentSchema.getClass(theType.CM_CargoType.classNameToCreate);
		endif;
	else
		self.myDataClass := CM_TrackedItem;
	endif;
	
	if self.myDataClass = null
	and app.cargoBOLTypeIsBOLType(_typeId)
	then
		self.myDataClass := CM_BOL;
	endif;
	
	//03 Jun 2015	NDL	Par 36338
	if self.isShowingAlphabetised and self.myDataClass = CM_CargoGroup then
		self.showTableCategorically();		
	endif;
	
end;</source>
        <Parameter name="_typeId" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setRowSpecifics" id="c762fc9c-1b76-4cba-ad79-2ad7e9d728e6">
        <source>setRowSpecifics(_obj : CM_Object; _tbl : CM_EntryTable input; _jRow : JadeTableRow input;
			_isForEdit, _bulkEditing : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     21 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	entRowTrans				: EntTableRowTransient;
	tmpInputType,
	tmpValueColor,
	rowBackColor			: Integer;

begin
	entRowTrans := _jRow.itemObject.EntTableRowTransient;
	
	tmpValueColor	:= self.colorValueColumn;
	
	if entRowTrans.inputType = 0 then
		rowBackColor := CM_EntryTable.ReadOnlyRowColour;
	else
		rowBackColor := tmpValueColor;
	endif;
	
	if _isForEdit then
		entRowTrans.inputEnabled := true;
		// Put is kind of check here because it was crashing for logs. Dockets I think. DVB
		if _bulkEditing and _obj.isKindOf(CM_TrackedItem) then
			if (not _obj.CM_TrackedItem.propertyValidForBulkEdit(entRowTrans)) then	//must be TI if bulk editing
				_jRow.inputType := 0;
				rowBackColor := CM_EntryTable.ReadOnlyRowColour;
				entRowTrans.inputEnabled := false;

				//JC - for the case where the EntRow can't be read only
				_jRow.enabled := false;
			endif;
		endif;
	else
		entRowTrans.inputEnabled := false;
	endif;
	
	if entRowTrans.controlName = 'txnFlag' then
		rowBackColor := self.TXN_RELATED_COLOUR;
	endif;

	_jRow.backColor := rowBackColor;

	tmpInputType := _tbl.accessCell(_jRow.row, _tbl.ColumnValue).inputType;

	if _isForEdit then
		self.loadCombosForEdit(_tbl, entRowTrans.name, _obj);
	elseif tmpInputType = Table.InputType_ComboBox then
		_tbl.accessCell(_jRow.row, _tbl.ColumnValue).inputType := Table.InputType_TextBox;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_jRow" type="JadeTableRow" usage="input"/>
        <Parameter name="_isForEdit" type="Boolean"/>
        <Parameter name="_bulkEditing" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSearchSelector" id="2fa941db-0744-4390-bd58-1e335e5bb477">
        <updating/>
        <source>setSearchSelector(obj : Object) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Nov 2019	jlger1	Initial creation TFS 47132

*/

vars
	cargoType		: CM_CargoType;
	cargoBOLType 	: CM_CargoBOLType; 			// ### TFS 52923 22Mar2022 NAVPW1
	qDef 			: CM_QueryDefinition;
	criteriaLine 	: CM_SelectorCriteriaLine;
	invalidObj 		: Boolean;
	os 				: ObjectSet;
	
begin
	delete self.myCriteriaLineHolder;
	
	on Exception do app.handleDeletedObject(exception,obj, invalidObj);
	
	if obj &lt;&gt; null and obj.isKindOf(CM_MenuUserQuery) then
		if obj.CM_MenuUserQuery.allCriteriaLineHolders.first &lt;&gt; null then
			self.createEnqController(obj.CM_MenuUserQuery.queryMode);
			
			self.myCriteriaLineHolder:= obj.CM_MenuUserQuery.allCriteriaLineHolders.first.cloneSelf(true);
			obj.CM_MenuUserQuery.allCriteriaLineHolders.first.cloneReferences(true,self.myCriteriaLineHolder);
			criteriaLine:=self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::myTerminal.name);
			
			if criteriaLine = null then
				qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null];
				criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::myTerminal.name, CM_QueryOperator.Operator_Equal, self.myTerminal);
				criteriaLine.setMyCriteriaLineHolder(self.myCriteriaLineHolder);
			else
				criteriaLine.myQueryOperator.setSearchValue( self.myTerminal);
				
			endif;		
		endif;
		if invalidObj then
			self.cmbSelector.removeObject(obj);
		endif;
		self.btnFilterVoyages. enabled:=false;
	else
		self.btnFilterVoyages.enabled:=true;
	endif;
	
	if self.myCriteriaLineHolder &lt;&gt; null then
	
		self.setTblSearchFromSelector();
		create os transient;
		self.myCriteriaLineHolder.getCargoTypes(os);
		cargoType:=os.first.CM_CargoType;
		self.setMyCurrentCargoBOLType(cargoType);
	else
		// ### TFS 52923 22Mar2022 NAVPW1
		if self.myCurrentCargoBOLType &lt;&gt; null then
			cargoBOLType := self.myCurrentCargoBOLType;
		else
			cargoBOLType := app.myPassport.getDefaultCargoBOLType();
		endif;
		// ### TFS 52923 22Mar2022 NAVPW1
		
		self.createDefaultCritLineHolder(cargoBOLType, null);	// ### TFS 52923 22Mar2022 NAVPW1
		//self.createDefaultCritLineHolder(app.myPassport.getDefaultCargoBOLType(),null);
		
	endif;
	
epilog
	delete os;

end;</source>
        <access>protected</access>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setStateByCargoType" id="f27eda12-9700-4232-b176-9e97a7c602fb">
        <updating/>
        <source>setStateByCargoType(obj :Object) updating;
// ---------------------------------------------------------------------------
// Created:     27 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cargoType :CM_CargoType;
begin

	self.myCurrentCargoBOLType := obj.CM_CargoBOLType;
	
	if obj = null then
		self.setEditEnabledDisabled(0);
	elseif obj.isKindOf(CM_CargoType) then
		cargoType := obj.CM_CargoType; 
		self.setEditEnabledDisabled(cargoType.id);
	elseif obj.isKindOf(CM_BOLType) then
		self.setEditEnabledDisabled(0);
	endif;
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setTIFromTableSpecial" id="dbb74803-833d-4eb1-ae1a-57f0765639d3">
        <source>setTIFromTableSpecial(_attrName : String io;
						_strValue : String;
						_obj : CM_TrackedItem input;
						_tbl : CM_EntryTable input) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     31 January 2003		cnwth2	
//
// Purpose:     Although there are no references to this method, it is called from the
//				tbl.setObjectFromTable (in the doSave) that contains 
//				a sendMsgWithParams - DO NOT DELETE

//				Called for attributes needing special treatment. If handled here, pass back true,
//				otherwise pass back false to have attribute set normally from table 
//			 
// ----------   ----------  --------------------------------------------------
/* Changes

Date		Name	TFS#			Description
============================================================================
25 Jun 2008	cnwkpd1	PAR #17183 		remove leading spaces from Customs Entry numbers
06 Nov 2009	cnwdap1	CCMS MES 1017 	Container Over Dimension details
30 Nov 2009	cnwdap1	CCMS MES 1007 	Reefer details now held on separate CM_ReeferProperties object
02 Feb 2010	cnwdap1	PAR #21867  	update "track as vehicle" attributes
09 Mar 2010 cnwdap1	PAR #22171 		correct updating of length and width based on over-length and over-width attributes
11 Mar 2010	cnwdap1	PAR #22938 		Correct reefer checking
17 Mar 2010 cnwcs5	par 22726  		vehicle dimensions in cm's
29 mar 2010	cnwdap1	PAR #23224 		Expand reefer check to include commodity
28 jun 2010	cnwdap1	PAR #24516 		Update selected tranship data
02 feb 2011	cnwdap1	PAR #26861	
					CCMS POL 2031 	update destination terminal
24 feb 2011	cnwdap1	PAR #27100 		Changes to tranship discharge port
21 mar 2012	cnwdap1	CCMS SFW 1259 
					PAR #26287 		Change setting of booking ref item so it checks for already fully-allocated items
18 jan 2013	cnwdap1	PAR #31018 
					CCMS POL 2223 	New On Power During transit fields
15 feb 2013	cnwdap1	PAR #31155 
					CCMS SFW 1321 	Imperial Measurements
13 Aug 2013	cnwdap1	PAR #32123		 Added Colour Picker
13 Sep 2013	cnwdap1	PAR #32215	 	Added new Car attributes
11 Mar 2014	cnwdap1	PAR #33603 		Correct handling of measurement fields for dofferent locales - don't use Comma as a delimiter as some locales
									(e.g. Italian) use Comma as a decimal separator, and don't just type-cast as Decimal otherwise we lose locale-sensitive info
11 Jul 2014	cnwrs1	Par 34566 	
					CCMS 2346 		Suzano Viagram Prenote file 
21 Apr 2015	cnwdap1	PAR #36094 	
					CCMS SFW 1413 
					TFS 313 		Cold Store Enhancements
15 Apr 2016	cnwrs1	TFS 1600 		VERMAS EDI
29/08/2016  cnwma1  TFS #2607
					PAR38173 		STWO - Unable to edit cargo subtype
29 Jun 2017	cnwdap1	TFS 4492 		SNO VERMAS Changes
12 Sep 2017	jlgdap1	TFS 6939 		POL Errors when bulk editing VGM details
03 Oct 2017	jlgdap1	TFS 7204 		STWR Problems with reals in locales where decimal place is not a .
23 Jan 2018 jlgsl4	TFS 36608 		QNS - non-blank VGM Authority on Ship Ops causes Save error
29 Mar 2019 jlgka1	TFS 44020		Change StringArray to HugeStringArray.
29 may 2019	jlgdap1	TFS 43346		Correct handling of hazard details
04 Nov 2019	jlgdap1	TFS 46405 		AAT Flat Rack and OOG in LOLO Planning Screen
04 Nov 2020 cnwma1 					ChangeRequest 50112: ASPA - GCI Stevedores
24 Nov 2020 cnwma1                  Bug 50375: 49179 ASPA - Cargo Enquiry
13 May 2022	jlika1	TFS 53316 		EUP - GEN - Additional Dimensions For Cargo - PortSchema
29 Jun 2022	navdap1	TFS 53362 		EUP Master Data Interface Customers Between TOS and ERP
27 July 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
19 Dec 2022	jlika1		TFS 55584 HS Code Combobox Usage
24 Jan 2023	navak20 Bug 56070: MTN - Check Grade, Grammage and Has New Damage usage in Cargo Enquiry form
22 Feb 2023	jlika1		TFS 56496 CUX - Add attribute to cargo (to allow for conversions of MAFI types)
12 Jun 2023	navpw1		TFS: 57812 (58439) - Added Itemised, Secondary Barcode Id &amp; Sorting Method
19 Jul 2023	jlirs1	TFS 59187 (59019) EUP - Manifest Processing - Container Reference Field
07 Aug 2023	jlirs1	TFS 59148 Port of Origin BOP
13 Nov 2023	jlika1	TFS 61130 61013 CUX | Cargo Priority - Cargo Maintenance
04 Jul 2024	jlizm1	TFS 64736 HS Code edi allow invalid codes
============================================================================*/

vars
	obj					: Object;
	str					: String;
	availGrade			: CM_MTGrade;
	hazDict				: CM_HazardByCodeDict;
	spDict				: CM_SpecialLiftByCodeDict;
	sa					: StringArray512;
	editObject			: CMIF_EditObject;
	temperature			: Real;
	tmpQuantity			: Integer;
	carbonDioxide		: Decimal[6,2];
	oxygen				: Decimal[6,2];
	tmpInt				: Integer;
	tmpHumidity			: Decimal[6,2];	//02 Apr 2020	NDL	TFS 47958
	errors				: String;
	debtorTypeCode		: String;
	theCompany			: CM_Bank;
	value				: Boolean;
	prodAttr			: CM_ProductAttr;
	aControl			: Control;
	aDebtor				: CM_Debtor;
	train				: CM_Train;
	reefer				: Boolean;
	commodity			: CM_Commodity;
	port				: CM_Port;
	
	sealTypeCode		: String;
	seal				: CM_SealTI;
	newSeal				: CM_SealTI;
	strSeal				: String;
	foundSeal			: Boolean;
	now					: TimeStamp;
	tmpAllowTimeOffPwr 	: Decimal[12,2]; //cnwas3 par 26199
	pos					: Integer;					// PAR #31155
	measurementTypeCode	: String;					// PAR #31155
	measureCode			: String;					// PAR #31155
	rowValue			: Decimal [23,10];			// PAR #31155
	rowValueStr			: String;					// PAR #31155
	entRowName			: String;					// PAR #31155
	//commaPos, endPos	: Integer;					// PAR #31155	// PAR #33603
	semiColonPos, endPos	: Integer;								// PAR #33603
	expDate				: Date;
	ts					: TimeStamp;
	ti					: CM_TrackedItem;
	ptd					: CM_PackTempReading;
	mrp					: CM_TIReeferProperties;
	wagonClass			: CM_WagonClass;
	subCargo			: CM_Product;
	weighInfo			: String;						// TFS 4492
	vgmDetails : CM_VGMDetails;							// TFS 4492
	authSig, commsType, docDetails, ediTrans, email, 	// TFS 4492
	mail, phone, fax, telephone : String;				// TFS 4492
	docsIssued, determination : TimeStamp;				// TFS 4492
begin
	now := app.actualTimeServer();	// 14/6/16 cnwmp6 TFS 488 - Multi timezone support
	if self.doingMultiEdit then //we've already checked whether row has been changed by the user at this point
		create editObject transient;
		editObject.myBulkEditController := self.myBulkEditController;
		editObject.attrName := _attrName;
	endif;
	
    if  _obj.isBulkOrBreakBulkGeneric and
       (_attrName = ETRow_Volume or
       _attrName = ETRow_Length or
       _attrName = ETRow_Height or
       _attrName = ETRow_Width or
       _attrName = ETRow_Pieces or
      // _attrName = ETRow_Density or
	   _attrName = ETRow_TotalWeight) then //cnwrd1 par 19000 13.3.09
      
		if (_obj.myProduct &lt;&gt; null) then
			prodAttr := _obj.myProduct.getProdAttrFromName(_attrName);
            
            if (not prodAttr.isViewable) then
                return true; //don't set a value - row shouldn't appear anyway
            endif;		
			if _attrName = ETRow_Pieces then
              _attrName := ETRow_Quantity;
			   _obj.setPropertyValue(_attrName,	prodAttr.divideValue(_strValue.asDecimalJMT) );       
            endif;
		else
				if _attrName = ETRow_Pieces then
				_attrName := ETRow_Quantity;
					_obj.setPropertyValue(_attrName,	_strValue.asIntegerJMT);       
				endif;
		endif;          
		// PAR #31155 still have to return true here so the calling method doesn't do a 
		// setPropertyValue on the original (hidden) row for measurements
        return true;
	//epr par 36023 24/4/15	
   	elseif _attrName = ETRow_Density then
		_obj.zSetPxyDensity( _strValue.asIntegerJMT );
		return true; 
	elseif _attrName = ETRow_MyVoyage then
		_obj.setVoyageCode(_strValue, app.myPassport);
		foreach obj in self.allProxyObjects do
			obj.CM_TrackedItem.setVoyageCode(_strValue, app.myPassport);
		endforeach;
		return true;
		
	elseif _attrName = ETRow_ContentsStatus then
		if self.cmbContents.listObject.CM_ContentsStatus &lt;&gt; null then
			_obj.setContentsStatus(self.cmbContents.listObject.CM_ContentsStatus.code);  // 7/9/22 	jlier1	TFS 54700
		endif;
		return true; 

	elseif _attrName = ETRow_BookingReference then
		_obj.setBookingReference(_strValue);
		//return true;
	elseif _attrName = ETRow_MyBookingRefItem then
		_obj.setMyBookRefItemActual(cmbBRItem.listObject.CM_BookingRefItem);		// PAR #26287
		//return true;
	elseif _attrName = ETRow_AvailabilityGrade then
		availGrade := self.cmbMTGrade.myObject.CM_MTGrade;
		if availGrade &lt;&gt; null then
			_obj.zSetPxyAVGrade( availGrade.code);			
		endif;
		return true; 
	
	elseif _attrName = ETRow_CouType then
		_obj.setPropertyValue('couType', app.couTypeStringToEnum(_strValue));	
		return true;
		
	elseif _attrName = ETRow_MyGeneratorType then
		if self.cmbGenSetType.myObject &lt;&gt; null then
			_obj.setPropertyValue( CM_Generator::myGeneratorType.name, self.cmbGenSetType.myObject.CM_GeneratorType );
		endif;
		return true;
		
	elseif _attrName = ETRow_ImexStatus then
		if self.cmbImExStatus.listObject &lt;&gt; null then
			_obj.setImExStatus(self.cmbImExStatus.listObject.CM_IMEXStatus.code);
		endif;
		return true;

	elseif _attrName = ETRow_CompanyCode then
		if self.allowSubTerminalUpdate then	//08 May 2015	NDL	Par 36181
			theCompany := self.myTerminal.companies[self.cmbCompany.text];
			if theCompany &lt;&gt; null then
				_obj.setCompanyOid(theCompany);
				foreach obj in self.allProxyObjects do
					obj.CM_TrackedItem.setCompanyOid(theCompany);
				endforeach;	
			endif;
		endif;
		return true;
		
	elseif _attrName = ETRow_CargoGroup then	//04 Jun 2015	NDL	Par 36338
		if app.isCargoGroupEnabled then
			_obj.CM_TrackedItem.setCargoGroup( null, _strValue, app.myPassport );
		endif;
		return true;

	elseif _attrName = ETRow_CustomsEntryNumber then
		// moved up from container specific section below (as part of PAR 16824 changes)
		create sa transient;
		str := _strValue;
		str := str.replaceString(' ','');		// PAR #17183			
		str.getTokensForDelimiter(',', sa);
		
		// PAR 16824 - need to allow bulk edit of Customs Entry Number
		foreach obj in self.allProxyObjects do
			obj.CM_TrackedItem.zSetPxyAllCustomsEntryNumbers(sa);
		endforeach;
		return true;

	elseif _attrName = ETRow_DamageDetail then
			self.tblDamage.setProxyFromTable(_obj.IF_DamageDetails, errors, null);
	elseif _attrName = ETRow_DeliveryReleaseReason then
		_obj.setPropertyValue(CM_TrackedItem::deliveryReleaseReason.name, app.deliveryReasonStringToEnum(_strValue));
		return true;
		
	elseif _attrName = ETRow_IsDirectDelivery then	//28 Jan 2013	NDL	CCMS 1299		Par 31102
			foreach obj in self.allProxyObjects do
				obj.CM_TrackedItem.setDirectDelivery( _strValue.Integer.Boolean, false );
			endforeach;
			return true;
			
	elseif _attrName = ETRow_CustomExportEntryNumber then
		//this is virtual - so skipped over in setObjFromTable - but OK if set
		if _obj.customExportEntryNumber = null and
		   _strValue &lt;&gt; null then
			//_obj.removeCEDOStop();
		endif;
		_obj.setCEDO(_strValue);
		foreach obj in self.allProxyObjects do
			_obj.setCEDO(_strValue);
		endforeach;
		return true;
	//following also virual properties :-
	elseif _attrName = ETRow_ExportReleaseNumber then	//cnwrd1 4.11.08 CCMS JMT 1743/1764 
		_obj.setOperatorExpReleaseNo(_strValue);		//cnwrd1 4.11.08 CCMS JMT 1743/1764 
		return true;									//cnwrd1 4.11.08 CCMS JMT 1743/1764 
	elseif _attrName = ETRow_ImportReleasePIN then		//cnwrd1 4.11.08 CCMS JMT 1743/1764 
		_obj.setOperatorImportReleasePIN(_strValue);	//cnwrd1 4.11.08 CCMS JMT 1743/1764 	
		return true;									//cnwrd1 4.11.08 CCMS JMT 1743/1764 
	elseif _attrName = ETRow_AllTIHazards then
		//epr TFS 47132 30/12/19
		/*if not self.myTerminal.getConfig(UseDetailedHazEntry).Boolean then		// TFS 43346
			create hazDict transient;
			self.lstHazList.allSelectedObjects.copy(hazDict);
			_obj.zSetPxyTIHazards(hazDict);
			foreach obj in self.allProxyObjects do
				obj.CM_TrackedItem.zSetPxyTIHazards(hazDict);
			endforeach;
		endif;																	// TFS 43346*/
		return true;

	elseif _attrName = ETRow_AllStops then
		// par 24342 - we no lobnger allow stops to be edited using the table
		// so no stops changes for bulks edit
		//self.compareStops;
		return true;
	// ### TFS 55215 18Nov2022 NAVPW1
	elseif _attrName = ETRow_CustomsReferences then
		return true;
	// ### TFS 55215 18Nov2022 NAVPW1
	elseif _attrName = ETRow_AllSpecialLifts then
		create spDict transient;
		self.lstTblSpecialLif.allSelectedObjects.copyNoDupsNoTransaction(spDict); //cnwrd1 
		_obj.zSetPxySpecialLifts(spDict);
		return true;
	elseif (_attrName = ETRow_Quantity) or (_attrName = ETRow_TotalQuantity) then
		if _strValue = '' then
			tmpQuantity := NULL_QUANTITY;
		else
			tmpQuantity := _strValue.Integer;
		endif;
		_obj.setPropertyValue(_attrName, tmpQuantity);
		return true;	
	elseif (_attrName = ETRow_Volume) then
		// now handled by measurement type rows return true so it doesn't use setPropertyValue on ti
		return true;	
	elseif (_attrName = ETRow_TotalVolume) then
		// now handled by measurement type rows return true so it doesn't use setPropertyValue on ti
		return true;
	elseif _attrName = ETRow_ContainerVolume then	// 26490 2/12/2010
		// now handled by measurement type rows return true so it doesn't use setPropertyValue on ti
		return true;
	elseif _attrName = ETRow_TotalWeight then												//+cnwml2 MSL CCMS 1017
		// now handled by measurement type rows return true so it doesn't use setPropertyValue on ti
		return true;
	elseif _attrName = ETRow_TareWeight then
		// now handled by measurement type rows return true so it doesn't use setPropertyValue on ti
		return true;
	elseif _attrName = ETRow_MinWeight then	//09 Jul 2015	NDL	Par 36608
		// now handled by measurement type rows return true so it doesn't use setPropertyValue on ti
		return true;
	elseif _attrName = ETRow_MaxWeight then	//09 Jul 2015	NDL	Par 36608
		// now handled by measurement type rows return true so it doesn't use setPropertyValue on ti
		return true;
	elseif _attrName = ETRow_OverHeight then //jlier1 TFS 54700 1/9/22
		return true;
	elseif _attrName = ETRow_OverWidth then
		return true;
	elseif _attrName = ETRow_OverLength then
		return true;
	elseif _attrName = ETRow_PackTempC then //+ cnwmd1 CCMS 1871
		_obj.CM_TrackedItem.setPackTempC(_strValue);
		return true;
	elseif _attrName = ETRow_PackTempF then //+ cnwmd1 CCMS 1871
		_obj.CM_TrackedItem.setPackTempF(_strValue);
		return true;
	elseif _attrName = ETRow_AllowableTimeOffPower then //+ cnwmd1 CCMS 1871
		if _strValue = null then									//+ cnwas3 par 26199
			tmpAllowTimeOffPwr := NULL_ALLOWABLE_TIME_OFF_POWER;
		else
			tmpAllowTimeOffPwr := _strValue.asDecimalJMT();
		endif;
		_obj.CM_TrackedItem.setAllowableTimeOffPower(tmpAllowTimeOffPwr);
		return true;
		
	elseif _attrName = ETRow_PackDate then //+ cnwmd1 CCMS 1871
		_obj.CM_TrackedItem.setPackDate(_strValue.asDateJMT);
		return true;
		
	elseif _attrName = ETRow_PackTime then //+ cnwmd1 CCMS 1871
		ti := _obj.CM_TrackedItem;
		if ti.myReeferProperties &lt;&gt; null then
			ptd := ti.myReeferProperties.packTempDetails;
			if ptd &lt;&gt; null then
				if ptd.dateTime.isValid() then
					ts.setDate(ptd.dateTime.date());
					ts.setTime(_strValue.asTimeJMT());
					
					ts := ti.localToSystemTime(ts);		// 14/6/16 cnwmp6 TFS 488 - Multi timezone support
					ti.setPackDate(ts.date());
					ti.setPackTime(ts.time());
				else
					ti.setPackTime(_strValue.asTimeJMT);
				endif;
			return true;
			endif;
		endif;
	elseif _attrName = ETRow_InvoiceNumber then
		_obj.CM_TrackedItem.setInvoiceNumber(_strValue);
		return true;
	elseif _attrName = ETRow_OrderNumber then
		_obj.CM_TrackedItem.setOrderNumber(_strValue);
		return true;
	elseif _attrName.length &gt; 6 and _attrName[1:6] = "StRow_" then		// Seals
		if _obj.isKindOf(CM_TrackedItem) then
			//+cnwml2 PAR23715 SFW CCMS1131
			sealTypeCode := _attrName[7:end];
			if not sealTypeCode.startsWith("PreviousSeal_") and not sealTypeCode.startsWith("DateTime_") then
				foreach seal in _obj.allSeals do
					if seal.sealType = sealTypeCode then
						//found existing seal in ti
						foreach str in seal.allSealNums do
							if strSeal &lt;&gt; null then
								strSeal := strSeal &amp; ", " &amp; str;
							else
								strSeal := str;
							endif;
						endforeach;
						if _strValue &lt;&gt; strSeal then
							seal.setPreviousSeal(strSeal);
							seal.setSealedDT( now );	//29 Sep 2010	NDL	Par 25608
						endif;
								
						seal.allSealNums.clear();
						seal.allSealNums.add(_strValue.trimBlanks); //jlgka1 TFS 44020
						foundSeal := true;
						break;
					endif;
				endforeach;
						
				if not foundSeal and _strValue &lt;&gt; null then	//25 Nov 2010	NDL Par 26409
					//create new seal
					create newSeal transient;
					newSeal.setPreviousSeal(null);
					newSeal.setSealType(_attrName[7:end]);
					newSeal.allSealNums.add(_strValue.trimBlanks); //jlgka1 TFS 44020
					newSeal.setSealedDT( now );	//29 Sep 2010	NDL	Par 25608
					newSeal.setMyTrackedItem(_obj.CM_TrackedItem);
				endif;
			endif;
		endif;
		return true;
	elseif _attrName.length &gt; 6 and _attrName[1:6] = "DtRow_" then // PAR 16666 CCMS CP 1047 April 2008 debtor types
		if _obj.isKindOf(CM_TrackedItem) then
	
			debtorTypeCode := _attrName[7:end];
			aControl := self.allDebtorTypeControls["cmbDebtorType" &amp; debtorTypeCode];
			if aControl &lt;&gt; null then
				aDebtor := aControl.CMUI_ComboBox.listObject.CM_Debtor;
				if _obj.CM_TrackedItem.allDebtorsByType[debtorTypeCode] &lt;&gt; null then //PAR 17591 cnwgb1 29 July 2008
						_obj.CM_TrackedItem.allDebtorsByType.removeKey(debtorTypeCode);
					endif;
				if aDebtor &lt;&gt; null then //PAR 17591 cnwgb1 29 July 2008
					_obj.CM_TrackedItem.allDebtorsByType[debtorTypeCode] := aDebtor;
				endif;
			endif;
		endif;
		return true;
	
	// PAR #31155 measurement types are dealt with specially - so we return true for the types we're
	// updating here so the setPropertyValue in setObjectFromTableWithProps doesn't end up getting triggered
	elseif _attrName.length &gt; 6 and _attrName.isMeasurementType() then
		if _obj.isKindOf(CM_TrackedItem) then
			// This is a measurement row - _strValue will contain the value then the measurement unit, separated by a space	
			// The actual row name is in the _attrName which is formatted WTRow_&lt;ent table row&gt;_&lt;measurement unit&gt;
			// e.g. WTRow_totalWeight_kg is a weight row for totalWeight, and has been entered in kg
			pos := _strValue.pos(Space, 2); //epr par 32291 9/1/14 these rows always start space value then unit i.e. " kg" start from 2 character

			//commaPos := _strValue.pos(Comma, 2);																// PAR #33603
			//if commaPos &lt;&gt; null then																			// PAR #33603
			//	endPos := commaPos - pos - 1;																	// PAR #33603
			semiColonPos := _strValue.pos(SemiColon, 2);														// PAR #33603
			if semiColonPos &lt;&gt; null then																		// PAR #33603
				endPos := semiColonPos - pos - 1;																// PAR #33603
			else
				endPos := _strValue.length;
			endif;
			_attrName.getRowNameMeasureType(entRowName, measureCode);
						
		//	if pos &lt;&gt; null then
			if pos &lt;&gt; null and endPos &gt;= 0 then	//18 Feb 2021	NDL	TFS 50733
				rowValueStr := _strValue[1:pos-1];
				measurementTypeCode := _strValue[pos+1:endPos];
				
				//rowValue := app.convertMeasurementForStorage(measurementTypeCode, rowValueStr.Decimal);		// PAR #33603
				rowValue := app.convertMeasurementForStorage(measurementTypeCode, rowValueStr.asDecimalJMT);	// PAR #33603
			else
				if _attrName[1:6] = Prefix_Weight then
					rowValue := NULL_WEIGHT;
				elseif _attrName[1:6] = Prefix_Volume then
					rowValue := NULL_VOLUME;
				elseif _attrName[1:6] = Prefix_Displacement then
					rowValue := NULL_VENTILATION;
				else
					rowValue := null;
				endif;
			endif;
			
			_obj.CM_TrackedItem.setMeasurementValue(entRowName, rowValue);
			return true;
		endif;
		
	elseif _attrName.isOneOf(ETRow_WeightDeclared, ETRow_WeightCargo, ETRow_WeightTare, ETRow_Density, ETRow_Diameter, ETRow_RollingLength) then
		// now handled by measurement type rows return true so it doesn't use setPropertyValue on ti
		return true;
	// PAR #31155 end
	
	elseif _attrName = ETRow_Colour then												// PAR #32123
		if self.myTerminal.getConfig(ValidateColour).Boolean then						// PAR #32123
			str := self.myAssistant.getColourString(self.lstColour, null);			// PAR #32215
			_obj.setColour(str);								// PAR #32123
			return true;	
		endif;																			// PAR #32123		
	elseif _attrName = ETRow_ReceiveStevedore then       //02.10.2020 cnwma1 TFS #50112
		// TFS 53362 start of this bit
		if app.myRoot.getConfig(ComboByNameStevedore).Boolean and self.cmbReceiveStevedore.listObject &lt;&gt; null then
			_obj.setStevedoreCodeRecieve(self.cmbReceiveStevedore.listObject.CM_Stevedore.code);
			return true;
		endif;
		// TFS 53362 end of this bit
		_obj.setStevedoreCodeRecieve(_strValue);	 	 //24.11.2020 cnwma1 #50410
		return true;	
	elseif _attrName = ETRow_ReleaseStevedore then       //02.10.2020 cnwma1 TFS #50112
		// TFS 53362 start of this bit
		if app.myRoot.getConfig(ComboByNameStevedore).Boolean and self.cmbReleaseStevedore.listObject &lt;&gt; null then
			_obj.setStevedoreCodeRelease(self.cmbReleaseStevedore.listObject.CM_Stevedore.code);
			return true;
		endif;
		// TFS 53362 end of this bit
		_obj.setStevedoreCodeRelease(_strValue);	     //24.11.2020 cnwma1 50410
		return true;	
	endif;
	
	// CCMS 1007 other tracked items apart from containers can now be treated as reefers
	commodity := app.myRoot.allCommodities[_obj.CM_TrackedItem.commodity];									// PAR #23224
	if _obj.CM_TrackedItem.isReefer or (commodity &lt;&gt; null and commodity.hasTemp) then		// PAR #22938	// PAR #23224
		reefer := true;
	endif;
	if (CM_Container.hasInstance(_obj) or reefer) then
		
		if _attrName = ETRow_Humidity then
			if _strValue = '' then
				tmpHumidity := NULL_HUMIDITY;
			else
				tmpHumidity := _strValue.Decimal;
			endif;
			_obj.CM_TrackedItem.setHumidity(tmpHumidity);				// CCMS 1007
			return true;

		elseif _attrName = ETRow_Temperature then
			if _strValue = '' then
				temperature := NULL_TEMPERATURE;
			else
				//temperature := _strValue.Real;			// TFS 7204
				temperature := _strValue.asRealJMT;			// TFS 7204
			endif;
			_obj.CM_TrackedItem.setTemperature(temperature);		// CCMS 1007
			return true;

		elseif _attrName = ETRow_CarbonDioxide then
			if _strValue = '' then
				carbonDioxide := NULL_CARBON_DIOXIDE;
			else
				carbonDioxide := _strValue.Decimal;
			endif;
			_obj.CM_TrackedItem.setCarbonDioxide(carbonDioxide);	// CCMS 1007
			return true;
		elseif _attrName = ETRow_Oxygen then
			if _strValue = '' then
				oxygen := NULL_OXYGEN;
			else
				oxygen := _strValue.Decimal;
			endif;
			_obj.CM_TrackedItem.setOxygen(oxygen);				// CCMS 1007
			return true;

		elseif (_attrName = ETRow_Ventilation) then
			//is now handled by measurement type rows just return true so it doesn't continue on and set property value
			return true;
		elseif _attrName = ETRow_CoolingType then
			_obj.CM_TrackedItem.setCoolingType(app.coolingTypeStringToENum(_strValue));	// CCMS 1007
			return true;

		elseif _attrName = ETRow_VoltageType then
			_obj.CM_TrackedItem.setVoltageType(app.voltageTypeStringToENum(_strValue));	// CCMS 1007
			return true;
			
		elseif _attrName = ETRow_ReeferRemarks then					// CCMS 1007
			_obj.CM_TrackedItem.setReeferRemarks(_strValue);		// CCMS 1007
			return true;											// CCMS 1007
		
		elseif _attrName = ETRow_CurtainsIn then						// CCMS 1007
			_obj.CM_TrackedItem.setCurtainsIn(_strValue.asBooleanJMT);	// CCMS 1007
			return true;												// CCMS 1007
			
		elseif _attrName = ETRow_OnPowerDuringTransit then							// PAR #31018
			_obj.CM_TrackedItem.setOnPowerDuringTransit(_strValue.asBooleanJMT);	// PAR #31018
			return true;															// PAR #31018
																					// PAR #31018
		elseif _attrName = ETRow_TransitOnPowerDate then							// PAR #31018
			_obj.CM_TrackedItem.setTransitOnPowerDate(_strValue.asDateJMT);			// PAR #31018
			return true;															// PAR #31018
																					// PAR #31018
		elseif _attrName = ETRow_TransitOnPowerTime then							// PAR #31018
			mrp := _obj.CM_TrackedItem.myReeferProperties;
			if mrp &lt;&gt; null then
				if mrp.transitOnPowerDate.isValid() then
					ts.setDate(mrp.transitOnPowerDate);
					ts.setTime(_strValue.asTimeJMT());
					
					ts := self.localToSystemTime(ts);		// 14/6/16 cnwmp6 TFS 488 - Multi timezone support
					mrp.setTransitOnPowerDate(ts.date());
					mrp.setTransitOnPowerTime(ts.time());
				else
					mrp.setTransitOnPowerTime(_strValue.asTimeJMT);
				endif;
				return true;
			endif;
																					// PAR #31018
		elseif _attrName = ETRow_TransitOnPowerRemarks then							// PAR #31018
			_obj.CM_TrackedItem.setTransitOnPowerRemarks(_strValue);				// PAR #31018
			return true;															// PAR #31018		
			
		elseif _attrName = ETRow_ExpiryDate then									// PAR #36094
			_obj.CM_TrackedItem.setExpiryDate(_strValue.asDateJMT);					// PAR #36094
		endif;
		
	endif;
	
	// CCMS 1007 split reefer and non-reefer properties in to separate conditions
	if (CM_Container.hasInstance(_obj)) then
		if _attrName = ETRow_OffsiteCleaned then
			value := (_strValue.toUpper = 'YES');
			_obj.CM_Container.setOffsiteCleaned(value);
			foreach obj in self.allProxyObjects do
				obj.CM_Container.setOffsiteCleaned(value);
			endforeach;
		
		elseif _attrName = ETRow_OffsitePreTrip then
			value := (_strValue.toUpper = 'YES');
			_obj.CM_Container.setOffsitePreTrip(value);
			foreach obj in self.allProxyObjects do
				obj.CM_Container.setOffsitePreTrip(value);
			endforeach;
		elseif _attrName = ETRow_MySubTerminal then //08/04/2009 cnwdz2 ccms1735
			if self.allowSubTerminalUpdate then	//27 Nov 2014	NDL	Par 35295
				_obj.setMySubTerminal(self.cmbSubTerminal.text);
			endif;
			return true;
		elseif _attrName = ETRow_IntendedReleaseMode then //+ cnwmd1, CCMS 1067, Par 19710
			_obj.CM_Container.setPropertyValue(CM_Container::intendedReleaseMode.name, app.intendedReleaseModeString2Enum(_strValue));
			return true;
		elseif _attrName = ETRow_MyTrainAssigned then //+ cnwmd1, CCMS 1067, Par 19710
			train := cmbTrainAssigned.listObject.CM_Train;
			_obj.CM_Container.setPropertyValue(CM_Container::myTrainAssigned.name, train );
			return true;			
		// CCMS 1017 Over Dimension details
		// PAR #31155 CCMS SFW 1321 don't update dimensions here, it's done in the 
		// measurement section above - just return true for each here
		elseif _attrName = ETRow_OverHeight then
			return true;
		elseif _attrName = ETRow_OverLengthFront then
			return true;
		elseif _attrName = ETRow_OverLengthBack then
			return true;
		elseif _attrName = ETRow_OverWidthLeft then
			return true;
		elseif _attrName = ETRow_OverWidthRight then
			return true;
		elseif _attrName.isOneOf(ETRow_Height, ETRow_Length, ETRow_Width) then
			//do nothing for containers - all done above. Just return true
			return true;
			
		// TFS 46405 start
		elseif _attrName = ETRow_FlatRackStatus then
			str := _tbl.getValueByName(ETRow_FlatRackStatus).String;
			if str &lt;&gt; null then
				_obj.CM_Container.setPropertyValue(CM_Container::doorsDirn.name, app.flatRackEndsStringToEnum(str));
			endif;
		// TFS 46405 end
		elseif _attrName = ETRow_MyCarProduct then //02/10/2025	navkc1 JIRA 36144 
			subCargo := self.cmbProduct.listObject.CM_Product;
			_obj.CM_Container.setMyProduct(subCargo);
		endif;
	endif;
	
	//cnwmc5 - PAR 32757 - 10 Oct 2013
	if CM_Timber.hasInstance(_obj) or CM_LCL.hasInstance(_obj) 
	 or CM_TILC.hasInstance(_obj) then // PAR 33846
		if _attrName.isOneOf(ETRow_Height, ETRow_Length, ETRow_Width) then
			//Do nothing for Timber, Trailers and LCL cargo types - all done above. Just return true
			return true;
		endif;
	endif;
	
	// PAR #21867 vehicle-specific rows
	if CM_Car.hasInstance(_obj) then
		if _attrName = ETRow_IsSelfPropelled then
			_obj.CM_Car.setSelfPropelled(_strValue.asBooleanJMT);
		endif;
		// par 22726 - vehicle dimensions
		// use different etrow and let calling method do updating
		if _attrName = ETRow_LengthCM then
			_obj.setLength (_strValue.asDecimalJMT);
			return true;
		endif;
		if _attrName = ETRow_HeightCM then
			_obj.setHeight (_strValue.asDecimalJMT);
			return true;
		endif;
		if _attrName = ETRow_WidthCM then
			_obj.setWidth (_strValue.asDecimalJMT);
			return true;
		endif;
		// par 22726 - end
		// 34293 car length, height and width now done as measurement types
		if _attrName.isOneOf(ETRow_Height, ETRow_Length, ETRow_Width) then
			return true;
		endif;
		
		if _attrName = ETRow_Doors then									// PAR #32215
			_obj.CM_Car.setNbrDoors(_strValue.asIntegerJMT);			// PAR #32215
		elseif _attrName = ETRow_NewVehicle then						// PAR #32215
			_obj.CM_Car.setIsNew(_strValue.asBooleanJMT);				// PAR #32215
		elseif _attrName = ETRow_VehicleType then						// PAR #32215
			_obj.CM_Car.setVehicleType(_strValue);						// PAR #32215
		elseif _attrName = ETRow_DocsReceived then						// PAR #32215
			_obj.CM_Car.setDocsReceived(_strValue.asDateJMT);				// PAR #32215 //epr par 32824
		elseif _attrName = ETRow_DocsSent then							// PAR #32215
			_obj.CM_Car.setDocsSent(_strValue.asDateJMT);					// PAR #32215
		elseif _attrName = ETRow_DocsCleared then						// PAR #32215
			_obj.CM_Car.setDocsCleared(_strValue.asDateJMT);					// PAR #32215
		elseif _attrName = ETRow_DocsReturned then						// PAR #32215
			_obj.CM_Car.setDocsReturned(_strValue.asDateJMT);				// PAR #32215
		elseif _attrName = ETRow_MyCarProduct then                     //29/08/2016 cnwma1 TFS #2607 PAR #38173
			subCargo := cmbProduct.listObject.CM_Product;
			_obj.CM_Car.setMyProduct( subCargo );
		endif;															// PAR #32215
	endif;

	// PAR #24516 Enable update of selected tranship details 
	if _attrName = ETRow_TranshipExportVoyage then
		_obj.setTranshipExportVoyage(_strValue, app.myPassport);
		return true;
	elseif _attrName = ETRow_TranshipDischargePort then
		port := self.cmbExpTshipDisch.CMUI_ComboPorts.myObject.CM_Port;
		if port &lt;&gt; null then
			_obj.setTranshipDischargePort(port);								// PAR #27100
		endif;
		return true;
	elseif _attrName = ETRow_TranshipDestPort then
		port := self.cmbExpTshipDest.CMUI_ComboPorts.myObject.CM_Port;
		if port &lt;&gt; null then
			_obj.setDestinationPort(port.code);
		endif;
		return true;
	elseif _attrName = ETRow_TranshipOutBookingRef then
		_obj.setTranshipOutBookingRef(_strValue);
		return true;
	elseif _attrName = ETRow_TranshipInBookingRef then	
		_obj.setTranshipInBookingRef(_strValue);
		return true;
	elseif _attrName = ETRow_TranshipRemarks then
		_obj.remarksTranship := _strValue;
		return true;
	elseif _attrName = ETRow_DestTerminalForPrenote then
		if self.cmbDestTerm.listIndex &gt; 0 then
			_obj.setDestinationTerminal(self.cmbDestTerm.listObject.CM_Terminal.code);
		else
			_obj.setDestinationTerminal(null);
		endif;
		return true;
	elseif _attrName = ETRow_WagonClass then	//12 May 2014	NDL	Par 33615
		return true; // we do it with Wagon Number....
	elseif _attrName = ETRow_WagonNumber then
		wagonClass := self.cmbWagonClass.listObject.CM_WagonClass;
	//	_obj.setWagon(_strValue.trimBlanks(), null);
	//	_obj.setWagon( _strValue.trimBlanks(), null, wagonClass );	//12 May 2014	NDL	Par 33615
		_obj.setWagon( _strValue.trimBlanks(), null, wagonClass, false ); //12 Jan 2018 MPD TFS 36406
		return true;
	//cnwmc5 - PAR 31160
	elseif _attrName = ETRow_ReceiptTransportMode and _obj.CM_TrackedItem.isPreNote then //epr par 32357 16/9/13
		_obj.setReceiptTransportMode(app.transModeToCode(_strValue));
		return true;
	
	//29 Jul 2013	NDL	Par 31763
	elseif _attrName = ETRow_ExpectedArrivalTime then
		ti := _obj.CM_TrackedItem;
		if ti.isPreNote then
			if ti.expectedArrivalDate.isValid then
				ts.setDate(ti.expectedArrivalDate);
				ts.setTime(_strValue.asTimeJMT());
				
				ts := ti.localToSystemTime(ts);
				ti.setExpectedArrivalDate(ts.date());
				ti.setExpectedArrivalTime(ts.time());
			else
				ti.setExpectedArrivalTime(_strValue.asTimeJMT);
			endif;
			return true;
		endif;
	//29 Jul 2013	NDL	Par 31763
	elseif _attrName = ETRow_ExpectedArrivalDate then
		if _obj.CM_TrackedItem.isPreNote then
			expDate := _strValue.asDateJMT;
			if expDate.isValid then
				_obj.CM_TrackedItem.setExpectedArrivalDate(expDate);
				return true;
			endif;
		endif;
	//cnwmc5 - 14 March 2014 - PAR 33659
	elseif _attrName = ETRow_TrailerTypeUpd then
		if _obj.isKindOf(CM_TILC) then
			_obj.CM_TILC.setMyType(self.cmbTrailerType.listObject.CM_TILCType);
			return true;
		endif;
	//cnwmc5 - 16 Oct 2015 - PAR 37057
	elseif _attrName = ETRow_HasExternalMonitoring then
		_obj.CM_TrackedItem.setExternalMonitoring(_strValue.asBooleanJMT);
		return true;
	elseif _attrName = ETRow_WeightCertifiedPerson then
		//_obj.CM_TrackedItem.setWeightCertifiedName(_strValue, null, null);						// TFS 4492
		vgmDetails := _obj.CM_TrackedItem.getMyVGMDetails();										// TFS 4492
		if vgmDetails &lt;&gt; null then																	// TFS 4492
			authSig := vgmDetails.vgmAuthSignature;													// TFS 4492
			commsType := vgmDetails.vgmCommsType;													// TFS 4492
			docDetails := vgmDetails.vgmDocumentDetails;											// TFS 4492
			ediTrans := vgmDetails.vgmEDITransmission;												// TFS 4492
			email := vgmDetails.vgmElectronicMail;													// TFS 4492
			mail := vgmDetails.vgmMail;																// TFS 4492
			phone := vgmDetails.vgmPhone;															// TFS 4492
			fax := vgmDetails.vgmTelefax;															// TFS 4492
			telephone := vgmDetails.vgmTelephone;													// TFS 4492
			docsIssued := vgmDetails.vgmDocsIssuedDT;												// TFS 4492
			determination := vgmDetails.vgmDeterminationDT;											// TFS 4492
		endif;																						// TFS 4492
		//weighInfo := self.tblEdit1.getValueByName(ETRow_WeightCertifiedBy).String;					// TFS 4492
		weighInfo := getValueFromTables(ETRow_WeightCertifiedBy).String;							// TFS 36608		
		_obj.CM_TrackedItem.setMyVGMDetails(	weighInfo, _strValue,  								// TFS 4492
											authSig, commsType, docDetails, ediTrans, email, mail, 	// TFS 4492
											phone, fax, telephone, docsIssued, determination, null	);	// TFS 4492
		return true;			// TFS 6939
	elseif _attrName = ETRow_WeightCertifiedBy then													// TFS 4492
		//_obj.CM_TrackedItem.setWeightCertifiedReference(_strValue, null, null);					// TFS 4492
		vgmDetails := _obj.CM_TrackedItem.getMyVGMDetails();										// TFS 4492
		if vgmDetails &lt;&gt; null then																	// TFS 4492
			authSig := vgmDetails.vgmAuthSignature;													// TFS 4492
			commsType := vgmDetails.vgmCommsType;													// TFS 4492
			docDetails := vgmDetails.vgmDocumentDetails;											// TFS 4492
			ediTrans := vgmDetails.vgmEDITransmission;												// TFS 4492
			email := vgmDetails.vgmElectronicMail;													// TFS 4492
			mail := vgmDetails.vgmMail;																// TFS 4492
			phone := vgmDetails.vgmPhone;															// TFS 4492
			fax := vgmDetails.vgmTelefax;															// TFS 4492
			telephone := vgmDetails.vgmTelephone;													// TFS 4492
			docsIssued := vgmDetails.vgmDocsIssuedDT;												// TFS 4492
			determination := vgmDetails.vgmDeterminationDT;											// TFS 4492
		endif;																						// TFS 4492
		//weighInfo := self.tblEdit1.getValueByName(ETRow_WeightCertifiedPerson).String;				// TFS 4492
		weighInfo := getValueFromTables(ETRow_WeightCertifiedPerson).String;						// TFS 36608
		_obj.CM_TrackedItem.setMyVGMDetails(	_strValue, weighInfo, 								// TFS 4492
											authSig, commsType, docDetails, ediTrans, email, mail, 	// TFS 4492
											phone, fax, telephone, docsIssued, determination, null	);	// TFS 4492
		return true;			// TFS 6939		
		
	// TFS 53362 some more
	elseif _attrName = ETRow_Consignee then
		if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean and self.cmbConsignee.listObject &lt;&gt; null then
			_obj.setConsigneeByString(self.cmbConsignee.listObject.CM_ConsigneeConsignor.code);
			return true;
		endif;
	elseif _attrName = ETRow_Consignor then
		if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean and self.cmbConsignor.listObject &lt;&gt; null then
			_obj.setConsignorByString(self.cmbConsignor.listObject.CM_ConsigneeConsignor.code);
			return true;
		endif;
	// TFS 53362 end of this bit
	
	// ### TFS 54021 30June2022 NAVPW1
	elseif _attrName = ETRow_Grammage and _obj.isKindOf(CM_BreakBulkGeneric) then
		_obj.CM_BreakBulkGeneric.setGrammage(getValueFromTables(ETRow_Grammage).Decimal);
		return true;	// 23.01.2023 navak20 TFS 56070
	elseif _attrName = ETRow_Grade and _obj.isKindOf(CM_BreakBulkGeneric) then
		_obj.CM_BreakBulkGeneric.setGrade(getValueFromTables(ETRow_Grade).String);
		return true;	// 23.01.2023 navak20 TFS 56070
	// ### TFS 54021 30June2022 NAVPW1
	
	//Start 27.07.2022 navak20 TFS 53862
	elseif _attrName = ETRow_HasNewDamage then
		_obj.CM_TrackedItem.setDamagedDT(_strValue.Integer.Boolean);
		return true;	// 23.01.2023 navak20 TFS 56070
	//End 27.07.2022 navak20 TFS 53862
	elseif _attrName = ETRow_HsCode then		
		if self.cmbHsCode.listObject &lt;&gt; null then
			_obj.CM_TrackedItem.setHSCode(self.cmbHsCode.listObject.CM_HarmonizedSystem.id);
			return true;	
		endif;
		if self.cmbHsCode.text &lt;&gt; null then
			_obj.CM_TrackedItem.setHSCode(self.cmbHsCode.text);
			return true;
		endif;
	elseif _attrName = ETRow_ManifestNumber then
		_obj.CM_TrackedItem.setManifestNumber(_strValue); //jlier1 TFS 55788 19/1/23
	elseif _attrName = ETRow_ShipperDescription then
		_obj.CM_TrackedItem.setShipperDescription(_strValue); //jlier1 TFS 55788 19/1/23
	elseif _attrName = ETRow_FloorType then				
		_obj.CM_TILC.setFloorType(self.cmbFloorType.listData());
		return true;		
	elseif _attrName = ETRow_InvoiceContractId then // ### TFS BUG 57309 03APR2023 NAVAB1
		_obj.CM_TrackedItem.setContractId(self.cmbInvoiceContractId.text); // ### TFS BUG 57309 03APR2023 NAVAB1
		return true; // ### TFS BUG 57309 03APR2023 NAVAB1
	// ### TFS 57812 (58439) 12Jun2023 NAVPW1
	elseif _attrName = ETRow_Itemised then
		_obj.setItemised(self.getValueFromTables(ETRow_Itemised).Boolean);
		
	elseif _attrName = ETRow_SecondaryBarcodeId then
		_obj.setSecondaryBarcodeId(self.getValueFromTables(ETRow_SecondaryBarcodeId).String);
	// ### TFS 57812 (58439) 12Jun2023 NAVPW1
	
	elseif _attrName = ETRow_ContainerNumberText then			//19 July 2023	jlirs1	TFS 59187 (59019) EUP
		_obj.setContainerNumberText(self.getValueFromTables(ETRow_ContainerNumberText).String);
		
	elseif _attrName = ETRow_PortOfOrigin then					//07 Aug 2023	jlirs1	TFS 59148 Port of Origin BOP
		port := self.cmbOrigPort.CMUI_ComboPorts.myObject.CM_Port;
		if port &lt;&gt; null then
			_obj.setPortOfOrigin(port.code);
		endif;
		return true;
	elseif _attrName = ETRow_MyCustomerPriority then		
		if self.cmbCustPriority.listObject &lt;&gt; null then
			_obj.CM_TrackedItem.setMyCustomerPriority(self.cmbCustPriority.listObject.CM_CustomerPriority);
			return true;	
		endif;	
	endif;

	//row not handled here, so pass back false to be handle normally
	return false;
	
epilog
	delete hazDict;
	delete spDict;
	delete sa;
end;</source>
        <access>protected</access>
        <Parameter name="_attrName" type="String" usage="io"/>
        <Parameter name="_strValue" type="String"/>
        <Parameter name="_obj" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="181ee045-84c0-4528-844c-39d6582546e3">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
//--------------------------------------------------
// Created:	13 November 2003 By: cnwgd1
// Updated: 23 July 2010 By: cnwjo3 par 25114
//--------------------------------------------------
// 04/03/2013	cnwcs5	par 31087 - new parameter for zSetXMLStrFoTblColumns
// 10 September 2023 navmv20 CR 58250 Task 58252: Jade - New mapping methods
// 11/12/2024	jlizm1	MTN 33442 Mafi load details column organiser not saved
//	9/6/25		jlier1  MTN-34771 - using display collection
vars
	obj 				: CM_Object;
	idx, fixed, numRows : Integer;
	col 				: Collection;
	invalid 			: Boolean;	
begin
	on Exception do app.handleDeletedObject(exception,obj,invalid);
	if not  _theTable.isPaginated then
		
		create col as ObjectSet transient;
		numRows := _theTable.rows;
		fixed 	:= _theTable.fixedRows + 1;
		
		
		
		foreach idx in fixed to numRows do
			invalid := false;
			obj 	:= _theTable.accessRow(idx).itemObject.CM_Object;
			
			if obj &lt;&gt; null then
				obj.creationTime(); //cause exception	
				if not invalid then
					col.add(obj);
				endif;
			endif;
		endforeach;
	
	endif;
	
	
	// Data table columns have changed, must re-display table data
	// PAR 9027 Don't inherit method as it blows away all the data populated by Search Item form 

	// This method will clear the table and display the saved col
	if _theTable = self.tblData then
		//jlier1 9/6/25 MTN-34771
		if _theTable.isPaginated then	
			self.displaySelectorResults(_theTable.getCollection, self.filterCargoTypeId);
		else
			self.displaySelectorResults(col, self.filterCargoTypeId);
		endif;
	
		// Save the entTableDef order to XLMStr 
		// must do after display so that columnWidths are stored correctly
		self.zSetXMLStrForTblColumns(_theTable, false, self.xmlStrTblData);	// par 31087 March 2013
		
		// 30/10/18 MAP TFS41134	update the user window with the changed XML immediately
		self.setUserWindowXMLForTable(self.tblData);
		
	elseif _theTable = tblView2 then //jlier1 TFS 54700 15/9/22
		//if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_TILC) then
		//10/09/2023 navmv20 CR 58250 Task 58252 - start
		if self.myCurrentObject &lt;&gt; null then
			self.zSetXMLStrForTblColumns(_theTable, false, self.xmlStrTblView2);
			
			if tblView2.myEntTableDef.name = ETDef_StorageExpDetails then
				self.loadStorageExpDetailsTable(self.myCurrentObject.CM_TrackedItem);
			elseif self.myCurrentObject.isKindOf(CM_TILC) then
			//10/09/2023 navmv20 CR 58250 Task 58252 - end
				self.loadTILCLoadDetailsTable(self.myCurrentObject.CM_TILC);
			endif; //10/09/2023 navmv20 CR 58250 Task 58252
			
			self.setUserWindowXMLForTable(self.tblView2);
		endif;
	endif;
epilog
	if col &lt;&gt; null then
		delete col;	
	endif;	
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTableForGeneralCargo" id="b094bb13-e682-477a-932a-5c8aae81953b">
        <updating/>
        <source>setTableForGeneralCargo(_obj : Object; _tbl : CM_EntryTable input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     12 May 2004	cnwth2
//
// Purpose:     When viewing general cargo items, this method will hide the table rows
//				that display attributes that are not visible on the item's product
//			 
// ----------   ----------  --------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
 23/02/2010	cnwdap1	PAR #22171 Make product attribute fields read-only
 13/05/2022	jlika1	TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
============================================================================*/

vars
	product		: CM_Product;
	prodAttr	: CM_ProductAttr;
	tbl 		: CM_EntryTable;
	entDef		: EntTableDef;
	entRow		: EntTableRow;
	attrStr		: String;
	cargoType	: CM_CargoType;
	idx			: Integer;
begin
	if not CM_TrackedItem.hasInstance(_obj) then
        return;
    endif;

	// cnwjk3 PAR 16505 - 18/11/2008
    if (not _obj.CM_TrackedItem.isBulkOrBreakBulkGeneric) then
        return;
    endif;
	
	tbl := _tbl;
	if _obj.CM_TrackedItem.myProduct &lt;&gt; null then											//cnwas3 PAR 21122 begin
		product := _obj.CM_TrackedItem.myProduct;	
		cargoType := product.myCargoType;
		if cargoType = null then // found during testing NDL  29 Jan 2014 - possibly just test data.
			cargoType := app.myRoot.allCargoTypesById[_obj.CM_TrackedItem.cargoType];
		endif;
	else
		cargoType := app.myRoot.allCargoTypesById[_obj.CM_TrackedItem.cargoType];
		product := cargoType.mySystemProductType;		
		if product = null then
			if _obj.isKindOf(CM_BreakBulk) and not _obj.isKindOf(CM_BreakBulkGeneric) then
				tbl.hideRowByName(ETRow_Colour, false);
				tbl.hideRowByName(ETRow_WidthString, false);
				tbl.hideRowByName(ETRow_LengthString, false);
				tbl.hideRowByName(ETRow_HeightString, false);
				tbl.hideRowByName(ETRow_Type, false);				
			endif;			
		endif;
	endif;
	
	if not _obj.isKindOf(CM_BreakBulkGeneric) then
		tbl.hideRowByName(ETRow_Diameter, false);
		tbl.hideRowByName(ETRow_Grade, false);
		tbl.hideRowByName(ETRow_Grammage, false);
		tbl.hideRowByName(ETRow_RollingLength, false);
	endif;
	//cnwas3 PAR 21122 end

	entDef := app.myController.getEntTableDef(ETDef_BreakBulkEnt);
	if entDef = null then
		return;
	endif;

	foreach entRow in entDef.allEntTableRows do
		attrStr := entRow.name;
		if (attrStr = ETRow_MyProduct or attrStr = ETRow_ProductGroupDesc) and not cargoType.isSubCargoTypeRequired then
			tbl.hideRowByName(attrStr, false);
		endif;
		
		if product = null then
			continue;
		endif;
		
		prodAttr := product.getProdAttrFromName(attrStr);
		if prodAttr = null then
			continue;
		endif;
		
		if cargoType.allAttributesOnProduct.includes(prodAttr.name) and prodAttr.isViewable then
		// This is the new one for after 7.4.1 release	
			if self.mode = Mode_View and self.isHideThumbnailEmtpy then
				if not tbl.isRowVisible(attrStr) then
					continue;
				endif;
			endif;
			
			idx := tbl.showRowByName(attrStr, false);
			if idx = 0 then
				continue;
			endif;
			
			//epr par 34310 22/7/14
			if attrStr = ETRow_Type then
				if _obj.isKindOf(CM_BreakBulkGeneric) then
					tbl.enableRowByName(ETRow_Type);
					tbl.accessCell(idx,2).backColor := self.colorValueColumn;
				else
					tbl.setRowReadOnly(ETRow_Type);					
				endif;
			endif;
			
			tbl.setCellText(idx, tbl.ColumnHeading, prodAttr.displayName);
			// PAR #22171 product attributes should be read-only, as they're not saved anyway
			//tbl.accessCell(idx, tbl.ColumnValue).backColor := self.READ_ONLY_COLOUR;
			if prodAttr.validationType = prodAttr.ValidationType_Codes then
				if attrStr = ETRow_WidthString then
					tbl.accessCell(idx, tbl.ColumnValue).cellControl := self.cmbWidthCodes;
				elseif attrStr = ETRow_HeightString then
					tbl.accessCell(idx, tbl.ColumnValue).cellControl := self.cmbHeightCodes;				
				elseif attrStr = ETRow_LengthString then
					tbl.accessCell(idx, tbl.ColumnValue).cellControl := self.cmbLengthCodes;				
				elseif attrStr = ETRow_Type then
					tbl.accessCell(idx, tbl.ColumnValue).cellControl := self.cmbTypeCodes;
				endif;
			endif;
		else
			tbl.hideRowByName(attrStr, false);
		endif;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTableForObject" id="2d452370-7157-4541-b915-1d7a18072683">
        <updating/>
        <source>setTableForObject(_tbl : CM_EntryTable io; _allEntTableRows : EntTableRowArray;
				 _obj : CM_Object; _entDefName : String; _isForEdit : Boolean; _maxHeadingWidth : Integer io) protected, updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 06/11/2009	cnwdap1		CCMS MES 1017 - Display over dimensions details
// 09/12/2009	cnwmh5		PAR21608 - Change so cutoff ts only displays for export
// 04/02/2010	cnwdap1		PAR #21867 Allow edit of "Vehicle" specific fields
// 24/02/2010	cnwdap1		PAR #22024 Show commodity combo if cargo type allows commdities and has some commodities
// 09/03/2010	cnwdap1		PAR #22661 Show/hide appropriate Is Weight Certified row
// 28/05/2010	cnwdap1		CCMS 1116 Tranship changes
// 28/06/2010	cnwdap1		PAR #24516 Disable selected tranship tab fields so the tab can be edited safely
// 21/07/2010	cnwdap1		PAR #25021 Correct tranship disabling
// 02/02/2011	cnwadp1		PAR #26861 CCMS POL 2031 Hide destination terminal if system is not multi-terminal
// 18/01/2013	cnwdap1		PAR #31018 CCMS POL 2223 make On Power During Transit fields read-only except for pre-notes
// 13/02/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 13/08/2013	cnwdap1		PAR #32123 Added Colour picker
// 17/09/2013	cnwdap1		PAR #32215 Colour picker is now applicable to Motor Vehicles as well as Break-Bulk Generic
// 23/06/2015	cnwdap1		PAR #36421 Hazardous Materials Handling
// 29/09/2015   cnwma1      PAR #36944 Bulk edit error
// 30/11/2015   cnwma1		PAR #36992	Hazardous Flag not cleared when Hazardous Details removed
// 15/04/2016 	cnwns1 		TFS 488 Multi Timezone
// 28/04/2016   cnwma1		PAR #37806 TFS #1910  PEN Cannot add color to BULK cargo
// 29/08/2016   cnwma1  	TFS #2607:PAR38173 STWO - Unable to edit cargo subtype
// 04/10/2016   cnwma1	    TFS #2603:JMT - Cargo Enquiry not A-Z
// 15/11/2016	cnwdap1		TFS 2842 STWR Hazardous Details Enhancements
// 07/07/2017	cnwrs1		TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 30/08/2018	jlgrh7 		TFS #413721 MSL - MGW on Cargo Enquiry
// 17/07/2019	jlgsl4		TFS 45634 - STWO - Sort 'Storage Left' and 'Free Days' numerically
// 04/11/2019	jlgdap1		TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
// 18/02/2021   cnwma1      Bug 50821: STWO - 1- Calculate storage/ demurrage charges for all cargo discharged from a vessel onto Steinweg's Terminal, either Import or Transshipment.
// 13/07/2022	navak20		TFS 53862 EUP - WMS - Damage Recording Extra Details
// 08/08/2023   navma1		Bug 55427: MTN - Cannot report damage on bulk cargo
// 11/12/2023	jlika1		TFS 61189 61645 RTL - Cargo Maintenance
// 25/06/2024	navcs2		ChangeRequest 64765: CUX | Enable change of Trailer Type when MAFI has onboard cargo - Cargo Enquiry
// 11/04/2025 	navma1  	MTN-34621 MTN - 1081 dead lock on CM_EIRNumberDict
vars
	entRow					: EntTableRow;
	rowName					: String;
	tmpValueColor			: Integer;
	rowIdx					: Integer;
	jRow					: JadeTableRow;
	useReadyToShip			: Boolean;
	bulkEditing				: Boolean;
	terminologyCargoBOLType	: CM_CargoBOLType;
	tmpStr					: String;
	tmpHeight				: Integer;
	entRowTrans				: EntTableRowTransient;
	anObj					: Object;
	viewOpImpPin 			: Boolean;	  //cnwrd1 10.11.08 CCMS JMT 1743/1764 
	viewOpExpNo 			: Boolean;	  //cnwrd1 10.11.08 CCMS JMT 1743/1764 
	editOpImpPin 			: Boolean;	  //26 Jan 2011	NDL	Par 26802
	ti, actualTI			: CM_TrackedItem;
	br  					: CM_BookingRef;
	terminal 				: CM_Terminal;	
	canBeCertified, 
	isForPreNote, 
	isDDCandidate			: Boolean;
	row						: Integer;
	tshipImex				: CM_IMEXStatus;
	sealType				: CM_SealType;
	entArray				: CM_ObjectArray;			// PAR #31155
	realTI					: CM_TILC;					// cnwmc5 - 14 March 2014 - PAR 33659
	useReleaseReceiptEIR 	: Boolean;
	handlingType 			: CM_HandlingType;
	preNoteRequiresDiscrep 	: Boolean;	//02 Nov 2018	NDL	TFS 41736
	editReadyToLoad			: Boolean;
	user					: CM_User;
begin
	/*
		Date		 Who		Reason
		12 Aug 2008	cnwdz2	    Par15507
	*/
	if _obj = null then		
		return;
	endif;
	isForPreNote  := false;
	isDDCandidate := false;
	user          := app.getMyUser;				//11.04.2025 navma1 #MTN-34621
	terminal 	  := self.myTerminal;
	if terminal = null then
		terminal := app.getMyTerminalDO_NOT_USE;
	endif;
	
	if CM_TrackedItem.hasInstance(_obj) then
		terminologyCargoBOLType := _obj.CM_TrackedItem.myCargoType;
		ti := _obj.CM_TrackedItem;  //set ti since we'll use it later in the method
		isForPreNote:=ti.isPreNote;
		
		actualTI := ti.pxyGetRealObject();
		if actualTI &lt;&gt; null then
			isDDCandidate := actualTI.isDirectDeliveryCandidate();
		else
			isDDCandidate := ti.isDirectDeliveryCandidate();
		endif;
	elseif CM_BOL.hasInstance(_obj) then
		terminologyCargoBOLType := app.myRoot.allBOLTypes[_obj.CM_BOL.bolType];	
	endif;
	
	_tbl.setTerminologyRelevant(terminologyCargoBOLType, self.myTerminal);
	
	_tbl.clearValues();
	_tbl.rows := _tbl.fixedRows;
	
	_tbl.allEntRowTransients.purge;
	_tbl.loadEntRowTransients(_entDefName, _allEntTableRows, null, 'entTableDefSetupWarning');

	useReadyToShip 	 := self.myTerminal.getConfig(UseReadyToShip).Boolean;
	tmpValueColor	 := self.colorValueColumn;
	_maxHeadingWidth := _maxHeadingWidth.max(_tbl.headingColumnWidth);
	bulkEditing 	 := self.doingMultiEdit;	
	
	
	
	//cnwrd1 10.11.08 CCMS JMT 1743/1764 
	
	
	viewOpImpPin	:= user.canDo(terminal, PmAdmOpImpReleasePinView) or user.canDo(terminal, PmAdmOpImpReleasePinEdit);//25 Jan 2011	NDL	Par 26802
	editOpImpPin	:= user.canDo(terminal, PmAdmOpImpReleasePinEdit);	//26 Jan 2011	NDL	Par 26802
	viewOpExpNo 	:= user.canDo(terminal, PmAdmOpExpReleaseNumEdit);
	editReadyToLoad := user.canDo(terminal, PmCargoReadyToLoad);
	
	//epr CCMS 1409 par 35553 22/1/15
	useReleaseReceiptEIR := terminal.getConfig(UseReceiveReleaseEIR).Boolean;
	//cnwrd1 10.11.08 CCMS JMT 1743/1764 
	if viewOpImpPin then
		_tbl.showRowByName(ETRow_ImportReleasePIN, false);
	else
		_tbl.hideRowByName(ETRow_ImportReleasePIN, false);
	endif;

	if viewOpExpNo then
		_tbl.showRowByName(ETRow_ExportReleaseNumber, false);			
	else
		_tbl.hideRowByName(ETRow_ExportReleaseNumber, false);
	endif;
		
	if not terminal.isVehicleBookingEnabled then
		_tbl.hideRowByName(ETRow_VsBookingSlot, false);
	endif;
	//04 Jun 2015	NDL	Par 36338
	if not app.isCargoGroupEnabled then
		_tbl.hideRowByName(ETRow_CargoGroup, false);
	endif;
	
	if ti &lt;&gt; null then
		self.loadConditionCodes(ti);
		if ti.bookingReference &lt;&gt; null and terminal &lt;&gt; null then		// PAR #17642
			br := terminal.getBookingReference(ti.operatorCode, ti.bookingReference.trimRight, ti.myVoyage); // adm 150908 Par 17936
		endif;
		loadBookingRefItems(br);
		
		// PAR #22661 Is the cargo type "Weight Can Be Certified" flag set?
		canBeCertified := ti.myCargoType.canWeightBeCertified;
		
		//18 Apr 2013	NDL	Par 31393
		if terminal.isVehicleBookingEnabled then
			_tbl.showRowByName(ETRow_VsBookingSlot, false);
			rowIdx := _tbl.getRowByName(ETRow_VsBookingSlot);
			if rowIdx &lt;&gt; 0 and not app.myCurrentUserCan(self.myTerminal, PmGteVehSchMaint) then 
				_tbl.setRowReadOnly(ETRow_VsBookingSlot);
			endif;
		endif;
		
		_tbl.hideRowByName(ETRow_ExpectedArrivalDate, false);	//29 Jul 2013	NDL	Par 31763
		_tbl.hideRowByName(ETRow_ExpectedArrivalTime, false);	//29 Jul 2013	NDL	Par 31763
		rowIdx := _tbl.getRowByName(ETRow_ExpectedDateTime);
		if rowIdx &lt;&gt; 0 then 
			_tbl.setRowReadOnly(ETRow_ExpectedDateTime);
			
		endif;
		
		//cnwmc5 - 19 Nov 2015 - PAR 36827
		if isForPreNote then
			_tbl.showRowByName(ETRow_WagonNumber, false);	
			_tbl.hideRowByName(ETRow_Wagon, false);
		else
			_tbl.hideRowByName(ETRow_WagonNumber, false);	
			_tbl.showRowByName(ETRow_Wagon, false);
		endif;
		
		if isForPreNote and _isForEdit then
			self.setWagonClassOnWagonIdChg();	//12 May 2014	NDL	Par 33615
		
			//29 Jul 2013	NDL	Par 31763
			if _obj.CM_TrackedItem.myVehicleBookingTimeslot = null then
				_tbl.showRowByName(ETRow_ExpectedArrivalDate, false);
				rowIdx := _tbl.getRowByName(ETRow_ExpectedArrivalDate);
				if rowIdx &lt;&gt; 0 then 
					_tbl.accessCell(rowIdx,2).backColor := tmpValueColor;
					_tbl.accessedCell.enabled := true;
				endif;
				_tbl.showRowByName(ETRow_ExpectedArrivalTime, false);
				rowIdx := _tbl.getRowByName(ETRow_ExpectedArrivalTime);
				if rowIdx &lt;&gt; 0 then 
					_tbl.accessCell(rowIdx,2).backColor := tmpValueColor;
					_tbl.accessedCell.enabled := true;
				endif;
				_tbl.hideRowByName(ETRow_ExpectedDateTime, false);
			endif;
		else
			_tbl.setRowReadOnly(ETRow_WagonClass);
		endif;
		
		//epr par 36149 4/5/15
		if (not CM_TrackedItem.hasInstance(_obj)) or
		   (not _obj.CM_TrackedItem.myCargoType.showDamageCodes) then
			_tbl.hideRowByName(ETRow_DamageDetail, false);
			_tbl.hideRowByName(ETRow_Damaged, false);
			_tbl.hideRowByName(ETRow_DamagedDT, false);
		else
			_tbl.showRowByName(ETRow_DamageDetail, false);
			_tbl.showRowByName(ETRow_Damaged, false);
			_tbl.showRowByName(ETRow_DamagedDT, false);
		endif;
		
		if ti.isKindOf(CM_Container) then																					//+TFS41372
				_tbl.showRowByName(ETRow_MaxTotalWeight, false);
			else
				_tbl.hideRowByName(ETRow_MaxTotalWeight, false);
		endif;
		
		rowIdx := _tbl.getRowByName(ETRow_GeneralLandingDate);      // 18.02.2021 cnwma1 #50821 
		if rowIdx &lt;&gt; 0 then 
			_tbl.setRowReadOnly(ETRow_GeneralLandingDate);
		endif;
		
		//08/10/2025	navkc1 JIRA 36144
		if not ti.isRotatableContainer() then
			_tbl.hideRowByName(ETRow_MyCarProduct, false);
			_tbl.hideRowByName(ETRow_MyCargoTypeForContents, false);
		endif;
	endif;	
	
	//12 Nov 2018	NDL	TFS 41736
	if ti &lt;&gt; null and ti.isNotified then
		preNoteRequiresDiscrep := terminal.getConfig( AllowPrenoteDiscrep ).Boolean;
	endif;
	create entArray transient;	
	
	foreach entRow in _allEntTableRows do
		rowName := entRow.name;
		rowIdx  := _tbl.getRowByName(rowName);
		jRow    := _tbl.accessRow(rowIdx);
		
		if self.setGeneralCargoInfoRows(_tbl, _obj, entRow.name ) then	// 35199 if hidden then skip the rest of the code as it can show them again
			continue;
		endif;
		
		self.setRowSpecifics(_obj, _tbl, jRow, _isForEdit, bulkEditing);
		//jlier1 MTN-34671 23/4/25
		if entRow.measurementType &lt;&gt; null then
			entArray.add(entRow);
		endif;
		
		// CCMS 1875
		if entRow.name = ETRow_MySubTerminal then
			if (not app.isSubTerminalsOn(terminal)) then
				_tbl.hideRowByName(ETRow_MySubTerminal, false);
			elseif not self.allowSubTerminalUpdate then	//27 Nov 2014	NDL	Par 35295
				_tbl.setRowReadOnly(entRow.name);
			endif;
		endif;
		
		//08 May 2015	NDL	Par 36181
		if entRow.name = ETRow_CompanyCode then
			if not self.allowSubTerminalUpdate then
				_tbl.setRowReadOnly(entRow.name);
			endif;
		endif;

		if (entRow.name = ETRow_ReadyToShip) and (not useReadyToShip) then
			_tbl.hideRowByName(entRow.name, false);
			continue;	
		endif;

		if (entRow.name = ETRow_WeighbridgeNo) and (not terminal.getConfig(WeighBridgeEnabled).Boolean) then 
			_tbl.hideRowByName(entRow.name, false);
		endif;
		
		// 09/12/2009 cnwmh5 #21608 - Start
		if entRow.name = ETRow_CutoffTS then
			if _obj.CM_TrackedItem.getImExStatus() = TI_IMEX_STATUS_EXPORT then
				_tbl.showRowByName(ETRow_CutoffTS, false);
			else
				_tbl.hideRowByName(ETRow_CutoffTS, false);
			endif;
		endif;
		
		//epr CCMS 1409 par 35553 22/1/15
		if entRow.name = ETRow_EirNumber then
			if useReleaseReceiptEIR then
				_tbl.hideRowByName(	ETRow_EirNumber,false);
				continue;
			else
				_tbl.showRowByName(	ETRow_EirNumber,false);	
			endif;
		endif;
		if entRow.name = ETRow_ReceiveEIR then
			if useReleaseReceiptEIR then
				_tbl.showRowByName(	ETRow_ReceiveEIR,false);			
			else
				_tbl.hideRowByName(	ETRow_ReceiveEIR,false);
				continue;
			endif;
		endif;
		if entRow.name = ETRow_ReleaseEIR then
			if useReleaseReceiptEIR then
				_tbl.showRowByName(	ETRow_ReleaseEIR,false);			
			else
				_tbl.hideRowByName(	ETRow_ReleaseEIR,false);
				continue;
			endif;
		endif;
		
		if entRow.name = ETRow_InputDT then
			tmpStr := _obj.getDisplayStringForAttribute(entRow.name, false);
			//jlier1 MTN-34671 23/4/25 have the rowIdx use that rahter than looking through all the rows again
			_tbl.setValue(rowIdx, tmpStr);
			continue;
		endif;
		
		if _isForEdit then			
			if entRow.name = ETRow_MyCustomerPriority and _obj.isKindOf(CM_TrackedItem) then // For Cargo Priority we are displaying the lowest possible value when the value is null so the display migt be different from the value
				tmpStr := _obj.CM_TrackedItem.getDisplayMyCustomerPriority();
				//jlier1 MTN-34671 23/4/25 have the rowIdx use that rahter than looking through all the rows again
				_tbl.setValue(rowIdx, tmpStr);
			elseif not self.setEditValueForRow(_tbl, entRow.name, _obj) then //incase it's different to the display string
				tmpStr := _obj.getDisplayStringForAttribute(entRow.name, false);
				//jlier1 MTN-34671 23/4/25 have the rowIdx use that rahter than looking through all the rows again
				_tbl.setValue(rowIdx, tmpStr);
			elseif entRow.name = ETRow_Remarks then
				// hack so we have the remarks below
				tmpStr := _obj.getDisplayStringForAttribute(entRow.name, false);
			endif;
				
		else

			tmpStr := _obj.getDisplayStringForAttribute(entRow.name, false);
			
			if self.isHideThumbnailEmtpy then
				if self.hideEmptyRow(_tbl,entRow,tmpStr) then
					continue;
				endif;
			endif;
			//jlier1 MTN-34671 23/4/25 have the rowIdx use that rahter than looking through all the rows again
			_tbl.setValue(rowIdx, tmpStr);
		endif;
		

		if entRow.name = ETRow_Remarks 
		or entRow.name = ETRow_TranshipRemarks
		or entRow.name = ETRow_Info then
			_tbl.accessCell(rowIdx, CM_EntryTable.ColumnValue).wordWrap := true;
			if tmpStr &lt;&gt; null then
				tmpHeight := _tbl.getTextHeightForWidth(tmpStr, _tbl.accessColumn(CM_EntryTable.ColumnValue).width - 18).Integer + 10; 	// add fudge factor
				jRow.height := tmpHeight;
			endif;
		endif;
		
		//added by cnwyl1 15/05/2008 for par 16556
		if entRow.name = ETRow_Temperature then
			self.txtTempC.text := tmpStr;
		endif;
		
		if entRow.name = ETRow_TemperatureInFahrenheit then
			self.txtTempF.text := tmpStr;
		endif;
		//////////////////////////
				
		if entRow.name = ETRow_TotalWeight then
			// ### CCMS 1420
		//	if (not app.getMyUser.canDo(self.myTerminal, PmAdmWeightOverride)) then	
			if (not app.getMyUser.canDo(self.myTerminal, PmAdmWeightOverride))
			or (_obj.isKindOf(CM_TILC) and not _obj.CM_TILC.canUpdateTotalWeight())	//24 feb 2014	NDL	Par 33561   //15/10/2025	navkc1 JIRA 36057
			or (_obj.isKindOf(CM_Bulk) and ((_obj.CM_Bulk.myCargoType.isTrackByWeight and ( ( not ti.isNotified ) or preNoteRequiresDiscrep) )
										or _obj.CM_Bulk.myCargoType.isTrackByVolume))
			//epr CCMS 1366 must change weight with discepancy
			or _obj.isKindOf(CM_CargoGroup)	//03 Jun 2015	NDL	Par 36338
			then	
				//epr tfs 1707 5/4/16			
				_tbl.setRowReadOnly(ETRow_TotalWeight);
			endif;
			
		endif;
		
		if entRow.name = ETRow_TotalVolume then
			if (_obj.isKindOf(CM_Bulk) and _obj.CM_Bulk.myCargoType.isTrackByVolume and ( ( not ti.isNotified ) or preNoteRequiresDiscrep) )
			or _obj.isKindOf(CM_CargoGroup)	//03 Jun 2015	NDL	Par 36338
			then
				//epr tfs 1707 5/4/16
				_tbl.setRowReadOnly(ETRow_TotalVolume);
			endif;
			
		endif;
		
		// CCMS 1017 Over Dimensions details for containers
		if _obj.isKindOf(CM_Container) then
				
			if entRow.name.isOneOf(ETRow_OverHeight, ETRow_OverLengthBack, ETRow_OverLengthFront, ETRow_OverWidthLeft, ETRow_OverWidthRight) then
					_tbl.showRowByName(entRow.name, false);
			elseif entRow.name.isOneOf(ETRow_Width, ETRow_Height, ETRow_Length) then
				_tbl.hideRowByName(entRow.name, false);
			endif;
		else
			//jlier1 TFS 54700 1/9/22
			if _obj.isKindOf(CM_TILC) then
				if entRow.name = ETRow_OverHeight then
					_tbl.showRowByName(entRow.name, false);
				endif;
			else
				if entRow.name.isOneOf(ETRow_OverHeight, ETRow_OverLengthBack, ETRow_OverLengthFront, ETRow_OverWidthLeft, ETRow_OverWidthRight) then
					_tbl.hideRowByName(entRow.name, false);
				endif;
			endif;
			
			if entRow.name.isOneOf(ETRow_Width, ETRow_Height, ETRow_Length) then
				_tbl.showRowByName(entRow.name, false);
			endif;
		endif;
		
		if entRow.name = ETRow_DriversPieceCount then
			if _tbl.accessCell(_tbl.getRowByName(ETRow_PieceCountError),2).text &lt;&gt; app.getErrorString(Yes) then
				_tbl.hideRowByName(entRow.name,false);
			else
				_tbl.showRowByName(entRow.name,false);
			endif;
		endif;

		// PAR #21867 show/hide vehicle-specific fields as appropriate
		if not CM_Car.hasInstance(_obj) and entRow.name.isOneOf(ETRow_IsSelfPropelled, ETRow_HasRadio) then
			_tbl.hideRowByName(entRow.name, false);
		endif;
		// PAR# 21867 end
		
		if entRow.name = ETRow_WeightTare or entRow.name = ETRow_WeightCargo then
			if _obj.CM_TrackedItem.myCargoType.useTareCargoWeight then
				//epr tfs 1707 5/4/16
				//24 Feb 2014	NDL	Par 33561
				if  _obj.isKindOf(CM_TILC) and  entRow.name = ETRow_WeightCargo then	
					_tbl.setRowReadOnly(entRow.name);		
				endif;
				_tbl.showRowByName(entRow.name, false);
			else
				_tbl.hideRowByName(entRow.name, false);
			endif;
		endif;
		
		// PAR #22024 show commodity if cargo type needs one
		if entRow.name.isOneOf( ETRow_Commodity, ETRow_CommodityGroup) then
			if _obj.CM_TrackedItem.myCargoType.isCommodityRequired or not _obj.CM_TrackedItem.myCargoType.allCommodities.isEmpty then
				_tbl.showRowByName(entRow.name, false);
			else
				_tbl.hideRowByName(entRow.name, false);
			endif;
		endif;
		
		// PAR #22661 show/hide appropriate Is Weight Certified line
		if entRow.name = ETRow_IsWeightCertified and not canBeCertified then
			_tbl.hideRowByName(entRow.name, false);
		elseif entRow.name = ETRow_IsWeightCertifiedRO and canBeCertified then
			_tbl.hideRowByName(entRow.name, false);
		endif;
		
		if entRow.name = ETRow_PackTempC then //+ cnwmd1 CCMS 1871
			if _obj.CM_TrackedItem.showTemperatureInFahrenheit() then
				_tbl.hideRowByName(entRow.name, false);
			else
				_tbl.showRowByName(entRow.name, false);
			endif;
		endif;
		if entRow.name = ETRow_PackTempF then //+ cnwmd1 CCMS 1871
			if _obj.CM_TrackedItem.showTemperatureInFahrenheit() then
				_tbl.showRowByName(entRow.name, false);
			else
				_tbl.hideRowByName(entRow.name, false);
			endif;
		endif;
		
		// PAR #23645 CCMS 1116 Disable imex status row if imex status is Tranship
		if entRow.name = ETRow_ImexStatus then
			tshipImex := app.myRoot.allImexStatuses[TI_IMEX_STATUS_TRANSHIP];
			if _obj.CM_TrackedItem.isTranshipItem then
				_tbl.setRowReadOnly(entRow.name);			
				if self.cmbImExStatus.findObject(tshipImex) = null then
					self.cmbImExStatus.addItemObject(tshipImex.description, tshipImex);
				endif;
			else
				_tbl.accessCell(_tbl.getRowByName(ETRow_ImexStatus),2).backColor := White;
				_tbl.accessedCell.enabled := true;
				self.cmbImExStatus.removeObject(tshipImex);
			endif;
		endif;
		// and disable "Is Tranship" row
		if entRow.name = ETRow_IsTranshipItem then
			_tbl.setRowReadOnly(entRow.name);	
		endif;			
		// PAR #23645 CCMS 1116 end
		// PAR #24516 Disable Inbound Stowage, Actual Location, Planned Location, 
		// Inbound Voyage and Inbound Voyage Load Port on Tranship tab
		//if entRow.name.isOneOf(ETRow_TranshipImportStowage, ETRow_TranshipActualLocation, ETRow_TranshipPlannedLocation, ETRow_ImportVoyageCode, ETRow_OriginalLoadPort) then		// PAR #25021
		if entRow.name.isOneOf(ETRow_TranshipImportStowage, ETRow_TranshipActualLocation, ETRow_TranshipPlannedLocation, ETRow_TranshipImportVoyage, ETRow_OriginalLoadPort) then	// PAR #25021
			_tbl.setRowReadOnly(entRow.name);	
		endif;
		// Disable Outbound Voyage if Ti is on the export ship
		if entRow.name = ETRow_TranshipExportVoyage then
			//if _obj.CM_TrackedItem.isOnShip and _obj.CM_TrackedItem.myVoyage = _obj.CM_TrackedItem.myExportVoyage then				// PAR #25021
			if _obj.CM_TrackedItem.site = TI_SITE_ONSHIP and _obj.CM_TrackedItem.myVoyage = _obj.CM_TrackedItem.myExportVoyage then		// PAR #25021
				_tbl.setRowReadOnly(entRow.name);
			else
				_tbl.accessCell(_tbl.getRowByName(ETRow_TranshipExportVoyage),2).backColor := White;
				_tbl.accessedCell.enabled := true;
			endif;
		endif;
		// PAR #24516 end
		
		//+cnwml2 PAR23715 SFW CCMS1131
		// 28459 rows prevSealNum and sealDT have been removed from the StatusData table but keep the code here
		if entRow.name = ETRow_SealNum  or
			entRow.name = ETRow_PrevSealNum or
			entRow.name = ETRow_SealDT or
			entRow.name = ETRow_SealNumShippers or
			entRow.name = ETRow_SealNumCustoms or
			entRow.name = ETRow_SealNumVent	or
			entRow.name = ETRow_SealNumTerminalOperator or
			entRow.name = ETRow_SealNumUnknown or
			entRow.name = ETRow_OtherSeals then		// 28459 'otherSeals' used to trigger soft seal display
				_tbl.hideRowByName(entRow.name, false);
		endif;	
		// Nov 2011 28459, keep the seals for which there is an explicit row as these can be configured to separate tabs
		if _obj.isKindOf(CM_TrackedItem) then
			//epr par 36149 1/5/15
			sealType:=null;
			if entRow.name = ETRow_SealNum then
				sealType := app.myRoot.getSealType( SealType_Operator );			
			elseif entRow.name = ETRow_SealNumShippers then
				sealType := app.myRoot.getSealType( SealType_Shipper );
			elseif entRow.name = ETRow_SealNumCustoms then
				sealType := app.myRoot.getSealType( SealType_Customs );
			elseif entRow.name = ETRow_SealNumVent then
				sealType := app.myRoot.getSealType( SealType_Vent );
			elseif entRow.name = ETRow_SealNumTerminalOperator then
				sealType := app.myRoot.getSealType(SealType_TerminalOperator);
			elseif entRow.name = ETRow_SealNumUnknown then
				sealType := app.myRoot.getSealType(SealType_Unknown);
			endif;
			//epr par 36149 1/5/15
			if sealType &lt;&gt; null then
				if sealType.allCargoTypes.includes( ti.myCargoType ) then
					self.insertSealType(_tbl, sealType, rowIdx);
				endif;
			endif;
		endif;
		
		//+cnwml2 PAR23715 SFW CCMS1131
		if _obj.isKindOf(CM_TrackedItem) then
			//jlier1 TFS 54700 31/8/22
			if entRow.name = ETRow_ContentsStatus then	
				if not ti.isContainer and not ti.isChassis then
					_tbl.hideRowByName(entRow.name, false);
				else
					if ti.isContainer then
						_tbl.setRowReadOnly(entRow.name);
					endif;
				endif;
			endif;
		
			if not ti.isContainer then
				if 	entRow.name = ETRow_IsClean or
					entRow.name = ETRow_OffsiteCleaned or
					entRow.name = ETRow_WashDT or
					entRow.name = ETRow_OffsitePreTrip or
					entRow.name = ETRow_IsHeavyDuty then
						_tbl.hideRowByName(entRow.name, false);
				endif;
							
			endif;
			
			if	entRow.name = ETRow_AvailabilityGrade and  not ti.canSetAvailabilityGrade then
				_tbl.hideRowByName(entRow.name, false);
			endif;
		endif;
		//+cnwml2 PAR26349
		if entRow.name = ETRow_AllSpecialLifts then
			self.lstTblSpecialLif.allSelectedObjects.clear();		//cnwas3 par 28156
			if _obj.CM_TrackedItem.allSpecialLifts.size &gt; 0 then				
				_obj.CM_TrackedItem.allSpecialLifts.copy(self.lstTblSpecialLif.allSelectedObjects);
			endif;
		endif;
		
		//26 Jan 2011	NDL	Par 26802
		if entRow.name = ETRow_ImportReleasePIN then
			if editOpImpPin then
				_tbl.accessCell(_tbl.getRowByName(ETRow_ImportReleasePIN),2).backColor := White;
				_tbl.accessedCell.enabled := true;
			elseif viewOpImpPin then
				_tbl.setRowReadOnly(entRow.name);
			endif;
		endif; 
		
		
		if  entRow.name = ETRow_TotalQuantity then	
			if ti &lt;&gt; null and ((ti.myCargoType.isBreakBulkMulti and ( ( not ti.isNotified ) or preNoteRequiresDiscrep ) ) )
			or _obj.isKindOf(CM_CargoGroup)	//03 Jun 2015	NDL	Par 36338
			then
				_tbl.setRowReadOnly(entRow.name);
			elseif ti &lt;&gt; null and not ti.myCargoType.isBreakBulkMulti then
				_tbl.hideRowByName(ETRow_TotalQuantity, false);
			endif;
		endif;
		
		// PAR #26861 hide destination terminal row if system only has one terminal
		if entRow.name = ETRow_DestTerminalForPrenote and app.myRoot.allTerminals.size = 1 then
			_tbl.hideRowByName(ETRow_DestTerminalForPrenote, false);
		endif;
		
		//18 Jul 2011	NDL	Par 27868
		if entRow.name = ETRow_ContainerVolume then
			if _obj.isKindOf(CM_Container) then
				_tbl.showRowByName(entRow.name, false);
				_tbl.setRowReadOnly(entRow.name);
			else
				_tbl.hideRowByName(entRow.name, false);
			endif;
		endif;
		
		//18 Jul 2011	NDL	Par 27868
		
		if entRow.name = ETRow_Volume then
			if _obj.isKindOf(CM_Container) then
				_tbl.showRowByName(entRow.name, false);
			else
				if _entDefName = ETDef_GeneralData then
					_tbl.hideRowByName(entRow.name, false);
				else
					_tbl.showRowByName(entRow.name, false);
				endif;
			endif;
		endif;
		
		//epr ccms 2274 6/5/13
		if entRow.name = ETRow_Density then
			if _obj.isKindOf(CM_Container) then
				_tbl.showRowByName(entRow.name, false);
			else
				if _entDefName = ETDef_GeneralData then
					_tbl.hideRowByName(entRow.name, false);
				else
					_tbl.showRowByName(entRow.name, false);
				endif;
			endif;
		endif;
		// PAR #31018 On Power During Transit fields are read-only except for pre-notes																// PAR #31018
		if entRow.name.isOneOf(ETRow_OnPowerDuringTransit, ETRow_TransitOnPowerDate, ETRow_TransitOnPowerTime, ETRow_TransitOnPowerRemarks) then	// PAR #31018
			if not _obj.CM_TrackedItem.isPreNote then																								// PAR #31018
				_tbl.setRowReadOnly(entRow.name);																					// PAR #31018
			endif;																																	// PAR #31018
		endif;																																	// PAR #31018

		if entRow.name = ETRow_ReceiveVisit then   //29/09/2015 cnwma1 PAR #36944
				entRowTrans := _tbl.accessRow(_tbl.getRowByName(entRow.name)).itemObject.EntTableRowTransient;
				if entRowTrans &lt;&gt; null and entRowTrans.name = ETRow_ReceiveVisit then
					entRowTrans.setPropertyValue("inputEnabled", false); 
				endif;
		endif;
		
		if entRow.name = ETRow_ReleaseVisit then   //29/09/2015 cnwma1 PAR #36944
				entRowTrans := _tbl.accessRow(_tbl.getRowByName(entRow.name)).itemObject.EntTableRowTransient;
				if entRowTrans &lt;&gt; null and entRowTrans.name = ETRow_ReleaseVisit then
					entRowTrans.setPropertyValue("inputEnabled", false); 
				endif;
		endif;
		
		if entRow.name = ETRow_VsBookingSlot  then  //29/09/2015 cnwma1 PAR #36944
				entRowTrans := _tbl.accessRow(_tbl.getRowByName(entRow.name)).itemObject.EntTableRowTransient;
				if entRowTrans &lt;&gt; null and entRowTrans.name = ETRow_VsBookingSlot then
					entRowTrans.setPropertyValue("inputEnabled", false); 
				endif;
		endif;		
			
		//epr CCMS 2274 28/5/13 if cargo can be split/merged hide declared weight
		if entRow.name = ETRow_WeightDeclared then
			if _obj.CM_TrackedItem.canMergeBreakBulk
			or _obj.CM_TrackedItem.hasBeenMerged
			or _obj.isKindOf(CM_TILC)	//25 Feb 2014	NDL	Par 33561
			then
				_tbl.hideRowByName(entRow.name, false);
			else
				_tbl.showRowByName(entRow.name, false);
			endif;
		endif;
		
		if entRow.name = ETRow_Colour then																	// PAR #32123
			if _obj.isKindOf(CM_Bulk) then									//28/04/2016 cnwma1 PAR #37806 TFS #1910 
				_tbl.hideRowByName(entRow.name, false);
			endif;
			
			//if not self.myTerminal.getConfig(ValidateColour).Boolean or not _obj.isKindOf(CM_BreakBulkGeneric) then	// PAR #32123
			if self.myTerminal.getConfig(ValidateColour).Boolean 											// PAR #32215
			and (_obj.isKindOf(CM_BreakBulkGeneric) or _obj.isKindOf(CM_Car)) then							// PAR #32215
				self.myAssistant.setColourDetails(_obj.CM_TrackedItem.getColour, self.lstColour, null);	// PAR #32123
			else																							// PAR #32215
				foreach anObj in _tbl.allEntRowTransients do												// PAR #32123
					entRowTrans := anObj.EntTableRowTransient;												// PAR #32123
					if entRowTrans.name = ETRow_Colour then													// PAR #32123
						row := _tbl.getRowByControlName(entRowTrans.controlName);							// PAR #32123
						_tbl.accessCell(row, _tbl.columns).cellControl := null;								// PAR #32123
						entRowTrans.setControlName(null);													// PAR #32123
					endif;																					// PAR #32123
				endforeach;																					// PAR #32123
			endif;																							// PAR #32123																						// PAR #32123
		endif;
		// PAR #32123
		
		if entRow.name = ETRow_MyCarProduct and (_obj.isKindOf(CM_Car) or _obj.isKindOf(CM_Container)) then //29/08/2016 cnwma1 TFS #2607 PAR #38173
			if _obj.isKindOf(CM_Container) then //02/10/2025	navkc1 JIRA 36144 
				self.myAssistant.comboBoxProduct(self.cmbProduct, _obj.CM_TrackedItem.getCargoTypeForContents(), null, _obj.CM_TrackedItem.myProduct);
			else
				self.myAssistant.comboBoxProduct(self.cmbProduct, _obj.CM_TrackedItem.myCargoType, null, _obj.CM_TrackedItem.myProduct);
			endif;
		endif;
		//epr   par 32357 16/9/13
		if  entRow.name = ETRow_ReceiptTransportMode then
			if (isForPreNote and _isForEdit) then
				_tbl.enableRow(rowIdx);
				_tbl.setControl(rowIdx,self.cmbRecTransMode);
				_tbl.accessCell(rowIdx,2).inputType:=Table.InputType_TextBox;		
				_tbl.accessCell(rowIdx,2).backColor := tmpValueColor;													
			else
				_tbl.disableRow(rowIdx);	
				_tbl.accessCell(rowIdx,2).inputType:=Table.InputType_None;
			endif;		
		endif;
		
		if entRow.name = ETRow_ReceiptTransModePreNote then
			_tbl.hideRowByName(entRow.name, false);
		endif;

		if  entRow.name = ETRow_IsDirectDelivery then

			if (isDDCandidate) then
				_tbl.enableRow(rowIdx);
				_tbl.accessCell(rowIdx,2).backColor := tmpValueColor;
			else
				_tbl.setRowReadOnly(entRow.name);
			endif;
		endif;
		
		//cnwmc5 - 14 March 2014 - PAR 33659
		if  entRow.name = ETRow_TrailerTypeUpd then
			if ti.isTILC then									// 25/06/2024 navcs2 ChangeRequest 64765
				if ti.isTransient then
					realTI := ti.pxyGetRealObject.CM_TILC;
				else	
					realTI := ti.CM_TILC;
				endif;
				if not self.myTerminal.getConfig(AllowTrailerChange).Boolean and (realTI.hasAssociatedTIs and not self.myTerminal.roadProcessIsASPA) then		// 25/06/2024 navcs2 ChangeRequest 64765
					_tbl.setRowReadOnly(entRow.name);
				endif;
			endif;
		endif;
		
		// PAR #36421 If terminal config option UseDetailedHazEntry is set, and this TI		// PAR #36421
		// has children, use the Hazardous Chidren form to maintain them. Otherwise			// PAR #36421
		// just use the standard hazard list 												// PAR #36421
	
		if entRow.name = ETRow_AllTIHazardsNew then 										// PAR #36421
			if self.myTerminal.getConfig(UseDetailedHazEntry).Boolean then					// PAR #36421
			//	if ti.hasChildren then														// PAR #36421 //30/11/2015 cnwma1 PAR #36992
					_tbl.accessCell(rowIdx,2).backColor := self.TXN_RELATED_COLOUR;			// PAR #36421
					_tbl.accessedCell.inputType := 0;										// PAR #36421
			//	else																		// PAR #36421 //30/11/2015 cnwma1 PAR #36992
			//		_tbl.hideRowByName(entRow.name, false);									// PAR #36421 //30/11/2015 cnwma1 PAR #36992
			//	endif;																		// PAR #36421 //30/11/2015 cnwma1 PAR #36992
			else																			// PAR #36421
				_tbl.hideRowByName(entRow.name, false);										// PAR #36421
			endif;																			// PAR #36421
		endif;																				// PAR #36421
		if entRow.name = ETRow_AllTIHazards then											// PAR #36421
			if self.myTerminal.getConfig(UseDetailedHazEntry).Boolean then					// PAR #36421
			//	if ti.hasChildren then														// PAR #36421 //30/11/2015 cnwma1 PAR #36992
					_tbl.hideRowByName(entRow.name, false);									// PAR #36421
			//	endif;																		// PAR #36421 //30/11/2015 cnwma1 PAR #36992
			else																	// TFS 2842
				_tbl.accessCell(rowIdx, 2).backColor := self.TXN_RELATED_COLOUR;	// TFS 2842
				_tbl.accessedCell.inputType := 0;									// TFS 2842
				_tbl.accessedCell.cellControl := null;								// TFS 2842
			endif;																			// PAR #36421
		endif;																				// PAR #36421

		//epr TFS 3581 7/3/17 
		if entRow.name = ETRow_HasExternalMonitoring then
			if not app.myPassport.myUser.canDo(self.myTerminal,PmAdmIsExternallyMonitored) then
				_tbl.setRowReadOnly(entRow.name);
			endif;
		endif;
		
		if entRow.name = ETRow_HandlingType then	//06 Apr 2017	NDL	TFS 3424
			if ti &lt;&gt; null then
				handlingType := ti.getHandlingType();
				if handlingType &lt;&gt; null and handlingType.hasSubTypes() then
					_tbl.accessCell(rowIdx, 2).backColor := self.TXN_RELATED_COLOUR;
				endif;
			endif;
		endif;

		if entRow.name = ETRow_FreeStorageDaysRemaining or entRow.name = ETRow_FreeStorageDaysAssigned then // --&gt; TFS 45634
			_tbl.setRowReadOnly(entRow.name);
		endif; // &lt;-- TFS 45634
		
		// TFS 46405 start
		if entRow.name = ETRow_FlatRackStatus then
			if not ti.isContainer or not ti.CM_Container.isFlat then
				_tbl.hideRowByName(ETRow_FlatRackStatus, false);
			endif;
		endif;
		// TFS end
		
		//jlier1 TFS 54700 5/9/22
		if entRow.name = ETRow_TrailerLocation or
			entRow.name = ETRow_TrailerID or
			entRow.name = ETRow_TrailerOperator or
			entRow.name = ETRow_HighestCargoHeight then
			if not ti.isOnTrailer then
				_tbl.hideRowByName( entRow.name, false);
			else
				if ti.isOnMAFI then
					if entRow.name = ETRow_TrailerID then
						_tbl.setHeadingByName(entRow.name, app.getErrorString(MAFI_ID));
					elseif entRow.name = ETRow_TrailerLocation then
						_tbl.setHeadingByName(entRow.name, app.getErrorString(Mafi_location));		
					elseif entRow.name = ETRow_TrailerOperator then
						_tbl.setHeadingByName(entRow.name, app.getErrorString(Mafi_operator));		
					endif;
				endif;
			endif;
		endif;
		
		
		if entRow.name = ETRow_HsCodeSearcher then
			_tbl.accessCell(rowIdx,2).backColor := self.TXN_RELATED_COLOUR;			
			_tbl.accessedCell.inputType := 0;		
		endif;
		
		
	endforeach;
	
	loadDebtorTypes(_tbl, _entDefName); //ccms CP 1047 cnwgb1 10 April 2008
	
	self.loadSealTypes(_tbl, _entDefName);				//+cnwml2 PAR23715 SFW CCMS1131
	
												// PAR #31155
	
	self.loadMeasurementTypes(_tbl, _entDefName, entArray, _isForEdit);		// PAR #31155
	delete entArray;														// PAR #31155

	//cnwjo3, par 22756
	if ti &lt;&gt; null then
		loadBookingRefItems(ti.myBookingRef);
	endif;
	
	
	_tbl.changeMode := _tbl.ChangeMode_FirstOnly;
	
	if _isForEdit then
		if bulkEditing then
			_tbl.changeMode := _tbl.ChangeMode_All;	
			//+cnwml2 PAR24259
			foreach row in 1 to _tbl.rows do
				entRowTrans := _tbl.accessRow(row).itemObject.EntTableRowTransient;
				if entRowTrans &lt;&gt; null then
					entRowTrans.hasChanged := false;
				endif;		
			endforeach;
		endif;
		_tbl.userInputEnabled := true;
	else
		//_tbl.userInputEnabled := false;				//-cnwml2 PAR24389
	endif;
		
	_tbl.cnEcResizeContents();
	
	if self.isShowingAlphabetised   //04/10/2016 cnwma1 TFS #2603
	and _tbl.name = "tblEdit1" then
		_tbl.zOrder(0);
	endif;	
	
	// 13.07.2022 navak20 TFS 53862
	if ti &lt;&gt; null  and ti.myCargoType.showDamageCodes then						//08.08.2023 navma1 #55427
		if ti.myCargoType.isBulk or ti.myCargoType.isBreakBulk then
			_tbl.showRowByName(ETRow_RepairDetail, false);
		else
			_tbl.hideRowByName(ETRow_RepairDetail, false);
		endif;
		
		if ti.myCargoType.isBulk or ti.myCargoType.isBreakBulk then
			_tbl.showRowByName(ETRow_DamageDetail, false);
		endif;
		
		if ti.allDamageInstancesByPos.size &lt;&gt; 0 then
			_tbl.hideRowByName(ETRow_HasNewDamage, false);
			_tbl.setValueByName(ETRow_HasNewDamage, false);
		endif;
		
		if self.myTerminal.getConfig(DamageDetailsOptional).Boolean and not ti.damaged then
			_tbl.showRowByName(ETRow_HasNewDamage, false);
			_tbl.hideRowByName(ETRow_Damaged, false);
		else
			_tbl.hideRowByName(ETRow_HasNewDamage, false);
			_tbl.showRowByName(ETRow_Damaged, false);
		endif;
		
	else
		_tbl.hideRowByName(ETRow_RepairDetail, false);						//08.08.2023 navma1 #55427
		_tbl.hideRowByName(ETRow_RepairDT, false);							//08.08.2023 navma1 #55427
	endif;
	// 13.07.2022 navak20 TFS 53862
	
	// ### TFS 55215 18Nov2022 NAVPW1
	if ti &lt;&gt; null then
		_tbl.showRowByName(ETRow_CustomsReferences, false);
	endif;
	// ### TFS 55215 18Nov2022 NAVPW1
	
	if not editReadyToLoad then
		_tbl.setRowReadOnly(ETRow_ReadyToLoad);
	endif;
	
	_tbl.visible := true;

end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_EntryTable" usage="io"/>
        <Parameter name="_allEntTableRows" type="EntTableRowArray"/>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_entDefName" type="String"/>
        <Parameter name="_isForEdit" type="Boolean"/>
        <Parameter name="_maxHeadingWidth" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setTblSearchFromSelector" id="5e1b9bd0-ec79-4f37-a9d8-4cd2a714a192">
        <updating/>
        <source>setTblSearchFromSelector() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Nov 2019	jlger1	Initial creation TFS 47132

*/

vars
	context : String;
begin
	if self.cmbSelector.getCurrentItemObject = null then
		context:=CM_ContainerEnqForm.name;
	endif;
	
	self.tblSearch.setTableFromSelector(self.myCriteriaLineHolder,context,self.frmArgument,CM_ContainerEnqForm::doCmbSearchTableEvent);
	self.adjustSearcherHeight;
	
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setUserWindowXMLForTable" id="888101bf-49cc-4b84-9ddc-3dcd7ba2f13b">
        <source>setUserWindowXMLForTable(_theTable: CM_DataTable input);
/*

Purpose:				Taken from CM_ContainerEnqForm::setTableDataFromOrganiser
						Updates the xml on UserWindow with the new values for the table

Parameters:			

Return Value:		

Date					Who		Reason
11 December 2024		jlizm1	Initial creation MTN 33442 Mafi load details column organiser not saved

*/

vars
	tableText		: String;
	xml				: String;
	supercededXML	: String;
	replacementXML	: String;
	userWindow		: CM_UserWindow;
	
begin
	if _theTable = null then
		return;
	endif;
	
	tableText := _theTable.XMLTag_Table &amp; _theTable.name;
	userWindow := app.getUserWindow(self.name, true);
	xml := userWindow.xmlInfo;
	
	if _theTable = self.tblData then
		replacementXML := global.formatAsXMLPrefix(tableText) &amp; self.xmlStrTblData.cnEcGetTagValueOfName(tableText).trimBlankCharacters() &amp; CrLf &amp; global.formatAsXMLSuffix(tableText);
	elseif _theTable = self.tblView2 then
		replacementXML := global.formatAsXMLPrefix(tableText) &amp; self.xmlStrTblView2.cnEcGetTagValueOfName(tableText).trimBlankCharacters() &amp; CrLf &amp; global.formatAsXMLSuffix(tableText);
	else
		return;
	endif;
	
	if xml = null then
		xml := replacementXML;
	else
		supercededXML := xml.cnEcGetTagValueOfName(tableText);
		if supercededXML.length &gt; 2 and supercededXML[1:2] = CrLf then
			supercededXML := supercededXML[3:end];
		elseif supercededXML = CrLf then
			supercededXML := null;
		endif;
		supercededXML := global.formatAsXMLPrefix(tableText) &amp; supercededXML &amp; global.formatAsXMLSuffix(tableText);
		xml := xml.replaceString(supercededXML, replacementXML);
	endif;
	
	userWindow.CM_UserWindowForOpen.setProxy(app.getMyUser, self.name, xml, self.top, self.left, self.width, self.height, self.windowState);
	
epilog

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setVolumeFromHLW" id="26a4b64f-1b8f-4619-b52e-0331efaf7224">
        <source>setVolumeFromHLW(table : CM_EntryTable input; row : Integer; rowName : String; pValue : Any);
// --------------------------------------------------------------------------------
// Created:		1 Janurary 2009 by cnwjo3
//
// Purpose:		
//
// Parameters:	
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	length,	width,	height	: Integer;
	product : CM_Product;
begin
	if self.mode = self.Mode_View then
		return;  //no need to do anything until update mode
	endif;
	
	length	:= table.getValueByNameIfVisible(ETRow_Length).Integer;
	width	:= table.getValueByNameIfVisible(ETRow_Width).Integer;
	height	:= table.getValueByNameIfVisible(ETRow_Height).Integer;

	//don't bother doing calculation if fields are empty;
	//or values are 0 (can't work out volume)
	if length = 0 or width = 0 or height = 0 then
		return;
	endif;	
	
	product := self.cmbProduct.listObject.CM_Product;
	
	if product = null then
		return;  //return, couldnt find product code from table
	endif;
	
	table.setValueByName ( ETRow_Volume, product.calculateVolume(length,width,height));	
	
end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
        <Parameter name="row" type="Integer"/>
        <Parameter name="rowName" type="String"/>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setWagonClassOnWagonIdChg" id="a2a450fb-5ceb-40df-8f54-b9ed4f674a86">
        <source>setWagonClassOnWagonIdChg();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2014	cnwndl1	Initial creation	Par 33615

*/

vars

	
	pxyTI : CM_TrackedItem;
	wagonId : String;
	wagonVisit : CM_Wagon;
	wagonClassId : String;
	wagonClass : CM_WagonClass;
	wagonMaster : CM_WagonMaster;
	isForEdit : Boolean;
	table : CM_EntryTable;
	rowIndex : Integer;
	isVisible : Boolean;

begin

	table := self.getTableForRow(ETRow_WagonClass);
	if table &lt;&gt; null then
		rowIndex := table.getRowByName(ETRow_WagonClass);
		if rowIndex &lt;&gt; 0 then 
			table.accessCell(rowIndex,2).backColor := CM_EntryTable.ReadOnlyRowColour;
			table.accessedCell.enabled := false;
		endif;
	endif;

	isForEdit := (self.mode = self.Mode_Update);

	if self.myProxyObject = null
	or not self.myProxyObject.isKindOf( CM_TrackedItem )
	or not isForEdit
	then
		return;
	endif;
	
	pxyTI := self.myProxyObject.CM_TrackedItem;
	table := self.getTableForRow(ETRow_WagonNumber);
	
	if not pxyTI.isPreNote
	or table = null
	then
		return;
	endif;
	
	rowIndex := table.getRowByName(ETRow_WagonNumber);
	if rowIndex &lt;= table.fixedRows
	or rowIndex &gt; table.rows
	then
		return;
	endif;
	
	isVisible := table.accessRow(rowIndex).visible;
	if not isVisible
	then
		return;
	endif;

	
	wagonId := table.accessCell(rowIndex, table.ColumnValue).text;
	if wagonId = null then
		//NO wagon entered, no need to allow entry of a wagon class
		return;
	endif;
	
	wagonVisit := self.myTerminal.getCurrentWagonByID(wagonId);
	if wagonVisit &lt;&gt; null then
		//There is a current wagon on site with this id, unconditionally use its wagon class, and don't allow them to change it.
		self.cmbWagonClass.listIndex := self.cmbWagonClass.findObject( wagonVisit.myWagonClass );
		self.cmbWagonClass.lostFocus(self.cmbWagonClass);
		return;
	endif;
	
	wagonMaster := self.myTerminal.myRoot.allWagonMasters[wagonId];
	if wagonMaster &lt;&gt; null then
		wagonClass := wagonMaster.myWagonClass;
		if wagonClass &lt;&gt; null then
			//know about this one, it has visited previously... unconditionally use its wagon class, and don't allow them to change it.
			self.cmbWagonClass.listIndex := self.cmbWagonClass.findObject( wagonClass );
			self.cmbWagonClass.lostFocus(self.cmbWagonClass);
			return;
		endif;
	endif;
	
	wagonClassId := app.myRoot.getWagonClassViaHookCode( self.myTerminal, wagonId, null );
	if wagonClassId &lt;&gt; null then
		wagonClass := self.myTerminal.myRoot.allWagonClasses[wagonClassId];
		if wagonClass &lt;&gt; null then
			//Hook code says use this one... unconditionally use its wagon class, and don't allow them to change it.
			self.cmbWagonClass.listIndex := self.cmbWagonClass.findObject( wagonClass );
			self.cmbWagonClass.lostFocus(self.cmbWagonClass);
			return;
		endif;
	endif;
	
	
	
	
	table := self.getTableForRow(ETRow_WagonClass);
	if table &lt;&gt; null then
		rowIndex := table.getRowByName(ETRow_WagonClass);
		if rowIndex &lt;&gt; 0 then 
			table.accessCell(rowIndex,2).backColor := self.colorValueColumn;
			table.accessedCell.enabled := true;
		endif;
	endif;
	
	wagonClassId := self.myTerminal.getConfig(DefWagonClass).String;
	if wagonClassId &lt;&gt; null then
		wagonClass := self.myTerminal.myRoot.allWagonClasses[wagonClassId];
		if wagonClass &lt;&gt; null and self.cmbWagonClass.listObject = null then
			//OK default it and let them change it if they want
			self.cmbWagonClass.listIndex := self.cmbWagonClass.findObject( wagonClass );
			self.cmbWagonClass.lostFocus(self.cmbWagonClass);
		endif;
	endif;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setYardLocations" id="d2bb2d89-1e24-48c8-aca1-0020e4e3cd61">
        <source>setYardLocations(tmpTA : CM_TerminalArea);
/*
Purpose:			
Date		Who		Reason
19 September 2013	cnwab1	Initial creation

	NOTE : Re-implemented in  YRD_LocationEnquiryFrm to set up Shelves and Racks for General Cargo Areas.

*/

vars

begin

	self.myAssistant.comboBoxLocationControllers(self.cmbFiltYardLocn, tmpTA.getLCsCollectionForDisplay, false);

epilog

end;</source>
        <Parameter name="tmpTA" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="setupContextMenuItems" id="4ff265c5-198a-4005-a487-af1efcb6809e">
        <updating/>
        <source>setupContextMenuItems( conwin : Window input ) updating;
// ---------------------------------------------------------------------------
// Created:     18 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 19/01/2018	jlgdap1		TFS 36658 STWR Cargo Scanning Enhancements
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	tmpMenu	: MenuItem;
	locale : CM_Locale;
	tbl : CM_DataTable;
	hideCargoMenus : Boolean; 
	obj : Object;

begin


	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	
	if conwin.isKindOf(CM_DataTable) then
		tbl := conwin.CM_DataTable;
		if tbl &lt;&gt; null and app.isCargoGroupEnabled and self.includesCargoGroupAnCargoItems(tbl) then
			hideCargoMenus := true;
		endif;
	endif;
	
	self.mnuCargo.visible := false;
	mnuCargo.translateCaption(Xlat_0008311, locale);	//03 Jun 2015	NDL	Par 36338
	mnuCargoAttach.translateCaption(Xlat_0008313, locale);	//03 Jun 2015	NDL	Par 36338
	mnuCargoCreateItem.translateCaption(Xlat_0008315, locale);	//03 Jun 2015	NDL	Par 36338
	self.mnuCargoEdit.visible := false;
	self.mnuCargoEnquiry.visible := false;
	self.mnuRemarks.visible := false;
	self.mnuShowCargoForBOL.enabled := false;
	self.mnuShowCargoForBOL.visible := false;
	self.mnuAuditEnquiry.visible := false;
	self.mnuUnQueueSel.visible := false;	//23 Dec 2013	NDL	Par 32900
	self.mnuCustomsStatus.visible := false;			//cnwmc5 - 3 July 2014 - CCMS 2353
	self.mnuShowAlphabetised.visible := true;
	
	self.mnuCargoMoveIt.caption := app.getErrorString(Move_It_Menu_Caption);				// TFS 36658
	
	// cnwrl1 18/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - start of coding
	self.mnuSummarise.visible	:= false;	// default this menu level to invisible, makes sub-menu invisible.
	if self.bAllowSummaryDefn then
		self.mnuSummarise.visible			:= true;
		// the summarise selected is only enabled if something is actually selected.
		self.mnuSummariseSelected.visible	:= not self.tblData.allSelectedObjects.isEmpty;
	endif;
	tmpMenu := self.zCloneMenu( self.mnuTblVCloneDataTbl, self.mnuSummarise, false );
	self.zCloneMenu( tmpMenu, self.mnuSummariseAll, true );
	self.zCloneMenu( tmpMenu, self.mnuSummariseSelected, true );
	// cnwrl1 18/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - end of coding
	
	if (not self.canAccessAudits) then
		self.mnuTblVViewAudits.visible := false;
	endif;
	if self.myCurrentObject = null or
	   not self.myCurrentObject.isKindOf(CM_BOL) then
		if app.getMyUser().canDo(self.myTerminal, PmAdmCargoEnquiryConfigView) then // TFS 2734
			self.mnuConfig.visible := true;		// CCMS 1776 Sep 2011
		endif;
	endif;
	if self.useSelectorTable then
		//epr TFS 47132 18/12/19
		tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuRememberQuery, false); 
		tmpMenu.visible:=false;
		if conwin = self.sptMain  then		
			tmpMenu.visible :=  self.cmbSelector.visible;
		endif;
	endif;
	
	//changed by cnwyl1 100506
	//was...
/*	if conwin = tblData and 
	   (self.filterCargoTypeId = TI_CargoType_Log or self.filterCargoTypeId &gt; TI_CargoBOLType_Max) and 
	   self.myCurrentObject &lt;&gt; null then*/
	if conwin = tblData 
	and self.filterCargoTypeId = TI_CargoType_Log 
	and self.myCurrentObject &lt;&gt; null
	then
		self.mnuShowBOLForCargo.visible 	:= true;
		self.mnuShowBOLsInLocation.visible 	:= true;
		self.mnuShowCargoInLocation.visible	:= true;	
				
		if self.canAccessTransactions then
			self.mnuTransactions.visible := true;		
			self.btnTransactions.enabled := true;
		else
			self.mnuTransactions.visible := false;
		endif;
	else
		self.mnuShowBOLForCargo.visible := false;
		self.mnuShowBOLsInLocation.visible := false;
		self.mnuShowCargoInLocation.visible := false;
		
		// note when discharging from ship there is no current object
		if self.myCurrentObject &lt;&gt; null then
			if self.myCurrentObject.isKindOf(CM_BOL) then
				if self.canAccessTransactions then
					self.mnuTransactions.visible := true;
					self.btnTransactions.enabled := true;
				else
					self.mnuTransactions.visible := false;
				endif;
				
				if self.mode = self.Mode_View then //14/05/2010 cnwdz2 par23918
					self.mnuCargo.visible := true;
					if self.myCurrentObject.isKindOf(CM_BOLIn) then
						self.buildBOLInCargoMenu(self.myCurrentObject.CM_BOLIn);
					endif;
				endif;
				
				self.mnuShowCargoForBOL.enabled := true;
				self.mnuShowCargoForBOL.visible := true;
				
				self.mnuCustomsStatus.visible := (self.myCurrentObject.isKindOf(CM_BOLIn) and self.myCurrentObject.CM_BOLIn.hasCustomsStatusMessages()) or app.isSpecial();		//cnwmc5 - 3 July 2014 - CCMS 2353
			elseif self.myCurrentObject.isKindOf(CM_CargoGroup) then
				if self.canAccessTransactions then
					self.mnuTransactions.visible := true;
					self.btnTransactions.enabled := true;
				else
					self.mnuTransactions.visible := false;
				endif;
				if self.mode = self.Mode_View then //14/05/2010 cnwdz2 par23918
				//	self.mnuCargo.visible := true;
				//	self.buildCargoGroupMenu(self.myCurrentObject.CM_CargoGroup);
					self.mnuCargo.visible := true;
					if hideCargoMenus then	//05 Jun 2015	NDL	Par 36338
						self.mnuCargo.visible := false;
						tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuCargo, false);
						return;
					else
						self.buildCargoGroupMenu(self.myCurrentObject.CM_CargoGroup);
					endif;
				endif;
				
			elseif self.myCurrentObject.isKindOf(CM_TrackedItem) then
				if self.canAccessTransactions then
					self.mnuTransactions.visible := true;
					self.btnTransactions.enabled := true;
				else
					self.mnuTransactions.visible := false;
				endif;
				self.mnuToggleDepartedVoys.visible := true;
				self.mnuToggleDepartedVoys.enabled := true;
				
				if self.mode = self.Mode_View then //14/05/2010 cnwdz2 par23918
					//05 Jun 2015	NDL	Par 36338
					self.mnuCargo.visible := true;
					if hideCargoMenus then	//05 Jun 2015	NDL	Par 36338
						self.mnuCargo.visible := false;
						tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuCargo, false);
						return;
					else
						self.buildCargoMenu(self.myCurrentObject.CM_TrackedItem);
					endif;
				endif;
				
				if self.canAccessAudits and 
				   conwin &lt;&gt; tblData then
					self.mnuAuditEnquiry.visible := true;
				else
					self.mnuAuditEnquiry.visible := false;
				endif;
				
			else
				return;
			endif;
		//21 Jul 2015	NDL	Par 36338 - for testing anyway.
		elseif self.myCurrentObject = null and filterCargoTypeId &gt; 0 then
			//obj := self.cmbFiltTiType.listObject;
			obj:= app.myRoot.allCargoTypesById[self.filterCargoTypeId];
			if obj &lt;&gt; null and obj.isKindOf( CM_CargoType ) then
				if obj.CM_CargoType.isCargoGroup then
					self.mnuTransactions.visible := false;
					if self.mode = self.Mode_View then 
						self.mnuCargo.visible := true;
						if hideCargoMenus then
							self.mnuCargo.visible := false;
							tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuCargo, false);
							return;
						else
							self.buildCargoGroupMenu(null);
						endif;
					endif;
				endif;
			endif;
		endif;
		
	endif;
	
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuCustomsStatus, false);		//cnwmc5 - 3 July 2014 - CCMS 2352
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuShowBOLForCargo, false); 
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuShowBOLsInLocation, false); 
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuShowCargoInLocation, false); 
	if self.canAccessTransactions then
		tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuTransactions, false);
	endif;
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuShowAlphabetised, false); 
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuToggleDepartedVoys, false); 
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuShowCargoForBOL, false); 
	//tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuNonTrans, false); 
	if self.mode &lt;&gt; self.Mode_View then //14/05/2010 cnwdz2 par23918
		tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuCargo, false);
	endif;
epilog
	
end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d836de2e-3494-4def-9f61-102eb010ffff">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:		
Parameters:		
Return Value:	

Date		Who		Reason
23 Feb 2009	cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)
21 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
29 Jun 2022	navdap1	TFS 53362 EUP Master Data Interface Customers Between TOS and ERP
// 07 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
17 Jun 2025	jlier1	JIRA MTN-35088 - removed methods calls that were not needed and caused performance issues
*/
vars
	idx 		: Integer;
	cargoType 	: CM_CargoBOLType;
	tmpStr		: String;
	userQuery 	: CM_MenuUserQuery;
	idCrit 		: CM_SelectorCriteriaLine;
	idRow 		: Integer;
	
begin
	// cnwrl1 236/02/2009 - (CCMS SFW 1047 - Totals Only Lists)
	// The user can access the summarise functionality only if they have at least view security role.
	self.bAllowSummaryDefn	:= app.myCurrentUserCan( self.myTerminal, PmSummaryDefView );
	cmbFiltSubTerm.style	:=	ComboBox.Style_DropDownComboList;
	
	self.cmbSubTerminal.automaticCellControl	:= true;		// CCMS 1875
	
	self.allowSubTerminalUpdate := not self.myTerminal.getConfig(IsSubTerminalAreaDefined).Boolean;	//27 Nov 2014	NDL	Par 35295

	inheritMethod();
	
	//epr TFS 47132 13/12/19
	if self.useSelectorTable then
		self.frmToolbarCombos.visible:=true;
		self.myAssistant.comboBoxUserQuery(self.cmbSelector,null,null,true);
		
	endif;
	
	self.shtEdit8.visible := false;
	self.shtEdit9.visible := false;
	self.shtEdit10.visible := false;
	self.shtEdit1.visible := true;
	self.fldEdit.topSheet := self.shtEdit1;
	self.shtEdit1.visible := false;
	
	//21 Sep 2016	cnwrs1	TFS 2586
	self.btnFilterVoyages.caption := app.getErrorString(All_Voyages);
	self.btnFilterVoyages.bubbleHelp := app.getErrorString(All_Voyages);
	idx := self.tblSearch.getRowByName(ETRow_FilterVoyage);
	if idx &gt; 0 then
		self.tblSearch.accessCell(idx, 1).text := app.getErrorString(Active_Voyages);
	endif;

	// CCMS 1776 Sep 2011 listen for changes to user config
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(UserConfigCargo_Update_Event), Response_Continuous, null);

	//epr TFS 47132 13/12/19
	if self.myCurrentObject = null then
		if self.myCurrentCargoBOLType &lt;&gt; null then				// ### TFS 52923 22Mar2022 NAVPW1
			cargoType := self.myCurrentCargoBOLType;			// ### TFS 52923 22Mar2022 NAVPW1
		else													// ### TFS 52923 22Mar2022 NAVPW1
			cargoType:=app.myPassport.getDefaultCargoBOLType();
		endif;													// ### TFS 52923 22Mar2022 NAVPW1
	endif;
	
	if self.allowSearch and self.useSelectorTable then
		self.createDefaultCritLineHolder(cargoType,self.myCurrentObject);
		
		if self.myUserWindow &lt;&gt; null then
			tmpStr := self.myUserWindow.xmlInfo.cnEcGetTagValueOfName(self.XmlTag_SelectorQuery);
			if tmpStr &lt;&gt; null then
				userQuery:=tmpStr.asOid.CM_MenuUserQuery;
				if userQuery &lt;&gt; null then
					self.cmbSelector.setIndexFromObject(userQuery);
					if self.cmbSelector.listObject &lt;&gt; null then
						self.doRememberQuery();	
						self.cmbSelector.click(self.cmbSelector);
						return;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	self.cmbShippingLine.isDisplayByName := self.myTerminal.getConfig(ComboByNameLine).Boolean;		// TFS 53362
	self.btnInstruction.enabled := false;	//07.10.2022 navtnr20 TFS 54967
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupMoveModeCtrl" id="4cd48ec4-23a3-42c7-bfef-f6319f787b24">
        <updating/>
        <source>setupMoveModeCtrl() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2011	cnwndl1	Initial creation	Par 28035

*/

vars

	index : Integer;
	cntrl : Control;
	staLineMoveMode : CMUI_GridAreaStatusLine;
	top : Real;

begin

	foreach index in 1 to controlCount do
		cntrl := controls(index);
		if cntrl.isKindOf(CMUI_GridAreaStatusLine) then
			staLineMoveMode :=  cntrl.CMUI_GridAreaStatusLine;
			break;
		endif;
	endforeach;
	
	if staLineMoveMode = null then

		create staLineMoveMode transient;

		self.addControl(staLineMoveMode);
		staLineMoveMode.name := "frmStaMoveMode";
		
		staLineMoveMode.doBuildMenuMove();	
		staLineMoveMode.sendMsg("createGraphics");
		
		staLineMoveMode.transparent := true;
		staLineMoveMode.myFrameMoveMode.transparent := false;
		staLineMoveMode.myFrameDisplayMode.transparent := true;
		//staLineMoveMode.myFrameOther.transparent := true;		// 20/02/2013 cnwar2 #31176 - these options should no longer be shown.
		staLineMoveMode.myFrameCaption.transparent := true;
		
		staLineMoveMode.alignContainer := 0;
		staLineMoveMode.myFrameMoveMode.alignContainer := 0;
		staLineMoveMode.myFrameDisplayMode.alignContainer := 0;
		//staLineMoveMode.myFrameOther.alignContainer := 0;		// 20/02/2013 cnwar2 #31176 - these options should no longer be shown.
		staLineMoveMode.myFrameCaption.alignContainer := 0;
		
		staLineMoveMode.bevelInnerWidth := 0;
		staLineMoveMode.myFrameMoveMode.bevelInnerWidth := 0;
		staLineMoveMode.myFrameDisplayMode.bevelInnerWidth := 0;
		//staLineMoveMode.myFrameOther.bevelInnerWidth := 0;	// 20/02/2013 cnwar2 #31176 - these options should no longer be shown.
		staLineMoveMode.myFrameCaption.bevelInnerWidth := 0;
		
		staLineMoveMode.bevelOuterWidth := 0;
		staLineMoveMode.myFrameMoveMode.bevelOuterWidth := 0;
		staLineMoveMode.myFrameDisplayMode.bevelOuterWidth := 0;
		//staLineMoveMode.myFrameOther.bevelOuterWidth := 0;	// 20/02/2013 cnwar2 #31176 - these options should no longer be shown.
		staLineMoveMode.myFrameCaption.bevelOuterWidth := 0;
		
		staLineMoveMode.boundaryWidth := 0;
		staLineMoveMode.myFrameMoveMode.boundaryWidth := 0;
		staLineMoveMode.myFrameDisplayMode.boundaryWidth := 0;
		//staLineMoveMode.myFrameOther.boundaryWidth := 0;	// 20/02/2013 cnwar2 #31176 - these options should no longer be shown.
		staLineMoveMode.myFrameCaption.boundaryWidth := 0;
				
		staLineMoveMode.myFrameMoveMode.enabled := true;
		staLineMoveMode.myFrameDisplayMode.enabled := false;
		//staLineMoveMode.myFrameOther.enabled := false;	// 20/02/2013 cnwar2 #31176 - these options should no longer be shown.
		staLineMoveMode.myFrameCaption.enabled := false;
		
		staLineMoveMode.myFrameMoveMode.visible := true;		
		staLineMoveMode.myFrameDisplayMode.visible := false;
		//staLineMoveMode.myFrameOther.visible := false;	// 20/02/2013 cnwar2 #31176 - these options should no longer be shown.
		staLineMoveMode.myFrameCaption.visible := false;
		
		staLineMoveMode.myFrameMoveMode.height := 13;
		staLineMoveMode.myFrameDisplayMode.height := 10;
		//staLineMoveMode.myFrameOther.height := 10;	// 20/02/2013 cnwar2 #31176 - these options should no longer be shown.
		staLineMoveMode.myFrameCaption.height := 10;
		staLineMoveMode.height := 13;
		
		staLineMoveMode.parent := self.staMain;
		
		staLineMoveMode.myFrameMoveMode.top := 0;
		staLineMoveMode.myFrameMoveMode.left := staLineMoveMode.myFrameMoveMode.left - 15;		
	
	else
		staLineMoveMode.width := staMain.width;	// 13 Mar 2013	NDL	- Moved line up...
		staLineMoveMode.myFrameMoveMode.left := staLineMoveMode.width - 110;
			
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupPermissions" id="da45bc82-8358-40a0-9cd6-e8ef073f6e2f">
