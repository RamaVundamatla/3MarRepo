    <JadeMethod name="setForUpdateVoyageAllocations" id="e1e7d503-7d66-4475-921d-41ffc3bcaa5c">
        <source>setForUpdateVoyageAllocations(_proxyVoyage : CM_Voyage; _useVAChanged : Boolean) protected;
// --------------------------------------------------------------------------------
// Created:		8 December 2009 by cnwjo3
//
// Purpose:		create a CM_VoyageAllocationConfig for a Voyage.  Note:  Currently can only have
//				1 allocation per voyage.  note, self.allVoyageAllocationConfigs.first!
//
vars
	yaimexConfig			: CM_YAIMEXConfig;
	newVAConfig, vaConfig : CM_VoyageAllocationConfig;
	allocationEmpty : Boolean;
begin
	allocationEmpty := self.allVoyageAllocationConfigs.isEmpty();
	
	foreach yaimexConfig in _proxyVoyage.allVoyageAllocationConfigs do
		if yaimexConfig.isKindOf(CM_VoyageAllocationConfig) then
			vaConfig := yaimexConfig.CM_VoyageAllocationConfig;
			
			if allocationEmpty then
				create newVAConfig;
			else
				//if we were going to have multiple VoyageAllocationConfigs we'd probably need
				//to use the myYACriteriaTypeForColour property.  Possibly.....
				newVAConfig := self.allVoyageAllocationConfigs.first().CM_VoyageAllocationConfig;
			endif;
			
			newVAConfig.setForUpdateIMEX();
			newVAConfig.setForUpdateVoyage( self );
			newVAConfig.setForUpdate(vaConfig);
		endif;
	endforeach;
	
	if _useVAChanged then
		self.emptySlotRequests();
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_proxyVoyage" type="CM_Voyage"/>
        <Parameter name="_useVAChanged" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIFVoyageGlobal" id="007df156-eec6-46e9-9781-23e3f1c594d2">
        <updating/>
        <source>setFromCMIFVoyageGlobal(_terminal : CM_Terminal; _cmif_VoyageGlobal : CMIF_VoyageGlobal; _passport : CM_Passport input) updating;
//-----------------------------------------------------------------------
//	Created:	13 September 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
/*

Date		Who		Reason
10 Apr 2008	cnwkpd1	PAR #16378 - Change update to use setMyTerminal to ensure global 
					voyages manual collections are maintained correctly
15 Mar 2012	cnwkpd1	PAR #29274 - only set key values if they have changed

*/

vars
	vessel	 					: CM_Vessel;
	realHMSVoyageData,
	hmsVoyageData				: HMS_VoyageData;
	pxyMovement,
	newMovement 				: HMS_VoyageMovement;
begin

	if self.myHMSVoyageData = null then
		hmsVoyageData := _cmif_VoyageGlobal.myHMSVoyageData.cloneSelf(true);
		self.myHMSVoyageData := hmsVoyageData;
	endif;
	
	self.setMyTerminal(_terminal);			// PAR #16378
	
	self.remarks 			:= _cmif_VoyageGlobal.remarksVessel;
	self.myTrade 			:= _cmif_VoyageGlobal.myTrade;
	self.myShippingLine 	:= _cmif_VoyageGlobal.myShippingLine;
	self.myOperator 		:= _cmif_VoyageGlobal.myOperator;
	self.colour 			:= _cmif_VoyageGlobal.colour;
	self.code 				:= _cmif_VoyageGlobal.voyageCode;
	if self.vesselCode &lt;&gt; _cmif_VoyageGlobal.vesselCode then		// PAR #29274
		self.vesselCode 		:= _cmif_VoyageGlobal.vesselCode;
	endif;
	self.vesselName 		:= _cmif_VoyageGlobal.vesselName;
	
// PAR 33644	self.isNonPlannedVoyage := true;
// PAR 33644	self.isNonWorkedVoyage 	:= true;

	if self.myHMSVoyageData &lt;&gt; null then
		vessel := self.getMyVessel();
		
		if vessel &lt;&gt; null then
			if vessel.myHMSVesselData = null then
				vessel.createHMSVesselDataDefault();
			endif;
		endif;
		
		self.myHMSVoyageData.setFromCMIFVoyageGlobal(_cmif_VoyageGlobal, _terminal.myHarbour, _passport);
	endif;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_cmif_VoyageGlobal" type="CMIF_VoyageGlobal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromWorkingVoyage" id="134c54aa-a947-463f-878c-a0f61c64fba1">
        <updating/>
        <source>setFromWorkingVoyage(_workingVoyage : CMIF_HMS_WorkingVoyage; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 30 July 2003 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------------
// 20/05/2014	cnwdap1		PAR #34172 Set myTerminal before calling setArrivalDepartureDT
//								as this method depends on having a terminal to update
//								the allVoyagesNew collection correctly. Also set code as
//								the collection update depends on having a code too.
// 12/04/2023	navdap1		TFS 57362 CUX Changes to Outgoing Message Formats
vars
	
begin

	self.setMyTerminal(_workingVoyage.ofTerminal);											// PAR #34172
    self.updateCode(_workingVoyage.code.trimBlanks, _passport);								// PAR #34172
	self.setArrivalDepartureDT(_workingVoyage.arrivedDT, _workingVoyage.departedDT, true);
 
    //self.updateCode(_workingVoyage.code.trimBlanks, _passport);							// PAR #34172
    
    self.remarks := _workingVoyage.remarks;
    // Modified by Russell 04/08/99
    // ---------------------------------
    self.status := _workingVoyage.voyageStatus;
    // ----------------------------------
	
	// ### TFS 55215 22Nov2022 NAVPW1
	if self.status = Voyage_Status_Arrived then
		CMIF_TrxActionTransport@createAction(self, null, null, CMIF_TrxActionTransport.ProcessVoyageArrival, app.myPassport);		// TFS 57362
	elseif self.status = Voyage_Status_Departed then
		CMIF_TrxActionTransport@createAction(self, null, null, CMIF_TrxActionTransport.ProcessVoyageDeparture, app.myPassport);		// TFS 57362
	endif;
	// ### TFS 55215 22Nov2022 NAVPW1
	
    self.archived := _workingVoyage.archived;		//Modified by Russell 13/08/99
    self.archivedDT := _workingVoyage.archivedDT;	//Modified by Russell 13/08/99
    //self.setMyTerminal(_workingVoyage.ofTerminal);										// PAR #34172
    
    self.updateVesselCodeVesselName(_workingVoyage.myHMSVoyageData.vesselCode, _workingVoyage.myHMSVoyageData.vesselName);

	self.updateVoyageInlandTerminals(_passport);
	
end;</source>
        <Parameter name="_workingVoyage" type="CMIF_HMS_WorkingVoyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setGeneralLandingDate" id="35113058-8d71-43bf-a9f7-ac8d39ea62bb">
        <updating/>
        <source>setGeneralLandingDate( _generalLandingDate : Date ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 March 2016	cnwndl1	Initial creation	TFS 1407
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	voyEvent : CMEVT_VoyageEvent;
	cmifEventCtrl : CMIF_VoyageEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
begin
	
	if self.generalLandingDate &lt;&gt; _generalLandingDate then
	
		if not self.isTransient then
			/* //17/02/2025	navkc1 JIRA Bug MTN-33582
			voyEvent := app.createEvent(EVT_VoyGeneralLandingDate, app.actualTimeServer, self.myTerminal, app.myPassport.userCode, false, false,0).CMEVT_VoyageEvent;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			if voyEvent &lt;&gt; null then
				voyEvent.setMyVoyage(self);
				voyEvent.setGeneralLandingDate( self.generalLandingDate, _generalLandingDate );
			endif;
			*/
			
			//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
			create cmifEventCtrl transient;
			cmifEventCtrl.type := EVT_VoyGeneralLandingDate;
			cmifEventCtrl.dateTime := app.actualTimeServer();
			cmifEventCtrl.myTerminal := self.myTerminal;
			cmifEventCtrl.userCode := app.myPassport.userCode;
			cmifEventCtrl.myVoyage := self;
			cmifEventCtrl.generalLandingDate := _generalLandingDate;
			cmifEventCtrl.prevGenLandingDate := self.generalLandingDate;
			
			voyEvent := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_VoyageEvent; 
			//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
			
		endif;

		self.generalLandingDate := _generalLandingDate;
	
	endif;

epilog
	delete cmifEventCtrl;
end;</source>
        <Parameter name="_generalLandingDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setHMSVesselDataForEDI" id="75922a4b-1d4f-44fb-8e57-ada7f4df4d9b">
        <updating/>
        <source>setHMSVesselDataForEDI(_vessel : CM_Vessel; _terminal : CM_Terminal; _adding : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:	13 February 2011 By Graeme Black cnwgb1
// Status: 	
// Purpose:	This method will create the HMSVoyageData from the supplied Vessels HMSVesselData
// ---------------------------------------------------------------------------
// 08 Aug 2019	jl4sl4	TFS 46030 - ASPA - 1090 when verifying voyage EDI file

vars
	hmsVoyageData		: HMS_VoyageData;
	
begin
	// Assumption is vessel has already been found.
	if _vessel = null then
		return;
	endif;
	
	// make sure have VTMIS License
	if  not app.myRoot.canDo(Mod_Harbour) then
		return;
	endif;
	
	// If the HMSVesselData exists then copy it to the HMSVoyageData
	if _vessel.myHMSVesselData = null then
		return;
	endif;
	
	if self.myHMSVoyageData = null then
//		if _adding and _vessel.hasHarbourDetails() then // TFS 46030 - add voyage data if vessel has harbour details
		if _adding then 		// 2/9/19 MAP TFS45926
			create hmsVoyageData transient;
			hmsVoyageData.setMyHarbour(_terminal.myHarbour);
            hmsVoyageData.setDefaultBerthPreferences(app.myPassport); //cnwgb1  PAR 27935 1.8.2011 
			self.setHMSVoyageData(hmsVoyageData);
		endif;
	endif;
	
	self.updateVoyageFromVessel(_vessel, app.myPassport);
end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_adding" type="Boolean"/>
    </JadeMethod>
