    <JadeMethod name="checkEditTransactionForId" id="24576c95-dfcb-4a1c-b901-cb1f96ed61b2">
        <updating/>
        <source>checkEditTransactionForId(_transaction:CM_TITransaction; _camProtocol:CM_CamProtocol; _camAgent : CM_CamControllerAgent input; _camFile:CM_CamFile input)updating;
//
// CCMS1644 cnwrs1 Aug 2008
//
// 27/06/2012	cnwcs5	par 29601 - change usage of _camFile
// 18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
// 23 Jul 2012	cnwcs5	par 29601/2
// 04 Feb 2013	cnwcs5	CCMS SFW 1294 /par 30855
//06 Mar 2015	cnwrs1	Par35784 - increased exclusion reason logging to include non excluded
//06 Jul 2016	cnwrs1	Par 38021 - Review Cam logging
vars
	trans, otherTrans 	: CM_TITransaction;
	field, oldValue, 
	newValue, code		: String;
	i 					: Integer;
	cls					: Class;
	coll				: ObjectSet;	// .includes more efficient for set than array
	isIDChange			: Boolean;		// par 29601/2
begin
	if not _transaction.isCamsEditType() then
		return;
	endif;
	
	code := _camProtocol.code;
	
	create coll transient;
	
	//we have an edit transaction see if it is intesteresting
	foreach i in 1 to _transaction.CM_Edit.fieldsValues.size do
		_transaction.CM_Edit.getFieldValues(i, field, oldValue, newValue);
		
		//see if it includes an id change
		if field = CM_TrackedItem::id.name then
			
			foreach trans in _transaction.myTrackedItem.allTransactions do
				// only want them if they are not after id change
				if trans = _transaction then
					break;
				endif; 
				
				otherTrans	:= null;
				cls 		:= trans.class;
				
				if cls = CM_Information then
					// par30855 - these are no longer created but we need the code for 'old' transactions
					if trans.CM_Information.description = CAMSDetails and 
						trans.CM_Information.getMyCamProtocolName = code then
						
						otherTrans := trans.CM_Information.getMyOtherTransaction();
					endif;
					
				elseif cls = CM_InfoEDISent then
					if trans.CM_InfoEDISent.getMyCamProtocolName = code then
						
						otherTrans := trans.CM_InfoEDISent.getMyOtherTransaction();
					endif;
				else
					continue;
				endif;
				
				if otherTrans &lt;&gt; null then
					if not coll.includes(otherTrans) then 
						// dont reprocess the same transaction multiple infos may exist for the same transaction
						self.processTransaction(otherTrans, _camProtocol, _camAgent, _camFile);
						app.writeLog(class.name&amp;'::'&amp;method.name&amp;' tr='&amp;otherTrans.String&amp;' ti='&amp;otherTrans.myTrackedItem.String&amp;' '&amp;otherTrans.myTrackedItem.id, LogDEBUG);
						
						coll.add(otherTrans);
					endif;
				endif;
			endforeach;
			
			isIDChange := true;
		endif;
	endforeach;
	
	if not isIDChange and
	   _camAgent.logExcludedTransactions then
		_camAgent.logReasonForExclusion (_transaction, '"Reprocess all Cam transactions after an ID change" - this EDIT transaction is not in ID change');	// par 29601/2
	endif;
epilog
	delete coll;
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
