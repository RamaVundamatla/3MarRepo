    <JadeMethod name="createStopStartTransaction" id="90ef21d4-149b-427f-ae21-5fbd09f2aaee">
        <source>createStopStartTransaction(_action: Integer; _ts: TimeStamp; _obj : CM_Object);	//15.10.2024  navbs1  #12445
/*
 
Purpose:			
 
Parameters:			
 
Return Value:		
 
Date		Who		Reason
14/03/2024	navkc1 CR 62896 Task 62897: Jade - Job Create Transactions and Events
15 Oct 2024 navbs1 Bug MTN-12445 EUP | FR 54883 - Start and End Times for Operations in Mobile App - Unpack issues
30 Oct 2024 navhl20 CR MTN-33232: EUP - Start End Times for Road and Rail jobs 
*/
 
vars
	txnParams		: CMIF_TITransactionController;
	parentTI,
	ti				: CM_TrackedItem;
	eventType,
	woTransType,
	cargoTransType,
	vvrType 		: Integer;
begin
	// Get the type based on the action
	self.getTypesToCreate(_action, eventType, vvrType, woTransType, cargoTransType);
	
	//START 15.10.2024  navbs1  #12445
	/*isStart := _action = Job_Action_Start or _action = Job_Action_Resume;
	// Create WO Transaction
	woDtl := self.getMyWorkOrderDtl();
	if woDtl &lt;&gt; null then
		woTrans := woDtl.createWOTransaction(woTransType);
		if woTrans &lt;&gt; null then
			woJobTrans := woTrans.CM_WOJobDetail;
			woJobTrans.setJobActionDetails(self, isStart, _ts);
		endif;
	endif;
	// Create TI transaction
	parentTI := self.getFirstParent();
	if parentTI &lt;&gt; null then
		create txnParams transient;
		txnParams.type := cargoTransType;
		tiTrans := parentTI.createTransaction(txnParams, app.myPassport);
		if tiTrans &lt;&gt; null then
			tiJobTrans := tiTrans.CM_TIJobDetail;
			tiJobTrans.setJobActionDetails(self, isStart, _ts);
		endif;
	endif;*/
	//END 15.10.2024  navbs1  #12445
	ti := _obj.CM_TrackedItem;															//30.10.2024 navhl20 #33232
	if ti &lt;&gt; null then																	//15.10.2024  navbs1  #12445	//30.10.2024 navhl20 #33232
		parentTI := ti;																									//30.10.2024 navhl20 #33232
		parentTI.createStartStopTransUnpack(self, _action, _ts, cargoTransType);	   //updating method
	endif;
	if app.isWebApp and _action = Job_Action_Complete and self.status &lt;&gt; JOB_COMPLETE  then 				//15.10.2024  navbs1  #12445
		return;
	else
		self.createWOTransaction(_action,woTransType,_ts);
	endif;
epilog
	delete txnParams;
end;</source>
        <Parameter name="_action" type="Integer"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="getFirstParent" id="8aed7c75-c1da-41ca-a300-0105fcc2c852">
