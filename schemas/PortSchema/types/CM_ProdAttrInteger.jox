    <JadeMethod name="divideValue" id="ac5e23a5-3537-4385-89d5-a2457d7d7b66">
        <source>divideValue(_value : Decimal): Integer;
// ---------------------------------------------------------------------------
// Created:     04 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if (self.multiplier &lt;&gt; 0) and (_value &lt;&gt; 0) then
		return (_value / self.multiplier).Integer;
	else
		return _value.Integer;
	endif;

end;</source>
        <Parameter name="_value" type="Decimal"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDefaultValueString" id="0d149f15-d1e8-44e4-bf95-7cdd7a1e5fb8">
        <source>getDefaultValueString(_attrName: String): String;
// ---------------------------------------------------------------------------
// Created:     17 October 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	
	if self.validationType = ValidationType_Value then
		return self.value.String;
	endif;
	


end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="d03cb954-deb9-4ee5-8e66-2f8c4bf96407">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     09 October 2002 by cnwth2
//
// Purpose:     
//
// Changes		PAR 22189. String changed by asStringJMT. Feb 2010
// ----------   ----------  --------------------------------------------------
vars

begin
	if _attrName = ETRow_Multiplier then
		return self.multiplier.asStringJMT();
	
	elseif _attrName = ETRow_Range then
		if self.minValue &lt;&gt; null and self.maxValue &lt;&gt; null then
			return self.minValue.asStringJMT() &amp; ':' &amp; self.maxValue.asStringJMT();
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_Value then
		return self.value.asStringJMT();
	endif;
	
	return inheritMethod(_attrName, _short);	

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayValueString" id="26228dc0-d6a9-4c59-9339-16734f272b0f">
        <source>getDisplayValueString(): String;
// ---------------------------------------------------------------------------
// Created:     24 October 2002		cnwth2	
//
// Purpose:     
//			 
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 15/03/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
vars
	displayValue 	: Decimal[10,3];
	errMsg,
	result : String;
begin
	result := null;
	
	if self.myMeasurementType &lt;&gt; null then															// PAR #31155
		result := app.convertMeasurementForDisplay(self.myMeasurementType.shortName, self.value);	// PAR #31155
	else																							// PAR #31155
	
		displayValue := (self.value * self.multiplier);
		
		if displayValue &gt; 0 then
			if displayValue mod 1 = 0 then
				result := displayValue.Integer.asStringJMT;
			else
				result := displayValue.asStringJMT;
			endif;
		endif;
	endif;																							// PAR #31155
	
	return result;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRangeDescr" id="06d7bd15-d43c-4caa-8c08-d0d2325f75f9">
        <source>getRangeDescr(): String;
// ---------------------------------------------------------------------------
// Created:     12 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	minValue,
	maxValue			: Decimal[10,3];
	minStr,
	maxStr				: String;
begin
	minValue := (self.minValue * self.multiplier).roundedTo(3);
	if minValue mod 1 = 0 then
		minStr := minValue.Integer.String;
	else
		minStr := minValue.String;
	endif;
	
	maxValue := (self.maxValue * self.multiplier).roundedTo(3);
	if maxValue mod 1 = 0 then
		maxStr := maxValue.Integer.String;
	else
		maxStr := maxValue.String;
	endif;
	return minStr &amp; ' : ' &amp; maxStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
