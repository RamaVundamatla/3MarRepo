    <JadeMethod name="getDisplayStringForAttribute" id="507f238f-cf68-49eb-9f06-3952e1cd4e44">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:	TFS 42882		
Date				Who			Reason
SEPTEMBER 2019		JLGAB1 initial creation
*/

vars
	lDetail : String;
	amountDisplay : String;
	drstr : String;
begin

	if _attrName = ETRow_Details then
		if self.deleted then
			return self.getDeletedDetails();	
		else
		
			if self.isDirectReleaseMove then
				drstr := " DR ";
			endif;
			amountDisplay := '(' &amp; self.getAmountDisplay() &amp; ') ';
			if amountDisplay &lt;&gt; "() " then
				lDetail:= app.getErrorString(Received) &amp; drstr &amp; " " &amp; amountDisplay &amp; " "  &amp; lDetail;
			else
				lDetail:= app.getErrorString(Received) &amp; drstr &amp;  " " &amp; lDetail;
			endif;
			return lDetail;
		endif;
	
	elseif _attrName = ETRow_ReceiveRailFrom then	//14 May 2020	NDL	TFS 49202
		return self.locationRail;
	elseif _attrName = ETRow_ReceiveRailTo then	//14 May 2020	NDL	TFS 49202
		return self.locationYard;
		
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
