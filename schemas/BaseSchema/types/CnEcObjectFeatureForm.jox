end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnSelect_click" id="f5118009-ae6f-4a05-ab02-511a0e26385c">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSelect_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		09 February 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aFeatureName	:=	null;
	
	if lstAttributes.listIndex &lt;&gt; CNEC_NULL_INDEX then
		self.aMyFeature		:=	lstAttributes.listObject.Property;
	elseif lstMethods.listIndex &lt;&gt; CNEC_NULL_INDEX then
		self.aMyFeature		:=	lstMethods.listObject.Method;
	endif;
	
	if self.aMyFeature = null then
		app.msgBox(	"Please select the attribute or method to define.",
					"Error",
					MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
	else
		self.modalResult	:=	self.CNEC_MODAL_SELECT;
		self.unloadForm();
	endif;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbSchema_click" id="3ce6e8b2-25c5-4fb8-bb8b-6a55d6dd7d6e">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbSchema_click(combobox: ComboBox input) updating;
// --------------------------------------------------------------------------------
// Created:		14 April 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.aMySchema		:=	combobox.listObject.Schema;
	self.populateClasses();
	self.doFormInitialize();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbSchema_displayEntry" id="fa23a2b6-3217-4b71-b168-129bbafc115e">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbSchema_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
// --------------------------------------------------------------------------------
// Created:		14 April 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
