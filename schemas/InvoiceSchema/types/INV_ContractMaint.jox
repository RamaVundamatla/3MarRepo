    <JadeMethod name="populateContractdt" id="49ca19bf-5bbb-4eaf-a9ad-42dfa189b21c">
        <source>populateContractdt();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Jan 2023 navtnr20	TFS CR 55646 Task 55664: UI - Contracts Maint

*/

vars
	localTS : TimeStamp;
begin
	
	self.txtContractID.text		:= self.myInvoiceContract.contractId;
	self.txtDescription.text 	:= self.myInvoiceContract.description;
	
	// ### TFS BUG 58796 26JUN2023 NAVAB1 start
	localTS := self.systemToLocalTime(self.myInvoiceContract.fromTS);
	self.mskContractFromStart.setDate(localTS.date);
	self.mskContractFromStartTime.setTime(localTS.time);

	localTS := self.systemToLocalTime(self.myInvoiceContract.toTS);
	self.mskContractFromEnd.setDate(localTS.date);
	self.mskContractFromEndTime.setTime(localTS.time);
	// ### TFS BUG 58796 26JUN2023 NAVAB1 end
	
	self.chkPrimary.value := self.myInvoiceContract.primary;
	self.chkActive.value := self.myInvoiceContract.active;
	self.cmbDebtor.listObject := self.myInvoiceContract.myDebtor;

epilog

end;</source>
    </JadeMethod>
