    <JadeMethod name="getDataForDefSpecial" id="db421756-2b05-46ed-ba56-2fe1f44584bd">
        <source>getDataForDefSpecial(_attrName, _heading : String; _headings: StringArray input; _data: HugeStringArray input): Boolean protected;
// ---------------------------------------------------------------------------
// Created:     21 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpStr : String;
begin

	if _attrName = ETRow_Cou then
		_headings.add(_heading);
		if self.getCou &lt;&gt; null then
			_data.add(self.getCou.id &amp; '  ' &amp; self.getCou.description);
		else
			_data.add(null);
		endif;
		return true;
	
	elseif _attrName = ETRow_CouType then
		_headings.add(_heading);
		if self.getCou &lt;&gt; null then
			_data.add(app.couTypeEnumToString(self.getCou.couType));
		else
			_data.add(null);
		endif;
		return true;

	elseif _attrName = ETRow_Temperature then
		if self.getTemperature = NULL_TEMPERATURE then
			tmpStr := null;
		else
			//tmpStr := self.temperature.String;
			tmpStr := app.temperatureDisplayString(self.getTemperature);
		endif;
		_headings.add(_heading);
		_data.add(tmpStr);
		return true;
	
	elseif _attrName = ETRow_IsControlledAtmosphere then
		if self.isControlledAtmosphere then
			_headings.add(_heading);
			_data.add(self.isControlledAtmosphere.getYesNo);
		endif;
		return true;
	elseif _attrName = ETRow_CarbonDioxide then
		if self.isControlledAtmosphere then
			_headings.add(_heading);
			_data.add(self.getCarbonDioxide.asNullCarbonDioxide);
		endif;
	elseif _attrName = ETRow_Oxygen then
		if self.isControlledAtmosphere then
			_headings.add(_heading);
			_data.add(self.getOxygen.asNullOxygen);
		endif;
	elseif _attrName = ETRow_CurtainsIn then		// CCMS 1654 - slw 11/09/2008
		if self.isControlledAtmosphere then
			_headings.add(_heading);
			_data.add(self.getCurtainsIn.getYesNo);
		endif;
	elseif _attrName = ETRow_TemperatureInFahrenheit then
		if self.getTemperature = NULL_TEMPERATURE then
			tmpStr := "";
		else
			//tmpStr := self.temperatureInFahrenheit.String;
			tmpStr := app.temperatureDisplayString(self.temperatureInFahrenheit);			
		endif;
		_headings.add(_heading);
		_data.add(tmpStr);
		return true;


	elseif _attrName = ETRow_HasToDo then
		_headings.add(_heading);
		_data.add(app.getYesNo(self.hasToDoTasks));
		return true;
	else
		return inheritMethod(_attrName, _heading, _headings, _data);
	endif;

	return true;	

end;</source>
        <access>protected</access>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_headings" type="StringArray" usage="input"/>
        <Parameter name="_data" type="HugeStringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDefaultMeasureHeight" id="eec4c172-2b53-4624-ae1a-98e5ede0eeb2">
        <source>getDefaultMeasureHeight(): String;
//
// Purpose:			For JRW reports - return the container's (over)height in the system default linear measurement type
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 22/05/2013	cnwdap1		Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
//
vars
	measureType : CM_MeasurementType;
	prod : CM_Product;
begin
	prod := self.getProductForMeasurementConv();
	if prod &lt;&gt; null then
		measureType := prod.getDefaultMeasurementForType(Type_Height);
	else
		measureType := app.getDefaultMeasurementForType(Type_Height);
	endif;
	if measureType = null then
		return (self.overHeight).asStringJMT;
	endif;
	return app.convertMeasurementForDisplay(measureType.shortName, self.overHeight);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
