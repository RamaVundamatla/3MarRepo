<Class name="HMS_SavedConflictReport" id="d0e431da-ab85-4fb0-9641-60a14dbf82a3">
    <superclass name="HMS_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="harbour"/>
    <ExplicitInverseRef name="allHMSConflicts" id="0dca46d3-10ae-4fe2-a6e9-36c12094130e">
        <kind>parent</kind>
        <updateMode>automatic</updateMode>
        <type name="HMS_ConflictSet"/>
        <access>readonly</access>
        <Inverse name="HMS_Conflict::mySavedConflictReport"/>
    </ExplicitInverseRef>
    <PrimAttribute name="endDT" id="e35fdd60-a9a0-409e-b79e-f2d328e5ea66">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="fromDT" id="58e0c272-30e6-4315-a78e-305f4aa137a3">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myTerminal" id="18dd93fe-f4f4-425e-98a3-515c8d907ae8">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Terminal"/>
        <access>readonly</access>
        <Inverse name="CM_Terminal::allHMSSavedConflictReports"/>
    </ExplicitInverseRef>
    <PrimAttribute name="userCode" id="a3da1df3-fa76-4631-9a92-160944511382">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getDisplayStringForAttribute" id="823fc90d-c568-4c82-8b93-1f61d06af5d2">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
08 March 2008	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if _attrName = ETRow_FilterTerminal then
		return self.myTerminal.name;
	elseif _attrName = ETRow_FilterDateFrom then
		return self.systemToLocalTime(self.fromDT).asStringJMT;	// 25/5/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_FilterDateTo then
		return self.systemToLocalTime(self.endDT).asStringJMT;	// 25/5/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_UserName then
		return self.userCode;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_HMS_ConflictMgr" id="2763b2f0-63f8-4847-b7c6-9dcc782b8f56">
        <updating/>
        <source>setFromCMIF_HMS_ConflictMgr(_cmif_hms_conflictManager : CMIF_HMS_ConflictsManager; _passport :CM_Passport) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
08 Mar 2008	cnwer1	Initial creation - PAR#xxxx
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/
vars
	iter				: Iterator;
	cmif_hms_conflict	:  CMIF_HMS_Conflict;
	hmsConflict			: HMS_Conflict;
	
begin
	self.userCode	:=	_passport.getUserCode;
	self.fromDT		:=	_cmif_hms_conflictManager.fromDT;
	self.endDT		:=	_cmif_hms_conflictManager.endDT;
	iter			:=	_cmif_hms_conflictManager.allCMIFConflicts.createIterator;
	
	while iter.next(cmif_hms_conflict) do
		create hmsConflict;
		hmsConflict.setFromCMIF_HMS_Conflict(cmif_hms_conflict);
		hmsConflict.setMySavedConflcitReport(self);
	endwhile;
	
	//do last
	self.myTerminal	:=	_passport.myTerminal;
	
epilog
	delete iter;		// PAR #26678
		
end;</source>
        <Parameter name="_cmif_hms_conflictManager" type="CMIF_HMS_ConflictsManager"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
