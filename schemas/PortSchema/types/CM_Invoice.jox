    <JadeMethod name="getInvoiceStats" id="58e090a0-3f49-47e3-bd01-d2ab0d3de3d3">
        <source>getInvoiceStats(invLineStatDict     : CM_InvoiceLineStatByNarManDict input;
				pd				    : CMS_Progress input;
				recordTrackedItems  : Boolean;
				separateManualLines : Boolean): Real;
/*
Purpose:	Consolidate By Narratiion/IsManual&amp;False
			The narration may have DIFF RATE, so consolidation is by Narration, Rate, IsManual				
			This function is getting out of control!  If separateManualLines is true then
			there is a separate CM_InvoiceLineStat for manual lines.
			Returns the only true invoice total.

Parameters:			

Return Value:		

Date		Who		Reason
16/08/2016 cnwma1   TFS #2538 PAR 38132 ADP -Cash Invoice Rounding Figure
13/10/2017 jlgns1	TFS 7408 QNS - Receipt Error in Cash Module later fix
05/03/2020 cnwma1   ChangeRequest 48524: CPL - Credit Invoice Details for Print
18/01/2022 jlika1	TFS 51891 CPL - Reprint Posted Returned Invoice
07/09/2022 navpw1	TFS: 54564 (54379) - EUP - Inv Config - Debtor Currencies and Countries
*/

vars
	invoiceLine				  : CM_InvoiceLine;
	ils						  : CM_InvoiceLineStat;
	invLineStat			      : CM_InvoiceLineStat;
	dild 				      :	CM_DebtorInvoiceLineDesc;
	charge					  : CM_Charge;
	invStatTotal,
	eachRate,
	r						  : Real;
	i						  : Integer;
	j						  : Integer;
	code					  : String;
	strWithObject			  : CM_StringWithObject;
	invoicePrintRemarks  	  : Boolean;
	invNarration,theTIid 	  : String;
	printSingleLineForDayType : Boolean;
	configILD				  : CM_InvoiceLineDesc;
	configTax				  : CM_InvoiceLineDesc;
	codeTaxList   			  : String;
	includeVoided 			  : Boolean;
	term                      : CM_Terminal;

begin
	term                      := self.myTerminal;
	includeVoided             := self.isReverseCredit() or self.isPostedReturned();
	printSingleLineForDayType := self.invoiceType.printSingleLineForDayType;
	invoicePrintRemarks       := term.getConfig(InvoicePrintRemarks).Boolean;
	configILD                 := term.getCashRoundInvLineType( self.getBank );	//08 Jan 2019	NDl	TFS 40010
	configTax                 := term.getCashTaxInvLineType( self.getBank );	//08 Jan 2019	NDL	TFS 40010
	codeTaxList 			  := term.getConfig(CashAllCashTax).String;
	
	
	foreach invoiceLine in invoiceLines do
	
		if not includeVoided and invoiceLine.status = CM_InvoiceLine.STATUS_VOIDED then  //09/03/2020 cnwma1 TFS #48524
			continue;
		endif;
		
		r := 0;
		foreach charge in invoiceLine.charges do
			if configILD &lt;&gt; null and configILD = invoiceLine.invoiceLineDesc then  		  //16/08/2016 cnwma1 TFS #2538 PAR 38132
				r := r +invoiceLine.lineTotal;
			elseif configTax &lt;&gt; null and codeTaxList &lt;&gt; null and configTax=invoiceLine.invoiceLineDesc then
				r := r +invoiceLine.lineTotal;
			else
				//05/03/2020 cnwma1 TFS #48524
				eachRate := charge.getRate();  
				if includeVoided then
					eachRate := -eachRate;
				endif;
				r := r + eachRate;
				//05/03/2020 cnwma1 TFS #48524
			endif;
			
		endforeach;
		
		if invoicePrintRemarks then
			invNarration := invoiceLine.invoiceLineDesc.remarks[1:60];
			if invNarration.trimBlanks = null then // PAR 8526 added
				//invNarration := invoiceLine.invoiceLineDesc.narration; // PAR 8526 added
				invNarration := invoiceLine.getNarrationFromInvoiceLocale(); // ### TFS 54564 (54379) 05Sep2022 NAVPW1
			endif;
		else
			//invNarration := invoiceLine.invoiceLineDesc.narration;
			invNarration := invoiceLine.getNarrationFromInvoiceLocale(); // ### TFS 54564 (54379) 05Sep2022 NAVPW1
		endif;				
		// CCMS 1253. If necessary append the TI TI on the end
		if printSingleLineForDayType then
			if invoiceLine.invoiceLineDesc.isChargeByDaysType() then
				theTIid := invoiceLine.getTIID();
				invNarration := invNarration  &amp; " - " &amp; theTIid;
			endif;
		endif;

		invLineStat := invLineStatDict[invNarration, invoiceLine.manual and separateManualLines];
		if invLineStat = null then
			create invLineStat transient;
			invLineStat.narration := invNarration;
			dild				  := invoiceLine.invoiceLineDesc.getDILDForDebtor(self.debtor);
			
			if dild &lt;&gt; null then
				if dild.remarks &lt;&gt; null  
				and invoicePrintRemarks then 
					invLineStat.narrationConsolidated := dild.remarks;
				else
					invLineStat.narrationConsolidated := dild.narration;
				endif;
			else
				invLineStat.narrationConsolidated := invNarration;
			endif;

			invLineStat.printingOrder := invoiceLine.invoiceLineDesc.printingOrder;
			invLineStat.manual        := invoiceLine.manual and separateManualLines;
			invLineStatDict.add(invLineStat);
			invLineStat.rate 		  := r;
			invLineStat.unitNarration := invoiceLine.invoiceLineDesc.unitNarration;
			if invoiceLine.remarks &lt;&gt; "" then
				invLineStat.narrationComments.add(invoiceLine.remarks[1:512]);//TFS 7408
			endif;
		else
			if r &lt;&gt; invLineStat.rate then
				j := 1;
				while true do
					code := invNarration &amp; " (Diff. Rate " &amp; j.String &amp; ")";
					ils  := invLineStatDict[code, invoiceLine.manual and separateManualLines];
					if ils = null then
						create invLineStat transient;
						invLineStat.narration := code;
						dild 				  := invoiceLine.invoiceLineDesc.getDILDForDebtor(self.debtor);
						if dild &lt;&gt; null then
							if dild.remarks &lt;&gt; null
							and invoicePrintRemarks then 
								invLineStat.narrationConsolidated := dild.remarks;
							else
								invLineStat.narrationConsolidated := dild.narration;
							endif;
						else
							invLineStat.narrationConsolidated := invLineStat.narration;
						endif;
						invLineStat.printingOrder := invoiceLine.invoiceLineDesc.printingOrder;
						invLineStat.manual        := invoiceLine.manual and separateManualLines;
						invLineStatDict.add(invLineStat);
						invLineStat.rate          := r;
						//invLineStat.unitNarration := invoiceLine.invoiceLineDesc.unitNarration;
						invLineStat.unitNarration := invoiceLine.getUnitNarrFromInvoiceLocale(); // ### TFS 54564 (54379) 05Sep2022 NAVPW1
						break;
					else
						if ils.rate = r then
							invLineStat := ils;
							break;
						endif;
					endif;
					j := j + 1;
				endwhile;
			endif;
			if invoiceLine.remarks &lt;&gt; "" then
				if not invLineStat.narrationComments.includes(invoiceLine.remarks[1:512]) then	//TFS 7408
					invLineStat.narrationComments.add(invoiceLine.remarks[1:512]);				//TFS 7408
				endif;
			endif;
		endif;
		invLineStat.remarks         := invoiceLine.invoiceLineDesc.remarks;
		invLineStat.quantity        := invLineStat.quantity + invoiceLine.quantity;		
		invLineStat.narrationMinMax := invoiceLine.lineTotalUsedMinMax();
		
		if invoiceLine.invoiceLineDesc.bPrintTrackedItems or recordTrackedItems then
			create strWithObject transient;
			strWithObject.string := invoiceLine.trackedItemId;
			strWithObject.object := invoiceLine;
			invLineStat.allTrackedItems.add(strWithObject);
		endif;
		i := i + 1;
	endforeach;
	
	if pd &lt;&gt; null then	// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
		pd.progress.partsDone := i;
		pd.doWindowEvents(0);
		if pd.aborted then
			invLineStatDict.purge;
			return 0;
		endif;
	endif;

	foreach invLineStat in invLineStatDict do
		invLineStat.total :=  (invLineStat.quantity * invLineStat.rate).Decimal.asDecimal(12, $CM_ChargeQuantity.decimalPlaces); 
		invStatTotal      := invStatTotal + invLineStat.total; 

	endforeach;
	
	return invStatTotal;
epilog

end;</source>
        <Parameter name="invLineStatDict" type="CM_InvoiceLineStatByNarManDict" usage="input"/>
        <Parameter name="pd" type="CMS_Progress" usage="input"/>
        <Parameter name="recordTrackedItems" type="Boolean"/>
        <Parameter name="separateManualLines" type="Boolean"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceStatsByGL" id="30d5905e-9025-462b-87c1-9a2599ae9d63">
        <source>getInvoiceStatsByGL(	_invLineStatDict	 : CM_InvoiceLineStatByNarManDict input;
						_progress 			 : CMS_Progress input;
						_recordTrackedItems  : Boolean;
						_separateManualLines : Boolean	) : Real;
/*
Purpose:			Builds a consolidated invoice line dict based on GL code and invoice narration

Parameters:			

Return Value:		consolidated invoice line total

Date		Who		Reason
31/12/2012	cnwdap1	Initial creation PAR #30860 CCMS QNS 2236
08/03/2013	cnwdap1	PAR #31198 Consolidate by GL Code on the charge, show GL code in the description
02/04/2013	cnwdap1	PAR #31198 Don't show GL code in the narration
13/10/2017  jlgns1	TFS 7408 QNS - Receipt Error in Cash Module later fix
05/03/2020  cnwma1  ChangeRequest 48524: CPL - Credit Invoice Details for Print
07/09/2022	navpw1	TFS: 54564 (54379) - EUP - Inv Config - Debtor Currencies and Countries
*/
vars
	invoiceLine 				: CM_InvoiceLine;
	ils 						: CM_InvoiceLineStat;
	invLineStat					: CM_InvoiceLineStat;
	dild 						: CM_DebtorInvoiceLineDesc;
	charge						: CM_Charge;
	invStatTotal, r				: Real;
	i							: Integer;
	j							: Integer;
	code						: String;
	strWithObject				: CM_StringWithObject;
	invoicePrintRemarks 		: Boolean;
	invNarration		 		: String;
	dyna                        : DynaDictionary;
	dynaKey           		    : Integer;
	obj                         : Object;
	includeVoided 			    : Boolean;
begin
	invoicePrintRemarks := self.myTerminal.getConfig(InvoicePrintRemarks).Boolean;
	includeVoided       := self.isReverseCredit();                                       //09/03/2020 cnwma1 TFS #48524
	
	foreach invoiceLine in invoiceLines do
		
		if not includeVoided and invoiceLine.status = CM_InvoiceLine.STATUS_VOIDED then  //09/03/2020 cnwma1 TFS #48524
			continue;
		endif;
		
		r := 0;
		foreach charge in invoiceLine.charges do
			r := r + charge.getRate();
		
			if invoicePrintRemarks then
				invNarration := invoiceLine.invoiceLineDesc.remarks[1:60];
				if invNarration.trimBlanks = null then
					//invNarration := charge.glCode &amp; "^" &amp; invoiceLine.invoiceLineDesc.narration;										// PAR #31198
					invNarration := charge.glCode &amp; "^" &amp; invoiceLine.getNarrationFromInvoiceLocale();									// ### TFS 54564 (54379) 05Sep2022 NAVPW1
				else
					//invNarration := charge.glCode &amp; "^" &amp; invNarration;																// PAR #31198
					invNarration := charge.glCode &amp; "^" &amp; invoiceLine.getNarrationFromInvoiceLocale();									// ### TFS 54564 (54379) 05Sep2022 NAVPW1
				endif;
			else
				invNarration := charge.glCode &amp; "^" &amp; invoiceLine.invoiceLineDesc.narration;											// PAR #31198
			endif;				

			invLineStat := _invLineStatDict[invNarration, invoiceLine.manual and _separateManualLines];
			if invLineStat = null then
				create invLineStat transient;
				invLineStat.narration := invNarration;
				dild :=  invoiceLine.invoiceLineDesc.getDILDForDebtor(self.debtor);
				
				if dild &lt;&gt; null then
					if dild.remarks &lt;&gt; null
					and invoicePrintRemarks then 
						invLineStat.narrationConsolidated := dild.remarks;
					else
						invLineStat.narrationConsolidated := dild.narration;
					endif;
				else
					invLineStat.narrationConsolidated := invNarration;
				endif;

				invLineStat.printingOrder := invoiceLine.invoiceLineDesc.printingOrder;
				invLineStat.manual 		  := invoiceLine.manual and _separateManualLines;
				_invLineStatDict.add(invLineStat);
				invLineStat.rate 		  := r;
				//invLineStat.unitNarration := invoiceLine.invoiceLineDesc.unitNarration;
				invLineStat.unitNarration := invoiceLine.getUnitNarrFromInvoiceLocale(); // ### TFS 54564 (54379) 05Sep2022 NAVPW1
				if invoiceLine.remarks &lt;&gt; "" then
					invLineStat.narrationComments.add(invoiceLine.remarks[1:512]);//TFS 7408
				endif;
			else
				if r &lt;&gt; invLineStat.rate then
					j := 1;
					while true do
						code := invNarration &amp; " (Diff. Rate " &amp; j.String &amp; ")";
						ils := _invLineStatDict[code, invoiceLine.manual and _separateManualLines];
						if ils = null then
							create invLineStat transient;
							invLineStat.narration := code;
							dild :=  invoiceLine.invoiceLineDesc.getDILDForDebtor(self.debtor);
							if dild &lt;&gt; null then
								if dild.remarks &lt;&gt; null 
								and invoicePrintRemarks then 
									invLineStat.narrationConsolidated := dild.remarks;
								else
									invLineStat.narrationConsolidated := dild.narration;
								endif;
							else
								invLineStat.narrationConsolidated := invLineStat.narration;
							endif;
							invLineStat.printingOrder := invoiceLine.invoiceLineDesc.printingOrder;
							invLineStat.manual 		  := invoiceLine.manual and _separateManualLines;
							_invLineStatDict.add(invLineStat);
							invLineStat.rate 		  := r;
							//invLineStat.unitNarration := invoiceLine.invoiceLineDesc.unitNarration;
							invLineStat.unitNarration := invoiceLine.getUnitNarrFromInvoiceLocale(); // ### TFS 54564 (54379) 05Sep2022 NAVPW1
							break;
						else
							if ils.rate = r then
								invLineStat := ils;
								break;
							endif;
						endif;
						j := j + 1;
					endwhile;
				endif;
				if invoiceLine.remarks &lt;&gt; "" then
					if not invLineStat.narrationComments.includes(invoiceLine.remarks[1:512]) then	//TFS 7408
						invLineStat.narrationComments.add(invoiceLine.remarks[1:512]);				//TFS 7408
					endif;
				endif;
			endif;
			invLineStat.remarks  := invoiceLine.invoiceLineDesc.remarks; 
			invLineStat.quantity := invLineStat.quantity + invoiceLine.quantity;
			
			invLineStat.narrationMinMax := invoiceLine.lineTotalUsedMinMax();
			
			if invoiceLine.invoiceLineDesc.bPrintTrackedItems or _recordTrackedItems then
				create strWithObject transient;
				strWithObject.string := invoiceLine.trackedItemId;
				strWithObject.object := invoiceLine;
				invLineStat.allTrackedItems.add(strWithObject);
			endif;
		endforeach;							

		i := i + 1;
	endforeach;
	
	if _progress &lt;&gt; null then
		_progress.progress.partsDone := i;
		_progress.doWindowEvents(0);
		if _progress.aborted then
			_invLineStatDict.purge;
			return 0;
		endif;
	endif;

	//this calculates what the invoice total SHOULD show.  It mimics the userNumberFormat($CM_ChargeQuantity) rounding
	foreach invLineStat in _invLineStatDict do
		// this next line rounds to 2 decimal places
		invLineStat.total := (invLineStat.quantity * invLineStat.rate).Decimal.asDecimal(12, $CM_ChargeQuantity.decimalPlaces); // PAR 20477
		invStatTotal := invStatTotal + invLineStat.total;
	endforeach;

	return invStatTotal;

epilog
end;</source>
        <Parameter name="_invLineStatDict" type="CM_InvoiceLineStatByNarManDict" usage="input"/>
        <Parameter name="_progress" type="CMS_Progress" usage="input"/>
        <Parameter name="_recordTrackedItems" type="Boolean"/>
        <Parameter name="_separateManualLines" type="Boolean"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceStatsConsolidate" id="b094d2dc-43f8-4332-b369-f5dc7842c8bb">
        <source>getInvoiceStatsConsolidate(_invLineStatDict: CM_InvoiceLineStatByNarManDict input) : CM_InvoiceLineStatByNarManDict;

// Consolidates by Narration on  an Invoice Line Consolidation object and the Rate

// This function is getting out of control!  If separateManualLines is true then
// there is a separate CM_InvoiceLineStat for manual lines.
//	Returns the only true invoice total.
vars
	invLineStatDictCol: CM_InvoiceLineStatByColNarDict;
	invLineStatDictForConsolidatn: CM_InvoiceLineStatByNarManDict;
	ils:            CM_InvoiceLineStat;
	invLineStat:    CM_InvoiceLineStat;
//	charge:         CM_Charge;
//	tempDec:		Decimal[12,2];
//	invStatTotal,
//	r:              Real;
	i:              Integer;
	j:              Integer;
	code:           String;
//	strWithObject:  CM_StringWithObject;
begin
	create invLineStatDictCol transient;
	create invLineStatDictForConsolidatn transient;
	
	
	foreach ils in _invLineStatDict do
		invLineStat := invLineStatDictCol[ils.narrationConsolidated, ils.rate];
		if invLineStat = null then
			create invLineStat transient;
			invLineStat.narration := ils.narrationConsolidated;
			invLineStat.narrationConsolidated := ils.narrationConsolidated;
			invLineStat.rate :=  ils.rate;
			invLineStatDictCol.add(invLineStat);

			invLineStat.printingOrder := ils.printingOrder;
			invLineStat.manual := ils.manual ;
			invLineStat.unitNarration := ils.unitNarration;
			if not ils.narrationComments.isEmpty then
				ils.narrationComments.copy(invLineStat.narrationComments);
			endif;
			//moved to after the endif;
			//invLineStat.remarks := invoiceLine.invoiceLineDesc.remarks; // CCMS 1074
		else
			if not ils.narrationComments.isEmpty then
				ils.narrationComments.copy(invLineStat.narrationComments);
			endif;
		endif;
		invLineStat.remarks := ils.remarks;
		invLineStat.quantity := invLineStat.quantity + ils.quantity;
		invLineStat.total 	 := invLineStat.total + ils.total;	
		invLineStat.allTrackedItems.copy(ils.allTrackedItems);
		i := i + 1;
	endforeach;
	
	j := 1;
	foreach ils in invLineStatDictCol do
		invLineStat := invLineStatDictForConsolidatn[ils.narrationConsolidated, ils.manual];
		if invLineStat &lt;&gt; null then
			code :=ils.narrationConsolidated &amp; " (Diff. Rate " &amp; j.String &amp; ")";
			ils.narrationConsolidated := code;
			ils.narration := code;
			j:=j+1;
		else
			j := 1;
		endif;
		invLineStatDictForConsolidatn.add(ils);
	endforeach;

	return invLineStatDictForConsolidatn;
	
epilog
	delete invLineStatDictCol;
end;</source>
        <Parameter name="_invLineStatDict" type="CM_InvoiceLineStatByNarManDict" usage="input"/>
        <ReturnType type="CM_InvoiceLineStatByNarManDict"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceStatsConsolidate2One" id="e1015d2a-db6d-48ee-9aed-3dd150e5ee5c">
        <source>getInvoiceStatsConsolidate2One(_invLineStatDict: CM_InvoiceLineStatByNarManDict input) : CM_InvoiceLineStatByNarQtyDict;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		CCM 1125 - Consolidate the invoice down to 1 line.
//
// ---------------------------------------------------------------------------
// This function is getting out of control!  If separateManualLines is true then
// there is a separate CM_InvoiceLineStat for manual lines.
//	Returns the only true invoice total.
vars
//	invLineStatDictCol: CM_InvoiceLineStatByColNarDict;
	invLineStatDictForConsolidatn: CM_InvoiceLineStatByNarQtyDict;
	ils:            CM_InvoiceLineStat;
	invLineStat:    CM_InvoiceLineStat;
//	charge:         CM_Charge;
//	tempDec:		Decimal[12,2];
//	invStatTotal,
//	r:              Real;
	i:              Integer;
//	j:              Integer;
//	code:           String;
//	strWithObject:  CM_StringWithObject;
	theQty			: Real;
	prevQuantity 	: Real;
//	theRate, theTotal : Real;
//	allSameQty : Boolean;
//	sameQTY : Boolean;
	consolNarr : String;
	diffRatePos : Integer;
begin
	create invLineStatDictForConsolidatn transient;

	foreach ils in _invLineStatDict do
		consolNarr := ils.narration;
		theQty :=  ils.quantity;
		diffRatePos := consolNarr.pos("(Diff. Rate",1); 
		if diffRatePos &gt; 0 then
			consolNarr := consolNarr[1 : diffRatePos - 1].trimBlanks;
		endif;
		
		//PAR 15225, if there is a different quantity the code was using the narr with 'diff rate' in it which stopped all following lines not to consolidate.
		/*invLineStat := invLineStatDictForConsolidatn.getAtKeyGeq(consolNarr,0);
		if invLineStat &lt;&gt; null and invLineStat.narration = consolNarr 
		and invLineStat.quantity &lt;&gt; theQty then
			consolNarr := consolNarr &amp; " (Diff Quantity)";
		endif;*/
		invLineStat := invLineStatDictForConsolidatn.getAtKeyGeq(consolNarr,prevQuantity);			//par 22923 begin
		if invLineStat &lt;&gt; null and invLineStat.narration[1:consolNarr.length()] = consolNarr and invLineStat.quantity &lt;&gt; theQty then			
			consolNarr := consolNarr &amp; " (Diff Quantity "&amp; theQty.asStringJMT() &amp;")";
		endif;			
																			
		prevQuantity := theQty;			////par 22923 end
		
		invLineStat := invLineStatDictForConsolidatn[consolNarr,theQty];
		if invLineStat = null then
			create invLineStat transient;
			invLineStat.narration := consolNarr;
			invLineStat.quantity := theQty;

			invLineStatDictForConsolidatn.add(invLineStat); 

			invLineStat.narrationConsolidated := ils.narrationConsolidated;
			invLineStat.printingOrder := ils.printingOrder;
		endif;

		invLineStat.rate := invLineStat.rate + ils.rate;
		invLineStat.total 	 := invLineStat.total + ils.total;	
		i := i + 1;
	endforeach;
	// ################################
/*	
	// ## CP wanted that if all the quantities were the same then we set the qty to that of the first line.
	theQty := -9999999;
	allSameQty := true;
	foreach ils in _invLineStatDict do
		theTotal := theTotal + ils.total;
		if ils.quantity &lt;&gt; theQty and theQty &lt;&gt; -9999999 then
			allSameQty := false;
		endif;
		theQty := ils.quantity;
	endforeach;

	if not allSameQty then
		theQty := 0;
		theTotal := 0; // PAR8325
		foreach ils in _invLineStatDict do
			theQty := theQty + ils.quantity;
			theTotal := theTotal + ils.total;
		endforeach;
	else
		if theQty = -9999999 then
			theQty := 1;
		endif;
	endif;
	
	theRate := theTotal / theQty;
	invLineStat.quantity := theQty;
	invLineStat.total 	 := theTotal;	
	invLineStat.rate := theRate;
*/
	return invLineStatDictForConsolidatn;
	
epilog
//	delete invLineStatDictCol;
end;</source>
        <Parameter name="_invLineStatDict" type="CM_InvoiceLineStatByNarManDict" usage="input"/>
        <ReturnType type="CM_InvoiceLineStatByNarQtyDict"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceStatusObject" id="e00c6eda-37a6-403d-8467-8d80a31c2295">
        <source>getInvoiceStatusObject(_status : Integer) : CM_InvoiceStatus;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Oct 2018	jlgsl4	TFS 39618 - LNX - Initial creation
05 Jun 2025 navma1  MTN-34114  MTN - Performance Improvements - Remove Class::FirstInstance usage  
*/

vars
	invoiceProcess : CM_InvoiceProcess;
begin
	
	invoiceProcess := self.getMyInvoiceProcess;
	
	if invoiceProcess = null then // use JMT default process if no InvoiceProcess has been set for
		invoiceProcess := app.myRoot.allInvoiceProcesses[InvoiceProcessDefault];		// the terminal by upgrade script	//05.06.2025 navma1 #MTN-34114; 
	endif;
	
	return invoiceProcess.allStatuses[_status];
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="CM_InvoiceStatus"/>
    </JadeMethod>
