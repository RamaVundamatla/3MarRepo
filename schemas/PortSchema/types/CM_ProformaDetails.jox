    <JadeMethod name="getGLRateSummaryStats" id="0d2a27ef-8875-4d60-9020-22af746cc139">
        <source>getGLRateSummaryStats(_glSumm : CM_GLSummaryByGLCodeRateDict input);
// Feb 2016 TFS 985 for Milaha credit export to Oracle
vars
	glCode	: String;
	service : CM_Service;
	gl		: CM_GLSummary;

begin
	// the rate is already on this instance, use the first service name
	service := self.myInvoiceLineType.services.first;
	if service = null then			// it shouldn't ever be? but if it is then this will have a zero value
		return;
	endif;
	
	if service.genLCode = null then
		glCode := null;
	else
		glCode := service.genLCode.code;
	endif;

	gl := _glSumm[glCode, self.rate, service.name];
	if gl = null then
		create gl;
		gl.glCode := glCode;
		gl.rate := self.rate;
		gl.serviceName := service.name;
		_glSumm.add(gl);
	endif;

	gl.quantity := gl.quantity + self.quantity;
	gl.amount := gl.amount + self.lineTotal;
	gl.myInvoiceLine := null;		// this isn't used in the export
	
end;</source>
        <Parameter name="_glSumm" type="CM_GLSummaryByGLCodeRateDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getProformaDesc" id="793e9464-ac47-4c64-8b98-8cea32f6e9b9">
        <source>getProformaDesc() : String;
// 34917 return the cash payment proformaDesc string to store on the associated CM_CashPayment
