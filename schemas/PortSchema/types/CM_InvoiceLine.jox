    <JadeMethod name="getServiceTypeCode" id="87b47119-69ff-4bc5-a699-e154131284cf">
        <source>getServiceTypeCode() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2022	navkc1	Initial creation - ChangeRequest 54570: EUP - Inv Config - Selector Query

*/

vars
	service			: CM_Service;
	serviceType		: CM_ServiceType;
	allServiceTypes,
	code			: String;
	stringArray		: StringArray;
	
begin
	create stringArray transient;
	
	foreach service in self.invoiceLineDesc.services do
		
		if service.allServiceTypes.isEmpty() then
			continue;
		endif;
		
		foreach serviceType in service.allServiceTypes do 
			if not stringArray.includes(serviceType.code) then
				stringArray.add(serviceType.code);
			endif;
		endforeach;
	endforeach;

	foreach code in stringArray do
		if allServiceTypes &lt;&gt; null then
			allServiceTypes := allServiceTypes &amp; ",";
		endif;
		allServiceTypes := allServiceTypes &amp; code;
	endforeach;
	
	return allServiceTypes;
epilog
	delete stringArray;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
