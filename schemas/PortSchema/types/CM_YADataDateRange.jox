    <JadeMethod name="setForUpdate" id="1d463459-22f6-4969-ac5e-d6108699b7bc">
        <updating/>
        <source>setForUpdate(pProxyObj: SelfType) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/05/2025	navdap1		Initial creation MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
//
vars

begin
	self.startDate := pProxyObj.startDate;
	self.endDate := pProxyObj.endDate;
epilog

end;</source>
        <Parameter name="pProxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="70699229-1b7b-43b0-9cf2-1206a3e0dcde">
        <updating/>
        <source>setProxy(_dates : String) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/05/2025	navdap1		Initial creation MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
// 26/06/2025	navdap1		MTN-35179 4031 Index used in substring is out of bounds in Satellite View
//
vars
	pos : Integer;

begin
	pos := _dates.pos("|", 1);
	if pos = null then				// MTN-35179
		if _dates.Date.isValid then
			self.startDate := _dates.Date;
			self.endDate := self.startDate;
		endif;
		return;
	endif;
	
	if pos = 1 then
		self.startDate := null;
	else
		self.startDate := _dates[1:pos-1].Date;
	endif;
	if pos = _dates.length then
		self.endDate := null;
	else
		self.endDate := _dates[pos+1:end].Date;
	endif;
epilog

end;</source>
        <Parameter name="_dates" type="String"/>
    </JadeMethod>
    <JadeMethod name="validate" id="816a7b87-0138-449b-868e-89b61aa7414b">
        <source>validate();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/05/2025	navdap1		Initial creation TFS MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
//
vars

begin
	inheritMethod();
	
	// Check the dates
	if self.endDate &lt; self.startDate then
		app.raiseCMException(EndDate_Before_StartDate, null, null);
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
