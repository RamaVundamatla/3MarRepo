    <JadeMethod name="getMultiValueConvertedString" id="32537fca-0608-468c-841e-769f97269334">
        <source>getMultiValueConvertedString( 	rawDisplayValue : Decimal input;
								measureToUse : CM_MeasurementType;
								convertedValue : String io
								);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

	measureType : CM_MeasurementType;
	decimals : Integer;

begin

	if not app.myRoot.getConfig(MeasuresSeparateLines).Boolean and rawDisplayValue &lt;&gt; null then
		foreach measureType in app.myRoot.allMeasurementTypesByShortName do
			if measureType = measureToUse 
			or measureType.measurementType &lt;&gt; measureToUse.measurementType 
			or not measureType.isAvailableForEntry 
			or not measureType.isDisplay then
				continue;
			endif;
			// convert from default measurement type to this measurement type
			decimals := measureToUse.getDecimalPrecision();
			if convertedValue = null then
				convertedValue := app.convertMeasurementForDisplay(measureType.shortName, rawDisplayValue) &amp; " " &amp; measureType.shortName;
			else
				//value := value &amp; ", " &amp; app.convertMeasurementForDisplay(measureType.shortName, displayString) &amp; " " &amp; measureType.shortName;				// PAR #33603
				convertedValue := convertedValue &amp; SemiColon &amp; Space &amp; app.convertMeasurementForDisplay(measureType.shortName, rawDisplayValue) &amp; " " &amp; measureType.shortName;	// PAR #33603
			endif;
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="rawDisplayValue" type="Decimal" usage="input"/>
        <Parameter name="measureToUse" type="CM_MeasurementType"/>
        <Parameter name="convertedValue" type="String" usage="io"/>
    </JadeMethod>
