    <JadeMethod name="recalculateCriteriaPriorities" id="31b097b8-f2c7-410a-b901-b91c03c36e9b">
        <updating/>
        <source>recalculateCriteriaPriorities() updating;
// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
vars
	criteriaObj			: CM_YACriteria;
	priorityTotal		: Real;	//26 Feb 2020	NDL	TFS 48689 change from Integer to Real
	
begin
	priorityTotal	:=	0;
	
	foreach criteriaObj in self.allCriteria do
		priorityTotal	:=	priorityTotal + criteriaObj.calculateInvoicePriority();
	endforeach;
	
	self.setPriorityValue(priorityTotal);
end;
</source>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="66b5da45-f3ca-481d-89a4-eab047ac0c64">
        <updating/>
        <source>setForUpdate(_proxyObj: CM_InvoiceAllocation) updating;
// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
//19 Jun 2017	cnwma1 TFS #4498 JMT - Cargo Allocation Fix Up Export Script
vars
	realQtyMap : CM_QuantityMap;
	realBroker : CM_CargoServiceBroker;
begin
	inheritMethod(_proxyObj);
	
	if _proxyObj.isTransient then //09/06/2017 cnwma1 TFS #4498
		return;
	endif;
	self.myQuantityMap := _proxyObj.myQuantityMap;
	self.myServiceBroker := _proxyObj.myServiceBroker;
		

end;
</source>
        <Parameter name="_proxyObj" type="CM_InvoiceAllocation"/>
    </JadeMethod>
