    <JadeMethod name="getAllCalendarDatesForDay" id="c1c4ea06-56a2-4a9e-9e8b-579bd9d15213">
        <source>getAllCalendarDatesForDay( _date : Date; _calendars : CM_CalendarDatesByDateTimedict io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 October 2010	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	firstObject : CM_CalendarDate;
	calendarDate : CM_CalendarDate;
	
begin

	_calendars.clear();
	if self.allCalendarDates.isEmpty or not _date.isValid then
		return;
	endif;
	
	firstObject := self.allCalendarDates.getAtKeyGeq( _date, null );
	if firstObject = null then
		return;
	endif;
	
	iter := self.allCalendarDates.createIterator;
	iter.startAtObject(firstObject);
	while iter.next( calendarDate ) do
		if calendarDate.date &lt;&gt; _date then
			return;
		endif;
		_calendars.add( calendarDate );
	endwhile;
	
epilog

	delete iter;

end;</source>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_calendars" type="CM_CalendarDatesByDateTimedict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getBusinessDaysBetween" id="9e2ba4d4-c4b0-4d90-9be1-c976f6b67476">
        <source>getBusinessDaysBetween(_startTimeStamp, _endTimeStamp : TimeStamp) : Integer;
// CCMS 1295 free storage days - used to derive storage quantities
// Date				Who		Reason
// 18 Oct 2024 		navlw1	JIRA-33107: Invoice Logging Use Levels
// 25 Feb 2025		navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
vars
	count	: Integer;
	days	: Integer;
	result	: Integer;
	date	: Date;
	calendarDate : CM_CalendarDate;
	canLogExtra			: Boolean;	//26.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//26.02.2025 navah1	#34141
	if canLogExtra then	//26.02.2025 navah1	#34141
		app.invLog(method.qualifiedName &amp; " _startTimeStamp: " &amp; _startTimeStamp.String &amp; " _endTimeStamp: " &amp; _endTimeStamp.String, LogINFO.String);
	endif;
	if not _startTimeStamp.isValid or not _endTimeStamp.isValid then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " Returning ZERO - invalid dates", LogINFO.String);
		endif;
		return 0;
	endif;
	days := _endTimeStamp.date - _startTimeStamp.date;
	if self.allCalendarDates.isEmpty or
	   days &lt;= 0 then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " Returning Days - No Dates in Calendar", LogINFO.String);
		endif;
		return days;
	endif;
	
	date := _startTimeStamp.date;
	while true do
		date := date + 1;
		count := count + 1;
		calendarDate := self.getFirstCalendarDateForDay(date);
		if calendarDate = null then	// not a weekend/holiday
			result := result + 1;
		else
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " Excluding Date - " &amp; calendarDate.date.String, LogINFO.String);
			endif;

		endif;
		if count = days then
			break;
		endif;
	endwhile;
	
	return result;
end;
</source>
        <Parameter name="_startTimeStamp" type="TimeStamp"/>
        <Parameter name="_endTimeStamp" type="TimeStamp"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCalendarNoDatesMessage" id="bb204950-87e0-4758-b055-1d099b8d9346">
        <source>getCalendarNoDatesMessage( _numDaysNotice : Integer ) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 November 2010	cnwndl1	Initial creation	Par 25530

*/

vars

	date : Date;
	calendarDate : CM_CalendarDate;
	
begin

	calendarDate := self.allCalendarDates.last();
	
	if calendarDate &lt;&gt; null then
	
		if calendarDate.date &gt;= date then
			// to day or in teh future.
			if (date + _numDaysNotice).Date &gt; calendarDate.date then
				// the last calendsr date scheduled is less than _numDaysNotice days away.
				// create a message line for the Email
				return app.getErrorString2(Calendar_last_date_is, self.description, calendarDate.date.asStringJMT );
				
			else
				// Its scheduled out past _numDaysNotice days away, all is good.
				return null;
				
			endif;
		else
			// in the past
			// create a message line for the Email
			return app.getErrorString2(Calendar_last_date_was, self.description, calendarDate.date.asStringJMT );
			
		endif;
	else
		// There are no days in the calendar at all.
		// create a message line for the Email
		return app.getErrorString1(Calendar_no_dates, self.description );
		
	endif;
	
epilog

end;</source>
        <Parameter name="_numDaysNotice" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="01119777-837f-4e2a-9b63-fd23efad8a9a">
        <source>getDisplayDetails(_short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 November 2010	cnwndl1	Initial creation

*/

vars

begin

	if _short then
		return self.code;
