    <JadeMethod name="getSearcherHeight" id="5d875293-1e00-4741-bd6e-fc1c3ea2478b">
        <source>getSearcherHeight() : Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwer1	Initial creation

*/
constants 
	SEARCHER_HEIGHT = 30;
vars

begin

	//24 Feb 2015	NDL	Par 35604
	if self.useHHResizeCode then
		return self.getStdControlHeight() + ( self.resizedMargin * 2 );
	endif;
	
	if app.myVMAgent = null then
		return SEARCHER_HEIGHT;
	endif;
	
	if app.myVMAgent.getMyRTVehicleConfig = null then	
		return SEARCHER_HEIGHT;
	endif;
	
	if app.myVMAgent.getMyScreenMode = null then	
		return SEARCHER_HEIGHT;
	endif;
	
	//return self.cmbSearchItem.clientHeight + (self.MARGIN * 2);
	return self.getStdControlHeight() + (self.resizedMargin * 2);
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSelectableCargoReleaseSTW" id="f179cbe4-2b3c-4f08-adac-db36d4a635bb">
        <source>getSelectableCargoReleaseSTW( _tiSet : CM_TISet input; _bulkRelease : CM_BulkRelease; _reserveDetail : CM_ReserveDetail; _firstStagingLC : CM_LocationsController io );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 November 2015	cnwndl1	Initial creation	Par 37152
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars

	ti : CM_TrackedItem;
	cargoType : CM_CargoType;
	iter : Iterator;
	startTi : CM_TrackedItem;
	reason : String;
	allowOtherReleases : Boolean;
	allTis	: CM_TISet;
begin
	create allTis transient;
	
	allowOtherReleases := _bulkRelease.allowCargoOnMultipleReleases;

	if _reserveDetail &lt;&gt; null then
		_reserveDetail.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
		if _reserveDetail.isKindOf(CM_ReserveTI) then
			//foreach ti in _reserveDetail.allTrackedItems do
			foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
				if not ti.isStagedFor( _bulkRelease ) then
					if ti.isAvailableToStageFor(  _bulkRelease ) then	//21 Jan 2016	NDL	Par 37439
						_tiSet.addNoDuplicates( ti, false );
					endif;
				elseif _firstStagingLC = null then	//21 Jan 2016	NDL	Par 37439
					_firstStagingLC := ti.myPrimaryActualLocation;
				endif;
			endforeach;
		elseif _reserveDetail.isKindOf(CM_ReserveSelection) then
			//foreach ti in _reserveDetail.allTrackedItems do
			foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
				if not ti.isStagedFor( _bulkRelease ) then
					if ti.isAvailableToStageFor(  _bulkRelease ) then	//21 Jan 2016	NDL	Par 37439
						_tiSet.addNoDuplicates( ti, false );
					endif;
				elseif _firstStagingLC = null then	//21 Jan 2016	NDL	Par 37439
					_firstStagingLC := ti.myPrimaryActualLocation;
				endif;
			endforeach;
			if _tiSet.isEmpty then
				//none actually assigned that aren't already in a staging area
				//so search the rest of the onsite cargo
				self.getNonStagedAvailSTW( _reserveDetail.CM_ReserveSelection, _tiSet,  allowOtherReleases, _bulkRelease );	// 17 Mar 2016	NDL	TFS 1684
			
			endif;
		endif;
	endif;

epilog

	delete iter;
	delete allTis;
end;</source>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
        <Parameter name="_firstStagingLC" type="CM_LocationsController" usage="io"/>
    </JadeMethod>
