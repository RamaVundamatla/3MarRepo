	self.setWarehouseDoor(null);
	self.setSplitValues( 0, 0, null );
	self.setMyYardLocation(null);
	self.setMyWle(null);
	self.setMyVoyage(null);
	self.setInterTerminal(false);
	self.setInward(true);
	self.setForward( true );
	self.setDoingReversal( false );
	self.setMyReceivalRequestInfo(null);
	self.setMyMultiUnloadArrayContent( null );
	self.setMyNextTiToAction(null);
	self.setAutoPlanWagonCargo( false );
	self.setCurrentRakePosition( 0 );
	self.setChecksState(0);
	self.allCargoCheckItemSelections.purge();
	self.allCurrentVoyages.clear();
	self.setAllMultiMoveCargo( null );
	self.allNonCargoCheckItemSelections.purge();
	self.setDecimalField1(0);
	self.setDisplayIdOnCheckForm(false);
	self.setDriver(null);
	self.setLocationPreChecks(null);
	self.setMyBOL(null);
	self.setMyBookingRef(null);
	self.setMyCraneTransferArea(null);
	self.setMyCurrentRailLine( null );
	self.setMyCurrentTrain( null );
	self.setMyCurrentWagon( null );
	self.setMyDeliveryRequest(null);
	self.setGate(null);
	self.setMyLocationsController(null);
	self.setStringField1(null);
	self.setMyMachine(null);	//05 Apr 2016	NDL	TFS 1667
	self.setAllReserveDetails(null);
	self.setAllBookingRefItems(null);		// TFS 2653
	self.setAllSelectedBookings(null);	// TFS 2811 / 2549
	//self.setMyNotifiedCargoGroup(null);	//06 Jul 2018	NDL	TFS 39186
	self.setMyCargoGroupAssignment(null);	//06 Jul 2018	NDL	TFS 39186
	self.setMyCargoGroup(null);	//02 Oct 2018	NDL	TFS 39186
	self.setReloadValues(0,0);	//28 Aug 2018	NDL	TFS 39769
epilog

end;</source>
