    <JadeMethod name="translateForm" id="b14e8754-4ac8-449a-90e5-acee90689d44">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 19 October 2017 08:58:12.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017166, locale);
	chkShowColour.translateCaption(Xlat_0017167, locale);
	chkShowDirections.translateCaption(Xlat_0022157, locale);
	chkShowFail.translateCaption(Xlat_0017168, locale);
	chkShowRTG.translateCaption(Xlat_0017169, locale);
	chkShowSelPanel.translateCaption(Xlat_0017170, locale);
	chkShowYAMTable.translateCaption(Xlat_0017171, locale);
	lblDoubleClick.translateCaption(Xlat_0017172, locale);
	lblHeightRest.translateCaption(Xlat_0020363, locale);
end;</source>
    </JadeMethod>
