    <JadeMethod name="addToolbarControls" id="b035ea29-2f49-4668-a4b4-379cc7cae27f">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 August 2004 by cnwrs2
//
// Purpose:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	toolbar		: CMUI_Toolbar;
begin
	inheritMethod();

	toolbar := self.frmToolbar;

	toolbar.addButton(self.btnViewDwellDays, CMUI_Toolbar.Control_Alignment_Left);	//20 Jul 2011	NDL	Par 27890
	toolbar.addButton(self.btnViewVoyage, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnViewTrain, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewCommodity, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewConsignee, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewDischarge, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnViewDest,CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnViewISOGroup, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewOperator, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnViewStatus, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewCargoType, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewYardAlloc, CMUI_Toolbar.Control_Alignment_Left);
	

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnMoveTopLeft, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnMoveTopRight, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnMoveBotLeft, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnMoveBotRight, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);

	if app.getMyUser.canDo (self.myTerminal, PmAdmAuditTALocationView) then
		toolbar.addSeperator( CMUI_Toolbar.Control_Alignment_Left );
		toolbar.addButton( self.btnTALocnAudit, CMUI_Toolbar.Control_Alignment_Left );
	endif;
	if app.myCurrentUserCan( self.myTerminal, PmSummaryDefView ) then
		// always make this button visible but the enabling will depend on the display mode being used.
		toolbar.addSeperator( CMUI_Toolbar.Control_Alignment_Left );
		toolbar.addButton( self.btnSummariseAll, CMUI_Toolbar.Control_Alignment_Left );
	endif;



end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnFlipH_click" id="bb1f482c-ab4c-455e-8cef-a0203116c4ba">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnFlipH_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	tmpDC :	YRD_GCRackDrawingController;
begin
	tmpDC := self.myCurrentDrawingController;
	tmpDC.setFlip(not tmpDC.flipHorizontal, tmpDC.flipVertically);
	self.xmlFlipH := tmpDC.flipHorizontal;
	self.xmlFlipV := tmpDC.flipVertically;
	tmpDC.drawSelf(true);
	self.doSetCaption();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnFlipV_click" id="3d336b62-f0c9-4343-9973-d1e2e84e067a">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnFlipV_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpDC :	YRD_GCRackDrawingController;
begin
	tmpDC := self.myCurrentDrawingController;
	tmpDC.setFlip(tmpDC.flipHorizontal, not tmpDC.flipVertically);
	self.xmlFlipH := tmpDC.flipHorizontal;
	self.xmlFlipV := tmpDC.flipVertically;
	tmpDC.drawSelf(true);
	self.doSetCaption();

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
