    <JadeMethod name="validateForUpdate" id="4fd61c07-fd8c-4023-8761-080f0144580b">
        <source>validateForUpdate(_readTransObj: SelfType; _passportObj:CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		05 September 2008 by cnwdad1
//
// Purpose:		Standard method that is invoked from a transaction when the receiver
//				is updated.
//
// Parameters:	_realDefinitionObj - A reference to the real (i.e. not a proxy) object.
//				_passportObj - A reference to the current user's Passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.validateMe(_readTransObj, _passportObj);
end;</source>
        <Parameter name="_readTransObj" type="SelfType"/>
        <Parameter name="_passportObj" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="850d8314-c92b-4bc7-b569-22d326fd14c4">
        <source>validateMe(_readTransObj: SelfType; _passportObj:CM_Passport input) protected;
// --------------------------------------------------------------------------------
// Created:		05 September 2008 by cnwdad1
//
// Purpose:		Standard validation method to validate the receiver's property values,
//				and raises an exception if any of the data is not valid.
//
// Parameters:	_realDefinitionObj - A reference to the real (i.e. not a proxy) object.
//				_passportObj - A reference to the current user's Passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.translationString = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Translation value", null, null);
		app.raiseCMException(Input_required_field_transVal, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.myInterfaceDefinition = null then
//		app.raiseCMException1(REQUIRED_FIELD, "Interface Definition", null, null);
		app.raiseCMException(Input_required_field_intfceDef, null, null); // cnwdb2	PAR 35364


	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_readTransObj" type="SelfType"/>
        <Parameter name="_passportObj" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
