    <JadeMethod name="handleException" id="87b2e89a-9b01-4b97-97bb-e76302e4b7f2">
        <source>handleException(exObj: Exception): Integer;

constants
	StringTooLong = 1035;
vars
	errObject:      Object;
	methCall:       MethodCallDesc;
	msg:            String;
begin
	if exObj.errorCode = StringTooLong then
		methCall := exObj.currentMethodDesc;
		msg := "The string is too long: " &amp; methCall.receiverAsString;
		errObject := exObj.errorObject;
		app.msgBox (msg, "Error", 0);
		if process.isInTransactionState then
			abortTransaction;
		endif;
		return Ex_Abort_Action;
	else
		return Ex_Pass_Back;	 //default dialog
	endif;
end;</source>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
