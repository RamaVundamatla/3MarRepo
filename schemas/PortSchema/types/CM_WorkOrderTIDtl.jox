					_realJob	  : CM_Job io;
					_passport     : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Apr 2023 navma1 ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks

*/

vars

begin

epilog

end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction"/>
        <Parameter name="_realJob" type="CM_Job" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCompleteTask" id="c22ac927-63a7-499a-bf66-635819f92f30">
        <updating/>
        <source>doCompleteTask(_operationalWle ,
			   _workOrderWle   : CM_WorkListEntry;
			   _toDoTaskDesc   : CM_ToDoTaskDesc)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jun 2023 navma1 ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation

*/

vars
	ti 			: CM_TrackedItem;
	parent	 	: CM_WorkOrderTI;
	doComplete  : Boolean;
	todoTaskDesc: CM_ToDoTaskDesc;
	isRelByType : Boolean;
	reserveDet  : CM_ReserveDetail;
begin
	inheritMethod(_operationalWle, _workOrderWle,_toDoTaskDesc);
	
	if _workOrderWle &lt;&gt; null then
		ti := _workOrderWle.myTrackedItem;
	endif;
	
	if ti = null then
		ti  := _operationalWle.myTrackedItem;
		
	endif;
	
	if ti = null then
		return;
	endif;
	
	/*
	Release by Type 
	Needs to add to selectedTIs 
	*/
	if self.allCompleteTIs.includes(ti) then					// Already Completed
		return;
	endif;
	
	// remove from available
	self.allAvailableTIs.tryRemoveIfNotNull( ti);

	//remove from actioned
	self.allActionedTIs.tryRemoveIfNotNull(ti);
	
	parent := self.myParent.CM_WorkOrderTI;
	// move to complete collection
	if not self.allCompleteTIs.includes( ti) then
		//because of RBT we may not have this TI on the Work order main collection
		if not parent.allTIs.includes(ti) then
			
			//30.08.2022 navma1 #54297
			if self.isKindOf(CM_WodPack)then
				if not self.CM_WodPack.allPackingTIs.includes(ti) then
					if ti.myParent &lt;&gt; null and  parent.allTIs.includes(ti.myParent) then
						self.CM_WodPack.allPackingTIs.addNoDuplicates(ti,false);
					else
						parent.allTIs.addNoDuplicates(ti,false);
					
					endif;
				endif;
			else
				parent.allTIs.addNoDuplicates(ti,false);
			endif;
		endif;
	
		//23.08.2022 navma1 #54297
		if self.isKindOf(CM_WodPack) then
			if  self.CM_WodPack.allPackingTIs.includes(ti) then
				doComplete := false;
			else
				doComplete := true;
			endif;
		elseif self.isKindOf(CM_WodToDo) then								//27.03.2023 navma1 #56614:[56615]
			if ti.allToDoTasksToDo.isEmpty then
				doComplete := true;
			else
				doComplete := true;
				foreach todoTaskDesc in self.CM_WodToDo.allToDoTasksDescs do
					if ti.allToDoTasksToDo.includesToDoDesc(todoTaskDesc.code) then
						doComplete := false;
					endif;
				endforeach;
			endif;
		else
			doComplete := true;
		endif;
		
		//23.08.2022 navma1 #54297
		if doComplete then
			self.allCompleteTIs.add( ti);
			
			self.totalComplete   := self.allCompleteTIs.size;			
		endif;
		self.changeStatusWoWLE(JOB_COMPLETE,ti,_toDoTaskDesc);
	endif;
	
	//if self.isFirstTask and parent.taskStatus = WO_STATUS_APPROVED then											//08.02.2023 navma1 #56457:[56458]
	if parent.allWoDtls.includes(self) then																			//06.03.2023 navma1 #56457:[56458]
		if not parent.isAllTasksWithStatus(WO_STATUS_COMPLETE) and parent.taskStatus = WO_STATUS_APPROVED then		//08.02.2023 navma1 #56457:[56458]
			parent.setTaskStatus(WO_STATUS_PARTCOMPLETE);
			
		endif;
	endif;
	self.setStatus(WO_STATUS_PARTCOMPLETE);																			//08.02.2023 navma1 #56457:[56458]
		
	//if parent.totalRequired = self.totalComplete then					//08.02.2023 navma1 #56457:[56458]
	if self.isKindOf(CM_WodRelease) then
		reserveDet := self.CM_WodRelease.myReserveDetail;
		if reserveDet &lt;&gt; null then
			isRelByType := reserveDet.myReserveHeader.releaseByType;
		endif;
		
		
	else
	
	endif;
	
	if parent.myTerminal.isUseYardJobsForCargoWo then
		if self.isAllJobsWithStatus(JOB_COMPLETE) then
			self.completeMe();
		endif;
	else
		
		if self.allSelectedTIs.size = self.allCompleteTIs.size then			//08.02.2023 navma1 #56457:[56458]
			self.completeMe();
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_operationalWle" type="CM_WorkListEntry"/>
        <Parameter name="_workOrderWle" type="CM_WorkListEntry"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="doUnApprove" id="556b41f7-39ec-4285-a42a-9a3ec11ced23">
        <updating/>
        <source>doUnApprove(_passport : CM_Passport input)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Apr 2024 navhl20 ChangeRequest 63583: EUP | 54014 - Cargo Work Orders Enhancements - Remedial
24 Jun 2024 ChangeRequest 64770: EUP | 54014 - Cargo Work Orders Enhancements - Remedial - 1
11 Sep 2024 navah1  Bug 65907: EUP - Error 1310 when actioning work order that has been un - approved before
*/

vars
	job 		: CM_Job;
	doUnApprove	: Boolean;
	wle			: CM_WorkListEntry;
	linkedJob 	: CM_Job;
	todoDesc    : CM_ToDoTaskDesc;
	term		: CM_Terminal;
begin
	doUnApprove := true;
	foreach job in self.allJobs do
		if not job.status = JOB_UNACTIONED then
			doUnApprove := false;
		endif;
	endforeach;
	
	if doUnApprove then
		foreach job in self.allJobs do
			
			//Start 24.06.2024 navhl20 #64770
			wle := job.workListEntries.first;
			
			if wle &lt;&gt; null then
				linkedJob := wle.getLinkedJob();
			endif;
			
			if linkedJob &lt;&gt; null then
				linkedJob.setMyWorkOrderJobSheet(null);
				if linkedJob.myJobSheetForWorkPoint &lt;&gt; null then
					linkedJob.setMyWorkPointJobSheet(null);
				endif;
				linkedJob.causeTerminalEvent(linkedJob.Event_Mode_Update);
			endif;
			//End 24.06.2024 navhl20 #64770
			
			app.myUtilityDA.utlDeleteJob(job, _passport);
			
			//10/04/2025	navkc1 JIRA Defect Sub-task MTN-34619 - Send notification on the linked job so the WO Ops screen gets updated
			if linkedJob &lt;&gt; null then
				term := linkedJob.getMyTerminal();
				if term &lt;&gt; null then
					linkedJob.causeEvent(term.getTerminalEvent(WorkOrderJob_Update_Event), false, linkedJob);
				endif;
			endif;
		endforeach;
	endif;
	
	if self.allJobs.isEmpty() then
		self.setStatus(WO_STATUS_USERENTRY);
	endif;
	
	if self.isKindOf(CM_WodToDo) then 					//23.09.2024 navah1 #65907
		todoDesc :=	self.CM_WodToDo.allToDoTasksDescs.first;
		app.myUtilityUA.utlUpdateTIToDoTaskRemBulk(todoDesc,self.CM_WodToDo.allSelectedTIs,app.myPassport);
		self.CM_WodToDo.allToDoTasks.purge();
	endif;
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllToDoTaksDescsUsed" id="cf0d60cf-844c-4195-a80c-26d42ba8de58">
        <source>getAllToDoTaksDescsUsed( _todoSet : CM_ToDoTaskDescSet input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 July 2018	jlgndl1	Initial creation	TFS 39236
15 Mar 2023  	navhl20 ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
*/

vars

	wodToDo 	: CM_WodToDo;
	toDoTask	: CM_ToDoTaskDesc;
	
begin

	foreach wodToDo in self.allToDoRequests do
		//_todoSet.addNoDuplicates( wodToDo.myToDoTaskDesc, false );		//15.3.2023 navhl20	#56614[56615]
		foreach toDoTask in wodToDo.allToDoTasksDescs do					//15.3.2023 navhl20	#56614[56615]
			_todoSet.addNoDuplicates( toDoTask, false );
		endforeach;
	endforeach;

epilog

end;</source>
        <Parameter name="_todoSet" type="CM_ToDoTaskDescSet" usage="input"/>
    </JadeMethod>
