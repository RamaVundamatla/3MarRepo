    <JadeMethod name="cleanupData" id="85facd4f-ae43-490b-93e4-70fe4697957a">
        <updating/>
        <source>cleanupData()updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2016	cnwndl1	Initial creation	TFS 2022

*/

vars

begin

	self.deleteDataAccessController("CarDAC1", CM_Carrier.name);
	self.deleteDataAccessController("ConDAC1", CM_ConsigneeConsignor.name);
	self.deleteDataAccessController("CusDAC1", CM_CustomsAgent.name);
	self.deleteDataAccessController("OperDAC1", CM_Operator.name);
	self.deleteDataAccessController("OrgDAC1", CM_Organisation.name);
	self.deleteDataAccessController("SubtDAC1", CM_SubTerminal.name);

	self.deleteContainer( "DACZ0101010" );
	self.deleteContainer( "DACZ0202020" );
	self.deleteContainer( "DACZ0303030" );
	
	self.deleteTerminalArea("DACB1");
	self.deleteTerminalArea("DACB2");
	
	self.deleteCarrier("DAC1");
	self.deleteCarrier("DAC2");
	
	self.deleteConsigneeConsignor("DAC1");
	self.deleteConsigneeConsignor("DAC2");
	
	self.deleteCustomsAgent("DAC1");
	self.deleteCustomsAgent("DAC2");
	
	self.deleteOperator("DAC1");
	self.deleteOperator("DAC2");
	
	self.deleteOrganisation("DACOrganisation1");
	self.deleteOrganisation("DACOrganisation2");
	
	self.deleteSubTerminal("DAC1");
	self.deleteSubTerminal("DAC2");
	
	self.deleteUser("UTDAC1");

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCreateCriteriaLine" id="160b75e9-c91a-4b44-8731-20d8dd0c0be7">
        <source>doCreateCriteriaLine(	_qDef : CM_QueryDefinition;
						_criteriaHolder : CM_QueryCriteriaLineHolder io;
						_propName : String;
						_qOperatorStr : String;
						_value : Any
						) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2016	cnwndl1	Initial creation

*/

vars

	criteriaLine : CM_SelectorCriteriaLine;

begin

	criteriaLine := _qDef.createCriteriaLine(_propName, _qOperatorStr, _value);
	criteriaLine.setMyCriteriaLineHolder(_criteriaHolder);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_qDef" type="CM_QueryDefinition"/>
        <Parameter name="_criteriaHolder" type="CM_QueryCriteriaLineHolder" usage="io"/>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_qOperatorStr" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setupAndRunQuery" id="302d8670-a06a-4918-aa17-cf404599d930">
        <source>setupAndRunQuery( myEnqController : CM_EnqControllerTI io; qDef : CM_QueryDefinition ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2016	cnwndl1	Initial creation	TFS 2022

*/

vars

	criteriaHolder : CM_QueryCriteriaLineHolder;
	term : CM_Terminal;
	cargoType : CM_CargoType;

begin

	term := self.getTerminal;
	cargoType := app.myRoot.allCargoTypesById[ TI_CargoType_Container ];
	
	create myEnqController.allObjects as  CM_TISet transient;
	create criteriaHolder transient;
	myEnqController.myTerminal := term;
	myEnqController.myCriteriaLineHolder := criteriaHolder;
	
	self.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::myTerminal.name, CM_QueryOperator.Operator_Equal, term);
	self.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::cargoType.name, CM_QueryOperator.Operator_Equal, cargoType);
	self.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::site.name, CM_QueryOperator. Operator_Equal, TI_SITE_ONSITE);
//	process.isNDL; // get rid of the next line once all debugging is done, only there to lessen the number fo lines we need to be reviewing in debug.
//	self.doCreateCriteriaLine(qDef, criteriaHolder, CM_TrackedItem::id.name, CM_QueryOperator.Operator_StartsOrEndsWith, "DACZ0");
	
	myEnqController.doQuery( qDef );

epilog

end;</source>
        <access>protected</access>
        <Parameter name="myEnqController" type="CM_EnqControllerTI" usage="io"/>
        <Parameter name="qDef" type="CM_QueryDefinition"/>
    </JadeMethod>
    <JadeMethod name="setupBaseData" id="5dd17242-d8b6-4113-a8f4-82c3f39540bc">
        <updating/>
        <source>setupBaseData() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2016	cnwndl1	Initial creation	TFS 2022

*/

vars

	email : CM_EmailEntityByTypeNameDict;
	objSet : CM_ObjectSetActual;
	dac : CM_DataAccessController;
	daSet : CM_DataAccessControllerSet;
	cargoType : CM_CargoType;

begin

	cargoType := app.myRoot.getCargoTypeFromAbbrev("CONT");

	self.myBS1 := self.addBlockStack( "DACB1", 10, null );
	self.assertTrueMsg( self.myBS1 &lt;&gt; null, "First Block stack not created in setup");
	self.myBS2 := self.addBlockStack( "DACB2", 10, null );
	self.assertTrueMsg( self.myBS2 &lt;&gt; null, "Second Block stack not created in setup");
	
	create email transient;
	self.myCarrier1 := self.addCarrier( "DAC1", "DACCarrier1", email, false, true, true, null);
	self.assertTrueMsg( self.myCarrier1 &lt;&gt; null, "First Carrier not created in setup");
	self.myCarrier2 := self.addCarrier( "DAC2", "DACCarrier2", email, false, true, true, null);
	self.assertTrueMsg( self.myCarrier2 &lt;&gt; null, "Second Carrier not created in setup");
	
	self.myConsignee1 := self.addConsigneeConsignor("DAC1", "DACConsignee1", true, false, false);
	self.assertTrueMsg( self.myConsignee1 &lt;&gt; null, "First Consignee not created in setup");
	self.myConsignee2 := self.addConsigneeConsignor("DAC2", "DACConsignee2", true, false, false);
	self.assertTrueMsg( self.myConsignee2 &lt;&gt; null, "Second Consignee not created in setup");
	
	self.myCustomsAgent1 := self.addCustomsAgent("DAC1", "DACustomsAgent1");
	self.assertTrueMsg( self.myCustomsAgent1 &lt;&gt; null, "First Customs Agent not created in setup");
	self.myCustomsAgent2 := self.addCustomsAgent("DAC2", "DACustomsAgent2");
	self.assertTrueMsg( self.myCustomsAgent2 &lt;&gt; null, "Second Customs Agent not created in setup");
	
	self.myOperator1 := self.addOperatorSimple("DAC1", "DACOperator1");
	self.assertTrueMsg( self.myOperator1 &lt;&gt; null, "First Operator not created in setup");
	self.myOperator2 := self.addOperatorSimple("DAC2", "DACOperator2");
	self.assertTrueMsg( self.myOperator2 &lt;&gt; null, "Second Operator not created in setup");
	
	self.myOrganisation1 := self.addOrganisation("DACOrganisation1", true);
	self.assertTrueMsg( self.myOrganisation1 &lt;&gt; null, "First Organisation not created in setup");
	self.myOrganisation2 := self.addOrganisation("DACOrganisation2", true);
	self.assertTrueMsg( self.myOrganisation2 &lt;&gt; null, "Second Organisation not created in setup");
	
	self.mySubTerminal1 := self.addSubTerminal("DAC1",1);
	self.assertTrueMsg( self.mySubTerminal1 &lt;&gt; null, "First Sub Terminal not created in setup");
	self.mySubTerminal2 := self.addSubTerminal("DAC2",1);
	self.assertTrueMsg( self.mySubTerminal1 &lt;&gt; null, "Second Sub Terminal not created in setup");
	
	self.myTI1 := self.addContainerAtLocation("DACZ0101010", self.myOperator1, "2200", "MT", TI_IMEX_STATUS_STORAGE, self.myBS1);
	self.assertTrueMsg( self.myTI1 &lt;&gt; null, "First Cargo Item not created in setup");
	self.opts.purge();
	self.opts.addAssoc("SubTerminal", self.mySubTerminal1);
	self.updateTI(self.myTI1);
	
	self.myTI2 := self.addContainerAtLocation("DACZ0202020", self.myOperator1, "2200", "MT", TI_IMEX_STATUS_STORAGE, self.myBS1);
	self.assertTrueMsg( self.myTI2 &lt;&gt; null, "Second Cargo Item not created in setup");
	self.updateTI(self.myTI2);
	
	self.myTI3 := self.addContainerAtLocation("DACZ0303030", self.myOperator1, "2200", "MT", TI_IMEX_STATUS_STORAGE, self.myBS1);
	self.assertTrueMsg( self.myTI3 &lt;&gt; null, "Third Cargo Item not created in setup");
	self.updateTI(self.myTI3);
	
	create daSet transient;
	create objSet transient;
	objSet.add(self.myCarrier1);
	dac := null;
	app.myTrxCA.trxCreateDataAccessController("CarDAC1", CM_Carrier, objSet, false, true, dac, app.myPassport);
	self.assertTrueMsg( dac &lt;&gt; null, "Carrier DAC not created in setup");
	daSet.add(dac);
	
	objSet.clear();
	objSet.add(self.myConsignee1);
	dac := null;
	app.myTrxCA.trxCreateDataAccessController("ConDAC1", CM_ConsigneeConsignor, objSet, false, true, dac, app.myPassport);
	self.assertTrueMsg( dac &lt;&gt; null, "Consignee DAC not created in setup");
	daSet.add(dac);
	
	objSet.clear();
	objSet.add(self.myCustomsAgent1);
	dac := null;
	app.myTrxCA.trxCreateDataAccessController("CusDAC1", CM_CustomsAgent, objSet, false, true, dac, app.myPassport);
	self.assertTrueMsg( dac &lt;&gt; null, "Customs Agent DAC not created in setup");
	daSet.add(dac);
	
	objSet.clear();
	objSet.add(self.myOperator1);
	dac := null;
	app.myTrxCA.trxCreateDataAccessController("OperDAC1", CM_Operator, objSet, false, true, dac, app.myPassport);
	self.assertTrueMsg( dac &lt;&gt; null, "Operator DAC not created in setup");
	daSet.add(dac);
	
	objSet.clear();
	objSet.add(self.myOrganisation1);
	dac := null;
	app.myTrxCA.trxCreateDataAccessController("OrgDAC1", CM_Organisation, objSet, false, true, dac, app.myPassport);
	self.assertTrueMsg( dac &lt;&gt; null, "Organisation DAC not created in setup");
	daSet.add(dac);
	
	objSet.clear();
	objSet.add(self.mySubTerminal1);
	dac := null;
	app.myTrxCA.trxCreateDataAccessController("SubtDAC1", CM_SubTerminal, objSet, false, true, dac, app.myPassport);
	self.assertTrueMsg( dac &lt;&gt; null, "Sub Terminal DAC not created in setup");
	daSet.add(dac);
	
	self.opts.purge();
	self.opts.addAssoc("Organisation", self.myOrganisation1.name);
	self.opts.addAssoc("DAC", daSet);
	self.myDACUser := self.addUser("UTDAC1", "UTDAC1");
	self.assertTrueMsg( self.myDACUser &lt;&gt; null, "DAC User not created in setup");
	
	self.opts.purge();
	self.opts.addAssoc("RequestedUser", self.myDACUser.code);
	self.addUserTerminalToUser(cargoType);

epilog

	delete email;
	delete objSet;
	delete daSet;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tTrackedItemBasicDAC" id="d39ec45a-4971-45b1-b687-35bd6c681d84">
        <updating/>
        <source>tTrackedItemBasicDAC() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2016	cnwndl1	Initial creation	TFS 2022
16 Apr 2024	jlirs1	TFS 9999 - Fixing unitTests
*/

vars
	resetSubTermAreaDefined : Boolean;
	startUser : CM_User;
	myEnqController : CM_EnqControllerTI;
	iter : Iterator;
	ti : CM_TrackedItem;
	qDef : CM_QueryDefinition;
	debugMess : String;
	terminal : CM_Terminal;
	subTerminalsEnabled : Boolean;
begin

	startUser := app.getMyUser();
	terminal := self.getTerminal();

	subTerminalsEnabled := self.getTerminalConfig(IsSubTerminalsOn).Boolean;
	self.setTerminalConfig(IsSubTerminalsOn, true);
	self.assertTrueMsg(app.isSubTerminalsLicensed, "Not licensed for sub terminals!");
	self.assertTrueMsg(app.isSubTerminalsOn(terminal), terminal.name &amp; " not set up for sub terminals!");

	self.cleanupData();
	self.setupBaseData();
	
	app.myPassport.setMyUser( self.myDACUser );
	
	//set up and run the query
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,TI_CargoType_Container];
	create myEnqController transient;
	self.setupAndRunQuery( myEnqController, qDef );
	
	debugMess := "[User = " &amp; app.myPassport.myUser.code &amp; "]";
	debugMess := debugMess &amp; "[DAC size = " &amp; app.myPassport.allDataAccessControllers.size.String &amp; "]";
	self.assertTrueMsg( myEnqController.allObjects.size = 3, "Found " &amp; myEnqController.allObjects.size.String &amp; " items. Should have found the 3 we set up - test 1 " &amp; debugMess);
	
	//change the operator to one we shouldn't see.
	self.opts.purge();
	self.opts.addAssoc("Operator", self.myOperator2);
	self.updateTI(self.myTI2);
	//change the sub-terminal to one we shouldn't see.
	self.opts.purge();
	self.opts.addAssoc("SubTerminal", self.mySubTerminal2);
	self.updateTI(self.myTI3);
	
	//run it again
	myEnqController.allObjects.clear();
	myEnqController.doQuery( qDef );
	
	self.assertTrueMsg( myEnqController.allObjects.size = 1, "Found " &amp; myEnqController.allObjects.size.String &amp; " items. Should have only found 1 - test 2a");
	self.assertTrueMsg( not myEnqController.allObjects.includes(self.myTI2), "Should not find TI2, the Operator should not be allowed past the DAC - test 2b");
	self.assertTrueMsg( not myEnqController.allObjects.includes(self.myTI3), "Should not find TI3, the Sub terminal should not be allowed past the DAC - test 2c");
	
	//Put them back to values we can wee again
	self.opts.purge();
	self.opts.addAssoc("Operator", self.myOperator1);
	self.updateTI(self.myTI2);
	
	self.opts.purge();
	self.opts.addAssoc("SubTerminal", self.mySubTerminal1);
	self.updateTI(self.myTI3);
	
	//run it again
	myEnqController.allObjects.clear();
	myEnqController.doQuery( qDef );
	
	self.assertTrueMsg( myEnqController.allObjects.size = 3, "Found " &amp; myEnqController.allObjects.size.String &amp; " items. Should have found all 3 again - test 3");
	
	//change the carrier to one we shouldn't see.
	self.opts.purge();
	self.opts.addAssoc("Carrier", self.myCarrier2.code);
	self.updateTI(self.myTI2);
	//change the consignee to one we shouldn't see.
	self.opts.purge();
	self.opts.addAssoc("Consignee", self.myConsignee2.code);
	self.updateTI(self.myTI3);
	
	//run it again
	myEnqController.allObjects.clear();
	myEnqController.doQuery( qDef );
	
	self.assertTrueMsg( myEnqController.allObjects.size = 1, "Found " &amp; myEnqController.allObjects.size.String &amp; " items. Should have only found 1 - test 4a");
	self.assertTrueMsg( not myEnqController.allObjects.includes(self.myTI2), "Should not find TI2, the Carrier should not be allowed past the DAC - test 4b");
	self.assertTrueMsg( not myEnqController.allObjects.includes(self.myTI3), "Should not find TI3, the Consignee should not be allowed past the DAC - test 4c");
	
	//Put them back to values we can wee again
	self.opts.purge();
	self.opts.addAssoc("Carrier", self.myCarrier1.code);
	self.updateTI(self.myTI2);
	
	self.opts.purge();
	self.opts.addAssoc("Consignee", self.myConsignee1.code);
	self.updateTI(self.myTI3);
	
	//run it again
	myEnqController.allObjects.clear();
	myEnqController.doQuery( qDef );
	
	self.assertTrueMsg( myEnqController.allObjects.size = 3, "Found " &amp; myEnqController.allObjects.size.String &amp; " items. Should have found all 3 again - test 5");
	
	//change the customs agent to one we shouldn't see.
	self.opts.purge();
	self.opts.addAssoc("CustomsAgent", self.myCustomsAgent2);
	self.updateTI(self.myTI2);
	//change the carrier to one of each... We should still see it.
	self.opts.purge();
	self.opts.addAssoc("Carrier", self.myCarrier1.code);
	self.opts.addAssoc("ReleaseCarrier", self.myCarrier2.code);
	self.updateTI(self.myTI3);
	
	//run it again
	myEnqController.allObjects.clear();
	myEnqController.doQuery( qDef );
	
	self.assertTrueMsg( myEnqController.allObjects.size = 2, "Found " &amp; myEnqController.allObjects.size.String &amp; " items. Should have only found 2 - test 6a");
	self.assertTrueMsg( not myEnqController.allObjects.includes(self.myTI2), "Should not find TI2, the Customs Agent should not be allowed past the DAC - test 6b");

epilog

	delete iter;

	if myEnqController &lt;&gt; null then
		if myEnqController.myCriteriaLineHolder &lt;&gt; null then
			delete myEnqController.myCriteriaLineHolder;
		endif;
	endif;
	delete myEnqController;
	

	app.myPassport.setMyUser( startUser );

	self.cleanupData();
	self.setTerminalConfig(IsSubTerminalsOn, subTerminalsEnabled);

//	if resetSubTermAreaDefined then
//		self.setSubTerminalAreaDefined(true);
//	endif;

end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
