    <JadeMethod name="testa" id="99d01867-ca5f-4207-ad4f-60d44a37fd12">
        <source>testa(_term : CM_Terminal; _vessel : CM_Vessel) : String;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2018	jlgrh7	Initial creation

*/

vars
	currentTerm,rootTerminal            : CM_Terminal;
	archivedVoyage 								: CM_Voyage;
	bigEachTerminaVoyage 				: CM_Voyage;
	minimum, maximum : Integer;
	prefix, sysVoyCode : String;
	archivedExtCode : Integer;
	bigEachExtCode : Integer;
	biggestExtCode : Integer;
	reference : Integer;
	isFound : Boolean;
begin

	prefix := "P";
	minimum := 500000;
	maximum := 799999;
	biggestExtCode := 0;	
	reference := HookType_VoyageCode; 
	currentTerm := _term;
	 //app.initialize;
    
    //root := CM_Root.firstInstance;
	
	if currentTerm.allVoyagesArchived.size &gt; 0 then
		foreach archivedVoyage in currentTerm.allVoyagesArchived  do				//get biggest external code form the passing terminal's archived voayges
			if archivedVoyage &lt;&gt; null and archivedVoyage.voyageCodeExternal &lt;&gt; null  and
				archivedVoyage.voyageCodeExternal[2:end].Integer &gt; minimum and
				archivedVoyage.voyageCodeExternal[2:end].Integer &lt; maximum then
					archivedExtCode := archivedVoyage.voyageCodeExternal[2:end].Integer ;
			endif;
			if archivedVoyage.voyageCodeExternal[2:end].Integer= minimum then
				isFound := true;
			endif;
			if biggestExtCode &lt; archivedExtCode then
				biggestExtCode := archivedExtCode;
			endif;
		endforeach;
	endif;
	
	foreach rootTerminal in app.myRoot.allTerminals do																				// add up all existingvoyages from all terminals
		if rootTerminal &lt;&gt; null and  rootTerminal.allVoyagesByExternalCode.size &gt; 0 then
			if  rootTerminal.allVoyagesByExternalCode[prefix&amp;minimum.String.padLeadingZeros(6)] &lt;&gt; null then
				isFound := true;
			endif;
			bigEachTerminaVoyage := rootTerminal.allVoyagesByExternalCode.getAtKeyLss(prefix&amp;maximum.String.padLeadingZeros(6)).CM_Voyage;
			if bigEachTerminaVoyage &lt;&gt; null and bigEachTerminaVoyage.voyageCodeExternal &lt;&gt; null then
				bigEachExtCode := bigEachTerminaVoyage.voyageCodeExternal[2:end].Integer;
			endif;
			if bigEachExtCode &gt; minimum then
				if biggestExtCode &lt; bigEachExtCode then
					biggestExtCode := bigEachExtCode;
				endif;
			else
				continue;
			endif;
		endif;	
	endforeach;
	
	if biggestExtCode &lt;&gt; 0 then
			sysVoyCode := prefix &amp; (biggestExtCode+1).String.padLeadingZeros(6);
			
	elseif isFound then
			sysVoyCode := prefix &amp; (minimum+1).String.padLeadingZeros(6);
		
	else	
			sysVoyCode := prefix &amp; (minimum).String.padLeadingZeros(6);
	endif;

	return sysVoyCode;


epilog
	
end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="tfs3835" id="9b84668e-62ee-4d94-9299-080b810c0c0e">
        <source>tfs3835();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 31/03/2017	cnwdap1		Initial creation TFS 3835 Reproduce JRW Cams XML message issue
//
vars
	camProtocol : CM_CamProtocol;
	startDate, endDate : TimeStamp;
	camRequest : BGP_CamsRequest;
	camDirectory : String;

begin
	camProtocol := "2173.195235".asOid.CM_CamProtocol;
	startDate.setDate("20/01/2017".Date);
	endDate.setDate("31/05/2017".Date);
	
	// initialise the app and passport
	app.initialize();
	app.setMyTerminal("2351.53".asOid.CM_Terminal);
	app.myPassport.setMyUserFromCode("BGPUSER");
	
	camDirectory := app.myPassport.myTerminal.getConfig_FileDirectory(CamsFileDirectory).String;
	
	// create the cams protocol request
	app.myTrxCA.trxCreateAdhocCamsRequest(camProtocol, startDate, endDate, false, app.myPassport);
	
	// find and run the request
	camRequest := BGP_CamsRequest.instances.last.BGP_CamsRequest;
	if camRequest = null then
		app.msgBox("Couldn't find cams request", "Oops", MsgBox_OK_Only);
		return;
	endif;
	
	// temporarily override the terminal's CAMS directory to something that's likely to exist
	// and set cams request user
	beginTransaction;
	camRequest.setPropertyValue(BGP_CamsRequest::myUser.name, app.myPassport.myUser);
	app.myPassport.myTerminal.setConfig(CamsFileDirectory, "c:\temp\cams");
	commitTransaction;
	camRequest.action();
epilog
	beginTransaction;
	app.myPassport.myTerminal.setConfig(CamsFileDirectory, camDirectory);
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="tfs38555" id="3571f250-b163-42c6-a1ee-769b1d4bc5c0">
        <source>tfs38555();
/*

Purpose:			Portainer Cranes are not currently allowed VMTs, and should not have been allowed to be setup as one

Parameters:			

Return Value:		


Date			Who		Reason
11 May 2018		jlgmd1	Initial creation TFS #38555 MSL PORTAINER CRANE IN RT

*/

vars
	root : CM_Root;
	machine : CM_Machine;
	machineType : CM_MachineType;
	iter : Iterator;
	auditAgent : CM_UpdateTransactionAuditAgent;
begin
	app.initialize;
	
	/*app.writeLog(method.qualifiedName &amp; " Fix Machines being incorrectly allowed to support RT when they shouldn't", LogAlways);
	if _controller &lt;&gt; null then
		_controller.logEntry("Fix Machines being incorrectly allowed to support RT when they shouldn't") ;	
	endif;*/
	
	create auditAgent transient;
	
	root := CM_Root.firstInstance;
	iter := root.allMachines.createIterator;
	
	beginTransaction;
	
	while iter.next(machine) do
		if not app.isValidObject(machine) then
			continue;
		endif;
		
		machineType := null;
		machineType := app.myRoot.allMachineTypes[machine.machineType];
		
		if machineType &lt;&gt; null and not machineType.supportsRT then
			auditAgent.audUpdateGeneric(machine, true);
			machine.setPropertyValue('hasRadioTelemetry', false);
			machine.setPropertyValue('myRTDevice', null);
			machine.setPropertyValue('canWeighCargo', false);
			machine.setPropertyValue('canCertifyWeight', false);
			auditAgent.audUpdateGeneric(machine, false);
		endif;
	endwhile;
	
	commitTransaction;
	
	/*app.writeLog(method.qualifiedName &amp; " Finished fixing Machines being incorrectly allowed to support RT when they shouldn't",LogAlways );
	if _controller &lt;&gt; null then
		_controller.logEntry("Finished fixing Machines being incorrectly allowed to support RT when they shouldn't");
	endif;
	self.addScriptRun(method.name);*/
epilog
	delete iter;
	delete auditAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="tfs50706" id="fb5fac7f-af87-45a1-89f5-589e3d737c16">
        <source>tfs50706();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 26 January 2021	jlgdap1		Initial creation TFS 
//
vars
	fileFolder : FileFolder;
	fileNode : FileNode;
	file, out1027, out1081 : File;
	line, msg, date, time : String;
	is1027, is1081 : Boolean;
	pos, endPos, count, filesRead : Integer;

begin
	create fileFolder transient;
	fileFolder.fileName := "C:\temp\PRP\dphpjmt3\logs\archive\cnwhousekeeper\";
	create out1027 transient;
	out1027.openOutput("c:\temp\PRP\locks_010321.txt");
	create out1081 transient;
	out1081.openOutput("c:\temp\PRP\deadlocks_010321.txt");
	if fileFolder.isAvailable then
		foreach fileNode in fileFolder.files where fileNode.cnEcIsFile do
			file := fileNode.File;
			if file.fileName.toLower.pos("dump", 1) = null then
				continue;
			endif;
			count := null;
			is1027 := false;
			is1081 := false;
			filesRead := filesRead + 1;
			if filesRead mod 20 = 0 then
				write "read " &amp; filesRead.String &amp; " files...";
				out1027.commit;
				out1081.commit;
			endif;
			if not file.tryOpen() then
				continue;
			endif;
			while not file.endOfFile do
				line := file.readLine();
				count := count + 1;
				if count = 4 then 
					is1027 := line.pos("1027", 1) &lt;&gt; null;
					is1081 := line.pos("1081", 1) &lt;&gt; null;
					if not is1027 and not is1081 then
						break;
					endif;
					pos := line.pos("Time :", 1);
					if pos &lt;&gt; null then
						endPos := pos+7;
						line.scanUntil(",", endPos);
						if endPos &gt; pos+7 then
							date := line[pos+7:endPos-pos-7];
							pos := endPos+2;
							line.scanUntil("(", endPos);
							if endPos &gt; pos+2 then
								time := line[pos:endPos-pos-2-3];
							endif;
						endif;
					endif;
				endif;
				
				if (is1027 and line.pos("Exception=1027",1) &lt;&gt; null) or (is1081  and line.pos("Deadlock Exception",1) &lt;&gt; null) then		// this is the line with the lock details
					// 1027 has lockTarget locked by 
					endPos := null;
					if is1027 then
						msg := date &amp; Tab &amp; time &amp; Tab;
						pos := line.pos("lockTarget", 1);
						if pos &lt;&gt; null then
							endPos := pos + 1;
							line.scanUntil(",", endPos);
							if endPos &gt; pos then
								msg := msg &amp; "lockTarget" &amp; Tab &amp; line[pos+11:endPos-pos-11] &amp; Tab;
							endif;
						endif;
						pos := line.pos("locked by", pos);
						if pos &lt;&gt; null then
							endPos := pos+10;
							line.scanUntil(Space, endPos);
							if endPos &gt; pos+10 then
								msg := msg &amp; "lockedBy" &amp; Tab &amp; line[pos+10:endPos-pos-10] &amp; Tab;
							endif;
						endif;
						pos := line.pos("locking process app name", pos);
						if pos &lt;&gt; null then
							endPos := pos+24;
							line.scanUntil(")", endPos);
							if endPos &gt; pos+24 then
								msg := msg &amp; "locking process" &amp; Tab &amp; line[pos+24:endPos-pos-24];
							endif;
						endif;
						out1027.writeLine(msg);
						break;
					elseif is1081 then
						msg := date &amp; Tab &amp; time &amp; Tab;
						pos := line.pos("locktarget", 1);
						if pos &lt;&gt; null then
							endPos := pos + 1;
							line.scanUntil(",", endPos);
							if endPos &gt; pos then
								msg := msg &amp; "lockTarget" &amp; Tab &amp; line[pos+11:endPos-pos-11] &amp; Tab;
							endif;
						endif;
						pos := line.pos("currently held by", pos);
						if pos &lt;&gt; null then
							endPos := pos+18;
							line.scanUntil(")", endPos);
							if endPos &gt; pos+18 then
								msg := msg &amp; "lockedby" &amp; Tab &amp; line[pos+18:endPos-pos-18] &amp; Tab;
							endif;
						endif;
						pos := line.pos("trying to lock", pos);
						if pos &lt;&gt; null then
							msg := msg &amp; "trying to lock" &amp; Tab &amp;line[pos+16:end] &amp; Tab;
						endif;
						out1081.writeLine(msg);
						break;
					endif;
				endif;
			endwhile;
			//break;
		endforeach;
	endif;
epilog
	delete fileFolder;
	if out1027 &lt;&gt; null then
		out1027.close();
	endif;
	delete out1027;
	if out1081 &lt;&gt; null then
		out1081.close();
	endif;
	delete out1081;
end;</source>
    </JadeMethod>
    <JadeMethod name="tfs50706DeleteScript" id="8140ecbf-7f0a-4ca5-b77c-ac1a1c04b7cf">
        <source>tfs50706DeleteScript();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04 February 2021	jlgdap1		Initial creation TFS 
//
vars
	file, errorFile : File;
	line, yaCode : String;
	pos : Integer;
	ya : CM_YardAllocation;
	term : CM_Terminal;
	total, error, ignored, deleted : Integer;
	
begin
	create file transient;
	file.openInput("c:\temp\DaveP\PRP_unused_yard_allocations_sorted_v2.txt");
	if not file.isAvailable then
		app.msgBox("File c:\temp\DaveP\PRP_unused_yard_allocations_sorted_v2.txt not found", "Error", MsgBox_OK_Only);
		return;
	endif;
	create errorFile transient;
	errorFile.openOutput("c:\temp\DaveP\PRP_unused_yard_allocations_ERRORS.txt");
	term := CM_Terminal.firstInstance;
	
	while not file.endOfFile do
		line := file.readLine;
		if line[1:15] = "Yard Allocation" then
			// first line is a header
			continue;
		endif;
		
		total := total + 1;
		pos := line.pos(Tab, 1);
		if pos = null then
			errorFile.writeLine(app.actualTimeServer.String &amp; Tab &amp; "No Tab character found in " &amp; line);
			error := error + 1;
			continue;
		endif;
		
		yaCode := line[1:pos-1];
		ya := term.allYardAllocatonsByCode[yaCode];
		if ya = null then
			errorFile.writeLine(app.actualTimeServer.String &amp; Tab &amp; "No yard allocation found for code '" &amp; yaCode &amp; "'");
			error := error + 1;
			continue;
		endif;
		if ya.isKindOf(CM_InvoiceCargoAllocation) then
			errorFile.writeLine(app.actualTimeServer.String &amp; Tab &amp; yaCode &amp; " is a CM_InvoiceCargoAllocation - not deleting");
			ignored := ignored + 1;
			continue;
		endif;
		
		app.myValDA.valYardAllocation(ya);
		if app.myPassport.hasErrorsOrWarnings then
			errorFile.writeLine(app.actualTimeServer.String &amp; Tab &amp; "Validation Errors / warnings for " &amp; yaCode &amp; " - " &amp; app.myPassport.getErrorsAndWarningsAsString);
			app.myPassport.clearErrorsWarnings;
			error := error + 1;
			continue;
		endif;
		
		beginTransaction;
		app.myUtilityDA.myDeleteAuditAgent.audDeleteGeneric(ya);
		ya.erase(NORMAL_ERASE);
		if app.myPassport.hasErrorsOrWarnings then	
			errorFile.writeLine(app.actualTimeServer.String &amp; Tab &amp; "Errors / warnings while deleting " &amp; yaCode &amp; " - " &amp; app.myPassport.getErrorsAndWarningsAsString);
			app.myPassport.clearErrorsWarnings;
			error := error + 1;
			abortTransaction;
			continue;
		else
			commitTransaction;
			deleted := deleted + 1;
			if deleted mod 100 = 0 then
				app.msgBox(deleted.String &amp; " yard allocations deleted", "Progress", MsgBox_OK_Only);
			endif;
		endif;
	endwhile;
	
epilog
	app.msgBox(total.String &amp; " yard allocations in file, " &amp; deleted.String &amp; " yard allocations deleted, " &amp; error.String &amp; " errors, " &amp; ignored.String &amp; " ignored", "Result", MsgBox_OK_Only);
	if file &lt;&gt; null then
		file.close;
	endif;
	delete file;
	if errorFile &lt;&gt; null then
		errorFile.close;
	endif;
	delete errorFile;
end;</source>
    </JadeMethod>
    <JadeMethod name="tfs7431" id="52da61ff-70a9-40a8-8b4e-bf41bb68a611">
        <source>tfs7431();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2017	jlgma1	Initial creation
//17 Oct 2017	cnwma1  TFS #7431 JMT - Refactoring - Drawing Attributes Labels
*/

vars
	drwAttr : CM_DrawingAttribute;
begin
	//TFS 7431 cnwma1  17.10.2017 
	foreach drwAttr in CM_DrawingAttribute.instances do
		if drwAttr&lt;&gt; null then
			if drwAttr.label = null then
				beginTransaction;
				if drwAttr.getLabel &lt;&gt; null then
					drwAttr.label := drwAttr.getLabel;
				else
					drwAttr.label := drwAttr.code;
				endif;
				commitTransaction;
			endif;
		endif;
	endforeach;
	//TFS 7431 cnwma1  17.10.2017
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tfs7493" id="036d3197-89cd-4734-b2ce-720063755efe">
        <source>tfs7493();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2017	jlgma1	Initial creation
//17 Oct 2017	cnwma1  TFS #7431 JMT - Refactoring - Drawing Attributes Labels
*/

vars
	drwAttr : CM_DrawingAttribute;
	root: CM_Root;
	cargoType: CM_CargoType;
	hazardclass: CM_HazardClass;
	specialStow: CM_SpecialStow;
begin
//	if self.hasScriptBeenRunAtAll(method.name, null) then
//		return;
//	endif;
	
//	app.writeLog(method.qualifiedName &amp; " updating drawing attributes", null);

	root := CM_Root.firstInstance;
	//TFS 7431 cnwma1  17.10.2017 
	foreach drwAttr in CM_DrawingAttribute.instances do

		if drwAttr.code[1:15] = "picTICargoType_" then
			write "Delete " &amp; drwAttr.code;
			beginTransaction;
			foreach cargoType in CM_CargoType.instances do
				if cargoType.myDrawingAttribute = drwAttr then
					cargoType.setMyDrawingAttribute(null);
					write "CargoType " &amp; cargoType.abbreviation &amp; " null myDrawingAttribute";
				endif;
			endforeach;
			foreach hazardclass in CM_HazardClass.instances do
				if hazardclass.myDrawingAttribute = drwAttr then
					hazardclass.setMyDrawingAttribute(null);
					write "HazardClass " &amp; hazardclass.code &amp; " null myDrawingAttribute";
				endif;
			endforeach;
			foreach specialStow in CM_SpecialStow.instances do
				if specialStow.myDrawingAttribute = drwAttr then
					specialStow.setMyDrawingAttribute(null);
					write "SpecialStow " &amp; specialStow.code &amp; " null myDrawingAttribute";
				endif;
			endforeach;
			delete drwAttr;
			commitTransaction;
			continue;
		endif;
		
			
	if drwAttr.code[1:5].toUpper ="picTA".toUpper then
		
		beginTransaction;
		drwAttr.drawingAttrType := DrawingAttrType_TerminalArea;
		drwAttr.productType     :=ProductType_Extra;
		commitTransaction;
		
		
		write drwAttr.code &amp; Tab &amp; drwAttr.drawingAttrType.String &amp; Tab &amp; drwAttr.productType.String;
		
		endif;
		
	
		if drwAttr.code[1:10] ="CargoType_" then
		
		beginTransaction;
		drwAttr.drawingAttrType := DrawingAttrType_CargoType;
		drwAttr.productType     :=ProductType_Extra;
		commitTransaction;
		
		
		write drwAttr.code &amp; Tab &amp; drwAttr.drawingAttrType.String &amp; Tab &amp; drwAttr.productType.String;
		
		endif;
		
		if  drwAttr.code[1:12] = "HazardClass_" then
			beginTransaction;			
			drwAttr.drawingAttrType := DrawingAttrType_Hazard;
			drwAttr.productType     :=ProductType_Extra;
			commitTransaction;
			write drwAttr.code &amp; Tab &amp; drwAttr.drawingAttrType.String &amp; Tab &amp; drwAttr.productType.String;
		endif;
		
		
		
		
//		if  drwAttr.code[1:12] = "HazardClass_" then
//			beginTransaction;			
//			drwAttr.drawingAttrType := DrawingAttrType_Hazard;
//			drwAttr.productType     :=ProductType_Extra;
//			commitTransaction;
//			write drwAttr.code &amp; Tab &amp; drwAttr.drawingAttrType.String &amp; Tab &amp; drwAttr.productType.String;
//		endif;
		
	
		
		if  drwAttr.code[1:12] = "SpecialStow_" then
			beginTransaction;			
			drwAttr.drawingAttrType := DrawingAttrType_Special;
			drwAttr.productType     :=ProductType_Extra;
			commitTransaction;
			
		endif;	
		write drwAttr.code &amp;Tab &amp;Tab &amp; drwAttr.drawingAttrType.String &amp;Tab &amp; Tab &amp; drwAttr.productType.String;
		
		if  drwAttr.code[1:5] = "picTI" then
			
			beginTransaction;			
			drwAttr.drawingAttrType := DrawingAttrType_TrackedItem;
			//drwAttr.productType     :=ProductType_Extra;
			commitTransaction;
			
				write drwAttr.code &amp;Tab &amp;Tab &amp; drwAttr.drawingAttrType.String &amp;Tab &amp; Tab &amp; drwAttr.productType.String &amp;Tab &amp; drwAttr.label; 
		endif;
		
		beginTransaction;
		if  drwAttr.code[1:5] = "picTI" then
		
			if drwAttr.code = PicTITimber then
				write  drwAttr.code &amp; Tab  &amp;" Timber";
				drwAttr.productType := ProductType_Timb;
				
			elseif drwAttr.code = PicTIBreakBulk then
				write  drwAttr.code &amp; Tab  &amp;" BreakBulk";
				drwAttr.productType := ProductType_BreakBulk;
			
			elseif drwAttr.code.isOneOf(PicTIInTransit,PicTIReadyToShip,PicTICustomHold,PicTIHazard,PicSpecialStow,PicTITBA,PicTIQueued,PicTIPlanned,PicTIActual,PicTIRT) then
				write  drwAttr.code &amp; Tab  &amp;" TrackedItem";
				drwAttr.productType := ProductType_TI;
			
			elseif drwAttr.code = PicTICOU then		
				write  drwAttr.code &amp; Tab  &amp;" Generator";
				drwAttr.productType := ProductType_Gen;
			
			elseif drwAttr.code.isOneOf(PicTI40Footer,PicTI45Footer,PicTI30Footer,PicTI30FooterBE,PicTI53Footer,PicTIWaterCooled,PicTIControlledAtmos,
										PicTIConnected,PicTIReefer,PicTIEmpty,	PicTIFlat,PicTICrib,PicTIOpentop,PicTIFantainer,PicTITank,PicTIHiCube,
										PicTI_OD_HLW,PicTI_OD_HL,PicTI_OD_HW,PicTI_OD_H,PicTI_OD_WL,PicTI_OD_L,PicTI_OD_W,PicTI40FooterBackEnd,
										PicTI53FooterBE,PicTI45FooterBackEnd,PicTIDoorsAft,PicTIDoorsFwd,PicTIDoorsAft40,PicTIDoorsFwd40)then
				write  drwAttr.code &amp; Tab  &amp;" Container";
				drwAttr.productType := ProductType_Container;
			
			elseif drwAttr.code.isOneOf (PicTI10,PicTI1,PicTI0,PicTI2,PicTI3,PicTI4,PicTI5,PicTI6,PicTI7,PicTI8,PicTI9,PicTIBuilding,PicTIGap,PicTIHalfHeight,
										PicTIInteg,PicTILabour,PicTILight,PicTILoad,PicTIMTOnly,PicTIMotorAft,PicTIMotorAft40,PicTIMotorFwd,PicTIMotorFwd40,
										PicTIPower,PicTIUnavail,PicTIReeferGantry,PicTIHeavy,PicTIVoltageSingle,PicTIVoltageDual,PicTIDischarge,PicTIOversized) then
			drwAttr.productType := ProductType_Definition;
				write drwAttr.code &amp; Tab  &amp;" Definition";
			
			else
				write  drwAttr.code &amp; Tab  &amp;" N/A";
			endif;
			
		endif;
		commitTransaction;
		
		if drwAttr.myRoot &lt;&gt; root then
			beginTransaction;
			drwAttr.myRoot := root;
			commitTransaction;
		endif;
		
		write drwAttr.code &amp; ","&amp; drwAttr.label &amp; "," &amp; drwAttr.priority.String&amp; ","&amp; drwAttr.drawingAttrType.String &amp; ","&amp; drwAttr.productType.String;
	endforeach;
	//TFS 7431 cnwma1  17.10.2017

//	app.writeLog(method.qualifiedName &amp; ": updating drawing attributes complete.", LogAlways);
	
//	self.addScriptRun(method.name);

epilog

end;</source>
    </JadeMethod>
