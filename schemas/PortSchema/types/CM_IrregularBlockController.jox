    <JadeMethod name="setProxy" id="e579de0e-496f-436b-a93a-cbe46ff0d2d0">
        <updating/>
        <source>setProxy(	blockAreaProxy : CM_IrregularBlockArea;
			id: String;
			region: PointArray;
			_colour : Integer;
			_defaultCapacity : Integer;
			_locationType : Integer;
			_maximumWeight : Real;
			_myICArea : CM_InterchangeArea
			) updating;
// Set values to a proxy instance of self
begin
	self.myTerminalArea := blockAreaProxy;
	self.ident := id;
	self.setProxyRegion(region);
	
	//21 Aug 2013	NDL	Par 32308
	self.colour := _colour;
	self.defaultCapacity := _defaultCapacity;
	self.locationType := _locationType;
	if self.locationType = 0 then
		self.locationType := GC_GroundLocation;
	endif;
	self.maximumWeight := _maximumWeight;
	self.myAssociatedInterchangeArea := _myICArea;
end;
</source>
        <Parameter name="blockAreaProxy" type="CM_IrregularBlockArea"/>
        <Parameter name="id" type="String"/>
        <Parameter name="region" type="PointArray"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_defaultCapacity" type="Integer"/>
        <Parameter name="_locationType" type="Integer"/>
        <Parameter name="_maximumWeight" type="Real"/>
        <Parameter name="_myICArea" type="CM_InterchangeArea"/>
    </JadeMethod>
    <JadeMethod name="setProxyRegion" id="77b7c1c9-3859-43fc-901c-7b140b473f0d">
        <updating/>
        <source>setProxyRegion(region: PointArray) updating;
// Set values to a proxy instance of self
begin
	if region = null then
		self.region.clear();
	elseif region &lt;&gt; self.region then
		self.region.clear();
		self.region.add(region.first);
		self.region.add(region.last);
	endif;
end;
</source>
        <Parameter name="region" type="PointArray"/>
    </JadeMethod>
