    <JadeMethod name="addToolbarControls" id="e9e3d2a7-1217-4bca-b876-9fb427df53af">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*

Purpose:			Adds controls to the toolbar

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
07 October 2022	navpw1	Initial creation TFS: 54566

*/

vars
	toolbar	: CMUI_Toolbar;
	
begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnAddItem, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEditItem, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnImportCSVMap, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnExportCSVMap, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;

	toolbar := self.frmPropToolbar;
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancel, CMUI_Toolbar.Control_Alignment_Right);
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addToolbarControlsQuery" id="a2553f48-5e18-495c-8d82-0d6b0e3e95bf">
        <source>addToolbarControlsQuery() protected;
/*

Purpose:			Adds controls to the query toolbar

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
07 October 2022	navpw1	Initial creation TFS: 54566

*/

vars
	queryToolbar	: CMUI_Toolbar;
	
begin
	queryToolbar := self.frmQueryToolbar;
	queryToolbar.addButton(self.btnQuery, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	queryToolbar.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnHideSearcher, CMUI_Toolbar.Control_Alignment_Left);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
