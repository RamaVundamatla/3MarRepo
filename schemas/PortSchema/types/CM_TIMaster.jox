    <JadeMethod name="extHeightMetres" id="82f66a64-81eb-45b2-bf18-b48ad6ec794f">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>extHeightMetres(set: Boolean; _value: Integer io) mapping, updating;
// --------------------------------------------------------------------------------
// Created:		19 February 2009 by cnwdad1
//
// Purpose:		When setting: Sets the non-virtual External Height of the reciever
//				(which is stored in centimetres) by converting from the specified value.
//
//				When retrieving: Returns the External Height of the receiver in metres,
//				by converting from the non virtual External Height which is stored
//				in centimetres.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if set then
		self.extHeight	:=	(_value / 100);
	else
		_value			:=	(self.extHeight * 100).rounded();
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="extLengthMetres" id="9b532629-ac9d-448c-9458-67015c5bbe26">
