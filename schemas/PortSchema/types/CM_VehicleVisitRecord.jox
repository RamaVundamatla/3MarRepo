    <JadeMethod name="getCargoMoves" id="b97b9971-c3f3-482a-baa7-97d641dd75c9">
        <source>getCargoMoves( _allMoves :  CM_TITransactionByIdTypeDict input ; _forRelease : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		Returns a consolidated list of moves to the diferent target locations

Date		Who		Reason
21 June 2019	jlger1	Initial creation 44965

*/

vars
	pxyMove : CM_TITransaction;
	setdownMove,
	move : CM_Move;
	vvr 	: CM_VehicleVisitRecordDetail;
	ti 		: CM_TrackedItem;
	recordType : Integer;
	undoRecordType : Integer;
begin
	
	if _forRelease then
		recordType := VisitRecord_CargoPlaced;
		undoRecordType:=VisitRecord_CargoRemoved;
	else
		recordType := VisitRecord_CargoRemoved;
		undoRecordType := VisitRecord_CargoPlaced;
	endif;
	
	foreach vvr in self.allVehicleVisitRecordDetails discreteLock do
		if vvr.recordType = recordType  then
			move := vvr.getExtraInfo_Move();
			if move = null then
				return;
			endif;
			
			if move.isKindOf(CM_Pickup) then
				setdownMove:= move.CM_Pickup.getSetdownTrx;
				if setdownMove &lt;&gt; null then
					move:=setdownMove;
				endif;
			endif;
			ti:=move.myTrackedItem;
			pxyMove:=_allMoves[move.id,TRANS_TYPE_MOVE];
			if pxyMove = null then
				pxyMove:=move.cloneSelfAs(CM_Move,true).CM_Move;
				pxyMove.setTypeAndTI(TRANS_TYPE_MOVE,ti);
				_allMoves.add(pxyMove);
			else
				
				if ti.myCargoType.allowDuplicates then
					//same id moved to same location then 
					if pxyMove.CM_Move.targetLocn = move.targetLocn then

						pxyMove.resetQVW(	pxyMove.totalQuantity +  move.totalQuantity,
												pxyMove.totalVolume +  move.totalVolume,
												pxyMove.totalWeight +  move.totalWeight);
					else
						pxyMove:=move.cloneSelfAs(CM_Move,true).CM_Move;
						pxyMove.setTypeAndTI(TRANS_TYPE_MOVE,ti);
						_allMoves.add(pxyMove);
						
					endif;
				endif;
			endif;
		elseif vvr.recordType = undoRecordType  then
			move := vvr.getExtraInfo_Move();
			if move = null then
				return;
			endif;
			
			if move.isKindOf(CM_Pickup) then
				setdownMove:= move.CM_Pickup.getSetdownTrx;
				if setdownMove &lt;&gt; null then
					move:=setdownMove;
				endif;
			endif;
			ti:=move.myTrackedItem;
			pxyMove:=_allMoves[move.id,TRANS_TYPE_MOVE];
			if pxyMove = null then
				continue; //must off been removed off truck first
			endif;
			if ti.myCargoType.allowDuplicates then
					//same id moved to same location then 
					if pxyMove.CM_Move.targetLocn = move.sourceLocn then  

						pxyMove.resetQVW(	pxyMove.totalQuantity -  move.totalQuantity,
												pxyMove.totalVolume -  move.totalVolume,
												pxyMove.totalWeight -  move.totalWeight);
					endif;

				endif;
			
		endif;
		
	endforeach;
	
epilog

end;</source>
        <Parameter name="_allMoves" type="CM_TITransactionByIdTypeDict" usage="input"/>
        <Parameter name="_forRelease" type="Boolean"/>
    </JadeMethod>
