<GUIClass name="CMUI_ToolbarMoreToShow" id="71438ea2-c87f-4e4d-8656-7c27e10ee591">
    <superclass name="CMUI_ToolbarControl"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <JadeMethod name="click" id="d045baee-be34-4bbf-a32d-11ce8995f77e">
        <updating/>
        <source>click(frame: Frame input) updating;
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	menuItem	: MenuItem;
	baseForm	: CM_BaseForm;
	numControls,
	idx			: Integer;
	control		: CMUI_ToolbarControl;
		
begin

	self.myToolbar.showMoreToShowContextMenu();

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="8d214549-c109-44c5-a473-72494a119328">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.borderStyle 		:= BorderStyle_None;
	self.boundaryWidth 		:= 0;
	self.bevelInnerWidth 	:= 0;
	self.bevelOuterWidth 	:= 0;
	self.alignment			:= Alignment_Center_Top;
	self.enabled 			:= true;
	self.autoRedraw 		:= true;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="3ea8f2c0-19fd-4584-ac9c-34b3e758bb91">
        <updating/>
        <source>mouseDown(frame: CMUI_ToolbarMoreToShow input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	frame.drawButtonDown();

end;</source>
        <Parameter name="frame" type="CMUI_ToolbarMoreToShow" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseEnter" id="afb5ab21-7240-4847-9153-0713fb50db8e">
        <updating/>
        <source>mouseEnter(frame: CMUI_ToolbarMoreToShow input) updating;
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	frame.drawButtonUp();

end;</source>
        <Parameter name="frame" type="CMUI_ToolbarMoreToShow" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mouseLeave" id="c38124fc-2e5d-4070-8f46-68ad4b7001db">
        <updating/>
        <source>mouseLeave(frame: CMUI_ToolbarMoreToShow input) updating;
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	frame.clearGraphics();

end;</source>
        <Parameter name="frame" type="CMUI_ToolbarMoreToShow" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="e36e0a72-273f-46f5-a035-848318ad826f">
        <updating/>
        <source>mouseUp(frame: CMUI_ToolbarMoreToShow input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	frame.drawButtonUp();

end;</source>
        <Parameter name="frame" type="CMUI_ToolbarMoreToShow" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="adf05907-352c-4bb7-bcb9-ef33118e0524">
        <updating/>
        <source>windowCreated(cntrl: CMUI_ToolbarMoreToShow input; persistCntrl: Control) updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(cntrl, persistCntrl);
	
	cntrl.fontSize	:= 6;
	cntrl.fontBold 	:= true;
	cntrl.caption 	:= '&gt;&gt;';
	cntrl.width		:= CMUI_Toolbar.MoreToShowWidth;

end;</source>
        <Parameter name="cntrl" type="CMUI_ToolbarMoreToShow" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
    <DevControlTypes name="CMUI_ToolbarMoreToShow">
        <bitmap></bitmap>
        <windowClass>AlFrame</windowClass>
        <DevControlProperties name="alignChildren">
