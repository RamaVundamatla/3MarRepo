    <JadeMethod name="addToExtraStrings" id="04ef3993-eedc-4de2-a781-8aa3ac49c013">
        <source>addToExtraStrings() protected;

// Created by cnwdvb1 on 28 June 2006

vars

	port	: CM_Port;

begin

	port := self.cmbPorts.myObject.CM_Port;
	
	if port = null then
		return;
	endif;
	
	self.allExtraStrings.add(port.code);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="a8541d43-3564-4033-878a-ba2e9cc12d12">
        <updating/>
        <source>addToolbarControls() updating, protected;
// -------------------------------------------
// Created 28 August 2003 by cnwdvb1
// -------------------------------------------
vars

	toolbar	: CMUI_Toolbar;
	
begin
