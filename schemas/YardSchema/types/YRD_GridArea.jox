    <JadeMethod name="convertPositionToGridPoint" id="6117f3fb-dbc3-43ba-8de2-8c159a8dfc2f">
        <source>convertPositionToGridPoint(x, y : Real) : CMUI_GridPoint; 

vars
	foundPoint,
	tmpPoint	: CMUI_GridPoint;
	tmpRow		: CMUI_GridRow;
	tmpX, tmpY : Real;
	pntX1, pntY1, pntX2, pntY2 : Real;	
	rowX, rowY : Real;	
begin
	// Do the row first as it is "non-variable" length.  At some
	// point columns in each row may be variable length (RJS Dec/02)
	tmpX := x;
	tmpY := y;
	foreach tmpRow in self.allGridRows do : outerLoop
		rowY := tmpRow.y2 + YRD_GridArea.ROW_SPACING;
		if tmpY &gt;= tmpRow.y1 and
		   tmpY &lt;= rowY then
		   	// Found the row now check the points in this row
		   	foreach tmpPoint in tmpRow.allGridPointsByColumn do
		   		pntY1 := tmpPoint.y1;
		   		pntX1 := tmpPoint.x1;
		   		// for block stakcs extend the search over the 'gaps' i.e. where we do not draw
				if tmpPoint.YRD_GridPoint.mySubBlockStack &lt;&gt; null then
			   		pntY2 := tmpPoint.y2 + YRD_GridArea.ROW_SPACING;
			   		pntX2 := tmpPoint.x2 + YRD_GridArea.COLUMN_SPACING;
			   	else
			   		pntY2 := tmpPoint.y2;
			   		pntX2 := tmpPoint.x2;
		   		endif;
				if tmpX &gt;= pntX1 
				and tmpX &lt;= pntX2 then
					if tmpY &gt;= pntY1 
					and tmpY &lt;= pntY2 then
					   	foundPoint := tmpPoint;
					   	break outerLoop;
					endif;
				endif;
		   	endforeach;
		endif;
	endforeach;
	
	return foundPoint;

end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="CMUI_GridPoint"/>
    </JadeMethod>
    <JadeMethod name="create" id="92420dad-6f0f-4e2e-9f3f-b5dff88e722e">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.scaleXFactor	:= 2;
	self.scaleYFactor	:= 2;

end;</source>
    </JadeMethod>
    <JadeMethod name="drawSpecialAfter" id="b9c6dcd8-cd22-42c9-9353-6b6cf75da9a3">
        <source>drawSpecialAfter() ;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aCMObject : CM_Object;
	pointX, pointY, aColour, offset : Integer;
	anIterator : Iterator;
	aLabel,aCRLabel : String;

	b : Integer;
begin

	self.allTerminalAreas.removeInvalidObjects();
	anIterator := self.allPointLabels.createIterator;
	
	// Draw the Sub Block Stack Labels
	while anIterator.next(aCMObject) do 
		if global.isValidObject(aCMObject) then
		if aCMObject.isKindOf(CM_TerminalArea) then
			pointX := anIterator.getCurrentKey(1).Integer;
			pointY := anIterator.getCurrentKey(2).Integer;
			aLabel := aCMObject.CM_TerminalArea.id;
			if aCMObject.CM_TerminalArea.myLayoutGraphic &lt;&gt; null then
				aColour := aCMObject.CM_TerminalArea.myLayoutGraphic.drawLineColour.getInverseColour;
			else
				aColour := Black;
			endif;
			self.myGridAreaFrame.drawTextAt(aLabel,pointX ,pointY, aColour);
			if aCMObject.isKindOf(CM_BlockStack) then
				aLabel := aCMObject.CM_BlockStack.getMenuDetails(true, self.mySDF.displayMode);
				if aLabel.trimBlanks &lt;&gt; null then
//					b := aLabel.pos(" ", 1);
//					b := aLabel.pos(" ", b + 1);
					
//					aLabel := aLabel[1 : b] &amp; CrLf &amp; aLabel[b+1 : end];
					if self.scaleXFactor = 4 then
						offset := 25;
					elseif self.scaleXFactor = 3 then
						offset := 20;
					elseif self.scaleXFactor = 2 then
						offset := 15;
					elseif self.scaleXFactor = 1.5 then
						offset := 10;
					elseif self.scaleXFactor = 1 then
						offset := 10;
					endif;
					self.myGridAreaFrame.drawTextAt(aLabel,pointX ,pointY + offset, aColour);
				endif;
			endif;
		endif;
		endif;
	endwhile;	

epilog
	delete anIterator;
end;</source>
    </JadeMethod>
    <JadeMethod name="maxRowHeight" id="700b9380-49d0-4f43-8356-d73284d9f76c">
        <methodInvocation>mapping</methodInvocation>
        <source>maxRowHeight(set: Boolean; _value: Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpGridRow	: CMUI_GridRow;
	
begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	foreach tmpGridRow in self.allGridRows do
		_value := _value.max(tmpGridRow.YRD_GridRow.maxHeight);
	endforeach;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="selectSinglePoint" id="0046e7de-483a-437a-9a60-ae809068abe4">
        <updating/>
        <source>selectSinglePoint( x, y : Real) : CMUI_GridPoint updating;

vars
	returnPoint, gridPoint, origPoint 	: CMUI_GridPoint;
	x1, y1					: Real;
	aTI : CM_TrackedItem;
	column40, moveMode : Integer;
	theSelectedTIs : CM_TIArray;
begin

	gridPoint := self.convertPositionToGridPoint(x, y);
	if gridPoint &lt;&gt; null then
		if gridPoint.locked then
			return gridPoint;
		endif;
		// if the user clicks on a block stack or a light etc, DO NOT redraw it
		if gridPoint.letter = GridPointType_Building 
		or gridPoint.letter = GridPointType_Light 
		or gridPoint.letter = GridPointType_ReeferGantry
		or gridPoint.letter[1:4]= GridPointType_SubBlock 
		or gridPoint.locked then

			return gridPoint;
		endif;

		theSelectedTIs := self.allSelectedTrackedItems;

		aTI := gridPoint.getTI(x,y);
		if aTI &lt;&gt; null then
			if not theSelectedTIs.includes(aTI) then
				theSelectedTIs.add(aTI);
			else
				theSelectedTIs.remove(aTI);
			endif;

			// if this is a 40 and they have clicked on the second location the 40 will not be redrawn properly, so get the grid point prior to us
			if aTI.isAttributeTrue(TI_Attrib_IsForty)  then
				if self.mySDF.displayMode = 1 then
					moveMode := REAL_MODE;
				elseif self.mySDF.displayMode = 2 then
					moveMode := QUEUE_MODE;
				elseif self.mySDF.displayMode = 3 then
					moveMode := PLANNING_MODE;
				endif;
				if aTI.getPrimaryLocation(moveMode) &lt;&gt; gridPoint.myLocationsController then
					if ( not self.flipHorizontal and gridPoint.column &lt;&gt; 1) or  (self.flipHorizontal and gridPoint.column &lt;&gt; gridPoint.myGridRow.allGridPointsByColumn.size) then
						origPoint := gridPoint;
						if self.flipHorizontal then
							column40 := 1;
						else
							column40 := -1;
						endif;
						gridPoint := gridPoint.myGridRow.allGridPointsByColumn[gridPoint.column + column40];
						if gridPoint = null then
							if origPoint.column &gt; 2 then
								gridPoint := origPoint.myGridRow.allGridPointsByColumn[origPoint.column + (column40 * 2)];
							endif;
						endif;
					endif;
				endif;
			endif;
		endif;

		if gridPoint &lt;&gt; null then
			if not self.allSelectedPoints.includes(gridPoint) then
				self.allSelectedPoints.add(gridPoint);
				returnPoint := gridPoint;
			else
				self.allSelectedPoints.remove(gridPoint);
				returnPoint := null;
			endif;
			gridPoint.drawSelf(self.myGridAreaFrame);
		endif;
		
		return returnPoint;
	endif;

end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="CMUI_GridPoint"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="34652619-8032-491b-9b42-bfe1d2b8ee40">
        <updating/>
        <source>setForCreate(pGridArea : CM_GridArea; pAssistant : CMUI_Assistant; 
		_controller : CMIF_DrawingAttrController input; pEdit : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------
vars
	cGridRow		: CM_GridRow;
	cGridCol		: CM_GridColumn;
	cGridController	: CM_GridController;
	yGridRow		: YRD_GridRow;
	yGridCol		: YRD_GridColumn;
	yGridPoint		: YRD_GridPoint;
	loadStateSet 	: Boolean;
	theMaxWidth, 
	theWidth 		: Real;
	theTIs 		: CM_TIArray;

begin

	if pGridArea = null then
		return;
	endif;
	app.cmsBeginLoad(loadStateSet);
	
	self.label		:= pGridArea.id;
	
	self.myAssistant	:= pAssistant;

	foreach cGridRow in pGridArea.allGridRows do
		create yGridRow transient;
		yGridRow.setForCreate(cGridRow, self);
	endforeach;

	foreach cGridCol in pGridArea.allGridColumns do
	
//		cGridController := cGridCol.allControllersByRow.first;
//		if cGridController &lt;&gt; null and cGridController.isKindOf(CM_GapController) and cGridController.CM_GapController.width = 0 then
//			continue;
//		endif;

		// this is checking for a column of gap controllers only, that all have a width of zero
		// if this is the case do not create a column.
		theMaxWidth := 0;
		foreach cGridController in cGridCol.allControllersByRow do
			if (not cGridController.isKindOf(CM_GapController)) then
				theMaxWidth := 1;
				break;
			endif;
			theWidth := cGridController.CM_GapController.width;
			theMaxWidth := theMaxWidth.max(theWidth);
		endforeach;
		if theMaxWidth = 0 then
			continue;
		endif;

		create yGridCol transient;
		yGridCol.setForCreate(cGridCol, self);
	endforeach;
	
	create theTIs transient;

	foreach cGridController in pGridArea.allGridControllersByRowColumn do
		create yGridPoint transient;
		yGridPoint.setForCreate(cGridController, self, _controller, theTIs);
	endforeach;

epilog
	app.cmsEndLoad(loadStateSet);
	delete theTIs;
end;</source>
        <Parameter name="pGridArea" type="CM_GridArea"/>
        <Parameter name="pAssistant" type="CMUI_Assistant"/>
        <Parameter name="_controller" type="CMIF_DrawingAttrController" usage="input"/>
        <Parameter name="pEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreateArray" id="68e37741-f186-4fbb-ae1b-4fd6e227b124">
        <updating/>
        <source>setForCreateArray(_terminalArea : CM_TerminalArea; _array : StringArray512; 
				_myAssistant : CMUI_Assistant;
				_controller : CMIF_DrawingAttrController input; 
				_amEdit : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theMaxWidth, 
	theWidth		: Real;
	lineType,
	tmpStr			: String;
	tmpData,
	tmpArray		: StringArray512;
	tmpGridRow		: YRD_GridRow;
	tmpGridCol		: YRD_GridColumn;
	tmpGridPoint	: YRD_GridPoint;

begin

	self.label 			:= _terminalArea.id;
	self.myAssistant	:= _myAssistant;
	self.myTerminalArea := _terminalArea;
	
	create tmpData transient;
	create tmpArray transient;

	foreach tmpStr in _array do
		tmpData.clear;
		tmpStr.getTokensForDelimiter(GridData_Delimiter, tmpData);
		if tmpData.size &lt; 1 then
			continue;
		endif;
		lineType := tmpData[1];
		
		if lineType = GridData_Row then
			create tmpGridRow transient;
			tmpGridRow.setForCreateArray(tmpData, self);

		elseif lineType = GridData_Column then
			create tmpGridCol transient;
			tmpGridCol.setForCreateArray(tmpData, self);

		elseif lineType = GridData_LC then
			create tmpGridPoint transient;
			tmpGridPoint.setForCreateArray(tmpData, self);

		elseif lineType = GridData_TI_Actual then
			tmpGridPoint.setForCreateTI_Array(tmpData, REAL_MODE, _controller, tmpArray);

		elseif lineType = GridData_TI_Queued then
			tmpGridPoint.setForCreateTI_Array(tmpData, QUEUE_MODE, _controller, tmpArray);

		elseif lineType = GridData_TI_Planned then
			tmpGridPoint.setForCreateTI_Array(tmpData, PLANNING_MODE, _controller, tmpArray);

		else
//			write class.name &amp; '::' &amp; method.name &amp; ' unhandled lineType (' &amp; lineType &amp; ')';
		endif;
	endforeach;

epilog
	delete tmpData;
	delete tmpArray;

end;</source>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_array" type="StringArray512"/>
        <Parameter name="_myAssistant" type="CMUI_Assistant"/>
        <Parameter name="_controller" type="CMIF_DrawingAttrController" usage="input"/>
        <Parameter name="_amEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreateXML" id="867b3095-490f-4f08-9035-5b73f1799dad">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>setForCreateXML(_theXML : String; _myAssistant : CMUI_Assistant;_amEdit : Boolean) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	loadStateSet : Boolean;
	theMaxWidth, theWidth : Real;
	theXMLTag : String;
begin

	self.label := _theXML.cnEcGetTagValueOfName("ID");

	/* set in the create method
	theXMLTag := _theXML.cnEcGetTagValueOfName("OR");
	theXMLTag := _theXML.cnEcGetTagValueOfName("OC");
	theXMLTag := _theXML.cnEcGetTagValueOfName("OID");
	*/
	
	theXMLTag := _theXML.cnEcGetTagValueOfName("ROWS");
	self.setForCreateXMLRows(theXMLTag,_amEdit);
	
	theXMLTag := _theXML.cnEcGetTagValueOfName("COLUMNS");
	self.setForCreateXMLColumns(theXMLTag,_amEdit);

	theXMLTag := _theXML.cnEcGetTagValueOfName("POINTS");
	self.setForCreateXMLPoints(theXMLTag, _amEdit);

	self.myAssistant	:= _myAssistant;

end;</source>
        <Parameter name="_theXML" type="String"/>
        <Parameter name="_myAssistant" type="CMUI_Assistant"/>
        <Parameter name="_amEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreateXMLColumns" id="a20c9504-744e-42aa-bfa5-1dfaabe3e145">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>setForCreateXMLColumns(_theXML : String; _amEdit : Boolean) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	maxH,pos, theCol : Integer;
	aLabel : String;
	aGridColumn : YRD_GridColumn;
begin
	// #################
	// Columns
	pos := 1;
	while (pos &lt;&gt; 0) do
		theCol := _theXML.cnEcGetNextTagValueOfName("COL",pos).Integer;  
		if pos = 0 then
			break;
		endif;
		
		create aGridColumn transient;
		aLabel		:= _theXML.cnEcGetNextTagValueOfName("ID",pos);
		aGridColumn.setForCreateXML(self,aLabel,theCol);

	endwhile;


end;</source>
        <Parameter name="_theXML" type="String"/>
        <Parameter name="_amEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreateXMLPoints" id="5792cc94-5bb6-4c11-9948-b9bed2510505">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>setForCreateXMLPoints(_theXML : String; _amEdit : Boolean) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	pos : Integer;
	theXML : String;
	aGridPoint : YRD_GridPoint;
begin
	// #################
	// Points
	pos := 1;
	while (pos &lt;&gt; 0) do
		theXML := _theXML.cnEcGetNextTagValueOfName("GP",pos);  
		if pos = 0 then
			break;
		endif;
		
		create aGridPoint transient;
		aGridPoint.setForCreateXML(theXML,self);

	endwhile;


end;</source>
        <Parameter name="_theXML" type="String"/>
        <Parameter name="_amEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreateXMLRows" id="d94bb43b-0680-4306-b60a-a311cb3c07d1">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>setForCreateXMLRows(_theXML : String; _amEdit : Boolean) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	maxH,pos, theRow : Integer;
	aLabel : String;
	aGridRow : YRD_GridRow;
begin
	// #################
	// ROWS
	pos := 1;
	while (pos &lt;&gt; 0) do
		theRow := _theXML.cnEcGetNextTagValueOfName("ROW",pos).Integer;  
		if pos = 0 then
			break;
		endif;
		
		create aGridRow transient;
		aLabel		:= _theXML.cnEcGetNextTagValueOfName("ID",pos);
		maxH	:= _theXML.cnEcGetNextTagValueOfName("MAX",pos).Integer;

		aGridRow.setForCreateXML(self,aLabel,theRow,maxH);

	endwhile;

end;</source>
        <Parameter name="_theXML" type="String"/>
        <Parameter name="_amEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setGridRowColPositions" id="3825520a-a01f-441e-bdc5-ba8046249b0a">
        <updating/>
        <source>setGridRowColPositions() updating;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	TopMargin		: Integer = 10;
	BottomMargin	: Integer = 10;
	LeftMargin		: Integer = 10;
	RightMargin		: Integer = 10;

	RowHeight		: Integer = 12;
//	RowSpacing		: Integer = 10;
	ColWidth		: Integer = 12;

vars
	tmpRow		: CMUI_GridRow;
	tmpCol		: CMUI_GridColumn;
	yGridRow	: YRD_GridRow;
	yGridCol	: YRD_GridColumn;
	lastPos,
	theRowHeight,
	theColWidth,
	tmpPos1,
	tmpPos2		: Real;	
	lGap,theRowNumber : Integer;
	lNow : TimeStamp;
begin

	theRowHeight := RowHeight * self.maxRowHeight * self.scaleYFactor;
	theColWidth	 := ColWidth * self.scaleXFactor;
	foreach tmpRow in self.allGridRows do
		yGridRow := tmpRow.YRD_GridRow;
		tmpPos1 := TopMargin + ((yGridRow.row - 1) * theRowHeight) + ((yGridRow.row - 1) * self.ROW_SPACING);
		tmpPos2 := tmpPos1 + theRowHeight;
		yGridRow.setYPos(tmpPos1, tmpPos2);
	endforeach;
	self.totalPointHeight := tmpPos2 + BottomMargin;
	foreach tmpCol in self.allGridColumns do
		yGridCol := tmpCol.YRD_GridColumn;
		if yGridCol.hasAllTowers then
			theColWidth := (ColWidth * self.scaleXFactor );
		else
			theColWidth := (ColWidth * self.scaleXFactor * yGridCol.maxWidth );
		endif;
		if lastPos = 0 then
			lastPos := LeftMargin;
		endif;
		tmpPos1 := lastPos + self.COLUMN_SPACING;
		
		tmpPos2 := tmpPos1 + theColWidth;
		yGridCol.setXPos(tmpPos1, tmpPos2);
		
		lastPos := tmpPos2;
	endforeach;
	
	self.totalPointWidth := tmpPos2 + RightMargin;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="updateFromNote" id="9b0f7ddb-40c9-4ad1-a937-8a09732ee933">
        <source>updateFromNote(_theRow: Integer; _theColumn: Integer; _controller: CM_LocationsController);
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
//	lSource, lTarget : CM_LocationsController;
	lRow, lCol : Integer;
//	lGridArea : CMUI_GridArea;
	lGridPoint : CMUI_GridPoint;
//	theSlotController : CM_SlotController;
//	lMoveController : CMIF_MoveController;
//	flipH, flipV,isGridController : Boolean;
	numGridTI : Integer;
	droppedTI : CM_TrackedItem;
//	aGridArea : CM_GridArea;
//	aGridController : CM_GridController;
	myParentForm : Form;
	myDrawingAttrController : CMIF_DrawingAttrController;
	yardFlippedDropOnRight : Boolean;
begin
	if self.allGridPoints.isEmpty then
		return;
	endif;
	myParentForm := self.mySDF.myParentForm;
	myDrawingAttrController := self.mySDF.myDrawingAttrController;
	lRow := _theRow;
	lCol := _theColumn;
	
	
	if self.flipHorizontal then
		lCol := self.allGridColumns.size - (lCol - 1);
	endif;
	if self.flipVertical then
		lRow := self.allGridRows.size - (lRow - 1);
	endif;
	lGridPoint := self.allGridPoints[lRow,lCol];

	if lGridPoint &lt;&gt; null then
		if lGridPoint.myLocationsController = _controller then
			if myParentForm &lt;&gt; null then
				if myParentForm.isKindOf(CMUI_GridAreaForm) then
					droppedTI := myParentForm.CMUI_GridAreaForm.myDroppedTI;
				endif;
			endif;				
			// this blanks out the whole point. This is needed cos we might re draw in a non solid fill which leaves the old stuff visible.
			// NOTE draw a filled rectangle gets rid of all other rectangles in the graphic history that where within the same Xs and Ys
			numGridTI := lGridPoint.getNumTI(REAL_MODE,droppedTI); //lGridPoint.allTrackedItems.size;
			if not lGridPoint.allTrackedItems.isEmpty then
				if lGridPoint.allTrackedItems.first &lt;&gt; self.myDummyTI then
				self.myGridAreaFrame.drawFillColor := self.myGridAreaFrame.backColor;
				self.myGridAreaFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
				self.myGridAreaFrame.drawFilledRectangle(lGridPoint.x1,lGridPoint.y1,lGridPoint.x2,lGridPoint.y2,self.myGridAreaFrame.drawFillColor);
				endif;
			endif;
			self.clearAllSelectedItems();
			// update the point
			lGridPoint.setForUpdate(myDrawingAttrController); // update all the attributes for this point - mainly TI properties
			lGridPoint.drawBetweenPoints(self.myGridAreaFrame); // clear the 2 pixel gap between points
			// this is so that in the yard the dropped TI is highlighted
			if numGridTI &lt;lGridPoint.allTrackedItems.size 
			and not lGridPoint.allTrackedItems.isEmpty then
				if myParentForm &lt;&gt; null then
					if myParentForm.isKindOf(CMUI_GridAreaForm) then
						if myParentForm.CMUI_GridAreaForm.doCheckDroppedTI(lGridPoint.allTrackedItems.last) then
							self.addTIToSelected(lGridPoint.allTrackedItems.last);
							self.addPointToSelected(lGridPoint); // PAR 7372 added AKB2004JAN
						endif;
					endif;
				endif;
			endif;

			lGridPoint.drawSelf(self.myGridAreaFrame);
			lGridPoint.setForUpdateAssociatedPoint(myDrawingAttrController);
		endif;
	endif;

end;</source>
        <Parameter name="_theRow" type="Integer"/>
        <Parameter name="_theColumn" type="Integer"/>
        <Parameter name="_controller" type="CM_LocationsController"/>
    </JadeMethod>
</Class>
