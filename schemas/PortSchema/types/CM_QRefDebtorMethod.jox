<Class name="CM_QRefDebtorMethod" id="f6f0bcda-db2d-4677-8bf7-12ffd486e54e">
    <superclass name="CM_QReferenceMethod"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
