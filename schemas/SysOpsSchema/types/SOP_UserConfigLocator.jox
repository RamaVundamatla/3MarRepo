    <JadeMethod name="setupForm" id="38d67120-3583-497f-8d4e-fefc91e3fde8">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 July 2012	cnwndl1	Initial creation
*/

vars

	canUpdateConfigs : Boolean;

begin

	create self.myAssistant transient;
	
	toolbarStyle := ToolbarStyle_ShowNoHide;	
	showToolbar := true;

	canUpdateConfigs := app.myCurrentUserCan( null, PmAdmConfigMaint );
	self.allowConfigCompare := canUpdateConfigs;
	self.allowDataMigration := ( canUpdateConfigs and app.isSpecial );
	self.allowRoleCompare := app.myCurrentUserCan( null, PmSecurityRoleView );
	self.allowShowConstant := ( app.isDevelopmentSystem or app.isSpecial );
	self.allowUserCompare := app.myCurrentUserCan( null, PmCmpUserTableView );
	
	if self.allowShowConstant then
		self.minimumWidth := 1350;
	else
		self.minimumWidth := 900;
	endif;
	self.minimumHeight := 550;
	
	inheritMethod();
	
	self.shtCompare.visible := false;
	self.shtUsers.visible := false;
	self.shtRoles.visible := false;
	self.shtBaseCode.visible := false;
	
	
	if self.allowConfigCompare then
		self.shtCompare.visible := true;
		self.shtCompare.caption := "Compare System and Terminal Config Options";
	endif;
	if self.allowUserCompare then
		self.shtUsers.visible := true;
		self.shtUsers.caption := "Compare System User setup";
	endif;
	if self.allowRoleCompare then
		self.shtRoles.visible := true;
		self.shtRoles.caption := "Compare System Security Role setup";	
	endif;
	if self.allowDataMigration then
		self.initBaseCodeFeature();
		self.shtBaseCode.caption := "System Admin Table Data Migration";
	endif;
	
	self.doResize();
	
	self.populateCombo();
	self.initTable();
	self.populateTable();
	self.doTbComparelDiffCount( true );
	
	self.resizeColumns( true );
	
	self.txtFilterBox.setFocus();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showHideMsgSearch" id="3e65e236-19f1-48af-8b26-f45463269293">
        <source>showHideMsgSearch();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 July 2012	cnwndl1	Initial creation

*/

vars

begin

	if self.frmSearchMsg.visible then
		self.frmSearchMsg.visible := false;
		self.btnSearchMsg.default := false;
	else
		
		self.frmSearchMsg.parent := self;
		self.frmSearchMsg.top := ( self.height - self.frmSearchMsg.height ) / 2;
		self.frmSearchMsg.left := ( self.width - self.frmSearchMsg.width ) / 2;
		self.frmSearchMsg.visible := true;
		self.lblSeachMsg.caption := "Enter the text you wish to search for.";
		self.frmSearchMsg.zOrder(1);
		self.txtSearchMsg.setFocus();
		self.btnSearchMsg.default := true;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="shtChange" id="5b7c2b4b-f6ff-4d14-b0eb-36dc253ffe0e">
        <updating/>
        <source>shtChange( newSheet : Sheet ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2014	cnwndl1	Initial creation

*/

vars

begin

	self.btnShowSearchTV.enabled := false;
	self.btnResetSearchMs.enabled := false; // ### TFS 55322 08NOV2022 NAVAB1
	self.btnShowOption.enabled := false; // ### TFS 55322 08NOV2022 NAVAB1
	self.frmFilter.enabled := false; // ### TFS 55322 08NOV2022 NAVAB1
	self.btnJumpTo.visible := false; // ### TFS 55322 08NOV2022 NAVAB1
	self.frmTerminal.enabled := true;
	self.btnRefresh2.visible := false; // ### TFS 55322 08NOV2022 NAVAB1
	self.btnSearchMsg.enabled := false; // ### TFS 55322 08NOV2022 NAVAB1
	self.btnRefresh.enabled := false; // ### TFS 55322 08NOV2022 NAVAB1

	if newSheet = self.shtMain then
		self.btnShowOption.enabled := true; // ### TFS 55322 08NOV2022 NAVAB1
		self.btnSearchMsg.enabled := true; // ### TFS 55322 08NOV2022 NAVAB1
		// ### TFS 55322 08NOV2022 NAVAB1 self.btnShowSearchTV.enabled := true;
		self.btnResetSearchMs.enabled := true;
		self.frmFilter.enabled := true; // ### TFS 55322 08NOV2022 NAVAB1
	elseif newSheet = self.shtUsers then
		self.btnJumpTo.visible := false;
		self.frmTerminal.enabled := false;
		self.btnRefresh2.visible := false;
		self.btnRefresh.enabled := true; // ### TFS 55322 08NOV2022 NAVAB1
	elseif newSheet = self.shtRoles then
		self.btnJumpTo.visible := false;
		self.frmTerminal.enabled := false;
		self.btnRefresh2.visible := false;
		self.btnRefresh.enabled := true; // ### TFS 55322 08NOV2022 NAVAB1
	elseif newSheet = self.shtCompare then
		self.btnShowOption.enabled := true; // ### TFS 55322 08NOV2022 NAVAB1
		self.btnSearchMsg.enabled := true; // ### TFS 55322 08NOV2022 NAVAB1
	elseif newSheet = self.shtBaseCode then
		self.btnJumpTo.visible := false;
		self.frmTerminal.enabled := false;
		self.btnRefresh2.visible := false;
	endif;

epilog

end;</source>
        <Parameter name="newSheet" type="Sheet"/>
    </JadeMethod>
