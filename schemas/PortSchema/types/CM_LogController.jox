    <JadeMethod name="getLogGradeColour" id="7284dcbf-e7e1-4b42-9117-2f0cbe9727a8">
        <source>getLogGradeColour(colour : Integer output) : Boolean;
// ---------------------------------------------------------------------------
// Created:      10 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	soh : CM_SOHLocation;
	prod : CM_Product;
	logGrade : CM_LogGrade;
	ti : CM_TrackedItem;

begin
	if self.isStockControlled then
		foreach soh in self.allProductLocations do
			if soh.numTIs &lt; 1 then
				continue;
			endif;
		
			prod := soh.myProduct;
			if prod &lt;&gt; null and CM_ProductLog.hasInstance(prod) then
				logGrade := prod.CM_ProductLog.myLogGrade;
				if logGrade &lt;&gt; null then
					colour := logGrade.colour;
					return true;
				endif;
			endif;
		endforeach;	

	else
		if self.numTIs &gt; 0 then
			foreach ti in self.allTrackedItems do
				if CM_Log.hasInstance(ti) then
					logGrade := ti.CM_Log.myLogGrade;
					if logGrade &lt;&gt; null then
						colour := logGrade.colour;
						return true;
					endif;
				endif;
			endforeach;
		endif;
	endif;		
				
	return false;
end;</source>
        <Parameter name="colour" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getMasterLog" id="e958c541-8692-4f93-a05c-70a88530bea2">
        <updating/>
        <source>getMasterLog(_theMode : Integer) : CM_Log updating;
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theLog : CM_Log;
	theTrackedItem : CM_TrackedItem;
begin

	theTrackedItem := self.getTIAtIndex(_theMode, 1);
	
	if theTrackedItem = null then
		return null;
	endif;
	
	theLog := null;
	if theTrackedItem.isKindOf(CM_Log) then
		theLog := theTrackedItem.CM_Log;
	endif;
	
	return theLog;
end;</source>
        <Parameter name="_theMode" type="Integer"/>
        <ReturnType type="CM_Log"/>
    </JadeMethod>
    <JadeMethod name="getOperatorColour" id="edc9bd0d-c7cf-42a5-8fb0-23a06fb8c757">
        <source>getOperatorColour(colour : Integer output) : Boolean;
// ---------------------------------------------------------------------------
// Created:      10 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	passport : CM_Passport;
	soh : CM_SOHLocation;
	op : CM_Operator;
	ti : CM_TrackedItem;
	failedDAC  :CM_DataAccessController;

begin
	passport := app.myPassport;
	
	if self.isStockControlled then
		foreach soh in self.allProductLocations do
			if soh.numTIs &lt; 1 then
				continue;
			endif;
			
			op := soh.myOperator;
			if op &lt;&gt; null 
			and op.canUserAccessSelf(null, failedDAC, passport) then
				colour := op.colour;
				return true;
			endif;
		endforeach;

	else
		if self.numTIs &gt; 0 then
			foreach ti in self.allTrackedItems do
				op := ti.myOperator;
				if op &lt;&gt; null 
				and op.canUserAccessSelf(null, failedDAC, passport) then
					colour := op.colour;
					return true;
				endif;
			endforeach;
		endif;
	endif;		
				
	return false;
end;</source>
        <Parameter name="colour" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getPercentageFull" id="2dda1c20-6aa3-4650-93e8-327c0a0fe364">
        <source>getPercentageFull() : Integer;
/*
----------   ----------  --------------------------------------------------
Created:	12 March 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.estimatedMaxVolume &lt;&gt; 0 then
			return ((self.totalVolume/self.estimatedMaxVolume)*100).Integer;
	endif;
	return null;

end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPictureType" id="b31fa15f-19dd-44e1-8615-d908d985fb6a">
        <source>getPictureType(): Integer;

begin
	
	if self.usage = BUILDING_USE then
		return LOC_Display_Building;
	elseif self.usage = LIGHT_TOWER_USE then
		return LOC_Display_LightTower;
	elseif self.availability = PAD_UNAVAILABLE or self.availability = PAD_USER_UNAVAILABLE then
		return LOC_Display_Unavailable;
	endif;
	
	return LOC_Display_Available;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
