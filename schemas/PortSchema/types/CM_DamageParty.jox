    <JadeMethod name="validateForDelete" id="6d3cb7e1-59e3-41df-b7cf-851d35cb6fe5">
        <source>validateForDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2022	navak20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars

begin
	if self.allDamageInstances.isNotEmpty then
		app.raiseCMException1(Cannot_Delete_DamageParty, self.code, null, null);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="7a104e62-7bd7-461a-8ba3-611b000867e7">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2022	navak20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	realDamageParty,
	existingDamageParty			: CM_DamageParty;
begin
	if self.code = null then
		app.raiseCMException(Input_required_field_code, ETRow_Code, self);
	endif;
	
	if self.description = null then
		app.raiseCMException(Input_required_field_desc, ETRow_Description, self); 
	endif;
	
	
	existingDamageParty	:= self.myTerminal.allDamageParties[self.code];
	realDamageParty		:= self.pxyGetRealObject();
	
	if existingDamageParty &lt;&gt; null and
	   (realDamageParty = null or //in which case we are trying add a new one that is duplicate
	   realDamageParty &lt;&gt; existingDamageParty) //in which case we are trying update one to be same as another
	   then
		app.raiseCMException1(DamageParty_code_already_exist, self.code.String, null, null); 
	endif;
	
epilog

end;</source>
    </JadeMethod>
</Class>
