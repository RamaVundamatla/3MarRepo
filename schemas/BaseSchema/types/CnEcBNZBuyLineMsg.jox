    <JadeMethod name="buildMessage" id="78fd8c3d-9474-4cba-ad8c-e85abf05ed44">
        <source>buildMessage(pMessage : String io):String;

// pMessage becomes equal to the message to be sent to the BuyLine system.
// Any error message is returned.

vars
	errorString	: String;
	
begin
	errorString := " 'BuyLine' Message type not yet implemented. ";
	return errorString;
end;</source>
        <Parameter name="pMessage" type="String" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="checkAmount" id="b6eca5a9-172b-4891-9e38-4bc0f1c6563e">
        <source>checkAmount():String;

vars
	errorMessage	: String;
	
begin
	if self.amount = 0 then
		errorMessage := "Amount may not be Zero.  ";
	endif;
epilog
	return errorMessage;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="checkCardNum" id="b4c24ece-63f3-4123-8373-394cae89a2d0">
        <source>checkCardNum():String;

vars
	errorMessage	: String;
	
begin
	if self.cardNum.String.length &lt; 16 then
		errorMessage := "Credit Card Number too short.  ";
	endif;
epilog
	return errorMessage;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="checkCurrency" id="86642075-d8a0-46a1-8193-e4402434dbb0">
        <source>checkCurrency():String;

vars
	errorMessage	: String;
	
begin
	if self.currency &lt;&gt; 554 then
		errorMessage := "Must New Zealand Dollars.  ";
	endif;
epilog
	return errorMessage;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
