    <JadeMethod name="tReleaseByType_ISOGroup" id="ef760004-a467-4160-98dc-67b826bd22c5">
        <source>tReleaseByType_ISOGroup();
// cnwdap1
//27 Jan 2010	cnwdw1	
// Test that gate out of a "by type" release request for ISO Group
vars
	releaseRequest: CM_BulkRelease;
	truck: CM_Vehicle;
	ti: CM_TrackedItem;
	ya: CM_YardAllocation;
	locations : CM_LCArray;
	source: CM_LocationsController;
	yaName: String;
	vvr: CM_VehicleVisitRecord;
begin
	self.disableAllYA(true);
	deleteReleaseRequest("UTRRRoad");
	deleteVehicle("UTTRUCK");
	self.deleteContainer("TEST0000001");
	
	// Setup a YA over a block stack that has a cvontainer that could be released
	ti := self.addContainer("TEST0000001", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"UT20", "MT", TI_IMEX_STATUS_STORAGE);
	
	create locations transient;
