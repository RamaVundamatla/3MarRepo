<GUIClass name="CnEcDesignWebButton" id="9e61bca5-63fd-4923-a6a1-ed7d109274d1">
    <superclass name="Button"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
