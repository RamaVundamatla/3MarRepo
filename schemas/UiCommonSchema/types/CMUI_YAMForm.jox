    <JadeMethod name="doContextMenu" id="2bb434c9-de2d-4871-b882-e5dfc6c3b141">
        <updating/>
        <source>doContextMenu(conwin: Window input; mouse: Boolean; x: Integer; y: Integer) : Boolean updating;
//19 February 2009	cnwwc2	Initial creation
//04 November 2011	cnwdap1	PAR #28629 Do't show Delete menu item of user has no Yard Allocation Maintenance permissions
vars

	x1, y1	: Real;
	menu	: MenuItem;
	caption: String;
begin
	self.doTurnOffContextMenus();
	
	if self.tblData = conwin then
		self.mnuColumnOrg.visible		:=	true;
		self.mnuColumnOrg.userObject	:=	self.tblData;
		
		//09 Jan 2012	NDL	Par 28889
		self.mnuClearYamTblFilters.visible := false;
		if self.allColumnFilters &lt;&gt; null then
			if not self.allColumnFilters.isEmpty then
				if self.allColumnFilters.includesFiltersFor( self.tblData ) then
					self.mnuClearYamTblFilters.visible := true;
				endif;
			endif;
		endif;
		
		// Show Context menu for YAM table
		self.mnuYANew.visible		:=	true;
		// PAR 19177
		//if self.tblData.hasGroups then
		if self.tblData.hasGroups and self.tblData.getSelectedObjectsYA() &lt;&gt; null then
			self.mnuYAGroupNew.visible			:=	true;
		endif;

		if app.getMyUser.canDo(self.myTerminal, PmAdmYardStatistics) then
			self.mnuGridSeperator03.visible		:=	true;
			self.mnuRebuildStats.visible		:=	true;
			self.mnuProcessMovementLog.visible	:=	true;
		endif;
		self.mnuGridSeperator02.visible		:=	true;
		if self.tblData.isSelected then
			if self.tblData.isSingleSelection then
				
				if self.tblData.isYABlockSelected then
					 caption := "Range ";
				elseif self.tblData.isYAGroupSelected then
					 caption := "Group ";
				endif;

				caption := caption &amp; '"' &amp; self.tblData.getSelectedName() &amp; '"';
			else
				caption := 'Selected';
			endif;
			if self.tblData.isSingleSelection or self.tblData.isYASelected then
				self.mnuYAEdit.caption := 'Edit ' &amp; caption &amp; '...';
				self.mnuYAEdit.visible := true;
			endif;
			self.mnuYADelete.caption := 'Delete ' &amp; caption;
			if app.myCurrentUserCan(self.myTerminal, PmAdmYAMaint) then		// PAR #28629
				self.mnuYADelete.visible := true;
			else															// PAR #28629
				self.mnuYADelete.visible := false;							// PAR #28629
			endif;															// PAR #28629
		endif;
		if self.tblData.isSingleSelection and self.tblData.isYABlockSelectedAndDeckable then
			self.mnuYADeckingOptions.visible := true;
			self.mnuYADeckingOptions.caption := "Decking Option";
		endif;
		
		self.mnuInspect.visible				:=	false;
		self.mnuPurgeMovementLog.visible	:=	false;
		if app.isAllowedToInspect then
			self.mnuInspect.visible		:=	true;
			self.mnuInspect.enabled		:=	true;
			self.mnuInspect.userObject	:=	self.tblData.getSelectedObject();
			self.mnuPurgeMovementLog.visible	:=	app.isSpecial;
		endif;
		self.mnuGridSeperator02.visible := self.mnuInspect.visible;
		
		
		
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuYANew.visible := false;
		self.mnuYAGroupNew.visible := false;
		self.mnuYAEdit.visible := false;
		self.mnuYADelete.visible := false;
		self.mnuYADeckingOptions.visible := false;
		self.mnuRebuildStats.visible := false;
		self.mnuPurgeMovementLog.visible := false;
		self.mnuProcessMovementLog.visible := false;
	endif;
		
		self.popupMenu(self.mnuSpecial, x, y);

	endif;	
	
	return false;
end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCopy" id="b14f73cd-cb8b-4eeb-8a54-4ee0c6d84cdc">
        <source>doCopy() protected;

// Created by cnwdvb1 on 07 August 2006

vars

	viewObj,
	objCopy		: Object;
	result		: Integer;

begin

	// Get combo objects.
	viewObj		:= self.cmbTemplateView.listObject;
	objCopy 	:= self.cmbTemplateTo.listObject;
	
	if app.msgBox('Do you wish to copy the selected allocation(s)', 'Confirm Copy',
					MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	
	// Get allocations to copy.
	self.yaSet.clear();
	self.tblData.allSelectedObjects.copy(self.yaSet);
	if self.yaSet.isEmpty() then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	// Looking at terminal copy to group or group to group.
	if (viewObj.isKindOf(CM_Terminal) and objCopy.isKindOf(CM_YATemplateGroup)) or
		(viewObj.isKindOf(CM_YATemplateGroup) and objCopy.isKindOf(CM_YATemplateGroup)) then
		
		while true do
			app.myTrxCA.trxCreateYASnapshot(false, objCopy.CM_YATemplateGroup, self.yaSet, app.myPassport);
			if app.myPassport.trxCompletedOK then
				break;
			else
				result := app.showErrorWarningDialog('Copy', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;
	
	// Looking at group to terminal copy.
	elseif viewObj.isKindOf(CM_YATemplateGroup) and objCopy.isKindOf(CM_Terminal) then
		while true do
			app.myTrxCA.trxCreateYASnapshot(true, viewObj.CM_YATemplateGroup, self.yaSet, app.myPassport);
			if app.myPassport.trxCompletedOK then
				break;
			else
				result := app.showErrorWarningDialog('Copy', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;
	endif;

epilog
	app.mousePointer := MousePointer_Default;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDeleteGroup" id="7f461e76-205c-497d-9b6b-73f2543968ff">
        <updating/>
        <source>doDeleteGroup() protected, updating;

// Created by cnwdvb1 on 08 August 2006

vars
	obj 	: CM_Object;
	msgStr	: String;

begin

	obj := self.myCurrentTemplateGroup;
	
	if obj = null then
		return;
	endif;
	
	msgStr := app.getErrorString2(ConfirmDelete, 'Template Group', self.myCurrentTemplateGroup.code);
	if app.msgBox(msgStr, 'Confirm Deletion',
					MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	app.myTrxDA.trxDeleteCMObject(obj, app.myPassport);
	if app.myPassport.trxCompletedOK() then
		self.setupTemplateGrpsCombo();
		self.doRefresh();
	endif;
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doEditTemplateGroup" id="8b55e04e-d34e-46a4-85d7-7dd36f69d0f4">
        <updating/>
        <source>doEditTemplateGroup() protected, updating;

// Created by cnwdvb1 on 07 August 2006

vars
	groupName	: String;
	inputBox	: CMUI_InputBox;
	
begin
	if self.myCurrentTemplateGroup = null then
		return;
	endif;

	// PAR 16394
	create inputBox transient;
//	inputBox.init(app.getErrorString(Edit_template_group),app.getErrorString(Edit_name_templat_group),"", 0, TextBox.DataType_AlphaNumeric, true);	// cnwrl1 05/06/2009 PAR 19574 - what it was
	inputBox.init(	app.getErrorString(Edit_template_group), app.getErrorString(Edit_name_templat_group),
					"", 0, TextBox.DataType_AlphaNumeric, TextBox.Case_None, true, false);
	inputBox.showModal;
	if inputBox.modalResult &lt;&gt; IDOK then
		return;
	endif;

	groupName := inputBox.txtInput.text;
	//groupName	:=	self.cnEcGetUserInput("Edit Template Group", "Enter the new name of the Template Group:", null);
	
	if groupName = null then
		return;
	endif;
	
	beginTransaction;
	self.myCurrentTemplateGroup.setForCreate(groupName);
	commitTransaction;

	self.setupTemplateGrpsCombo();
	self.doRefresh();
epilog

//	app.mousePointer := MousePointer_Default;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
