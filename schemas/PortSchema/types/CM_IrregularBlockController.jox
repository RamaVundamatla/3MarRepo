end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="erase" id="ec3c14e4-559d-461d-8312-0c32850bc700">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     31 October 2013 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if self.hasTIs() then
		app.raiseCMException1(Canno_erase_becau_cargo_colou_, self.getFullId, null,null); // PAR 32886
	
	endif;
	
	inheritMethod(_eraseLevel);

epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="41c00a7f-0a97-48e4-b45b-fd9a5f207f9e">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jan 2025	navnk30	JIRA 19801: MTN - Audits on Terminal Area Definitions

*/

vars
	auditTxt	: String;
begin
	auditTxt[10000] := '*';
	auditTxt 		:= null;
	auditTxt 		:= inheritMethod();
	
	auditTxt := self.asStringJMT() &amp; AuditStringSeparator &amp; auditTxt.length.String &amp; AuditStringSeparator &amp; auditTxt &amp; AuditStringSeparator;
	return auditTxt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCapacityPC" id="f30b62ab-b30d-4a76-ac2b-d2589855a5f1">
        <source>getCapacityPC(_mode : Integer) : Integer;
/*
Purpose:	return the capacity as a percentage		
Date		Who		Reason
04 September 2013	cnwab1	Initial creation
*/

vars
	capacity, capacityPC, totQty : Integer;
	array : CM_TIArray; 
	ti : CM_TrackedItem;
begin

	capacity := self.getCurrentCapacity();
	if capacity = 0 then
		return 0;
	endif;
	
	create array transient;
	self.getTIs(array, _mode, true);
	foreach ti in array discreteLock do
		totQty := totQty + ti.totalQuantity;
	endforeach;
	
	capacityPC := ((totQty / capacity) * 100).Integer;

	return capacityPC;
epilog
	delete array;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCarCountForVoyage" id="d94aa7b2-41f1-4705-82c8-07c4dfc0d983">
        <source>getCarCountForVoyage(_voyageCode: String): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 December 2017	jlger1	Initial creation 7931

*/

vars
	shelf : CM_RackShelfController;
	shelfIter : Iterator;
	ti : CM_TrackedItem;
	count : Integer;
begin
	if self.isRack then 
		foreach shelf in self.allSubLocations do					
			shelfIter := shelf.allTrackedItemsById.createIterator();
			while shelfIter.next(ti) do
				if not ti.isCar then
					continue;
				endif;
				
				if (ti.voyageCode = _voyageCode or (ti.isTranshipExport and ti.importVoyageCode = _voyageCode )) then		
					count := count + 1;
				endif;
			endwhile;
			delete shelfIter;
		endforeach;		
		return count;
	else
		return inheritMethod(_voyageCode);
	endif;
epilog
	delete shelfIter;
end;</source>
        <Parameter name="_voyageCode" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCargoFillColour" id="4ee7a1cd-ce81-48ac-9068-d3c4df6b3b33">
