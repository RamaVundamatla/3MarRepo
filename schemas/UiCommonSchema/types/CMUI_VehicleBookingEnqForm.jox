    <JadeMethod name="doTblInfoDbClick" id="30161c82-7039-4ae4-ad50-db90c7c3f03e">
        <updating/>
        <source>doTblInfoDbClick(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
14 December 2022	navhl20	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
25 Aug 2023			navlw1	Bug 60046: FR | 53429 - VBS MTN - Enquiry Screen issues
*/

vars
	obj		: Object;
	booking : CM_BookingRef;
begin
	if table.row &lt;= table.fixedRows or table.column &lt;= table.fixedColumns then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	obj := table.accessCell(table.row, table.column).itemObject.Object;
	if obj &lt;&gt; null then
		if obj.isKindOf(CM_BulkRelease) then
			self.doShowBulkRelease(obj.CM_BulkRelease);		
			return;
		endif;
		if obj.isKindOf(CM_TrackedItem) then		
			self.doShowCargoEnquiry(obj.CM_TrackedItem);	
			return;
		endif;
		if obj.isKindOf(CM_BookingRef) then
			self.doShowBooking(obj.CM_BookingRef);
		endif;
		if obj.isKindOf(CM_BookingRefItem) then
			booking := obj.CM_BookingRefItem.myBookingReference;
			self.doShowBooking(booking);
		endif;
		if app.isAllowedToInspect() then
			obj.inspect;
		endif;
	endif;

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="emailLayoutPermissionCheck" id="4f203735-8576-49de-b8db-a8aa353ec180">
        <source>emailLayoutPermissionCheck();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Oct 2022	navak20 ChangeRequest 54046: EUP - VBS MTN - [7] - Email configuration and notifications

*/

vars

begin
	if not app.myCurrentUserCan(self.myTerminal, PmAdmVbsEmailConfigureMaint) and not app.myCurrentUserCan(self.myTerminal, PmAdmVbsEmailConfigureView) then
		self.btnEmailLayout.enabled := false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="enableCopySlot" id="63c4f5d9-c9c7-4e48-a98d-003b636a2e9f">
        <source>enableCopySlot():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Aug 2023	navma1	ChangeRequest 59700: FR | 53429 - VBS Slot transfer - Slot status
*/

vars
	firstSlot,
	slot   		: CM_VehicleBookingTimeSlot;
begin

	if self.tblData.allSelectedObjects.isEmpty then
		return false;
	endif;
	
	
	if self.tblData.allSelectedObjects.size = 1 then 
		firstSlot := self.tblData.allSelectedObjects.first.CM_VehicleBookingTimeSlot;
		if firstSlot.canBeCopied then
			return true;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enableTransferSlot" id="47d0de24-38d1-480c-beb8-b2f04567e003">
        <source>enableTransferSlot():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Aug 2023	navma1	ChangeRequest 59700: FR | 53429 - VBS Slot transfer - Slot status
25 Aug 2023 navhl20 ChangeRequest 60058: FR | 53429 - VBS Slot transfer - Multiple Slot types
*/

vars
	firstSlot,
	slot   		: CM_VehicleBookingTimeSlot;
begin

	if self.tblData.allSelectedObjects.isEmpty then
		return false;
	endif;
	
	//firstSlot := self.tblData.allSelectedObjects.first.CM_VehicleBookingTimeSlot;				//25.8.2023 navhl20 #60058
	
	foreach slot in self.tblData.allSelectedObjects as CM_VehicleBookingTimeSlot  do
		/*if slot.myVBTimeSlotType &lt;&gt; firstSlot.myVBTimeSlotType then							//25.8.2023 navhl20 #60058
			return false;
		endif;*/
		
		if not slot.canBeTransfered then
			return false;
		endif;
	endforeach;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="d2ae72d1-4bb0-45c8-a47e-4d36a5db3f4a">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Sep 2022	navhl20	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
14 Jul 2023	navma1	ChangeRequest 59136: EUP | VBS Edi Enhancement [1]
06 Aug 2023	navlw1	Bug 60367: FR | 53429 - VBS MTN - Enquiry Screen issues
*/

vars
	theXML	:	String;
	hideMacro : Boolean;
begin
	hideMacro :=  (self.mnuContextHide.caption = self.MNU_MACRO_SHOW);
	theXML    := inheritMethod();
	theXML    := theXML &amp; global.formatAsXML("HM",hideMacro.Integer.String);
	theXML    := theXML &amp; self.tblData.getXmlStrForColumns(false);
	
	theXML &amp;= global.formatAsXMLPrefix(self.VbsSlotType_Setting.String).removeCrLfs    &amp; self.cmbSlotType.text  	 &amp; global.formatAsXMLSuffix(self.VbsSlotType_Setting.String);
	theXML &amp;= global.formatAsXMLPrefix(self.Direction_Setting.String).removeCrLfs      &amp; self.cmbDirection.text      &amp; global.formatAsXMLSuffix(self.Direction_Setting.String);
	theXML &amp;= global.formatAsXMLPrefix(self.Source_Setting.String).removeCrLfs         &amp; self.cmbSource.text   	     &amp; global.formatAsXMLSuffix(self.Source_Setting.String);
	theXML &amp;= global.formatAsXMLPrefix(self.SourceId_Setting.String).removeCrLfs  	   &amp; self.cmbRRID.text 		     &amp; global.formatAsXMLSuffix(self.SourceId_Setting.String);
	theXML &amp;= global.formatAsXMLPrefix(self.CreationMethod_Setting.String).removeCrLfs &amp; self.cmbCreationMethod.text &amp; global.formatAsXMLSuffix(self.CreationMethod_Setting.String); //14.07.2023 navma1 #59136
	theXML &amp;= global.formatAsXMLPrefix(self.Status_Setting.String).removeCrLfs		   &amp; self.cmbStatus.text 		 &amp; global.formatAsXMLSuffix(self.Status_Setting.String); // 06.09.2023 navlw1 tfs #60367
	return theXML;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="3bcc6f69-d5bc-4e3d-b258-e5d4d3d84ac8">
        <source>getXMLSettingsForSetup();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2022	navhl20	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen

*/

vars
	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
	hideM : Boolean;
begin

	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	theXML := userWindow.xmlInfo;
	// #### HIDE MACRO
 	theXMLValue := theXML.cnEcGetTagValueOfName("HM");
 	hideM := false;
 	if theXMLValue &lt;&gt; null then
 		hideM := theXMLValue.Integer.Boolean;
 	endif;
 	
 	if hideM then
 		self.splMain.hideRightControl(true);
 		self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
 	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="includeObject" id="210c2808-b8a1-46ad-8ed2-0f8028aac5a0">
        <source>includeObject(_vbsSlot : CM_VehicleBookingTimeSlot ):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Sep 2022 navma1	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
22 Sep 2022 navhl20 ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
14 Jul 2023	navma1	ChangeRequest 59136: EUP | VBS Edi Enhancement [1]
31 Jul 2023 navma1	Bug 59332: MTN - Vehicle Booking Enquiry Notifications don't check current terminal
25 Aug 2023	navlw1	Bug 60046: FR | 53429 - VBS MTN - Enquiry Screen issues
06 Sep 2023	navlw1	Bug 60367: EUP | FR | 53429 - VBS changes - Enquiry screen search issues
22 Nov 2023 navlc30 ChangeRequest 61256: EUP | FR | 54329 | VBS - Pending issues - Issue 12
*/

vars
	startDate,
	endDate		: Date;
	ti 			: CM_TrackedItem;
	source		: Integer;
	slotItem 	: CM_VehicleBookingTimeSlotItem;
	include		: Boolean;
	filterOperator : CM_Operator;
	
begin
	if not app.isValidObject(_vbsSlot) then
		return false;
	endif;
	
	if _vbsSlot.myTerminal &lt;&gt; self.myTerminal then	//31.07.2023 navma1 #59332
		return false;
	endif;
	//Start 22.09.2022 navhl20 TFS 53900
	if self.cmbType.text = self.By_Day and self.mskStartDate.getDate() &lt;&gt; null then
		if _vbsSlot.bookingTSstart.Date &lt;&gt; self.mskStartDate.getDate() then
			return false;
		endif;
	endif;
	
	if self.cmbType.text = self.By_Month and self.cmbMonth.listIndex &gt; 0 then
		if _vbsSlot.bookingTSstart.Date.month &lt;&gt; self.cmbMonth.listIndex then
			return false;
		endif;
	endif;
	
	if self.cmbType.text = self.By_Period and self.mskStartDate.getDate() &lt;&gt; null then
		startDate := self.mskStartDate.getDate();
		if self.mskEndDate.getDate() &lt;&gt; null then
			endDate := self.mskEndDate.getDate();
		else
			endDate := app.cnGetServerTime().Date;  
		endif;
		if _vbsSlot.bookingTSstart.Date &lt; startDate or _vbsSlot.bookingTSstart.Date &gt; endDate then
			return false;
		endif;
	endif;
	
	if self.cmbSlotType.listObject &lt;&gt; null then
		if _vbsSlot.myVBTimeSlotType &lt;&gt;  self.cmbSlotType.listObject then
			return false;
		endif;
	endif;
	
	if self.txtVbsId.text &lt;&gt; null then
		if _vbsSlot.id.pos(self.txtVbsId.text,1) &lt;= 0 then
			return false;
		endif;
	endif;
	
	if self.txtExtRef.text &lt;&gt; null then
		if _vbsSlot.externalReference.pos(self.txtExtRef.text,1) &lt;= 0 then
			return false;
		endif;
	endif;
	
	if self.cmbCarrier.listObject &lt;&gt; null then
		if _vbsSlot.myCarrier &lt;&gt;  self.cmbCarrier.listObject then
			return false;
		endif;
	endif;
	
	if self.cmbSubCarrier.listObject &lt;&gt; null then
		if _vbsSlot.mySubCarrier &lt;&gt;  self.cmbSubCarrier.listObject then
			return false;
		endif;
	endif;
	
	if self.cmbDriver.listObject &lt;&gt; null then
		if _vbsSlot.myDriver &lt;&gt;  self.cmbDriver.listObject then
			return false;
		endif;
	endif;
	
	if self.cmbVehicle.listObject &lt;&gt; null then
		if _vbsSlot.myVehicle &lt;&gt;  self.cmbVehicle.listObject then
			return false;
		endif;
	endif;
	
	if self.cmbStatus.text &lt;&gt; null and self.cmbStatus.text &lt;&gt; Any_String then // 06.09.2023 navlw1 tfs #60367
		if _vbsSlot.getStatusString &lt;&gt; self.cmbStatus.text then
			return false;
		endif;
	endif;
	
	if self.cmbCreationMethod.text &lt;&gt; self.CreationMethod_Any_Value then							//14.07.2023 navma1 #59136
		if _vbsSlot.getCreationMethod &lt;&gt; self.cmbCreationMethod.text then
			return false;
		endif;
	endif;
	
	if self.txtRemarks.text &lt;&gt; null then
		if _vbsSlot.remarks.pos(self.txtRemarks.text,1) &lt;= 0 then
			return false;
		endif;
	endif;
	
	source := self.cmbSource.getCurrentItemData;
	
	if source = self.SOURCE_BOOKING and self.cmbRRID.listObject &lt;&gt; null then
		if not _vbsSlot.allBookingRefs.includes(self.cmbRRID.listObject.CM_BookingRef) then
			return false;
		endif;
	endif;
	
	if source = self.SOURCE_RELEASE and self.cmbRRID.listObject &lt;&gt; null then
		if not _vbsSlot.allBulkReleases.includes(self.cmbRRID.listObject.CM_BulkRelease) then
			return false;
		endif;
	endif;
	
	if source = self.SOURCE_CARGO and self.txtCargoId.text &lt;&gt; null then
		if _vbsSlot.allBookedTrackedItems.size = 0 then
			return false;
		endif;
		foreach ti in _vbsSlot.allBookedTrackedItems do
			if not ti.id = self.txtCargoId.text then
				return false;
			endif;
 		endforeach;
	endif;
	//End 22.09.2022 navhl20 TFS 53900
	
	// 25.08.2023 navlw1 #60046
	if self.cmbDirection.text &lt;&gt; self.Direction_Any_Value then
		if self.cmbDirection.text = "Delivery" then
			return _vbsSlot.hasDelivery();
		else
			return _vbsSlot.hasPickup();
		endif;
	endif;
	
	filterOperator := self.cmbOperator.listObject.CM_Operator;									//22.11.2023 navlc30 #61256
	if filterOperator &lt;&gt; null then
		if not _vbsSlot.isOperatorMatch(filterOperator) then
			return false;
		endif;
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_vbsSlot" type="CM_VehicleBookingTimeSlot"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
