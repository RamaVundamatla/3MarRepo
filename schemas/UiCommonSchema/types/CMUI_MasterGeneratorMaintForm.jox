    <JadeMethod name="doBaseFormCancel" id="9720bb28-5c82-4522-91a3-cb8545ba506c">
        <updating/>
        <source>doBaseFormCancel() updating, protected;
/* ---------------------------------------------------------------------------
Created:	13 August 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	inheritMethod();
	
	if self.hasChanged then
		if self.confirmCancel(app.getErrorString(The_Current_Item)) then
			self.unloadForm();
		else
			return;
		endif;
	else	
	self.unloadForm();
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
