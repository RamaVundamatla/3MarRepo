    <JadeMethod name="getMyTerminal" id="ca1a3f48-7e9d-479c-a8f5-3cb9d0161c20">
        <source>getMyTerminal(): CM_Terminal;
/*
Purpose:		TFS 2682	
Date		Who		Reason
15 September 2016	cnwab1	Initial creation
*/

vars
	bu : CM_Bank;
begin
	bu := self.getBank();
	
	if bu = null then
		return null;
	endif;
	
	return bu.getMyTerminal();

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getServiceBroker" id="988b52c1-07da-4441-b13b-bee545c11ca2">
        <source>getServiceBroker(_theTransaction: HMS_VTMISTransaction) : CM_ResourceServiceBroker;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
23 Oct 2024 navlw1  JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	theBroker 		: CM_ResourceServiceBroker;
	theResource 	: HMS_Resource;
	invalid 		: Boolean;
	resUsed			: HMS_ResourceUsed;
	canLogExtra	: Boolean;	//28.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//28.02.2025 navah1	#34141
	if _theTransaction = null then
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog("No transaction, no charging", LogTRACE.String);
		endif;
		return null;
	endif;
	
	on Exception do app.handleDeletedObject(exception, _theTransaction, invalid);
	resUsed := _theTransaction.myResourceUsed;
	
	if invalid or resUsed = null then
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog("No resources used, no charging", LogINFO.String);
		endif;
		return null;
	endif;
	
	theResource := resUsed.myResource;
	if theResource = null then
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog("No resources used, no charging", LogINFO.String);
		endif;
		return null;
	endif;
	
	theBroker := self.allResourceSBs[theResource.code];
	if theBroker &lt;&gt; null then
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog("Resource map found for " &amp;  theResource.description &amp; " (" &amp; theResource.code &amp; ")", LogTRACE.String);
		endif;
	endif;
	
	if theBroker = null then
		theBroker := self.allResourceSBs[null]; // DEFAULT
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog("Resource map used for DEFAULT. Resource to be charged is " &amp; theResource.description &amp; " (" &amp; theResource.code &amp; ")", LogTRACE.String);
		endif;
	endif;
	return theBroker;
	
end;</source>
        <Parameter name="_theTransaction" type="HMS_VTMISTransaction"/>
        <ReturnType type="CM_ResourceServiceBroker"/>
    </JadeMethod>
    <JadeMethod name="getServiceBrokerFromResource" id="b1ab7ea6-8fd1-40af-8773-ced6c3fcc81c">
        <source>getServiceBrokerFromResource(_theResource : HMS_Resource) : CM_ResourceServiceBroker;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theBroker : CM_ResourceServiceBroker;
begin

	theBroker := self.allResourceSBs[_theResource.code];
	
	if theBroker = null then
		theBroker := self.allResourceSBs[null]; // DEFAULT
	endif;
	return theBroker;
end;</source>
        <Parameter name="_theResource" type="HMS_Resource"/>
        <ReturnType type="CM_ResourceServiceBroker"/>
    </JadeMethod>
