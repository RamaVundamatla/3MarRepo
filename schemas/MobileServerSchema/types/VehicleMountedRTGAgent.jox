    <JadeMethod name="setMyWorkedVehicleMachine" id="a4bb06aa-2435-4e4f-bea3-ccf0a84a7d83">
        <updating/>
        <source>setMyWorkedVehicleMachine(_value : CM_VehicleMachine) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
19 March 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.myWorkedVehicleMachine:=_value;
