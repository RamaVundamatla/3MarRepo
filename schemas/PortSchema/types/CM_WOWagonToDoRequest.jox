<Class name="CM_WOWagonToDoRequest" id="dbd95095-ab00-43e9-b104-f3a2d0830547">
    <superclass name="CM_WOToDoRequest"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="workorder"/>
    <ExplicitInverseRef name="allWagons" id="15671e3a-c040-46aa-b448-ede5c9c6848b">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <type name="CM_WagonByIdDict"/>
        <access>readonly</access>
        <Inverse name="CM_Wagon::allWorkOrderRequests"/>
    </ExplicitInverseRef>
    <JadeMethod name="createWLEs" id="8cc3c086-fbdf-4106-b92a-d4ed4392922e">
        <source>createWLEs();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/

vars
	aWLE			:	CM_WOWagonToDoWLE;
	wagon			:	CM_Wagon;
	toDoTask		: 	CM_ToDoTask;
	wagonIter		: 	Iterator;
begin
	wagonIter := self.myJob.CM_WOToDoWagonJob.allWagons.createIterator();
	
	while wagonIter.next(wagon) do
		create aWLE persistent;
		aWLE.setForCreate(self.myJob, self); 
		aWLE.setMyWagon(wagon);
	endwhile;
epilog
	delete wagonIter;
end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreateInternal" id="9801a416-dbb7-4a28-9651-6b6e5b6da415">
        <updating/>
        <source>setForCreateInternal(_myJob: CM_WOToDoTaskJob; _toDoInternalJobParam: CMIF_WorkOrderJobParams) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/

vars

begin
	inheritMethod(_myJob, _toDoInternalJobParam);
	
	self.myJob.CM_WOToDoWagonJob.allWagons.copy(self.allWagons);
epilog

end;</source>
        <Parameter name="_myJob" type="CM_WOToDoTaskJob"/>
        <Parameter name="_toDoInternalJobParam" type="CMIF_WorkOrderJobParams"/>
    </JadeMethod>
</Class>
