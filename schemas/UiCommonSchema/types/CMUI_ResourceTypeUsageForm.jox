    <JadeMethod name="setTblCargo" id="7eda5ca3-3b4b-4320-bd6a-602cb09ff06b">
        <source>setTblCargo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Jul 2024	navbs1	CR 64901 Task 64903: UI - Show Cargo Ids in To Do Complete Thin Client

*/

vars
	entTableDef		: EntTableDef;
	ti				:CM_TrackedItem;
	dataLine		:String;
	tbl 			:CM_DataTable;
begin

	tbl:=self.tblCargo;
	tbl.userInputEnabled := false;
	tbl.selectMode := CM_EntryTable.SelectMode_FixedRow;
	tbl.selectionType  := CM_EntryTable.SelectionType_Row;
	tbl.fixedRows := 1;
	tbl.rows := 1;
	
	entTableDef := app.myController.getEntTableDef(ETDef_LlHeadings);
	if entTableDef &lt;&gt; null then
		tblCargo.setTblDataEntRowsFromXML(entTableDef, self.defTblCargo);	
	endif;
	
	if self.myWOJob &lt;&gt; null then 
		foreach ti in  self.myWOJob.allTrackedItems do			
			if tbl.rows &gt;= JadeTableRowLimit then
				app.msgBox('Maximum number of entries in table exceeded. Only the first ' &amp; 
						JadeTableRowLimit.String &amp; ' will be shown', 'Error', MsgBox_OK_Only);
				break;
			endif;
			dataLine := ti.getAttributeStringForDefArray(self.tblCargo.allTblDataEntRows);
			tbl.accessRow(tbl.addItem(dataLine)).itemObject := ti;
		endforeach;
	
	else
		if self.myTrackedItem &lt;&gt; null then // ### JIRA 12476 29OCT2024 NAVAB1
			dataLine := self.myTrackedItem.getAttributeStringForDefArray(self.tblCargo.allTblDataEntRows);
			tbl.accessRow(tbl.addItem(dataLine)).itemObject := self.myTrackedItem;
		endif;
	endif;	

epilog


end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a0f5c79d-f20c-4990-860f-0a56eb0b3dda">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	cnwndl1	Initial creation	CCMS MES 1006
05/04/2023	navcs2	Bug 57455: EUP - Todo Tasks Completed without adding Mandatory resources

*/

vars

	capString : String;
	ti : CM_TrackedItem;
	task : CM_ToDoTask;
	taskDesc : String;
	
begin

	inheritMethod();
	//
	// Null these so accelerator keys work for save and cancel
	//
	self.btnCancelBase.caption := '';
	self.btnSaveBase.caption := '';
	
	if app.getApplicationSkin &lt;&gt; null then		//15.07.2024  navbs1  CR 64901 Task 64903
		self.jdbTop.ignoreSkin	 	:= true;
		self.jdbBottom.ignoreSkin	:= true;
	endif;

	if self.myTransaction &lt;&gt; null then
		ti := self.myTransaction.myTrackedItem;
		if ti &lt;&gt; null then
			capString := ti.id;
		endif;
		task := self.myTransaction.myToDoTask;
		if task &lt;&gt; null and task.getMyToDoTaskDesc &lt;&gt; null then
			taskDesc := task.getMyToDoTaskDesc.description;
			if taskDesc &lt;&gt; null then
				if capString &lt;&gt; null then
					capString := capString &amp; " / ";
				endif;
				capString := capString &amp; taskDesc;
			endif;
		endif;
	 // ### TFS CR 54345 TASK 58281 16JUN2023 NAVAB1
	elseif self.myToDoTransaction &lt;&gt; null then
		capString := self.myToDoTransaction.getDescription();
	
	elseif self.myToDoTaskDesc &lt;&gt; null then
		capString := self.myToDoTaskDesc.description;
		if self.myTrackedItem &lt;&gt; null then
			capString := capString &amp; " " &amp; self.myTrackedItem .id;
		endif;
	endif;
	
	if capString = null then
		capString := app.getErrorString(Transaction);
	endif;
	
	if self.objectStr &lt;&gt; null then							//05/04/2023	navcs2	Bug 57455
		capString := capString &amp; " - " &amp; self.objectStr; 	//05/04/2023	navcs2	Bug 57455
	endif;													//05/04/2023	navcs2	Bug 57455
	
	capString := capString &amp; " - ";
	
	capString := capString &amp; app.getErrorString(Resource_usage);
	
	self.setCaption(capString);
	
	self.makePalletStuffVisible( null );	//13 Apr 2017 NDL TFS 3414
	
	self.modalResult := 1;
	self.clearGrpResource();				// ### TFS 58758 (60742) 12Dec2023 NAVPW1
	setTblCargo();							//15.07.2024  navbs1  CR 64901 Task 64903
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblCargo_contextMenu" id="744fa394-df1d-477d-8528-b6ac091c7da7">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCargo_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
