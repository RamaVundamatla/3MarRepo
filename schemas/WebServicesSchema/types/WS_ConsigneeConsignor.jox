<Class name="WS_ConsigneeConsignor" id="120c5ee3-ad01-487c-b366-9496f4aef05b">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Consignee, Consignor and Freight Forwarder code table</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="code" id="c433d0c9-f977-44a5-8a38-41ffceb3cb9d">
        <length>6</length>
        <embedded/>
        <type name="String"/>
        <text>5 character unique code</text>
    </PrimAttribute>
    <PrimAttribute name="comboboxDescription" id="546a5f72-4eca-4662-a3ab-9ee7077ce9f1">
        <type name="String"/>
        <access>readonly</access>
        <text>Concatenated code and description of the consignee/Consignor.</text>
    </PrimAttribute>
    <PrimAttribute name="description" id="6f86c3ff-588d-4581-8475-59b1df24747c">
        <type name="String"/>
        <text>Consignee/Consignor description</text>
    </PrimAttribute>
    <PrimAttribute name="isConsignee" id="9da2e0f2-9914-4724-a8c2-ec7ed2f2bebd">
        <embedded/>
        <type name="Boolean"/>
        <text>If the code is for a consignee,to decide whether the code is excluded or not from any Consignee combo boxes in Master Terminal. ex True/False</text>
    </PrimAttribute>
    <PrimAttribute name="isConsignor" id="3517a30f-e5c4-4f56-8bfb-fcfc68fffd7d">
        <embedded/>
        <type name="Boolean"/>
        <text>If the code is for a consignor,to decide whether the code is excluded or not from any Consignor combo boxes in Master Terminal. ex True/False</text>
    </PrimAttribute>
    <PrimAttribute name="isFreightForwarder" id="27526d69-c425-49d8-a213-608580d0cb80">
        <embedded/>
        <type name="Boolean"/>
        <text>If the code is for a freight forwarder,to decide whether the code is excluded or not from any freight forwarder combo boxes in Master Terminal. ex True/False</text>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="e9a577ba-eaff-4dae-ad3e-823216c35bac">
        <updating/>
        <source>setProxyFromObject(_object: CM_ConsigneeConsignor) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars

begin
	inheritMethod(_object);
	
	self.code := _object.code;
	self.description := _object.description;
	self.isConsignee := _object.isConsignee;
	self.isConsignor := _object.isConsignor;
	self.isFreightForwarder := _object.isFreightFwdr;
	//09/07/2009 cnwdz2 par 20233
	self.comboboxDescription := self.code &amp; " " &amp; self.description;

epilog

end;</source>
        <Parameter name="_object" type="CM_ConsigneeConsignor"/>
    </JadeMethod>
</Class>
