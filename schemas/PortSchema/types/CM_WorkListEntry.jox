/*

Purpose:			

Parameters:			

Return Value:		True if this wle is part of a Direct Release and Linked via future move

Date		Who		Reason
22 May 2019	jlgzm1	TFS 42840 MSL Direct Release between Voyages and Rail

*/

vars

begin

	if self.myFutureMoveDR &lt;&gt; null then
		return true;
	endif;
	if self.myFutureMove &lt;&gt; null then
		if self.myFutureMove.myWorkListEntryDR &lt;&gt; null then
			return true;
		endif;
	endif;
	return false;
	
epilog

end;</source>
