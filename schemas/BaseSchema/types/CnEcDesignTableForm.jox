    <JadeMethod name="mShowAllColumns_click" id="5ac0ee2c-3d1b-4fd7-b23e-9d5843d4c5bb">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mShowAllColumns_click(menuItem: MenuItem input) updating;

vars
	mi					: MenuItem;
	loopIndex			: Integer;
begin
	loopIndex := 2;
	mi := mShowColumn.getMenuItem(loopIndex);
	while mi &lt;&gt; null do
		mi.checked := true;
		transientTable.columnVisible[loopIndex] := true;
		loopIndex := loopIndex + 1;
		mi := mShowColumn.getMenuItem(loopIndex);
	endwhile;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mShowColumn_click" id="39390255-9c15-4189-8614-b173c9c9e27f">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mShowColumn_click(menuItem: MenuItem input) updating;

begin
	menuItem.checked := not menuItem.checked;
	transientTable.columnVisible[menuItem.index] := menuItem.checked; 
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mSortColumnAsc_click" id="46bdb53d-e64d-4ae1-89b5-3864ea2a56af">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mSortColumnAsc_click(menuItem: MenuItem input) updating;

begin
	transientTable.sortColumn[1] := transientTable.column;
	transientTable.sortAsc[1] := true;
	transientTable.sortColumn[2] := 0;
	transientTable.resort;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mSortColumnDesc_click" id="113ebdb2-8688-4c5a-a999-3e34fa46a537">
