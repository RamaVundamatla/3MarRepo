        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setHoldsInDrawingOrder" id="52d9563f-514c-4adb-adbe-22a3fea0e2b0">
        <source>setHoldsInDrawingOrder(_holds : CM_HoldArray input) protected;
// ---------------------------------------------------------------------------
// Created:     05 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theHoldsDict	: CM_HoldByOrdinalDict;
	tmpHoldsArray	: CM_HoldArray;
	numColumns,
	startHold,
	endHold,
	idx, 
	fwdHoldSize : Integer;
	aHold 	: CM_Hold;
begin

	theHoldsDict := self.allHolds;
	
	_holds.clear;
	
	if (not self.drawInReverse) then
		theHoldsDict.copy(_holds);
		return;
	endif;
	
	// =============================
	// drawing in reverse - that is
	//		3		2		1
	//		6		5		4
	//		9		8		7
	// =============================

	numColumns := self.getNumHoldColumns();
	
	create tmpHoldsArray transient;
	theHoldsDict.copy(tmpHoldsArray);
	
	startHold := 1;
	fwdHoldSize := theHoldsDict.size;
	
	endHold := numColumns;
	while true do : outerLoop
		foreach idx in startHold to endHold reversed do
			if idx &lt;= fwdHoldSize then
				aHold := tmpHoldsArray[idx];
				if aHold &lt;&gt; null then
					_holds.add(aHold);
				endif;
			endif;
		endforeach;
		startHold := endHold + 1;
		endHold := endHold + numColumns;
		
		if startHold &gt; fwdHoldSize then
			break outerLoop;
		endif;
	endwhile;

epilog
	delete tmpHoldsArray;

end;</source>
        <access>protected</access>
        <Parameter name="_holds" type="CM_HoldArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setIsBackend" id="d6edcab7-116f-4560-917e-f5113af128c6">
        <updating/>
        <source>setIsBackend(_bay : CM_Bay; _slotRequest : CM_SlotRequest) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		sets the attribute backend and returns the value
//
// ---------------------------------------------------------------------------
vars
	tmpIsBackend,
	iAMPrinting 		: Boolean;
	theDisplayMode, tmpShowColorOthers		: Integer;
	tmpSlotDefn			: CM_SlotDefn;
	tmpSlotController	: CM_SlotController;
	tmpTI				: CM_TrackedItem;
	fm					: CM_FutureMove;
begin
	iAMPrinting := self.amPrinting;
	tmpIsBackend := false;
	theDisplayMode := self.displayMode;
	tmpShowColorOthers := self.showColorOthers;

	// do not draw the backend unless we want it

	if theDisplayMode = ShpDisplayMode_ColCodeLoad then
		// if there is Load CC here for a 20 do not show the actual TIs back end
		if _slotRequest &lt;&gt; null then
			
			// PAR 21746 if _slotRequest.fortyBack 
			// PAR 16415 CCMS 1029
			// PAR 21746 or _slotRequest.isBackend then
			if _slotRequest.getAttrIsBackend() then // PAR 21746 
				tmpIsBackend := true;
			endif;
		elseif self.myTrackedItem &lt;&gt; null 
		and tmpShowColorOthers  = ShipShowOtherColor_Hatched then // PAR 8668 added to stop discharge backends showing in load CC
			//tmpIsBackend := (self.myTrackedItem.myPrimaryActualLocation &lt;&gt; self.myLocationsController);
			tmpIsBackend := self.myTrackedItem.isBackendForSHPDrawing( self.myLocationsController, false ); //17 Nov 2020	NDL	TFS 49891
		endif;

	elseif theDisplayMode = ShpDisplayMode_ColCodeDisch then
		if _slotRequest &lt;&gt; null then
			// PAR 21746 if _slotRequest.fortyBack 
			// PAR 16415 CCMS 1029
			// PAR 21746 or _slotRequest.isBackend then
			if _slotRequest.getAttrIsBackend() then // PAR 21746
				tmpIsBackend := true;
			endif;
		elseif self.myTrackedItem &lt;&gt; null then
			// PAR 9028 from here
			if self.amPrinting then
				if self.showColorOthers = ShipShowOtherColor_Other then
					tmpIsBackend := false;
				else
//					tmpIsBackend := true;
					//tmpIsBackend := (self.myTrackedItem.myPrimaryActualLocation &lt;&gt; self.myLocationsController);
					tmpIsBackend := self.myTrackedItem.isBackendForSHPDrawing( self.myLocationsController, false ); //17 Nov 2020	NDL	TFS 49891
				endif;
			else
			// PAR 9028 to here
				//tmpIsBackend := (self.myTrackedItem.myPrimaryActualLocation &lt;&gt; self.myLocationsController);
				tmpIsBackend := self.myTrackedItem.isBackendForSHPDrawing( self.myLocationsController, false ); //17 Nov 2020	NDL	TFS 49891
			endif;
		endif;

	elseif theDisplayMode = ShpDisplayMode_Actual 
	or theDisplayMode = ShpDisplayMode_VoyGlobActual then
		if self.myTrackedItem &lt;&gt; null and
		  // self.myTrackedItem.myPrimaryActualLocation &lt;&gt; self.myLocationsController then
		   self.myTrackedItem.isBackendForSHPDrawing( self.myLocationsController, false ) then //17 Nov 2020	NDL	TFS 49891
			tmpIsBackend := true;
		/* 17 Nov 2020	NDL	TFS 49891 - no longer want teh one in the OS collection
		else
			tmpTI :=  self.myLocationsController.allTrackedItemOSBackEnds.first;
			if tmpTI &lt;&gt; null then
				tmpIsBackend := true;
			endif;
		*/	
		endif;

	elseif theDisplayMode = ShpDisplayMode_Proposed 
	or theDisplayMode = ShpDisplayMode_VoyGlobProposed then
	//	tmpIsBackend := self.myLocationsController.CM_SlotController.isTIBackEndForProposed(self.myTrackedItem);
		//17 Nov 2020	NDL	TFS 49891
	//	if self.myTrackedItem &lt;&gt; null then
	//		tmpIsBackend := self.myTrackedItem.isBackendForSHPDrawing( self.myLocationsController, ( self.myTrackedItem.getFutureMoveForLC( PLANNING_MODE, self.myLocationsController ) &lt;&gt; null )   ); 
	//	endif;
		//11 Jan 2021	NDL	TFS 50611
		tmpIsBackend := self.myLocationsController.CM_SlotController.isTIBackEndForProposed(self.myTrackedItem);
		/*
		if self.myTrackedItem &lt;&gt; null and
		   self.myTrackedItem.myPrimaryPlannedLocation &lt;&gt; self.myLocationsController and
		   self.myTrackedItem.myPrimaryActualLocation &lt;&gt; self.myLocationsController then
			if _slotRequest &lt;&gt; null then
				tmpIsBackend := _slotRequest.fortyBack;
			else
				tmpIsBackend := true;
			endif;
		endif;
		*/
	elseif theDisplayMode = ShpDisplayMode_EDI then	// JC added 09/07/2004
		if self.myTrackedItem &lt;&gt; null
		and	(not self.myTrackedItem.allPlannedFutureMoves.isEmpty) then
			fm := self.myTrackedItem.allPlannedFutureMoves.first;
			if CM_FutureMovePlanned.hasInstance(fm)
			and (not fm.CM_FutureMovePlanned.allLocationsControllers.isEmpty) then
				if fm.CM_FutureMovePlanned.allLocationsControllers.first &lt;&gt; self.myLocationsController then
					tmpIsBackend := true;
				endif;
			endif;
		endif;
	
	endif;

	if iAMPrinting then
		if theDisplayMode = ShpDisplayMode_Proposed or 
		   theDisplayMode = ShpDisplayMode_Actual then
			if self.imexMode = SHP_VoyageAreaForm2.ImexMode_Exports and (not self.isExport) 
			or self.imexMode = SHP_VoyageAreaForm2.ImexMode_Imports and (not self.isImport) then // PAR 9029
				tmpIsBackend := false;
			endif;
		endif;
	
	endif;
	
	self.isBackend := tmpIsBackend;

	return tmpIsBackend;
end;</source>
        <access>protected</access>
        <Parameter name="_bay" type="CM_Bay"/>
        <Parameter name="_slotRequest" type="CM_SlotRequest"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
