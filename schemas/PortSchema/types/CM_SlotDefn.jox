    <JadeMethod name="setFortyAttributes" id="0c8d19f7-7704-4566-aac0-5dc471ea4404">
        <updating/>
        <source>setFortyAttributes(_value : Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	bayIndex, bayType : Integer;
	amForty : Boolean;
	tmpBay	: CM_Bay;

begin

	tmpBay := self.myBay;

	amForty := _value;
	// auto do the aft
	if (not amForty) and tmpBay.isAftBay then
		if self.myForwardSlot &lt;&gt; null then
			amForty := self.myForwardSlot.fortyFront;
		endif;
	endif;
	
	// AKB2003MAY changed this
	bayIndex := tmpBay.myHold.allBays.indexOf(tmpBay);
	bayType := tmpBay.bayType;
	// we use the forty front to set the fact that the user has drawn 40's on the GUI
	if amForty then
		if bayType = BAY_TYPE_SINGLE then
			if _value then
				// you cannot make a single bay a 40
				app.raiseCMException3(ERR_FORTYFOOT, self.getStowageId(false,true),tmpBay.id, "Bay " &amp; tmpBay.id &amp; " is a single bay.", null, null);
				return;
			endif;
			self.fortyFront := false;
			self.fortyBack := false;

		elseif bayIndex = 1 and (bayType = BAY_TYPE_TWIN or bayType = BAY_TYPE_TRIPLE) then
			self.fortyFront := true;
			self.fortyBack := false;

		elseif bayIndex = 2 and bayType = BAY_TYPE_TWIN then
			self.fortyFront := false;
			self.fortyBack := true;

		elseif bayIndex = 2 and bayType = BAY_TYPE_TRIPLE then
			self.fortyFront := true;
			self.fortyBack := true;

		elseif bayIndex = 3  then
			self.fortyFront := false;
			self.fortyBack := true;
		endif;	
	else
		self.fortyFront := false;
		self.fortyBack := false;
	endif;	

end;</source>
        <access>protected</access>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
