    <JadeMethod name="doSave" id="25707076-a56c-4549-9774-12ef5105bfdc">
        <updating/>
        <source>doSave(): Boolean updating;

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/6/2006	RBarr		CM_Port::codeDisplay attribute obsolete, portCode renamed to portCode
// ---------------------------------------------------------------------------

vars
	errObj					:CM_Error;
	idx						:Integer;
	tmpListBox				:ListBox;
	ignoreWarnings,rtnValue,
	isNotAvailableForEntry	:Boolean;
	proxyPort				:CM_Port;
	code,groupDescription,
	portCode,
	ccodePrint				:String;
	usLocation				: String;
	colour					: Integer;
	country					:CM_Country;
	portGroup				:CM_PortGroup;	
	theForm 				: SOP_TableMaintForm;
	changeCodeReturn		: Integer;		//	cnwvu1	27/10/2006	PAR12482
	countryProxy			: CM_Country;	//	cnwvu1	27/10/2006	PAR12482
	countryCode,
	codeProxy,
	countryCodeProxy		: String;		//	cnwvu1	27/10/2006	PAR12482 
	bIsPort, bIsRoad, 
	bIsRail, bIsAirport, 
	bIsFixed, bIsMulti, 
	bIsBorder, bIsPostal	: Boolean;
begin
    theForm := self.myForm; 
	code := theForm.tblInput1.getValueByName(ETRow_Code).String;
	portCode := theForm.tblInput1.getValueByName(ETRow_PortCode).String;
	
	groupDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;
	ccodePrint := theForm.tblInput1.getValueByName(ETRow_CcodePrint).String;
	colour := theForm.tblInput1.getValueByName(ETRow_Colour).Integer;		
	portGroup := theForm.cmbPortGroup.myObject.CM_PortGroup;
    country := theForm.cmbCountry.myObject.CM_Country;
	if country = null then	// Par13703
//		app.raiseCMException1(REQUIRED_FIELD, 'Country' , null, null);
		app.raiseCMException(Input_required_field_country , null, null); // cnwdb2	PAR 35364
		return false;
	endif;
	
    isNotAvailableForEntry := theForm.tblInput1.getValueByName(ETRow_NotAvailableForEntry).Boolean;	
    bIsPort := theForm.tblInput1.getValueByName(ETRow_IsPort).Boolean;	
    bIsRoad := theForm.tblInput1.getValueByName(ETRow_IsRoad).Boolean;	
    bIsRail := theForm.tblInput1.getValueByName(ETRow_IsRail).Boolean;	
    bIsAirport := theForm.tblInput1.getValueByName(ETRow_IsAirport).Boolean;	
    bIsFixed := theForm.tblInput1.getValueByName(ETRow_IsFixedTransport).Boolean;	
    bIsMulti := theForm.tblInput1.getValueByName(ETRow_IsMultiModal).Boolean;	
    bIsBorder := theForm.tblInput1.getValueByName(ETRow_IsBorderCrossing).Boolean;	
    bIsPostal := theForm.tblInput1.getValueByName(ETRow_IsPostalExchange).Boolean;			   
	
	usLocation := theForm.tblInput1.getValueByName(ETRow_UsLocationCode).String;			   

    
	
//	cnwvu1	27/10/2006	PAR12482
	if theForm.mode = theForm.Mode_Update then
		countryCode		:= country.code;
		codeProxy		:= theForm.myProxyObject.CM_Port.code;
		countryProxy	:= theForm.myProxyObject.CM_Port.myCountry.CM_Country;
		if countryProxy &lt;&gt; null then	// Par13703 - when country = null for a port - remnant from previous versions
			countryCodeProxy:= countryProxy.code;
		endif;
		if ( codeProxy &lt;&gt; code ) or (countryCodeProxy &lt;&gt; countryCode) then
			changeCodeReturn := app.msgBox( 'This will NOT update all occurances of this port code in the system. You may want to consider flagging this code as "Not Available for Entry" and adding a new port code. Select OK to continue with the update.', 
											'You have changed either the port or country code', 
											MsgBox_OK_Cancel + MsgBox_Information_Icon);
			if changeCodeReturn = MsgBox_Return_Cancel then 
				return false;
			endif;	
		endif;
	endif;

	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_Port transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyPort := theForm.myProxyObject.CM_Port;
	proxyPort.setProxy(code, portCode, groupDescription,ccodePrint,colour,country,portGroup,usLocation, isNotAvailableForEntry, 
						bIsPort, bIsRail, bIsRoad, bIsAirport, bIsPostal, bIsMulti, bIsFixed, bIsBorder);

	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreatePort(proxyPort, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdatePort(proxyPort,app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;

	return app.myPassport.trxCompletedOK;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
