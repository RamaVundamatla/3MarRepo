        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateCharges" id="bc18a244-9145-4543-92e3-54dd1f1528a7">
        <source>updateCharges( debtorNode : CM_DebtorNode );
/*
Purpose:	SEE SIMILAR ON CM_RATE		

Date			Who		Reason
14AUG2024		NAVAB1	ADO - BUG 64886
23 Oct 2024		navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	iter	: Iterator;
	status	: Integer;
	serv	: CM_Service;
	charge	: CM_Charge;
	charges : CM_ChargeByInvStatusSeqNumDict;
	invoices : CM_InvoiceSet;
	inv : CM_Invoice;
	invLine : CM_InvoiceLine;
	canLogExtra			: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141

	if self.myService = null then
		return;
	endif;
	
	create invoices transient;
	create charges transient;
	
	
	foreach invLine in self.myInvoiceContractDetail.allInvoiceLines discreteLock do
		inv := invLine.invoice;
		if inv = null then
			continue;
		endif;
		
		if not inv.status.isOneOf(CM_Invoice.INVOICE_OPEN,CM_Invoice.INVOICE_PENDING, CM_Invoice.INVOICE_SUSPENSE, CM_Invoice.INVOICE_PREPEND ) then
			continue;
		endif;
		
		foreach charge in invLine.charges discreteLock do
			if charge.service = self.myService then
				charges.add(charge);
			endif;
		
		endforeach;
	
	endforeach;
	
	
	foreach charge in charges discreteLock do
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; "CONT Calling CM_Charge.evaluateRate", LogINFO.String); 
		endif;
		charge.evaluateRate();
		
		inv := charge.getInvoice();
		if invoices.tryAddIfNotNull(inv) then
			reserveLock(inv);
		endif;
	
	endforeach;

	foreach inv in invoices do
		inv.setAmountDetailsToNull();
		inv.setTaxDetailsToNull();
		foreach invLine in inv.invoiceLines discreteLock do
			invLine.setTotalAmount();
			invLine.setTaxDetails();
		endforeach;
	endforeach;
epilog
	delete invoices;

	delete iter;
	delete charges;
end;</source>
        <Parameter name="debtorNode" type="CM_DebtorNode"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="e6229708-1926-41e5-aef9-e4e5ec817bbd">
        <source>validateForCreate();
/*
Purpose:			

Date		Who		Reason
08 December 2022	navab1	TFS CR 55623 TASK 55675
*/

vars
	rate : CM_InvoiceContractRate;
	invLineType : CM_InvoiceLineDesc;
begin
	if self.myService = null then
		app.raiseCMException(Contra_rate_must_have_servic,null,null);
	endif;
	
	if self.myInvoiceContractDetail = null then
		app.raiseCMException(Contr_rate_must_have_contr_det,null,null);
	elseif self.myService &lt;&gt; null then
		invLineType := self.myInvoiceContractDetail.myInvoiceLineType;
		if invLineType &lt;&gt; null then
			if not invLineType.services.includes(self.myService) then
				app.raiseCMException2(Servi_not_confi_contr_detai_in,self.myService.name,invLineType.narration, null ,null); // ### TFS BUG 56879 02MAR2023 NAVAB1, did not have the 2 parameters
			
			endif;
		
		endif;
		
		rate := self.myInvoiceContractDetail.allInvContractRatesByService[self.myService]; // ### TFS CR 55644 TASK 55684 16JAN2023 NAVAB1 - new collection for finding correct rate
		if rate &lt;&gt; null then 
			app.raiseCMException1(Rate_alrea_exist_with_servi_cu,self.myService.name,null,null);
		
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
