    <JadeMethod name="createSnapshotData" id="9a02ea57-18aa-4aef-b287-ff567ffe41dc">
        <source>createSnapshotData(_definition : CM_OutputFormat_SS) : CM_SnapshotData;
// copy of BGP_SummarySnapshot::action + getCollection with just the data creation, no file creation or invoicing
//	return the data
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support

vars 
	
	userQuery 		: CM_MenuUserQuery;
	queryAgent 		: CM_QueryAgentFilter;
	qDef 			: CM_QueryDefinition;
	enqController	: CM_EnquiryController;
	criteriaHolder	: CM_QueryCriteriaLineHolder;
	collection 		: Collection;
	snapshotData 	: CM_SnapshotData;
	terminal		: CM_Terminal;
	user			: CM_User;
	ts				: TimeStamp;

begin
	
	terminal := self.getTerminal();
	user := app.getMyUser();

	//get a collection of data based on the selector query
	create collection as CM_TISet transient;
	userQuery := _definition.mySelectorQuery;
	queryAgent := app.myQAFilter;
	
	qDef := app.myRoot.allQueryDefinitionObjects[userQuery.getType, userQuery.queryMode];
	queryAgent.createEnqControllerForMode(userQuery.queryMode, userQuery.getType, enqController);
	delete enqController.allObjects;
	create enqController.allObjects as CM_TISet transient;
	
	foreach criteriaHolder in userQuery.allCriteriaLineHolders do
		enqController.myCriteriaLineHolder := criteriaHolder;
		enqController.doQuery(qDef);
	endforeach;
	
	ts := app.actualTimeServer;	// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	
	enqController.allObjects.copy(collection);	
	
	if not collection.isEmpty then
		// build the snapshotdata from the collection and the OutputFormat
		snapshotData := _definition.generateSnapshotDataFromColl(collection, null, ts, terminal, user);
	endif;
		
	return snapshotData;
epilog
	if enqController &lt;&gt; null then
		delete enqController.allObjects;
	endif;
	delete enqController;
	delete collection;
end;</source>
        <Parameter name="_definition" type="CM_OutputFormat_SS"/>
        <ReturnType type="CM_SnapshotData"/>
    </JadeMethod>
    <JadeMethod name="createStorageConfig" id="51ea600c-2613-4d48-9ad1-36f7b8f0a481">
        <source>createStorageConfig(_criteria : CM_YACriteriaTypeArray; _triggers : CM_StorageTriggerByType; _deriveDebtorFrom : CM_DebtorType; _firstDayTimeCutoff : Time; _includeFirstDay : Boolean; _includeLastDay : Boolean; _lastDayTimeCutoff : Time; 
					_shipReceivalType : Integer; _shipReleaseType : Integer; _calendar : CM_Calendar; _compulsory : CM_Calendar; _roadReceivalType : Integer; _railReceivalType : Integer; _unpackReceivalType : Integer) : CM_StorageConfig;
// CCMS 1295
vars
	proxy		: CM_StorageConfig;
	realConfig	: CM_StorageConfig;
	terminal	: CM_Terminal;
begin
	create proxy transient;
	terminal := self.getTerminal();
	proxy.setProxy(_criteria, _triggers, _firstDayTimeCutoff, _includeFirstDay, _includeLastDay, terminal, _shipReceivalType, _shipReleaseType, _calendar, _compulsory, _roadReceivalType, _railReceivalType, _unpackReceivalType);

	app.myTrxCA.trxCreateStorageConfig(proxy, realConfig,null,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return realConfig;

epilog
	delete proxy;
end;
</source>
