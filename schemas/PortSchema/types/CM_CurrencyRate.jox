    <JadeMethod name="getAuditText" id="0c0ed7d3-da3f-4f06-9f99-9b24267f9cc8">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2018	jlgndl1	Initial creation	TFS 37550

*/

vars
	txt,
	tmpStr,str	: String;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
	tmpStr := null;
	str    :=null;
	if self.myCurrencyType &lt;&gt; null then
		tmpStr:=self.myCurrencyType.auditIdDisplay;
		txt := txt &amp; app.getErrorString(Currency_type) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	str    :=null;
	if self.effectiveDT &lt;&gt; null then
		tmpStr:=self.effectiveDT.asStringJMT;
		txt := txt &amp; app.getErrorString(Code) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	return txt;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="b975753b-430b-4267-bafc-cc8d7dcb0c85">
        <source>getDisplayDetails(_short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2018	jlgndl1	Initial creation	TFS 37550

*/

vars

begin
	if _short then
		return self.rate.asStringJMT &amp; " " &amp; self.effectiveDT.asStringJMT;
	else
		return self.myCurrencyType.getDisplayDetails(true) &amp; " "  &amp; self.rate.asStringJMT &amp; " " &amp; self.effectiveDT.asStringJMT;
	endif;

epilog

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
