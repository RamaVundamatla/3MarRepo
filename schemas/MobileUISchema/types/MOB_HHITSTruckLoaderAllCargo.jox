    <JadeMethod name="doInterTerminalCheck" id="a9ad99aa-a48a-453f-8683-5c2445844245">
        <source>doInterTerminalCheck( ti : CM_TrackedItem ) : Boolean;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 February 2010	cnwndl1	Initial creation

*/

vars
	errorMess : String;
begin

	// called during save process... from "clickInYardItem".
	
	if ti &lt;&gt; null then
		if not ti.allBulkReleasesAssigned.includesInterTerminalRelease then
			// not valid container to be released by inter terminal 
			errorMess := app.getErrorString1(Not_Part_inter_term_release, ti.id);
			self.msgBox(errorMess ,app.getErrorString(Error), MsgBox_OK_Only, true);
			return false;
		endif;
	endif;
	
	return true;
	

epilog

end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="963991d9-07de-40ab-8374-3a837480f9ff">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	top : Real;
	width : Real;
	left : Real;
	height : Real;
	halfWidth : Real;

begin

	self.setResizeableMarginAndFontSize();
	inheritMethod(_initialSetup);

						
	top := 1;
	width := self.frmCargoInYard.width - (self.resizedMargin * 3);
	halfWidth := ( width  - 4 ) / 2;
	left := 1;
	height := self.getStdControlHeight;
	
	if _initialSetup then
		self.txtCargoId.visible := true;
	endif;
	self.txtCargoId.move(	left,
							top,
							width,
							height );
							
	
	top := top + txtCargoId.height + self.resizedMargin;
	if _initialSetup then
		self.lblOperator.visible := true;
	endif;
	self.lblOperator.move(	left,
							top,
							halfWidth,
							height );
							
	if _initialSetup then
		self.lblCargoType.visible := true;
	endif;
	self.lblCargoType.move(	left + halfWidth + self.resizedMargin,
							top,
							halfWidth,
							height );
							
	top := top + lblOperator.height + self.resizedMargin;
	if _initialSetup then
		self.cmbTargetTerm.visible := true;
	endif;
	self.cmbTargetTerm.move(	left,
								top,
								width,
								height );
							
	top := top + cmbTargetTerm.height + ( self.resizedMargin * 3) ;
	left := ( width - btnOne.width ) / 2;
	if _initialSetup then
		self.btnLoad.visible := true;
	endif;
	self.btnLoad.move(	left,
						top,
						btnOne.width,
						btnOne.height );
						
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
