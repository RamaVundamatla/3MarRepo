    <JadeMethod name="trxCreateCompanyCustDocuments" id="0f9bc7d6-b035-4bdb-ab1a-26ffe2fd052b">
        <updating/>
        <source>trxCreateCompanyCustDocuments(_cmifAgent : CMIF_CompanyCustDocAgent input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/10/2023	navkc1	CR 60422 Task 60917: JADE - Group Selected TIs by Transport

*/

vars
	cmifCompanyCustDocDetail : CMIF_CompanyCustDocDetail;
	cgti : CM_CargoGroup;
	pxyCustDoc,
	realCustDoc	: CM_CustomDocument;
	cmifCustDocDetail : CMIF_CustomDocumentDetail;
	allCMIFs,
	allPxyCustDocs, allPxyDetails: ObjectArray;
	subTI, ti		: CM_TrackedItem;
	totalWeight,
	totalVolume : Decimal[14,4];
	idx,
	totalQuantity : Integer;
	realSubDetail, realDetail, subPxyDetail, pxyDetail, cdd : CM_CustomDocumentDetail;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	
	create allPxyCustDocs transient;
	create allCMIFs transient;
	create allPxyDetails transient;
	
	// Each cmifCompanyCustDocDetails is an individual Custom Document
	foreach cmifCompanyCustDocDetail in _cmifAgent.allCompanyCustDocDetails do
		create pxyCustDoc transient;
		create cmifCustDocDetail transient;
		allPxyCustDocs.add(pxyCustDoc);
		allCMIFs.add(cmifCustDocDetail);
		
		// Code will be auto generated at the end of the TRX, use tempCode for now
		pxyCustDoc.setProxy(_cmifAgent.myTerminal, "tempCode", _cmifAgent.description, _cmifAgent.externalRef, null, _cmifAgent.remarks, _cmifAgent.startTS, null, null, 
							_cmifAgent.direction, _cmifAgent.lineNumber, _cmifAgent.myCustomDocumentType, _cmifAgent.myCustomLicense, _cmifAgent.myCustomDocAgent, _cmifAgent.myHSCode, _cmifAgent.docSequence);
		
		// Now we go through each TI, it is an individual Custom Document Detail
		foreach ti in cmifCompanyCustDocDetail.allTIs do
			create pxyDetail transient;
			allPxyDetails.add(pxyDetail);
			totalWeight := ti.totalWeight;
			totalVolume := ti.totalVolume;
			totalQuantity := ti.totalQuantity;
			
			if ti.getCustDocIsPartiallyCleared() then
				cdd := ti.allCustomDocDetails.getLastActive(); // ### TFS CR 60425 TASK 60828 14NOV2023 NAVAB1
				if cdd &lt;&gt; null and cdd.clearedQuantity &lt; ti.totalQuantity then 
					totalWeight := ti.totalWeight - cdd.clearedWeight;
					totalVolume := ti.totalVolume - cdd.clearedVolume;
					totalQuantity := ti.totalQuantity - cdd.clearedQuantity;
				endif;
			endif;
			
			pxyDetail.setProxy(totalQuantity, totalWeight, totalVolume, true, ti, pxyCustDoc, null);
			cmifCustDocDetail.allProxyCustDocDetails.add(pxyDetail);	
			pxyCustDoc.allTrackedItems.addNoDuplicates(ti, false);
			
			if ti.isCargoGroupItem then
				cgti := ti.CM_CargoGroup;
				foreach subTI in cgti.allAssignedTrackedItems discreteLock do
					create subPxyDetail transient;
					allPxyDetails.add(subPxyDetail);
					totalWeight := subTI.totalWeight;
					totalVolume := subTI.totalVolume;
					totalQuantity := subTI.totalQuantity;
					
					subPxyDetail.setProxy(totalQuantity,totalWeight,totalVolume,true,subTI,null,pxyDetail);			
					cmifCustDocDetail.allSubProxyCustDocDetails.add(subPxyDetail);
					pxyCustDoc.allTrackedItems.addNoDuplicates(subTI, false);
				endforeach;
			endif;
		endforeach;	
		
		cmifCustDocDetail.validateForCreateCustDocTypSeq(pxyCustDoc);
	endforeach;
	
	// Validate the CMIF details
	foreach cmifCustDocDetail in allCMIFs as CMIF_CustomDocumentDetail do
		idx += 1;
		cmifCustDocDetail.validateForCreateCustDocTypSeq(allPxyCustDocs[idx].CM_CustomDocument);
	endforeach;
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;
	
	// Now do create actual Custom Document and Custom Document Details
	idx := null;
	foreach pxyCustDoc in allPxyCustDocs as CM_CustomDocument do
		
		idx += 1;
		// This is Custom Document
		app.myUtilityCA.utlCreateCustDocHeader(pxyCustDoc, realCustDoc, _passport);
		
		if not self.checkValidationWithPassport(_passport) then
			return;
		endif;
		
		// This is Custom Document Detail
		cmifCustDocDetail := allCMIFs[idx].CMIF_CustomDocumentDetail;
		
		foreach pxyDetail in cmifCustDocDetail.allProxyCustDocDetails do
			// Now that we have Custom Document created, set proxies to point to the real one
			pxyDetail.setMyCustomDocument(realCustDoc);
			app.myUtilityCA.utlCreateCustDocDetail(pxyDetail, realDetail, _passport);
			if (not self.checkValidationWithPassport(_passport)) then
				return;
			endif;
			
			cmifCustDocDetail.allRealCustDocDetails.add(realDetail);
			
			// Now that we have Custom Document Details created, set the sub details proxies to point to the real one
			foreach subPxyDetail in pxyDetail.allSubDetails do
				subPxyDetail.setProxyParentDetail(realDetail);
				app.myUtilityCA.utlCreateCustDocDetail(subPxyDetail, realSubDetail, _passport);
				if (not self.checkValidationWithPassport(_passport)) then
					return;
				endif;
				cmifCustDocDetail.allRealCustDocDetails.add(realSubDetail);
			endforeach;
		endforeach;
		
		cmifCustDocDetail.validateTIs();
		if (not self.checkValidationWithPassport(_passport)) then
			return;
		endif;
		
		realCustDoc.handleStops(null);
		if (not self.checkValidationWithPassport(_passport)) then
			return;
		endif;
		
		realCustDoc.createTransactionForTI(TRANS_TYPE_CUSTDOCADDED);
		
		// Add newly create custom document to CMIF so we can use them
		_cmifAgent.allNewCustDocsCreated.add(realCustDoc);
	endforeach;
	
epilog
	allPxyCustDocs.purge();
	allCMIFs.purge();
	allPxyDetails.purge();
	delete allPxyCustDocs;
	delete allCMIFs;
	delete allPxyDetails;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_cmifAgent" type="CMIF_CompanyCustDocAgent" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
