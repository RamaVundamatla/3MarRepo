    <JadeMethod name="translateForm" id="eee2a5b8-decb-4e56-83d5-13145ca44674">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 18 July 2024 12:15:21.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026886, locale);
	btnAudits.translateCaption(Xlat_0026887, locale);
	btnCancel.translateCaption(Xlat_0026888, locale);
	btnDelete.translateCaption(Xlat_0026889, locale);
	btnEmail.translateCaption(Xlat_0026925, locale);
	btnSave.translateCaption(Xlat_0026890, locale);
	chkDoAutoComp.translateCaption(Xlat_0026926, locale);
	grpRetro.translateCaption(Xlat_0026891, locale);
	lblDischargeLC.translateCaption(Xlat_0026892, locale);
	lblEmail.translateCaption(Xlat_0026927, locale);
	lblMinOffset.translateCaption(Xlat_0026893, locale);
	lblVoyageDateType.translateCaption(Xlat_0026894, locale);
	lblVoyageStatus.translateCaption(Xlat_0026920, locale);
	msgCompFields.translateCaption(Xlat_0026928, locale);
	shtClosure.translateCaption(Xlat_0026895, locale);
	shtComparison.translateCaption(Xlat_0026896, locale);
	shtMovements.translateCaption(Xlat_0026897, locale);
end;</source>
    </JadeMethod>
