    <JadeMethod name="isWeightWithinRange" id="6ae2367d-af0e-4a65-b25b-f19391fd55b5">
        <source>isWeightWithinRange(_weight:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		30 July 2010 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the specified weight
//				falls within the receiver's range.
//
// Parameters:	_weight - The weight to test.
//
// Returns:		True if the weight is within range, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 30/07/2010	cnwdad1		PAR #24045. Original implementation.
// --------------------------------------------------------------------------------
begin
	return (_weight &gt;= self.lower and _weight &lt;= self.upper);
end;</source>
        <Parameter name="_weight" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lowerOld" id="71b586b6-3465-44d9-8897-3e54fa978b19">
        <source>lowerOld();

begin
/*lowerOld(set: Boolean; _value: Integer io) mapping;
// --------------------------------------------------------------------------------
// Created:		09 March 2005 by cnwdad1:2
//
// Purpose:		Mapping method for the virtual attribute. This method will fetch the
//				value of the previous instance, to represent the lower range of the
//				receiver.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	weightRangeObj	: CM_WeightRange;
	iteratorObj		: Iterator;
	
begin
	iteratorObj	:=	self.myRoot.allWeightRanges.createIterator();
	
	iteratorObj.startAtObject(self);
	iteratorObj.back(weightRangeObj);
	
	if iteratorObj.back(weightRangeObj) then
		_value	:=	weightRangeObj.upper;
	else
		_value	:=	0;
	endif;
epilog
	delete iteratorObj;*/
end;</source>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="fc162cee-ec4d-4cbd-9117-77c5a8f90ec4">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     09 February 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxyWeightRange:CM_WeightRange;
	completedOK		: Boolean;
	
begin

	proxyWeightRange := inheritMethod();
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyWeightRange;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyWeightRange;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
