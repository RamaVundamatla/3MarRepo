//	app.setContinueCMExceptions(false);
//	app.myTrxUA.trxSetEDIDataStatus(self, CM_EDIFile.EDI_STATUS_LOADING);
	
	// Gather up the data to be maintained, onto the CMIF parameter object.
	
//	create cmifConsist transient;
