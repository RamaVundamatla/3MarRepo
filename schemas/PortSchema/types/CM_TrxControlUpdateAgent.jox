    <JadeMethod name="trxUpdateBookingBulkRel" id="5726455d-6827-4fc5-b04e-d5233b1d1f50">
        <updating/>
        <source>trxUpdateBookingBulkRel(_pxyBooking : CM_BookingRef input; 
						_passport 	: CM_Passport input) updating;
/*
Date		Who		Reason
18 Nov 2008	cnwer1	Initial creation
28 Sep 2008	consw1	SFW1035 - Handle deletion of associated Release
20 Feb 2012	cnwcs5	pat 28756 - changed to use utlUpdateBulkRelase instead of utlUpdateBulkReleaseNew
28 Jun 2012	cnwcs5	par 29847 - pass booking in _realBooking parameter for utlUpdateBulkRelease
29 Jul 2013	cnwcs5	CCMS POL 2221 / par 32094 - signature change
20 Jul 2023	navdap1	TFS 58923 EUP CallOff EDI Data Type / Data Load
28 May 2024	navdap1	TFS 64315 CUX - System Lock when creating bookings and prenotes via Booking and Cargo APIs
21 Jan 2026 navbk1  MTN 36097 MTN | Deferred update required on trxUpdateBookingBulkRel
*/

vars
	pxyRelease, release : CM_BulkRelease;
	booking				: CM_BookingRef;
	edition 			: Integer;
	proxyColl			: CM_ObjectArrayActual;
	proxy 				: CM_Object;
begin
// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	create proxyColl transient;
	
	_passport.useTIDictDeferUpdate 		  := true;										//21.01.26 navbk1 #36097						
	_passport.useTITransactionDeferUpdate := true;										//21.01.26 navbk1 #36097	
	
	beginTransaction;


	// TFS 64315 lock everything up front
	if app.myPassport.myTerminal &lt;&gt; null then
		self.exclusiveLock(app.myPassport.myTerminal.allBookingRefsByOperatorRef);
		self.exclusiveLock(app.myPassport.myTerminal.allBookingRefsByRef);
	endif;
	if _pxyBooking.myVoyage &lt;&gt; null then
		self.exclusiveLock(_pxyBooking.myVoyage.allBookingRefs);
	endif;
	// TFS 64315 end
	
	app.myUtilityUA.utlUpdateBookingRef(_pxyBooking, _passport, proxyColl);
	
	_pxyBooking.pxyGetRealObjectAndEdition(booking, edition);
	
	pxyRelease:=_pxyBooking.allReleaseRequests.first.CM_BulkRelease;
	
	if _passport.noErrors() then
	
		if pxyRelease = null then
			release := booking.allReleaseRequests.first.CM_BulkRelease;
			
			if release &lt;&gt; null then
				app.myUtilityDA.utlDeleteBulkRelease(release, _passport);
			endif;
		else
			pxyRelease.pxyGetRealObjectAndEdition(release, edition);
			
			if release = null then
				app.myUtilityCA.utlCreateBulkRelease(pxyRelease, release,  booking, null, null, null, _passport);	// TFS 58923
			else
				app.myUtilityUA.utlUpdateBulkRelease(pxyRelease, booking, true, null, null, _passport);				// TFS 58923
			endif;
		endif;
		_passport.doDeferredUpdates();																				//21.01.26 navbk1 #36097	
	endif;

epilog
	//these proxies have not been committed yet so if there was an exception then need to remove proxy link
	if proxyColl &lt;&gt; null then
		foreach proxy in proxyColl do
			app.myProxyManager.deleteProxyLink(proxy);
		endforeach;
		
		delete proxyColl;
	endif;
	
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyBooking" type="CM_BookingRef" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateBookingRefMulti" id="ebfd8a2e-ee3e-4d12-b2fa-751dfaf9bc16">
        <updating/>
        <source>trxUpdateBookingRefMulti(_cmifBookingRef : CMIF_BookingRef input; _passport : CM_Passport input; pUserObject : Object) updating;
/*
	Created on 13 February 2008
	
	by Debby Hutchison
	
	Purpose:
	
Changed On	By			Reason
----------	--------	--------------------------------------------------
28/05/2024	navdap1		TFS 64315 CUX - System Lock when creating bookings and prenotes via Booking and Cargo APIs

*/

vars
	//realBookingRef	: CM_BookingRef;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	beginTransaction;
	
	// TFS 64315 lock everything up front
	if app.myPassport.myTerminal &lt;&gt; null then
		self.exclusiveLock(app.myPassport.myTerminal.allBookingRefsByOperatorRef);
		self.exclusiveLock(app.myPassport.myTerminal.allBookingRefsByRef);
	endif;
	if _cmifBookingRef.myProxyBookingRef &lt;&gt; null and _cmifBookingRef.myProxyBookingRef.myVoyage &lt;&gt; null then
		self.exclusiveLock(_cmifBookingRef.myProxyBookingRef.myVoyage.allBookingRefs);
	endif;
	// TFS 64315 end
	
	app.myUtilityUA.utlUpdateBookingRefMulti(_cmifBookingRef, _passport, pUserObject/*realBookingRef*/);	//Par18495. pUserObject should be passed as a parameter for following validation

epilog	
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_cmifBookingRef" type="CMIF_BookingRef" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
