    <JadeMethod name="wagonIsForNullTrain" id="6adb5cd0-6759-4ef7-8ab9-5671e58be473">
        <source>wagonIsForNullTrain(_wagon: CM_Wagon): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2010	cnwndl1	Initial creation

*/

vars

	train : CM_Train;
	
begin

	train := _wagon.myTrainOutwards;
	
	if train &lt;&gt; null then
		return train.isNullTrain;
	endif;
	
	return false;
	
epilog

end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
