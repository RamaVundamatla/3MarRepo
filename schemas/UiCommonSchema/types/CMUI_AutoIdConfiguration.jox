    <JadeMethod name="doOK" id="e1d57f2e-4bd2-409c-a375-7eb8b9f25647">
        <updating/>
        <source>doOK() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2010	cnwndl1	Initial creation	CCMS MES 1004
24 June 2022  navsrk20 ChangeRequest 53898: EUP - VBS MTN - [2] - External Reference Code Generation
01 September 2022 navmv20 ChangeRequest 54610: MTN - Auto Cargo Id New Options
04/01/2023	navkc1	TFS CR 55300 TASK 55525 UI - Business Unit Maint changes  for auto id
09/02/2023	navkc1	Bug 56444: Jade - Country in Invoice/Credit note Auto Id
23 Feb 2023	navak20 Defect 56701: Warning message need to change 2 and 4
29/08/2023	navkc1	CR 59556  Task 59557: Jade - CustDocs Auto Id
10/09/2024	jlizm1	TFS 65953 NSW Dynamics Integration - Auto Generate ID
*/

vars

	style : Integer;
	proxy : CM_AutoIdGenerator;
	nextSequenceNum : Real;
	result : Integer;
	seqYear : Integer;
	tmpDate : Date;
	resetSeqOn : Integer;
	prefixText : String; //1 Sept 2022 navmv20 TFS 54610
	seqLength : Integer;
	country : String; // 09/02/2023	navkc1	Bug 56444
begin

	if cmbStyle.listIndex &lt; 1 then
		app.msgBox( app.getErrorString(INV_Please_Select_A) &amp; " " &amp; lblStyle.caption ,app.getErrorString(Warning) , MsgBox_OK_Only + MsgBox_Stop_Icon);
		cmbStyle.setFocus();
		return;
	endif;
	
	style := cmbStyle.itemData[cmbStyle.listIndex];
	
	if self.typeToCreate = CM_AutoInvoiceExtNumberGen or
		self.typeToCreate = CM_AutoCreditExtNumberGen or
		self.typeToCreate = CM_AutoIdCrdInvExtNumberGen then
		if style = AutoIdStyle_P_SSS then
			prefixText := txtPrefix.text.trimBlanks;
		else
			prefixText := txtCategoryPrefix.text.trimBlanks();
		endif;
	else
		prefixText := txtPrefix.text.trimBlanks; //1 Sept 2022 navmv20 TFS 54610
	endif;
	
	seqLength := txtSeqLength.text.Integer;
	
	//if txtSeqLength.text.Integer &lt; 3 or txtSeqLength.text.Integer &gt; 20 then //15/09/2022 navmv20 54610
		//app.msgBox( app.getErrorString2(Enter_value_between, "3", "20") &amp; " " &amp; lblNumLength.caption ,app.getErrorString(Warning) , MsgBox_OK_Only + MsgBox_Stop_Icon); //15/09/2022 navmv20 54610
	if txtSeqLength.text.Integer &lt; 2 or txtSeqLength.text.Integer &gt; 20 then //15/09/2022 navmv20 54610
		app.msgBox( app.getErrorString2(Enter_value_between, "2", "20") &amp; " " &amp; lblNumLength.caption ,app.getErrorString(Warning) , MsgBox_OK_Only + MsgBox_Stop_Icon); //15/09/2022 navmv20 54610
		txtSeqLength.setFocus();
		return;
	endif;
	
	//23 June 2022	navmv20 TFS 53898 - START
	//if self.txtExtRefSeqLength.text &lt;&gt; null and self.txtExtRefSeqLength.text.Integer &lt; 2 or self.txtExtRefSeqLength.text.Integer &gt; 20 then	// 23.02.2023 navak20 TFS 56701
	if self.txtExtRefSeqLength.text &lt;&gt; null and self.txtExtRefSeqLength.text.Integer &lt; 2 or self.txtExtRefSeqLength.text.Integer &gt; 4 then		// 23.02.2023 navak20 TFS 56701
		//app.msgBox( app.getErrorString2(Enter_value_between, "2", "20") &amp; " " &amp; self.lblExtRefSeqLength.caption ,app.getErrorString(Warning) , MsgBox_OK_Only + MsgBox_Stop_Icon);	// 23.02.2023 navak20 TFS 56701
		app.msgBox( app.getErrorString2(Enter_value_between, "2", "4") &amp; " " &amp; self.lblExtRefSeqLength.caption ,app.getErrorString(Warning) , MsgBox_OK_Only + MsgBox_Stop_Icon);	// 23.02.2023 navak20 TFS 56701
		self.txtExtRefSeqLength.setFocus();
		return;
	endif;
	//23 June 2022	navmv20 TFS 53898 - END
	
	//23 Jan 2019	NDL TFS 43018
	if self.cmbReset.listIndex &gt; 0 then
		resetSeqOn := self.cmbReset.itemData[ self.cmbReset.listIndex ];
	endif;
	
	if not self.checkLength() then
		return;
	endif;

	create proxy as self.typeToCreate transient;
	
	nextSequenceNum := txtNextSeqNum.text.Real;
	if nextSequenceNum = 0 then
		if ( self.typeToCreate = CM_AutoIdVoyWOIdGen and style = AutoIdStyle_VoyWOPelindo1 ) then
			//do nothing
		else
			nextSequenceNum := 1;
		endif;
	endif;
	
	proxy.setProxy(	//txtPrefix.text.trimBlanks,	//_idPrefix : String ;
					prefixText, //1 Sept 2022 navmv20 TFS 54610
					seqLength,	//_idSeqNumLength : Integer;
					style,	//_idStyle : Integer;
					self.myTerminal,	//_myTerminal : CM_Terminal; 
					nextSequenceNum,	//_nextSequenceNum : Real;
					resetSeqOn	//_resetSeqOn : Integer
					);
					
	if proxy.isBookingId then
		proxy.CM_AutoBookingIdGen.setPxyOtherAttributes( self.chkEnabled.value );
	elseif proxy.isCargoId then
		proxy.CM_AutoCargoIdGen.setPxyOtherAttributes( self.txtFormat.text.trimBlanks,
		self.chkAbbreviation.value); //1 Septr 2022 navmv20 TFS 54610
	elseif proxy.isReleaseId then
		proxy.CM_AutoReleaseIdGen.setPxyOtherAttributes( self.chkEnabled.value );
	elseif proxy.isTaxNumber then	//18 Dec 2018	NDL	TFS 42614
		seqYear := self.cmbYear.text[3:2].Integer;  // only want the yy bit
		tmpDate.setDate(01,01,self.cmbYear.text.Integer);
		proxy.setLastAndNextValues(	null,	//_lastIdGenerated: String;
									//null,	//_lastIdGeneratedYear: String;
									nextSequenceNum,	//_nextSeqNum: Real;
									seqYear,	//_seqYear: Integer
									tmpDate	//_lastGeneratedDate : Date
									);
	elseif proxy.isVehicleBookingId then																	//Start 24/06/2022  navsrk20 TFS 53898
		proxy.CM_AutoVehicleBookingIdGen.setPxyOtherAttributes(self.txtExtRefSeqLength.text,
																self.txtExtRefPrefix.text.trimBlanks, 
																self.chkGenExtRef.value.Boolean);			//End 24/06/2022  navsrk20 TFS 53898
	elseif proxy.isExternalInvoiceNumber() or 
			proxy.isExternalCreditNoteNumber() or	// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
			proxy.isExternalCreditInvoiceNumber() then 
		seqYear := self.txtYear.text.Integer;
		country := self.txtCountryCode.text; // 09/02/2023	navkc1	Bug 56444
		proxy.CM_AutoInvCatExtNumberGen.setProxyOtherAttributes(nextSequenceNum.Integer, seqYear, self.myBusinessUnit, country);

	elseif proxy.isCustDocNumber() then 	//29/08/2023	navkc1	CR 59556  Task 59557
		seqYear := self.cmbYear.text[3:2].Integer;
		tmpDate.setDate(01, 01, self.cmbYear.text.Integer);
		proxy.setLastAndNextValues(null, nextSequenceNum, seqYear, tmpDate);
	endif;
	
	while true do
		if self.myAutoIdGenerator = null then
			app.myTrxCA.trxCreateAutoIdGenerator( proxy, self.myAutoIdGenerator, app.myPassport);
		else
			app.myTrxUA.trxUpdateAutoIdGenerator( proxy, self.myAutoIdGenerator, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// 18/01/2023	navkc1	TFS CR 55300 TASK 55525 starts
			app.msgBox( app.getErrorString(SAVE_COMPLETE),app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
			self.doSelect();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Automated_generator_format), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
	endwhile; 
	
	//inheritMethod(); // closes the form.

epilog

	delete proxy;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="b2bddce2-96e2-4a9d-b98d-6824d864760e">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2010	cnwndl1	Initial creation	CCMS MES 1004
01 September 2022 navmv20 ChangeRequest 54610: MTN - Auto Cargo Id New Options
*/

vars

	btnTop 			: Real;
	vbsProcess		: CM_VBSProcess;
begin

	inheritMethod();
	self.width := 475;
	//self.height := 375; 			// 1 Sept 2022 navmv20 TFS 54610
	self.height :=440; //1 Sept 2022 navmv20 TFS 54610
	
	//04 July 2022 navmv20 53898 -start
	vbsProcess := self.myTerminal.getMyVBSProcess();
	
	if self.cmbIdType.listData = CM_AutoIdGenerator.VehicleBookingIdType and 
		vbsProcess &lt;&gt; null and vbsProcess.isVbsSlotValidation  then //53898-start
		self.height := 555;
	else 
		//self.height := 375; // 1 Sept 2022 navmv20 TFS 54610
		self.height := 440; //1 Sept 2022 navmv20 TFS 54610
	endif;//04 July 2022 navmv20 53898 -end
	
	self.grpMain.width := self.width - 12;
	self.grpMain.height := self.height - 50; // TFS 2198
	self.grpMain.top := 1;
	self.grpMain.left := 1;
	
	btnTop := self.txtFormat.top + self.txtFormat.height + 15;
	/* TFS 2198
	self.btnCancel.parent := self.grpMain;
	self.btnCancel.top := btnTop;
	self.btnCancel.left := self.grpMain.width - self.btnCancel.width - 60;//340;
	
	self.btnOk.parent := self.grpMain;
	self.btnOk.top := btnTop;
	self.btnOk.left := self.btnCancel.left - self.btnOk.width - 10;//273;
*/
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelect" id="bd0f38b5-f63b-444a-80ce-835ff5d18b01">
        <updating/>
        <source>doSelect()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2014	cnwndl1	Initial creation
04/01/2023	navkc1	TFS CR 55300 TASK 55525 UI - Business Unit Maint changes  for auto id
29/08/2023	navkc1	CR 59556  Task 59557: Jade - CustDocs Auto Id
11/09/2024	jlizm1	TFS 65953 NSW Dynamics Integration - Auto Generate ID
*/

vars

	type : Integer;
	ioClass : CM_ExtFinanceIO;
	businessUnit : CM_Bank;

begin

	type := self.cmbIdType.listData;

	if type &gt; 0 then
		if type = CM_AutoIdGenerator.CargoIdType then
			self.typeToCreate :=  CM_AutoCargoIdGen;
		elseif type = CM_AutoIdGenerator.BookingIdType then
			self.typeToCreate :=  CM_AutoBookingIdGen;
		elseif type = CM_AutoIdGenerator.ReleaseIdType then
			self.typeToCreate :=  CM_AutoReleaseIdGen;
		elseif type = CM_AutoIdGenerator.VehicleBookingIdType then
			self.typeToCreate :=  CM_AutoVehicleBookingIdGen;
		elseif type = CM_AutoIdGenerator.EIRNumberType then			
			//epr CCMS 1409 par 35553 22/1/15
			self.typeToCreate := CM_AutoEIRNumberGen;
		elseif type = CM_AutoIdGenerator.WorkOrderIdType then	//12 Jun 2018	NDL	TFS 39142
			self.typeToCreate :=  CM_AutoIdWOIdGen;
		elseif type = CM_AutoIdGenerator.VoyWorkOrderIdType then	//15 Aug 2018	NDL	TFS 40249
			self.typeToCreate :=  CM_AutoIdVoyWOIdGen;
		elseif type = CM_AutoIdGenerator.PaymentIdType then	//13 Jun 2018	NDL	TFS 39197
			// NOT user maintainable, just here for completeness...
			//Used against  CM_ExtFinanceIO
			type := 0;
			self.typeToCreate :=  null;
		elseif type = CM_AutoIdGenerator.TaxNumberType then	//13 Jun 2018	NDL	TFS 39197
			type := 0;
			self.typeToCreate :=  null;
			//18 Dec 2018	NDL	TFS 42614
			ioClass := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
			if ioClass &lt;&gt; null and ioClass.isKindOf( CM_Pelindo1Interface ) then
				type := CM_AutoIdGenerator.TaxNumberType;
				self.typeToCreate :=  CM_AutoTaxNumberGen;
			endif;
		elseif type = CM_AutoIdGenerator.ExternalNumberType then	//13 Jun 2018	NDL	TFS 39197
			// NOT user maintainable, just here for completeness...
			//Used against  CM_ExtFinanceIO
			type := 0;
			self.typeToCreate :=  null;
		elseif type = CM_AutoIdGenerator.ExternalReceiptNumberType then	 //01.11.2018 cnwma1 TFS #41688
			// NOT user maintainable, just here for completeness...
			//Used against  CM_ExtFinanceIO
			type := 0;
			self.typeToCreate :=  null;
		elseif type = CM_AutoIdGenerator.RoadServiceOrderNumberType then	//14 Oct 2020	NDL	TFS 49189
			self.typeToCreate :=  CM_AutoServiceOrderGen;
		elseif type = CM_AutoIdGenerator.InvExtNumberType then
			self.typeToCreate :=  CM_AutoInvoiceExtNumberGen;	// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
		elseif type = CM_AutoIdGenerator.CrdExtNumberType then
			self.typeToCreate := CM_AutoCreditExtNumberGen;		// 04/01/2023	navkc1	TFS CR 55300 TASK 55525	
		elseif type = CM_AutoIdGenerator.CustDocNumberType then //29/08/2023	navkc1	CR 59556  Task 59557
			self.typeToCreate := CM_AutoIdCustomDocs;
		elseif type = CM_AutoIdGenerator.CrdInvExtNumberType then
			self.typeToCreate := CM_AutoIdCrdInvExtNumberGen;
		endif;
	else
		type := 0;
		self.typeToCreate :=  null;
	endif;
	
	self.populateCmbStyle(type); // 04/01/2023	navkc1	TFS CR 55300 TASK 55525
	
	// 04/01/2023	navkc1	TFS CR 55300 TASK 55525 - Invoice/Credit external number are stored at Business Unit
	if type = CM_AutoIdGenerator.InvExtNumberType or
		type = CM_AutoIdGenerator.CrdExtNumberType or
		type = CM_AutoIdGenerator.CrdInvExtNumberType then
		businessUnit := self.myBusinessUnit;
		if businessUnit &lt;&gt; null then
			self.myAutoIdGenerator := self.myBusinessUnit.getMyAutoIdGenerator(self.typeToCreate);
		endif;
	else
		self.myAutoIdGenerator := self.myTerminal.getMyAutoIdGenerator( self.typeToCreate );
	endif;
	
	self.loadDetails();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doViewAudit" id="56b425eb-b131-43ae-aaae-39b9cec94d37">
        <source>doViewAudit();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 January 2023	navkc1	Initial creation TFS CR 55300 TASK 55525 UI - Business Unit Maint changes  for auto id

*/

vars

begin
	app.viewAuditForm(self.myAutoIdGenerator, self.myAssistant.class, self.myTerminal);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getExtRefExample" id="539c7dac-6f22-4234-b62b-a0b0530b96d2">
        <source>getExtRefExample(_prefix, _date1, _date2 : String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 June 2022	navsrk20	ChangeRequest 53898: EUP - VBS MTN - [2] - External Reference Code Generation
*/

vars
	extRefExample : String;
begin
	if not self.chkGenExtRef.value then
		return null;
	else
		extRefExample := _prefix &amp; _date1 &amp; _date2;
		return extRefExample;
	endif;
	return null;
epilog

end;</source>
        <Parameter name="_prefix" type="String"/>
        <Parameter name="_date1" type="String"/>
        <Parameter name="_date2" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="loadDetails" id="44c72fe4-1f29-49df-b4d7-fa1739f57622">
        <updating/>
        <source>loadDetails()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		 	Reason
20 Jan 2010	cnwndl1	 	Initial creation
24 Jun 2022 navgm20  	ChangeRequest 53898: EUP - VBS MTN - [2] - External Reference Code Generation
01 Sep 2022 navmv20  	ChangeRequest 54610: MTN - Auto Cargo Id New Options
13 Sep 2022 navsrk20 	ChangeRequest 54610: MTN - Auto Cargo Id New Options
04 Jan 2023	navkc1	 	TFS CR 55300 TASK 55525 UI - Business Unit Maint changes  for auto id
09 Feb 2023	navkc1	 	Bug 56444: Jade - Country in Invoice/Credit note Auto Id
11 May 2023 navma1	 	ChangeRequest 57929: FR | EUP 53429 - BR - VBS changes MTN - Auto Id config
29/08/2023	navkc1		CR 59556  Task 59557: Jade - CustDocs Auto Id
10 Sep 2024	jlizm1		TFS 65953 NSW Dynamics Integration - Auto Generate ID
*/

vars

	appScm   : Schema;
	category : ConstantCategory;
	const    : Constant;
	index    : Integer;
	now      : TimeStamp;
	
begin

	appScm    := rootSchema.getSchema(PortSchemaName);
	category  := appScm.getCategory("AutoIdStyle");

	self.chkEnabled.visible := false;
	self.chkEnabled.value := false;
	self.lblFormat.visible := false;
	self.txtFormat.visible := false;
	self.lblYear.visible := false;
	self.cmbYear.visible := false;
	self.txtYear.visible := false;
	self.txtYear.text := null;
	self.chkAbbreviation.visible := false; //1 Sept 2022 navmv20 TFS 54610
	self.lblCountryCode.visible := false;	// 09/02/2023	navkc1	Bug 56444
	self.txtCountryCode.visible := false; 	// 09/02/2023	navkc1	Bug 56444
	self.txtCountryCode.text := null;		// 09/02/2023	navkc1	Bug 56444
	// Start 23/06/2022  navgm20 TFS 53898
	self.chkGenExtRef.visible := false;
	self.lblGenExtRef.visible := false;
	self.lblExtRefPrefix.visible := false;
	self.txtExtRefPrefix.visible := false;
	self.lblExtRefSeqLength.visible := false;
	self.txtExtRefSeqLength.visible := false;
	self.lblTemplate1.visible := false;
	self.lblExample1.visible := false;
	self.lblGenExtRef.visible := false;
	self.txtExtRefPrefix.text := null; 
	self.txtExtRefSeqLength.text := null; 
	self.lblExample1.caption := null; 
	self.chkGenExtRef.value := false;
	//self.height := 375; //1 Sept 2022 navmv20 TFS 54610
	self.height := 440;  //1 Sept 2022 navmv20 TFS 54610
	//self.grpMain.height:=312;  //1 Sept 2022 navmv20 TFS 54610
	self.grpMain.height := 380;  //1 Sept 2022 navmv20 TFS 54610
	// End 23/06/2022  navgm20 TFS 53898
	self.txtCategoryPrefix.visible := false;
	self.txtCategoryPrefix.text := null;
	self.lblCategoryPrefix.visible := false;
	
	if self.typeToCreate = CM_AutoBookingIdGen then
		self.chkEnabled.visible := true;
		
	elseif self.typeToCreate = CM_AutoCargoIdGen then
		self.lblFormat.visible := true;
		self.txtFormat.visible := true;
		self.chkAbbreviation.visible:= true;  //1 Sept 2022 navmv20 TFS 54610
		txtFormat.text := CM_AutoCargoIdGen.DefaultFormat;
		
	elseif self.typeToCreate = CM_AutoReleaseIdGen then
		self.chkEnabled.visible := true;
		
	elseif self.typeToCreate = CM_AutoTaxNumberGen then	//18 Dec 2018	NDL	TFS 42614
		self.lblYear.visible := true;
		self.cmbYear.visible := true;
		self.cmbYear.clear();
		now := app.actualTimeAppServer;
		if now.Date.month &lt; 6 then
			self.cmbYear.addItem( (now.Date.year - 1).String );
		endif;
		self.cmbYear.addItem( (now.Date.year).String );
		if now.Date.month &gt; 5 then
			self.cmbYear.addItem( (now.Date.year + 1).String );
		endif;
		self.cmbYear.listIndex := self.cmbYear.findStringExact( 1, (now.Date.year).String );
		
	// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
	elseif self.typeToCreate = CM_AutoInvoiceExtNumberGen or 
			self.typeToCreate = CM_AutoCreditExtNumberGen or
			self.typeToCreate = CM_AutoIdCrdInvExtNumberGen then
		self.txtYear.visible := true;
		self.lblYear.visible := true;
		self.lblPrefix.visible := true;
		self.txtPrefix.visible := true;
		self.lblCountryCode.visible := true; // 09/02/2023	navkc1	Bug 56444
		self.txtCountryCode.visible := true; // 09/02/2023	navkc1	Bug 56444
		if self.typeToCreate = CM_AutoInvoiceExtNumberGen then
			self.lblCategoryPrefix.caption := app.getErrorString(Invoice_label) &amp; " :";
		elseif self.typeToCreate = CM_AutoCreditExtNumberGen then
			self.lblCategoryPrefix.caption := app.getErrorString(Credit_note_label) &amp; " :";
		else
			self.lblCategoryPrefix.caption := app.getErrorString(Credit_invoice_label) &amp; " :";
		endif;
		self.lblCategoryPrefix.visible := true;
		self.txtCategoryPrefix.visible := true;
		
	//29/08/2023	navkc1	CR 59556  Task 59557
	elseif self.typeToCreate = CM_AutoIdCustomDocs then
		self.lblYear.visible := true;
		self.cmbYear.visible := true;
		self.cmbYear.clear();
		now := app.actualTimeAppServer;
		if now.Date.month &lt; 6 then
			self.cmbYear.addItem( (now.Date.year - 1).String );
		endif;
		self.cmbYear.addItem( (now.Date.year).String );
		if now.Date.month &gt; 5 then
			self.cmbYear.addItem( (now.Date.year + 1).String );
		endif;
		self.cmbYear.listIndex := self.cmbYear.findStringExact( 1, (now.Date.year).String );
	endif;
	
	//16 Aug 2018	NDL	TFS 40249	
/*	if self.typeToCreate = CM_AutoIdVoyWOIdGen then
		cmbStyle.itemEnabled[ AutoIdStyle_VoyWOPelindo1 ] := true;
	else
		cmbStyle.itemEnabled[ AutoIdStyle_VoyWOPelindo1 ] := false;
	endif; */
	
	//23 Jan 2019	NDL	TFS 43018
	foreach const in category.getConstants do
		index := 0;
		if const.GlobalConstant.valueAsInteger = AutoIdStyle_VoyWOPelindo1 then
			index := cmbStyle.findStringExact(1,const.GlobalConstant.text);
			if index &gt; 0 then
				cmbStyle.itemEnabled[ index ] := ( self.typeToCreate = CM_AutoIdVoyWOIdGen );
			endif;
		elseif const.GlobalConstant.valueAsInteger = AutoIdStyle_CargoWOPelindo1 then
			index := cmbStyle.findStringExact(1,const.GlobalConstant.text);
			if index &gt; 0 then
				cmbStyle.itemEnabled[ index ] :=  ( self.typeToCreate = CM_AutoIdWOIdGen );
			endif;
		endif;
	endforeach;
	
	if self.myAutoIdGenerator &lt;&gt; null then
		
		cmbStyle.listIndex := -1;
		foreach const in category.getConstants do
			if self.myAutoIdGenerator.idStyle = const.GlobalConstant.valueAsInteger then
				cmbStyle.listIndex := cmbStyle.findStringExact(1,const.GlobalConstant.text);
				break;
			endif;
		endforeach;
	
		txtPrefix.text := self.myAutoIdGenerator.idPrefix;
		txtSeqLength.text := self.myAutoIdGenerator.idSeqNumLength.String;
		txtNextSeqNum.text := self.myAutoIdGenerator.nextSequenceNum.String;
		
		if self.myAutoIdGenerator.lastIdGenerated = null then
			txtLastId.text := "&lt;" &amp; app.getErrorString(None_Lowercase) &amp; "&gt;";
		else
			txtLastId.text := self.myAutoIdGenerator.lastIdGenerated;
		endif;
		
		if self.typeToCreate = CM_AutoBookingIdGen then
			self.chkEnabled.value := self.myAutoIdGenerator.isEnabled;
		elseif self.typeToCreate = CM_AutoCargoIdGen then
			txtFormat.text := self.myAutoIdGenerator.CM_AutoCargoIdGen.getCargoLabelFormat;
			chkAbbreviation.value := self.myAutoIdGenerator.CM_AutoCargoIdGen.useCargoTypeAbbrv;  //1 Sept 2022 navmv20 TFS 54610
		elseif self.typeToCreate = CM_AutoReleaseIdGen then
			self.chkEnabled.value := self.myAutoIdGenerator.isEnabled;
		elseif self.typeToCreate = CM_AutoVehicleBookingIdGen then //TFS 53898
			self.populateExtRef(); //TFS 53898
		elseif self.typeToCreate = CM_AutoInvoiceExtNumberGen or
				self.typeToCreate = CM_AutoCreditExtNumberGen or 
				self.typeToCreate = CM_AutoIdCrdInvExtNumberGen	then
			self.txtNextSeqNum.text := self.myAutoIdGenerator.CM_AutoInvCatExtNumberGen.currSeq.String; // 04/01/2023	navkc1	TFS CR 55300 TASK 55525
			self.txtYear.text := self.myAutoIdGenerator.CM_AutoInvCatExtNumberGen.currYear.String;
			self.txtCategoryPrefix.text := self.myAutoIdGenerator.idPrefix;
			self.txtCountryCode.text := self.myAutoIdGenerator.CM_AutoInvCatExtNumberGen.currCountry; // 09/02/2023	navkc1	Bug 56444
		elseif self.typeToCreate = CM_AutoIdCustomDocs then //29/08/2023	navkc1	CR 59556  Task 59557
			self.cmbYear.click(self.cmbYear);
		endif;
	else
		cmbStyle.listIndex := -1;
		txtPrefix.text := null;
		txtSeqLength.text := null;
		txtNextSeqNum.text := null;
		txtLastId.text := "&lt;" &amp; app.getErrorString(None_Lowercase) &amp; "&gt;";
	
	endif;
	
	//18 Dec 2018	NDL	TFS 42614 - Only permitted to set the next seq num.
	cmbStyle.enabled := true;
	if self.typeToCreate = CM_AutoTaxNumberGen then
		cmbStyle.listIndex := cmbStyle.itemDataIndex(AutoIdStyle_SSS);
		txtSeqLength.text := "8";
		self.cmbYear.click( cmbYear );
	endif;
	
	self.selectStyle();
	
	// start 1 Sept 2022 navmv20 TFS 54610
	if self.myAutoIdGenerator &lt;&gt; null and self.typeToCreate = CM_AutoCargoIdGen then
		self.lblPrefix.enabled := not chkAbbreviation.value;
		self.txtPrefix.enabled := not chkAbbreviation.value;
	endif;
	//  end 1 Sept 2022 navmv20 TFS 54610
	
	//22 Jan 2019	NDL	TFS 43018
	if self.myAutoIdGenerator &lt;&gt; null and self.cmbReset.listCount &gt; 1 then
		foreach index in 1 to self.cmbReset.listCount do
			if self.cmbReset.itemData[index] = self.myAutoIdGenerator.resetSeqOn then
				self.cmbReset.listIndex := index;
				break;
			endif;
		endforeach;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbReset" id="3ed88a64-99c9-4c7f-afc7-a38df9b9ca7b">
        <source>populateCmbReset( _styleId : Integer );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 January 2019	jlgndl1	Initial creation	TFS 43018

*/

vars

	tmpAutoIdGen : CM_AutoIdGenerator;
	intArray : IntegerArray;
	int : Integer;

begin

	self.cmbReset.clear();
	self.cmbReset.enabled := false;
	self.lblReset.enabled := false;
	
	if self.typeToCreate = null then
		return;
	else
		create tmpAutoIdGen as self.typeToCreate transient;
		create intArray transient;
		tmpAutoIdGen.getValidResetOptions( intArray, _styleId );
	endif;
	
	foreach int in intArray do
		self.cmbReset.itemData[ self.cmbReset.addItem( tmpAutoIdGen.getStringForResetOption( int ) ) ] := int;
	endforeach;
	
	if intArray.size = 1 then
		self.cmbReset.listIndex := 1;
	elseif intArray.size &gt; 1 then
		self.cmbReset.enabled := true;
		self.lblReset.enabled := true;
	endif;

epilog

	delete tmpAutoIdGen;
	delete intArray;

end;</source>
        <Parameter name="_styleId" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="populateCmbStyle" id="2312f044-ef4d-404e-8294-2311568863f6">
        <source>populateCmbStyle(_type : Integer);
/*

Purpose:			
			This method populate the Style combo box based on the selected ID Type
Parameters:			

Return Value:		

Date				Who		Reason
04 January 2023		navkc1	Initial creation TFS CR 55300 TASK 55525 UI - Business Unit Maint changes  for auto id
29/08/2023			navkc1	CR 59556  Task 59557: Jade - CustDocs Auto Id
11 September 2024	jlizm1	Initial creation TFS 65953 NSW Dynamics Integration - Auto Generate ID
*/

vars
	appScm 		: Schema;
	category 	: ConstantCategory;
	const 		: GlobalConstant;
	dict		: ConstantNDict;
	constValue	: Integer;
	index		: Integer;
begin
	appScm := rootSchema.getSchema(PortSchemaName);
	category := appScm.getCategory("AutoIdStyle");
	
	self.cmbStyle.clear();
	
	dict  := category.getConstants();
	
	foreach const in dict as GlobalConstant do
		constValue := const.valueAsInteger();
		
		// For Invoice/Credit External number types, display these styles
		if _type = CM_AutoIdGenerator.InvExtNumberType or
			_type = CM_AutoIdGenerator.CrdExtNumberType or
			_type = CM_AutoIdGenerator.CrdInvExtNumberType then
			if not (constValue = AutoIdStyle_CC_T_L_YY_SSS or
				constValue = AutoIdStyle_CC_B_L_YY_SSS or
				constValue = AutoIdStyle_CC_T_B_L_YY_SSS or
				constValue = AutoIdStyle_P_SSS or
				constValue = AutoIdStyle_B_L_YY_SSS or	//17/01/2025	navkc1 JIRA Bug MTN-33813
				constValue = AutoIdStyle_L_YY_SSSS 		//17/01/2025	navkc1 JIRA Bug MTN-33813
				) 				
				then
				continue;
			else
				
				//17/01/2025	navkc1 JIRA Bug MTN-33813 - Credit Invoice External Number to exclude these
				if _type = CM_AutoIdGenerator.CrdInvExtNumberType then
					if 	constValue = AutoIdStyle_B_L_YY_SSS or
						constValue = AutoIdStyle_L_YY_SSSS
						then
							continue;
					endif;
				endif;
				
			endif;
		// For Customs Document, only display this
		elseif _type = CM_AutoIdCustomDocs.CustDocNumberType then
			if not constValue = AutoIdStyle_P_YY_SSS then
				continue;
			endif;
		// For other types, do not display these styles
		else
			if constValue = AutoIdStyle_CC_T_L_YY_SSS or
				constValue = AutoIdStyle_CC_B_L_YY_SSS or
				constValue = AutoIdStyle_CC_T_B_L_YY_SSS or
				constValue = AutoIdStyle_B_L_YY_SSS or	//17/01/2025	navkc1 JIRA Bug MTN-33813
				constValue = AutoIdStyle_L_YY_SSSS 		//17/01/2025	navkc1 JIRA Bug MTN-33813
				then
				continue;
			endif;
		endif;
		
		index := cmbStyle.addItem(const.text);
		cmbStyle.itemData[index] := constValue;
		
	endforeach;
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="populateExtRef" id="05e43dc3-75ab-4ca9-9899-9a7b0db45f23">
        <updating/>
        <source>populateExtRef() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2022	navgm20	ChangeRequest 53898: EUP - VBS MTN - [2] - External Reference Code Generation
01 September 2022 navmv20 ChangeRequest 54610: MTN - Auto Cargo Id New Options
*/

vars
	vbsProcess : CM_VBSProcess;
	autoIdGenerator : CM_AutoVehicleBookingIdGen;
begin
	vbsProcess := self.myTerminal.getMyVBSProcess();
	autoIdGenerator := self.myAutoIdGenerator.CM_AutoVehicleBookingIdGen;
	
	if vbsProcess &lt;&gt; null and vbsProcess.isVbsSlotValidation then
		self.chkGenExtRef.value := autoIdGenerator.getExtRefEnabled();			
		self.txtExtRefPrefix.text := autoIdGenerator.externalRefPrefix;
		
		if autoIdGenerator.externalRefLength &lt;&gt; null then
			self.txtExtRefSeqLength.text := autoIdGenerator.externalRefLength.String;
		endif;
		self.chkGenExtRef.visible		:= true;
		self.lblGenExtRef.visible 		:= true;
		self.lblExtRefPrefix.visible	:= true;
		self.txtExtRefPrefix.visible	:= true;
		self.lblExtRefSeqLength.visible	:= true;
		self.txtExtRefSeqLength.visible := true;
		self.lblTemplate1.visible		:= true;
		self.lblExample1.visible		:= true;
		self.lblGenExtRef.visible		:= true;
		 
		if chkGenExtRef.value then
			self.lblExtRefPrefix.enabled	:= true;
			self.txtExtRefPrefix.enabled	:= true;
			self.lblExtRefSeqLength.enabled	:= true;
			self.txtExtRefSeqLength.enabled	:= true;
			self.lblTemplate1.enabled		:= true;
			self.lblExample1.enabled		:= true;
		else
			self.lblExtRefPrefix.enabled	:= false;
			self.txtExtRefPrefix.enabled	:= false;
			self.lblExtRefSeqLength.enabled	:= false;
			self.txtExtRefSeqLength.enabled	:= false;
			self.lblTemplate1.enabled		:= false;
			self.lblExample1.enabled		:= false;
		endif;
		
		//self.height 		 := 515;  		// 1 sept 2022 navmv20 TFS 54610
		//self.grpMain.height := 465;  		// 1 Sept 2022 navmv20 TFS 54610
		 self.height 		 := 600; 		// 1 Sept 2022 navmv20 TFS 54610
		 self.grpMain.height := 550; 		// 1 Sept 2022 navmv20 54610

	endif;	 
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="selectStyle" id="404ddd25-b451-4201-8826-a73a907cd13c">
        <source>selectStyle();

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
19 January 2010		cnwndl1	Initial creation
24 June 2022    	navmv20 ChangeRequest 53898: EUP - VBS MTN - [2] - External Reference Code Generation
01 September 2022 	navmv20 ChangeRequest 54610: MTN - Auto Cargo Id New Options
04/01/2023			navkc1	TFS CR 55300 TASK 55525 UI - Business Unit Maint changes  for auto id
11 September 2024	jlizm1	TFS 65953 NSW Dynamics Integration - Auto Generate ID
*/

vars

	style : Integer;
	yearStr : String;
	monthStr : String;
	prefixStr : String;
	seqNumString : String;
	plus : String;
	extRefPrefix : String;	// 24 June 2022 navmv20 53898
	checkDigit : String;	// 24 June 2022 navmv20 53898
	dayStr : String; //1 Sept 2022 navmv20 TFS 54610
	countryStr : String;		// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
	terminalStr : String; 		// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
	businessUnitStr : String; 	// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
	labelStr : String;
begin
if cmbStyle.listIndex &gt; 0 then
		style := cmbStyle.itemData[cmbStyle.listIndex];
	endif;
	
	//22 Jan 2019	NDL	TFS 43018
	if cmbStyle.listIndex &gt; 0 then
		self.populateCmbReset( cmbStyle.itemData[ cmbStyle.listIndex ] );
	else
		self.populateCmbReset( 0 );
	endif;
	
	
	monthStr := app.getErrorString(Month);
	yearStr := app.getErrorString(Year);
	dayStr := app.getErrorString(Day); //1 Sept 2022 navmv20 TFS 54610
	prefixStr := app.getErrorString(Prefix);
	seqNumString := app.getErrorString(SequenceNumber);
	extRefPrefix := app.getErrorString(Ext_Ref_Prefix);	//23/06/2022 navgm20 TFS 53898
	checkDigit := app.getErrorString(Check_Digit);			//23/06/2022 navgm20 TFS 53898
	countryStr := app.getErrorString(Country);				// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
	terminalStr := app.getErrorString(Terminal);			// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
	businessUnitStr := app.getErrorString(CM_Business_Unit);// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
	labelStr := app.getErrorString(Heading_Label);
	plus := " + ";
	
	if style &lt; 1 then
		txtPrefix.enabled := false;
		txtSeqLength.enabled := false;
		txtNextSeqNum.enabled := false;
		lblPrefix.enabled := false;
		lblNumLength.enabled := false;
		lblNextSeqNum.enabled := false;
		lblTemplate.caption := null;
		lblExample.caption := null;
		lblTemplate1.caption := null;		//23/06/2022 navgm20 TFS 53898
		lblExample1.caption := null;			//23/06/2022 navgm20 TFS 53898
		
	elseif style = AutoIdStyle_P_MM_YY_SSS then
		txtPrefix.enabled := true;
		txtSeqLength.enabled := true;
		txtNextSeqNum.enabled := true;
		lblPrefix.enabled := true;
		lblNumLength.enabled := true;
		lblNextSeqNum.enabled := true;
		lblTemplate.caption := prefixStr &amp; plus &amp; monthStr &amp; plus &amp; yearStr &amp; plus &amp; seqNumString;
		lblExample.caption := null;
		self.lblTemplate1.caption := extRefPrefix &amp; plus &amp; monthStr &amp; plus &amp; yearStr &amp; plus &amp; seqNumString &amp; plus &amp; checkDigit;	//23/06/2022 navgm20 TFS 53898
		self.lblExample1.caption := null;			//23/06/2022 navmv20 TFS 53898
	// TFS 39976
	
	elseif style = AutoIdStyle_P_YY_MM_SSS then
		txtPrefix.enabled := true;
		txtSeqLength.enabled := true;
		txtNextSeqNum.enabled := true;
		lblPrefix.enabled := true;
		lblNumLength.enabled := true;
		lblNextSeqNum.enabled := true;
		lblTemplate.caption := prefixStr &amp; plus  &amp; yearStr &amp; plus &amp; monthStr &amp; plus &amp; seqNumString;
		self.lblTemplate1.caption := extRefPrefix &amp; plus &amp; yearStr &amp; plus &amp; monthStr &amp; plus &amp; seqNumString &amp; plus &amp; checkDigit;	//23/06/2022 navgm20 TFS 53898
		self.lblExample.caption := null;
		self.lblExample1.caption := null;			//23/06/2022 navmv20 TFS 53898
		
	elseif style = AutoIdStyle_P_YY_SSS then
		txtPrefix.enabled := true;
		txtSeqLength.enabled := true;
		txtNextSeqNum.enabled := true;
		lblPrefix.enabled := true;
		lblNumLength.enabled := true;
		lblNextSeqNum.enabled := true;
		lblTemplate.caption := prefixStr &amp; plus &amp; yearStr &amp; plus &amp; seqNumString;
		self.lblTemplate1.caption := extRefPrefix &amp; plus &amp; yearStr &amp; plus &amp; seqNumString &amp; plus &amp; checkDigit;	//23/06/2022 navgm20 TFS 53898
		lblExample.caption := null;
		self.lblExample1.caption := null;			//23/06/2022 navmv20 TFS 53898
		
	elseif style = AutoIdStyle_YY_SSS then
		txtPrefix.enabled := false;
		txtSeqLength.enabled := true;
		txtNextSeqNum.enabled := true;
		lblPrefix.enabled := false;
		lblNumLength.enabled := true;
		lblNextSeqNum.enabled := true;
		lblTemplate.caption := yearStr &amp; plus &amp; seqNumString;
		self.lblTemplate1.caption := yearStr &amp; plus &amp; seqNumString &amp; plus &amp; checkDigit;	//23/06/2022 navgm20 TFS 53898
		lblExample.caption := null;
		self.lblExample1.caption := null;			//23/06/2022 navmv20 TFS 53898
		
	elseif style = AutoIdStyle_P_SSS then
		txtPrefix.visible := true;
		txtPrefix.enabled := true;
		txtSeqLength.enabled := true;
		txtNextSeqNum.enabled := true;
		txtCountryCode.visible := false;
		txtCategoryPrefix.visible := false;
		txtYear.visible := false;
		lblPrefix.visible := true;
		lblPrefix.enabled := true;
		lblNumLength.enabled := true;
		lblNextSeqNum.enabled := true;
		lblTemplate.caption := prefixStr &amp; plus &amp; seqNumString;
		lblTemplate1.caption := extRefPrefix &amp; plus &amp; seqNumString &amp; plus &amp; checkDigit;		//23/06/2022 navgm20 TFS 53898
		lblExample.caption := null;
		lblExample1.caption :=null;			//23/06/2022 navmv20 TFS 53898
		lblCountryCode.visible := false;
		lblCategoryPrefix.visible := false;
		lblYear.visible := false;
		
	elseif style = AutoIdStyle_SSS then
		txtPrefix.enabled := false;
		txtSeqLength.enabled := true;
		txtNextSeqNum.enabled := true;
		lblPrefix.enabled := false;
		lblNumLength.enabled := true;
		lblNextSeqNum.enabled := true;
		lblTemplate.caption := seqNumString;
		self.lblTemplate1.caption := seqNumString &amp; plus &amp; checkDigit;	//23/06/2022 navgm20 TFS 53898
		lblExample.caption := null;
		self.lblExample1.caption := null;			//23/06/2022 navmv20 TFS 53898
		//18 Dec 2018	NDL	TFS 42614
		if self.typeToCreate = CM_AutoTaxNumberGen then
			cmbStyle.enabled := false;
			txtSeqLength.enabled := false;
			lblTemplate.caption := "Hard Coded Format";
		endif;
		// Start 1 Sept 2022 navmv20 TFS 54610
		
	elseif style = AutoIdStyle_P_YY_MM_DD_SSS then 
		txtPrefix.enabled := false;
		txtSeqLength.enabled := true;
		txtNextSeqNum.enabled := true;
		lblPrefix.enabled := false;
		lblNumLength.enabled := true;
		lblNextSeqNum.enabled := true;
		lblTemplate.caption := prefixStr &amp; plus  &amp; yearStr &amp; plus &amp; monthStr &amp; plus &amp; dayStr &amp; plus &amp; seqNumString;
		lblExample.caption := null;
		//End 1 Sept 2022 navmv20 TFS 54610
		
	elseif style = AutoIdStyle_VoyWOPelindo1 then	//16 Aug 2018	NDL	TFS 40249
		//This one is hard coded, only valid for 'Voyage Work Orders' and not user editable. 
		txtPrefix.enabled := false;
		txtSeqLength.enabled := false;
		txtNextSeqNum.enabled := false;
		lblPrefix.enabled := false;
		lblNumLength.enabled := false;
		lblNextSeqNum.enabled := false;
		txtPrefix.text := null;
		txtSeqLength.text := '3';
	//	txtNextSeqNum.text := null;	25 Feb 2019	NDL	TFS 43562
		lblTemplate.caption := "Hard Coded Format";
		
	elseif style = AutoIdStyle_CargoWOPelindo1 then	//23 Jan 2019	NDL	TFS 43045
		//This one is hard coded, only valid for 'Cargo Work Orders' and not user editable. 
		txtPrefix.enabled := false;
		txtSeqLength.enabled := false;
		txtNextSeqNum.enabled := false;
		lblPrefix.enabled := false;
		lblNumLength.enabled := false;
		lblNextSeqNum.enabled := false;
		txtPrefix.text := null;
		txtSeqLength.text := "5";
	//	txtNextSeqNum.text := null;	25 Feb 2019	NDL	TFS 43562
		lblTemplate.caption := "Hard Coded Format";
		
	elseif style = AutoIdStyle_CC_B_L_YY_SSS then	// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
		txtPrefix.visible := false;
		txtSeqLength.enabled := true;
		txtNextSeqNum.enabled := true;
		txtCountryCode.visible := true;
		txtCountryCode.enabled := true;
		txtCategoryPrefix.visible := true;
		txtCategoryPrefix.enabled := true;
		txtYear.visible := true;
		txtYear.enabled := true;
		lblPrefix.visible := false;
		lblNumLength.enabled := true;
		lblNextSeqNum.enabled := true;
		lblCountryCode.visible := true;
		lblCountryCode.enabled := true;
		lblCategoryPrefix.visible := true;
		lblCategoryPrefix.enabled := true;
		lblYear.visible := true;
		lblYear.enabled := true;
		lblTemplate.caption := countryStr &amp; plus  &amp; businessUnitStr &amp; plus &amp; labelStr &amp; plus &amp; yearStr &amp; plus &amp; seqNumString;
		
	elseif style = AutoIdStyle_CC_T_B_L_YY_SSS then // 04/01/2023	navkc1	TFS CR 55300 TASK 55525
		txtPrefix.visible := false;
		txtSeqLength.enabled := true;
		txtNextSeqNum.enabled := true;
		txtCountryCode.visible := true;
		txtCountryCode.enabled := true;
		txtCategoryPrefix.visible := true;
		txtCategoryPrefix.enabled := true;
		txtYear.visible := true;
		txtYear.enabled := true;
		lblPrefix.visible := false;
		lblNumLength.enabled := true;
		lblNextSeqNum.enabled := true;
		lblCountryCode.visible := true;
		lblCountryCode.enabled := true;
		lblCategoryPrefix.visible := true;
		lblCategoryPrefix.enabled := true;
		lblYear.visible := true;
		lblYear.enabled := true;
		lblTemplate.caption := countryStr &amp; plus  &amp; terminalStr &amp; plus &amp; businessUnitStr &amp; plus &amp; labelStr &amp; plus &amp; yearStr &amp; plus &amp; seqNumString;
		
	elseif style = AutoIdStyle_CC_T_L_YY_SSS then	// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
		txtPrefix.visible := false;
		txtSeqLength.enabled := true;
		txtNextSeqNum.enabled := true;
		txtCountryCode.visible := true;
		txtCountryCode.enabled := true;
		txtCategoryPrefix.visible := true;
		txtCategoryPrefix.enabled := true;
		txtYear.visible := true;
		txtYear.enabled := true;
		lblPrefix.visible := false;
		lblNumLength.enabled := true;
		lblNextSeqNum.enabled := true;
		lblCountryCode.visible := true;
		lblCountryCode.enabled := true;
		lblCategoryPrefix.visible := true;
		lblCategoryPrefix.enabled := true;
		lblYear.visible := true;
		lblYear.enabled := true;
		lblTemplate.caption := countryStr &amp; plus  &amp; terminalStr &amp; plus &amp; labelStr &amp; plus &amp; yearStr &amp; plus &amp; seqNumString;
	elseif style = AutoIdStyle_L_YY_SSSS then	//17/01/2025	navkc1 JIRA Bug MTN-33813
		txtPrefix.visible := false;
		txtSeqLength.enabled := true;
		txtNextSeqNum.enabled := true;
		txtCountryCode.visible := false;
		txtCountryCode.enabled := false;
		txtCategoryPrefix.visible := true;
		txtCategoryPrefix.enabled := true;
		txtYear.visible := true;
		txtYear.enabled := true;
		lblPrefix.visible := false;
		lblNumLength.enabled := true;
		lblNextSeqNum.enabled := true;
		lblCountryCode.visible := false;
		lblCountryCode.enabled := false;
		lblCategoryPrefix.visible := true;
		lblCategoryPrefix.enabled := true;
		lblYear.visible := true;
		lblYear.enabled := true;
		lblTemplate.caption := labelStr &amp; plus &amp; yearStr &amp; plus &amp; seqNumString;
	elseif style = AutoIdStyle_B_L_YY_SSS then	//17/01/2025	navkc1 JIRA Bug MTN-33813
		txtPrefix.visible := false;
		txtSeqLength.enabled := true;
		txtNextSeqNum.enabled := true;
		txtCountryCode.visible := false;
		txtCountryCode.enabled := false;
		txtCategoryPrefix.visible := true;
		txtCategoryPrefix.enabled := true;
		txtYear.visible := true;
		txtYear.enabled := true;
		lblPrefix.visible := false;
		lblNumLength.enabled := true;
		lblNextSeqNum.enabled := true;
		lblCountryCode.visible := false;
		lblCountryCode.enabled := false;
		lblCategoryPrefix.visible := true;
		lblCategoryPrefix.enabled := true;
		lblYear.visible := true;
		lblYear.enabled := true;
		lblTemplate.caption := businessUnitStr &amp; plus &amp; labelStr &amp; plus &amp; yearStr &amp; plus &amp; seqNumString;
	endif;
	
	self.checkLength();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCaption" id="cd565bad-b84c-4d6f-80d9-d436d7e43e6b">
        <updating/>
        <source>setCaption(_caption: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Jan 2023	navkc1	Initial creation TFS CR 55300 TASK 55525 - Inv Maint - Invoice / Credit Auto ID
21 Aug 2023 navma1	Defect 59926: MTN - 1090 exception when clicking on Auto Id Configuration
*/

vars

begin
	inheritMethod(_caption);
	
	if self.myParentForm &lt;&gt; null and self.myParentForm.isInvCompanyStructureForm() then		//21.08.2023 navma1 #59926
		self.caption := self.caption &amp; " - " &amp; self.myBusinessUnit.code;
	endif;

epilog

end;</source>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="setCorrectComboStyle" id="24ae65db-260b-40c2-b28c-afdaff04581f">
        <updating/>
        <source>setCorrectComboStyle() updating;
/*
Purpose:	During the change to 22.0.24 some combo boxes had their STYLE set to zero, this is a patchable way to fix that.				

Date		Who		Reason
11 June 2024	navab1	BUG 64462
*/

vars

begin
	inheritMethod();

	self.cmbIdType.style := 2;
	self.cmbReset.style := 2;
	self.cmbStyle.style := 2;
	self.cmbYear.style := 2;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setForIdType" id="68e17836-6d69-40f3-882b-747ab7259022">
        <updating/>
        <source>setForIdType( _int : Integer; _term : CM_Terminal ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2014	cnwndl1	Initial creation	Par 34660

*/

vars

begin

	self.setMyTerminal( _term );
	self.setForType := _int;

epilog

end;</source>
        <Parameter name="_int" type="Integer"/>
        <Parameter name="_term" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setMyBusinessUnit" id="9988b05b-42b4-4430-943a-f74951a1016a">
        <updating/>
        <source>setMyBusinessUnit(_bank : CM_Bank) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 January 2023	navkc1	Initial creation TFS CR 55300 TASK 55525 UI - Business Unit Maint changes  for auto id

*/

vars

begin
	self.myBusinessUnit := _bank;
epilog

end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="6ca57b9f-17be-48eb-9c0a-da7e8433f31c">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 Jan 2010	cnwndl1	Initial creation	CCMS MES 1004
04 Jan 2023	navkc1	TFS CR 55300 TASK 55525 UI - Business Unit Maint changes  for auto id
21 Aug 2023 navma1	Defect 59926: MTN - 1090 exception when clicking on Auto Id Configuration
29/08/2023	navkc1	CR 59556  Task 59557: Jade - CustDocs Auto Id
06 Sep 2024	jlizm1	TFS 65953 NSW Dynamics Integration - Auto Generate ID
*/

vars
	ioClass 	: CM_ExtFinanceIO;
	isBUForm    : Boolean;
begin
    
	self.handleMenusForModalDisplay();
	if self.myTerminal = null then
		self.myTerminal := app.getMyTerminalDO_NOT_USE;
	endif;

	if self.myParentForm &lt;&gt;null and self.myParentForm.isInvCompanyStructureForm() then								//21.08.2023 navma1 #59926
		isBUForm := true;
	endif;
	inheritMethod();
	
	self.populateCmbStyle(null); // 04/01/2023	navkc1	TFS CR 55300 TASK 55525
	
	// 18/01/2023	navkc1	navkc1	TFS CR 55300 TASK 55525
	if not isBUForm then																							//21.08.2023 navma1 #59926
		cmbIdType.addItemWithData(app.getErrorString(CargoId),CM_AutoIdGenerator.CargoIdType);
		//cmbIdType.addItemWithData(app.getErrorString(BookingId),CM_AutoIdGenerator.BookingIdType);			    //17 Jul 2015	NDL May be required when Ghana get going, part of Par 34660/GPHA CCMS 2363
		cmbIdType.addItemWithData(app.getErrorString(Web_Release_Id),CM_AutoIdGenerator.ReleaseIdType);				// 14/5/18 epr used by tfs 38519 webportal cargo release
		cmbIdType.addItemWithData(app.getErrorString(EIRNumber),CM_AutoIdGenerator.EIRNumberType); 					//epr CCMS 1409 par 35553 22/1/15
		cmbIdType.addItemWithData(app.getErrorString(Work_order_id),CM_AutoIdGenerator.WorkOrderIdType);			//12 Jun 2018	NDL TFS 39142
		cmbIdType.addItemWithData(app.getErrorString(Voyage_work_order_id),CM_AutoIdGenerator.VoyWorkOrderIdType);	//15 Aug 2018	NDL TFS 40249
		
		if app.isVehicleBookingEnabled then	//09 Oct 2014	NDL	Par 35008
			cmbIdType.addItemWithData(app.getErrorString(VehicleBookingId),CM_AutoIdGenerator.VehicleBookingIdType);
		endif;
		
		//18 Dec 2018	NDL	TFS 42614
		ioClass := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
		if ioClass &lt;&gt; null and ioClass.isKindOf( CM_Pelindo1Interface ) then
			cmbIdType.addItemWithData(app.getErrorString(Tax_Number),CM_AutoIdGenerator.TaxNumberType);
		endif;
		
		//14 Oct 2020	NDL	TFS 49189
		if self.myTerminal.roadProcessIsASPA then
			cmbIdType.addItemWithData(app.getErrorString(Aspa_service_order_number),CM_AutoIdGenerator.RoadServiceOrderNumberType);
		endif;
		
		//29/08/2023	navkc1	CR 59556  Task 59557
		cmbIdType.addItemWithData(app.getErrorString(Customs_document_number), CM_AutoIdGenerator.CustDocNumberType);
	else
		cmbIdType.addItemWithData(app.getErrorString(Invoice_external_number),CM_AutoIdGenerator.InvExtNumberType);	// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
		cmbIdType.addItemWithData(app.getErrorString(Credit_note_ext_number),CM_AutoIdGenerator.CrdExtNumberType);	// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
		cmbIdType.addItemWithData(app.getErrorString(Credit_invoice_external_number), CM_AutoIdGenerator.CrdInvExtNumberType);
	endif;
	
	if self.setForType &gt; 0 then
		cmbIdType.setIndexForItemData(self.setForType);
		cmbIdType.enabled := false;
		doSelect();
	else
		loadDetails();
	endif;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.grpMain.enabled := false;
		self.btnOk.enabled := false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="skipToAttribute" id="8004beea-8330-4824-b49b-5c3a6b8a0c4b">
        <updating/>
        <source>skipToAttribute(_attributeName: String; _shtName: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2014	cnwndl1	Initial creation

*/

vars

begin
	if _attributeName &lt;&gt; null then
		self.cmbIdType.listIndex := self.cmbIdType.findStringExact(1,_attributeName);
		self.doSelect();
	endif;
	
epilog

end;</source>
        <Parameter name="_attributeName" type="String"/>
        <Parameter name="_shtName" type="String"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="6b9a9863-0282-455b-bef6-0972ef9aa5bb">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 16 February 2023 14:08:38.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014093, locale);
