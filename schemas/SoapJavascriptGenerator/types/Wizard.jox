    <JadeMethod name="btnGenGenerate_click" id="ebd4ab4e-c268-49bb-8f35-9b4c19dd93cc">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnGenGenerate_click(btn: Button input) updating;

vars
	lsa,lsa2 : LargeStringArray;
begin
	create lsa transient;
	//lstGenLog.listCollection(lsa,true,0);
	generator.generate(lsa);
epilog
	lsa2 := lsa.copySelf(true);
	delete lsa;
	//endNotification(lsa,Object_Update_Event);
	//endNotificationForSubscriber(lsa);
	
end;
</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnSerAdd_click" id="fd79a9dd-d65d-4801-9a45-9a4d58e1f7a6">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSerAdd_click(btn: Button input) updating;

vars
	i,j : Integer;
	jel : JadeExposedList;
begin
	foreach i in 1 to lstSerAvailable.listCount
			where lstSerAvailable.itemSelected[i]
			and	lstSerAvailable.itemObject[i] &lt;&gt; null
			and generator.getWebservice(lstSerAvailable.itemObject[i].JadeExposedList.name) = null do
		 generator.addWebservice(lstSerAvailable.itemObject[i].JadeExposedList);		
	endforeach;
	lstSerAvailable.clearAllSelected();
	lstSerSelected.listCollection(generator.webservices,false,0);
		 
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnSerRemove_click" id="61cdf437-c66f-4e67-8e93-e7b650541060">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSerRemove_click(btn: Button input) updating;

vars
	i : Integer;
begin

	foreach i in 1 to lstSerSelected.listCount
			where lstSerSelected.itemSelected[i] do
		generator.webservices.remove(lstSerSelected.itemObject[i].WsdlApplication);		
	endforeach;	
	lstSerSelected.listCollection(generator.webservices,false,0);
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnSetBrowse_click" id="c005bd68-c419-43b7-aa41-02be2841851e">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSetBrowse_click(btn: Button input) updating;

vars
	ff : FileFolder;
	folder : String;
	startAt : String;
begin
	create ff transient;
	ff.usePresentationFileSystem := true;
	if txtSetDirectory.text &lt;&gt; "" then
		startAt := txtSetDirectory.text;
	else
		startAt := app.getJadeInstallDir;
	endif;
	folder := ff.browseForFolder("Please select the target directory",startAt);
	if folder &lt;&gt; null then
		txtSetDirectory.text := folder;
	endif;
	if txtSetDirectory.text &lt;&gt; null then
		generator.directory := txtSetDirectory.text;
	endif;	
epilog
	delete ff;
end;
</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="load" id="b50ab294-bb77-4b46-815f-abaa1e2d59d1">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

vars
	gws : GenerateWsdlScripts;
	sch : Schema;
	sColl : SchemaColl;
	c : Class;
	cColl : ObjectArray;
	expList : JadeExposedList;
	schemaListed : Boolean;
	consumedListed : Boolean;
	providedListed : Boolean;
	count : Integer;
	i : Integer;
begin
	create gws transient;
	generator := gws;
	generator.directory := app.getJadeInstallDir() &amp; '/Javascripts';
	generator.namespace := 'JMT';
	txtSetDirectory.text := generator.directory;
	txtSetNamespace.text := generator.namespace;
	
		create sColl transient;
		create cColl transient;
		rootSchema.allSubschemas(sColl);
		foreach sch in sColl where not sch.isSystemObject do
			schemaListed := false;
			
			foreach i in 1 to 1 do // check for consumed and then check for provided
				consumedListed := false;			
				foreach expList in sch.getPropertyValue("_exposedLists").JadeExposedListNDict do
					if (i = 1 and expList.registryId = "_WebServices_Consumer") or (i = 2 and expList.registryId = "_WebServices_Provider") then
						if not schemaListed then
							count := count + 1;
							lstSerAvailable.addItemAt(sch.name,count);
							lstSerAvailable.itemForeColor[count] := Blue;
							schemaListed := true;
						endif;
						if not consumedListed then
							count := count + 1;
							if i = 1 then
								lstSerAvailable.addItemAt("Consumed:",count);
							elseif i = 2 then
								lstSerAvailable.addItemAt("Provided:",count);
							endif;
							lstSerAvailable.itemEnabled[count] := false;
							lstSerAvailable.itemLevel[count] := 2;
							consumedListed := true;
						endif;
						count := count + 1;
						lstSerAvailable.addItemAt(expList.name,count);
						lstSerAvailable.itemObject[count] := expList;
						lstSerAvailable.itemLevel[count] := 3;
						//cColl.add(expList);
					endif;
				endforeach;
			endforeach;
			/*c := sch.getClass("JadeWebServiceConsumer");
			c.allLocalSubclasses(cColl);*/
		endforeach;
		//lbxSerAvailable.listCollection(cColl,false,0);
		if lstSerAvailable.listCount &gt; 0 then
			lstSerAvailable.listIndex := 1;
		endif;		
		//
		lstSerSelected.listCollection(generator.webservices,false,0);
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="lstSerAvailable_click" id="59e366cb-d620-42b2-888f-6483a56e7859">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstSerAvailable_click(listbox: ListBox input) updating;

vars
	i : Integer;
begin
	i := listbox.listIndex;
	if i &lt; 1 then
		return;
	endif;
	if listbox.itemLevel[i] = 1 then
		listbox.itemSelected[i] := false;
	endif;

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstSerAvailable_dblClick" id="cf28ad68-4a4e-4cc8-9a64-9d98ade18795">
        <controlMethod name="ListBox::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstSerAvailable_dblClick(listbox: ListBox input) updating;

vars
	currentIndex : Integer;
begin
	currentIndex := listbox.listIndex;
	
	btnSerAdd.click(btnSerAdd);
	
	if listbox.listCount &gt; 0 then
		if currentIndex &lt; 1 or currentIndex &gt; listbox.listCount then
			currentIndex := 1;
		endif;
		listbox.listIndex := currentIndex;
		listbox.itemSelected[currentIndex] 	:= true;
	endif;
	
end;
</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstSerAvailable_pictureClick" id="b0dea303-15c2-4413-88b2-9e957d64ea11">
        <controlMethod name="ListBox::pictureClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstSerAvailable_pictureClick(listbox: ListBox input; picIndex: Integer; whatClicked: Integer) updating;

vars
	i : Integer;
begin
	listbox.itemExpanded[picIndex] := not listbox.itemExpanded[picIndex];
	if listbox.itemExpanded[picIndex] then // if we're expanding, then expand the consumer and provider lists
		i := picIndex + 1;
		while i &lt; listbox.listCount and listbox.itemLevel[i] &gt; 1 do
			listbox.itemExpanded[i] := true;
			i := i +1;
		endwhile;
	endif;
end;	</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="picIndex" type="Integer"/>
        <Parameter name="whatClicked" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lstSerSelected_dblClick" id="0853fb2f-72bb-4493-a2e7-1ae328a9c842">
        <controlMethod name="ListBox::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstSerSelected_dblClick(listbox: ListBox input) updating;

vars
	currentIndex : Integer;
begin
	currentIndex := listbox.listIndex;

	btnSerRemove.click(btnSerRemove);
	
	if listbox.listCount &gt; 0 then
		if currentIndex &lt; 1 or currentIndex &gt; listbox.listCount then
			currentIndex := 1;
		endif;
		listbox.listIndex := currentIndex;
		listbox.itemSelected[currentIndex] 	:= true;
	endif;
end;
</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstSerSelected_displayEntry" id="aedeb8d0-92ae-4694-971d-af5bb2df6d1c">
        <controlMethod name="ListBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstSerSelected_displayEntry(listbox: ListBox input; obj: Any; lstIndex: Integer):String updating;

vars

begin
	return obj.WsdlApplication.jadeName;
end;
</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="txtSetNamespace_change" id="ee2d9371-8d2d-42ad-849e-a0f7e5c8ebca">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtSetNamespace_change(textbox: TextBox input) updating;

vars

begin
	if textbox.text &lt;&gt; null then
		generator.namespace := textbox.text;
	endif;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
