    <JadeMethod name="getDefaultDischargeLane" id="e9828721-a1e0-43bc-8aa2-055b962fb2fb">
        <source>getDefaultDischargeLane() : CM_LocationsController;
/*
 ------------------------------------------------------------------------
Created:			30 April 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin

	if self.transferArea = null then
		return null;
	endif;
	if self.transferArea.dischargeLanes.isEmpty = false then
		//----------------------
		//Use the 1st discharge lane
		//----------------------
		return self.transferArea.dischargeLanes[1];
	elseif self.transferArea.lanes.isEmpty = false then
		//----------------------
		//Fek, simply default to the 1st bloody lane!
		//----------------------
		return self.transferArea.lanes[1];
	endif;
	return null;
end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
