    <JadeMethod name="setProxyFromTable" id="84c6f929-95c1-44d5-ad92-d2c2ab12c6a0">
        <updating/>
        <source>setProxyFromTable(_damageInterface : IF_DamageDetails input; _errors : String output; _locationStr : String) updating;
/*
----------   ----------  --------------------------------------------------
Created:	21 September 2006 By cnwth2

Purpose:	

/****Changes

Date		Name	TFS#			Description
============================================================================
11/2/2009	cnwcp2		 			Needed spacing between each error message, 
									added a fullstop and space at the end of each	
28/07/2009  cnwsh3	CCMS SFW1066 	Recording Damage Details Changes.
					PAR20321 		location is now CM_DamagePosition
22/11/2016  cnwma1	TFS #2944 
					PAR38399 		STWO - damage recording - cargo quantity
30/11/2018	jlgka1	41225			SNO - Add repaired attribute.
30/04/2019	jlgdi1	44530			Set the timeStamp of created proxy CM_DamageInstance
09/05/2019	jlgka1	44287			JMT - Damage Refactoring. 
13/05/2019	jlgdi1	44730			Added a line that calls the method 'createListOfTimeStamps' before the object reference gets purged.
									Determines the value to store in the timeStamp attribute based on the created list.
01/07/2022  navak20					ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
============================================================================*/

constants
	ONE : Integer = 1;
	
vars
	fixed				: Integer;
	numberRows			: Integer;
	row					: Integer;
	posStr				: String;
	codeStr				: String;
	remarks				: String;
	severity			: CM_DamageSeverity;		// 11.07.2022 navak20 TFS 53862		
	damageCode			: CM_DamageDefinitionCode;
	damageCodeDict		: CM_DamageDefinitionByCodeDict;
	damagePosition		: CM_DamagePosition; // CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	quantityStr 		: String;
	quantityInt 		: Integer;
	repairedStr			: String;
	repaired			: Boolean;
	pxyDamageInstance : CM_DamageInstance;
	timeStampList : TimeStampArray;
	damageTimeStamp : TimeStamp;
	terminal : CM_Terminal;					// 13.07.2022 navak20 TFS 53862
begin
	numberRows := self.rows;
	fixed := self.fixedRows;
	if _damageInterface =null  then
		return;
	endif;
	
	create timeStampList transient;
	createListOfTimeStamps(fixed + ONE,
						   numberRows,
						   timeStampList);
	
	terminal := _damageInterface.getDamageTerminal;		// 13.07.2022 navak20 TFS 53862
	_damageInterface.purgeAllDamageInstances();
	
	damageCodeDict := app.myRoot.allDamageDefinitionCodes;
	foreach row in fixed + 1 to numberRows do
		posStr		:= self.getCellText(row, 1).trimBlanks;
		codeStr		:= self.getCellText(row, 2).trimBlanks.toUpper;

		//Start 13.07.2022 navak20 TFS 53862
		if terminal &lt;&gt; null then
			severity	:= terminal.allDamageSeverities[self.getCellText(row, 3).trimBlanks];		// 11.07.2022 navak20 TFS 53862		
		endif;
		quantityStr		 := self.getCellText(row, 4).trimBlanks;	// 15 Oct 2013	NDL	Par 32803
		damagePosition   := app.myRoot.allDamagePositionsByCode[posStr]; //Need to do it this way as the combo listObject changes each time a new damage instance is entered.
		repairedStr 	 := self.getCellText(row, 5).trimBlanks;	 		
		repaired 		 := repairedStr.asBooleanJMT();		//jlgka1	44287

		// 15 Oct 2013	NDL	Par 32803
		if quantityStr &lt;&gt; null and quantityStr.isInteger then
			quantityInt := quantityStr.Integer;
		else
			quantityInt := 0;			
		endif;

		if posStr = null and codeStr = null and severity = null and quantityInt = 0 then		// 13.07.2022 navak20 TFS 53862
			continue;
		endif;
		
		if posStr = null or codeStr = null or severity = null or quantityStr = null then		// 13.07.2022 navak20 TFS 53862
			_errors := _errors &amp; 'Incomplete damage information specified on row ' &amp; (row - fixed).String &amp; ' of the damage entry table. The row will be skipped. ';
			continue;
		endif;
		
		if damagePosition = null then
			_errors := _errors &amp; 'No valid damage position was found to match the description "' &amp; posStr &amp; '". The row will be skipped. ';
			continue;
		endif;
		
		damageCode := damageCodeDict[codeStr];
		if damageCode = null then
			_errors := _errors &amp; 'No damage code was found to match "' &amp; codeStr &amp; '". ';
			continue;
		endif;

		if severity = null then	// 13.07.2022 navak20 TFS 53862
			_errors := _errors &amp; 'Invalid damage severity specified on row ' &amp; (row - fixed).String &amp; ' of the damage entry table. The row will be skipped. ';
			continue;
		endif;
		
		if quantityInt = 0 or quantityInt &gt; 999999999 then // 22/11/2016 cnwma1 TFS 2944
			_errors := _errors &amp; 'Invalid damage quantity specified on row ' &amp; (row - fixed).String &amp; ' of the damage entry table. The row will be skipped. ';
			continue;
		endif;
		
		pxyDamageInstance := _damageInterface.createPxyDamageInstance( damageCode, 
																	   damagePosition,
																	   remarks,
																	   true,
																	   quantityInt,	// 15 Oct 2013	NDL	Par 32803
																	   severity,	// 13.07.2022 navak20 TFS 53862
																	   //repaired,		// jlgka1 TFS 41225		// July 1, 2022 navak20 TFS 53862
																	   _locationStr,	// 01 Mar 2016	NDL	TFS 1593
																	   null,					// July 1, 2022 navak20 TFS 53862
																	   null,					// July 1, 2022 navak20 TFS 53862
																	   null,					// July 1, 2022 navak20 TFS 53862
																	   null,					// July 1, 2022 navak20 TFS 53862
																	   null,					// July 1, 2022 navak20 TFS 53862
																	   app.actualTimeServer,	// July 1, 2022 navak20 TFS 53862
																	   null,					// July 1, 2022 navak20 TFS 53862
																	   null,					// July 1, 2022 navak20 TFS 53862
																	   null						// July 1, 2022 navak20 TFS 53862
																	   );
		
		damageTimeStamp := getTimeStampFromList(timeStampList, row - ONE);
		pxyDamageInstance.setTimeStamp(damageTimeStamp);	// TFS 44530
	endforeach;
	
epilog
	delete timeStampList;
end;</source>
        <Parameter name="_damageInterface" type="IF_DamageDetails" usage="input"/>
        <Parameter name="_errors" type="String" usage="output"/>
        <Parameter name="_locationStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTableFromDamageInterface" id="74ac7def-e77b-464d-a1db-32c07f1690f9">
        <updating/>
        <source>setTableFromDamageInterface(_damageInterface : IF_DamageDetails) updating;
/*
----------   ----------  --------------------------------------------------
Created:	21 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	damageInstance		: CM_DamageInstance;
	allDamageInstances 	: CM_DamageInstanceByDmgePos;
	
begin
	
	self.rows := self.fixedRows;
	
	if _damageInterface &lt;&gt; null then
		allDamageInstances:= _damageInterface.getDamageInstances;
	endif;
	
	// 24/08/2009 	cnwsh3 		CCMS SFW1868 PAR20300 - CSI Inspection Stop revmoval via CUSRES
	if allDamageInstances = null or allDamageInstances.isEmpty then
		self.addDamageRow(null);
	else
		
		foreach damageInstance in allDamageInstances do
			self.addDamageRow(damageInstance);
		endforeach;
	endif;
	
end;


</source>
        <Parameter name="_damageInterface" type="IF_DamageDetails"/>
    </JadeMethod>
    <JadeMethod name="validateDamageDetails" id="db911a26-5932-4968-95cf-48256865c9e7">
        <source>validateDamageDetails(_damageInterface : IF_DamageDetails) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
13 November 2024		jlizm1	Initial creation MTN 33161 Damage check details being lost when incomplete

*/

vars
	fixed			: Integer;
	numberRows		: Integer;
	row 			: Integer;
	posStr			: String;
	codeStr			: String;
	quantity		: Integer;
	severity		: CM_DamageSeverity;
	damageCode 		: CM_DamageDefinitionCode;
	damageCodeDict 	: CM_DamageDefinitionByCodeDict;
	damagePosition 	: CM_DamagePosition; 
	quantityStr 	: String;
	quantityInt 	: Integer;
	terminal 		: CM_Terminal;

begin
	on Exception do self.handleWarnings(exception, app.myPassport);
	if _damageInterface = null then
		return false;
	endif;
	
	numberRows 		:= self.rows;
	fixed 			:= self.fixedRows;
	terminal 		:= _damageInterface.getDamageTerminal;	
	damageCodeDict 	:= app.myRoot.allDamageDefinitionCodes;

	foreach row in fixed + 1 to numberRows do
		posStr		:= self.getCellText(row, 1).trimBlanks;
		codeStr		:= self.getCellText(row, 2).trimBlanks.toUpper;
		
		if terminal &lt;&gt; null then
			severity := terminal.allDamageSeverities[self.getCellText(row, 3).trimBlanks];
		endif;
		
		quantityStr := self.getCellText(row,4).trimBlanks;
		damagePosition := app.myRoot.allDamagePositionsByCode[posStr]; //Need to do it this way as the combo listObject changes each time a new damage instance is entered.
		
		if quantityStr &lt;&gt; null and quantityStr.isInteger then
			quantityInt := quantityStr.Integer;
		else
			quantityInt := 0;
		endif;
		
		if posStr = null and codeStr = null and severity = null and (quantityInt = 0 or quantityInt = 1) then
			// nothing entered, just ignore
			continue;
		endif;
		
		if posStr = null or codeStr = null or severity = null or quantityStr = null then
			app.raiseCMWarning1(Incomplete_Damage_Info, (row - fixed).String, null, null, null);
			continue;
		endif;
		
		if damagePosition = null then
			app.raiseCMWarning1(No_Valid_Damage_Pos, posStr, null, null, null);
			continue;
		endif;
		
		damageCode := damageCodeDict[codeStr];
		if damageCode = null then
			app.raiseCMWarning1(No_Damage_Code_Found, codeStr, null, null, null);
			continue;
		endif;

		if severity = null then
			app.raiseCMWarning1(Invalid_Damage_Severity, (row - fixed).String, null, null, null);
			continue;
		endif;
		
		if quantityInt = 0 or quantityInt &gt; 999999999 then
			app.raiseCMWarning1(Invalid_Damage_Quantity, (row - fixed).String, null, null, null);
			continue;
		endif;
	endforeach;
	
	if app.myPassport.hasErrorsOrWarnings then
		return false;
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_damageInterface" type="IF_DamageDetails"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="73821dc5-2de7-405d-a7bf-752862c0a4b3">
        <controlMethod name="CM_Table::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
/*
----------   ----------  --------------------------------------------------
Created:	25 October 2006 By cnwth2

Purpose:	

/****Changes

Date		Name	TFS#	Description
============================================================================
30/11/2018	jlgka1	41225	Add repaired attribute.	
============================================================================*/
vars
	row			: Integer;
begin
	inheritMethod(cntrl, persistCntrl);
	
	self.fixed3D	:= false;
	
	create self.myCmbPosition transient;
	self.form.addControl(self.myCmbPosition);
	self.myCmbPosition.automaticCellControl := true;
	
	create self.myCmbCode transient;
	self.form.addControl(self.myCmbCode);
	self.myCmbCode.automaticCellControl := true;
	
	create self.myCmbSeverity transient;
	self.form.addControl(self.myCmbSeverity);
	self.myCmbSeverity.automaticCellControl := true;
	
	create self.myCmbRepaired transient;
	self.form.addControl(self.myCmbRepaired);
	self.myCmbRepaired.automaticCellControl := true;
	
	if self.isInPainter then
		return;
	endif;
	self.height := self.MAX_TABLE_HEIGHT;
	self.tabKey := J_key_Tab;
	self.init();
end;





</source>
