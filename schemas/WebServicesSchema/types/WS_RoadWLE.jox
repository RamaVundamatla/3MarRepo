    <JadeMethod name="delete" id="c2f6ef7b-6dfb-472f-931f-f41d0d9c2d1f">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2017	jlger1	Initial creation 7521

*/

vars

begin
	delete self.cargoType;
	delete self.isoType;
	delete self.myOperator;
	delete self.myReserveSelection;
	delete self.myTrackedItem;
	delete self.myVoyage;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="787f89cc-820c-45dc-8e1e-1c4d245f064c">
        <updating/>
        <source>setProxyFromObject(_wle: CM_YardWLE) updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
22 Sep 2017 jlgsc8  TFS #7053 	an invalid cast was being made for reserveSelection
10 Nov 2015	cnwer1				Initial creation PAR
26 Jul 2016 cnwma1 	TFS #2235	JMT - Mobile Apps - Truck Loader &amp; UnLoader Issues
16 Mar 2017 cnwam15 			JMT-Truck Loader &amp; Unloader : Need operator and voyage to do advance search on WLE
16 Sep 2019	jlgka1 	TFS 46426	PEN - Truck Loader - search cargo with release request and consignee.
14 Jun 2021 cnwma1  ChangeRequest 51330: MTN - Euro Ports: Bulk Process - Move Amount in HHT
20 Feb 2025 navma1	MTN-34072	TPT| Remove Cargo Once the Truck has been Completed via the Handheld
============================================================================*/

vars
	operatorCode  : String;
	wleCargoType  : CM_CargoType;
	isoTypeCode	  : String;
	request		  : CM_Request;
	isRelByType   : Boolean;
	ti			  : CM_TrackedItem;
	voyage		  : CM_Voyage;
	reserveDetail : CM_ReserveDetail;
	consignee     : CM_ConsigneeConsignor;
	density		  : Decimal[14,4];
begin
	inheritMethod(_wle);
	
	ti		              := _wle.myTrackedItem;
	request				  := _wle.myRequest;
	isRelByType           := _wle.isReleaseByType;
	wleCargoType 		  := _wle.getCargoType();
	
	if request &lt;&gt; null then
		reserveDetail		  := request.myReserveDetail;
		voyage				  := request.getMyVoyageObject();
	endif;
	
	
	self.moveAmount		  := _wle.getMoveAmountDisplay(true);
	self.isReceipt		  := _wle.isReceipt;
	self.status			  := _wle.status;
	self.isAnyAmount	  := _wle.isAnyAmount();
	self.weight           := _wle.weight.asStringJMT(); 							 //14.06.2021 navma1 #51330
	self.quantity         := _wle.quantity;             							 //14.06.2021 navma1 #51330   
	self.deliveryNumber   := request.CM_YardRequest.deliveryNumber;
	
	if  _wle.weight &gt; 0 and  ti &lt;&gt; null then
		density := ti.getDensity();
		if  density &lt;&gt; null then	 												//14.06.2021 navma1 #51330
			self.volume := (_wle.weight / density).asStringJMT;	
		endif;
	endif;	
	
	if wleCargoType &lt;&gt; null then	
		create self.cargoType transient;
		self.cargoType.setProxyFromObject(wleCargoType);
		self.description := self.cargoType.description;		
	endif;
	
	isoTypeCode := request.getISOType();
	if isoTypeCode &lt;&gt; null and wleCargoType &lt;&gt; null  then
		create self.isoType transient;
		self.isoType.setProxyFromObject(wleCargoType.allISOTypes[isoTypeCode]);
	endif;
	
	operatorCode := request.getOperatorCode();
	if  operatorCode &lt;&gt; null then
		create self.myOperator transient;
		self.myOperator.setProxyFromObject(app.myRoot.allOperators[operatorCode]);
	endif;
		
	if voyage &lt;&gt; null then
		create self.myVoyage transient;
		self.myVoyage.setProxyFromObject(voyage);
	endif;
		
	if ti &lt;&gt; null and ti.isOnSite  then
		create self.myTrackedItem transient;
		self.myTrackedItem.setProxyFromObject(ti);	
	endif;
	
	if isRelByType and reserveDetail &lt;&gt; null and reserveDetail.isReserveSelection then
		create self.myReserveSelection transient;
		self.myReserveSelection.setProxyFromObject(reserveDetail.CM_ReserveSelection);
	endif;
	
	//jlgka TFS 46426 --&gt;
	if isRelByType and app.myPassport.myTerminal.getConfig(IgnoreHHFindCargoConsignee).Boolean   then
		consignee := request.getConsignee();					//20.02.2025 navma1 #MTN-34072
		if consignee &lt;&gt; null then
			create self.myConsignee transient;
			self.myConsignee.setProxyFromObject(consignee);
		endif;
	endif;
	//jlgka TFS 46426 &lt;--
epilog

end;</source>
        <Parameter name="_wle" type="CM_YardWLE"/>
    </JadeMethod>
</Class>
