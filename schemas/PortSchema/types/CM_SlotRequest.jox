    <JadeMethod name="updateForRelease" id="c86891f7-f70a-4067-9eba-12735981d1bd">
        <updating/>
        <source>updateForRelease(	_ti: CM_TrackedItem input;
					_totalQuantity : Integer) updating;

/*
Date				Who		Reason
04 November 2009	cnwar2	Initial creation #21489

*/
vars

begin
	if _ti = null then
		return;
	endif;
	
	if self.myBulkReleaseReserveDetail = null then
		return;
	endif;
	
	if not (self.myJob.isRelease
	and self.isLoad
	and self.myJob.isKindOf(CM_VoyageJob)) then
		return;
	endif;
	
	_ti.setBulkReleaseReleased(self.myBulkReleaseReserveDetail.myReserveHeader, self, _totalQuantity);

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_totalQuantity" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="ddb0709c-4822-41d1-9b05-8b26b7437cd6">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     06 June 2002 cnsrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpSlotController	: CM_SlotController;
	aSlotRequest : CM_SlotRequest;
begin

	tmpSlotController := self.mySlotController;
	if tmpSlotController = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Slot_Controller), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Slot_Controller), null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	exclusiveLock(tmpSlotController);
	
	// The user is only allowed 1 OPEN slot request at a time.
	// a slot request is deemed closed when the job is complete
	// if there are other slot requests and any of them are open then error
	if self.isDischarge then

		aSlotRequest := tmpSlotController.mySlotRequestDischarge;
		if  aSlotRequest &lt;&gt; null and aSlotRequest &lt;&gt; self 
		 // PAR 16415 CCMS 1029
		// PAR 21746 and not (aSlotRequest.fortyBack or aSlotRequest.isBackend) then // PAR 11242 - if re working a 40, the original discharge in the back end has not job, we do not put back ends in jobs.
		and not (aSlotRequest.getAttrIsBackend()) then // PAR 21746

			if aSlotRequest.myJob = null then
				app.raiseCMException3(ERR_SLOT_REQUEST_DEFINED,tmpSlotController.getFullId,"Discharge","Job Not Created", null, null);
				return;
			//elseif aSlotRequest.myJob.isJobComplete = false then
			elseif not aSlotRequest.isComplete then // CNWMC5 - PAR #31218
				app.raiseCMException3(ERR_SLOT_REQUEST_DEFINED,tmpSlotController.getFullId,"Discharge",aSlotRequest.myJob.jobId, null, null);
				return;
			endif;
		endif;
	else
		aSlotRequest := tmpSlotController.mySlotRequestLoad;
		if  aSlotRequest &lt;&gt; null 
		// PAR 11242 - if re working a 40, the original discharge in the back end has not job, we do not put back ends in jobs.
		// PAR 16415 CCMS 1029
		// PAR 21746 and not (aSlotRequest.fortyBack or aSlotRequest.isBackend) then 
		and not (aSlotRequest.getAttrIsBackend()) then // PAR 21746
			if aSlotRequest.myJob = null then
				app.raiseCMException3(ERR_SLOT_REQUEST_DEFINED,tmpSlotController.getFullId,"Load","Job Not Created", null, null);
				return;
			elseif not aSlotRequest.isComplete then // PAR 30985
			// PAR 30985 elseif aSlotRequest.myJob.isJobComplete = false then
				app.raiseCMException3(ERR_SLOT_REQUEST_DEFINED,tmpSlotController.getFullId,"Load",aSlotRequest.myJob.jobId, null, null);
				return;
			endif;
		endif;
	endif;
	self.validateMe(); // 722B testing
	
end;</source>
    </JadeMethod>
