    <JadeMethod name="addToolbarControls" id="08cfe812-23e7-4eb5-a598-0c0e2017920e">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24th Jan 2024 	navra1  TFS 62081 - CUX | Auto-setdown of cargo that doesn't require a machine move

*/

vars
	frm				: CMUI_Toolbar;
begin	
	inheritMethod();
	frm := self.frmToolbar;

	frm.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnEditItem, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	self.frmType.borderStyle := Frame.BorderStyle_None;
	frm.addFrame(self.frmType, CMUI_Toolbar.Control_Alignment_Left);
	
	frm.positionToolbarControls();
	frm.visible := true;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
