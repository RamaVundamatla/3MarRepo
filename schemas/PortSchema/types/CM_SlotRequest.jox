    <JadeMethod name="setProxyFiftyThreeFooter" id="53f6096a-1a20-4dc1-886c-f7ba8fa82701">
        <updating/>
        <source>setProxyFiftyThreeFooter(_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		22 May 2008 By Andrew Bishop cnwab1
//
// Purpose:		this should only be used to create teh front end of a 53.
//					we give total flexibility when creating 53s so the front end of the 
//					colour coding does not have to be in the forward bay.
//
// ---------------------------------------------------------------------------
vars
	aftSlot : CM_SlotRequest;
begin
//	if self.mySlotController &lt;&gt; null then
//		if self.mySlotController.myBayVoyage.isForwardBay() then
			self.is53 := true;
			self.fortyFront := false;
			self.fortyBack := false;
			self.is30 := false;
			self.is45 := false;
			self.isBackend := false;
//		endif;
//	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyForCreate" id="a3dcd187-d887-495c-b483-3e422cd71405">
        <updating/>
        <source>setProxyForCreate(_slotController : CM_SlotController; _moveType : Integer; _isLoad : Boolean; _cargoType : CM_CargoType; _dischargePort : CM_Port) updating;
// ---------------------------------------------------------------------------
// Created:     02 June 2002 by cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
begin
	if _slotController = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_slotController', null, null);
		return;
	endif;

	self.setMoveType(_moveType);
	self.isLoad := _isLoad;

	// Do this check AFTER setting moveType above as the
	// error seting uses moveTypeString
	if (_isLoad and _moveType = DISCHARGE_MOVETYPE) or
	   ((not _isLoad) and _moveType = LOAD_MOVETYPE) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid _isLoad (' &amp; _isLoad.String &amp;
					') for _moveType (' &amp; self.moveTypeString &amp; ')');
		return;
	endif;
	
	self.ordinalDeck := _slotController.ordinalDeck;
	self.ordinalCell := _slotController.ordinalCell;
	self.ordinalTier := _slotController.ordinalTier;
	self.mySlotController := _slotController;
	self.setPxyCargoType(_cargoType);
	self.setPxyDischargePort(_dischargePort);
end;</source>
        <Parameter name="_slotController" type="CM_SlotController"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_dischargePort" type="CM_Port"/>
    </JadeMethod>
    <JadeMethod name="setProxyForCreateVA" id="6269f5ce-ebe3-4d52-b283-ec309e2a6e99">
        <updating/>
        <source>setProxyForCreateVA(_slotController : CM_SlotController; _moveType : Integer; _isLoad : Boolean; _voyAlloc : CM_VoyageAllocation) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 December 2009	cnwas3	Initial creation

*/

vars
	voyAlloc : CM_VoyageAllocation;
begin

	if _slotController = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_slotController', null, null);
		return;
	endif;

	self.setMoveType(_moveType);
	self.isLoad := _isLoad;
	
	if (_isLoad and _moveType = DISCHARGE_MOVETYPE) or
	   ((not _isLoad) and _moveType = LOAD_MOVETYPE) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid _isLoad (' &amp; _isLoad.String &amp;
					') for _moveType (' &amp; self.moveTypeString &amp; ')');
		return;
	endif;
	self.ordinalDeck := _slotController.ordinalDeck;
	self.ordinalCell := _slotController.ordinalCell;
	self.ordinalTier := _slotController.ordinalTier;
	self.mySlotController := _slotController;
	
	
	if _voyAlloc &lt;&gt; null then	
			self.allAllocations.clear(); // do not purge
			self.allAllocations.add(_voyAlloc);		
			self.useVoyageAllocations := true; // PAR 25629
	endif;

end;</source>
        <Parameter name="_slotController" type="CM_SlotController"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_voyAlloc" type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="setProxyForDoorDirection" id="4ef049a2-d712-4795-a0de-40e938f7ddf9">
        <updating/>
        <source>setProxyForDoorDirection(_direction:Integer) updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.doorsDirection := _direction;
	//epr TFS 7006 29/9/17
	if self.doorsDirection = TI_DOORSDIRN_FWD then	
		self.motorDirection := Motor_Aft;
	elseif self.doorsDirection =  TI_DOORSDIRN_AFT then
		self.motorDirection := Motor_Forward;
	else 
		self.motorDirection := Motor_Null;
	endif;
end;</source>
        <Parameter name="_direction" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxyForEDI" id="e0a9672f-a85a-4589-8f9d-4091565cb6a2">
        <updating/>
        <source>setProxyForEDI(_theEdiTI : CM_EDIStowAdviceTI; _slot: CM_SlotController) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	realSlotReq		: CM_SlotRequest;
	workedDT		: TimeStamp;
	aPort			: CM_Port;
	aPortCode		: String;
	isoType			: CM_ISOType;
	cmdtyCode,msg	: String;
	cmdty			: CM_Commodity;
	ediSR			: CM_EDIStowAdviceTI;
	theBay			: CM_BayVoyage;
	isForty,
	noLength		: Boolean;
	cargoType 		: CM_CargoType; //cnwas3 PAR 24273
begin
	ediSR := _theEdiTI;
	
	isoType := app.myRoot.allISOTypes[ediSR.isoType];

	if isoType = null then
		if ediSR.isoType = null then
			noLength := true;
		else
			if ediSR.isoType[1:1] = "4" then
				msg := "assuming 40 ft";
				isForty := true;
			elseif ediSR.isoType[1:1] = "2" then
				msg := "assuming 20 ft";
				isForty := false;
			else
				noLength := true;
			endif;
			app.raiseCMWarning3(ERR_INVALID_ISOTYPE, ediSR.isoType, ediSR.stowageId, msg, 'isoType', ediSR, self);
		endif;
		if noLength then
			app.raiseCMException3(ERR_INVALID_ISOTYPE, "null", 'the item in position', ediSR.stowageId, 'isoType', ediSR);
			return;	
		endif;
	else
		isForty := (isoType.is40ftLong or isoType.is45ftLong);
	endif;
	
//	self.slotDefn := _slot.mySlotDefnVoyage;
	
	self.myCargoType := ediSR.myCargoType;
	cargoType := self.getAttrCargoType();	//cnwas3 PAR 24273
	if cargoType &lt;&gt; null then	//cnwas3 PAR 24273	
		self.cargoType := cargoType.id;	//cnwas3 PAR 24273
	endif;
	

	aPortCode := ediSR.dischargePort.trimBlanks;
	
	if aPortCode = null then
		aPortCode := self.myTerminal.getConfig(PortDestCode).String.trimBlanks;
	endif;
	
	if aPortCode.length &gt; 3 then
		self.dischargePort := aPortCode[aPortCode.length-2:end];
	else
		self.dischargePort := aPortCode;
	endif;
	
	//self.myDischargePort := app.myRoot.allPorts[aPortCode];
	self.myDischargePort := app.myRoot.allPorts[aPortCode];
	
	cmdtyCode := ediSR.commodity.trimBlanks;
	self.commodity := cmdtyCode;
	
	cmdty := app.myRoot.allCommodities[cmdtyCode];
	
	if cmdty &lt;&gt; null then
		self.myCommodityGroup := cmdty.myCommodityGroup;
	endif;

	self.overDimension := false;
	self.hazardous := (not ediSR.imCodes.isEmpty);
	self.unavailable := false;
	self.empty := (ediSR.fullOrMT = "E");
	
	if isoType &lt;&gt; null then
// PAR7496 AKB2004FEB			self.reefer := (ediSR.temperature &lt;&gt; NULL_TEMPERATURE) and isoType.isPorthole;
		self.power := (ediSR.temperature &lt;&gt; NULL_TEMPERATURE) and isoType.isIntegral;
		self.highCubed := isoType.is9ft6High;
		self.halfHeight := isoType.isHalfHeight;
	else
		self.power := ediSR.temperature &lt;&gt; NULL_TEMPERATURE;
	endif;

	if self.getAttrPowerRequired() then
		self.waterCooled := (ediSR.cooledType = ContainerWaterCooled);
	endif;
/*	
	if isoType.is40ftLong then
		self.fortyBack := _slot.myBayVoyage.isAftBay;
		self.fortyFront := not _slot.myBayVoyage.isAftBay;
	
	else
		self.fortyBack := false;
		self.fortyFront := false;
	endif;
*/
	if isForty  then
		realSlotReq := self;
		theBay := _slot.myBayVoyage; // PAR 7899
		if theBay.bayType = BAY_TYPE_TRIPLE and theBay.isAftBay() and theBay.isForwardBay() then // PAR 7899
			self.fortyFront := true;
			self.fortyBack := not self.getAttrIs40(); // PAR 7899
		else
			self.fortyBack := theBay.isAftBay;
			self.fortyFront := not self.fortyBack; // PAR 7899 not realSlotReq.mySlotController.myBayVoyage.isAftBay;
		endif;
	else
		self.fortyBack := false;
		self.fortyFront := false;
	endif;

end;</source>
        <Parameter name="_theEdiTI" type="CM_EDIStowAdviceTI"/>
        <Parameter name="_slot" type="CM_SlotController"/>
    </JadeMethod>
    <JadeMethod name="setProxyForUpdate" id="6297ebae-50a0-4382-9ab8-fd9ab6035b4c">
        <updating/>
        <source>setProxyForUpdate(_doorsDirection,_motorDirection,_moveType,_numSeqPort,_numSeqStarBoard:Integer;
         _empty,_fixed,_halfHeight,_hazardous,_overDimension,_power,_sequenced,_unavailable,_waterCooled,_highCubed, _fortyFront, _fortyBack:Boolean;
         _dischargePort : CM_Port; _commodity : CM_CommodityGroup;_cargoType : CM_CargoType) updating;
// PAR7496 AKB2004FEB	removed reefer attribute
// ---------------------------------------------------------------------------
// Created:     02 June 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	realSlotReq 	: CM_SlotRequest;
	theBay 			: CM_Bay;
	commodityGroup 	: CM_CommodityGroup; //cnwas3 PAR 24273
begin

	self.setPxyCargoType(_cargoType);
	self.setPxyDischargePort(_dischargePort);
/*
	self.myCommodity := _commodity;
	if self.myCommodity &lt;&gt; null then
		self.commodity := self.myCommodity.code;
	endif;
*/
	self.myCommodityGroup := _commodity;
	commodityGroup := self.getAttrCommodityGroup();		//cnwas3 PAR 24273
	if commodityGroup &lt;&gt; null then						//cnwas3 PAR 24273
		self.commodity := commodityGroup.code;			//cnwas3 PAR 24273
	endif;

	self.setMoveType(_moveType);
	self.highCubed := _highCubed;
	self.doorsDirection := _doorsDirection;
	self.motorDirection := _motorDirection;
	self.empty := _empty;
	self.halfHeight := _halfHeight;
	self.hazardous := _hazardous;
	self.overDimension := _overDimension;
	self.power := _power;
// PAR7496 AKB2004FEB		self.reefer := _reefer;
	self.unavailable := _unavailable;
	self.waterCooled := _waterCooled;
	
	self.fixed := _fixed;
	self.numSeqPortCustom := _numSeqPort;
	self.numSeqStarboardCustom := _numSeqStarBoard;

	realSlotReq := self.pxyGetRealObject;
	
	self.fortyFront := _fortyFront;
	self.fortyBack := _fortyBack;
	
end;</source>
        <Parameter name="_doorsDirection" type="Integer"/>
        <Parameter name="_motorDirection" type="Integer"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_numSeqPort" type="Integer"/>
        <Parameter name="_numSeqStarBoard" type="Integer"/>
        <Parameter name="_empty" type="Boolean"/>
        <Parameter name="_fixed" type="Boolean"/>
        <Parameter name="_halfHeight" type="Boolean"/>
        <Parameter name="_hazardous" type="Boolean"/>
        <Parameter name="_overDimension" type="Boolean"/>
        <Parameter name="_power" type="Boolean"/>
        <Parameter name="_sequenced" type="Boolean"/>
        <Parameter name="_unavailable" type="Boolean"/>
        <Parameter name="_waterCooled" type="Boolean"/>
        <Parameter name="_highCubed" type="Boolean"/>
        <Parameter name="_fortyFront" type="Boolean"/>
        <Parameter name="_fortyBack" type="Boolean"/>
        <Parameter name="_dischargePort" type="CM_Port"/>
        <Parameter name="_commodity" type="CM_CommodityGroup"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="setProxyFortyFiveFootFrontend" id="cf935fa5-538e-46fa-8818-d82b59cb2b6a">
