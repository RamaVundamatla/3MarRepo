    <JadeMethod name="getDisplayStringForAttribute" id="6091c4cb-927d-45f1-a61a-f8cfac2983f6">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
19 July 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	if _attrName = ETRow_XmlHeight then
		return self.height.asStringJMT;
	elseif _attrName = ETRow_XmlLength then
		return self.length.asStringJMT;
	elseif _attrName = ETRow_XmlNum then
		return self.number.asStringJMT;
	elseif _attrName = ETRow_XmlTwist then
		return self.twistlock.asStringJMT;
	elseif _attrName = ETRow_XmlVer then
		return self.ver.asStringJMT;
	elseif _attrName = ETRow_XmlWeight then
		return self.weight.asStringJMT;
	elseif _attrName = ETRow_XmlXPos then
		return self.xPos.asStringJMT;
	elseif _attrName = ETRow_XmlYPos then
		return self.yPos.asStringJMT;
	elseif _attrName = ETRow_XmlLocn then
		return self.location.asStringJMT;
	else

		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationController" id="f0a5670f-8078-4b32-b7e3-b386a961e598">
        <source>getLocationController(_mach : CM_Machine) : CM_LocationsController;
/*

Purpose:			


Return Value:		


Date		Who		Reason
24 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	loc : CM_LocationsController;
	foundHeight : Integer;
	terminal : CM_Terminal;
	ta : CM_TerminalArea;
begin
	if self.location = null then
		return null;
	endif;
	if _mach = null then
		return null;
	endif;
	terminal:=_mach.myTerminal;
	if terminal &lt;&gt; null then
		//if not terminal.getConfig(UseRTGGPSLocation).Boolean then
			terminal.findLocationFromString(self.location.trimBlanks, false, loc, foundHeight);
		/*else
		//not sure of the method here
			ta := terminal.getTAFromClassString(self.location,CM_RTGArea);
			if ta &lt;&gt; null then
				loc:=ta.CM_RTGArea.getLCFromGPSLiebherr(xPos,yPos, self.length);
			endif;		
		endif;*/
	endif;
	return loc;
epilog

end;</source>
        <Parameter name="_mach" type="CM_Machine"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getTerminal" id="c9faec8d-3660-44d0-ae64-ab80deffeab5">
        <source>getTerminal() : CM_Terminal;
/*

Purpose:			


Return Value:		


Date		Who		Reason
28 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self.myMachine &lt;&gt; null then
		return self.myMachine.myTerminal;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="isTwistLockClosed" id="f380192d-b1a6-4878-931f-04b2231ad898">
        <source>isTwistLockClosed() : Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
28 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	return self.twistlock = TL_CLOSED;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTwistLockOpen" id="c9bf11d5-9e1a-4a37-bac0-18dbb00c57ca">
        <source>isTwistLockOpen() : Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
28 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	return self.twistlock = TL_OPEN;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="c640b49c-2c2b-41dc-9064-7cc5e1067105">
        <updating/>
        <source>setForCreate(	_proxy  : SelfType;
				_machine : CM_Machine input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
24 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.ver :=_proxy.ver;
	self.height :=_proxy.height;
	self.location:=_proxy.location;
	self.number:=_proxy.number;
	self.length:=_proxy.length;
	self.weight:=_proxy.weight;
	self.xPos:=_proxy.xPos;
	self.yPos:=_proxy.yPos;
	self.twistlock:=_proxy.twistlock;
	self.myMachine := _machine;

epilog

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="9b880600-1af2-47ca-8d65-272da53027b9">
        <updating/>
        <source>setProxy(	_version : Integer input;
			_height	: Real input;
			_length : Integer input;
			_xPos,
			_yPos : Real input;
			_locn : String input;
			_twl : Character input;
			_weight : Real input;
			_number : Integer input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
24 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.ver:=_version;
	self.height:=_height;
	self.length :=_length;
	self.xPos :=_xPos;
	self.yPos:= _yPos;
	self.location :=_locn;
	self.twistlock:=_twl;
	self.weight:=_weight;
	self.number:=_number;
	

epilog

end;</source>
        <Parameter name="_version" type="Integer" usage="input"/>
        <Parameter name="_height" type="Real" usage="input"/>
        <Parameter name="_length" type="Integer" usage="input"/>
        <Parameter name="_xPos" type="Real" usage="input"/>
        <Parameter name="_yPos" type="Real" usage="input"/>
        <Parameter name="_locn" type="String" usage="input"/>
        <Parameter name="_twl" type="Character" usage="input"/>
        <Parameter name="_weight" type="Real" usage="input"/>
        <Parameter name="_number" type="Integer" usage="input"/>
    </JadeMethod>
