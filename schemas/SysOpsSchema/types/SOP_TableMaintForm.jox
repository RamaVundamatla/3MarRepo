//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/08/2016	cnwdap1		Initial creation TFS #1832 TSW Changes
//
vars

begin
	self.tblData4.text := textbox.text;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtPassword_change" id="760a4b91-7d2c-4b0e-8138-10d8774e3af0">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtPassword_change(textbox: TextBox input) updating;
//
// 28 May 2013		cnwrs1	ccms 1336 Par 31389 separate BGP EmailRequest to seperate read and send
//
vars

	msg : String;

begin
	
	//07 Jul 2017	NDL	TFS 5235
/*	if textbox.text.length &gt; 64 then
		msg := app.getErrorString2( ERR_STRING_TO_LONG, app.getErrorString(Password), '64');
		app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only );
	endif; */
//	self.enteredPassword := textbox.text[1:64];
	//25 Aug 2021	NDL	TFS 51632 - no longer truncate here
	self.enteredPassword := textbox.text;
	if self.enteredPassword &lt;&gt; null then
		tblInput2.text := '&lt;set&gt;';
	else
		tblInput2.text := null;
	endif;

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtTZShortID_change" id="ba1eaa85-f755-4b4e-8859-307dd7d7145e">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtTZShortID_change(textbox: TextBox input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23 June 2016	cnwdap1		Initial creation PAR #
//
vars

begin
	self.tblInput2.text := textbox.text;
	self.myCurrentTableItem.SOPTM_Terminal.myIntFaceConfig.timeZoneShortID := textbox.text;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
