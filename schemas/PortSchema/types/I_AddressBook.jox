    <JadeMethod name="entryObject" id="94370803-6d11-4b38-934a-cac4dcd0fb05">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>entryObject(set_:Boolean; value_:IDispatch io) updating, mapping;
	// 

vars
	v : IDispatch;

begin
	if not set_ then
		_jadeActiveXProperty('EntryObject', '', set_, v);
		if v = null then
			value_ := null;
		else
			value_ := v.IDispatch._morph(IDispatch).IDispatch;
		endif;
	else
		_jadeActiveXProperty('EntryObject', '', set_, value_);
	endif;
end;
</source>
        <Parameter name="set_" type="Boolean"/>
        <Parameter name="value_" type="IDispatch" usage="io"/>
    </JadeMethod>
