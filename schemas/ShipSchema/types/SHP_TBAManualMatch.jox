    <JadeMethod name="setCurrentTBA" id="a9b992dd-bb47-4f41-bb84-054b40d94656">
        <updating/>
        <source>setCurrentTBA(_tba : CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2019	jlgab1	Initial creation

*/

vars
	haz : CM_TIHazard;
	info : String;
begin
	self.cmbTBAItems.listIndex := -1;
	self.myTBAItem := _tba;
	
	if _tba = null then
		return;
	endif;
	
	if self.cmbTBAItems.findObject(_tba) &lt; 1 then
		return;
	endif;
	
	self.cmbTBAItems.listObject := _tba;
	
	
	self.txtBooking.text := _tba.bookingReference;
	self.txtCommodity.text := _tba.commodity;
	
	haz := _tba.allTIHazards.first.CM_TIHazard;
	self.txtHazardDetails.text := "";
	if haz &lt;&gt; null then
		self.txtHazardDetails.text := haz.getTableDisplay(false, true);
	endif;
	self.txtISOType.text := _tba.isoTypeDesc;
	self.txtOperator.text := _tba.operatorDescription;
	self.txtOverDimension.text := _tba.isOverDimensions.getYesNo();
	
	self.txtReeferDetails.text :="";
	if _tba.myReeferProperties&lt;&gt; null then
		self.txtReeferDetails.text := _tba.myReeferProperties.getDisplayDetails(false);
	endif;
	self.txtTotalWeight.text := _tba.totalWeight.asStringJMT();
	

	info := _tba.getPlannedLocationDisplay();
	self.lblDescriptionTBA.caption := "";
	if info &lt;&gt; null then
		self.lblDescriptionTBA.caption := app.getErrorString(Planned_location) &amp; " " &amp; _tba.myVoyage.code &amp; " " &amp;  info;
	endif;
	
	self.doQuery();

epilog

end;</source>
        <Parameter name="_tba" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="e7733257-c991-4d6b-b32a-4fd6971bc38c">
        <updating/>
        <source>setProxy(_pxyti : CM_TrackedItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2019	jlgab1	Initial creation

*/

vars
	haz			: CM_Hazard;
	clonedHaz	: CM_TIHazard;
	packTempReading : CM_PackTempReading;
begin
	if _pxyti = null then
		return;
	endif;
	
	if self.chkBooking.value 
	and self.myTBAItem.bookingReference &lt;&gt; null then
		_pxyti.setBookingReference(self.myTBAItem.bookingReference);
	endif;
	
	if self.chkCommodity.value
	and self.myTBAItem.commodity &lt;&gt; null then
		_pxyti.setCommodity(self.myTBAItem.commodity);
	endif;
	
	if self.chkHazardDetails.value 
	and self.myTBAItem.allTIHazards.isNotEmpty() then
		
		foreach haz in self.myTBAItem.allTIHazards do
			create clonedHaz transient;
			clonedHaz.setForCreate(haz,_pxyti,app.myPassport);
		endforeach;
	endif;
	
	if self.chkISOType.value
	and self.myTBAItem.getISOType() &lt;&gt; null then
		_pxyti.setISOType(self.myTBAItem.getISOType());
	endif;
	
	if self.chkOperator.value
	and self.myTBAItem.myOperator &lt;&gt; null then
		_pxyti.setMyOperator(self.myTBAItem.myOperator);
	endif;
	
	if self.chkOverDimension.value then
		_pxyti.setIsOverDimensions(self.myTBAItem.isOverDimensions);
	endif;
	
	if self.chkReeferDetails.value then
	
		if self.myTBAItem.myReeferProperties &lt;&gt; null then 
			delete _pxyti.myReeferProperties; // transient leak. We are about to replace the reefer properties with a clone from the TBA
			_pxyti.setPxyReeferProperties(self.myTBAItem.myReeferProperties.cloneSelf(true));
			packTempReading := self.myTBAItem.getPackTempDetails();
			if packTempReading &lt;&gt; null then
				_pxyti.myReeferProperties.setPackedDetails(packTempReading.dateTime.date,
															packTempReading.dateTime.time,
															packTempReading.tempC,
															packTempReading.tempF	
															);
			endif;
		endif;
	endif;
	
	if self.chkTotalWeight.value then
		_pxyti.setTotalWeightWithoutTrans(self.myTBAItem.totalWeight);
	endif;
epilog

end;</source>
        <Parameter name="_pxyti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="23375665-44c7-4884-b5cf-9702ad5a5249">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
/*
Purpose:	TFS 45590		
Date				Who			Reason
NOVEMBER 2019		JLGAB1 initial creation
*/

vars
	rowIdx : Integer;
begin

	self.doQuery();
	
	if self.tblData.findObjectInRow(self.myCurrentVoyage, rowIdx) then
		self.tblData.selectRow(rowIdx, false);
	endif;
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setUpdateSelected" id="7e073bb5-50e6-45b7-b87f-2f0914f543ec">
        <source>setUpdateSelected(_update : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2019	jlgab1	Initial creation

*/

vars
	ti : CM_TrackedItem;
begin
	self.chkBooking.value := _update;
	self.chkCommodity.value := _update;
	self.chkHazardDetails.value := _update;
	self.chkISOType.value := _update;
	self.chkOperator.value := _update;
	self.chkOverDimension.value := _update;
	self.chkReeferDetails.value := _update;
	self.chkTotalWeight.value := _update;

	if _update then
		self.btnSelectAll.tag := "ON";
		self.btnSelectAll.caption := app.getErrorString(SHP_UnSelect_Al); 
	else
		self.btnSelectAll.tag := "OFF";
		self.btnSelectAll.caption := app.getErrorString(SelectAll); 
	endif;
	
		
epilog

end;</source>
        <Parameter name="_update" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="eed4b917-48d5-46ca-8877-f883311eecf7">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2019	jlgab1	Initial creation

*/

vars
	queryTBA : CM_TrackedItem;
begin
	queryTBA := self.myTBAItem;
	self.getXMLSettingsForSetup();

	inheritMethod();

	self.setNavigatorHeading(self.caption);
	self.initTableData();

	

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.tblData.userInputEnabled := false;
		self.chkBooking.enabled := false;
		self.chkCommodity.enabled := false;
		self.chkHazardDetails.enabled := false;
		self.chkISOType.enabled := false;
		self.chkOperator.enabled := false;
		self.chkOverDimension.enabled := false;
		self.chkReeferDetails.enabled := false;
		self.chkTotalWeight.enabled := false;
		self.tblData.userInputEnabled := false;
		
		self.btnMatch.enabled := false;
	endif;
	
	self.initComboTBA();
	
	self.setCurrentTBA(queryTBA);

	self.doQuery();

	self.mnuContext.visible := false;
	self.setUpdateSelected(true);

epilog

end;</source>
    </JadeMethod>
