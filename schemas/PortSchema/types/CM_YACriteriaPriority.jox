    <JadeMethod name="createDataValue" id="4e705f97-460b-4d52-817e-3258a1d848e4">
        <source>createDataValue(pCriteriaTypeObj:CM_YACriteriaType; pDataValue:Any):CM_YAData protected;
/* --------------------------------------------------------------------------------
// Created:		23 March 2005 by cnwdad1
//
// Purpose:		Create a Data Value object for the receiver.
//
// Parameters:	pCriteriaTypeObj - A reference to the Criteria Type object.
//				pDataValue - A primitive value, used where object data values
//					are not used, or a set of object data values.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
03 May 2012 	cnwer1	PAR 29524 - 1215 exception 
05 Apr 2017		cnwma1 	TFS #3890:STWO - Add 'in transit' to Cargo allocations
07 Sep 2020		jlgdap1	TFS 49953 MTN Satellite View Criteria Search doesn't work for some criteria
07 Mar 2024     navrv30 Bug 61941: FR | 53383 - Release Request by Type - Cargo Group (part II)
28 Aug 2024		navdap1	TFS 65510 PEN - Weight Flexi field no longer allows use of decimals
27 May 2025		navdap1	MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
30 Jun 2025 	navma1 MTN-34090  MTN | Dead lock (1081) on CM_TIByIdCargoTypeRelseDictRev
*/
vars
	dataValueObj	: CM_YAData;
	objectSet		: ObjectSet;
	valueArray		: IntegerArray;
	obj 			: Object;								
	rackStatus 		: CMIF_FlatRackStatus;			
	status, 
	strvalue 		: String;						
	int 			: Integer;
	locnMoveDir 	: CMIF_LocnMoveDirection; 
	dataValue 		: String;		
begin
	
	if self.isTransient then
		if pCriteriaTypeObj.isBooleanType() then
			create dataValueObj as CM_YADataBoolean transient;
			dataValueObj.CM_YADataBoolean.setProxy(pDataValue.Integer);
		elseif pCriteriaTypeObj.isDateRangeType then						// MTN-34981
			create dataValueObj as CM_YADataDateRange transient;
			dataValueObj.CM_YADataDateRange.setProxy(pDataValue.String);
			//07 Mar 2024     navrv30 Bug 61941
		elseif pCriteriaTypeObj.type.isOneOf(YACriteriaType_Diameter, YACriteriaType_Grammage, YACriteriaType_RollingLength) then
				create dataValueObj as CM_YADataString transient;
				dataValueObj.CM_YADataString.setProxy(pDataValue.String);
				dataValueObj.CM_YADataString.setCriteriaType(pCriteriaTypeObj);
		elseif pCriteriaTypeObj.isStringType() then
			// TFS 65510 strip thousands separators from flexi weight strings
			if pDataValue.isKindOf(String) then
				dataValue := pDataValue.String;
				self.stripThousandsSeparators(dataValue);
			endif;
			// TFS 65510 end of this bit
			create dataValueObj as CM_YADataString transient;
			if pDataValue.isKindOf(String) then
			//	dataValueObj.CM_YADataString.setProxy(pDataValue.String);			// TFS 65510
				dataValueObj.CM_YADataString.setProxy(dataValue.String);			// TFS 65510
				dataValueObj.CM_YADataString.setCriteriaType(pCriteriaTypeObj);
			else
				dataValueObj.CM_YADataString.setProxy(null);
			endif;
		elseif pCriteriaTypeObj.isIntendedRelModeType then		// 23/02/2011 cnwmh5 #26912
				if pDataValue.isKindOf(IntegerArray) then
				create dataValueObj as CM_YADataInteger transient;
				dataValueObj.CM_YADataInteger.setProxy(pDataValue.IntegerArray);
			else
				create dataValueObj as CM_YADataPattern transient;
				dataValueObj.CM_YADataPattern.setProxy(pDataValue.String);
				dataValueObj.CM_YADataPattern.setCriteriaType(pCriteriaTypeObj);
			endif;
		elseif pCriteriaTypeObj.isTransitStatusType then	 //05/04/2017 cnwma1 TFS #3890	
				if pDataValue.isKindOf(IntegerArray) then
				create dataValueObj as CM_YADataInteger transient;
				dataValueObj.CM_YADataInteger.setProxy(pDataValue.IntegerArray);
			else
				create dataValueObj as CM_YADataPattern transient;
				dataValueObj.CM_YADataPattern.setProxy(pDataValue.String);
				dataValueObj.CM_YADataPattern.setCriteriaType(pCriteriaTypeObj);
			endif;
		elseif pCriteriaTypeObj.isTransportModeType() then
			if pDataValue.isKindOf(IntegerArray) then
				create dataValueObj as CM_YADataInteger transient;
				dataValueObj.CM_YADataInteger.setProxy(pDataValue.IntegerArray);
			else
				create dataValueObj as CM_YADataPattern transient;
				dataValueObj.CM_YADataPattern.setProxy(pDataValue.String);
				dataValueObj.CM_YADataPattern.setCriteriaType(pCriteriaTypeObj);
			endif;
		// TFS 49953 start
		elseif pCriteriaTypeObj.isFlatRackStatusType then
			if pDataValue.isKindOf(String) then
				create dataValueObj as CM_YADataPattern transient;
				dataValueObj.CM_YADataPattern.setProxy(pDataValue.String);
				dataValueObj.CM_YADataPattern.setCriteriaType(pCriteriaTypeObj);
			elseif pDataValue.isKindOf(ObjectSet) then
				foreach obj in pDataValue.ObjectSet do
					rackStatus := obj.CMIF_FlatRackStatus;
					if status = null then
						status := rackStatus.status;
					else
						status := status &amp; Comma &amp; rackStatus.status;
					endif;
				endforeach;
				create dataValueObj as CM_YADataPattern transient;
				dataValueObj.CM_YADataPattern.setProxy(status);
				dataValueObj.CM_YADataPattern.setCriteriaType(pCriteriaTypeObj);
				
			//19 Nov 2020	NDL	TFS 50347
			elseif pDataValue.isKindOf(IntegerArray) then
				foreach int in pDataValue.IntegerArray do
					if int.isOneOf( TI_DOORSDIRN_ENDUP, TI_DOORSDIRN_ENDDOWN ) then
						if status = null then
							status := app.flatRackEndsEnumToString(int);
						else
							status := status &amp; Comma &amp; app.flatRackEndsEnumToString(int);
						endif;
					endif;
				endforeach;
				create dataValueObj as CM_YADataPattern transient;
				dataValueObj.CM_YADataPattern.setProxy(status);
				dataValueObj.CM_YADataPattern.setCriteriaType(pCriteriaTypeObj);
				
			elseif pDataValue.isKindOf(Integer) then	//23 Nov 2020	NDL	TFS 49953
				int := pDataValue.Integer;
				if int.isOneOf( TI_DOORSDIRN_ENDUP, TI_DOORSDIRN_ENDDOWN ) then
					if status = null then
						status := app.flatRackEndsEnumToString(int);
					else
						status := status &amp; Comma &amp; app.flatRackEndsEnumToString(int);
					endif;
				endif;	
				create dataValueObj as CM_YADataPattern transient;
				dataValueObj.CM_YADataPattern.setProxy(status);
				dataValueObj.CM_YADataPattern.setCriteriaType(pCriteriaTypeObj);
				
			endif;
		// TFS 49953 end
		
		// TFS 51219 START
		elseif pCriteriaTypeObj.isLocnMoveDirType then
			if pDataValue.isKindOf(String) then
				create dataValueObj as CM_YADataPattern transient;
				dataValueObj.CM_YADataPattern.setProxy(pDataValue.String);
				dataValueObj.CM_YADataPattern.setCriteriaType(pCriteriaTypeObj);
			endif;	
		// TFS 51219 END
		else
			if pDataValue.isKindOf(ObjectSet) then
				create dataValueObj as CM_YADataObjects transient;
				dataValueObj.CM_YADataObjects.setProxy(pDataValue.ObjectSet);
			else
				create objectSet transient;
				self.resolvePattern(pDataValue.String, objectSet, true);
				if not objectSet.isEmpty then
					create dataValueObj as CM_YADataObjects transient;
					dataValueObj.CM_YADataObjects.setValue(objectSet);
				else
				
					create dataValueObj as CM_YADataPattern transient;
					dataValueObj.CM_YADataPattern.setProxy(pDataValue.String);
					dataValueObj.CM_YADataPattern.setCriteriaType(pCriteriaTypeObj);
				endif;
			endif;
		endif;
		
	else
		if pCriteriaTypeObj.isBooleanType() then
			create dataValueObj as CM_YADataBoolean;
			dataValueObj.CM_YADataBoolean.setValue(pDataValue);
		elseif pCriteriaTypeObj.isDateRangeType then
			create dataValueObj as CM_YADataDateRange;						// MTN-34981
			dataValueObj.CM_YADataDateRange.setProxy(pDataValue.String);
		elseif pCriteriaTypeObj.isStringType() then
			// TFS 65510 strip thousands separators from flexi weight strings
			dataValue := pDataValue.String;
			self.stripThousandsSeparators(dataValue);
			// TFS 65510 end of this bit
			create dataValueObj as CM_YADataString;
			//dataValueObj.CM_YADataString.setValue(pDataValue);			// TFS 65510
			dataValueObj.CM_YADataString.setValue(dataValue);				// TFS 65510
			dataValueObj.CM_YADataString.setCriteriaType(pCriteriaTypeObj);
		elseif pCriteriaTypeObj.isIntendedRelModeType then		// 23/02/2011 cnwmh5 #26912
			if pDataValue.isKindOf(IntegerArray) then
				create dataValueObj as CM_YADataInteger; // 02/05/12 cnwer1 PAR 29524
				dataValueObj.CM_YADataInteger.setValue(pDataValue.IntegerArray);
			else
				create valueArray transient;
				self.resolveIntendedRelModePattern(pDataValue.String, valueArray);
				if not valueArray.isEmpty then
					create dataValueObj as CM_YADataInteger;
					dataValueObj.CM_YADataInteger.setValue(valueArray);
				else
					create dataValueObj as CM_YADataPattern;
					dataValueObj.CM_YADataPattern.setValue(pDataValue.String);
					dataValueObj.CM_YADataPattern.setCriteriaType(pCriteriaTypeObj);
				endif;
			endif;
		elseif pCriteriaTypeObj.isTransitStatusType then		 //05/04/2017 cnwma1 TFS #3890
			if pDataValue.isKindOf(IntegerArray) then
				create dataValueObj as CM_YADataInteger; 
				dataValueObj.CM_YADataInteger.setValue(pDataValue.IntegerArray);
			else
				create valueArray transient;
				self.resolveTransitStatusPattern(pDataValue.String, valueArray);
				if not valueArray.isEmpty then
					create dataValueObj as CM_YADataInteger;
					dataValueObj.CM_YADataInteger.setValue(valueArray);
				else
					create dataValueObj as CM_YADataPattern;
					dataValueObj.CM_YADataPattern.setValue(pDataValue.String);
					dataValueObj.CM_YADataPattern.setCriteriaType(pCriteriaTypeObj);
				endif;
			endif;
		elseif pCriteriaTypeObj.isTransportModeType() then
		
			if pDataValue.isKindOf(IntegerArray) then
				create dataValueObj as CM_YADataInteger;
				dataValueObj.CM_YADataInteger.setValue(pDataValue);
			else
				create valueArray transient;
				self.resolveTransportModePattern(pDataValue.String, valueArray);
				if not valueArray.isEmpty then
					create dataValueObj as CM_YADataInteger;
					dataValueObj.CM_YADataInteger.setValue(valueArray);
				else
					create dataValueObj as CM_YADataPattern;
					dataValueObj.CM_YADataPattern.setValue(pDataValue.String);
					dataValueObj.CM_YADataPattern.setCriteriaType(pCriteriaTypeObj);
				endif;
			endif;
		//19 Nov 2020	NDL	TFS 50146
		elseif pCriteriaTypeObj.isFlatRackStatusType then
			if pDataValue.isKindOf(String) then
				create dataValueObj as CM_YADataPattern;
				dataValueObj.CM_YADataPattern.setValue(pDataValue.String);
				dataValueObj.CM_YADataPattern.setCriteriaType(pCriteriaTypeObj);
			elseif pDataValue.isKindOf(ObjectSet) then
				foreach obj in pDataValue.ObjectSet do
					rackStatus := obj.CMIF_FlatRackStatus;
					if status = null then
						status := rackStatus.status;
					else
						status := status &amp; Comma &amp; rackStatus.status;
					endif;
				endforeach;
				create dataValueObj as CM_YADataPattern;
				dataValueObj.CM_YADataPattern.setValue(status);
				dataValueObj.CM_YADataPattern.setCriteriaType(pCriteriaTypeObj);	
			elseif pDataValue.isKindOf(IntegerArray) then
				foreach int in pDataValue.IntegerArray do
					if int.isOneOf( TI_DOORSDIRN_ENDUP, TI_DOORSDIRN_ENDDOWN ) then
						if status = null then
							status := app.flatRackEndsEnumToString(int);
						else
							status := status &amp; Comma &amp; app.flatRackEndsEnumToString(int);
						endif;
					endif;
				endforeach;
				create dataValueObj as CM_YADataPattern;
				dataValueObj.CM_YADataPattern.setValue(status);
				dataValueObj.CM_YADataPattern.setCriteriaType(pCriteriaTypeObj);	
			elseif pDataValue.isKindOf(Integer) then	//23 Nov 2020	NDL	TFS 49953
				int := pDataValue.Integer;
				if int.isOneOf( TI_DOORSDIRN_ENDUP, TI_DOORSDIRN_ENDDOWN ) then
					if status = null then
						status := app.flatRackEndsEnumToString(int);
					else
						status := status &amp; Comma &amp; app.flatRackEndsEnumToString(int);
					endif;
				endif;
				create dataValueObj as CM_YADataPattern;
				dataValueObj.CM_YADataPattern.setValue(status);
				dataValueObj.CM_YADataPattern.setCriteriaType(pCriteriaTypeObj);	
			endif;
			
		// TFS 51219 START
		elseif pCriteriaTypeObj.isLocnMoveDirType then
			if pDataValue.isKindOf(String) then
				create dataValueObj as CM_YADataPattern;
				dataValueObj.CM_YADataPattern.setValue(pDataValue.String);
				dataValueObj.CM_YADataPattern.setCriteriaType(pCriteriaTypeObj);
				
			elseif pDataValue.isKindOf(ObjectSet) then
				foreach obj in pDataValue.ObjectSet do
					locnMoveDir := obj.CMIF_LocnMoveDirection;
					if status = null then
						status := locnMoveDir.status;
					else
						status := status &amp; Comma &amp; locnMoveDir.status;
					endif;
				endforeach;
				create dataValueObj as CM_YADataPattern;
				dataValueObj.CM_YADataPattern.setValue(status);
				dataValueObj.CM_YADataPattern.setCriteriaType(pCriteriaTypeObj);
				
			elseif pDataValue.isKindOf(IntegerArray) then
				foreach int in pDataValue.IntegerArray do
					strvalue := app.locnMoveDirEnumToString(int);
					if strvalue &lt;&gt; "" then
						if status = null then
							status := strvalue;
						else
							status := status &amp; Comma &amp; strvalue;
						endif;
					endif;
				endforeach;
				create dataValueObj as CM_YADataPattern;
				dataValueObj.CM_YADataPattern.setValue(status);
				dataValueObj.CM_YADataPattern.setCriteriaType(pCriteriaTypeObj);
				
			elseif pDataValue.isKindOf(Integer) then
				int := pDataValue.Integer;
				strvalue := app.locnMoveDirEnumToString(int);
				if strvalue &lt;&gt; "" then
					if status = null then
						status := strvalue;
					else
						status := status &amp; Comma &amp; strvalue;
					endif;
				endif;
				create dataValueObj as CM_YADataPattern;
				dataValueObj.CM_YADataPattern.setValue(status);
				dataValueObj.CM_YADataPattern.setCriteriaType(pCriteriaTypeObj);
				
			endif;	
		// TFS 51219 END
		else
			if pDataValue.isKindOf(ObjectSet) then
				create dataValueObj as CM_YADataObjects;
				dataValueObj.CM_YADataObjects.setValue(pDataValue);
			else
				create objectSet transient;
				self.resolvePattern(pDataValue.String, objectSet, true);
				if not objectSet.isEmpty then
					create dataValueObj as CM_YADataObjects;
					dataValueObj.CM_YADataObjects.setValue(objectSet);
				else
					create dataValueObj as CM_YADataPattern;
					dataValueObj.CM_YADataPattern.setValue(pDataValue.String);
					dataValueObj.CM_YADataPattern.setCriteriaType(pCriteriaTypeObj);
				endif;
			endif;
		endif;
		
	endif;
	
	return dataValueObj;
epilog
	delete objectSet;
	delete valueArray;
end;</source>
        <access>protected</access>
        <Parameter name="pCriteriaTypeObj" type="CM_YACriteriaType"/>
        <Parameter name="pDataValue" type="Any"/>
        <ReturnType type="CM_YAData"/>
    </JadeMethod>
    <JadeMethod name="getListDisplay" id="a2219117-1450-4c76-9d96-a50c42039d7a">
        <source>getListDisplay():String;
// --------------------------------------------------------------------------------
// Created:		04 March 2005 by cnwdad1
//
// Purpose:		Returns a display string for the receiver, to show in a listbox.
//
// Parameters:	None
//
// Returns:		The receiver's description.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	on Exception do self.xInvalidObjectDisplayHandler(exception);
	
	if self.myYAData = null then	
		return "No data found for criteria";	// This should not happen in normal situations
	endif;
	
	return self.myYACriteriaType.getDescriptionWithData(self.myYAData);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="6213035c-2a50-4dae-93cb-568d498dc688">
        <source>getMyTerminal() : CM_Terminal abstract;</source>
        <abstract/>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getTableDisplay" id="f97949f6-ad5f-4957-a315-0030630d9f18">
        <source>getTableDisplay(): String;
// --------------------------------------------------------------------------------
// Created:		16 March 2005 by cnwdad1
//
// Purpose:		Returns a tab-delimited display string for the receiver, to show in
//				a table control.
//
// Parameters:	None
//
// Returns:		The receiver's description.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	//return self.myYACriteriaType.getTypeName() &amp; Tab &amp;
	return self.myYACriteriaType.description &amp; Tab &amp;	 //09 Oct 2013	NDL	Par 32456
		   self.code &amp; Tab &amp; 
		   self.myYACriteriaType.getDataDisplay(self.myYAData) &amp; Tab &amp;
		   self.priorityValue.String;
		   
		  
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTransient" id="92a72c3e-8469-46cf-bf8b-c6898357c43b">
        <source>getTransient():CMIF_YACriteriaPriority;
// --------------------------------------------------------------------------------
// Created:		22 March 2005 by cnwdad1
//
// Purpose:		Creates a transient representation of the receiver, and returns a
//				reference to it.
//
// Parameters:	None
//
// Returns:		A reference to the transient object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	transientObj	: CMIF_YACriteriaPriority;
	
begin
	create transientObj transient;
	transientObj.setReferences(self);
	
	return transientObj;
end;</source>
        <ReturnType type="CMIF_YACriteriaPriority"/>
    </JadeMethod>
    <JadeMethod name="isValueUsed" id="260c733d-2c5c-4679-83e9-08bd27d3add4">
        <source>isValueUsed(pAllValues:Any):Boolean;
// --------------------------------------------------------------------------------
// Created:		13 June 2005 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether specific data values
//				have already been used.
//
// Parameters:	pAllValues - This will be an array of values, the Type of which will
//					depend upon the Type of the data value.
//
// Returns:		True if one of the values is used, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myYAData.isValueUsed(pAllValues);
end;</source>
        <Parameter name="pAllValues" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isYAKioskCriteria" id="aaa9c6aa-edbb-4917-a1ff-e2c2635c9762">
