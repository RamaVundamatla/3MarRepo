    <JadeMethod name="getAllGateAreas" id="8cf696f9-1661-4657-8fdc-d5ea2ead321b">
        <source>getAllGateAreas(_coll :CM_ObjectSet input);
// ---------------------------------------------------------------------------
// Created:     13 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/10/2009	cnwcs5		par 20800 - fix exception with deleted gate
// ---------------------------------------------------------------------------
vars
	gate			:CM_Gate;
	area			:Object;
	coll			:CM_ObjectSet;
	invalidObject	:Boolean;
begin
	on Exception do app.handleDeletedObject (exception, gate, invalidObject);	// par 20800
	
	create coll transient;
	foreach gate in self.myRoadOpController.allGates do
		// interested in any vehicles in-transit-to any p-gate area
		gate.CM_Gate.getPGateAreas_IN (coll); 
		
		if invalidObject then								// par 20800
			self.myRoadOpController.allGates.remove (gate);	// par 20800
			invalidObject := false;							// par 20800
			continue;										// par 20800
		endif;												// par 20800
		
		foreach area in coll do
			if area.CM_GateArea.laneCount = 0 then
				continue;
			endif;
			_coll.addNoDuplicates (area, false);
		endforeach;
		
		coll.clear;
	endforeach;
epilog
	delete coll;
end;</source>
        <Parameter name="_coll" type="CM_ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllVehicles" id="be26fcae-307f-46b4-a6e9-b3722f1c0ff4">
        <source>getAllVehicles()protected;
/*
Purpose:			
Return Value:		

Date			Who		Reason
15 August 2006	cnwer1	Initial creation - PAR#xxxx
11/08/2009		cnwcs5	ccms 1016 - changed for new gate configuration stuff
02/09/2009		cnwcs5	ccms 1061 - remove old VTA handling
17/03/2015		cnwmh5	Transient Leaks
10 June 2022 	navhl20 TFS 53058 MTN - Job List in Road Operations screen not filtered out by Gate
01 Feb 2022     navma1	Bug 56382: GPHA -- Error 1090 on opening Road Operations Screen
*/
vars
	coll		: CM_ObjectSet;
	obj			: Object;
	gateArea	: CM_GateArea;
	lc			: CM_LocationsController;
	vehicleM	: CM_VehicleMachine;
	operator	: CM_Operator;
	operArr		: CM_OperatorArray;
	area		: CM_TerminalArea;
	icArea		: CM_InterchangeArea;
	roadJob     : CM_RoadJob;
begin
	create coll transient;

	// interested in any vehicles curretly in a p-gate lane which is not closed
	// and in an inward gate lane
	self.getAllGateAreas (coll);
	
	foreach obj in coll do
		gateArea := obj.CM_GateArea;
		
		if gateArea.laneCount = 0 then
			// include in pre-gate if any there
			continue;
		endif;
		
		foreach lc in gateArea.allLocationsControllers do
			if not lc.isLaneController then
				continue;
			endif;
			if lc.CM_LaneController.isUnavailable or
				lc.CM_LaneController.vehicleDirection &lt;&gt; CM_LaneController.Is_In_Lane then
				continue;
			endif;
			
			//Start 21 June 2022 	navhl20 TFS 53058
			create operArr transient;
			self.getOperators(operArr);
			foreach vehicleM in lc.CM_LaneController.allVehicleMachines do
				roadJob := vehicleM.CM_Vehicle.getCurrentRoadJob();					//01.02.2023 navma1 #56382
				if roadJob &lt;&gt; null then
					operator := roadJob.myOperator;
					if roadJob.myVehicle &lt;&gt; null then
						area := roadJob.myVehicle.getTerminalAreaForCurrentLocn();
					endif;
				
				endif;
				if area &lt;&gt; null then												//01.02.2023 navma1 #56382
					if  area.isKindOf (CM_InterchangeArea) then	
						if self.myRoadOpController.allOperators.size = operArr.size and self.myRoadOpController.allInterchangeAreas.includes(area.CM_InterchangeArea) then  
							self.allVehicles.addNoDuplicates (vehicleM, false);
						elseif self.myRoadOpController.allInterchangeAreas.includes(area.CM_InterchangeArea) and self.myRoadOpController.allOperators.includes(operator) then
							self.allVehicles.addNoDuplicates (vehicleM, false);
						endif;
					elseif  area.isKindOf (CM_CraneTransferArea) then	//31 Jan 2013	NDL	Par 31102 
						if self.myRoadOpController.allOperators.size = operArr.size and self.myRoadOpController.allInterchangeAreas.includes(area.CM_CraneTransferArea) then  
							self.allVehicles.addNoDuplicates (vehicleM, false);
						elseif self.myRoadOpController.allInterchangeAreas.includes(area.CM_CraneTransferArea) and self.myRoadOpController.allOperators.includes(operator) then
							self.allVehicles.addNoDuplicates (vehicleM, false);
						endif;
					else
						if area.allAssociatedInterchangeAreas.size = 0 then
							if self.myRoadOpController.allOperators.size = operArr.size then  
								self.allVehicles.addNoDuplicates (vehicleM, false);
							elseif self.myRoadOpController.allOperators.includes(operator) then
								self.allVehicles.addNoDuplicates (vehicleM, false);
							endif;
						endif;
						// not an interchange area
						foreach icArea in area.allAssociatedInterchangeAreas do
							if self.myRoadOpController.allOperators.size = operArr.size and self.myRoadOpController.allInterchangeAreas.includes(icArea) then  
								self.allVehicles.addNoDuplicates (vehicleM, false);
							elseif self.myRoadOpController.allInterchangeAreas.includes(icArea) and self.myRoadOpController.allOperators.includes(operator) then
								self.allVehicles.addNoDuplicates (vehicleM, false);
							endif;
						endforeach;
					endif;
				endif;
			endforeach;
			//lc.CM_LaneController.allVehicleMachines.copyNoDuplicates(self.allVehicles, false);
			//End 21 June 2022 	navhl20 TFS 53058
		endforeach;
	endforeach;
epilog
	delete coll;
	delete operArr;
end;</source>
        <access>protected</access>
    </JadeMethod>
