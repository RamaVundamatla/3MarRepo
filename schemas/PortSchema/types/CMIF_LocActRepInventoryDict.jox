<CollClass name="CMIF_LocActRepInventoryDict" id="f985a3d0-7006-4c0c-9efe-e9c0ac0590d4">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="CMIF_LocActRepInventoryLine"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <MemberKey>
        <property name="CMIF_LocActRepInventoryLine::myLocationsController"/>
    </MemberKey>
    <MemberKey>
        <property name="CMIF_LocActRepInventoryLine::myOperator"/>
    </MemberKey>
    <MemberKey>
        <property name="CMIF_LocActRepInventoryLine::myCargoType"/>
    </MemberKey>
    <MemberKey>
        <property name="CMIF_LocActRepInventoryLine::dateTime"/>
    </MemberKey>
    <JadeMethod name="addLocationActivity" id="955b4ddc-af37-4304-9e42-66bf29327406">
        <lockReceiver/>
        <updating/>
        <source>addLocationActivity( _la : CMEVT_LocationActivity ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

	existingPreviousLine : CMIF_LocActRepInventoryLine;
	newLine : CMIF_LocActRepInventoryLine;
	
	dateTime : TimeStamp;
	lcOut : CM_LocationsController;
	lcIn : CM_LocationsController;
	operator : CM_Operator;
	cargoType : CM_CargoType;
	
	balance : CMEVT_LocationActivity;
	prevBalance : CMEVT_LocationActivity;
	line : CMIF_LocActRepInventoryLine;

begin

	dateTime := _la.dateTime;

	if _la.mySourceLocation &lt;&gt; null then
		if _la.mySourceLocation.isActivityTrackingLocation then
			lcOut := _la.mySourceLocation;
		endif;
	endif; 
	if _la.myTargetLocation &lt;&gt; null then
		if _la.myTargetLocation.isActivityTrackingLocation then
			lcIn := _la.myTargetLocation;
		endif;
	endif;
	
	operator := _la.getOperator;
	cargoType := _la.getCargoType;

	if lcOut &lt;&gt; null then
		existingPreviousLine := self.getAtKeyLeq( lcOut, operator, cargoType, dateTime );
		if existingPreviousLine &lt;&gt; null then
			if existingPreviousLine.myLocationsController &lt;&gt; lcOut
			or existingPreviousLine.myOperator &lt;&gt; operator
			or existingPreviousLine.myCargoType &lt;&gt; cargoType
			then
				existingPreviousLine := null;
			endif;
		endif;
		
	// Currently don't need this, until she changes her mind again, and decides we don't want all that balance crap.
	//	if existingPreviousLine = null then
	//		balance := _la.myLocationBalance;
	//		if balance &lt;&gt; null then
	//			prevBalance := balance.myPrevBalance;
	//			if prevBalance &lt;&gt; null then
	//				create line transient;
	//				line.setFromLocationActivity( lcOut, prevBalance, null, operator, cargoType );
	//				self.add( line );
	//			endif;
	//		endif;
	//	endif;
		
		create line transient;
		line.setFromLocationActivity( lcOut, _la, existingPreviousLine, operator, cargoType );
		self.add( line );
		
	endif; 
	
	if lcIn &lt;&gt; null then
		existingPreviousLine := null;
		existingPreviousLine := self.getAtKeyLeq( lcIn, operator, cargoType, dateTime );
		if existingPreviousLine &lt;&gt; null then
			if existingPreviousLine.myLocationsController &lt;&gt; lcIn
			or existingPreviousLine.myOperator &lt;&gt; operator
			or existingPreviousLine.myCargoType &lt;&gt; cargoType
			then
				existingPreviousLine := null;
			endif;
		endif;
		
	//	if existingPreviousLine = null then
	//		balance := _la.myLocationBalance;
	//		if balance &lt;&gt; null then
	//			prevBalance := balance.myPrevBalance;
	//			if prevBalance &lt;&gt; null then
	//				create line transient;
	//				line.setFromLocationActivity( lcIn, prevBalance, null, operator, cargoType );
	//				self.add( line );
	//			endif;
	//		endif;
	//	endif;
		
		create line transient;
		line.setFromLocationActivity( lcIn, _la, existingPreviousLine, operator, cargoType );
		self.add( line );
		
	endif;


epilog

end;</source>
        <Parameter name="_la" type="CMEVT_LocationActivity"/>
    </JadeMethod>
</CollClass>
