    <JadeMethod name="setupEDIDataTypes" id="5fa937d3-fe18-4d35-a362-6af228ebf3eb">
        <source>setupEDIDataTypes()protected;
// ---------------------------------------------------------------------------
// Created:     27 April 2010 by cnwcs5:1
// Purpose:     Create dummy objects for use in data type multi select list box
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	coll	:IntegerArray;
	int		:Integer;		// status data type value
	status	:CM_Association;
begin
	self.allDummyEDIDataTypeObjects.purge;	// just in case
	
	create coll transient;
	
	self.myEDIControllerAgent.getAllEDIDataTypeValues (coll, false);
	
	foreach int in coll do
		if int = EDIDataType_Generic then
			continue;
		endif;
		// create a dummy status object for use in the multi select group box
		create status transient;
		status.setValue (int);	// code
		
		self.allDummyEDIDataTypeObjects.add (status);
	endforeach;
epilog
	delete coll;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupEDIStatus" id="2025d63a-b5da-4c17-8b79-9fd076c9652d">
        <source>setupEDIStatus()protected;
// ---------------------------------------------------------------------------
// Created:     22 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/04/2010	cnwcs5		ccms 1118 - enhanced edi form
// ---------------------------------------------------------------------------
vars
	coll	:IntegerArray;
	int		:Integer;	// status integer value
	status	:CM_Association;
begin
	self.allDummyEDIStatusObjects.purge;	// just in case
	
	create coll transient;
	
	self.myEDIControllerAgent.getAllEDIStatusValues (coll);
	
	foreach int in coll do
		// create a dummy status object for use in the multi select group box
		create status transient;
		status.setValue (int);	// code
		
		self.allDummyEDIStatusObjects.add (status);
	endforeach;
epilog
	delete coll;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d8fc6edc-5cc8-4b4d-abc3-4a2c9d8470bf">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     19 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 28/07/2010	cnwrl1		PAR 24415 - EDI Admin form does not handle deleted of EDI File Types.
// 12/10/2022 	navsj20		ChangeRequest 55084: EUP - EDI Administration Usability Requirements
// 04/10/2023	jlika1	TFS 60232 - EUP | FR 54871 - EDI Management for New EDI Types
// ---------------------------------------------------------------------------

vars
	comboVesselsBoxObj: CMUI_ComboVessels;	//12.10.2022	navsj20	TFS 55084
	idx: Integer;
begin
	self.staStatusBar.visible	:= true;
	self.usesQueryFrame 		:= true;
	self.toolbarStyle 			:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar 			:= true;
	self.useTableInfo 			:= false;
	self.useTableSorting 		:= true;

	self.initEDIAgents;
	
	inheritMethod();
	// START 26 Oct 2022 navvt20 TFS 55084
	self.cmbCargoOperator.initialise(false);
	self.cmbVesselName.isVesselComboByName := self.myTerminal.getConfig(VesselComboByName).Boolean;
	self.cmbVesselName.initialise(false);
	self.cmbReceiptTransMode.clear;
	self.cmbReceiptTransMode.addItem(Empty_String);
	idx := self.cmbReceiptTransMode.addItem(TI_TRANSMODE_ROAD_STR);
	self.cmbReceiptTransMode.itemData[idx] := TI_TRANSMODE_ROAD;
	idx := self.cmbReceiptTransMode.addItem(TI_TRANSMODE_RAIL_STR);
	self.cmbReceiptTransMode.itemData[idx] := TI_TRANSMODE_RAIL;
	idx := self.cmbReceiptTransMode.addItem(TI_TRANSMODE_SHIP_STR);
	self.cmbReceiptTransMode.itemData[idx] := TI_TRANSMODE_SHIP;
	// END 26 OCt 2022 navvt20 TFS 55084
	self.getXMLSettingsForSetup();
	self.initTableData (self.getEntTableDef);
	
	if self.frmQuery.visible then
		self.searcherShowHideControls (false);
		self.frmQuery.centreHorizontallyInParent();				// cnwrl1 03/06/2010 PAR 24299
		self.frmQuery.centreVerticallyInParent();				// cnwrl1 03/06/2010 PAR 24299
		self.txtQDateStart.setFocus;
	endif;
	
	self.myAssistant.comboBoxVoyageObject(self.cmbVoyageCode, null);
	
	// cnwrl1 28/07/2010 PAR 24415 - start of coding
	// Register the persistent CM_EDIFileTypeUser class for notification of a deletion.
	self.beginClassNotification( CM_EDIFileTypeUser, false, Object_Delete_Event, Response_Continuous, null );
	// cnwrl1 28/07/2010 PAR 24415 - end of coding
	
	self.setNavigatorHeading (self.caption);
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showEDIComparisonForm" id="32b25800-f78b-441a-8e7f-b0f948360f69">
        <source>showEDIComparisonForm(_table :CM_DataTable input)protected;
/*
Date		Who		Reason
29 Jul 2013	cnwcs5	CCMS POL 2221 / par 32094
// 05 Dec 2017	jlgrs1	TFS 8195 - SNO - EDI Release Comparison add support for ReleaseRequestMulti
*/
vars
	row		:Integer;
	obj		:Object;
	ediData	:CM_EDIData;
	form	:CMUI_EDICompareReleaseForm;
begin
	row := _table.row;
	self.fldQuery.topSheet := self.shtQuery1; // 1 Nov 2022 navvt20 TFS 55084
	if row &lt;= _table.fixedRows then
		return;
	endif;
	
	obj := _table.accessRow(row).itemObject;
	
	if obj.isKindOf (CM_EDIDataReleaseRequest) or
	   obj.isKindOf (CM_EDIDataRequestMultiLine) or	
	   obj.isKindOf (CM_EDIDataGateDoc) then
		ediData := obj.CM_EDIData;	
	else
		return;
	endif;
	
	if ediData = null then
		return;
	endif;
	
	form := app.loadForm (CMUI_EDICompareReleaseForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_EDICompareReleaseForm;
	
	form.myEDIData := ediData;
	
	form.show;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showHideLoadNewFile" id="cf43f7db-5129-488d-b756-47d175c1a011">
        <source>showHideLoadNewFile(_show :Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     28 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	existingType	:CM_EDIFileType;
	frame			:CMUI_MoveableFrame;
begin
	frame := self.frmLoadFile;
	
	if _show then
		//need to reload types as user defined type may be 
		//added or deleted 0- try to re-select existing if it exists
		existingType := self.cmbLoadAsType.listObject.CM_EDIFileType;
		
		self.myEDIAgent.loadEDIFileTypes_UserDefined(self.cmbLoadAsType, null, self.myEDIControllerAgent);
		
		if self.cmbLoadAsType.findObject(existingType) &gt; 0 then
			self.cmbLoadAsType.listObject := existingType;
		endif;
		
	endif;
	
	frame.parent := self;
	frame.centreHorizontallyInParent;
	frame.centreVerticallyInParent;
	frame.zOrder(1);
 	frame.visible := _show;
		
	self.loadFileShowHideControls (not _show);
end;</source>
        <access>protected</access>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showVerifyErrors" id="1d4d41d0-d72b-4444-97c3-05780915e4af">
        <source>showVerifyErrors(_msg, _title :String	)protected;
// ---------------------------------------------------------------------------
// Created:     29 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	form		: CMUI_EDIForm;
	passport	: CM_Passport;
	ediData 	: CM_EDIData;	//par 27392 13 Apr 2011
begin
	if app.msgBox (_msg, _title, MsgBox_Yes_No) = MsgBox_Return_Yes then
		// display the edi form
		// self.myEDIAgent.showEDIFormWithColl (coll, self.myMasterMenuAction, false);	

		
		form		:= self.doViewItem(ediData);	//par 27392 13 Apr 2011
		passport	:= app.myPassport;
		
		// not sure why we need to do this but it seems to get verify errors to display
		// something in the bowels of the edi form i suspect.
		form.doWindowEvents(0);
		
		if form &lt;&gt; null and passport &lt;&gt; null and ediData.allErrorWarnings.size &gt; 0 then
			form.showVerifyErrors(ediData);	//par 27392 13 Apr 2011
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_msg" type="String"/>
        <Parameter name="_title" type="String"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="9ad1de2e-b083-4bc3-bf9a-1246dc0adca4">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 22 May 2024 10:58:58.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014734, locale);
	btnBrowse.translateCaption(Xlat_0014735, locale);
	btnExtractNew.translateCaption(Xlat_0014736, locale);
	btnHideFileLoad.translateBubbleHelp(Xlat_0014739, locale);
