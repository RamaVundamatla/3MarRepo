<Class name="CMIF_RectangleResizer" id="4ff5965b-7a79-481b-b2af-c77897a05042">
    <superclass name="CMIF_RectangleManipulator"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmui"/>
    <JadeMethod name="doExtendLine" id="271b8473-99a9-487f-88c2-3085e4104e9c">
        <updating/>
        <source>doExtendLine(_firstPoint: Point; _secondPoint: Point; _currentX: Real; _currentY: Real): Point updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	xDiff, yDiff,xMseDiff, yMseDiff,theSlope : Real;
	pntX1,pntY1,pntX2,pntY2,currentX,currentY,newX,newY : Integer;
	newPoint : Point;
begin
	xMseDiff := (_currentX - self.originalX);
	yMseDiff := (_currentY - self.originalY);
	
	pntX1 := _firstPoint.x;
	pntY1 := _firstPoint.y;
	pntX2 := _secondPoint.x;
	pntY2 := _secondPoint.y;
	
	if pntY2 = pntY1 then
		newY := pntY2;
		newX := (pntX2 + xMseDiff).Integer;
	else
		theSlope := (pntX2 - pntX1) / (pntY2 - pntY1);
		if theSlope = 0 then
			return _secondPoint;
		endif;
		
		newX := (pntX2 + xMseDiff).Integer;
		newY := ((newX - pntX1) / theSlope).Integer + pntY1;
	endif;
	
	
	newPoint.set(newX,newY);
	return newPoint;
end;</source>
        <Parameter name="_firstPoint" type="Point"/>
        <Parameter name="_secondPoint" type="Point"/>
        <Parameter name="_currentX" type="Real"/>
        <Parameter name="_currentY" type="Real"/>
        <ReturnType type="Point"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="72991924-a574-470a-a532-c2808e1b3247">
        <updating/>
        <source>doResize(_currentX,_currentY : Real) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	cntX, cntY,pntX, pntY, idx : Integer;
	theRatio : Real;
	aPoint,newPoint, oPoint : Point;
begin

	newPoint := self.doExtendLine(self.centrePoint,self.originalMousePoint,_currentX,_currentY);
	
	pntX := newPoint.x;
	pntY := newPoint.y;
	cntX := self.centrePoint.x;
	cntY := self.centrePoint.y;
		
	theRatio := self.doGetRatio(cntX,cntY,self.originalX, self.originalY,pntX,pntY);
	
	self.newPoints.clear;
	foreach idx in 1 to self.originalPoints.size do
		aPoint := self.centredPoints[idx];
		oPoint := self.originalPoints[idx];
	
//		pntX := oPoint.x + (aPoint.x * theRatio).Integer;
//		pntY := oPoint.y + (aPoint.y * theRatio).Integer;
		pntX := self.centrePoint.x +  (aPoint.x * theRatio).Integer;
		pntY := self.centrePoint.y + (aPoint.y * theRatio).Integer;
		
		newPoint.set(pntX,pntY);
		self.newPoints.add(newPoint);
	endforeach;	
	
end;</source>
        <Parameter name="_currentX" type="Real"/>
        <Parameter name="_currentY" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doResizeOLD" id="483c1f38-f599-43fc-b8aa-7e6422ba1523">
        <updating/>
        <source>doResizeOLD(_currentX,_currentY : Real) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	cntX, cntY,pntX, pntY, idx : Integer;
	theRatio : Real;
	aPoint,newPoint, oPoint : Point;
begin

	self.newPoints.clear;
	// ### ONE
	newPoint := self.originalPoints[1];
	self.newPoints.add(newPoint);
	
	// ### TWO
	newPoint := self.doExtendLine(self.originalPoints[1],self.originalPoints[2],_currentX,_currentY);
	self.newPoints.add(newPoint);
	
	// ### THREE
	newPoint.set(_currentX.Integer,_currentY.Integer);
	newPoint := self.doExtendLine(self.centrePoint,self.originalMousePoint,_currentX,_currentY);
	self.newPoints.add(newPoint);

	// ### FOUR
	newPoint := self.doExtendLine(self.originalPoints[1],self.originalPoints[4],_currentX,_currentY);
//	newPoint.set(newPoint.x,self.originalPoints[4].y);
	self.newPoints.add(newPoint);

	// ### FIVE
	newPoint := self.originalPoints[1];
	self.newPoints.add(newPoint);
end;</source>
        <Parameter name="_currentX" type="Real"/>
        <Parameter name="_currentY" type="Real"/>
    </JadeMethod>
</Class>
