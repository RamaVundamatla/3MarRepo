    <JadeMethod name="setTableDataFromOrganiser" id="ec823026-ea4f-4cac-be1c-8b8d046805b4">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//20/07/2023	navkc1	Bug 58995: EUP - Inv Maint Credit Notes

*/

vars
	invoice : CM_Invoice;
	line	: String;
begin
	if _theTable = self.tblInvoiceResult then
		// If we have not seach for anything yet, don't do it.
		if _theTable.rows &lt;&gt; _theTable.fixedRows then
			self.doQuery();
		endif;
	elseif _theTable = self.tblInvoiceLink then
		_theTable.rows := _theTable.fixedRows;
		foreach invoice in self.allInvoicesToLink do
			line := invoice.getAttributeStringForDefArray(_theTable.allTblDataEntRows);
			_theTable.addItemObject(invoice, line);
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f09c4521-e4d3-46b1-a035-17af2f75b58b">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			Sets up the form

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
30 September 2022	navpw1	Initial creation TFS: 54565 (54384)
16 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type
29 May 2023  navmv20 Bug 58090: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 050.d
20/07/2023	navkc1	Bug 58995: EUP - Inv Maint Credit Notes
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
*/
vars
	theNarrRow 		: Integer;
	textHeight,
	narrHeight		: Integer;
	theTable 		: CM_EntryTable;
	
begin
	inheritMethod();

	if not app.defaultMdi then
		self.centreWindow;
	endif;
	
	self.frmToolbar.alignContainer	:= Frame.AlignContainer_Top; // this will make the dkcMain line up its top	
	self.toolbarStyle				:= self.ToolbarStyle_ShowNoHide;
	self.frmToolbar.priorityRight	:= true;
	self.showToolbar				:= true;
	
	self.frmMain.left			:= 0;
	self.frmMain.width			:= self.clientWidth - 2;
	self.frmMain.height			:= self.clientHeight - self.frmToolbar.clientHeight;
	self.frmMain.parentAspect	:= 3;
	
	self.fldMain.left			:= 0;
	self.fldMain.width			:= self.frmMain.clientWidth - 2;
	self.fldMain.height			:= self.frmMain.clientHeight - 10;
	self.fldMain.parentAspect	:= 3;
	
	//Resize tables
	self.resizeTable(self.tblBOL);
	self.resizeTable(self.tblBooking);
	self.resizeTable(self.tblCargo);
	self.resizeTable(self.tblCargoGroup);
	self.resizeTable(self.tblInvProperties);
	self.resizeTable(self.tblRelease);
	self.resizeTable(self.tblVoyage);
	
	//Set up Ent Table Defs
	self.initEntTables();
	
	//Hide Sheets
	self.shtBOL.visible := false;
	self.shtBooking.visible := false;
	self.shtCargo.visible := false;
	self.shtCargoGroup.visible := false;
	self.shtRelease.visible := false;
	self.shtVoyage.visible := false;
	self.shtPONumber.visible := false; // ### BUG 56925 07MAR2023 NAVAB1
	
	//29 May 2023  navmv20 Bug 58090- start
	if self.myTerminal.allWorkOrders.isEmpty then
		self.shtWorkOrder.visible := false;
	endif;
	
	
	//29 May 2023  navmv20 Bug 58090 - end
	//16/03/2023  navmv20 TFS 56128 Task 56129 - START
	if self.myTerminal.getConfig(InvShowAllSeparation).Boolean then
		self.showAllSeparations();
	endif;
	//16/03/2023  navmv20 TFS 56128 Task 56129 - END
	
// BUG 58106	self.setMyCaption();

	/*// 10/11/2023	navkc1 Bug 61004
	self.tblInvProperties.hideRowByName(ETRow_StartDate, false); //navtnr20 13-04-2023 55531
	self.tblInvProperties.hideRowByName(ETRow_StartTime, false);  //navtnr20 13-04-2023 55531
	*/
	//20/07/2023	navkc1	Bug 58995
	self.initLinkedInvoiceSheet();
	
	//14/08/2023	navkc1	Bug 59803
	theTable := self.tblInvProperties;
	
	theNarrRow := theTable.getRowByName(ETRow_Narration);
	if theNarrRow &gt; 0 then
		theTable.accessCell(theNarrRow,CM_EntryTable.ColumnValue).wordWrap := true;
	endif;
	
	self.txtNarr.text := null;
	
	if  theNarrRow &gt; 0 then
		textHeight := self.txtNarr.getTextHeightForWidth(self.txtNarr.text, self.txtNarr.width.Integer) + 10;
		narrHeight := textHeight;
		if textHeight &lt; 50 then
			narrHeight := 50;
		elseif textHeight &gt; 150 then
			narrHeight := 150;
		endif;
		theTable.accessRow(theNarrRow).height := narrHeight;
		self.txtNarr.height := narrHeight;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="showAllSeparations" id="4ea22db6-4baa-48f4-8909-9f37ae3ee243">
        <source>showAllSeparations();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
21 Aug 2023 navhl20 Bug 59906: FR | 54086 - Drop down menu for 'Cargo Group Specific' for Invoice/Credit note - Creation/update screens
11 Sep 2023 navhl20 ChangeRequest 59376: CPL - Invoice Generation Clocking (avg 25 secs)
*/

vars
	cargoTypeCol	: CM_CargoTypeSet;
begin

	if self.cmbVoyageInvProp.listCount &lt;= 1 then
		//self.doCmbVoyageBuild(self.cmbVoyageInvProp,true);						//11.9.2023 navhl20 #59376
		self.doCmbVoyageBuild(self.cmbVoyageInvProp, self.includeArchivedVoyages);	//11.9.2023 navhl20 #59376
		self.doCmbVoyageBuild(self.cmbVoyageGen, self.includeArchivedVoyages); // 10/11/2023	navkc1 Bug 61004
	endif;
		
	self.tblVoyage.disableRowByName(ETRow_ArrivalTS);
	self.tblVoyage.disableRowByName(ETRow_DepartureTS);
	self.tblVoyage.disableRowByName(ETRow_VoyageDesc);
	self.shtVoyage.visible := true;
	 
	if self.cmbCargoTypeInvP.listCount &lt;= 1 then
		create cargoTypeCol transient;
		self.myTerminal.getAllCargoTypes(cargoTypeCol,true);
		self.cmbCargoTypeInvP.listCollection( cargoTypeCol, false, 0); 
	endif;
	self.populateCargoOperLocns();
	
	// ### JIRA 33006 15OCT2024 NAVAB1
	self.populateCargoSubTypes(null);
	self.populateCargoCommodities(null);
		
	self.tblCargo.disableRowByName(ETRow_ReceivedDT);
	self.tblCargo.disableRowByName(ETRow_ReleaseDT);
		
	self.shtCargo.visible := true;
	
	if self.cmbBillOfLading.listCount() &lt; 1 then
		self.doCmbBolBuild();
	endif;
	self.shtBOL.visible := true;
	
	if self.cmbBooking.listCount() &lt; 1 then
		self.doCmbBookingBuild();
	endif;
	self.shtBooking.visible := true;
	
	if self.cmbCGType.listCount() &lt; 1 then
		self.doCmbCargoGroupTypeBuild();
		self.doCmbCargoGroupIdBuild(null);							//21.8.2023 navhl20 #59906
	endif;
	self.shtCargoGroup.visible := true;
	
	if self.cmbReleaseRequest.listCount() &lt; 1 then
		self.doCmbReleaseRequestBuild();
	endif;
	self.shtRelease.visible := true;
	
	//14/08/2023	navkc1	Bug 59803 - Dont need this as we are now always displaying PO in general sheet
	//self.shtPONumber.visible := true;
	//self.txtPONumber.text := "";
epilog

end;</source>
    </JadeMethod>
