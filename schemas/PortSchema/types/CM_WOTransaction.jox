    <JadeMethod name="hasCargoWorkOrderDetails" id="bd588055-2476-46f9-8c44-be1586b48358">
        <source>hasCargoWorkOrderDetails():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Mar 2023 navma1 ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task

*/

vars
	
begin
	if self.myWorkOrder = null then
		return false;
	endif;
	
	if self.myWorkOrderDetail = null then																	//08.02.2023 navma1 #56457 Task#56458
		return false;
	endif;
	
	if not self.myWorkOrder.isKindOf(CM_WorkOrderTI) then
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasTaskThatAllowsResources" id="9187a65e-bb1b-41c4-b424-ec580395a804">
        <source>hasTaskThatAllowsResources(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2023  navmv20 CR 57925 Task 57921: UI - WO Enquiry To Do Tasks

*/

vars
	taskDesc : CM_ToDoTaskDesc;
	myWodToDo : CM_WodToDo;
	show : Boolean;
	trnType : CM_TransactionType;
begin
	// ### TFS CR 54345 TASK 58281 01JUN2023 NAVAB1
	trnType := self.getTransactionType();
	if trnType &lt;&gt; null then
		return trnType.hasToDoResourcesConfigured();
	endif;

	if self.myWorkOrderDetail = null then
		return false;
	endif;
	
	if self.myWorkOrderDetail.isKindOf(CM_WodToDo) then
		taskDesc:=self.myWorkOrderDetail.CM_WodToDo.allToDoTasksDescs.first;
	endif;
	
	if taskDesc = null then
		return false;
	endif;

	show := not taskDesc.allResourceTypes.isEmpty;
	return show;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasTaskThatIsComplete" id="e5658dea-9d52-442d-8874-cf9b61f2389f">
        <source>hasTaskThatIsComplete(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2023  navmv20 CR 57925 Task 57921: UI - WO Enquiry To Do Tasks
 // ### TFS CR 54345 TASK 58281 16JUN2023 NAVAB1
*/

vars
	task : CM_ToDoTask;
	myWodToDo : CM_WodToDo;
begin

	if self.myToDoTask = null then
		return false;
	endif;
	
	return self.myToDoTask.status = STATUS_COMPLETE;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
