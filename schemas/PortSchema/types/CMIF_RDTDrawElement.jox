    <JadeMethod name="drawGridRightRowHeaderTopDown" id="064a8a5f-55f2-4faf-9471-08591f1533aa">
        <source>drawGridRightRowHeaderTopDown(_x1, _y1, _x2, _y2 : Real; _frame : Frame input; _scaleFactor : Real;  _isLandScape, _flipH, _flipV : Boolean; _mode : Integer; _isGapRow : Boolean) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21/06/2011	cnwdz2	Initial creation 27732
29 May 2012 cnwer1	PAR 29588
*/
vars
	lc 				: CM_LocationsController;
	gridLc			: CM_GridController;
	headerX, headerY,
	noAccessDrawX,
	lengthPixels	: Real;
	label        : String;
	labelTextHeight : Real;
	gridArea : CM_GridArea;
	forkLiftStack : CM_ForkLiftStack;
begin	
	if _frame = null then
		return;
	endif;
	
	lc := self.getLocationController();
	if lc = null or not lc.isKindOf(CM_GridController) then
		return;
	endif;
	gridLc := lc.CM_GridController;
	gridArea := gridLc.getMyTerminalArea.CM_GridArea;	
	//16/06/2011 cnwdz2 27732
	if gridArea.isKindOf(CM_ForkLiftStack) then
		forkLiftStack := gridLc.getMyTerminalArea.CM_ForkLiftStack;
	endif;
		
	if _isLandScape then
		lengthPixels := self.getSizeInPixels(self.widthFt, _scaleFactor);	
		label := gridLc.getRowLabel();
	else
		lengthPixels := self.getSizeInPixels(self.heightFt, _scaleFactor);	
		label := gridLc.getColumnLabel(true);
	endif;
	
	//08/10/2010 cnwdz2 par25671
	if lc.isGap() then
		if _isGapRow then
			lengthPixels := lc.getGapWidthPixels(lengthPixels);
		endif;
	endif;
	
	if _flipH then 
		headerX := _x2 + (_x2-_x1)/2;
	else
		headerX := _x1 + (_x2-_x1)/2;		
	endif;
	
	labelTextHeight := _frame.drawTextHeight(label);
	
	if _flipV then
		headerY := _y2 - lengthPixels/2 - labelTextHeight/2;
	else
		headerY := _y1 + lengthPixels/2 - labelTextHeight/2;
	endif;

	_frame.drawTextAlign := Frame.DrawTextAlign_Center;	
	_frame.drawTextAt(label, headerX, headerY, Black);
	//16/06/2011 cnwdz2 27732
	if forkLiftStack &lt;&gt; null and not _isLandScape and
	   // col lcs passed in are always for the top row because this is the bottom label row test is oppposite to the top col headings
		((not forkLiftStack.accessFront and gridLc.myGridRow.row = gridArea.allGridRows.size ) or
		(not forkLiftStack.accessBack and gridLc.myGridRow.row = 1  )) then
	 
		_frame.drawWidth := 3;
		if _flipH then 
			noAccessDrawX := _x2+1;
		else
			noAccessDrawX := _x1+1;
		endif;
		_frame.drawLine(noAccessDrawX,_y1,noAccessDrawX,_y2,Red);					
	endif;

end;</source>
