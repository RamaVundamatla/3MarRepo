    <JadeMethod name="hasNoMatchingCargo" id="1fabf9b3-9d9b-48db-a6af-365b07cd83c7">
        <source>hasNoMatchingCargo() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18/03/2021	navdap1		Initial creation TFS 50946 PRP Auto Delete of Yard Allocations
//
vars
	voyage : CM_Voyage;
	ti : CM_TrackedItem;
	onSiteIter, voyageIter, onShipIter : Iterator;
	agent : CM_YAAutoplanAgent;

begin
	create agent transient;
	onSiteIter := self.myTerminal.allOnsiteTIsByCargoTypeId.createIterator;
	while onSiteIter.next(ti) do
		if ti.testAgainstYardAllocation(self, null, agent, false) then
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Found ti " &amp; ti.getOidString &amp; " on site that matches", LogDEBUG);
			return false;
		endif;
	endwhile;
	
	voyageIter := self.myTerminal.allVoyagesByCode.createIterator;
	while voyageIter.next(voyage) do
		//jlier1 TFS 51963 5/10/21
		if voyage.status.isOneOf(Voyage_Status_Cancelled,Voyage_Status_VoyCancelled, Voyage_Status_Archived, Voyage_Status_Departed, Voyage_Status_Closed) then
			continue;
		endif;
		
		delete onShipIter;
		onShipIter := voyage.allOnshipTIsByCargoTypeId.createIterator;
		while onShipIter.next(ti) do
			if ti.testAgainstYardAllocation(self, null, agent, false) then
				app.writeLog(method.qualifiedName &amp; Tab &amp; "Found ti " &amp; ti.getOidString &amp; " on voyage " &amp; voyage.getOidString &amp; " that matches", LogDEBUG);
				return false;
			endif;
		endwhile;
	endwhile;
	
	return true;
epilog
	delete onSiteIter;
	delete voyageIter;
	delete onShipIter;
	delete agent;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasYardAllocationExpired" id="0631b1a7-2e95-488a-a493-4b04e6664e3f">
        <source>hasYardAllocationExpired() : Boolean;
// -------------------------------------------
// Created 03 May 2005 by cnwdvb1
// -------------------------------------------
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------
// 18/03/2021	navdap1		TFS 50946 PRP Auto Delete of Yard Allocations
vars


begin

	if self.expiryType = YAExpiryType_Never then
		return false;
	elseif self.expiryType = YAExpiryType_VoyageDepart then
		return self.haveVoyagesDeparted();
	elseif self.expiryType = YAExpiryType_WhenEmpty then
		return self.isAllocationEmpty();
	elseif self.expiryType = YAExpiryType_SpecifiedDate then
		return (self.expiryDate.isValid() and app.actualTimeServer().date &gt; self.expiryDate);		
	elseif self.expiryType = YAExpiryType_VoyageClear then	//29 Jun 2011	NDL	Par 27786
		return self.haveAnyAssocVoyagesDeparted();
	elseif self.expiryType = YAExpiryType_NoCargo then		// TFS 50946
		return self.hasNoMatchingCargo();					// TFS 50946
	else
		return false;
	endif;


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="haveAnyAssocVoyagesDeparted" id="fabdc2bd-5fa7-414a-b1f5-2dde1f165b6d">
        <source>haveAnyAssocVoyagesDeparted() : Boolean;

/*

Purpose:			Find any Yard Allocations set up to auto clear when the 
					their associated voyage departs that have an association with a 
					voyage that has departed.

Parameters:			

Return Value:		


Date		Who		Reason
29 June 2011	cnwndl1	Initial creation	Par 27786

*/

vars

	criteria	: CM_YACriteria;
	obj			: Object;
	hasVoyage	: Boolean;
	allObjects  : CM_ObjectSet;
begin

	if not self.expiryType = YAExpiryType_VoyageClear then
		return false;
	endif;

	foreach criteria in self.allCriteria do
		if criteria.myYACriteriaType.type = YACriteriaType_Voyage then
			create allObjects transient;
			criteria.myYAData.CM_YADataObjects.copyAllObjects(allObjects);
			foreach obj in allObjects do
				if obj.CM_Voyage.hasDeparted() then
					return true;
				endif;
			endforeach;
		endif;
	endforeach;
	
	return false;

epilog
	delete allObjects;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="haveVoyagesDeparted" id="5573ea37-06a5-484d-bbbe-d35dc4df40ee">
        <source>haveVoyagesDeparted() : Boolean protected;
// -------------------------------------------
// Created 03 May 2005 by cnwdvb1
// -------------------------------------------
vars

	criteria	: CM_YACriteria;
	obj			: Object;
	hasVoyage	: Boolean;
	allObjects  : CM_ObjectSet;
begin

	foreach criteria in self.allCriteria do
		if criteria.myYACriteriaType.type = YACriteriaType_Voyage then
			create allObjects transient;
			criteria.myYAData.CM_YADataObjects.copyAllObjects(allObjects);
			foreach obj in allObjects do
				hasVoyage := true;
				if not obj.CM_Voyage.hasDeparted() then
					return false;
				endif;
			endforeach;
		endif;
	endforeach;
	
	if hasVoyage then
		return true;
	endif;
	
	return false;

epilog
	delete allObjects;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
