    <JadeMethod name="displayVoyageCombo" id="eb9647a9-6f66-4a8b-9e1b-080d1a97cb6a">
        <source>displayVoyageCombo(_sheet : CMUI_Sheet input) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
//
vars
	voyage : CM_Voyage;

begin
	if self.myVoyage &lt;&gt; null then
		voyage := self.myVoyage;
	elseif self.myCurrentProxyTask &lt;&gt; null then
		voyage := self.myCurrentProxyTask.getMyVoyageObject;
	endif;
	self.lblVoyage.parent := _sheet;
	self.cmbVoyage.parent := _sheet;
	self.cmbVoyage.listIndex := self.cmbVoyage.findObject(voyage);
	self.cmbVoyage.enabled := false;
	
	//16 oct 2018	NDL	TFS 41412
	if _sheet = self.shtCargoRequest
	or _sheet = self.shtMarineI
	or _sheet = self.shtMarineD
	then
		self.lReqBy.caption := app.getErrorString( Occurs_On_Caption );
	else
		self.lReqBy.caption := app.getErrorString( Required_By_Caption );
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_sheet" type="CMUI_Sheet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="displayVoyageRequest" id="9bcb495c-0e31-4fbb-acab-e7e9b53ef0e6">
        <updating/>
        <source>displayVoyageRequest( _wodtl : CM_WodVoyageRequest ) updating, protected ;
/*
Purpose:	TFS 40029		
Date				Who			Reason
AUGUST 2018		CNWAB1		Initial creation
*/

vars

	voyageStatus : CM_VoyageStatus;
	wodVoyageCargoRequest : CM_WodVoyageCargoRequest;
	tmpTS: TimeStamp;
	port : CM_Port;
begin

	// display the voyage
	self.displayVoyageCombo(self.shtVoyageRequest);
	
	self.shtVoyageRequest.showMySheet();
	
	
	// ARRIVAL
	tmpTS := _wodtl.estimatedArrivalTS;
	if not tmpTS.isValid() then
		tmpTS := self.myVoyage.estimatedArrivalDT;
	endif;
	if not tmpTS.isValid() then
		tmpTS := self.myVoyage.arrivedDT;
	endif;
	self.txtEstArrVR.setDate(tmpTS.date);
	self.txtEstArrTimeVR.setTime(tmpTS.time);
	
	// DEPARTURE
	tmpTS := _wodtl.estimatedDepartureTS;
	if not tmpTS.isValid() then
		tmpTS := self.myVoyage.estimatedDepartureDT;
	endif;
	if not tmpTS.isValid() then
		tmpTS := self.myVoyage.departedDT;
	endif;
	self.txtEstDepVR.setDate(tmpTS.date);
	self.txtEstDepTimeVR.setTime(tmpTS.time);
	
	self.txtCodeVoyageInVR.text := _wodtl.voyageCodeIn;
	self.txtCodeVoyageOutVR.text := _wodtl.voyageCodeOut;

	self.buildComboAllPorts(_wodtl);
	self.buildComboAllOperators(_wodtl);
	
	self.buildComboAllVisitTypes(self.cmbVisitTypeVR,_wodtl.visitTypeCode);
	self.buildComboAllVesCat(self.cmbVesselCatVR,_wodtl.vesselCategoryCode);
	
	self.chkHasCargoVR.value := _wodtl.hasCargo;  //epr TFS 51963 23/9/21
	self.txtGeneralRemarksVR.text := _wodtl.generalRemarks; // jlizm1 TFS 51963 06/10/2021
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodVoyageRequest"/>
    </JadeMethod>
    <JadeMethod name="displayWaterRequest" id="0aa428dc-867d-4fde-93ed-2f618d688c99">
        <updating/>
        <source>displayWaterRequest(_water : CM_WodWaterRequest) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
//
vars

begin
	// display the voyage
	self.displayVoyageCombo(self.shtWaterRequest);
	
	self.shtWaterRequest.showMySheet();
	
	if _water.myHMSResourceType &lt;&gt; null then
		self.cmbResourceType.listIndex := self.cmbResourceType.findObject(_water.myHMSResourceType);
		self.cmbResourceType_click(self.cmbResourceType);
	endif;
	if _water.myHMSResource &lt;&gt; null then
		self.cmbResource.listIndex := self.cmbResource.findObject(_water.myHMSResource);
	endif;
	self.txtUnitsUsed.text := _water.unitsUsed.String;
	if _water.fromDateTime.isValid then
		self.txtFromDate.setDate(_water.fromDateTime.date);
		self.txtFromTime.setTime(_water.fromDateTime.time);
	endif;
	if _water.toDateTime.isValid then
		self.txtToDate.setDate(_water.toDateTime.date);
		self.txtToTime.setTime(_water.toDateTime.time);
	endif;
	self.cmbWTransferType.listIndex := self.cmbWTransferType.findObject(app.myRoot.allVoyageJobTransferTypes[_water.transferType]);
	
	if _water.isComplete then
		self.shtWaterRequest.enabled := false;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_water" type="CM_WodWaterRequest"/>
    </JadeMethod>
    <JadeMethod name="displayWorkOrderToDoTaks" id="bfe043b2-b193-475f-ad0c-fa3d92643a78">
        <source>displayWorkOrderToDoTaks(_wodDtl : CM_WorkOrderTIDtl);
/*

Purpose:			
	This method will be used to display To do Tasks for the following work order types
	Cargo Receive 
	Cargo Release 
	Pack 
	UnPack
Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders

*/

vars
	todoSet : CM_ToDoTaskDescSet;
begin
	
	if not _wodDtl.allToDoRequests.isEmpty then
		create todoSet transient;
		_wodDtl.getAllToDoTaksDescsUsed( todoSet );
		self.mulReceiveToDo.setSelected( todoSet );
	endif; 
	
epilog
	delete todoSet;
end;</source>
        <Parameter name="_wodDtl" type="CM_WorkOrderTIDtl"/>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="ccce7d06-7b2e-42ff-b72d-808654274208">
        <updating/>
        <source>doBaseFormSave() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14/08/2009	cnwmd1	Initial creation
24/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders

Update the proxy in all cases
Update the real objects if real work order exists (When in update mode)
*/

vars
	result : Integer;						// TFS 38560

begin
	inheritMethod();
	
	if not self.doSaveProxy() then
		//22 Jun 2018	NDL	TFS 39248
		return;
	endif;
	
	if self.myProxyWorkOrder.pxyGetRealObject() &lt;&gt; null then
		while true do																			// TFS 38560
			app.myTrxUA.trxUpdateWorkOrderTasks(self.myProxyWorkOrder, app.myPassport);
			//if not app.myPassport.trxCompletedOK then											// TFS 38560
			if app.myPassport.trxCompletedOK then												// TFS 38560
				self.clearErrorWarnings();														// TFS 38560
				break;																			// TFS 38560
			else																				// TFS 38560
				//app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Update);	// TFS 38560
				result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);	// TFS 38560
				if app.myPassport.noErrors and result = IDOK then								// TFS 38560
					app.myPassport.warningsAcknowledged := true;								// TFS 38560
					continue;																	// TFS 38560
				endif;																			// TFS 3856		
			endif;
			return;																				// TFS 38560
		endwhile;
	endif;
	
	self.modalResult := IDOK;
	
	if self.myMainForm.isKindOf(YRD_TaskJobMaintForm) then 
		self.myMainForm.YRD_TaskJobMaintForm.refreshFromChildTaskForm();
	endif;
	self.unloadForm();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCargodblClick" id="b9d83a57-5187-4002-b7df-c5523e181fb3">
        <updating/>
        <source>doCargodblClick( _table : Table ) updating;

/*

Purpose:			

Parameters:			

