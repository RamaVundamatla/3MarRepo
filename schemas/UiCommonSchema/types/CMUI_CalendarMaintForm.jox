    <JadeMethod name="doResize" id="840dbaa9-45d6-4de9-a91e-ddab39ee5483">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 October 2010	cnwndl1	Initial creation	Par 25530

*/

vars

	vLeft : Real;
	vWidth : Real;

begin

	inheritMethod();
	
	vLeft := 1;
	self.grpDetail.left := vLeft;
	self.grpDayData.left := vLeft;
	self.grpSelect.left := vLeft;
	
	vWidth := self.width - 10;
	self.grpSelect.width := vWidth;
	self.grpDetail.width := vWidth;
	self.grpDayData.width := vWidth;
	self.grpDateButtons.width := grpDayData.width - 10;
	
	self.grpSelect.top := 1;
	self.grpDetail.top := self.grpSelect.top + self.grpSelect.height;
	self.grpDayData.top := self.grpDetail.top + self.grpDetail.height;
	
	self.tblDayData.width := self.grpDayData.width - self.tblDayData.left - 5;
	self.tblDayData.height := self.grpDayData.height - self.tblDayData.top - self.grpDateButtons.height - 5;
	
	self.grpDateButtons.top := self.tblDayData.top + self.tblDayData.height;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initTblDayData" id="d3948434-8b2c-411b-b502-281a5c0470d2">
        <source>initTblDayData();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 October 2010	cnwndl1	Initial creation

*/

vars

	headingRow : String;
	
begin

	self.lblEntryCount.caption := null;

	self.tblDayData.clear();
	self.tblDayData.fixedRows := 1;
	self.tblDayData.rows := 1;
	self.tblDayData.fixedColumns := 0;
	self.tblDayData.columns := 5;
	
	self.tblDayData.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.tblDayData.selectionType := CM_BaseTable.SelectionType_Row;
	
	headingRow := app.getErrorString(Year) &amp; Tab
					&amp; app.getErrorString(DateStr) &amp; Tab
					&amp; app.getErrorString(Day) &amp; Tab
					&amp; app.getErrorString(TimeStr) &amp; Tab
					&amp; app.getErrorString(Description);
					
	self.tblDayData.setCellText(1,1,headingRow);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbYears" id="479f4912-01cc-44ba-b534-b7f902e57f09">
        <source>populateCmbYears( _calendar : CM_Calendar );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 October 2010	cnwndl1	Initial creation

*/

vars

	existingYear : Integer;
	calendarYear : CM_CalendarYear;
	date : Date;
	pos : Integer;
	
begin

	existingYear := cmbYears.text.Integer;
	
	cmbYears.clear();
	
	if _calendar = null then
		return;
	endif;
	
	foreach calendarYear in _calendar.allCalendarYears do
		pos := cmbYears.addItem( calendarYear.year.String  );
		cmbYears.itemObject[pos] := calendarYear;
	endforeach;
	
	if existingYear &gt; 0 then
		cmbYears.listIndex := cmbYears.findStringExact( 1, existingYear.String );
	endif;
	
	if cmbYears.listIndex = -1 then
		cmbYears.listIndex := cmbYears.findStringExact( 1, date.year.String );
	endif;
	
epilog

end;</source>
        <Parameter name="_calendar" type="CM_Calendar"/>
    </JadeMethod>
    <JadeMethod name="populateCombos" id="fe6411bc-9f04-4ca7-91b4-4e77285967b9">
        <source>populateCombos();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 October 2010	cnwndl1	Initial creation

*/

vars

	pos : Integer;
	calendar : CM_Calendar;
	dayType : CM_DayType;

begin

	self.cmbCalendar.clear();
	foreach calendar in app.myRoot.allCalendars do
		pos := self.cmbCalendar.addItem(calendar.description);
		self.cmbCalendar.itemObject[pos] := calendar;
	endforeach;

	self.cmbDayType.clear();
	foreach dayType in app.myRoot.allDayTypes do
		pos := self.cmbDayType.addItem(dayType.description);
		self.cmbDayType.itemObject[pos] := dayType;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateTblDayData" id="5413ac49-a631-46d3-823e-a3e8debbd8da">
        <source>populateTblDayData();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 October 2010	cnwndl1	Initial creation

*/

vars

	calendarYear : CM_CalendarYear;
	calendarDate : CM_CalendarDate;
	iter : Iterator;
	jadTableRow : JadeTableRow;
	maintAllowed : Boolean;
	
begin

	maintAllowed := ( app.getMyUser.canDo(null, PmAdmCalendarMaint) or app.getMyUser.canDo(self.myTerminal, PmAdmCalTermMaint) );
	
	self.btnBulk.enabled := self.myRealCalendar &lt;&gt; null and maintAllowed;
	self.btnRemDate.enabled := false;
	self.btnUpdDate.enabled := false;
	self.btnNewDate.enabled := maintAllowed and cmbCalendar.listObject &lt;&gt; null;

	self.initTblDayData();
	
	calendarYear := cmbYears.listObject.CM_CalendarYear;
	
	if calendarYear = null then
		return;
	endif;
	
	self.lblEntryCount.caption :=  "( " &amp; app.getErrorString1(Calendar_entries, calendarYear.allCalendarDates.size.String) &amp; " )";
	
	iter := calendarYear.allCalendarDates.createIterator;
	
	while iter.next( calendarDate ) do
		self.tblDayData.rows := self.tblDayData.rows + 1;
		jadTableRow := self.tblDayData.accessRow( self.tblDayData.rows );
		jadTableRow.itemObject := calendarDate;
		self.tblDayData.setCellText( self.tblDayData.rows, 1, calendarDate.getStringForTable );
	endwhile;

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateTblTerms" id="774ed466-4008-4efe-8b27-dc7a48e82730">
        <source>populateTblTerms( _calendar : CM_Calendar );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 October 2010	cnwndl1	Initial creation

*/

vars

	user : CM_User;
	userTerminal : CM_UserTerminal;
	terminal : CM_Terminal;
	check : Boolean;

begin

	self.tblTerminal.clear();
	self.tblTerminal.allSelectedObjects.clear();
	self.tblTerminal.rows := 0;
	
	user := app.getMyUser();
	if user = null then
		return;
	endif;
	
	foreach userTerminal in user.allUserTerminals do
		terminal := userTerminal.getMyTerminal;
		if _calendar = null then
			check := false;
		else
			check := _calendar.allTerminals.includes( terminal );
		endif;
		tblTerminal.accessRow(tblTerminal.addItem(check.cnEcGetTableCheckBoxValue &amp; Tab &amp; terminal.code &amp; ' - ' &amp; terminal.name)).itemObject := terminal;
		if check then
			tblTerminal.allSelectedObjects.add( terminal );
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_calendar" type="CM_Calendar"/>
    </JadeMethod>
    <JadeMethod name="selectCalendar" id="959d21fa-4c02-466f-a67b-3297fafeda4e">
        <updating/>
        <source>selectCalendar( _calendar : CM_Calendar ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 October 2010	cnwndl1	Initial creation	Par 25530

*/

vars

	maintAllowed : Boolean;

begin

	self.setCalendar( _calendar );
	self.txtHookCode.enabled := false;

	if _calendar = null then
		self.txtCode.text := null;
		self.txtDescription.text := null;
		self.cmbDayType.listIndex := -1;
		self.chkHasStart.value := false;
		self.chkHasEnd.value := false;
		self.txtHookCode.text := null;
	else
		self.txtCode.text := _calendar.code;
		self.txtDescription.text := _calendar.description;
		self.cmbDayType.listIndex := cmbDayType.findObject( _calendar.myDayType );
		self.chkHasStart.value := _calendar.hasTime;
		self.chkHasEnd.value := _calendar.hasEndTime;
		if _calendar.myHookCode &lt;&gt; null then
			self.txtHookCode.text := _calendar.myHookCode.code;
		else
			self.txtHookCode.text := null;
		endif;
	endif;
	
	self.populateTblTerms( _calendar );
	self.populateCmbYears( _calendar );
	self.populateTblDayData();
	
	self.btnCalSave.enabled := false;
	self.btnCancel.enabled := false;

epilog

end;</source>
        <Parameter name="_calendar" type="CM_Calendar"/>
    </JadeMethod>
    <JadeMethod name="setCalendar" id="2ca8fcb4-b7c6-4556-8926-aadd3d6797fc">
        <updating/>
        <source>setCalendar( _calendar : CM_Calendar ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 October 2010	cnwndl1	Initial creation

*/

vars

	code : String;
	description : String;
	dayType : CM_DayType;
	hasStartTime : Boolean;
	hasEndTime : Boolean;
	hookCode : String;
	selectedTerms : CM_TerminalSet;
	loadState : Boolean;
	
begin

//	code := txtCode.text;
//	description := txtDescription.text;
//	dayType := cmbDayType.listObject.CM_DayType;
//	hasStartTime := chkHasStart.value;
//	hasEndTime := chkHasEnd.value;
//	hookCode := txtHookCode.text;
//	create selectedTerms transient;
//	process.isNDL;
	//get selected terms   selectedTerms : CM_TerminalSet;
		
	
	if self.myProxyCalendar &lt;&gt; null then
	
		delete self.myProxyCalendar;
		self.myProxyCalendar := null;
		
	endif;
	
	self.myRealCalendar := null;
	if _calendar &lt;&gt; null then
		app.cmsBeginLoad(loadState);
		self.myProxyCalendar := _calendar.pxyCreateUpdateProxy;
		app.cmsEndLoad(loadState);
		self.myRealCalendar := _calendar;
	endif;

epilog

//	delete selectedTerms;
	app.cmsEndLoad(loadState);
	
end;</source>
        <Parameter name="_calendar" type="CM_Calendar"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d4fd2760-52bd-46cd-aa79-27e91a1315f5">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 October 2010	cnwndl1	Initial creation

*/

vars

	maintAllowed : Boolean;

begin

	self.beginClassNotification(CM_Calendar, false, EVENT_Calendar_Update, Response_Continuous, null);
	self.beginClassNotification(CM_DayType, false, Object_Create_Event, Response_Continuous, null);
	self.beginClassNotification(CM_DayType, false, Object_Delete_Event, Response_Continuous, null);
	
	self.doResize();
	self.initTblDayData();
	self.populateCombos();
	
	inheritMethod();
	
	self.minimumWidth := 600;
	self.minimumHeight := 540;
	
	maintAllowed := ( app.getMyUser.canDo(null, PmAdmCalendarMaint) or app.getMyUser.canDo(self.myTerminal, PmAdmCalTermMaint) );
	
	self.btnNewCalendar.enabled := maintAllowed;
	self.mode := ViewMode;

epilog

end;</source>
