    <JadeMethod name="getDisplayStringForAttribute" id="c3315c4a-47a2-4936-b91a-ebcc7e2805c5">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22 Jul 2009	consw1		SFW1075 - To Do Task Scheduling
// 26 Apr 2016	cnwns1		TFS 488 - Multi Timezone Support
// 18 May2022 	navhl20	 	TFS 53430  EUP - Sub Carrier registration in MTN
// 22 May 2023 	navhl20 	ChangeRequest 57714:[57764] EUP - Delivery Dispatch – Gate
// 29 May 2023  navhl20 	ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
// 06 Jun 2023  navhl20 	ChangeRequest 57762: EUP - Delivery Dispatch – Pack/UnPack
// 08 Jun 2023  navhl20 	ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS
// 19 Jun 2023  navma1		Defect 58679: MTN - Some details are not populating correctly on the Delivery dispatch screen
// 21 June 2023 navhl20 	ChangeRequest 58348: EUP | Sorting Method and Itemized info in Delivery Dispatch
// 10 Jul 2023	navma1		ChangeRequest 54550: EUP | Delivery Dispatch Screen - Pack Operation
// 13 Jul 2023	navhl20		ChangeRequest 54550: EUP | Delivery Dispatch Screen - Pack Operation
// 13 Sep 2023	navlw1		Bug 60382: MTN - The Work Order Operations form's column organizer is missing some fields.
// 03 Oct 2023  navhl20 	ChangeRequest 60033: EUP | Ship Operations in DD - [54176.010] - [Receive] Ship Job List
// 18 Oct 2023  navhl20 	ChangeRequest 60090: EUP | Ship Operations in DD - [54176.020] -[Receive] Allocate Jobs to Gangs and Gangs to Holds
// 31 Oct 2023  navhl20 	ChangeRequest 60091: EUP | Ship Operations in DD - [54176.040] - [Receive] Allocation List
// 24 Jan 2024	navhl20		ChangeRequest 62056:[62122] FR | 53891 - Mobile App changes for Delivery Dispatch - multiple Release Line Items
// 29 Jan 2023 	navhl20 	ChangeRequest 62166: EUP | 53729 - Delivery Dispatch Screen - outstanding issues
// 09 Feb 2024	navnk30		ChangeRequest 62420: EUP | Retrospective Operations - [54177.020] - Allocate Road Jobs
// 23/02/2023	navkc1 		CR 62580 Task 62581: UI - Road Exit Custom Document Details
// 26 Feb 2024 	navhl20 	ChangeRequest 61869: EUP | FR | 53891 - Mobile App changes for Delivery Dispatch - Source Location
// 25 Mar 2024  navhl20 	ChangeRequest 62300: EUP | 53729 - Delivery Dispatch Screen - outstanding issues - 2
// 02 May 2024  navhl20 	ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen
// 10 Jul 2024  navbs1	 	ChangeRequest 64778: EUP | Delivery Dispatch Multi Select Search
// 26 Aug 2024	navbs1		Bug 65777: EUP | 53729 - Delivery Dispatch Screen - wrong WO info when multiple in one Job
// 11 Sep 2024  navbk1      Change Request 62456: EUP* | VAS Mobile App - [53813.040] VAS Tasks in other Operational Mobile Apps - Flow Integration - 2
// 16 Oct 2024	navpw1		JIRA: MTN-33053 - Added code that if this is Any Id Any Amount then return the release request total requested.
// ---------------------------------------------------------------------------

vars
	workListEntries : CM_WLESet;
	isEntrySetEmpty,
	invalidEntries  : Boolean;
	ti 				: CM_TrackedItem;
	shift			: CM_Shift;
	request			: CM_Request;
	jobSheet		: CM_WorkPointJobSheet;
	voyage			: CM_Voyage;
	type 			: String;
	str				: String;
	reserveDetail	: CM_ReserveDetail;
	index			: Integer;
begin
	if _attrName = ETRow_TransactionNum or 
	   _attrName = ETRow_Train          or
	   _attrName = ETRow_QryCrane1      or
	   _attrName = ETRow_QryCrane2      or
	   _attrName = ETRow_QryVoyage      or
	   _attrName = ETRow_Location       or
	   _attrName = ETRow_NumEmptyD      or
	   _attrName = ETRow_NumFullD       or
	   _attrName = ETRow_NumEmptyRHD    or
	   _attrName = ETRow_NumFullRHD     or
	   _attrName = ETRow_Is2040			or
	   _attrName = ETRow_CarrierId      or
	   _attrName = ETRow_Wagon          or
	   _attrName = ETRow_RegNumber      or
	   _attrName = ETRow_Debtor      	or
	   _attrName = ETRow_VbsId      	or
	   _attrName = ETRow_ExternalRef    or
	   _attrName = ETRow_ExtRef1 		or
	   _attrName = ETRow_ExtRef2 		or 
	   _attrName = ETRow_JobRemarks 	or
	   _attrName = ETRow_StartDT 		or 
	   _attrName = ETRow_EndDT 			or					//31.10.2023 navhl20 #60091
	   _attrName = ETRow_VoyageTransType or 
	   _attrName = ETRow_InspectionCheck or					//13.6.2023 navhl20 #58543
	   _attrName = ETRow_SubCarrierCodeDesc then 			//18/05/2022 navhl20 TFS 53430
		return null;
	
	elseif _attrName = ETRow_DwellTimeStr then				 //This is the visible column in mins
		return self.dwellTime.String;
	elseif _attrName = ETRow_DwellTime then 				 //This is the hidden sort column
		return self.dwellTimeAsString();
	elseif _attrName = ETRow_HasRTQEntries then
		return app.getYesNo((not self.allEntries.isEmpty));		
	elseif _attrName = ETRow_JobStatus then
		return self.statusString;

	elseif _attrName = ETRow_Type then
		return self.jobTypeId;
	elseif _attrName = ETRow_WleCount or _attrName = ETRow_JobCountWLE then
		return self.workListEntries.size.asStringJMT();
	elseif _attrName = ETRow_JobCountIncompleteWLE then
		return self.getCountIncompleteWLE().asStringJMT();
	elseif _attrName = ETRow_JobCountUnallocatedWLE then
		return self.getCountUnallocatedWLE().asStringJMT();
	elseif _attrName = ETRow_JobCountQueuedWLE then	  //cnwrd1 24.8.09
		return self.getCountRTQueuedWLE().asStringJMT();
	elseif _attrName = ETRow_JobNumber then
		return self.id;
	elseif _attrName = ETRow_TaskType or _attrName = ETRow_WorkEntry then
		if  not self.workListEntries.isEmpty then
			return self.workListEntries.first.getDisplayStringForAttribute(_attrName, _short);
		endif;
		return null;
	elseif _attrName = ETRow_WorkOrder then
		return self.getWorkOrderForDisplay;		//26.08.2024 navbs1 #65777
	elseif _attrName = ETRow_RadioTelemetry then			
		if self.allRequests.size &lt;&gt; 1 then
			return null;
		endif;
		//11/03/2011 cnwdz2 27121 start
		on Exception do app.handleDeletedObject(exception, workListEntries, invalidEntries);
		workListEntries := self.allRequests.first.allWorkListEntries;		
		isEntrySetEmpty := workListEntries.isEmpty();
		if invalidEntries or isEntrySetEmpty then
			return null;
		endif;		
		//11/03/2011 cnwdz2 27121 end
		
		if self.isJobComplete() then //cnwrd1 par 24971 16.7.2010 check if we are complete.
			return null;
		endif;		
		return self.getRadioTelemetryDisplay(); 	
		
	elseif _attrName = ETRow_RequiredBy or 
		   _attrName = ETRow_RequiredByDate then									//06.06.2023 navma1 #58339
		//26 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
		return self.systemToLocalTime(self.getRequiredByDT()).asStringJMT();	
	elseif _attrName = ETRow_Remarks then		
		return self.getRemarks();
	elseif _attrName = ETRow_Request then
		request := self.allRequests.first;
		if request &lt;&gt; null then
			return request.getId;
		endif;
		return null;
	elseif _attrName = ETRow_Source then
		if self.allRequests.size &lt;&gt; 1 then
			return null;
		endif;
		return self.allRequests.first.getSourceLocationID();
	elseif _attrName = ETRow_ReleaseNumber then
		if self.allRequests.size &lt;&gt; 1 then
			return null;
		endif;
		return self.allRequests.first.getReleaseNumber();
	elseif _attrName = ETRow_Target then
		if self.allRequests.size &lt;&gt; 1 then
			return null;
		endif;
		return self.allRequests.first.getTargetLocationID();
	elseif _attrName = ETRow_RadioTelemetryQueue then
		if self.allRequests.size &lt;&gt; 1 then
			return null;
		endif;
		return self.allRequests.first.getSelectedRTQ();		
	elseif _attrName = ETRow_CreationDateTime then	 //cnwrd1 ccms 1075 10.9.09		
		//26 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
		return self.systemToLocalTime(self.createdTime).asStringJMT();
	elseif _attrName = ETRow_JobCreatedDate then
		//26 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
		return self.systemToLocalTime(self.createdTime).date.asStringJMT();
	elseif _attrName = ETRow_User then
		if self.allRequests.first &lt;&gt; null then
			return self.allRequests.first.userCode;
		endif;
		return null;
	elseif _attrName = ETRow_CraneShiftDesc then
		shift := self.myShift;
		if shift &lt;&gt; null then
			return shift.getShiftDay &amp; Space &amp; shift.code &amp; Space &amp; shift.startDateTime.date.asStringJMT();
		endif;
		return null;

	elseif _attrName = ETRow_CargoLocation then				//Start 22.5.2023 navhl20 #57714[57764]
		ti := self.getFirstTrackedItem();
		if ti &lt;&gt; null then
			return ti.locationId;
		endif;
		return null;
	elseif _attrName = ETRow_CargoSubType then
		return self.getCargoSubType().formatWithEllipsis(1,50,true); //04.10.2023 navhl20 #60033
	elseif _attrName = ETRow_Carrier then
		ti := self.getFirstTrackedItem();
		if ti &lt;&gt; null then
			return ti.getCarrierDescription();
		endif;
		return null;
	elseif _attrName = ETRow_Commodity then
		return self.getCommodity().formatWithEllipsis(1,50,true);	//04.10.2023 navhl20 #60033
	elseif _attrName = ETRow_FirstWarehouse then
		//return self.plannedLocations;								//26.02.2024 navhl20 #61869
		//return self.plannedLocation; 								//26/08/2024	navkc1 CR 63588 Task 63589
		//19/11/2024	navkc1 JIRA Bug MTN-33448
		if self.plannedTerminalAreas &lt;&gt; null then
			index := 1;
			return self.plannedTerminalAreas.scanUntil(Comma, index);
		endif;
		return null;
	elseif _attrName = ETRow_Instructions then
		return self.getInstruction();								//5.6.2023 navhl20	#57762
	elseif _attrName = ETRow_GateEntry then
		return self.getGateEntry();
	elseif _attrName = ETRow_IMEXStatus then
		return self.getIMEXStatus().formatWithEllipsis(1,50,true);	//04.10.2023 navhl20 #60033
	elseif _attrName = ETRow_NumWarehouses then
		/* //26/08/2024	navkc1 CR 63588 Task 63589
		if self.getPlannedLocationCount() &lt;&gt; '0' then						//Need to fix this
			return self.getPlannedLocationCount();
		endif;
		
		return null;
		*/
		
		return self.plannedTerminalAreas; //26/08/2024	navkc1 CR 63588 Task 63589
	elseif _attrName = ETRow_JobType then
		return self.getJobTypeDescription();
	elseif _attrName = ETRow_ParentCargoType then
		ti := self.getFirstParent();
		request := self.getRequest();
		if ti &lt;&gt; null then
			return ti.cargoTypeDescr;
		elseif request &lt;&gt; null then							//12.7.2023 navhl20 #54550
			return request.getReqCargoType(true);
		endif;
		return null;
	elseif _attrName = ETRow_ParentISOType then
		ti := self.getFirstParent();
		request := self.getRequest();
		if ti &lt;&gt; null then
			return ti.getISOTypeDesc();
		elseif request &lt;&gt; null then							//12.7.2023 navhl20 #54550
			return request.getReqISOType();
		endif;
		return null;
	elseif _attrName = ETRow_ParentOperCode then
		ti := self.getFirstParent();
		request := self.getRequest();
		if ti &lt;&gt; null then
			return ti.getOperatorDisplay();
		elseif request &lt;&gt; null then							//12.7.2023 navhl20 #54550
			return request.getReqOperatorCode(true);
		endif;
		return null;
	elseif _attrName = ETRow_ParentAvailGrade then
		ti := self.getFirstParent();
		request := self.getRequest();						//25.03.2024 navhl20 #62300
		if ti &lt;&gt; null then
			return ti.getAvailabilityGradeDesc();
		elseif request &lt;&gt; null then							//25.03.2024 navhl20 #62300
			return request.getReqAvailGrade();
		endif;
		return null;
	elseif _attrName = ETRow_ParentTotalReq then
		return self.getTotalReq();
	elseif _attrName = ETRow_Priority then
		return self.priority.asStringJMT;
	elseif _attrName = ETRow_Quantity then
		// ### JIRA: MTN-33053 16Oct2024 NAVPW1
		if app.myPassport.isVASEnabled and self.getIsAnyIdAnyAmt() then
			reserveDetail := self.getReserveDetail();
			
			if reserveDetail &lt;&gt; null and not reserveDetail.byTypeByWeight then
				return reserveDetail.totalRequested.asStringJMT();
			else
				return self.getTotalQuantity().asStringJMT();
			endif;
			
		endif;
		// ### JIRA: MTN-33053 16Oct2024 NAVPW1
		return self.getTotalQuantity().String;
	elseif _attrName = ETRow_CarrierName then
		return self.getRailCarrier();
	elseif _attrName = ETRow_Reference then
		return self.getReference();						//24.01.2023 navhl20 #62056[62122]
	elseif _attrName = ETRow_SpecialLift then
		return self.getSpecialLift();					//25.03.2024 navhl20 #62300
	elseif _attrName = ETRow_SpecialStow then
		return self.getSpecialStow();					//25.10.2023 navhl20 #60090
	elseif _attrName = ETRow_SubCarrier then
		return self.getSubCarrier();
	elseif _attrName = ETRow_ToDoTaskType then
		return self.getToDoTaskType();
	elseif _attrName = ETRow_WagonEntry then
		return self.getWagonEntry();					  //End   22.5.2023 navhl20 #57714[57764]
	elseif _attrName = ETRow_OperStarted then			  //Start 30.5.2023 navhl20 #57747[57748]
		return self.getOperationStarted();
	elseif _attrName = ETRow_OperEnded then
		return self.getOperationEnded();
	elseif _attrName = ETRow_RemQuantity then
		// ### JIRA: MTN-33053 17Oct2024 NAVPW1
		if app.myPassport.isVASEnabled and self.getIsAnyIdAnyAmt() then
			return app.getErrorString(AnyAmount);
		endif;
		// ### JIRA: MTN-33053 17Oct2024 NAVPW1
		return self.getRemainingQuantity();
	elseif _attrName = ETRow_RemWeight then
		return self.getRemainingWeight();
	elseif _attrName = ETRow_RemVolume then
		return self.getRemainingVolume();
	elseif _attrName = ETRow_WorkPoint then
		return self.getWorkPoint();						//End 29.5.2023 navhl20 #57747[57748]
	elseif _attrName = ETRow_WaitingTime then			//07.6.2023 navhl20 #58543
		return self.dwellTime.asStringJMT;
	elseif _attrName = ETRow_Shift then					//07.6.2023 navhl20 #58543
		return self.getShift();
	elseif _attrName = ETRow_ExitDate then				//07.6.2023 navhl20 #58543
		return self.getExitDate();
	elseif _attrName = ETRow_JobCategory then			//07.6.2023 navhl20 #58543
		return self.getJobCategory();
	elseif _attrName = ETRow_BarrieInDate then			//13.6.2023 navhl20 #58543
		return self.getBarrierInDate();
	elseif _attrName = ETRow_ToDoTasks then				//13.6.2023 navhl20 #58543
		return self.getMyTodoTask();
	elseif _attrName = ETRow_ToDoTaskPending then		//11.09.2024 navbk1 #62456
		return self.isToDoTaskPending();
	elseif _attrName = ETRow_Itemised then				//21.6.2023 navhl20 #58348
		return self.getItemised();						//25.03.2024 navhl20 #62300
	elseif _attrName = ETRow_SortingMethod then			//21.6.2023 navhl20 #58348
		return self.getSortingMethods();				//25.03.2024 navhl20 #62300
	elseif _attrName = ETRow_Name then // 13.09.2023 navlw1 #60382
		jobSheet := self.getJobSheetForWorkPoint();
		if jobSheet &lt;&gt; null then
			return jobSheet.externalName;
		endif;
		return null;
	elseif _attrName = ETRow_ExternalRef1 then // 13.09.2023 navlw1 #60382
		jobSheet := self.getJobSheetForWorkPoint();
		if jobSheet &lt;&gt; null then
			return jobSheet.externalReference1;
		endif;
		return null;
	elseif _attrName = ETRow_ExternalRef2 then // 13.09.2023 navlw1 #60382
		jobSheet := self.getJobSheetForWorkPoint();
		if jobSheet &lt;&gt; null then
			return jobSheet.externalReference2;
		endif;
		return null;
	elseif _attrName = ETRow_ExternalRef3 then // 13.09.2023 navlw1 #60382
		jobSheet := self.getJobSheetForWorkPoint();
		if jobSheet &lt;&gt; null then
			return jobSheet.externalReference3;
		endif;
		return null;
	elseif _attrName = ETRow_JobId then		  //26.9.2023 navhl20 #60382
		if self.id &lt;&gt; null then
			return self.id;
		else
			return self.jobId;
		endif;
		return null;
	elseif _attrName = ETRow_Voyage then		//03.10.2023 navhl20 #60033
		voyage := self.getMyVoyage();
		if voyage &lt;&gt; null then
			return voyage.code;
		endif;
		return null;
	elseif _attrName = ETRow_Vessel then		//03.10.2023 navhl20 #60033
		voyage := self.getMyVoyage();
		if voyage &lt;&gt; null then
			return voyage.vesselCode;
		endif;
		return null;
	elseif _attrName = ETRow_VesselType then	//03.10.2023 navhl20 #60033
		return self.getVesselType();			//02.05.2024 navhl20 #63971
	elseif _attrName = ETRow_VoyageOperator then //03.10.2023 navhl20 #60033
		voyage := self.getMyVoyage();
		if voyage &lt;&gt; null and voyage.myOperator &lt;&gt; null then
			return voyage.myOperator.code;
		endif;
		return null;
	elseif _attrName = ETRow_VoyageTrade then	//03.10.2023 navhl20 #60033
		voyage := self.getMyVoyage();
		if voyage &lt;&gt; null and voyage.myTrade &lt;&gt; null then
			return voyage.myTrade.description;
		endif;
		return null;
	elseif _attrName = ETRow_VoyageShippingLine then	//03.10.2023 navhl20 #60033
		voyage := self.getMyVoyage();
		if voyage &lt;&gt; null and voyage.myShippingLine &lt;&gt; null then
			return voyage.myShippingLine.description;
		endif;
		return null;
	elseif _attrName = ETRow_DischargePort then		//03.10.2023 navhl20 #60033
		return self.getDischargePort();
	elseif _attrName = ETRow_VoyageETA then			//03.10.2023 navhl20 #60033
		voyage := self.getMyVoyage();
		if voyage &lt;&gt; null then
			return voyage.estimatedArrivalDT.asStringJMT;
		endif;
		return null;
	elseif _attrName = ETRow_VoyageETD then			//03.10.2023 navhl20 #60033
		voyage := self.getMyVoyage();
		if voyage &lt;&gt; null then
			return voyage.estimatedDepartureDT.asStringJMT;
		endif;
		return null;
	elseif _attrName = ETRow_VoyageHold then		//03.10.2023 navhl20 #60033
		return self.getHolds();
	elseif _attrName = ETRow_VoyageStatus then		//31.10.2023 navhl20 #60091
		voyage := self.getMyVoyage();
		if voyage &lt;&gt; null then
			return voyage.statusDescription;
		endif;
		return null;
	elseif _attrName = ETRow_VoyageBerth then		//31.10.2023 navhl20 #60091
		voyage := self.getMyVoyage();
		if voyage &lt;&gt; null then
			return voyage.getBerthCode();
		endif;
		return null;
	elseif _attrName = ETRow_RetrospectiveDT then	//09.02.2024 navnk30 #62420
		return self.retrospectiveDT.asStringJMT;
	elseif _attrName = ETRow_CustomStatus then
		return self.getCustomStatus(); 				//23/02/2023	navkc1 CR 62580 Task 62581
	elseif _attrName = ETRow_JobActivity then 		//20/03/2024	navkc1 CR 62694 Task 62901
		return self.getJobActivity();
	elseif _attrName = ETRow_WorkPointType then		//10.07.2024 navbs1 #64778
		return self.getWorkPointTypeCode();
	
	/*Always needs to be last if statment*/
	elseif _attrName.isMeasurementType then			//03.10.2023 navhl20 #60033
		_attrName.getRowNameMeasureType(str, type);
		return self.getMeasurementStringForAttrib(str, type, _short);
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
