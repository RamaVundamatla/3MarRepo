    <JadeMethod name="utlUpdateHMSMovement" id="db620df7-ac24-42f0-884c-9a6671dbd5cc">
        <updating/>
        <source>utlUpdateHMSMovement(_pxyHMSMovement : HMS_Movement; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------------
// 04/02/2019	jlgdap1		TFS 43037 PEL1 Erro in HMS_VoyageMovement
// 21 Sep 2020  cnwma1 		ChangeRequest 49906: MTN - Ops View External Webservice

vars
	realMovement : HMS_Movement;
	expectedEdition : Integer;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	_pxyHMSMovement.raiseExceptionIfNotProxy(method);
	_pxyHMSMovement.validateForUpdate(_passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	_pxyHMSMovement.pxyGetRealObjectAndEdition(realMovement, expectedEdition);
	app.setContinueCMExceptions(true);

	if realMovement = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, _pxyHMSMovement.getName, null, null);
		return;
	endif;
	
	exclusiveLock(realMovement);

	if _passport.noErrors and realMovement.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'HMS Movement', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realMovement, true);
	endif;
	
	if _passport.noErrors then
		//realMovement.setForUpdateMovement(_pxyHMSMovement, _passport, true, true);	// TFS 43037
		realMovement.setForUpdateMovement(_pxyHMSMovement, _passport, true, false);		// TFS 43037
	endif;
	
	if _passport.noErrors then
		realMovement.causeHMSEvent(realMovement.EventMode_Update);
		self.myUpdateAuditAgent.audUpdateGeneric(realMovement, false);
		
		//21.09.2020 cnwma1 TFS #49906
		if _passport.isOpsViewEnabled(realMovement.getMyTerminal()) then
			realMovement.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,
												 BGP_OpsViewWSRequest.OPS_TYPE_HMSMOVE,
												 realMovement);
		endif;
		//21.09.2020 cnwma1 TFS #49906
	endif;
	
end;</source>
        <Parameter name="_pxyHMSMovement" type="HMS_Movement"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
