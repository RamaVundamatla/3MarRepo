    <JadeMethod name="cloneMySelf" id="859528d7-361b-48a4-bc26-6ea4b7d4325f">
        <source>cloneMySelf(_newLocn : CM_ROROLocnDefn; _copy : Boolean) : CM_ROROSlotDefn;
/*
Purpose:			
Date			Who		Reason
29 April 2011	cnwab1	Initial creation
30/01/2012		cnwmh5	#28918 - Change to hande locn defs where labelManuallyChanged has been set
*/

vars
	allStateData : CM_StateDataDict;
	newMe : SelfType;
	rotateLabel : String;
begin
	if _newLocn.isKindOf(CM_ROROLocnDefnVessel) then
		newMe := self.cloneSelf(_copy);
	elseif _newLocn.isKindOf(CM_ROROLocnDefnVoyage) then 
		newMe := self.cloneSelfAs(CM_ROROSlotDefnVoyage,_copy).CM_ROROSlotDefnVoyage;
	endif;
	
	///newMe.code := _newLocn.code &amp; newMe.ordinal.String; // PAR 27528
	if _newLocn.labelManuallyChanged then				   	// 31/01/2012 cnwmh5 #28918
		if self.isRotatedLinked(true) then // PAR 28990
			newMe.code := self.code &amp; "#";
		else
			newMe.code := self.code;
		endif;
	else
		newMe.code := _newLocn.code &amp; newMe.ordinal.String; // PAR 27528
	endif;
	
	newMe.myROROLocnDen := _newLocn;
	newMe.myDeck := _newLocn.myDeck;
	
	return newMe;


epilog

end;</source>
        <Parameter name="_newLocn" type="CM_ROROLocnDefn"/>
        <Parameter name="_copy" type="Boolean"/>
        <ReturnType type="CM_ROROSlotDefn"/>
    </JadeMethod>
