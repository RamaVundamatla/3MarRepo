    <JadeMethod name="setProxyFromObject" id="d721335c-e555-4ea3-a645-e653f9a2797b">
        <updating/>
        <source>setProxyFromObject(_object: CM_Bank) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2018	jlger1	Initial creation

*/

vars

begin
	inheritMethod(_object);
	self.code:=_object.code;
	self.description:=_object.code;
	
	if  app.myPassport.myTerminal &lt;&gt; null then
		self.isDefault := _object = app.myPassport.myTerminal.getDefaultCompanyBank();
	endif;
epilog

end;</source>
        <Parameter name="_object" type="CM_Bank"/>
    </JadeMethod>
