    <JadeMethod name="setTargetLocation" id="eab436c8-1496-46ac-9bc3-a6bb48c908c3">
        <updating/>
        <source>setTargetLocation() updating, protected;
//--------------------------------------------------------------
//Created: 24 May 2002 By: cnwgd1
//--------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	wle : CM_WorkListEntry;
begin
	if self.myCurrentWLE = null then
		app.msgBox('Please select a Work Entry from the table to edit.','Make Selection', MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;	
	endif;
	wle := self.myCurrentWLE;
	
	if wle.status &lt;&gt; WLE_UNACTIONED then
		return;
	endif;
	
	app.setContinueCMExceptions(true);	

	if wle.queue = null then
		if wle.myTrackedItem &lt;&gt; null then
			if wle.checkToDoComplete(false) then
				self.myAssistant.inputMoveToData(wle.myTrackedItem);
			else
				app.raiseCMException3(ERR_TODOTASKS, 'outstanding', app.getErrorString(Completed).toLower, wle.job.CM_RoadJob.jobNumber, "To Do Task", null);
			endif;
		else
			app.raiseCMException(BOL_NOT_MATCHED, "Work List Entry", null);					
		endif;
	endif;

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setToDoTaskComplete" id="c8905ac1-79e5-4528-9420-cc026e364f17">
        <updating/>
        <source>setToDoTaskComplete()updating, protected;
//--------------------------------------------------------------
//Created: 10 Apri 2002 By: cnwgd1
//nds TFS 2867 17/01/17 PKT - Bulk Process
//--------------------------------------------------------------
vars
	wle	: CM_WorkListEntry;
	toDoWle : CM_WOToDoWLE;
	bol : CM_BOL;
	job : CM_RoadJob;
	request : CM_Request;
	wleTable : CM_DataTable;
	wleArray : CM_WLEArray;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin

	wleTable:=self.mnuTableContext.userObject.CM_DataTable;
	if wleTable = null then
		return;
	endif;

	create wleArray transient;
	self.getAllWLEsInTableSelected(wleArray,wleTable,false);//nds TFS 2867 17/01/17 PKT - Bulk Process
		
	
	foreach wle in wleArray do 
	
		if wle = null or wle.status &lt;&gt; WLE_UNACTIONED then
			continue;
		endif;
		
		app.setContinueCMExceptions(true);	
		app.mousePointer := MousePointer_HourGlass;			
		//Get the toDoTask if there is one
		if wle.isKindOf(CM_WOToDoWLE) then
			toDoWle :=  wle.CM_WOToDoWLE;
		else
			toDoWle := wle.getRelatedWLE().CM_WOToDoWLE;
		endif;
	
		if toDoWle &lt;&gt; null then	
			if toDoWle.myRequest.CM_ToDoRequest.isComplete then
				app.msgBox('The task is already complete.','Task Complete', MsgBox_Stop_Icon + MsgBox_OK_Only);	
				return; //nothing to do here as already complete
			else
				bol := toDoWle.myBOL;
				if bol &lt;&gt; null then
					request := toDoWle.myRequest;
					if	bol.doToDoRequest(request.CM_WOToDoRequest) then
					
						//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
						while true do
						
							app.myTrxUA.trxUpdateLogScaleTaskBOLIn(request, STATUS_COMPLETE, bol, app.myPassport);
						
							if app.myPassport.trxCompletedOK then
								break;
							else
								theResult := app.showErrorWarningDialog('Yard Ops', app.myPassport, ErrWarnMode_Update);
								if app.myPassport.noErrors and theResult = IDOK then
									app.myPassport.warningsAcknowledged	:= true;
									continue;
								endif;
							endif;
							
							return;
							
						endwhile;
																	
					else
						return;									
					endif;
				endif;
			endif;
		//System not setup for toDoTasks 
		elseif wle.myBOL &lt;&gt; null then
			bol := wle.myBOL;
			if bol.bolType = BOLType_Log then
			
				//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
				while true do
				
					app.myTrxCA.trxCreateUnscaledLogs(bol, app.myPassport); //create unscaled logs
				
					if app.myPassport.trxCompletedOK then
						break;
					else
						theResult := app.showErrorWarningDialog('Yard Ops', app.myPassport, ErrWarnMode_Update);
						if app.myPassport.noErrors and theResult = IDOK then
							app.myPassport.warningsAcknowledged	:= true;
							continue;
						endif;
					endif;
					
					return;
					
				endwhile;
		
			endif;
		else		
			return;		//Nothing to do here
		endif;
		
		//Queue up whole job if all toDoTasks are complete
		job := wle.job.CM_RoadJob;
		if job.jobType = BOLType_Log then //job.checkAllToDoTaskComplete then  //jlier1 MTN-34117 18/3/25 - deadlocks - road jobs can't have CM_WOToDoWLE kind of wles so just ineffiecient to check
		
			//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxUA.trxUpdateJobDoMove(job, QUEUE_MODE, true, app.myPassport);
			
				if app.myPassport.trxCompletedOK then
					break;
				else
					theResult := app.showErrorWarningDialog('Yard Ops', app.myPassport, ErrWarnMode_Update);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				return;
				
			endwhile;
						
		endif;

	endforeach;

epilog
	delete wleArray;
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupDockbars" id="33a15744-238d-41a6-b946-568ea9b5e881">
        <updating/>
        <source>setupDockbars() updating, protected;

vars

begin
// dkcMain is parent to dkcLCBase and dkcVehicles
	self.dkcMain.height:=self.clientHeight - self.frmToolbar.clientHeight - self.frmModeStatusBar.clientHeight;
	self.dkcMain.width:=self.clientWidth;
	self.dkcMain.ignoreSkin:=true;
// dkcLCBase is parent to all the dkc_LC ( Location Controllers i.e pre gate, post gate, gate lane controllers ) and the macro info ddkcMacro
	self.dkcStageBase.height:=  self.dkcMain.clientHeight;
	self.dkcStageBase.top:=self.frmToolbar.height;
	self.dkcStageBase.ignoreSkin:=true;
	
	self.setupMacroDock();
	self.setupOpAreaDocks();
	self.setupVehiclesDock();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="cf0f4215-3dca-49cf-ae55-42daf106b572">
        <updating/>
        <source>setupForm() updating;
// 24/06/2010	cnwcs5	par 24292 - no toolbar on the select frame now
// 23/10/2012	cnwcs5	par 29653
// 22/11/2017 	cnwma1 TFS #7828 QNS - System buffering
// 03 Feb 2022  NAVLW1 TFS #52768 STWR - Review of 52455 (Searcher Behaviour resets user defaults)
vars
	terminal	: CM_Terminal;
	regKeys 	: IntegerArray;
	obj 		: Object;
	logBOL 		: CM_CargoBOLType;
	msg 		: String;
begin
	terminal	:= self.myTerminal;
	self.allOperators.clear(); // 03 Feb 2022 NAVLW1 TFS# 52768
	
	//01 Oct 2020	NDL	TFS 49189
	if self.myTerminal.roadProcessIsASPA then
		msg := app.getErrorString2( Road_opera_form_not_suppo_term, self.myTerminal.getMyRoadProcess.description, app.getErrorString(XLAT_Road_operations) );
		msg := msg &amp; CrLf &amp; app.getErrorString(Please_vehicl_visit_enquir_for);
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon );
		self.unloadForm;
		return;
	endif;
	
	inheritMethod();
	
	self.lstJobs.multiSelect := ListBox.MultiSelect_Extended;
	
	self.beginClassNotification(CM_YardWLE, false, terminal.getTerminalEvent(WLE_Create_Event), Response_Continuous, null);
	self.beginClassNotification(CM_YardWLE, false, terminal.getTerminalEvent(WLE_Update_Event), Response_Continuous, null);
	self.beginClassNotification(CM_YardWLE, false, terminal.getTerminalEvent(WLE_Delete_Event), Response_Continuous, null);
	self.beginClassNotification(CM_YardWLE, false, terminal.getTerminalEvent(EVENT_WLE_COMPLETE), Response_Continuous, null);
	self.beginClassNotification(CM_RoadJob, false, terminal.getTerminalEvent(RoadJob_Create_Event), Response_Continuous, null);
	self.beginClassNotification(CM_RoadJob, false, terminal.getTerminalEvent(RoadJob_Update_Event), Response_Continuous, null);
	self.beginClassNotification(CM_RoadJob, false, terminal.getTerminalEvent(RoadJob_Delete_Event), Response_Continuous, null);
	self.beginClassNotification(CM_Vehicle, false, terminal.getTerminalEvent(Vehicle_VTA_Area_Update), Response_Continuous, null);
	self.beginClassNotification(CM_Vehicle, false, terminal.getTerminalEvent(Vehicle_Update_Event), Response_Continuous, null);
	self.beginClassNotification(CM_Object, false, terminal.getTerminalEvent(Event_GateLane_Change), Response_Continuous, null); // 23 May 2008 cnwgb1 PAR 16483
	
	self.beginNotification(global, terminal.getTerminalEvent(Event_RFIDTagInUse), Response_Continuous, null);					//23 Apr 2012	NDL	Par 29417
	
	self.toolbarStyle := ToolbarStyle_ShowNoHide;	
	
	self.frmModeStatusBar.initFrame();
	self.frmModeStatusBar.myFrameDisplayMode.enabled := false;
	//setting up of dockbars relies on having allLocationControllers

	self.myMasterMenuAction.setHeading(self.caption);	// 11/08/2009 cnwcs5 ccms 1061
	
	self.setupDockbars();
	
	self.myRoadJobSheet := terminal.myRoadJobSheet;
	//epr TFS 7824 24/11/17
	logBOL:= app.myRoot.allCargoTypesById[BOLType_Log];
	if logBOL &lt;&gt; null then
		self.checkLogDocket:=self.myTerminal.allCargoBOLTypes.includes(logBOL);
	endif;
	
	create self.myRoadOpController transient;
		
	self.myRoadOpController.initController(self.myRoadJobSheet, self.dkbStage, self.dkcStage, 85 , self.chkPrefTiled.value);						//+cnwml2 PAR21536

	self.myRoadOpController.setNumberOfMenuItems(self.menuItemCount);
	
	// build tables for each of the areas (does not load data yet)
	self.initAreaTables();
	
	// make sure that multiSelect context menu item is visible and all tables multiSelect value is set to tru
	// 30/04/2010 cnwmh5 #23634
	self.mnuToggleMultiSelect.visible := true;
	
	self.mnuToggleMultiSelect.click(self.mnuToggleMultiSelect);
	
	// what were our sttings last time?
	self.getXMLSettingsForSetup();
	
	//load Find col
	self.doBuildFindColCombo();
	
	self.setupOpenedFromSatelliteView();
	// setup the search frame
	self.setupSearchFrame;
	// load data into list and tables
	if  self.dkcVehicles.visible then    		 //22/11/2017 cnwma1 TFS #7828
		self.loadListJobsForTerminal (true);
	endif;
	if self.allGates.isEmpty and self.allInterchangeAreas.isEmpty then
		//epr annoyed me that everytime i switch terminals i have to redo this now just select them all by default
		terminal.allGates.copy(self.allGates);
		
		foreach obj in lstICAreas_Avail.itemObject  do
			//self.allInterchangeAreas.add(obj.CM_InterchangeArea);
			self.allInterchangeAreas.add(obj.CM_TerminalArea);
		endforeach;	
	endif;
	
	self.setupOperators(); // 03 Feb 2022 NAVLW1 TFS# 52768

	self.setupTerminalAreas;
	
	self.addSearchToolbarControls();
	self.addPrefToolbarControls();	
	self.resetSearch; 
	
	// none of the code handles having more than one entry selected!!!
	self.lstJobs.multiSelect	:= ListBox.MultiSelect_None;
	if dkbMacro.visible then     //22/11/2017 cnwma1 TFS #7828
		displayExtraInfoForObj(null);					// 09/11/2012 cnwmh5 #24936
	endif;
	create regKeys transient;
	regKeys.add(CMUI_Key_F4);
	self.addRegisteredKeys(regKeys);
	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.tblMacro.userInputEnabled := false;
		self.tblStage.userInputEnabled := false;
		self.btnProcessRoad.enabled:= false;
		self.btnMoveIt.enabled:= false;
		self.btnEdit.enabled:= false;
		self.btnHideCompleted.enabled:= false;
		self.btnShowProblem.enabled:= false;
		self.btnHandheldOnly.enabled:= false;
		self.btnVehicleBook.enabled:= false;
		self.btnMoveIt.enabled:= false;
		
	endif;

	self.mnuRecordWeight.visible := app.myCurrentUserCan(self.myTerminal, PmGteVVRTruckWeighMaint) or app.myCurrentUserCan(self.myTerminal, PmGteVVRTruckWeighView);	// 22/6/17 MAP TFS4273	

epilog
	delete regKeys;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupMacroDock" id="aff00adf-1ab7-4c58-8ad5-fd2e3567a68b">
        <source>setupMacroDock()protected;

vars
	mHeight : Real;
	zHeight : Real;
begin

	//write self.height;
	zHeight:= self.dkcStageBase.clientHeight;
	//self.height -self.frmToolbar.height - self.frmModeStatusBar.height;

	//make macro %15 of height avail
	
	mHeight:= (zHeight*.15);
	self.dkcMacro.left:=self.dkcStageBase.left;
	self.dkcMacro.parentAspect:=Frame.ParentAspect_StretchBoth;
	self.dkcMacro.top:=(	zHeight - mHeight ); //self.height - mHeight - self.frmModeStatusBar.height;

	self.dkcMacro.height:=mHeight;
	self.dkcMacro.width:=self.dkcStageBase.width;
	self.dkcMacro.visible:=true;
	self.dkbMacro.left:=self.dkcMacro.left;
	self.dkbMacro.height:=self.dkcMacro.clientHeight - 10;
	self.dkbMacro.parentAspect:=Frame.ParentAspect_StretchBoth;
	self.dkbMacro.floatingStyle:=JadeDockBar.FloatingStyle_None;
	self.dkbMacro.drawGrip:=JadeDockBase.DrawGripBar_None;
	self.setupMacroTable;



end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupMacroTable" id="5af387a4-d732-48de-b530-21c9eb6eb3ab">
        <source>setupMacroTable()protected;

vars

begin

	self.tblMacro.left:=0;
	self.tblMacro.top:=0;
	self.tblMacro.clear;
	self.tblMacro.columns := 2;
	self.tblMacro.fixedRows := 0;
	self.tblMacro.fixedColumns := 0;
	self.tblMacro.userInputEnabled := false;
	self.tblMacro.selectMode := Table.SelectMode_None;
	self.tblMacro.height:=dkbMacro.height; 
	self.tblMacro.parentAspect:=Table.ParentAspect_StretchBoth;	
	self.tblMacro.width:=dkbMacro.width - app.getVerticalScrollbarWidth;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupMoveSubMenus" id="5a4253b5-07dc-4947-884e-b9916c45e43d">
        <source>setupMoveSubMenus(_parent, _other :MenuItem input; _index :Integer io) protected;
// ---------------------------------------------------------------------------
// Created:     24 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	subMenu	:MenuItem;
begin
	// par24292 - start
	if _parent.visible then								
		// add a sub menu for move to another location
		
		subMenu := _parent.getMenuItem(_index);						
	
		if subMenu = null then
			// add new menu item
			subMenu := _parent.loadSubMenu(_index);					
		endif;
		
		subMenu.caption		:= app.getErrorString (To_Another_Location);
	
		subMenu.setEventMapping(MenuItem::click.name,YRD_RoadOperationsForm::doShowMoveVehicleForm.name);

		subMenu.visible := true;
		
		if _other &lt;&gt; null then
			_other.visible := false;
		endif;
	else
		if _other &lt;&gt; null then
			_other.visible := true;
		endif;
	endif;
	// par 24292 - end
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_parent" type="MenuItem" usage="input"/>
        <Parameter name="_other" type="MenuItem" usage="input"/>
        <Parameter name="_index" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setupOpAreaDocks" id="c286b0a9-b320-45e5-8f9b-4aa61ef3a967">
