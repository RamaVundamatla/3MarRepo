<Class name="WebInPatch" id="d745a9e7-eb3b-4041-837d-cc7c279a7b69">
    <superclass name="Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="HotFixesCommonSchema"/>
    <ExplicitInverseRef name="myPatch" id="8b0dab41-0954-49e6-a9a0-a39275a46bed">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="Patch"/>
        <Inverse name="Patch::allWebsInPatch"/>
    </ExplicitInverseRef>
    <PrimAttribute name="pathName" id="ed0070c8-1ad7-4649-910b-b27ceadb6e00">
        <type name="String"/>
        <access>protected</access>
    </PrimAttribute>
    <PrimAttribute name="targetName" id="1d5e9caf-52f8-438e-8333-d8ed659bf345">
        <type name="String"/>
        <access>protected</access>
    </PrimAttribute>
    <PrimAttribute name="webSite" id="226a9a19-a24b-4ac4-967d-d19baf5ec6a7">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>protected</access>
    </PrimAttribute>
    <JadeMethod name="copy" id="e1549c16-ad3a-4b5e-9ce3-2525302acb54">
        <source>copy() : Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 October 2012	cnwdw1	Initial creation
*/
vars
	patchesDir: String;
	webFolder, siteFolder, targetFolder: FileFolder;
begin
	create webFolder transient;
	patchesDir := self.myPatch.getPatchesDirectory();
	webFolder.fileName := patchesDir &amp; RootHotFixes.DIR_WEB_NAME;
	if not webFolder.isAvailable then
		webFolder.make;
		app.writeLogMessage(' created ' &amp; webFolder.fileName);
	endif;		

	create siteFolder transient;
	siteFolder.fileName := webFolder.fileName &amp; "\" &amp; self.webSite;
	if not siteFolder.isAvailable then
		siteFolder.make;
		app.writeLogMessage(' website created ' &amp; siteFolder.fileName);
	endif;		
	
	if self.isFileCopy then
		if not app.copyAFile(self.pathName, true, siteFolder.fileName &amp; "/" &amp; self.getTargetName, true) then
			app.writeLogMessage(' copy file failed');
			return false;
		endif;
	else
		create targetFolder transient;
		targetFolder.fileName := siteFolder.fileName &amp; "/" &amp; self.getTargetName;
		if not targetFolder.isAvailable then
			targetFolder.make;
			app.writeLogMessage(' Target Folder created ' &amp; siteFolder.fileName);
		endif;	
		if not app.copyAFolder(self.pathName, true, targetFolder.fileName, true) then
			app.writeLogMessage(' copy folder failed');
			return false;
		endif;
	endif;
	
	return true;
	
epilog
	delete webFolder;
	delete siteFolder;
	delete targetFolder;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="display" id="65405312-42db-4827-b55f-bd04999a808f">
        <source>display(): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2012	cnwdw1	Initial creation
*/
vars
	str: String;
begin
	str := "WebSite: " &amp; self.webSite &amp; " Path: " &amp; self.pathName;
	if self.targetName &lt;&gt; null then
		str := str &amp; " Target: " &amp; self.targetName;
	endif;
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="formatForNotepad" id="5faca0db-d448-48cf-b6b2-876c07f389e0">
        <source>formatForNotepad() : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2012	cnwdw1	Initial creation
*/
vars
	str: String;
begin
	str := 'Web ' &amp; self.webSite &amp; ' "' &amp; self.pathName &amp; '"';
	if self.targetName &lt;&gt; null then
		str := str &amp; " " &amp; self.targetName;
	endif;
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTargetName" id="f97ef77a-5eac-43a7-998a-9e805cd1af1e">
        <source>getTargetName() : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2012	cnwdw1	Initial creation
*/
vars
	file: File;
	fileFolder: FileFolder;
begin
	if self.targetName &lt;&gt; null then
		return self.targetName;
	endif;
	
	if self.isFileCopy then
		create file transient;
		file.fileName := self.pathName;
		return file.cnGetSimpleFileName;
	endif;
	
	create fileFolder transient;
	fileFolder.fileName := self.pathName;
	return fileFolder.cnGetSimpleFileName
;

epilog
	delete file;
	delete fileFolder;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isFileCopy" id="e04bcdc5-4051-489f-bf9f-ac3c3b13bb9e">
        <source>isFileCopy() : Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2012	cnwdw1	Initial creation
*/
vars

begin
	return app.fileExists(self.pathName, true);
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="2f29adf4-4c1d-4bf2-865c-fe91f048853c">
        <updating/>
        <source>setForCreate(_webSite, _pathName, _targetName: String; _patch: Patch) updating;

vars
begin
	self.webSite := _webSite;
	self.pathName := _pathName;
	self.targetName := _targetName;
	self.myPatch := _patch;
epilog
end;</source>
        <Parameter name="_webSite" type="String"/>
        <Parameter name="_pathName" type="String"/>
        <Parameter name="_targetName" type="String"/>
        <Parameter name="_patch" type="Patch"/>
    </JadeMethod>
    <JadeMethod name="validate" id="beabef87-6bc4-44f9-9657-906963327440">
        <source>validate() : Boolean;

vars

begin
	if self.webSite.toUpper &lt;&gt; "TALLYMAN" and 
	   self.webSite.toUpper &lt;&gt; "KEA" and 
	   self.webSite.toUpper &lt;&gt; "JMT_RIA" then
   		app.writeLogMessage('WebSite must be one of Tallyman, KEA, JMT_RIA');
		return false;
	endif;
	
	if self.pathName &lt;&gt; null and not app.pathExists(self.pathName, true) then
   		app.writeLogMessage('Path does not exist: ' &amp; self.pathName);
		return false;
	endif;

	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
