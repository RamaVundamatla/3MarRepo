    <JadeMethod name="getDamageOnCargo" id="fa7d68d6-a632-43e8-bc46-d22c33442349">
        <updating/>
        <source>getDamageOnCargo(cargoUid : String) : WS_CargoDamageResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
17 Oct 2022		navlw1	TFS 54812: EUP - WMS - Damage Extra Details

*/

vars
	response 		: WS_CargoDamageResponse;
	ti 				: CM_TrackedItem;
	terminal		: CM_Terminal;
	damageItem		: CM_DamageInstance;
	wsDamageItem	: WS_DamageDetails;
	queryParam 		: WS_NameValuePair;
	ignoreRepaired 	: Boolean;
	
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	create response transient;
	
	queryParam := self.qsData[self.QueryParam_IgnoreRepaired];
	if queryParam &lt;&gt; null then
		ignoreRepaired := queryParam.value.Boolean;
	endif;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		// user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
		if app.myPassport.hasErrors then
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	ti := app.myPassport.getObjectOfTypeFromOid(cargoUid, CM_TrackedItem).CM_TrackedItem;
	
	if ti = null then
		app.raiseCMException1(Cargo_item_not_found, cargoUid , null, null);
		self.httpStatusCode := HttpResponseNotFound;
		return response;
	endif;
	
	foreach damageItem in ti.allDamageInstancesByTS reversed do // Return the damage by timestamp with the latest first	
		if ignoreRepaired and damageItem.repaired then
			continue;
		endif;
		create wsDamageItem transient;
		wsDamageItem.setProxyFromObject(damageItem);
		response.allDamageItems.add(wsDamageItem);
	endforeach;
	response.photosCount := ti.numAttachments(CM_Photo.Type_Photo);
	return response;
epilog
	finaliseResponse(response);
end;</source>
        <Parameter name="cargoUid" type="String"/>
        <ReturnType type="WS_CargoDamageResponse"/>
    </JadeMethod>
