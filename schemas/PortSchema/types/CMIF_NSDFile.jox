    </JadeMethod>
    <JadeMethod name="readSignedByte" id="fd33dbb4-94de-4af0-864d-868ed3a081ae">
        <source>readSignedByte(_file : File io ; _length : Integer):Byte;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2020	jlgma1	Initial creation

*/

vars
	byte : Byte;
begin
	byte := _file.readBinary(_length).Byte;
	
	return byte;
epilog

end;</source>
        <Parameter name="_file" type="File" usage="io"/>
        <Parameter name="_length" type="Integer"/>
        <ReturnType type="Byte"/>
    </JadeMethod>
    <JadeMethod name="readStringBuffer" id="e2bf7ce2-5b15-40a5-9309-a7398586b94f">
        <source>readStringBuffer(_file       : File io;
				 _bufferSize : Integer ) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2020	jlgma1	Initial creation

*/

vars
	str			    : String;
	remainingBytes,
	stringLength    : Integer;

begin
	write "_file.currentOffset ###:" &amp; _file.currentOffset().String;
	
	stringLength := self.readUnsignedByte(_file,_bufferSize);
	self.skipBytes(_file,1);
	str :=  _file.readBinary(stringLength).asStringJMT;
	
	write "_file.currentOffset Before:" &amp; _file.currentOffset().String;
	write "Str := " &amp; str;
	remainingBytes := _bufferSize - str.length -1 ;
	
	self.skipBytes(_file,remainingBytes);
	
	write "_file.currentOffset After :" &amp; _file.currentOffset().String;
	return str;
epilog

end;</source>
        <Parameter name="_file" type="File" usage="io"/>
        <Parameter name="_bufferSize" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="readUnsignedByte" id="ec912248-ee1b-4318-b953-87481c91b866">
        <source>readUnsignedByte(_file : File io ; _length : Integer):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2020	jlgma1	Initial creation

*/

vars
	byte : Byte;
	byte1 : Byte;
	byte2 : Byte;
begin
	byte := _file.readBinary(_length).Byte;
	byte1 := 255.Integer.Byte;
	//byte2 := "FF".asHex.Byte;
	return  byte.bitAnd(byte1).Integer;
epilog

end;</source>
        <Parameter name="_file" type="File" usage="io"/>
        <Parameter name="_length" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="readUnsignedShort" id="4937b7f1-42b9-40fc-ad29-6ff6aa3095d6">
        <source>readUnsignedShort(_file :File io ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 February 2020	jlgma1	Initial creation

*/

vars
	ch1,a :  Integer;
	ch2 : Integer;
	str1,
	str2 : String;
	byte1,
	byte2 : Byte;
	bin1,
	bin2	: Binary;
begin

	ch1 := _file.readBinary(1).Integer.leftBitShift(8);
	ch2 := _file.readBinary(1).Integer.leftBitShift(0);

	
	return ch1 + ch2;
epilog

end;

/*  int ch1 = in.read();
        int ch2 = in.read();
        if ((ch1 | ch2) &lt; 0)
            throw new EOFException();
        return (ch1 &lt;&lt; 8) + (ch2 &lt;&lt; 0);*/</source>
        <Parameter name="_file" type="File" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="skipBytes" id="591f4340-ce75-4025-bad3-fcee26f6a73c">
        <source>skipBytes(_file 	: File io;
		  _skipInt  : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 February 2020	jlgma1	Initial creation

*/

vars
	i : Integer;
begin
	foreach i in 1 to _skipInt do
	
		_file.readBinary(i);
	
	endforeach;
epilog

end;</source>
        <Parameter name="_file" type="File" usage="io"/>
        <Parameter name="_skipInt" type="Integer"/>
    </JadeMethod>
</Class>
