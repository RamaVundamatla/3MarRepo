    <JadeMethod name="doRemoveDeckItemRemarks" id="6717ef1f-842d-48cb-b33c-e8b4cdbf1184">
        <source>doRemoveDeckItemRemarks(_deckItem :CM_DeckItem) protected;
/*
Date		Who		Reason
13 Aug 2012	cnwcs5	Initial creation - par 29124
*/
vars
	obj				:Object;
	control 		:Control;
	layout			:CM_DeckItemLayout;
	deckItem		:CM_DeckItem;
	gotException	:Boolean;
begin
	on Exception do app.handleDeletedObject (exception, layout, gotException);
	
	foreach obj in self.allRemarksControls do
		control		:= obj.Control;
		layout		:= control.userObject.CM_DeckItemLayout;
		deckItem	:= layout.getDeckItem;
		
		if gotException or deckItem = _deckItem then
			self.allRemarksControls.remove (control);
			delete control;
			gotException := false;
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_deckItem" type="CM_DeckItem"/>
    </JadeMethod>
    <JadeMethod name="doRepositionRemarks" id="dca2fbb9-eebd-4d3e-a52e-6aeaeb7589b1">
        <source>doRepositionRemarks() protected;
/*
Date		Who		Reason
30 July 2012	cnwcs5	Initial creation - par 29124
*/
vars
	obj			:Object;
	control		:Control;
	layout		:CM_DeckItemLayout;
	left, top	:Real;	// note same name as form properties
	gotException	:Boolean;
begin
	// we may need to re-position remarks
	on Exception do app.handleDeletedObject (exception, layout, gotException);
	
	foreach obj in self.allRemarksControls do
		control := obj.Control;
		
		if not control.name = self.picRemarks.name then
			continue;
		endif;
		// user object is the slot
		layout := control.userObject.CM_DeckItemLayout;
		
		if layout = null then
			continue;
		endif;
		
		// find the top left position for the location
		if not self.getPositionForRemarks (layout, left, top) then
			// should not happen
			continue;
		endif;
		
		if gotException then
			// Layout has been deleted
			self.allRemarksControls.remove (control);
			delete control;
			
			gotException := false;
			continue;
		endif;

		control.move (left, top, control.width, control.height);
	endforeach;	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="e6c57266-0972-45f1-8b58-5bfafa352632">
        <updating/>
        <source>doResize() updating;
/*
Purpose:			
Date		Who		Reason
09 June 2011	cnwab1	Initial creation

*/

vars
	folder	:Folder;
	toolbar	:CMUI_Toolbar;
	frame	:CMUI_ScrollableDrawingFrame;
begin
	inheritMethod();
	
	folder 	:= self.fldMain;
	toolbar	:= self.frmToolbar;
	
	folder.top 		:= toolbar.top + toolbar.height + self.frmToolbar2.height; // TFS 50421   27;		// 1/2/17 MAP TFS3267
	folder.height 	:= (folder.top - self.frmStatus.top) ;
	
	frame := self.frmDeck;
	
	frame.repositionAfterResize();
	frame.resizeDrawingFrame((self.deckX2Offset * self.scaleFactor ) + 10, (self.deckY2Offset * self.scaleFactor) + 10);
	self.frmPhotoThumb.doResize();
	self.repositionAllBackFrames();
	frame.myTopLeftFillerFrame.zOrder(1);
	self.frmStatus.doResize();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRotateLocnDefn" id="7e051b33-67f3-493f-b795-83b1eb266aac">
        <updating/>
        <source>doRotateLocnDefn(_theDeckItem : CM_ROROLocnDefn;  _items, _split : Integer; _isLoad : Boolean) updating;
/*
Purpose:			
Date		Who		Reason
13 July 2011	cnwab1	Initial creation
*/

vars

	theReturn : Integer;

begin
		
	while true do
		app.myTrxUA.trxUpdateROROLocnDefnRotate(_theDeckItem, _items, _split, _isLoad, app.myPassport, _isLoad); // PAR 28990 PAR 31110 PAR 31162
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Locn_rotate), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

epilog

end;</source>
        <Parameter name="_theDeckItem" type="CM_ROROLocnDefn"/>
        <Parameter name="_items" type="Integer"/>
        <Parameter name="_split" type="Integer"/>
        <Parameter name="_isLoad" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveCC" id="b55f9b83-e1e7-48ff-9ebf-a208be9ece4a">
        <updating/>
        <source>doSaveCC(_voyAllocation : CM_VoyageAllocation) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 December 2009	cnwas3	Initial creation

*/

vars
	ct : CM_CargoType;
begin

	if self.modeView = ShpDisplayMode_ColCodeLoad then
		if _voyAllocation.isForContainer() then
			self.updateSlotRequestAttributes(_voyAllocation, 1);
		elseif _voyAllocation.isForBulk() then	//09 Dec 2019	NDL	TFS 46875
			app.msgBox( app.getErrorString(Colou_code_plann_bulk_weigh_vo), app.getErrorString(Warning),MsgBox_OK_Only);
			return;
		else
			self.doGetQuantity(_voyAllocation, self.GetData_Quantity, null); // PAR 28985
		endif;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString1(Invalid_display_mode_none,self.modeView.String));
	endif;

end;</source>
        <Parameter name="_voyAllocation" type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="doSaveJob" id="d82d150b-8b56-4a5a-8973-b840991514f5">
        <updating/>
        <source>doSaveJob(_fromToolBar, _fromFrmHatchLidJob : Boolean) updating, protected;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

vars
	theSlots,
	theSlotsAlt		: CM_LCArray;
	slot : CM_VoyageROROController;
	editions : CM_ObjectByOidEditionDict;
	theJobId, theCraneID : String;
	theJobParams : CMIF_VoyageJobParams;
	isCreate : Boolean;
	aftReq : CM_RORORequest;
	theReturn	: Integer;
	theRealVJob,
	theProxyVJob : CM_VoyageJob;
	isLoad, isLaneJob : Boolean;
	theWP : CM_WorkPoint;
	lc : CM_LocationsController;
begin

	if (self.modeWork &lt;&gt; WorkMode_Job) then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString1(Invalid_working_mode_something,self.modeWork.String));
		return;
	endif;

	app.mousePointer := Window.MousePointer_HourGlass;
	isLoad := (self.modeView = ShpDisplayMode_ColCodeLoad);
	create theSlotsAlt transient;
	create theSlots transient;


	theJobId := self.cmbWPJob.text.trimBlanks.toUpper;
	isCreate := false;
	if self.cmbWorkPoint.listObject &lt;&gt; null then
		if self.cmbWorkPoint.listObject.isKindOf(CM_WorkPoint) then
			theWP := self.cmbWorkPoint.listObject.CM_WorkPoint;
			theCraneID := theWP.code;
		else
			theCraneID := self.cmbWorkPoint.listObject.CM_Crane.id.trimBlanks;
		endif;
	endif;

	if (not _fromToolBar) then // called from context menu
		isCreate := true;
	else
		theRealVJob := self.myCurrentJob; // do not use teh combo box incase we have changed teh job id //self.cmbWPJob.listObject.CM_VoyageJob;
		if theRealVJob = null  then
			isCreate := true;
		endif;
	endif;

	
	create theJobParams transient;
	theJobParams.useNewMethod := true;
	
	if (not isCreate) then
		// PAR 28941
		if theRealVJob.myDeck &lt;&gt; self.myCurrentDeck then
			self.cmbWPJob.setFocus();
			return;
		endif;

		theProxyVJob := app.createUpdateProxy(theRealVJob).CM_VoyageJob;
	endif;

	theJobParams.isDischarge			:= not isLoad;
	theJobParams.jobNumLinkedLoad	:=	null; //self.txtJobLinkLoad.text.trimBlanks.toUpper;
	theJobParams.craneID				:=	theCraneID;
	theJobParams.myVoyage			:=	self.myCurrentVoyage;
	theJobParams.myProxyJob			:=	theProxyVJob;
	theJobParams.resquence			:=	true;		//set true whenever there's the posibility of slots added/removed from a job
	theJobParams.isSeqForJob			:=	false;
	theJobParams.myDeck				:= self.myCurrentDeck;
	theJobParams.myWorkPoint		:=theWP;
	theJobParams.id 						:= theJobId.toUpper;
	if isLoad then //cnwrd1 par 31771 19.6.13
		theJobParams.allowOutOfOrderLoading	:= self.chkOutOfSequence.value;  //cnwrd1 par 30626 ccms 2209 23.10.12
	else
		theJobParams.allowOutOfOrderLoading	:= false;  //cnwrd1 par 30626 ccms 2209 23.10.12
	endif;
	
	
	
	// Get the selected objects on the side view, if that has none then use the selected objects on the deck view
	if self.mySideViewForm &lt;&gt; null then
		if  not self.mySideViewForm.myROROLocnDrawingController.getSelectedObjectsAndALT(theSlots, theSlotsAlt) then
			self.myROROPlanDrawController.getSelectedObjectsAndALT(theSlots, theSlotsAlt);
			editions := self.myROROPlanDrawController.allObjectEditions;
		else
			editions := self.mySideViewForm.myROROLocnDrawingController.allObjectEditions;
		endif;
	else
		self.myROROPlanDrawController.getSelectedObjectsAndALT(theSlots, theSlotsAlt);

		editions := self.myROROPlanDrawController.allObjectEditions;
	endif;



	editions.copy(theJobParams.allObjectEditions);
	foreach lc in theSlots discreteLock do
		slot := lc.CM_VoyageROROController;
		//if isLoad and slot.myRORORequestLoad &lt;&gt; null then
		if isLoad and slot.myRORORequestLoad &lt;&gt; null and not slot.myRORORequestLoad.allAllocations.isEmpty then	//23 Oct 2012	NDL	Par 30608
			aftReq := slot.myRORORequestLoad.getFwdSlotReq().CM_RORORequest;
			if aftReq = null then // 20s and fwd 40 slots only
				theJobParams.allROROControllers.add(slot);
			endif;
		elseif not isLoad then
			if slot.myRORORequestDischarge &lt;&gt; null then
				aftReq := slot.myRORORequestDischarge.getFwdSlotReq().CM_RORORequest;
				if aftReq = null then // 20s and fwd 40 slots only
					theJobParams.allROROControllers.add(slot);
				endif;
			// Adding a LOAD SOB to the Discharge Job
			elseif slot.myRORORequestLoad &lt;&gt; null and slot.myRORORequestLoad.isSoB then
				aftReq := slot.myRORORequestLoad.getFwdSlotReq().CM_RORORequest;
				if aftReq = null then // 20s and fwd 40 slots only
					theJobParams.allROROControllers.add(slot);
				endif;
			endif;
		endif;
		
		if slot.isROROVoyageLanePos() or slot.isLaneController() then
			isLaneJob := true;
		endif;
	endforeach;

	if isLaneJob then
		self.doSaveJobLanes(theJobParams);
	endif;

	// PAR 28986
	if theJobParams.allROROControllers.isEmpty() then
		return;
	endif;

	while true do
		if isCreate then
			app.myTrxCA.trxCreateVoyageJob(theJobParams, theRealVJob, app.myPassport);
		else
			app.myTrxUA.trxUpdateVoyageJob(theJobParams, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			self.hasChanged := false;
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Job_save), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;

	self.doCmbJobBuild(true);
	
	if not theJobParams.allTIs.isEmpty then
		self.myAssistant.showShipNowSingleLiftForm(theJobParams, self.myMasterMenuAction);
	endif;
epilog
	if theJobParams &lt;&gt; null then
		delete theJobParams.myProxyJob;
	endif;
	delete theJobParams;
	delete theSlotsAlt;
	delete theSlots;

//	self.txtJobLinkLoad.text := null;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <access>protected</access>
        <Parameter name="_fromToolBar" type="Boolean"/>
        <Parameter name="_fromFrmHatchLidJob" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveJobLanes" id="6eeb3ef7-25a7-438c-957e-25936dd37f84">
        <source>doSaveJobLanes(_theJobParams : CMIF_VoyageJobParams input);
/*
Purpose:			
Date		Who		Reason
07 December 2011	cnwab1	Initial creation
*/

vars
	obj : Object;
	theReq : CM_RORORequest;
begin
	foreach obj in self.myROROPlanDrawController.allSelectedObjects discreteLock do
		if obj.isKindOf(CM_RORORequestLayout) then
			theReq := obj.CM_RORORequestLayout.myRequest;
			_theJobParams.allRORORequests.addNoDuplicates(theReq, false);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_theJobParams" type="CMIF_VoyageJobParams" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSetJobComboForClick" id="459b1f43-742a-45f8-988a-39d6e28d92ec">
        <updating/>
        <source>doSetJobComboForClick(_theJob : CM_VoyageJob) updating;
/*
Purpose:			
Date		Who		Reason
28 September 2011	cnwab1	Initial creation
*/

vars

begin
	if _theJob = null then
		return;
	endif;
	
	self.cmbWorkPoint.setIndexFromObject(_theJob.getWorkPointObject());
	self.doCmbJobBuild(false);
	self.cmbWPJob.setIndexFromObject(_theJob);
	self.setCurrentJob(_theJob);
	self.chkOutOfSequence.value := _theJob.allowOutOfOrderLoading;  //cnwrd1 par 30626 ccms 2209 23.10.12

epilog

end;</source>
        <Parameter name="_theJob" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="doShowCraneShiftAllocation" id="ad9ee135-3033-478c-bb35-f1696edd6920">
        <source>doShowCraneShiftAllocation();
/*
Purpose:			
Date		Who		Reason
17 February 2017	cnwab1	Initial creation
*/

vars

	form 		: SHP_VoyageJobShifts;

begin
	if self.myCurrentVoyage = null then
		app.msgBox(app.getErrorString(SHP_Please_Select_A_Voyage),app.getErrorString(ERR_ErrorBoxTitle), MsgBox_OK_Only);
		return;
	endif;
	
	form := app.loadForm(SHP_VoyageJobShifts, SHP_Assistant, false, false, true, self.myTerminal, null).SHP_VoyageJobShifts;	
	
	if form = null then
		return;
	endif;	
	
	
	form.setParentForm(self);
	form.setMyCurrentVoyage(self.myCurrentVoyage);
	

	form.show;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowRemarks" id="d8fa21d5-cce0-4ba4-9c01-d89b11f0e00c">
        <updating/>
        <source>doShowRemarks() updating, protected;
/*
Date		Who		Reason
25 Jul 2012	cnwcs5	Initial creation - par 29124
20 Aug 2012	cnwcs5	par 29124:2 - fix layout remarks display
19 Dec 2012	cnwrs1	Par 30922 problems with deck item remarks
*/
vars
	obj				: Object;
	control			: Control;
	layer 			: CM_DeckLayerLayout;
	layerFrame 		: CMUI_PointDrawingFrame;
	layout 			: CM_DeckItemLayout;
	left, top		: Real;
	gotException	: Boolean;
	layerType		: Integer;		// par 29124:2 Aug 2012
	set				: ObjectSet;	// par 29124:2 Aug 2012
	deckItem		: CM_DeckItem;	// par 29124:2 Aug 2012
begin 
	if self.haveCreatedRemarks then
		// just make them visible again
		on Exception do app.handleDeletedObject (exception, layout, gotException);
		
		foreach obj in self.allRemarksControls do
			control := obj.Control;
			
			if control.isKindOf (Picture) then
				// user object is the slot
				layout := control.userObject.CM_DeckItemLayout;
		
				if layout = null then
					// should not happen
					control.visible := false;
					continue;
				endif;
		
				// find the top left position for the location
				if not self.getPositionForRemarks (layout, left, top) then
					// should not happen
					continue;
				endif;
				
				if gotException then
					// Layout has been deleted
					self.allRemarksControls.remove (control);
					delete control;
					
					gotException := false;
					continue;
				endif;
		
				control.move (left, top, control.width, control.height);
			endif;
			// they are there - make them visible
			control.visible := true;
		endforeach;
	else
		create set transient;
		
		foreach obj in self.myROROPlanDrawController.allBackFrames  do
			layerFrame 	:= obj.CMUI_PointDrawingFrame; 
			
			if not layerFrame.visible then					// par 29124:2 Aug 2012
				continue;									// par 29124:2 Aug 2012
			endif;											// par 29124:2 Aug 2012
			
			layer 		:= layerFrame.userObject.CM_DeckLayerLayout;
			layerType	:= layer.type;						// par 29124:2 Aug 2012
							
			if layerType &lt;&gt; ROROLayerType_CCLoad and		// par 29124:2 Aug 2012
				layerType &lt;&gt; ROROLayerType_Cargo then		// par 29124:2 Aug 2012
				continue;									// par 29124:2 Aug 2012
			endif;											// par 29124:2 Aug 2012
			
			foreach layout in layer.allDeckItemLayouts do 
				deckItem	:= layout.getDeckItem;			// par 29124:2 Aug 2012
				if deckItem = null then	//18 dec 2012	cnwrs1	Par 30922 
					continue;
				endif;
				if set.includes (deckItem) then				// par 29124:2 Aug 2012
					continue;								// par 29124:2 Aug 2012
				endif;										// par 29124:2 Aug 2012

				self.doDrawRemarks(layout);
				
				set.add (deckItem);							// par 29124:2 Aug 2012

			endforeach;	
		endforeach;
		
		self.haveCreatedRemarks		:= true;
	endif;

epilog
	delete set;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTableDblClick" id="877f9b0f-bf91-45f6-b3aa-65268cdad4ef">
        <updating/>
        <source>doTableDblClick(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	itemObject : CM_Object;
begin

	if table = null then
		return;
	endif;
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	
	if table.accessRow(table.row).itemObject &lt;&gt; null then
		//cnwjo3 par 25628
		itemObject := table.accessRow(table.row).itemObject.CM_Object;
		
		if itemObject.isKindOf(CM_VoyageAllocation) then
			//at the moment do nothing.  possibly open voyage configuration later if customer requires
		else
			self.myAssistant.showTableMaintForm(itemObject, self.myMasterMenuAction, false, false);
		endif;
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblDeckClick" id="d0159d2d-672c-4ba6-86d9-70f3d08988a0">
        <updating/>
        <source>doTblDeckClick() updating; 

// 30 Jul 2012	cnwcs5	par 29124
vars
	x1, y1, x2, y2  :Integer;
	deck			:CM_DeckVoyage;
	table			:CM_DataTable;
begin
	self.doClearRemarks;	// par 29124
	
	table	:= self.tblDecks;
	deck 	:= table.accessRow(table.row).itemObject.CM_DeckVoyage;
	
	//cnwmc5 - PAR #31061
	if deck &lt;&gt; null then
		self.myCurrentDeck	:= deck;
	endif;
	
	if deck = null then
		//cnwmc5 - 09/01/2013 - PAR #30965
		self.changeViewMode(self.modeView);
		return;
	endif;
	
	x1 := 9999999;
	y1 := 9999999;

	deck.myDeckLayout.getExtremePoints(x1, y1, x2, y2);
	
	self.deckX1Offset := x1;
	self.deckX2Offset := (x2* 1.2).Integer; // PAR 30227 noticed in testing that this is a bit tight
	self.deckY1Offset := y1;
	self.deckY2Offset := (y2 * 1.75).Integer; // PAR 30227 noticed in testing that this is a bit tight
	
	if self.deckY1Offset = 0 then
		self.deckY1Offset := 1;
	endif;
	
	self.drawDeckLayouts();
	self.doJobsRefresh();
	self.doEnableJobButtons(true);
	self.doResize();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblLayerClick" id="9e1cbba9-0c6c-48a8-8601-fc638169925a">
        <updating/>
        <source>doTblLayerClick() updating;
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 30 Jul 2012	cnwcs5	par 29124 - remarks
// 21 Aug 2012	cnwcs5	par 29124:2 - always hide/show remarks
vars
	theCol, theRow, stIdx, endIdx, idx  : Integer;
	shipLayer 	: CM_DeckLayerLayout;
	frame 		: CMUI_PointDrawingFrame;
	obj 		: Object;
	table		: CM_DataTable;
	controller	: SHP_ROROPlanDrawingController;	
begin
	table		:= self.tblLayers;
	theRow 		:= table.row;
	controller	:= self.myROROPlanDrawController;
	
	if theRow &lt;= table.fixedRows then
		return;
	endif;
	
	theCol := table.column;
	
	self.myCurrentDeckItem 	:= null;
	shipLayer 				:= table.accessRow(theRow).itemObject.CM_DeckLayerLayout;
	
	self.setModeOnBackFrames(CMUI_PointDrawingFrame.Mode_Work); 
	self.doClearTopDrawingFrame(true);
	
	if self.myCurrentLayer &lt;&gt; null then
		frame := self.getFrameForLayer(self.myCurrentLayer, controller.allBackFrames);

		self.doDrawLayer(frame, self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame);
	endif;
	
	// Select Layer
	if theCol &lt;&gt; 1 then 
		return;
	endif;
	
	self.myCurrentLayer := shipLayer;
		
	if self.myCurrentLayer = null then // ALL LAYERS
		self.myCurrentDrawingFrame 	:= null;
		backFrameIndex 				:= 0;
		
		foreach obj in controller.allBackFrames do
			shipLayer := obj.Frame.userObject.CM_DeckLayerLayout;
						
			if not shipLayer.isVisible then
				continue;
			endif;
			
			if self.modeView = ShpDisplayMode_Defn then
				if shipLayer.type = ROROLayerType_CCDischarge 
				or shipLayer.type = ROROLayerType_CCLoad
				or shipLayer.type = ROROLayerType_GC then
					continue;
				endif;
			endif;
			if self.modeView = ShpDisplayMode_Actual then
				if shipLayer.type = ROROLayerType_CCDischarge 
				or shipLayer.type = ROROLayerType_CCLoad then
					continue;
				endif;
			endif;
			if self.modeView = ShpDisplayMode_Proposed then
				if shipLayer.type = ROROLayerType_CCDischarge 
				or shipLayer.type = ROROLayerType_CCLoad then
					continue;
				endif;
			endif;
			
			obj.Frame.visible := true;
		endforeach;
	else
		// HIDE ALL EXCEPT STRUCTURES
		foreach obj in controller.allBackFrames do
			shipLayer := obj.Frame.userObject.CM_DeckLayerLayout;
			
			if shipLayer.type = ROROLayerType_Structure then
				obj.Frame.visible := true;
				continue;
			endif;
			
			obj.Frame.visible := false;
		endforeach;
		
		
		// PAR 29897 show all selected layers
		stIdx 		:= 2;
		endIdx 		:= table.rows;
		
		foreach idx in stIdx to endIdx do
			table.accessRow(idx);
						
			shipLayer 	:= table.accessedRow.itemObject.CM_DeckLayerLayout;
			
			if not table.accessedRow.selected then
				continue;
			endif;

			frame 			:= self.getFrameForLayer(shipLayer, controller.allBackFrames);
			backFrameIndex 	:= 0;
			frame.visible 	:= true;	
			self.myCurrentDrawingFrame := frame.CMUI_PointDrawingFrame;
		endforeach;

		if self.myCurrentLayer.type = ROROLayerType_GC then
			self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame.mode := CMUI_PointDrawingFrame.Mode_LineAlter;
		endif;
	endif;
	
	self.doClearRemarks;				// par 29124:2 Aug 2012		
	
	if self.btnDrawRemarks.value then	// par 29124:2 Aug 2012
		self.doShowRemarks;				// par 29124:2 Aug 2012
	endif;								// par 29124:2 Aug 2012
end;</source>
    </JadeMethod>
    <JadeMethod name="doUnRotateLocnDefn" id="24ffb251-78b7-4799-96c2-08b5e32625bd">
        <updating/>
        <source>doUnRotateLocnDefn(_theDeckItem : CM_ROROLocnDefn) updating;
/*
Purpose:			
Date		Who		Reason
13 July 2011	cnwab1	Initial creation
*/

vars

	theReturn : Integer;
	isLoad : Boolean;
begin
	if _theDeckItem.isOOTL then // PAR 29990
		isLoad := (_theDeckItem.isRotatedLoadLayer); // PAR 29990
	else
		isLoad := (self.modeView = ShpDisplayMode_ColCodeLoad); // PAR 29884
	endif;
	
	while true do
		app.myTrxUA.trxUpdateROROLocnDefnUnRotate(isLoad, _theDeckItem,  app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Locn_unrotate), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

epilog

end;</source>
        <Parameter name="_theDeckItem" type="CM_ROROLocnDefn"/>
    </JadeMethod>
    <JadeMethod name="doUnplanBulkReleases" id="c92ae486-9800-4a07-9660-2ccb25bb9245">
        <updating/>
        <source>doUnplanBulkReleases( _tmpSlots : CM_LCArray) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 December 2012	cnwrd1	Initial creation

*/

vars
	theReturn : Integer;
begin

	while true do
		if _tmpSlots.isEmpty() then	//14 Jan 2020 NDL	TFS 46815
			break;
		endif; 		
		app.myTrxUA.trxROROControlerUpdateRelease(_tmpSlots, null ,  app.myPassport);		
		//app.myTrxUA.trxUpdateRORORequestVA(theSlots, theSlotsAlt, isLoad,editions	, _voyAllocation, numItems, app.myPassport);	
		
		if app.myPassport.trxCompletedOK then
			self.hasChanged := false;
			self.myROROPlanDrawController.updateEditionForSelectedObjs(_tmpSlots);
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Assign_roro_request_attribute), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
					theReturn = IDOK then
			// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;

epilog

end;</source>
        <Parameter name="_tmpSlots" type="CM_LCArray"/>
    </JadeMethod>
    <JadeMethod name="doUserNotifyLayers" id="662ffb38-91c5-4149-9445-4f7c4baaf4c6">
        <updating/>
        <source>doUserNotifyLayers(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) protected, updating;
/*
Purpose:	the layers are maintained on a seperate form		
Date				Who			Reason
APRIL 2011		CNWAB1		Initial creation
*/


vars
	layerFrame : CMUI_PointDrawingFrame;
	idx : Integer;
	aLayer : CM_DeckLayerLayout;
begin

	// PAR 29979 - noticed during testing
	if self.myCurrentDeck = null then
		return;
	endif;


	if eventType = EVENT_RORO_LAYER_UPDATE then
		// PAR 28890. When we rotate atcual locnDefn, we now rotate some clones of the locndefn on the load layer. 
		//					The first time this happens we do not know about these locn defn and we do not know about the new load layer 
		//					so we pass the new load layer through with the cargo layer
		aLayer := theObject.CM_DeckLayerLayout;
		layerFrame := self.getFrameForLayer(aLayer, self.myROROPlanDrawController.allBackFrames);
		if layerFrame = null then
			// This happens for the first item on a layer. The layer has just been created so it does not have a frame to draw it
			self.doCloneBackFrame(aLayer, self.shtDeck, self.scaleFactor, self.myROROPlanDrawController.allBackFrames, true);
			self.doDrawLayers();
		else
			self.doClearTopDrawingFrame(true);
			self.doDrawLayer(layerFrame, self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame);
		endif;

		// PAR 28890 - if we have rotated/unrotating  locns we pass through the cargo layer and the load layer
		if userInfo.isKindOf(CM_DeckLayerLayout) then 
			aLayer := userInfo.CM_DeckLayerLayout;
			layerFrame := self.getFrameForLayer(aLayer, self.myROROPlanDrawController.allBackFrames);
			if layerFrame = null then
				// This happens for the first item on a layer. The layer has just been created so it does not have a frame to draw it
				self.doCloneBackFrame(aLayer, self.shtDeck, self.scaleFactor, self.myROROPlanDrawController.allBackFrames, true);
				self.doDrawLayers();
			else
				self.doClearTopDrawingFrame(true);
				self.doDrawLayer(layerFrame, self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame);
			endif;
		endif;
		
		
		
		if self.mySideViewForm &lt;&gt; null then
			self.mySideViewForm.doRedisplay();
		endif;
	endif;
	
	if eventType = EVENT_RORO_ITEM_UPDATE then


		self.doDrawSelectObject(false);		//cnwmc5 - 26 Nov 2013 - PAR 32697

			
			// PAR 28409 if the GC location has been updated need to draw the cargo layer to show/hide covered container positions
			aLayer := self.myCurrentDeck.myDeckLayout.getCargoLayer();
			if aLayer &lt;&gt; null then
				layerFrame := self.getFrameForLayer(aLayer, self.myROROPlanDrawController.allBackFrames);
				if layerFrame &lt;&gt; null then

					self.doDrawLayer(layerFrame,null);

				endif;
			endif;
	elseif eventType = EVENT_RORO_ITEM_DELETE then
		if self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame.allPointGraphics.includes(theObject) then
			self.doClearTopDrawingFrame(true);
		endif;
		if theObject.isKindOf(CM_DeckItemLayout) then
			// ** 28878 Jan 2012 - works but is not sensitive to tblLayers
			if userInfo.isKindOf(CM_DeckLayerLayout) then
				aLayer := userInfo.CM_DeckLayerLayout;
			else
				aLayer := self.myCurrentDeck.myDeckLayout.getCCDischargeLayer();
			endif;
			layerFrame := self.getFrameForLayer(aLayer, self.myROROPlanDrawController.allBackFrames);

			self.doDrawLayer(layerFrame,null);
			
			// PAR 28920
			if theObject = self.myCurrentItemLayout then
				self.myCurrentItemLayout := null;
				self.myCurrentDeckItem := null;
			endif;
			if theObject = self.myCurrentDeckItem then
				self.myCurrentItemLayout := null;
				self.myCurrentDeckItem := null;
			endif;
		endif;
		
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="drawDeckLayouts" id="42fcc0cf-573e-436e-a424-1e66e60aeb16">
        <updating/>
        <source>drawDeckLayouts() updating;
// ---------------------------------------------------------------------------
// Created:     06 April 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame.mode := CMUI_PointDrawingFrame.Mode_Work; //Mode_Work;

	self.doClearTopDrawingFrame(true);

	self.doCloneBackFrames();
	self.setModeOnBackFrames(CMUI_PointDrawingFrame.Mode_Work); //Mode_MultiSelect); //Mode_Work);

	if self.optColour.value then
		self.myROROPlanDrawController.modeViewSub := ShpDisplayModeSub_Colour;
		self.setModeSubOnBackFrames(ShpDisplayModeSub_Colour);
		self.myROROPlanDrawController.modeView := self.modeView;
	else
		self.myROROPlanDrawController.modeViewSub := ShpDisplayModeSub_Text;
		self.setModeSubOnBackFrames(ShpDisplayModeSub_Text);
		self.myROROPlanDrawController.modeView := self.modeView;
	endif;
	
	self.doDrawLayers();

	self.frmDeck.zOrder(1);
	self.frmDeck.myHLabels.zOrder(1);
	self.frmDeck.myVLabels.zOrder(1);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="eraseLoadCCLocation" id="e403d72c-c6fb-41bb-b5ca-37c240b4d711">
        <source>eraseLoadCCLocation();
/*
Purpose:			
Date			Who		Reason
11 August 2011	cnwab1	Initial creation
13 Aug 2012		cnwcs5	par 29124
*/

vars
	obj 		: Object;
	deckItem 	: CM_DeckItem;
	theReturn 	: Integer;
begin
	foreach obj in self.myROROPlanDrawController.allSelectedObjects discreteLock do
		if not  obj.isKindOf(CM_RORORequest) then
			continue;
		endif;
			
		deckItem := obj.CM_RORORequest.myROROController.getDefn();
		if deckItem.isOOTL or deckItem.isLocnGC then
			break;
		endif;
		deckItem := null;
	endforeach;
	
	if deckItem = null then
		return;
	endif;
	
	while true do
		app.myTrxDA.trxDeleteRORODeckItem(deckItem,app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.doRemoveDeckItemRemarks (deckItem);	// par 29124
			
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Delete_load_cc_location), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="findContextSlot" id="756f483c-16bf-4918-b682-b39bb5b0def5">
        <source>findContextSlot(_roroRequest : CM_RORORequest input) : CM_RORORequest;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 December 2012	cnwrd1	Initial creation

*/

// answer the slot to use as context for creating the Assign Release Context Menu
// If no slot selected, then answer the slot the mouse is over
// If slot(s) selected, then answer the first slot in selection
// slots must be same job
vars
	contextSlot,
	roroRequestLoad : CM_RORORequest;
	selectedObject : Object;
begin
	if self.modeWork = WorkMode_Plan  then
		if self.myROROPlanDrawController.allSelectedObjects.size = 0 then
			// No slots selected
			if _roroRequest.myJob &lt;&gt; null then
				contextSlot := _roroRequest;
			endif;
		else
			// One or more slots selected
			foreach selectedObject in self.myROROPlanDrawController.allSelectedObjects do
				if selectedObject.isKindOf(CM_RORORequest)  then
				   
					roroRequestLoad := selectedObject.CM_RORORequest;
					// All selected slots must be in same job and not completed
					if roroRequestLoad.myJob = null then
						contextSlot := null;
						break;
					endif;
					// Slot request should not have been completed
					if roroRequestLoad.isComplete then
						contextSlot := null;
						break;
					endif;
					
					if roroRequestLoad.myROROControllerLoad = null then
						contextSlot := null;
						break;
					endif;
					// Make sure nothing is already planned to this slot
					if 	roroRequestLoad.myROROControllerLoad.hasPlannedTIs(self.modeView = ShpDisplayMode_ColCodeLoad) then
						contextSlot := null;
						break;
					endif;
					
					// The first selected slot is used as the context
					if contextSlot = null then
						contextSlot := roroRequestLoad;
					endif;

					if contextSlot.myJob &lt;&gt; roroRequestLoad.myJob then
						contextSlot := null;
						break;
					endif;
				endif;
			endforeach;
		endif;
	endif;
	
	return contextSlot;

end;
</source>
        <Parameter name="_roroRequest" type="CM_RORORequest" usage="input"/>
        <ReturnType type="CM_RORORequest"/>
    </JadeMethod>
