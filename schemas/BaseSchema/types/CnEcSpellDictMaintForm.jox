    <JadeMethod name="tblSpellDict_displayRow" id="714c6a2c-c56a-4485-9a67-7892b7e6a9fd">
        <controlMethod name="CnEcTable::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblSpellDict_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
// --------------------------------------------------------------------------------
// Created:		07 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	wordObj		: CnEcSpellWord;
	
begin
	wordObj	:=	obj.CnEcSpellWord;
	
	if wordObj = null then
		return null;
	else
		return wordObj.name &amp; Tab &amp; wordObj.metaPhoneName &amp; Tab &amp; wordObj.soundexName;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
