    <JadeMethod name="getValueForRow" id="ceedc675-f163-4fa6-b625-23cf86637326">
        <source>getValueForRow(_rowName : String; _obj : Object output) : Any;

// cnwdvb1 16 January 2003 

vars

begin
	
	if _rowName = ETRow_BgpAutoTaskType then
		return self.class.text.cnEcGetTagValueOfName('display');
	elseif _rowName = ETRow_BgpAutoDescription then 
		return self.description;
	elseif _rowName = ETRow_BgpAutoTerminals then
		// Check for valid object.
		if global.isValidObject(self.myTerminal) then
			return self.myTerminal.code;
		endif;
	elseif _rowName = ETRow_BgpAutoUser then
		// Check for valid object.
		if global.isValidObject(self.myUser) then
			return self.myUser.code;
		endif;
	endif;
	

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_obj" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
