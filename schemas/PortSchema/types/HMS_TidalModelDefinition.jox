    <JadeMethod name="getData_TidalHeight" id="e2263809-f49d-4e24-88df-edd0dcc389ee">
        <source>getData_TidalHeight(_tsArray 		: TimeStampArray input; 
					_heightDataArray : RealArray input);
/*
----------   ----------  --------------------------------------------------
Created:	12 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	percentOfHour 	: Decimal[23,2];
	requestedMinute,
	timeDiffGrt,
	timeDiffLess	: Integer;
	ts				: TimeStamp;
	tidalDataLess,
	tidalDataGrt	: HMS_TidalData;
	heighestVal		: Integer;
	dict			: HMS_TidalDataByTSDict;
	averageHeight,
	grtHeight,
	lessHeight		: Real;
begin

	dict := self.allHMSTidalData;
	
	foreach ts in _tsArray do
		tidalDataGrt := dict.getAtKeyGeq(ts);
		if tidalDataGrt = null then
			return;
		endif;
		
		tidalDataLess := dict.getAtKeyLss(ts);
		if tidalDataLess = null then
			continue;
		endif;
		grtHeight 		:= tidalDataGrt.HMS_DraftTidalData.height;
		lessHeight 		:= tidalDataLess.HMS_DraftTidalData.height;
		
		timeDiffLess 	:= ts.getDifferenceInMinutes(tidalDataLess.HMS_DraftTidalData.ts).Integer;
		timeDiffGrt 	:= ts.getDifferenceInMinutes(tidalDataGrt.HMS_DraftTidalData.ts).Integer;
		//timeDiffGrt + timeDiffLess in this case will always equal 60 minutes, but not assumed in case this changes in future
		requestedMinute := ts.time.minute;
		if requestedMinute &gt; 0 then //division by zero quite often doesn't work
			percentOfHour  := (ts.time.minute / (timeDiffGrt + timeDiffLess));
		else
			percentOfHour  := 0;
		endif;
		
		//app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-percentOfHour = ' &amp; percentOfHour.String);
		if percentOfHour = 0 then
			averageHeight := grtHeight;
		else
			averageHeight := ((grtHeight - lessHeight) * percentOfHour) + lessHeight;
		endif;
		
		_heightDataArray.add(averageHeight);
	endforeach;

end;


</source>
        <Parameter name="_tsArray" type="TimeStampArray" usage="input"/>
        <Parameter name="_heightDataArray" type="RealArray" usage="input"/>
    </JadeMethod>
