    <DbClassMap file="_usergui"/>
    <JadeMethod name="displayEntry" id="176b873b-1521-46c1-a817-846f1a9de85d">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; _reason: CM_LogRejectCode ; lstIndex: Integer): String updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     25 May 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	if _reason = null then
		return null;
	endif;
	
	if _reason.notAvailableForEntry then
		if self.myObject &lt;&gt; _reason then
			return null;
		else
			self.hasDirtyObject := true;
		endif;
	endif;

	return _reason.code &amp; Tab &amp; _reason.description;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_reason" type="CM_LogRejectCode"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="a0b5aaca-77b2-4766-8ef5-c54737c0f0ee">
        <source>getCollectionJMT(): Collection protected;
// ---------------------------------------------------------------------------
// Created:     25 May 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	return app.myRoot.allLogRejectCodes;

end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
