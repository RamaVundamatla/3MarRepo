    <JadeMethod name="getCCEventProperties" id="72337dde-c0d9-4e89-b6f9-ef7a34037278">
        <source>getCCEventProperties(ccEvent: CMIF_CCEvent) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2019	jlgndl1	Initial creation	TFS 45963

*/

vars

	vOldVolume : Decimal[16,4];
	vNewVolume : Decimal[16,4];
	vOldQuantity : Integer;
	vNewQuantity : Integer;
	
begin

	vOldVolume := self.oldVolume;
	vNewVolume := self.newVolume;
	vOldQuantity := self.oldQuantity;
	vNewQuantity := self.newQuantity;

	inheritMethod(ccEvent);
	
	ccEvent.addVolume( "oldVolume", vOldVolume );
	ccEvent.addVolume( "newVolume", vNewVolume) ;
	ccEvent.addInteger( "oldQuantity", vOldQuantity );
	ccEvent.addInteger( "newQuantity", vNewQuantity) ;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="ccEvent" type="CMIF_CCEvent"/>
    </JadeMethod>
    <JadeMethod name="getCCEventType" id="760fafdf-c7e4-4b6e-bc7c-97fc5512737a">
        <source>getCCEventType(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2019	jlgndl1	Initial creation		TFS 45963

*/

vars

begin
	return CC_EventType_VolDiscrep;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDiscrepancyReason" id="8801e3d0-b28c-4683-aa34-33b1fcbe5ae3">
        <source>getDiscrepancyReason(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2019	jlgmp6	Initial creation	TFS41707

*/

vars

begin
	if self.myReason &lt;&gt; null then
		return self.myReason.description;
	endif;

	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="eea9ea3d-e403-407a-ba33-1037ecceffae">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Aug 2017	cnwma1	TFS #5695:STWO - Re-Calculate Volumes on Forms and EDI
10 May 2021 cnwma1  Bug 51141: STWO - Volume Discrepancy Transaction displays Changes in Height reflect as " TEXT = NEW LENGTH instead of NEW HEIGHT"
*/

vars	
	lDetail : String;
	measureType : CM_MeasurementType;
begin
	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
		else
		measureType :=app.myRoot.allDefaultMeasurementTypes[Type_Linear];
		
			if diffVolume &lt;&gt; null then
				lDetail := lDetail &amp; "Old Total Volume "   &amp;  app.getVolumeForDefaultDisplay(oldVolume) 
								   &amp; ", Change " 		   &amp;  app.getVolumeForDefaultDisplay(self.diffVolume) 
								   &amp; ", New Total Volume " &amp;  app.getVolumeForDefaultDisplay(self.newVolume) ;
			endif;
			if diffQuantity &lt;&gt; null then
				lDetail := lDetail &amp;CrLf &amp;  "Old Total Quantity " &amp; oldQuantity.asStringJMT &amp; ", Change " &amp; self.diffQuantity.asStringJMT &amp; ", New Total Quantity " &amp; self.newQuantity.asStringJMT ;
			endif;
			
			if diffLength &lt;&gt; null then
				lDetail := lDetail &amp;CrLf &amp;  "Old Length "  &amp; app.convertMeasurementForDisplay(measureType.shortName, oldLength)  &amp; " " &amp; measureType.shortName 
										 &amp; ", Change "     &amp; app.convertMeasurementForDisplay(measureType.shortName, diffLength) &amp; " " &amp; measureType.shortName 
										 &amp; ", New Length " &amp; app.convertMeasurementForDisplay(measureType.shortName, newLength)  &amp; " " &amp; measureType.shortName  ;
			endif;
			
			if diffWidth &lt;&gt; null then
				lDetail := lDetail &amp; CrLf &amp;  "Old Width " &amp; app.convertMeasurementForDisplay(measureType.shortName, oldWidth)   &amp; " " &amp; measureType.shortName 
										  &amp; ", Change "   &amp; app.convertMeasurementForDisplay(measureType.shortName, diffWidth) &amp; " " &amp; measureType.shortName
										  &amp; ", New Width "&amp; app.convertMeasurementForDisplay(measureType.shortName, newWidth)  &amp; " " &amp; measureType.shortName ;
			endif;
			
			if diffHeight &lt;&gt; null then
				lDetail := lDetail &amp; CrLf &amp;  "Old Height " &amp; app.convertMeasurementForDisplay(measureType.shortName, oldHeight)  &amp; " " &amp; measureType.shortName
										  &amp; ", Change "    &amp; app.convertMeasurementForDisplay(measureType.shortName, diffHeight) &amp; " " &amp; measureType.shortName 
										  &amp; ", New Height "&amp; app.convertMeasurementForDisplay(measureType.shortName, newHeight)  &amp; " " &amp; measureType.shortName  ; //10.02.2021 cnwma1 #51141
			endif;
			
			if diffWeight &lt;&gt; null then
				lDetail := lDetail &amp; CrLf &amp;  "Old Weight "  &amp; app.getWeightForDefaultDisplay(oldWeight) 
										  &amp; ", Change "     &amp; app.getWeightForDefaultDisplay(self.diffWeight) 
										  &amp; ", New Weight " &amp; app.getWeightForDefaultDisplay(self.newWeight) ;
			endif;
			
			if self.reason &lt;&gt; null then
				lDetail := lDetail &amp; CrLf &amp;  'Reason : ' &amp; self.reason;
			endif;
			return lDetail;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="04acfae2-ab81-4796-b6ab-6503ffae947c">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_VolumeDiscrepancyCont; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Aug 2017	cnwma1	TFS #5695:STWO - Re-Calculate Volumes on Forms and EDI

*/

vars

begin
	inheritMethod(_tiTransCntrl, _passport);
	self.oldQuantity:= _tiTransCntrl.oldQuantity;
	self.newQuantity:= _tiTransCntrl.newQty;
	self.diffQuantity:= _tiTransCntrl.diffQty;
	
	self.oldWeight	:= _tiTransCntrl.oldWeight;
	self.newWeight	:= _tiTransCntrl.newWeight;
	self.diffWeight	:= _tiTransCntrl.diffWeight;
	
	self.oldVolume	:= _tiTransCntrl.oldVolume;
	self.newVolume	:=_tiTransCntrl.newVolume;
	self.diffVolume	:=_tiTransCntrl.diffVolume;
	
	self.oldWidth	:=_tiTransCntrl.oldWidth;
	self.newWidth	:=_tiTransCntrl.newWidth;
	self.diffWidth	:=_tiTransCntrl.diffWidth;
	
	self.oldLength	:=_tiTransCntrl.oldLength;
	self.newLength	:=_tiTransCntrl.newLength;
	self.diffLength	:=_tiTransCntrl.diffLength;
	
	self.oldHeight	:=_tiTransCntrl.oldHeight;
	self.newHeight	:=_tiTransCntrl.newHeight;
	self.diffHeight	:=_tiTransCntrl.diffHeight;
	
	self.oldPieces	:=_tiTransCntrl.oldPieces;
	self.newPieces	:=_tiTransCntrl.newPieces;
	self.diffPieces :=_tiTransCntrl.diffPieces;
	
	self.reason		:= _tiTransCntrl.reason;
	self.myReason	:= _tiTransCntrl.myReason;		// 3/5/19 MAP TFS41707
epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_VolumeDiscrepancyCont"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
