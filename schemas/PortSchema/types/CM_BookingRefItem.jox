epilog

end;</source>
        <Parameter name="_proxy" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="populatePxyfromBolDtl" id="f6a453a8-6f21-4a10-bb68-f6cd9cea81e2">
        <updating/>
        <source>populatePxyfromBolDtl(_bolDtl	: CM_BOLDtl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Nov 2022	navgm20	ChangeRequest 54979 : EUP - Transport Mode change - PortSchema Changes
07 Dec 2022 jlika1	TFS 55586 - HS Code User Defined EDI
31 Jan 2023 navdp20 ChangeRequest 56969:[56288] EUP - [Framework] Constructing methods to populate booking, bill of lading, and release request conversion
04 Sep 2023 navhl20 Bug 60135: MTN - Error 1090 when using Transport Mode Change
*/

vars
	isoType : CM_ISOType;
begin
	self.cargoType			 :=	_bolDtl.cargoType;
	self.colour				 :=	_bolDtl.colour;
	self.commodity			 :=	_bolDtl.commodity;
	self.description		 :=	_bolDtl.description;
	self.height				 :=	_bolDtl.height;
	self.length				 :=	_bolDtl.length;
	self.markNumber			 :=	_bolDtl.markNumber;
	self.quantity			 :=	_bolDtl.quantity;
	self.remarks			 :=	_bolDtl.remarks;
	self.volume			 	 :=	_bolDtl.volume;
	self.weight				 :=	_bolDtl.weight;
	self.width				 :=	_bolDtl.width;
	self.hsCode				 := _bolDtl.hsCode;
	
	//Start 31.01.2023 navdp20 TFS #56969[56288]
	if _bolDtl.myCargoType &lt;&gt; null and _bolDtl.myCargoType.allISOTypes.isNotEmpty() then		//04.9.2023 navhl20 #60135
		isoType 			 :=  _bolDtl.myCargoType.allISOTypes.first;
		if isoType &lt;&gt; null then
			self.isoType 	 :=  isoType.code;
			if isoType.myISOTypeGroup &lt;&gt; null then												//04.9.2023 navhl20 #60135
				self.isoTypeGroup:=  isoType.myISOTypeGroup.code;
			endif;
		endif;
	endif;
	//End 31.01.2023 navdp20 TFS #56969[56288]
	
epilog

end;</source>
        <Parameter name="_bolDtl" type="CM_BOLDtl"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="d94a8fbc-bb1e-459b-9366-ed9de0c6d8bd">
        <source>pxyCreateUpdateProxy(): SelfType;
// --------------------------------------------------------------------------------
// Created:		16 May 2008 by cnwdad1
//
// Purpose:		Standard method to instantiate a proxy of the receiver.
//
// Parameters:	None
//
// Returns:		A reference to the proxy object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 30/11/2009	cnwdap1		CCMS MES 1007 - Reefer properties moved to CM_ReeferProperties class
//							and available to all subclasses
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// 28/11/2022	jlizm1		TFS 55280 Harmonized System Codes
// --------------------------------------------------------------------------------
vars
	proxyObj		: SelfType;
	completedOK		: Boolean;
	proxyDetailActions : CM_BookingItemActions;
	
begin
	proxyObj	:=	inheritMethod();
	
	proxyObj.myProduct			:=	self.myProduct;
	proxyObj.myReserveDetail    :=  self.myReserveDetail;
	
	proxyObj.mySpecialStow		:=	self.mySpecialStow;
	proxyObj.inspected			:= 	self.inspected;
	proxyObj.hsCode				:=  self.hsCode;	// TFS 55280
	proxyObj.setSpecialLifts(self.allSpecialLifts);
	self.allLinkedExportBookings.copy(proxyObj.allLinkedExportBookings);					//+cnwml2 MSL CCMS 1012
	
	proxyObj.setPxyHazards(self.allTIHazards);
	
	// CCMS 1007 create proxy reefer properties if required
	if self.myReeferProperties &lt;&gt; null then
		proxyObj.myReeferProperties := self.myReeferProperties.pxyCreateUpdateProxy;
	endif;
	
	//14 Sep 2016	NDL	TFS 2278 / 2670
	if self.myBookingRefItemActions &lt;&gt; null then
		create proxyDetailActions transient;
		proxyDetailActions.setMyBookingRefItem( proxyObj );
		self.myBookingRefItemActions.updateProxyFromSelf( proxyDetailActions );
	endif;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyObj;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyObj;
	endif;	
end;
</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
