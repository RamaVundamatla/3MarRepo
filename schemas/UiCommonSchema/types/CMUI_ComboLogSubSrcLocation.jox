    <ImplicitInverseRef name="mySourceLocation" id="0dcd07cc-5eca-4146-bf02-6bbde8e6dc67">
        <embedded/>
        <type name="CM_SourceLocation"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="displayEntry" id="e2f2a105-e33b-43c6-81f8-a12fbe647368">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; _srcLocn : CM_SourceSubLocation; lstIndex: Integer): String updating, clientExecution;
//--------------------------------------------------
// Created:	26 November 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	
	if _srcLocn = null then
		return null;
	endif;

	if _srcLocn.notAvailableForEntry then
		if self.myObject &lt;&gt; _srcLocn then
			return null;
		else
			self.hasDirtyObject := true;
		endif;
	endif;
			
	return _srcLocn.code.String &amp; Tab &amp; _srcLocn.description;
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_srcLocn" type="CM_SourceSubLocation"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="2f450243-5179-4807-b736-fc0a2e8e0042">
        <source>getCollectionJMT(): Collection protected;
//--------------------------------------------------
// Created:	26 November 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpCodeGroup : CM_CodesByCodeDict;
begin
	if self.mySourceLocation &lt;&gt; null then
		tmpCodeGroup := self.mySourceLocation.allSubLocations;
	endif;

	return tmpCodeGroup;

end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="getObjectByCode" id="369e724e-8607-4db9-af32-4b564539648d">
        <source>getObjectByCode(_paraString : String) : CM_SourceSubLocation;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	rtnObj 	: CM_SourceSubLocation;
	obj		: Object;
	coll	: Collection;
	code	: String;
	token	: Integer;
begin
	coll := self.getCollectionJMT();
	if coll = null then
		return null;
	endif;
	
	token := 1;
	code := _paraString.getNextToken(token);
	foreach obj in coll.CM_CodesByCodeDict do
		if obj.CM_SourceSubLocation.code = code then
			return obj.CM_SourceSubLocation;
		endif;
	endforeach;

	return null;
end;</source>
        <Parameter name="_paraString" type="String"/>
        <ReturnType type="CM_SourceSubLocation"/>
    </JadeMethod>
    <JadeMethod name="init" id="c95c22e0-09a2-459c-97ec-989ee9e6a0b8">
        <updating/>
        <source>init() updating, protected;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	coll		: Collection;
	idx, 
	token		: Integer;
	saveText,
	code,
	tmpStr		: String;
	obj			: Object;
	tmpObj		: CM_SourceSubLocation;
	isDeleted	: Boolean;
	
begin
	coll := self.getCollectionJMT();
	if coll = null then
		self.amInitialised := false;
		return;
	endif;
	isDeleted := true;
	
	// save the current text as calling listCollection
	// clears the current text
	if self.text &lt;&gt; null then
		token 		:= 1;
		saveText 	:= self.text;
		code 		:= self.text.getNextToken(token);
	endif;
	
	foreach obj in coll.CM_CodesByCodeDict do
		if obj.CM_SourceSubLocation.code = code then
			isDeleted := false;
		endif;
		
		self.addItem(obj.CM_SourceSubLocation.code &amp; Tab &amp; obj.CM_SourceSubLocation.description);
	endforeach;

	if isDeleted and code &lt;&gt; null then
		self.addItem(code &amp; Tab &amp; "Deleted");
	endif;
	
	self.selLength := 1000;			
	idx := self.findString(1, saveText);

	if idx &gt; 0 then
		self.listIndex := idx;
		self.setEntryTableCell();
		self.text := saveText;
	else
		self.text := null;
	endif;
		
	self.amInitialised := true;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setObjectAndSrcLocation" id="0c7368c9-d4b7-4a33-a82b-3605c67cc52a">
        <updating/>
        <source>setObjectAndSrcLocation(_obj : CM_SourceSubLocation; _srcLocation : CM_SourceLocation) updating;
// -------------------------------------------
// Created 29 september 2005 by cnwhjg1
// -------------------------------------------
vars

begin
	if self.mySourceLocation &lt;&gt; _srcLocation or _obj &lt;&gt; self.myObject then
		self.mySourceLocation := _srcLocation;

		if _obj = null then
			self.text := null;
			self.amInitialised := false;
			// want collection to reset itslef which does not happen if obj is null. 
			self.myObject := _obj;
			self.zInit();
			
			if self.findObject(_obj) &gt; 0 then
				self.listObject := _obj;
			else
				self.clear();
			endif;	
			return;
		endif;	
	endif;
	// Forces a clear because we want new .
	self.amInitialised := false;
	
	self.setObject(_obj);
end;</source>
        <Parameter name="_obj" type="CM_SourceSubLocation"/>
        <Parameter name="_srcLocation" type="CM_SourceLocation"/>
    </JadeMethod>
    <JadeMethod name="setTextForDisplayCollection" id="cbad852a-b035-43cb-a5ac-9e2d0cdce3ea">
        <updating/>
        <source>setTextForDisplayCollection(_text: String) updating;
// ---------------------------------------------------------------------------
// Created:     11 April 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_text);
	
	if (not self.amInitialised) and
		self.mySourceLocation = null and 
		_text &lt;&gt; null then
		// init call in inheritMethod failed
		self.clear;
		self.addItem(_text);
		self.text := _text;
	endif;

end;
</source>
        <Parameter name="_text" type="String"/>
    </JadeMethod>
