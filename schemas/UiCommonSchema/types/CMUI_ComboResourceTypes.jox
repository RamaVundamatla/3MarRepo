    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <JadeMethod name="displayEntry" id="adc38dbe-68ba-46e7-8d92-94424a46cf1d">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; _resourceType : HMS_ResourceType; lstIndex: Integer): String updating, clientExecution;
//--------------------------------------------------
// Created:	26 November 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _resourceType = null then
		return null;
	endif;

//	if _resourceType.HMS_ResourceType.isMarineService then // CCMS 1350
//		return null;
//	endif;
	
	if _resourceType.isNotAvailableForEntry then // CCMS 1350
		if self.myObject &lt;&gt; _resourceType then
			return null;
		else
			self.hasDirtyObject := true;
		endif;
	endif;

	//PAR3818
	return _resourceType.description &amp; ' ('&amp; _resourceType.code &amp; ')';				
	//return _resourceType.code &amp; Tab &amp; _resourceType.description;
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_resourceType" type="HMS_ResourceType"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="e3d0ad6e-aff6-417c-9a0f-39a68a9930d0">
        <source>getCollectionJMT(): Collection protected;
//--------------------------------------------------
// Created:	26 November 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	return app.myRoot.allResourceTypes;

end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="lostFocus" id="1d243a23-56df-4113-a2d6-7a421fc72dd9">
        <controlMethod name="CMUI_ComboBoxObject::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lostFocus(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Nov 2025	navhl20	Bug MTN-36437: SAL - Dropdown not working properly in Harbor Function &gt;&gt; Movement Maintenance &gt;&gt; Add Resource

*/

vars
	dataTable 		: CM_DataTable;
	resourceType	: HMS_ResourceType;
begin
	if self.filterIgnore then
		inheritMethod(combobox);
	else
		self.helpContextId := AllKeys; 
		
		if self.parent.isKindOf(CM_DataTable) then
			dataTable := self.parent.CM_DataTable;
			resourceType := combobox.listObject.HMS_ResourceType;
			if resourceType &lt;&gt; null and resourceType.description = combobox.text then
				dataTable.setCellText(dataTable.row, dataTable.getColumnByRowName(ETRow_MyResourceType), combobox.text);
			endif;
		endif;

		self.filterReshowAllItems();
	endif;
	
	if self.parent.isKindOf(CMUI_RowFrame) then
		self.parent.CMUI_RowFrame.handleComboLostFocus(combobox.CMUI_ComboBox);
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
