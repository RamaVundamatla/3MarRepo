    <JadeMethod name="getCargoTotalWeight" id="a67a4811-5380-4e91-a01d-f6eefbdf0b0e">
        <source>getCargoTotalWeight():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2022	navhl20	ChangeRequest 54281: EUP - Wagon Track Planning

*/

vars
	ti : CM_TrackedItem;
	wagonTotalWeight :	Decimal[12,4];
	cont : CM_WagonController;
begin
	foreach cont in self.allLocationsControllers do
		foreach ti in cont.allTrackedItems do
			wagonTotalWeight := wagonTotalWeight + ti.totalWeight;
		endforeach;
	endforeach;
	return wagonTotalWeight.asStringMeasurementJMT;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCargoTotals" id="b243e4b9-2008-47a9-a925-be5f81e42860">
        <source>getCargoTotals(_attrName : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     05 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 06 Sep 2024 Bug 65987: EUP - Error 1308 when loading Train enquiry screen
// ---------------------------------------------------------------------------

vars
	tiArray 			: CM_TIArray;
	inward, 
	confirmd, 
	invalid, 
	inTransit			: Boolean;
	tmpTI 				: CM_TrackedItem;
	tot 				: Integer;
	primaryActLoc		: CM_LocationsController;
begin
	create tiArray transient;

	if _attrName = ETRow_NumCargoRec  then
		inward 		:= true;
		confirmd 	:= self.confirmed;
	elseif _attrName = ETRow_TotalCargoIn  then
		inward 		:= true;
		confirmd 	:= self.confirmed;
	elseif _attrName = ETRow_NumCargoRel  then
		inward 		:= false;
		confirmd	:= self.confirmedOutwards or self.isDeparted;
	elseif _attrName = ETRow_TotalCargoIntransit  then
		inward 		:= true;
		confirmd 	:= self.confirmed;
	elseif _attrName = ETRow_TotalCargoLoaded  then
		inward 		:= false;
		confirmd 	:= self.confirmedOutwards or self.isDeparted;
	elseif _attrName = ETRow_TotalCargoDischarged then
		inward 		:= true;
		confirmd 	:= self.confirmed;
	endif;

	
	self.getAllTrackedItems(inward, tiArray, confirmd);
	
	on Exception do app.handleDeletedObject (exception, tmpTI, invalid);	// 05/03/2013 cnwar2 #31230
	
	foreach tmpTI in tiArray discreteLock do
		invalid		:= false;
		inTransit := tmpTI.isInTransitOnShip;				// OR ON TRAIN
		if invalid then
			continue;
		endif;
	
		primaryActLoc := tmpTI.myPrimaryActualLocation;		//06.09.2024 navma1 #65987
		
		if _attrName = ETRow_TotalCargoIntransit then
			if inTransit then  
				if tmpTI.totalQuantity &gt; 1 then
					tot := tot + tmpTI.totalQuantity;
				else
					tot := tot + 1;
				endif;
			endif;
			
		elseif _attrName = ETRow_TotalCargoDischarged then
			if ( tmpTI.hasBeenMerged ) or ( primaryActLoc &lt;&gt; null and not primaryActLoc.isWagon() ) then
				//tot := tot + 1;
				//19 Sep 2013	NDL	Par 32479
				if ( tmpTI.hasBeenMerged or tmpTI.canMergeBreakBulk ) and tmpTI.isBulkByQuantity then 
					tot := tot + tmpTI.CM_BreakBulkGeneric.getTotalQuantityReceived( TRANS_TYPE_REC_RAIL );
				elseif tmpTI.totalQuantity &gt; 1 then
					tot := tot + tmpTI.totalQuantity;
				else
					tot := tot + 1;
				endif;

			elseif primaryActLoc &lt;&gt; null and primaryActLoc.isWagon() then
				if primaryActLoc.CM_WagonController.myWagon &lt;&gt; null then
					if primaryActLoc.CM_WagonController.myWagon &lt;&gt; self then
						//tot := tot + 1;
						//19 Sep 2013	NDL	Par 32479
						if ( tmpTI.hasBeenMerged or tmpTI.canMergeBreakBulk ) and tmpTI.isBulkByQuantity then 
							tot := tot + tmpTI.CM_BreakBulkGeneric.getTotalQuantityReceived( TRANS_TYPE_REC_RAIL );
						elseif tmpTI.totalQuantity &gt; 1 then
							tot := tot + tmpTI.totalQuantity;
						else
							tot := tot + 1;
						endif;
					endif;
				
				endif;
			endif;
		elseif _attrName = ETRow_TotalCargoLoaded then
			if self.isDeparted() then
				if self.allTIsReleased.includes(tmpTI) then
					//tot := tot + 1;
					if tmpTI.totalQuantity &gt; 1 then
						tot := tot + tmpTI.totalQuantity;
					else
						tot := tot + 1;
					endif;
				endif;
			else
				if primaryActLoc &lt;&gt; null then
					if primaryActLoc.isWagon() then
						if self.isTIOutward(tmpTI) then
							//tot := tot + 1;
							if tmpTI.totalQuantity &gt; 1 then
								tot := tot + tmpTI.totalQuantity;
							else
								tot := tot + 1;
							endif;
						endif;
					endif;
				endif;
			endif;

		elseif _attrName = ETRow_TotalCargoIn or _attrName = ETRow_NumCargoRec then
			//tot := tot + 1;
			//19 Sep 2013	NDL	Par 32479
			if ( tmpTI.hasBeenMerged or tmpTI.canMergeBreakBulk ) and tmpTI.isBulkByQuantity then 
				tot := tot + tmpTI.CM_BreakBulkGeneric.getTotalQuantityReceived( TRANS_TYPE_REC_RAIL );
			elseif tmpTI.totalQuantity &gt; 1 then
				tot := tot + tmpTI.totalQuantity;
			else
				tot := tot + 1;
			endif;
		
		elseif _attrName = ETRow_NumCargoRel then
			//tot := tot + 1;
			if tmpTI.totalQuantity &gt; 1 then
				tot := tot + tmpTI.totalQuantity;
			else
				tot := tot + 1;
			endif;
			
		else
			//tot := tot + 1;
			if tmpTI.totalQuantity &gt; 1 then
				tot := tot + tmpTI.totalQuantity;
			else
				tot := tot + 1;
			endif;
		endif;
			
		
	endforeach;

	return tot;

epilog
	delete tiArray;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCargoTypeCode" id="82cbb6e8-b766-4f05-a045-de9be5757b78">
        <source>getCargoTypeCode():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02-May-2023 navtnr20	Bug 57780: Bug 57780: EUP -FR 53740 | Wagon Track Planning - Multiple Values
*/

vars
	ti : CM_TrackedItem;
	cont : CM_WagonController;
	data : String;
	code : String;
begin
	foreach cont in self.allLocationsControllers do
		foreach ti in cont.allTrackedItems do
			if ti.myCargoType &lt;&gt; null then
				code := ti.myCargoType.abbreviation;
				if code &lt;&gt; null then
					/*
					if data.pos(code,1) = 0 then
						if data = null then
							data := code;
						else
							data := data &amp; ", " &amp; code;
						endif;
					endif;
					*/
					
					data.addStringToList(code, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
				endif;
			endif;
		endforeach;
	endforeach;
	return data;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
