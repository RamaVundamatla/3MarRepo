    <JadeMethod name="canUpdateStop" id="f46ac510-48b1-4357-823d-9c14aba3b33a">
        <source>canUpdateStop(_terminal : CM_Terminal; _stopTable : CM_StopsTable) : Boolean;
//-----------------------------------------
// Created: November 2005 By: cnwjc2
//
//	Returns true if user has update access.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09 Sep 2019	jlgdi1		45802 Added condition check for JMTSupport user 
// ---------------------------------------------------------------------------

vars
	userTerminal	: CM_UserTerminal;
begin
	if _stopTable = null then
		return false;
	endif;
	if app.isSpecial() then
		return true;
	endif;

	// AKB UNIT TESTS
	if self.isSuperUser() then
		return true;
	endif;
	
	// 45802
	if self.isJmtSupportUser() then 
		return false;
	endif;
	
	if _terminal = null then
		return false;
	endif;
	
	userTerminal := self.getUserTerminal(_terminal);
	if userTerminal = null then
		return false;
	endif;

	if userTerminal.mySecurityRole &lt;&gt; null and
	   userTerminal.mySecurityRole.allStopsMaint.includes(_stopTable) then
	   	return true;
	endif;

	return false;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_stopTable" type="CM_StopsTable"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUpdateStops" id="73f6e7f9-d5cf-425e-afd1-5843c956c309">
        <source>canUpdateStops(_terminal : CM_Terminal ) : Boolean;

/*

Purpose:	Check if the user can maintain ANY stops.		

Parameters:			

Return Value:		

---------------------------------------------------------------------------
Date		Who		Reason
---------------------------------------------------------------------------
26 April 2012	cnwrd1	Initial creation
09 Sep 2019	jlgdi1	45802 Added condition check for JMTSupport user 
---------------------------------------------------------------------------
*/

vars
	userTerminal	: CM_UserTerminal;
begin

	if app.isSpecial() then
		return true;
	endif;

	if _terminal = null then
		return false;
	endif;
	
	// 45802
	if self.isJmtSupportUser() then 
		return false;
	endif;
	
	userTerminal := self.getUserTerminal(_terminal);
	if userTerminal = null then
		return false;
	endif;

	if userTerminal.mySecurityRole &lt;&gt; null and
	   not userTerminal.mySecurityRole.allStopsMaint.isEmpty then
		return true;
	endif;

	return false;
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserAccessObj" id="e0f73559-4a97-414b-b8f7-7f4edb2370b6">
        <source>canUserAccessObj(_obj : CM_Object; _class : Class) : Boolean;
// -------------------------------------------
// Created 15 December 2004 by cnwdvb1
// -------------------------------------------
vars

	dac 	: CM_DataAccessController;
	class	: Class;

begin
	
	if _obj = null and _class = null then
		return false;
	endif;

	if _obj = null and _class &lt;&gt; null then
		class := _class;
	elseif _obj &lt;&gt; null then
		//epr par 11883 
		if _obj.isKindOf(CM_Organisation) then
		//CM_Organiation is abstract so will be either CM_InternalOrganiation or CM_ExternalOrganisation
		// it needs to be CM_Organisation for the below class &lt;&gt; check and the allDataAcessControllers are created for CM_Organisation
			class:=CM_Organisation;
		else
			class := _obj.class;
		endif;		
	endif;
		
	if	class &lt;&gt; CM_Carrier and
		class &lt;&gt; CM_ConsigneeConsignor and
		class &lt;&gt; CM_Operator and
		class &lt;&gt; CM_Organisation then
		return true;
	endif;

	dac := self.getDataAccessController(class.name);
	
	if dac &lt;&gt; null and (not dac.canAccess(_obj)) then
		return false;
	endif;

	return true;


end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_class" type="Class"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserAccessSelf" id="3b1eb611-3c88-4a4f-8907-8b6f2761b3da">
        <source>canUserAccessSelf(_user : CM_User; _failedDAC  :CM_DataAccessController output; passport: CM_Passport): Boolean;
// ---------------------------------------------------------------------------
// Created:     24 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// sgp 6 June 2003
// Passport is passed in instead of user for performance reasons.  The data
// data access controllers for the current user are set on passport on startup.
// ---------------------------------------------------------------------------
vars
	dac : CM_DataAccessController;
	
begin

	if app.isSpecial() then
		return true;
	endif;

	dac := passport.allDataAccessControllers[CM_Organisation.name];

	if dac &lt;&gt; null and (not dac.canAccess(self.myOrganisation)) then
		_failedDAC := dac;
		return false;
	endif;
	
	return inheritMethod(_user, _failedDAC,  passport);

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserUnlockMe" id="b80aed2c-a47a-4001-b2b7-f4d8a608e250">
        <source>canUserUnlockMe( _user : CM_User) : Boolean;

/*

Purpose:	NFS 30581 		

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2013	cnwrd1	Initial creation
11 Sep 2019	jlgdi1	45802 Added condition check for JMTSupport user
*/

vars

begin

	if self = _user then
		// user can always update themselves
		return true;
	endif;
	
	if _user.mySystemSecurityRole = null then
		// this should never happen
		return false;
	endif;

	// 45802
	if self.isJmtSupportUser() then 
		return false;
	endif;	
	
	if self.mySystemSecurityRole = _user.mySystemSecurityRole then
		// Can unlock users at same role 
		return true;
	endif;
	
	if _user.mySystemSecurityRole = app.myRoot.mySecurityRoleSystem then
		// If user has the root role then can alter all others
		return true;
	endif;

	if self.mySystemSecurityRole = null then
		return true;
	endif;

	if (not self.mySystemSecurityRole.isChildOf(_user.mySystemSecurityRole)) then
		return false;
	endif;


	return true;

epilog

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserUpdateDataAccess" id="46bde617-dc9c-4a9e-818a-99ff0638808b">
        <source>canUserUpdateDataAccess(_user : CM_User) : Boolean;
// ---------------------------------------------------------------------------
// Created:     25 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11 Sep 2019	jlgdi1		45802 Added condition check for JMTSupport user
// 21 Sep 2020 cnwma1		ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data
// ---------------------------------------------------------------------------
vars

begin

	if _user.mySystemSecurityRole = null then
		// this should never happen
		return false;
	endif;

	// 45802
	if self.isJmtSupportUser() then 
		return false;
	endif;
	
	if self.isOpsViewUser() then     //21.09.2020 cnwma1 TFS #49758
		return false;
	endif;
	
	if _user.mySystemSecurityRole = app.myRoot.mySecurityRoleSystem then
		//top level so yes
		return true;
	endif;

	if (self.mySystemSecurityRole.isChildOf(_user.mySystemSecurityRole)) then
		return true;
	endif;
	
	return false;

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserUpdateMe" id="23624bc8-d2b3-4bd1-8a7d-81fe7c7fa4f3">
        <source>canUserUpdateMe(_user : CM_User) : Boolean;
// ---------------------------------------------------------------------------
// Created:     25 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11 Sep 2019	jlgdi1		45802 Added condition check for JMTSupport user
// 21 Sep 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data
// ---------------------------------------------------------------------------
vars

begin

	if self = _user then
		// user can always update themselves
		return true;
	endif;
	
	if _user.mySystemSecurityRole = null then
		// this should never happen
		return false;
	endif;
	
	// 45802 - meantime allow superuser to update/delete JMTSupport
//	if (self.isJmtSupportUser()or self.isOpsViewUser()) and not _user.isSuperUser()then  //21.09.2020 cnwma1 TFS #49758
	if self.isInternalSystemUser and not _user.isSuperUser() then	//17 Jun 2021	NDL	TFS 51310
		return false;
	endif;
	
	/*
	if self.mySystemSecurityRole = _user.mySystemSecurityRole then
		// Can update users at same role - should use organisation if
		// want to separate out different groups with same role ??
		return true;
	endif;
	*/

	if _user.mySystemSecurityRole = app.myRoot.mySecurityRoleSystem then
		// If user has the root role then can alter all others
		return true;
	endif;

	if self.mySystemSecurityRole = null then
		return true;
	endif;
	
	//14 Feb 2018	NDL	TFS 36947
	if _user.mySystemSecurityRole.allChildMaintenanceRoles.includes( self.mySystemSecurityRole ) then
		return true;
	endif;

	if (not self.mySystemSecurityRole.isChildOf(_user.mySystemSecurityRole)) then
		return false;
	endif;


	return true;

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserViewReport" id="88189f6c-8650-4abc-8410-c6f0ef7ed80e">
        <source>canUserViewReport(_qryReport : CM_QryReport) : Boolean;
// -------------------------------------------
// Created 21 September 2004 by cnwdvb1
// -------------------------------------------
vars

	userTerminal	: CM_UserTerminal;

begin

	foreach userTerminal in self.allUserTerminals do
		if userTerminal.canDoReport(_qryReport.menuId) then
			return true;
		endif;
	endforeach;
	return false;
end;</source>
        <Parameter name="_qryReport" type="CM_QryReport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
