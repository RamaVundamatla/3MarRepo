    <JadeMethod name="processMessage" id="cd93dbc0-d731-4739-b8b2-1dd9b9f76647">
        <source>processMessage( _voyage : CM_Voyage; _req : WS_EntryPPKRequest  );
/*

Purpose:	we get the work order from the nomorRpkRO then if status = 2 approved approve the work order ir status = 3 then reject the work order		

Parameters:			

Return Value:		

Date		Who		Reason
20 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars
	workOrder  : CM_WorkOrder;
	workOrderDetail : CM_WorkOrderDtl;
	workOrderDtl : CM_WorkOrderVoyageDtl;
	workOrderOid : String;
	rpkroSubString : String;
	movement : HMS_VoyageMovement;
	extensions : IntegerArray;
begin
	
	rpkroSubString:=_voyage.myTerminal.getDefaultPort().code &amp; "-RPKRO-";
	if self.nomorRpkRo.length &gt; rpkroSubString.length then
		workOrderOid:=self.nomorRpkRo[rpkroSubString.length + 1 : end];
	endif;
	
	if workOrderOid &lt;&gt; null then
		workOrderDtl:=app.myPassport.getObjectOfTypeFromOid(workOrderOid,CM_WorkOrderVoyageDtl).CM_WorkOrderVoyageDtl;
	endif;
	
	if workOrderDtl = null then
		create extensions transient;
		_req.getExtensionStatuses(extensions);
		if extensions.includes(_voyage.status) then
			//
			workOrderDtl:=_voyage.findWorkOrderDtlNotApproved(WO_TASK_EXTENSION);
		endif;
	endif;
	
	
	
	if workOrderDtl &lt;&gt; null then
		app.myTrxUA.trxUpdateWorkOrderPPK(workOrderDtl,_req.nomorPpk,self.status.Integer = 2,app.myPassport);
	endif;
epilog
	delete extensions;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_req" type="WS_EntryPPKRequest"/>
    </JadeMethod>
    <JadeMethod name="validateForVoyageUpdate" id="13257e48-530d-48bf-beb9-4e752fd0158e">
        <source>validateForVoyageUpdate( _req : WS_EntryPPKRequest; _voyage : CM_Voyage io ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

	term : CM_Terminal;
	voyage : CM_Voyage;
	operator : CM_Operator;
	commodity : CM_Commodity;
	date : Date;
	time : Time;
	port : CM_Port;

begin

	term := app.myPassport.myTerminal;

	on Exception do _req.handleCMExcDuringValidation(exception);	//So we don't bail on the first exception we raise.
	
	//10. nomorRpkRo, number of RPKRO bup, Mandatory
	//self.nomorRpkRo	
	
	//11.	nomorPkk, PKK number, Mandatory
	//self.nomorPkk
	if _voyage = null then
		//first time thru, this is called in a loop.
		_voyage := term.allVoyagesByExternalCode.getAtKey( self.nomorPkk);
		if _voyage = null then
			app.raiseCMException3(Value_field_not_resolve, self.nomorPkk, WS_DetailPPK::nomorPkk.name, app.getErrorString(Voyage), null, null);
			return false;
		endif;
	else
		voyage := term.allVoyagesByExternalCode.getAtKey( self.nomorPkk );
		if _voyage &lt;&gt; voyage then
			app.raiseCMException2(Incorrect_voyage, self.nomorPkk, WS_DetailPPK::nomorPkk.name, null, null ); 
			return false;
		endif;
	endif;
	operator := _voyage.myOperator;
	
	//12.	nomorPPKB, number of PKKB bup, Mandatory
	//self.nomorPPKB
	
	//13.	nomorRkbmMuat, Ref Num of RKBM Loading, Optional
	//self.nomorRkbmMuat
	
	//14.	nomorRkbmBongkar, Ref Num of RKBM UnLoading, Optional
	//self.nomorRkbmBongkar
	
	//15.	kegiatanBongkar, Quantity of UnLoading Activity in Ton, Optional
/*	if self.kegiatanBongkar.trimBlanks &lt;&gt; null then
		if not self.kegiatanBongkar.trimBlanks.isInteger then
			app.raiseCMException1(Value_field_must_integer, WS_DetailPPK::kegiatanBongkar.name, null, null);
		endif;
	endif;
	
	//16.	kegiatanMuat, Quantity of Loading Activity in Ton, Optional
	if self.kegiatanMuat.trimBlanks &lt;&gt; null then
		if not self.kegiatanMuat.trimBlanks.isInteger then
			app.raiseCMException1(Value_field_must_integer, WS_DetailPPK::kegiatanMuat.name, null, null);
		endif;
	endif;
	
	//17.	komoditi, Commodity, Optional
	if self.komoditi &lt;&gt; null then
		commodity := _req.getCommodity( self.komoditi, operator );
		if commodity = null then
			app.raiseCMException3(Value_field_not_resolve, self.komoditi, WS_DetailPPK::komoditi.name, app.getErrorString(Commodity), null, null);
		endif;
	endif;*/
	
	//18.	nomorGudang, Name of Commodity
	//self.nomorGudang
	
	//19.	keterangan, Warehouse Number, Optional
	//self.keterangan
	
	//20.	tanggalMulaiTambat, Date Mandatory
	//self.tanggalMulaiTambat
	date:=self.tanggalMulaiTambat.asDateFromInaportnet;
	if not date.isValid then
		app.raiseCMException1(Invalid_date_expect_format,"yyyy-mm-dd " &amp; WS_DetailPPK::tanggalMulaiTambat.name, null, null); 
	endif;
	
	//21.	jamMulaiTambat, Time Mandatory
	//self.jamMulaiTambat
/*	_req.setTimeFrom( time, self.jamMulaiTambat );
	if not time.isValid then
		app.raiseCMException1(Invalid_time_expect_format,"hh:mm " &amp; WS_DetailPPK::jamMulaiTambat.name, null, null); 
	endif;
	
	//22.	tanggalSelesaiTambat, date Mandatory
	//self.tanggalSelesaiTambat
	_req.setDateFrom( date, self.tanggalSelesaiTambat );
	if not date.isValid then
		app.raiseCMException1(Invalid_date_expect_format,"yyyy-mm-dd " &amp; WS_DetailPPK::tanggalSelesaiTambat.name, null, null); 
	endif;
	
	//23.	jamSelesaiTambat, Time Mandatory
	//self.jamSelesaiTambat
	_req.setTimeFrom( time, self.jamSelesaiTambat );
	if not time.isValid then
		app.raiseCMException1(Invalid_time_expect_format,"hh:mm " &amp; WS_DetailPPK::jamSelesaiTambat.name, null, null); 
	endif;
	
	//24.	kadeMeterAwal, Integer Mandatory
	//self.kadeMeterAwal
	if not self.kadeMeterAwal.trimBlanks.isInteger then
		app.raiseCMException1(Value_field_must_integer, WS_DetailPPK::kadeMeterAwal.name, null, null);
	endif;
	
	//25.	kadeMeterAkhir, Integer Mandatory
	//self.kadeMeterAkhir
	if not self.kadeMeterAkhir.trimBlanks.isInteger then
		app.raiseCMException1(Value_field_must_integer, WS_DetailPPK::kadeMeterAkhir.name, null, null);
	endif;*/
	
	//26.	status - DISETUJUI = Approved, DITOLAK = Rejected, PENDING = Pending
	if self.status.trimBlanks &lt;&gt; null then
		if self.status.trimBlanks = '2'
		or self.status.trimBlanks = '3'
		//'or self.status.trimBlanks = 'PENDING'
		then
			//Its OK
		else
			app.raiseCMException2(ERR_FIELD_VALUE, self.status.trimBlanks, WS_DetailPPK::status.name, null, null);
		endif;
	endif;
	
	//27.	portCode, Mandatory
	//self.portCode
	port := _req.getPort( self.portCode, operator );
	if port = null then
		app.raiseCMException3(Value_field_not_resolve, self.portCode, WS_DetailPPK::portCode.name, app.getErrorString(Port), null, null);
	endif;
		
epilog

	return not app.myPassport.hasErrors;

end;</source>
        <Parameter name="_req" type="WS_EntryPPKRequest"/>
        <Parameter name="_voyage" type="CM_Voyage" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMandFieldsPresent" id="4e6a4445-4d29-4c83-be16-1dc4d3808f21">
        <source>validateMandFieldsPresent( _req : WS_EntryPPKRequest ):Boolean;
/*

Purpose:			

