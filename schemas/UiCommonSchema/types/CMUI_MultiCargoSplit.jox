        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2020	jlgndl1	Initial creation	TFS 49401

*/

vars

begin

	if self.myTrackedItem = null or not self.myTrackedItem.canSplitTotalQuantity then
		self.unloadForm;
		return;
	endif;
	
	inheritMethod();
	
	self.populateCommonControls();
	self.populateTiFields();
	
	self.enableButtons();
	
epilog

end;</source>
