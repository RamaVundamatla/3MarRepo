    <JadeMethod name="getTblAllDef" id="3802f5e2-f019-4ab0-ac9f-0715ae347b88">
        <source>getTblAllDef() : EntTableDef;
// ---------------------------------------------------------------------------
// Created:     16 October 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	entDef		:EntTableDef;
begin

	if self.isFromShipPreNote then 
		entDef := app.myController.getEntTableDef(ETDef_AllDataGC);
		// want diff ent def as dont want location details displayed, as is on a ship not in yard.
	else
		entDef := app.myController.getEntTableDef(ETDef_AllData);
	endif;
	return entDef;
end;</source>
        <ReturnType type="EntTableDef"/>
