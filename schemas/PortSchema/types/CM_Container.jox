    <JadeMethod name="getCleanStatus" id="a5c06bed-b330-4687-830d-aa89f7fc601b">
        <source>getCleanStatus(isClean: Boolean io);

//cnwjo3 CCMS 1892, par 23587.  Method reworked a little for par.

vars
	numDays :	Integer;
	serverTime	:	TimeStamp;
begin
	if self.washDT.isValid() then
		isClean := true;
	else
		isClean := false;
		return;
	endif;
	
	if self.canWashDTExpire() then
		if self.myOperator &lt;&gt; null then
			numDays := self.myOperator.washExpiryReefer;
		endif;
		if numDays = 0 then
			numDays := self.myTerminal.getConfig(WashWarnDays).Integer;
		endif;
	endif;

	if numDays = 0 then  //neither operator or terminal wash expiry days have been set, or is not a reefer contianer
		return;
	endif;	
	
	// Get the last wash date in secs
	serverTime := app.actualTimeServer;

	if serverTime.date &lt;= (self.washDT.date + numDays) then
		isClean := true;
	else
		isClean := false;
 	endif;
end;</source>
        <Parameter name="isClean" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getContainerLength" id="8540cd10-6ebe-4a56-953a-3aac01948fa4">
        <source>getContainerLength(containerLength: CMIF_ContainerLength input);
vars

begin
	if self.is45() then 
		containerLength.setLength(45);
	elseif self.is40 then
		containerLength.setLength(40);
	elseif self.is30() then 
		containerLength.setLength(30);
	elseif self.is53() then 
		containerLength.setLength(53);
	else
		containerLength.setLength(20);
	endif;
end;</source>
