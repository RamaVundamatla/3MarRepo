    <JadeMethod name="create" id="38b31a94-feeb-4e4b-b82c-fd01f9522281">
        <updating/>
        <source>create() updating;
//--------------------------------------------------------------
//Created: 11 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.name := SOP_TableMaintForm.Table_WharfLockout;
	/*self.permissionView	 := PmHMSWharfView;
	self.permissionMaint := PmHMSWharfMaint;*/
		
	self.permissionView	 := PmHMSWLockoutView;
	self.permissionMaint := PmHMSWLockoutMaint;
	self.myDataClass := HMS_WharfLockout;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="98dd0d32-dcd5-42ba-bf93-7dcfa7814d34">
        <updating/>
        <source>doSave(): Boolean updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	conflictManager : CMIF_HMS_ConflictsManager;
	pxyWharfLockout	: HMS_WharfLockout;
	theForm : SOP_HMS_TableMaintForm;
	startDT,
	endDT : TimeStamp;
	
begin
  	theForm := self.myForm.SOP_HMS_TableMaintForm;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as HMS_WharfLockout transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	pxyWharfLockout := theForm.myProxyObject.HMS_WharfLockout;
	theForm.tblInput1.setObjectFromTable(pxyWharfLockout, null, false);
	
//	startDT.setDate(theForm.tblInput1.getValueByName(ETRow_StartOfLockoutDT).Date);
	startDT.setDate(theForm.tblInput1.getValueAsDate(ETRow_StartOfLockoutDT));
	startDT.setTime(theForm.tblInput1.getValueByName(ETRow_StartTime).Time);
//	endDT.setDate(theForm.tblInput1.getValueByName(ETRow_EndOfLockoutDT).Date);
	endDT.setDate(theForm.tblInput1.getValueAsDate(ETRow_EndOfLockoutDT));
	endDT.setTime(theForm.tblInput1.getValueByName(ETRow_EndTime).Time);
	
	pxyWharfLockout.setProxy(theForm.myHarbour, startDT, endDT);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateHMSObject(pxyWharfLockout, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateHMSObject(pxyWharfLockout, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	create conflictManager transient; //gets deleted when the form is unloaded
	
	if conflictManager.myHarbour = null then
		conflictManager.myHarbour := theForm.myHarbour;
	endif;
	
	conflictManager.endDT := endDT;
	conflictManager.allValidationTypes.add(ValidateWharfLockout);
	conflictManager.runConflictReport();
	
	if (not conflictManager.allCMIFConflicts.isEmpty()) then
		if app.msgBox('There are Voyages with conflicts in the system. Do you want to view the "Conflict Report" now?', 'View Conflict Report', MsgBox_Exclamation_Mark_Icon + MsgBox_Yes_No + MsgBox_Default_Second) = MsgBox_Return_Yes then
// cnwdad1 30/06/2008 - PAR #17135.
			theForm.myAssistant.showConflictsReport(conflictManager, null, theForm.myHarbour);
		else
			delete conflictManager;
		endif;
	else
		delete conflictManager;
	endif;
	
	return app.myPassport.trxCompletedOK();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="5fc2c0ab-4342-4d4d-8e92-0cca25a0bed3">
        <source>getCollection(): Collection;
//--------------------------------------------------------------
//Created: 11 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	return self.myForm.SOP_HMS_TableMaintForm.myHarbour.allWLockoutsByStartDT;

end;</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="getDefNameTblInput" id="9ff1f238-e284-47fc-bed8-e7c4cc86995e">
        <source>getDefNameTblInput(): String protected;
//--------------------------------------------------------------
//Created: 11 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	return ETDef_HMSWharfLockout;

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="d9ca3ce3-fa2b-49d3-8028-920244934142">
        <updating/>
        <source>setControlsForAddEdit() updating;
// -------------------------------------------
// Created 11 November 2004 by cnwdvb1
// -------------------------------------------
vars
	theForm : SOP_HMS_TableMaintForm;
	today	: TimeStamp;
begin
	inheritMethod();
	theForm := self.myForm.SOP_HMS_TableMaintForm;
	today 	:= app.actualTimeServer();
	
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.setValueByName(ETRow_StartOfLockoutDT, today.date);
		theForm.tblInput1.setValueByName(ETRow_EndOfLockoutDT, today.date);
		theForm.tblInput1.setValueByName(ETRow_StartTime, today.time);
		theForm.tblInput1.setValueByName(ETRow_EndTime, today.time);		
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="b5980cbe-0b67-485a-9b2a-333407b54d52">
        <updating/>
        <source>setupThumbnailDetails() updating;
//--------------------------------------------------
// Created:	28 January 2004 By: cnwgd1
//--------------------------------------------------
vars
	theForm : SOP_HMS_TableMaintForm;
begin
  
    theForm := self.myForm.SOP_HMS_TableMaintForm;
	inheritMethod();
	theForm.setTblDataEntRows(ETDef_HMSWharfLockout);		//cnwdb2 - 17 April 2014 - PAR 33977

	theForm.myAssistant.comboBoxHMSWharf(theForm.cmbMyWharf, theForm.myHarbour, null);	
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="54960257-91e3-4ac1-a68e-276050b88977">
        <updating/>
        <source>showThumbnail(pObj: HMS_WharfLockout) updating;
//--------------------------------------------------
// Created:	28 January 2004 By: cnwgd1
//--------------------------------------------------
vars
	theForm : SOP_HMS_TableMaintForm;
	theTbl : CM_EntryTable;		
begin
  
    theForm := self.myForm.SOP_HMS_TableMaintForm;
    theTbl := theForm.tblInput1;
	theTbl.clearValues;
	theTbl.setTableFromObject(pObj, null);
	theForm.myAssistant.comboBoxHMSWharf(theForm.cmbMyWharf, pObj.myHarbour, pObj.myWharf);
	theForm.cmbMyWharf.lostFocus(theForm.cmbMyWharf);

//	theForm.txtEndDate.setTextFromDate(pObj.endOfLockoutDT.date);
//	theForm.txtStartDate.setTextFromDate(pObj.startOfLockoutDT.date);	
//	theForm.txtStartTime.time := pObj.startOfLockoutDT.time;
//	theForm.txtEndTime.time := pObj.endOfLockoutDT.time;	
	
	theTbl.setValueByName(ETRow_StartOfLockoutDT, pObj.startOfLockoutDT.date);
	theTbl.setValueByName(ETRow_EndOfLockoutDT, pObj.endOfLockoutDT.date);
	theTbl.setValueByName(ETRow_StartTime, pObj.startOfLockoutDT.time);
	theTbl.setValueByName(ETRow_EndTime, pObj.endOfLockoutDT.time);			
end;</source>
        <Parameter name="pObj" type="HMS_WharfLockout"/>
    </JadeMethod>
</Class>
