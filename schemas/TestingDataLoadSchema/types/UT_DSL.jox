    </JadeMethod>
    <JadeMethod name="removeCraneFromAllVoyages" id="cbea326f-5c74-4076-bd2b-95a468fd306c">
        <source>removeCraneFromAllVoyages(_crane : CM_Crane io; terminal : CM_Terminal);

/*

Purpose:			Remove the crane from any voyages that it might be attached to

Date				Who		Reason
21 November 2011	cnwmh5	Initial creation

*/

vars

	voyageSet			: CM_VoyageSet;
	tmpVoyageSet		: CM_VoyageSet;
	voyage				: CM_Voyage;
	jobSheet			: CM_JobSheet;
	queue				: CM_VoyageCraneQueue;
	obj					: Object;
	
	queues				: ObjectArray;

begin

	// Shouldn't ever happen but I'm paranoid.  If no terminal then ignore
	if terminal = null then
		return;
	endif;

	// get all the voyages for the terminal
	create voyageSet transient;
	create tmpVoyageSet transient;
	terminal.getAllCargoVoyages(tmpVoyageSet);
	tmpVoyageSet.copyNoDuplicates(voyageSet, false);
	tmpVoyageSet.clear();
	terminal.getAllCellularVoyages(tmpVoyageSet, true, false);
	tmpVoyageSet.copyNoDuplicates(voyageSet, false);
	tmpVoyageSet.clear();
	terminal.getAllCurrentVoyages(tmpVoyageSet, true, false, true);
	tmpVoyageSet.copyNoDuplicates(voyageSet, false);
	
	// read through all the voayge and remove the crane if it exists
	beginTransaction;
	foreach voyage in voyageSet discreteLock where voyage.allJobSheets.isNotEmpty() do
		jobSheet := voyage.allJobSheets[_crane.id];
		if jobSheet &lt;&gt; null then
			delete jobSheet;
		endif;
	endforeach;
	commitTransaction;
	
	// remove the crane from any queues it still remains in 
	if _crane.allCraneQueues.isNotEmpty() then
		create queues transient;
		_crane.allCraneQueues.copy(queues);
		beginTransaction;
		foreach obj in queues discreteLock do
			queue := obj.CM_VoyageCraneQueue;
			queue.setPropertyValue('crane', null);
		endforeach;
		commitTransaction;
	endif;
	
epilog

	delete voyageSet;
	delete tmpVoyageSet;
	delete queues;

end;</source>
        <Parameter name="_crane" type="CM_Crane" usage="io"/>
        <Parameter name="terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="removeMergeIterCollection" id="30c4a09d-d4b8-4e7e-af06-ee1c490b6224">
        <source>removeMergeIterCollection(_dictionary : Dictionary);

/*

Purpose:		Remove the passed in collection from a mergeIterator if it
				exists.

Date			Who		Reason
02/12/2014		cnwmh5	Initial creation

*/

vars

	index 				: Integer;

begin

	if self.myMergeIter = null then
		return;
	endif;
	
	foreach index in 1 to self.myMergeIter.getCollectionCount() do
	
		if myMergeIter.getCollectionAt(index) = _dictionary then
			self.myMergeIter.removeCollection(_dictionary);
			break;
		endif;
	
	endforeach;

epilog

end;</source>
        <Parameter name="_dictionary" type="Dictionary"/>
    </JadeMethod>
    <JadeMethod name="removeQueuesFromGateAreas" id="45b7c65c-7812-43eb-99ce-c077151c4b16">
        <source>removeQueuesFromGateAreas(_gate :CM_Gate)protected;
// ---------------------------------------------------------------------------
// Created:     18 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	coll	:CM_ObjectSet;
	obj		:Object;
	queue	:CM_RadioTelemetryQueue;
begin
	create coll transient;
	_gate.getAllGateAreas (coll);
	
	beginTransaction;
	
	foreach obj in coll do 
		
		if not queue.isKindOf (CM_SubQueue) then
			continue;
		endif;
		
		foreach queue in obj.CM_GateArea.allSubRTQueues do
			queue.CM_SubQueue.allMoveFromTAMasters.removeIfPresent (obj.CM_GateArea);
			queue.CM_SubQueue.allMoveToTAMasters.removeIfPresent (obj.CM_GateArea);
		endforeach;
	endforeach;
	
	commitTransaction;
epilog
	delete coll;
end;</source>
        <access>protected</access>
        <Parameter name="_gate" type="CM_Gate"/>
    </JadeMethod>
