<CollClass name="HMS_ResourceUsedSet" id="99d60689-1d18-4ad6-8753-bc2995bd9255">
    <memberType name="HMS_ResourceUsed"/>
    <superclass name="CM_ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="harbour"/>
    <JadeMethod name="findResourceUsedFor" id="fb6b27f3-5a58-4ae4-8f83-1f086ed4070e">
        <source>findResourceUsedFor( _resource : HMS_Resource ):HMS_ResourceUsed;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2018	jlgndl1	Initial creation	TFS 39248

*/

vars

	resourceUsed : HMS_ResourceUsed;

begin

	foreach resourceUsed in self do
		if resourceUsed.myResource = _resource then
			return resourceUsed;
		endif;
	endforeach;
	
	return null;

epilog

end;</source>
        <Parameter name="_resource" type="HMS_Resource"/>
        <ReturnType type="HMS_ResourceUsed"/>
    </JadeMethod>
    <JadeMethod name="findResourceUsedForDtl" id="eae673bc-7180-4d81-9d3f-c0d705a3bae6">
        <source>findResourceUsedForDtl( _wodMarineServiceDtl : CM_WodMarineServiceDetail ):HMS_ResourceUsed;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2018	jlgndl1	Initial creation	TFS 41980

*/

vars

	resourceUsed : HMS_ResourceUsed;

begin

	if _wodMarineServiceDtl = null then
		return null;
	endif;

	foreach resourceUsed in self do
		if resourceUsed.myWorkOrderVoyageDtl = _wodMarineServiceDtl then
			return resourceUsed;
		endif;
	endforeach;
	
	return null;

epilog

end;</source>
        <Parameter name="_wodMarineServiceDtl" type="CM_WodMarineServiceDetail"/>
        <ReturnType type="HMS_ResourceUsed"/>
    </JadeMethod>
</CollClass>
