    <JadeMethod name="getClassMethodDetails" id="8263ba7f-d299-4419-aa68-20a33242bb8f">
        <source>getClassMethodDetails(_className, _methodName : String) : UM_UnitTestClassMethod;

/*

Purpose:		Get the Class / Method object.  If doesn't exist then create		

Date		Who		Reason
02/09/2013	cnwmh5	Initial creation

*/

vars

	classMethod					: UM_UnitTestClassMethod;

begin

	if _className &lt;&gt; null and _methodName &lt;&gt; null then
	
		// Check to see if the combination exists
		if self.myTestRun &lt;&gt; null then
			classMethod := self.myTestRun.myRoot.allRunnableUTClassesMethods[_className, _methodName];
		else
			classMethod := UM_Root.firstInstance.allRunnableUTClassesMethods[_className, _methodName];
		endif;
		
		// if doesn't exist the create
		if classMethod = null then
			create classMethod persistent;
			classMethod.updateDetails(_className, _methodName);
		endif;
	
	endif;
	
	return classMethod;

epilog

end;</source>
        <Parameter name="_className" type="String"/>
        <Parameter name="_methodName" type="String"/>
        <ReturnType type="UM_UnitTestClassMethod"/>
    </JadeMethod>
    <JadeMethod name="getMyTestRunRunDate" id="28fe05ca-227c-4002-bb5d-1b001c5a8be0">
        <source>getMyTestRunRunDate() : Date;

/*

Purpose:		Get the actual run date for the test run

Date			Who		Reason
03/08/2013		cnwmh5	Initial creation

*/

vars

	runDate					: Date;

begin

	runDate := self.myTestRun.startTS.date;
	if self.myTestRun.endTS &lt;&gt; null and 
			self.myTestRun.startTS.date &lt;&gt; self.myTestRun.endTS.date then
		runDate := self.myTestRun.endTS.date;
	endif;

	return runDate;

epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getResultDetails" id="6744863f-52cf-44c1-ad40-4d134b18d301">
        <source>getResultDetails(_result : Any) : Any;

/*

Purpose:			

Date		Who		Reason
02/09/2013	cnwmh5	Initial creation

*/

vars

	resultDetails					: Any;

begin

	if _result.String.cnIsNumeric then
		if _result.Integer = 0 then
			resultDetails := "PASS";
		elseif _result.Integer = 1 then
			resultDetails := "FAIL";
		else
			resultDetails := "IGNORED";
		endif;
	elseif _result.String.isAlpha then
		if _result.String = "PASS" then
			resultDetails := 0;
		elseif _result.String = "FAIL" then
			resultDetails := 1;
		else
			resultDetails := 2;
		endif;
	endif;
	
	return resultDetails;

epilog

end;</source>
        <Parameter name="_result" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
