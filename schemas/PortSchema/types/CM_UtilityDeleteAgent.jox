    <JadeMethod name="utlDeleteTerminalArea" id="84d99f50-52b0-4ee8-8fb0-0580f9220a52">
        <source>utlDeleteTerminalArea(pTA : CM_TerminalAreaMaster; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01 Jul 2013	cnwkpd1		PAR #31929 - moved YA tidy up code to Terminal Area erase method
// ---------------------------------------------------------------------------
vars
	toDelete	: CM_TerminalAreaMaster;
	aTA : CM_TerminalArea;
	termEvent	: Integer;
begin

	toDelete := pTA;

	if not self.exclusiveLockObjectToDelete(toDelete) then
	    // toDelete is null, invalid or has already been deleted
	    return;
	endif;

	app.setContinueCMExceptions(true);
	app.myValDA.valTerminalArea(toDelete);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;

	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(toDelete);
	endif;

	if _passport.noErrors then

		termEvent := toDelete.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA);
		/*
			Date		 Who		Reason
		25 July 2008	cnwdz2	  Par16866 - Notify all the subscribers after deleting a terminal area in the form Terminal Area Definition.
		*/
		toDelete.causeEvent(toDelete.myTerminal.getTerminalEvent(Event_TALocation_Delete),false,toDelete);
		
		if toDelete.isKindOf(CM_SubBlockStack) then
			aTA := toDelete.CM_SubBlockStack.myParent;
			if aTA &lt;&gt; null then
				//epr par 37377 18/1/16
				aTA.causeEvent(aTA.myTerminal.getTerminalEvent(Event_TALocation_Delete),false,toDelete);
				aTA.causeEvent(termEvent, false, aTA);
			endif;
		endif;
		toDelete.causeEvent(termEvent, false, toDelete);
		toDelete.erase(NORMAL_ERASE);
		
	endif;
epilog
	return;
	
end;</source>
        <Parameter name="pTA" type="CM_TerminalAreaMaster"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteTerminalAreaStorageGp" id="c34e6b9c-2837-4216-8cc5-9a250bf01964">
