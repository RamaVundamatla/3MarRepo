    <JadeMethod name="getWorkOrderForStatus" id="70e75b57-e871-4559-8474-b7beb5806b07">
        <source>getWorkOrderForStatus() : CM_WorkOrderVoyageDtl;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20/08/2018	jlger1	Initial creation
13/09/2018	jlgdap1	TFS 40030 PEL1 Multiple Estimates and Invoices
11/10/2021 	jlier1	TFS 51963
*/

vars

begin
	if self.status = Voyage_Status_CargoRequested  or 
		self.status = Voyage_Status_CargoPreInvGen or				// TFS 40030
		self.status = Voyage_Status_CargoTaxInvGen then			// TFS 40030
		return self.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_CARGOINITIAL).CM_WorkOrderVoyageDtl;
	// TFS 40030 new options
	elseif self.status = Voyage_Status_InitSerRequested  or
		self.status = Voyage_Status_ServPreInvGen or
		self.status = Voyage_Status_ServTaxInvGen then
		return self.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_MARINEINITIAL).CM_WorkOrderVoyageDtl;
	elseif self.status = Voyage_Status_DepServRequested  then
		return self.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_MARINEDEPART).CM_WorkOrderVoyageDtl;
	// TFS 40030 end of new options
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_WorkOrderVoyageDtl"/>
    </JadeMethod>
    <JadeMethod name="getWorkOrderForVoyCargoRequest" id="052250eb-317b-44d9-b680-de9d46f715cf">
        <source>getWorkOrderForVoyCargoRequest() : CM_WodVoyageCargoRequest;
/*

Purpose:			TFS 40435

