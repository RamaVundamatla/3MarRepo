    <JadeMethod name="jrwGetMoveMTCount" id="390d56d0-95a2-4e86-adca-b6c3e6623348">
        <source>jrwGetMoveMTCount():Integer;
// ---------------------------------------------------------------------------
// Created:     10 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	kpiMove :CM_KPIMachineMoveDtl;
	count	:Integer;
begin
	foreach kpiMove in self.allKPIMachineMoves do
		if kpiMove.isMT then
			count := count + 1;
		endif;
	endforeach;
	
	return count;
epilog

