    <JadeMethod name="tblFailed_mouseMove" id="8e3cf226-c6f5-4847-a473-7914005fb99a">
        <updating/>
        <source>tblFailed_mouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 March 2012	cnwndl1	Initial creation	Par 29195

*/

vars
	tmpHeight : Real;	
begin

	if not self.isLocalTerminal then
		return;
	endif;

	if table.fixedRows &gt; 0 then
		tmpHeight := table.accessRow(table.fixedRows).height;
		if self.origYPos &lt;= tmpHeight then
			return;
		endif;
	endif;

	if button = 1 then
		if app.dragDetected(x, y, self.origXPos, self.origYPos) then
			self.doTblFailedDragTrackedItem();
			self.origXPos := 0;
			self.origYPos := 0;
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
