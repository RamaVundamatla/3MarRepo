    <JadeMethod name="showTerminalAreaDef" id="521a3b8c-42b6-4aa6-9604-07e6f2237ad6">
        <source>showTerminalAreaDef(_terminalArea : CM_TerminalArea; _masterMenuAction : CMUI_MenuAction);
/*
----------   ----------  --------------------------------------------------
Created:	26 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	schema		: Schema;
	taDefForm 	: CM_TableViewForm;
	menuAction 	: CMUI_MenuAction;

begin

	menuAction := app.myController.createMenuAction(PmAdmTermareadefView, null, _masterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
		
	taDefForm := menuAction.goToObject(null, null, false, null).CM_TableViewForm;
	if taDefForm = null then
		return;
	endif;
	
	if _terminalArea &lt;&gt; null then
		taDefForm.showWithObject(_terminalArea, true, true);
	else
		taDefForm.showForNew(true, true);
		
	endif;
	
end;</source>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showTerminalAreaForm" id="196cfd7f-8cec-498b-8811-15ba8f768e0d">
        <source>showTerminalAreaForm(_terminalArea : CM_TerminalArea; _masterMenuAction : CMUI_MenuAction);
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16MAY08	AKB			To Use YardSchema GridAreas Form
// ---------------------------------------------------------------------------
vars
	yrdForm : Form;
	aClass : Class;
	jrw : Schema;
begin
	if _terminalArea = null then
		return;
	endif;

	if _terminalArea.isGridArea() then
		jrw := rootSchema.getSchema("YardSchema");
		aClass := jrw.getClass("YRD_GridAreasForm");
		yrdForm := app.loadForm(aClass, CMUI_Assistant, false, false, true, self.myTerminal, _masterMenuAction);
		if yrdForm = null then
			return;
		endif;
	
		yrdForm.setPropertyValue("myInitializeObject", _terminalArea);
		yrdForm.show();
	else
		// Block Stacks etc. are shown in the Cargo Enquiry Form!
		self.showCargoEnquiryForm(_terminalArea, _masterMenuAction, false, false);
	endif;

end;</source>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showTestAutoPlan" id="b1eea430-6492-49cf-bb83-0cf8f0ddf5b7">
        <source>showTestAutoPlan(	_terminal : CM_Terminal;
					_terminalArea : CM_TerminalArea;
					_ti : CM_TrackedItem;
					_tiArray : ObjectArray input;
					_childrenOnly : Boolean
					);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 February 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	testAutoPlanForm : CMUI_TestAutoPlanForm;
	tiArray : CM_TIArray;
	obj : Object;
	index : Integer;
	form : Form;
	child : CM_TrackedItem;

begin

	create tiArray transient;
	if _ti &lt;&gt; null then
		if _childrenOnly then
			//15 July 2014	NDL	Par 34599
			foreach child in _ti.allChildren do
				if CM_TrackedItem.hasInstance( child ) then
					tiArray.addExclusive( child );
				endif;
			endforeach;
		else
			tiArray.addExclusive( _ti );
		endif;
	endif;
	if _tiArray &lt;&gt; null and not _tiArray.isEmpty then
		foreach obj in _tiArray discreteLock do
			if CM_TrackedItem.hasInstance( obj ) then
				if _childrenOnly then
					//15 July 2014	NDL	Par 34599
					foreach child in obj.CM_TrackedItem.allChildren do
						if CM_TrackedItem.hasInstance( child ) then
							tiArray.addExclusive( child );
						endif;
					endforeach;
				else
					tiArray.addExclusive( obj.CM_TrackedItem );
				endif;
			endif;
		endforeach;
	endif;
	if tiArray.isEmpty then
		return;
	endif;
	
	// try to find an existing form.
//	testAutoPlanForm := app.getForm( CMUI_TestAutoPlanForm.name ).CMUI_TestAutoPlanForm;
	foreach index in 1 to app.formsCount do
		form := app.forms(index);
		if form.name = CMUI_TestAutoPlanForm.name then
			if form.CMUI_TestAutoPlanForm.myTerminal = _terminal then
				testAutoPlanForm := form.CMUI_TestAutoPlanForm;
				break;
			endif;
		endif;
	endforeach;
	
	if testAutoPlanForm = null then
		// there wasn't one, create it and set it up.
		testAutoPlanForm := app.loadForm(CMUI_TestAutoPlanForm, CMUI_Assistant, false, false, false, _terminal, null).CMUI_TestAutoPlanForm;
		testAutoPlanForm.show();
	endif;
	// add the new cargo items passed to us.
	testAutoPlanForm.addSelectedCargo( tiArray );
	//bring the form to the front again.
	testAutoPlanForm.setFocus();

epilog

	delete tiArray;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiArray" type="ObjectArray" usage="input"/>
        <Parameter name="_childrenOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showTextTransalationForm" id="2895ebc3-1bae-4871-bfca-6e496c453738">
        <source>showTextTransalationForm(_entTableDef : EntTableDef);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

	formCls,
	assistCls	: Class;
	textTranslationForm : CM_BaseForm;
	menuAction : CMUI_MenuAction;
	subSys : CMUI_SubSystem;
	term : CM_Terminal;
	
begin
	subSys := app.myController.allSubSystems['SysOpsSchema'];
	
	if subSys &lt;&gt; null then
		subSys.getFormDetails('SOP_TextTranslationForm', formCls, assistCls);
	endif;
	
	if formCls = null then
		return;
	endif;
	
	textTranslationForm := app.loadForm(formCls, assistCls, false, false, true, null, null).CM_BaseForm;
	if textTranslationForm = null then
		return;
	endif;

	if _entTableDef = null then
		return;
	endif;
	
	textTranslationForm.setFormObject(_entTableDef);
	
	textTranslationForm.show;

epilog

end;</source>
        <Parameter name="_entTableDef" type="EntTableDef"/>
