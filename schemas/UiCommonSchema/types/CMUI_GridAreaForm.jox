    <JadeMethod name="moveTrackedItemSource" id="4dbd4ec4-efb5-470b-9638-06639adb0f8f">
        <updating/>
        <source>moveTrackedItemSource() updating; 
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		NOTE the TI and the Source Location are set in somewhere like frmGridArea_contextMenu on YRD_GridForm
//				NOTE this code is duplicated in CM_ContainerEnqForm
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	if app.myMoveController = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'app.myMoveController = null');
		return;
	endif;
	
	app.myMoveController.moveTrackedItemSource(self.myTerminal);	
	
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
