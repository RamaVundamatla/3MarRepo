    <JadeMethod name="txtFind_keyDown" id="41fa41e4-d9cb-4ea5-aed3-fdb34af7def1">
        <controlMethod name="TextBox::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtFind_keyDown(textbox: TextBox input; keyCode: Integer io; shift: Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17 March 2020	jlgdap1		Initial creation TFS 
//
vars

begin
	if keyCode = J_key_Return then
		self.btnFind.click( self.btnFind );
		keyCode := null;
	endif;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
</GUIClass>
