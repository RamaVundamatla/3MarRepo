    <JadeMethod name="getCraneID" id="de12ad69-aa19-4cf5-8d1a-84625c82ac1e">
        <source>getCraneID() : String;
/*
Date		Who		Reason
27 Sep 2011	#cnwdz2	 

*/
vars

begin
	if self.myCrane &lt;&gt; null then
		return self.myCrane.id;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
