end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="1f06a4d1-79bb-466b-baea-cad716f1d4c5">
        <updating/>
        <source>setProxy(pCode, pDescription : String; 
		 pTareKilos,
		 pColour : Integer;
		 pCargoType : CM_CargoType;
		 pISOTypeGroup:CM_ISOTypeGroup;
		 pIS20ftLong,pIS30ftLong, pIS40ftLong, pIS45ftLong,pIS53ftLong, pIS4ft3High, pIS4ftHigh, 
		 pIS8ft6High, pIS8ftHigh, pISHalfHeight, pISOver8ft6High,
		 pISCrib, pISFantainer, pISFlat, pISGeneral,
		 pISIntegral, pISMachinery, pISOpenTop, pISPorthole,
		 pISPowered, pISReefer, pISTank, pISFrame, pIsRotatable, _isNotAvailableForEntry, _isNotTwinLiftCapable : Boolean;
		 maxTotalWeight,
		 maxTareWeight : Integer) updating;
//02/08/2016 cnwma1 TFS #2447:Adding duplicate gives error
//02/10/2025	navkc1 JIRA 36151 AAT | RotaBox ISO Type and New Attributes - JADE - pIsRotatable
vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.code := pCode[1:4].toUpper; //02/08/2016 cnwma1 TFS #2447
	self.description := pDescription[1:40];
	self.tareKilos := pTareKilos;
	self.colour := pColour;
	self.myCargoType := pCargoType;
	self.myISOTypeGroup := pISOTypeGroup;
	self.isNotAvailableForEntry := _isNotAvailableForEntry;
	// Not twin lift capable if 40 foot or user defined.
//	self.isNotTwinLiftCapable := _isNotTwinLiftCapable or pIS40ftLong;
	self.isNotTwinLiftCapable := _isNotTwinLiftCapable or (not pIS20ftLong); // PAR 17390
	self.sizeAttributes := self.setSizeAttributes(pIS20ftLong,pIS30ftLong,pIS40ftLong,pIS45ftLong,pIS53ftLong,pIS4ft3High,pIS4ftHigh,pIS8ft6High,pIS8ftHigh,pISHalfHeight,pISOver8ft6High);
	self.typeAttributes := self.setTypeAttributes(pISCrib,pISFantainer,pISFlat,pISGeneral,pISIntegral,pISMachinery,pISOpenTop,pISPorthole,pISPowered,pISReefer,pISTank,pISFrame, pIsRotatable);
	self.maxTareWeight := maxTareWeight;
	self.maxTotalWeight :=  maxTotalWeight;
	self.myRoot := app.myRoot;
	
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="pTareKilos" type="Integer"/>
        <Parameter name="pColour" type="Integer"/>
        <Parameter name="pCargoType" type="CM_CargoType"/>
        <Parameter name="pISOTypeGroup" type="CM_ISOTypeGroup"/>
        <Parameter name="pIS20ftLong" type="Boolean"/>
        <Parameter name="pIS30ftLong" type="Boolean"/>
        <Parameter name="pIS40ftLong" type="Boolean"/>
        <Parameter name="pIS45ftLong" type="Boolean"/>
        <Parameter name="pIS53ftLong" type="Boolean"/>
        <Parameter name="pIS4ft3High" type="Boolean"/>
        <Parameter name="pIS4ftHigh" type="Boolean"/>
        <Parameter name="pIS8ft6High" type="Boolean"/>
        <Parameter name="pIS8ftHigh" type="Boolean"/>
        <Parameter name="pISHalfHeight" type="Boolean"/>
        <Parameter name="pISOver8ft6High" type="Boolean"/>
        <Parameter name="pISCrib" type="Boolean"/>
        <Parameter name="pISFantainer" type="Boolean"/>
        <Parameter name="pISFlat" type="Boolean"/>
        <Parameter name="pISGeneral" type="Boolean"/>
        <Parameter name="pISIntegral" type="Boolean"/>
        <Parameter name="pISMachinery" type="Boolean"/>
        <Parameter name="pISOpenTop" type="Boolean"/>
        <Parameter name="pISPorthole" type="Boolean"/>
        <Parameter name="pISPowered" type="Boolean"/>
        <Parameter name="pISReefer" type="Boolean"/>
        <Parameter name="pISTank" type="Boolean"/>
        <Parameter name="pISFrame" type="Boolean"/>
        <Parameter name="pIsRotatable" type="Boolean"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="_isNotTwinLiftCapable" type="Boolean"/>
        <Parameter name="maxTotalWeight" type="Integer"/>
        <Parameter name="maxTareWeight" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setSizeAttributes" id="718de4be-7b5a-4995-a6f8-4f882e1f03bd">
        <updating/>
        <source>setSizeAttributes(pIS20ftLong,pIS30ftLong,pIS40ftLong,pIS45ftLong,pIS53ftLong,pIS4ft3High,pIS4ftHigh,pIS8ft6High,pIS8ftHigh,pISHalfHeight,pIS9ft6High:Boolean) :Integer updating, protected;

vars
intIs20ftLong,intIs40ftLong,intIs4ft3High,intIs4ftHigh,
intIs8ft6High,intIs8ftHigh,intIs9ft6High,intIsHalfHeight : Integer;
attributes : Integer;
begin
	intIs20ftLong := ISO_LEN_20;
	intIs40ftLong := ISO_LEN_40;
	intIs4ft3High := ISO_HEIGHT_43;
	intIs4ftHigh  := ISO_HEIGHT_4;
    intIs8ft6High := ISO_HEIGHT_86;
    intIs8ftHigh  := ISO_HEIGHT_8;
    intIs9ft6High := ISO_HEIGHT_96;
    intIsHalfHeight := ISO_HALF_HEIGHT;
 
    if pIS20ftLong  then
    	//intIs20ftLong:=intIs20ftLong.bitNot;
    	attributes:=attributes.bitOr(intIs20ftLong); 
    endif;
    if pIS40ftLong  then
    	//intIs40ftLong:=intIs40ftLong.bitNot;
    	attributes:=attributes.bitOr(intIs40ftLong);  
    endif;
    if pIS45ftLong  then
    	attributes:=attributes.bitOr(ISO_LEN_45);  
    endif;
    if pIS53ftLong  then
    	attributes:=attributes.bitOr(ISO_LEN_53);  
    endif;
    if pIS30ftLong  then
    	attributes:=attributes.bitOr(ISO_LEN_30);  
    endif;
    if pIS4ft3High  then
    	//intIs4ft3High:=intIs4ft3High.bitNot;
    	attributes:=attributes.bitOr(intIs4ft3High);
		attributes:=attributes.bitOr(intIsHalfHeight); 	// 25/11/2025 	navkc1	JIRA MTN 36254
    endif;
    if pIS4ftHigh  then
    	//intIs4ftHigh:=intIs4ftHigh.bitNot;
    	attributes:=attributes.bitOr(intIs4ftHigh);
		attributes:=attributes.bitOr(intIsHalfHeight); 	// 25/11/2025 	navkc1	JIRA MTN 36254
    endif;
    if pIS8ft6High  then
    	//intIs8ft6High:=intIs8ft6High.bitNot;
    	attributes:=attributes.bitOr(intIs8ft6High);  
    endif;
    if pIS8ftHigh  then
    	//intIs8ftHigh:=intIs8ftHigh.bitNot;
    	 attributes:=attributes.bitOr(intIs8ftHigh);  
    endif;
    if pIS9ft6High  then
    	//intIsOver8ft6High:=intIsOver8ft6High.bitNot;
    	attributes:=attributes.bitOr(intIs9ft6High);  
    endif;
    if pISHalfHeight  then
    	//intIsHalfHeight:=intIsHalfHeight.bitNot;
    	 attributes:=attributes.bitOr(intIsHalfHeight); 
    endif;
/*   
    attributes:=attributes.bitOr(intIs20ftLong);  
    attributes:=attributes.bitOr(intIs40ftLong);  
    attributes:=attributes.bitOr(intIs4ft3High);  
    attributes:=attributes.bitOr(intIs4ftHigh);  
    attributes:=attributes.bitOr(intIs8ft6High);  
    attributes:=attributes.bitOr(intIs8ftHigh);  
    attributes:=attributes.bitOr(intIs9ft6High);  
    attributes:=attributes.bitOr(intIsHalfHeight); 
*/
	return attributes;
end;</source>
        <access>protected</access>
        <Parameter name="pIS20ftLong" type="Boolean"/>
        <Parameter name="pIS30ftLong" type="Boolean"/>
        <Parameter name="pIS40ftLong" type="Boolean"/>
        <Parameter name="pIS45ftLong" type="Boolean"/>
        <Parameter name="pIS53ftLong" type="Boolean"/>
        <Parameter name="pIS4ft3High" type="Boolean"/>
        <Parameter name="pIS4ftHigh" type="Boolean"/>
        <Parameter name="pIS8ft6High" type="Boolean"/>
        <Parameter name="pIS8ftHigh" type="Boolean"/>
        <Parameter name="pISHalfHeight" type="Boolean"/>
        <Parameter name="pIS9ft6High" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTypeAttributes" id="714d2017-360d-4ded-8cbb-a378d9aa157b">
        <updating/>
        <source>setTypeAttributes(pISCrib,pISFantainer,pISFlat,pISGeneral,pISIntegral,pISMachinery,pISOpenTop,pISPorthole,pISPowered,pISReefer,pISTank,pISFrame,pIsRotatable:Boolean) :Integer updating ,protected;

vars
	intISCrib,intISFantainer,intISFlat,intISGeneral,intISIntegral,intISMachinery,
	intISOpenTop,intISPorthole,intISPowered,intISReefer,intISTank :Integer;
	intIsRotatable,
	intISFrame : Integer;
	attributes : Integer;
	
begin
	intISCrib := ISO_CRIB;
	intISFantainer := ISO_FAN;
	intISFlat := ISO_FLAT;
	intISGeneral := ISO_GENERAL;
	intISIntegral := ISO_INTEGRAL;
	intISMachinery := ISO_MACHINERY;
	intISOpenTop := ISO_OPENTOP;
	intISPorthole := ISO_PORTHOLE;
	intISPowered := ISO_POWERED;
	intISReefer := ISO_REEFER;
	intISTank := ISO_TANK;
	intISFrame := ISO_FRAME;	//02 Feb 2018	NDL	TFS 36752
	intIsRotatable := ISO_ROTATABLE; //02/10/2025	navkc1 JIRA 36151
	
	if pISCrib  then
		//intISCrib:=intISCrib.bitNot;
		attributes := attributes.bitOr(intISCrib);
	endif;
	if pISFantainer  then
		//intISFantainer:=intISFantainer.bitNot;
		attributes := attributes.bitOr(intISFantainer);
	endif;
	if pISFlat then
		//intISFlat:=intISFlat.bitNot;
		attributes := attributes.bitOr(intISFlat);
	endif;
	if pISGeneral then
		//intISGeneral:=intISGeneral.bitNot;
		attributes := attributes.bitOr(intISGeneral);
	endif;
	if pISIntegral  then
		//intISIntegral:=intISIntegral.bitNot;
		attributes := attributes.bitOr(intISIntegral);
	endif;
	if pISMachinery  then
		//intISMachinery:=intISMachinery.bitNot;
		attributes := attributes.bitOr(intISMachinery);
	endif;
	if pISOpenTop  then
		//intISOpenTop:=intISOpenTop.bitNot;
		attributes := attributes.bitOr(intISOpenTop);
	endif;
	if pISPorthole  then
		//intISPorthole:=intISPorthole.bitNot;
		attributes := attributes.bitOr(intISPorthole);
	endif;
	if pISPowered  then
		//intISPowered:=intISPowered.bitNot;
		attributes := attributes.bitOr(intISPowered);
	endif;
	if pISReefer  then
		//intISReefer:=intISReefer.bitNot;
		attributes := attributes.bitOr(intISReefer);
	endif;
	if pISTank  then
		//intISTank:=intISTank.bitNot;
		attributes := attributes.bitOr(intISTank);	
	endif;
	
	//02 Feb 2018	NDL	TFS 36752
	if pISFrame then
		attributes := attributes.bitOr(intISFrame);
	endif;
	
	//02/10/2025	navkc1 JIRA 36151
	if pIsRotatable then
		attributes := attributes.bitOr(intIsRotatable);
	endif;

/*   
	attributes := attributes.bitOr(intISCrib);
 	attributes := attributes.bitOr(intISFantainer);
	attributes := attributes.bitOr(intISFlat);
	attributes := attributes.bitOr(intISGeneral);
	attributes := attributes.bitOr(intISIntegral);
	attributes := attributes.bitOr(intISMachinery);
	attributes := attributes.bitOr(intISOpenTop);
	attributes := attributes.bitOr(intISPorthole);
	attributes := attributes.bitOr(intISPowered);
	attributes := attributes.bitOr(intISReefer);
	attributes := attributes.bitOr(intISTank);	
*/
 
  	return attributes;
end;</source>
        <access>protected</access>
        <Parameter name="pISCrib" type="Boolean"/>
        <Parameter name="pISFantainer" type="Boolean"/>
        <Parameter name="pISFlat" type="Boolean"/>
        <Parameter name="pISGeneral" type="Boolean"/>
        <Parameter name="pISIntegral" type="Boolean"/>
        <Parameter name="pISMachinery" type="Boolean"/>
        <Parameter name="pISOpenTop" type="Boolean"/>
        <Parameter name="pISPorthole" type="Boolean"/>
        <Parameter name="pISPowered" type="Boolean"/>
        <Parameter name="pISReefer" type="Boolean"/>
        <Parameter name="pISTank" type="Boolean"/>
        <Parameter name="pISFrame" type="Boolean"/>
        <Parameter name="pIsRotatable" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="ce05b723-0587-4ddc-ba02-11b54fd7cdbc">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;

vars

begin
	if _property = null or
	   _property.name = CM_ISOType::colour.name or
	   _property.name = CM_ISOType::sizeAttributes.name or
	   _property.name = CM_ISOType::tiType.name or
	   _property.name = CM_ISOType::typeAttributes.name or
	   _property.name = CM_ISOType::cargoTypeId.name or
	   _property.name = CM_ISOType::myCargoType.name then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="bdc2372a-286d-442b-b83b-af698d90d934">
        <source>showThumbnail(pTable : Table);
// ---------------------------------------------------------------------------
// Created:     27 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpStr		: String;
	firstOne	: Boolean;

begin

	pTable.addItem('Code' &amp; Tab &amp; self.code.trimRight);
	pTable.addItem('Description' &amp; Tab &amp; self.description.trimRight);
	pTable.addItem('');
	
	if self.myCargoType &lt;&gt; null then
		pTable.addItem('Cargo Type' &amp; Tab &amp; self.myCargoType.description);
	else
		pTable.addItem('Cargo Type' &amp; Tab &amp; 'Unknown');
	endif;
	
	if self.myISOTypeGroup &lt;&gt; null then
		tmpStr := self.myISOTypeGroup.code.trimRight;
	else
		tmpStr := '&lt;not set&gt;';
	endif;
	pTable.addItem('Group' &amp; Tab &amp; tmpStr);
	if self.myISOTypeGroup &lt;&gt; null then
		pTable.addItem(Tab &amp; self.myISOTypeGroup.description.trimRight);
	endif;
		
	pTable.addItem('');
	
	if self.is20ftLong then
		tmpStr := '20 ft';
	elseif self.is40ftLong then
		tmpStr := '40 ft';
	elseif self.is45ftLong then
		tmpStr := '45 ft';
	elseif self.is30ftLong then
		tmpStr := '30 ft';
	elseif self.is53ftLong then
		tmpStr := '53 ft';
	else
		tmpStr := 'Unknown';
	endif;
	pTable.addItem('Length' &amp; Tab &amp; tmpStr);

	if self.is4ftHigh then
		tmpStr := '4 ft';
	elseif self.is4ft3High then
		tmpStr := '4 ft 3';
	elseif self.is8ftHigh then
		tmpStr := '8 ft';
	elseif self.is8ft6High then
		tmpStr := '8 ft 6';
	else
		tmpStr := 'Unknown';
	endif;
	pTable.addItem('Height' &amp; Tab &amp; tmpStr);
	
	tmpStr := null;
	self.buildTypeDescr(self.isCrib, 'Crib', tmpStr);
	self.buildTypeDescr(self.isFantainer, 'Fantainer', tmpStr);
	self.buildTypeDescr(self.isFlat, 'Flat', tmpStr);
	self.buildTypeDescr(self.isGeneral, 'General', tmpStr);
	self.buildTypeDescr(self.isHalfHeight, 'HalfHeight', tmpStr);
	self.buildTypeDescr(self.isIntegral, 'Integral', tmpStr);
	self.buildTypeDescr(self.isMachinery, 'Machinery', tmpStr);
	self.buildTypeDescr(self.isOpenTop, 'OpenTop', tmpStr);
	self.buildTypeDescr(self.isPorthole, 'Porthole', tmpStr);
	self.buildTypeDescr(self.isPowered, 'Powered', tmpStr);
	self.buildTypeDescr(self.isReefer, 'Reefer', tmpStr);
	
	pTable.addItem('Attributes' &amp; Tab &amp; tmpStr);

end;</source>
        <Parameter name="pTable" type="Table"/>
    </JadeMethod>
    <JadeMethod name="tiType" id="b443b65f-857b-43c0-bb6f-fd8056ae361e">
        <methodInvocation>mapping</methodInvocation>
        <source>tiType(set: Boolean; _value: Integer io) mapping;
	// keep after version 7 as Virtual for DSS uses this field
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	else
		_value :=  self.myCargoType.id;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="648a68d2-7dec-46dd-b8e0-aa79a4303b03">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	isoCode	: String;
begin
	// TFS 1847 cnwjre1 20/04/2016 upper-case ISO code on save to avoid the problem with '22gp' and '22GP' getting
	//		1310 in CM_YATypeISO::getObjects from upperCased code value
	isoCode := self.code.trimBlanks.toUpper();
	if app.myRoot.allISOTypes[isoCode] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, isoCode, null, null);
	endif;

	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="77168548-2d4f-4b44-a3ad-1d8006bbf7a0">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30475 - remove location restriction classes
// ---------------------------------------------------------------------------
vars
	iter 		: Iterator;
	rule 		: CM_EDIPartyCoparnRules;
	whereUsed : String;
begin
	//01 Nov 2012	NDL	Par 30471
	iter := CM_EDIPartyCoparnRules.instances.createIterator;
	
	while iter.next( rule ) do
		if rule.myISOTypeForEQD_plus_RD = self then
			app.raiseCMException2(ObjectStillHasEntries, self.code, "Coparn rules", null, null);
			return;
		endif;
	endwhile;
	
	//10 Nov 2020	NDL	TFS 50279
	if self.isUsedinConfig( whereUsed ) then
		app.raiseCMException2(ERR_CANNOT_DELETE, self.code, whereUsed, null, self);
	endif;
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="1f018eda-4d2a-4cba-8ac2-8e8ae7d06c39">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	whereUsed : String;

begin
	self.validateMe;
	
	//10 Nov 2020	NDL	TFS 50279
	if self.isNotAvailableForEntry then
		if self.isUsedinConfig( whereUsed ) then
			app.raiseCMException1(Not_make_not_availa_while, whereUsed, null, self);
		endif;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="730205fa-46ad-4646-b64e-ea7ef6a02d55">
        <source>validateMe() protected;

vars

begin
	if (self.cargoTypeId = null) then
		app.raiseCMException2(ERR_INVALID_VALUE, "Cargo Type","A Cargo type must be entered",null , null );
	endif;
	
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'ISOType Code', null, null);
		app.raiseCMException(Input_required_field_isoCode, null, null); // cnwdb2	PAR 35364

	endif;
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'ISOType Description', null, null);
		app.raiseCMException(Input_required_field_isoTypDes, null, null); // cnwdb2	PAR 35364
	endif;
	
	//Check for duplicates on height or length and valid combinations or type have been selected
	if (not self.isHeightOK) then
		app.raiseCMException2(ERR_INVALID_VALUE, "ISOType Heights","More than one height specified",null , null );
	endif;
	
	if (not self.isLengthOK) then
		app.raiseCMException2(ERR_INVALID_VALUE, "ISOType Lengths","More than one length specified",null , null );
	endif;
	
	if (not self.isTypeOK) then
		app.raiseCMException2(ERR_INVALID_VALUE, "ISOType Types","Incompatible types specified",null , null );
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
