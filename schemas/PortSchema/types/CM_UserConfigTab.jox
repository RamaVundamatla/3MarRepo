    <PrimAttribute name="description" id="b5d3d561-1994-4593-840e-0013ffa24db4">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>User-visible description, shown in cargo enquiry sheets</text>
    </PrimAttribute>
    <ExplicitInverseRef name="myUserCargoType" id="ef964d88-2c3f-4130-a807-6e63b93f54e1">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_UserConfigCargoType"/>
        <access>readonly</access>
        <Inverse name="CM_UserConfigCargoType::allUserConfigTabs"/>
    </ExplicitInverseRef>
    <PrimAttribute name="name" id="c8133bbb-c55e-4156-a2ac-be92dcad8516">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Corresponding entTable name, used to identify tranships mainly</text>
    </PrimAttribute>
    <PrimAttribute name="tabType" id="c9462fda-f91f-4ab4-9f9c-93119be0edae">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
        <text>Has a value of 0 for regular tabs, and 1 for the reefer tab, which is shown conditionally by the cargo enquiry form.</text>
    </PrimAttribute>
    <JadeMethod name="moveAttribute" id="fe2aecbb-a830-4031-a9ca-a9fe3e479007">
        <source>moveAttribute(_attr : CM_UserConfigAttribute; _moveUp : Boolean);

vars

begin
	self.allAttributes.moveElement(_attr, _moveUp);
end;
</source>
        <Parameter name="_attr" type="CM_UserConfigAttribute"/>
        <Parameter name="_moveUp" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTabType" id="ce9dd721-4c76-464d-a03d-17b805696075">
        <updating/>
        <source>setTabType(_value : Integer) updating;

vars

begin
	self.tabType := _value;
end;
</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setup" id="6b1e7d88-f4f8-49ab-9bd7-81c64c7e6baf">
        <updating/>
        <source>setup(_description : String; _name : String; _tabType : Integer; _userCargoType : CM_UserConfigCargoType) updating;

vars

begin
	self.description := _description;
	self.name := _name;
	self.tabType := _tabType;
	self.myUserCargoType := _userCargoType;
end;
</source>
        <Parameter name="_description" type="String"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_tabType" type="Integer"/>
        <Parameter name="_userCargoType" type="CM_UserConfigCargoType"/>
    </JadeMethod>
    <JadeMethod name="swapAttribute" id="00bb5332-158b-4e0a-a47a-8bfa17450076">
        <source>swapAttribute(_fromIndex : Integer; _toIndex : Integer);

// 14/10/2011	cnwmh5	#28424 - Change so that removes before it inserts item so 1272 error doesn't occur
vars
	moving	: CM_UserConfigAttribute;
begin
	if _fromIndex &lt; 1 or
	   _fromIndex &gt; self.allAttributes.size then
		return;
	endif;
	if _toIndex &lt; 1 or
	   _toIndex &gt; self.allAttributes.size then
		return;
	endif;

	moving := self.allAttributes[_fromIndex];
	
	// remove the item from the collection 1st, else causes 1272 error
	self.allAttributes.removeAt(_fromIndex);
	self.allAttributes.insert(_toIndex, moving);
	
	/*
	if _fromIndex &gt; _toIndex then
		self.allAttributes.insert(_toIndex, moving);
		self.allAttributes.removeAt(_fromIndex);
	else
		self.allAttributes.removeAt(_fromIndex);
		self.allAttributes.insert(_toIndex, moving);
	endif;
	*/
end;
</source>
        <Parameter name="_fromIndex" type="Integer"/>
        <Parameter name="_toIndex" type="Integer"/>
    </JadeMethod>
</Class>
