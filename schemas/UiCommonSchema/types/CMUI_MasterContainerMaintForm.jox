    <JadeMethod name="loadData" id="98e5c4f4-ed0a-4a41-a998-581fd3a6d63b">
        <source>loadData();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/08/2008	cnwrd1	Initial creation
12/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
26/09/2013	cnwdap1	PAR #32552 Weight fields are now measurement tables too
04/03/2014	cnwdap1	PAR #33638 Correct External / Internal measurement fields
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
*/
vars
	indx	: Integer;
	stopTable : CM_StopsTable;
	toDoTaskDesc : CM_ToDoTaskDesc;
	tmpIsoType : CM_ISOType;
	weightType : CM_MeasurementType;				// PAR #31155
	volumeType : CM_MeasurementType;				// PAR #31155
	lengthType : CM_MeasurementType;
	widthType : CM_MeasurementType;
	heightType : CM_MeasurementType;
	
begin
	weightType := app.getDefaultMeasurementForType(Type_Weight);		// PAR #31155
	volumeType := app.getDefaultMeasurementForType(Type_Volume);		// PAR #31155
	lengthType := app.getDefaultMeasurementForType(Type_Length);
	widthType := app.getDefaultMeasurementForType(Type_Width);
	heightType := app.getDefaultMeasurementForType(Type_Height);
	
	if self.myTiMaster &lt;&gt; null then
		self.chkOverwrite.value := true;
		self.chkOverwrite.enabled := false;
		
		self.txtID.text			:= self.myTiMaster.id;
		
		indx:=self.cmbOperator.findObject(self.myTiMaster.myOperatorNew);
		if indx &gt; 0 then
			self.cmbOperator.listIndex:=indx;
			//self.tblData.setValueByControlName(self.cmbOperator.name, self.cmbOperator.text);
		endif;

		indx:=self.cmbOwner.findObject(self.myTiMaster.myOwner);
		if indx &gt; 0 then
			self.cmbOwner.listIndex:=indx;		
		endif;
		
		tmpIsoType := self.myTiMaster.getISOTypeObject(); 
		
		indx	:=	self.cmbISOType.findObject(tmpIsoType);
		if indx &gt; 0 then
			self.cmbISOType.listIndex	:=	indx;
		endif;
		//27.02.2018 cnwma1 ChangeRequest #36813
		indx	:= self.cmbGenerator.findObject(self.myTiMaster.allTIMasterAttachees.first.CM_TIMaster);
		if indx &gt; 0 then
			self.cmbGenerator.listIndex	:=	indx;
		endif;
		
		setForReefer(tmpIsoType.isReefer);
		
		self.cmbCoolingType.listIndex :=  self.myTiMaster.coolingType +1;
		self.cmbVoltageType.listIndex :=  self.myTiMaster.voltageType +1;
		
		//self.txtWeight.text := self.myTiMaster.tWeight.asStringWeightJMT();												// PAR #31155
		//self.txtWeight.decimals := weightType.getDecimalPrecision;																				// PAR #32552
		//self.txtWeight.text := app.convertMeasurementForDisplay(weightType.shortName, self.myTiMaster.tWeight);									// PAR #32552
		self.txtWeight.setValues(app.convertMeasurementForDisplay(weightType.shortName, self.myTiMaster.tWeight) &amp; Space &amp; weightType.shortName);	// PAR #32552
		self.chkCommunicating.value := self.myTiMaster.isCommunicating;
		self.chkHeavyLift.value := self.myTiMaster.isHeavyLift;
		if lengthType.isFeetAndInches then																					// PAR #31155
			self.txtFtExtLength.text := app.convertMeasureForMaskDisplay(lengthType.shortName, self.myTiMaster.extLength);	// PAR #31155
			self.txtFtIntLength.text := app.convertMeasureForMaskDisplay(lengthType.shortName, self.myTiMaster.intLength);	// PAR #31155
		else																												// PAR #31155
			self.txtExtLength.setValues(app.convertMeasurementForDisplay(lengthType.shortName, self.myTiMaster.extLength) &amp; Space &amp; lengthType.shortName);	// PAR #33638
			self.txtIntLength.setValues(app.convertMeasurementForDisplay(lengthType.shortName, self.myTiMaster.intLength) &amp; Space &amp; lengthType.shortName);	// PAR #33638
		endif;
		if widthType.isFeetAndInches then																					// PAR #31155
			self.txtFtExtWidth.text := app.convertMeasureForMaskDisplay(widthType.shortName, self.myTiMaster.extWidth);		// PAR #31155
			self.txtFtIntWidth.text := app.convertMeasureForMaskDisplay(widthType.shortName, self.myTiMaster.intWidth);		// PAR #31155
		else																												// PAR #31155
			self.txtExtWidth.setValues(app.convertMeasurementForDisplay(widthType.shortName, self.myTiMaster.extWidth) &amp; Space &amp; widthType.shortName);		// PAR #33638
			self.txtIntWidth.setValues(app.convertMeasurementForDisplay(widthType.shortName, self.myTiMaster.intWidth) &amp; Space &amp; widthType.shortName);		// PAR #33638
		endif;
		if heightType.isFeetAndInches then																					// PAR #31155
			self.txtFtExtHeight.text := app.convertMeasureForMaskDisplay(heightType.shortName, self.myTiMaster.extHeight);	// PAR #31155
			self.txtFtIntHeight.text := app.convertMeasureForMaskDisplay(heightType.shortName, self.myTiMaster.intHeight);	// PAR #31155
		else																												// PAR #31155
			self.txtExtHeight.setValues(app.convertMeasurementForDisplay(heightType.shortName, self.myTiMaster.extHeight) &amp; Space &amp; heightType.shortName);	// PAR #33638
			self.txtIntHeight.setValues(app.convertMeasurementForDisplay(heightType.shortName, self.myTiMaster.intHeight) &amp; Space &amp; heightType.shortName);	// PAR #33638
		endif;// PAR #31155
		self.txtMaxWeight.setValues(app.convertMeasurementForDisplay(weightType.shortName, self.myTiMaster.maxKilos) &amp; Space &amp; weightType.shortName);	// PAR #32552
		self.txtVolume.setValues(app.convertMeasurementForDisplay(volumeType.shortName, self.myTiMaster.volume) &amp; Space &amp; volumeType.shortName);		// PAR #32552
		
		self.lstTblStops.clearSelected(); //cnwrd1 par 18399 13.3.09
		foreach stopTable in self.myTiMaster.allStopsNew do
			self.lstTblStops.addSelectedObject(stopTable);		
		endforeach;
		//self.setListAllStops;
		
		self.lstTblToDoTasks.clearSelected(); //cnwrd1 par 18399 13.3.09
		foreach toDoTaskDesc in self.myTiMaster.allToDoTaskDesc do
			self.lstTblToDoTasks.addSelectedObject(toDoTaskDesc);
		endforeach;
		//self.setListToDoTaksDescs;
		
		//self.tblDamage.setTableFromProxyTIMaster(self.myTiMaster);
		//self.myAssistant.damageTableLostFocus(self.tblData, self.saveRowHeight, self.tblDamage);
		self.btnDamage.top := self.btnOk.top;
		self.btnDamage.enabled := true;	// cnwrd1 par 20799 27/10/09
	else
		self.btnDamage.enabled := false;// cnwrd1 par 20799 27/10/090
	endif;
end;</source>
    </JadeMethod>
