    <JadeMethod name="getGrpSumDisplay" id="db82f971-0565-4018-8b15-024d7e39f82d">
        <updating/>
        <source>getGrpSumDisplay(_objectSet: ObjectSet):String updating;
//----------------------------------------------------------------
//	Created:	10 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	obj			: Object;
	tmpSumObj	: SelfType;
begin
	foreach obj in _objectSet do
		tmpSumObj := obj.CMIF_MTRequestsAvailabilitySum;
		self.awaitingTask03				:= self.awaitingTask03	+ tmpSumObj.awaitingTask03;
		self.awaitingTask01				:= self.awaitingTask01	+ tmpSumObj.awaitingTask01;
		self.awaitingTask02				:= self.awaitingTask02	+ tmpSumObj.awaitingTask02;
		self.awaitingTask04				:= self.awaitingTask04	+ tmpSumObj.awaitingTask04;
		self.awaitingTask05				:= self.awaitingTask05	+ tmpSumObj.awaitingTask05;
		self.inAreaTask01				:= self.inAreaTask01	+ tmpSumObj.inAreaTask01;
		self.inAreaTask02				:= self.inAreaTask02	+ tmpSumObj.inAreaTask02;
		self.inAreaTask03				:= self.inAreaTask03	+ tmpSumObj.inAreaTask03;
		self.inAreaTask04				:= self.inAreaTask04	+ tmpSumObj.inAreaTask04;
		self.totalAvailable 			:= self.totalAvailable	+ tmpSumObj.totalAvailable;
		self.totalOnSite				:= self.totalOnSite		+ tmpSumObj.totalOnSite;
		self.totalWithStops				:= self.totalWithStops	+ tmpSumObj.totalWithStops;
		self.balanceTotal				:= self.balanceTotal	+ tmpSumObj.balanceTotal;
		self.totalPendingRequests		:= self.totalPendingRequests		+ tmpSumObj.totalPendingRequests;
		self.totalGeneralCargoRequests	:= self.totalGeneralCargoRequests	+ tmpSumObj.totalGeneralCargoRequests;
		//self.totalTransportRequests		:= self.totalTransportRequests		+ tmpSumObj.totalTransportRequests;
		self.totalRoadRequests			:= self.totalRoadRequests		+ tmpSumObj.totalRoadRequests;//29 Dec 2010	NDL	Par 26650
		self.totalRailRequests			:= self.totalRailRequests		+ tmpSumObj.totalRailRequests;//29 Dec 2010	NDL	Par 26650
		self.totalShippingRequests      := self.totalShippingRequests		+ tmpSumObj.totalShippingRequests;
		
	endforeach;
	
		return	self.totalOnSite.String &amp; Tab &amp; 
			self.task03Display &amp; Tab &amp; 
			self.task01Display &amp; Tab &amp; 
			self.task02Display &amp; Tab &amp; 
			self.task04Display &amp; Tab &amp; 
			self.task05Display &amp; Tab &amp; 
			self.stopsDisplay &amp; Tab &amp; 
			self.availableDisplay &amp; Tab &amp; 
			//self.transRequestsDisplay.String &amp; Tab &amp; 
			self.roadRequestsDisplay.String &amp; Tab &amp; //29 Dec 2010	NDL	Par 26650
			self.railRequestsDisplay.String &amp; Tab &amp; //29 Dec 2010	NDL	Par 26650
			self.shippingRequestsDisplay.String &amp; Tab &amp;
			self.genCargoRequestsDisplay.String &amp; Tab &amp; 
			self.pendingRequestsDisplay.String &amp; Tab &amp; 
			self.balanceTotal.String;
end;</source>
        <Parameter name="_objectSet" type="ObjectSet"/>
        <ReturnType type="String"/>
    </JadeMethod>
