    <JadeMethod name="getCraneTypeDescription" id="355e8eb4-f1c3-4677-a7ed-3692bf507566">
        <source>getCraneTypeDescription() : String;
/*
Purpose:			
Date		Who		Reason
26 November 2014	cnwab1	Initial creation
*/

vars

begin
	if self.craneType = JobTypePriority_Crane1 then
		return "Single Lift";
	endif;
	
	return "Twin Lift";
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="is40" id="d664decd-2040-4574-8919-74b448d8df67">
        <source>is40() : Boolean;
// ---------------------------------------------------------------------------
// Created:		11 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.jobType = JobTypePriority_DischargeDLR40 
		or self.jobType = JobTypePriority_LoadDLR40 
		or self.jobType = JobTypePriority_DischargeIMP40
		or self.jobType = JobTypePriority_LoadExport40 then
		return true;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isDischarge" id="02510fdb-010a-4cef-8f6a-f22de8a5694b">
