    <JadeMethod name="showWithObject" id="b6883d2f-c261-471e-bc20-a0a4bf3a1e0b">
        <updating/>
        <source>showWithObject(_object: CM_Object input; _voyage : CM_Voyage) updating;
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	numJobs		: Integer;
begin
	inheritMethod(_object, _voyage);

	if _voyage &lt;&gt; null then
		self.doCmbVoyageBuild();
		self.cmbVoyage.listIndex := self.cmbVoyage.findObject(_voyage);
		if _object &lt;&gt; null  then
			self.filterWorkPoint := _object.IF_VoyageWorkPoint;
		endif;
		self.doQuery();
	endif;

end;</source>
