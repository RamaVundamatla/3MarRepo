    <DbClassMap file="basedvr"/>
    <ImplicitInverseRef name="myDateFrom" id="06f0d131-03eb-434f-a9e3-f6ba7455baea">
        <embedded/>
        <type name="CnEcDate"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myDateTo" id="e61ba0c8-c6b4-495c-a3f7-7890d3731e33">
        <embedded/>
        <type name="CnEcDate"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="create" id="9cbffa3f-d801-4ba5-848b-c4187746a7d4">
        <updating/>
        <source>create() updating;
// -----------------------------------------------------------------------------
// Created:		28 January 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if self.isTransient() then
		create self.myDateFrom transient;
		create self.myDateTo transient;
	else
		create self.myDateFrom;
		create self.myDateTo;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="c1defc4b-30b0-4103-80b6-d01dc03ce94c">
        <updating/>
        <source>delete() updating;
// -----------------------------------------------------------------------------
// Created:		28 January 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	delete self.myDateFrom;
	delete self.myDateTo;
end;</source>
    </JadeMethod>
    <JadeMethod name="getDateFrom" id="daad0f25-4d55-4c5e-adfa-b7f6709ac0d2">
        <source>getDateFrom():Date;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Get the date from value.
//
// Parameters:	None
//
// Returns:		The date from value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myDateFrom.dateClient;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getDateTo" id="579b6fb3-96e9-4a0a-bb2d-5c56bc119a38">
        <source>getDateTo():Date;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Get the date to value.
//
// Parameters:	None
//
// Returns:		The date to value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myDateTo.dateClient;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="setDateFrom" id="85af79e7-42a5-4b73-b212-92fb95ab0ede">
        <updating/>
        <source>setDateFrom(pDateFromObj:CnEcDate) updating;
// --------------------------------------------------------------------------------
// Created:		16 May 2001 by cnwdad1
//
// Purpose:		Set the date from value object.
//
// Parameters:	pDateFromObj - The date from object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.validateRange(pDateFromObj.dateClient, self.myDateTo.dateClient) then
		self.myDateFrom	:=	pDateFromObj;
	endif;
end;</source>
        <Parameter name="pDateFromObj" type="CnEcDate"/>
    </JadeMethod>
    <JadeMethod name="setDateTo" id="256d0cc1-20e1-44c0-88d4-e71713cfd556">
        <updating/>
        <source>setDateTo(pDateToObj:CnEcDate) updating;
// --------------------------------------------------------------------------------
// Created:		16 May 2001 by cnwdad1
//
// Purpose:		Set the date to value object.
//
// Parameters:	pDateToObj - The date to object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.validateRange(self.myDateFrom.dateClient, pDateToObj.dateClient) then
		self.myDateTo	:=	pDateToObj;
	endif;
end;</source>
        <Parameter name="pDateToObj" type="CnEcDate"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="38c8000a-8d23-4f01-90af-0184b0d500b6">
        <updating/>
        <source>updateMe(pDateFrom:Date; pDateTo:Date) updating;
// --------------------------------------------------------------------------------
// Created:		16 May 2001 by cnwdad1
//
// Purpose:		Update the receiver's date range.
//
// Parameters:	pDateFrom - The date from value.
//				pDateTo - The date to value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.validateRange(pDateFrom, pDateTo) then
		self.myDateFrom.updateMe(pDateFrom);
		self.myDateTo.updateMe(pDateTo);
	endif;
end;</source>
        <Parameter name="pDateFrom" type="Date"/>
        <Parameter name="pDateTo" type="Date"/>
    </JadeMethod>
</Class>
