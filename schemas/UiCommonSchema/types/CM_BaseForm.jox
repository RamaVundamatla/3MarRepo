    <JadeMethod name="mnuOptsClearSaved_click" id="c41da01f-302d-4a4a-b72c-e919ddcbe169">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuOptsClearSaved_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//02/03/2025    NAVRV30	JIRA 33944 MTN | Clear Individual Form XML settings

*/

vars
	myMenuAction : CMUI_MenuAction;
	realUserWindow	: CM_UserWindowForOpen;
	formCls,
	assistCls	: Class;
	form		: CM_BaseForm;
	subSys 		: CMUI_SubSystem;
begin
	self.clearSavedSettingsForCurr := (not menuItem.checked);
	/* Clear the xml settings by passing in an empty xml string and then we also need to
	remove the window from the userWindows or else the default config is not seen correctly*/
	if self.visible and app.getMyUser &lt;&gt; null	
	then
		realUserWindow := app.getUserWindow(self.name, true);	// returns a transient
		if realUserWindow &lt;&gt; null then 			
			realUserWindow.setProxy(app.getMyUser, self.name, "", self.top, self.left, self.width, self.height, self.windowState);
		endif;
	endif;	
	app.allUserWindows.remove(realUserWindow);
	/*Since we are closing the window and re-opening on the click of the menu option we
	need to save the menu action information along with the Menu User Details and the Menu detail
	to the new transient menuaction object because on unload of this window the menuaction is cleaned up.
	The new menu action action gets cleaned up when the opened window is closed.*/
	create myMenuAction transient;
	myMenuAction := self.myMasterMenuAction.cloneSelf(true);
	myMenuAction.setFromMenuDtl(self.myMasterMenuAction.myMenuUserDtl, self.myMasterMenuAction.myMenuDtl);
	myMenuAction.actionFromMenuDtl(true, app.getUserWindow(self.name, false));
	myMenuAction.setMyParent(self.myMasterMenuAction.myParent);
	/*We need to fetch the schema subsystem and the form information from the schema and
	unload the current form and bring up the same form with the configuration settings restored to the
	windows defaults*/
	subSys := app.myController.allSubSystems[self.myMasterMenuAction.myMenuDtl.schemaName];
	subSys.getFormDetails(self.name, formCls, assistCls);	
	self.unloadForm();
	//form := app.loadForm(formCls, assistCls, false, false, false, self.myTerminal, myMenuAction).CM_BaseForm;
	/*fetch the form and set the window info and also associate the menuaction to this form and then show the form*/
	form := app.getForm(self.name).CM_BaseForm;
	form.setMyTerminal(self.myTerminal);
	form.myUserWindow := app.getUserWindow(self.name, false);
	myMenuAction.setMyFormWhenMaster(form);
	
	form.show();
	
	if form.windowState = Form.WindowState_Minimized then
		form.windowState := Form.WindowState_Normal;
	endif;
	
	form.setFocus;
	form.zOrder(1);
	form.resizePostInitialShow();
	form.doResize();
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuOptsFileManager_click" id="39113ede-844b-4695-8927-921f7bcd80b5">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuOptsFileManager_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     14 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// hack here for testing until get proper Jade Locales into Dmast
	if app.isDevelopmentSystem then
		if app.msgBox('Do you want to reset locale instead?', '', MsgBox_Yes_No) = MsgBox_Return_Yes then
			if app.myCurrentLocale = CM_Locale.firstInstance then
				app.setPropertyValue('myCurrentLocale', CM_Locale.lastInstance);
			else
				app.setPropertyValue('myCurrentLocale', CM_Locale.firstInstance);
			endif;
			app.msgBox('Locale set to ' &amp; app.myCurrentLocale.localeDescription, '', 0);
			return;
		endif;
	endif;
	
	app.mousePointer := Busy;
	app.myFileManager.showFileBrowser(false, Form.MdiChild_NotMdi);
epilog
	app.mousePointer := Idle;
end;</source>
