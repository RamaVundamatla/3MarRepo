    <JadeMethod name="translateForm" id="ad348f11-6805-4f22-b25e-f41ae50cae4e">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 23 May 2017 08:47:46.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022003, locale);
	btnConfirm.translateCaption(Xlat_0022004, locale);
	btnDamage.translateCaption(Xlat_0022005, locale);
	btnLabel.translateCaption(Xlat_0022006, locale);
	btnReset.translateCaption(Xlat_0022007, locale);
	lblCargoId.translateCaption(Xlat_0022008, locale);
	lblNoDamage.translateCaption(Xlat_0022009, locale);
	lblShipCounts.translateCaption(Xlat_0022010, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
