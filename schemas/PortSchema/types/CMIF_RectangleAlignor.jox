    <JadeMethod name="addGraphic" id="7482ecb9-ebb4-49ae-bf81-a7177a4282fe">
        <updating/>
        <source>addGraphic(_graphic : CM_Graphic) updating;
/*
Purpose:			
Date		Who		Reason
13 April 2011	cnwab1	Initial creation
*/

vars
	firstGraphic : CM_Graphic;
begin
	if _graphic.pointsPolygon.isEmpty() then
		return;
	endif;
	
	if self.allPolygonGraphicObjects.isEmpty() then
		// The first graphic is what we are aligning to
		firstGraphic := _graphic;
		self.xLeft := firstGraphic.getExtremePoint(CM_Graphic.Position_Left).x;
		self.xRight :=  firstGraphic.getExtremePoint(CM_Graphic.Position_Right).x;
		self.yBottom :=  firstGraphic.getExtremePoint(CM_Graphic.Position_Bottom).y;
		self.yTop :=  firstGraphic.getExtremePoint(CM_Graphic.Position_Top).y;
	endif;
	
	if not self.allPolygonGraphicObjects.includes(_graphic) then
	self.allPolygonGraphicObjects.add(_graphic);
	endif;
epilog

end;</source>
        <Parameter name="_graphic" type="CM_Graphic"/>
    </JadeMethod>
    <JadeMethod name="doAlignment" id="9da3543c-fefa-4bf9-bc3a-74be0f524947">
        <updating/>
        <source>doAlignment(_alignMode : Integer) updating;
/*
Purpose:			
Date		Who		Reason
13 April 2011	cnwab1	Initial creation
*/

vars
	theGraphic : CM_Graphic;
	grphXLeft, grphXRight, grphYTop, grphYBottom, diffX, diffY, newX, newY : Integer;
	tmpPoint, newPoint : Point;
	newPoints : PointArray;
begin
	self.alignMode := _alignMode;
	
	if self.alignMode = 0 then
		return;
	endif;

	create newPoints transient;
	foreach theGraphic in self.allPolygonGraphicObjects discreteLock do
		// ### Ignore empty graphics
		if theGraphic.pointsPolygon.isEmpty() then
		continue;
		endif;
		newPoints.clear;
		
		
		if self.alignMode = self.AlignMode_Left then
			// ### Get the extreme point
			grphXLeft := theGraphic.getExtremePoint(CM_Graphic.Position_Left).x;
			// ### Work out the adjustment X to be applied to all Xs in the polygon
			diffX := self.xLeft - grphXLeft;
			foreach tmpPoint in theGraphic.pointsPolygon  discreteLock do
				// ### Apply adjustment to polygon to 'move' it.
				newX := tmpPoint.x + diffX;
				
				newPoint.setX(newX);
				newPoint.setY(tmpPoint.y);
				
				newPoints.add(newPoint);
			
			endforeach;
		elseif self.alignMode = self.AlignMode_Right then
			// ### Get the extreme point
			grphXRight :=  theGraphic.getExtremePoint(CM_Graphic.Position_Right).x;
			// ### Work out the adjustment X to be applied to all Xs in the polygon
			diffX := self.xRight - grphXRight;
			foreach tmpPoint in theGraphic.pointsPolygon  discreteLock do
				// ### Apply adjustment to polygon to 'move' it.
				newX := tmpPoint.x + diffX;
				
				newPoint.setX(newX);
				newPoint.setY(tmpPoint.y);
				
				newPoints.add(newPoint);
			
			endforeach;
		elseif self.alignMode = self.AlignMode_Top then
			// ### Get the extreme point
			grphYTop :=  theGraphic.getExtremePoint(CM_Graphic.Position_Top).y;
			// ### Work out the adjustment X to be applied to all Xs in the polygon
			diffY := self.yTop - grphYTop;
			foreach tmpPoint in theGraphic.pointsPolygon  discreteLock do
				// ### Apply adjustment to polygon to 'move' it.
				newY := tmpPoint.y + diffY;
				
				newPoint.setX(tmpPoint.x);
				newPoint.setY(newY);
				
				newPoints.add(newPoint);
			
			endforeach;
			
		elseif self.alignMode = self.AlignMode_Bottom then
			// ### Get the extreme point
			grphYBottom :=  theGraphic.getExtremePoint(CM_Graphic.Position_Bottom).y;
			// ### Work out the adjustment X to be applied to all Xs in the polygon
			diffY := self.yBottom - grphYBottom;
			foreach tmpPoint in theGraphic.pointsPolygon  discreteLock do
				// ### Apply adjustment to polygon to 'move' it.
				newY := tmpPoint.y + diffY;
				
				newPoint.setX(tmpPoint.x);
				newPoint.setY(newY);
				
				newPoints.add(newPoint);
			
			endforeach;
			
		endif;
		
		// ### update the polygon
		theGraphic.setPointsPolygon(newPoints);
	endforeach;
	
	
epilog
	delete newPoints;
end;</source>
        <Parameter name="_alignMode" type="Integer"/>
    </JadeMethod>
</Class>
