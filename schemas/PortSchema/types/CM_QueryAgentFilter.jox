    <JadeMethod name="qryTransactions" id="eb91694c-1c00-4f50-a7d3-b420c002a83b">
        <updating/>
        <source>qryTransactions(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     15 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	numSelected			: Integer;
	jrwTrans			: CM_JRWTransaction;
	tiFilter			: CMQF_Transactions;
	tran : CM_TITransaction;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	tiFilter := _filter.CMQF_Transactions;
	jrwTrans := self.createJRWTransient(CM_JRWTransaction).CM_JRWTransaction;
	
	jrwTrans.allTransactions.clear();
	_filter.filterObjects(jrwTrans.allTransactions, _passport);
	
//	tiFilter.allTerminals.copy(jrwTrans.allTerminals);
	jrwTrans.setAllTerminals(tiFilter.allTerminals);
	jrwTrans.blockLength 	:= _filter.blockLength;
	jrwTrans.baseDate		:= _filter.baseDate;
	jrwTrans.ageType		:= _filter.ageType;
	jrwTrans.myOperator 	:= tiFilter.myOperator;
	jrwTrans.myVoyage		:= tiFilter.getMyVoyage;
	
	jrwTrans.startDate 	:= tiFilter.startDate;
	jrwTrans.endDate	:= tiFilter.endDate;
	jrwTrans.transType 	:= tiFilter.transType;
	jrwTrans.transTypeStr 	:= tiFilter.transTypeStr;
	jrwTrans.includeChildTransactions := tiFilter.includeChildTransactions;	// 03 Aug 2010	NDL	Par 23056
	
	numSelected := jrwTrans.allTransactions.size; //which should always be 1, but whatever...

	// TFS 40632
	foreach tran in jrwTrans.allTransactions 	discreteLock do
		tran.copySnapShotForReporting(jrwTrans);
	endforeach;
	

epilog
	
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryTransactionsCam" id="d2825bd2-d0cf-4d4d-a893-426f4f25853b">
        <updating/>
        <source>qryTransactionsCam(_filter : CMQF_CamTransactions input; _passport : CM_Passport) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     J Harliwich 29/7/09 MES1011 
//
// Purpose:     JMT to CICS interface uses this query to filter data to be sent
//				Copied qryTransactiosn and modified 
//
// ----------   ----------  --------------------------------------------------
// 27/06/2012	cnwcs5		par 29601 - log excluded transactions
vars
	numSelected	: Integer;
	jrwTrans	: CM_JRWTransaction;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	jrwTrans := self.createJRWTransient(CM_JRWCamTransaction).CM_JRWCamTransaction;
	
	jrwTrans.allTransactions.clear();
	
	_filter.filterObjects(jrwTrans.allTransactions, _passport);
	
	jrwTrans.setAllTerminals(_filter.allTerminals);
	
	jrwTrans.blockLength 				:= _filter.blockLength;
	jrwTrans.baseDate					:= _filter.baseDate;
	jrwTrans.ageType					:= _filter.ageType;
	jrwTrans.myOperator 				:= _filter.myOperator;
	jrwTrans.myVoyage					:= _filter.getMyVoyage;
	jrwTrans.startDate 					:= _filter.startDate;
	jrwTrans.endDate					:= _filter.endDate;
	jrwTrans.transType 					:= _filter.transType;
	jrwTrans.transTypeStr 				:= _filter.transTypeStr;
	jrwTrans.includeChildTransactions 	:= _filter.includeChildTransactions;	// 03 Aug 2010	NDL	Par 23056
	
	numSelected := jrwTrans.allTransactions.size; 
epilog
	
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_CamTransactions" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryTransactionsCargoAll" id="31999372-3aca-4e1d-be07-85bd47756e1d">
        <updating/>
        <source>qryTransactionsCargoAll(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		24 February 2010
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
// MES CCMS 1015 cnwsh3 Changes as part of reports for Messina.
//----------------------------------------------------------------------
vars
	numSelected			: Integer;
	jrwTrans			: CM_JRWTransaction;
	tiFilter			: CMQF_TransactionCargoOnsite;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);

	tiFilter := _filter.CMQF_TransactionCargoOnsite;
	jrwTrans := self.createJRWTransient(CM_JRWTransaction).CM_JRWTransaction;

	jrwTrans.allTransactions.clear();
	_filter.filterObjects(jrwTrans.allTransactions, _passport);
	
	jrwTrans.setAllTerminals(tiFilter.allTerminals);
	jrwTrans.blockLength 	:= _filter.blockLength;
	jrwTrans.baseDate		:= _filter.baseDate;
	jrwTrans.ageType		:= _filter.ageType;
	jrwTrans.myOperator 	:= tiFilter.myOperator;
	jrwTrans.myVoyage		:= tiFilter.getMyVoyage;
	jrwTrans.startDate 	:= tiFilter.startDate;
	jrwTrans.endDate	:= tiFilter.endDate;
	jrwTrans.includeChildTransactions := tiFilter.includeChildTransactions;	// 03 Aug 2010	NDL	Par 23056
	
	numSelected := jrwTrans.allTransactions.size; 

epilog
	
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryTransactionsCargoChanges" id="173fca6a-c58d-4c02-943d-20f408751f7b">
        <updating/>
        <source>qryTransactionsCargoChanges(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 February 2012	cnwndl1	Initial creation	Par 29118

*/

vars
	numSelected			: Integer;
	jrwTrans			: CM_JRWTransaction;
	tiFilter			: CMQF_TransVoyageCargoChanges;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);

	tiFilter := _filter.CMQF_TransVoyageCargoChanges;
	jrwTrans := self.createJRWTransient(CM_JRWTransaction).CM_JRWTransaction;

	jrwTrans.allTransactions.clear();
	_filter.filterObjects(jrwTrans.allTransactions, _passport);
	
	jrwTrans.setAllTerminals(tiFilter.allTerminals);
	jrwTrans.blockLength 	:= _filter.blockLength;
	jrwTrans.baseDate		:= _filter.baseDate;
	jrwTrans.ageType		:= _filter.ageType;
	jrwTrans.myOperator 	:= tiFilter.myOperator;
	jrwTrans.myVoyage		:= tiFilter.getMyVoyage;
	jrwTrans.startDate 	:= tiFilter.startDate;
	jrwTrans.endDate	:= tiFilter.endDate;
	jrwTrans.includeChildTransactions := tiFilter.includeChildTransactions;	
	jrwTrans.myCargoType := tiFilter.getMyCargoType.CM_CargoType;
	
	jrwTrans.allSites.clear();
	if not tiFilter.allSites.isEmpty then
		tiFilter.allSites.copy( jrwTrans.allSites );
	endif;
	
	numSelected := jrwTrans.allTransactions.size; 

epilog
	
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryTransactionsDiscrepancy" id="b95184d1-f44d-451c-9e35-abe6d1c92804">
        <updating/>
        <source>qryTransactionsDiscrepancy(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 19 November 2008
//
// Implemented version: 7.7.1
// CCMS1765 GDANSK - Maersk reporting requirements. 
//----------------------------------------------------------------------
vars
	tiFilter : CMQF_Discrepancy;
	jrwTrans : CM_JRWTransaction;
	numSelected : Integer;
begin
	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	tiFilter := _filter.CMQF_Discrepancy;
	jrwTrans := self.createJRWTransient(CM_JRWTransaction).CM_JRWTransaction;
	jrwTrans.allTransactions.clear();
	_filter.filterObjects(jrwTrans.allTransactions, _passport);
	
	jrwTrans.setAllTerminals(tiFilter.allTerminals);
	jrwTrans.blockLength 	:= _filter.blockLength;
	jrwTrans.baseDate		:= _filter.baseDate;
	jrwTrans.ageType		:= _filter.ageType;
	jrwTrans.myOperator 	:= tiFilter.myOperator;
	jrwTrans.myVoyage		:= tiFilter.getMyVoyage;
	
	jrwTrans.startDate 		:= tiFilter.startDate;
	jrwTrans.endDate		:= tiFilter.endDate;
	jrwTrans.transType 		:= tiFilter.transType;
	jrwTrans.transTypeStr 	:= tiFilter.transTypeStr;
	jrwTrans.includeChildTransactions := tiFilter.includeChildTransactions;	// 03 Aug 2010	NDL	Par 23056
	
	numSelected := jrwTrans.allTransactions.size; //which should always be 1, but whatever...
	return numSelected;
epilog
	
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
