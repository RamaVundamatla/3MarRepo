    <JadeMethod name="getTargetDisplay" id="98109d10-b866-4d9e-b4a9-df80a7378def">
        <source>getTargetDisplay():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

	obj : Object;
	edition : Integer;
	invalid : Boolean;

begin

	if self.isLocationBalance then
		return null;
	elseif self.isLocationDiscrepancyDecrease then
		return null;
	endif;

	if self.targetLocationStr &lt;&gt; null then
		return self.targetLocationStr;
	endif;
	
	on Exception do app.handleDeletedObject( exception, obj, invalid );
	
	if self.myTargetLocation &lt;&gt; null then
		obj := self.myTargetLocation;
		edition := obj.edition;
		if not invalid then
			return self.myTargetLocation.getFullId();
		endif;
		invalid := false;
	endif;
	
	if self.myTargetTA &lt;&gt; null then
		obj := self.myTargetTA;
		edition := obj.edition;
		if not invalid then
			return self.myTargetTA.id;
		endif;
		invalid := false;
	endif;
	
	if self.myTargetTrain &lt;&gt; null then
		obj := self.myTargetTrain;
		edition := obj.edition;
		if not invalid then
			return self.myTargetTrain.getCodeDate();
		endif;
		invalid := false;
	endif;
	
	if self.myTargetVVR &lt;&gt; null then
		obj := self.myTargetVVR;
		edition := obj.edition;
		if not invalid then
			return self.myTargetVVR.idForLocationActivity();
		endif;
		invalid := false;
	endif;
	
	if self.myTargetVoyage &lt;&gt; null then
		obj := self.myTargetVoyage;
		edition := obj.edition;
		if not invalid then
			return self.myTargetVoyage.idForLocationActivity();
		endif;
		invalid := false;
	endif;
	
	return app.getErrorString( Unknown );

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
