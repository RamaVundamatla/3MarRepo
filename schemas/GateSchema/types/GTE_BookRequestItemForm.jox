    <JadeMethod name="lstHazardsGotFocus" id="9d2625c6-565d-4ab6-a325-e742ee818694">
        <updating/>
        <source>lstHazardsGotFocus() updating;
//-----------------------------------------
//
// Created : by cnwaer1 25 August 2008
//-----------------------------------------
vars

begin
	if self.focusOnIsClean then
		self.focusOnIsClean := false;
		return;
	endif;

	//frame setup
	
	/*self.frmHazards.top := self.txtHazards.top + 5;
	self.frmHazards.left := self.txtHazards.left + 6;*/
	
	self.frmHazards.top := self.txtHazards.top + 1 + grpDetail.top;
	//self.frmHazards.left := self.txtHazards.left + 2 + grpDetail.left;					//-cnwml2 PAR20173 SFW CCMS 1091
	self.frmHazards.left := self.txtHazards.left - 10 + grpDetail.left;						//+cnwml2 PAR20173 SFW CCMS 1091

	
	//if self.grpReefer.visible = true then
		self.frmHazards.height := 100;
	//else
	//	self.frmHazards.height := 84;
	//endif;
	self.frmHazards.width := self.txtHazards.width;
	
	//list setup
	self.lstHazards.top := 0;
	self.lstHazards.left := 0;
	self.lstHazards.height := self.frmHazards.height ;
	self.lstHazards.width := self.frmHazards.width;
	
	self.frmHazards.visible := true;
	//self.frmHazards.tabStop:=false;						//-cnwml2 PAR19884 SFW CCMS 1079
	self.frmHazards.zOrder(1);
	self.lstHazards.setFocus();								//+cnwml2 PAR19884 SFW CCMS 1079
	self.txtHazards.visible := false;

end;</source>
    </JadeMethod>
