    <JadeMethod name="loadConditionCodes" id="d2c2660f-8d55-4b5d-8d7d-e7e4bda04c50">
        <source>loadConditionCodes() protected;
// ---------------------------------------------------------------------------
// Created:     18 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	cmb					: CMUI_ComboBox;
	code		: CM_Code;
	conditionDict		: CM_LogConditionCodesByCodeDict;
	
begin
	cmb := self.cmbCondition;
	cmb.clear();
	conditionDict := app.myRoot.allLogConditionCodes;
	foreach code in conditionDict do
		cmb.itemObject[cmb.addItem(code.code &amp; '  ' &amp; code.description)] := code;
	endforeach;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="runReport" id="d0310a15-39b2-48fb-bf75-d87894040eed">
        <source>runReport(_rptName : String) protected;
// ---------------------------------------------------------------------------
// Created:     20 May 2003		cnwth2	
//
// Purpose:     		 
//
// Changed On	Changed By	Reason
// ----------	----------	--------------------------------------------------
// 16 Mar 2010	consw1		PAR #22886 - Leaking report transients

vars
	qryReport 			: CM_QryReport;
	jrwManager			: JadeReportWriterManager;
	jadeReport			: JadeReportWriterReport;
	jrwFileName			: String;
	checkScaleHdr		: CM_LogCheckScaleHdr;
	checkScaleDtl		: CM_LogCheckScaleDtl;
	numRows,
	row					: Integer;
	tbl					: CM_DataTable;
	jrwTransient		: CM_JRWLogCheckScaling;
begin
	qryReport := self.getDefaultReport(_rptName);
	
	if qryReport = null then
		app.msgBox('The default report to run from this button has not been set.' &amp; CrLf &amp;
					'Set the default check scaling report in the terminal maintenence section' &amp; CrLf &amp;
					'of the system admin screen','Report not set', 0);
		return;
	endif;
	
	jrwTransient := app.myQAFilter.createJRWTransient(CM_JRWLogCheckScaling).CM_JRWLogCheckScaling;
	
	if jrwTransient = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Failed to create JRW transient singleton');
		return;
	endif;
	
	jrwTransient.allCheckScaleDetail.clear();
	tbl := self.tblData;
	numRows := tbl.rows;
	//populate the JRW transient singleton
	foreach row in 1 to numRows do
		checkScaleHdr := tbl.accessRow(row).itemObject.CM_LogCheckScaleHdr;
		if checkScaleHdr = null then
			continue;
		endif;
		
		foreach checkScaleDtl in checkScaleHdr.allCheckScaleDtls do
			//if checkScaleDtl.logSEDMean &lt;&gt; 0 then
				jrwTransient.allCheckScaleDetail.add(checkScaleDtl);
			//endif;
		endforeach;			
	endforeach;		
	
	if jrwTransient.allCheckScaleDetail.isEmpty then
		app.msgBox('There are no check scaling batch headers displayed to report on', 'Nothing to report on', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	jrwManager := app.createReportWriterManager();
	
	jrwFileName := qryReport.jrwReportName.first;
	jadeReport := jrwManager.getReport(jrwFileName);
	jadeReport.setPreviewOptions(true, true, true, false, null);	
	jadeReport.setOutputDestination(JadeReportWriterReport.PRINTER);
	jadeReport.run;
			
	abortTransaction;		// to clear any locks held by the report writer
	
epilog
	delete jadeReport;
	delete jrwManager;
end;</source>
        <access>protected</access>
        <Parameter name="_rptName" type="String"/>
    </JadeMethod>
