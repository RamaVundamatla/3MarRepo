    <JadeMethod name="jtdInitialize" id="7773e698-4ce9-49b8-96ef-a76d5771bff1">
        <updating/>
        <source>jtdInitialize() updating;

begin
	self.jtdTotalDeadlocks := 0;
	self.jtdTotalLocks := 0;
	self.jtdTotalErrs := 0;
	self.jtdTotalGenSecs := 0;
	self.jtdTotalTrxSecs := 0;
	self.jtdTotalTransactions := 0;
	self.jtdTotalUnhandledExceptions := 0;
end;</source>
    </JadeMethod>
    <JadeMethod name="jtdInitializeSecs" id="654eabab-4036-4290-a2ae-74ef51a6d8df">
        <updating/>
        <source>jtdInitializeSecs() updating;

begin
	self.jtdTotalGenSecs := 0;
	self.jtdTotalTrxSecs := 0;
end;</source>
    </JadeMethod>
    <JadeMethod name="jtdSet" id="370c14f6-f6f8-4860-9a4b-6bd984604eb7">
        <updating/>
        <source>jtdSet(_deadlocks, _locks, _errs : Integer; _genSecs, _trxSecs : Real;
	_transactions, _exceptions : Integer) updating;

begin
	self.jtdTotalDeadlocks := _deadlocks;
	self.jtdTotalLocks := _locks;
	self.jtdTotalErrs := _errs;
	self.jtdTotalGenSecs := _genSecs;
	self.jtdTotalTrxSecs := _trxSecs;
	self.jtdTotalTransactions := _transactions;
	self.jtdTotalUnhandledExceptions := _exceptions;
end;</source>
        <Parameter name="_deadlocks" type="Integer"/>
        <Parameter name="_locks" type="Integer"/>
        <Parameter name="_errs" type="Integer"/>
        <Parameter name="_genSecs" type="Real"/>
        <Parameter name="_trxSecs" type="Real"/>
        <Parameter name="_transactions" type="Integer"/>
        <Parameter name="_exceptions" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jtdSetFromString" id="cc8a36dc-1cc3-4f33-b918-78092a576e1b">
        <updating/>
        <source>jtdSetFromString(details : String) updating;

vars
	s, propName, typ : String;
	trimmedDetails : String;
	n, detailsLen : Integer;
	
begin
	self.jtdInitialize;

	trimmedDetails := details.trimBlanks;

	detailsLen := trimmedDetails.length;

	if detailsLen &lt; 1 then
		return;
	endif;
	
	n := 1;

	foreach propName in self.jtdAllPropertyNames do
		if n &gt; detailsLen then
			// past the end of the string, so nothing more to do
			break;
		endif;
		
		s := trimmedDetails.scanUntil(';', n).trimBlanks;
		
		if n &lt; 1 then
			// no delimiter found, so assume that whatever's left is junk
			break;
		endif;
		
		n := n + 1; // move past the delimiter for the next iteration

		if s = null then
			// property has already been initialized, so on to the next one
			continue;
		endif;

		typ := propName[1];
		propName := propName[2 : end];
			
		if typ = 'R' then
			self.setPropertyValue(propName, s.Real);
		else
			// assume integer
			self.setPropertyValue(propName, s.Integer);
		endif;
	endforeach;
end;</source>
        <Parameter name="details" type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdSetMaxSecs" id="2278cd46-d252-4917-9b1a-d9284a16b5c7">
        <updating/>
        <source>jtdSetMaxSecs(genSecs, trxSecs : Real) updating;

begin
	if genSecs &gt; self.jtdTotalGenSecs then
		self.jtdTotalGenSecs := genSecs;
	endif;
	if trxSecs &gt; self.jtdTotalTrxSecs then
		self.jtdTotalTrxSecs := trxSecs;
	endif;
end;</source>
        <Parameter name="genSecs" type="Real"/>
        <Parameter name="trxSecs" type="Real"/>
    </JadeMethod>
    <JadeMethod name="jtdSubtractSummary" id="8a5aef45-07d3-493c-980f-d9ae32e4fb4f">
        <updating/>
        <source>jtdSubtractSummary(jts : JtdTransactionSummary; subtractSecs : Boolean) updating;

begin
	if jts = null then
		return;
	endif;

	self.jtdTotalDeadlocks := self.jtdTotalDeadlocks - jts.jtdTotalDeadlocks;
	self.jtdTotalLocks := self.jtdTotalLocks - jts.jtdTotalLocks;
	self.jtdTotalErrs := self.jtdTotalErrs - jts.jtdTotalErrs;
	self.jtdTotalTransactions := self.jtdTotalTransactions - jts.jtdTotalTransactions;
	self.jtdTotalUnhandledExceptions := self.jtdTotalUnhandledExceptions - jts.jtdTotalUnhandledExceptions;

	if self.jtdTotalDeadlocks &lt; 0 then
		self.jtdTotalDeadlocks := 0;
	endif;
	if self.jtdTotalLocks &lt; 0 then
		self.jtdTotalLocks := 0;
	endif;
	if self.jtdTotalErrs &lt; 0 then
		self.jtdTotalErrs := 0;
	endif;
	if self.jtdTotalUnhandledExceptions &lt; 0 then
		self.jtdTotalUnhandledExceptions := 0;
	endif;
	if self.jtdTotalTransactions &lt; 0 then
		self.jtdTotalTransactions := 0;
	endif;
	
	if not subtractSecs then
		return;
	endif;

	self.jtdTotalGenSecs := self.jtdTotalGenSecs - jts.jtdTotalGenSecs;
	self.jtdTotalTrxSecs := self.jtdTotalTrxSecs - jts.jtdTotalTrxSecs;

	if self.jtdTotalGenSecs &lt; 0 then
		self.jtdTotalGenSecs := 0;
	endif;
	if self.jtdTotalTrxSecs &lt; 0 then
		self.jtdTotalTrxSecs := 0;
	endif;
end;</source>
        <Parameter name="jts" type="JtdTransactionSummary"/>
        <Parameter name="subtractSecs" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdUpdateStatistics" id="deecf9a0-64ea-404a-ae74-2f380b93a36b">
        <updating/>
        <source>jtdUpdateStatistics(genSecs, trxSecs : Real; trxErrNo, exErrNo : Integer) updating;

constants
	ObjectLocked = 1027;
	Deadlock = 1081;

begin
	if exErrNo &lt;&gt; 0 then
		self.jtdTotalUnhandledExceptions := self.jtdTotalUnhandledExceptions + 1;
		
		if exErrNo = ObjectLocked then
			self.jtdTotalLocks := self.jtdTotalLocks + 1;
		elseif exErrNo = Deadlock then
			self.jtdTotalDeadlocks := self.jtdTotalDeadlocks + 1;
		endif;
	endif;
	
	self.jtdTotalTransactions := self.jtdTotalTransactions + 1;
	self.jtdTotalGenSecs := self.jtdTotalGenSecs + genSecs;
	self.jtdTotalTrxSecs := self.jtdTotalTrxSecs + trxSecs;
		
	if trxErrNo &lt;&gt; 0 then
		self.jtdTotalErrs := self.jtdTotalErrs + 1;
	endif;		
end;</source>
        <Parameter name="genSecs" type="Real"/>
        <Parameter name="trxSecs" type="Real"/>
        <Parameter name="trxErrNo" type="Integer"/>
        <Parameter name="exErrNo" type="Integer"/>
    </JadeMethod>
</Class>
