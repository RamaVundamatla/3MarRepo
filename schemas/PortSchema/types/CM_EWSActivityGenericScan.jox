    <JadeMethod name="getDisplayStringForAttribute" id="0d9e861c-7ea1-4e82-965f-29d5ab949ec1">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			Displays data based on Ent Table Row

Parameters:			_attrName	String	
					_short		Boolean

Return Value:		String: Containing Data to display

Date		Who		Reason
21 February 2022	navpw1	Initial creation TFS: 52773

*/

begin
	if _attrName = ETRow_Sequence then
		return self.sequence.padLeadingWith("0",10);
	elseif _attrName = ETRow_IsSnapshot then        
		return "";	
	endif;
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initialiseActivity" id="641f0a1b-d9e0-442d-9ce9-e8d9d972adad">
        <updating/>
        <source>initialiseActivity(_description: String; _interface: String; _terminal: CM_Terminal; _opsViewObject: CM_Object; _dataAction: Character; _dataType: String; _snapshot: Boolean; _oid: String) updating;
/*

Purpose:			Initializes our EWS Activity

Parameters:			_description	String	
					_interface		String	
					_terminal		CM_Terminal	
					_opsViewObject	CM_Object	
					_dataAction		Character	
					_dataType		String		
					_snapshot		Boolean		
					_oid			String		

Return Value:		NONE

Date		Who		Reason
21 February 2022	navpw1	Initial creation TFS: 52773

*/

begin
	inheritMethod(_description, _interface, _terminal, _opsViewObject, _dataAction, _dataType, _snapshot, _oid);
	self.dataAction := _dataAction;
	self.dataType := _dataType;
	self.objectOid := _oid;

end;</source>
        <Parameter name="_description" type="String"/>
        <Parameter name="_interface" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_opsViewObject" type="CM_Object"/>
        <Parameter name="_dataAction" type="Character"/>
        <Parameter name="_dataType" type="String"/>
        <Parameter name="_snapshot" type="Boolean"/>
        <Parameter name="_oid" type="String"/>
    </JadeMethod>
