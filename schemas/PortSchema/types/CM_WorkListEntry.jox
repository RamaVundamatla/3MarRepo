    <JadeMethod name="isBulkGateVisit" id="d8ba89ec-f7a2-4821-8d8f-477e8d79a99e">
        <source>isBulkGateVisit():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 January 2017	cnwns1	Initial creation
//nds TFS 2867 17/01/17PKT - Bulk Process
*/

vars
	lIsBulkGateVisit : Boolean;
	job : CM_Job;
	
begin
	job 	:= self.job;
	
	if job &lt;&gt; null and job.isRoadJob then
		if job.CM_RoadJob.myVehicleVisit &lt;&gt; null then
			lIsBulkGateVisit := job.CM_RoadJob.myVehicleVisit.isBulkGateVVR;
		endif;
	endif;
	
	return lIsBulkGateVisit;
epilog

end;</source>
