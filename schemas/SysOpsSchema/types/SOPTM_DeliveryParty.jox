    <JadeMethod name="initShtMultiSelect" id="701a4466-3bf9-46d6-8f3e-f04571acf51a">
        <source>initShtMultiSelect();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 10 June 2022
TFS#		: 53679
Function	:

*** Changes ***
Date			Name	TFS#		Description
08/05/2025		navlw1	JIRA-34582: MTN | Filtering order Issue in system Admin Table as terminal collection cannot be re-ordered

****************************************************/

vars
	theForm	: SOP_TableMaintForm;
	
begin

	inheritMethod();
	
	theForm := self.myForm;
	
	self.setupMultiSelect1(app.getErrorString(Terminals), app.myRoot.allTerminals, SOP_TableMaintForm::displayEntryTerminal.name);
	theForm.mulSelect1.setVisibleButtons(true,true,false);  // navlw1 08/05/2025 #JIRA-34582
	theForm.mulSelect1.myBaseForm	:= theForm;
	theForm.mulSelect1.mySelectedListBox.sorted := false;	
	
	theForm.sheetAddress.visible := true;
	theForm.picAddress.width:=theForm.sheetAddress.width;
	theForm.picAddress.height:=theForm.sheetAddress.height;
	theForm.picAddress.parentAspect:=Control.ParentAspect_StretchBoth;
	theForm.picAddress.borderStyle:=Control.BorderStyle_None;
	theForm.picAddress.scrollBars:=Control.ScrollBars_Both;
	self.setAddressScrollRange();
end;</source>
    </JadeMethod>
