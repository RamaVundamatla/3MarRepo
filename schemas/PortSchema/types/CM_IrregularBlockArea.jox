        <Parameter name="_rowLabels" type="StringArray"/>
        <Parameter name="_columnLabels" type="StringArray"/>
        <Parameter name="_autoRestrictions" type="Boolean"/>
        <Parameter name="_stockControlled" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_allInterchangeAreas" type="CM_InterchangeAreaArray"/>
        <Parameter name="_defaultInterchangeArea" type="CM_InterchangeArea"/>
    </JadeMethod>
    <JadeMethod name="validate" id="48854401-5c39-4f06-99ad-975e1e9c11fa">
        <source>validate() protected;

/*

Purpose:            Validate the receiver

Parameters:

Return Value:


Date        Who         Reason
25 Jun 2008 cnwkpd1     PAR #17218 - Set a minimum and maximum number of rows and columns, and a minumum value for unit

*/

vars
	location: CM_LocationsController;
begin
	inheritMethod();
	
	if self.rows &lt; 1 or self.rows &gt; 999 then
		app.raiseCMException2(ERR_INVALID_VALUE, "Terminal Area Rows", "Please enter a value between 1 and 999", null, null);
	endif;
	if self.columns &lt; 1 or self.columns &gt; 999 then
		app.raiseCMException2(ERR_INVALID_VALUE, "Terminal Area Columns", "Please enter a value between 1 and 999", null, null);
	endif;
	if self.unit &lt;= 0 then
		app.raiseCMException2(ERR_INVALID_VALUE, "Terminal Area Unit", "Please enter a value greater than zero", null, null);
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="152bbacf-8002-4d2e-a2b9-c35c9a8b3252">
        <source>validateForUpdate(terminalArea : CM_IrregularBlockArea);
vars
	location, locationProxy : CM_LocationsController;
	ids : StringArray;
	locationBottomRight : Point;
begin
	self.raiseExceptionIfNotTransient(method);

	// Check that ok to delete a location
	foreach location in terminalArea.allLocationsControllers do
		//06/05/2009 cnwdz2 par19577
		locationProxy := location.pxyGetProxyObject();
		if location.hasTIs() then
			// Location is trying to be deleted
			if locationProxy = null then
				app.raiseCMException2(ERR_INVALID_VALUE, "Location " &amp; location.getID, " it is not empty, so cannot be deleted.", null, null);
				break;
			endif;
			
			// Location id is trying to be changed
			if locationProxy.getID &lt;&gt; location.getID then
				app.raiseCMException2(ERR_INVALID_VALUE, "Location " &amp; location.getID, " it is not empty, so its ID cannot be changed.", null, null);
			endif;	
		endif;
	endforeach;
	
	// Check that if the area has been reduced in size, no location is truncated PAR 16979
	if terminalArea.rows &gt; self.rows or terminalArea.columns &gt; self.columns then
		foreach locationProxy in self.allLocationsControllers do
			locationBottomRight := locationProxy.CM_IrregularBlockController.bottomRight;
			if locationBottomRight.x &gt; self.rows or locationBottomRight.y &gt; self.columns then
				app.raiseCMException2(ERR_INVALID_VALUE, "Rows or Columns", " The number of rows or columns cannot be reduced.", null, null);
				break;
			endif;
		endforeach;
	endif;
	
	// Check that the locations have unique ids
	create ids transient;
	foreach locationProxy in self.allLocationsControllers do
		if ids.includes(locationProxy.getID()) then
			app.raiseCMException2(ERR_INVALID_VALUE, "Location " &amp; locationProxy.getID(), " it is already used as the name of location in this area.", null, null);
			break;
		endif;
		if locationProxy.getID().length &gt; 0 // PAR 32886
		and locationProxy.getID().hasInvalidChars() then
			app.raiseCMException1(ERR_INVALID_CHARACTERS, locationProxy.getID(), null, null);
			break;
		endif;
		ids.add(locationProxy.getID());
	endforeach;

	inheritMethod(terminalArea);
epilog
	delete ids;
end;</source>
        <Parameter name="terminalArea" type="CM_IrregularBlockArea"/>
    </JadeMethod>
    <JadeMethod name="yaBuildBlocks" id="1c5be674-adc4-4ec5-b25b-12b3887c080a">
        <source>yaBuildBlocks(pYardAllocationObj: CM_YardAllocation; pAllControllersObj: CM_LCArray input; pAllBlocksInObj: CM_YABlockArray input; pAllBlocksOutObj: CM_YABlockArray input): Boolean;
/*
Purpose:		PAR 34205	
Date			Who			Reason
JUNE 2014		CNWAB1		Initial creation
11/07/2022		navdap1		TFS 53765 EUP Warehouse Yard Allocation Desktop Application
*/
vars
	blockObj			: CM_YABlock;
	controllerObj		: CM_LocationsController;
	irregularController	: CM_IrregularBlockController;
	controllerSetObj	: CM_LCArray;
	deleteBlockSet		: CM_YABlockSet;
	doDelete			: Boolean;
	
	yaAlloc : CM_YardAllocation;
	yaAgent : CM_YAAgent;
	range : String;
	ranges : StringArray;
begin
	// *** Do not inherit any behaviour ***
	//inheritMethod(pAllControllersObj, pAllBlocksObj);
	
	if self.myTerminal.getAutoPlanAllowFullGCArea and pAllControllersObj.size = self.allLocationsControllers.size then	// TFS 53765
		range := self.id;																								// TFS 53765
	else																												// TFS 53765
		range := self.getRackYALocationString(pAllControllersObj);
	endif;																												// TFS 53765
	
	create yaAgent transient;
	create ranges transient;
	
	range.getTokensForDelimiter(";",ranges);
	
	yaAlloc := pYardAllocationObj;
	
	foreach range in ranges do
		yaAgent.addRange(yaAlloc, range);
	endforeach;
	
	yaAlloc.allYABlocksIn.copy(pAllBlocksInObj);
	yaAlloc.allYABlocksOut.copy(pAllBlocksOutObj);
	yaAlloc.allYABlocksIn.clear;
	yaAlloc.allYABlocksOut.clear;
	
	return true;

epilog
	delete yaAgent;
	delete ranges;
	
	delete controllerSetObj;
	delete deleteBlockSet;

end;</source>
        <Parameter name="pYardAllocationObj" type="CM_YardAllocation"/>
        <Parameter name="pAllControllersObj" type="CM_LCArray" usage="input"/>
        <Parameter name="pAllBlocksInObj" type="CM_YABlockArray" usage="input"/>
        <Parameter name="pAllBlocksOutObj" type="CM_YABlockArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="yaFindLCs" id="0bb9f018-2e1a-4ad7-8da6-3ec968996314">
        <source>yaFindLCs(pFromId: String; pToId: String; pAllControllersObj: CM_LCArray input);
vars
	controllerObj	: CM_LocationsController;
	codes : StringArray;
	height : Integer;
begin
	create codes transient;
	codes.add(pFromId);
	self.findLocation(codes, false, controllerObj, height);
	if controllerObj &lt;&gt; null then
		pAllControllersObj.add(controllerObj);
	endif;
epilog
	delete codes;
end;</source>
        <Parameter name="pFromId" type="String"/>
        <Parameter name="pToId" type="String"/>
        <Parameter name="pAllControllersObj" type="CM_LCArray" usage="input"/>
    </JadeMethod>
