    <JadeMethod name="yaRecalculatePriorities" id="b52ad7f9-62b4-494b-ad8e-cb08c8d56299">
        <source>yaRecalculatePriorities();
// --------------------------------------------------------------------------------
// Created:		09 May 2005 by cnwdad1
//
// Purpose:		Recalculates the priority value for all of the receiver's Yard
//				Allocations and their Criteria.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allocationObj	: CM_YardAllocation;
	
begin
	foreach allocationObj in self.allYardAllocations do
		allocationObj.recalculateCriteriaPriorities();
	endforeach;
end;</source>
    </JadeMethod>
</Class>
