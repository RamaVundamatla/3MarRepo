    <JadeMethod name="getEntDefFromTrackedItem" id="c81474fd-200c-4e58-8551-8b8149a88646">
        <source>getEntDefFromTrackedItem(_ti : CM_TrackedItem) : String;
/*
Purpose:			Return the appropriate Ent Table Def for flexi forms based on a tracked item

Parameters:			

Return Value:		

Date		Who		Reason
26 August 2009	cnwdap1	Initial creation
*/
vars

begin
	if not _ti.isKindOf(CM_Container) then
		if _ti.isReefer then
			return ETDef_GeneralCargoReefer;
		else
			return ETDef_GeneralCargo;
		endif;
	elseif _ti.CM_Container.isReefer then
		return ETDef_ContainerFullReefer;
	elseif _ti.CM_Container.isEmpty then
		return ETDef_ContainerEmpty;
	endif;
	
	return ETDef_ContainerFull;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEventTypeActionDesc" id="3e690fd1-71c8-4b5b-a766-d8d7bac5fa96">
        <source>getEventTypeActionDesc(_eventType : Integer ) : String;
/*

Date		Who		Reason
08 December 2014	cnwer1	Initial creation PAR

*/

vars
	baseScm 	: Schema;
	category 	: ConstantCategory;
	const 		: Constant;
	constDict	: ConstantNDict;
	text,
	descr	: String;
begin
	if _eventType &gt;= EVT_MAX_JMT then
		return null;
	endif;
	
	baseScm := rootSchema.getSchema(PortSchemaName);
	category := baseScm.getCategory('EventTypes');
	constDict := category.getConstants();
	
	foreach const in constDict do
		if const.getSource.Integer = _eventType then
			text 		:= const.text;
			descr 	  	:= text.cnEcGetTagValueOfName('Descr');
			return descr;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEventTypeActionName" id="022b8947-c005-4edb-ae5f-f2f61369f9a0">
        <source>getEventTypeActionName(_eventType : Integer ) : String;
/*

Date		Who		Reason
08 December 2014	cnwer1	Initial creation PAR

*/

vars
	baseScm 	: Schema;
	category 	: ConstantCategory;
	const 		: Constant;
	constDict	: ConstantNDict;
	text,
	name	: String;
begin
	if _eventType &gt;= EVT_MAX_JMT then
		return null;
	endif;
	
	baseScm := rootSchema.getSchema(PortSchemaName);
	category := baseScm.getCategory('EventTypes');
	constDict := category.getConstants();
	
	foreach const in constDict do
		if const.getSource.Integer = _eventType then
			text 		:= const.text;
			name		:= text.cnEcGetTagValueOfName('Name');
			return name;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
