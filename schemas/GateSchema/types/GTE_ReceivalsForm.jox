//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 30/06/2022	navdap1		Initial creation TFS 53362 EUP Master Data Interface Customers Between TOS and ERP
//
vars

begin
	if combobox.listObject &lt;&gt; null then
		if app.myRoot.getConfig(ComboByNameOperator).Boolean then
			self.tblSearch.setValueByName(ETRow_FilterOperator, combobox.listObject.CM_Operator.description);
		else
			self.tblSearch.setValueByName(ETRow_FilterOperator, combobox.listObject.CM_Operator.code);
		endif;
	elseif combobox.text = Any_String then
		self.tblSearch.setValueByName(ETRow_FilterOperator, Any_String);
	endif;
epilog

end;</source>
