    <JadeMethod name="loadVoyageCombo" id="95258099-8f2a-4ee9-b55f-83ca8476881d">
        <source>loadVoyageCombo( _newCombo : ComboBox input;
				 _criteriaLine : CM_SelectorCriteriaLine input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2019	jlger1	Initial creation 47132

*/

vars

	voyageCode : String;
	voyage : CM_Voyage;
begin
	if _criteriaLine = null then
		return;
	endif;
	voyageCode :=_criteriaLine.myQueryOperator.getSearchValueStr(_criteriaLine.myQueryProperty);
	if voyageCode &lt;&gt; null then
		voyage := self.myTerminal.lookupVoyage (voyageCode, null, false);
	endif;
				
	self.myAssistant.comboBoxVoyageCurrent(_newCombo,
								voyage,
								true,
								self.includeArchivedVoyages,
								self.includeSailedVoyages,
								true,
								true,
								true,
								true,
								false,
								false); //cnwrs1 par15258 nov 2007
epilog

end;</source>
        <Parameter name="_newCombo" type="ComboBox" usage="input"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstColour_displayRow" id="a10de4d2-acd2-4bd7-b438-32d402142c56">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstColour_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 13/08/2013	cnwdap1		Initial creation PAR #32123
//
vars
	selected : Boolean;
	
begin
	selected := table.CMUI_ListTableColour.allSelectedObjects.includes(obj);
	return self.myAssistant.displayEntryColour(obj.CM_VehicleColour, selected);
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="lstColour_lostFocus" id="311e77b3-0398-4ad6-bae5-9342f8697528">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstColour_lostFocus(table: Table input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 13/08/2013	cnwdap1		Initial creation PAR #32123
//
vars
	tbl		: CM_EntryTable;
begin
	tbl := self.getEditTableForSheet(self.fldEdit.topSheet.CMUI_Sheet);

	self.myAssistant.listTableLostFocus(tbl, self.saveRowHeight, table.CMUI_ListTable, CM_VehicleColour::colour.name, false);
	if tbl.getValueByName(ETRow_Colour).String = Any_String then
		tbl.setValueByName(ETRow_Colour, null);
	endif;
	tbl.adjustHeight(400);
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstTblSpecialLif_displayRow" id="2bc58f90-b85d-4a07-b388-3ae4c35063e4">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstTblSpecialLif_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 July 2009	cnwml2	Initial creation

*/

vars

	ti 				: CM_TrackedItem;
begin
	//if self.tblData.allSelectedObjects.size &gt; 0 then
	//	ti := self.tblData.allSelectedObjects.first.CM_TrackedItem;
	if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_TrackedItem) then	// 09/11/2010 cnwar2 #26270 - tblData only valid in search form mode
		ti := self.myCurrentObject.CM_TrackedItem;
		
		if ti.allSpecialLifts.includes(obj.CM_SpecialLift) then
			return TableCheckBox_Selected  &amp; Tab &amp; obj.CM_SpecialLift.description;
		else
			return  TableCheckBox_NotSelected &amp; Tab &amp; obj.CM_SpecialLift.description;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="lstTblSpecialLif_lostFocus" id="a8195aba-d8d2-4b68-b7b6-87d65e79a861">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstTblSpecialLif_lostFocus(table: Table input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 July 2009	cnwml2	Initial creation

*/

vars
	tbl	,editTable	: CM_EntryTable;
begin
	tbl := self.getEditTableForSheet(self.fldEdit.topSheet.CMUI_Sheet);

	self.myAssistant.listTableLostFocus(tbl, self.saveRowHeight, table.CMUI_ListTable, CM_SpecialLift::code.name, false);
	if tbl.getValueByName(ETRow_AllSpecialLifts).String = Any_String then
		tbl.setValueByName(ETRow_AllSpecialLifts, null);
	endif;
//	tbl.adjustHeight(400);
	
	//epr 3/6/14 - this annoyed me
	editTable := self.getTableForRow(ETRow_AllSpecialLifts);
	if editTable &lt;&gt; null then
		editTable.cnEcResizeContents();
	endif;
	//added by cnwyl1

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuAdditionalStorage_click" id="eb0f4af1-abe9-4ecd-aab3-c2da06a21621">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuAdditionalStorage_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 September 2012	cnwer1	Initial creation SFW 1295
08 August 2016	cnwma1	   TFS #2467 PAR #38101 PEN - Mass Edit Free Storage Time
03/08/2017	jlgdap1	TFS 5681 AAT Error when trying to add additional free storage days
*/

vars
	tiArray	: CM_TIArray;
	ti		: CM_TrackedItem;
begin

	//self.myAssistant.showAdditionalFreeStorage(menuItem.userObject.CM_TrackedItem,false);  // 09/08/2016 cnwma1 TFS #2467 PAR #38101
	create tiArray transient;  																// 09/08/2016 cnwma1 TFS #2467 PAR #38101
	if not self.tblData.allSelectedObjects.isEmpty then				// TFS 5681
		self.tblData.allSelectedObjects.copy(tiArray); 										// 09/08/2016 cnwma1 TFS #2467 PAR #38101
	else															// TFS 5681
		tiArray.add(self.myCurrentObject.CM_TrackedItem);			// TFS 5681
	endif;															// TFS 5681
	self.myAssistant.showAdditionalFreeStorage(tiArray,false); 								// 09/08/2016 cnwma1 TFS #2467 PAR #38101
epilog
		delete tiArray;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
