    <JadeMethod name="canViewBookingRef" id="527fa0a0-7ee8-46e9-9cbf-2498b63beefc">
        <source>canViewBookingRef() : Boolean;
/* ---------------------------------------------------------------------------
Created:     29 August 2008 by cnwrs2

Purpose:     PAR 17823
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
begin
	if app.myCurrentUserCan(self.myTerminal, PmGteFullReleaseForward)
	or app.myCurrentUserCan(self.myTerminal, PmGteFullReleaseOperatorMaint)
	then
		return true;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
