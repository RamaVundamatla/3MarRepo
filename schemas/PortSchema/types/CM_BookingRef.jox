    <JadeMethod name="voyageCode" id="df0bb924-1e77-451c-8f9b-d1a4b21d5ebd">
        <methodInvocation>mapping</methodInvocation>
        <source>voyageCode(set: Boolean; _value: String io) mapping;

vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if self.myVoyage &lt;&gt; null then
		_value := self.myVoyage.code.trimBlanks;
	else
		_value := "";
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
