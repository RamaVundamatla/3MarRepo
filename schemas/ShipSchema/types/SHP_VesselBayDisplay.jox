    <JadeMethod name="setFormPermissions" id="ed4193bc-7333-4eb6-beb1-b71f296473b2">
        <source>setFormPermissions(_form: CM_BaseForm io);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 May 2009	cnwer1	Initial creation

*/

vars

begin
	_form.setPropertyValue(CM_BaseForm::permissionView.name,PmShipBayDefView);
	_form.setPropertyValue(CM_BaseForm::permissionMaint.name,PmShipBayDefMaint);
	_form.setPropertyValue(CM_BaseForm::helpFileName.name,HelpFile_Voyage);
epilog

end;</source>
        <Parameter name="_form" type="CM_BaseForm" usage="io"/>
    </JadeMethod>
