    <JadeMethod name="showTransactions" id="8b281fd1-1223-4ba6-9f3d-22fd8757f715">
        <source>showTransactions();
// ---------------------------------------------------------------------------
// Created:     21 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	wagon	 : CM_Wagon;
	wagonForm : YRD_WagonTransactionForm;
begin
	wagon := self.tblData.allSelectedObjects.first.CM_Wagon;
	
	if wagon = null then
