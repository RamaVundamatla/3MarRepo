    <JadeMethod name="addDirectoryNode" id="b03cd8c7-40b9-4cb4-b09b-2175f68dc399">
        <source>addDirectoryNode(index : Integer; level : Integer; name : String);
vars
	i : Integer;
begin
	if index = 0 then
		dirTreeList.addItem(name);
		i := dirTreeList.newIndex;
	else
		dirTreeList.addItemAt(name, index);
		i := index;
	endif;

	dirTreeList.itemLevel[i] := level;
	dirTreeList.itemPictureType[i] := ListBox.ItemPictureType_Closed;
end;</source>
        <Parameter name="index" type="Integer"/>
        <Parameter name="level" type="Integer"/>
        <Parameter name="name" type="String"/>
    </JadeMethod>
    <JadeMethod name="addDirectoryNodes" id="15070ca1-7dd7-4d74-8b89-9b96f0e80f9a">
        <source>addDirectoryNodes(startIndex : Integer; level : Integer; dirName : String);
vars
	index :		Integer;
	dirList :	String;
	pos :		Integer;
	dir :		String;
	length :	Integer;
	delims :	String;
	dName :		String;
begin
	dirList := folder._getServerDirectoryList(dirName, folder.mask);
	// directory names are delimited by null
	delims[1] := null;
	pos := 1;
	index := startIndex;
	length := dirList.length;
	while pos &gt; 0 and pos &lt; length do
		dir := dirList.scanUntil(delims, pos);
		addDirectoryNode(index, level, dir);
		index := index + 1;
		pos := pos + 1;
		if dirList[pos] = "Y" or hasFile(dirName &amp; dirSep &amp; dir) then
			// "Y" =&gt; has subdirectory
			addDummyNode(index, level+1);
			index := index + 1;
		endif;
		pos := pos + 1;
	endwhile;

	addFileNodes(index, level, dirName);
end;</source>
        <Parameter name="startIndex" type="Integer"/>
        <Parameter name="level" type="Integer"/>
        <Parameter name="dirName" type="String"/>
    </JadeMethod>
    <JadeMethod name="addDriveNode" id="0ea27751-16b2-44c1-90e3-81569acedbe3">
        <source>addDriveNode(drive : String);
vars
	i : Integer;
begin

	dirTreeList.addItem(drive);
	i := dirTreeList.newIndex;

	dirTreeList.itemLevel[i] := 1;
	dirTreeList.itemPictureType[i] := ListBox.ItemPictureType_Leaf;

end;</source>
        <Parameter name="drive" type="String"/>
    </JadeMethod>
    <JadeMethod name="addDummyNode" id="d1d776f2-aff0-4789-ae1a-ec83b4e72447">
        <source>addDummyNode(index : Integer; level : Integer);
begin
	if index = 0 then
		dirTreeList.addItem(Dummy);
		dirTreeList.itemLevel[dirTreeList.newIndex] := level;
	else
		dirTreeList.addItemAt(Dummy, index);
		dirTreeList.itemLevel[index] := level;
	endif;
end;</source>
        <Parameter name="index" type="Integer"/>
        <Parameter name="level" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addFileNode" id="4364ec65-4a9c-4c25-976a-9af407422cd6">
        <source>addFileNode(index : Integer; level : Integer; name : String);
vars
	i : Integer;
begin
	if index = 0 then
		dirTreeList.addItem(name);
		i := dirTreeList.newIndex;
	else
		dirTreeList.addItemAt(name, index);
		i := index;
	endif;

	dirTreeList.itemLevel[i] := level;
end;</source>
        <Parameter name="index" type="Integer"/>
        <Parameter name="level" type="Integer"/>
        <Parameter name="name" type="String"/>
    </JadeMethod>
    <JadeMethod name="addFileNodes" id="04475182-35cd-4087-993c-20dec0fd033e">
        <source>addFileNodes(startIndex : Integer; level : Integer; dirName : String);

vars
	index :		Integer;
	fileList :	String;
	pos :		Integer;
	fileName : 	String;
	length :	Integer;
	delims :	String;
begin
	fileList := folder.getServerFileList(dirName, folder.mask);
	// file names are delimited by Tab
	delims[1] := Tab;
	pos := 1;
	index := startIndex;
	length := fileList.length;
	while pos &gt; 0 and pos &lt; length do
		fileName := fileList.scanUntil(delims, pos);
		addFileNode(index, level, fileName);
		index := index + 1;
		if pos = 0 then
			break;
		endif;
		pos := pos + 1;
	endwhile;
end;</source>
        <Parameter name="startIndex" type="Integer"/>
        <Parameter name="level" type="Integer"/>
        <Parameter name="dirName" type="String"/>
    </JadeMethod>
