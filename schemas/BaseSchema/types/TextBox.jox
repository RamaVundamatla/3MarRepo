<GUIClass name="TextBox">
    <JadeMethod name="cnEcDate" id="f87be31e-3112-4d35-82e7-a2653180e29f">
        <source>cnEcDate():Date;
// --------------------------------------------------------------------------------
// Created:		20 December 2000 by cnwdad1
//
// Purpose:		Returns the text value of the receiver as a Date value.
//
// Parameters:	None
//
// Returns:		Date - the trimmed text cast to a Date value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
//	return self.text.trimBlanks().Date;
	return self.text.asDate();
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="cnEcDecimal" id="9a046ee4-5e83-4039-bc44-ef3b83935389">
        <source>cnEcDecimal():Decimal;
// --------------------------------------------------------------------------------
// Created:		20 December 2000 by cnwdad1
//
// Purpose:		Returns the text value of the receiver as a Decimal value.
//
// Parameters:	None
//
// Returns:		Decimal - the trimmed text cast to a Decimal value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	//return self.text.trimBlanks().cnEcRemoveSubstring(",").Decimal;
	return self.text.trimBlanks().cnEcRemoveSubstring(app.currentLocaleInfo.numericInfo.thousandSeparator).Decimal;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="cnEcDoSpellCheck" id="981148fa-c030-4244-88d0-aab21b573072">
        <updating/>
        <source>cnEcDoSpellCheck():Boolean updating;
// --------------------------------------------------------------------------------
// Created:		08 December 2001 by cnwdad1
//
// Purpose:		Spell-Checks the receiver's text, and updates it if the prose has
//				been modified.
//
// Parameters:	None
//
// Returns:		True if the text was changed, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 10/07/2006	cnwdad1		Added a check for whether the updated text would fit in
//							the textbox.
//
// 07/06/2008	cnwdad1		Changed to only check whether updated text will fit in
//							the textbox if the maxLength property is &gt; zero.
// --------------------------------------------------------------------------------
vars
	spellCheckObj	: CnEcSpellCheck;
	checkedProse	: String;
	userResponse	: Integer;
	
begin
	create spellCheckObj transient;
	
	if spellCheckObj.isCheckProse(self.text, checkedProse) then
		if self.maxLength &gt; 0 and checkedProse.length() &gt; self.maxLength then
			userResponse	:=	app.msgBox(	"The updated text will not fit in the text box." &amp;
											"  It can be left as it was, or the updated text can be truncated." &amp;
											CrLf &amp; CrLf &amp; "Would you like the text to be truncated ?",
											"Truncate ?",
											MsgBox_Question_Mark_Icon + MsgBox_Yes_No);
			
			if userResponse = MsgBox_Return_Yes then
				self.text	:=	checkedProse[1:self.maxLength];
				return true;
			else
				return false;
			endif;
		else
			self.text	:=	checkedProse;
			return true;
		endif;
	else
		return false;
	endif;
epilog
	delete spellCheckObj;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcInteger" id="4a61dd26-81f8-4fee-992a-9be8ad8db781">
        <source>cnEcInteger():Integer;
// --------------------------------------------------------------------------------
// Created:		20 December 2000 by cnwdad1
//
// Purpose:		Returns the text value of the receiver as a Integer value.
//
// Parameters:	None
//
// Returns:		Integer - the trimmed text cast to a Integer value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	//return self.text.trimBlanks().cnEcRemoveSubstring(",").Integer;
	return self.text.trimBlanks().cnEcRemoveSubstring(app.currentLocaleInfo.numericInfo.thousandSeparator).Integer;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsInScrollZone" id="e7748fdf-19be-4c6d-935c-808953424092">
        <source>cnEcIsInScrollZone(pXPos:Real; pYPos:Real):Boolean;
// --------------------------------------------------------------------------------
// Created:		19 May 2006 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the specified coordinates
//				are within an estimated scroll zone, i.e. within a certain distance
//				from the edge of the receiver.
//
// Parameters:	pXPos - The x coordinate.
//				pYPos - The y coordinate.
//
// Returns:		True if the coordinate is near the scroll zone, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	ScrollMargin	: Integer = 25;
	
begin
	if pXPos &lt;= ScrollMargin or pYPos &lt; ScrollMargin then
		return true;
	endif;
	
	if pXPos &gt;= (self.clientWidth - ScrollMargin)
	or pYPos &gt;= (self.clientHeight - ScrollMargin)
	then
		return true;
	endif;
	  
	return false;
end;</source>
        <Parameter name="pXPos" type="Real"/>
        <Parameter name="pYPos" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcReal" id="bb732984-31bc-428f-a521-dadacaca4273">
        <source>cnEcReal():Real;
// --------------------------------------------------------------------------------
// Created:		20 December 2000 by cnwdad1
//
// Purpose:		Returns the text value of the receiver as a Real value.
//
// Parameters:	None
//
// Returns:		Real - the trimmed text cast to a Real value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.text.trimBlanks().Real;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEcSet" id="530a08fa-6df1-4584-b839-cb429f3c7666">
        <updating/>
        <source>cnEcSet(pValue:String) updating;
// --------------------------------------------------------------------------------
// Created:		13 August 2002 by cnwdad1
//
// Purpose:		Updates the receiver's text with the specified value.
//
// Parameters:	pValue - The string value to set the text to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.text &lt;&gt; pValue then
		self.text	:=	pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcString" id="52384eba-72b3-4432-90c4-49176c7b1b29">
        <source>cnEcString():String;
// --------------------------------------------------------------------------------
// Created:		20 December 2000 by cnwdad1
//
// Purpose:		Returns the (trimmed) text value of the receiver.
//
// Parameters:	None
//
// Returns:		String - the trimmed text value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.text.trimBlanks();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
