    <JadeMethod name="testDumpSort" id="ee771d01-907b-4c0d-a109-fd059d49cb24">
        <source>testDumpSort();
//-----------------------------------------------------------
//
// Created by cnwsh3
//
// Date: 15 January 2007
//
// ----------------------------------------------------------

vars
	rootFolderPath : String;
	fileNode : FileNode;
	fileFolder : FileFolder;
	file : File;
	file1 :File;
	fileList : FileNodeArray;
	int, 
	int2 : Integer;
	str,
	errorNumber: String;
begin
	//Set the path of the file folder I'm looking in
	//rootFolderPath := 'c:\Test';
	create fileFolder transient;
	create fileList;
	rootFolderPath := fileFolder.browseForFolder('test', 'C:\JMTerminal\Pars\Par13157\test');
	
	fileFolder.fileName := rootFolderPath;
	
	if not fileFolder.isAvailable then
		app.writeStatement( 'File Folder is Unavailable');
	else 
		foreach fileNode in fileFolder.files do
			if fileNode.isKindOf(FileFolder) then
				continue;
			endif;
			int := 1;
			if fileNode.name.pos('_dump_20', int) &gt; 0 then// pos('cn_dump', int) &gt; 0 then
				file1 		:= fileNode.File;			// 29/2/16  cnwns1 PAR 36286 unicode version
				file1.kind 	:= File.Kind_Unknown_Text; 	// 29/2/16  cnwns1 PAR 36286 unicode version
				while not file1.endOfFile do			// 29/2/16  cnwns1 PAR 36286 unicode version
					str := file1.readLine();			// 29/2/16  cnwns1 PAR 36286 unicode version
			//	while not fileNode.File.endOfFile do	// 29/2/16  cnwns1 PAR 36286 unicode version
			//		str := fileNode.File.readLine();	// 29/2/16  cnwns1 PAR 36286 unicode version
			//		int := 1;
					if str.pos('Exception',int) &gt; 0 then
						//Now look for the number before the "(" in the str.
						int2 := 1;
						app.writeStatement( str);
						errorNumber := str.scanUntil('(', int2);
						//reverse scan until we don't have a number;
						errorNumber := errorNumber.reverse.trimLeft;
						app.writeStatement( errorNumber);
						int2 := 1;
						errorNumber := errorNumber.scanWhile('0123456789', int2);
						errorNumber := errorNumber.reverse;
						app.writeStatement( errorNumber);
						break;
					else 
						
					endif;
					
				endwhile;
			
				create file transient;
				//file.fileName := fileNode.;
			endif;
		endforeach;
	endif;
	//fileFolder := 
	//check to see if there are files in the folder
	
epilog
	delete fileList;
	
end;</source>
    </JadeMethod>
