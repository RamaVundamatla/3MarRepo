    <JadeMethod name="deleteLabourRestriction" id="88b7c8e1-0011-4e9d-9c69-fa00d7192259">
        <source>deleteLabourRestriction(_labourRestriction : CM_LabourRestriction);

/*

Purpose:		Delete a labour restriction

Parameters:		_labourRestrcition - Labour restrcition to delete

Date			Who		Reason
16 August 2011	cnwmh5	Initial creation

*/

vars

	invalidObject: Boolean;
	edition : Integer;
	
begin
	
	// should never happen but you never know
	if _labourRestriction = null then
		return;
	endif;
	
	//23 Apr 2015	NDL	Par 36014
	on Exception do app.handleDeletedObject( exception, _labourRestriction, invalidObject );
	edition := _labourRestriction.edition;
	if invalidObject then
		return;
	endif;
	
	app.myTrxDA.trxDeleteRestrictionLabour(_labourRestriction, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
end;
</source>
