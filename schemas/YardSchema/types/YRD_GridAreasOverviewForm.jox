    <JadeMethod name="doResizeBars" id="01d69cf4-491d-4086-95f3-1518aa5eb4e0">
        <source>doResizeBars();
// ---------------------------------------------------------------------------
// Created:		08 November 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aDB : YRD_ContainerGridAreaDockBar;
	aTA : Object;
begin
	foreach aTA in self.allDockBars do
		aDB := aTA.YRD_ContainerGridAreaDockBar;
		aDB.visible := true;
		if aDB.alignContainer = YRD_ContainerGridAreaDockBar.AlignChildren_AllVertical then
			aDB.width := (self.dkcGridArea.clientWidth );
		else
			aDB.height := (self.dkcGridArea.clientHeight );
		endif;
		aDB.myDrawingController.showDrawingFrame(true);
	endforeach;

end;</source>
    </JadeMethod>
