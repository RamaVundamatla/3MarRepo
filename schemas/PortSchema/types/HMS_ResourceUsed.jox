    <JadeMethod name="setProxy" id="22f7fc03-5170-48a1-b553-54dd3290fbf3">
        <updating/>
        <source>setProxy(_harbour : HMS_Harbour; _resourceType : HMS_ResourceType;
		 _rescource : HMS_Resource; _pxyVTMISTrans : HMS_VTMISTransaction;
		 _fromDateTime, _toDateTime : TimeStamp; _unitsUsed : Real;
		 _poc : Boolean;
		 _wodOrderVoyageDtl : CM_WorkOrderVoyageDtl; //31 Oct 2018	NDL	TFS 41281 
		 _debtor : CM_Debtor	//26 Nov 2018	NDL	TFS 41980
		 )updating;
//--------------------------------------------------
// Created:	16 February 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	if _pxyVTMISTrans &lt;&gt; null then
		_pxyVTMISTrans.raiseExceptionIfNotTransient(method);
		if self.myVTMISTransaction &lt;&gt; null then
			if (not self.myVTMISTransaction.isTransient) then
				app.raiseUnexpectedProgramError(class.name, method.name, 'myVTMISTransaction already set');
			endif;
		else
			self.myVTMISTransaction := _pxyVTMISTrans;
		endif;
	endif;
	
	self.myResource := _rescource;
	self.myResourceType := _resourceType;
	self.myHarbour := _harbour;
	self.myWorkOrderVoyageDtl := _wodOrderVoyageDtl;	//31 Oct 2018	NDL	TFS 41281 
	
	//26 Nov 2018	NDL	TFS 41980
	if _debtor &lt;&gt; null then
		self.myDebtor := _debtor;
	endif;
	
	if _rescource &lt;&gt; null then
		self.code 			:= _rescource.code.toUpper.trimBlanks;
		self.description 	:= _rescource.description;	
	endif;

	self.fromDateTime := _fromDateTime;
	self.toDateTime := _toDateTime;
	self.unitsUsed := _unitsUsed;
	self.partOfContract := _poc;
end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_resourceType" type="HMS_ResourceType"/>
        <Parameter name="_rescource" type="HMS_Resource"/>
        <Parameter name="_pxyVTMISTrans" type="HMS_VTMISTransaction"/>
        <Parameter name="_fromDateTime" type="TimeStamp"/>
        <Parameter name="_toDateTime" type="TimeStamp"/>
        <Parameter name="_unitsUsed" type="Real"/>
        <Parameter name="_poc" type="Boolean"/>
        <Parameter name="_wodOrderVoyageDtl" type="CM_WorkOrderVoyageDtl"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromDateFromMovement" id="d3ab82a2-32e6-4e2c-ad62-e201ff81531a">
        <updating/>
        <source>setProxyFromDateFromMovement(_move : HMS_VoyageMovement) updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		used to set a default date time
//
// ---------------------------------------------------------------------------

vars

begin
	self.raiseExceptionIfNotTransient(method);

	if self.myResourceType &lt;&gt; null and self.myResourceType.isActionDateTimeRequired = false then
		return;
	endif;
	
	if self.fromDateTime.isValid then
		return;
	endif;
	
	if _move.occursOnDTNEW.isValid() then
		self.fromDateTime := _move.occursOnDTNEW;
	endif;
end;</source>
        <Parameter name="_move" type="HMS_VoyageMovement"/>
    </JadeMethod>
