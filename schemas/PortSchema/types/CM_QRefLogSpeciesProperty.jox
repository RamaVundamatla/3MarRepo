    <JadeMethod name="create" id="d5865c74-087a-41df-a0fb-30b82d27e69b">
        <updating/>
        <source>create() updating;
// -------------------------------------------
// Created 16 September 2004 by cnwdvb1
// -------------------------------------------
vars

	oper : CM_QueryOperator;

begin

	if self.isTransient then 
		return;
	endif;

	create oper as CM_QReferenceIsOneOf persistent;
	self.allAllowedOperators.add(oper);

end;</source>
    </JadeMethod>
    <JadeMethod name="getControlNameForOperator" id="ebc21d14-661b-4004-8a39-680a556e7f2a">
        <source>getControlNameForOperator(_operator: CM_QueryOperator): String;
// ---------------------------------------------------------------------------
// Created:     16 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if CM_QReferenceLookup.hasInstance(_operator) then
		return 'cmbLogSpecies';
	endif;


end;</source>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOpList" id="132425ef-bc65-4803-9f00-647e3fe17564">
        <source>getOpList(_crit : CM_SelectorCriteriaLine) : CM_OperatorSet;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2017	jlgab1	Initial creation

*/

vars
	opset : CM_OperatorSet;
	op : CM_Operator;
	anything : Any;
	array : StringArray;
	lookup : String;
begin
	create array transient;
	create opset transient;
	
	anything := _crit.myQueryOperator.getSearchValue();
	if anything &lt;&gt; null then
		if anything.isKindOf(String) then
			array.add(anything.String);
		elseif anything.isKindOf(StringArray) then
			anything.StringArray.copy(array);
		endif;
	endif;
	
	foreach lookup in array do
		op := app.myRoot.allOperators[lookup];
		if op &lt;&gt; null then
			opset.add(op);
		endif;
	endforeach;
	
	return opset;
epilog
	delete array;
end;</source>
        <Parameter name="_crit" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="CM_OperatorSet"/>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="86402939-8c0e-4e1c-907e-f930864ca466">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     18 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	crit		: CM_SelectorCriteriaLine;
	op			: CM_Operator;
	code		: CM_Code;	
	codeDict	 : CM_CodesByCodeDict;
	terminology : String;
	theCargoBOLType : CM_CargoBOLType;
	opset : CM_OperatorSet;
	desc : String;
begin
	_combo.clear;
	
	if _params = null then
		return;
	endif;
				

	crit := _params.allCriteriaByPropertyName['myOperator', CM_BOL.name/*CM_Log.name*/];	// Par16731. cnwvu1 15 May 2008
	if crit = null then		
		crit := _params.allCriteriaByPropertyName['operatorCode', CM_BOL.name/*CM_Log.name*/];	// Par16731. cnwvu1 15 May 2008
		if crit = null then
		
			crit := _params.allCriteriaByPropertyName['myOperator', CM_Log.name];	 // TFS 7821
			if crit = null then		
				crit := _params.allCriteriaByPropertyName['operatorCode', CM_Log.name];	 // TFS 7821
				if crit = null then
					theCargoBOLType := app.myRoot.getCargoBOLTypeForId(TI_CargoType_Log);// TFS 7821
					terminology := app.getTerminologyAlternate(theCargoBOLType, null, "Operator" , CM_TermExpressionSingular, "Operator") ;	// TFS 7821
				
					_combo.addItem('Must select an appropriate ' &amp; terminology);// TFS 7821
					return;
				endif;
			endif;
		endif;
		opset := self.getOpList(crit);// TFS 7821
	else
		op := crit.myQueryOperator.getSearchValue().CM_Operator;
		if op &lt;&gt; null then// TFS 7821
			create opset transient;// TFS 7821
			opset.add(op);// TFS 7821
		endif;
	endif;

	// TFS 7821
	foreach op in opset do
		codeDict := op.getAllLogSpecies;
		
		if codeDict= null then
			return;
		endif;
		
		foreach code in codeDict do
			desc := code.code &amp; '   ' &amp; code.description;
			if _combo.findObject(code) &lt;= 0 then
				_combo.itemObject[_combo.addItem(desc)] := code;
			endif;
		endforeach;
		
	endforeach;
	
	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		code := _queryOperator.CM_QReferenceLookup.mySelectionValue.CM_LogSpecies;
		if code &lt;&gt; null then
			if _combo.findObject(code) &gt; 0 then
				_combo.listObject := code;
			endif;
		endif;
	endif;
epilog
	delete opset;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="acd64e2f-9476-4e91-bf46-6b8672db9c91">
        <source>setListValues(_tbl : Table input; _params : CM_QueryCriteriaLineHolder; _operator : CM_QReferenceIsOneOf; _passport : CM_Passport);
/*
Purpose:		TFS 7821	
Date				Who			Reason
NOVEMBER 2017		CNWAB1		Initial creation
*/

vars
	
	op			: CM_Operator;
	codeDict	 : CM_CodesByCodeDict;
	code		: CM_Code;	
	
	opset : CM_OperatorSet;
	lookup : String;
	crit				: CM_SelectorCriteriaLine;
	obj : Object;
	selectionValue, idx : Integer;
begin
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;
	_tbl.sortColumn[1] := 2;
	
	if _params = null then
		return;
	endif;

	crit := _params.allCriteriaByPropertyName['myOperator', CM_BOL.name];	
	if crit = null then		
		crit := _params.allCriteriaByPropertyName['operatorCode', CM_BOL.name];	
		if crit = null then
			crit := _params.allCriteriaByPropertyName['myOperator', CM_Log.name];	
			if crit = null then		
				crit := _params.allCriteriaByPropertyName['operatorCode', CM_Log.name];	
				if crit = null then
					_tbl.addItem("" &amp; Tab &amp; 'Must select an operator');
					return;
				endif;
			endif;
		endif;
		
		opset := self.getOpList(crit);// TFS 7821
	else
		op := crit.myQueryOperator.getSearchValue().CM_Operator;
		if op &lt;&gt; null then// TFS 7821
			create opset transient;// TFS 7821
			opset.add(op);// TFS 7821
		endif;
	endif;
	
	// TFS 7821
	foreach op in opset do
		codeDict := op.getAllLogSpecies;
		
		if codeDict= null then
			return;
		endif;
		
		foreach code in codeDict do
			selectionValue := 0;
			if _operator &lt;&gt; null and _operator.allSelectionValues.includes(code) then
				selectionValue := 1;
			endif;
			
			if _tbl.cnEcFindObjectRow(code) = null then
				idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; code.code &amp; '   ' &amp; code.description);
				_tbl.accessRow(idx).itemObject := code;
				_tbl.row := idx;
				_tbl.change(_tbl);
			endif;
		endforeach;
		
	endforeach;
	
	

epilog
	delete opset;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QReferenceIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="3a88c886-c184-4e28-be21-92d71bd42c0b">
        <source>translateStringToSearchValue( _value: Any; _criteriaLine : CM_SelectorCriteriaLine ): Any;
// ----------------------------------------------------------------------
// Created 13 May 2008 by cnwvu1
//
// Purpose:	Gets value as String from RT screen and returns value
//			 into criteriaLineLine for running a query
// ----------------------------------------------------------------------

vars
	codeSpecies	: CM_Code;
	critHolder	: CM_QueryCriteriaLineHolder;
	critLine	: CM_SelectorCriteriaLine;
	op			: CM_Operator;
	dict		: CM_CodesByCodeDict;
	tmpValue	: String;
	
begin

	if _value.isKindOf( CM_Code ) then
		return _value;
	endif;

	tmpValue := _value.String.toUpper();
	
	critHolder	:= _criteriaLine.myCriteriaLineHolder;
	critLine	:= critHolder.allCriteriaByPropertyName['myOperator', CM_BOL.name];
	if critLine &lt;&gt; null then
		op := critLine.myQueryOperator.getSearchValue().CM_Operator;
	else
		critLine := critHolder.allCriteriaByPropertyName['operatorCode', CM_BOL.name];
		op := app.myRoot.allOperators[critLine.myQueryOperator.getSearchValue().String];
	endif;
	
	dict	:= op.getAllLogSpecies;
	
	foreach codeSpecies in dict discreteLock do
		if codeSpecies.code.toUpper() = tmpValue then
			return codeSpecies;
		endif;
	endforeach;

	// when not found. Par 17092	cnwvu1, June 2008
	inheritMethod( _value, _criteriaLine );

end;
</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="5a2f7d2c-087f-42a4-89ec-4a4a88dc8a83">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     19 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
22 Oct 2008	cnwkpd1	PAR #18099 - Handle null objects in selector queries

*/

vars

begin
	if _value &lt;&gt; null then
		return _value.CM_LogSpecies.code;
	endif;

	return null;


end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="f83945b4-0fe2-4f95-bd19-6b1473388f72">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     19 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
06 Oct 2008	cnwkpd1	PAR #18099 - Correct Selector query processing
22 Oct 2008	cnwkpd1	PAR #18348 - Prevent 1002 exceptions in Selector query processing with isOneOf

*/

vars
	returnVal		: CM_LogSpecies;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;

		if _value.isKindOf(CM_LogSpecies) then
			returnVal := _value.CM_LogSpecies;
		endif;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
