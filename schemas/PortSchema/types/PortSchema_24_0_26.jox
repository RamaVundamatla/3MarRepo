    <JadeMethod name="convertInvoiceLineTaxDetails" id="90cad37b-faa7-4e91-9421-aa1484c95a55">
        <source>convertInvoiceLineTaxDetails(_controller : CnEcReleaseController);
/*
Purpose - 	
Who - NAVAB1
Date - 02APR2024
ADO -  CR 62992 TASK 62994 
*/

vars
	iter01 : Iterator;
	theInvLine : CM_InvoiceLine;
	theInv : CM_Invoice;
	oArray : ObjectArray; 
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Convert Invoice Line Tax", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Convert Invoice Line Tax") ;	
	endif;
	
	create oArray transient;
	CM_TaxCode.allInstances(oArray,0,false);
	if oArray.size = 0 then
		app.writeLog(method.qualifiedName &amp; " No tax codes in system, no lines converted", LogINFO);
		if _controller &lt;&gt; null then
			_controller.logEntry(" No tax codes in system, no lines converted") ;
		endif;
		
		self.addScriptRun(method.name);
		
		return;
	endif;
	
	oArray.clear();
	
	CM_InvoiceLine.allInstances(oArray,0,false);
	iter01 := oArray.createIterator;

	beginTransaction;
	
	while iter01.next(theInvLine) do
		theInvLine.setTaxDetails();
	endwhile;

	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " all Invoice Lines converted", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" all Invoice Lines converted") ;
	endif;
	
	self.addScriptRun(method.name);
epilog
	delete oArray;
end;</source>
