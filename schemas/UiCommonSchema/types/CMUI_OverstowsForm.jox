	self.tblOverStowed.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblOverStowed.multiSelect := CM_BaseTable.MultiSelect_Simple;
	
	self.tblOverstowing.setMyEntTableDef(entDef);
	self.tblOverstowing.setTblDataEntRowsFromDef(entDef);
	self.tblOverstowing.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblOverstowing.multiSelect := CM_BaseTable.MultiSelect_Simple;

epilog

end;</source>
