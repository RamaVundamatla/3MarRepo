    <JadeMethod name="setTidalModelDef" id="487b0f14-3ea5-4311-a957-2cd5b975c43f">
        <source>setTidalModelDef(_pxyTidalModelDef : HMS_TidalModelDefinition input) protected;
/*
----------   ----------  --------------------------------------------------
Created:	09 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	dataType			: Integer;
	hasGaps				: Boolean;
	tidalData			: HMS_TidalData;
	theDate,
	previousDate		: Date;
	val,
	highestVal,
	lowestVal			: Real;
	dict				: HMS_TidalDataByTSDict;
begin
	if self.cmbDataType.listIndex &gt; 0 then
		dataType := self.cmbDataType.itemData[self.cmbDataType.listIndex];
	endif;
	
	
	//lowestVal := self.tblInput1.getValueByName(ETRow_LowestValue).Real;
	//highestVal := self.tblInput1.getValueByName(ETRow_HighestValue).Real;
	
	//here we loop through all the tidal data to set a few things
	//persistently to avoid work at run-time - hasGaps, highest and lowest value
	theDate := null;
	previousDate := null;
	
	if not _pxyTidalModelDef.allHMSTidalData.isEmpty then//no new data loaded
		dict := _pxyTidalModelDef.allHMSTidalData;
	else
		if self.myCurrentObject &lt;&gt; null then
			dict := self.myCurrentObject.HMS_TidalModelDefinition.allHMSTidalData;
		endif;
	endif;
	
	if dict &lt;&gt; null then
		foreach tidalData in dict do
			theDate := tidalData.ts.date;
			if previousDate &lt;&gt; null and theDate &lt;&gt; previousDate and (theDate - previousDate &gt; 1) then
				//there must be a date gap greater than one day
				hasGaps := true;
			endif;
			previousDate := theDate;
			
			val := tidalData.getValue;
			if val &gt; highestVal then
				highestVal := val;
			endif;
			
			if val &lt; lowestVal or lowestVal = null then
				lowestVal := val;
			endif;
		endforeach;
	endif;
	if self.tblInput1.getValueByName(ETRow_DataSource).String = HMS_TidalDataSourceGetTideFile then //CCMS1640 cnwrs1 jan 2009
		highestVal := self.tblInput1.getValueByName(ETRow_HighestValue).Real;
		lowestVal := self.tblInput1.getValueByName(ETRow_LowestValue).Real;
	endif;
	_pxyTidalModelDef.setProxy(self.tblInput1.getValueByName(ETRow_Code).String,
								self.tblInput1.getValueByName(ETRow_Description).String,
								dataType,
								self.tblInput1.getValueByName(ETRow_DataSource).String,
								highestVal,
								lowestVal,
								self.tblInput1.getValueByName(ETRow_DeclaredDepth).Real,
								self.tblInput1.getValueByName(ETRow_UnderKeelClearance).Real,
								hasGaps,
								app.myRoot,
								self.tblInput1.getValueByName(ETRow_GetTideFileName).String); //cnwrs1 Jan 2009
end;


</source>
        <access>protected</access>
        <Parameter name="_pxyTidalModelDef" type="HMS_TidalModelDefinition" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupSpecialMenus" id="fad50552-c860-41dc-8d7c-5b2ce872104d">
        <updating/>
        <source>setupSpecialMenus() updating;
/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#		Description
============================================================================
07/08/2008	cnwer1				Initial creation
29/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
============================================================================*/

vars
		newMenu : MenuItem;
begin
	if app.isSpecial then
		/*self.clonedMenuCount := self.clonedMenuCount + 1;
		newMenu:=self.mnuTblVCloneDataTbl.loadMenu(self.clonedMenuCount);
		newMenu.caption:="Get next time for height";
		newMenu.visible:=true;
		newMenu.setEventMapping(MenuItem::click.name,HMS_TidalModelMaintForm::getNextTimeForHeightAtTime.name);*/
		
		self.clonedMenuCount := self.clonedMenuCount + 1;
		newMenu:=self.mnuTblVCloneDataTbl.loadMenu(self.clonedMenuCount);
		newMenu.caption:="Get max draft from date";
		newMenu.visible:=true;
		newMenu.setEventMapping(MenuItem::click.name,HMS_TidalModelMaintForm::getMaxDraughtFromDate.name);
		
		self.clonedMenuCount := self.clonedMenuCount + 1;
		newMenu:=self.mnuTblVCloneDataTbl.loadMenu(self.clonedMenuCount);
		newMenu.caption:="Get drafts for time (-12 to + 12 hours)";
		newMenu.visible:=true;
		newMenu.setEventMapping(MenuItem::click.name,HMS_TidalModelMaintForm::getHiLoTidesForTime.name);
	endif;
epilog

end;</source>
