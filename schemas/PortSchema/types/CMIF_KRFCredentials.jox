    <JadeMethod name="setFromWSDef" id="1f12970c-2d14-417f-9eca-ab88576571f5">
        <updating/>
        <source>setFromWSDef(_wsDefinition : CM_KiwiRailCheckInWSDef) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Mar 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message
*/

vars

begin
	self.password := _wsDefinition.getPwForUse( CM_KiwiRailCheckInWSDef::messagePassword.name );
	self.username := _wsDefinition.messageUsername;
epilog

end;</source>
        <Parameter name="_wsDefinition" type="CM_KiwiRailCheckInWSDef"/>
