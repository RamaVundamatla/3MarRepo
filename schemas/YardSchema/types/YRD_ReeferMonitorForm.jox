    <JadeMethod name="translateForm" id="3a9f5d8c-641d-4d5f-9249-3e5287c226bd">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 May 2025 16:50:45.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008856, locale);
	btnAddJob.translateBubbleHelp(Xlat_0024014, locale);
	btnAddJob.translateCaption(Xlat_0024015, locale);
	btnAutoJobs.translateBubbleHelp(Xlat_0024016, locale);
	btnAutoJobs.translateCaption(Xlat_0024017, locale);
	btnPrintLabel.translateCaption(Xlat_0004633, locale);
	btnReeferLayout.translateBubbleHelp(Xlat_0024405, locale);
	btnReeferLayout.translateCaption(Xlat_0024406, locale);
	btnShowJobs.translateBubbleHelp(Xlat_0024018, locale);
	btnShowJobs.translateCaption(Xlat_0024019, locale);
	btnWalkPath.translateBubbleHelp(Xlat_0024020, locale);
	btnWalkPath.translateCaption(Xlat_0024021, locale);
	btnWorkList.translateCaption(Xlat_0004632, locale);
	mnuAddReading.translateCaption(Xlat_0008857, locale);
	mnuColourLegend.translateCaption(Xlat_0008858, locale);
	mnuConnect.translateCaption(Xlat_0008859, locale);
	mnuContainerContext.translateCaption(Xlat_0008860, locale);
	mnuContainerEnquiry.translateCaption(Xlat_0008861, locale);
	mnuCreateReefJobSelected.translateCaption(Xlat_0027086, locale);
	mnuDisconnect.translateCaption(Xlat_0008862, locale);
	mnuSelectAll.translateCaption(Xlat_0008863, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="4c2186b5-f16f-4bc3-8cb5-8699328404fc">
        <controlMethod name="Form::unload"/>
