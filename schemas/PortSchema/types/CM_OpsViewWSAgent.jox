    <JadeMethod name="setupTrainForActivity" id="42118a14-17db-4da9-ba78-b0d8ea17f813">
        <source>setupTrainForActivity(_cmifArray : CMIF_OpsViewTablesArray io; _ewsOpsView : CM_EWSActivityOpsview): CMIF_OpsViewTablesArray;
/*
Purpose:	MTN has 1 CM_Train for in and out, N$ has 2 seperate trains 1 for in and 1 for out
			In N4 the in and the out trains are in the same table so we need seperate GKEYs
			Have added a prefix that is used in the build of the gkey

Date		Who		Reason
14 December 2021	navab1	TFS 51855
*/

vars
	carrierVisitCmif : CMIF_ArgoCarrierVisit;
//	visitDetailsCmif : CMIF_ArgoVisitDetails;
//	opsviewData : CMIF_RailTrainVisitDetails;
	data : Any; // CM_Train

begin
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		data := _ewsOpsView.objectOid;
	else
		data := _ewsOpsView.myOpsviewObject;
	endif;


	// ### INBOUND TRAIN
	create carrierVisitCmif transient;
	carrierVisitCmif.initializeForActivityPrefix(data,_ewsOpsView, CMIF_OpsViewTables.Prefix_Inbound);
	_cmifArray.add(carrierVisitCmif);
/*
	create visitDetailsCmif transient;
	visitDetailsCmif.initializeForActivityPrefix(data,_ewsOpsView, CMIF_OpsViewTables.Prefix_Inbound);
	carrierVisitCmif.argoVisitDetails := visitDetailsCmif;
	
	create opsviewData transient;
	opsviewData.initializeForActivityPrefix(data,_ewsOpsView, CMIF_OpsViewTables.Prefix_Inbound);	
	_cmifArray.add(opsviewData);
*/
	// ### OUTBOUND TRAIN
	create carrierVisitCmif transient;
	carrierVisitCmif.initializeForActivityPrefix(data,_ewsOpsView, CMIF_OpsViewTables.Prefix_Outbound);
	_cmifArray.add(carrierVisitCmif);

/*
	create visitDetailsCmif transient;
	visitDetailsCmif.initializeForActivityPrefix(data,_ewsOpsView, CMIF_OpsViewTables.Prefix_Outbound);
	carrierVisitCmif.argoVisitDetails := visitDetailsCmif;
	
	create opsviewData transient;
	opsviewData.initializeForActivityPrefix(data,_ewsOpsView, CMIF_OpsViewTables.Prefix_Outbound);	
	_cmifArray.add(opsviewData);

*/	
	
	
	
	return _cmifArray;


epilog

end;</source>
        <Parameter name="_cmifArray" type="CMIF_OpsViewTablesArray" usage="io"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <ReturnType type="CMIF_OpsViewTablesArray"/>
    </JadeMethod>
    <JadeMethod name="setupVVRForActivity" id="6e4d42f6-f16f-4de7-be95-4c0b6344f973">
        <source>setupVVRForActivity(_cmifArray : CMIF_OpsViewTablesArray io; _ewsOpsView : CM_EWSActivityOpsview): CMIF_OpsViewTablesArray;
/*
Purpose:			

Date		Who		Reason
26AUG2021	NAVAB1	TFS 51853
*/

vars
	carrierVisitCmif    	: CMIF_ArgoCarrierVisit;
	roadTruckCmif : CMIF_RoadTruckVisitDetails;
	visitStats : CMIF_RoadTruckVisitStats;
	data            : Any;
begin
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		data := _ewsOpsView.objectOid;
	else
		data := _ewsOpsView.myOpsviewObject;
	endif;

	create roadTruckCmif transient;
	roadTruckCmif.initializeForActivity(data,_ewsOpsView);
	_cmifArray.add(roadTruckCmif);

	create carrierVisitCmif transient;
	carrierVisitCmif.initializeForActivityPrefix(data,_ewsOpsView, "");
	_cmifArray.add(carrierVisitCmif);


	create visitStats transient;  // ### TFS 51853 01DEC2021 NAVAB1
	visitStats.initializeForActivity(data,_ewsOpsView); // ### TFS 51853 01DEC2021 NAVAB1
	_cmifArray.add(visitStats); // ### TFS 51853 01DEC2021 NAVAB1
	
	return _cmifArray;
	
epilog

end;</source>
        <Parameter name="_cmifArray" type="CMIF_OpsViewTablesArray" usage="io"/>
