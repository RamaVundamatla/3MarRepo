    <JadeMethod name="populateTrackedItem" id="770b3d5d-5255-4ac6-aae8-ef30eccacbeb">
        <source>populateTrackedItem();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 July 2010	cnwndl1	Initial creation	CCMS MES 1077

*/

vars
	
begin

	if self.myTrackedItem = null then
		self.txtId.text := self.lblId.caption.toUpper;
		self.txtId.setFocus();
		self.lblCargoType.caption := null;
	else
		self.txtId.text := self.myTrackedItem.id;
		self.lblCargoType.caption := self.myTrackedItem.cargoTypeDescr;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="selectCargoItem" id="a60abc0d-c880-4469-a90d-28a91abc44a4">
        <updating/>
        <source>selectCargoItem( _manual : Boolean ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 July 2010	cnwndl1	Initial creation	CCMS MES 1077

*/

vars

	cargoId : String;
	term : CM_Terminal;
	firstTi : CM_TrackedItem;
	tiArray : CM_TIArray;
	iter : Iterator;
	ti : CM_TrackedItem;
	voyage : CM_Voyage;
	errMsg : String;
	
	revDict : CM_TIByIdCargoTypeDictRev;	//11 Oct 2010	NDL	Par 25836
	cargoIdLength : Integer;	//11 Oct 2010	NDL	Par 25836
	cargoIdReversed : String;	//11 Oct 2010	NDL	Par 25836
	
begin

	self.myTrackedItem := null;
	self.lblCargoType.caption := null;
	
	cargoId := txtId.text.trimBlanks.toUpper;
	if cargoId = lblId.caption.toUpper then
		cargoId := null;
	endif;
	
	term := self.myMobileDataAgent.myTerminal;
	voyage := self.myMobileGenericAgent.myVoyage;
	create tiArray transient;
	
	if cargoId &lt;&gt; null then
	
		cargoIdLength := cargoId.length;	//11 Oct 2010	NDL	Par 25836
		cargoIdReversed := cargoId.reverse;	//11 Oct 2010	NDL	Par 25836
		
		firstTi := voyage.allOnsiteTIsByIdCargoType.getAtKeyGeq(cargoId,null);
		//if firstTi &lt;&gt; null and firstTi.id = cargoId then
		if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then	//11 Oct 2010	NDL	Par 25836
			iter := voyage.allOnsiteTIsByIdCargoType.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
			//	if ti.id &lt;&gt; cargoId then
				if ti.id[1:cargoIdLength] &lt;&gt; cargoId then	//11 Oct 2010	NDL	Par 25836
					break;
				endif;
				if ti.myPrimaryActualLocation.isCraneLaneController then
					continue;
				endif;
				if ti.myPrimaryActualLocation.isVoyageController then
					continue;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
		//11 Oct 2010	NDL	Par 25836 - Try reverse 'cargoId' as any piece of the id
		if tiArray.isEmpty and not voyage.allOnsiteTIsByIdCargoType.isEmpty then
			create revDict transient;
			voyage.allOnsiteTIsByIdCargoType.copy( revDict );
			firstTi := revDict.getAtKeyGeq(cargoIdReversed,null);
			if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
				iter := revDict.createIterator;
				iter.startAtObject(firstTi);
				while iter.next( ti ) do
					if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
						break;
					endif;
					tiArray.addExclusive(ti);
				endwhile;
				delete iter;
			endif;
			delete revDict;
		endif;
		
	endif;
		
	if not _manual and tiArray.isEmpty then
		return;
		
	elseif tiArray.size = 1 then
		self.myTrackedItem := tiArray.first;
		populateTrackedItem();
		return;
		
	else
		// more than one found.
		/*		30 Apr 2013	NDL	Par 31506
		if not _manual then
			self.msgBox( app.getErrorString1(Multiple_cargo_items_search, cargoId), app.getErrorString(Warning), MsgBox_OK_Only,true );
		endif;
		*/
		app.myMobileCargoFindAgent.setMyVoyage( self.myMobileGenericAgent.myVoyage );
		app.myMobileCargoFindAgent.setMyCraneTransferArea( self.myMobileGenericAgent.myCraneTransferArea );
		app.myMobileCargoFindAgent.setID( cargoId );
		app.myMobileCargoFindAgent.setMyTrackedItemToProcess(null);
		app.myMobileCargoFindAgent.setDoSearchImmediate( cargoId.trimBlanks &lt;&gt; null );
		app.myMobileCargoFindAgent.setSearchSite(TI_SITE_UNDEFINED);	//11 Oct 2010	NDL	Par 25836
	
		self.myMobileGenericAgent.setMyNextTiToAction(null);
		self.gotoForm( MOB_HHCargoFind, false );
	endif;
	

epilog

	delete tiArray;
	delete iter;
	delete revDict;	//11 Oct 2010	NDL	Par 25836

end;</source>
        <Parameter name="_manual" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="37168c5c-2b26-4242-a73d-e8c58a982ef7">
        <updating/>
        <source>setupControls() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 July 2010	cnwndl1	Initial creation	CCMS MES 1077

*/

vars
	
begin
	 
	self.doResizeControls(true);					 

	populateTrackedItem();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="57b5cebd-4eb5-4311-a9a1-0604573811db">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 July 2010	cnwndl1	Initial creation	CCMS MES 1077
*/

vars

begin
	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;
	self.myTrackedItem := app.myMobileCargoFindAgent.myTrackedItemToProcess; // populated if returning from a search.
	if self.myTrackedItem = null then
		self.myTrackedItem := self.myMobileGenericAgent.myNextTiToAction;	// populated if returning from cargo checks
	endif;
	app.myMobileCargoFindAgent.clearHistory(true);
	
	inheritMethod();
	
	self.setupCmdButtons( 2, app.getErrorString(Complete), app.getErrorString(Back), null, null, null );
	
	setupControls();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="ec5df494-8560-4db7-b994-285e4468ae3b">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0015215, locale);
	lblId.translateCaption(Xlat_0015216, locale);
	lblLoad.translateCaption(Xlat_0015217, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtId_gotFocus" id="b2ad4cd4-0c48-4c7a-a0cf-355e6dd14d4d">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtId_gotFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 July 2010	cnwndl1	Initial creation	CCMS 1077

*/

vars

begin
	if self.txtId.text = self.lblId.caption.toUpper then
		//self.txtId.text := null;
		self.txtId.selStart := 0;
		self.txtId.selLength := self.lblId.caption.length;
	endif;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtId_lostFocus" id="0ef3e165-6d95-4504-92a5-a2279e507870">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtId_lostFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 July 2010	cnwndl1	Initial creation	CCMS 1077

*/

vars

begin

	app.convertScannedCargoId( self.myTerminal, textbox, false, null );	//06 Jul 2016	NDL	TFS 2275

	if self.txtId.text.trimBlanks = null then
		self.txtId.text := self.lblId.caption.toUpper;
	else
		self.selectCargoItem( false );
	endif;
	
	self.txtId.selStart := 0;
	self.txtId.selLength := 0;
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
