    <JadeMethod name="downLoadToFile" id="e783c575-2e40-4df1-8e36-56634a7981a9">
        <source>downLoadToFile();

vars

	downLoadFile		: File;
	saveDialog			: CMDFileSave;
	row					: Integer;
	col					: Integer;
	pos                 : Integer;
	str					: String;
	output              : String;
	hsa					: HugeStringArray;
	sampleMessage       : SampleMessages;
begin
	//
	// Check if we have any output
	//
	if tbl_cache.rows &lt; 2 then
		app.msgBox('Download NOT Completed','Snap Shot Download', MsgBox_OK_Only);
		return;
	endif;

	create saveDialog transient;
	saveDialog.initDir 	:= 'C:\temp';
	saveDialog.fileName	:= 'CacheSS.csv';		
	if saveDialog.open &lt;&gt; 0 then
		return;
	endif;

	app.mousePointer := Window.MousePointer_HourGlass;
	create downLoadFile;
	downLoadFile.mode := File.Mode_Output; // 3/3/16  cnwns1 PAR 36286 unicode version
	downLoadFile.fileName:= saveDialog.fileName;
	downLoadFile.open;
	if chkSSNoDup.value then
		create hsa transient;
	endif;
	//setup file heading
	row := 1;
	str:= null;
	foreach col in 1 to tbl_cache.columns do
		if str = null then
			str:= tbl_cache.getCellText(row,col);
		else
			str:= str &amp; ',' &amp; tbl_cache.getCellText(row,col);
		endif;
	endforeach;
	//
	// Write out Heading
	//
	downLoadFile.writeLine(str);
	foreach sampleMessage in v_tcpHandler.v_snapshotMessageSet do

		output := sampleMessage.message;
		output.replaceChar(Tab, ',');
		if chkSSNoDup.value then
			pos := 1;
			str := output.getToken(pos);
			if not hsa.includes(str) then
				hsa.add(output);
			endif;
		else
			downLoadFile.writeLine(output);
		endif;
	endforeach;
	if hsa &lt;&gt; null then
		foreach str in hsa do
			downLoadFile.writeLine(str);
		endforeach;
		delete hsa;
	endif;
	downLoadFile.close;
	app.msgBox('Download of Cache snapshot has Completed','Snap Shot Download', MsgBox_OK_Only);
	
epilog
	delete saveDialog;
	delete downLoadFile;
	app.mousePointer := Window.MousePointer_Default;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="enableControls" id="1c4228c0-d747-4dca-893e-268e0bb26264">
        <updating/>
        <source>enableControls() updating;

vars

begin
	b_Clear.enabled   := true;
	b_Listen.enabled  := true;
	b_Print.enabled   := true;
	b_Refresh.enabled := true;
	b_Sample.enabled  := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="findTextString" id="ee7b790c-4a9e-4a81-9892-59b3cb53e03c">
        <updating/>
        <source>findTextString(sample : SampleMessages; target : String; offset : Integer io) : Boolean updating;
//
//	Searches for matching string.
//  If we get a match
//  	Bumps found count
//		Highlights appropriate line
//
vars
	index  : Integer;
	size   : Integer;
	source : String;
	row    : JadeTableRow;
begin
	if chx_case.value = true then
		source := (sample.type &amp; sample.message);
	else
		source := (sample.type &amp; sample.message).toLower;
	endif;

	index  := source.pos (target, offset);
	if index &lt;&gt; 0 then
		offset := index + target.length;
		tbl_Messages.displayCollection(v_tcpHandler.v_sampleMessageSet, false, 
		                               Table.DisplayCollection_Forward + Table.DisplayCollection_Prior, sample);
		v_searchFoundCount.bump;
		size := tbl_Messages.rows;
		foreach index in 1 to size do
			row := tbl_Messages.accessRow(index);
			if row.itemObject = sample then
				row.foreColor := Red;
				break;
			endif;
		endforeach;
		return true;
	endif;
	return false;
epilog
end;</source>
        <Parameter name="sample" type="SampleMessages"/>
        <Parameter name="target" type="String"/>
        <Parameter name="offset" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="firstTimeInitialize" id="e6e4536a-230f-4aa5-bf27-e1286b095af0">
        <updating/>
        <source>firstTimeInitialize() updating;

vars
	time : Time;
begin
	sl_Status.caption := time.String &amp; ' ' &amp; 'Need to load classes before running';
	caption := 'Need to load classes before running';
	b_Clear.enabled   := false;
	b_Listen.enabled  := false;
	b_Print.enabled   := false;
	b_Refresh.enabled := false;
	b_Sample.enabled  := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="getCacheConcurrencyInfo" id="f82ef1cd-7235-46f0-8f93-1380674bc730">
        <updating/>
        <source>getCacheConcurrencyInfo() : String updating;

vars
	jdo     : JadeDynamicObject;
	value   : Any;
	decimal : Decimal [ 23 , 3 ];
	string  : String;
begin
	create jdo transient;

	node.getObjectCaches(jdo, 1);
	value  := jdo.getPropertyValue('totalCacheCoherencyNotifications');
	string :=  'Total Cache Coherency Notifications ' &amp; value.String &amp; CrLf;
	value  := jdo.getPropertyValue('cacheCoherencyNotificationHits');
	string := string &amp; 'Cache Coherency Notification Hits ' &amp; value.String &amp; CrLf;
	value  := jdo.getPropertyValue('cacheCoherencyUpdatedObjects');
	string := string &amp; 'Cache Coherency Updated Objects ' &amp; value.String &amp; CrLf;

	process.getRequestStatistics(jdo, 1);
	value   := jdo.getPropertyValue('processCPUTime');
	decimal := value.Decimal / 1000;
	string  := string &amp; 'Process CPU Time (' &amp; process.persistentApp.name &amp; ') ' &amp; decimal.userNumberFormat($MilliSeconds) &amp; CrLf;
	value   := jdo.getPropertyValue('nodeCPUTime');
	decimal := value.Decimal / 1000;
	string  := string &amp; 'Node CPU Time (' &amp; node.name &amp; ') ' &amp; decimal.userNumberFormat($MilliSeconds) &amp; CrLf;
	return string;
epilog

	delete jdo;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
