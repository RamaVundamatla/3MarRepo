    <JadeMethod name="getInvoiceList" id="535abdc1-e173-4965-b38b-8bb6fa56dd06">
        <source>getInvoiceList() : String;
 /*

Purpose:			// TFS 39349

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2018	jlgab1	Initial creation

*/

vars
	inv :	CM_Invoice;
	extFinID, 
	str : String;
begin

	foreach inv in self.allInvoices	discreteLock do
		extFinID := inv.getExternalFinancialId(); //08/12/2025	navkc1 JIRA 36262
		
		if str = null then
			//if inv.externalFinancialId &lt;&gt; null then
				//str := inv.externalFinancialId;
			if extFinID &lt;&gt; null then //08/12/2025	navkc1 JIRA 36262
				str := extFinID; //08/12/2025	navkc1 JIRA 36262
			else	
				str := inv.sequenceNum.String;
			endif;
		else
			//if inv.externalFinancialId &lt;&gt; null then
				//str := str &amp; ", " &amp; inv.externalFinancialId;
			if extFinID &lt;&gt; null then //08/12/2025	navkc1 JIRA 36262
				str := str &amp; ", " &amp; extFinID; //08/12/2025	navkc1 JIRA 36262
			else	
				str := str &amp; ", " &amp; inv.sequenceNum.String;
			endif;
		endif;
		
	endforeach;
	
   return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
