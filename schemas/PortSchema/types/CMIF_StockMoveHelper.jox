    <JadeMethod name="clearSelf" id="3fdfbd9c-e1db-4826-af5c-dea4691e6f0f">
        <source>clearSelf();
// ---------------------------------------------------------------------------
// Created:     22 August 2002 by cnwth2
//
// Purpose:     This clears the array values - and initializes the supscripts if being used for the first time
//
// ----------   ----------  --------------------------------------------------
vars
	idx			: Integer;
	stkMoveDtl	: CMIF_StockMoveDtl;
begin

	self.allStockMoveDtls.purge;

	foreach idx in 1 to Index_Max do
		create stkMoveDtl transient;
		self.allStockMoveDtls.add(stkMoveDtl);
	endforeach;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="fee7cf6d-bbeb-420a-ab59-9e115df71512">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     29 August 2002 by cnwrs2
