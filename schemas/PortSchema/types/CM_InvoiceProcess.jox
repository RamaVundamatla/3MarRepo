    <JadeMethod name="validateForUpdateStatus" id="09c571cf-3d6b-4f73-8097-b650ae422711">
        <source>validateForUpdateStatus(_invoice : CM_Invoice; _status : CMIF_InvoiceStatus);
/*

Purpose: Check new status is part of process, and follows current status

Parameters:			

Return Value:		

Date		Who		Reason
28 Dec 2018	jlgsl4	TFS 39618 - LNX Invoice Approved Status
23/01/2023	navkc1 CR 59146 Task 62129: Jade - TAS Credit Note Test
*/

vars
 	proxyInvoice : CM_Invoice;
	newStatus : Integer;
	validNextStatuses : CM_InvoiceStatusByPriority;
	newInvoiceStatus : CM_InvoiceStatus;
	internalStatusInvoiceAPI : CM_InvoiceStatus;	//navra1 - TFS 54090 CR - 61386/Task - 61564 - 30th Nov 2023
	existingTASInvoice	: CM_Invoice; 	//23/01/2023	navkc1 CR 59146 Task 62129
	bank				: CM_Bank;		//23/01/2023	navkc1 CR 59146 Task 62129
	existingTASInvoiceIDs	: String;		//23/01/2023	navkc1 CR 59146 Task 62129
begin
	newStatus := _status.newStatus;
	if newStatus &lt;&gt; CM_Invoice.INVOICE_POSTED_PENDING and newStatus = _invoice.status then  //jlier1 MTN-34357 20/3/25
		app.raiseCMException2(ERR_STATUS_CHANGE, _invoice.sequenceNum.String, "Is already status of " &amp; _invoice.getStatusDescription(newStatus),null, null);
	endif;
	newInvoiceStatus := self.allStatuses[newStatus];
	if newInvoiceStatus = null then // new status isn't valid for this process
		app.raiseCMException2(ERR_STATUS_CHANGE, _invoice.sequenceNum.String,
										"New invoice status (" &amp; newStatus.String &amp; ") is not configured for invoice process '" &amp; self.description &amp; "'",null, null); // TFS 43059 better message
	endif;
	
	if newInvoiceStatus &lt;&gt; null then
		create validNextStatuses transient;
		self.getNextValidStatuses(_invoice, validNextStatuses, false); // get the next valid statuses after current one
		
		if _invoice.myInvoiceProcess.isInvoiceAPIProcess() then														//navra1 - TFS 54090 CR - 61386/Task - 61564 - 30th Nov 2023
			if newInvoiceStatus =  self.allStatuses[CM_Invoice.INVOICE_POSTED_PENDING] 								//navra1 - TFS 54090 CR - 61386/Task - 61564 - 30th Nov 2023
						and validNextStatuses.includes(self.allStatuses[CM_Invoice.INVOICE_POSTED]) then			//navra1 - TFS 54090 CR - 61386/Task - 61564 - 30th Nov 2023
				validNextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_POSTED_PENDING]);							//navra1 - TFS 54090 CR - 61386/Task - 61564 - 30th Nov 2023
			endif;			
			
			//jlier1 19/9/24 TFS 65963 - 65949 NSW | Dynamic Integration Development
			if newInvoiceStatus = self.allStatuses[CM_Invoice.INVOICE_POSTED_CREDIT_PENDING] then	
				validNextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_POSTED_CREDIT_PENDING]);	
			elseif newInvoiceStatus = self.allStatuses[CM_Invoice.INVOICE_POSTED_CREDIT_ERROR] then	
				validNextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_POSTED_CREDIT_ERROR]);	
			elseif newInvoiceStatus = self.allStatuses[CM_Invoice.INVOICE_POSTED_ERROR] then
				if  _invoice.status = CM_Invoice.INVOICE_POSTED_PENDING and  not validNextStatuses.includes(self.allStatuses[CM_Invoice.INVOICE_POSTED_ERROR]) then
					validNextStatuses.add(self.allStatuses[CM_Invoice.INVOICE_POSTED_ERROR]);
				endif;
			endif;
			
		endif;																										//navra1 - TFS 54090 CR - 61386/Task - 61564 - 30th Nov 2023
		
		if validNextStatuses.isEmpty or not validNextStatuses.includes(newInvoiceStatus) then // new status isn't valid for this process
			app.raiseCMException2(ERR_STATUS_CHANGE, _invoice.sequenceNum.String,
											"Cannot progress to new status '" &amp; newInvoiceStatus.description &amp; "' from current status.",null, null); // TFS 43059 better message
		endif;
	endif;
	
	//23/01/2023	navkc1 CR 59146 Task 62129 - validation when posting a TAS credit note
	if _invoice.isTASCreditNote() and newStatus = CM_Invoice.INVOICE_POSTED then
		bank := _invoice.bank;
		
		foreach existingTASInvoice in bank.allInvoicesByExternalCode where existingTASInvoice.exportCurrencyCode = _invoice.exportCurrencyCode do
			if existingTASInvoice.isTASInvoice() and not existingTASInvoice.isPostedOrReversal() then
				if existingTASInvoiceIDs &lt;&gt; null then
					existingTASInvoiceIDs &amp;= "," &amp; existingTASInvoice.sequenceNum.String;
				else
					existingTASInvoiceIDs := existingTASInvoice.sequenceNum.String;
				endif;
			endif;
		endforeach;
		
		if existingTASInvoiceIDs &lt;&gt; null then
			app.raiseCMException2(This_credi_note_canno_poste_in, existingTASInvoiceIDs, existingTASInvoice.exportCurrencyCode, null, null);
		endif;
	endif;
epilog
	delete validNextStatuses;
end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_status" type="CMIF_InvoiceStatus"/>
    </JadeMethod>
    <JadeMethod name="validateSelf" id="71531d70-56d4-45c0-8cd0-9c65fc77b8bd">
        <source>validateSelf();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Oct 2018	jlgsl4	TFS 39618 - LNX - Invoice Approved Status

*/

vars

begin
	if self.code = null then
		app.raiseCMException(Input_required_field_code, "code", null);
	endif;
	if self.description = null then
		app.raiseCMException(Input_required_field_Desc, "description", null);
	endif;
	if self.pinEmailOffset = null then
		app.raiseCMException(Input_required_field_Desc, "PINEmail offset", null);
	endif;	
epilog

end;</source>
    </JadeMethod>
</Class>
