    <JadeMethod name="onCargoIdChange" id="3d19402f-c01c-406d-81a8-34a3239685e0">
        <updating/>
        <source>onCargoIdChange(_id: String) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2012	cnwndl1	Initial creation

*/

vars

	onsite : CM_TrackedItem;
	cargoType : CM_CargoType;
	cargoTypeInt : Integer;
	preNote : CM_TrackedItem;

begin

	self.updateMode := Mode_Add;

	if _id.trimBlanks &lt;&gt; null then
	
		cargoType := self.cmbType.getObject.CM_CargoType;
		if cargoType &lt;&gt; null then
			cargoTypeInt := cargoType.id;
		endif;
		onsite := self.myTerminal.lookupTrackedItem( _id, cargoTypeInt, TI_STATE_NORMAL, null, false );
		if onsite &lt;&gt; null then
			app.msgBox(app.getErrorString1(ERR_DUP_ONSITE_TI,_id),"",MsgBox_OK_Only);
			txtCargoID.setFocus();
			return;
		endif;
		
		preNote := self.myTerminal.lookupTrackedItem( _id, cargoTypeInt, TI_STATE_NOTIFIED, null, false );
		
	endif;

	inheritMethod(_id);
	
	if preNote &lt;&gt; null then
		self.myTI := preNote;
		self.setFieldsFromTi();
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
    </JadeMethod>
    <JadeMethod name="resetForm" id="96a442e1-e8f4-4b50-ab2d-f81a64aa50bf">
        <updating/>
        <source>resetForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2012	cnwndl1	Initial creation

*/

vars

begin

	if app.isValidObject(myProxyTrackedItem) then
		self.myProxyTrackedItem.erase(NORMAL_ERASE);
		self.myProxyTrackedItem := null;
	endif;

	self.updateMode := self.Mode_Add;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFieldsFromTi" id="5b643c59-d321-45db-bb79-b15830677ae2">
        <updating/>
        <source>setFieldsFromTi() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2012	cnwndl1	Initial creation

*/

vars

	consignor : CM_ConsigneeConsignor;

begin

	cmbISOType.listCollection(app.myRoot.allISOTypes, true, 0);
	cmbImexStatus.setForObject(app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT]);
	self.picTitleEmpty.visible := true;
	
	if self.myTI &lt;&gt; null then
	
		self.myProxyTrackedItem := self.myTI.pxyGetProxyObject();
		if self.myProxyTrackedItem = null then
			self.myProxyTrackedItem := app.createUpdateProxy(self.myTI).CM_TrackedItem;
		endif;
		
		self.updateMode 		:= self.Mode_Update;
		
		self.setContainerMainDetails(self.myTI);
		self.cmbVoyageCode.setObject(self.myTI.myVoyage);
		self.cmbOperatorCode.setObject(self.myTI.myOperator);
		self.cmbDischargePort.setObjectFromCode(self.myTI.dischargePort);
		consignor := app.myRoot.allConsigneeConsignors.getAtKey(self.myTI.consignor);
		if consignor &lt;&gt; null then
			self.cmbConsignor.setForObject(consignor);
		endif;
		
	else
		self.resetForm();
	
	endif;
	
epilog

end;</source>
    </JadeMethod>
