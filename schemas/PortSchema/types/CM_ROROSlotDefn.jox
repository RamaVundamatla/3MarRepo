    <JadeMethod name="setForCreate" id="fa78561c-022c-4247-8b78-629ed99b3439">
        <updating/>
        <source>setForCreate(_pxySelf : CM_ROROSlotDefn) updating;
/*
Purpose:			
Date		Who		Reason
19 April 2011	cnwab1	Initial creation
*/

vars

begin

	self.code := _pxySelf.code;
	self.description := _pxySelf.description;
	self.remarks := _pxySelf.remarks;
	
	self.ordinal := _pxySelf.ordinal;
	self.isAvailable := _pxySelf.isAvailable;
	self.hasOther := _pxySelf.hasOther;
	
	if _pxySelf.myROROLocnDen.isTransient() then
		self.myROROLocnDen := _pxySelf.myROROLocnDen.pxyGetRealObject();
	else
		self.myROROLocnDen := _pxySelf.myROROLocnDen;
	endif;
	
	self.myDeck := self.myROROLocnDen.myDeck;
epilog

end;</source>
        <Parameter name="_pxySelf" type="CM_ROROSlotDefn"/>
    </JadeMethod>
