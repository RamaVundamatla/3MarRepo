    <JadeMethod name="imExStatusToString" id="0758d04e-6e08-4a17-b92a-d7d02c0ef157">
        <source>imExStatusToString(_ti:CM_TrackedItem) : String;
//
// 14/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
//
vars
	imexString:String;
begin
	// CCMS 5158 treat generators differently for Maersk
	//epr par 37551 refactoring 18/2/16
	if _ti.isKindOf(CM_Generator) then
		return null;
	endif;
	
	if _ti.isRehandle and not _ti.isARework then
		imexString := "7";  //Domestic? local change for Maersk
	elseif _ti.isSOB and not _ti.isARework then
		imexString := "5";  //Shifter
	//elseif _ti.isExport then							// PAR #25021
	elseif _ti.isExport or _ti.isTranshipOutbound then	// PAR #25021
		imexString := "2";
	elseif _ti.isStorage then//for Coarri a storage has been imported
		imexString := "3";
	//elseif _ti.isImport then							// PAR #25021
	elseif _ti.isImport or _ti.isTranshipInbound then	// PAR #25021
		imexString := "3";
	else
		imexString := "";
	endif;
	return imexString;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
