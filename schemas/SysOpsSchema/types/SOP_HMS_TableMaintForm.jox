    <JadeMethod name="cmbChkPointType_click" id="86961859-ea07-4b90-a788-96863a04cd10">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbChkPointType_click(combobox: ComboBox input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	16 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tidalType			: Integer;
	
begin
	app.mousePointer	:=	Busy;
	
	if combobox.listIndex = CNEC_NULL_INDEX then
		return;
	endif;
	
	tidalType := combobox.itemData[combobox.listIndex];
	self.myAssistant.comboBoxHMSTidalModelDef(self.cmbTidalModel, tidalType, self.cmbTidalModel.listObject.HMS_TidalModelDefinition);
	self.tblInput1.setValueByName(ETRow_TidalModel, self.cmbTidalModel.text);
	self.showTidalTypeRows(tidalType);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
