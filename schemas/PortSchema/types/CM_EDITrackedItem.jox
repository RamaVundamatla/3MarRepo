    <JadeMethod name="addCustomsSeal" id="79286ca8-9f3e-4e1e-96c8-3076109288a7">
        <source>addCustomsSeal(_sealNum: String);
//----------------------------------------------------------------
//	Created:	13 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 30 Apr 2019	jlgrs1	TFS40086 JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal
//
vars
	theNumber	: String;
begin
	theNumber :=  _sealNum.trimBlanks;
	
	if theNumber &lt;&gt; null then
		self.setSealsAsObjects(theNumber, SealType_Customs);
	endif;
end;</source>
        <Parameter name="_sealNum" type="String"/>
    </JadeMethod>
    <JadeMethod name="addImCodes" id="361a18d1-b723-40cb-81d3-33941a49ed07">
        <source>addImCodes(_value : String; _imCodes : StringArray input) protected;
/* 
---------------------------------------------------------------------------
 Created:     J Harliwich               

 Purpose:     MES 1008	Previously only CM_EDIPreNoteTI had imcodes, now we can have on booking ref so make flexible,
						cannot hard code CM_EDIPreNoteTI anymore

 Parameters:  The code to be added to the array

 Changed On   Changed By  Reason
 ----------   ----------  --------------------------------------------------
02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
05 Apr 2012	cnwrs1		Par 29391 - EDI RORO Stowage Advice hazard codes
30 May 2013	cnwcs5		par 31626 - changed parameter usage
 ---------------------------------------------------------------------------
*/

vars
	strHaz	: String;
begin
	if _value = null or _imCodes.includes(_value) then
		return;
	endif;
	
	strHaz	:= _value.trimBlanks;
	
	// Each hazard can be delimited by any combination of space(s) or colon(s).
	// Convert all Colons into a Space.
	strHaz := strHaz.cnEcFindReplace(Colon, Space, false);
	strHaz := strHaz.cnEcFindReplace(' +', '+', false);	//par 26798 cnwrs1 26 Jan 2011 
	strHaz := strHaz.cnEcFindReplace('+', ':+', false);	//par 26798 cnwrs1 26 Jan 2011
	strHaz := strHaz.cnEcFindReplace(',', '', false);	//cnwmc5 - 8 Jan 2013 - PAR 31984
	
	
	// Convert all double spaces into 1 space, triming blanks incase started or ended with a colon(s).
	strHaz	:= strHaz.trimBlanks.eliminateContiguous(Space.Character);
	
	if strHaz.pos('(', 1) &gt; 0 then
		self.processHazards(strHaz, _imCodes);
	else
		// Now break this string into the separate hazards delimited by space.
		strHaz.getTokensForDelimiter(Space, _imCodes);
	endif;
epilog

end;
</source>
        <access>protected</access>
        <Parameter name="_value" type="String"/>
        <Parameter name="_imCodes" type="StringArray" usage="input"/>
    </JadeMethod>
