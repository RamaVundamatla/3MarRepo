    <JadeMethod name="click" id="5fda40cd-b13b-4c17-a5b1-301f7e1fe71f">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>click(combobox: ComboBox input) updating, clientExecution;
// -------------------------------------------
// Created 21 December 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	self.myObject := self.listObject;
	inheritMethod(combobox);


end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
