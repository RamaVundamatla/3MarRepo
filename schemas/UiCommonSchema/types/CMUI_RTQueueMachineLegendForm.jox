    <JadeMethod name="doSearch" id="fa460de4-0cff-4d87-af76-eeba838fc0bb">
        <source>doSearch() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2011	#cnwdz2	 27747

*/

vars
	tableObj	: Table;
	rowStart	: Integer;
	rowCount	: Integer;
	rowPointer	: Integer;
	searchFor	: String;
	cellText	: String;
	colSearch	: Integer;
begin
	searchFor	:=	self.cnEcGetUserInput("Find Text", "Enter the text to search for:", null);
	
	if searchFor = null then
		return;
	endif;
	
	tableObj	:=	self.tblDetails;
	rowStart	:=	tableObj.fixedRows + 1;
	rowCount	:=	tableObj.rows;
	tableObj.clearAllSelected();

	colSearch := 1;
	foreach rowPointer in rowStart to rowCount do
		cellText	:=	tableObj.getCellText(rowPointer, colSearch);
		
		if cellText.toLower().pos(searchFor.toLower(), 1) &gt; 0 then
			tableObj.row := rowPointer;
			break;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getDetailForDisplay" id="18c1a4ad-aba8-4323-994d-f8e0abc752f8">
        <source>getDetailForDisplay(_array: HugeStringArray input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2011	#cnwdz2	 27747

*/
vars

begin

	if _array = null then
		return false;
	endif;
	
	//_array.add(app.getErrorString(Operator), self.operatorCode);
	_array.add(app.getErrorString(RTQMachineTableIconColourGrey) &amp; Tab &amp; app.getErrorString(RTQMachineTableIconGreyMean));
	_array.add(app.getErrorString(RTQMachineTableIconColourRed) &amp; Tab &amp; app.getErrorString(RTQMachineTableIconRedMean));
	_array.add(app.getErrorString(RTQMachineTableIconColourGreen) &amp; Tab &amp; app.getErrorString(RTQMachineTableIconGreenMean));
	_array.add(app.getErrorString(RTQMachineTableAnnotateM) &amp; Tab &amp; app.getErrorString(RTQMachineTableAnnotateMMean));
	_array.add(app.getErrorString(RTQMachineTableAnnotateSecQ) &amp; Tab &amp; app.getErrorString(RTQMachineTblAnnotateSecQMean));
	_array.add(app.getErrorString(RTQMachineTableAnnotateMoveOut) &amp; Tab &amp; app.getErrorString(RTQMachineTblAnnotateMOutMean));
	_array.add(app.getErrorString(RTQMachineTableAnnotateMoveIn) &amp; Tab &amp; app.getErrorString(RTQMachineTblAnnotateMInMean));
	_array.add(app.getErrorString(RTQMachineTableAnnotateMove) &amp; Tab &amp; app.getErrorString(RTQMachineTblAnnotateMoveMean));
	_array.add(app.getErrorString(RTQMachineTblAnnotateWorkSecQ) &amp; Tab &amp; app.getErrorString(RTQMachineTblAnnotWorkSecQMean)); 
	
	return true;

end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
