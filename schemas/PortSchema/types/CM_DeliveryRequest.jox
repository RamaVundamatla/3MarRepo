    <JadeMethod name="numberOfWleQueued" id="46b767a5-0772-44d7-845e-dfe18f9d16cc">
        <source>numberOfWleQueued() : Integer;
// -------------------------------------------
// Created 25 May 2005 by cnwdvb1
// -------------------------------------------
vars

	wle		: CM_WorkListEntry;
	count	: Integer;

begin

	foreach wle in self.allWorkListEntries discreteLock do
		if not wle.allRTQueueEntries.isEmpty() then
			count := count + 1;
		endif;
	endforeach;
	return count;


end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="59f37f6a-f1da-4fdc-a4f0-f9027fe89b72">
        <source>pxyCreateUpdateProxy(): SelfType;

// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxyRequest	: CM_DeliveryRequest;
	idArray : StringArray;
	completedOK		: Boolean;
begin

	proxyRequest := inheritMethod();

	create idArray transient;
	self.getIds(idArray);
	proxyRequest.setIds(idArray);
	proxyRequest.clean := self.clean;
	proxyRequest.consignee := self.consignee;
	proxyRequest.isoGroup := self.isoGroup;  //cnwrd1 22.12.09
	proxyRequest.heavyRated := self.heavyRated;
	proxyRequest.isoType := self.isoType;
	proxyRequest.myOperatorGroup := self.myOperatorGroup;
	proxyRequest.myCargoType := self.myCargoType;		
	proxyRequest.operatorCode := self.operatorCode;
	proxyRequest.totalRequested := self.totalRequested;
// cnwdad1 03/08/2009 - PAR #20410.
	proxyRequest.mySubTerminalSource	:=	self.mySubTerminalSource;
	proxyRequest.setNominatedTAs( self.allTerminalAreas, self.allTerminalAreaGridObj); //cnwrd1 par 24169  3.6.2010
	proxyRequest.isBestPick := self.isBestPick;
	proxyRequest.isFIFO := self.isFIFO; //cnwrd1 par 24169  3.6.2010
	
	// sfw1035 cnwjk3
	proxyRequest.mySubCargoType := self.mySubCargoType;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyRequest;
epilog
	delete idArray;
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyRequest;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="removeBulkReleaseTI" id="20bb5f58-792d-4440-95fc-34aac71bacb2">
        <updating/>
        <source>removeBulkReleaseTI(_ti : CM_TrackedItem input)updating;
// ---------------------------------------------------------------------------
// Created:		22 July 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//11 Mar 2024 jlier1  BUG 60770 - Issues unassigning cargo that was previously assigned .
vars

begin
	inheritMethod(_ti);
	//if self.isAnyAmount and self.isAnyId then
	//if (self.isAnyAmount and _ti.isCar) and not self.isAnyId then	//21 Sep 2017	NDL	TFS 7053
		//epr TFS 5597 don't remove if any id and any amount
	//else
	if self.myReserveDetail &lt;&gt; null  then // ### CCMS 1282 AKB2004NOV
		self.myReserveDetail.removeTIAssigned(_ti);
	endif;
//	endif;
	
	if self.allTrackedItemsAllocated.includes(_ti) then
		self.allTrackedItemsAllocated.remove(_ti);
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="returnJob" id="7b0d28e2-cf29-4f28-b90b-b72519d51814">
        <updating/>
        <source>returnJob(_newJob: CM_Job) updating;
//--------------------------------------------------------------
//Created: 02 April 2003 By: cnwgd1
//--------------------------------------------------------------
// self.validateForReturnJob should have been done before we get here
// therefore must be OK to split off the actioned form the unactioned WLEs
vars

begin
	inheritMethod(_newJob);
	self.splitUnactionedWLEs(_newJob);
end;</source>
        <Parameter name="_newJob" type="CM_Job"/>
    </JadeMethod>
    <JadeMethod name="set" id="0ed827a1-0c2e-42ed-bec7-50678ef9d26b">
        <updating/>
        <source>set(pConsignee,
	pConsignorVoyageCode,
	pDeliveryNumber,
	pEirNumber,
	pIsoType,
	pOperatorCode : String;
	pOperatorGroup : CM_OperatorGroup;
	pCargoType : CM_CargoType;
	pClean,
	pDoISOGrpCheck : Boolean;
	pDoorsDirection: Integer;
	pHeavyRated,
	pIsReceipt, 
	pNeedCOU,
	pNeedGenerator,
	pRemoveStops : Boolean; 
	pTotalRequested,
	pReasonCode : Integer;
	pGrades : IntegerArray;
	pReasonCodeDescr,
	pRemarks : String;
	pIds : CM_Strings;
	pPinNo : String;
	pTransToTerminal: CM_Terminal;
	_br : CM_BulkRelease;
	pSubTerminalSource : CM_SubTerminal;	// cnwdad1 02/07/2009 - CCMS 1735. - added setting of mySubTerminalSource
	pIsoGroup 		: String;				// MES 1088 JMH 29/9/09
	pImexStatus : Integer;	// CCMS 1101
	colour: String;    // PAR 32190
	mark: String; // PAR 32190
	bol : String	//18 Feb 2014	NDL	Par 33524
	) updating;

/*

Date		Who		Reason
06 Jul 2015	cnwkpd1	PAR #36578 - Tidy up leaked CM_Strings objects
	
*/
vars
	hugeStrings		: HugeStringArray;
	strings			: StringArray;
	
begin
//	self.raiseExceptionIfNotTransient(method);
	//th2 PAR 14912 - 1090
	if pGrades &lt;&gt; null then
		pGrades.copy(self.allAvailabilityGrades);		//AA 9/4
	endif;
	
	self.consignorVoyageCode	:= pConsignorVoyageCode;
	self.consignee				:= pConsignee;
	
	
	if _br &lt;&gt; null then 																			//cnwas3 par 26675 begin
		self.setMyOriginatingBulkRelease(_br); 		
		self.deliveryNumber := _br.getDeliveryReleaseNumber();
	elseif pDeliveryNumber &lt;&gt; null then
		self.setDeliveryNumber(pDeliveryNumber);	
	endif;
	/*
	// 30/11/2010 cnwmh5 #26400 - Start
	if pDeliveryNumber &lt;&gt; null then
		self.setDeliveryNumber(pDeliveryNumber);
	elseif _br &lt;&gt; null then // ### AKB2005MAY - cope with duplicate codes.
		self.setMyOriginatingBulkRelease(_br); // ### AKB2005MAY - cope with duplicate codes.
		//self.deliveryNumber := _br.code; // ### AKB2005MAY - cope with duplicate codes.
		self.deliveryNumber := _br.getDeliveryReleaseNumber();
	endif;*/																						//cnwas3 par 26675 end
	
	
	self.eirNumber				:= pEirNumber;
	self.isoType				:= pIsoType;
	self.operatorCode			:= pOperatorCode;
	self.myOperatorGroup		:= pOperatorGroup;
	self.myTransferToTerminal	:= pTransToTerminal;
	self.myCargoType			:= pCargoType;
	self.mySubTerminalSource	:= pSubTerminalSource;
	
	self.clean					:= pClean;
	//self.doISOGroupCheck		:= pDoISOGrpCheck;
	self.doorsDirection			:= pDoorsDirection;
	self.heavyRated				:= pHeavyRated;
	// PAR #36578 - reworked to prevent leaks
	if pIds = null then
		delete self.ids;
	else
		create hugeStrings transient;
		pIds.getStrings(hugeStrings);
		create strings transient;
		hugeStrings.copy(strings);
		self.setIds(strings);
	endif;
	self.ids					:= pIds;
	self.isReceipt				:= pIsReceipt;
	self.isoGroup				:= pIsoGroup;			// MES1088 JMH 29/09/09 Add isogroup
	self.imexStatus				:= pImexStatus;
	self.needCOU				:= pNeedCOU;
	self.needGenerator			:= pNeedGenerator;
	self.removeStops			:= pRemoveStops;
	self.pinNo					:= pPinNo;		// ccms1037
	self.setRemarks(pRemarks);
	self.totalRequested			:= pTotalRequested;
	self.colour					:= colour;
	self.mark					:= mark;
	self.billOfLading			:= bol; //18 Feb 2014	NDL	Par 33524

	if pReasonCode &lt;&gt; null then
		self.reasonCode			:= pReasonCode;
	else
		self.reasonCodeDescr	:= pReasonCodeDescr;
	endif;
	
epilog
	delete hugeStrings;
	delete strings;
end;</source>
        <Parameter name="pConsignee" type="String"/>
        <Parameter name="pConsignorVoyageCode" type="String"/>
        <Parameter name="pDeliveryNumber" type="String"/>
        <Parameter name="pEirNumber" type="String"/>
        <Parameter name="pIsoType" type="String"/>
        <Parameter name="pOperatorCode" type="String"/>
        <Parameter name="pOperatorGroup" type="CM_OperatorGroup"/>
        <Parameter name="pCargoType" type="CM_CargoType"/>
        <Parameter name="pClean" type="Boolean"/>
        <Parameter name="pDoISOGrpCheck" type="Boolean"/>
        <Parameter name="pDoorsDirection" type="Integer"/>
        <Parameter name="pHeavyRated" type="Boolean"/>
        <Parameter name="pIsReceipt" type="Boolean"/>
        <Parameter name="pNeedCOU" type="Boolean"/>
        <Parameter name="pNeedGenerator" type="Boolean"/>
        <Parameter name="pRemoveStops" type="Boolean"/>
        <Parameter name="pTotalRequested" type="Integer"/>
        <Parameter name="pReasonCode" type="Integer"/>
        <Parameter name="pGrades" type="IntegerArray"/>
        <Parameter name="pReasonCodeDescr" type="String"/>
        <Parameter name="pRemarks" type="String"/>
        <Parameter name="pIds" type="CM_Strings"/>
        <Parameter name="pPinNo" type="String"/>
        <Parameter name="pTransToTerminal" type="CM_Terminal"/>
        <Parameter name="_br" type="CM_BulkRelease"/>
        <Parameter name="pSubTerminalSource" type="CM_SubTerminal"/>
        <Parameter name="pIsoGroup" type="String"/>
        <Parameter name="pImexStatus" type="Integer"/>
        <Parameter name="colour" type="String"/>
        <Parameter name="mark" type="String"/>
        <Parameter name="bol" type="String"/>
    </JadeMethod>
    <JadeMethod name="setBulkReleaseTI" id="e39f28c6-e06e-4ea2-ac10-3610ea98c840">
        <updating/>
        <source>setBulkReleaseTI(_theTrackedItem: CM_TrackedItem input) updating;
// ---------------------------------------------------------------------------
// Created:		22 July 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 16/12/2011	cnwmh5	#28804 - Add test for Delivery Request's consignee not being null 
// 29/08/2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition
vars

begin
	inheritMethod(_theTrackedItem);
	
	if self.allTrackedItemsAllocated.includes(_theTrackedItem) then
		return;
	endif;
	
	// We currently cannot reserve break-bulk cargo  36127
	if not _theTrackedItem.canMergeBreakBulk then
		self.allTrackedItemsAllocated.add(_theTrackedItem);
	endif;
	
	if self.myReserveDetail &lt;&gt; null  then // ### CCMS 1282 AKB2004NOV
		self.myReserveDetail.addTI(_theTrackedItem);
		self.updateObjectEdition(self.myReserveDetail.myReserveHeader);	// par 30292 //cause an update of the BR
		
	elseif self.myOriginatingBulkRelease &lt;&gt; null then
		self.updateObjectEdition(self.myOriginatingBulkRelease);		// par 30292 //cause an update of the BR
	endif;	
	
	if self.consignee &lt;&gt; null and _theTrackedItem.consignee &lt;&gt; self.consignee then
		app.myUtilityUA.utlUpdateTIConsignee(_theTrackedItem, self.getMyConsignee, app.myPassport);
	endif;
end;</source>
        <Parameter name="_theTrackedItem" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="5acde97c-e268-4dc5-9c86-e8fc1efe476e">
        <updating/>
        <source>setForCreate(pProxyRequest: CM_DeliveryRequest) updating;
// ---------------------------------------------------------------------------
// Created:     22 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 03/07/2009	cnwdad1		CCMS 1735 - added Sub-Terminal.
// 15/10/13 	cnwer1		par 32445 removed allContainerLengths
// 19/10/2022	jlizm1		TFS 54118 Assigning Releases to Wagons
// ---------------------------------------------------------------------------

vars
	idArray			: StringArray;
	theBulkRelease	: CM_BulkRelease;

begin
	self.raiseExceptionIfTransient(method);
	pProxyRequest.raiseExceptionIfNotTransient(method);

	self.commodity			:= pProxyRequest.commodity;
	self.isoGroup 			:= pProxyRequest.isoGroup;
	self.isAnyAmount 		:= pProxyRequest.isAnyAmount;	// TFS 54118
	self.voyageCode 		:= pProxyRequest.voyageCode;
	self.billOfLading 		:= pProxyRequest.billOfLading;
	self.mySubCargoType 	:= pProxyRequest.mySubCargoType;
	self.mark 				:= pProxyRequest.mark;
	self.markNumber 		:= pProxyRequest.markNumber;
	self.description 		:= pProxyRequest.description;
	self.weight 			:= pProxyRequest.weight;
	self.volume 			:= pProxyRequest.volume;
	self.density 			:= pProxyRequest.density;
	self.quantity 			:= pProxyRequest.quantity;
	self.colour 			:= pProxyRequest.colour;
	self.yardInstructions 	:= pProxyRequest.yardInstructions;
	self.width 				:= pProxyRequest.width;
	self.widthString 		:= pProxyRequest.widthString;
	self.length 			:= pProxyRequest.length;
	self.lengthString 		:= pProxyRequest.lengthString;
	self.height 			:= pProxyRequest.height;
	self.heightString 		:= pProxyRequest.heightString;
	self.type 				:= pProxyRequest.type;

	// Do this again here as we need to check that the "remainingQuantity"
	// on the bulk release has not been updated by another release subsequent
	// to doing the validation (typically by another request on the same job)
	//self.validateQuantity(null);
	/*th2 PAR 14996 - this check should already be done in the validation
	theBulkRelease := pProxyRequest.myOriginatingBulkRelease;
	if theBulkRelease &lt;&gt; null then
		if theBulkRelease.getTotalOutstanding &lt; pProxyRequest.totalRequested then
			//app.raiseCMException1(MTRequestExceedsNumBulkRequest, self.myOriginatingBulkRelease.code, 'quantity', null);
			//GD if over releasing  self.myOriginatingBulkRelease will be null so use theBulkRelease instead
			app.raiseCMException1(MTRequestExceedsNumBulkRequest, theBulkRelease.code, 'quantity', null);			
		endif;
	endif;
	*/
	//self.availabilityGrade	:= pProxyRequest.availabilityGrade;
	pProxyRequest.allAvailabilityGrades.copy(self.allAvailabilityGrades);
	self.clean					:= pProxyRequest.clean;
	//self.doISOGroupCheck		:= pProxyRequest.doISOGroupCheck;
	self.heavyRated				:= pProxyRequest.heavyRated;
	self.isoType				:= pProxyRequest.isoType;
	self.imexStatus				:= pProxyRequest.imexStatus;
	self.operatorCode			:= pProxyRequest.operatorCode;
	self.myOperatorGroup		:= pProxyRequest.myOperatorGroup;
	self.totalRequested			:= pProxyRequest.totalRequested;
	self.myCargoType 			:= pProxyRequest.myCargoType;
	self.mySubTerminalSource	:= pProxyRequest.mySubTerminalSource;		// cnwdad1 03/07/2009 - CCMS 1735.
	self.myTILCType				:=pProxyRequest.myTILCType;
	self.allTerminalAreas.clear;
	pProxyRequest.allTerminalAreas.copy(self.allTerminalAreas);
	
	self.allTerminalAreaGridObj.clear; //cnwrd1 ccms 2098
	pProxyRequest.allTerminalAreaGridObj.copy(self.allTerminalAreaGridObj);
	
	create idArray transient;
	pProxyRequest.getIds(idArray);
	self.setIds(idArray);
	
	inheritMethod(pProxyRequest);
epilog
	delete idArray;
end;</source>
        <Parameter name="pProxyRequest" type="CM_DeliveryRequest"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="d00ef056-b732-4b22-9ac9-d18464a8fe94">
        <updating/>
        <source>setForUpdate(pProxyRequest: CM_DeliveryRequest) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 03/07/2009	cnwdad1		CCMS 1735 - added Sub-Terminal.
// 15/10/13 	cnwer1		par 32445 removed allContainerLengths
// 19/10/2022	jlizm1		TFS 54118 Assigning Releases to Wagons
// ---------------------------------------------------------------------------

vars
	idArray		: StringArray;
	lOperator	: CM_Operator;
	
begin
	inheritMethod(pProxyRequest);
	
	self.commodity			:= pProxyRequest.commodity;
	self.isoGroup 			:= pProxyRequest.isoGroup;
	self.isAnyAmount 		:= pProxyRequest.isAnyAmount;	// TFS 54118
	self.voyageCode 		:= pProxyRequest.voyageCode;
	self.billOfLading 		:= pProxyRequest.billOfLading;
	self.mySubCargoType 	:= pProxyRequest.mySubCargoType;
	self.mark 				:= pProxyRequest.mark;
	self.markNumber 		:= pProxyRequest.markNumber;
	self.description 		:= pProxyRequest.description;
	self.weight 			:= pProxyRequest.weight;
	self.volume 			:= pProxyRequest.volume;
	self.density 			:= pProxyRequest.density;
	self.quantity 			:= pProxyRequest.quantity;
	self.colour 			:= pProxyRequest.colour;
	self.yardInstructions 	:= pProxyRequest.yardInstructions;
	self.width 				:= pProxyRequest.width;
	self.widthString 		:= pProxyRequest.widthString;
	self.length 			:= pProxyRequest.length;
	self.lengthString 		:= pProxyRequest.lengthString;
	self.height 			:= pProxyRequest.height;
	self.heightString 		:= pProxyRequest.heightString;
	self.type 				:= pProxyRequest.type;
	
	self.clean 				:= pProxyRequest.clean;
	//self.doISOGroupCheck 	:= pProxyRequest.doISOGroupCheck;
	self.heavyRated 		:= pProxyRequest.heavyRated;
	self.isoType 			:= pProxyRequest.isoType;
	self.imexStatus			:= pProxyRequest.imexStatus;
	self.operatorCode 		:= pProxyRequest.operatorCode;
	self.totalRequested 	:= pProxyRequest.totalRequested;
	self.myOperatorGroup 		:= pProxyRequest.myOperatorGroup;
	self.myCargoType 	 		:= pProxyRequest.myCargoType;
	self.mySubTerminalSource	:= pProxyRequest.mySubTerminalSource;		// cnwdad1 03/07/2009 - CCMS 1735.
	self.myTILCType				:=pProxyRequest.myTILCType; //epr par 34254
	self.allAvailabilityGrades.clear();
	pProxyRequest.allAvailabilityGrades.copy(self.allAvailabilityGrades);
	
	self.allTerminalAreas.clear;											// 25683
	pProxyRequest.allTerminalAreas.copy(self.allTerminalAreas);

	self.allTerminalAreaGridObj.clear; //cnwrd1 ccms 2098
	pProxyRequest.allTerminalAreaGridObj.copy(self.allTerminalAreaGridObj);
	
	create idArray transient;
	pProxyRequest.getIds(idArray);
	self.setIds(idArray);
epilog
	delete idArray;
end;</source>
        <Parameter name="pProxyRequest" type="CM_DeliveryRequest"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_Request" id="bd35f5ce-851c-40b0-b935-f400e0c984ab">
        <updating/>
        <source>setFromCMIF_Request(cmifRequest : CMIF_Request)updating;
//------------------------------------------------------------------------
//Created: 28 March 2003 By: cnwgd1
//------------------------------------------------------------------------
/****Changes

Date		Name	TFS#			Description
==========================================================================
15/11/2010	cnwdap1	PAR #23794 		Update commodity from interaceObj.myReserveDetail.
					CCMS MES 1102 	
03/10/2018	jlgka1	40698			Populate "heavyRated" value from the Request.
19/10/2022	jlizm1	TFS 54118 		Assigning Releases to Wagons

*/
vars
	array	: StringArray;
	resSel 	: CM_ReserveSelection;
begin

	inheritMethod(cmifRequest);

	self.allAvailabilityGrades.clear;	
	cmifRequest.allMTGrades.copy(self.allAvailabilityGrades);
	
	if cmifRequest.idMask &lt;&gt; null then
		create array transient;
		cmifRequest.idMask.convertToDelimitedArray(",", array);
		if (not array.isEmpty) then
			self.setIds(array);		
		endif;
	endif;
		
	self.clean 				:= cmifRequest.clean;
	self.doISOGroupCheck 	:= cmifRequest.doISOGroupCheck;
	self.heavyRated 		:= cmifRequest.heavyRated;
	self.isoType 			:= cmifRequest.isoType;
	self.heavyRated			:= cmifRequest.heavyRated; // jlgka1 40698
	self.isAnyAmount		:= cmifRequest.isAnyAmount;	// TFS 54118
	
	
	// PAR 23877
	if cmifRequest.myReserveDetail &lt;&gt; null 
	and cmifRequest.myReserveDetail.isKindOf(CM_ReserveSelection) then
		resSel := cmifRequest.myReserveDetail.CM_ReserveSelection;
		if resSel.myISOGroup &lt;&gt; null then
			self.isoGroup := resSel.myISOGroup.code;
		endif;
		if self.isoType = null 
		and resSel.myISOType &lt;&gt; null then
			self.isoType  := resSel.myISOType.code;
		endif;
	endif;

	self.operatorCode 		:= cmifRequest.operatorCode;
	self.totalRequested 	:= cmifRequest.quantityTxt;
	self.weightRequested 	:= cmifRequest.weight;	//03 Feb 2016	NDL	Par 37492
	self.myOperatorGroup	:= cmifRequest.myOperatorGroup;
	if CM_CargoType.hasInstance(cmifRequest.myCargoBOLType) then
		self.myCargoType 	:= cmifRequest.myCargoBOLType.CM_CargoType;		
	endif;
	
// cnwdad1 03/08/2009 - PAR #20410.
	if self.myOriginatingBulkRelease &lt;&gt; null then
		self.mySubTerminalSource	:=	self.myOriginatingBulkRelease.mySubTerminal;
	endif;
	
	// PAR #23794 update commodity from originating bulk release
	if cmifRequest.myReserveDetail &lt;&gt; null then
		if (not cmifRequest.myReserveDetail.myReserveHeader.fullRelease) then
			self.commodity	:= self.myTerminal.getDefaultEmptyCommodity();
		endif;
		//03 Feb 2016	NDL	Par 37492
		if cmifRequest.myReserveDetail.isKindOf(CM_ReserveSelection) then
			self.mySubCargoType :=cmifRequest.myReserveDetail.CM_ReserveSelection.myProduct;
			self.colour := cmifRequest.myReserveDetail.CM_ReserveSelection.colour;	//13 Sep 2019	NDL	TFS 46559
			self.mark := cmifRequest.myReserveDetail.CM_ReserveSelection.markSelection;	//13 Sep 2019	NDL	TFS 46559
		endif;
	endif;
	// PAR #23794 end
	
epilog
	delete array;
end;</source>
        <Parameter name="cmifRequest" type="CMIF_Request"/>
    </JadeMethod>
    <JadeMethod name="setFromFlexiGate" id="fef95aec-c5be-4207-a46f-1496f8bfaced">
        <updating/>
        <source>setFromFlexiGate(_consignee,
	_consignorVoyageCode,
	_deliveryNumber,
	_eirNumber,
	_isoType,
	_operatorCode : String;
	_operatorGroup : CM_OperatorGroup;
	_cargoType : CM_CargoType;
	_trailerType : CM_TILCType;
	_clean,
	_doISOGrpCheck : Boolean;
	_doorsDirection: Integer;
	_heavyRated,
	_isReceipt, 
	_needCOU,
	_needGenerator,
	_removeStops : Boolean; 
	_totalRequested,
	_reasonCode : Integer;
	_grades : IntegerArray;
	_reasonCodeDescr,
	_remarks : String;
	_ids : CM_Strings;
	_pinNo : String;
	_transToTerminal: CM_Terminal;
	_br : CM_BulkRelease;
	_subTerminalSource : CM_SubTerminal;
	_customEntryNumber : String;
	_isoGroup : String;
	_voyageCode : String;
	_billOfLading : String;
	_subCargoType: CM_Product;
	_mark : String;
	_markNumber : String;
	_description	: String;
	_weight : Decimal;
	_length : Decimal;
	_volume : Decimal;
	_width 	: Decimal;
	_height : Decimal;
	_widthString : String;
	_heightString : String;
	_lengthString : String;
	_density : Decimal;							// PAR #33606
	_quantity : Integer;
	_colour : String;
	_yardInstructions : String;
	_type : String;
	_commodity : String;
	_reserveDetail : CM_ReserveDetail;
	_imexStatus : Integer;
	_isAnyAmount : Boolean					// ### TFS 65623 (65624) 25Sep2024 NAVPW1
	) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who			Reason
03 September 2009	cnwjk3		sfw1035
15/10/13 			cnwer1		par 32445 removed allContainerLengths
20/03/2014			cnwdap1		PAR #33606 CCM SSFW 1366 Bulk - changed _density parameter from Integer to Decimal
25/09/2024			navpw1		TFS: 65623 (65624) - Added code to set isAnyAmount from the gate entity

*/

vars

begin
	
	self.commodity := _commodity;
	self.customEntryNumber := _customEntryNumber;
	self.isoGroup := _isoGroup;
	self.voyageCode := _voyageCode;
	self.billOfLading := _billOfLading;
	self.mySubCargoType := _subCargoType;
	self.mark := _mark;
	self.markNumber := _markNumber;
	self.description := _description[1:30];
	self.weight := _weight;
	self.length := _length;
	self.volume := _volume;
	self.width := _width;
	self.height := _height;
	self.widthString := _widthString;
	self.heightString := _heightString;
	self.lengthString := _lengthString;
	self.density := _density.Integer;
	self.quantity := _quantity;
	self.colour := _colour;
	self.yardInstructions := _yardInstructions;
	self.type := _type;
	self.myReserveDetail := _reserveDetail;
	self.isAnyAmount	:= _isAnyAmount;			// ### TFS 65623 (65624) 25Sep2024 NAVPW1
	
	self.set(
			_consignee,
			_consignorVoyageCode,
			_deliveryNumber,
			_eirNumber,
			_isoType,
			_operatorCode,
			_operatorGroup,
			_cargoType,
			_clean,
			_doISOGrpCheck,
			_doorsDirection,
			_heavyRated,
			_isReceipt, 
			_needCOU,
			_needGenerator,
			_removeStops, 
			_totalRequested,
			_reasonCode,
			_grades,
			_reasonCodeDescr,
			_remarks,
			_ids,
			_pinNo,
			_transToTerminal,
			_br,
			_subTerminalSource,
			_isoGroup,						  //MES1008 JMH 29/9/09 Add iso group
			_imexStatus,
			_colour,
			_mark,
			_billOfLading	//18 Feb 2014	NDL	Par 33524
			);
			
	//epr par 32092 21/8/13
	self.myTILCType:=_trailerType;
	if self.myTILCType &lt;&gt; null then
		self.myCargoType:=self.myTILCType.myCargoType;
	endif;
epilog

end;</source>
        <Parameter name="_consignee" type="String"/>
        <Parameter name="_consignorVoyageCode" type="String"/>
        <Parameter name="_deliveryNumber" type="String"/>
        <Parameter name="_eirNumber" type="String"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_operatorGroup" type="CM_OperatorGroup"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_trailerType" type="CM_TILCType"/>
        <Parameter name="_clean" type="Boolean"/>
        <Parameter name="_doISOGrpCheck" type="Boolean"/>
        <Parameter name="_doorsDirection" type="Integer"/>
        <Parameter name="_heavyRated" type="Boolean"/>
        <Parameter name="_isReceipt" type="Boolean"/>
        <Parameter name="_needCOU" type="Boolean"/>
        <Parameter name="_needGenerator" type="Boolean"/>
        <Parameter name="_removeStops" type="Boolean"/>
        <Parameter name="_totalRequested" type="Integer"/>
        <Parameter name="_reasonCode" type="Integer"/>
        <Parameter name="_grades" type="IntegerArray"/>
        <Parameter name="_reasonCodeDescr" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_ids" type="CM_Strings"/>
        <Parameter name="_pinNo" type="String"/>
        <Parameter name="_transToTerminal" type="CM_Terminal"/>
        <Parameter name="_br" type="CM_BulkRelease"/>
        <Parameter name="_subTerminalSource" type="CM_SubTerminal"/>
        <Parameter name="_customEntryNumber" type="String"/>
        <Parameter name="_isoGroup" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_billOfLading" type="String"/>
        <Parameter name="_subCargoType" type="CM_Product"/>
