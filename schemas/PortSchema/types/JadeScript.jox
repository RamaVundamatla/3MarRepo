    <JadeMethod name="convertIndextoLineNumber" id="bcaef77b-a6a7-47ca-87f5-e17da13e845f">
        <source>convertIndextoLineNumber();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 July 2022	navtnr20 	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level

*/

vars
	reserveSelection : CM_ReserveSelection;
begin
	beginTransaction;
	foreach reserveSelection in CM_ReserveSelection.instances do
		if reserveSelection.lineNumber = null and reserveSelection.myReserveHeader &lt;&gt; null then
			reserveSelection.setLineNumber(reserveSelection.myReserveHeader.allReserveDetails.indexOf(reserveSelection));
		endif;
	endforeach;
	commitTransaction;
epilog

end;</source>
