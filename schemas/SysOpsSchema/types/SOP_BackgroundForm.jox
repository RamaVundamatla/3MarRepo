    <JadeMethod name="doClearFutureActorMulti" id="28202e27-cc91-4e85-80af-8bd152989d51">
        <updating/>
        <source>doClearFutureActorMulti(_redisplay : Boolean output) protected, updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12/12/2019	jlgdap1		Initial creation TFS 47988 JMT Excessive Windows When Clearing BGP Requests
//
vars
	objArray : CM_ObjectArrayActual;
	rtnValue : Integer;

begin
	create objArray transient;
	self.tblRequest.allSelectedObjects.copy(objArray);
	
	_redisplay := true;
	while true do
		app.myTrxDA.trxDeleteCMObjects(objArray, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			rtnValue := app.showErrorWarningDialog("Deletion", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   rtnValue = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			_redisplay := false;
			break;
		endif;
		break;
	endwhile;

epilog
	delete objArray;
end;</source>
        <access>protected</access>
        <Parameter name="_redisplay" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="doClearFutureActorSingle" id="0dd294f3-805d-4396-8b0a-cdcca464feac">
        <updating/>
        <source>doClearFutureActorSingle(_request : CM_Object io; _redisplay : Boolean io) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12/12/2019	jlgdap1		Initial creation TFS 47988 JMT Excessive Windows When Clearing BGP Requests
//
vars
	rtnValue : Integer;

begin
	_redisplay := true;
	while true do
		app.myTrxDA.trxDeleteCMObject(_request, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			rtnValue := app.showErrorWarningDialog("Deletion", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   rtnValue = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			_redisplay := false;
			break;
		endif;
		break;
	endwhile;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_request" type="CM_Object" usage="io"/>
        <Parameter name="_redisplay" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doClearRequest" id="e7c75df6-7538-45f9-840d-10f54ecbb553">
        <updating/>
        <source>doClearRequest() protected, updating;

// cnwdvb1 17 February 2003 
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 12/12/2019	jlgdap1		TFS 47988 JMT Excessive Windows When Clearing BGP Requests
vars
		
	manager		: BGP_Manager;
	request		: BGP_Request;
	obj			: Object;
	str			: String;
	theReturn : Integer;	
	redisplay : Boolean;
begin
	redisplay := true; // TFS 45464
	
	app.mousePointer := MousePointer_HourGlass;	
	
	// TFS 47988 if we're clearing future actors, process these separately
	if not self.tblRequest.allSelectedObjects.isEmpty and self.tblRequest.allSelectedObjects.first.isKindOf(CM_OfflineFutureActor) then
		if self.tblRequest.allSelectedObjects.size = 1 then
			self.doClearFutureActorSingle(self.tblRequest.allSelectedObjects.first.CM_Object, redisplay);
		else
			self.doClearFutureActorMulti(redisplay);
		endif;
	else
		foreach obj in self.tblRequest.allSelectedObjects do
			// TFS 47988 now done above
			/*//epr TFS 4474 1/6/17
			if obj.isKindOf(CM_OfflineFutureActor) then
			/* TFS 45464 WAS 
				app.myTrxDA.trxDeleteCMObject(obj.CM_Object,app.myPassport);
				if app.myPassport.hasErrors then
					app.showErrorWarningDialog(app.getErrorString(Error), app.myPassport,  ErrWarnMode_Update);
				endif;
				
				NOW adding deletion warning*//*
				while true do
					app.myTrxDA.trxDeleteCMObject(obj.CM_Object,app.myPassport);
					if app.myPassport.trxCompletedOK then
						// Clear errors/warnings from form and err/warnings window
						self.clearErrorWarnings();
						global.beep;
						break;
					else
						theReturn := app.showErrorWarningDialog("Deletion", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
						if app.myPassport.noErrors and
						   theReturn = IDOK then
							// there must have just been warnings that the user has acknoledged so ..
							app.myPassport.warningsAcknowledged	:= true;
							continue;
						endif;
						self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
						redisplay := false; // TFS 45464
						break;
					endif;
					break;
				endwhile;
	
				
			else*/
			request := obj.BGP_Request;
		
			if global.isValidObject(request) then
				manager := BGP_Manager.firstInstance;
				if manager &lt;&gt; null then
					str := manager.doClearSingleRequest(request);
					if str &lt;&gt; null then
						app.msgBox(str,app.getErrorString(Delete_Request), MsgBox_OK_Only + MsgBox_Information_Icon);
					endif;
				endif;
			endif;
			//endif;
		endforeach;
	endif;
	
	if redisplay then // TFS 45464
		self.doDisplay();
	endif;
epilog
	app.mousePointer := MousePointer_Default;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doClonedMenuClickSpecial" id="556c36a2-aac9-4826-b348-7c1153630757">
