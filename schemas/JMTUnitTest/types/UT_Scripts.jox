    <JadeMethod name="uDeleteRRPsForTrain" id="da3ed5f8-e328-430f-8619-48318e02c3d7">
        <source>uDeleteRRPsForTrain();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 March 2020	jlgndl1	Initial creation

*/

vars

	termId : String;
	terminal : CM_Terminal;
	tiSet : CM_TISet;
	rrp: CM_TrackedItem;

begin

	termId := "Enter Terminal Id";
	read termId;
	terminal := app.myRoot.allTerminals.getAtKey(  termId );
	
	self.assertTrueMsg( terminal &lt;&gt; null, "Terminal '" &amp; termId &amp; "' not found");
	
	self.opts.purge();
	self.opts.addAssoc("Terminal",termId );
	self.assertTrueMsg( self.getTerminal = terminal, "getTerminal doesn't return '" &amp; termId &amp; "'");
	
	create tiSet transient;
	terminal.allRRPTIsByCargoTypeId.copy( tiSet );
	
	foreach rrp in tiSet do
		if rrp.isRRPforRail and rrp.myTrainAssigned = null then
			self.deleteTrackedItem( rrp, false );
		endif;
	endforeach;

epilog

	delete tiSet;

end;</source>
    </JadeMethod>
