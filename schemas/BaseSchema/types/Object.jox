    <JadeMethod name="cnEcGetPreviousMethods" id="14fe3510-90ab-4eae-9c15-1d3aab53cae8">
        <source>cnEcGetPreviousMethods(pCallStackArray:ProcessStackArray io);
// --------------------------------------------------------------------------------
// Created:		10 March 2001 by cnwdad1
//
// Purpose:		Use this method for debugging to see where a method has been called
//				from.  The pProcessStack array will be populated with all method
//				calls prior to the one from which this method is called.
//
//				NOTE: The pTheProcessStack array will be populated with transient
//				MethodCallDesc objects, so they must be purged before deleting
//				the pTheProcessStack array object.
//
// Parameters:	pCallStackArray - An array of method call (MethodCallDesc) objects.
//
// Returns:		The populated pTheCallStack array.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 09/06/2008	cnwdad1		Changed to delete the Method Call elements that are
//							removed from the array.
// --------------------------------------------------------------------------------
begin
	// Get the stack for the current process.

	process.currentStack(pCallStackArray);

	// Cut back the stack to the current method.
	
	delete pCallStackArray.removeAt(1);		// Remove the current method call.
	delete pCallStackArray.removeAt(1);		// Remove this method call (i.e. self).
end;</source>
        <Parameter name="pCallStackArray" type="ProcessStackArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetSortKey" id="0054abd1-e512-48ed-bc64-9e5a49b20e1b">
        <source>cnEcGetSortKey():Any;
// --------------------------------------------------------------------------------
// Created:		11 February 2001 by cnwdad1
//
// Purpose:		Returns the value of a member of the CnEcSorter's dynamic dictionary.
//				If this method is invoked from any kind of object other that a
//				CnEcSortKey instance, a 1086 exception will be raised (Class of
//				object is invalid in this context).
//
//				Note that this is slightly slower than casting an Object to the
//				CnEcSortKey class in your logic when iterating through the
//				CnEcSorter.allKeys collection (DynaDictionary).
//
// Parameters:	None
//
// Returns:		The value of the key property corresponding to the type of sort that
//				was requested.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.CnEcSortKey.getKey();
end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetSortKeyWithObject" id="401f3bdf-5b96-45e1-92da-e9e5ff46549f">
        <source>cnEcGetSortKeyWithObject(pObject:Object output):Any;
// --------------------------------------------------------------------------------
// Created:		26 October 2005 by cnwdad1
//
// Purpose:		Returns the value of a member of the CnEcSorter's dynamic dictionary.
//				If this method is invoked from any kind of object other that a
//				CnEcSortKey instance, a 1086 exception will be raised (Class of
//				object is invalid in this context).
//
//				Note that this is slightly slower than casting an Object to the
//				CnEcSortKey class in your logic when iterating through the
//				CnEcSorter.allKeys collection (DynaDictionary).
//
// Parameters:	pObject - A reference to the object associated with the key.
//
// Returns:		The value of the key property corresponding to the type of sort, and
//				any associated data via the output parameters.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.CnEcSortKey.getKeyWithObject(pObject);
end;</source>
        <Parameter name="pObject" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="cnEcIniString" id="b9cbb238-8491-4dee-9a70-a69b2b6c3751">
        <source>cnEcIniString(pSection:String; pItem:String):String;

vars
	itemValue		: String;
	errorMessage	: String;

begin
	itemValue	:=	app.getProfileString(global.cnGetServerIniFileName(), pSection, pItem, "");
	
	if itemValue = null then
		errorMessage	:=	"Warning: " &amp; "'" &amp; pSection &amp; ":" &amp; pItem &amp; "' not defined in " &amp; global.cnGetServerIniFileName();
		self.cnEcLog(errorMessage);
		write errorMessage;
	endif;
	
	return itemValue;
end;</source>
        <Parameter name="pSection" type="String"/>
        <Parameter name="pItem" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcInspect" id="7f7ee940-8ee9-43d0-a28a-42fbe3d8e9aa">
        <source>cnEcInspect();
// -----------------------------------------------------------------------------
// Created:		31 October 2001 by cnwdad1
//
// Purpose:		This method displays an inspector window for the receiver object.
//				The inspector contains split panes showing the receiver's
//				properties and values, plus workspace code can be entered and
//				executed against the receiver.
//
//				Using this method, the inspector window will be shown non-modally.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	inspectorFormObj	: CnEcObjectInspectorForm;
	
begin
	create inspectorFormObj;
	inspectorFormObj.setObject(self);
	inspectorFormObj.show();
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcInspectModal" id="185617a2-88da-40fe-82fb-88d51f086221">
        <source>cnEcInspectModal();
// -----------------------------------------------------------------------------
// Created:		01 November 2001 by cnwdad1
//
// Purpose:		This method displays an inspector window for the receiver object.
//				The inspector contains split panes showing the receiver's
//				properties and values, plus workspace code can be entered and
//				executed against the receiver.
//
//				Using this method, the inspector window will be shown modally.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	inspectorFormObj	: CnEcObjectInspectorForm;
	
begin
	create inspectorFormObj;
	inspectorFormObj.setObject(self);
	inspectorFormObj.showModal();
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcIsGUI" id="30303972-2ff8-46b2-8b1f-0fcbc9cdb3d5">
