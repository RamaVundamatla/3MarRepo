    <JadeMethod name="doAlignment" id="cc88faae-3027-40a7-b001-5d4d610748bd">
        <updating/>
        <source>doAlignment(_position : Integer) updating;
/*
Purpose:			
Date		Who		Reason
14 April 2011	cnwab1	Initial creation
*/

vars
	alignor : CMIF_RectangleAlignor;
	obj : Object;
	tmpDeckItemLayout : CM_Graphic;
begin
	if self.myCurrentProxyLayerLayout = null then
		return;
	endif;
	
	create alignor;

	foreach obj in self.frmScrollable.myDrawingFrame.CMUI_PointDrawingFrame.allPointGraphics discreteLock do
		tmpDeckItemLayout := obj.CM_Graphic;
		alignor.addGraphic(tmpDeckItemLayout);
	endforeach;
	
	alignor.doAlignment(_position);

	self.myCurrentProxyLayerLayout.causeEvent(EVENT_RORO_LAYER_UPDATE,true,null);
	
	// PAR 27773
	self.btnMultiSelect.value := false;
	self.doSetMultiSelectMode(self.mnuGrpMulti);

epilog
	delete alignor;
end;</source>
        <Parameter name="_position" type="Integer"/>
    </JadeMethod>
