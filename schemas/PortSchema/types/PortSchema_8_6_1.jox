    <JadeMethod name="createSecRoleInvStatuses" id="719a1ce7-01ca-4675-8575-99d0d7e5a638">
        <source>createSecRoleInvStatuses( _updController : CnEcReleaseController );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2019	jlgndl1	Initial creation	TFS 39618

*/

vars

	secRoleTerm : CM_SecurityRoleTerminal;
	invoiceStatus : CM_InvoiceStatus;

begin

	if self.hasScriptBeenRunAtAll(method.name, _updController) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Create Invoice Process and Invoice Status defaults", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Create Invoice Process and Invoice Status defaults") ;	
	endif;
	
	beginTransaction;
	
//	foreach secRoleTerm in CM_SecurityRoleTerminal.instances do
//		secRoleTerm.allInvoiceStatusesMaint.clear();	//During testing to reset the incorrectly over populated roles
//	endforeach;

	//add all invoice status to the Terminal root security role
	foreach invoiceStatus in app.myRoot.allInvoiceStatuses do
		app.myRoot.mySecurityRoleTerminal.allInvoiceStatusesMaint.addNoDuplicates(invoiceStatus, false);
	endforeach;
	
	foreach secRoleTerm in CM_SecurityRoleTerminal.instances do
		secRoleTerm.convertOldInvoiceStauses();
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Create Invoice Process and Invoice Status defaults complete", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Create Invoice Process and Invoice Status defaults complete") ;	
	endif;
	
	self.addScriptRun(method.name);

epilog

end;</source>
