    <JadeMethod name="showRoRoLaneAreasForm" id="6bd854fb-1e18-4acb-8dd1-7f2fd0bb1501">
        <source>showRoRoLaneAreasForm(_obj : Object; _viewMode : Integer; _masterMenuAction : CMUI_MenuAction );

/*

Purpose:			Show RoRo Lane Areas for given  Controllers.

Parameters:			_obj is a CM_RoRoLaneArea

Return Value:		


Date				Who		Reason
3  December 20009	cnwjk3	Initial creation
*/

vars
	enqForm 		: Form;
	aClass 			: Class;
	assistClass 	: Class;
	jrw 			: Schema;
	obj 			: Object;
	terminalAreas 	: CM_TerminalAreaSet;
	dock 			: Object;
begin
	jrw := rootSchema.getSchema("YardSchema");
	aClass := jrw.getClass("YRD_RoRoLaneAreasForm");
	assistClass := jrw.getClass("YRD_Assistant");
	
	enqForm := app.loadForm(aClass, assistClass, false, false, true, self.myTerminal, _masterMenuAction);
	if enqForm = null then
		return;
	endif;

	if _obj = null then
		return;
	endif;

	create terminalAreas transient;
	//terminalAreas.add(_obj.CM_RoRoLaneArea);
	
	//20 Jan 2012	NDl	Par 28901
	if _obj.isKindOf ( CM_RoRoLaneArea ) then				
		terminalAreas.add(_obj.CM_RoRoLaneArea);
	elseif _obj.isKindOf ( CM_ObjectArray ) then
		foreach obj in _obj.CM_ObjectArray do
			if obj.isKindOf ( CM_RoRoLaneArea ) then
				terminalAreas.addNoDuplicates( obj.CM_RoRoLaneArea, false );
			elseif obj.isKindOf ( CM_RoRoController ) then
				terminalAreas.addNoDuplicates( obj.CM_RoRoController.myRoRoLaneArea, false );
			endif;
		endforeach;
	endif;
	
	if terminalAreas.isEmpty then
		return;
	endif;

	enqForm.sendMsgWithParams("setViewMode",_viewMode);
	enqForm.sendMsgWithParams("setAllTerminalAreas",terminalAreas);
	enqForm.show(); 

epilog
	delete terminalAreas;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_viewMode" type="Integer"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
