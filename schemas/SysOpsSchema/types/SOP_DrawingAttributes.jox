    <JadeMethod name="translateForm" id="676a77ab-0843-4428-976c-322d4e2aad68">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 08 January 2018 09:35:52.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017682, locale);
	btnAdd.translateBubbleHelp(Xlat_0003842, locale);
	btnAdd.translateCaption(Xlat_0003843, locale);
	btnCancel.translateCaption(Xlat_0003844, locale);
	btnNewSave.translateCaption(Xlat_0003841, locale);
	btnPriority.translateCaption(Xlat_0022177, locale);
	lblNew.translateCaption(Xlat_0003845, locale);
end;</source>
    </JadeMethod>
</GUIClass>
