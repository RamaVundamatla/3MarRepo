    <JadeMethod name="doUserNotes" id="655bc729-72c7-47a3-8ac1-013a91cedabc">
        <updating/>
        <source>doUserNotes(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

vars
	temrinal		: CM_Terminal;
	breakOut		: Boolean;
	batchNo,
	idx				: Integer;
	checkScaleBatch	: CM_LogCheckScaleHdr;
	tbl				: CM_DataTable;
	numRows,
	row				: Integer;
	tmpObj			: Object;
begin
	
	if eventType = EVENT_CHECKSCALE_CREATE then
		if theObject &lt;&gt; null then
			if self.includeObject(theObject, app.myPassport) then
				self.addObjectToTable(theObject, idx, breakOut);
			endif;
		endif;
		
	elseif eventType = EVENT_CHECKSCALE_DELETE then
		batchNo := userInfo.Integer;
		tbl := self.tblData;
		numRows := tbl.rows;
		foreach row in tbl.fixedRows + 1 to numRows do
			tmpObj := tbl.accessRow(row).itemObject;
			if CM_LogCheckScaleHdr.hasInstance(tmpObj) and
			   tmpObj.CM_LogCheckScaleHdr.batchNo = batchNo then
				checkScaleBatch := tmpObj.CM_LogCheckScaleHdr;
				break;
			endif;
		endforeach;
		if checkScaleBatch &lt;&gt; null then
			self.zTblDataSysNotifyDelete(eventType, checkScaleBatch, null);
		endif;
	endif;


end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="editCheckScaleDetail" id="33de3736-a19c-49ab-bd25-62686fb3fa03">
        <source>editCheckScaleDetail() protected;
// ---------------------------------------------------------------------------
// Created:     15 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	conditionCode			: CM_Code;
begin
	if self.myCurrentObject = null then
		app.msgBox('Please select a check scaling header first','Nothing selected',0);
		return;
	endif;
	
	if self.myCurrentScaleDtl = null then
		app.msgBox('Please select a check scaling detail to edit','Nothing selected',0);
		return;
	endif;
	
	self.loadConditionCodes();
	
	self.tblEntDetail.setValueByName(ETRow_LogId, self.myCurrentScaleDtl.logId);
	self.tblEntDetail.setValueByName(ETRow_CheckSEDMin, self.myCurrentScaleDtl.checkSEDMin.Integer);
	self.tblEntDetail.setValueByName(ETRow_CheckSEDMax, self.myCurrentScaleDtl.checkSEDMax.Integer);
	
	conditionCode := app.myRoot.allLogConditionCodes[self.myCurrentScaleDtl.checkConditionCode];
	if conditionCode &lt;&gt; null then
		self.tblEntDetail.setValueByName(ETRow_CheckConditionCode, conditionCode.code);
		self.cmbCondition.listObject := conditionCode;
	endif;
		
	self.showModalFrame();
	self.lblEntDetail.caption := 'Enter details:';

	self.cmbScaler.visible := false;
	self.tblEntDetail.visible := true;
	self.tblEntDetail.setFocus;
	self.tblEntDetail.moveFirst();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="editCheckScaler" id="88a75810-226d-4686-90c5-577b992ab7a7">
        <source>editCheckScaler() protected;
// ---------------------------------------------------------------------------
// Created:     15 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	scaler		: CM_User;
	indxList	: Integer;  // cnwrd1 par #18228 22.10.08
begin
	if self.myCurrentObject = null then
		app.msgBox('Please select a check scaling batch header before continuing','Nothing selected', 0);
		return;
	endif;
	
	self.showModalFrame();
	self.tblEntDetail.visible := false;
	self.doLoadCmbScaler();
	
	scaler := app.myRoot.allUsers[self.myCurrentObject.CM_LogCheckScaleHdr.userCode];
	
	if scaler = null then
		self.cmbScaler.listIndex := 1; 	
	else
		indxList := self.cmbScaler.findObject( scaler ) ; 	// cnwrd1 par #18228 22.10.08 ++
		self.cmbScaler.listIndex := indxList;  				// cnwrd1 par #18228 22.10.08 ++
		//self.cmbScaler.listObject := scaler;				 // cnwrd1 par #18228 22.10.08 --
	endif;
	
	
	self.lblEntDetail.caption := 'Select a scaler:';
	self.cmbScaler.visible := true;
	self.cmbScaler.setFocus();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getDefaultReport" id="ee762ef9-b272-42fb-b7d4-38026e1f2f0c">
        <source>getDefaultReport(_rptName : String) : CM_QryReport protected;
// ---------------------------------------------------------------------------
// Created:     20 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	menuItemDict				: CM_MenuItemByTypeMenuIdDict;
	menuItem					: CM_MenuItem;
	qryReport					: CM_QryReport;
begin
	menuItemDict := app.myRoot.myReportMenuRoot.allMenuItems;
	
	foreach menuItem in menuItemDict do
		if not menuItem.isKindOf(CM_QryReport) then
			continue;
		endif;
		
		if menuItem.CM_QryReport.reportName = _rptName then
			qryReport := menuItem.CM_QryReport;
			break;
		endif;
	endforeach;
	
	return qryReport;	
	

end;</source>
        <access>protected</access>
        <Parameter name="_rptName" type="String"/>
        <ReturnType type="CM_QryReport"/>
    </JadeMethod>
