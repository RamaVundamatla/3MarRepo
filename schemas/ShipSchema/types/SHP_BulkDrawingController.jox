    <JadeMethod name="setModes" id="0a8d7474-9674-44dd-9a5f-dcc8b02f9e73">
        <updating/>
        <source>setModes(_displayMode, _imexMode, _workingMode : Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	config : CMIF_ConfigUserVoyagePlanning;

begin
	if self.displayMode &lt;&gt; _displayMode then
		self.setDisplayMode(_displayMode);
		self.setAttrPositions(_displayMode);
	endif;

	self.imexMode := _imexMode;
	self.workingMode := _workingMode;

	config := self.myConfig;
	self.otherSlotColor := config.shipOtherSlotColor;
	self.showColorOthers := 0;
epilog

end;</source>
        <Parameter name="_displayMode" type="Integer"/>
        <Parameter name="_imexMode" type="Integer"/>
        <Parameter name="_workingMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setToNULL" id="eb26f9db-3971-4bb0-bd66-9adcd463c096">
