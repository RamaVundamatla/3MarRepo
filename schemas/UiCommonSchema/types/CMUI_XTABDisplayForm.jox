    <JadeMethod name="doGenerateXTAB" id="4df9b7e4-9c6f-47ca-a58e-d5c24d196452">
        <updating/>
        <source>doGenerateXTAB() : Boolean updating, protected;

/*

Purpose:		
Parameters:		
Return Value:	returns false if user pressed cancel

Date				Who		Reason
30 January 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	cmifMonitor : CMIF_Monitor;
//	reportFormatName : String;
	translation	: XLAT_Translation;
	rawCaptionObject : XLAT_FormCaption;
	
begin
	// add the defintion name to the form caption and generate the display.
	self.caption := null;	//27 Nov 2009	NDL	Par 21539 - need to clear this
							// as we could be returning to the form with a different summary.
							
	self.translateCaption( Xlat_0009236, self.getLocale );
	if self.caption = null then	//27 Nov 2009	NDL	Par 21539
		// translate didn't find a translated version for this locale. 
		//original was cleared so we need to re-populate with default value.
		rawCaptionObject := app.myRoot.allXLAT_TranslatableText.getAtKey(XLAT_FormCaptions, Xlat_0009236).XLAT_FormCaption;
		self.caption := rawCaptionObject.vDefaultMessage;
	endif;

	self.setCaption( self.caption &amp; ' [' &amp; myProxyOutputFormat.name &amp; ']' );
	
	// For some reason changing the TAB value does not reset the table sheets size so do it here.
	self.tblMain.sheets	:= 1;
	
	// Setup the progress bar
	delete app.myPassport.myCMIFMonitor;
	create cmifMonitor transient;
	app.myPassport.setMyCMIFMonitor( cmifMonitor );
	cmifMonitor.myParent	:= self;
	self.frmModalDialog.zOrder( 1 );
	self.modalDialogShow2(	null,
							null,
							null,
							app.getErrorString( Cancel ),
							app.getErrorString( CMUI_Retreiving_Data ),
							cmifMonitor.message,
							true );
	self.modalDialogProgressBar( self.myCollection.size );
	
	if not self.myOutputFormatAgent.generateXTAB(	self.myProxyOutputFormat,
													self.myCollection,
													self.tblMain,
													cmifMonitor ) then
		// clear table as may have some data half displayed.
		self.tblMain.rows		:= 0;
		self.tblMain.columns	:= 0;
		return false;
	endif;
	
	return true;
	
epilog
	delete cmifMonitor;
	app.myPassport.setMyCMIFMonitor( null );
	self.frmModalDialog.visible	:= false;
	self.modalDialogReturnValue	:= null;
	
end;
</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
