        <type name="String"/>
    </Constant>
    <Constant name="WhenToDeleteNull" id="f785343b-a654-48ca-bf13-2f62e111903f">
        <source>0</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="WhenToDeleteNullStr" id="a50da567-92c4-43b1-8398-de28275f2d21">
        <source>""</source>
        <type name="String"/>
    </Constant>
    <ExplicitInverseRef name="myRoot" id="72b00a1d-2552-47b2-a409-0d480bbf3d4a">
