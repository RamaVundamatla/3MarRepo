    </JadeMethod>
    <JadeMethod name="getConfig" id="6f3b08bd-10fa-4220-aab8-84b7ea20c2e0">
        <source>getConfig(_code : String) : Any;
// ---------------------------------------------------------------------------
// Created:     19 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 21/09/2011	cnwdap1		PAR #28223 CCMS MSL 1024 added "Record Extra Edit Info" config options
// 05/12/2016	cnwdap1		TFS 3039 SNO Empty Container Pool Management
vars

begin

	if _code = WeighExports then
		return self.weighExports;
	elseif _code = WeighImports then
		return self.weighImports;
	elseif _code = WeighMTImports then
		return self.weighMTImports;
	elseif _code = WeighMTExports then
		return self.weighMTExports;
	elseif _code = WeighTranships then
		return self.weighTranships;
			
	elseif _code = AllReceivalRestrictions then		// 25/05/2009 cnwar2 CCMS1040/#19796
		return self.allReceivalCutoffOpTerms;
	//cnwjo3 ccms 1039 par 22315.  don't know why all the other constants are doubled up.  I'm just using an Enttable here
	elseif _code = ETRow_RestrictCargoBookEdits then
		return self.restrictCargoBookingEdits;
		
	// PAR #28223 start
	elseif _code = RecordExtraEditInfoExports then
		return self.recordExtraEditExports;
	elseif _code = RecordExtraEditInfoImports then
		return self.recordExtraEditImports;
	elseif _code = RecordExtraEditInfoStorage then
		return self.recordExtraEditStorage;
	elseif _code = RecordExtraEditInfoTranships then
		return self.recordExtraEditTranships;
	// PAR #28223 end
	
	elseif _code = ETRow_PoolParty then								// TFS 3039
		return self.myPoolingParty;									// TFS 3039
	elseif _code = ETRow_IsExternallyMonitored then 		//epr TFS 3581 6/3/17 
		return self.isExternallyMonitored;
	endif;	
	
	return null;
end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getDictForTISite" id="d58c0fb8-a6c8-4031-b3ca-692a0504054b">
        <source>getDictForTISite(_site : Integer; _haveId : Boolean) : Dictionary;
// ---------------------------------------------------------------------------
// Created:     30 July 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
begin
	
	if _site = TI_SITE_ONSITE then 
		if _haveId then
			return self.allOnsiteTIsByIdCargoType;
		else
			return self.allOnsiteTIsByCargoTypeId;
		endif;

	elseif _site = TI_STATE_TBA then 
		if _haveId then
			return self.allTbaTIsByIdCargoType;
		else
			return self.allTbaTIsByCargoTypeId;
		endif;
		
	elseif _site = TI_SITE_PLACEHOLDER then //13 Mar 2020	NDL	TFS 47004
		if _haveId then
			return self.allRRPTIsByIdCargoType;
		else
			return self.allRRPTIsByCargoTypeId;
		endif;

	elseif _site = TI_SITE_OFFSITE then
		if _haveId then
			return self.allOffsiteTIsByIdCargoType;
		else
			return self.allOffsiteTIsByCargoTypeId;
		endif;
	//th2 added 08/05/2007 for PAR 14021 - pre-notifys
	elseif _site = TI_SITE_UNDEFINED then
		if _haveId then
			return self.allNotifiedTIsByIdCargoType;
		else
			return self.allNotifiedTIsByCargoTypeId;
		endif;
		
	endif;
	
end;</source>
        <Parameter name="_site" type="Integer"/>
        <Parameter name="_haveId" type="Boolean"/>
        <ReturnType type="Dictionary"/>
    </JadeMethod>
    <JadeMethod name="getDictForTIState" id="f950bd6b-47b2-4716-8467-eed1977406e0">
        <source>getDictForTIState(pState : Integer; pHaveId : Boolean) : Collection;
// ---------------------------------------------------------------------------
// Created:     27 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	
	if pState = TI_STATE_NORMAL then 
		if pHaveId then
			return self.allOnsiteTIsByIdCargoType;
		else
			return self.allOnsiteTIsByCargoTypeId;
		endif;

	elseif pState = TI_STATE_NOTIFIED then
		if pHaveId then
			return self.allNotifiedTIsByIdCargoType;
		else
			return self.allNotifiedTIsByCargoTypeId;
		endif;

	elseif pState = TI_STATE_TBA then 
		if pHaveId then
			return self.allTbaTIsByIdCargoType;
		else
			return self.allTbaTIsByCargoTypeId;
		endif;
		
	elseif pState = TI_STATE_PLACEHOLDER then //13 Mar 2020	NDL	TFS 47004
		if pHaveId then
			return self.allRRPTIsByIdCargoType;
		else
			return self.allRRPTIsByCargoTypeId;
		endif;

	elseif pState = TI_STATE_DELETED then 
		if pHaveId then
			return self.allDeletedTIsByIdCargoType;
		else
			return self.allDeletedTIsByCargoTypeId;
		endif;
	else
		if pHaveId then
			return self.allOffsiteTIsByIdCargoType;
		else
			return self.allOffsiteTIsByCargoTypeId;
		endif;
		
	endif;
	
end;</source>
        <Parameter name="pState" type="Integer"/>
        <Parameter name="pHaveId" type="Boolean"/>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="init" id="14bee4aa-b02e-4c7b-ad83-d2c716ba9038">
        <updating/>
        <source>init(_operator : CM_Operator; _terminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     08 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myOperator		:= _operator;
	self.myTerminal		:= _terminal;

end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="fd073f37-ca0c-4e93-ae42-41c2673813d2">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
11 June 2009	cnwar2	Initial creation
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
21/12/2016		cnwdap1	TFS 3039 SNO Empty Container Pool Management
*/

vars
	pxyOpTerm 	 : CM_OperatorTerminal;
	recCutoff,
	pxyRecCutoff : CM_ReceivalCutoffOpTerm;
	completedOK		: Boolean;
	
begin
	pxyOpTerm := inheritMethod();
	
	foreach recCutoff in self.allReceivalCutoffOpTerms do
		create pxyRecCutoff transient;
		pxyRecCutoff.setValues(pxyOpTerm, recCutoff.myReceivalCutoffTermDef, recCutoff.defaultRelativeTo, recCutoff.defaultCutoff, recCutoff.defaultEarliestReceival, 
								recCutoff.defaultCutoffPN, 	//04/03/2025	navkc1 JIRA Story MTN-34227
								recCutoff.defaultEarliestReceivalPN); 	//04/03/2025	navkc1 JIRA Story MTN-34227
	endforeach;
	
	pxyOpTerm.myPoolingParty := self.myPoolingParty;							// TFS 3039
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyOpTerm;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyOpTerm;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="recordExtraLiftInfo" id="4345c335-82a7-427b-9903-14ab4229203e">
        <source>recordExtraLiftInfo(_imexStatus : Integer) : Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/11/2011	cnwdap1	Initial creation PAR #28223 CCMS MSL 1024 Extralift handling
*/
vars

begin
	if _imexStatus = TI_IMEX_STATUS_EXPORT and self.recordExtraEditExports then
		return true;
	elseif _imexStatus = TI_IMEX_STATUS_IMPORT and self.recordExtraEditImports then
		return true;
	elseif _imexStatus = TI_IMEX_STATUS_TRANSHIP and self.recordExtraEditTranships then
		return true;
	elseif _imexStatus = TI_IMEX_STATUS_STORAGE and self.recordExtraEditStorage then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_imexStatus" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectBookingRefTIs" id="bbc4ea67-1fd6-4ee5-80f4-303b3178d8c7">
        <source>selectBookingRefTIs(pVoyageCode : String; pReceiveDT : TimeStamp) : Integer;
// ---------------------------------------------------------------------------
// Created:     27 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	br 			: CM_BookingRef;
	checkVoyage,
	checkReceipt : Boolean;
	voyage 		: CM_Voyage;
	ti 			: CM_TrackedItem;

begin

	voyage := self.myTerminal.lookupVoyage(pVoyageCode, null, false);
	checkVoyage := (voyage &lt;&gt; null);
	checkReceipt := (pReceiveDT &lt;&gt; null);
	
	foreach br in self.allBookingRefsByRef do
		if checkVoyage and br.myVoyage &lt;&gt; voyage then
			continue;		//Ignore this b/r		
		endif;
		
		if checkReceipt then
			foreach ti in br.allTIs do
				if ti.receivedDT &lt;&gt; null and ti.receivedDT &gt; pReceiveDT then
					app.allReportTIs.add(ti);
				endif;
			endforeach;
		else
			br.allTIs.copy(app.allReportTIs);
		endif;			
		
	endforeach;
	return app.allReportTIs.size;
end;</source>
        <Parameter name="pVoyageCode" type="String"/>
        <Parameter name="pReceiveDT" type="TimeStamp"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setConfig" id="e49adbad-f6cd-4936-8291-d03852820130">
        <updating/>
        <source>setConfig(_cmif	: CMIF_OperatorTerminalConfig) updating;
// ---------------------------------------------------------------------------
// Created:     19 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 21/09/2011	cnwdap1		PAR #28223 CCMS MSL 1024 added "record extra edit info" flags
// 05/12/2016	cnwdap1		TFS 3039 SNO Empty Container Pool Management
vars
	recCutoff : CM_ReceivalCutoffOpTerm;
	defRelativeTo	: Integer;
	defCutoff		: Decimal[7,2];
	defEarliest		: Decimal[7,2];
	cutoffDateTimePN	: Decimal[7,2]; //04/03/2025	navkc1 JIRA Story MTN-34227
	earliestDateTimePN	: Decimal[7,2]; //04/03/2025	navkc1 JIRA Story MTN-34227
begin
	self.weighImports 			:= _cmif.weighImports;
	self.weighExports 			:= _cmif.weighExports;
	self.weighMTExports			:= _cmif.weighMTExports;
	self.weighMTImports			:= _cmif.weighMTImports;
	self.weighTranships 		:= _cmif.weighTranships;
	//th2 PAR 14641
//	self.freeStorageDays 		:= _cmif.freeStorageDays;
//	self.fullFreeStorageDays 	:= _cmif.fullFreeStorageDays;
//	self.emptyFreeStorageDays 	:= _cmif.emptyFreeStorageDays;
	
	//cnwjo3 ccms 1039 par 22315
	self.restrictCargoBookingEdits := _cmif.restrictCargoBookingEdits;
	
	// 25/05/2009 cnwar2 CCMS1040/#19796
	foreach recCutoff in _cmif.allReceivalCutoffs do
		defRelativeTo	:= recCutoff.defaultRelativeTo;
		defCutoff		:= recCutoff.defaultCutoff;
		defEarliest		:= recCutoff.defaultEarliestReceival;
		cutoffDateTimePN:= recCutoff.defaultCutoffPN; //04/03/2025	navkc1 JIRA Story MTN-34227
		earliestDateTimePN := recCutoff.defaultEarliestReceivalPN; //04/03/2025	navkc1 JIRA Story MTN-34227
		if self.allReceivalCutoffOpTerms[recCutoff.myReceivalCutoffTermDef] &lt;&gt; null then
			recCutoff := self.allReceivalCutoffOpTerms[recCutoff.myReceivalCutoffTermDef];
		endif;
		recCutoff.setValues(self, recCutoff.myReceivalCutoffTermDef, defRelativeTo, defCutoff, defEarliest, 
							cutoffDateTimePN, 		//04/03/2025	navkc1 JIRA Story MTN-34227
							earliestDateTimePN); 	//04/03/2025	navkc1 JIRA Story MTN-34227
	endforeach;
	
	// PAR #28223 start
	self.recordExtraEditExports		:= _cmif.recordExtraEditInfoExports;
	self.recordExtraEditImports		:= _cmif.recordExtraEditInfoImports;
	self.recordExtraEditStorage		:= _cmif.recordExtraEditInfoStorage;
	self.recordExtraEditTranships	:= _cmif.recordExtraEditInfoTranships;
	// PAR #28223 end
	
	self.myPoolingParty := _cmif.myMTPoolParty;						// TFS 3039
	self.isExternallyMonitored  := _cmif.isExternallyMonitored;		//epr TFS 3581 3/6/17
end;</source>
        <Parameter name="_cmif" type="CMIF_OperatorTerminalConfig"/>
    </JadeMethod>
    <JadeMethod name="setFromProxy" id="385f46f1-2c8d-4961-9f53-e862c8537b7a">
        <updating/>
        <source>setFromProxy(_pxy : CM_OperatorTerminal) updating;
/* ---------------------------------------------------------------------------
// Created:     19 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 21/09/2011	cnwdap1		PAR #28223 CCMS MSL 1024 added "record extra edit info" flags
// 06/03/2012	cnwcs5		par 29158 - EDI Booking cutoffs
30 Apr 2012		cnwer1		PAR 29487 - default cutoff and earliest is derived on the ti if not overridden no need to update all voyages in the system
// 05/12/2016	cnwdap1		TFS 3039 SNO Empty Container Pool Management
*/
vars
	pxyCutoffDef, 
	realCutoffDef		: CM_ReceivalCutoffOpTerm;
begin
	self.weighImports 			:= _pxy.weighImports;
	self.weighExports 			:= _pxy.weighExports;
	self.weighMTExports			:= _pxy.weighMTExports;
	self.weighMTImports			:= _pxy.weighMTImports;
	self.weighTranships 		:= _pxy.weighTranships;
	//th2 PAR 14641
//	self.freeStorageDays 		:= _pxy.freeStorageDays;
//	self.fullFreeStorageDays 	:= _pxy.fullFreeStorageDays;
//	self.emptyFreeStorageDays 	:= _pxy.emptyFreeStorageDays;
	
	//ccms 1039 par 22315 cnwjo3
	self.restrictCargoBookingEdits := _pxy.restrictCargoBookingEdits;
	

	foreach pxyCutoffDef in _pxy.allReceivalCutoffOpTerms do
		realCutoffDef := self.allReceivalCutoffOpTerms[pxyCutoffDef.myReceivalCutoffTermDef];
		
		if realCutoffDef = null or 
			realCutoffDef.defaultCutoff &lt;&gt; pxyCutoffDef.defaultCutoff or 
			realCutoffDef.defaultEarliestReceival &lt;&gt; pxyCutoffDef.defaultEarliestReceival or 
			realCutoffDef.defaultRelativeTo &lt;&gt; pxyCutoffDef.defaultRelativeTo or
			realCutoffDef.defaultCutoffPN &lt;&gt; pxyCutoffDef.defaultCutoffPN or //04/03/2025	navkc1 JIRA Story MTN-34227
			realCutoffDef.defaultEarliestReceivalPN &lt;&gt; pxyCutoffDef.defaultEarliestReceivalPN //04/03/2025	navkc1 JIRA Story MTN-34227
			then
		endif;
		
		if realCutoffDef = null then
			create realCutoffDef persistent;
		endif;
		
		realCutoffDef.setValues(self, pxyCutoffDef.myReceivalCutoffTermDef, pxyCutoffDef.defaultRelativeTo, pxyCutoffDef.defaultCutoff, pxyCutoffDef.defaultEarliestReceival, 
								pxyCutoffDef.defaultCutoffPN, 		//04/03/2025	navkc1 JIRA Story MTN-34227
								pxyCutoffDef.defaultEarliestReceivalPN); 	//04/03/2025	navkc1 JIRA Story MTN-34227
	endforeach;
	
	// PAR #28223 start
	self.recordExtraEditExports		:= _pxy.recordExtraEditExports;
	self.recordExtraEditImports		:= _pxy.recordExtraEditImports;
	self.recordExtraEditStorage		:= _pxy.recordExtraEditStorage;
	self.recordExtraEditTranships	:= _pxy.recordExtraEditTranships;
	// PAR #28223 end
	
	self.myPoolingParty := _pxy.myPoolingParty;						// TFS 3039
	self.isExternallyMonitored := _pxy.isExternallyMonitored;		// epr TFS 3581 6/3/17
epilog

end;</source>
        <Parameter name="_pxy" type="CM_OperatorTerminal"/>
    </JadeMethod>
