    </JadeMethod>
    <JadeMethod name="valMachineAcceptTask" id="88928f33-d80b-4742-a02f-3b7aa7a7adb1">
        <source>valMachineAcceptTask(	_machine : CM_Machine;
						_rtQueueTask,
						_twinRTQueueTask: CM_RTQueueTask;
						_isTandemLift	: Boolean;
						_checkMachineAssign : Boolean;
						_checkRestrictedAccess : Boolean);
/*

Date		Who		Reason
09 May 2017	cnwer1	Initial creation TFS 995 refactored from MobileServerSchema CM_ValidationAgent::valAcceptTask
17 May 2019 cnwma1	Bug 44062: JMT - Vehicle App - Tandem Driver Move
*/

vars

	str : String;
	errorString : String;
	messageLogger : CM_MachineRTQueueEntryLogger;
	config: CM_RTVehicleConfig;
begin
	if _machine = null then
		return;  //don't raise error anymore.  The valMediator() will pick up this error
	endif;

	if _rtQueueTask = null then
		if not _checkMachineAssign then
			app.raiseCMException(Machine_not_work_task,null,null);
		else
			app.raiseCMException2(ERR_ALERT_NOTASKS,_machine.id,null,null,null);
		endif;
		// TFS 3082 exit to avoid 1090 in the code below
		return;
	endif;
	
	if _rtQueueTask.machine &lt;&gt;  null and _rtQueueTask.machine &lt;&gt; _machine then
		app.raiseCMException2(ERR_MACH_BUSY,_rtQueueTask.machine.id,_rtQueueTask.queueId,null,null);
	endif;	
	
	create messageLogger transient;
	if _checkMachineAssign then
		//epr CCMS 1099 6/5/10 changed to used  queryMachineAssign this a better validation than machine.canMachineMoveTI 
		
		if not _rtQueueTask.queryMachineAssign(_machine,false,true,false,_checkRestrictedAccess,true,messageLogger) then
			if messageLogger &lt;&gt; null then
				if messageLogger.allMessages.size &gt; 0 then
					str := messageLogger.allMessages.first();  //its only 1 error message but this will definetely help the operator
				endif;
			endif;
			app.raiseCMException2(ERR_MACH_ASSIGN, _machine.id.trimRight, "Machine is unsuitable. " &amp; str, null, null); // PAR 17043
		endif;
	endif;
	
	if _twinRTQueueTask &lt;&gt; null then
		
		//epr par 20701 - if it is an IMV then can always twin carry
		if _isTandemLift then
			if not _machine.isTandemLift then
				if not _machine.isTwinLift then   // CCMS SFW 1210
					app.raiseCMException1(ERR_MACH_NOT_TANDEM,_machine.id, null,null);	
				endif;
			endif;
		else
			if (not _machine.machineType = MACHINETYPE_IMV and
				not _machine.isTwinLift ) 	then
				app.raiseCMException1(ERR_MACH_NOT_TWIN, _machine.id, null,null);	
			endif;
		endif;
		if _twinRTQueueTask.machine &lt;&gt;  null and _twinRTQueueTask.machine &lt;&gt; _machine then
			app.raiseCMException2(ERR_MACH_BUSY,_twinRTQueueTask.machine.id,_twinRTQueueTask.queueId,null,null);
		endif;	
		
	
		//epr CCMS 1099 6/5/10 changed to used  queryMachineAssign this a better validation than machine.canMachineMoveTI 
		messageLogger.allMessages.clear;
		if _checkMachineAssign then
			if not _twinRTQueueTask.queryMachineAssign(_machine,false,true,false,_checkRestrictedAccess,true,messageLogger) then
				if messageLogger &lt;&gt; null then
					if messageLogger.allMessages.size &gt; 0 then
						str := messageLogger.allMessages.first();  //its only 1 error message but this will definetely help the operator
					endif;
				endif;
				app.raiseCMException2(ERR_MACH_ASSIGN, _machine.id.trimRight, "Machine is unsuitable. " &amp; str, null, null); // PAR 17043
			endif;
		endif;
		
		if not _isTandemLift and not  _machine.checkTwinCarryTwoTasks(_rtQueueTask,_twinRTQueueTask,true,errorString) then
		
			if errorString &lt;&gt; null then
				app.raiseCMException2(ERR_MACH_ASSIGN, _machine.id.trimRight, errorString, null, null);  // 27090
			endif;
		endif;

		if _isTandemLift  then //17.05.2019 cnwma1 Bug #44062
			config := _machine.myTerminal.getRTVehicleConfigForObject(_machine);		// 21/11/19 MAP TFS47394
			if (config = null or not config.allowTandemToDiffTargets) and _twinRTQueueTask.targetLocation &lt;&gt; _rtQueueTask.targetLocation then
				app.raiseCMException3(Tandem_lift_locations, _rtQueueTask.targetLocation.getFullId, _twinRTQueueTask.targetLocation.getFullId,app.getErrorString(Locations_different), null, null);
			endif;
		endif;
		
	endif;
	
epilog
	delete messageLogger;

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_rtQueueTask" type="CM_RTQueueTask"/>
        <Parameter name="_twinRTQueueTask" type="CM_RTQueueTask"/>
        <Parameter name="_isTandemLift" type="Boolean"/>
        <Parameter name="_checkMachineAssign" type="Boolean"/>
        <Parameter name="_checkRestrictedAccess" type="Boolean"/>
    </JadeMethod>
