    <JadeMethod name="doFilterTable" id="f6bc30f1-246b-44be-ade5-faa319a9a3e5">
        <source>doFilterTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
25 July 2025		jlizm1	Initial creation MTN 35372 Add table filter to auto schedule form

*/

vars
	filterText 	: String;
	
begin
	filterText := self.frmTableFilter.txtFilterBox.text.toUpper();
	
	if (filterText = "") then
		self.frmTableFilter.btnClearFilter.enabled := false;
	else
		self.frmTableFilter.btnClearFilter.enabled := true;
	endif;
	
	self.frmTableFilter.myDataTable.topRow := 1;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doListBoxCargoBuild" id="b543c688-0594-4b46-a0ba-c1534f57ec2a">
        <updating/>
        <source>doListBoxCargoBuild() updating;
// ---------------------------------------------------------------------------
// Created:		November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	aCargoType : CM_CargoType;
	idx : Integer;
	object			: Object;
	terminalArea	: CM_TerminalArea;
	anArray : ObjectArray;
begin
	self.lstCargoTypes.rows := 0;
	self.lstCargoTypes.zOrder(1);
	foreach aCargoType in app.myRoot.allCargoTypesById do
		// from 31981 skip not-available-for-entry cargo types
		if aCargoType.isNotAvailableForEntry then
			continue;
		endif;
		self.lstCargoTypes.addItemObject(aCargoType.abbreviation &amp; " - " &amp; aCargoType.description,aCargoType);
		
		// #################
		// DEFAULT TO CONTAINER
		if aCargoType.id = TI_CargoType_Container then
			self.lstCargoTypes.rowChecked(lstCargoTypes.rows);

			if not self.lstCargoTypes.allSelectedObjects.includes(aCargoType) and aCargoType &lt;&gt; null then
				self.lstCargoTypes.allSelectedObjects.add(aCargoType);
			endif;


		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doListBoxTermAreaBuild" id="28577ee1-6d0e-4ca5-890d-8178b0ea6d9f">
        <updating/>
        <source>doListBoxTermAreaBuild(_terminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:		November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	aTerminalAreaMaster : CM_TerminalAreaMaster;
	idx : Integer;
	ls : Boolean;
	object			: Object;
	terminalArea	: CM_TerminalArea;
	passport : CM_Passport;
	failedDAC  :CM_DataAccessController;
begin
	passport := app.myPassport;
	self.lstTermArea.zOrder(1);
	self.lstTermArea.rows := 0;
	
	if _terminal = null then
		return;
	endif;
	
	app.cmsBeginLoad(ls);
	foreach aTerminalAreaMaster in _terminal.allTerminalAreaMastersById 
				where aTerminalAreaMaster.type  = TA_TYPE_STRADDLE_STACK
				or aTerminalAreaMaster.type = TA_TYPE_FORK_LIFT_STACK
				or aTerminalAreaMaster.type = TA_TYPE_RTG
				or aTerminalAreaMaster.type = TA_TYPE_RMG 
					do
		if aTerminalAreaMaster.canUserAccessSelf(null, failedDAC, passport) then
			idx := self.lstTermArea.addItemObject(aTerminalAreaMaster.getID(),aTerminalAreaMaster); // &amp; " - " &amp; aTerminalAreaMaster.typeString
			self.lstTermArea.accessRow(idx).backColor := White;
			self.lstTermArea.accessRow(idx).foreColor := Black;
		endif;
	endforeach;
	app.cmsEndLoad(ls);
	self.lstTermArea.userInputEnabled := true;
epilog
	endLoad;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
