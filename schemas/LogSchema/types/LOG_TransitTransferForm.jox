    <JadeMethod name="resetDistances" id="cd1469f8-8ce0-47a7-976a-c4ebbf3ddeec">
        <source>resetDistances() protected;

vars

	difference : Real;

begin

	
	self.tblSelectData.top := (self.tblSelection.top + self.tblSelection.height + VerticalSpacing);
	
	difference := self.tblActionData.top - (self.tblSelectData.top + self.tblSelectData.height);
	difference := difference - VerticalSpacing;
	self.tblSelectData.height	:= self.tblSelectData.height + difference;

	if self.selection = SPECS
	or self.selection = LOGID then
		self.btnSearchT.enabled	:= true;
		// PAR11630 no valid for log ID option
		if (not self.optLogID.value) then
			self.btnResetT.enabled	:= true;
		else
			self.btnResetT.enabled	:= false;
		endif;
	else
		self.btnSearchT.enabled	:= false;
		self.btnResetT.enabled	:= false;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="selectAll" id="87a63192-9bd1-47b1-8770-bfb36e2ace1e">
        <source>selectAll(_all : Boolean) protected;

vars

	cell 	: JadeTableCell;
	firstEntryRow,
	row		: Integer;		

begin
	firstEntryRow := self.tblSelectData.fixedRows + 1;

	foreach row in 2 to self.tblSelectData.rows do
		cell := self.tblSelectData.accessCell(row, 1);
		cell.text := _all.Integer.String;
	endforeach;

	if _all and self.tblSelectData.rows &gt;= firstEntryRow then
		self.tblSelectData.clearAllSelected();
		self.tblSelectData.selectRow(firstEntryRow, true);
		self.tblSelectData.row := firstEntryRow;
		self.doTblSelectDataClick();
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setButtons" id="b9c7be65-3438-4b32-b2d7-c2cb7c938bb1">
        <updating/>
        <source>setButtons(_value : Boolean) protected, updating;

vars

begin

	self.btnSaveBase.enabled	:= _value;
	self.btnNextT.enabled		:= _value;
	self.btnSelectAllT.enabled	:= _value;
	self.btnSelectNoneT.enabled	:= _value;

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnSaveBase.enabled	:= false;
		self.btnNextT.enabled		:= false;
		self.btnSelectAllT.enabled	:= false;
		self.btnSelectNoneT.enabled	:= false;

	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
