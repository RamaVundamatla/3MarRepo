    <JadeMethod name="hasCurrentRTQueueEntry" id="d4fc4a88-cea2-4eea-bb7c-4755cde5cb4c">
        <source>hasCurrentRTQueueEntry(_rtQueueEntries : CM_RTQueueEntryArray) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 May 2010	cnwer1	Initial creation

*/

vars
	rtQueueTask : CM_RTQueueTask;
begin
	if _rtQueueEntries = null then
		return false;
	endif;
	
	if self.allCurrentQueueTasks.isEmpty then
		return false;
	endif;
	
	foreach rtQueueTask in self.allCurrentQueueTasks discreteLock do
		if _rtQueueEntries.includes(rtQueueTask.myEntry) then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_rtQueueEntries" type="CM_RTQueueEntryArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
