end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormResize" id="7d80e4d4-f65c-4799-b005-7615c40b801a">
        <source>doFormResize() protected;
// --------------------------------------------------------------------------------
// Created:		18 January 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	fraMenuRule.move(1, 1, self.width, fraMenuRule.height);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doReadInitializationOptions" id="8bbeefef-799e-4112-8c7f-1ff03e8a1580">
        <source>doReadInitializationOptions() protected;
// --------------------------------------------------------------------------------
// Created:		22 November 2001 by cnwdad1
//
// Purpose:		This method will read the window sizing settings from the client's
//				initialization file, and set the File|Options menu checks accordingly.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	keyValue	: String;
	isKeyValue	: Boolean;
	
begin
	keyValue	:=	app.getProfileString(	app.getIniFileName(),
											self.getApplicationIniSection(),
											INI_ENTRY_MAIN_WIN_MAX,
											"true");
	
	mnuJSSFileOptionsMain.checked	:=	(keyValue = true.String);
	
	keyValue	:=	app.getProfileString(	app.getIniFileName(),
											self.getApplicationIniSection(),
											INI_ENTRY_CHILD_WIN_MAX,
											"false");
	
	mnuJSSFileOptionsChild.checked	:=	(keyValue = true.String);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSaveInitializationOptions" id="e73b8875-0cfb-4ef8-8298-1df49208c3be">
        <source>doSaveInitializationOptions() protected;
// --------------------------------------------------------------------------------
// Created:		22 November 2001 by cnwdad1
//
// Purpose:		This method will save the window sizing settings from the File|Options
//				menu checks, to the client's initialization file.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.setProfileString(	app.getIniFileName(),
							self.getApplicationIniSection(),
							INI_ENTRY_MAIN_WIN_MAX,
							mnuJSSFileOptionsMain.checked.String);
	
	app.setProfileString(	app.getIniFileName(),
							self.getApplicationIniSection(),
							INI_ENTRY_CHILD_WIN_MAX,
							mnuJSSFileOptionsChild.checked.String);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowForm" id="98beb7e1-0686-47af-a0b8-d4e6fb342456">
        <source>doShowForm(pTheNewForm: GUIClass input):Form protected;
// --------------------------------------------------------------------------------
// Created:		22 November 2001 by cnwdad1
//
// Purpose:		Refer to the superclass implementation of this method.  The purpose
//				of this reimplementation is to first load the form, by inheriting
//				the behaviour of the superclass implementation, and then to set
//				the window states according to the settings in the client's
//				initialization file.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theChildForm	: Form;
	
begin
	theChildForm				:=	inheritMethod(pTheNewForm);
	theChildForm.windowState	:=	self.getChildWindowState();
	theChildForm.resize();
epilog
	return theChildForm;
end;</source>
        <access>protected</access>
        <Parameter name="pTheNewForm" type="GUIClass" usage="input"/>
        <ReturnType type="Form"/>
    </JadeMethod>
    <JadeMethod name="getApplicationIniSection" id="bd71e599-1295-45fc-8069-5159c95188dc">
        <source>getApplicationIniSection():String protected;
// --------------------------------------------------------------------------------
// Created:		02 May 2002 by cnwdad1
//
// Purpose:		This method should be reimplemented on subclass forms to return a
//				unique identifier for an Initialization File section, in which
//				the client's options for window sizing are stored.
//
// Parameters:	None
//
// Returns:		The unique Initialization File section name.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return null;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getChildWindowState" id="fc796e06-2a2c-47ef-bac9-9ef28c06f37c">
        <source>getChildWindowState():Integer protected;
// --------------------------------------------------------------------------------
// Created:		22 November 2001 by cnwdad1
//
// Purpose:		Returns the current state of the MDI child's window size option.
//
// Parameters:	None
//
// Returns:		One of two JADE constant values, either Form.WindowState_Maximized
//				or Form.WindowState_Normal.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	childState		: Integer;
	
begin
	if mnuJSSFileOptionsChild.checked then
		childState			:=	Form.WindowState_Maximized;
	else
		childState			:=	Form.WindowState_Normal;
	endif;
epilog
	return childState;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initializeWindowStates" id="c3bb3fc9-6874-4c8e-a253-52cf20531c72">
        <updating/>
        <source>initializeWindowStates() updating, protected;
// --------------------------------------------------------------------------------
// Created:		22 November 2001 by cnwdad1
//
// Purpose:		This method will set/initialize the current state of the window
//				panes.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theChildForm	: Form;
	
begin
	if mnuJSSFileOptionsMain.checked then
		self.windowState	:=	Form.WindowState_Maximized;
	else
		self.windowState	:=	Form.WindowState_Normal;
	endif;
	
	theChildForm	:=	self.activeChild();
	
	if theChildForm &lt;&gt; null then
		theChildForm.windowState	:=	self.getChildWindowState();
		theChildForm.resize();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="menuDisplay" id="6ca50695-cef8-46f0-bfb7-e38e2da6e74b">
        <source>menuDisplay(pMessage:String; pIsClosed:Boolean);
// --------------------------------------------------------------------------------
// Created:		06 October 2001 by cnwdad1
//
// Purpose:		Use this method in the "select" event method of a menu property to
//				display a message in the status bar of the MDI frame.
//
// Parameters:	pMessage - The message to display in the caption bar.
//				pIsClosed - The boolean flag from the menu's "select" event method.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pIsClosed then
		staStatus.caption	:=	self.CAPTION_READY;
	else
		staStatus.caption	:=	" " &amp; pMessage;
	endif;
end;</source>
        <Parameter name="pMessage" type="String"/>
        <Parameter name="pIsClosed" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mnuJSSFileExit_click" id="5b5e5956-9654-4e93-9055-d8e5cdf02889">
