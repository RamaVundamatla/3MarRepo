    <JadeMethod name="doSave" id="ef9cf88e-38fa-4e9d-90d8-8290bb8f5366">
        <updating/>
        <source>doSave() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2014	cnwndl1	Initial creation

*/

vars

	success : Boolean;
	load : Boolean;
	wellId : String;
	numUnits : Integer;
	wellIdArray : StringArray;
	overallLength : Decimal[16,4];
	overallWidth : Decimal[16,4];
	deckHeight : Decimal[16,4];
	maxCargoHeight : Decimal[16,4];
	maxLoadWeight : Decimal[16,4];
	tareWeight : Decimal[16,4];
	
	pxy : CM_WagonWellDefinition;
	warningsResult : Integer;
	mess : String;

begin

	wellId := self.txtWellId.text;
	numUnits := self.txt10FootUnits.text.Integer;
	wellIdArray := self.txtLocations.text.cnGetTokens(",");
	overallLength := self.tblExtLength.getConvertedValue;
	overallWidth := self.tblExtWidth.getConvertedValue;
	deckHeight := self.tblDeckHeight.getConvertedValue;
	maxCargoHeight := self.tblCargoHeight.getConvertedValue;
	maxLoadWeight := self.tblMaxCWeight.getConvertedValue;
	tareWeight := self.tblTare.getConvertedValue;
	
	if wellIdArray = null or wellIdArray.size &lt;&gt; numUnits then
		mess := app.getErrorString2(Number_must_match_number, self.lblLength.caption, self.lblLocations.caption);
		app.msgBox(mess, app.getErrorString(Error), MsgBox_OK_Only);
		return;
	endif;
	
	app.cmsBeginLoad(load);
	pxy := self.myWagonWellDef.pxyCreateUpdateProxy();
	app.cmsEndLoad(load);
	
	pxy.setProxy(	deckHeight,	//_deckHeight : Decimal;			
					numUnits,	//_lenInUnits : Integer;
					maxCargoHeight,	//maxCargoHeight : Decimal;
					maxLoadWeight,	//_maxLoadWeight : Decimal;
					overallLength,	//_overallLength : Decimal;
					overallWidth,	//_overallWidth : Decimal;
					tareWeight,	//_tareWeight : Decimal;
					wellId,	//_wellId : String;
					wellIdArray	//_wellLocations : StringArray
					);
					
	while true do
	
		app.myTrxUA.trxUpdateWagonWellDef(pxy, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			success := true;
			break;
			
		else
			warningsResult := app.showErrorWarningDialog(pxy.wellId, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if warningsResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
	
	endwhile;
	
	
	if success then
		if self.isBaseFormModal then
			self.modalResult := IDOK;
		endif;
		self.unloadForm;
	endif;

epilog

	delete wellIdArray;
	delete pxy;

end;</source>
    </JadeMethod>
    <JadeMethod name="loadData" id="88337f89-29ac-46f3-9ae6-d80a80925af1">
        <source>loadData();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2014	cnwndl1	Initial creation	Par 35346

*/

vars

begin

	self.txtWellId.text := self.myWagonWellDef.wellId;
	self.txt10FootUnits.text := self.myWagonWellDef.lenInUnits.String;
	self.txtLocations.text := self.myWagonWellDef.wellLocationIds.asCSV(false);
	self.tblExtLength.setValues(app.convertMeasurementForDisplay(self.lengthType.shortName, self.myWagonWellDef.overallLength) &amp; Space &amp; self.lengthType.shortName);
	self.tblExtWidth.setValues(app.convertMeasurementForDisplay(self.widthType.shortName, self.myWagonWellDef.overallWidth) &amp; Space &amp; self.widthType.shortName);
	self.tblDeckHeight.setValues(app.convertMeasurementForDisplay(self.heightType.shortName, self.myWagonWellDef.deckHeight) &amp; Space &amp; self.heightType.shortName);
	self.tblCargoHeight.setValues(app.convertMeasurementForDisplay(self.heightType.shortName, self.myWagonWellDef.maxCargoHeight) &amp; Space &amp; self.heightType.shortName);
	self.tblMaxCWeight.setValues(app.convertMeasurementForDisplay(self.weightType.shortName, self.myWagonWellDef.maxLoadWeight) &amp; Space &amp; self.weightType.shortName);
	self.tblTare.setValues(app.convertMeasurementForDisplay(self.weightType.shortName, self.myWagonWellDef.tareWeight) &amp; Space &amp; self.weightType.shortName);

	if self.myWagonWellDef.allWellcarWellVisits.isEmpty then
		self.txt10FootUnits.enabled := true;
		self.txtLocations.enabled := true;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyWagonWellDef" id="bb7e0598-dd8e-41a6-a48e-c4e18a6bcf9e">
        <updating/>
        <source>setMyWagonWellDef( _myWagonWellDef : CM_WagonWellDefinition; _form : SOP_WagonPositionRuleForm ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2014	cnwndl1	Initial creation

*/

vars

begin

	self.myWagonWellDef := _myWagonWellDef;
	self.myWagonClassMaintForm := _form;

epilog

end;</source>
        <Parameter name="_myWagonWellDef" type="CM_WagonWellDefinition"/>
        <Parameter name="_form" type="SOP_WagonPositionRuleForm"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="3f987419-a42a-4ef5-96e4-d41ec4bb845b">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2014	cnwndl1	Initial creation

*/

vars
	form : SOP_WagonPositionRuleForm;
	str : String;
begin
	
	// starting size
	self.width := 465;
	self.height := 348;
	
	self.displayMeasurementFields();

	inheritMethod();
	
	if self.myWagonWellDef = null then
		self.btnCancel.click(btnCancel);
		return;
	else
		self.setCaption( app.getErrorString(Wagon_well_definition) &amp; " " &amp; self.myWagonWellDef.wellId );
	endif;
	
	loadData();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="dd42d6ca-6ea1-4031-b50e-c16f5b715281">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 10 August 2018 13:33:07.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022885, locale);
	btnCancel.translateCaption(Xlat_0020185, locale);
	btnSave.translateCaption(Xlat_0020186, locale);
	lblCWeight.translateCaption(Xlat_0020187, locale);
	lblCargoHeight.translateCaption(Xlat_0020188, locale);
	lblExtLength.translateCaption(Xlat_0020189, locale);
	lblExtWidth.translateCaption(Xlat_0020190, locale);
	lblHeight.translateCaption(Xlat_0020191, locale);
	lblLength.translateCaption(Xlat_0020192, locale);
	lblLocations.translateCaption(Xlat_0020193, locale);
	lblTare.translateCaption(Xlat_0020194, locale);
	lblWellId.translateCaption(Xlat_0020195, locale);
end;</source>
    </JadeMethod>
</GUIClass>
