    <JadeMethod name="getOrdinalsForPortRotationSort" id="7a81d804-7d0b-461c-b40d-cd31f9a14f32">
        <source>getOrdinalsForPortRotationSort(_forDeckOrd : Integer; _deckOrd, _x1, _y1, _z1, _portIndex : Integer output) : Boolean;
/*
Purpose:			
Date		Who		Reason
04 August 2011	cnwab1	Initial creation
*/

vars
	extremePoint : Point;
	disPort : CM_Port;
begin
	_deckOrd := self.myROROController.myDeck.ordinal;
	if _forDeckOrd &lt;&gt; _deckOrd then
		return false;
	endif;
	
	extremePoint := self.myLayout.getExtremePoint(CM_Graphic.Position_Top);
	
	_x1 := extremePoint.x;
	_y1 := extremePoint.y;
	_z1 := self.myROROController.getOrdinalSlot();
	
	disPort:= self.getAttrDischargePort();
	if disPort = null then
		_portIndex := 0;
	else
		_portIndex := self.myROROController.myVoyage.allPorts.indexOf(disPort);
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_forDeckOrd" type="Integer"/>
        <Parameter name="_deckOrd" type="Integer" usage="output"/>
        <Parameter name="_x1" type="Integer" usage="output"/>
        <Parameter name="_y1" type="Integer" usage="output"/>
        <Parameter name="_z1" type="Integer" usage="output"/>
        <Parameter name="_portIndex" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getPlannedDischargeTotals" id="5f20acd8-2743-4fae-8d43-ab0451f24a0a">
        <source>getPlannedDischargeTotals(_totalDischarge,_totalDischargeToPlan, _totalTodo : Integer io);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	theWLE : CM_WorkListEntry;
	theTI	: CM_TrackedItem;
	anFM : CM_FutureMove;
begin
	// 29830 don't double-count 40' etc
	if self.isBackEndRequest() then
		return;
	endif;

	foreach theWLE in self.allWorkListEntries  discreteLock do
		// 31977 to match totals with KPI stats and order of works, skip WLE with no job
		if self.myJob = null then
			continue;
		endif;
		_totalDischarge := _totalDischarge + 1;
		// 31977 accumulate todo totals as well
		if theWLE.status &lt;&gt; WLE_COMPLETED then
			_totalTodo :=_totalTodo + 1;
		endif;
		theTI := theWLE.myTrackedItem;
		if theTI &lt;&gt; null then
			if self.isRehandle then
				anFM := theTI.getFutureMoveOfType(PLANNING_MODE,TI_FutureMoveDLRDischarge);
			elseif self.isSoB then
				anFM := theTI.getFutureMoveOfType(PLANNING_MODE,TI_FutureMoveSOB);
			else
				anFM := theTI.getFutureMoveOfType(PLANNING_MODE,TI_FutureMovePlanned);
			endif;
			if anFM = null then
				_totalDischargeToPlan := _totalDischargeToPlan+1;
			endif;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_totalDischarge" type="Integer" usage="io"/>
        <Parameter name="_totalDischargeToPlan" type="Integer" usage="io"/>
        <Parameter name="_totalTodo" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getPlannedLoadTotals" id="5a3eac55-ee2e-4d43-8979-4cbdecaad527">
        <source>getPlannedLoadTotals(_totalLoad, _totalLoadToPlan, _totalTodo : Integer io);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 September 2011	cnwer1	Initial creation CCMS MES 1033
Aug 2013	cmwjre1	31977 add _totalTodo parameter and code
*/

vars
	theWLE : CM_WorkListEntry;
	theTI	: CM_TrackedItem;
begin
	// 29830 don't double-count 40' etc
	if self.isBackEndRequest() then
		return;
	endif;
	
	foreach theWLE in self.allWorkListEntries  discreteLock do
		// 31977 to match totals with KPI stats and order of works, skip WLE with no job
		if self.myJob = null then
			continue;
		endif;
		if self.isSoB and self.isLoad then // from 31977 do not include the load part of the SOB, as it doubles up the figures - matching code for order of works
			continue;
		endif;
		theTI := theWLE.myTrackedItem;
		if theTI = null then
			_totalLoadToPlan := _totalLoadToPlan + 1;
		endif;
		// 31977 accumulate todo totals as well
		if theWLE.status &lt;&gt; WLE_COMPLETED then
			_totalTodo := _totalTodo + 1;
		endif;
		_totalLoad:=_totalLoad + 1;
	endforeach;

epilog

end;</source>
        <Parameter name="_totalLoad" type="Integer" usage="io"/>
        <Parameter name="_totalLoadToPlan" type="Integer" usage="io"/>
        <Parameter name="_totalTodo" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getPlanningGuide" id="5b939931-93e1-45ea-b99e-5c21b6bc5d7f">
        <source>getPlanningGuide(guide : CMIF_PlanningGuideBay input; colourCodeType : Integer);
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars
	wleSize : Integer;
begin
	if self.isBackEndRequest() then 
		return;	//ignore any back ends
	endif;
	if self.moveType = NULL_MOVETYPE then
		return;
	endif;
	
	if not self.myROROController.getIsAvailable() then
		return;
	endif;
	
	wleSize := self.allWorkListEntries.size;
	if wleSize = 0 then
		wleSize := 1;
	endif;
	
	if self.moveType = DISCHARGE_MOVETYPE then
		guide.dischargeImportOD := guide.dischargeImportOD + wleSize; // for RORO we are always ON DECK, get it!?
	elseif self.moveType = LOAD_MOVETYPE then
		guide.loadExportOD := guide.loadExportOD + wleSize; // for LOAD these WLEs may be empty but they will exist
		
	elseif self.isSOB then
		if colourCodeType = DISCHARGE_COLOURCODE then
			guide.dischargeSOBOD := guide.dischargeSOBOD + wleSize;
		endif;
	elseif self.isRehandle then
		if colourCodeType = DISCHARGE_COLOURCODE then
			guide.dischargeDLROD := guide.dischargeDLROD + wleSize;
		else
			//Load Colour Code
			guide.loadDLROD := guide.loadDLROD + wleSize; // for LOAD these WLEs may be empty but they will exist
		endif;	
	endif;
end;</source>
        <Parameter name="guide" type="CMIF_PlanningGuideBay" usage="input"/>
        <Parameter name="colourCodeType" type="Integer"/>
    </JadeMethod>
