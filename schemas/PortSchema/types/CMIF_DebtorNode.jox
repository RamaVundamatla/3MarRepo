        <ReturnType type="CMIF_Address"/>
    </JadeMethod>
    <JadeMethod name="getLinkedRelatedEntityCode" id="2526d26e-a487-401b-9932-5c7637f0230a">
        <source>getLinkedRelatedEntityCode(_debtor : CM_Debtor input; _autoGenerateId : String) : String protected;
/*

Purpose: Trying to find the closest match code to the debtor hexOid String.			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2023	navsp1	Initial creation TFS ChangeRequest 57447: EUP - Customer Update - Process Customer info from API method

*/

vars
	tmpDict : DynaDictionary;
    debtorHexOid,
    startHexOid : String;
    count : Integer;
	pxyCarrier : CM_Carrier;
	pxyConsign : CM_ConsigneeConsignor;
	pxyCustomsAgents : CM_CustomsAgent;
	pxyOperator : CM_Operator;
	pxyShippingLine : CM_ShippingLine;
	pxyStevedore : CM_Stevedore;
begin
	create tmpDict transient;
    tmpDict.setMembership(CM_Object);
    tmpDict.addExternalKey(String, 4, true, true);
    tmpDict.endKeys(true);
    
    // start various allxxxx collection loops        
    if not _debtor.allCarriers.isEmpty then
		foreach pxyCarrier in _debtor.allCarriers do
			tmpDict.putAtKey(pxyCarrier.code, pxyCarrier);
		endforeach;
	endif;
	
	if not _debtor.consignors.isEmpty then
		foreach pxyConsign in _debtor.consignors do
			tmpDict.putAtKey(pxyConsign.code, pxyConsign);
		endforeach;
	endif;
	
	if not _debtor.allCustomsAgents.isEmpty then
		foreach pxyCustomsAgents in _debtor.allCustomsAgents do
			tmpDict.putAtKey(pxyCustomsAgents.code, pxyCustomsAgents);
		endforeach;
	endif;
	 
	 if not _debtor.operators.isEmpty then
		foreach pxyOperator in _debtor.operators do
			tmpDict.putAtKey(pxyOperator.code, pxyOperator);
		endforeach;
	endif;
	 
	 if not _debtor.allShippingLines.isEmpty then
		foreach pxyShippingLine in _debtor.allShippingLines do
			tmpDict.putAtKey(pxyShippingLine.code, pxyShippingLine);
		endforeach;
	endif;
	
	if not _debtor.allStevedores.isEmpty then
		foreach pxyStevedore in _debtor.allStevedores do
			tmpDict.putAtKey(pxyStevedore.code, pxyStevedore);
		endforeach;
	endif;
	// end various allxxxx collection loops
	
	debtorHexOid := _autoGenerateId;
	
    startHexOid := debtorHexOid;
    while true do
        if tmpDict.getAtKey(debtorHexOid) &lt;&gt; null then
            break;  // found it!
        endif;
        if count = 100 then
            // never had an auto id before, or, for some reason, has more than 100 related entities
            debtorHexOid := startHexOid;
            break;
        endif;
        count += 1;
        debtorHexOid.incrementHex();
    endwhile;       
	
	return debtorHexOid;	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_debtor" type="CM_Debtor" usage="input"/>
        <Parameter name="_autoGenerateId" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRealRelatedEntityObject" id="915389a9-b041-44cf-bc86-64178e23079e">
        <source>getRealRelatedEntityObject(_pxyObject : CM_Object; _code : String) : CM_Object protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2023	navsp1	Initial creation TFS ChangeRequest 57447: EUP - Customer Update - Process Customer info from API method

*/

vars

begin
	if _pxyObject.isKindOf(CM_Carrier) then				
		return app.myRoot.allCarriers[_code];
	elseif _pxyObject.isKindOf(CM_ConsigneeConsignor) then				
		return app.myRoot.allConsigneeConsignors[_code];
	elseif _pxyObject.isKindOf(CM_CustomsAgent) then				
		return app.myRoot.allCustomsAgents[_code];
	elseif _pxyObject.isKindOf(CM_Operator) then				
		return app.myRoot.allOperators[_code];
	elseif _pxyObject.isKindOf(CM_ShippingLine) then				
		return app.myRoot.allShippingLines[_code];
	elseif _pxyObject.isKindOf(CM_Stevedore) then				
		return app.myRoot.allStevedores[_code];
	endif;
	
	return null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_pxyObject" type="CM_Object"/>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="isAnyRelEntExistsWithSameCode" id="00abd478-a617-44c3-a890-cdaad25490a5">
        <source>isAnyRelEntExistsWithSameCode(_code : String) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2023	navsp1	Initial creation TFS ChangeRequest 57447: EUP - Customer Update - Process Customer info from API method

*/

vars
	realCarrier : CM_Carrier;
	realConsign : CM_ConsigneeConsignor;
	customsAgents : CM_CustomsAgent;
	realOperator : CM_Operator;
	realShippingLine : CM_ShippingLine;
	realStevedore : CM_Stevedore;
begin
	realCarrier 		:= app.myRoot.allCarriers[_code];
	realConsign 		:= app.myRoot.allConsigneeConsignors[_code];
	customsAgents       := app.myRoot.allCustomsAgents[_code];
	realOperator 		:= app.myRoot.allOperators[_code];				
	realShippingLine 	:= app.myRoot.allShippingLines[_code];				
	realStevedore 		:= app.myRoot.allStevedores[_code];
	
	if realCarrier = null and realConsign = null and customsAgents = null and realOperator = null and  realShippingLine = null and  realStevedore = null then
		return false;
	else
		return true;
	endif;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setBillingAddress" id="294df01e-cdec-480f-879b-a55706ebef21">
        <updating/>
        <source>setBillingAddress(_line1, _line2, _line3, _city, _region, _postCode, _country, _email : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
21 June 2023	navmd1	Initial creation TFS 57447 POST /Customer fixes

*/

vars
	str : String;
begin
	
	// Always assume there is at *least* one address line
	str := _line1;
	
	// Otherwise - all the others are technically optional
	if _line2 &lt;&gt; null then
		str &amp;= CrLf &amp; _line2;
	endif;
	
	if _line3 &lt;&gt; null then
		str &amp;= CrLf &amp; _line3;
	endif;
	
	if _city &lt;&gt; null then
		str &amp;= CrLf &amp; _city;
	endif;
	
	if _region &lt;&gt; null then
		str &amp;= CrLf &amp; _region;
	endif;
	
	if _postCode &lt;&gt; null then
		str &amp;= CrLf &amp; _postCode;
	endif;
	
	if _country &lt;&gt; null then
		str &amp;= CrLf &amp; _country;
	endif;
	
	if _email &lt;&gt; null then
		str &amp;= CrLf &amp; _email;
	endif;
	
	self.billingAddress := str;
epilog

end;</source>
        <Parameter name="_line1" type="String"/>
        <Parameter name="_line2" type="String"/>
        <Parameter name="_line3" type="String"/>
        <Parameter name="_city" type="String"/>
        <Parameter name="_region" type="String"/>
        <Parameter name="_postCode" type="String"/>
        <Parameter name="_country" type="String"/>
        <Parameter name="_email" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForImport" id="337e9040-006e-47b6-9b63-15a0623d5816">
        <updating/>
        <source>setForImport(_debtorName, 
			_debtorAddress,
			_remarks,
			_account,
			_purchOrder 	  : String; 
			_poMandatory,
			_zeroRated,
			_suspended		  : Boolean; 
			_parent 		  : CM_DebtorNode; 
			_termsOfTrade     : CM_InvoiceTermsOfTrade;
			_carrier          : CM_Carrier; 
			_operator 		  : CM_Operator; 
			_consignor 		  : CM_ConsigneeConsignor;
			_debtorType 	  : CM_DebtorType;
			_customsAgent     : CM_CustomsAgent;
			_longName 		  : String;
			_externalRef      : String;
			_badCredit  	  : Boolean;
			_code,
			_addInfo1,
			_addInfo2		  : String) updating;
/*

Purpose:		JMT 1010 Interface Load	

Date		Who		Reason
19/08/2009	cnwjmn1	Initial creation
08/08/2018	jlgdap1	TFS 40092 PEL1 Adding Changes to Debtors
28/03/2020  cnwma1	Bug 48994: ASPA - Debtor Uploads missing Attributes
*/

vars

	rdg		: CM_RootDebtorGroup;
begin

	rdg := app.myRoot.myRootCompany.getRootDebtorGroup();
	
	self.name						:= _debtorName[1:100];			// TFS 40092
	self.billingAddress				:= _debtorAddress;
	self.remarks					:= _remarks;	
	self.decfinName					:= _account[1:40];
	self.purchaseOrderCode			:= _purchOrder[1:10];	
	self.isPurchaseOrderMandatory	:= _poMandatory;
	self.isZeroRated				:= _zeroRated;	
	self.isSuspended				:= _suspended;
	self.badDebtor 					:= _badCredit;
	self.longName 					:= _longName;
	self.externalReference	 		:= _externalRef[1:30];
	self.myTermsOfTrade				:= _termsOfTrade;
	self.code                       := _code[1:100];
	self.additionalInformation1     := _addInfo1;
	self.additionalInformation2     := _addInfo2;
	
	if _parent &lt;&gt; null then
		self.myParentDebtorNode			:= _parent;
	else
		self.myParentDebtorNode			:= rdg;
	endif;
	
	if _carrier &lt;&gt; null then
		self.allCarriers.add(_carrier);
	endif;
	if _operator &lt;&gt; null then
		self.allOperators.add(_operator);
	endif;
	if _consignor &lt;&gt; null then
		self.allConsignors.add(_consignor);
	endif;
	if _debtorType &lt;&gt; null then
		self.allDebtorTypes.add(_debtorType);
	endif;
	if _customsAgent &lt;&gt; null then
		self.allCustomsAgents.add(_customsAgent);
	endif;

end;</source>
        <Parameter name="_debtorName" type="String"/>
        <Parameter name="_debtorAddress" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_account" type="String"/>
        <Parameter name="_purchOrder" type="String"/>
        <Parameter name="_poMandatory" type="Boolean"/>
        <Parameter name="_zeroRated" type="Boolean"/>
        <Parameter name="_suspended" type="Boolean"/>
        <Parameter name="_parent" type="CM_DebtorNode"/>
        <Parameter name="_termsOfTrade" type="CM_InvoiceTermsOfTrade"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_consignor" type="CM_ConsigneeConsignor"/>
        <Parameter name="_debtorType" type="CM_DebtorType"/>
        <Parameter name="_customsAgent" type="CM_CustomsAgent"/>
        <Parameter name="_longName" type="String"/>
        <Parameter name="_externalRef" type="String"/>
        <Parameter name="_badCredit" type="Boolean"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_addInfo1" type="String"/>
        <Parameter name="_addInfo2" type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromDebtor" id="2c8a4390-2928-4735-9fe0-0fe7cdb7f57f">
        <updating/>
        <source>setFromDebtor(_debtor : CM_DebtorNode) updating;
// for CCMS GLT 2342 quick agent/debtor maintenance, set up the controller from the debtor
// 08/08/2018	cnwma1	ChangeRequest 40092: PEL1 - Adding Changes to Debtors
// 30/05/2019	jlgdap1	TFS 44554 AAT Stevedore Data Access
// 02/06/2022	navdap1	TFS 53362 EUP Master Data interface customers between TOS and ERP
// 08/09/2022	navmd1	TFS 54664 Removed xlat attributes from CM_Debtor
vars
	debtorTermDetail : CMIF_DebtorTerminalDetail;
	debtor 	: CM_Debtor;
	drTerm	: CM_DebtorTerminal;
begin
	// common to CM_Debtor and CM_DebtorNode
	self.myParentDebtorNode 	:= _debtor.myParentDebtorNode;
	self.isSuspended 			  := _debtor.isSuspended;
	self.isZeroRated 			  := _debtor.isZeroRatedTax;
	self.badDebtor 				  := _debtor.badDebtor;
	self.name					  := _debtor.name;
	self.remarks 				  := _debtor.remarks;
	self.isPurchaseOrderMandatory := _debtor.isPurchaseOrderMandatory;
	
	// CM_Debtor
	if not _debtor.isKindOf(CM_Debtor) then
		return;
	endif;
	debtor := _debtor.CM_Debtor;

	debtor.allCarriers.copy(self.allCarriers);
	debtor.consignors.copy(self.allConsignors);
	debtor.allCustomsAgents.copy(self.allCustomsAgents);
	debtor.allDebtorTypes.copy(self.allDebtorTypes);
	debtor.operators.copy(self.allOperators);
	debtor.allSpecialReleaseTxnTypes.copy(self.allSpecialReleaseTxnTypes);
	debtor.allContacts.copy(self.allContacts); 
	debtor.allStevedores.copy(self.allStevedores);		
	debtor.allShippingLines.copy(self.allShippingLines);		//13-May-2022 TFS 53195	
	
	self.code                   := debtor.code;									//08.8.2018 cnwma1 TFS #340092
	self.longName				:= debtor.longName;
	self.decfinName 		    := debtor.decfinName;
	self.billingAddress		    := debtor.getBillingAddressString();
	self.purchaseOrderCode 		:= debtor.purchaseOrderCode;
	self.externalReference 		:= debtor.externalReference;
	self.myTermsOfTrade		    := debtor.myTermsOfTrade;
	self.additionalInformation1 := debtor.additionalInformation1;			   //22 Mar 2018	NDL	TFS 37559
	self.additionalInformation2 := debtor.additionalInformation2;				//22 Mar 2018	NDL	TFS 37559
	
	 // ### TFS 52237 27OCT2021 NAVAB1
	foreach drTerm in debtor.allDebtorTerminals do
		create debtorTermDetail transient;
		debtorTermDetail.setMyTerminal(drTerm.myTerminal);
		debtorTermDetail.setCashOnly(drTerm.isCashOnly);
		debtorTermDetail.setPaymentType(drTerm.paymentType);
		
		self.allDebtorTerminalDetails.add(debtorTermDetail);
	endforeach;
end;</source>
        <Parameter name="_debtor" type="CM_DebtorNode"/>
    </JadeMethod>
    <JadeMethod name="updateRelatedEntity" id="0d54cb4c-3e69-4a89-9233-2181f5d08ed1">
        <updating/>
        <source>updateRelatedEntity(pxyObject:CM_Object input; realDebtorNode :CM_DebtorNode; _passport : CM_Passport input; isUpdate : Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2023	navsp1	Initial creation ChangeRequest 57447: EUP - Customer Update - Process Customer info from API method

*/

vars
	subMsg : String;
begin
	if pxyObject.isKindOf(CM_Carrier) then
		pxyObject.CM_Carrier.setDebtor(realDebtorNode.CM_Debtor);
		if isUpdate then
			if pxyObject.CM_Carrier.isNotAvailableForEntry then											//19.Jul.2023 navsp1 TFS 58837
				subMsg := app.getErrorString(Carrier) &amp; " '" &amp; pxyObject.CM_Carrier.code &amp; "'";
				app.raiseCMWarning1( NotAvailableForEntry,  subMsg, null, null, null );
			endif;
			app.myUtilityUA.utlUpdateCarrier(pxyObject.CM_Carrier, _passport);
		endif;
	elseif	pxyObject.isKindOf(CM_ConsigneeConsignor) then
		pxyObject.CM_ConsigneeConsignor.setDebtor(realDebtorNode.CM_Debtor);
		if isUpdate then
			if pxyObject.CM_ConsigneeConsignor.isNotAvailableForEntry then								//19.Jul.2023 navsp1 TFS 58837
				subMsg := app.getErrorString(Consignee_Consignor) &amp; " '" &amp; pxyObject.CM_ConsigneeConsignor.code &amp; "'";
				app.raiseCMWarning1( NotAvailableForEntry,  subMsg, null, null, null );
			endif;
			app.myUtilityUA.utlUpdateConsigneeConsignor(pxyObject.CM_ConsigneeConsignor, _passport);
		endif;
	elseif	pxyObject.isKindOf(CM_CustomsAgent) then
		pxyObject.CM_CustomsAgent.setDebtor(realDebtorNode.CM_Debtor);
		if isUpdate then
			if pxyObject.CM_CustomsAgent.isNotAvailableForEntry then									//19.Jul.2023 navsp1 TFS 58837
				subMsg := app.getErrorString(Customs_agent) &amp; " '" &amp; pxyObject.CM_CustomsAgent.code &amp; "'";
				app.raiseCMWarning1( NotAvailableForEntry,  subMsg, null, null, null );
			endif;
			app.myUtilityUA.utlUpdateCustomsAgent(pxyObject.CM_CustomsAgent, _passport);
		endif;
	elseif	pxyObject.isKindOf(CM_Operator) then
		pxyObject.CM_Operator.setDebtor(realDebtorNode.CM_Debtor);
		if isUpdate then
			if pxyObject.CM_Operator.isNotAvailableForEntry then										//19.Jul.2023 navsp1 TFS 58837
				subMsg := app.getErrorString(Operator) &amp; " '" &amp; pxyObject.CM_Operator.code &amp; "'";
				app.raiseCMWarning1( NotAvailableForEntry,  subMsg, null, null, null );
			endif;
			app.myUtilityUA.utlUpdateOperator(pxyObject.CM_Operator, null, _passport);
		endif;
	elseif	pxyObject.isKindOf(CM_ShippingLine) then
		pxyObject.CM_ShippingLine.setDebtor(realDebtorNode.CM_Debtor);
		if isUpdate then
			if pxyObject.CM_ShippingLine.isNotAvailableForEntry then									//19.Jul.2023 navsp1 TFS 58837
				subMsg := app.getErrorString(Shipping_Line) &amp; " '" &amp; pxyObject.CM_ShippingLine.code &amp; "'";
				app.raiseCMWarning1( NotAvailableForEntry,  subMsg, null, null, null );
			endif;
			app.myUtilityUA.utlUpdateShippingLine(pxyObject.CM_ShippingLine, _passport);
		endif;
	elseif	pxyObject.isKindOf(CM_Stevedore) then
		pxyObject.CM_Stevedore.setDebtor(realDebtorNode.CM_Debtor);
		if isUpdate then
			if pxyObject.CM_Stevedore.notAvailableForEntry then											//19.Jul.2023 navsp1 TFS 58837
				subMsg := app.getErrorString(Stevedore) &amp; " '" &amp; pxyObject.CM_Stevedore.code &amp; "'";
				app.raiseCMWarning1( NotAvailableForEntry,  subMsg, null, null, null );
			endif;
			app.myUtilityUA.utlUpdateStevedore(pxyObject.CM_Stevedore, _passport);
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="pxyObject" type="CM_Object" usage="input"/>
        <Parameter name="realDebtorNode" type="CM_DebtorNode"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="isUpdate" type="Boolean"/>
    </JadeMethod>
</Class>
