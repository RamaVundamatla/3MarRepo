    <JadeMethod name="createEntry" id="fdb1ab01-efdd-48af-989e-5d51e1f39ff5">
        <lockReceiver/>
        <updating/>
        <source>createEntry():CnEcArrayObject updating, protected;
// --------------------------------------------------------------------------------
// Created:		29 August 1999 by cnwdad1
//
// Purpose:		Private method to create a new CnEcArrayObject instance for a new
//				element in the array.
//
// Parameters:	None
//
// Returns:		CnEcArrayObject - The newly created instance of CnEcArrayObject.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	elementObj	: CnEcArrayObject;

begin
	if self.isTransient() then
		create elementObj transient;
	else
		create elementObj;
	endif;
epilog
	return elementObj;
end;</source>
        <access>protected</access>
        <ReturnType type="CnEcArrayObject"/>
    </JadeMethod>
    <JadeMethod name="delete" id="606ead18-5475-46a6-ac61-f4660a0ed17f">
        <lockReceiver/>
        <updating/>
        <source>delete() updating, protected;
// --------------------------------------------------------------------------------
// Created:		29 August 1999 by cnwdad1
//
// Purpose:		Private method to purge the CnEcArrayObject instances of the array.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.purge();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getBinaryAt" id="f00dc15d-95c3-406c-a9c1-ae1a50089d99">
        <source>getBinaryAt(pIndex:Integer):Binary;
// --------------------------------------------------------------------------------
// Created:		29 August 1999 by cnwdad1
//
// Purpose:		Returns the binary value of a specified array element.
//
// Parameters:	pIndex (Integer) - The index of the array element whose value to return.
//
// Returns:		Binary - The binary value of the specified array element.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pIndex &gt; self.size() then
		return null;
	else
		return self[pIndex].getBinaryValue();
	endif;
end;</source>
        <Parameter name="pIndex" type="Integer"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getStringAt" id="a865ab5e-dcd1-4b8b-bfb5-32eb7fa29ab3">
        <source>getStringAt(pIndex:Integer):String;
// --------------------------------------------------------------------------------
// Created:		29 August 1999 by cnwdad1
//
// Purpose:		Returns the string value of a specified array element.
//
// Parameters:	pIndex (Integer) - The index of the array element whose value to return.
//
// Returns:		String - The string value of the specified array element.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pIndex &gt; self.size() then
		return null;
	else
		return self[pIndex].getStringValue();
	endif;
end;</source>
        <Parameter name="pIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includesBinary" id="02657740-58cd-4992-b1ea-9fe50bcfece2">
        <source>includesBinary(pBinaryValue:Binary):Boolean;
// --------------------------------------------------------------------------------
// Created:		03 June 2003 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver contains an
//				element who's binary value is the same as the specified parameter
//				value.
//
// Parameters:	pBinaryValue - The binary value to scan for.
//
// Returns:		True if the receiver contains an element with the same value,
//				otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	elementObj	: CnEcArrayObject;
	
begin
	foreach elementObj in self do
		if elementObj.binaryValue = pBinaryValue then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="pBinaryValue" type="Binary"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesString" id="d798c01b-e31e-40e1-a848-c33640e4c4ba">
        <source>includesString(pStringValue:String):Boolean;
// --------------------------------------------------------------------------------
// Created:		03 June 2003 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver contains an
//				element who's string value is the same as the specified parameter
//				value.
//
// Parameters:	pStringValue - The string value to scan for.
//
// Returns:		True if the receiver contains an element with the same value,
//				otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	elementObj	: CnEcArrayObject;
	
begin
	foreach elementObj in self do
		if elementObj.stringValue = pStringValue then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="pStringValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeBinary" id="9bcc987b-9e7d-4466-ad0a-d2ad5f63996a">
        <lockReceiver/>
        <updating/>
        <source>removeBinary(pBinaryValue:Binary):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		29 August 1999 by cnwdad1
//
// Purpose:		Removes an array element which has a specified binary value.
//
// Parameters:	pBinaryValue (Binary) - The value to scan for in the array.
//
// Returns:		Boolean - True is an element was removed, false if not.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	elementsToDelete	: ObjectArray;
	deleteObj			: Object;
	elementObj			: CnEcArrayObject;
	isRemoved			: Boolean;

begin
	create elementsToDelete transient;

	// Find the array elements to be removed.

	foreach elementObj in self do
		if (elementObj.getBinaryValue() = pBinaryValue) then
			elementsToDelete.add(elementObj);
		endif;
	endforeach;

	// Now removed the matching array elements.

	foreach deleteObj in elementsToDelete do
		self.remove(deleteObj.CnEcArrayObject);

		if (not isRemoved) then
			isRemoved	:=	true;
		endif;
	endforeach;
epilog
	delete elementsToDelete;

	return isRemoved;
end;</source>
        <Parameter name="pBinaryValue" type="Binary"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeString" id="afc811fb-4060-4617-8422-87f5c400f495">
        <lockReceiver/>
        <updating/>
        <source>removeString(pStringValue:String):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		29 August 1999 by cnwdad1
//
// Purpose:		Removes an array element which has a specified string value.
//
// Parameters:	pStringValue (String) - The value to scan for in the array.
//
// Returns:		Boolean - True is an element was removed, false if not.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	elementsToDelete	: ObjectArray;
	deleteObj			: Object;
	elementObj			: CnEcArrayObject;
	isRemoved			: Boolean;

begin
	create elementsToDelete transient;

	// Find the array elements to be removed.

	foreach elementObj in self do
		if elementObj.getStringValue() = pStringValue then
			elementsToDelete.add(elementObj);
		endif;
	endforeach;

	// Now removed the matching array elements.

	foreach deleteObj in elementsToDelete do
		self.remove(deleteObj.CnEcArrayObject);

		if (not isRemoved) then
			isRemoved	:=	true;
		endif;
	endforeach;
epilog
	delete elementsToDelete;

	return isRemoved;
end;</source>
        <Parameter name="pStringValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
