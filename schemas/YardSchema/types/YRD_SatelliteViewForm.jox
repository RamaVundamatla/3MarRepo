    <JadeMethod name="doAutoplan" id="a01cb17e-970d-48f8-a2df-7fd9737acb2a">
        <updating/>
        <source>doAutoplan(_tiArray: CM_TIArray; _alertArray: CM_AlertsArray; _mode: Integer) updating;
//14 April 2009	cnwdw1	
//
vars
	tiArray : CM_TIArray;
	alert	: CM_SystemAlert;
begin
	inheritMethod(_tiArray, _alertArray, _mode);
	
	create tiArray transient;
	if _tiArray = null then
		foreach alert in _alertArray do
			if alert.myTrackedItem &lt;&gt; null then	
				tiArray.add(alert.myTrackedItem);
			endif;
		endforeach;
	else
		_tiArray.copy(tiArray);
	endif;
	self.tblFailAutoPlan.selectRows(tiArray); // PAR 19442 
end;</source>
        <Parameter name="_tiArray" type="CM_TIArray"/>
        <Parameter name="_alertArray" type="CM_AlertsArray"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doBtnEditYardAllocClick" id="f1357ad3-d179-464d-9c77-3c8a372040ee">
        <updating/>
        <source>doBtnEditYardAllocClick() updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	olVIEWFrame, olEDITFrame	: YRD_ContainerOverDrawingFrame;
	ydc							: YRD_ContainerDrawingController;
	obj							: Object;
	void, editYA 				: Boolean;
	yalloc,ya   				: CM_YardAllocation;
	idx							: Integer;
begin

	editYA := self.btnViewYardAllEd.value;
	self.btnDeleteYA.enabled := not editYA; 
	self.btnAddYA.enabled := not editYA; 
	self.btnSelect.enabled := not editYA;

	foreach obj in self.allDrawingControllers do
		ydc := obj.YRD_ContainerDrawingController;
		if editYA then
			self.allSelectedYAMObjects.clear;
			self.tblYAM.allSelectedObjects.copy(self.allSelectedYAMObjects);
			self.tblYAM.getExpandedObjectsYA(self.allExpandedYAMObjects);
			yalloc := self.getSelectedYA();
			ydc.getOverlayEditFrame.zOrder(1);
			ydc.getOverlayEditFrame.myCurrentEditYardAllocation := yalloc;
			self.doDisplayYardAllocationForEdit(ydc, void);
			self.txtYALocation.text := null;
			self.lblYALocation.caption := null;
			self.frmYALocation.visible := true;
			// Populate YA Combobox  CCMS CPL 2059
			self.cmbYA.clear();
			foreach ya in self.getTerminal.allYardAllocatonsByCode do
				if not ya.isDisabled then
					// TFS 1775 Apr 2016 cnwjre1 stop invoice allocations as showing as yard allocations
					if ya.isInvoiceAllocation then
						continue;
					endif;
					idx := self.cmbYA.addItem(ya.code);
					self.cmbYA.itemObject[idx] := ya;
				endif;
			endforeach;
			if yalloc &lt;&gt; null then
				self.cmbYA.text := yalloc.code;
			endif;
			self.frmYALocation.zOrder(1);
			// This will cause rectangles to automatically be selected if a corrresponding
			// Yam Table entry has been selected
			self.doYAMTableSelection();
		else
			self.frmYALocation.visible := false;
			ydc.getOverlayEditFrame.visible := false;
			ydc.getOverlayViewFrame.visible := true;
			self.tblYAM.allSelectedObjects.clear;		// CCMS CPL 2052
			foreach obj in self.allSelectedYAMObjects do
				self.tblYAM.selectObject(obj, false);
			endforeach;
			self.tblYAM.expandAllYALocations(false);
			foreach obj in self.allExpandedYAMObjects do
				self.tblYAM.expandYALocations(obj.CM_YardAllocation, true);
			endforeach;
			ydc.getOverlayEditFrame().deleteAllRectFrames();
		endif;
	endforeach;
	self.txtYALocation.setFocus();
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnViewYardAllocClick" id="1e57ddea-c7a8-4de4-a343-c2f3efcc070f">
        <updating/>
        <source>doBtnViewYardAllocClick() updating;
vars
	// PAR 19466
	obj	: Object;
	ydc	: YRD_ContainerDrawingController;
begin
	if not tblLocnStats.visible and tblYAM.visible then
		tblLocnStats.visible	:=	true;
		if tblLocnStats.myForm = null then
			self.tblLocnStats.setForm(self);
			self.tblLocnStats.initialise(self.allTerminalAreas, self.fraPictures, self.pic1, self.pic2, self.pic3);
		endif;
		tblYAM.visible			:=	false;
		self.btnSearchYAM.visible := false;
		self.btnViewYardAllEd.enabled := false;
		self.btnDeleteYA.enabled := false;
		self.btnAddYA.enabled := false;
		
		// PAR 19466
		foreach obj in self.allDrawingControllers do
			ydc := obj.YRD_ContainerDrawingController;
			ydc.getOverlayViewFrame.clearGraphics();
		endforeach;


	elseif not tblYAM.visible and tblLocnStats.visible then
		tblLocnStats.visible	:=	false;
		tblYAM.visible			:=	true;
		if self.tblYAM.myForm = null then
			self.tblYAM.setForm(self);
			self.tblYAM.initialise(false, self.fraPictures, self.pic1, self.pic2, self.pic3);
		endif;
		self.btnSearchYAM.visible := true;
		self.btnViewYardAllEd.enabled := true;
		self.btnDeleteYA.enabled := true;
		self.btnAddYA.enabled := true;
		
		// PAR 19466
		foreach obj in self.allDrawingControllers do
			ydc := obj.YRD_ContainerDrawingController;
			ydc.getOverlayViewFrame.setYardAllocations(self.tblYAM.allSelectedObjects);
			ydc.getOverlayViewFrame.setYABlocks(self.tblYAM.allSelectedObjects);
			ydc.getOverlayViewFrame.drawAllYAFrames();
			ydc.getOverlayViewFrame.visible := true;
		endforeach;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildMnuAddLabourRestricts" id="2c561899-24b4-4f0c-b1ac-13bb0358ef50">
        <source>doBuildMnuAddLabourRestricts(_ta: CM_TerminalArea) protected;

/*

Purpose:			

Parameters:	

			copy of super form version with changes specific to regions

Return Value:		


Date		Who		Reason
23 September 2011	cnwndl1	Initial creation	Par 28236

*/

vars

	tStr :String;
	str :String;
	index :Integer;
	lIndex : Integer;
	mnuChild,mnuMaster	: MenuItem;
	mnuIndex 	: Integer;
	root : CM_Root;
	checked : Boolean;
	termSubArea : CM_TerminalSubArea;
	locCont : CM_LocationsController;
	

begin
	
	if not app.myCurrentUserCan(self.myTerminal,PmAdmLabrestrMaint) 
	or not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then // TFS 2198 CNWAB1
		self.mnuLabourAddRest1.enabled := false;
		self.mnuLabourAddRest1.visible := false;
		return;
	endif;
	
	if not self.allSelectedRegionLocs.isEmpty then
		// this is only allowed if we have a single region selection that is all
		// within a single terminal area. ( I.e. one rectangular selection on the 
		// form that is within one terminal area.)
		
		if self.allSelectedRegionObjs.size &lt;&gt; 1 then
			// More than one region selected (i.e. rectangular block of locations.)
			return;
		else
			foreach locCont in self.allSelectedRegionLocs discreteLock do
				if locCont.myTerminalArea &lt;&gt; _ta then
					// must be more than one terminal area in play, bail....
					return;
				endif;
			endforeach;
			//looks OK
			self.mnuLabourAddRegion1.visible := true;
		endif;
		
		return;
		
	endif;
	
	mnuMaster := self.mnuLabourAddRest1;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.userObject := null;
	mnuMaster.helpKeyword := "MAIN";

	foreach index in 1 to 50 do
		mnuChild := mnuMaster.getMenuItem(index); // check if the menu is already cloned
		delete mnuChild;
	endforeach;

	foreach termSubArea in _ta.allSubAreas do
		mnuIndex 	:= mnuIndex + 1;
		mnuChild := mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned
		if mnuChild = null then
			mnuChild := mnuMaster.loadSubMenu(mnuIndex); // Clone menu
		endif;
		mnuChild.caption := termSubArea.id;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := termSubArea.id;
		mnuChild.userObject := termSubArea;
	endforeach; 
	
	if mnuIndex &gt; 0 then // index has not been set as no termsubareas added above 
		mnuIndex := mnuIndex + 1;
		mnuChild := mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned	
		if mnuChild = null then
			mnuChild := mnuMaster.loadSubMenu(mnuIndex); // Clone menu
		endif;
		mnuChild.caption := "-";
	endif;
	
	mnuIndex := mnuIndex + 1; 
	
	mnuChild := mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned
	if mnuChild = null then
		mnuChild := mnuMaster.loadSubMenu(mnuIndex); // Clone menu
	endif;
	mnuChild.caption := "&amp;All...";
	mnuChild.visible := true;
	mnuChild.enabled := true;
	mnuChild.helpKeyword := "ALL";
	mnuChild.userObject := _ta;
	
	mnuIndex := mnuIndex + 1; 
	
	if _ta.isKindOf(CM_InterchangeArea) or  _ta.isKindOf(CM_BlockStack) then
		return;
	endif;
		
	mnuChild := mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned
	if mnuChild = null then
		mnuChild := mnuMaster.loadSubMenu(mnuIndex); // Clone menu
	endif;
	mnuChild.caption := "&amp;Define Area...";
	mnuChild.visible := true;
	mnuChild.enabled := true;
	mnuChild.helpKeyword := "DEFINE";
	mnuChild.userObject := _ta;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuDecking" id="5e978cce-a030-47e3-867f-c3f815248989">
        <source>doBuildMnuDecking( _termArea : CM_TerminalArea ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 September 2011	cnwndl1	Initial creation	Par 28236

*/

vars

begin

	if not self.configAutoPlanUseAllocations 
	or not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then // TFS 2198 CNWAB1
		return;
	endif;

	if _termArea = null then
		return;
	endif;
	
	if _termArea.isDeckable then
		self.mnuDeckingOpt1.caption := _termArea.id &amp; " Decking Options...";
		self.mnuDeckingOpt1.userObject := _termArea;
		self.mnuDeckingOpt1.visible := true;
	endif;	

epilog

end;
</source>
        <access>protected</access>
        <Parameter name="_termArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuLocMaint" id="c98d2bda-7728-459c-8171-5d68814bcec5">
        <source>doBuildMnuLocMaint( _termArea : CM_TerminalArea; _gridController : CM_GridController ) protected;
/*
Date		Who		Reason
23 September 2011	cnwndl1	Initial creation	Par 28236 - Copy of version from YRD_GridAreasOverviewForm
															but using local mnu item names....
															And less the items never used.
															And with changes specific to regions
07/11/2012	cnwcs5	par 30475 - remove location restrictions	
*/

vars
	menuParams : CMIF_MenuParams;
	aSub : CM_BlockStack;
	aLabR : CM_LabourRestriction;
	termArea : CM_TerminalArea;
	gridController : CM_GridController;
	rtgController : CM_RTGController;
	termID,controllerID : String;
	aChildMenuItem : MenuItem;
	aStackController : CM_StackController;
	maxHeight, idx,nuthinIndex : Integer;
	regionProcessing : Boolean;
	multiProcessing : Boolean;
	locCont : CM_LocationsController;
begin

	self.mnuLcnAreaMain1.visible := false; 
	self.mnuLcnPadMain1.visible := false; 
	self.mnuLcnAreaHeight1.visible := false;
	self.mnuLcnAreaLabour1.visible := false;
	self.mnuLcnAreaSBS1.visible := false;
	self.mnuLcnPadMain1.visible := false;
	self.mnuLcnPadPad1.visible := false;

	self.clearupMenuParams(); // PAR 18723
	
	if _termArea.isKindOf(CM_InterchangeArea) then
		return;
	endif;
	
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	
	if not self.allSelectedRegionLocs.isEmpty then
		if self.allSelectedRegionObjs.size = 1 then
			foreach locCont in self.allSelectedRegionLocs discreteLock do
				if locCont.myTerminalArea &lt;&gt; _termArea then
					// must be more than one terminal area in play, bail....
					return;
				endif;
			endforeach;
			regionProcessing := true;
		else
			return;
		endif;
	endif;
	
	termArea := _termArea;
	maxHeight := termArea.CM_GridArea.heightOfStack;
	gridController := _gridController;
	termID := termArea.id;
	controllerID := gridController.getID;
	
	if not regionProcessing then
		
		// ########
		// The Form
		self.mnuLcnAreaMain1.visible := true; 
		self.mnuLcnPadMain1.visible := true; 
		
		// ##############################
		// ##############################
		// AREA MENU
		// ##############################
		// ##############################
		
		self.mnuLcnAreaMain1.caption := termID  &amp; " Location &amp;Maintenance"; 
		
		// ########
		// PAD EDIT
		create menuParams transient;
		self.mnuLcnAreaHeight1.userObject := menuParams;
		menuParams.setForCreate(YRD_PadArea.AreaMode_Height,null,null,termArea,null,null);
		self.mnuLcnAreaHeight1.caption := termID &amp; " Pad &amp;Edit...";
		self.mnuLcnAreaHeight1.visible := true;
	
		// ########
		// LABOUR
		create menuParams transient;
		self.mnuLcnAreaLabour1.userObject := menuParams;
		menuParams.setForCreate(YRD_PadArea.AreaMode_Labour,null,null,termArea,null,null);
		self.mnuLcnAreaLabour1.caption := termID &amp; " &amp;Labour Restrictions...";
		self.mnuLcnAreaLabour1.visible := true;
	
		// ########
		// SUB BLOCK STACKS
		create menuParams transient;
		self.mnuLcnAreaSBS1.userObject := menuParams;
		menuParams.setForCreate(YRD_PadArea.AreaMode_SubBlock,null,null,termArea,null,null); // just generally go to SBS
		self.mnuLcnAreaSBS1.caption := termID &amp; " &amp;Sub BlockStacks...";
		self.mnuLcnAreaSBS1.visible := true;
		
	
	// ############################################################################################################
	
		// ##############################
		// ##############################
		// PAD MENU
		// ##############################
		// ##############################
		
		aSub := gridController.mySubBlockStack;

		self.mnuLcnPadMain1.caption := controllerID  &amp; " Location &amp;Maintenance";
		self.mnuLcnPadMain1.visible := true;
		
		// ########
		// PAD EDIT
		create menuParams transient;
		self.mnuLcnPadPad1.userObject := menuParams;
		menuParams.setForCreate(YRD_PadArea.AreaMode_Height,null,gridController,termArea,null,null);
		self.mnuLcnPadPad1.caption := controllerID &amp; " Pad &amp;Edit...";
		self.mnuLcnPadPad1.visible := true;
		
		self.mnuLcnPadLocation1.visible := false;
		// ########
		// SUB BLOCK STACKS
		if aSub &lt;&gt; null then
			create menuParams transient;
			self.mnuLcnPadSBS1.userObject := menuParams;
			menuParams.setForCreate(YRD_PadArea.AreaMode_SubBlock,null,aSub,termArea,null,null); // just generally go to SBS
			self.mnuLcnPadSBS1.visible := true;
			self.mnuLcnPadSBS1.caption := aSub.id &amp; " &amp;Sub BlockStack...";
		else
			self.mnuLcnPadSBS1.visible := false;
		endif;
		
	endif;

	// #################################
	// DYNAMIC LOCATION CONTROLLER MENUS
	
	
	
	
	if regionProcessing then
		// height restriction and availability only.. ( for the selection of pads.)
		if self.allSelectedRegionLocs.size &gt; 1 then
			multiProcessing := true;
			controllerID := "Selected Pad(s)";
		endif;
		
		self.mnuLcnPadMain1.caption := controllerID &amp; " Location &amp;Maintenance";
		self.mnuLcnPadMain1.visible := true; 
		
	endif;
		
	// clean up first
	foreach idx in 1 to 8 do
		aChildMenuItem := self.mnuLcnPadMain1.getMenuItem(MENU_INDEX_NOTHING_BASE + idx);
		if aChildMenuItem &lt;&gt; null then
			delete aChildMenuItem;
		endif;
	endforeach;
	foreach idx in 1 to 10 do
		aChildMenuItem := self.mnuLcnPadMain1.getMenuItem(MENU_INDEX_LABOUR_BASE + idx);
		if aChildMenuItem &lt;&gt; null then
			delete aChildMenuItem;
		endif;
	endforeach;
	
	aChildMenuItem := self.mnuLcnPadMain1.getMenuItem(MENU_INDEX_POWER_GOOD);
	if aChildMenuItem &lt;&gt; null then
		delete aChildMenuItem;
	endif;
	aChildMenuItem := self.mnuLcnPadMain1.getMenuItem(MENU_INDEX_POWER_BAD);
	if aChildMenuItem &lt;&gt; null then
		delete aChildMenuItem;
	endif;
	aChildMenuItem := self.mnuLcnPadMain1.getMenuItem(MENU_INDEX_UNAVAIL);
	if aChildMenuItem &lt;&gt; null then
		delete aChildMenuItem;
	endif;
	aChildMenuItem := self.mnuLcnPadMain1.getMenuItem(MENU_INDEX_AVAIL);
	if aChildMenuItem &lt;&gt; null then
		delete aChildMenuItem;
	endif;
	
	// make those menus
	// ########
	// LABOUR
	self.mnuLcnPadLabour1.visible := false;
	idx := 0;
	if not multiProcessing then
		foreach aLabR in gridController.allLabourRestrictions do
			idx := idx + 1;
			create menuParams transient;
			aChildMenuItem := self.mnuLcnPadMain1.getMenuItem(MENU_INDEX_LABOUR_BASE + idx);
			if aChildMenuItem = null then
				aChildMenuItem := self.mnuLcnPadMain1.loadSubMenu(MENU_INDEX_LABOUR_BASE + idx);
			endif;
			aChildMenuItem.caption := controllerID &amp; " &amp;" &amp; aLabR.id &amp; " Labour Restriction...";
			aChildMenuItem.userObject := menuParams;
			menuParams.setForCreate(YRD_PadArea.AreaMode_Labour,null,aLabR,termArea,null,null);
		endforeach;
	endif;

	if CM_StackController.hasInstance(gridController) or  CM_RTGController.hasInstance(gridController) then
		if CM_StackController.hasInstance(gridController) then
			aStackController := gridController.CM_StackController;
		endif;
		if  CM_RTGController.hasInstance(gridController)  then
			rtgController := gridController.CM_RTGController;
		
		endif;
		
		// ### AVAILABLE OR NOT
//		if not aStackController.CM_GridController.amIAvailable then
		if not gridController.amIAvailable and not multiProcessing then
			aChildMenuItem := self.mnuLcnPadMain1.getMenuItem(MENU_INDEX_AVAIL);
			if aChildMenuItem = null then
				aChildMenuItem := self.mnuLcnPadMain1.loadSubMenu(MENU_INDEX_AVAIL);
			endif;
			aChildMenuItem.caption := controllerID &amp; " Make &amp;Available";
//			aChildMenuItem.userObject := aStackController;
			aChildMenuItem.userObject := gridController;
			aChildMenuItem.helpContextId := MENU_INDEX_AVAIL;

		else
//			if aStackController.availability &lt;&gt; PAD_AVAILABLE then
			if (aStackController &lt;&gt; null and aStackController.availability &lt;&gt; PAD_AVAILABLE)
			or (rtgController &lt;&gt; null and rtgController.availability &lt;&gt; PAD_AVAILABLE)
			or multiProcessing
			then
				aChildMenuItem := self.mnuLcnPadMain1.getMenuItem(MENU_INDEX_AVAIL);
				if aChildMenuItem = null then
					aChildMenuItem := self.mnuLcnPadMain1.loadSubMenu(MENU_INDEX_AVAIL);
				endif;
				aChildMenuItem.caption := controllerID &amp; " Make &amp;Available";
//				aChildMenuItem.userObject := aStackController;
				aChildMenuItem.userObject := gridController;
				aChildMenuItem.helpContextId := MENU_INDEX_AVAIL;
			endif;

			aChildMenuItem := self.mnuLcnPadMain1.getMenuItem(MENU_INDEX_UNAVAIL);
			if aChildMenuItem = null then
				aChildMenuItem := self.mnuLcnPadMain1.loadSubMenu(MENU_INDEX_UNAVAIL);
			endif;
			aChildMenuItem.caption := controllerID &amp; " Make &amp;Unavailable";
//			aChildMenuItem.userObject := aStackController;
			aChildMenuItem.userObject := gridController;
			aChildMenuItem.helpContextId := MENU_INDEX_UNAVAIL;
		endif;
		
		// ### NOTHING FROM... MENUS
		foreach idx in 1 to maxHeight do
			nuthinIndex := MENU_INDEX_NOTHING_BASE + idx;
			aChildMenuItem := self.mnuLcnPadMain1.getMenuItem(nuthinIndex);
			if aChildMenuItem = null then
				aChildMenuItem := self.mnuLcnPadMain1.loadSubMenu(nuthinIndex);
			endif;
			aChildMenuItem.caption := controllerID &amp; " Nothing From &amp;" &amp; idx.String;
//			aChildMenuItem.userObject := aStackController;
			aChildMenuItem.userObject := gridController;
			aChildMenuItem.helpContextId := nuthinIndex;
		endforeach;	
	endif;
	
	// ### POWER GOOD OR BAD
	if not multiProcessing then
		if gridController.hasPower then
			if gridController.powerDamaged then
				aChildMenuItem := self.mnuLcnPadMain1.getMenuItem(MENU_INDEX_POWER_GOOD);
				if aChildMenuItem = null then
					aChildMenuItem := self.mnuLcnPadMain1.loadSubMenu(MENU_INDEX_POWER_GOOD);
				endif;
				aChildMenuItem.caption := controllerID &amp; " Power Is &amp;Good";
				aChildMenuItem.userObject := gridController;
				aChildMenuItem.helpContextId := MENU_INDEX_POWER_GOOD;
	
			else
				aChildMenuItem := self.mnuLcnPadMain1.getMenuItem(MENU_INDEX_POWER_BAD);
				if aChildMenuItem = null then
					aChildMenuItem := self.mnuLcnPadMain1.loadSubMenu(MENU_INDEX_POWER_BAD);
				endif;
				aChildMenuItem.caption := controllerID &amp; " Power Is &amp;Bad";
				aChildMenuItem.userObject := gridController;
				aChildMenuItem.helpContextId := MENU_INDEX_POWER_BAD;
			endif;
		endif;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_termArea" type="CM_TerminalArea"/>
        <Parameter name="_gridController" type="CM_GridController"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuOutOfAllocation" id="da10d0c9-12d5-4a86-a586-ebe347a0047f">
        <updating/>
        <source>doBuildMnuOutOfAllocation(_object :Object; _menuCargo, _menuOA, _menuShow, _menuList, _menuAutoPlan :MenuItem input)updating, protected;
/*
Parameters:	_object		- a terminal area of grid object
			_menuCargo	- either mnuAreaCargo1 or mnuBayCargo1
			_menuOA		- either mnuAreaOutofAll1 or mnuBayOutofAll1
			
Date		Who		Reason
08 November 2011	cnwcs5	Initial creation - par 28623 - Improve menu build performance
*/
vars
	array		:CM_TIArray;
	isEnabled	:Boolean;
begin
	if not _menuCargo.visible or not _menuCargo.enabled then
		// no submenus possible
		return;
	endif;
	
	// the Out of Allocation menu item is enabled if there are any OA tracked items
	create array transient;
	self.findOATisFromObject( _object, array);

	// always show them - they may just be disabled
	_menuShow.visible 			:= true;
	_menuList.visible 			:= true;
	_menuAutoPlan.visible 		:= true;

	isEnabled		:= not array.isEmpty;
	
	if isEnabled then
		// show, list and autoplan menu items are visible if the out of allocation
		// menu item is enabled.  they were previously hidden in doContextMenuBuild
		_menuShow.enabled 			:= true;
		_menuShow.userObject 		:= _object;
		_menuList.enabled 			:= true;
		_menuList.userObject 		:= _object;
		_menuAutoPlan.enabled 		:= true;
		_menuAutoPlan.userObject 	:= _object;
	else
		_menuShow.enabled 			:= false;
		_menuShow.userObject 		:= null;
		_menuList.enabled 			:= false;
		_menuList.userObject 		:= null;
		_menuAutoPlan.enabled 		:= false;
		_menuAutoPlan.userObject 	:= null;	
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_menuCargo" type="MenuItem" usage="input"/>
        <Parameter name="_menuOA" type="MenuItem" usage="input"/>
        <Parameter name="_menuShow" type="MenuItem" usage="input"/>
        <Parameter name="_menuList" type="MenuItem" usage="input"/>
        <Parameter name="_menuAutoPlan" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuRemoveLabRestricts" id="3237cd09-12b3-4e1f-bc9b-0846be254d19">
        <source>doBuildMnuRemoveLabRestricts( _ta : CM_TerminalArea ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 September 2011	cnwndl1	Initial creation	Par 28236	Copy of version from YRD_GridAreasOverviewForm
															but using local mnu item names....
														

*/

vars
	str :String;
	index :Integer;
	mnuChild,mnuMaster	: MenuItem;
	mnuIndex 	: Integer;
	labourRestriction : CM_LabourRestriction;

begin

	if not app.myCurrentUserCan(self.myTerminal,PmAdmLabrestrMaint) 
	or _ta.allRestrictionsLabour.isEmpty 
	or not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then // TFS 2198 CNWAB1
		self.mnuLabourRemRest1.enabled := false;
		self.mnuLabourRemRest1.visible := false;
		return;
	endif;

	mnuMaster := self.mnuLabourRemRest1;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.userObject := null;
	mnuMaster.helpKeyword := "MAIN";

	foreach index in 1 to 50 do
		mnuChild := mnuMaster.getMenuItem(index); // check if the menu is already cloned
		delete mnuChild;
	endforeach;

	foreach labourRestriction in _ta.allRestrictionsLabour do
		mnuIndex 	:= mnuIndex + 1;
		mnuChild := mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned
		if mnuChild = null then
			mnuChild := mnuMaster.loadSubMenu(mnuIndex); // Clone menu
		endif;
		
		mnuChild.caption := labourRestriction.getDisplayStringFull();
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := labourRestriction.id ;
		mnuChild.userObject := labourRestriction;
	endforeach; 
	
	if mnuIndex &gt; 0 then // index has not been set as no termsubareas added above 
		mnuIndex := mnuIndex + 1;
		mnuChild := mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned	
		if mnuChild = null then
			mnuChild := mnuMaster.loadSubMenu(mnuIndex); // Clone menu
		endif;
		mnuChild.caption := "-";
	endif;
	
	mnuIndex := mnuIndex + 1; 
	
	mnuChild := mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned
	if mnuChild = null then
		mnuChild := mnuMaster.loadSubMenu(mnuIndex); // Clone menu
	endif;
	mnuChild.caption := "&amp;All...";
	mnuChild.visible := true;
	mnuChild.enabled := true;
	mnuChild.helpKeyword := "ALL";
	mnuChild.userObject := _ta;
	
	mnuIndex := mnuIndex + 1; 
		
	mnuChild := mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned
	if mnuChild = null then
		mnuChild := mnuMaster.loadSubMenu(mnuIndex); // Clone menu
	endif;
	mnuChild.caption := "&amp;View Restrictions...";
	mnuChild.visible := true;
	mnuChild.enabled := true;
	mnuChild.helpKeyword := "VIEW";
	mnuChild.userObject := _ta;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="doBuildRequestSelector" id="6acfe647-0210-42c5-be3c-e36afc467932">
        <source>doBuildRequestSelector(menuItem: MenuItem input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 January 2012	cnwndl1	Initial creation	Par 28953

*/

vars

	reserve : CM_ReserveSelection;
	deliveryRequest : CM_DeliveryRequest;
	
	transUserQuery : CM_MenuUserQuery;
	transCriteriaLineHolder : CM_QueryCriteriaLineHolder;

	selectorForm : CMUI_Selector;
	queryDef : CM_QueryDefinition;
	
	msg : String;

begin

	// get the selected YAM
	if menuItem &lt;&gt; null and menuItem.userObject.isKindOf( CM_ReserveSelection ) then
		reserve := menuItem.userObject.CM_ReserveSelection;
	elseif menuItem &lt;&gt; null and menuItem.userObject.isKindOf( CM_DeliveryRequest ) then
		deliveryRequest := menuItem.userObject.CM_DeliveryRequest;
	endif;
	
	if reserve = null and deliveryRequest = null then
		return;
	endif;
	
	// Build a selector query that will match cargo to the request details.
	// set up the base query details
	create transUserQuery transient;
	create transCriteriaLineHolder transient;
	transUserQuery.allCriteriaLineHolders.add(transCriteriaLineHolder);
	
	if reserve &lt;&gt; null then
		msg := reserve.buildQueryToMatchDetails( transUserQuery, transCriteriaLineHolder );
	elseif deliveryRequest &lt;&gt; null then
		deliveryRequest.buildQueryToMatchDetails( transUserQuery, transCriteriaLineHolder );
	endif;

	// get the selector form
	selectorForm	:=	app.getSelectorForm(self, self.myMasterMenuAction);	
	if selectorForm = null then
		return;
	endif;
	
	//show the query details...
	selectorForm.show();
	selectorForm.showQuery(transUserQuery);
	
	if msg &lt;&gt; null then
		msg := app.getErrorString(Unable_convert_criteria) &amp; CrLf &amp; msg;
		app.msgBox(msg,app.getErrorString(Warning),MsgBox_OK_Only);
	endif;
	
epilog

	delete transUserQuery;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBuildSep1AMenuItems" id="b59498c9-a8a9-4370-96b4-d08c0caec9f6">
        <updating/>
        <source>doBuildSep1AMenuItems( _irrBlockCont : CM_LocationsController ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 August 2013	cnwndl1	Initial creation	Par 32308

*/

vars
	hasCargo		: Boolean;
	menuShow, menuList, menuCargo, menuSep, menuEdit, menuMove, 
	menuTest, menuOA	:MenuItem;
	irrBlockCont : CM_IrregularBlockController;
	maintenabled : Boolean;
begin
	maintenabled := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);	// TFS 2198 CNWAB1

	menuShow 	:= self.mnuBayShow1;
	menuList	:= self.mnuBayList1;
	menuCargo	:= self.mnuBayCargo1;
	menuSep		:= self.mnuNewSep1;
	menuEdit 	:= self.mnuBayEdit1;
	menuMove	:= self.mnuBayMove1;
	menuTest	:= self.mnuBayTestAP1;
	menuOA		:= self.mnuBayOutofAll1;

	if _irrBlockCont = null then	
		return;
	endif;
		
	menuShow.caption 	:= "Show "&amp; _irrBlockCont.ident &amp; "...";
	menuList.caption 	:= "List "&amp; _irrBlockCont.ident &amp; "...";
	menuCargo.caption 	:= "Cargo "&amp; _irrBlockCont.ident;
	
	menuShow.userObject	:= _irrBlockCont; //epr par 34994 6/10/14
	menuShow.visible 	:= _irrBlockCont.isRack; //epr par 34995 29/10/14
	menuList.visible 	:= true;
	menuCargo.visible 	:= true;
	
	hasCargo := self.hasCargoInObject (_irrBlockCont);

	if hasCargo then
		menuList.userObject 	:= _irrBlockCont;
		menuList.enabled 		:= true;
		menuCargo.userObject 	:= _irrBlockCont;
		menuCargo.enabled 		:= true;
	else
		menuList.enabled 		:= false;
		menuCargo.enabled 		:= false;
	endif;
	
	menuSep.visible := true;
		
	// set up the sub menus.
	if hasCargo then
		menuEdit.visible 		:= maintenabled;
		menuEdit.userObject 	:= _irrBlockCont;
		menuMove.visible 		:= maintenabled;
		menuMove.userObject 	:= _irrBlockCont;
		menuTest.visible 		:= maintenabled;
		menuTest.userObject 	:= _irrBlockCont;	
		menuOA.visible			:= maintenabled;
		menuOA.enabled			:= true;
		menuOA.userObject		:= _irrBlockCont;
	endif;

	// remaining menu items will be enabled/disabled when the Bay Cargo menu item is clicked
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_irrBlockCont" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="doBuildSep1MenuItems" id="309e2baa-0e2c-4677-bbc8-8d0405cd7172">
        <updating/>
        <source>doBuildSep1MenuItems( _anLC : CM_LocationsController ) updating, protected;
/*
Date				Who		Reason
22 September 2011	cnwndl1	Initial creation	Par 28236
08/11/2011			cnwcs5	par 28623 - improve performance when loading menus
*/

vars
	gridController 	: CM_GridController;
	gridObject 		: CM_GridObject;
	type 			: String;
	hasCargo		: Boolean;
	menuShow, menuList, menuCargo, menuSep, menuEdit, menuMove, 
	menuTest, menuOA	:MenuItem;
	irrBlockCont : CM_IrregularBlockController;
	maintenabled : Boolean;
begin
	maintenabled := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);	// TFS 2198 CNWAB1

	menuShow 	:= self.mnuBayShow1;
	menuList	:= self.mnuBayList1;
	menuCargo	:= self.mnuBayCargo1;
	menuSep		:= self.mnuNewSep1;
	menuEdit 	:= self.mnuBayEdit1;
	menuMove	:= self.mnuBayMove1;
	menuTest	:= self.mnuBayTestAP1;
	menuOA		:= self.mnuBayOutofAll1;
	
	menuShow.visible 		:= false;
	menuList.visible 		:= false;
	menuCargo.visible 		:= false;
	menuSep.visible 		:= false;
	menuEdit.visible 		:= false;
	menuMove.visible 		:= false;
	menuTest.visible 		:= false;
	menuOA.visible 			:= false;
	
	// the following menu items will be enabled/disabled in doBuildMnuOutOfAllocation
	self.mnuBayOAShow1.visible 		:= false;
	self.mnuBayOAList1.visible 		:= false;
	self.mnuBayOAAutoPlan1.visible 	:= false;
	
	if not self.allSelectedRegionLocs.isEmpty then
		// don't want this section if we are region based.
		return;
	endif;

	if _anLC = null then	
		return;
	endif;
	
	if _anLC.isKindOf(CM_GridController) then
		gridController := _anLC.CM_GridController;
	elseif _anLC.isKindOf(CM_IrregularBlockController) then	//28 Aug 2013	NDL	Par 32308
		irrBlockCont := _anLC.CM_IrregularBlockController;
	endif;
	
	if gridController = null and irrBlockCont = null then	
		return;
	endif;
	
	//28 Aug 2013	NDL	Par 32308
	if irrBlockCont &lt;&gt; null then
		self.doBuildSep1AMenuItems( irrBlockCont );
		return;
	endif;
	
	if gridController.isForkLiftController() then // TFS 4436
		gridObject 	:= gridController.CM_StackController.myGridColumn; // TFS 4436
		type 		:= "Bay"; // TFS 4436
	elseif gridController.isKindOf( CM_StackController ) then
		gridObject 	:= gridController.CM_StackController.myGridRow;
		type 		:= "Row";
		
	elseif gridController.isKindOf( CM_RTGController ) then
		gridObject 	:= gridController.CM_RTGController.myGridColumn;
		type 		:= "Bay";
	endif;
	
	if gridObject = null then	
		return;
	endif;
		
	menuShow.caption 	:= "Show "&amp; type &amp; "...";
	menuList.caption 	:= "List "&amp; type &amp; "...";
	menuCargo.caption 	:= "Cargo "&amp; type;
	
	
	menuShow.userObject := gridObject;
	menuShow.visible 	:= true;

	menuList.visible 	:= true;
	menuCargo.visible 	:= true;
	
	hasCargo := self.hasCargoInObject (gridObject);

	if hasCargo then
		menuList.userObject 	:= gridObject;
		menuList.enabled 		:= true;
		menuCargo.userObject 	:= gridObject;
		menuCargo.enabled 		:= true;
	else
		menuList.enabled 		:= false;
		menuCargo.enabled 		:= false;
	endif;
	
	menuSep.visible := true;
		
	// set up the sub menus.
	if hasCargo then
		menuEdit.visible 		:= maintenabled;
		menuEdit.userObject 	:= gridObject;
		menuMove.visible 		:= maintenabled;
		menuMove.userObject 	:= gridObject;
		menuTest.visible 		:= maintenabled;
		menuTest.userObject 	:= gridObject;	
		menuOA.visible			:= maintenabled;
		menuOA.enabled			:= true;
		menuOA.userObject		:= gridObject;
	endif;

	// remaining menu items will be enabled/disabled when the Bay Cargo menu item is clicked
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_anLC" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="doBuildSep2MenuItems" id="2c7a77c6-04ec-4dd2-9b05-f1ff706957bc">
        <updating/>
        <source>doBuildSep2MenuItems( _anLC : CM_LocationsController ) updating, protected;
/*
Date				Who		Reason
22 September 2011	cnwndl1	Initial creation	Par 28236
08/11/2011			cnwcs5	par 28623 - improve performance when loading menus
26/06/2020			jlgdap1	TFS 49577 ASPA Double Click Action in Satellite View
13/11/2024 			navsaa30 MTN - UX issue with the implemented solution
*/

vars
	termArea 		: CM_TerminalArea;
	hasCargo		: Boolean;
	menuShow, menuList, menuCargo, menuSep, menuEdit, menuMove, 
	menuTest, menuOA		:MenuItem;
	maintenabled : Boolean;
begin
	maintenabled := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);	// TFS 2198 CNWAB1

	menuShow 	:= self.mnuAreaShow1;
	menuList	:= self.mnuAreaList1;
	menuCargo	:= self.mnuAreaCargo1;
	menuSep		:= self.mnuNewSep2;
	menuEdit 	:= self.mnuAreaEdit1;
	menuMove	:= self.mnuAreaMove1;
	menuTest	:= self.mnuAreaTestAP1;
	menuOA		:= self.mnuAreaOutofAll1;
	
	menuShow.visible 		:= false;
	menuList.visible 		:= false;
	menuCargo.visible 		:= false;
	menuSep.visible 		:= false;
	menuEdit.visible 		:= false;
	menuMove.visible 		:= false;
	menuTest.visible 		:= false;
	menuOA.visible 			:= false;
	
	// the following menu items will be enabled/disabled in doBuildMnuOutOfAllocation
	self.mnuAreaOutofAll1.visible 	:= false;
	self.mnuAreaOAShow1.visible 	:= false;
	self.mnuAreaOAList1.visible 	:= false;
	self.mnuAreaOAAutoPlan1.visible := false;
	
	if not self.allSelectedRegionLocs.isEmpty then
		// don't want this section if we are region based.
		return;
	endif;

	if _anLC = null then	
		return;
	endif;
	
	termArea := _anLC.myTerminalArea;
	
	if termArea = null then	
		return;
	endif;
		
	menuShow.userObject := termArea;
	menuShow.visible 	:= termArea.isKindOf( CM_GridArea ) or termArea.isKindOf( CM_RoRoLaneArea ) or termArea.isKindOf(CM_IrregularBlockArea);
	menuList.visible 	:= true;
	menuCargo.visible 	:= true;								//10 Oct 2011	NDL	Par 28397
		
	hasCargo := self.hasCargoInObject (termArea);
	
	if hasCargo and ( not termArea.isKindOf( CM_IrregularBlockArea ) ) then
		menuList.userObject := termArea;
		menuList.enabled 	:= true;
		menuCargo.enabled 	:= true;
	else
		if self.myTerminal.getConfig(DblClkSatShowSubArea).Boolean then			//navsaa30  12/11/24 #MTN-33229
			menuList.userObject := termArea;
			menuList.enabled 	:= true;
			menuCargo.enabled 	:= true;
		else
			menuList.enabled 	:= false;
			menuCargo.enabled 	:= false;
		endif;
	endif;
	
	menuSep.visible := true;
	
	// set up the sub menus.
	if hasCargo then
		menuEdit.visible 	:= maintenabled;
		menuEdit.userObject := termArea;
		menuMove.visible 	:= maintenabled;
		menuMove.userObject := termArea;
		menuTest.visible 	:= maintenabled;
		menuTest.userObject := termArea;
		menuOA.visible		:= maintenabled;
		menuOA.enabled		:= true;
		menuOA.userObject	:= termArea;
	endif;
	
	if not menuEdit.visible and not menuMove.visible and not menuTest.visible and not menuOA.visible then	// TFS 49577
		menuCargo.visible := false;																			// TFS 49577
	endif;																									// TFS 49577

	// remaining menu items will be enabled/disabled when the Bay Cargo menu item is clicked
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_anLC" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="doBuildSep3AMenuItems" id="8392c843-ecee-49bd-84bc-350032c128ec">
        <updating/>
        <source>doBuildSep3AMenuItems() updating, protected;

/*

Purpose:			

Parameters:		// This one is for non grided regions.

				//  I.e. Block Controllers, and ROROControllers

Return Value:		


Date		Who		Reason
20 January 2012	cnwndl1	Initial creation	Par 28901

*/

vars

	tiArray 		: CM_TIArray;
	hasCargo		: Boolean;
	menuShow, menuList, menuCargo, menuSep, menuOA	:MenuItem;
	canShow : Boolean;
	
	maintenabled : Boolean;
begin
	maintenabled := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);	// TFS 2198 CNWAB1


	menuShow 	:= self.mnuRegionShow1;
	menuList	:= self.mnuRegionList1;
	menuCargo	:= self.mnuRegionCargo1;
	menuSep		:= self.mnuNewSep3;
	menuOA		:= self.mnuRegionOutofAll1;
	
	menuShow.visible 	:= false;
	menuList.visible 	:= false;
	menuCargo.visible 	:= false;
	menuSep.visible 	:= false;
	
	if self.allSelectedRegionLocs.isEmpty then
		// No region(s) selected.
		return;
	endif;
	
	menuShow.visible 	:= true;
	menuShow.enabled 	:= true;
	menuList.visible 	:= true;
	menuList.enabled 	:= true;
	menuCargo.visible 	:= true;
	menuCargo.enabled 	:= true;
	menuSep.visible 	:= true;
	
	//have we got any associated cargo
	create tiArray transient;
	self.findRegionTis( tiArray, true );
	
	hasCargo := not tiArray.isEmpty;
	
	canShow := self.includesCargoInShowableArea();
	menuShow.enabled	:= canShow;
	
	if not hasCargo then		
		menuList.enabled 	:= false;
		menuCargo.enabled 	:= false;
		if not canShow then
			return;
		endif;
	endif;
	
	// set up the sub menus.
	self.mnuRegionEdit1.visible 	:= maintenabled;
	self.mnuRegionMove1.visible 	:= maintenabled;
	self.mnuRegionTestAP1.visible 	:= maintenabled;	
	
	menuOA.visible := maintenabled;
	menuOA.enabled := true;
	
	// remaining menu items will be enabled/disabled when the Bay Cargo menu item is clicked
epilog

	delete tiArray;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBuildSep3MenuItems" id="98ded1d0-75aa-43a5-9f5d-8b3db3d9723d">
        <updating/>
        <source>doBuildSep3MenuItems( _anLC : CM_LocationsController ) updating, protected;
/*
Date				Who		Reason
26 September 2011	cnwndl1	Initial creation	Par 28236
08/11/2011			cnwcs5	par 28623 - improve performance when loading menus
*/

vars
	tiArray 		: CM_TIArray;
	gridLocArray 	: CM_ObjectArray;
	hasCargo		: Boolean;
	menuShow, menuList, menuCargo, menuSep, menuOA	:MenuItem;
	maintenabled : Boolean;
begin
	maintenabled := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);	// TFS 2198 CNWAB1

	menuShow 	:= self.mnuRegionShow1;
	menuList	:= self.mnuRegionList1;
	menuCargo	:= self.mnuRegionCargo1;
	menuSep		:= self.mnuNewSep3;
	menuOA		:= self.mnuRegionOutofAll1;
	
	menuShow.visible 	:= false;
	menuList.visible 	:= false;
	menuCargo.visible 	:= false;
	menuSep.visible 	:= false;
	
	if self.allSelectedRegionLocs.isEmpty then
		// No region(s) selected.
		return;
	endif;
	
	create gridLocArray transient;
	self.findRegionGridLocs( gridLocArray, true, false );
	
	if gridLocArray.isEmpty then
		self.doBuildSep3AMenuItems();	//20 Jan 2012	NDL	Par 28901
		return;
	endif;
	
	menuShow.visible 	:= true;
	menuShow.enabled 	:= true;
	menuList.visible 	:= true;
	menuList.enabled 	:= true;
	menuCargo.visible 	:= true;
	menuCargo.enabled 	:= true;
	menuSep.visible 	:= true;
	
	//have we got any associated cargo
	create tiArray transient;
	self.findRegionTis( tiArray, true );
	
	hasCargo := not tiArray.isEmpty;
	
	if not hasCargo then
		//menuShow.enabled	:= false;
		menuList.enabled 	:= false;
		menuCargo.enabled 	:= false;
		return;
	endif;
	
	// set up the sub menus.
	self.mnuRegionEdit1.visible 	:= maintenabled;
	self.mnuRegionMove1.visible 	:= maintenabled;
	self.mnuRegionTestAP1.visible 	:= maintenabled;	
	
	menuOA.visible := maintenabled;
	menuOA.enabled := true;
	
	// remaining menu items will be enabled/disabled when the Bay Cargo menu item is clicked
epilog

	delete tiArray;
	delete gridLocArray;
end;</source>
        <access>protected</access>
        <Parameter name="_anLC" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="doBuildSep4MenuItems" id="c8139b00-6fc1-4f5b-8d76-4db638287df6">
        <updating/>
        <source>doBuildSep4MenuItems( _anLC : CM_LocationsController ) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 September 2011	cnwndl1	Initial creation	Par 28236

*/

vars

	gridObject : CM_GridObject;
	type : String;
	irrBlockCont : CM_IrregularBlockController;
	obj : Object;

	maintenabled : Boolean;
begin
	maintenabled := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);	// TFS 2198 CNWAB1


	self.mnuSummarise1.visible := self.bAllowSummaryDefn;	// Top level item
	self.mnuReport1.visible := true;	// Top level option.

	
	self.mnuAllSum1.visible := true;
	self.mnuAllSum1.caption := "All...";
	
	self.mnuAllReport1.visible := true;
	self.mnuAllReport1.caption := "All...";
	
	//Add lower level summarise and report  items based on the population of existing menu item (less processing)
	
	self.mnuSumRegion1.enabled := self.mnuRegionList1.enabled;
	self.mnuSumRegion1.visible := self.mnuRegionList1.visible;
	
	self.mnuRegionReport1.enabled := self.mnuRegionList1.enabled;
	self.mnuRegionReport1.visible := self.mnuRegionList1.visible;
	
	if self.mnuAreaList1.userObject &lt;&gt; null and self.mnuAreaList1.userObject.isKindOf( CM_TerminalArea ) then
		self.mnuAreaSum1.enabled := self.mnuAreaList1.enabled;
		self.mnuAreaSum1.visible := self.mnuAreaList1.visible;
		self.mnuAreaSum1.userObject := self.mnuAreaList1.userObject;
		self.mnuAreaSum1.caption := "Area...";
		
		self.mnuAreaReport1.enabled := self.mnuAreaList1.enabled;
		self.mnuAreaReport1.visible := self.mnuAreaList1.visible;
		self.mnuAreaReport1.userObject := self.mnuAreaList1.userObject;
		self.mnuAreaReport1.caption := "Area...";
		
	else
		self.mnuAreaSum1.visible := false;
		self.mnuAreaReport1.visible := false;
		
	endif;
	
	
	if self.mnuBayList1.userObject &lt;&gt; null and ( self.mnuBayList1.userObject.isKindOf(CM_GridObject) or self.mnuBayList1.userObject.isKindOf(CM_IrregularBlockController) )then
		obj := self.mnuBayList1.userObject;
		if obj.isKindOf(CM_GridObject) then
			gridObject := obj.CM_GridObject;
			if gridObject.isKindOf( CM_GridRow ) then
				type := "Row...";
			elseif gridObject.isKindOf(CM_GridColumn) then
				type := "Bay...";
			endif;
		elseif obj.isKindOf(CM_IrregularBlockController) then
			irrBlockCont := obj.CM_IrregularBlockController;
			type := irrBlockCont.ident &amp; "...";
		endif;
		self.mnuBaySum1.enabled := self.mnuBayList1.enabled;
		self.mnuBaySum1.visible := self.mnuBayList1.visible;
		self.mnuBaySum1.userObject := obj;
		self.mnuBaySum1.caption := type;
		
		self.mnuBayReport1.enabled := self.mnuBayList1.enabled;
		self.mnuBayReport1.visible := self.mnuBayList1.visible;
		self.mnuBayReport1.userObject := obj;
		self.mnuBayReport1.caption := type;
		
	else
		self.mnuBaySum1.visible := false;
		self.mnuBayReport1.visible := false;
	endif;

	
	self.mnuNewSep4.visible := true;

epilog


end;</source>
        <access>protected</access>
        <Parameter name="_anLC" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="doBuildSep5MenuItems" id="d0910398-c9bf-4df3-9dc7-d1f16da22a17">
        <updating/>
        <source>doBuildSep5MenuItems( _anLC : CM_LocationsController ) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23/09/2011	cnwndl1	Initial creation
19/06/2020	jlgdap1	TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
*/

vars

	termArea : CM_TerminalArea;
	locCont : CM_LocationsController;

	maintenabled : Boolean;
begin
	maintenabled := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);	// TFS 2198 CNWAB1


	self.mnuLabourAddRest1.visible := false;
	self.mnuLabourAddRegion1.visible := false;
	self.mnuLabourRemRest1.visible := false;
	self.mnuDeckingOpt1.visible := false;
	self.mnuLcnAreaMain1.visible := false;
	self.mnuLcnPadMain1.visible := false;
	self.mnuMaintLabel.visible := false;
	self.mnuAuditDetail1.visible := false;
	self.mnuNewSep5.visible := false;
	
	
	if not self.allSelectedRegionLocs.isEmpty then	
		// this is only allowed if we have a single region selection that is all
		// within a single terminal area. ( I.e. one rectangular selection on the 
		// form that is within one terminal area.)		
		if self.allSelectedRegionObjs.size &lt;&gt; 1 then
			// More than one region selected (i.e. rectangular block of locations.)
			return;
		else
			termArea := self.allSelectedRegionLocs.first.myTerminalArea;
			self.doBuildMnuAddLabourRestricts( termArea );
			self.doBuildMnuRemoveLabRestricts( termArea );	//03 Dec 2013	NDL	Par 33130
			if self.allSelectedRegionLocs.first.isKindOf(CM_GridController) then
				self.doBuildMnuLocMaint( termArea, self.allSelectedRegionLocs.first.CM_GridController );
			endif;
			if termArea &lt;&gt; null and termArea.isGeneralCargoAllocArea() then			// TFS 49453
				if app.getMyUser.canDo(self.myTerminal, self.permissionMaint) then	// TFS 49453
					self.mnuMaintLabel.visible := true;								// TFS 49453
					self.mnuMaintLabel.userObject := _anLC;							// TFS 49453
				endif;																// TFS 49453
			endif;																	// TFS 49453
		endif;
	
	else

		if _anLC = null then	
			return;
		endif;
	
		termArea := _anLC.myTerminalArea;
		if termArea = null or termArea.isIrregularBlockArea then	
			return;
		endif;
	
		self.doBuildMnuAddLabourRestricts( termArea );
		self.doBuildMnuRemoveLabRestricts( termArea );
		self.doBuildMnuDecking( termArea );
		
		if _anLC.isKindOf( CM_GridController ) then
			self.doBuildMnuLocMaint( termArea, _anLC.CM_GridController );
		endif;
		
		if app.getMyUser.canDo (self.myTerminal, PmAdmAuditTALocationView) then
			self.mnuAuditDetail1.visible := true;
			self.mnuAuditDetail1.userObject := termArea;
			self.mnuAuditDetail1.caption := termArea.id &amp; ' ' &amp; app.getErrorString (XLAT_AuditTALocnDetails);
		endif;
	
		if termArea &lt;&gt; null and termArea.isGeneralCargoAllocArea() then			// TFS 49453
			if app.getMyUser.canDo(self.myTerminal, self.permissionMaint) then	// TFS 49453
				self.mnuMaintLabel.visible := true;								// TFS 49453
				self.mnuMaintLabel.userObject := _anLC;							// TFS 49453
			endif;																// TFS 49453
		endif;																	// TFS 49453
	endif;

epilog

	if ( self.mnuLabourAddRest1.visible or 	self.mnuLabourRemRest1.visible or
		self.mnuDeckingOpt1.visible or self.mnuLcnAreaMain1.visible or
		self.mnuAuditDetail1.visible or self.mnuLabourAddRegion1.visible )
	then
		self.mnuNewSep5.visible := true;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_anLC" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="doBuildSep6MenuItems" id="edc6ce32-a273-4220-b1a1-dcc699888862">
        <updating/>
        <source>doBuildSep6MenuItems( _anLC : CM_LocationsController ) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 September 2011	cnwndl1	Initial creation	Par 28236

*/

vars

	maintenabled : Boolean;
begin
	maintenabled := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);	// TFS 2198 CNWAB1


	self.mnuInspect1.visible := false;
	self.mnuZoom1.visible := true;
	self.doBuildMnuZoom(self.mnuZoom1);
	self.mnuPref1.visible := true;
	
	if self.myCurrentDrawingController &lt;&gt; null and self.myCurrentDrawingController.allSelectorTIs &lt;&gt; null then
		self.mnuGridSelectorClear1.visible := not self.myCurrentDrawingController.allSelectorTIs.isEmpty;
	else
		self.mnuGridSelectorClear1.visible := false;
	endif;
	
	if app.isAllowedToInspect then
	//	self.mnuShowSelectionBounds.visible	:= true;
		self.mnuInspect1.visible := true;
		if _anLC &lt;&gt; null and _anLC.myTerminalArea &lt;&gt; null then
			self.mnuInspect1.userObject := _anLC.myTerminalArea;
			self.mnuInspect1.enabled := true;
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_anLC" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="doBuildYAMSelectorQuery" id="b70cadb6-0aa2-4e64-9ef6-c500980ad900">
        <source>doBuildYAMSelectorQuery( menuItem: MenuItem input );

/*

Purpose:		

		called by "mnuYABuildSelector"
		takes the currently selected YAM and builds a query representing the cargo that should be valid
		for it.

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2012	cnwndl1	Initial creation	Par 28889

*/

vars

	ya : CM_YardAllocation;
	
	cloneUserQuery : CM_MenuUserQuery;
	cloneCriteriaLineHolder : CM_QueryCriteriaLineHolder;
	cloneQueryLine : CM_SelectorCriteriaLine;

	cloneProperty : CM_QueryProperty;
	cloneOperator : CM_QueryOperator;
	objSet : ObjectSet;
	
	selectorForm : CMUI_Selector;
	queryDef : CM_QueryDefinition;

begin

	// get the selected YAM
	if menuItem &lt;&gt; null then
		ya := menuItem.userObject.CM_YardAllocation;
	endif;
	
	if ya = null then
		return;
	endif;
	
	// Build a selector query that has site, terminal and YAM details.
	// set up the base query details
	create cloneUserQuery transient;
	create cloneCriteriaLineHolder transient;
	cloneUserQuery.allCriteriaLineHolders.add(cloneCriteriaLineHolder);
	
	//	Add Site criteria line
	create cloneQueryLine transient; 
	cloneQueryLine.setMyCriteriaLineHolder(cloneCriteriaLineHolder);
	
	create cloneProperty as CM_QTiSiteLookupProperty transient;
	cloneProperty.set(	"Site",	//_niceName : String
						CM_TrackedItem::site.name,	//_propName : String
						"CM_TrackedItem"	//_className : String
						);
	cloneProperty.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
	
	create cloneOperator as CM_QIntegerLookupEqual transient;
	cloneOperator.setSearchValue( TI_SITE_ONSITE );
	
	cloneQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
										cloneProperty,	//_myQueryProperty : CM_QueryProperty;
										cloneOperator,	//_myQueryOperator : CM_QueryOperator;
										cloneProperty.propertyName,	//_propName : String;
										cloneProperty.propertyClassName	//_propClassName : String
										);
											
	
	//	Add Terminal criteria line
	create cloneQueryLine transient; 
	cloneQueryLine.setMyCriteriaLineHolder(cloneCriteriaLineHolder);
	
	create cloneProperty as CM_QRefTerminalProperty transient;
	cloneProperty.set(	"Terminal",	//_niceName : String
						"myTerminal",	//_propName : String
						"CM_TrackedItem"	//_className : String
						);
	cloneProperty.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
	
	create cloneOperator as CM_QReferenceLookup transient;
	cloneOperator.setSearchValue( ya.myTerminal );
	
	cloneQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
										cloneProperty,	//_myQueryProperty : CM_QueryProperty;
										cloneOperator,	//_myQueryOperator : CM_QueryOperator;
										cloneProperty.propertyName,	//_propName : String;
										cloneProperty.propertyClassName	//_propClassName : String
										);
																				
	//	Add YAM criteria line
	create objSet transient;
	objSet.add( ya );
	
	create cloneQueryLine transient; 
	cloneQueryLine.setMyCriteriaLineHolder(cloneCriteriaLineHolder);
	
	create cloneProperty as QRefYardAllocationMethod transient;
	cloneProperty.set(	"Yard Allocation Range",	//_niceName : String
						CM_TrackedItem::getAllocationsForMyTermArea.name,	//_propName : String
						"CM_TrackedItem"	//_className : String
						);
	cloneProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
	
	create cloneOperator as CM_QReferenceIsOneOf transient;
	cloneOperator.setSearchValue( objSet );
	
	cloneQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
										cloneProperty,	//_myQueryProperty : CM_QueryProperty;
										cloneOperator,	//_myQueryOperator : CM_QueryOperator;
										cloneProperty.propertyName,	//_propName : String;
										cloneProperty.propertyClassName	//_propClassName : String
										);

	// get the selector form
	selectorForm	:=	app.getSelectorForm(self, self.myMasterMenuAction);	
	if selectorForm = null then
		return;
	endif;
	
	//show the query details...
	selectorForm.show();
	selectorForm.showQuery(cloneUserQuery);
	
epilog

	delete cloneUserQuery;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
