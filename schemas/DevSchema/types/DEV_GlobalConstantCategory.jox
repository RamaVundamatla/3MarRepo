    <JadeMethod name="create" id="6e4b4932-61bf-40c5-b6c6-88b2ae37d9c0">
        <updating/>
        <source>create(_name, 
		_documentationTextData	: String;
		_reason					: Integer;
		_devSchema				: DEV_Schema;
		_devConstantsSection	: DEV_SchemaConstantsSection) ::super(_name) updating;
/*

Purpose:			Constructor for DEV_GlobalConstantCategory class

Parameters:			_name:					The name of the global constant category
					_documentationTextData:	The documentation text on the global constant category
					_devConstantsSection:	The constants section object the global constant category belongs to

Return Value:		

Date		Who		Reason
27 October 2021	navpw1	Initial creation TFS: 52202

*/

begin
	//Set Attributes
	self.documentationTextData 	:= _documentationTextData;
	self.reason					:= _reason;
	
	//Set References
	self.mySection				:= _devConstantsSection;
	self.mySchema				:= _devSchema;
end;</source>
        <Parameter name="_name" type="String"/>
