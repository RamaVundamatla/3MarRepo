    <JadeMethod name="lookupCountryByCode" id="0fe5ae51-f97a-463e-8a28-82cd723b4304">
        <options>4</options>
        <source>lookupCountryByCode(_isoCode: String): CM_Country typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22 June 2023	navmd1	Initial creation 57447 Try and return a sensible country given a variable length code that could mean two different things

*/

vars

begin
	if _isoCode.length = 3 then
		return app.myRoot.allCountriesByISOCode[_isoCode];
	endif;
	
	return app.myRoot.allCountries[_isoCode];
epilog

end;</source>
        <Parameter name="_isoCode" type="String"/>
        <ReturnType type="CM_Country"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="d334987d-00cd-43d4-b2f3-d69137f7a7c8">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     09 February 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxyCountry	: CM_Country;
	completedOK		: Boolean;
begin

	proxyCountry := inheritMethod();

	// RJS - need to add other references here, including collections
	// self.ports is inversed and this is the auto end so no need
	// to copy to the proxy
	self.ports.copy(proxyCountry.ports);
	proxyCountry.myCountryRegion := self.myCountryRegion; //03/08/2023	navkc1	CR 59552   Task 59555
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyCountry;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyCountry;
	endif;
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
