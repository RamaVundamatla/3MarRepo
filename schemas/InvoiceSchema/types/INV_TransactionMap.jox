        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCalcType_click(combobox: ComboBox input) updating;
// 1279 selectively enable the Full mapping option
vars
	calcType	: CM_CalculationType;
begin
	calcType := self.cmbCalcType.listObject.CM_CalculationType;

	if calcType &lt;&gt; null and
	   calcType.allQuantityRanges.size = 0 then
		if self.optMapTypeEscPlu.value then
			self.optMapTypeEscPlu.visible := false;
			self.optMapTypeEscalt.value := true;
		endif;
		self.optMapTypeEscPlu.visible := false;
	else
		self.optMapTypeEscPlu.visible := true;
	endif;
end;
</source>
