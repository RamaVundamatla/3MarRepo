    <JadeMethod name="doConfirmDamage" id="cd7e08e2-0aa2-4ce5-98e6-90e6390f3d7c">
        <source>doConfirmDamage(_containerInfo	: DTO_ContainerInfo;
				_damageRemarks 	: String; 
				// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
				//_damageDict 	: CM_DamageInstanceByLocDict;
				_damageDict 	: CM_DamageInstanceByDmgePos;
				_errorMsgs 		: DTO_HandHeldGateErrorDict input);
/*
----------   ----------  --------------------------------------------------
Created:	20 September 2006 By cnwth2

Purpose:	Note that the damageInstanceDict might be empty, but they may still want
			to record the damage free text remarks. In this case, the container should
			be flagged as damaged.

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	pxyTI			: CM_TrackedItem;
	error			: CM_Error;
	damageInstance	: CM_DamageInstance;
begin
	self.initialiseForNewRequest(_errorMsgs);  //cnwjo3 par 24636

	if _containerInfo = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null DTO_ContainerInfo object passed in.');
		return;
	endif;
	
	if _containerInfo.myRealTrackedItem = null then
		self.addError(Err_ID_No_Match, app.getErrorString1(Err_ID_No_Match, _containerInfo.idx.String), _errorMsgs);
		return;
	endif;

	//create proxy, clear all damage instances and copy the new ones onto it
	pxyTI := app.createUpdateProxy(_containerInfo.myRealTrackedItem).CM_TrackedItem;
	// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	//pxyTI.allDamageInstances.purge();
	pxyTI.allDamageInstancesByPos.purge();
	foreach damageInstance in _damageDict do
		damageInstance.setMyTrackedItem(pxyTI);
	endforeach;
	
	if _damageRemarks &lt;&gt; null then
		pxyTI.setRemarks(_damageRemarks, true);//add to existing remarks
	endif;
	//might be actually setting damaged to false here
	pxyTI.setDamaged(_damageRemarks &lt;&gt; null or (not _damageDict.isEmpty));
	
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateTIDamage(pxyTI, app.myPassport);
	
	self.createErrorsFromPassport(_errorMsgs);


epilog
	
	delete pxyTI;

end;


</source>
        <Parameter name="_containerInfo" type="DTO_ContainerInfo"/>
        <Parameter name="_damageRemarks" type="String"/>
        <Parameter name="_damageDict" type="CM_DamageInstanceByDmgePos"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doLogoff" id="65d00f5f-f122-4878-b403-4c724c076df4">
        <source>doLogoff();
/*

Purpose:			


Return Value:		


Date		Who		Reason
13 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	tmpUser	: CM_User;
	
begin
	// PAR 25509 - Implement saved window settings for Mobile Devices 24 Aug 2010 - CNWRS2
	tmpUser := app.getMyUser();
	if tmpUser &lt;&gt; null then
		app.doSaveSettingsOnExit(tmpUser);
	endif;
	
	app.myTrxUA.trxUpdateLogoff(self.getMyMachine, app.myPassport);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doLogon" id="79d33faf-a977-499a-a0d5-1fa3765e0a1c">
        <updating/>
        <source>doLogon(_userName: String; _password : String; _errorStr : String output) updating;
/*
----------   ----------  --------------------------------------------------
Created:	11 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	result		: Integer;
begin
	
	if not self.validateRTDeviceDetails(_errorStr) then
		return;
	endif;
	
	user := app.myRoot.allUsers[_userName];
	
	if user = null then
		_errorStr :=  app.getErrorString(ERR_PASSWORD);
		return;
	endif;
	
	if not self.validateUserPermissions(_errorStr) then
		return;
	endif;
		
	
	result := app.validateUserPassword(_userName, _password);	
	
	if result &lt;&gt; 0 then
		_errorStr := app.getErrorString(result);
		app.myRoot.resolveMessagesWithExtraInfo(result, _errorStr); //+ cnwmd1 Par 22287
		return;
	endif;
	
	if app.myPassport &lt;&gt; null then
		app.myPassport.setMyTerminal(self.myTerminal);
	endif;
	
end;
</source>
        <Parameter name="_userName" type="String"/>
        <Parameter name="_password" type="String"/>
        <Parameter name="_errorStr" type="String" usage="output"/>
    </JadeMethod>
