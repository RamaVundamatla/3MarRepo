    <JadeMethod name="machineLogOff" id="9255fdc9-d68e-42e5-9aff-00ed0d78dace">
        <source>machineLogOff(_machine: CM_Machine);
//08 January 2009	cnwdw1	
//
vars
	agent: RadioTelemetryThinClientAgent;
	mediator : CM_RadioTelemetryMediator;
	id: String;
begin
	// if the machine is null, mostly likely an error has already occurred
	// don't want to return 1090 from this method as will hide the real error
	if _machine = null then		// 21/11/2011 cnwmh5
		return;
	endif;
	beginTransaction;
	create agent transient;
	if _machine.myRTDevice &lt;&gt; null then
		id := _machine.myRTDevice.id.String;
	endif;
	agent.bindMediator(_machine.myTerminal.code,  id, app.myPassport.myUser); 
	if agent.myMediator = null and app.isUnitTestGarbageCollect then
		return;
	endif;
	agent.myMediator.state := RadioTelemetryAgent.LoggedOn_Reset;
	assertEqual(agent.myMediator.machine, _machine);
	commitTransaction;
	app.myTrxRT.trxLogOff(agent, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog
	abortTransaction;
	delete agent;
end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="machineLogon" id="e56b7247-e970-4b81-963d-8c3d1fce2afb">
        <source>machineLogon(_machine: CM_Machine);
//08 January 2009	cnwdw1	
//
vars
	agent: RadioTelemetryThinClientAgent;
	connection: String;
begin
	create agent transient;
	connection := _machine.myRTDevice.id.String&amp;":"&amp;_machine.myTerminal.code	;
	//epr 8/3/2011 want the machine to be set as logged on - has flow on effects for accept, pickup if machine::loggedOn not set
	beginTransaction;
	agent.bindMediator(_machine.myTerminal.code,_machine.myRTDevice.id,app.myPassport.myUser);
	commitTransaction;
	app.myTrxRT.trxLogon(agent, connection, false, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog
	delete agent;
end;</source>
