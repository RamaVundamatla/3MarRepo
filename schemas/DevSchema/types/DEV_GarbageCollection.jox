    <JadeMethod name="archiveVoyages" id="0a296305-a59a-4d6f-90c3-d9f84076f83b">
        <updating/>
        <source>archiveVoyages(_setTime : TimeStamp) updating;

constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	errorCount : Integer;
	voy : CM_Voyage;
	iter : Iterator;
	size : String;
    dict, array : CM_VoyageArray;
	archiveInt : CMIF_ArchiveVoyage;
	error : CM_Error;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting Voyages..."); 
	if self.abortStatus = true then
		return;
	endif;

	create dict transient;
	create array transient;

	CM_Voyage.allInstances(array,0,true); 
	size := array.size.userNumberFormat($CNEC_NO_DECIMALS);
	count := 0;
	self.monitor("Checking " &amp; size &amp; " Archived Voyages for items to delete...");
	if self.abortStatus = true then
		return;
	endif;

	foreach voy in array do

		count := count + 1;
//		if count mod 100  = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("Voyages checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
				&amp; ". Voyages to archive: " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;

		if voy.archived = false and
		   voy.hasDeparted() and
		   not voy.isNullVoyage() then
			dict.add(voy);
		endif;
	endforeach;

	self.monitor("There are " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " voyages to archive"); 
	if self.abortStatus = true then
		return;
	endif;

	size := dict.size.userNumberFormat($CNEC_NO_DECIMALS);
	iter := dict.createIterator;
	count :=  0;

	create archiveInt transient;
	archiveInt.removeEDITrackedItems := true;
	archiveInt.removeNonWorkedTrackedItems := true;
	archiveInt.removePreNotifiedTrackedItems := true;
	archiveInt.removeTBATrackedItems := true;
	archiveInt.removeBookingRefs := true;
	archiveInt.archiveBookingRef := false;//10 Sep 2009	NDL	Par 10413
		
	on Exception do self.tiEraseExceptionHandler(exception);
	
	while iter.next(voy) do

		self.monitor("Archiving "&amp;voy.code&amp;" "&amp;voy.String); 
		if self.abortStatus = true then
			return;
		endif;
		archiveInt.myVoyage := voy;
		
		app.myTrxUA.trxUpdateVoyageArchive(archiveInt,app.myPassport);
		app.myPassport.myActivityCapture.stopCaptureDebugMisc();
		if (not app.myPassport.trxCompletedOK) then
				foreach error in app.myPassport.allWarnings do
					self.monitor(class.name&amp;'::'&amp;method.name&amp;' '&amp;voy.code&amp;" WARNING: "&amp;error.text);
				endforeach;
				foreach error in app.myPassport.allErrors do
					self.monitor(class.name&amp;'::'&amp;method.name&amp;' '&amp;voy.code&amp;" ERROR: "&amp;error.text);
				endforeach;
			errorCount := errorCount + 1;
//			app.showErrorWarningDialog(app.getErrorString(VoyageArchive), app.myPassport, ErrWarnMode_Update);
//			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
//			return false;
		else
//			self.clearErrorWarnings();
//			global.beep;
			count := count + 1;
			self.monitor('The selected voyage(s) has been successfully archived.');
		endif;
		app.myPassport.clearErrorsWarnings();
	endwhile;
	
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " Voyages archived. "&amp;errorCount.userNumberFormat($CNEC_NO_DECIMALS)&amp;' failed.');
	
	if self.abortStatus = true then
		return;
	endif;
	
epilog
	delete iter;
	delete dict;
	delete array;
	delete archiveInt;
	on Exception do null;
end;</source>
        <Parameter name="_setTime" type="TimeStamp"/>
    </JadeMethod>
