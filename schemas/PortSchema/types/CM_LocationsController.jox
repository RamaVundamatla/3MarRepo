    <JadeMethod name="getKPILocation" id="65292bb3-a001-4614-9f97-970467f06f3f">
        <source>getKPILocation(_agent : CMIF_SpaceUtilisationQryAgent input);
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 17/06/2014	cnwdap1		PAR #34422 Remove beginLock / endLock
//26 Feb 2015  cnwma1 PAR # 33352 Space Utilisation functionality for Block Stacks

vars
	tmpKPI 						: CM_KPILocation;
	tmpTI 						: CM_TrackedItem;
	cargoTypeCode,
	imex, ta, iso, cnts, user 	: String;
	isRoRo,
	ls, is40, isFull 			: Boolean;
	tmpISOGrp 					: CM_ISOTypeGroup;
	maxStack 					: Integer;
	length						: Decimal[16,4];
	cargoType					: CM_CargoType;
	lc							: CM_LocationsController;
begin
	user := app.myPassport.userCode;
	maxStack := self.getMaxStackingHeight();

//	app.cmsBeginLoad(ls);
//	sharedLock(self.allTrackedItems);
	//beginLock;			// PAR #34422
	if self.allTrackedItems.isEmpty then
		// update grand totals for terminal area
		_agent.myCurrentKPITerminalArea.updateLocnTotals(self, true, false, 0,maxStack, _agent);
		return;
	endif;
	
	isFull := (self.allTrackedItems.size = maxStack);
	_agent.myCurrentKPITerminalArea.updateLocnTotals(self, false, isFull, self.allTrackedItems.size,maxStack, _agent);
	
	isRoRo := self.isRoRoController(); //05/09/2025	navkc1 JIRA 35622
	
	foreach tmpTI in self.allTrackedItems discreteLock do
		length := null; //05/09/2025	navkc1 JIRA 35622
		// no double dipping for 40s
		if tmpTI.myPrimaryActualLocation &lt;&gt; self then
			continue;
		endif;
		
		if not _agent.doCheckTI(tmpTI) then // query params
			continue;
		endif;

		// get TI INFO
		is40 := (tmpTI.isAttributeTrue(TI_Attrib_IsForty) or tmpTI.isAttributeTrue(TI_Attrib_IsFortyFive));
		ta := self.myTerminalArea.id;
		imex := tmpTI.getImExStatusStringDesc(false);
		tmpISOGrp := tmpTI.getISOTypeGroup();
		iso := null;
		if tmpISOGrp &lt;&gt; null then
			iso := tmpISOGrp.code;
		endif;
		
		//05/09/2025	navkc1 JIRA 35622 - ISO type now also being used as cargo subtype
		if iso = null and not tmpTI.isContainer() then
			iso := tmpTI.productCode;
		endif;
		
		cnts := tmpTI.getContentsStatusDesc(false);
		
		cargoType := tmpTI.myCargoType; //05/09/2025	navkc1 JIRA 35622
		
		//05/09/2025	navkc1 JIRA 35622
		if cargoType &lt;&gt; null then
			cargoTypeCode := cargoType.abbreviation;
		endif;
		
		//05/09/2025	navkc1 JIRA 3562
		if isRoRo then
			length := self.CM_RoRoController.getTILengthInMetres(tmpTI);
		endif;
		
		// Create or Update KPI for location
		tmpKPI := _agent.myCurrentKPITerminalArea.allKIPLocations[_agent.dateTime,ta,imex,iso,cnts,cargoTypeCode]; //05/09/2025	navkc1 JIRA 35622
		if tmpKPI = null then
			create tmpKPI transient;
			//tmpKPI.setProxy(self.myTerminal, _agent.dateTime, user, KPI_Type_Location, ta,imex,iso,cnts, is40);     //26/02/2015  cnwma1 PAR #33352
			//tmpKPI.setProxy(tmpTI,self.myTerminal, _agent.dateTime, user, KPI_Type_Location, ta,imex,iso,cnts, is40); //26/02/2015  cnwma1 PAR #33352
			tmpKPI.setProxy(tmpTI,self.myTerminal, _agent.dateTime, user, KPI_Type_Location, ta,imex,iso,cnts, is40, length, cargoTypeCode); //05/09/2025	navkc1 JIRA 35622
			_agent.myCurrentKPITerminalArea.addLocation(tmpKPI);
		else
			//tmpKPI.updateTotals(is40);  //26/02/2015  cnwma1 PAR #33352
			tmpKPI.updateTotals(tmpTI);   //26/02/2015  cnwma1 PAR #33352
		endif;
		
		// update grand totals for terminal area
		//_agent.myCurrentKPITerminalArea.updateTotals(is40); - //26/02/2015  cnwma1 PAR #33352
		  _agent.myCurrentKPITerminalArea.updateTotals(tmpTI);  //26/02/2015  cnwma1 PAR #33352
	endforeach;
epilog
	//endLock;					// PAR #34422
	//app.cmsEndLoad(ls);

	
end;</source>
        <Parameter name="_agent" type="CMIF_SpaceUtilisationQryAgent" usage="input"/>
    </JadeMethod>
