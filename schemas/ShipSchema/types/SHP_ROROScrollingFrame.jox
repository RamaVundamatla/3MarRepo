    </JadeMethod>
    <JadeMethod name="mouseMove" id="024d3052-293f-4e08-b206-fc51c0ac3ef1">
        <controlMethod name="Frame::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseMove(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
/*
Purpose:			
Date		Who		Reason
21 September 2011	cnwab1	Initial creation
*/

vars

begin


	inheritMethod(frame, button, shift, x, y);

	self.myLocationDrawingFrame.handleMouseMove(frame, button, shift, x, y);	

epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="803f3707-1527-48c5-85c5-6505f6337c1f">
        <controlMethod name="Frame::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
/*
Date		    Who			Reason
26 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	tmpObj	: Object;	
begin
	frame.enableEvent("mouseMove", true);
	if button = Window.MouseButton_Left and shift = 0 or shift.isAltKeyPressed() then
		
		tmpObj := self.myLocationDrawingFrame.getObjectForPosition(x.Integer, y.Integer);
		
		if tmpObj = null or (not tmpObj.isKindOf(CM_ROROSlotController) and not tmpObj.isKindOf(CM_ROROLocnDefn))	then		
			return;
		endif;

		self.myLocationDrawingFrame.setSelectedSlot(tmpObj, shift);	
	
	endif;
//app.myDraggedTrackedItem := null;
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. NULLED');
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
