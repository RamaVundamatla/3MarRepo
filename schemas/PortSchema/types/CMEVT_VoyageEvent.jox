        <source>getVoyageShippingLineName() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 April 2025		jlizm1	Initial creation MTN 34568 PEN Expose vessel fields to event stream

*/

vars
	shippingLine 	: CM_ShippingLine;
	
begin

	if self.myVoyage = null then
		return null;
	endif;
	
	shippingLine := self.myVoyage.myShippingLine;
	
	if shippingLine = null then
		return null;
	endif;
	
	return shippingLine.description;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWeightConverted" id="ff5cc1fd-c251-41b4-8a35-085b0f9c5cab">
        <source>getWeightConverted() : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 July 2022		jlizm1	Initial creation TFS 54165 EDI Voyage Events

*/

vars

	type : CM_MeasurementType;

begin

	if self.myEventType = null then
		return null;
	endif;
	
	type := self.myEventType.myWeightType;
	
	if type = null then
		return null;
	endif;
	
	return type.convertValueAsValue(self.weight);
	
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="hasTaskThatIsComplete" id="8513c9b8-9674-4963-9d35-5c0a09447bbb">
        <source>hasTaskThatIsComplete(): Boolean;
/*
Purpose:			

Date		Who		 Reason
16JUN2023	NAVAB1	 CR 54345 TASK 58281 
05 Dec 2024 navma1	 navma1 MTN-33567 MTN - Charges Are Not Created When adding Events
*/


vars
	taskDesc  : CM_ToDoTaskDesc;
	task 	  : CM_ToDoTask;
	myWodToDo : CM_WodToDo;
	voyage	  : CM_Voyage;
begin

	if self.myToDoTask = null then
		return false;
	endif;
	
	voyage := self.myVoyage;
	
	if voyage = null then				//05.12.2024 navma1 #MTN-33567
		return false;
	endif;
	
	return voyage.allToDoTasksCompleted.includes(self.myToDoTask);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
