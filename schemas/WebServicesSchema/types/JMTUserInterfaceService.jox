    <JadeWebServicesMethod name="getBOLsForVoyage" id="0f3bf61c-b3d5-4772-88b1-b7ca72ce4753">
        <source>getBOLsForVoyage(_voyage : String) : WS_BOLResponse webService;
/*

Date		Who		Reason
20 January 2017	cnwer1	Initial creation TFS 1487

*/

vars
	response : WS_BOLResponse;
	completedOK : Boolean;
	voyage  : CM_Voyage;
	iter : Iterator;
	bolId : WS_BOLID;
	bol : CM_BOL;
	failedDAC 	: CM_DataAccessController;	
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;
	
	voyage:= app.myPassport.getObjectOfTypeFromOid(_voyage,CM_Voyage).CM_Voyage;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	if voyage = null then
		//try get voyage
		voyage := app.myPassport.myTerminal.allVoyagesByCode[_voyage,null];
		//epr TFS 5535 10/8/17 
		if voyage &lt;&gt; null and not voyage.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
			voyage := null;
		endif;
	endif;
	
	if voyage &lt;&gt; null then
		iter := voyage.allBOLInByTypeStatusNumDT.createIterator;
		while iter.next( bol ) do
			create bolId transient;
			bolId.setProxyFromObject(bol);
			response.allBOLs.add(bolId);
		endwhile;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	delete iter;
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction();

end;</source>
        <Parameter name="_voyage" type="String"/>
        <ReturnType type="WS_BOLResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getBaysForRoroGenCargoArea" id="8add825e-86ff-4c53-9be9-51e0b4ad07af">
        <source>getBaysForRoroGenCargoArea(request : WS_GetLanesForRoroRequest) : WS_RoroGenCargoAreaResponse webService;
/*

Purpose:			
	for general cargo roro display - return list of bays + total vehicles scanned in terminal area
Parameters:			

Return Value:		

Date		Who		Reason
01 August 2017	jlghl1	Initial creation
31 Aug 2017		jlghl1	TFS#6771

*/

vars
	iter, cargoIter, shelfIter : Iterator;	
	response : WS_RoroGenCargoAreaResponse;
	completedOK : Boolean;
	terminalArea : CM_TerminalArea;
	area : CM_IrregularBlockArea;
	taMaster	: CM_TerminalAreaMaster;
	terminal : CM_Terminal;
	locationsController	: CM_LocationsController;
	totalScanned : Integer;
	location : WS_LocationsController;
	failedDAC : CM_DataAccessController;
	ti : CM_TrackedItem;
	shelf : CM_RackShelfController;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	terminal := app.myPassport.myTerminal;
	terminalArea := terminal.allTerminalAreasByTypeId[TA_TYPE_IRREGULAR_BLOCK_AREA, request.roroAreaId];
	totalScanned := 0;
	
	area := terminalArea.CM_IrregularBlockArea;	
	
	if area &lt;&gt; null then
		iter := area.allLocationsControllers.createIterator();
		
		while iter.next(locationsController)do
					
			if locationsController.isRack then 
				foreach shelf in locationsController.CM_IrregularBlockController.allSubLocations do
					create location transient;
					location.setProxyFromObject(shelf);					
					response.allLocationsControllers.add(location);					
					
					shelfIter := shelf.allTrackedItemsById.createIterator();
					while shelfIter.next(ti) do
						if not ti.isCar then
							continue;
						endif;
						
						if (ti.voyageCode = request.voyageCode or (ti.isTranshipExport and ti.importVoyageCode = request.voyageCode )) then
							totalScanned := totalScanned + 1;
						endif;
					endwhile;
					delete shelfIter;		
				endforeach;
			
			endif;
			
			create location transient;
			location.setProxyFromObject(locationsController);					
			response.allLocationsControllers.add(location);
			
			if not locationsController.isRack then
				cargoIter := locationsController.allTrackedItemsById.createIterator();
				while cargoIter.next(ti) do
					if not ti.isCar then
						continue;
					endif;
					
					if (ti.voyageCode = request.voyageCode or (ti.isTranshipExport and ti.importVoyageCode = request.voyageCode )) then		
						totalScanned := totalScanned + 1;
					endif;
				endwhile;
				delete cargoIter;		
			endif;			
			
		endwhile;
		delete iter;
		
		response.totalCargoItemsScanned := totalScanned;
		
	endif;
	
	completedOK := true;
	return response;
		
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_GetLanesForRoroRequest"/>
        <ReturnType type="WS_RoroGenCargoAreaResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getBlockStackRoroDetails" id="18358472-a1ef-4468-b911-c5636e3cfbab">
        <source>getBlockStackRoroDetails(request : WS_GetLanesForRoroRequest) : WS_RoroGenCargoAreaResponse webService;
/*

Purpose:			
	get number of scanned roro vehicles for a voyage, in a block stack
Parameters:			

Return Value:		

Date		Who		Reason
01 August 2017	jlghl1	Initial creation
31 Aug 2017		jlghl1	TFS 6771

*/

vars
	terminalArea : CM_TerminalArea;
	locController : CM_LocationsController;
	response : WS_RoroGenCargoAreaResponse;
	completedOK : Boolean;
	totalScanned : Integer;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	totalScanned := 0;
	terminalArea := app.myPassport.myTerminal.allTerminalAreasByTypeId[TA_TYPE_BLOCK_STACK, request.roroAreaId];
		
	if terminalArea &lt;&gt; null then
		locController := terminalArea.CM_BlockStack.getLocationsController();
		totalScanned := totalScanned + locController.getCarCountForVoyage(request.voyageCode);
		response.totalCargoItemsScanned := totalScanned;
	endif;
		
	completedOK := true;
	return response;
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_GetLanesForRoroRequest"/>
        <ReturnType type="WS_RoroGenCargoAreaResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getBookingItemPackCargo" id="790264a9-a36a-4ae1-a25b-56f72dc96d17">
        <source>getBookingItemPackCargo(request : WS_BookingItemPackCargoRequest) : WS_TrackedItemQueryResponse webService;
/*
Purpose:			
Date				Who			Reason
27 Sep 2016 		cnwer1		Initial creation TFS 2526
*/



vars
	response		: WS_TrackedItemQueryResponse;
	completedOK		: Boolean;
	ultParent,
	packContainer 			: CM_TrackedItem;
	ti 		: CM_TrackedItem;
	proxyTI			: WS_TrackedItem;
	failedDAC 		: CM_DataAccessController;
	bookingItem		: CM_BookingRefItem;
	tiArray : CM_TIArray;
	
begin

	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;
	
	//epr TFS 5535 4/8/17 
	bookingItem:= app.myPassport.getObjectOfTypeFromOid(request.bookingItemOid,CM_BookingRefItem).CM_BookingRefItem;
	if bookingItem = null then
		completedOK := true;
		return response;
	endif;
	
	//epr TFS 5535 4/8/17 
	packContainer :=app.myPassport.getObjectOfTypeFromOid(request.parentCargoOid,CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	create tiArray transient;
	
	foreach ti in bookingItem.allTIs do
		if not ti.isOnSite then
			continue;
		endif;
		
		if not ti.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then   
			continue;
		endif;
			
		if ti.myParent = null then
			tiArray.add( ti );
		else
			//11 July 2014	NDL	Par 34020
			ultParent := ti.getUltimateParentIfNotPackedIn(  packContainer );
			if ultParent &lt;&gt; null then
				tiArray.addExclusive( ultParent );
			endif;
		endif;
			
	endforeach;

	foreach ti in tiArray do
	
		create proxyTI transient;
		proxyTI.setProxyFromObject(ti);
		response.allTrackedItems.add(proxyTI);
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction();

	delete tiArray;

end;</source>
        <Parameter name="request" type="WS_BookingItemPackCargoRequest"/>
        <ReturnType type="WS_TrackedItemQueryResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getBookingReferencesForDisplay" id="4fb10526-6de5-4b8d-87e1-84242ea55bb5">
        <source>getBookingReferencesForDisplay() : WS_BookingReferencesResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2016	cnwmc5	Initial creation

*/

vars
	response		: WS_BookingReferencesResponse;
	completedOK		: Boolean;
	wsBooking		: WS_BookingReference;
	bookingRef		: CM_BookingRef;
	terminal		: CM_Terminal;
	iter			: Iterator;
	user			: CM_User;
	failedDAC		: CM_DataAccessController;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmGteBookingRefView);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	user := app.myPassport.myUser;
	
	iter := terminal.allBookingRefsByStatusRef.createIterator();
	terminal.allBookingRefsByStatusRef.startKeyGeq(BOOKING_REF_ACTIVE, null, iter);
	
	while iter.next(bookingRef) do			
		if not bookingRef.canUserAccessSelf(user, failedDAC, app.myPassport) then
			continue;
		endif;
		
		create wsBooking transient;
		wsBooking.setProxyFromObject(bookingRef);
		response.allBookingReferences.addExclusive(wsBooking);
	endwhile;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog
	// Tidy up any local transients
	delete iter;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <ReturnType type="WS_BookingReferencesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getBookingStatus" id="c326cd75-9bba-4100-bede-d182de816032">
        <source>getBookingStatus() : WS_BookingStatusesResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2013	cnwmc5	Initial creation - PAR 31988

*/

vars
	response 		: WS_BookingStatusesResponse;
