    <JadeMethod name="resetTopPositions" id="c271525c-eb67-4cbb-9278-e04970ddec16">
        <source>resetTopPositions();

vars

	theHeight	: Real;
begin
	theHeight 					:= self.topMargin + 10;
	self.optLogId.top 			:= theHeight;
	self.optStockMovement.top	:= theHeight;
	self.tblSelection.top		:= self.optLogId.top + self.optLogId.height + 10;
	self.tblData.top			:= self.tblSelection.top + self.tblSelection.height + 10;
	self.tblData.height			:= self.tblActionData.top - self.tblData.top - 10;
	self.tblActionData.top		:= self.tblData.top + self.tblData.height + 10;

end;</source>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="82981666-9760-4e33-8681-f5063731f103">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     29 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_colorControl);
	
	self.setColorsForEntryTable(self.tblActionData);
	self.setColorsForEntryTable(self.tblSelection);
	self.setColorsForTable(self.tblData);
	

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c8d6854e-c829-4398-8f7f-e792c2f89e5d">
        <updating/>
        <source>setupForm() updating;

// cnwdvb1 27 November 2002 

vars

	entTableControl	: EntTableDef;

begin

	inheritMethod();
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;

	self.optStockMovement.value := true;
	self.doSelectionTable();
	self.tblSelection.setDistanceFromRight(22);
	self.tblSelection.setDistanceFromBottom(300);
	self.tblSelection.lockBottom := false;
	self.tblSelection.lockRight := false;
	self.tblSelection.stretchWidth := true;
	self.tblSelection.optimiseRowHeight := true;
	
	self.tblData.setDistanceFromRight(22);
	self.tblData.setDistanceFromBottom(80);
	self.tblData.lockBottom := false;
	self.tblData.lockRight := false;
	self.tblData.stretchHeight := true;
	self.tblData.stretchWidth := true;
	self.tblData.optimiseRowHeight := true;
	self.tblData.autoSize := Table.AutoSize_Column;

	entTableControl := app.myController.getEntTableDef(ETDef_ReinstateRejects);
	self.tblActionData.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');	
	self.tblActionData.setDistanceFromRight(22);
	self.tblActionData.setDistanceFromBottom(40);
	self.tblActionData.lockBottom := true;
	self.tblActionData.lockRight := false;
	self.tblActionData.stretchWidth := true;
	self.tblActionData.optimiseRowHeight := true;
	self.tblActionData.cnEcResizeContents;
	
	self.tblData.setColumnHeadingsFromDef(ETDef_ReinstateRejectsData, false);	
	self.setColorsForTable(self.tblData);	
	// sgp 30 May 2003 : moved to loadDataForFirstTime
//	self.doLoadCombos();

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnSaveBase.enabled:= false;
		self.btnNextT.enabled:= false;
		self.tblActionData.userInputEnabled:= false;
		self.tblData.userInputEnabled := false;
	endif;


end;</source>
    </JadeMethod>
    <JadeMethod name="tblActionData_rowColumnChg" id="504b7c9d-c142-4533-bdc5-4635a9befb3e">
        <controlMethod name="CM_EntryTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblActionData_rowColumnChg(table: Table input) updating;

vars

begin

	if table.row &gt; 0 then
		table.CM_EntryTable.setSelectionStyle(table.row, false);
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblSelection_lostFocus" id="fca0f439-e4f4-42a4-b6fd-2b7343648481">
        <controlMethod name="CM_EntryTable::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblSelection_lostFocus(table: Table input) updating;

vars
	ctrl : Control;

begin

	ctrl := table.accessCell(table.row, table.column).cellControl;
	if ctrl &lt;&gt; null and not ctrl.isKindOf(ComboBox) and self.optLogId.value then
		self.getTrackedItem();
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
