	self.permissionMaint := PmAdmTranshipSummary;
	self.initTable();
end;</source>
    </JadeMethod>
    <JadeMethod name="displayCollEmptiesAndFulls" id="c9e49a71-9004-4164-a3bd-43a0e78877c1">
        <source>displayCollEmptiesAndFulls();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 February 2014	cnwndl1	Initial creation	Par 33607
28 May 2014	NDL	Par 34217 - provide some debug type function to allow double click on total to show the first ti in the collection.
05/12/2019	JLGNS1	Bug 47854: POL - [Fwd: ##RE-13625## : FW: Master Terminal - [Voyage Discharge Summary (AST948R MSC ASTRID)]]
*/

vars

	empties : DynaDictionary;
	fulls : DynaDictionary;
	ti : CM_TrackedItem;
	thisPort : String;
	cmif : CMIF_TranshipSummary;
	isoGroup : String;
	availabilityGrade : Integer;
	hasToDoTasks : Boolean;
	operatorCode : String;
	commodityGroup : String;
	yardAllocations : CM_ObjectSet;
	tiCriteria : String;
	priorCmif : CMIF_TranshipSummary;
	lineStr : String;
	ya : Object;
	dynaObj : Object;
	dynaObj2 : Object;
	strArray : StringArray;
	index : Integer;
	tot : Integer;
	cmif2 : CMIF_TranshipSummary;
	iter : Iterator;
	mtTrans : DynaDictionary;
	fullTrans : DynaDictionary;
	newRowIndex : Integer;

begin

	thisPort := self.myTerminal.getConfig(PortDestCode).String.trimBlanks;

	self.clearTable( self.tblEmpties );
	self.clearTable( self.tblFulls );
	
	if not ( app.myRoot.client = Client_PortOtago or app.isDevelopmentSystem ) then
		self.shtEmpty.visible := false;
		self.shtFulls.visible := false;
		return;
	endif;

	if self.myCurrentVoyage = null then
		return;
	endif;
	
	create yardAllocations transient;
	create strArray transient;
	
	create mtTrans transient;
	mtTrans.setMembership(CMIF_TranshipSummary);
	mtTrans.addMemberKey(CMIF_TranshipSummary::isoGroup.name, true, false);
	mtTrans.endKeys(true);
	
	create fullTrans transient;
	fullTrans.setMembership(CMIF_TranshipSummary);
	fullTrans.addMemberKey(CMIF_TranshipSummary::isoGroup.name, true, false);
	fullTrans.endKeys(true);
	
	create empties transient;
	empties.setMembership(CMIF_TranshipSummary);
	empties.addMemberKey(CMIF_TranshipSummary::operatorCode.name, true, false);
	empties.addMemberKey(CMIF_TranshipSummary::isoGroup.name, true, false);
	empties.addMemberKey(CMIF_TranshipSummary::availabilityGrade.name, true, false);
	empties.endKeys(true);
	
	create fulls transient;
	fulls.setMembership(CMIF_TranshipSummary);
	fulls.addMemberKey(CMIF_TranshipSummary::isoGroup.name, true, false);
	fulls.addMemberKey(CMIF_TranshipSummary::commodityGroup.name, true, false);
	fulls.endKeys(true);
	
	//create the cmifs, representing the different tyoes of containers
	foreach ti in self.myCurrentVoyage.allOnshipTIsByIdCargoType do
		if not ti.isContainer then
			continue;
		endif;
		if ti.dischargePort &lt;&gt; thisPort then
			continue;
		endif;
		isoGroup := ti.CM_Container.isoGroup;
		if ti.contentsStatusCode = "MT" then
			if ti.isTranshipItem then
				cmif2 := mtTrans[isoGroup].CMIF_TranshipSummary;
				if cmif2 = null then
					create cmif2 transient;
					cmif2.isoGroup := isoGroup;
					mtTrans.add(cmif2);
				endif;
				cmif2.count := cmif2.count + 1;
			endif;
			operatorCode := ti.operatorCode;
			availabilityGrade := ti.CM_Container.availabilityGrade;
			hasToDoTasks := ti.hasToDoTasks;
			
			if ti.isTranshipItem then // PAR 35868
				continue;
			endif;
			
			cmif := empties[operatorCode,isoGroup,availabilityGrade].CMIF_TranshipSummary;
			if cmif = null then
				create cmif transient;
				cmif.operatorCode := operatorCode;
				cmif.isoGroup := isoGroup;
				cmif.availabilityGrade := availabilityGrade;
				cmif.hasToDoTasks := hasToDoTasks;
				yardAllocations.clear();
				app.findYardAllocation(ti, yardAllocations, tiCriteria);
				if not yardAllocations.isEmpty then
					yardAllocations.copy( cmif.yardAllocations );
				endif;
				cmif.count := 1;
				cmif.allTis.add(ti);
				cmif.myFirstTrackedItemAdded := ti;	//28 May 2014	NDL	Par 34217
				empties.add(cmif);
			else
				if cmif.yardAllocations.isEmpty then // 27 Mar 2020	NDL	TFS 47854 - Only redo this if it is empty, huge performance hit
					cmif.myFirstTrackedItemAdded := ti;	// And update the ti its based on at the same time
					yardAllocations.clear();								//Bug 47854
					app.findYardAllocation(ti, yardAllocations, tiCriteria);//Bug 47854
					if not yardAllocations.isEmpty then						//Bug 47854
						yardAllocations.copyNoDups(cmif.yardAllocations);	//Bug 47854
					endif;													//Bug 47854
				endif;
				cmif.count := cmif.count + 1;
				cmif.allTis.add(ti);
			endif;
		elseif ti.contentsStatusCode = "FCL" then
			if ti.isTranshipItem then
				cmif2 := fullTrans[isoGroup].CMIF_TranshipSummary;
				if cmif2 = null then
					create cmif2 transient;
					cmif2.isoGroup := isoGroup;
					fullTrans.add(cmif2);
				endif;
				cmif2.count := cmif2.count + 1;
			endif;
			commodityGroup := ti.CM_Container.commodityGroup;
			
			
			if ti.isTranshipItem then // PAR 35868
				continue;
			endif;
			
			cmif := fulls[isoGroup,commodityGroup].CMIF_TranshipSummary;
			if cmif = null then
				create cmif transient;
				cmif.isoGroup := isoGroup;
				cmif.commodityGroup := commodityGroup;
				yardAllocations.clear();
				app.findYardAllocation(ti, yardAllocations, tiCriteria);
				if not yardAllocations.isEmpty then
					yardAllocations.copy( cmif.yardAllocations );
				endif;
				cmif.count := 1;
				cmif.myFirstTrackedItemAdded := ti;	//28 May 2014	NDL	Par 34217
				fulls.add(cmif);
				cmif.allTis.add(ti);
			else
				if cmif.yardAllocations.isEmpty then // 27 Mar 2020	NDL	TFS 47854 - Only redo this if it is empty, huge performance hit
					cmif.myFirstTrackedItemAdded := ti;	// And update the ti its based on at the same time
					yardAllocations.clear();								//Bug 47854
					app.findYardAllocation(ti, yardAllocations, tiCriteria);//Bug 47854
					if not yardAllocations.isEmpty then						//Bug 47854
						yardAllocations.copyNoDups(cmif.yardAllocations);	//Bug 47854
					endif;													//Bug 47854
				endif;			
				cmif.count := cmif.count + 1;
				cmif.allTis.add(ti);
			endif;
		endif;
	endforeach;
	
	//create the string lines for the empty tables
	foreach dynaObj in empties do
		cmif := dynaObj.CMIF_TranshipSummary;
		if priorCmif &lt;&gt; null and cmif.operatorCode = priorCmif.operatorCode then
			lineStr := " " &amp; Tab &amp; " " &amp; Tab;
		else
			tot := 0;
			iter := empties.createIterator;
			iter.startAtObject(cmif);
			while iter.next(dynaObj2) do
				cmif2 := dynaObj2.CMIF_TranshipSummary;
				if cmif.operatorCode &lt;&gt; cmif2.operatorCode then
					break;
				endif;
				tot := tot + cmif2.count;
			endwhile;
			delete iter;
			lineStr := cmif.operatorCode &amp; Tab &amp; tot.String &amp; Tab;
		endif;
		if priorCmif &lt;&gt; null and cmif.isoGroup = priorCmif.isoGroup and cmif.operatorCode = priorCmif.operatorCode then
			lineStr := lineStr &amp; " " &amp; Tab &amp; " " &amp; Tab;
		else
			tot := 0;
			iter := empties.createIterator;
			iter.startAtObject(cmif);
			while iter.next(dynaObj2) do
				cmif2 := dynaObj2.CMIF_TranshipSummary;
				if cmif.isoGroup &lt;&gt; cmif2.isoGroup or cmif.operatorCode &lt;&gt; cmif2.operatorCode then
					break;
				endif;
				tot := tot + cmif2.count;
			endwhile;
			delete iter;
			lineStr := lineStr &amp; cmif.isoGroup &amp; Tab &amp; tot.String &amp; Tab;
		endif;
		if priorCmif &lt;&gt; null and cmif.availabilityGrade = priorCmif.availabilityGrade and cmif.isoGroup = priorCmif.isoGroup and cmif.operatorCode = priorCmif.operatorCode then
			lineStr := lineStr &amp; " " &amp; Tab &amp; " " &amp; Tab;
		else
			tot := 0;
			iter := empties.createIterator;
			iter.startAtObject(cmif);
			while iter.next(dynaObj2) do
				cmif2 := dynaObj2.CMIF_TranshipSummary;
				if cmif.availabilityGrade &lt;&gt; cmif2.availabilityGrade or cmif.isoGroup &lt;&gt; cmif2.isoGroup or cmif.operatorCode &lt;&gt; cmif2.operatorCode then
					break;
				endif;
				tot := tot + cmif2.count;
			endwhile;
			delete iter;
			lineStr := lineStr &amp; cmif.availabilityGrade.String &amp; Tab &amp; tot.String &amp; Tab;
		endif;
		if cmif.hasToDoTasks then
			lineStr := lineStr &amp; cmif.hasToDoTasks.String &amp; Tab;
		else
			lineStr := lineStr &amp; " " &amp; Tab;
		endif;
		if cmif.yardAllocations.isEmpty then
			//self.tblEmpties.addItem(lineStr);
			newRowIndex := self.tblEmpties.addItem(lineStr);	//28 May 2014 NDL Par 34217
			self.tblEmpties.accessCell(newRowIndex,6).itemObject := cmif.myFirstTrackedItemAdded;	//28 May 2014 NDL Par 34217
		else
			foreach ya in cmif.yardAllocations do
				lineStr := lineStr &amp; ya.CM_YardAllocation.code &amp; Tab ;
				ya.CM_YardAllocation.getAllocationRanges( strArray );
				if strArray.isEmpty then
					//epr par 35152 31/10/14
					lineStr := lineStr &amp; " " &amp; Tab &amp; " " &amp; Tab &amp; ya.CM_YardAllocation.remarks;
					//self.tblEmpties.addItem(lineStr);
					newRowIndex := self.tblEmpties.addItem(lineStr);	//28 May 2014 NDL Par 34217
					self.tblEmpties.accessCell(newRowIndex,6).itemObject := cmif.myFirstTrackedItemAdded;	//28 May 2014 NDL Par 34217
					lineStr := " " &amp; Tab &amp; " " &amp; Tab &amp; " " &amp; Tab &amp; " " &amp; Tab &amp; " " &amp; Tab &amp; " " &amp; Tab &amp; " " &amp; Tab;
				else
					foreach index in 1 to strArray.size do
						lineStr := lineStr &amp; strArray[index];
						//epr par 35152 31/10/14
						if index = 1 then
							lineStr := lineStr  &amp; " " &amp; Tab &amp;  " " &amp; Tab &amp; ya.CM_YardAllocation.remarks;
						endif;
						//self.tblEmpties.addItem(lineStr);
						newRowIndex := self.tblEmpties.addItem(lineStr);	//28 May 2014 NDL Par 34217
						self.tblEmpties.accessCell(newRowIndex,6).itemObject := cmif.myFirstTrackedItemAdded;	//28 May 2014 NDL Par 34217
						lineStr := " " &amp; Tab &amp; " " &amp; Tab &amp; " " &amp; Tab &amp; " " &amp; Tab &amp; " " &amp; Tab &amp; " " &amp; Tab &amp; " " &amp; Tab &amp; " " &amp; Tab;
					endforeach;
					lineStr := " " &amp; Tab &amp; " " &amp; Tab &amp; " " &amp; Tab &amp; " " &amp; Tab &amp; " " &amp; Tab &amp; " " &amp; Tab &amp; " " &amp; Tab;
				endif;
			endforeach;
		endif;
		priorCmif := cmif;
	endforeach;
	
	//create the string lines for the full tables
	priorCmif := null;
	foreach dynaObj in fulls do
		cmif := dynaObj.CMIF_TranshipSummary;
		if priorCmif &lt;&gt; null and cmif.isoGroup = priorCmif.isoGroup then
			lineStr := " " &amp; Tab &amp; " " &amp; Tab;
		else
			tot := 0;
			iter := fulls.createIterator;
			iter.startAtObject(cmif);
			while iter.next(dynaObj2) do
				cmif2 := dynaObj2.CMIF_TranshipSummary;
				if cmif.isoGroup &lt;&gt; cmif2.isoGroup then
					break;
				endif;
				tot := tot + cmif2.count;
			endwhile;
			delete iter;
			lineStr := cmif.isoGroup &amp; Tab &amp; tot.String &amp; Tab;
		endif;
		if priorCmif &lt;&gt; null and cmif.commodityGroup = priorCmif.commodityGroup and cmif.isoGroup = priorCmif.isoGroup then
			lineStr := lineStr &amp; " " &amp; Tab &amp; " " &amp; Tab;
		else
			tot := 0;
			iter := fulls.createIterator;
			iter.startAtObject(cmif);
			while iter.next(dynaObj2) do
				cmif2 := dynaObj2.CMIF_TranshipSummary;
				if cmif.commodityGroup &lt;&gt; cmif2.commodityGroup or cmif.isoGroup &lt;&gt; cmif2.isoGroup then
					break;
				endif;
				tot := tot + cmif2.count;
			endwhile;
			delete iter;
			lineStr := lineStr &amp; cmif.commodityGroup.String &amp; Tab &amp; tot.String &amp; Tab;
		endif;
		
		if cmif.yardAllocations.isEmpty then
			//self.tblFulls.addItem(lineStr);
			newRowIndex := self.tblFulls.addItem(lineStr);	//28 May 2014 NDL Par 34217
			self.tblFulls.accessCell(newRowIndex,4).itemObject := cmif.myFirstTrackedItemAdded;	//28 May 2014 NDL Par 34217
		else
			foreach ya in cmif.yardAllocations do
				lineStr := lineStr &amp; ya.CM_YardAllocation.code &amp; Tab;
				ya.CM_YardAllocation.getAllocationRanges( strArray );
				if strArray.isEmpty then
						//epr par 35152 31/10/14
					lineStr := lineStr &amp; " " &amp; Tab &amp; " " &amp; Tab &amp; ya.CM_YardAllocation.remarks;
					//self.tblFulls.addItem(lineStr);
					newRowIndex := self.tblFulls.addItem(lineStr);	//28 May 2014 NDL Par 34217
					self.tblFulls.accessCell(newRowIndex,4).itemObject := cmif.myFirstTrackedItemAdded;	//28 May 2014 NDL Par 34217
					lineStr := " " &amp; Tab &amp; " " &amp; Tab &amp; " " &amp; Tab &amp; " " &amp; Tab;
				else
					foreach index in 1 to strArray.size do
						lineStr := lineStr &amp; strArray[index];
						//epr par 35152 31/10/14
						if index = 1 then
							lineStr := lineStr  &amp; " " &amp; Tab &amp;  " " &amp; Tab &amp; ya.CM_YardAllocation.remarks;
						endif;
						//self.tblFulls.addItem(lineStr);
						newRowIndex := self.tblFulls.addItem(lineStr);	//28 May 2014 NDL Par 34217
						self.tblFulls.accessCell(newRowIndex,4).itemObject := cmif.myFirstTrackedItemAdded;	//28 May 2014 NDL Par 34217
						lineStr := " " &amp; Tab &amp; " " &amp; Tab &amp; " " &amp; Tab &amp; " " &amp; Tab &amp; " " &amp; Tab;
					endforeach;
					lineStr := " " &amp; Tab &amp; " " &amp; Tab &amp; " " &amp; Tab &amp; " " &amp; Tab;
				endif;
			endforeach;
		endif;
		priorCmif := cmif;
	endforeach;

	/* PAR PAR 35868
	//Add the bogus tranship summary lines
	lineStr := app.getErrorString(Tranships) &amp; Tab &amp; " " &amp; Tab;
	self.tblEmpties.addItem(lineStr);
	foreach dynaObj in mtTrans do
		cmif := dynaObj.CMIF_TranshipSummary;
		lineStr := " " &amp; Tab &amp; " " &amp; Tab &amp; cmif.isoGroup &amp; Tab &amp; cmif.count.String;
		//self.tblEmpties.addItem(lineStr);
		newRowIndex := self.tblEmpties.addItem(lineStr);	//28 May 2014 NDL Par 34217
		self.tblEmpties.accessCell(newRowIndex,2).itemObject := cmif.myFirstTrackedItemAdded;	//28 May 2014 NDL Par 34217
	endforeach;
	
	lineStr := app.getErrorString(Tranships) &amp; Tab &amp; " " &amp; Tab;
	self.tblFulls.addItem(lineStr);
	foreach dynaObj in fullTrans do
		cmif := dynaObj.CMIF_TranshipSummary;
		lineStr := cmif.isoGroup &amp; Tab &amp; cmif.count.String;
		//self.tblFulls.addItem(lineStr);
		newRowIndex := self.tblFulls.addItem(lineStr);	//28 May 2014 NDL Par 34217
		self.tblFulls.accessCell(newRowIndex,2).itemObject := cmif.myFirstTrackedItemAdded;	//28 May 2014 NDL Par 34217
	endforeach;
*/
epilog

	// 33819 Mar 2014 if not Otago, get here without these being created
	if mtTrans &lt;&gt; null then
		if not mtTrans.isEmpty then
			mtTrans.purge();
		endif;
		delete mtTrans;
	endif;
	if fullTrans &lt;&gt; null then
		if not fullTrans.isEmpty then
			fullTrans.purge();
		endif;
		delete fullTrans;
	endif;
	if fulls &lt;&gt; null then
		if not fulls.isEmpty then
			fulls.purge();
		endif;
		delete fulls;
	endif;
	if empties &lt;&gt; null then
		if not empties.isEmpty then
			empties.purge();
		endif;
		delete empties;
	endif;
	delete yardAllocations;
	delete strArray;
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="displayCollectionEDI" id="b4b10ae2-d963-40d0-894a-f340f72c0531">
        <source>displayCollectionEDI();
// ---------------------------------------------------------------------------
// Created:     September 2007 cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
//	cmifMonitor		: CMIF_Monitor;
//	partsInJob,
//	partsDone,
	cnt, st, en				: Integer;
	theColl			: Collection;
	stopWhenChange	: Boolean;
	ts				: TimeStamp;
	ediTI : CM_EDITrackedItem;
	isoType : CM_ISOType;
	isoGroup : CM_ISOTypeGroup;
	isoGroupArray : StringArray;
	dischargePortArray : StringArray;
	transhipSummary : CMIF_TranshipSummary;
	dischargePort : String;
	isoGroupStr, discGroupStr : String;
	isoLine, discLine, isoTot, discTot : Integer;
	obj : Object;
	totalCount : Integer;
	dynaDict : DynaDictionary;
	loadVessel, loadVoyage : String;
	tmpStr : String;
	commodityGroup : String;
begin
	self.clearTable(tblTranship);
	create dynaDict transient;
	dynaDict.setMembership(CMIF_TranshipSummary);
	dynaDict.addMemberKey(CMIF_TranshipSummary::isoGroup.name, true, false);
	dynaDict.addMemberKey(CMIF_TranshipSummary::dischargePort.name, true, false);
	dynaDict.addMemberKey(CMIF_TranshipSummary::commodityGroup.name, true, false); // PAR 19484
	dynaDict.addMemberKey(CMIF_TranshipSummary::exportVesselName.name, true, false);
	dynaDict.endKeys(true);
	//copy across the dict so you don't have to access self.myTerminal every loop
	totalCount := 0;
	foreach ediTI in self.myEDIDataTranship.allEDITrackedItems do
		isoType := app.myRoot.allISOTypes[ediTI.CM_EDITranshipTI.isoType];
		if isoType &lt;&gt; null and
		   isoType.myISOTypeGroup &lt;&gt; null then
			isoGroupStr := isoType.myISOTypeGroup.description;
		endif;
		dischargePort := ediTI.CM_EDITranshipTI.dischargePort;
		commodityGroup := ediTI.CM_EDITranshipTI.getCommodityGroupCode(); // PAR 19484
		loadVessel := ediTI.CM_EDITranshipTI.exportVesselName;
//		loadVoyage := ediTI.CM_EDITranshipTI.exportVoyageCode;		// cnwrl1 11/06/2010 PAR 24299 - what it was
		loadVoyage := ediTI.CM_EDITranshipTI.getExportVoyageCode();
		transhipSummary := null;
		transhipSummary := dynaDict[isoGroupStr, dischargePort, commodityGroup, loadVessel].CMIF_TranshipSummary;  // PAR 19484
		if transhipSummary = null then
			create transhipSummary transient;
			transhipSummary.isoGroup := isoGroupStr;
			transhipSummary.dischargePort := dischargePort;
			transhipSummary.exportVesselName := loadVessel;
			transhipSummary.exportVoyageCode := loadVoyage;
			transhipSummary.commodityGroup := commodityGroup; // PAR 19484
			transhipSummary.count := 1;
			dynaDict.add(transhipSummary);
		else
			transhipSummary.count := transhipSummary.count + 1;
		endif;
	endforeach;
	isoGroupStr := null;
	cnt := 1;
	foreach obj in dynaDict do
		transhipSummary := obj.CMIF_TranshipSummary;
		/*
		if transhipSummary.isoGroup &lt;&gt; isoGroupStr and
		   isoGroupStr &lt;&gt; null then
			isoGroupStr := transhipSummary.isoGroup;
			tmpStr := transhipSummary.isoGroup&amp;Tab&amp;totalCount.String;
			cnt := cnt + 1;
			totalCount := 0;
			self.tblTranship.addItemAt(tmpStr, cnt);
			self.tblTranship.accessRow(cnt).itemObject := transhipSummary;
		endif;
		*/
		cnt := cnt + 1;
//		totalCount := totalCount + transhipSummary.count;
		self.displayTranshipSummary(transhipSummary, cnt);
	endforeach;
	
	// #### GRAND TOTAL
	/*
	tmpStr := transhipSummary.isoGroup&amp;Tab&amp;totalCount.String;
	cnt := cnt + 1;
	self.tblTranship.addItemAt(tmpStr, cnt);
	self.tblTranship.accessRow(cnt).itemObject := transhipSummary;
	*/
	self.displayTotals();
	
epilog
	dynaDict.purge;
	delete dynaDict;
end;</source>
    </JadeMethod>
    <JadeMethod name="displayCollectionVoyage" id="2cd3fa28-67a9-4755-a843-ce6c3425ac94">
        <updating/>
        <source>displayCollectionVoyage() updating;
// ---------------------------------------------------------------------------
// Created:     September 2007 cnwrs1 CCMS 1547
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 12/05/2010		cnwdap1			CCMS 1116 Tranship changes
vars

	isoGroupStr, discGroupStr : String;
	isoLine, discLine, isoTot, discTot, st, en : Integer;
	cnt				: Integer;
	theColl			: Collection;
	stopWhenChange	: Boolean;
	ts				: TimeStamp;
	ti : CM_TrackedItem;
	isoType : CM_ISOType;
	isoGroup : CM_ISOTypeGroup;
	isoGroupArray : StringArray;
	dischargePortArray : StringArray;
	transhipSummary : CMIF_TranshipSummary;
	dischargePort : String;
	commodityGroup : String;
	obj : Object;
	totalCount : Integer;
	dynaDict : DynaDictionary;
	loadVessel, loadVoyage : String;
	tmpStr : String;
	ya : CM_YardAllocation;
	yardAllocations : CM_ObjectSet;
	object : Object;
	tiCriteria : String; //for debug purpose
	str : String;
	yc : CM_YardController;
	firstYCId, lastYCId, codeStr : String;
begin

	self.caption := app.getErrorString(Voyage_discharge_summary);	//03 Mar 2014	NDL	Par 33607
	if self.myCurrentVoyage &lt;&gt; null then
		self.caption := self.caption&amp;' ('&amp;self.myCurrentVoyage.getDisplayDetails(false)&amp;')';
	endif;
	self.clearTable(tblTranship);
	create yardAllocations transient;
	create dynaDict transient;
	dynaDict.setMembership(CMIF_TranshipSummary);
	dynaDict.addMemberKey(CMIF_TranshipSummary::isoGroup.name, true, false);
	dynaDict.addMemberKey(CMIF_TranshipSummary::dischargePort.name, true, false);
	dynaDict.addMemberKey(CMIF_TranshipSummary::commodityGroup.name, true, false); // PAR 19484
	dynaDict.addMemberKey(CMIF_TranshipSummary::exportVesselName.name, true, false);
	dynaDict.endKeys(true);
	//copy across the dict so you don't have to access self.myTerminal every loop
	totalCount := 0;
	foreach ti in self.myCurrentVoyage.allOnshipTIsByCargoTypeId where ti.isTranshipOnInboundVoyage do
		if not ti.isKindOf(CM_Container) then
			continue;
		endif;
		isoGroupStr := ti.CM_Container.isoGroup;
		dischargePort := ti.dischargePort;
		commodityGroup := ti.commodityGroup; // PAR 19484
		
		if ti.myExportVoyage &lt;&gt; null then										// PAR #23645 CCMS 1116
			loadVessel := ti.myExportVoyage.vesselName;							// PAR #23645 CCMS 1116
			loadVoyage := ti.myExportVoyage.code;								// PAR #23645 CCMS 1116
		endif;																	// PAR #23645 CCMS 1116
		// TFS 2122 add null test
		if ti.myTranshipDetail &lt;&gt; null and
		   ti.myTranshipDetail.myDischargePort &lt;&gt; null then						// PAR #23645 CCMS 1116
			dischargePort := ti.myTranshipDetail.myDischargePort.code;			// PAR #23645 CCMS 1116
		endif;																	// PAR #23645 CCMS 1116
		transhipSummary := null;
		transhipSummary := dynaDict[isoGroupStr, dischargePort, commodityGroup, loadVessel].CMIF_TranshipSummary;  // PAR 19484
		if transhipSummary = null then

			create transhipSummary transient;
			transhipSummary.isoGroup := isoGroupStr;
			transhipSummary.dischargePort := dischargePort;
			transhipSummary.exportVesselName := loadVessel;
			transhipSummary.exportVoyageCode := loadVoyage;
			transhipSummary.commodityGroup := commodityGroup; // PAR 19484
			yardAllocations.clear();
			app.findYardAllocation(ti, yardAllocations, tiCriteria); 
			str := null;
			codeStr := null;
			if yardAllocations.isEmpty then
				str := " no allocation.";
			else
				foreach object in yardAllocations do
					ya := object.CM_YardAllocation;
					if str = null then
						str := ya.getDescriptionWithLocations(false);
					else
						str := str &amp; CrLf &amp; ya.getDescriptionWithLocations(false);
					endif;
					
					if codeStr = null then
						codeStr := ya.code;
					else
						codeStr := codeStr &amp; CrLf &amp; ya.code;
					endif;
				endforeach;
			endif;
			transhipSummary.yardAllocation := codeStr[1:120];
			transhipSummary.yardAllocationRows := str[1:120];
			transhipSummary.count := 1;
			dynaDict.add(transhipSummary);
		else
			transhipSummary.count := transhipSummary.count + 1;
		endif;
	endforeach;
	isoGroupStr := null;
	cnt := 1;
	
	foreach obj in dynaDict do
		transhipSummary := obj.CMIF_TranshipSummary;
		cnt := cnt + 1;
		self.displayTranshipSummary(transhipSummary, cnt);
	endforeach;
	
	self.displayTotals();
	
	self.displayCollEmptiesAndFulls();	//28 Feb 2014	NDL	Par 33607

epilog
	dynaDict.purge;
	delete dynaDict;
	delete yardAllocations;
end;</source>
    </JadeMethod>
    <JadeMethod name="displayTotals" id="41acfc4e-3039-4e95-9ac2-9887d4bee7ff">
        <source>displayTotals();
// ---------------------------------------------------------------------------
// Created:     17 April 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	isoGroupStr, discGroupStr : String;
	isoLine, discLine, isoTot, discTot, st, en, cnt, sub, gTotal : Integer;
	transhipSummary :CMIF_TranshipSummary;
begin

	// PAR 19772
	if self.tblTranship.rows = self.tblTranship.fixedRows then
		return;
	endif;
	
	
	st := self.tblTranship.fixedRows + 1;
	en :=  self.tblTranship.rows;
	
	isoLine := st;
	discLine := st;
	foreach cnt in st to en do
		transhipSummary := self.tblTranship.accessRow(cnt).itemObject.CMIF_TranshipSummary;
		
		if discGroupStr &lt;&gt; null and discGroupStr &lt;&gt; transhipSummary.dischargePort then
			self.tblTranship.accessCell(discLine,4).text := discTot.String;
			self.tblTranship.accessCell(discLine,4).fontBold := true;
			self.tblTranship.accessCell(discLine,3).fontBold := true;
			
			foreach sub in discLine + 1 to cnt -1 do
				self.tblTranship.accessCell(sub,3).text := null;
			endforeach;
			discTot := 0;
			discLine := cnt;
		endif;
		if isoGroupStr &lt;&gt; null and isoGroupStr &lt;&gt; transhipSummary.isoGroup then
			self.tblTranship.accessCell(isoLine,2).text := isoTot.String;
			self.tblTranship.accessCell(isoLine,2).fontBold := true;
			self.tblTranship.accessCell(isoLine,1).fontBold := true;
			foreach sub in isoLine + 1 to cnt -1 do
				self.tblTranship.accessCell(sub,1).text := null;
			endforeach;
			
			isoTot := 0;
		
			isoLine := cnt;
		endif;

		discTot := discTot + transhipSummary.count;
		isoTot := isoTot + transhipSummary.count;
		gTotal := gTotal + transhipSummary.count;
		discGroupStr := transhipSummary.dischargePort;
		isoGroupStr := transhipSummary.isoGroup;

	
	endforeach;
	self.tblTranship.accessCell(discLine,4).text := discTot.String;
	self.tblTranship.accessCell(discLine,4).fontBold := true;
	self.tblTranship.accessCell(discLine,3).fontBold := true;
	
	self.tblTranship.accessCell(isoLine,2).text := isoTot.String;
	self.tblTranship.accessCell(isoLine,2).fontBold := true;
	self.tblTranship.accessCell(isoLine,1).fontBold := true;
	
	foreach sub in discLine + 1 to en do
		self.tblTranship.accessCell(sub,3).text := null;
	endforeach;
	foreach sub in isoLine + 1 to cnt -1 do
		self.tblTranship.accessCell(sub,1).text := null;
	endforeach;
	
	// #### GRAND TOTAL
	self.tblTranship.addItem("Total" &amp; Tab &amp; gTotal.String);
	self.tblTranship.accessCell( self.tblTranship.rows,2).fontBold := true;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayTranshipSummary" id="f4e8b8b5-8143-423b-83af-c4053db5b0b3">
        <source>displayTranshipSummary(_transhipSummary : CMIF_TranshipSummary; _row : Integer) protected;
// ---------------------------------------------------------------------------
// Created:     September 2007 cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	pad3High : Integer;
	pad2High : Integer;
	tmpStr, newRow : String;
	idx : Integer;
	totISO, totDISH, numCRs : Integer;
begin
	pad2High := (_transhipSummary.count/2).Integer;
	if _transhipSummary.count mod 2 &lt;&gt; 0 then
		pad2High := pad2High + 1;
	endif;
	pad3High := (_transhipSummary.count/3).Integer;
	if _transhipSummary.count mod 3 &lt;&gt; 0 then
		pad3High := pad3High + 1;
	endif;
	newRow := _transhipSummary.yardAllocationRows.insertCrIntoLongString(40,",", numCRs); // PAR 19484

	tmpStr := _transhipSummary.isoGroup&amp;Tab&amp;Tab&amp;
					_transhipSummary.dischargePort&amp;Tab&amp;
					Tab&amp;
					_transhipSummary.exportVoyageCode&amp;Tab&amp;
					_transhipSummary.commodityGroup&amp;Tab&amp;
					_transhipSummary.count.String&amp;Tab&amp;
					pad2High.String&amp;Tab&amp;
					pad3High.String&amp;Tab&amp;
					_transhipSummary.yardAllocation &amp;Tab&amp;
					newRow // PAR 19484
					
					;
					
	if _row = 0 then
		idx := self.tblTranship.addItemObject(_transhipSummary, tmpStr);
	else
		idx := _row;
		self.tblTranship.addItemAt(tmpStr, idx);
		self.tblTranship.accessRow(idx).itemObject := _transhipSummary;
	endif;
	if numCRs &gt; 0 then
		self.tblTranship.accessRow(idx).height := self.tblTranship.defaultRowHeight * (numCRs + 1);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_transhipSummary" type="CMIF_TranshipSummary"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
