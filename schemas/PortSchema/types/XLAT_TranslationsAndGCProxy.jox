    </JadeMethod>
    <JadeMethod name="zBuildXmlForTextMessageConstan" id="75bae658-f7b5-4252-8953-f805ff340d4d">
        <source>zBuildXmlForTextMessageConstan(includeHeader : Boolean):String protected;

// use this method when creating or updating a global constant for literal text (error messages, translatable strings)

vars
	txt : String;
begin
	
	if includeHeader then
		txt := XML_Version;
	endif;
	
	return	txt &amp; 
			XMLTag_Header &amp; '&gt;
' &amp; zzBuildXmlForLocaleText( myCategory.usesShortText) &amp; '&lt;/' &amp; XMLTag_Header &amp; '&gt;';
		   
end;</source>
        <access>protected</access>
        <Parameter name="includeHeader" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="zzBuildXmlForLocaleText" id="f4f1310c-303b-4355-8872-1a78a415124d">
        <source>zzBuildXmlForLocaleText(includeShortText : Boolean):String protected;

vars
	locale 		: CM_Locale;
	text		: String;
	shortText	: String;
	xml			: String;
	idx			: Integer;
begin

// get 0000 locale and output.  if no 0000 then use 5129
// do not output any other categories at this point

	foreach locale in self.allLocales do
		idx := idx + 1;
		if locale.localeId &lt;&gt; StandardTextLocaleStr then
			continue;
		endif;
		text := allText[idx];
		if includeShortText then
			shortText := allShortText[idx];
		endif;
		
		xml := xml &amp; '&lt;' &amp; XMLTag_LocaleMsg &amp; ' ' &amp; XMLTag_LocaleName &amp; '="' &amp; locale.localeId &amp; '"&gt;' &amp; CrLf;
		xml := xml &amp; '&lt;' &amp; XMLTag_Msg &amp; '&gt;' &amp; text.xmlReplaceReservedChars(true) &amp; '&lt;/' &amp; XMLTag_Msg &amp; '&gt;' &amp; CrLf;
		if includeShortText then
			xml := xml &amp; '&lt;' &amp; XMLTag_ShortMsg &amp; '&gt;' &amp; shortText.xmlReplaceReservedChars(true) &amp; '&lt;/' &amp; XMLTag_ShortMsg &amp; '&gt;' &amp; CrLf;
		endif;
		xml := xml &amp; '&lt;/' &amp; XMLTag_LocaleMsg &amp; '&gt;' &amp; CrLf;
	endforeach;		
	
	return xml;
end;</source>
        <access>protected</access>
        <Parameter name="includeShortText" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
