    <JadeMethod name="getObjectInPriorRow" id="5bcb5751-90a7-4366-b964-00f88a2177f5">
        <updating/>
        <source>getObjectInPriorRow() updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 25 February 2004
//
//********************************************************************
vars
	theTI : CM_TrackedItem;
	theRow : Integer;
	obj : Object;
begin
	if (self.tableRowNumber &lt;= self.tblData.fixedRows + 1) or self.tblData.rows = self.tblData.fixedRows + 1 then
		return;
	endif;
	
	theRow := self.tableRowNumber - 1;
	obj := self.tblData.accessRow(theRow).itemObject;
	if obj.isKindOf(CM_TrackedItem) then
		self.myObjectBeforeNote :=  obj.CM_TrackedItem;
	endif;
	
epilog
	self.tableRowNumber := null;
end;</source>
    </JadeMethod>
    <JadeMethod name="getTblDataDef" id="e03127be-8f82-4b73-a904-f705777e7cf4">
        <source>getTblDataDef(): EntTableDef;
//--------------------------------------------------------------
//Created: 14 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	entDef				: EntTableDef;
	entDefStr			: String;
	cargoBOLType		: CM_CargoBOLType;
	yardLocn			: CM_Object;
begin

	yardLocn := self.filterYardLocation; 

	cargoBOLType := self.myCurrentCargoBOLType;
	if cargoBOLType &lt;&gt; null and
	  (not cargoBOLType.isKindOf(CM_CargoType)) then
		return inheritMethod();
	elseif CM_WarehouseRowController.hasInstance(yardLocn) then
	//global.processDebug("CNWJC2", true);
		entDef := app.myController.getEntTableDef(ETDef_BreakBulkData);
		//entDef := app.myController.getEntTableDef(ETDef_ContainerData);
	elseif CM_LogController.hasInstance(yardLocn) then
	//global.processDebug("CNWJC2", true);
		entDef := app.myController.getEntTableDef(ETDef_LogDataTable);
	else
		entDef := app.myController.getEntTableDef(ETDef_ContainerData);
	endif;
	
	return entDef;
	
end;</source>
        <ReturnType type="EntTableDef"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="4cb3a6ed-8c82-4bc3-9dae-a577e601bdba">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:     06 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------

vars
	newXML			: String;
	otherXML		: String;
	xmlInformation		: String;
	xmlData				: String;
	xmlTa				: String;
	tCode				: String;
	ta				: CM_TerminalArea;
	terminal 		: CM_Terminal;
	startTagPos,
	tmpPos			: 	Integer;
	startTag			: String;
	endTag				: String;
	
	startPos : Integer;
	endPos   : Integer;
	tmpUserWin	: CM_UserWindow;
	
begin

	xmlData	:=	inheritMethod();

	startTag	:=	"&lt;" &amp; TAG_Terminal &amp; "&gt;";
	endTag		:=	"&lt;/" &amp; TAG_Terminal &amp; "&gt;";
	
	tmpUserWin := app.allUserWindows[self.name];
	if tmpUserWin &lt;&gt; null then
		xmlInformation := tmpUserWin.xmlInfo;
	endif;
	
	if self.myStartupObject &lt;&gt; null and CM_BoxcarWagonController.hasInstance( self.myStartupObject) then	//08 Apr 2013	NDL	Par 31278
		//Just leave it the way it was.
		return xmlData &amp; xmlInformation;
	endif;

	
	// extract all xml informtion of all user terminals except myTerminal.
	startPos := xmlInformation.pos(startTag, 1);
	if startPos &lt;&gt; 0 then // we have a start tag
		endPos :=  xmlInformation.pos(endTag,startPos)  + (endTag.length);
		while true do
			startTagPos := startPos;
			tCode	:=	xmlInformation.cnEcGetNextTagValueOfName(TAG_Code, startTagPos);
			if tCode = null then
				break;
			endif;
			if self.myTerminal.code &lt;&gt; tCode then
				if endPos &gt; startPos then
					// get the xml text between the &lt;Terminal&gt; &lt;/Terminal&gt; tages.
					newXML :=  newXML &amp; xmlInformation[startPos:(endPos-startPos)];
				endif;
			endif;
			startPos := xmlInformation.pos(startTag, endPos);
			if startPos = 0 then 
				break;
			endif;
			endPos := xmlInformation.pos(endTag,startPos)  +(endTag.length);
			if (endPos-1) &gt; xmlInformation.length then 
				break;
			endif;
		endwhile;
	endif;
	
	// here we add the new xml tags to be saved for myTerminal.
	newXML	:=	newXML &amp; self.TAG_Terminal.asXmlPrefix();
	newXML	:=	 newXML &amp; self.TAG_Code.asXmlPrefix() &amp; self.myTerminal.code &amp; self.TAG_Code.asXmlSuffix();
	ta := self.filterTerminalArea;
	if ta &lt;&gt; null then
		newXML := newXML &amp; self.TAG_TerminalArea.asXmlPrefix() &amp; ta.id &amp; self.TAG_TerminalArea.asXmlSuffix();
	endif;
	newXML	:=	newXML &amp; self.TAG_Terminal.asXmlSuffix();
	

	
	return xmlData &amp; newXML ;
	
	/*
	// this is how it was
	xmlData	:=	inheritMethod();
	
	ta := self.filterTerminalArea;
	
	if ta &lt;&gt; null then
		xmlTa := self.XML_TA.asXmlPrefix() &amp; ta.id &amp; self.XML_TA.asXmlSuffix();
	endif;
	
	return xmlData &amp;  xmlTa;
	*/
	
end;

</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleHeaderSelect" id="e71a86b5-e20e-4db9-a8c9-c7bc7815e8c5">
