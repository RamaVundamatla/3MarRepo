vars

begin
	self.doOK();
epilog

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyWorkOrder" id="f6f1f3c2-9ef3-4ab7-afa4-4b6f14742455">
        <updating/>
        <source>setProxyWorkOrder(_workOrder : CM_WorkOrder)updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2022 navma1 ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars

begin
	self.myPxyWorkOrder := _workOrder;
epilog

end;</source>
        <Parameter name="_workOrder" type="CM_WorkOrder"/>
    </JadeMethod>
    <JadeMethod name="setWorkOrderMode" id="90a7323c-bf4c-46df-9ba0-2c03b64ed8f1">
        <updating/>
        <source>setWorkOrderMode(_mode : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2022 navma1 ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars

begin
	self.workOrderMode := _mode;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1c920bc0-f30b-45d3-8b05-5b3ccddc5261">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2022 navma1 	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
15 Dec 2022	navcs2	ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Sceen
24 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

begin
	
	inheritMethod();
	
	
	if self.workOrderMode = WorkOrderMode_Cargo then									
		self.myAssistant.listWorkOrderCargoTasks(self.lstTasks, self.myTerminal);
	elseif self.workOrderMode = WorkOrderMode_Voyage then																		
		self.myAssistant.listWorkOrderVoyageTasks(self.lstTasks, self.myTerminal);			//10.01.2022 navma1 #52510
	else
		self.myAssistant.listWorkOrderToDoTasks(self.lstTasks, self.myTerminal);			//15 Dec 2022 navcs2 #56840:[54265]
	endif;																					
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="bc972303-c420-48b1-9f85-e8f93de8b140">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 23 December 2022 12:07:12.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0024865, locale);
	lblSelectTasks.translateCaption(Xlat_0024866, locale);
end;</source>
    </JadeMethod>
</GUIClass>
