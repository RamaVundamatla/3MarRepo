    <JadeMethod name="addWorkAndCompChargeDaysTo" id="866c0e5c-6252-405c-af05-5bb3cbdead01">
        <source>addWorkAndCompChargeDaysTo(  _ti : CM_TrackedItem; _expiryDate : Date; _days : Integer ) : Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 September 2017	jlgndl1	Initial creation	TFS 7032

*/

vars

	storageConfigType : CM_StorageConfigType;
	
begin

	// re-write for TFS 7032	NDL	06 Nov 2017
	storageConfigType := self.myTerminal.getMyStorageConfigType;
