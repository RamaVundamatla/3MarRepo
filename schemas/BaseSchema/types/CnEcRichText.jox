        <embedded/>
        <type name="Integer"/>
        <access>protected</access>
    </PrimAttribute>
    <PrimAttribute name="focusColor" id="06bc671f-ea46-4f47-91c1-86b96f9ee571">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="isFocusColorUsed" id="95c69f21-111f-48ac-99f4-ac92d8520f45">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="isRequired" id="1c030b90-1dd6-452a-a2ea-606667fca4ef">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="controlNamePrefix" id="3f5a4705-ce7f-403d-936d-e85d55346771">
        <source>controlNamePrefix(): String;
// --------------------------------------------------------------------------------
// Created:		20 February 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return "rtf";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="40ac2178-fb09-423d-a91d-d83029ec49cf">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		20 February 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.focusColor		:=	self.backColor;
	self.colorNoFocus	:=	self.backColor;
end;</source>
    </JadeMethod>
    <JadeMethod name="gotFocus" id="a67d8f14-5ddb-406a-afb1-7bba16926052">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>gotFocus(textbox: JadeRichText input) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		20 February 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(textbox);
	
	if self.isFocusColorUsed and self.backColor &lt;&gt; self.focusColor then
		self.colorNoFocus	:=	self.backColor;
		self.backColor		:=	self.focusColor;
	endif;
end;</source>
        <Parameter name="textbox" type="JadeRichText" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lostFocus" id="dc3253e5-0412-4eb9-91c4-7334e160ad98">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>lostFocus(textbox: JadeRichText input) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		20 February 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(textbox);
	
	if self.isFocusColorUsed and self.backColor &lt;&gt; self.colorNoFocus then
		self.backColor		:=	self.colorNoFocus;
	endif;
end;</source>
        <Parameter name="textbox" type="JadeRichText" usage="input"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="61c02018-2da9-4032-a18c-4d26d5505ea6">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		20 February 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(cntrl, persistCntrl);
	
	if self.isRequired then
		self.autoRedraw	:=	true;
		self.drawSolidRectangle(self.clientWidth()-4, 0, self.clientWidth(), 4, Red);
	endif;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
