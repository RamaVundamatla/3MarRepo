    <JadeMethod name="setTableDataFromOrganiser" id="a13c4bcc-91dc-4f35-bb6b-030a09bb9f4d">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:     03 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 08/03/2011		cnwdap1			PAR #27166 CCMS POL 2001 Separate column organisers for inwards/outwards
// ---------------------------------------------------------------------------

vars
	index	: Integer;	// PAR #27166
	
begin
	// PAR #27166 start set tbale xml string, and store new string returned from column organiser
	self.zSetXMLStrForTblColumns(_theTable, false);	
	index := self.getIndexForXmlStrTblDataArray();
	if index &lt;= self.xmlStrTblDataArray.size then
		self.xmlStrTblDataArray[index] := self.xmlStrTblData;
	endif;
	// PAR #27166 end
	
	self.doBuildQueryLists();
	//17/12/2009 cnwdz2 par22001
	self.doChangeInOut();
epilog

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="8688bc37-5913-4e51-b849-b84655ff0714">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     04 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/05/2009	consw1		SFW1067 - Rail Simplifications
// 08/03/2011	cnwdap1		PAR #27166 CCMS POL 2001 Separate column organisers for inwards/outwards
// 07/06/24		jlier1 		TFS 64530 - performance improvements
// 29 Aug 2024  navhl20		ChangeRequest 65898: MTN - Add Text Filter to Rail operations screen
// ---------------------------------------------------------------------------
vars
	tmpRoot : CM_Root;
	colXml	: String;	// PAR #27166
begin
	inheritMethod();
	
	self.setCaption( app.getErrorString(Rail_operations) );

	self.mnuHideTreeView.visible := false;
	self.initTblTrainQuery();
	
	//11/08/2010 cnwdz2 25317
	//self.loadCmbDestinationPort();
	self.cmbDestination.myAssistant 	:= self.myAssistant;
	self.cmbDestination.isRail			:= true;
	
	self.loadCmbFreightForward();
	self.loadCmbReleaseRequest();
	self.loadConsignee(); 

	self.beginClassNotification(CM_Rail, false, self.myTerminal.getTerminalEvent(Rail_Clear_Rake_Event), Response_Continuous, null);

	self.beginClassNotification(CM_RailJob, false, self.myTerminal.getTerminalEvent(RailJob_Create_Event), Response_Continuous, null);
	self.beginClassNotification(CM_RailJob, false, self.myTerminal.getTerminalEvent(RailJob_Update_Event), Response_Continuous, null);
	self.beginClassNotification(CM_RailJob, false, self.myTerminal.getTerminalEvent(RailJob_Delete_Event), Response_Continuous, null);

	self.beginClassNotification(CM_Wagon, false, self.myTerminal.getTerminalEvent(Wagon_Update_Event), Response_Continuous, null);
	self.beginClassNotification(CM_Wagon, false, self.myTerminal.getTerminalEvent(Wagon_Create_Event), Response_Continuous, null);
	self.beginClassNotification(CM_Wagon, false, self.myTerminal.getTerminalEvent(Wagon_Delete_Event), Response_Continuous, null);
	
	self.beginClassNotification(CM_Train, false, Any_System_Event, Response_Continuous, null);

	
	tmpRoot := app.myRoot;
	self.mySDF.picture1 := tmpRoot.getConfig(PicAvail).Binary;
	self.mySDF.picture2 := tmpRoot.getConfig(PicUnAvail).Binary;
	self.mySDF.picture3 := tmpRoot.getConfig(PicHasTLs).Binary;
	self.mySDF.picture4 := tmpRoot.getConfig(PicTLsUp).Binary;
	self.mySDF.myParentForm := self;
	
	self.myAssistant.comboBoxTrain(self.cmbTrain, self.cmbTrain.listObject.CM_Train, false, false, false);
	self.btnConfirmTrain.enabled := false;
	self.fldInfo.topSheet := self.shtTransportView;
	self.frmModeStatusBar.myFrameDisplayMode.enabled := true;	
	self.getXMLSettingsForSetup();


	self.switchParents();
	self.doHideShowClearButton();
	
	
	self.mnuToggleTransportView.visible := true;
	if self.myCurrentRailArea = null and self.myCurrentTrain = null then // might be pre initialized from Train Enq
		self.myCurrentRailArea := self.getFirstRailArea(); // PAR 20384
	endif;
	
	self.btnViewDest.value:=true;
	self.mySDF.setViewMode(VIEW_JOB);	
	self.doShowTrainRail(); // PAR 20384
	self.fldSelectAreas.topSheet := self.shtSelectAreas;
	
	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDeleteJob.enabled:= false;
		self.btnAddRequest.enabled:= false;
		self.btnClearRake.enabled:= false;
		self.btnMoveIt.enabled:= false;
		self.btnEditWagon.enabled:= false; // TFS 2734
		self.btnAddWagon.enabled:= false; // TFS 2734
		self.btnCCWagon.enabled:= false; // TFS 2734
		self.btnRailAllocRem.enabled:= false; // TFS 2734
	endif;
	
	self.chkRetrospect_click( self.chkRetrospect );
	self.frmTableFilter.setupControl(self.tblWorkEntries, null);		//29.08.2024 navhl20 #65898
end;</source>
    </JadeMethod>
    <JadeMethod name="showAreaSelector" id="0fc438a8-7733-49f9-bc47-64f314500f93">
        <source>showAreaSelector();
// ---------------------------------------------------------------------------
// Created:     May 2009 ANDREW BISHOP
//
// Changed On	Changed By	Reason
// ----------	----------  --------------------------------------------------
// 26 Mar 2010	consw1		PAR #23400 - Can still view departed trains
// ---------------------------------------------------------------------------

vars
	theFrame : CMUI_MoveableFrame;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
