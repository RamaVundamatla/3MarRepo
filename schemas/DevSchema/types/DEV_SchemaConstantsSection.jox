<Class name="DEV_SchemaConstantsSection" id="9456ef59-263d-40ff-ae8b-63663b2455bb">
    <superclass name="DEV_SchemaGenericSection"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="dev"/>
    <ExplicitInverseRef name="allConstantCategories" id="6633d975-6d7b-49ea-b049-3d31a967575f">
        <kind>parent</kind>
        <updateMode>automatic</updateMode>
        <type name="DEV_GlobalConstantCategories"/>
        <access>readonly</access>
        <Inverse name="DEV_GlobalConstantCategory::mySection"/>
    </ExplicitInverseRef>
    <JadeMethod name="create" id="c19cfb9f-1518-4a6e-b7ac-b16817c472e1">
        <updating/>
        <source>create(_name,
		_content 		: String; 
		_contentArray	: DEV_StringArray;
		_devSchema 		: DEV_Schema) 
		::super(_name, _content, _contentArray, _devSchema) updating;
/*

Purpose:			Constructor for DEV_SchemaConstantsSection class

Parameters:			_name:			The name of the section
					_content:		The content in the section
					_contentArray:	The data in an array in case we are dealing with a large section
					_devSchema:		The schema the section belongs to

Return Value:		

Date		Who		Reason
28 October 2021	navpw1	Initial creation TFS: 52202

*/

vars

begin

epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_content" type="String"/>
        <Parameter name="_contentArray" type="DEV_StringArray"/>
        <Parameter name="_devSchema" type="DEV_Schema"/>
    </JadeMethod>
    <JadeMethod name="extractSection" id="1ab9e808-a7a0-4dda-84b9-d56a5f2f4950">
        <source>extractSection(_outputFile : File io);
/*

Purpose:			Extracts the constants section to file

Parameters:			_outputFile: File to write output string/line to

Return Value:		

Date		Who		Reason
15 November 2021	navpw1	Initial creation TFS: 52202

*/

vars
	globalConstantCategory	: DEV_GlobalConstantCategory;
	globalConstant			: DEV_GlobalConstant;
	outputText				: String;
	
begin
		outputText := self.name;
		
		foreach globalConstantCategory in self.allConstantCategories do
			outputText &amp;= CrLf &amp; self.getDelimiter() &amp; "categoryDefinition " &amp; globalConstantCategory.name;
			//Writes: &lt;NewLine&gt;&lt;Tab&gt;categoryDefinition&lt;Space&gt;&lt;GlobalConstantCategoryName&gt;
			
			if globalConstantCategory.documentationTextData &lt;&gt; null then
				outputText &amp;= CrLf &amp; self.getDelimiter() &amp; "documentationText";
				//Writes: &lt;NewLine&gt;&lt;Tab&gt;documentationText
				outputText &amp;= CrLf &amp; "`" &amp; globalConstantCategory.documentationTextData &amp; "`" &amp; CrLf;
				//Writes: &lt;NewLine&gt;&lt;DocumentationTextData&gt;
			endif;
			
			if globalConstantCategory.hasTimeStamp() &lt;&gt; null then
				//outputText &amp;= CrLf &amp; self.getDelimiter() &amp; self.getDelimiter() &amp; "setModifiedTimeStamp " &amp; globalConstantCategory.modifiedTimeStamp;
				outputText &amp;= CrLf &amp; self.getDelimiter() &amp; self.getDelimiter() &amp; "setModifiedTimeStamp " &amp; globalConstantCategory.getLastModifiedTimeStamp();
				//Writes: &lt;NewLine&gt;&lt;Tab&gt;&lt;Tab&gt;setModifiedTimeStamp&lt;Space&gt;&lt;modifiedTimeStamp&gt;
			endif;
			
			foreach globalConstant in globalConstantCategory.allConstants do
				outputText &amp;= CrLf &amp; self.getDelimiter() &amp; self.getDelimiter() &amp; (globalConstant.name  &amp; ":").cnEcPadTrailing(31, " ") &amp; globalConstant.type &amp; " = " &amp; globalConstant.value &amp; ";";
				//Writes: &lt;NewLine&gt;&lt;Tab&gt;&lt;Tab&gt;&lt;ConstantName:&lt;ConstantValue&gt;
				
				if (globalConstant.documentationTextData &lt;&gt; null) then
					outputText &amp;= CrLf &amp; self.getDelimiter() &amp; "documentationText";
					//Writes: &lt;NewLine&gt;&lt;Tab&gt;documentationText
					outputText &amp;= CrLf &amp; "`" &amp; globalConstant.documentationTextData &amp; "`" &amp; CrLf;
					//Writes: &lt;NewLine&gt;&lt;DocumentationTextData&gt;
				endif;
				
				if(globalConstant.hasTimeStamp() &lt;&gt; null) then
					//outputText &amp;= CrLf &amp; self.getDelimiter() &amp; self.getDelimiter() &amp; "setModifiedTimeStamp " &amp; globalConstant.modifiedTimeStamp;
					outputText &amp;= CrLf &amp; self.getDelimiter() &amp; self.getDelimiter() &amp; "setModifiedTimeStamp " &amp; globalConstant.getLastModifiedTimeStamp();
					//Writes: &lt;NewLine&gt;&lt;Tab&gt;&lt;Tab&gt;setModifiedTimeStamp&lt;Space&gt;&lt;modifiedTimeStamp&gt;
				endif;
				
			endforeach;
			_outputFile.writeString(outputText); //Write each constant category out to file. Stops the string becoming too long
			outputText := "";
		endforeach;
		
		outputText &amp;= CrLf;
		
		_outputFile.writeString(outputText);

end;</source>
        <Parameter name="_outputFile" type="File" usage="io"/>
    </JadeMethod>
</Class>
