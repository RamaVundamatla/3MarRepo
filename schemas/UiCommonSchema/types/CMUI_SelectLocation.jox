    <JadeMethod name="setupForm" id="fd3a8a57-acd7-4fe8-b8d0-94a1af12badd">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     28 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod();
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar	:= true;
	
	self.frmSelect.isToMove				:= false;
	self.frmSelect.distanceFromRight	:= 0;
	self.frmSelect.distanceFromBottom	:= 0;
	self.frmSelect.top					:= 0;
	self.frmSelect.left					:= 0;
	self.frmSelect.stretchWidth			:= true;
	self.frmSelect.stretchHeight		:= true;
	self.myTerminal	:= app.getMyTerminalDO_NOT_USE;
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="91c8acba-2cb0-4529-a549-61038d371de7">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008074, locale);
end;</source>
    </JadeMethod>
</GUIClass>
