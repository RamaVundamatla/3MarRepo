<Class name="TranslatableStringMigratnAgOLD" id="3b1498bb-2aea-48e3-b9eb-ddb9ae8c4da9">
    <superclass name="LocalisationSupportAgents"/>
    <transient/>
    <final/>
    <subschemaFinal/>
    <transientAllowed/>
    <text>Utility to migrate TranslatableString content to GlobalConstants (category=Exception)



Localisation - TranslatableStrings are being replaced with GlobalConstants
call utility methods for each migration step

Step 1 - Analyse existing translatable strings, and output to csv (tsexportFull.xls). 
		 Manually resolve any translatable string in superschemas, and remove any that are not used.

Step 2 - check for conficts between GCs and TSs, then create partial schema file (PortSchema) containing new GC definitions, 
		 based on existing TranslatableStrings.

Step 3 - AFTER the scm file is loaded, update existing references to TranslatableStrings to reference GC's instead

Step 4 - remove all TranslatableString definitions by manually editing the scm files</text>
    <DbClassMap file="dev"/>
    <ExplicitInverseRef name="allLSTranslatableStrgsBySchema" id="a32f4b1e-7af5-494b-97e3-0ee9dd49e774">
        <kind>parent</kind>
        <type name="LSTranslatableStringBySchema"/>
        <Inverse name="LStranslatableString::myAgentOLD"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="allLStranslatableStrings" id="084c51d4-e693-4137-b54b-d54dee88ad85">
        <kind>parent</kind>
        <type name="LStranslatableStringByNameDict"/>
        <Inverse name="LStranslatableString::myAgentOLD"/>
    </ExplicitInverseRef>
    <PrimAttribute name="migrationPath" id="eca9d05c-18a0-4a53-8caa-daae475077c7">
        <type name="String"/>
        <access>protected</access>
    </PrimAttribute>
    <JadeMethod name="doTranslatableStringMigrationA" id="03d14fbf-845c-4b8f-8264-b623f007f68f">
        <updating/>
        <source>doTranslatableStringMigrationA() updating;

// Localisation - TranslatableStrings are being replaced with GlobalConstants
// call utility methods for each migration step

// BEFORE RUNNING THIS, use tsexportFull.xls to identify any BaseSchema translatable strings in use, and replace them

// Step 1 - Analyse existing translatable strings, and output to csv. Manually resolve any translatable string in superschemas,
//			and remove any that are not used.
// Step 2 - check for conficts between GCs and TSs, then create partial schema file (PortSchema) containing new GC definitions, 
//			based on existing TranslatableStrings.
// Step 3 - AFTER the scm file is loaded, update existing references to TranslatableStrings to reference GC's instead
// Step 4 - remove all TranslatableString definitions by manually editing the scm files

begin
	migrationPath := "\\cnwchcm24\cnwpod$\localisation\translatablestrings\";
	
	zA1_AnalyseTranslatblStringUse;	// Step 1 - creates csv
	zzCheckGCandTSconflicts;		// Step 2 - check for conflicts between GCs and TSs
	zA2_createGlobalConstantScm;		// step 3 - creates partial scm containing global constants

end;</source>
    </JadeMethod>
    <JadeMethod name="doTranslatableStringMigrationB" id="312e663b-7375-403a-acf1-edf6f0a19667">
        <updating/>
        <source>doTranslatableStringMigrationB() updating;

// Localisation - TranslatableStrings are being replaced with GlobalConstants
// call utility methods for each migration step

// BEFORE RUNNING THIS, use tsexportFull.xls to identify any BaseSchema translatable strings in use, and replace them

// Step 1 - Analyse existing translatable strings, and output to csv. Manually resolve any translatable string in superschemas,
//			and remove any that are not used.
// Step 2 - check for conficts between GCs and TSs, then create partial schema file (PortSchema) containing new GC definitions, 
//			based on existing TranslatableStrings.
// Step 3 - AFTER the scm file is loaded, update existing references to TranslatableStrings to reference GC's instead
// Step 4 - remove all TranslatableString definitions by manually editing the scm files

begin
	migrationPath := "\\cnwchcm24\cnwpod$\localisation\translatablestrings\";
	
	zB3_updMethodRefsToUseGlbCnsts;	// step 3 - update method refs to use global constants

end;</source>
    </JadeMethod>
    <JadeMethod name="toDo" id="a9bbe829-b9fe-4fc8-99e8-393d707e7606">
        <source>toDo();

vars

begin
/*	z2_createGlobalConstantScm needs to output a file containing global constant references, so z3_updMethodRefsToUseGlbConsts can parse
	and modify corresponding methods. Could base it on z1_AnalyseTranslatablStringUse to produce the expected file format
	
	z3_updMethodRefsToUseGlbConsts  doesn't handle parameters, maybe easiest to substitute app.getErrorMessage, then fix up any that
	are uncompiled (incorrect number of parameters)
*/

end;</source>
    </JadeMethod>
    <JadeMethod name="zA1_AnalyseTranslatblStringUse" id="d4b4342d-4db0-4da5-ad07-4dbae87e3834">
        <source>zA1_AnalyseTranslatblStringUse() protected;

// Collate and extract to file TranslatableStrings information to assist in analysis for localisation
// Extract includes script and method references. For superschemas of PortSchema (i.e. non-application classes), indirect references are included

constants
	Comma=',';
vars
	file				: File;
	fileSave			: CMDFileSave;
	start,finish		: Time;
	lsTs				: LStranslatableString;
begin
	start := app.actualTimeServer.time;	// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	// set up translatableString and schema collections
	zzSetupTranslatableStringDicts;
	
	// we're also interested in TSs in BaseSchema
	// 5/9/2006 no longer - all references have been resolved manually
//	createLSchema('BaseSchema');

	// Setup output file
	create fileSave transient;
	fileSave.defaultExt := 'csv';
	fileSave.fileName := migrationPath &amp; 'tsexport';
	if fileSave.open &lt;&gt; 0 then return; endif;
	
	create file transient;
	file.usePresentationFileSystem := true;
	file.openOutput(fileSave.fileName);
	

	// Output to file a line for each TranslatableString, including reference info
	
	// column headers
	file.writeLine('TranslatableString Oid' &amp;Comma&amp; 'Schema' &amp;Comma&amp; 'Name' &amp;Comma&amp; 'JMT?' &amp;Comma&amp;
				   'Direct Script Refs' &amp;Comma&amp; 'Indirect Script Refs' &amp;Comma&amp; 
				   'Direct Method Refs' &amp;Comma&amp; 'Indirect Method Refs' &amp;Comma&amp; 
				   'Ref Type' &amp;Comma &amp; 'Ref Schema' &amp;Comma&amp; 'Ref SchemaType' &amp;Comma&amp; 'Ref Name');

	// write references to file
	foreach lsTs in allLStranslatableStrings do
		lsTs.formatResults(file, Comma);
	endforeach;


epilog

	if file &lt;&gt; null then file.close; endif;

	finish := app.actualTimeServer.time;		// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.writeStatement( 'Complete ' &amp; finish.String &amp; ' (' &amp; ((finish - start)/1000).roundedTo(1).String &amp; ' secs)');

	delete file;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zA2_createGlobalConstantScm" id="d0420207-5d74-4535-938d-32667691c6e6">
        <source>zA2_createGlobalConstantScm() protected;

/*	Localisation - TranslatableStrings are being replaced with GlobalConstants
	Create partial schema file (PortSchema) containing new GC definitions, based on existing TranslatableStrings
	Note that an existing ConstantCategory cannot be updated - it must be deleted, then reloaded in its entirety.
*/
constants
OutputFile="PortSchema-partial xlatStrgsToGC.scm";
vars
	fileOutput	: File;
	fileSave	: CMDFileSave;
	lsSchema	: LSschema;
	ts	 		: TranslatableString;
	schemaName	: String;
	stringName	: String;
	locale		: Locale;	// 5129 = NZ English
	lastValue	: Integer;
	nextValue 	: Integer;	// Glb Constant unique value
	portSchema	: LSschema;
	obj			: Object;
	constant	: GlobalConstant;
begin

	app.msgBox('Please select output filename, which will be witten with partial scm file containing Global Constants', '',0);

	// Setup scm file
	create fileSave transient;
	fileSave.fileName := migrationPath &amp; OutputFile;
	if fileSave.open &lt;&gt; 0 then return; endif;
	
	create fileOutput transient;
	fileOutput.usePresentationFileSystem := true;
	fileOutput.openOutput(fileSave.fileName);

	lastValue := getNextExceptionGlobConstValue;
	nextValue := lastValue;
	
	portSchema := allSchemas[PortSchemaName];
	fileOutput.writeLine(portSchema.zScmHeader);

	// constant category
	fileOutput.writeLine('constantDefinitions
	categoryDefinition ' &amp; XLAT_Exceptions);

	foreach obj in rootSchema.getSchema('PortSchema').getConstantCategory(XLAT_Exceptions).getConstants do
		constant := obj.GlobalConstant;
		fileOutput.writeLine(
						Tab&amp;Tab&amp;													// padding
						constant.name &amp;':'&amp;Tab&amp;Tab&amp;Tab&amp;								// Glb Constant name
						'Integer = ' &amp; constant.valueAsInteger.String &amp;';' &amp;CrLf &amp;	// Glb Constant type &amp; value
						'	documentationText' &amp;CrLf &amp;
						'`' &amp; constant.text &amp; '`');									// default locale text
		
	endforeach;

	
	foreach lsSchema in allSchemas do
		lsSchema.produceScmFileForXlatablStrngs(fileOutput, nextValue);
	endforeach;

	fileOutput.writeLine(portSchema.zScmTrailer);

	app.msgBox('Complete', '',0);
	
epilog
	delete fileOutput;
	delete fileSave;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zB3_updMethdRefsToUseGlbConOLD" id="afc58181-c914-4311-84ae-4b4c9d7aae07">
        <source>zB3_updMethdRefsToUseGlbConOLD() protected;

// Accepts a csv input file containing a list of translatable strings, and corresponding method references.
// Edit each method to change TranslatableString to Global Constant (same name, no $ sign), and recompile.

// Run this AFTER running migrateTranslatableStrings() and loading the resulting partial scm file,
// so new global constants are declared.
// 

constants
MigrationPath="C:\Documents and Settings\cnwrbb1.CNW\Desktop\JadeMaster\localisation\translatablestrings\";
InputFile="tsexportFull.csv";
vars
	appSchemas 	: SchemaColl;
	file		: File;
	fileOpen	: CMDFileOpen;
	line 		: String;
	pos	 		: Integer;
	tsScmName 	: String;
	tsName	 	: String;
	methScmName	: String;
	className	: String;
	methodName	: String;
	locale		: Locale;	// 5129 = NZ English
	refmethod	: Method;
	start,finish: Time;
	methCount	: Integer;
	source		: String;
	compiler	: JadeCompiler;
	sigChanged	: Boolean;
begin
	start := app.actualTimeServer.time;	// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.writeStatement( '&gt;&gt;&gt; Starting');
	
	// Setup input file
	create fileOpen transient;
	fileOpen.defaultExt := '.csv';
	fileOpen.fileName := MigrationPath &amp; InputFile;
	if fileOpen.open &lt;&gt; 0 then return; endif;

	create file transient;
	file.usePresentationFileSystem := true;
	file.kind := File.Kind_Unknown_Text;	// 24/2/16 cnwmp6 PAR 36286 unicode version
	file.openInput(fileOpen.fileTitle);

	// get JMT application schema list
	create appSchemas transient;
	getJmtSchemas(appSchemas);

	create compiler transient;

	// read the file
	file.readLine;	// skip header
	while not file.endOfFile do
		line := file.readLine;
		pos := 1;
						line.nextCsvToken(pos);		// col A
		tsScmName :=	line.nextCsvToken(pos);		// translatable string schema
		tsName	  :=	line.nextCsvToken(pos);		// translatable string name
					 	line.nextCsvToken(pos);		// col D
					 	line.nextCsvToken(pos);		// col E
					 	line.nextCsvToken(pos);		// col F
					 	line.nextCsvToken(pos);		// col G
					 	line.nextCsvToken(pos);		// col H
					 	line.nextCsvToken(pos);		// col I
		methScmName :=	line.nextCsvToken(pos);		// method schema name
		className :=	line.nextCsvToken(pos);		// method schema name
		methodName :=	line.nextCsvToken(pos);	// method schema name
	
		if appSchemas.includes(rootSchema.getSchema(tsScmName)) = false then
			continue;	// skip JMT app superschemas
		endif;
	
	
		refmethod := rootSchema.getSchema(methScmName).getClass(className).getMethod(methodName);
		source := refmethod.getSource;
		
		// skip script references (fix manually)
		if source.pos('$' &amp; tsName,1) = null then
			app.writeStatement( 'not found: ' &amp; line);
			continue;
		endif;
		
		// substitute TranslatableString reference(s) with Global Constant references
		while true do
			pos := source.pos('$' &amp; tsName,1);
			if pos = null then break; endif;	// no more
			source := source[1:pos-1] &amp; tsName &amp; source[pos+tsName.length+1:end];
			methCount := methCount + 1;
		endwhile;
		
		
		app.writeStatement( 'Removal count: '&amp; (refmethod.getSource.length - source.length).String &amp; 
			  ', TranslatableString: ' &amp; tsName &amp;
			  ', from method: ' &amp; methScmName.String &amp; '::' &amp; refmethod.qualifiedName);

// IMPORTANT NOTE - THE FOLLOWING CODE HAS BEEN UNIT TESTED, BUT IS NOT SUPPORTED BY 
// THE JADE PLANT, AND SHOULD BE VALIDATED IN AN OFFLINE ENVIRONMENT. 
// ONLY UN-COMMENT AND RUN IN DEV WHEN YOU ARE SURE THERE ARE NO SIDE-EFFECTS.
	
		// update the method source with the substituted values, then recomile
//		beginTransaction;
//		refmethod.setPropertyValue(Method::source.name,source);
//		compiler.compileMethod(refmethod, sigChanged);
//		commitTransaction;
	
//		break;	// TESTING - STOP AFTER ONE!

	endwhile;


epilog
	finish := app.actualTimeServer.time;	// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	app.writeStatement( '&gt;&gt;&gt; Complete ' &amp; finish.String &amp; ' (' &amp; ((finish - start)/1000).roundedTo(1).String &amp; ' secs), methods processed=' &amp; methCount.String);
	if file &lt;&gt; null then file.close; endif;
	delete appSchemas;
	delete file;
	delete fileOpen;
	delete compiler;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zB3_updMethodRefsToUseGlbCnsts" id="4dd6184d-efac-4bdf-98e0-1769e5901593">
        <source>zB3_updMethodRefsToUseGlbCnsts() protected;

// Run this AFTER running migrateTranslatableStrings() and loading the resulting partial scm file,
// so new global constants are declared.
// 

vars
	lsSchema		: LSschema;
	lsts			: LStranslatableString;
	features		: FeatureSet;
	feature			: Feature;
	start,finish	: Time;
	compiler		: JadeCompiler;
	methCount		: Integer;
	refCount		: Integer;
	message			: String;
begin
	start := app.actualTimeServer.time;	// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.writeStatement( '&gt;&gt;&gt; Starting');

	// set up translatableString and schema collections
	zzSetupTranslatableStringDicts;

	create compiler transient;
	create features transient;
	foreach lsSchema in allSchemas do
		foreach lsts in lsSchema.allTranslatableStrings do

			if lsts.validate(message) = false then
				app.writeStatement( 'Error: ' &amp; message);
				continue;
			endif;
		
			lsts.zGetAllRefs(features);
			foreach feature in features do
				if feature.isKindOf(Method) then
					zB3_zUpdateMethod(lsts, feature.Method, refCount);
					methCount := methCount + 1;
					return; // TESTING - STOP AFTER FIRST ONE!!
				else
					app.writeStatement( '&gt;&gt;&gt; Skipping: not a method: ' &amp; feature.display);
				endif;
			endforeach;	// feature
		endforeach;	// lsts
	endforeach;	// schema

epilog
	finish := app.actualTimeServer.time;			// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.writeStatement( '&gt;&gt;&gt; Complete ' &amp; finish.String &amp; ' (' &amp; ((finish - start)/1000).roundedTo(1).String &amp; ' secs), methods processed=' &amp; methCount.String);
	delete compiler;
	delete features;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zB3_zUpdateMethod" id="c61ed492-a46e-4c6d-8d15-5164fea38fc6">
        <source>zB3_zUpdateMethod(lsts : LStranslatableString; meth : Method; refCount : Integer io);

vars
	source			: String;
	tsName			: String;
	pos				: Integer;
	xlatMethodName	: String;
	insertText		: String;
	localRefCount	: Integer;
begin
	source	:= meth.getSource;
	tsName	:= lsts.name;
	
	// skip script references (fix manually)
	if source.pos('$' &amp; tsName,1) = null then
		app.writeStatement( '&gt;&gt;&gt; not found: ' &amp; meth.qualifiedName &amp;Tab&amp; lsts.name);
		return;
	endif;
	
	// create the method name that gets the translated text (depends upon number of parameters)
	xlatMethodName := 'app.getErrorString';
	if lsts.parameterCount &gt; 0 then
		xlatMethodName := xlatMethodName &amp; lsts.parameterCount.String;
	endif;
	
	insertText := xlatMethodName &amp; '(' &amp; tsName &amp; ')';
	
	// substitute TranslatableString reference(s) with Global Constant references
	while true do
		pos := source.pos('$' &amp; tsName,1);
		if pos = null then break; endif;	// no more
		source := source[1:pos-1] &amp; insertText&amp; source[pos + insertText.length + 1:end];
		localRefCount := localRefCount + 1;
	endwhile;
	
	refCount := refCount + localRefCount;
	
	app.writeStatement( 'Ref count: '&amp; localRefCount.String &amp; 
		  ', TranslatableString: ' &amp; tsName &amp;
		  ', from method: ' &amp; lsts.myLSSchema.name &amp; '::' &amp; meth.qualifiedName);

	app.writeStatement (CrLf &amp; source);
// IMPORTANT NOTE - THE FOLLOWING CODE HAS BEEN UNIT TESTED, BUT IS NOT SUPPORTED BY 
// THE JADE PLANT, AND SHOULD BE VALIDATED IN AN OFFLINE ENVIRONMENT. 
// ONLY UN-COMMENT AND RUN IN DEV WHEN YOU ARE SURE THERE ARE NO SIDE-EFFECTS.
	
		// update the method source with the substituted values, then recomile
//		beginTransaction;
//		meth.setPropertyValue(Method::source.name,source);
//		compiler.compileMethod(meth, sigChanged);
//		commitTransaction;
	
end;
</source>
        <Parameter name="lsts" type="LStranslatableString"/>
        <Parameter name="meth" type="Method"/>
        <Parameter name="refCount" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="zzCheckGCandTSconflicts" id="9631e69d-66c4-4489-87d4-cbc6adb92f54">
        <source>zzCheckGCandTSconflicts() protected;

vars
	lsTs : LStranslatableString;
	
begin
	zFindAllGlobalConstants;
	
	foreach lsTs in allLStranslatableStrings where allGlobalConstants[lsTs.name] &lt;&gt; null do
		self.log("*** ERROR *** Global Constant / Translatable String conflict: " &amp; lsTs.myLSSchema.name &amp; '::' &amp; lsTs.name, true);
		//process.debug; commented out PAR 19975
		return;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zzSetupTranslatableStringDicts" id="a30455e0-aca7-48de-b74c-c9cc2cb3bdc6">
        <source>zzSetupTranslatableStringDicts() protected;

vars
	ts 			: TranslatableString;
	lsTs		: LStranslatableString;
	appSchemas	: SchemaColl;
	lsSchema	: LSschema;
	scm			: Schema;
begin

	// Identify application schemas
	fillSchemas;	

	create appSchemas transient;
	foreach lsSchema in allSchemas do
		appSchemas.add(lsSchema.mySchema);
	endforeach;
	
	// Creates two TranslatableString dicts, one sorted by schema, name, the other by name, , locale
	foreach ts in TranslatableString.instances where allSchemas.includesKey(ts.getMySchema.name) do

		create lsTs;
		//lsTs.init(self, ts, appSchemas);
	endforeach;

epilog
	delete appSchemas;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
