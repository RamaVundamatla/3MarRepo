    <JadeMethod name="getPicture" id="dc2e12e9-f863-4478-81e2-5e55f6ff1fc8">
        <source>getPicture(form: INV_TransactionMap): Picture;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.hidePictures then
		return null;
	endif;

	if self.type = CMIF_TMCType.TYPE_TRACKEDITEM then
		return form.picTypeTI;
	elseif self.type = CMIF_TMCType.TYPE_VOYAGE then
		return form.picTypeVoyage;
	elseif self.type = CMIF_TMCType.TYPE_EVENT then
		return form.picTypeEvent;
	elseif self.type = CMIF_TMCType.TYPE_SSSUMMARY then
		return form.picSnapShot;
	elseif self.type = CMIF_TMCType.TYPE_CARGOALLOC then
		return form.picTypeTI;
	elseif self.type = CMIF_TMCType.TYPE_WO then // TFS 39236
		return form.picTypeVoyage; // TFS 39236
	elseif self.type = CMIF_TMCType.TYPE_BOL then //01 Nov 2019
		return form.picTypeBol;	
	elseif self.type = CMIF_TMCType.TYPE_INVENTORY then // TFS 51219 25MAY2021 NAVAB1
		return form.picTypeInventory;	
	endif;
end;</source>
        <Parameter name="form" type="INV_TransactionMap"/>
        <ReturnType type="Picture"/>
    </JadeMethod>
