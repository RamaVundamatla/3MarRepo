    <JadeMethod name="setDrawStyleAndColors" id="60912fde-85d6-461c-8fa9-54f39037772e">
        <updating/>
        <source>setDrawStyleAndColors(_obj : Object; _frame : YRD_ContainerDrawingFrame input; _drawFillColor : Integer io;
		_outerColourUpper, _outerColourLower : Integer output) updating, protected;
// ---------------------------------------------------------------------------
// Created:     12 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpDisplayMode	: Integer;
	
begin

	tmpDisplayMode := self.displayMode;

	_frame.drawFillStyle := Frame.DrawFillStyle_Solid;
	_frame.drawStyle := Frame.DrawFillStyle_Solid;
	_frame.drawWidth := 1;

	if self.allSelectedObjects.includes(_obj) then
		_outerColourUpper := DarkGray;
		_outerColourLower := White;
	else
		_outerColourLower := DarkGray;
		_outerColourUpper := White;
	endif;

	//self.theDrawFillColor := _drawFillColor;
	_frame.drawFillColor := _drawFillColor;

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_frame" type="YRD_ContainerDrawingFrame" usage="input"/>
        <Parameter name="_drawFillColor" type="Integer" usage="io"/>
        <Parameter name="_outerColourUpper" type="Integer" usage="output"/>
        <Parameter name="_outerColourLower" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setFontSize" id="0d029530-868e-4853-8516-42a70cf84529">
        <updating/>
        <source>setFontSize() updating;
// ---------------------------------------------------------------------------
// Created:		11 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.scaleFactor = ScaleFactor_3 then
		self.defaultFontSize := 10;
	elseif self.scaleFactor = ScaleFactor_4 then
		self.defaultFontSize := 12;
	elseif self.scaleFactor = ScaleFactor_6 then
		self.defaultFontSize := 16;
	elseif self.scaleFactor = ScaleFactor_9 then
		self.defaultFontSize := 18;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setFontSizeForAttribute" id="0d0db3e5-a4d4-4239-8ce5-d67f9536fbdc">
        <updating/>
        <source>setFontSizeForAttribute() updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theScale,
	theFontSize	: Real;
	
begin

	theScale := self.scaleFactor;

	if theScale = ScaleFactor_1 or theScale = ScaleFactor_1_5 then
		theFontSize := 8;

	elseif theScale = ScaleFactor_2 then
		theFontSize := 8;
	elseif theScale = ScaleFactor_3 then
		theFontSize := 12;
	elseif theScale = ScaleFactor_4 then
		theFontSize := 14; //was 18
	elseif theScale = ScaleFactor_6 then
		theFontSize := 16; //was 20
	elseif theScale = ScaleFactor_9 then
		theFontSize := 20; //was 26  //epr par  37386 20/1/16
	endif;
	
	self.defaultFontSizeForAttributes := theFontSize;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="0b89956f-51d0-4458-b453-0d67b8d3d1d5">
        <updating/>
        <source>setForCreate(_dockBar: YRD_ContainerGridAreaDockBar) updating;
// ---------------------------------------------------------------------------
// Created:		10 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
