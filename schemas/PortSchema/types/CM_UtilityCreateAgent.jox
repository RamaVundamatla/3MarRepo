        <source>utlCreateSortingMethod(_pxySortingMethod : CM_SortingMethod; _realSortingMethod : CM_SortingMethod output; _passport : CM_Passport input);
/*

Purpose:			Creates a Sorting Method Object

Parameters:			_pxySortingMethod	CM_SortingMethod	The proxy sorting method to use to create the persistent object
					_realSortingMethod	CM_SortingMethod	The real sorting method that is returned
					_passport			CM_Passport			The passport to use to hold errors and perform other tasks

Return Value:		NONE

Date			Who		Reason
07 June 2023	navpw1	Initial creation TFS: 57813 (58438)

*/

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valSortingMethod(_pxySortingMethod);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	create _realSortingMethod persistent;
	_realSortingMethod.setForCreate(_pxySortingMethod);
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_realSortingMethod);
	endif;
	
end;</source>
