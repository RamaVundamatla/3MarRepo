    <JadeMethod name="trxDeleteLoggingOrg" id="3a6c1587-0cec-4399-85cf-9eded29580a6">
        <updating/>
        <source>trxDeleteLoggingOrg(pLoggingOrg:CM_LoggingOrganisation io; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     11 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	self.raiseExceptionIfNull(pLoggingOrg, 'Log Condition Code');

	app.setContinueCMExceptions(false);

	beginTransaction;

	self.exclusiveLockObjectToDelete(pLoggingOrg);

	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;

	if _passport.noErrors then
		app.myUtilityDA.myDeleteAuditAgent.audDeleteGeneric(pLoggingOrg);
	endif;

	if _passport.noErrors then
		pLoggingOrg.erase(NORMAL_ERASE);
	endif;

epilog		
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="pLoggingOrg" type="CM_LoggingOrganisation" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
