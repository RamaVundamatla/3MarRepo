    <JadeMethod name="getJobDetailByAttribute" id="15c8023e-21a3-447a-9c73-b602db977c94">
        <source>getJobDetailByAttribute(_name: String): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Sep 2023	navma1 ChangeRequest 60527: EUP | Mobile DD - [BackEnd] Truck Jobs - Receive Jobs

*/

	
	
vars	
	any 			: Any;
	request 		: CM_Request;
	reserveDetail	: CM_ReserveDetail;
	objArr			: CM_ObjectArray;
begin
	
	create objArr transient;
	if self.isRoadJob then
		foreach request in self.allRequests do
			reserveDetail := request.myReserveDetail;
			
			if reserveDetail &lt;&gt; null then
				objArr.addExclusive(reserveDetail.myReserveHeader);
			endif;
		endforeach;
	endif;
	
	if objArr.isNotEmpty then
		if _name = CM_BulkRelease::code.name then
			
			return objArr.listString(Comma,CM_BulkRelease::code.name).String;
		endif;
	
	endif;
	return any;
epilog
	delete objArr;
end;
</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
