    <JadeMethod name="getMsgBoxText" id="cf7baa69-9ecc-43a0-8a51-51d787a6a182">
        <source>getMsgBoxText() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
04 December 2024	navlw1	Jira-14844: MTN - Refinement of EDI Issue Save
12 December 2024	navlw1	Jira-33658: MTN - Error message needs changing for Email Details

*/

vars

begin
	if self.ediChanged and not self.emailChanged then
		return app.getErrorString1(Edi_config_changed_save, self.myCurrentEDIIssue.code);
	elseif self.emailChanged and not self.ediChanged then
		return app.getErrorString1(Email_detail_changed_save, self.myCurrentEDIIssue.code);
	elseif self.emailChanged and self.ediChanged then
		return app.getErrorString1(Edi_config_email_details_save, self.myCurrentEDIIssue.code);
	else 
		return null;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
