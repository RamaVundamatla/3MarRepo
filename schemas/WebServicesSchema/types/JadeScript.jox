	delete 	 request;
end;</source>
    </JadeMethod>
    <JadeMethod name="par25524_old" id="cdef0007-bfdf-4c35-b8da-0b854f557f48">
        <source>par25524_old();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2010	#cnwdz2	 

*/

vars
	menuItemDict	: CM_MenuItemByTypeMenuIdDict;
	menuItem		: CM_MenuItem;
	qryReport		: CM_QryReport;
	visibleRows		: StringArray;
	isSystemReport	: Boolean;
	entTableDef		: EntTableDef;
	entView			: EntTableView;
	entRowArray 	: EntTableRowArray;
	entTableRow		: EntTableRow;
	reportAgent	   	: WebService_ReportAgent;
	
	fieldDef		: WS_FieldDefinition;
	dataStore		: String;
	dsIdField		: String;
	dsDescField		: String;
	formDef			: WS_FormDefinition;
begin
	app.initialize();
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	menuItemDict := app.myRoot.myReportMenuRoot.allMenuItems;
	foreach menuItem in menuItemDict do
		if not menuItem.isKindOf(CM_QryReport) then
			continue;
		endif;
		
		qryReport := menuItem.CM_QryReport;
		if	not qryReport.isAvailableToWeb() then
			continue;
		endif;
		
		create visibleRows transient;
		isSystemReport := false;
		if qryReport.isKindOf(CM_QryReportUser) then
			entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs.getAtKey(qryReport.getETDefName());
			if entTableDef &lt;&gt; null then
				entRowArray := entTableDef.allEntTableRows;
			else
				entRowArray := null;
			endif;
			qryReport.CM_QryReportUser.allVisibleRows.copy(visibleRows);
		else
			isSystemReport := true;
			entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs.getAtKey(qryReport.tableDefName);
			if entTableDef &lt;&gt; null then
				entView := entTableDef.allEntTableViews.getAtKey(qryReport.tableDefViewName);
				if entView &lt;&gt; null then
					entRowArray := entView.allEntTableRows;				
				endif;
			else
				entRowArray := null;
			endif;
		endif;
		
		create reportAgent transient;
		create formDef;
		if entRowArray &lt;&gt; null then	
		
			app.writeStatement("Report Name:   " &amp; qryReport.reportName);
			app.writeStatement("EntTable        EntTableDef        Parameter Entrow        Parameter Value");
			app.writeStatement("==========================================================================");
			
			foreach entTableRow in entRowArray do
				fieldDef := formDef.loadFieldFromRow(entTableRow);	
				fieldDef.dataList := formDef.getGeneralDataLists(entTableRow.name);
				if isSystemReport then 
					visibleRows.add(entTableRow.name); 
				endif;
				
				reportAgent.loadDefaultParameterByName(qryReport.myFilterObject, entTableRow, entTableRow.name, fieldDef.defaultDescription, fieldDef.defaultId);
				if fieldDef.defaultId &lt;&gt; null then
					app.writeStatement(entTableRow.myGroup.constantName &amp; "        " &amp; entTableDef.name &amp; "        " &amp; entTableRow.name &amp; "        " &amp; fieldDef.defaultId);
				endif;					
			endforeach;
			
			app.writeStatement("");
			app.writeStatement("");
			
		endif;
	endforeach;

epilog
	delete visibleRows;
	delete reportAgent;
	delete formDef;
end;</source>
    </JadeMethod>
    <JadeMethod name="pwTFS53155" id="4f08fd54-a34f-40a4-bc60-9e873504f596">
        <source>pwTFS53155();
/*

Purpose:			Testst changes for 53155: MTN - Truck Loader/Unloader working very slow  

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
05 August 2022	navpw1	Initial creation TFS: 53155

*/

vars
	job : CM_RoadJob;
	wsRoadJob : WS_RoadJob;
	wsRoadWLE : WS_RoadWLE;
	
begin
	app.initialize;
	app.myPassport.setMyUserFromCode("NAVPW1");
	app.myPassport.setMyTerminal(app.myRoot.allTerminals["PW"]);
	
	job:="2274.1341651".asOid.CM_RoadJob;
	
	create wsRoadJob transient;
	
	wsRoadJob.setProxyFromObject(job);
	wsRoadJob.setLoadWLEDetails(job, true, true);
	wsRoadJob.setUnloadWLEDetails(job);
	
	foreach wsRoadWLE in wsRoadJob.allWLEsToUnload do
		write "Tracked Item: " &amp; wsRoadWLE.myTrackedItem.idTextBox &amp; " | " &amp; wsRoadWLE.hasCargoChecks.String;
	endforeach;

epilog
	delete wsRoadJob;

end;</source>
    </JadeMethod>
    <JadeMethod name="undocumentedPropertiesForAClas" id="6d821387-9cbf-42d7-b47b-77b40434a053">
        <source>undocumentedPropertiesForAClas();
/*

Purpose:		

Identify which subclasses of WS_ProxyObject has text for all its attributes	

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2014	cnwjr2	Initial creation

*/
vars

	cls 			: Class;
	subs			: ClassColl;
	props			: PropertyNDict;
	prop			: Property;
	count			: Integer;	
	file			: File;
	status			: String;

begin

	props		:= WS_VehicleBookingTimeslot.getProperties;
	foreach prop in props do
		if prop.text.length = 0 then
			write prop.name;
		endif;
	endforeach;

end;
</source>
    </JadeMethod>
</Class>
