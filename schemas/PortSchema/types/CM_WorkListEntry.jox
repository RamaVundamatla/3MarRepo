    <JadeMethod name="getNextUnactionedRTQueueTask" id="22905ab5-fe47-4c92-864e-e4f282b36dec">
        <source>getNextUnactionedRTQueueTask() : CM_RTQueueTask;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 February 2010	cnwer1	Initial creation

*/

vars
	iter : Iterator;
	rtQueueEntry : CM_RTQueueEntry;
	rtQueueTask : CM_RTQueueTask;
begin

	iter:=self.allRTQueueEntries.createIterator;
	
	while iter.next(rtQueueEntry) do
		if rtQueueEntry.status = ENTRY_COMPLETE then
			continue;
		endif;
		foreach rtQueueTask in rtQueueEntry.allTasks do
			if rtQueueTask.status &lt;&gt; TASK_COMPLETE then
				return rtQueueTask;
			endif;		
		endforeach;	
	endwhile;
	

	return null;

epilog
	delete iter;
end;</source>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
