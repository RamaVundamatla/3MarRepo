    <JadeMethod name="tReceiveAndDeleteJobCams" id="32964d50-9e11-4671-824c-e65fe3660811">
        <updating/>
        <source>tReceiveAndDeleteJobCams() updating;
//25 March 2014 cnwrs1	
// gate In container thru to yard, then delete the road job 
// Cancelled job should still create a Road Exit visit record  PAR 27472
// cams should process that record
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
// 10 Sep 2019	cnwrs1	TFS 46030
//
constants
	Container01 : String = "UUT87654321";
	Container02 : String = "UTUT000001";
	TestOperator	= 'MSL';
	Truck01 : String = "UTTRUCK";
	VoyageName = 'UT_VOYAGE';				
	BoatName = 'UT_VESSEL';
	DestPort = "NZZQN";
	DischPort = "NZAKL";
	CamGroup = "UT-MSL";
	CamProtocol	= "UTCICS_MES1008_2";
//	CamProtocol2 = "UT_ECN_CODECO2";
	SenderCode = "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode = "UT_SHIPPER";
	FacilityCode = "UT_FACILITY";
	RecipientCode = "UT_RECIPIENT";
vars
	runDateTime : TimeStamp;
	lRegisteredCargoTypes : IntegerArray;
	truck: CM_Vehicle;
	ti: CM_TrackedItem;
	vvr: CM_VehicleVisitRecord;
	vvrDetail: CM_VehicleVisitRecordDetail;
	iter: Iterator;
	operator : CM_Operator;
	pin : CM_GateArea;
	dualGate : CM_Gate;
	voyage : CM_Voyage;
	tempStr : String;
	startDateTime 	: TimeStamp;
	endDateTime 	: TimeStamp;
	camGroup 		: CM_CamGroup;
	camProtocol 	: CM_CamProtocol;
	camTaskHistory 	: CM_CamTaskHistory;
	operatorDict 	: CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
	camProtocolDesc : CM_CamProtocolDesc;
	emailEntity : CM_EmailEntity;
	qFCamTransaction : CMQF_CamTransactionTemplate;
	origCamsCreateTrxAudit : Boolean;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	deleteContainer(Container01);
	deleteContainer(Container02);
	deleteVehicle(Truck01);
	dualGate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	pin := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_PIN).asString);
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
	voyage := self.createVesselVoyage (VoyageName,BoatName,  operator);
		
	// First Gate In an Empty so we get Road Receival Txs
	self.opts.purge;
	self.opts.addAssoc("ContainerID2", Container01);
	self.opts.addAssoc("Voyage", voyage.code);		// par 29517 May 2012
	self.opts.addAssoc ("IMEX", TI_IMEX_STATUS_EXPORT);	// cnwcs5 June2012
	self.opts.addAssoc ("DestinationPort", DestPort);
	self.opts.addAssoc ("DischargePort", DischPort);
	vvr := gateInContainer(Truck01, Container02, "2200", operator.code, "GENL", dualGate);
	beginTransaction;
//	self.getTerminal.setConfig (CamsCreateTrxAudit, true);
	commitTransaction;
	ti := self.getTrackedItem(Container02);
	assertNotNull(ti);
	assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
	assertEqual(pin.myInTransitToLocation, vvr.vehicle.myPrimaryActualLocation);
	assertEqual(vvr.vehicle.allRoadJobs.size, 1);
	assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 2);
	assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);

	self.deleteJobEntry(vvr.myRoadJob.workListEntries.first);
	self.assertNotEqual(vvr.status, CM_VehicleVisitRecord.Status_Cancelled);
	self.assertEqual(vvr.allVehicleVisitRecordDetails.last.recordType, VisitRecord_Deleted_Entry);
		
	self.moveVehicleToLane(vvr.vehicle, pin, 1);
	assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pin, 1));
		
	self.moveVehicleToYard(vvr.vehicle);
	assertTrue(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation);
		
	// Delete the road job 
	self.deleteJobEntry(vvr.myRoadJob.workListEntries.first);
	self.assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Cancelled);
	foreach vvrDetail in vvr.allVehicleVisitRecordDetails do
		self.logMessage(vvrDetail.recordTypeString &amp; " " &amp; vvrDetail.timeStart.getNumeralString);
	endforeach;
	iter := vvr.allVehicleVisitRecordDetails.createIterator;
//	iter.back(vvrDetail);
//	self.assertEqual(vvrDetail.recordType, VisitRecord_DepartSecurityGate);	//VisitRecord_Complete_OutGate); // PAR 27472
	iter.back(vvrDetail);
	self.assertIsOneOf(vvrDetail.recordType, "Invalid Status", VisitRecord_Complete_OutGate, VisitRecord_DepartSecurityGate);	//VisitRecord_Cancel); // PAR 27472

	self.setTerminalConfig(CamsCreateTrxAudit, false);
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);
//	self.deleteCamProtocol(CamProtocol2);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);

	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRoad).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["User Defined JRW-Report"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	qFCamTransaction := app.myRoot.allCamProtocolDescs[CM_CamUserDefRepDesc.UserDefinedDescName].CM_CamUserDefRepDesc.allQFCamTransactionTemplates["Export Containers"];
//	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
//	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
//									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, false, false, 
//									   false, true, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, 
//									   0, 0, 0, 0, '', '', 'CM_CamReceiptGCExport', camEditTriggerFields, camTrainEventTypes, qFCamTransaction, false, 0, self.getTerminal, true, true, false, false, false, false, false, false, true, 
//									   allPackAreas, null, null);
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, true, false, false, false, false, false, false, false, false, false, false,
									   0, 0, 0, 0, '', '', 'CM_CamReceiptGCExport', camEditTriggerFields, camTrainEventTypes, qFCamTransaction, false, 0, self.getTerminal, true, true, false, false, false, false, false, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);
	beginTransaction;
	camProtocol.setPropertyValue(CM_CamProtocol::tempLeadingZerosNoDecimal.name, false);
	commitTransaction;
		
	// run cams
	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
 
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete iter;
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
//	delete tiUpdateCntrlr;
	delete lRegisteredCargoTypes;
end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;DAC ISSUE&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tRwrWithEditProdAttrs" id="ee8e7712-7041-4a5d-84c5-f21ff171c5bb">
        <source>tRwrWithEditProdAttrs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2020	jlgndl1	Initial creation	TFS 49916

*/

constants
	PREFIX = 'EDIT';
	JRWREPORT = 'CM_CamReceiptGCExport';
	FILTER = QFCam_GeneralCargo;
	PROTOCOL1008 = 'TFS49916';
	OPERATOR = 'MSL';
	CAMGROUP = 'UT_MSL';
	Cargo_Type = "UTFRUITVEG";
	Garden = "GARD";
	CargoID = "SPUDS49916";
vars
	desc : CM_CamProtocolDesc;
	trxColl : StringArray;
	filter : CMQF_CamTransactionTemplate;
	theLines : HugeStringArray;
	runDateTime : TimeStamp;
	operator : CM_Operator;
	camGroup : CM_CamGroup;
	operators : CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
	bs : CM_BlockStack;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	scheduleTimes : TimeArray;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
	emailEntity : CM_EmailEntity;
	field : CM_CamEditTriggerField;
	lRegisteredCargoTypes : IntegerArray;
	camProtocol : CM_CamProtocol;
	now : TimeStamp;
	startTS, endTS	:TimeStamp;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	product: CM_Product;
	line : String;
begin

	cargoType := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	product := cargoType.allProducts.last(); // Spud
	self.deleteAllCargo( CargoID, cargoType );	
	
	self.deleteCamProtocol (PROTOCOL1008);
	self.deleteTerminalArea (Garden);
	self.deleteCamGroup (CAMGROUP);
	
	create theLines transient;
	create operators transient;
	create freightForwarders transient;
	create trxColl transient;
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	
	now := app.actualTimeServer;
	
	operator := self.getOperator (OPERATOR);
	self.assertNotNullMsg (operator, OPERATOR &amp; ' operator not found');
	CM_Operator.instances.copy (operators);
	
	camGroup := self.addCamGroup (CAMGROUP, CAMGROUP, OPERATOR, null, null, null, false, false, false, operators, freightForwarders, 10, 'MSL');
	self.assertNotNullMsg (camGroup, 'Cam group not created'&amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	bs := self.addBlockStack (Garden, null, null);	
	self.assertTrueMsg( bs &lt;&gt; null, "No 'Garden' Block stack pre test" );
	
	desc 	:= CM_CamUserDefRepDesc.firstInstance;
	filter	:= desc.CM_CamUserDefRepDesc.allQFCamTransactionTemplates[FILTER];
	self.assertTrueMsg (filter &lt;&gt; null, FILTER &amp; ' - CAM Filter not created');
	
	trxColl.add (global.getTiTxnTypeForClass(CM_Edit).asStringJMT);
	
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	
	field := CM_CamUserDefRepDesc.firstInstance.allCamEditTriggerFields['Decimal', 'height'];		
	self.assertTrueMsg( field &lt;&gt; null, "height cam trigger not found");
	camEditTriggerFields.add (field);
		
	lRegisteredCargoTypes.add( cargoType.id );
	
	camProtocol := self.addCamProtocol(PROTOCOL1008, PROTOCOL1008, allCoarriExportPorts, camGroup, null, emailEntity, false, emailCopyAddresses, false, null, null,
	                                   now, now, false, PREFIX, "csv", null, packOperators, packExportConsignees, null, desc, trxColl,
									   false, 1, false, scheduleTimes, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false,  false, false, false, false, 
									   999999, 6, 100000, 0, '', null, JRWREPORT, camEditTriggerFields, camTrainEventTypes, filter, false, 0, self.getTerminal, false, false, false, false, false, false, false, true /* null voyage*/, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);

	self.assertTrueMsg(camProtocol &lt;&gt; null, 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	ti := self.addCargoAtLocation( CargoID, product, operator, bs.myLocationsController );
	beginTransaction;
		ti.setTotalQuantity(1);
		ti.setTotalWeightWithoutTrans(1800);
		ti.setImExStatus(TI_IMEX_STATUS_IMPORT);
	commitTransaction;
	
	process.sleep(1000);
	
	startTS := app.actualTimeServer;
	
	self.opts.purge();
	self.opts.addAssoc("CargoHeight", 2.35);
	self.updateTI(ti);
	
	endTS := app.actualTimeServer;
	
	self.runCamsAdhoc (startTS, endTS, runDateTime, camProtocol);
	
	self.assertTrueMsg(camProtocol.taskHistoryByProtocolSeq.last &lt;&gt; null, camProtocol.code &amp; ' No history');
	camProtocol.taskHistoryByProtocolSeq.last.rawDataToHSA( theLines );
	self.assertTrueMsg(theLines.size = 2, camProtocol.code &amp; ' incorrect number of lines of output');
	self.assertTrueMsg(theLines[2].pos( CargoID, 1) &gt; 1, ' Second line of output should include the cargo id.');
	self.assertTrueMsg(theLines[2].pos( "2.3500", 1) &gt; 1, ' Second line of output should also include the cargos height.');
	
epilog

	delete trxColl;
	delete operators;
	delete theLines;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete lRegisteredCargoTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="tSuzanoCamsConfirm" id="59ab4c81-53ae-4fe6-a520-a5e19874b3a7">
        <updating/>
        <source>tSuzanoCamsConfirm() updating;
//
// 15 Aug 2014	cnwrs1	Par 34561 - Suzano Cams
//
//19 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
constants
	CamGroup 		= "UTSUCON";
	CamProtocol 	= "UT_SUZCONFIRM_34561";
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
	RecipientCode 	= "UT_RECIPIENT";
	OperatorCode = "SUZ";
vars
	runDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camProtocolDesc :CM_CamProtocolDesc;
	operatorDict : CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
	operator : CM_Operator;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camTaskHistory : CM_CamTaskHistory;
	tempStr : String;
	registeredTransactions : StringArray;
	expectedOutput : String;
	actualOutput : String;
	actualXML : JadeXMLDocument;
	expectedXML : JadeXMLDocument;
	ignoreList : StringArray;
	theLines : HugeStringArray;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
begin
	create camEditTriggerFields transient;
	create theLines transient;
	startDateTime := app.actualTimeServer;
	self.tSuzanoRelease;//Prenote; //Receive a Prenote Viagem file
	
	create registeredTransactions transient;
	// create cam group and protocols
	camGroup := self.getCamGroup(CamGroup);
	if camGroup &lt;&gt; null then
		foreach camProtocol in camGroup.protocols do
			self.deleteCamProtocol(camProtocol.code);
		endforeach;
	endif;
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operator := app.myRoot.allOperators[OperatorCode];
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	self.deleteCamProtocol(CamProtocol);
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	
	camProtocolDesc := app.myRoot.allCamProtocolDescs["Suzano Confirm"];
	camProtocol	:= self.createCamProtocol(CamProtocol, camGroup, "NZCHC", operator.code, camProtocolDesc, false, false, false, registeredTransactions, null, null, camEditTriggerFields,null);	

	// RUNS CAMS
	//startDateTime := startDateTime.addMinutes(-1);
	//process.sleep(1000);
//	runDateTime := app.actualTimeServer;
//	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	self.runCamsNow(startDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		
		actualOutput := actualOutput &amp; tempStr;
	endforeach;
	expectedOutput := self.zOutput_SuzanoConfirmXML();
	create actualXML transient;
	create expectedXML transient;
	actualXML.parseString(actualOutput);
	expectedXML.parseString(expectedOutput);
	create ignoreList transient;
	ignoreList.add("ns0:ID");
	ignoreList.add("ns0:Data_Hora");
	self.zCompareXML(actualXML, expectedXML, ignoreList);
epilog
	delete actualXML;
	delete expectedXML;
	delete ignoreList;
	delete operatorDict;
	delete freightForwarders;
	delete registeredTransactions;
	delete theLines;
	delete camEditTriggerFields;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tSuzanoCamsDeliveryComm" id="2054c26e-854e-49c7-98b5-4a1ee5ce00e1">
        <updating/>
        <source>tSuzanoCamsDeliveryComm() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 23/03/2023	navdap1		Initial creation TFS 56796 PRP - Suzano EDI - Delivery Communication
// 03/03/2025	navpw1		JIRA: MTN-30307 - Modified Unit Test for new Delivery COmmunication changes and to validate cams message
//
constants
	CamGroup					: String = "UTSUZA";
	CamProtocol					: String = "SUZANO DELIVERY COMMUNICATION";
	CamProtocolDesc				: String = "Suzano Delivery Communication";
	OperatorSuza				: String = "SUZA";
	CargoTypePulp				: String = "MSP-2EP";
	SuzaVoyage					: String = "SUZAVOY-0001";
	SuzaVessel					: String = "SUZAVESS1";
	//UT_VesselDischLocn2			: String = "090488";
	//ShipReleaseRqId				: String = "SUZAREL-01";
	RailReleaseRqId				: String = "SUZAREL-02";
	//BargeReleaseRqId			: String = "SUZAREL-03";
	TruckReleaseRqId			: String = "SUZAREL-04";
	//UT_ISO_TYPE					: String = "2200";
	//UT_COMMODITY				: String = "GENL";
	UT_BLOCKSTACK 				: String = "SUZABS1";
	UT_CONTAINER1				: String = "SUZATi1";
	UT_CONTAINER2				: String = "SUZATi2";
	UT_CONTAINER3				: String = "SUZATi3";
	UT_CONTAINER4				: String = "SUZATi4";
	DRWorkPoint					: String = "DRWP";
	
	UT_RailAreaId				: String = "SUZA_RA";
	UT_WagonClass				: String = "BC";
	UT_TrainCode				: String = "SUZA_TC";
	UT_WagonCode				: String = "SUZA_W";
	
	UT_Vehicle					: String = "UTSUZA5567";
	UT_Driver					: String = "UTSUZA";
	UT_Carrier					: String = "UTSUZA";
	
vars
	terminalUTHelper			: UT_HelperAdmTerm;
	camGroup					: CM_CamGroup;
	protocol					: CM_CamProtocol;
	protocolDesc				: CM_CamProtocolDesc;
	voyage						: CM_Voyage;
	vessel						: CM_Vessel;
	truckReleaseRequest,
	//bargeReleaseRequest,
	railReleaseRequest			: CM_BulkRelease;
	//releaseRequest			: CM_BulkRelease;
	cargoType					: CM_CargoType;
	operatorDict				: CM_OperatorByCodeDict;
	freightForwarders			: CM_ConsigneeConsignorSet;
	operator					: CM_Operator;
	terminal					: CM_Terminal;
	eventTypes					: CM_EventTypeByNameDict;
	cargoTypes					: IntegerArray;
	transactions				: StringArray;
	editTriggerFields			: CM_CamEditTriggerFieldDict;
	blockStack					: CM_BlockStack;
	ti1,
	ti2,
	ti3,
	ti4							: CM_TrackedItem;
	vesselLocations				: StringArray;
	startDateTime				: TimeStamp;
	camTaskHistory				: CM_CamTaskHistory;
	dischargePort				: CM_Port;
	txns						: CM_TransactionSet;
	allocatedWLEs				: CM_WLEArray;
	tmpVWle						: CM_VoyageWLE;
	workPoint					: CM_WorkPoint;
	
	//Train
	wagonMaster					: CM_WagonMaster;
	train						: CM_Train;
	railArea					: CM_Rail;
	railIORake					: CM_RailJSInOutRake;
	wagonClass					: CM_WagonClass;
	wagon						: CM_Wagon;
	railLine					: CM_RailLine;
	allRailJobsOutstandingArray	: CM_RailJobArray;
	railJob						: CM_RailJob;
	
	//Truck
	driver						: CM_DriverDetails;
	vehicle						: CM_Vehicle;
	carrier						: CM_Carrier;
	vvr							: CM_VehicleVisitRecord;
	allCarriers					: CM_CarrierByCodeDict;
	allVehicleMachines			: CM_VehicleSet;
	yic							: CM_YardInterchangeArea;
	dualGate					: CM_Gate;
	roadJob						: CM_RoadJob;
	gatePIn						: CM_GateArea;
	wle							: CM_WorkListEntry;
	wleArr						: CM_WLEArray;
	request						: CM_Request;
	
	//Other Variables
	taskOutputLines				: HugeStringArray;
	fileIndex					: Integer;
	startTs,
	finishTs					: TimeStamp;
	
begin
	terminal := self.getMyTerminal();
	self.setTerminalConfig(AutoPlanEnabled,false);
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_EDICAMS::tSuzanoCamsDeliveryComm;
	
	startDateTime	:= app.actualTimeServer;
	dischargePort	:= app.myRoot.allPorts["NZAKL"];
	workPoint		:= self.getWorkpoint(DRWorkPoint);
	
	// check cargo type, operator, cam protocol description exist up front
	cargoType := app.myRoot.getCargoTypeFromAbbrev(CargoTypePulp);
	self.assertNotNullMsg(cargoType, "Cargo type " &amp; CargoTypePulp &amp; " not found");
	
	operator := app.myRoot.allOperators[OperatorSuza];
	self.assertNotNullMsg(operator, "Operator " &amp; OperatorSuza &amp; " not found");
	
	protocolDesc := app.myRoot.allCamProtocolDescs[CamProtocolDesc];
	self.assertNotNullMsg(protocolDesc, "Cam Protocol Description " &amp; CamProtocolDesc &amp; " not found");
	
	// delete / create cam group for SUZANO operator
	camGroup := self.getCamGroup(CamGroup);
	if camGroup &lt;&gt; null then
		foreach protocol in camGroup.protocols do
			self.deleteCamProtocol(protocol.code);
		endforeach;
	endif;
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, OperatorSuza, terminal.code, null, null, false, false, false, operatorDict, freightForwarders, 16, OperatorSuza);
	self.assertNotNullMsg(camGroup, "Cam Group " &amp; CamGroup &amp; " not created");
	
	// delete create cam protocol
	self.deleteCamProtocol(CamProtocol);
	protocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeletedMsg(protocol, "CAM Protocol " &amp; CamProtocolDesc &amp; " not deleted");
	
	create eventTypes transient;
	eventTypes.add(app.myRoot.allEventTypesByType[EVT_TrainDepart]);
	eventTypes.add(app.myRoot.allEventTypesByType[EVT_TruckDeparture]);
	//eventTypes.add(app.myRoot.allEventTypesByType[EVT_VoyageDeparture]);
	create cargoTypes transient;
	cargoTypes.add(cargoType.id);
	create transactions transient;		//Should be handled in createCamProtocol and deal with nulls
	create editTriggerFields transient;	//Should be handled in createCamProtocol and deal with nulls
	protocol := self.createCamProtocol(CamProtocol, camGroup, "IDBTH", operator.code, protocolDesc, false, true, false, transactions, cargoTypes, eventTypes, editTriggerFields, null);	
	
	beginTransaction;
	protocol.setLogExcludedTransactions(true);
	protocol.setLogIncludedTransactions(true);
	commitTransaction;
	
	// create a voyage and a ship release
	self.deleteVoyage(SuzaVoyage);
	voyage := self.getVoyage(SuzaVoyage);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(SuzaVessel);
	vessel := self.getVessel(SuzaVessel);
	self.assertIsDeleted(vessel);
	
	vessel := self.addVesselCellular(SuzaVessel, operator);
	self.assertNotNullMsg(vessel, "Vessel is null");
	
	//voyage := self.addVoyageWithContainerStructur(SuzaVoyage, SuzaVessel, operator.code,  self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	voyage := self.addVoyageWithGeneralCargoStruc(SuzaVoyage, SuzaVessel, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNullMsg(voyage, "Voyage is null");
	
	/*
	** Create Ship Release
	*/
	/*self.deleteReleaseRequest(ShipReleaseRqId);
	releaseRequest := self.getReleaseRequest(ShipReleaseRqId);
	self.assertIsDeleted(releaseRequest);
	
	self.opts.purge();
	self.opts.addAssoc(UT_OPTS_Number, 50.Integer);
	self.opts.addAssoc(UT_OPTS_DischargePort, dischargePort);
	self.opts.addAssoc(UT_OPTS_FullRelease, true);
	self.opts.addAssoc(UT_OPTS_Operator, operator);
	self.opts.addAssoc(UT_OPTS_Voyage, voyage);
	releaseRequest := self.addReleaseByTypeRequestOpts(ShipReleaseRqId, BR_TYPE_SHIP, cargoType.id);
	self.assertTrueMsg(releaseRequest &lt;&gt; null, "Failed to set up Ship Release");
	*/
	
	/*
	** Create Rail Release
	*/
	self.deleteReleaseRequest(RailReleaseRqId);
	railReleaseRequest := self.getReleaseRequest(RailReleaseRqId);
	self.assertIsDeleted(railReleaseRequest);
	
	self.opts.purge();
	self.opts.addAssoc(UT_OPTS_Number, 50);
	self.opts.addAssoc(UT_OPTS_DischargePort, dischargePort);
	self.opts.addAssoc(UT_OPTS_FullRelease, true);
	self.opts.addAssoc(UT_OPTS_Operator, operator);
	self.opts.addAssoc(UT_OPTS_Voyage, voyage);
	railReleaseRequest := self.addReleaseByTypeRequestOpts(RailReleaseRqId, BR_TYPE_RAIL, cargoType.id);
	self.assertTrueMsg(railReleaseRequest &lt;&gt; null, "Failed to set up Rail Release");
	
	/*
	** Create Barge Ship Release
	*/
	/*self.deleteReleaseRequest(BargeReleaseRqId);
	bargeReleaseRequest := self.getReleaseRequest(BargeReleaseRqId);
	self.assertIsDeleted(bargeReleaseRequest);
	
	self.opts.purge();
	self.opts.addAssoc(UT_OPTS_ISOType, UT_ISO_TYPE);
	self.opts.addAssoc(UT_OPTS_Number, 6.Integer);
	bargeReleaseRequest := self.addReleaseByTypeRequestOpts(BargeReleaseRqId, BR_TYPE_SHIP, TI_CargoType_Container);
	self.assertTrueMsg(bargeReleaseRequest &lt;&gt; null, "Failed to set up Barge Release");
	*/
	
	/*
	** Create Truck Release
	*/
	self.deleteReleaseRequest(TruckReleaseRqId);
	truckReleaseRequest := self.getReleaseRequest(TruckReleaseRqId);
	self.assertIsDeleted(truckReleaseRequest);
	
	self.opts.purge();
	self.opts.addAssoc(UT_OPTS_Number, 150);
	self.opts.addAssoc(UT_OPTS_DischargePort, dischargePort);
	self.opts.addAssoc(UT_OPTS_FullRelease, true);
	self.opts.addAssoc(UT_OPTS_Operator, operator);
	self.opts.addAssoc(UT_OPTS_Voyage, voyage);
	truckReleaseRequest := self.addReleaseByTypeRequestOpts(TruckReleaseRqId, BR_TYPE_ROAD, cargoType.id);
	self.assertTrueMsg(truckReleaseRequest &lt;&gt; null, "Failed to set up Truck Release");
	
	/*
	** Create Blockstack
	*/
	blockStack := self.getTerminalArea(UT_BLOCKSTACK).CM_BlockStack;
	self.deleteTerminalArea(UT_BLOCKSTACK);
	self.assertIsDeleted(blockStack);
	
	blockStack := self.addBlockStack(UT_BLOCKSTACK, 10, null);
	
	/*
	** Create Cargo OnSite
	*/
	self.logMessage(app.logTimeStamp(app.actualTimeServer, 1, "Creating Tracked items"));
	ti1 := self.addCargoBreakBulkAtLocation(UT_CONTAINER1, cargoType, 50, blockStack.myLocationsController, dischargePort.code, TI_IMEX_STATUS_EXPORT, voyage, vessel.myOperator);
	ti2 := self.addCargoBreakBulkAtLocation(UT_CONTAINER2, cargoType, 50, blockStack.myLocationsController, dischargePort.code, TI_IMEX_STATUS_EXPORT, voyage, vessel.myOperator);
	
	/*
	** Assign cargo to the rail release, move the cargo to the train
	*/
	//Delete wagon master
	terminalUTHelper.xDeleteWagonMasterByCode(UT_WagonCode);
	
	//Delete train
	terminalUTHelper.xDeleteTrainByCode(UT_TrainCode, terminal);
	
	//Delete rail area
	terminalUTHelper.xDeleteRailAreaByCode(UT_RailAreaId, terminal);
	
	//Create train
	train := terminalUTHelper.xCreateTrain(UT_TrainCode, terminal);
	
	//Create rail area
	railArea := terminalUTHelper.xCreateRailArea(UT_RailAreaId, 4, 5, terminal);
	
	//Find rail io rake
	railIORake := terminalUTHelper.xGetRailIoRake(railArea);
	
	//Get the wagon class
	wagonClass := self.getRoot.allWagonClasses[UT_WagonClass];
	self.assertNotNullMsg(wagonClass, "wagonClass");
	
	//Create wagon master
	wagonMaster := terminalUTHelper.xCreateWagonMaster(UT_WagonCode, wagonClass);
	
	//Create wagon
	wagon := terminalUTHelper.xCreateWagon(UT_WagonCode, wagonClass.code, train, terminal);
	
	railLine := railArea.allRailLinesByIndex.first; 
	self.assertNotNullMsg(railLine, "railLine");
	
	self.deleteStops(ti2);
	
	// assign release to outwards rail area
	terminalUTHelper.xAssignReleasesToOutwardRail(railReleaseRequest, railIORake);
	
	//Arrive the train
	terminalUTHelper.xArriveTrain(train);
	
	//Rail line switch positions
	railLine.switchPositions(wagon, 01);
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Switch Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	self.assertNoTrxErrorsOrWarnings();
	
	//Confirm inwards all the inwards wagons on the train
	terminalUTHelper.xConfirmTrainIn(train);
	
	create allRailJobsOutstandingArray transient;
	foreach railJob in railIORake.railJobs do 
		allRailJobsOutstandingArray.add(railJob);
	endforeach;
	
	railJob := allRailJobsOutstandingArray.first;
	terminalUTHelper.xAssignReleasesToWagons(railIORake, railJob, wagon);
	allRailJobsOutstandingArray.remove(railJob);
	
	// Queue the WLE for the rail job
	terminalUTHelper.rail_RailJobWLEsDoMove(railJob, ti2); //Can get wle's from railJob
	
	self.assertTrueMsg(ti2.myPrimaryQueuedLocation &lt;&gt; null, "container did not queue");
	
	//Move wle for the rail job
	//Move the WLE to the Wagon
	terminalUTHelper.rail_MoveWLEWithNoAssert(railJob);
	
	// Confirm train out
	terminalUTHelper.rail_ConfirmTrainOut(train);
	
	// clear the entire train.
	terminalUTHelper.rail_ClearRake(train, wagon, false);
	
	//Depart Train
	terminalUTHelper.rail_TrainDeparture(train);
	
	/*
	** Assign cargo to the road release, move the cargo to the truck
	*/
	yic := self.getTerminalArea(self.getProfileSetting(UT_Profile.P_YIC).asString).CM_YardInterchangeArea;
	dualGate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	gatePIn := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_PIN).asString);
	
	self.logMessage(app.logTimeStamp(app.actualTimeServer, 1, "Creating Tracked items"));
	ti3 := self.addCargoBreakBulkAtLocation(UT_CONTAINER3, cargoType, 50, blockStack.myLocationsController, dischargePort.code, TI_IMEX_STATUS_EXPORT, voyage, vessel.myOperator);
	ti4 := self.addCargoBreakBulkAtLocation(UT_CONTAINER4, cargoType, 50, blockStack.myLocationsController, dischargePort.code, TI_IMEX_STATUS_EXPORT, voyage, vessel.myOperator);
	
	//Delete Carrier
	terminalUTHelper.xDeleteCarrier(UT_Carrier);
	
	//Delete Vehicle
	terminalUTHelper.xDeleteVehicleByReg(UT_Vehicle, terminal);
	
	//Delete Driver
	terminalUTHelper.xDeleteDriverDetails(UT_Driver, terminal);
	
	//Create Driver
	create allCarriers transient;
	create allVehicleMachines transient;
	driver := terminalUTHelper.xCreateDriverDetails(UT_Driver, terminal, allCarriers, allVehicleMachines);
	
	//Create Carrier
	carrier := terminalUTHelper.xCreateCarrier(UT_Carrier, UT_Carrier, null, false, true, true, null);
	
	//Create Vehicle
	vehicle := terminalUTHelper.xCreateVehicle(UT_Vehicle, carrier, terminal);
	
	//Create Vehicle Visit Record
	terminalUTHelper.opts.purge();
	terminalUTHelper.opts.addAssoc(UT_OPTS_YardInterchangeArea, yic.id);
	vvr := terminalUTHelper.xCreateVehicleVisitRecord(UT_Vehicle, UT_Driver, UT_Driver, null, terminal, dualGate.name);
	self.assertNotNullMsg(vvr, "vvr");
	
	//Gate Out cargo
	vvr := terminalUTHelper.xCreateGateEntityOutRelease(vvr, null, null, 50, truckReleaseRequest);
	vvr := terminalUTHelper.xCreateGateEntityOutRelease(vvr, null, null, 50, truckReleaseRequest);
	
	//Asserting
	self.assertEqualMsg(vvr.vehicle.allRoadJobs.size, 1, "Expected 1 road job");
	
	self.moveVehicleToLane(vvr.vehicle, gatePIn, 1);
	self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(gatePIn, 1));
	
	terminalUTHelper.xMoveVehicleToYard(vvr.vehicle);
	
	create wleArr transient;
	
	roadJob := vvr.vehicle.allRoadJobs.first.CM_RoadJob;
	roadJob.getAllWLEs(wleArr);
	request := wleArr.first.myRequest;
	
	self.assertEqualMsg(wleArr.size, 2, "Expected '" &amp; 2.String &amp; "' work list entries associated to the road job");
	self.assertTrueMsg(request.isKindOf(CM_DeliveryRequest), "Expected the Work List Entry Request to be the same kind as CM_DeliveryRequest");
	
	self.assignTiToRoadWLE(ti3, wleArr[1]);
	self.assignTiToRoadWLE(ti4, wleArr[2]);
	
	foreach wle in wleArr do
		self.assertEqualMsg(wle.status, JOB_COMPLETE, "Expected Work List Entry to be Unactioned");
		self.assertNotNullMsg(wle.myTrackedItem, "Work List Entry Tracked Item");
	endforeach;
	
	terminalUTHelper.opts.purge();
	terminalUTHelper.opts.addAssoc(UT_OPTS_YardInterchangeArea, yic.id);
	
	//self.workVehicle(vvr);
	self.assertNotNullMsg(ti3.getPrimaryLocation(REAL_MODE), "ti3 Primary Location");
	self.assertTrueMsg(ti3.getPrimaryLocation(REAL_MODE).isKindOf(CM_VehicleController), "Expecting ti3's primary location to be a CM_VehicleController. Actual: '" &amp; ti3.getPrimaryLocation(REAL_MODE).class.name &amp; "'");
	self.assertNotNullMsg(ti4.getPrimaryLocation(REAL_MODE), "ti4 Primary Location");
	self.assertTrueMsg(ti4.getPrimaryLocation(REAL_MODE).isKindOf(CM_VehicleController), "Expecting ti4's primary location to be a CM_VehicleController. Actual: '" &amp; ti4.getPrimaryLocation(REAL_MODE).class.name &amp; "'");
	self.assertTrue(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation);
	
	self.roadExit(vvr);
	self.assertNull(vvr.myRoadJob);
	self.assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Complete);
	self.assertNull(vvr.vehicle.myPrimaryActualLocation);
	
	// run cam protocol
	self.runCamsNow(startDateTime, protocol);
	camTaskHistory := protocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	// check output - should have one cam message containing all the released cargo
	create taskOutputLines transient;
	
	startTs := app.actualTimeAppServer;
	fileIndex := 1;
	foreach camTaskHistory in protocol.taskHistoryByProtocolSeq do
		taskOutputLines.clear();
		app.writeLog(camTaskHistory.getRawDataString(), LogTRACE);
		camTaskHistory.rawDataToHSA(taskOutputLines);
		
		if taskOutputLines.isEmpty then
			continue;
		endif;
		
		self.zCheckSuzanoCamsDelMsgValid(fileIndex, taskOutputLines, terminal, protocol, startDateTime);
		fileIndex += 1;
		
	endforeach;
	finishTs := app.actualTimeAppServer;
	
	self.logMessagePw("Processing Start Time of Check Method: " &amp; startTs.asStringJMT(), LogDEBUG);
	self.logMessagePw("Processing Finish Time of Check Method: " &amp; finishTs.asStringJMT(), LogDEBUG);
	self.logMessagePw("Processing Time of Check Method: " &amp; (finishTs-startTs).getMilliseconds().String &amp; " milliseconds", LogDEBUG);
	
epilog
	delete terminalUTHelper;
	delete operatorDict;
	delete freightForwarders;
	delete eventTypes;
	delete cargoTypes;
	delete transactions;
	delete editTriggerFields;
	delete vesselLocations;
	delete txns;
	delete allocatedWLEs;
	delete tmpVWle;
	delete allRailJobsOutstandingArray;
	
	delete allCarriers;
	delete allVehicleMachines;
	
	delete wleArr;
	delete taskOutputLines;
	//delete conflictManager;
	//delete pxyVoyage;

end;</source>
    </JadeMethod>
    <JadeMethod name="tSuzanoCamsReceive" id="6c1ef271-eb69-466f-a206-449931cde65c">
        <updating/>
        <source>tSuzanoCamsReceive() updating;
//
// 15 Aug 2014	cnwrs1	Par 34561 - Suzano Cams
//
//19 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
//20 Apr 2016	cnwrs1	Par 37788 TFS Came 1875 Events does not check cam group operators nor cargotype list
constants
	CamGroup 		= "UTSUREC";
	CamProtocol 	= "UT_SUZRECEIVE_34561";
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
	RecipientCode 	= "UT_RECIPIENT";
	OperatorCode 	= "SUZ";
	VoyageName 		= 'VYPAR34561';				// all upper case!
	BoatName 		= 'VSPAR34561';
	BsName			= 'UT_34561BS';
	BulkName1		= 'I111111111';
	BulkName2		= 'I111111112';
	BulkName3		= 'I111111113';
vars
	runDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camProtocolDesc :CM_CamProtocolDesc;
	operatorDict : CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
	operator : CM_Operator;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camTaskHistory : CM_CamTaskHistory;
//	str : String;
	registeredTransactions : StringArray;
	registeredEvents : CM_EventTypeByNameDict;
	registeredCargoTypes : IntegerArray;
	strArray : HugeStringArray;
	voyage : CM_Voyage;
	tempStr : String;
	transObj : CM_Transaction;
	vessel : CM_Vessel;
    voyageBS : CM_LocationsController;
    height : Integer;
	strs : StringArray;
	bulk1 : CM_Cargo;
	bulk2 : CM_Cargo;
	bulk3 : CM_Cargo;
	bulk4 : CM_Cargo;
	cargoType : CM_CargoType;
	terminal : CM_Terminal;
	yardStack : CM_BlockStack;
	stack : CM_TerminalArea;
	et : CM_EventTransaction;
	actualXMLStr : String;
	actualXML : JadeXMLDocument;
	expectedXMLStr : String;
	expectedXML : JadeXMLDocument;
	ignoreList : StringArray;
	theLines : HugeStringArray;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	cmifEventCtrl : CMIF_VoyageEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
begin
	create camEditTriggerFields transient;
	create theLines transient;
	startDateTime := app.actualTimeServer;
	operator := app.myRoot.allOperators[OperatorCode];
	terminal := self.getTerminal();
	
	// Delete required Voyages, Vessels, Cargo and Yard Areas
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);

	self.deleteTerminalArea(BsName);
	stack := self.getTerminalArea(BsName);
	self.assertIsDeleted(stack);
	
	
	// Now create the required Voyages, Vessels, Cargo and Yard Areas
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName,
													BoatName,
													OperatorCode, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName &amp; ' failed');
	
	yardStack := self.addBlockStack( BsName, 1000, null);
	self.assertNotNullMsg(yardStack, 'Add blockstack ' &amp; BsName &amp; ' failed');

	// Add the BBLK  to the voyage
	create strs transient;
    voyage.findLocation(strs, false, voyageBS, height);
	
	cargoType := self.getCargoType("UTREBAR");
    // Add a few Items to the voyage (Would normally be Pulp Bales)
    bulk1  := self.addCargoBreakBulkAtLocation( BulkName1, cargoType, 1, voyageBS, null, TI_IMEX_STATUS_IMPORT, voyage, operator );
	bulk2  := self.addCargoBreakBulkAtLocation( BulkName2, cargoType, 1, voyageBS, null, TI_IMEX_STATUS_IMPORT, voyage, operator );
	bulk3  := self.addCargoBreakBulkAtLocation( BulkName3, cargoType, 1, voyageBS, null, TI_IMEX_STATUS_IMPORT, voyage, operator );
	beginTransaction;
		bulk1.setInvoiceNumber("0090000000");
		bulk1.setPropertyValue(CM_TrackedItem::alternativeId.name, BulkName1);
		bulk2.setPropertyValue(CM_TrackedItem::alternativeId.name, BulkName2);
		bulk3.setPropertyValue(CM_TrackedItem::alternativeId.name, BulkName3);
	commitTransaction;
	//Move some of the cargo to the Yard
	self.move(bulk1, yardStack);
	self.move(bulk2, yardStack);

	// Create a Voyage departure Event
	beginTransaction;
	/*
    et := app.createEvent(EVT_VoyageDeparture, app.actualTimeServer, self.getTerminal(), app.myPassport.userCode, false, false, 1.0).CMEVT_VoyageEvent;
    et.CMEVT_VoyageEvent.setMyVoyage(voyage);
	*/
	
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
	create cmifEventCtrl transient;
	cmifEventCtrl.type := EVT_VoyageDeparture;
	cmifEventCtrl.dateTime := app.actualTimeServer();
	cmifEventCtrl.myTerminal := self.getTerminal();
	cmifEventCtrl.userCode := app.myPassport.userCode;
	cmifEventCtrl.myVoyage := voyage;
	cmifEventCtrl.amount := 1.0;
	
	et := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_VoyageEvent;
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
    commitTransaction;


	
	// Delete CAMs Groups and Protocol
	camGroup := self.getCamGroup(CamGroup);
	if camGroup &lt;&gt; null then
		foreach camProtocol in camGroup.protocols do
			self.deleteCamProtocol(camProtocol.code);
		endforeach;
	endif;
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	self.deleteCamProtocol(CamProtocol);
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	
	//Create CAMs Group and Protocol
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	create registeredCargoTypes transient;
	registeredCargoTypes.add(cargoType.id);
	create registeredTransactions transient;
	create registeredEvents transient;
	registeredEvents.add (app.myRoot.allEventTypesByType [EVT_VoyageDeparture]);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["Suzano Receive"];
	camProtocol	:= self.createCamProtocol(CamProtocol, camGroup, "NZCHC", operator.code, camProtocolDesc, false, true, false, registeredTransactions, registeredCargoTypes, registeredEvents, camEditTriggerFields,null);	

	// Run CAMS 
	//startDateTime := startDateTime.addMinutes(-1);
//	runDateTime := app.actualTimeServer;
//	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	self.runCamsNow(startDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	

	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		actualXMLStr := actualXMLStr &amp; tempStr;
	endforeach;
	
	// Check Output from CAMS with expected
	create actualXML transient;
	create expectedXML transient;
	expectedXMLStr := self.zOutput_SuzanoReceiveXML();
	expectedXML.parseString(expectedXMLStr);
	actualXML.parseString(actualXMLStr);

	create ignoreList transient;
	ignoreList.add("rec:ID");
	ignoreList.add("rec:Movement_Date");
	self.zCompareXML(actualXML, expectedXML, ignoreList);
epilog
	delete strArray;
	delete strs;
	delete operatorDict;
	delete freightForwarders;
	delete registeredTransactions;
	delete registeredCargoTypes;
	delete registeredEvents;
	delete ignoreList;
	delete expectedXML;
	delete actualXML;
	delete theLines;
	delete camEditTriggerFields;
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;
</source>
    </JadeMethod>
    <JadeMethod name="tSuzanoCamsReceiveTruck" id="6d6770f2-80a3-4be0-adec-a473f309a2ad">
        <updating/>
        <source>tSuzanoCamsReceiveTruck() updating;
//
//31 Aug 2015	cnwrs1	 CCMS 2405 - Suzano Receive by Truck 
//
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
// 10 Sep 2019	cnwrs1	TFS 46030
constants
	USER_DEF_NAME : String = "JMTInternalPrenote";
	Cargo_Type = "COILS";
	Cargo_Subtype = "GVS";
	VoyageName		= 'UT_VOY4AST';				
	BoatName		= 'UT_VES4AST';
	PortName		= "NZAKL";
	CargoID1	= 'COIL240501';
	CargoID2	= 'COIL240502';
	CargoID3	= 'COIL240503';
	CargoID4	= 'COIL240504';
	CargoID5	= 'COIL240505';
	BlockStackName	= 'BS26728';
	CamGroup 		= "UTSUTRU";
	CamProtocol 	= "UT_SUZRECTRUCK";
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
	RecipientCode 	= "UT_RECIPIENT";
	OperatorCode = "UTOP";
	Bookin = "Book2405";
//	TrainCode = "UT-TRAIN03";
//	WagonCode = "UK35564";
