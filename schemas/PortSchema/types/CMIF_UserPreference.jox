<Class name="CMIF_UserPreference" id="b1432fc5-e807-4ef2-b600-647fe5f7f54c">
    <superclass name="CMIF_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <PrimAttribute name="ackTodoStop" id="39cee085-e64a-42a4-9f4e-067ff427782f">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="appSkin" id="b9bdeb9e-86d1-4f2c-aa0b-a324aee78dac">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="helpFileBaseURL" id="7b1147ea-3d63-4c86-8b78-27c459198bd7">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="helpFileFormat" id="d9e9699f-3382-434f-bbea-bd10d414f54a">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="isUsePartialTxt" id="c240f34a-30b6-4b53-b2bc-841792ebacd8">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myLocale" id="21a2232b-7731-4b4d-b249-4ba3d318e148">
        <embedded/>
        <type name="CM_Locale"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myUser" id="d54c8710-5abc-42e7-b0e3-46029793b6d4">
        <embedded/>
        <type name="CM_User"/>
    </ImplicitInverseRef>
    <PrimAttribute name="ssoRememberSession" id="64f3f217-d15b-4305-9346-b79eff9079bd">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="userEdition" id="033b3d2a-792e-4720-af6b-dad699ca933d">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="setFromUser" id="0b57bef7-ae99-40d5-b52c-ffc73783312b">
        <updating/>
        <source>setFromUser(_user : CM_User) updating;
// ---------------------------------------------------------------------------
// Created:     18 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
26 May 2014	cnwkpd1	PAR #34210 - CCMS SFW 1350 - Online Documentation
	
*/

begin
	beginLoad;
	sharedLock(_user);		// lock to ensure get latest edition
	
	self.ssoRememberSession :=  _user.getRememberSSOSession(); //21.09.2022 navam1, #54866
	self.ackTodoStop		:=	_user.getAcknowledgeTodoStop();
	self.appSkin			:=	_user.getUseAppSkinName();
	self.isUsePartialTxt	:=	_user.getPartialTextIndication();
	self.myLocale			:=	_user.getLocale();
	self.helpFileBaseURL	:=	_user.getHelpFileBaseURL();		// PAR #34210
	self.helpFileFormat		:=	_user.getHelpFileFormat();
	
	self.userEdition		:=	_user.edition;
	self.myUser				:=	_user;
epilog
	endLoad;		// unlock the user
end;</source>
        <Parameter name="_user" type="CM_User"/>
    </JadeMethod>
</Class>
