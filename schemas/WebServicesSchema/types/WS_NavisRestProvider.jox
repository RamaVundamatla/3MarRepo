<Class name="WS_NavisRestProvider" id="485e0020-4573-4e27-91da-c8e71a95bc0c">
    <superclass name="WS_RestWebServiceProvider"/>
    <transient/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>Parent WS Class for all Navis APIs (e.g. as used by native apps),
including the NavisSmartData API provided by Master Terminal. 
</text>
    <DbClassMap file="webservice"/>
    <JadeMethod name="initTerminal" id="ebe31aa5-c6dd-4821-8006-84688ec726ec">
        <updating/>
        <source>initTerminal(user: CM_User): CM_Terminal updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2020	jlgrr1	Initial creation

*/

vars
	terminal : CM_Terminal;
begin
	// Navis REST APIs do not use a Terminal Cookie 
	// Terminal will get set as needed with method calls
	// Set to the first one by default so we don't have issues with no terminal set
	if not user.allUserTerminals.isEmpty then
		terminal := user.allUserTerminals.first.myTerminal;
	endif;
	
	return terminal;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="user" type="CM_User"/>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="preProcessRequest" id="be90ed13-f822-4c57-b6ec-61883fa19d65">
        <source>preProcessRequest(httpIn : String io; queryStr, pathIn, methodType, contentType : String) : String protected;
/*

Purpose:			Pre-Process Request - Used to do anything that needs to be done before we process a request on our web api

Parameters:			httpIn		String	The body of the request we want to process
					queryStr	String	The query string supplied with the request
					pathIn		String	The path used for the request
					methodType	String	The method type of the request
					contentType	String	The content type of the request

Return Value:		NONE

Date		Who		Reason
08 Mar 2023	navpw1	Initial creation TFS: 56988 (57003)
15 Jan 2026	navdap1	MTN-36569 CPL | Reefer Runner Integration
*/

begin
	// wrap any recognisable JSON on a "content" definition if it hasn't got a wrapper name already
	// - the putReefers API only sends data in an array container, without naming the array in the JSON
	if contentType = "application/json" then
		if httpIn[1:1] &lt;&gt; "{" then
			httpIn := '{"content":' &amp; httpIn &amp; '}';
		endif;
	endif;
	
	return pathIn;		// MTN-36569
end;</source>
        <access>protected</access>
        <Parameter name="httpIn" type="String" usage="io"/>
        <Parameter name="queryStr" type="String"/>
        <Parameter name="pathIn" type="String"/>
        <Parameter name="methodType" type="String"/>
        <Parameter name="contentType" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="saveUserState" id="7c93a40d-41f5-48dc-bbdc-179c77183bd1">
        <updating/>
        <source>saveUserState(user: CM_User; terminal: CM_Terminal) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2020	jlgrr1	Initial creation

*/

vars

begin
	// Navis REST APIs do not use User State at all
	// Nothing to do
	return;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="user" type="CM_User"/>
        <Parameter name="terminal" type="CM_Terminal"/>
    </JadeMethod>
</Class>
