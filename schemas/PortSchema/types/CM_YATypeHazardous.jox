    <JadeMethod name="getAllCriteriaValues" id="a7c92e13-79b9-487c-a0a4-f7586755204b">
        <source>getAllCriteriaValues(_terminalObj:CM_Terminal; _allCriteriaValues: ObjectSet input; _filter : Integer; _allDependentObjs : CM_ObjectArray);
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//17 September 2013	cnwmc5	PAR 31255 - allowing dependent objects the criteria is based on.
// --------------------------------------------------------------------------------
begin
	app.myRoot.allHazardClasses.copy(_allCriteriaValues);
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getAllHazardValues" id="4b7efb8e-3b73-41b2-bd0a-cc8ec5eac28d">
        <source>getAllHazardValues(_terminalObj:CM_Terminal; _allCriteriaValues: StringArray input; _filter : Integer);
//23 July 2010	cnwml2
//+cnwml2 PAR24472

vars
	hazard : CM_HazardClass;
	str : String;
begin
	foreach hazard in app.myRoot.allHazardClasses do
		str := hazard.code &amp; " - " &amp; hazard.description;
		_allCriteriaValues.add(str);
		str := hazard.code &amp; "L - " &amp; hazard.description;
		_allCriteriaValues.add(str);
	endforeach;
epilog

end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="StringArray" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllYAIdentifiers" id="e0c06981-2fce-45c4-a019-0a54e6c0baf5">
        <source>getAllYAIdentifiers(_yaIdentifiers: StringArray input) : Boolean;

/*

Purpose:		Return a list of the Hazards with and without a Limited postfix

Parameters:			

Return Value:		

17 September 2013	cnwmc5	PAR 31255 - allowing dependent objects the criteria is based on.
*/

vars
	criteriaColl 	: ObjectSet;
	obj: Object;
	name: String;
begin
	_yaIdentifiers.clear;
	create criteriaColl transient;
	self.getAllCriteriaValues(null, criteriaColl, YAFilterOpt_None, null);
	foreach obj in criteriaColl do
		name := self.getDisplay(obj).toUpper();
		_yaIdentifiers.add(name);
		_yaIdentifiers.add(name&amp;"L");
	endforeach;

	return true;
epilog
	delete criteriaColl;
end;</source>
        <Parameter name="_yaIdentifiers" type="StringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
