    <JadeMethod name="createPxyEmailTemplate" id="b73e4c12-1923-4a8d-b0b4-3a0b77365049">
        <updating/>
        <source>createPxyEmailTemplate() : CM_EmailTemplate updating;
/*
Purpose:	

Date		Who		Reason
17 July 2024	navab1	CR 64614 TASK 64643
*/

vars

	pxyEmailTemplate : CM_EmailTemplate;

begin
	create pxyEmailTemplate transient;
	pxyEmailTemplate.setMyParent(self);
	pxyEmailTemplate.setProxy(null,null,null,null,null,null, null,"Auto Comparison",null,false);
	return pxyEmailTemplate;


epilog

end;</source>
        <ReturnType type="CM_EmailTemplate"/>
    </JadeMethod>
