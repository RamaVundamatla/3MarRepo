    <JadeMethod name="mpdServerTest" id="42eba855-c84b-497e-93d9-d8c9bfd598f5">
        <executionLocation>server</executionLocation>
        <source>mpdServerTest() serverExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 January 2024		navmd1	Initial creation

*/

vars
	jwks : String;
begin
	app.initialize();
	
	jwks := JadeJsonWebKeySetReader@getJWKSFromURL("https://login.microsoftonline.com/common/discovery/v2.0/keys");
