    <JadeMethod name="displayEntry" id="591f1100-a790-4323-b6cd-407ac4a93d54">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; obj: CM_TIMaster; lstIndex: Integer): String updating, clientExecution;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 22 May 2007
//
//----------------------------------------------------------------------

vars
	ti : CM_TrackedItem;
	display : String;
	include : Boolean;
	
begin

	if obj = null then
		return null;
	endif;
	
	if not  obj.isKindOf(CM_TIMasterTILC) then
	//not masterTILC - cnwrd1 1.9.2008 currently using wrong collection -root.alltimasters.
		return null;
	endif;
	
	//DON'T CARE WHERE OR WHETHER WE HAVE A MATCHING CARGO ITEM OR NOT. JUST DISPLAY ME.
	if self.includeAll then
		return obj.CM_TIMaster.id;
	endif;
	
	include := false;
	if self.myTerminal &lt;&gt; null then
		//ti := obj.getCurrentTIForTerminal(self.myTerminal);
		ti := obj.getCurrentTi();
		if ti &lt;&gt; null then
			if self.includeForDisplay(ti) then
				include := true;
			endif;
		else
			if self.includeOffsite then
				include := true;
			endif;
		endif;
	else
		if not self.includeOnsite then
			include := true;
		endif;
	endif;

epilog
	if include then
		return obj.CM_TIMaster.id;
	else
		return null;
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="CM_TIMaster"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="55adf3d9-4bad-4687-87c9-a43caa0c28a1">
        <source>getCollectionJMT(): Collection protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 22 May 2007
//
//----------------------------------------------------------------------

vars

begin
	return app.myRoot.allTiMasters;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="includeForDisplay" id="79ac363f-d886-411e-93cc-e48d4667c3b7">
        <source>includeForDisplay(_ti : CM_TrackedItem) : Boolean protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 17 August 2007
//
//	CHECK THE STATE OF THE TI MATCHES WHAT THE REQUIREMENTS ARE FOR 
//  DISPLAYING THE ITEM.
//	DON'T WORRY ABOUT THE INCLUDEALL AS THAT MEANS WE'RE DISPLAYING ANYTHING.
//----------------------------------------------------------------------

vars
	ti : CM_TrackedItem;
begin
	if _ti = null then
		return false;
	endif;
	
	ti := _ti;

	if ti &lt;&gt; null then
		//check I am not onsite somewhere else.
		if self.myTerminal &lt;&gt; null then
			if ti.isOnSite and (ti.myTerminal &lt;&gt; self.myTerminal) then
				return false;
			endif;
		endif;
		
		if self.isValidOperator(ti) and self.isValidTILCType(ti.CM_TILC) then
			if self.includeOffsite and ti.isOffSite then
		    	return true;
			elseif self.includeOnsite and ti.isOnSite then
				return true;
			endif;
		endif;
	else
		if self.includeOnsite then
		else
			return true;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidOperator" id="6de86505-7ce3-4f3e-a21c-05da8dfb3838">
        <source>isValidOperator(_ti : CM_TrackedItem) : Boolean protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 17 August 2007
//
//----------------------------------------------------------------------

vars

begin
	if not self.checkOperator then
		return true;
	endif;
	
	if _ti = null then
		return false;
	endif;
	
	if self.myOperator = null then
		return true;
	endif;
	
	if self.myOperator = _ti.myOperator then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidTILCType" id="e8da08b8-dc7d-439b-9c80-f3cae0a5d8ac">
        <source>isValidTILCType(_ti : CM_TILC) : Boolean protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 17 August 2007
//
//----------------------------------------------------------------------

vars

begin
	if _ti = null then
		return false;
	endif;
	
	if self.myTILCType = null then
		return true;
	endif;
	
	if _ti.myTILCType = self.myTILCType then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TILC"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
