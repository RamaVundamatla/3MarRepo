    <JadeMethod name="getVesselName" id="3df0c457-432e-449e-8c9e-249b8f48076e">
        <source>getVesselName(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
*/

vars
	vCode: String;
	terminal: CM_Terminal;
	voyage: CM_Voyage;
begin
	vCode := self.getVoyageCode;
	terminal := self.getMyTerminal;
	if vCode &lt;&gt; null and terminal &lt;&gt; null then
		voyage := terminal.lookupVoyage(vCode, null, false);
		if voyage &lt;&gt; null then
			return voyage.vesselName;
		endif;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyage" id="0e83cd8b-0ecb-43fe-8de6-7715c0466ef9">
        <source>getVoyage(_code : String) : CM_Voyage;

vars

begin
	return self.getMyTerminal().lookupVoyage(_code, null, false);
end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
