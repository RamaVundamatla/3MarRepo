    <JadeMethod name="setMyProxyTrackedItem" id="5e3ed130-303f-4a82-9527-d24dec45e55e">
        <updating/>
        <source>setMyProxyTrackedItem(pTI : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:     16 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pTI &lt;&gt; null then
		pTI.raiseExceptionIfNotProxy(method);
	endif;

	self.myProxyTrackedItem := pTI;
	
end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setReferences" id="e35d83b6-5e4f-4ced-9990-f5d1e46d9454">
        <updating/>
        <source>setReferences() updating;
// ---------------------------------------------------------------------------
// Created:     10 June 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if self.myISOType = null then
		self.myISOType := app.myRoot.allISOTypes[self.isoType];
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="ab57ffea-6494-4124-bca8-825081397315">
        <updating/>
        <source>validateForCreate(_passport : CM_Passport input): Boolean updating;

vars
	masterInterface : CMIF_Receival;
	cou 			: CM_ClipOnUnit;
	tmpCargoType 	: CM_CargoType;
	tiUpdCntrl		: CMIF_TIUpdateController;
begin

	if self.myMasterObject.isKindOf(CMIF_Receival) then
		masterInterface := self.myMasterObject.CMIF_Receival;		
	else
		//TO DO: Raise an exception
		return false;
	endif;
	
	if masterInterface.myProxyTrackedItem = null then
		//TO DO: Raise an exception here
		return false;
	endif;

/*	if masterInterface.myProxyTrackedItem.typeAttributes.bitAnd(ISO_PORTHOLE) = 0 then
		//Not a porthole !!
		return false;
	endif;
*/
	cou := masterInterface.myProxyTrackedItem.CM_Container.getCou;
	
	if cou = null then
		//Create this TI as proxy and attach to myMasterItem proxy TI
		tmpCargoType:= app.myRoot.allCargoTypesById[TI_CargoType_COU];
		cou 		:= self.myTerminal.createTI(tmpCargoType, true).CM_ClipOnUnit;
	endif;
	
	cou.setFromCMIF_InOutCOU(self);
	cou.setVoyageCode(masterInterface.myProxyTrackedItem.voyageCode, _passport);
		
	masterInterface.myProxyTrackedItem.attachCOU(cou, _passport);						

	tiUpdCntrl := app.createTIUpdateControl(TI_UPDMODE_RECEIPT, null, self.myUserObject);
	cou.validateAttachedCOU(tiUpdCntrl);

	return true;
epilog
	delete tiUpdCntrl;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="f7a0664b-b7d6-4570-871b-2cfe518af7ab">
        <updating/>
        <source>validateForUpdate(_passport : CM_Passport input): Boolean updating;

vars
	masterInterface : CMIF_Receival;
	cou 			: CM_ClipOnUnit;
	tmpCargoType	: CM_CargoType;
	tiUpdCntrl	: CMIF_TIUpdateController;	
begin

	if self.myMasterObject.isKindOf(CMIF_Receival) then
		masterInterface := self.myMasterObject.CMIF_Receival;		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Master IntFace Object for COU is not a receival');
		return false;
	endif;
	
	if masterInterface.myProxyTrackedItem = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Master IntFace Object proxy TI is null for a COU');
		return false;
	endif;

	//Create this TI as proxy and attach to myMasterItem proxy TI
	
	cou := masterInterface.myProxyTrackedItem.CM_Container.getCou;
	if cou = null then
		tmpCargoType 	:= app.myRoot.allCargoTypesById[TI_CargoType_COU];
		cou 			:= self.myTerminal.createTI(tmpCargoType, true).CM_ClipOnUnit;
	endif;

	cou.setFromCMIF_InOutCOU(self);
	cou.setVoyageCode(masterInterface.myProxyTrackedItem.voyageCode, _passport);
			
	if masterInterface.myProxyTrackedItem.CM_Container.getCou &lt;&gt; cou then
		if masterInterface.myProxyTrackedItem.CM_Container.getCou &lt;&gt; null then
			masterInterface.myProxyTrackedItem.CM_Container.getCou.erase(NORMAL_ERASE);
		endif;
		masterInterface.myProxyTrackedItem.attachCOU(cou, _passport);						
	endif;

	tiUpdCntrl := app.createTIUpdateControl(TI_UPDMODE_RECEIPT, null, self.myUserObject);
	cou.validateAttachedCOU(tiUpdCntrl);

	return true;
epilog
	delete tiUpdCntrl;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
