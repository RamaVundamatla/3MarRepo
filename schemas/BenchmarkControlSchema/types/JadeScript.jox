		//ff.fileName := "\\" &amp; m.hostName &amp; "\c$\inetpub\WebServicesTest\bin_jadehttp\ini";
		//ff.fileName := "\\" &amp; m.hostName &amp; "\c$\Users\cnwjbl36\AppData\Local\Microsoft\Windows\WER\ReportQueue";
		//f.fileName := "\\" &amp; m.hostName &amp; "\c$\cardinal\bin\jblrun.exe";
		//ff.fileName := "\\" &amp; m.hostName &amp; "\c$\Users\cnwjbl6\AppData\Local\temp\nunit20\ShadowCopyCache";
		f.fileName := "\\" &amp; m.hostName &amp; "\c$\cardinal\bin\postappserver.bat";
		if f.isAvailable then
			write f.fileName &amp; " " &amp; f.lastModifiedTime.String;
			//f.purge;
		else
			//write ff.fileName &amp; " is not available on " &amp; m.hostName;
		endif;
	endforeach;
	// delete files
	/*f.fileName := f.fileName.replace(m.hostName, "cnwchcs118");
	if f.isAvailable then // and f.lastModifiedTime.date &lt;&gt; "15 feb 2016".Date then
		write m.hostName &amp; " " &amp; f.fileName &amp; " " &amp; f.lastModifiedTime.String;
		f.purge;
	endif;/**/
	
	// check t:\prepreparedenvironments
	/*foreach m in Machine.instances where m.hostName &lt;&gt; "cnwchcs118" do
		//ff.fileName:="\\" &amp; m.hostName &amp; "\t$\prepreparedenvironments\jade6309.032AR64";
		ff.fileName:="\\" &amp; m.hostName &amp; "\t$\prepreparedenvironments";
		if ff.isAvailable then
			foreach fn in ff.files where fn.name.contains("jade7107") do
				app.logMessage(fn.fileName &amp; " " &amp; fn.lastModifiedTime.String);
				i := 0; j := 0;
				//app.housekeepingRemoveDir(fn.fileName, i, j, -1, true); app.logMessage(Tab &amp; "removed " &amp; i.String &amp; Tab &amp; j.String);
			endforeach;
		else
			write "no prepreparedenvironments on " &amp; m.hostName;
		endif;
	endforeach;/**/
	
	// check perl cache
	/*foreach m in Machine.instances where m.hostName &lt;&gt; "cnwchcs118" do // and m.hostName = "cnwchcs123" do
		if    not m.checkFolder("\\" &amp; m.hostName &amp; "\c$\Users\cnwjbl6\AppData\Local\Temp\par-cnwjbl6")
		and not m.checkFolder("\\" &amp; m.hostName &amp; "\c$\Users\cnwjbl6\AppData\Local\Temp\1\par-cnwjbl6")
		and not m.checkFolder("\\" &amp; m.hostName &amp; "\c$\Users\cnwjbl6\AppData\Local\Temp\2\par-cnwjbl6")
		and not m.checkFolder("\\" &amp; m.hostName &amp; "\c$\Users\cnwjbl6\AppData\Local\Temp\3\par-cnwjbl6")
		then
			m.checkFolder("\\" &amp; m.hostName &amp; "\c$\Users\cnwjbl6\AppData\Local\Temp");
		endif;
	endforeach;/**/
	
	// back up jblworker.conf
	/*foreach m in Machine.instances do // and m.hostName = "cnwchcs127" do
		f.fileName:="\\" &amp; m.hostName &amp; "\c$\thinbin\tools\jblworker.conf";
		s:=f.readString(f.fileLength);
		f.close;
