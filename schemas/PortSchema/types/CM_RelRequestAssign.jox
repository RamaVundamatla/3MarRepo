<Class name="CM_RelRequestAssign" id="428d7dfe-6ca5-42f3-a310-760a7ef3d264">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <PrimAttribute name="myBulkReleaseCode" id="4796592a-5a7b-423b-ba33-85824f16efb8">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="getDisplayStringForAttribute" id="cbd903fb-4d59-41b9-bea9-5ca0e0f4be4a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			if self.context &lt;&gt; 0 then
				lDetail := " [" &amp; app.transModeToString(self.context) &amp; "]";
			endif;
			return app.getErrorString(AssignedTo) &amp; " " &amp; self.myBulkReleaseCode &amp; lDetail;
			
		endif;
							
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="89546cc7-de89-4d1d-bd8e-4b0cf902003b">
        <source>getEnquiryRow(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 February 2009	cnwar2	Initial creation

*/

vars
	lDetail 	: String;
	lReturn		: String;
	
begin
	lDetail := inheritMethod();
	
	lReturn := lDetail &amp; app.getErrorString(AssignedTo) &amp; " " &amp; self.myBulkReleaseCode;		// 27/03/2009 cnwar2 #19235
	
	//17 Aug 2016	NDL	TFS 2559
	if self.context &lt;&gt; 0 then
		lReturn :=  lReturn &amp; " [" &amp; app.transModeToString(self.context) &amp; "]";
	endif;
	
	return lReturn;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageToRestoreTo" id="d945f0e6-83f4-4fef-bd85-613112361675">
        <source>getVoyageToRestoreTo():CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 February 2017	cnwndl1	Initial creation	TFS 3189

*/

vars

	voy : CM_Voyage;
	edition : Integer;
	err : Boolean;

begin

	on Exception do app.handleDeletedObject( exception, voy, err );

	if self.myVoyageRelivant &lt;&gt; null then
		voy := self.myVoyageRelivant;
		edition := voy.edition;
		if err then
			voy := null;
			err := false;
		else
			return voy;
		endif;
	endif;
	
	if self.voyage &lt;&gt; null then
		voy := self.voyage;
		edition := voy.edition;
		if err then
			voy := null;
			err := false;
		else
			return voy;
		endif;
	endif;
	
	if self.myTerminal &lt;&gt; null then
		voy := self.myTerminal.getNullVoyage;
		if voy &lt;&gt; null then
			edition := voy.edition;
			if err then
				voy := null;
				err := false;
			else
				return voy;
			endif;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="0afab4ce-8158-4b7f-bf6d-4e1f3399e9e1">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 February 2009	cnwar2	Initial creation

*/

vars

begin
	
	if not app.isInProformaMode then
		self.myBulkReleaseCode := _tiTransCntrl.myBulkRelease.code;		// 27/03/2009 cnwar2 #19235
		self.context := _tiTransCntrl.myBulkRelease.type;	//17 Aug 2016	NDL	TFS 2559
	endif;
	inheritMethod(_tiTransCntrl, _passport);
end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
