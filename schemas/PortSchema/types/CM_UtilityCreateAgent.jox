    <JadeMethod name="utlCopyInvoiceTMDebtorMap" id="b09e53e6-8df9-4b9c-b831-336a2fbf58db">
        <source>utlCopyInvoiceTMDebtorMap(_debtorMap : CM_DebtorMap; _newDebtor : CM_Debtor; _newDebtorType : CM_DebtorType; _parent : CM_ServiceBroker; _newDebtorMap : CM_DebtorMap output; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		Sep 2013	cnwjre1
//
// Purpose:		
// 17/02/2017  cnwma1 TFS # 3497:JMT - Invoice Auditing add Copy Function
// ---------------------------------------------------------------------------
vars

begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	if _newDebtor = null and _parent.allDebtorMapsByDebtor[null] &lt;&gt; null then
		return;
	endif;
	if _newDebtor &lt;&gt; null and _parent.allDebtorMapsByDebtor[_newDebtor.name] &lt;&gt; null then
		return;
	endif;

	create _newDebtorMap persistent;

	_newDebtorMap.copyFrom(_debtorMap, _newDebtor, _newDebtorType, _parent);
	
	if _passport.noErrors then  //17/02/2017  cnwma1 TFs #3497
		self.myCreateAuditAgent.audCreateGeneric(_newDebtorMap);
	endif;
	if _passport.noErrors then
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_REFRESH), false, _newDebtorMap);
	endif;

end;</source>
        <Parameter name="_debtorMap" type="CM_DebtorMap"/>
        <Parameter name="_newDebtor" type="CM_Debtor"/>
        <Parameter name="_newDebtorType" type="CM_DebtorType"/>
        <Parameter name="_parent" type="CM_ServiceBroker"/>
        <Parameter name="_newDebtorMap" type="CM_DebtorMap" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
