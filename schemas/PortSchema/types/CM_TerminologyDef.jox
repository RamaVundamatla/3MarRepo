    <JadeMethod name="validateForUpdate" id="8f3d007d-f96c-4b1f-83a2-564216add4cb">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     10 August 2004	cnwth2
//
// Purpose:     
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable 
// ----------   ----------  --------------------------------------------------
vars
	pxyTermExp,
	realTermExp			: CM_TerminologyExpression;
	pxyTermHdr			: CM_TerminologyHdr;
	existingHdr,
	realDef				: CM_TerminologyDef;
	pxyTermDtl			: CM_TerminologyDtl;
	
begin
	realDef := self.pxyGetRealObject();
	existingHdr := self.myTerminologyType.allTerminologyDefs[self.name];
	
	if (realDef &lt;&gt; null) and (self.myTerminologyType &lt;&gt; realDef.myTerminologyType) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'You cannot update the terminology type of a header once it has been created');	
		return;
	endif;
	
	if self.name = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'name', 'name', null);
		app.raiseCMException(Input_required_field_name, 'name', null); // cnwdb2	PAR 35364
	endif;
	
	if self.myTerminologyType.allTerminologyTypeDtls.size &lt;&gt; self.allTerminologyDtls.size then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Details collection size (' &amp; 
									self.allTerminologyDtls.size.String &amp; ') differs from ' &amp; CrLf&amp;
									'types collection size (' &amp; self.myTerminologyType.allTerminologyTypeDtls.size.String);
	endif;
	
	if self.myTerminologyType.allTerminologyTypeExpressions.size &lt;&gt; self.allTerminologyExpressions.size then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Expression collection size (' &amp; 
									self.allTerminologyExpressions.size.String &amp; ') differs from ' &amp; CrLf &amp;
									'types collection size (' &amp; self.myTerminologyType.allTerminologyTypeExpressions.size.String);
	endif;
	
	if existingHdr &lt;&gt; null and realDef = null then //creating new header, but key already in use
		//app.raiseCMException2(DuplicateItem, 'Terminology Hdr: ' &amp; self.name, 'Terminology Type: ' &amp; self.myTerminologyType.name, ETRow_TermHdrName, null); //14.06.2022 navds20 53760
		// Terminology Hdr: %1 already exists for Terminology Type: %2 : Termin_alread_exists_termin_ty
		app.raiseCMException2(Termin_alread_exists_termin_ty, self.name, self.myTerminologyType.name, ETRow_TermHdrName, null); //14.06.2022 navds20 53760
	endif;

	if (existingHdr &lt;&gt; null and realDef &lt;&gt; null) and
	   (existingHdr &lt;&gt; realDef) then //updating header to a key already in use
		//app.raiseCMException2(DuplicateItem, 'Terminology Hdr: ' &amp; self.name, 'Terminology Type: ' &amp; self.myTerminologyType.name, ETRow_TermHdrName, null); //14.06.2022 navds20 53760
		// Terminology Hdr: %1 already exists for Terminology Type: %2 : Termin_alread_exists_termin_ty
		app.raiseCMException2(Termin_alread_exists_termin_ty,  self.name, self.myTerminologyType.name, ETRow_TermHdrName, null); //14.06.2022 navds20 53760
	endif;
	
	if (not self.pxyHeadingsHaveBeenProcessed) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Update attempted before proxy detail user heading have been processed');
	endif;
	
	if self.allTerminologyDtls.isEmpty then
		app.raiseUnexpectedProgramError(class.name, method.name, 'All terminology details collection was empty');
	endif;
	
	foreach pxyTermExp in self.allTerminologyExpressions do
		pxyTermExp.validateForUpdate();
	endforeach;
	
	foreach pxyTermDtl in self.allTerminologyDtls do
		pxyTermDtl.validateForUpdate();
	endforeach;
	
	foreach pxyTermHdr in self.allTerminologyHdrs do
		pxyTermHdr.validateForUpdate();
	endforeach;
end;</source>
    </JadeMethod>
</Class>
