/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2018	jlgndl1	Initial creation	TFS 38135
	Look up the shipping line using the value passed in, if doesn't match one try again using
	the EDI Translations.

*/

vars

	shippingLine : CM_ShippingLine;
	translatedCode : String;
	found : Boolean;

begin

	shippingLine := app.myRoot.allShippingLines[ _rawValue ];
		
	if shippingLine = null then
		translatedCode := app.myRoot.getXlationSystemCode( _rawValue, XLATION_TYPE_SHIPPINGLINE, found );
		if found then
			shippingLine := app.myRoot.allShippingLines[ translatedCode ];
		endif;
	endif;
	
	return shippingLine;

epilog

end;</source>
        <Parameter name="_rawValue" type="String"/>
