    <JadeMethod name="jreEDIConsignoreeCleanup" id="5e8c63ad-b5be-47c0-8040-7d256e719fe9">
        <source>jreEDIConsignoreeCleanup();
// delete all CM_EDIConsignoreeTI and associated CM_EDIData to save a reorg (all instances from unit tests)
vars
	count	: Integer;
	eti		: CM_EDIConsignoreeTI;
	ed		: CM_EDIData;
	oa, oa2		: ObjectArray;
	obj		: Object;
begin
	create oa transient;
	beginTransaction;
	foreach eti in CM_EDIConsignoreeTI.instances do
		ed := eti.myEDIData;
		if ed &lt;&gt; null then
			if not oa.includes(ed) then
				oa.add(ed);
			endif;
		endif;
		delete eti;
		count := count + 1;
	endforeach;
	commitTransaction;
	create oa2 transient;

	foreach obj in oa do
		ed := obj.CM_EDIData;
		if ed.allEDITrackedItems.isEmpty() then
			oa2.add(obj);
		endif;
	endforeach;
	write count.String &amp; " CM_EDIConsignoreeTI instances deleted, " &amp; oa2.size.String &amp; " CM_EDIData instances deleted.";
	beginTransaction;
	oa2.purge();
	commitTransaction;
epilog
	delete oa;
	delete oa2;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreExtractInvoiceStuff" id="cd852fc6-6687-4cc5-bcdc-9f64253a0632">
        <source>jreExtractInvoiceStuff();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2015	cnwjre1	Initial creation

*/

vars
	terminal	: CM_Terminal;
	bank		: CM_Bank;
	agent		: CM_ExtractLoadAgent;
	file		: File;
begin
	terminal := CM_Root.firstInstance.allTerminals["JOHN"];
	bank := terminal.getDefaultCompanyBank();
	
	create agent transient;
	create file transient;
	file.openOutput("c:\temp\InvoiceTypes.xml");
	agent.extractInvoiceTypes(file, bank);
	file.close;
	file.openOutput("c:\temp\Services.xml");
	agent.extractServices(file, bank);
	file.close;
	file.openOutput("c:\temp\InvoiceLineTypes.xml");
	agent.extractInvoiceLineTypes(file, bank);
	file.close;
	file.openOutput("c:\temp\GLCodes.xml");
	agent.extractGLCodesForBank(file, bank);
	
epilog
	delete agent;
	if file &lt;&gt; null then
		if file.isOpen then
			file.close();
		endif;
		delete file;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="jreFindBOLVoyages" id="3adf79e0-cd52-4a59-973d-ca9ecc30ec32">
        <source>jreFindBOLVoyages();

/*

Purpose:		For pars 33880 and 33881, list voyages which have no import BOL objects but do have on-site cargo
				with at least 3 different CM_TrackedItem.billOfLading values.
Parameters:			

Return Value:		


Date		Who		Reason
03 April 2014	cnwjre1	Initial creation

*/

vars
	terminal	: CM_Terminal;
	voyage	: CM_Voyage;
	voyages	: CM_VoyageSet;
	voyageBolNumbers	: StringArray;
	bolNumber			: String;
	count	: Integer;
	found	: Integer;
begin
	app.initialize;
	
	create voyages transient;
	create voyageBolNumbers transient;
	foreach terminal in CM_Root.firstInstance.allTerminals do
		if not terminal.isCashOnlyEnabled then
			continue;
		endif;
		voyages.clear();
		terminal.getAllCurrentVoyages(voyages, true, false, false);
		foreach voyage in voyages do
			if voyage.allBOLInByTypeStatusNumDT.isEmpty() then
				voyageBolNumbers.clear();
				count := 0;
				voyage.getImportBOLNumbers(voyageBolNumbers);
				foreach bolNumber in voyageBolNumbers do
					count := count + 1;
					if count &gt; 3 then
						write "Terminal " &amp; terminal.name &amp; " voyage " &amp; voyage.code;
						found := found + 1;
						break;
					endif;
				endforeach;
			endif;
			if found &gt; 20 then
				break;
			endif;
		endforeach;
	endforeach;
epilog
	delete voyages;
	delete voyageBolNumbers;
end;</source>
    </JadeMethod>
    <JadeMethod name="jreFindCargo" id="d75069e4-af38-4443-8cad-721d892a3c17">
        <source>jreFindCargo();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 October 2013	cnwjre1	Initial creation

*/

vars
	terminal	: CM_Terminal;
	ti			: CM_TrackedItem;
	found1, found2	: Boolean;
begin
	terminal := CM_Root.firstInstance.allTerminals["T01"];
	foreach ti in terminal.allOnsiteTIsByCargoTypeId do
		if ti.allOverriddenWarnings.size &gt; 1 then
			write ti.id &amp; " " &amp; ti.myCargoType.description &amp; " has warnings";
			found1 := true;
		endif;
		if (ti.allEventRequestsNotify.size + ti.allEventRequestsStops.size) &gt; 1 then
			write ti.id &amp; " " &amp; ti.myCargoType.description &amp; " has events";
			found2 := true;
		endif;
		if found1 and found2 then
			break;
		endif;
	
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="jreFindCargoToUnpack" id="e5241b1c-35ae-4254-b13c-53cafa26c310">
        <source>jreFindCargoToUnpack();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 October 2013	cnwjre1	Initial creation

*/

vars
	terminal	: CM_Terminal;
	ti			: CM_TrackedItem;
	count		: Integer;
begin
	terminal := CM_Root.firstInstance.allTerminals["T01"];
	foreach ti in terminal.allOnsiteTIsByCargoTypeId do
		if ti.cargoType &lt;&gt; 1 then
			continue;
		endif;
		if ti.hasChildren then
			write ti.id;
			count := count + 1;
		endif;
		if count &gt; 50 then
			break;
		endif;
	
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="jreFindClassInView" id="b04e6de2-86c3-417d-bc02-0549dc251965">
        <source>jreFindClassInView();
//  find all entries in all views for class CM_JRWInvoice
vars
	portScm,
	rws	: Schema;
	root	: Object;
	allViews,
	allTypes,
	allFeatures	: MemberKeyDictionary;
	view	: Object;
	type	: Object;
	feature	: Object;
	viewName,
	typeName,
	featureName,
	propType: String;
	cls		: Class;
	property	: Property;

begin
	rws := rootSchema.getSchema("JadeReportWriterSchema");
	if rws = null then
		app.writeStatement(method.name&amp;" no report writer schema");
		return;
	endif;
	root := rws.getClass("JRDRoot").firstInstance;
	if root = null then
		app.writeStatement(method.name&amp;" no report writer root");
		return;
	endif;
	
	portScm := rootSchema.getSchema("PortSchema");
	allViews := root.getPropertyValue("allReportingViews").MemberKeyDictionary;
	foreach view in allViews do
		viewName := view.getPropertyValue("name").String;
		allTypes := view.getPropertyValue("allReportingTypeDefns").MemberKeyDictionary;
		foreach type in allTypes do
			typeName := type.getPropertyValue("typeName").String;
			if typeName = "CM_JRWInvoice" then
				write "CM_JRWInvoice is in " &amp; viewName;
			endif;
		endforeach;
	endforeach;
epilog
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreFindFullReplacementText" id="44e0f1f1-93e5-4201-bd7a-e4a3c724c43d">
        <source>jreFindFullReplacementText();
// par 30346
vars
	scm	: Schema;
	cat : ConstantCategory;
	con	:  Constant;
begin
	scm := rootSchema.getSchema("PortSchema");
	cat := scm.getCategory("XLAT_Exceptions");
	foreach con in cat.getConstants do
		if con.text.pos("&gt;%1&lt;", 1) &gt; 0 or
		   con.text.pos("&gt; %1&lt;", 1) &gt; 0 or
		   con.text.pos("&gt;%1 &lt;", 1) &gt; 0 then
			write con.name;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="jreFindHMSInvoices" id="8e64388f-7538-44be-95df-6aec6cfbe51f">
        <source>jreFindHMSInvoices();

vars
	calcType	: CM_CalculationType;
	ild			: CM_InvoiceLineDesc;
	line		: CM_InvoiceLine;
	obj			: Object;
begin
	foreach line in CM_InvoiceLine.instances do
		if line.invoice = null then
			continue;
		endif;
		if line.invoice.status = 0 or
		   line.invoice.status = 1 or
		   line.invoice.status = 3 then
			if line.manual then
				continue;
			endif;
			if not line.isVTMISInvoiceLine() or
			   line.manual then
				continue;
			endif;
			if line.myTransactionHMS &lt;&gt; null then
				if line.myTransactionHMS.myResourceUsed &lt;&gt; null then
						write " invoice " &amp; line.invoice.sequenceNum.String &amp; " for " &amp; 
								line.invoice.debtor.name &amp; " " &amp; line.invoice.myTerminal.code &amp;
								" line " &amp; line.sequenceNum.String &amp; " " &amp; line.quantity.String &amp; " " &amp;
								line.invoice.getStatusDescription(line.invoice.status);
				endif;
			endif;
		endif;
	endforeach;
	
	write "Done";
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreFindHMSInvoices2" id="298cccec-59c6-40f0-9189-f9429e1ecf39">
        <source>jreFindHMSInvoices2();
// CCMS 1264 find open HMS invoice lines for calc types with min/max set
vars
	calcType	: CM_CalculationType;
	ild			: CM_InvoiceLineDesc;
	line		: CM_InvoiceLine;
	charge		: CM_Charge;
	service		: CM_Service;
	ct			: CM_CalculationType;
	obj			: Object;
begin
	foreach line in CM_InvoiceLine.instances do
		if line.invoice = null then
			continue;
		endif;
		if line.invoice.status = 0 or
		   line.invoice.status = 1 or
		   line.invoice.status = 3 then
			if line.manual then
				continue;
			endif;
			if not line.isVTMISInvoiceLine() or
			   line.manual then
				continue;
			endif;
			if line.myTransactionHMS &lt;&gt; null then
				if line.myTransactionHMS.myResourceUsed &lt;&gt; null then
					foreach charge in line.charges do
						service := charge.service;
						if not charge.overridden
						   and service &lt;&gt; null then
							ct := service.myCalculationType;
							if ct &lt;&gt; null and ct.isVoyageCalcType and
							   ct.amountMin &gt; 0 then
									if line.quantity &gt; 0 and charge.getRate() &gt; 0 then
									write " invoice " &amp; line.invoice.sequenceNum.String &amp; " for " &amp; 
										line.invoice.debtor.name &amp; " " &amp; line.invoice.myTerminal.code &amp;
										" line " &amp; line.sequenceNum.String &amp; " " &amp; line.quantity.String &amp; " " &amp;
										line.invoice.getStatusDescription(line.invoice.status);
									endif;
							endif;
						endif;
					endforeach;
				endif;
			endif;
		endif;
	endforeach;
	
	write "Done";
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreFindInView" id="de20ca99-0573-40d9-bd6c-8dd4a4614775">
        <source>jreFindInView();
//  find all entries in all views for type TimeStamp (and Date and Time)
vars
	portScm,
	rws	: Schema;
	root	: Object;
	allViews,
	allTypes,
	allFeatures	: MemberKeyDictionary;
	view	: Object;
	type	: Object;
	feature	: Object;
	viewName,
	typeName,
	featureName,
	propType: String;
	cls		: Class;
	property	: Property;
	file	: File;
begin
	rws := rootSchema.getSchema("JadeReportWriterSchema");
	if rws = null then
		app.writeStatement(method.name&amp;" no report writer schema");
		return;
	endif;
	root := rws.getClass("JRDRoot").firstInstance;
	if root = null then
		app.writeStatement(method.name&amp;" no report writer root");
		return;
	endif;
	
	create file transient;
	file.openOutput("c:\temp\ViewDateTimeProperties.txt");
	portScm := rootSchema.getSchema("PortSchema");
	allViews := root.getPropertyValue("allReportingViews").MemberKeyDictionary;
	foreach view in allViews do
		viewName := view.getPropertyValue("name").String;
		allTypes := view.getPropertyValue("allReportingTypeDefns").MemberKeyDictionary;
		foreach type in allTypes do
			typeName := type.getPropertyValue("typeName").String;
			cls := portScm.getClass(typeName);
			if cls = null then
				continue;
			endif;
			allFeatures := type.getPropertyValue("allReportingFields").MemberKeyDictionary;
			foreach feature in allFeatures do
				if feature.class.name = "JRDReportingFeatureDefn" then
					featureName := feature.getPropertyValue("featureName").String;
					property := cls.findProperty(featureName);
					if property = null then
						continue;
					endif;
					if property.isKindOf(PrimAttribute) then
						propType := property.type.name;
						if propType = "Date" or
						   propType = "Time" or
						   propType = "TimeStamp" then
							file.writeLine(viewName &amp; " " &amp; typeName &amp; " " &amp; featureName &amp; " " &amp; propType);
						endif;
					endif;
				endif;
			endforeach;
		endforeach;
	endforeach;
epilog
	if file &lt;&gt; null then
		if file.isOpen then
			file.close;
		endif;
		delete file;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreFindInvoiceLineTypesNoCalc" id="6dac68a0-d471-4bbe-8513-0dca4e138d29">
        <source>jreFindInvoiceLineTypesNoCalc();

vars
	total,
	noCalc,
	noBank,
	areVoid	: Integer;
	invoiceLineType	: CM_InvoiceLineDesc;
	ps	: PortSchema_8_3_1;
begin
	app.initialize();

	create ps transient;
	//ps.setInvoiceLineTypeCalcType();
	//beginTransaction;
	foreach invoiceLineType in CM_InvoiceLineDesc.instances do
		total := total + 1;
		if invoiceLineType.myCalculationType = null then
			noCalc := noCalc + 1;
		endif;
		if invoiceLineType.isVoid then
			areVoid := areVoid + 1;
		endif;
		//if invoiceLineType.bank = null then
		//	noBank := noBank + 1;
		//	delete invoiceLineType;
		//endif;
	endforeach;
	//commitTransaction;
	write total.String &amp; " total, " &amp; noCalc.String &amp; " have no calculation type, " &amp; noBank.String &amp; " have no bank, " &amp; areVoid.String &amp; " are void.";
epilog
	delete ps;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreFindLogs" id="e1238c09-d7fe-4f9f-8b28-4eace3c85a35">
        <source>jreFindLogs();
// find logs that can be regraded
vars
	keyType	: Integer;
	keyId	: String;
	term	: CM_Terminal;
	iter	: Iterator;
	ti		: CM_TrackedItem;
	log		: CM_Log;
begin
	app.initialize();
	
	term := app.myRoot.allTerminals['T01'];
	iter := term.allOnsiteTIsByCargoTypeId.createIterator;
	term.allOnsiteTIsByCargoTypeId.startKeyGeq(9, '', iter);
	
	while iter.next(ti) do
		term.allOnsiteTIsByCargoTypeId.getIteratorKeys(keyType, keyId, iter);
		if keyType &lt;&gt; 9 then
			break;
		endif;
		if not ti.isKindOf(CM_Log) then
			continue;
		endif;
		log := ti.CM_Log;
		if log.isAverageScaled then
			continue;
		endif;
		if log.myVoyage &lt;&gt; null and
		   log.myVoyage.isClosedStatus() then
			continue;
		endif;
		if log.myReceivalBOL &lt;&gt; null and
		   log.myReceivalBOL.myExtension &lt;&gt; null and
		   log.myReceivalBOL.myExtension.isKindOf(CM_BOLExtLogIn) then
			if log.myReceivalBOL.myExtension.CM_BOLExtLogIn.percentScaled = 100 then
				continue;
			endif;
		endif;
		write log.id;
	endwhile;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreFindVoyagesWithHMSUsage" id="4ddf8e70-c50c-40ab-85d9-841a1433936b">
        <source>jreFindVoyagesWithHMSUsage();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2012	cnwjre1	Initial creation

*/

vars
	voy	: CM_Voyage;
	mvmt : HMS_VoyageMovement;
	resUsed	: HMS_ResourceUsed;
begin
	app.initialize();
	
	foreach voy in CM_Voyage.instances do
		if voy.myHMSVoyageData &lt;&gt; null then
			foreach mvmt in voy.myHMSVoyageData.allVoyageMovements do
				foreach resUsed in mvmt.allResourceUsed do
					write voy.myTerminal.code &amp; " " &amp; voy.code &amp; " " &amp;voy.description;
					break;
				endforeach;
			endforeach;
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
