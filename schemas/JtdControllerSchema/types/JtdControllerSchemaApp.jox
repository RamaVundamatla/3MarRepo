    <JadeMethod name="logMessage" id="8a6017f4-7396-4253-b8e9-f7fb7953d9a2">
        <updating/>
        <source>logMessage(s:String) updating;
/*  Uses the JadeLog class to write a message to msg&lt;n&gt;.log  */
// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
begin
	if msgLog=null then
		create msgLog;
		msgLog.fileName:="msg";
		msgLog.formatOutput:=false;
		msgLog.maxFileSize:=getProfileStringAppServer(getIniFileNameAppServer,"JadeLog","MaxLogFileSize","1000000").Integer;
	endif;
	msgLog.log(actualTimeServer.logFormat&amp;" "		// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
					&amp;name&amp;"/"&amp;getInstanceId(process).String&amp;": "
					&amp;s&amp;CrLf);
end;</source>
        <Parameter name="s" type="String"/>
    </JadeMethod>
    <JadeMethod name="readInteger" id="0a92b262-c1d7-4654-b41b-aa323f1dedfe">
        <source>readInteger(prompt : String; performRangeChecks : Boolean; min, max : Integer;
	value : Integer io) : Boolean;

vars
	f : ReadIntegerForm;
	s : String;
		
begin
	create f transient;

	f.lblPrompt.caption := prompt;
	f.performRangeChecks := performRangeChecks;
	f.minValue := min;
	f.maxValue := max;

	if value &lt;&gt; 0 then
		s := value.String;
	else
		s := null;
	endif;
	
	if performRangeChecks then
		f.txbInt.maxLength := max.String.length;
		
		if s &lt;&gt; null and s.length &lt;= f.txbInt.maxLength then
			f.txbInt.text := s;
		endif;
	else
		f.txbInt.text := s;
	endif;
	
	if f.showModal = 0 then
		value := f.integer;
		return true;
	endif;
	
	return false;
	
epilog
	delete f;
end;</source>
        <Parameter name="prompt" type="String"/>
        <Parameter name="performRangeChecks" type="Boolean"/>
        <Parameter name="min" type="Integer"/>
        <Parameter name="max" type="Integer"/>
        <Parameter name="value" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="readString" id="57ba882d-4f1f-4552-8089-1fb140e8c648">
        <source>readString(prompt : String; maxLength : Integer; value : String io) : Boolean;

vars
	f : ReadStringForm;
		
begin
	create f transient;

	f.lblPrompt.caption := prompt;

	if maxLength &gt; 0 then
		f.txbStr.maxLength := maxLength;
		
		if value &lt;&gt; null and value.length &lt;= maxLength then
			f.txbStr.text := value;
		endif;
	else
		f.txbStr.maxLength := 0;
		f.txbStr.text := value;
	endif;
	
	if f.showModal = 0 then
		value := f.string;
		return true;
	endif;
	
	return false;
	
epilog
	delete f;
end;</source>
        <Parameter name="prompt" type="String"/>
        <Parameter name="maxLength" type="Integer"/>
        <Parameter name="value" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resumeNextExHandler" id="2e847212-6633-45e4-ac6a-6ad91d37d5ec">
        <source>resumeNextExHandler(exObj : Exception; errNo : Integer output;
	errTxt : String output) : Integer;

begin
	errNo := exObj.errorCode;
	errTxt := exObj.text;
	return Ex_Resume_Next;
end;</source>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="errNo" type="Integer" usage="output"/>
        <Parameter name="errTxt" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
