<Class name="CM_TCPIPAgentListen" id="fd3357ec-c422-43d0-aba3-11ba77ea1436">
    <superclass name="CM_TCPIPAgent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="jmtxml"/>
    <ImplicitInverseRef name="allWorkers" id="f17b083a-9577-49d0-900e-8b8aa73ba827">
        <memberTypeInverse/>
        <type name="CM_XMLSharedSet"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="finish" id="c4602103-d8a6-4b43-a5d6-eefb005b2929">
        <updating/>
        <source>finish() updating;

vars
	worker : CM_TCPIPShared;
begin

	foreach worker in self.allWorkers do
		worker.causeEvent(worker.ProcessTerminate, true, null);
	endforeach;
		
	inheritMethod();
	
	// Want to put this at the end to give workers enough time
	// to stop.
	beginTransientTransaction;
	self.allWorkers.purge;
	commitTransientTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="getFreeWorker" id="466279a3-5bac-470b-988a-fd33ae54809d">
        <source>getFreeWorker() : CM_TCPIPShared protected;
// -----------------------------------------------------------------------------
// Created:		05 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars	

	worker	: CM_TCPIPShared;
	iter 	: Iterator;
	
begin

	iter := self.allWorkers.createIterator();
	while iter.next(worker) do
		if worker.myTCPConnection = null then
			break;
		endif;
		worker := null;
	endwhile;
	return worker;
	
epilog

	delete iter;
	
end;</source>
        <access>protected</access>
        <ReturnType type="CM_TCPIPShared"/>
    </JadeMethod>
    <JadeMethod name="init" id="741a61b3-6546-4fde-bad3-797804fcba76">
        <updating/>
        <source>init() updating;
// -----------------------------------------------------------------------------
// Created:		01 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars

	i 					: Integer;
	port, numWorkers	: Integer;
	interface			: String;
	controller			: BGP_XMLListenController;
	
begin

	inheritMethod();
	on ConnectionException do self.xTcpHandler(exception) global;
	controller := app.myBGPController.BGP_XMLListenController;
	port 		:= controller.tcpIpPort;
	numWorkers 	:= controller.numberOfWorkers;
	interface	:= controller.tcpIpInterfaceAddress;
	
	beginTransientTransaction;
	if self.myTCPConnection = null then
		create self.myTCPConnection sharedTransient;
	endif;
	self.myTCPConnection.port 				:= port;  // config
	self.myTCPConnection.localInterface		:= interface; // Address
	commitTransientTransaction;

	foreach i in 1 to numWorkers do
		self.startWorker();	
	endforeach;

	self.myTCPConnection.listenContinuousAsynch(self, 'listenContiuousAsynchCB');

end;</source>
    </JadeMethod>
    <JadeMethod name="listenContiuousAsynchCB" id="5a0fd54d-fc42-4f58-a3cb-6f9016aa6e81">
        <updating/>
        <source>listenContiuousAsynchCB(_tcp:    TcpIpConnection; _newTcp: TcpIpConnection) updating;
// -----------------------------------------------------------------------------
// Created:		02 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars

	worker : CM_TCPIPShared;
	
begin

	on Exception do self.xFreeWorker(exception, _newTcp);
	worker := self.getFreeWorker();
	worker.bindConnection(_newTcp);
	
end;</source>
        <Parameter name="_tcp" type="TcpIpConnection"/>
        <Parameter name="_newTcp" type="TcpIpConnection"/>
    </JadeMethod>
    <JadeMethod name="startWorker" id="47ecc82f-a2d8-41d1-924d-90f4c9a09071">
        <source>startWorker() : CM_TCPIPShared protected;
// -----------------------------------------------------------------------------
// Created:		05 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars

	sharedWorker : CM_TCPIPShared;
	
begin

	beginTransientTransaction;
	create sharedWorker sharedTransient;
	sharedWorker.setForCreate(app.myBGPController.BGP_XMLListenController);
	self.allWorkers.add(sharedWorker);
	commitTransientTransaction;
	
	app.startApplicationWithParameter(currentSchema.name, 'TCPIPWorkerApp', sharedWorker);
	return sharedWorker;
	
end;</source>
        <access>protected</access>
        <ReturnType type="CM_TCPIPShared"/>
    </JadeMethod>
    <JadeMethod name="xFreeWorker" id="2a3858a8-71ff-44eb-8a7f-84b97bdca0c7">
        <updating/>
        <source>xFreeWorker(_exObj : Exception; _tcp : TcpIpConnection) : Integer updating, protected;
// -----------------------------------------------------------------------------
// Created:		15 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars

	tcp	: TcpIpConnection;
	
begin

	if _exObj.errorCode = 4 or _exObj.errorCode = 1090 then
		self.logIt(self.LogLevel_Log, 'No free xml workers');
		_tcp.writeBinary(self.createXmlError(Err_NoXMLWorkers, app.getErrorString(Err_NoXMLWorkers), null, null, null, null).asANSI(0));	// 14/3/16 cnwmp6 PAR 36286 unicode version
		// Sleep gives connection enough time to write string before closing.
		process.sleep(5000);
		self.logIt(self.LogLevel_Log, 'Closing connection - no free worker');
		tcp := _tcp;
		self.doConnectionClose(tcp);
		return Ex_Resume_Next;
	endif;
	return Ex_Pass_Back;	
	
end;</source>
        <access>protected</access>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_tcp" type="TcpIpConnection"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
