    <JadeMethod name="doDFMouseUp" id="41398709-00a2-45d4-870c-e4bc826ccaf0">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doDFMouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		10 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	form : Form;
	theObj : Object;
begin
	if self.myYardGridAreaForm &lt;&gt; null then
	
		self.myYardGridAreaForm.doDFMouseUp(frame,button,shift, x,y);
		
		if self.allSelectedObjects.isEmpty then
	//		self.myTrackedItem := null;
		endif;

	else
	
		if self.myDockBar &lt;&gt; null then
			if self.myDockBar.parent.isKindOf(Form) then
				form:=self.myDockBar.parent.Form;
			endif;
			if form &lt;&gt; null and form.isKindOf(YRD_MoveOverstowCargoForm) then
				theObj:= self.myDrawingFrame.getObjectForPosition(x.Integer, y.Integer);
				if theObj &lt;&gt; null then
					self.myDrawingFrame.handleMouseUp(theObj,button,shift, x,y);
				endif;
				form.YRD_MoveOverstowCargoForm.handleSelectionChange();
			endif;
			
		endif;
	endif;
	
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doDFStatusLine" id="24810b84-8464-44b7-82df-af33b01d1dcb">
        <source>doDFStatusLine();
// ---------------------------------------------------------------------------
// Created:		11 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
		self.myYardGridAreaForm.frmStatusLine.myFrameCaption.caption := null;
		self.myYardGridAreaForm.frmStatusLine.myFrameCaption.caption := " Selected: " &amp; self.allSelectedObjects.size.String;

end;</source>
    </JadeMethod>
    <JadeMethod name="doDrawFMLetter" id="f995e34f-c4e2-433c-84e3-763a907bbf71">
        <updating/>
        <source>doDrawFMLetter(_displayMode: Integer; _letterIndex: Integer; _fillColour: Integer; _startX : Real; _startY: Real; _endY: Real) updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//       AKB    19MAY2008     PAR 16415 CCMS 1029 30,45,53s
// ---------------------------------------------------------------------------
constants
	Local_ACTUAL_MODE = 6;
vars
	endX,tmpX,
	startX	: Real;
	theFMLetter : String;
	theMode		: Integer;
	isFMA40,
	isFMQ40,
	isFMP40		: Boolean;
	ti			: CM_TrackedItem;	
	tmpLC, primLC : CM_LocationsController;
	numActualTIs,  numQdTIs, numPdTIs, fmIndex : Integer;
	fm : CM_FutureMove;
begin
	tmpLC := self.myLocationsController;
	
	if tmpLC = null then
		return;
	endif;
//if process.isCnwab1 and tmpLC.CM_GridController.name = "A04" then
//write "";
//endif;
	
	numActualTIs := tmpLC.allTrackedItems.size;
	
	// draw the Ps and Qs in addition to the actual TI graphic
	if _displayMode &lt;&gt; DISPLAY_MODE_ACTUAL then
	/*
		if (not tmpLC.allTrackedItems.isEmpty) and _letterIndex &lt;= tmpLC.allTrackedItems.size then
			ti := tmpLC.allTrackedItems[_letterIndex];
	*/
		if _displayMode = DISPLAY_MODE_QUEUE then
			tmpLC.getAllQueuedTrackedItems(self.allTrackedItems, true);
		else
			tmpLC.getAllPlannedTrackedItems(self.allTrackedItems, true, false);
		endif;
		numQdTIs := self.allTrackedItems.size; 
		self.allTrackedItems.clear;
		
		tmpLC.allTrackedItems.copy(self.allTrackedItems);
		numActualTIs := self.allTrackedItems.size;
		fmIndex := _letterIndex - numQdTIs;
		
		if numActualTIs &gt; 0 
		and fmIndex &gt; 0 //PAR17836
		and (fmIndex &lt;= numActualTIs) then
			ti := self.allTrackedItems[fmIndex];
	
				if self.isForEndView // PAR 18682
				or ti.myPrimaryActualLocation = tmpLC then
//				if ti.myPrimaryActualLocation = tmpLC then
					theFMLetter := theFMLetter &amp; "A";
					ti.getFMLetter(theFMLetter);
					theMode := Local_ACTUAL_MODE;
				endif;
		endif;
	endif;

	if _displayMode &lt;&gt; DISPLAY_MODE_QUEUE then
		tmpLC.getAllQueuedTrackedItems(self.allTrackedItems, true);
		numQdTIs := self.allTrackedItems.size;
		fmIndex := _letterIndex - numActualTIs;
		
		if numQdTIs &gt; 0 
		and fmIndex &gt; 0 //PAR17836
		and (fmIndex &lt;= numQdTIs) then
			ti := self.allTrackedItems[fmIndex];
//			if ti.myPrimaryQueuedLocation = tmpLC then // front end only // PAR 18596
//			if tmpLC.isPrimaryLocationForFM(QUEUE_MODE, fmIndex) then // PAR 18596
			if self.isForEndView 
			or tmpLC.isPrimaryLocationForFM(QUEUE_MODE, fmIndex) then // PAR 18682
			
				theFMLetter := theFMLetter &amp; "Q";
				ti.getFMLetter(theFMLetter);
				fm := ti.getFutureMoveForLC(QUEUE_MODE, tmpLC); // PAR 18682
			endif;
			theMode := QUEUE_MODE;
		endif;
	endif;

	if _displayMode &lt;&gt; DISPLAY_MODE_PLAN then
		tmpLC.getAllPlannedTrackedItems(self.allTrackedItems, true, false);
		numPdTIs := self.allTrackedItems.size;
		fmIndex := _letterIndex - numActualTIs;
		
		if numPdTIs &gt; 0 
		and fmIndex &gt; 0 //PAR17836
		and (fmIndex &lt;= numPdTIs) then
			ti := self.allTrackedItems[fmIndex];
			primLC := ti.myPrimaryPlannedLocation;
			// PAR 17826. If a DLR and is planned to yard and seperately planned back to ship, 
			//					the primaryPlanned Location can be the ship, IF the discharge has been unplanned and replanned, so we need to see where the discharge plan is.
			if primLC &lt;&gt; tmpLC then
				if ti.isRehandle then	
					primLC := ti.getDLRFMPrimaryLocation(false);
				endif;
			endif;

			if self.isForEndView // PAR 18682
			or primLC = tmpLC  then // front end only
//			if primLC = tmpLC  then // front end only
//			if ti.myPrimaryPlannedLocation = tmpLC then // front end only
				theFMLetter := theFMLetter &amp; "P";
				ti.getFMLetter(theFMLetter);
				fm := ti.getFutureMoveForLC(PLANNING_MODE, tmpLC); // PAR 18682
			endif;
			theMode :=  PLANNING_MODE;
		endif;
	endif;


	if theFMLetter &lt;&gt; null then	
		startX := _startX;

		if (self.isForOverview or self.isForSatelliteView) and self.flipHorizontal then // PAR 19082
			if tmpLC.offsetFlexi = 0 then
			startX := startX + self.columnWidth;  // PAR 19082
			endif;
		endif; // PAR 19082
		
		
		endX := self.adjustEndX(ti, startX); // PAR 16415

		if startX &gt; endX then// PAR 19082
			tmpX := startX;// PAR 19082
			startX := endX;// PAR 19082
			endX := tmpX;// PAR 19082
		endif;
		
		if fm &lt;&gt; null then
			// PAR 18970 added '-1', 
			// PAR 18970 - the FM was being added 1 pixel too big. When a note comes thru 4 the LC it removes everything within the LC's rectangle. 
			// PAR 18970 - This was not removing the FM cos it was 1 pixel too large. so take away the 1 pixel here so that the remove works.
			if self.gridObjectsGetAtKeyForPut(startX.Integer,_startY.Integer,endX.Integer,_endY.Integer - 1) = null then  // PAR 18682 CCMS 1055
// PAR 18970				self.notableFMArmNotes(fm);
			// PAR 18970 added '-1'
				self.gridObjectsPutAtKey(startX.Integer,_startY.Integer,endX.Integer,_endY.Integer - 1, fm);  // PAR 18682 CCMS 1055
			endif;
		elseif ti &lt;&gt; null then
			if self.gridObjectsGetAtKeyForPut(startX.Integer,_startY.Integer,endX.Integer,_endY.Integer) = null then  // PAR 18682 CCMS 1055
				self.gridObjectsPutAtKey(startX.Integer,_startY.Integer,endX.Integer,_endY.Integer, ti);  // PAR 18682 CCMS 1055
			endif;
		endif;
		
		self.drawFMLetter(theFMLetter,isFMP40,isFMQ40,isFMA40,startX,_startY,endX,_endY,_fillColour,theMode);// PAR 16415
	endif;
end;</source>
        <Parameter name="_displayMode" type="Integer"/>
        <Parameter name="_letterIndex" type="Integer"/>
        <Parameter name="_fillColour" type="Integer"/>
        <Parameter name="_startX" type="Real"/>
        <Parameter name="_startY" type="Real"/>
        <Parameter name="_endY" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doDrawFMLetterForTI" id="3e329cbf-5d5b-4a84-b654-5931d488d3d7">
        <source>doDrawFMLetterForTI(_frame: CMUI_GridAreaDrawingFrame; _ti : CM_TrackedItem; _backColour : Integer; _x1, _y1, _x2, _y2 : Real);
// ---------------------------------------------------------------------------
// Created:     01 September 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//PAR 19468 NEW
// ---------------------------------------------------------------------------

vars
	theFMLetter : String;
	fm : CM_FutureMove;
	theTIIndex : Integer;
	x1, x2, x3, y1, y2 : Real;
	theFrame	: CMUI_GridAreaDrawingFrame;
	oldBC  : Integer;
begin
	x1 := _x1;
	x2 := _x2;
	
	if x2 &lt; x1 then
		x3 := x1;
		x1 := x2;
		x2 := x3;
	endif;
	
	theFrame := _frame;
	
	if self.drawBackEnd then
		self.drawFMLetterGraphic(theFrame, theFMLetter, x1, _y1, x2, _y2,_backColour);
		self.drawBackendAttForFM(_ti, theFrame, _x1, _y1, _x2, _y2, Black);
		return;
	endif;
		
	
	if self.allTIsQ.includes(_ti) then
		theTIIndex:=self.allTIsQ.indexOf(_ti);
		theFMLetter := theFMLetter &amp; "Q";
		if self.allTIsP.includes(_ti) then
			theFMLetter := theFMLetter &amp; "P";	
		endif;
		_ti.getFMLetter(theFMLetter);
		fm := _ti.getFMforLC(self.myLocationsController, QUEUE_MODE);
	elseif self.allTIsP.includes(_ti) and not self.allTIsQ.includes(_ti) then
		theTIIndex:=self.allTIsP.indexOf(_ti);
		theFMLetter := theFMLetter &amp; "P";
		_ti.getFMLetter(theFMLetter);
		fm := _ti.getFMforLC(self.myLocationsController, PLANNING_MODE);
	elseif self.allTIsA.includes(_ti) then
		theTIIndex:=self.allTIsA.indexOf(_ti);
		theFMLetter := theFMLetter &amp; "A";
		_ti.getFMLetter(theFMLetter);
		fm := null;
	else
		return;
	endif;

	if theFMLetter &lt;&gt; null then
		if self.myDrawingFrame &lt;&gt; null then
			if fm &lt;&gt; null then
				if self.gridObjectsGetAtKeyForPut(x1.Integer,_y1.Integer,x2.Integer,_y2.Integer - 1) = null then  
					self.gridObjectsPutAtKey(x1.Integer,_y1.Integer,x2.Integer,_y2.Integer - 1, fm);  
				endif;
			elseif _ti &lt;&gt; null then
				if self.gridObjectsGetAtKeyForPut(x1.Integer,_y1.Integer,x2.Integer,_y2.Integer) = null then 
					self.gridObjectsPutAtKey(x1.Integer,_y1.Integer,x2.Integer,_y2.Integer, _ti);  
				endif;
			endif;
		endif;
		//epr par 30524 18/10/12
		self.drawBlankSpaceForOffsetFlexi(theTIIndex, x1,_y1,x2,_y2);
		
		self.drawFMLetterGraphic(theFrame, theFMLetter,x1,_y1,x2,_y2,_backColour);
	endif;
end;</source>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_backColour" type="Integer"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
    </JadeMethod>
