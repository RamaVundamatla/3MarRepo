    <JadeMethod name="getDisplayStringForAttribute" id="b3bd8d1d-5990-4287-98e6-d58b8329490f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     18 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	resourcePilot : HMS_ResourceForPilot;
begin		
	if _attrName = ETRow_MyHarbour then
		if self.myCurrentHarbour &lt;&gt; null then
			return self.myCurrentHarbour.description;
		else
			return null;
		endif;
	elseif _attrName = ETRow_MyArrivalResource then
	resourcePilot := self.allResourcesForPilot[self.myCurrentHarbour, self];
		if resourcePilot &lt;&gt; null and resourcePilot.myArrivalResource &lt;&gt; null then 
			return (resourcePilot.myArrivalResource.description);
		else 
			return null;
		endif;
		
	elseif _attrName = ETRow_MyDepartResource then
	resourcePilot := self.allResourcesForPilot[self.myCurrentHarbour, self];
		if resourcePilot &lt;&gt; null and resourcePilot.myDepartResource &lt;&gt; null then 
			return (resourcePilot.myDepartResource.description);
		else 
			return null;
		endif;
	elseif _attrName = ETRow_MyShiftResource then
	resourcePilot := self.allResourcesForPilot[self.myCurrentHarbour, self];
		if resourcePilot &lt;&gt; null and resourcePilot.myShiftResource &lt;&gt; null then 
			return (resourcePilot.myShiftResource.description);
		else 
			return null;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getResourceForHarbourMovement" id="4977e325-25fa-4678-b2c1-cd8a79bba4de">
        <source>getResourceForHarbourMovement(_harbour : HMS_Harbour; _movement : String) : HMS_Resource;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	realResource : HMS_Resource;
	resourcePilot : HMS_ResourceForPilot;
begin		
	if _harbour = null then
		return null;
	endif;
	
	resourcePilot := self.allResourcesForPilot[_harbour, self];
	if resourcePilot &lt;&gt; null then
		if _movement = HMSMovementTypeArrival then
			return resourcePilot.myArrivalResource;
		elseif _movement = HMSMovementTypeDeparture then
			return resourcePilot.myDepartResource;
		else
			return resourcePilot.myShiftResource;
		endif;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_movement" type="String"/>
        <ReturnType type="HMS_Resource"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="5cfa31bd-8863-4cbd-9b0a-6a95a1b9188b">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 22 July 2003
//
//----------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy 	:	HMS_Pilot;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	proxy.myRoot := self.myRoot;
	proxy.myCurrentHarbour := self.myCurrentHarbour;
		
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForDelete" id="f3e9329e-1941-4db7-b696-a745f074d9d3">
        <updating/>
        <source>setForDelete(_passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     04 March 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	resourceForPilot	: HMS_ResourceForPilot;
begin
	inheritMethod(_passport);
	foreach resourceForPilot in self.allResourcesForPilot do
		resourceForPilot.setForDelete(_passport);
		resourceForPilot.erase(NORMAL_ERASE);
	endforeach;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="1e534ec7-645e-4dd6-b59a-71618d51bba6">
        <updating/>
        <source>setForUpdate(_pxyPilot: HMS_Pilot; _passport: CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
// 03-JUL-2014  cnwma1 CCMS SFW1328 -HMS Not Available For Entry 
//--------------------------------------------------------------
vars
	tmpresoucesForPilot,
	resoucesForPilot	: HMS_ResourceForPilot;
begin
	inheritMethod(_pxyPilot, _passport);
	
	self.code 					:= _pxyPilot.code.toUpper.trimBlanks;
	self.description			:= _pxyPilot.description;
	self.myCurrentHarbour		:= _pxyPilot.myCurrentHarbour;
	self.isNotAvailableForEntry	:= _pxyPilot.isNotAvailableForEntry; 	//  cnwma1 3/7/2014   CCMS SFW 1328
	self.myRoot					:= _pxyPilot.myRoot;
	

	foreach tmpresoucesForPilot in self.allResourcesForPilot do
		tmpresoucesForPilot.setForDelete(_passport);
	endforeach;

	self.allResourcesForPilot.purge();
	
	foreach tmpresoucesForPilot in _pxyPilot.allResourcesForPilot do
		create resoucesForPilot persistent;
		resoucesForPilot.setPilot(self);
		resoucesForPilot.setForUpdate(tmpresoucesForPilot, _passport);
	endforeach;
		
end;</source>
        <Parameter name="_pxyPilot" type="HMS_Pilot"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="fce9ee51-62da-4da4-86a9-3126bccbf6f3">
        <updating/>
        <source>setProxy(_root	:	CM_Root; _harbour: HMS_Harbour) updating ;
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 22 July 2003
//
//----------------------------------------------------------

vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.myRoot := _root;
	self.myCurrentHarbour := _harbour;
end;</source>
        <Parameter name="_root" type="CM_Root"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="d3e7f15b-0581-41c2-a124-a4bf65f15951">
        <source>validateForDelete(_passport: CM_Passport input);
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 22 July 2003
//
//----------------------------------------------------------

vars

begin
	inheritMethod(_passport);
	if (not self.allVoyageMovements.isEmpty) then
		app.raiseCMException2(ObjectStillHasEntries, self.description, "Voyage Movement", null, null);	
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="83e917a4-a025-42bc-b0e7-e8ab9f1180c0">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 22 July 2003
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
//----------------------------------------------------------

vars
	tmpPilot	:	HMS_Pilot;
	
begin
	inheritMethod(_passport);
	
	if self.code = null then
	//	app.raiseCMException1( REQUIRED_FIELD, 'Code', ETRow_Code, null );
		app.raiseCMException( Input_required_field_code, ETRow_Code, null ); // cnwdb2	PAR 35364


	endif;
	
	if self.description = null then
	//	app.raiseCMException1( REQUIRED_FIELD, 'Description', ETRow_Description, null );
		app.raiseCMException( Input_required_field_desc, ETRow_Description, null ); // cnwdb2	PAR 35364


	endif;
	
	if self.myRoot = null then
	//	app.raiseCMException1( REQUIRED_FIELD , 'Harbour Root', null, null );
		app.raiseCMException( Input_required_field_harbRoot, null, null );

	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	tmpPilot := self.myRoot.allPilots.getAtKey(self.code);
	if tmpPilot &lt;&gt; null then
		if self.isTransient and tmpPilot &lt;&gt; self.pxyGetRealObject() then
			//app.raiseCMException2(DuplicateItem, 'Pilot', self.code, ETRow_Code, null); //14.06.2022 navds20 53760
			// Pilot already exists for %1 : Pilot_already_exists
			app.raiseCMException1(Pilot_already_exists, self.code, ETRow_Code, null); //14.06.2022 navds20 53760
		endif;
	endif;

epilog


end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
