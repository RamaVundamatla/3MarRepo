    <JadeMethod name="setProxy" id="5dabb663-a80c-4652-abca-006826462f18">
        <updating/>
        <source>setProxy(_structure: CM_Object;
		_code: String; 
		_desc: String; 
		_remarks: String; 
		_deckItemLayout: CM_DeckItemLayout; 
		_deck: CM_Deck; 
		_hasPower: Boolean; 
		_isRotatable: Boolean; 
		_isWaterCooled: Boolean; 
		_maxLoadPer20: Decimal; 
		_maxLoadPer40: Decimal; 
		_maxLoadTotal: Decimal; 
		_maxStackHeight: Decimal; 
		_numTiers: Integer; 
		_ordinal: Integer; 
		_orientation: Integer; 
		_voltageType: Integer; 
		_adjacentSlot: CM_ROROLocnDefn; 
		_deckLayerLayout: CM_DeckLayerLayout;
		_labelManChanged, _isOOTL : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	self.setCode( _code, false );
	self.description := _desc;
	self.remarks := _remarks;
	self.hasPower := _hasPower;
	self.isRotatable := _isRotatable;
	self.isWaterCooled := _isWaterCooled;
	self.maxLoadPer20 := _maxLoadPer20;
	self.maxLoadPer40 := _maxLoadPer40;
	self.maxLoadTotal := _maxLoadTotal;
	self.maxStackHeight := _maxStackHeight;
	self.numTiers := _numTiers;
	self.ordinal := _ordinal;
	self.orientation := _orientation;
	self.voltageType := _voltageType;
	self.myAdjacentSlotAft := _adjacentSlot;
	self.labelManuallyChanged := _labelManChanged;
	self.isOOTLLocn := _isOOTL;
	self.myDeck := _deck;
	self.myDeckLayerLayout := _deckLayerLayout;
	self.myLayout := _deckItemLayout;
	
	self.createProxySlots();
epilog

end;</source>
        <Parameter name="_structure" type="CM_Object"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
        <Parameter name="_deck" type="CM_Deck"/>
        <Parameter name="_hasPower" type="Boolean"/>
        <Parameter name="_isRotatable" type="Boolean"/>
        <Parameter name="_isWaterCooled" type="Boolean"/>
        <Parameter name="_maxLoadPer20" type="Decimal"/>
        <Parameter name="_maxLoadPer40" type="Decimal"/>
        <Parameter name="_maxLoadTotal" type="Decimal"/>
        <Parameter name="_maxStackHeight" type="Decimal"/>
        <Parameter name="_numTiers" type="Integer"/>
        <Parameter name="_ordinal" type="Integer"/>
        <Parameter name="_orientation" type="Integer"/>
        <Parameter name="_voltageType" type="Integer"/>
        <Parameter name="_adjacentSlot" type="CM_ROROLocnDefn"/>
        <Parameter name="_deckLayerLayout" type="CM_DeckLayerLayout"/>
        <Parameter name="_labelManChanged" type="Boolean"/>
        <Parameter name="_isOOTL" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyAdjacent" id="24c4c1c5-af1f-4a6f-a3a1-a2537c36124d">
        <updating/>
        <source>setProxyAdjacent(_aft, _fwd : CM_ROROLocnDefn input) updating;
/*
Purpose:			
Date		Who		Reason
05 May 2011	cnwab1	Initial creation
*/

vars

begin	
	if _fwd &lt;&gt; null then
		_fwd.myAdjacentSlotAft := null;
	endif;
	if _aft &lt;&gt; null then
		_aft.myAdjacentSlotFwd := null;
	endif;
	
	self.myAdjacentSlotAft := _aft;
	self.myAdjacentSlotFwd := _fwd;
epilog

end;</source>
        <Parameter name="_aft" type="CM_ROROLocnDefn" usage="input"/>
        <Parameter name="_fwd" type="CM_ROROLocnDefn" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyCode" id="e965219c-59ce-4aad-8898-f3944f6ceaf6">
        <updating/>
        <source>setProxyCode(_code : String) : Boolean updating;
/*
Purpose:			
Date		Who		Reason
05 May 2011	cnwab1	Initial creation
*/

vars
	
	slotDefn				: CM_ROROSlotDefn;
	idx						: Integer;

begin
	self.setCode( _code, false );

	self.myLayout.setProxyCode(_code);
	self.labelManuallyChanged := true;
	
	// 21/12/2011 cnwmh5 #28838
	foreach slotDefn in self.allROROSlotDefnByOrdinal do
		idx := idx + 1;
		slotDefn.setCode(_code &amp; idx.String);
	endforeach;
	
	return true;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyForCreateDefaults" id="71647668-7798-41d6-9263-a8b03f868e85">
        <updating/>
        <source>setProxyForCreateDefaults(_deckItemLayout: CM_DeckItemLayout; _adjacent: CM_ROROLocnDefn; _orientation : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	tmpDeck, realDeck : CM_Deck;
	tmpLayer : CM_DeckLayerLayout;
	ord, numT, idx  : Integer;
	maxH : Real;
	newCode  : String;
begin
	tmpLayer := _deckItemLayout.myDeckLayer;
	tmpDeck := tmpLayer.myDeckLayout.myDeck;
	realDeck := tmpDeck.pxyGetRealObject();
	
	numT := tmpDeck.numTier;
	if numT = 0 then
		numT := 1;
	endif;
	maxH := numT * HEIGHT_FULL_HIGH_CUBE;
	maxH := (maxH * 0.3048); // convert to metres
	

/*	PAR 27749
	ord := tmpDeck.allROROLocnDefnByOrdinal.size + realDeck.allROROLocnDefnByOrdinal.size + 1;
	// PAR 27595
	while true do : codeLoop
		newCode := _deckItemLayout.code &amp; ord.String;
		if tmpDeck.allROROLocnDefnByCode[newCode] &lt;&gt; null then
			ord := ord + 1;
		else
			break codeLoop;
		endif;
	endwhile;
	*/	
	// PAR 27749 Get Unique Ordinal and Code
	tmpDeck.getUniqueOrdCodeLocnDefn(_deckItemLayout.code, realDeck.allROROLocnDefnByOrdinal.size, newCode, ord);

	self.setProxy(null,newCode , _deckItemLayout.description, null, _deckItemLayout,tmpDeck , 
					false, //_hasPower : Boolean;
					true, //_isRotatable : Boolean; // PAR 29178
					false, //_isWaterCooled : Boolean;
					0, //_maxLoadPer20 : Decimal;
					0, //_maxLoadPer40 : Decimal;
					0, //_maxLoadTotal : Decimal;
					maxH, //_maxStackHeight : Decimal;
					numT, //_numTiers : Integer;
					ord, // _ordinal : Integer;
					_orientation,
					0, //_voltageType: Integer;
					_adjacent,
					tmpLayer, false, false);

epilog

end;</source>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
        <Parameter name="_adjacent" type="CM_ROROLocnDefn"/>
        <Parameter name="_orientation" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxyHazards" id="256ca2ce-43e8-45e3-8dd6-0e888ba6255c">
        <updating/>
        <source>setProxyHazards(_hazs : CM_HazardByCodeDict) updating;
/*
Purpose:			
Date		Who		Reason
05 May 2011	cnwab1	Initial creation
*/

vars
	pxyHaz : CM_ROROHazard;
	aHaz : CM_Hazard;
begin
	self.allHazardsAllowed.purge;
	
	foreach aHaz in _hazs discreteLock do

		create pxyHaz transient;
		pxyHaz.setProxy(aHaz, self);
	endforeach;
epilog

end;</source>
        <Parameter name="_hazs" type="CM_HazardByCodeDict"/>
    </JadeMethod>
