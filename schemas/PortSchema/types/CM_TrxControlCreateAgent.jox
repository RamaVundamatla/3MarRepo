    <JadeMethod name="trxCreateReportPDFEmailRequest" id="30a33a11-ef81-48ab-95e0-ef6e07bef09a">
        <updating/>
        <source>trxCreateReportPDFEmailRequest(_user			: CM_User;
								_terminal		: CM_Terminal;
								_emailTemplate	: CM_EmailTemplate;
								_reportDetail	: CMIF_JRWReportDetail;
								_carrierEmail	: CM_PINObjectDefaultEmail;
								_pinNo			: CM_PinNo;
								_passport		: CM_Passport input) updating;
// -------------------------------------------
// Created	Feb 2006	cnwjc2
// -------------------------------------------
vars
	tmpEvent		: Integer;
	item			: CM_Object;
	reportDetails	: CMIF_JRWReportDetail;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Perform the operation
	app.myUtilityCA.utlCreateReportPDFEmailRequest(_user, _terminal, _emailTemplate, _reportDetail);
	
	if _pinNo &lt;&gt; null 
	and _passport.noErrors then
		_pinNo.addRecipientEmails(_carrierEmail, false);
	
		// issue notifications to display changes
		tmpEvent := _passport.myTerminal.getTerminalEvent(TIEvent_PreNote_Update);
		foreach item in _pinNo.allItems do
			if item.isKindOf(CM_TrackedItem) then
				item.causeEvent(tmpEvent, false, item);
			endif;
		endforeach;
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_emailTemplate" type="CM_EmailTemplate"/>
        <Parameter name="_reportDetail" type="CMIF_JRWReportDetail"/>
        <Parameter name="_carrierEmail" type="CM_PINObjectDefaultEmail"/>
        <Parameter name="_pinNo" type="CM_PinNo"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
