    <JadeMethod name="xSetupDeck2_Voy4_30863" id="2c0fb843-d2c1-41b4-a15a-197c56889bd5">
        <updating/>
        <source>xSetupDeck2_Voy4_30863(_voyage : CM_Voyage io) updating;

/*

Purpose:		Setup the details for deck 2 which will be a load deck	

Date			Who		Reason
24/01/2013		cnwmh5	Initial creation

*/
constants

	BlockStackName				: String = "UTMHBS7";
	
vars
	
	roroStructure 				: CM_ROROVoyageStructure;
	deck						: CM_DeckVoyage;
	operator					: CM_Operator;
	voyageJob 					: CM_VoyageJob;
	bs							: CM_BlockStack;
	lc							: CM_LocationsController;
	job							: CM_Job;
	req 						: CM_Request;
	wle 						: CM_WorkListEntry;
	
	roroLCs						: CM_LCArray;
	slotsToDiscCC				: StringArray;
	itemsToDischarge			: StringArray;
	
	str							: String;

begin

	operator := app.myRoot.allOperators["MSL"];
	self.assertNotNull(operator);

	roroStructure := _voyage.myROROStructure;
	self.assertNotNull(roroStructure);
	
	deck := roroStructure.allDecksByCode["3"];
	self.assertNotNull(deck);

	bs := self.getTerminal().allTerminalAreas[BlockStackName].CM_BlockStack;
	self.assertNotNull(bs);
	
	create slotsToDiscCC transient;
	slotsToDiscCC.add("D30891R");
	slotsToDiscCC.add("D30821R");
	slotsToDiscCC.add("D3490O1R");
	slotsToDiscCC.add("D30741R");
	slotsToDiscCC.add("D31441R");
	slotsToDiscCC.add("D31431R");
	slotsToDiscCC.add("D31511R");
	slotsToDiscCC.add("D3484O1");
	slotsToDiscCC.add("D3482O1");
	slotsToDiscCC.add("D3476O1");
	slotsToDiscCC.add("D3493O1R");
	slotsToDiscCC.add("D3483O");
	
	create roroLCs transient;
	beginTransaction;
	foreach str in slotsToDiscCC do
		app.writeLog(str, LogINFO);
		lc := _voyage.getLocationByID(str);
		if lc &lt;&gt; null then
			lc.CM_ROROSlotController.createDefaultDischargeCC(app.myPassport, true);
			roroLCs.add(lc);
		endif;
	endforeach;
	commitTransaction;
	self.assertNoTrxErrorsOrWarnings();
	
	// create a dishcarge job
	voyageJob := self.addVoyageROROJob(_voyage, deck, "UT_30863Job2", roroLCs, true);
	self.assertNotNull(voyageJob);
	
	// discharge the following containers
	create itemsToDischarge transient;
	itemsToDischarge.add("MDHUT230109");
	itemsToDischarge.add("RORO1112230");
	itemsToDischarge.add("MDHUT230113");
		
	lc := bs.allLocationsControllers.first;
	
	foreach job in _voyage.allVoyageJobs do
		if not job.CM_VoyageJob.isDischarge then			// Discharge only
			continue;
		endif;
		
		foreach req in job.allRequests discreteLock do
			foreach wle in req.allWorkListEntries discreteLock do
				if wle.myTrackedItem &lt;&gt; null and itemsToDischarge.includes(wle.myTrackedItem.id) then
					self.movePlannedWLE(wle.myTrackedItem, lc, wle);
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	// discharge the containers
	self.opts.purge;
	self.opts.addAssoc("Sleep", 5000);
	self.opts.addAssoc("WPOpHrs", 2);	//10 Apr 2012	NDL	Par 29369.
	self.expectedTrxErrors.clear();
	self.moveAllCargoOnVoyage(_voyage, REAL_MODE);
	
	
epilog

	delete roroLCs;
	delete slotsToDiscCC;
	delete itemsToDischarge;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xSetupDeck3_30863" id="a24b176b-975f-4504-b3ce-0848c31f66ff">
        <source>xSetupDeck3_30863(_voyage : CM_Voyage; _cargoId : String; _cargoCount : Integer io);

/*

Purpose:		Create the various rotations and cargo for deck 3	

Date			Who		Reason
23/01/2013		cnwmh5	Initial creation

*/

vars

	roroStructure 				: CM_ROROVoyageStructure;
	deck						: CM_DeckVoyage;
	location					: CM_ROROLocnDefn;
	tempTI						: CM_TrackedItem;
	operator					: CM_Operator;
	
	tiArray						: CM_TIArray;
	locationArray				: StringArray;
	
	str							: String;

begin

	operator := app.myRoot.allOperators["MSL"];
	self.assertNotNull(operator);

	roroStructure := _voyage.myROROStructure;
	self.assertNotNull(roroStructure);
	
	deck := roroStructure.allDecksByCode["3"];
	self.assertNotNull(deck);
	
	// create the rotated non OOTL cells
	location := deck.allROROLocnDefnByCode['D3097'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 10, 2, true, app.myPassport, false);
	self.assertNoTrxErrorsOrWarnings();
	
	location := deck.allROROLocnDefnByCode['D3087'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 10, 2, true, app.myPassport, false);
	self.assertNoTrxErrorsOrWarnings();
	
	location := deck.allROROLocnDefnByCode['D3077'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 5, 1, true, app.myPassport, false);
	self.assertNoTrxErrorsOrWarnings();
	
	location := deck.allROROLocnDefnByCode['D3072'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 5, 1, true, app.myPassport, false);
	self.assertNoTrxErrorsOrWarnings();

	location := deck.allROROLocnDefnByCode['D3140'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 3, 1, true, app.myPassport, false);
	self.assertNoTrxErrorsOrWarnings();

	location := deck.allROROLocnDefnByCode['D3144'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 3, 1, true, app.myPassport, false);
	self.assertNoTrxErrorsOrWarnings();

	location := deck.allROROLocnDefnByCode['D3069'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 6, 2, true, app.myPassport, false);
	self.assertNoTrxErrorsOrWarnings();

	location := deck.allROROLocnDefnByCode['D3150'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 6, 2, true, app.myPassport, false);
	self.assertNoTrxErrorsOrWarnings();

	// create the non rotated OOTL cells - with cargo in	
	//roroStructure.createQuickCargoOOTL(null, true, 140.4, -10.6, deck, 1); 	
	self.createQuickCargoOOTL(roroStructure, location, true, 140.4, -10.6, deck, 1); 	
	self.assertNoTrxErrorsOrWarnings();
	
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, location, true, 140.4, -7.1, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, location, true, 140.4, 2.9, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, location, true, 146.2, 2.75, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
		
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, location, false, 154.4, -7.1, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
		
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, location, false, 138.8, 6.7, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, location, false, 144.2, 6.9, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	
	// create the non rotated OOTL cells - without cargo
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, location, false, 154.4, -3.6, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, location, true, 140.6, -3.5, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
		
	create tiArray transient;
	create locationArray transient;
	locationArray.add("D3488O");
	locationArray.add("D3486O");
	
	locationArray.add("D3478O");
	locationArray.add("D3480O");
	locationArray.add("D3482O");
	locationArray.add("D3483O");
	locationArray.add("D3485O");
	locationArray.add("D3484O");
	
	foreach str in locationArray do
		location := deck.allROROLocnDefnByCode[str];
		tiArray.clear();
		location.getAllTIs(REAL_MODE, tiArray, true);
		foreach tempTI in tiArray do
			self.deleteTrackedItem(tempTI, false);
		endforeach;		
	endforeach;
	
	// create rotated OOTL cells 
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, location, true, 99.6, 11.2, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, location, true, 107.6, 11.2, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
		
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, location, false, 108.7, 11.2, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, location, false, 111.2, 11.2, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, location, true, 95.2, 11.2, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, location, true, 91.2, 11.2, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	
	//roroStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(roroStructure, location, true, 87.3, 11.2, deck, 1); 
	self.assertNoTrxErrorsOrWarnings();
	
	tiArray.clear();
	locationArray.clear();
	
	locationArray.add("D3490O");
	locationArray.add("D3492O");
	locationArray.add("D3494O");
	locationArray.add("D3493O");
	locationArray.add("D3496O");
	locationArray.add("D3498O");
	locationArray.add("D3500O");
	locationArray.add("D3476O");
	
	foreach str in locationArray do
		location := deck.allROROLocnDefnByCode[str];
		tiArray.clear();
		location.getAllTIs(REAL_MODE, tiArray, true);
		foreach tempTI in tiArray do
			self.deleteTrackedItem(tempTI, false);
		endforeach;		
		if str = "D3476O" then
			continue;
		endif;
		app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 1, 1, false, app.myPassport, false);
		self.assertNoTrxErrorsOrWarnings();
	endforeach;
	
	// create 2200 containers at location
	locationArray.clear();
	locationArray.add("D3136");
	locationArray.add("D3493OR");
	locationArray.add("D3495O");
	locationArray.add("D3496OR");
	locationArray.add("D3498OR");
	locationArray.add("D3499O");
	locationArray.add("D3086R");
	locationArray.add("D3089R");
	locationArray.add("D3082R");
	locationArray.add("D3073R");
	locationArray.add("D3074R");
	locationArray.add("D3144R");
	locationArray.add("D3143R");
	locationArray.add("D3475O");
	locationArray.add("D3476O");
	locationArray.add("D3145R");
	locationArray.add("D3151R");
	
	locationArray.add("D3483O");
	locationArray.add("D3485O");
	locationArray.add("D3484O");
	
	foreach str in locationArray do
		location := deck.allROROLocnDefnByCode[str];
		self.xCreateCargoAtShipLocation(_cargoId &amp; _cargoCount.stringWithLeadingZeros(2), operator, "2200", _voyage, "NZAKL", location);
		_cargoCount := _cargoCount + 1;
	endforeach;
	
	// create 4200 containers at location
	locationArray.clear();
	locationArray.add("D3083R");
	locationArray.add("D3476O");
	locationArray.add("D3496OR");
	locationArray.add("D3141");
	locationArray.add("D3490OR");	
	
	locationArray.add("D3478O");
	locationArray.add("D3480O");
	locationArray.add("D3482O");
	
	foreach str in locationArray do
		location := deck.allROROLocnDefnByCode[str];
		self.xCreateCargoAtShipLocation(_cargoId &amp; _cargoCount.stringWithLeadingZeros(2), operator, "4200", _voyage, "NZAKL", location);
		_cargoCount := _cargoCount + 1;
	endforeach;
	
epilog

	delete tiArray;
	delete locationArray;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_cargoCount" type="Integer" usage="io"/>
    </JadeMethod>
