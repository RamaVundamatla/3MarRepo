    <JadeMethod name="getCarrier" id="8b9ffe8a-78f3-4473-be77-8a872b2553ed">
        <source>getCarrier():CM_Carrier;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2013	cnwndl1	Initial creation	Par 31393
12 Aug 2022 navtnr20 Bug 52451: MTN - WebServices not using getObjectOfTypeFromOid
*/

vars

	cm_Carrier : CM_Carrier;
	
begin

	//cm_Carrier := self.carrierFilter.asOid.CM_Carrier;		//12.08.2022 navtnr20 52451
	cm_Carrier := app.myPassport.getObjectOfTypeFromOid(self.carrierFilter,CM_Carrier).CM_Carrier;		//12.08.2022 navtnr20 52451
	return cm_Carrier;

epilog

end;</source>
        <ReturnType type="CM_Carrier"/>
    </JadeMethod>
    <JadeMethod name="getDriver" id="c76b0c4c-2a8b-40f1-8e91-0562beddb6ed">
