    <JadeMethod name="resetHandlingType" id="56de34cd-c5ef-4ab4-aa06-59ec55e8129f">
        <source>resetHandlingType(_constant : Constant; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     07 October 2002 by cnwth2
//
// Purpose:     If called as part of standard release, this 
//				MUST be called AFTER loading entTableEntities from globs  
//
// ----------   ----------  --------------------------------------------------
vars
	text,
	descr,
	className			: String;
	class				: Class;
	proxyHandlingType,
	realHandlingType	: CM_HandlingType;
	
begin
	if _constant.valueAsInteger &lt;= TI_HandlingType_Null or
	   _constant.valueAsInteger &gt;= TI_HandlingType_Max then
	   	return;
	endif;

	text := _constant.text;
	
	descr := text.cnEcGetTagValueOfName('Descr');
	if descr = null and _constant.valueAsInteger = TI_HandlingType_Max then
		// The maximum product type is not created.
		return;
	endif;
	
	if descr = null then
		app.raiseUnexpectedProgramError(class.name, method.name,
				'Invalid format for text for handling type constant (' &amp; _constant.name &amp; ')');
		return;
	endif;

	realHandlingType := self.allHandlingTypes[_constant.valueAsInteger];

	if realHandlingType = null then
		// treat as a create
		create proxyHandlingType transient;
		proxyHandlingType.setProxyFromXML(_constant.valueAsInteger, text, self);
		app.myUtilityCA.utlCreateHandlingType(proxyHandlingType, realHandlingType, _passport);
	else
		proxyHandlingType := app.createUpdateProxy(realHandlingType).CM_HandlingType;
		proxyHandlingType.setProxyFromXML(_constant.valueAsInteger, text, self);
		app.myUtilityUA.utlUpdateHandlingType(proxyHandlingType, _passport);
	endif;
	
epilog

	delete proxyHandlingType;
	
end;</source>
        <Parameter name="_constant" type="Constant"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
