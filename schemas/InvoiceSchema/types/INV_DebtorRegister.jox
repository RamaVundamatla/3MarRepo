    <JadeMethod name="doLstDataDblClick" id="41cc09d7-2d0a-4442-862f-11064a084424">
        <updating/>
        <source>doLstDataDblClick(listbox: ListBox input) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//13/09/17 jlgns1 TFS 6921 1201 : ADP Kernel stack overflow

vars
	theForm : INV_DebtorRegister;
begin
	inheritMethod(listbox);
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	
	theForm := self;
	listbox.itemExpanded[listbox.listIndex] := not listbox.itemExpanded[listbox.listIndex];
	self.myCurrentDebtorNode := listbox.itemObject[listbox.listIndex].CM_DebtorNode;
	if self.myCurrentDebtorNode.isKindOf(CM_RootDebtorGroup) then						//TFS 6921
		return;																			//TFS 6921
	endif;																				//TFS 6921
	
	self.myCurrentDebtorParent := self.myCurrentDebtorNode.myParentDebtorNode;
	
	if self.myCurrentDebtorNode.isKindOf(CM_Debtor) then
		self.modePropertyUpdate := self.MODEPROPERTY_DEBTOR; // + dh 20/11/2007 par 14447
		//self.showPropertyFrame(null, null,PROPHEIGHT);
		self.doUpdate();
	elseif self.myCurrentDebtorNode.isKindOf(CM_DebtorGroup) then
		self.modePropertyUpdate := self.MODEPROPERTY_GROUP;
		self.doUpdate();
	endif;

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
