    <JadeMethod name="setStringValue" id="79798f87-7987-41d0-863d-4c3c8275dc94">
        <source>setStringValue(_ediTI : CM_EDITrackedItem input; _propName, _value : String) protected;
/*
Date		Who		Reason
15 September 2008	cnwrd1	Initial creation

*/
vars
	origValue		: String;
	lenRemaining	: Integer;
	prop			: Attribute;
begin
	prop := _ediTI.class.getPropertyInHTree(_propName).Attribute;

	if prop  = null then
		return;
	endif;
	
	if prop.length &gt; 0 then//if it's a max length string the length integer value here will be -1
		//N.B the length integer value of a string attribute is always 1 more than what you see
		//in the IDE - hence the subtraction of 1 below
		_ediTI.setPropertyValue(_propName, _value[1:prop.length - 1]);
	else//it's max length
		_ediTI.setPropertyValue(_propName, _value);
	endif;
	

	
end;


</source>
        <access>protected</access>
        <Parameter name="_ediTI" type="CM_EDITrackedItem" usage="input"/>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
