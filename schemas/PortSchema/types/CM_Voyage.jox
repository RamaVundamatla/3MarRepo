    <JadeMethod name="setToDoTaskComplete" id="da920993-bdda-4a1d-aebe-b34f3ca22d76">
        <updating/>
        <source>setToDoTaskComplete(taskCode : Integer; _passport : CM_Passport input; _resourceUsageProxys : CM_ResourceTypeUsageSet; _wodtl: CM_WorkOrderToDoDtl) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
30 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen
19 May 2023			navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes
*/

vars
	task 				: CM_ToDoTask;
	found 				: Boolean;
	wod					: CM_WodToDoVoyage;
	eventType			: Integer;
	event, trans		: CM_Transaction;
	resourceUsageProxys	: CM_ResourceTypeUsageSet;
	tasksComplete		: Boolean;
	transType : CM_TransactionType;
begin
	tasksComplete := true;
	
	foreach task in self.allToDoTasksToDo where (task.toDoTaskDescCode = taskCode and _wodtl.allToDoTasks.includes(task)) do
		found := true;
		break;
	endforeach;
	
	create resourceUsageProxys transient;
	if _resourceUsageProxys &lt;&gt; null then
		_resourceUsageProxys.copy(resourceUsageProxys);
	endif;
	
	if found then
		wod := task.myWODetailToDo.CM_WodToDoVoyage;
		task.setToDoTaskComplete(_passport, resourceUsageProxys);
		task.CM_VoyageToDoTask.updateVoyageComplete();
		trans := wod.createWOTransaction(wod.TRANS_COMPLETED, resourceUsageProxys, task);	 // ### JIRA 23013 16OCT2024 NAVAB1
		
		// ### JIRA 14793 24OCT2024 NAVAB1
		transType := task.toDoTaskDesc.myTransactionType;
		if transType &lt;&gt; null and transType.isForWorkOrder()    then // WO Trans Type
			trans := wod.createWOTransactionUserDefined(transType.trxType, resourceUsageProxys, task);
		else
			eventType := task.getToDoTaskCompleteEventInt;	
			if eventType &lt;&gt; null then
				event := self.createTransaction(eventType, app.actualTime, resourceUsageProxys, task, wod); // ### TFS CR 57927 TASK 54268 22MAY2023 NAVAB1
				/*  // ### TFS CR 54345 TASK 54267 12JUN2023 NAVAB1
				if event &lt;&gt; null then															//19.5.2023 navhl20 #56631[56185]
					event.addResourcesFromProxys(resourceUsageProxys);
				endif;
				*/
			endif;
		endif;
		
		foreach task in self.allToDoTasksToDo do
			if task.myWODetailToDo = wod and task.status = STATUS_TODO then
				tasksComplete := false;	
			endif;
		endforeach;
		if tasksComplete then
			wod.allVoyagesActioned.remove(self);
			wod.allVoyagesCompleted.add(self);
		endif;
		self.updateObjectEdition(self);
	endif;

epilog
	delete resourceUsageProxys;
end;</source>
        <Parameter name="taskCode" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_resourceUsageProxys" type="CM_ResourceTypeUsageSet"/>
        <Parameter name="_wodtl" type="CM_WorkOrderToDoDtl"/>
    </JadeMethod>
