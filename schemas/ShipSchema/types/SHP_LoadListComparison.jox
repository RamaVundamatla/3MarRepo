	self.fldQuery.top		:=	self.frmQueryToolbar.clientHeight()+20;
	self.fldQuery.left		:=	0;
	self.fldQuery.height	:=	frmQuery.clientHeight() - (self.frmQueryToolbar.height + 30);
	self.fldQuery.width		:=	self.frmQuery.clientWidth();
	
end;
</source>
