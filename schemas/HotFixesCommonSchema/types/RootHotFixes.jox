    <JadeMethod name="getHotfixNoFromHotfixName" id="a76cb737-866f-4b6f-952f-573bc80f2cb8">
        <source>getHotfixNoFromHotfixName( _hotFixName : String ) : String;
/* ---------------------------------------------------------------------------
Created:	07 November 2008	by cnwvu1

Purpose:	returns 012 from 763Hotfix012
   
Change Date		Who		Reason
20/01/2011		cnwar2	Needed correction due to changing of constant LENGTH_OF_RELEASE_VERSION from 3 to 5
------------------------------------------------------------------------------*/
vars

begin

	//return _hotFixName[ _hotFixName.length - LENGTH_OF_RELEASE_VERSION +1 : _hotFixName.length ];
	return _hotFixName[ _hotFixName.length - LENGTH_OF_RELEASE_VERSION +3 : _hotFixName.length ];	// e.g.  "782Hotfix_023" =&gt; "023"

end;</source>
        <Parameter name="_hotFixName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getJAPCheckPatchString" id="ca0ac6a0-04c3-40c3-ad1a-92073a17b257">
        <source>getJAPCheckPatchString( _hotFixName : String ) : String;
/* ---------------------------------------------------------------------------
Created:	07 November 2008	by cnwvu1

Purpose:	returns JAPCHECKPATCH::7.6.1::001::NOERRORS - 001 is the No of previous hotfix
			or 		JAPCHECKPATCH::7.6.1::0::NOERRORS - 0 for the first hotfix nothing to check
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	s,
	strOut,
	strNo	: String;
	
begin

	strOut := self.JMT_INSTALL_JAPCHECKPATCH &amp; self.JMT_INSTALL_STR_SP;

	// adding JMT version no
	strOut := strOut &amp; self.getReleaseVersionForJAPInstall();

	// adding previous hotfix version No for checking patch installed previously
	strNo := self.getHotfixNoFromHotfixName(_hotFixName);
	if strNo.Integer = 1 then	// the first hotfix, no previous hotfix No to be checked
		strNo := "0";
		
	else	// cuyrrent hotfix No - 1
		s := (strNo.Integer - 1).String;
		s := s.padLeadingZeros(self.LENGTH_OF_PATCH);
		if s.length &gt; self.LENGTH_OF_PATCH then
			app.writeLogMessage(' Patch number ' &amp; s &amp; ' is too long. Constant LENGTH_OF_PATCH');
			app.raiseUnexpectedProgramError( class.name, method.name, ' Patch number ' &amp; s &amp; ' is too long. Constant LENGTH_OF_PATCH' );
			return null;
		endif;
		strNo := s;	// current No - 1
		
	endif;
	strOut := strOut &amp; JMT_INSTALL_STR_SP &amp; strNo;
	
	strOut := strOut &amp; JMT_INSTALL_STR_SP &amp; JMT_INSTALL_STR_NOERRORS;
	
	return strOut;

end;</source>
        <Parameter name="_hotFixName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getListOfActualFiles" id="a1ff0bf0-f588-4aca-99af-ba333e6ab9bb">
        <source>getListOfActualFiles( _dir, _mask: String; _dirPatch: FileFolder input; _filesList: FileNodeArray io; _clear: Boolean );
// gives allFiles - the list of files/dir from dirPatch.
// without xxx examples files/dir

vars
	oneFile	: FileNode;
	rt : RootHotFixes;
	
begin

	//_filesList.clear;
	rt := app.myRootHotFix;
	
	// TFS 38497 jlgmd1 12/10/2018
	if _clear then
		_filesList.clear;
	endif;
	
// check syntax
	if not _dirPatch.isValidPathName( _dir ) then
		app.writeLogMessage(' Directory is invalid - '&amp; _dir);
		return;
	endif;
	
	_dirPatch.mask := _mask;
	_dirPatch.fileName := _dir;
	if not _dirPatch.isAvailable then
		app.writeLogMessage(' Directory not found... '&amp; _dirPatch.fileName);
		return;
	endif;	
	
//	---- remove from list the xxx directory ----
	foreach oneFile in _dirPatch.files do
		if not ( oneFile.fileName.pos( rt.SAMPLE_DIR_BEGIN,1) &gt; 0 ) then
			_filesList.add(oneFile);
			app.writeLogMessage(' ' &amp; oneFile.fileName);
		endif;
	endforeach;

end;
</source>
        <Parameter name="_dir" type="String"/>
        <Parameter name="_mask" type="String"/>
        <Parameter name="_dirPatch" type="FileFolder" usage="input"/>
        <Parameter name="_filesList" type="FileNodeArray" usage="io"/>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getNewPatchNoFromLastPatch" id="0eeea198-f49b-4dd9-9f46-8597af07188c">
        <source>getNewPatchNoFromLastPatch( _allFiles: FileNodeArray; _newPatchNo: String output) : Boolean;
/* created by cnwvu1 on 11/03/2007

Need to find the bigest patch number among the files on a disk. 
For example, list on a disk:
	1000
	1001
	998
	999
If took the last in array, it would be 999. That is not right, the last is 1001 and new patch should be 1002*/

vars
	tmpFile			: FileNode;
	maxPatchNumber	: Integer;
	tmpPatchNumber	: String;
	tmpPatchNumberInt: Integer;
	pos				: Integer;
	
begin
	
	maxPatchNumber := 0;
	
	foreach tmpFile in _allFiles do
		pos := 1;
		tmpPatchNumber := tmpFile.name.scanUntil("_", pos);
		if (pos = 0) or (tmpPatchNumber.length &gt; self.LENGTH_OF_PATCH_MAX) then
			continue;
		endif;
		
		tmpPatchNumberInt := tmpPatchNumber.Integer;
		if tmpPatchNumberInt = 0 then
			continue;
		endif;
		
		if maxPatchNumber &lt; tmpPatchNumberInt then
			maxPatchNumber := tmpPatchNumberInt;
		endif;
	endforeach;
	
	_newPatchNo := (maxPatchNumber + 1).String; // new patch number is increased by 1
	_newPatchNo := _newPatchNo.padLeadingZeros(self.LENGTH_OF_PATCH);	// to add zeros if number is too small
	
	if _newPatchNo.length &gt; self.LENGTH_OF_PATCH_MAX then
		app.writeLogMessage(' Patch number ' &amp; _newPatchNo &amp; ' is too long. Constant LENGTH_OF_PATCH_MAX');
		_newPatchNo := null;
		return false;
	endif;
	
	return true;

end;
</source>
        <Parameter name="_allFiles" type="FileNodeArray"/>
        <Parameter name="_newPatchNo" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getPatchNoForNewPar" id="0689ef09-c85b-47d7-87c1-a7e290e3abcf">
        <source>getPatchNoForNewPar( _patchNo: String output; _releaseNo : String ) : Boolean;
// created by cnwvu1 on 11/03/2007
vars
	dirPatchTFS,
	dirHfTFS	: FileFolder;
	allFiles	: FileNodeArray;
	
begin
	create dirHfTFS transient;
	create dirPatchTFS transient;
	create allFiles transient;
	
	if not self.validDirectories( _releaseNo ) then // ------------------------- check ------------------
		return false;
	endif;
	
	app.writeLogMessage('');
	app.writeLogMessage(' List of Hotfixes currently with QA: ' &amp; self.getDirOfPatches());
	
	self.getListOfActualFiles( self.getDirOfPatches(), RootHotFixes.MASK_DIR_TFS, dirPatchTFS, allFiles, true );

	if allFiles.size = 0 then
		app.writeLogMessage(' empty...');
	endif;
	
	app.writeLogMessage('');
	app.writeLogMessage(" List of 'Released' Hotfixes: " &amp; self.getDirHotFixes());
	
	self.getListOfActualFiles( self.getDirHotFixes(), RootHotFixes.MASK_DIR_TFS, dirHfTFS, allFiles, false );
	
	if allFiles.size &gt; 0 then 
	
		if not self.getNewPatchNoFromLastPatch( allFiles, _patchNo ) then
			return false;
		endif;
		app.writeLogMessage('');
		
	else
	
		app.writeLogMessage(' empty...');
		app.writeLogMessage('');
				
		_patchNo := '1';
		_patchNo := _patchNo.padLeadingZeros(self.LENGTH_OF_PATCH);	// to add zeros according to format		
	
	endif;

	return true;
	
epilog
	delete dirHfTFS;
	delete dirPatchTFS;
	delete allFiles;	
end;
</source>
        <Parameter name="_patchNo" type="String" usage="output"/>
        <Parameter name="_releaseNo" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getReleaseVersionForJAPInstall" id="6349d7c0-c427-41da-83ef-e6ed4c3f035c">
        <source>getReleaseVersionForJAPInstall() : String;
/* ---------------------------------------------------------------------------
Created:	07 November 2008	by cnwvu1

Purpose:	returns string as 7.6.3 from 763
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	sVersion,
	s	: String;
	i	: Integer;

begin

	s		:= self.releaseVersionNo;

	// adding JMT version no
	sVersion := '';
	foreach i in 1 to s.length do
		
		if i &lt;= 2 then // number has one digit
			sVersion := s[s.length-i+1] &amp; "." &amp; sVersion;
			
		else	// number can have more than digit, when "10.2.1" for example
			sVersion := s[1:s.length-i+1] &amp; "." &amp; sVersion;
			break;
			
		endif;
		
	endforeach;
	
	return sVersion[ 1 : sVersion.length-1 ];	// removing the last dot "."

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReleaseVersionNo" id="7e6f780f-10e8-40db-9c96-9b3753bff8e1">
        <source>getReleaseVersionNo() : String;

vars

begin
	return self.releaseVersionNo;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReleaseVersionNoFromJMT" id="1dbdb0e3-9ae1-4344-a120-354861ab6ff2">
        <source>getReleaseVersionNoFromJMT() : String;

vars
	vers		: String;
	strReturn	: String;
	i			: Integer;
begin
	
	vers := CM_Version.VERSION;
	if vers = null then
		app.msgBox('JMT Version is null. Root hotFixes will be created with release version = null', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return null;
	endif;

//	vers := '7.5.1';
	strReturn := vers.removeString(".");
	
	if strReturn.length &gt; self.LENGTH_OF_RELEASE_VERSION then
		app.msgBox('JMT version ' &amp; strReturn &amp; ' is too long. Check constant RootHotFixes.LENGTH_OF_RELEASE_VERSION. RoothotFixes will be created with release version = null', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return null;
	endif;
	
	return strReturn;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initRootHotFixes" id="5d30381b-1db9-4e72-9a04-d1ad94d52a0d">
        <source>initRootHotFixes( _dirSetupHotFixes, _releaseVersionNo : String ) : Boolean;

vars
	rt	: RootHotFixes;
	dS	: String;
	
begin

	// to check the end of dir strings
	dS := _dirSetupHotFixes;
	if dS[ dS.length ] &lt;&gt; '\' then
		dS := dS &amp; '\';
	endif;

	
	rt := app.myRootHotFix;

	if not rt.isValidReleaseNo( _releaseVersionNo ) then
		return false;
	endif;
	
	beginTransaction;
	rt.set( dS, _releaseVersionNo );
	commitTransaction;

	return true;
	
end;
</source>
        <Parameter name="_dirSetupHotFixes" type="String"/>
        <Parameter name="_releaseVersionNo" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidParNo" id="299a320c-3384-4bc7-baff-e68a3b91d0f5">
        <source>isValidParNo( _par : String ) : Boolean;
/*--------  ----------  --------------------------------------------------
Created:	07 April 2007 By cnwvu1
Purpose:	to validate ParNo
----------  ----------  --------------------------------------------------
*/

vars
	
begin

	if _par.length = 0 then
		app.msgBox('Please input Par No.', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	
	if _par.length &lt;&gt; app.myRootHotFix.LENGTH_OF_PAR and
	   _par.length &lt;&gt; app.myRootHotFix.LENGTH_OF_TFS then
		app.msgBox('Incorrect length of par.', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	
	return true;
	
end;
</source>
        <Parameter name="_par" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
