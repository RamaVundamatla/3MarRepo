    <JadeMethod name="testPos" id="1c79a9b8-50e8-4cd6-9e61-b9e039f47bb6">
        <source>testPos();

vars

	string1,
	string2 : String;
	start,
	pos : Integer;

begin

	string1 := 'tommorrow';
	string2 := 'david am going to david tommorrow';
	start := string2.length - 9;
	pos :=  string2.pos(string1, start);
	write pos;
	write string2[pos: end];

end;</source>
    </JadeMethod>
