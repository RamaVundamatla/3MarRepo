        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2016	cnwrh7	Initial creation

*/

vars

begin
	self.permissionView	 := PmRTDeviceMaint;
	self.permissionMaint := PmRTDeviceMaintMaint; // TFS 2198
epilog

