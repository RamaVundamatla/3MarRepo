    <JadeMethod name="hidePillarsUnderGC" id="7fb4a2b6-e1e5-40dc-8377-4473c3f6c72a">
        <updating/>
        <source>hidePillarsUnderGC(_gcLayout : CM_DeckItemLayout) updating;
/*
Purpose:	only looking at container layers. OOTL are on seperate layer as are structures etc.		
Date		Who		Reason
21 July 2011	cnwab1	Initial creation
*/

vars
	itemLayout : CM_DeckItemLayout;
	deckItem : CM_DeckItem;
begin
	if self.type &lt;&gt; ROROLayerType_Structure then
		return;
	endif;
	foreach itemLayout in self.allDeckItemLayouts discreteLock do
		if not itemLayout.isPillar() then
			continue;
		endif;
		
		// is top left corner in the GC polygon?
		if _gcLayout.myPolygonPixels.isPointInPolygon(itemLayout.myPolygonPixels[1].x, itemLayout.myPolygonPixels[1].y,1)  
		or _gcLayout.myPolygonPixels.isPointInPolygon(itemLayout.myPolygonPixels[2].x, itemLayout.myPolygonPixels[2].y,1)  // PAR 28409
		or _gcLayout.myPolygonPixels.isPointInPolygon(itemLayout.myPolygonPixels[3].x, itemLayout.myPolygonPixels[3].y,1) 
		or _gcLayout.myPolygonPixels.isPointInPolygon(itemLayout.myPolygonPixels[4].x, itemLayout.myPolygonPixels[4].y,1) then  // PAR 28409  
			itemLayout.hideContainerPositionsUnderGC(_gcLayout); // HIDE
		else
			itemLayout.showAllCoveredPolygons(); // SHOW
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_gcLayout" type="CM_DeckItemLayout"/>
    </JadeMethod>
    <JadeMethod name="importFromXMLDocReference" id="e1c44211-a187-40a2-bb3d-5ef6948ac29e">
        <updating/>
        <source>importFromXMLDocReference(_property: Property; _xmlElement: JadeXMLElement input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 April 2011	cnwer1	Initial creation

*/

vars
	allDeckItemLayoutElements : JadeXMLElementArray;
	deckItemLayoutElement 	: JadeXMLElement;
	deckItemLayout 			: CM_DeckItemLayout;
begin
	if _property = CM_DeckLayerLayout::allDeckItemLayouts then
		create allDeckItemLayoutElements transient;
		_xmlElement.getAllElementsByTagName(CM_DeckItemLayout.name,allDeckItemLayoutElements);
		
		foreach deckItemLayoutElement in allDeckItemLayoutElements do
			create deckItemLayout transient;
			deckItemLayout.setMyDeckLayer(self);
			deckItemLayout.importFromXMLDoc(deckItemLayoutElement);
		endforeach;
	endif;
epilog
	delete allDeckItemLayoutElements;
end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isActualCargoLayer" id="a27a06a2-a4a8-469c-b3d9-5dff7bf24b2c">
        <source>isActualCargoLayer() : Boolean;
/*
Purpose:			
Date		Who		Reason
07 July 2011	cnwab1	Initial creation
*/

vars

begin
	return (self.type = ROROLayerType_GC or self.type = ROROLayerType_OOTL or self.type = ROROLayerType_Cargo or self.type = ROROLayerType_Lanes);
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isDefinable" id="8c2eb6ea-969b-4c23-a6d9-f078bc54c6df">
        <source>isDefinable() : Boolean;
/*
Purpose:			
Date		Who		Reason
07 July 2011	cnwab1	Initial creation
*/

vars

begin
	return (self.type = ROROLayerType_Structure or self.type = ROROLayerType_Cargo or self.type = ROROLayerType_Lanes);
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isPlanningRedrawable" id="272cf66d-d9f1-4167-a005-dc4277d80001">
        <source>isPlanningRedrawable() : Boolean;
/*
Purpose:			
Date		Who		Reason
07 July 2011	cnwab1	Initial creation
*/

vars

begin
	return (self.type = ROROLayerType_GC or self.type = ROROLayerType_OOTL or self.type = ROROLayerType_CCLoad or self.type = ROROLayerType_Lanes);
