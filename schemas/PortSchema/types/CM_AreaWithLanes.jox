    <JadeMethod name="getRowByNumber" id="bd198a9f-65ba-489b-84f6-aa83404ebc22">
        <source>getRowByNumber(_row :Integer):CM_GridRow protected;
// ---------------------------------------------------------------------------
// Created:     30 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.allGridRows.size &gt;= _row then
		return self.allGridRows[_row];
	endif;
	
	return null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="CM_GridRow"/>
    </JadeMethod>
    <JadeMethod name="getUnusedLaneCapacity" id="58238327-e821-4d2b-84a5-b71286015539">
        <source>getUnusedLaneCapacity():Integer;
// ---------------------------------------------------------------------------
// Created:     27 May 2010 by cnwcs5
// Purpose:     Get unsed capacity in lanes for the receiver
// Parameters:  None
// Returns:     -1	- if any lanes have unlimited capacity
//				0	- if all lanes full
//				number of spaces available
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	coll	:CM_LCArray;
	lc		:CM_LocationsController;
	lane	:CM_LaneController;
	count,
	size,
	capacity:Integer;
begin
	create coll transient;
	
	self.getAllLaneControllers (coll);
	
	foreach lc in coll do
		lane := lc.CM_LaneController;
		
		if lane.isUnavailable then
			continue;
		endif;
		
		if lane.capacity = 0 then
			// no limit on this lane
			return -1;
		endif;
		
		size 		:= lane.allVehicleMachines.size;
		capacity	:= lane.capacity;
		
		if size &lt; capacity then
			// still has room for more vehicles
			count := count + (capacity - size);
		endif;
	endforeach;
	
	return count;
epilog
	delete coll;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
