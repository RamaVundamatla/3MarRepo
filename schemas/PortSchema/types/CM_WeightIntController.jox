    <JadeMethod name="handleConnectionException" id="c559201f-1469-4c2e-938b-d81577685c6d">
        <updating/>
        <source>handleConnectionException(_connectionException : ConnectionException) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2016	cnwrh7	Initial creation

*/

vars

begin
	self.diagnosticLog(method.qualifiedName &amp; " errorCode=" &amp; _connectionException.errorCode.String &amp; " " &amp; "errorItem=" &amp; _connectionException.errorItem &amp; " " &amp; "extendedErrorText=" &amp; _connectionException.extendedErrorText);
	
	self.raiseWeightICException(_connectionException.errorCode,"Failed to connect with error " &amp; _connectionException.errorCode.String &amp;  " - " &amp; _connectionException.errorItem &amp; " " &amp; _connectionException.extendedErrorText &amp; " ");
	
	//return Ex_Pass_Back;
	return Ex_Abort_Action;
epilog

end;</source>
        <Parameter name="_connectionException" type="ConnectionException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initializeWithSerialDetails" id="db58a342-78ca-4bb0-86b3-a1b614f85321">
        <updating/>
        <source>initializeWithSerialDetails(_serialDetails : CM_WinCEJadeSerialDetails) updating;
// --------------------------------------------------------------------------------
// Created:		25 May 2010 by cnwjo3
//
// Purpose:		set up the JadeSerialPort connection
//
/*

Date		Who		Reason
01 Jul 2010	cnwkpd1	PAR #24858 - save reference to persistent serial details for close/open of port if required
19 Apr 2016	cnwkpd1	TFS 1870 - Set minimum effective timeout to ensure proper response from
					the JadeSerialPort
					
*/

constants
	MinTimeout		= 500;
	
vars
	serialConnection : JadeSerialPort;
begin
//	self.diagnosticLog(method.qualifiedName &amp; " mySerialPort=" &amp; self.mySerialPort.String &amp; " listeningState=" &amp; self.listeningState.String);
	
	if self.myConnection &lt;&gt; null then
		if self.listeningState = self.Listening then
			self.raiseWeightICException(0,"Attempting to initialize but you are listening");
			return;
		else
			delete self.myConnection;
		endif;
	endif;
	create self.myConnection as JadeSerialPort transient;
	serialConnection:=self.myConnection.JadeSerialPort;
	serialConnection.dataBits := _serialDetails.dataBits;
	serialConnection.fillReadBuffer := true;
	serialConnection.flowControl := _serialDetails.flowControl;
	serialConnection.name := _serialDetails.portName;
	serialConnection.parity := _serialDetails.parity;
	if _serialDetails.speedBps &lt;&gt; 0 then
		serialConnection.speedBps := _serialDetails.speedBps;
	endif;
	serialConnection.stopBits := _serialDetails.stopBits;
	serialConnection.timeout := (_serialDetails.timeout ).max(MinTimeout);	// TFS 1870 this timeout is already in milliseconds
	self.diagnosticLog(method.qualifiedName &amp; " timeout set to " &amp; serialConnection.timeout.String);
	serialConnection.usePresentationClient := true;  //make sure this is always true
	
	if not _serialDetails.isTransient then
		self.mySerialDetails := _serialDetails;
	endif;
	
	self.listeningState := self.NotListening;
	
	self.diagnosticLog(method.qualifiedName &amp; " mySerialPort=" &amp; serialConnection.String &amp; " listeningState=" &amp; self.listeningState.String);
end;</source>
        <Parameter name="_serialDetails" type="CM_WinCEJadeSerialDetails"/>
    </JadeMethod>
    <JadeMethod name="initializeWithTcpDetails" id="86e1afb1-309c-46c9-8cd1-43a54ea68182">
        <updating/>
        <source>initializeWithTcpDetails(_tcpDetails: CM_DeviceTCPConnectionDetails) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2016	cnwrh7	Initial creation

*/
constants
		MinTimeout = 500;
vars
		
begin
		
		
	if self.myConnection &lt;&gt; null then
		self.diagnosticLog(method.qualifiedName &amp; " myTCPDetails=" &amp; self.myConnection.String &amp; " connectingState=" &amp; self.myConnection.state.String);
		if self.myConnection.state = Connection.Connecting then
				self.raiseWeightICException(0,"Attempting to initialize but you are connecting");
				return;
			else
				delete self.myConnection;
		endif;
	endif;
	
	//setting TCP Connection Details to get ready
	create self.myConnection as TcpIpConnection transient;
	
	self.myConnection.name := _tcpDetails.tcpAddress;
	self.myConnection.TcpIpConnection.port := _tcpDetails.tcpPortNumber;
	self.myConnection.timeout := (_tcpDetails.tcpTimeOut * 1000); //epr TFS 46353 this timeout is in seconds
	self.myConnection.TcpIpConnection.usePresentationClient := _tcpDetails.useTCPPresentationClient;
	
	//if not _tcpDetails.isTransient then
	self.myTCPDetails := _tcpDetails;
	//endif;


	self.diagnosticLog(method.qualifiedName &amp; " myTCPDetails=" &amp; self.myConnection.String &amp; " connectingState=" &amp; self.myConnection.state.String);
epilog

end;</source>
        <Parameter name="_tcpDetails" type="CM_DeviceTCPConnectionDetails"/>
    </JadeMethod>
    <JadeMethod name="initializeWithWeighbridge" id="56d8dc5b-e9b2-4f76-8af3-738a00803451">
        <updating/>
        <source>initializeWithWeighbridge(_weighBridge : CM_WeighBridgeObj) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2019	jlger1	Initial creation

*/

vars
	tcpDetails : CM_DeviceTCPConnectionDetails;
begin
	if _weighBridge = null then
		return;
	endif;
	self.myWeighBridge:=_weighBridge;
	
	if _weighBridge.mySerialDetails &lt;&gt; null  then
		self.initializeWithSerialDetails(_weighBridge.mySerialDetails);
	else
		create tcpDetails transient;
		tcpDetails.setProxy(_weighBridge.ipAddress,_weighBridge.portNumber,_weighBridge.timeOutSeconds,null,false);
		
		self.initializeWithTcpDetails(tcpDetails);
		
	endif;
epilog

end;</source>
        <Parameter name="_weighBridge" type="CM_WeighBridgeObj"/>
    </JadeMethod>
    <JadeMethod name="isOkToDelete" id="bf818bd5-8957-4726-b07a-32bb6de8e42b">
        <source>isOkToDelete() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 March 2019	jlger1	Initial creation

*/

vars

begin
	// If there is no serial port object then it is OK
	if self.myConnection = null then
		return true;
	endif;
	
	// If we're not listening or in a Pending Delete state then it is OK
	return self.listeningState = self.NotListening or 
		   self.listeningState = self.PendingDelete;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="openEvent" id="7fd9fef8-bb8b-4347-9590-710c7817d9f4">
        <updating/>
        <source>openEvent(_connection : Connection) updating, protected;
// --------------------------------------------------------------------------------
// Created:		26 May 2010 by cnwjo3
//
// Purpose:		serial port is open.  now start reading
//
constants
	Carriage : Binary =	#[0d];// 11/3/16  cnwns1 PAR 36286 unicode version
vars

begin
	self.diagnosticLog(method.qualifiedName &amp; " mySerialPort=" &amp; self.myConnection.String &amp; " listeningState=" &amp; self.listeningState.String);
	
	self.listeningState := self.Listening;
	self.myConnection.readUntilAsynch(Carriage,1000,self,CM_WeightIntController::readEvent.name);
end;</source>
        <access>protected</access>
        <Parameter name="_connection" type="Connection"/>
    </JadeMethod>
    <JadeMethod name="raiseWeightICException" id="87dc2783-dd2e-439c-9e03-c683cd89819f">
        <source>raiseWeightICException(_exceptionCode : Integer; _exceptionData : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2016	cnwrh7	Initial creation

*/

vars

begin
	app.writeLog("CM_TCPWeightInterfaceController: " &amp; _exceptionCode.String &amp; " " &amp; _exceptionData,0);
	if self.myWeightCallerInterface &lt;&gt; null then
		self.myWeightCallerInterface.handleWeightICException(_exceptionCode,_exceptionData);
	endif;
end;

</source>
        <Parameter name="_exceptionCode" type="Integer"/>
        <Parameter name="_exceptionData" type="String"/>
    </JadeMethod>
    <JadeMethod name="readEvent" id="da11c9ed-baaf-4a79-8052-d85a6e580b28">
        <updating/>
        <source>readEvent(_connection : Connection; _binaryData : Binary) updating, protected;
// --------------------------------------------------------------------------------
// Created:		26 May 2010 by cnwjo3
//
// Purpose:		some data has been received on the serial port.  parse to commandParser and continue reading
//
/*

Date		Who		Reason
19 Apr 2016	cnwkpd1	TFS 1870 - Check for PendingClose state and initiate a close if required
	
*/

constants
	Carriage : Binary =	#[0d];// 11/3/16  cnwns1 PAR 36286 unicode version
vars
	weight : Decimal[16,4];
begin
	self.diagnosticLog(method.qualifiedName &amp; " mySerialPort=" &amp; self.myConnection.String &amp; " listeningState=" &amp; self.listeningState.String);

	weight:=self.getWeight(_binaryData);
	if weight &lt;&gt; null then
		self.myWeightCallerInterface.sendWeight(weight);
	endif;
	
	if self.listeningState = self.PendingClose then
		self.myConnection.closeAsynch(self,CM_WeightIntController::closeEvent.name);
		return;
	endif;	
	
	self.myConnection.readUntilAsynch(Carriage,1000,self,CM_WeightIntController::readEvent.name);
end;</source>
        <access>protected</access>
        <Parameter name="_connection" type="Connection"/>
        <Parameter name="_binaryData" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="setWeightCallerInterface" id="2ed07399-873d-4c7f-98cb-c0af1e1c665e">
        <updating/>
        <source>setWeightCallerInterface(_weightCallerInterface : IF_TCPWeightCallerInterface) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2016	cnwrh7	Initial creation

*/

vars

begin
	self.myWeightCallerInterface := _weightCallerInterface;
	

epilog

end;</source>
        <Parameter name="_weightCallerInterface" type="IF_TCPWeightCallerInterface"/>
    </JadeMethod>
    <JadeMethod name="startListening" id="f73e7d2c-5c05-4295-9a9e-e6ce917de83d">
        <updating/>
        <source>startListening() updating;
// --------------------------------------------------------------------------------
// Created:		26 May 2010 by cnwjo3
//
// Purpose:		open connection to serial port and start reading (in open event)
//
/*

Date		Who		Reason
19 Apr 2016	cnwkpd1	TFS 1870 - Check for PendingDelete state, and create a new connection if
					this is set
	
*/

vars

begin
	if self.mySerialDetails = null then
		return;
	endif;
	
	self.diagnosticLog(method.qualifiedName &amp; " mySerialPort=" &amp; self.myConnection.String &amp; " listeningState=" &amp; self.listeningState.String);
	
	if self.listeningState = self.PendingDelete then
		self.initializeWithSerialDetails(self.mySerialDetails);
	endif;
	
	if not self.connectedState() and self.myWeightCallerInterface &lt;&gt; null and self.listeningState = self.NotListening then
		self.myConnection.openAsynch(self,CM_WeightIntController::openEvent.name);
	else
		self.raiseWeightICException(0,"Start Listening failed.  ConnectedState: " &amp; self.connectedState.String &amp; " callBackReady: " &amp; (self.myWeightCallerInterface &lt;&gt; null).String &amp; " Listening State: " &amp; self.listeningState.String);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="stopListening" id="13c0562e-40e4-4e6f-a7e7-980b2d8de976">
        <updating/>
        <source>stopListening() updating;
// --------------------------------------------------------------------------------
// Created:		26 May 2010 by cnwjo3
//
// Purpose:		close connection and reset JadeSerialPort connection for possible startListening again
//
/*

Date		Who		Reason
19 Apr 2016	cnwkpd1	TFS 1870 - If we're in Listening state, then we have an outstanding readAsynch, so
					just set the listeningState to PendingClose and let the next read callback initiate
					the close

*/

vars

begin
	if self.mySerialDetails = null then
		return;
	endif;
	
	self.diagnosticLog(method.qualifiedName &amp; " mySerialPort=" &amp; self.myConnection.String &amp; " listeningState=" &amp; self.listeningState.String);

	if self.connectedState() and self.listeningState = self.Listening then
		self.listeningState := self.PendingClose;
	else
		self.raiseWeightICException(0,"Stop Listening failed.  ConnectedState: " &amp; self.connectedState.String &amp; " Listening State: " &amp; self.listeningState.String);
	endif;
end;</source>
    </JadeMethod>
</Class>
