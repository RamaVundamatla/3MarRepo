    <JadeMethod name="autoPlan" id="125ea2a1-5cc7-4ead-aff2-ebb095ab1084">
        <source>autoPlan(obj : CMIF_AutoMovePlan input);
//This method is called by a method of the SAME NAME on CM_MovePlan.
//We are looking for a planned location for the TI in the obj reference.
vars
	attribArea : CM_AttributeArea;
	isGridArea :Boolean;
	extraMsg : String;
	autoStackDir	:	Integer;
	attribAreaIndex	:	Integer;
begin
	attribAreaIndex := 1;
	if obj.prevAutoPlanAAToStartFrom &lt;&gt; null then
		attribAreaIndex := self.attributeAreas.indexOf(obj.prevAutoPlanAAToStartFrom);
		if attribAreaIndex &lt;= 0  then
			//------------
			//Cant find it, set to 1st.
			//------------
			attribAreaIndex := 1;
		endif;
	endif;
	//------------------
	//Loop throught the attribute areas
	//------------------
	while attribAreaIndex &lt;= attributeAreas.size do
		attribArea := self.attributeAreas[attribAreaIndex];
 		//------------
 		//Ask each attributeArea to check itself!
 		//------------
		//-----------------
		//Ask area for an autoplan
		//-----------------
		attribArea.autoPlan(obj);

		if obj.getController &lt;&gt; null then
			obj.prevAutoPlanAAToStartFrom := attribArea;
			//-------------
			//FOUND 1!!!!
			//-------------
			return;
		endif;
		attribAreaIndex := attribAreaIndex +1;
 	endwhile;
end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="autoPlanRequest" id="b8e3989d-5603-4455-b157-d33e233de697">
        <source>autoPlanRequest(obj : CMIF_AutoMovePlan input);
//This method is called by a method of the SAME NAME on CM_MovePlan.
//We are looking for a target location for a request
vars
	attribArea : CM_AttributeArea;
	isStraddle :Boolean;
	sortedAreas	:	CM_AttributeAreasArray;
	searchAreas	:	CM_AttributeAreasArray;
	otherAreas	:	CM_AttributeAreasArray;
	aStr	:	String;
begin
	//-----------------
	//For requests, they may want to use FIFO, call method to
	//arrange what we have by FIFO
	//-----------------
	create sortedAreas transient;
	create otherAreas transient;
	self.sortAttributeAreasByFIFO(otherAreas, sortedAreas);

	if sortedAreas.isEmpty = false then
		searchAreas := sortedAreas;
		otherAreas.copy(searchAreas);	//Add these ones as well, they are non-fifo's	
		//obj.addLogEntry("Using " &amp; sortedAreas.size.String &amp; " FIFO Sorted Areas", IsForLogging ); //- cnwmd1, Par 20524
		obj.addLogEntry(app.getErrorString1(Using_fifo_sorted_areas, sortedAreas.size.String), IsForLogging, Using_fifo_sorted_areas );
		if app.verboseLogging then
			//aStr := "The Sorted Areas are: "; //- cnwmd1, Par 20524
			aStr := null;
			foreach attribArea in sortedAreas do
				aStr := aStr &amp; attribArea.restrictedTermAreaId.trimRight &amp; " ";
			endforeach;
			//obj.addVerboseLogEntry(aStr, IsForLogging); //- cnwmd1, Par 20524
			obj.addVerboseLogEntry(app.getErrorString1(Sorted_areas,aStr), IsForLogging, Sorted_areas);
		endif;
	else
		//---------------
		//There are no FIFO requirements, use standard areas
		//---------------
		searchAreas := self.attributeAreas;
		//obj.addVerboseLogEntry("NO FIFO Areas found. Using standard search sequence.", IsForLogging ); //- cnwmd1, Par 20524
		obj.addVerboseLogEntry(app.getErrorString(Fifo_areas_found_using_stand_s), IsForLogging, Fifo_areas_found_using_stand_s);
	endif;

	foreach attribArea in searchAreas do
 		//------------
 		//Ask each attributeArea to check itself!
 		//------------
		//obj.addLogEntry("Testing Terminal Area " &amp; attribArea.restrictedTermAreaId , IsForLogging);
		obj.addLogEntry(app.getErrorString1(Testing_terminal_area, attribArea.restrictedTermAreaId) , IsForLogging, Testing_terminal_area);

		attribArea.autoPlanRequest(obj);
		
		if obj.getController &lt;&gt; null then
			//-------------
			//FOUND 1!!!!
			//-------------
			return;
		endif;
 	endforeach;
 epilog
 	//---------------
 	//The sortAttributeAreasByFIFO method creates a transient returned for processing.
 	//Clean it up here...
 	//---------------
	delete sortedAreas;
	delete otherAreas;
end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
