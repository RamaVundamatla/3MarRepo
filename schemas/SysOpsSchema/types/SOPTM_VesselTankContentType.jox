    <JadeMethod name="setupThumbnailDetails" id="bb5aaa1c-09d4-4590-9297-a0de27a7c8a8">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 April 2011	cnwer1	Initial creation

*/

vars
	theForm : SOP_TableMaintForm;
begin		

	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_VesselTankContentType);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_VesselTankContentType);
	theForm.shtTblInput1.visible := true;
	
epilog

end;</source>
    </JadeMethod>
