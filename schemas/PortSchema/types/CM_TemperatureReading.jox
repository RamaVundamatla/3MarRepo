    <JadeMethod name="cloneForTrackedItemRefs" id="0c2f7f3d-4e0b-47b7-a3a9-27f55a3854a2">
        <updating/>
        <source>cloneForTrackedItemRefs(_ti: CM_Container; _orginalTransaction: CM_TemperatureReading) updating, protected;
//--------------------------------------------------
// Created:	23 April 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_ti, _orginalTransaction);
	self.myTempReading := _orginalTransaction.myTempReading.cloneSelf(self.isTransient);
	self.myTempReading.cloneForTrackedItemRefs(_ti, _orginalTransaction.myTempReading.myRefConRawData);
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_Container"/>
        <Parameter name="_orginalTransaction" type="CM_TemperatureReading"/>
    </JadeMethod>
    <JadeMethod name="getCCEventProperties" id="9de98c78-1e12-40db-81e3-623966f6aff1">
        <source>getCCEventProperties( ccEvent : CMIF_CCEvent) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 August 2019	jlger1	Initial creation

*/

vars
	temp	: CM_TempReading;
begin
	inheritMethod(ccEvent);
	
	temp:=self.myTempReading;
	
	if temp &lt;&gt; null then
		ccEvent.addTemperature("temperature",temp.getTemperatureValue.asStringJMT);
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="ccEvent" type="CMIF_CCEvent"/>
    </JadeMethod>
    <JadeMethod name="getCCEventType" id="ccc48ebd-9c1b-4bd0-a5f8-faa34ebc28fb">
        <source>getCCEventType(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2019	jlger1	Initial creation

*/

vars

begin
	return CC_EventType_TempRead;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="3f8ea19a-deab-4a19-84c6-a2de4740c607">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
	temp	: CM_TempReading;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			temp := self.myTempReading;
			if temp &lt;&gt; null then
				lDetail := temp.getDisplayTemp;
			endif;
			return lDetail;
			
		endif;

	elseif _attrName = ETRow_TransTemperature then
		temp := self.myTempReading;
		if temp &lt;&gt; null then
			lDetail := temp.getDisplayTemp;
		endif;
		return lDetail;
	
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="9a8cc7fd-0700-40df-b56e-457aa7111eab">
        <source>getEnquiryRow(): String;
// ---------------------------------------------------------------------------
// Created:		09 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	lDetail : String;
	temp	: CM_TempReading;
	ti		: CM_Container;
begin
	lDetail := inheritMethod();
	temp := self.myTempReading;
	if temp &lt;&gt; null then
		lDetail := lDetail &amp; " " &amp; temp.getDisplayTemp;
	endif;
epilog
	return lDetail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="ca48c04f-47fe-45e3-bd05-05f0a8b65138">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		10 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	
	
	self.setTempReading(_tiTransCntrl.CMIF_TempTransController.myTempReading);
	inheritMethod(_tiTransCntrl, _passport);

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTempReading" id="40c7de38-fa61-4ad1-bb29-d901fc8f1bbd">
        <updating/>
        <source>setTempReading(_tempReading:CM_TempReading) updating;

vars

begin
	self.myTempReading := _tempReading;
end;</source>
        <Parameter name="_tempReading" type="CM_TempReading"/>
    </JadeMethod>
</Class>
