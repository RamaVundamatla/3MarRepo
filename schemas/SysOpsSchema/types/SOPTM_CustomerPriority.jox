end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="06190855-f718-49c2-b08a-b69c0d9f4d39">
        <source>setupThumbnailDetails();
//-----------------------------------------
//
// Created : by cnwaer1 19 August 2008
//-----------------------------------------
vars
	theForm : SOP_TableMaintForm;
begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	
	theForm.setTblDataEntRows(ETDef_CustomerPriorityMaint);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_CustomerPriorityMaint);
	theForm.shtTblInput1.visible := true;

	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="e77a4bfc-5683-43fb-bbd1-9a3515d6ff72">
        <updating/>
        <source>showThumbnail(pCustomerPriority : CM_CustomerPriority) updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
19/11/2023	jlika1	TFS 61128 61013 CUX | System Admin - Customer Priority
============================================================================*/
vars
	theForm : SOP_TableMaintForm;
begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Code, pCustomerPriority.code);
	theForm.tblInput1.setValueByName(ETRow_Description,	pCustomerPriority.description);
	theForm.tblInput1.setValueByName(ETRow_Priority,	pCustomerPriority.priority);
end;</source>
        <Parameter name="pCustomerPriority" type="CM_CustomerPriority"/>
    </JadeMethod>
</Class>
