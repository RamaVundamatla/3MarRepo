    <JadeMethod name="construct" id="21d7b583-ca5a-48bb-b55c-88249b51161b">
        <updating/>
        <source>construct(_test: Method; _passed: Boolean; _ignored: Boolean; _elapsedTime: TimeStampInterval; _errorText: String; _blame : UM_Blame; _doPersist : Boolean; _unitTest : UT_UnitTest; _byTeam : Boolean) updating;
//24 April 2009	cnwdw1	
//
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// 25/03/2025	navcs2 	MTN-34203
// 28/04/2025	navpw1	MTN-34203 - Owner was not being set correctly on transient UT_TestResult for by team scenario these are used for reports.
// 16 Oct 2025	navbs1	Initial creation Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2
vars
	pos: Integer;
	linePos: Integer;
	line, token: String;
	tokens : StringArray512;
	unitTestResult : UM_UnitTestResult;
	result : String;
	methodsCalled	: StringArray;
	pos2				: Integer;
	root				: UM_Root;
	classMethod : UM_UnitTestClassMethod;
begin
	pos := 1;
	self.testClass := _test.qualifiedName().cnEcNextDelimitedField(":", pos);
	self.testMethod := _test.name;
	
	// Get The test owner by looking in comments at start of method
	create tokens transient;
	
	linePos := 1;
	_test.getSource.cnEcGetNextLine(linePos);
	while linePos &gt; 0 do
		line :=  _test.getSource.cnEcGetNextLine(linePos);
		if (line[1:9] = 'constants' and line.trimBlanks().length = 9) or 		// 30/03/2011 cnwmh5
				(line[1:4] = "vars" and line.trimBlanks().length = 4) then
			break;
		endif;
		line.replaceChar(Tab, ' ');
		tokens.clear;
		line.getTokensForDelimiter(" ", tokens);
		foreach token in tokens do
			///if token &lt;&gt; null and token[1:3].toUpper = "CNW" then
			///	self.owner := token;
			// 06/09/2017 jlgmh5 rewrite to handle new jlg user names
			/*
			if token &lt;&gt; null and token.toUpper().cnContains("CNW") then							// 10/09/2013 cnwmh5
				pos2 := token.toUpper().pos("CNW", 1);
				self.owner := token.toLower().scanWhile('abcdefghijklmnopqrstuvwxyz0123456789', pos2);
				linePos := 0;
				break;
			endif;
			//*/
			if token &lt;&gt; null and token.toUpper().cnContains("CNW") then							// 10/09/2013 cnwmh5
				pos2 := token.toUpper().pos("CNW", 1);
				self.owner := token.toLower().scanWhile('abcdefghijklmnopqrstuvwxyz0123456789', pos2);
				linePos := 0;
				break;
			endif;
			if token &lt;&gt; null and token.toUpper().cnContains("JLG") then							// 10/09/2013 cnwmh5
				pos2 := token.toUpper().pos("JLG", 1);
				self.owner := token.toLower().scanWhile('abcdefghijklmnopqrstuvwxyz0123456789', pos2);
				linePos := 0;
				break;
			endif;
			if token &lt;&gt; null and token.toUpper().cnContains("JLI") then	 // 05JAN2024 NAVAB1
				pos2 := token.toUpper().pos("JLI", 1);
				self.owner := token.toLower().scanWhile('abcdefghijklmnopqrstuvwxyz0123456789', pos2);
				linePos := 0;
				break;
			endif;
			if token &lt;&gt; null and token.toUpper().cnContains("NAV") then	//05 Mar 2021	NDL						
				pos2 := token.toUpper().pos("NAV", 1);
				self.owner := token.toLower().scanWhile('abcdefghijklmnopqrstuvwxyz0123456789', pos2);
				linePos := 0;
				break;
			endif;
		endforeach;
	endwhile;
	self.owner := app.returnCorrectUserName(self.owner, true);								// 18/02/2020 jlgmh5
	
	// ### JIRA: MTN-34203 28Apr2025 NAVPW1
	if _byTeam then
		self.owner := self.getTeamName;
	endif;
	// ### JIRA: MTN-34203 28Apr2025 NAVPW1
	
	self.passed := _passed;
	self.ignored := _ignored;
	self.elapsedTime := _elapsedTime;
	self.errorText := _errorText;
	if _test.text.length &lt; 30 then				// ### JIRA: MTN-xxxxx 20Nov2025 NAVPW1
		self.jiraItem  := _test.text;			 //16.10.2025 navbs1  #34979
	endif;
	//self.runTime := app.actualTimeServer();// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.runTime := app.actualTimeAppServer();
	
	app.writeLog(self.testClass &amp; "::" &amp; self.testMethod &amp; ' passed: ' &amp; self.passed.String &amp; ' runTime: ' &amp; runTime.String &amp; 
		' elapsedTime: ' &amp; elapsedTime.String, LogINFO);
		
	// update UM_RunTestDaily and UM_UnitTest
	if app.overnightRun and app.myUMTestRunONight &lt;&gt; null then					// 24/04/2012 cnwmh5
		///beginTransaction;
		///app.myUMTestRunONight.updateRunDetails(self);
		///commitTransaction;
		beginTransaction;
		create unitTestResult persistent;										// 05/09/2013 cnwmh5
		if self.ignored then
			result := "IGNORED";
		elseif self.passed then
			result := "PASS";
		elseif not self.passed then
			result := "FAIL";
		endif;
		unitTestResult.updateDetails(self.testClass, self.testMethod, (self.elapsedTime.getMilliseconds/1000).String, 
			self.getUserFailEmailedTo().trimBlanks(), self.owner, result, self.errorText, self.runTime, app.myUMTestRunONight, self.jiraItem);		//25/03/2025	navcs2 	MTN-34203		//17.10.2025 navbs1  #34979
		unitTestResult.myClassMethod.updateRunnableUTClassMethod(true);
		commitTransaction;
		
	elseif _unitTest &lt;&gt; null and _unitTest.methods and _blame &lt;&gt; null and self.passed then
		//create one off test result to update a test from the form, i.e. during a single test run...
		classMethod := UM_Root.firstInstance.allRunnableUTClassesMethods[self.testClass, self.testMethod];
		if classMethod &lt;&gt; null and classMethod.runnableUnitTestClassMethod then
			unitTestResult := classMethod.allUnitTestResults.first;
			if unitTestResult &lt;&gt; null and unitTestResult.myTestRun &lt;&gt; null then
				beginTransaction;
				unitTestResult.updateDetails(self.testClass, self.testMethod, (self.elapsedTime.getMilliseconds/1000).String, 
					null, self.owner, "PASS", self.errorText, self.runTime, unitTestResult.myTestRun, self.jiraItem);								//25/03/2025	navcs2 	MTN-34203		//17.10.2025 navbs1  #34979
				commitTransaction; 
			endif;
		endif;
	endif;	
	
	// 10/09/2013 cnwmh5
	// persist the profiler details for class / method selection	
	if unitTestResult &lt;&gt; null and ( _doPersist or _unitTest.methods ) and  _blame &lt;&gt; null then					
		create methodsCalled transient;
		_blame.doClassMethodCoverage(methodsCalled,  _test.qualifiedName() );
		unitTestResult.updateUsedByDetails(methodsCalled);
	endif;
	
	
epilog
	abortTransaction;
	delete tokens;
	delete methodsCalled;						// 13/12/2013 cnwmh5
end;</source>
        <Parameter name="_test" type="Method"/>
        <Parameter name="_passed" type="Boolean"/>
        <Parameter name="_ignored" type="Boolean"/>
        <Parameter name="_elapsedTime" type="TimeStampInterval"/>
        <Parameter name="_errorText" type="String"/>
        <Parameter name="_blame" type="UM_Blame"/>
        <Parameter name="_doPersist" type="Boolean"/>
        <Parameter name="_unitTest" type="UT_UnitTest"/>
        <Parameter name="_byTeam" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="formatElapsedTime" id="b494806e-01ec-4a04-a679-21af152c3d57">
        <source>formatElapsedTime(time: TimeStampInterval): String protected;
//11 September 2008	cnwdw1	
//
vars

begin
	return (time.getMilliseconds/1000).String.padDecimalsWithZeros(3) &amp; " sec";
end;</source>
        <access>protected</access>
        <Parameter name="time" type="TimeStampInterval"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="fullDetails" id="8e33de5a-ec08-4328-83c7-4ee4014ce437">
        <source>fullDetails(): String;
//24 April 2009	cnwdw1	
//
vars
	message: String;
begin
	message := self.summaryDetails(false);
	if errorText &lt;&gt; "" then
		message := message &amp; CrLf &amp; errorText;
	endif;
	return message;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
