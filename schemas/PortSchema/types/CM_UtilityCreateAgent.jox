    <JadeMethod name="utlCreateMachine" id="9975e334-7037-4cec-9ab2-4369aa98d28b">
        <source>utlCreateMachine(pProxyMachine:CM_Machine; pNewMachine:CM_Machine output;
				_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21 Sep 2020 cnwma1	    ChangeRequest 49906: MTN - Ops View External Webservice
// ---------------------------------------------------------------------------
vars
	cancelSave : Boolean;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valMachine(pProxyMachine);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	

	app.setContinueCMExceptions(false);

	create pNewMachine as pProxyMachine.class persistent;
	pNewMachine.setForCreate(pProxyMachine, _passport);
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(pNewMachine);
	endif;
	
	//21.09.2020 cnwma1 TFS #49906
	if _passport.isOpsViewEnabled(pNewMachine.getMyTerminal()) then
		pNewMachine.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,
								 BGP_OpsViewWSRequest.OPS_TYPE_MACHINE,
								 pNewMachine);
	endif;
	//21.09.2020 cnwma1 TFS #49906
end;</source>
