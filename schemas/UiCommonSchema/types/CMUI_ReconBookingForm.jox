    <JadeMethod name="setupContextMenuItems" id="3c430e94-987b-4e45-b358-8773a3f12d0a">
        <updating/>
        <source>setupContextMenuItems(conwin: Window input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2009	cnwml2	Initial creation

*/

vars
	tmpMenu : MenuItem;
	obj : Object;
	blnVisible : Boolean;
begin
	inheritMethod(conwin);
	self.mnuMveSelReconItem.caption := "Move to Selected Booking Item";
	self.mnuSeparator.visible := true;

	if conwin = self.tblActual then
		self.mnuMveSelReconItem.visible := true;
		self.mnuMveSelReconItem.userObject := conwin;
		self.mnuMveUnrecCargo.visible := true;
		self.mnuMveUnrecCargo.userObject := conwin;
		
		if self.tblActual.allSelectedObjects.size &gt; 0 then
			self.myCurrentObject := self.tblActual.allSelectedObjects.first;
			if self.tblExpected.allSelectedObjects.size = 1 then
				self.mnuMveSelReconItem.enabled := true;
			else
				self.mnuMveSelReconItem.enabled := false;
			endif;
			//+cnwml2 PAR 21824 start
			blnVisible := false;					
			foreach obj in self.tblActual.allSelectedObjects do
				if obj.CM_TrackedItem.allBookingRefDiscreps.size &gt; 0 then
					blnVisible := true;
					break;
				endif;
			endforeach;
			
			self.mnuBookingDiscrep.visible := blnVisible;
			//+cnwml2 PAR 21824 end
			
			self.mnuMveUnrecCargo.enabled := true;
		else
			self.mnuMveSelReconItem.enabled := false;
			self.mnuMveUnrecCargo.enabled := false;
			self.mnuBookingDiscrep.visible := false;
		endif;
	elseif conwin = self.tblUnreconciled then
		self.mnuMveSelReconItem.visible := true;
		self.mnuMveSelReconItem.userObject := conwin;
		self.mnuMveUnrecCargo.visible := false;
		if self.tblUnreconciled.allSelectedObjects.size &gt; 0 then
			self.myCurrentObject := self.tblUnreconciled.allSelectedObjects.first;
			if self.tblExpected.allSelectedObjects.size = 1 then
				self.mnuMveSelReconItem.enabled := true;
			else
				self.mnuMveSelReconItem.enabled := false;
			endif;
			
			//+cnwml2 PAR 21824 start
			blnVisible := false;
			foreach obj in self.tblActual.allSelectedObjects do
				if obj.CM_TrackedItem.allBookingRefDiscreps.size &gt; 0 then
					blnVisible := true;
					break;
				endif;
			endforeach;
			
			self.mnuBookingDiscrep.visible := blnVisible;
			//+cnwml2 PAR 21824 end
		else
			self.mnuMveSelReconItem.enabled := false;
			self.mnuBookingDiscrep.visible := false;		//+cnwml2 PAR 21824
		endif;
	
	
	elseif conwin = self.tblExpected then
		self.myCurrentObject := self.myBooking;
		self.mnuMveSelReconItem.visible := false;
		self.mnuMveUnrecCargo.visible := false;
		self.mnuSeparator.visible := false;
		self.mnuBookingDiscrep.visible := false;			//+cnwml2 PAR 21824

	endif;
	
	
	tmpMenu := self.zCloneMenu( self.mnuTblVCloneDataTbl, self.mnuSeparator, false );
	tmpMenu := self.zCloneMenu( self.mnuTblVCloneDataTbl, self.mnuMveUnrecCargo, false );	
	tmpMenu := self.zCloneMenu( self.mnuTblVCloneDataTbl, self.mnuMveSelReconItem, false );	
	tmpMenu := self.zCloneMenu( self.mnuTblVCloneDataTbl, self.mnuBookingDiscrep, false );			//+cnwml2 PAR 21824

	
		
epilog

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="cef0641b-b3bd-4bb5-8849-c208129f5a14">
        <updating/>
        <source>setupForm() updating;
//05 August 2009	cnwdw1	
//
vars

begin
	inheritMethod();

	create myBookingAgent transient;  // Deleted on form unload
	
	self.myVoyage := self.myBooking.myVoyage;
	self.cmbVoyage.setObject(self.myVoyage);
	

	self.setCmbBooking();
	self.loadData();
end;</source>
