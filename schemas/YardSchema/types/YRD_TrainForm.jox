    <JadeMethod name="optDirOutTB_change" id="37d947e4-b583-4387-bad7-6c9e566308a1">
        <controlMethod name="OptionButton::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>optDirOutTB_change(optionbutton: OptionButton input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 June 2009	cnwmd1	Initial creation

*/

vars

begin
	self.initTblWagon();
