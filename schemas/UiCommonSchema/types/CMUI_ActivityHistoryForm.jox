    <JadeMethod name="displayAllHistory" id="3fc1f550-b3c0-44b1-be50-e169805c97d8">
        <updating/>
        <source>displayAllHistory() updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
//	13 Jul 2016	NDL Make Activity History form use column organiser
// ---------------------------------------------------------------------------

vars
	num	: Integer;
	str	: String;
	buttonsOnOff : Boolean;

begin

	self.allTsTypeActivity.clear();
	self.allTypeTsActivity.clear();
	
	if	self.currentButton = ActivityHistoryEDI or
		self.currentButton = ActivityHistoryCams or
		self.currentButton = ActivityHistoryExtInterface or	//17 Apr 2018	NDL	TFS 38135
		self.currentButton = self.BTN_ALL then
		self.useTimeStampType	 := true;
	else
		self.useTimeStampType	:= false;
	endif;
	
	buttonsOnOff := true;
	
	if self.displayType = DISPLAY_SYSTEM then
		if self.useTimeStampType then
			num := self.displayCollection(app.myRoot.allActivityHistory);	
		else
			self.filterCollectionByDate(app.myRoot.allActivityHistory, self.allTypeTsActivity);		// PAR #19355
			num := self.displayCollection(self.allTypeTsActivity);
		endif;
		
	elseif self.displayType = DISPLAY_TERMINAL then
		// Using self.myTerminal because this method can be note driven and
		// therefore app.getMyTerminal could return wrong terminal;
		if self.useTimeStampType then
			num := self.displayCollection(self.myTerminal.allActivityHistory);		
		else
			self.filterCollectionByDate(self.myTerminal.allActivityHistory, self.allTypeTsActivity);	// PAR #19355
			num := self.displayCollection(self.allTypeTsActivity);		
		endif;
		
	elseif self.displayType = DISPLAY_BOTH then
		if self.useTimeStampType then
			self.filterCollectionByDate(self.myTerminal.allActivityHistory, self.allTsTypeActivity);	// PAR #19355
			self.filterCollectionByDate(app.myRoot.allActivityHistory, self.allTsTypeActivity);			// PAR #19355
			num := self.displayCollection(self.allTsTypeActivity);
		else
			self.filterCollectionByDate(self.myTerminal.allActivityHistory, self.allTypeTsActivity);	// PAR #19355
			self.filterCollectionByDate(app.myRoot.allActivityHistory, self.allTypeTsActivity);			// PAR #19355
			num := self.displayCollection(self.allTypeTsActivity);
		endif;
		
	else
		self.tblActivity.rows := self.tblActivity.fixedRows;
		buttonsOnOff := false;
		
	endif;
	
	self.setFormCaption(num);
	self.buttonsOffOn(buttonsOnOff);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="displayCollection" id="dd9cb92b-c4ac-496b-8fce-35d5723e951f">
        <updating/>
        <source>displayCollection(_coll : CM_MemberKeyDictionary): Integer updating;

/*

Date		Who		Reason
08 May 2009	cnwkpd1	PAR #19355 - Improve performance of Activity History form
					Added exception handling of invalid Activity History 
11 Mar 2015	cnwkpd1	PAR #35843 - Make progress bar updates time-based, not object counts
13 Jul 2016	NDL Make Activity History form use column organiser

*/

vars
	tmpCurrentButton,
	idx,
	colour 			: Integer;
	activity 		: CM_ActivityHistory;
	loadStateSet	: Boolean;
	terminalD		: String;
	iter			: Iterator;
	cmifMonitor		: CMIF_Monitor;
	passport		: CM_Passport;
	num,
	partsInJob,
	partsDone		: Integer;
	theColl			: CM_MemberKeyDictionary;
	stopWhenChange	: Boolean;
	//ts				: TimeStamp;
	invalidActivity	: Boolean;
	startTS			: TimeStamp;
	endTime : Time;
	endTs : TimeStamp;
	lastUpdate		: Decimal[20];
	
begin
	
	theColl := _coll;
	
//	self.initTable();
	self.tblActivity.rows := self.tblActivity.fixedRows;
	
	passport := app.myPassport;

	// cnwjk3 PAR 18356 - Date - 03/11/2008
	self.setQueryValues();
	
	cmifMonitor := passport.myCMIFMonitor;
	if cmifMonitor &lt;&gt; null then
		delete cmifMonitor;
	endif;
	create cmifMonitor transient;
	cmifMonitor.myParent := self;
	passport.setMyCMIFMonitor(cmifMonitor);

	self.modalDialogReturnValue := self.ModalDialogReturn_Null;	
	self.modalDialogShow(null, 'Cancel' , null, null, 'Loading Activity',  'Please Wait....');
	self.pbProgressBar.visible := true;
	//copy across the dict so you don't have to access self.myTerminal every loop
	
	tmpCurrentButton := self.currentButton;
	
	if self.isPreSelected then	//22 Nov 2018	NDL	TFS 42116
		// no further filtering here..
		iter := theColl.createIterator();
	else
		// 28 Oct 2011	NDL	Par 28449
		if self.queryDateTo.isValid then
			endTs.setDate( self.queryDateTo );
			endTime.setTime( self.queryTimeTo.hour, self.queryTimeTo.minute, 59, 999 );
			endTs.setTime( endTime );
		endif;
	
		iter := theColl.createIterator();
	
		if	self.useTimeStampType then
			if self.queryDateTo.isValid then
			   //theColl.startKeyLss((self.queryDateTo + 1).asTimeStamp(),null, iter);
				theColl.startKeyLss(endTs, null, iter);	// 28 Oct 2011	NDL	Par 28449
			endif;
		else
			//theColl.startKeyLss(tmpCurrentButton, (self.queryDateTo + 1).asTimeStamp(), iter);
			theColl.startKeyLss(tmpCurrentButton, endTs, iter);	// 28 Oct 2011	NDL	Par 28449
			stopWhenChange	:= true;
		endif;
	endif;

	partsInJob := theColl.size;

	on Exception do app.handleDeletedObject(exception, activity, invalidActivity);		// PAR #19355
	
	if self.isPreSelected then	//22 Nov 2018	NDL	TFS 42116
		// no further filtering here..
		self.queryDateFrom := null;
		startTS := null;
	endif;	
	
	if self.queryDateFrom.isValid then
		startTS := self.queryDateFrom.asTimeStamp();
		startTS.setTime( self.queryTimeFrom );	// 27 Oct 2011	NDL	Par 28449
	else
		startTS := null;
	endif;
			
	while iter.back(activity) do
		invalidActivity := false;
		
		if activity.isKindOf(CM_ActivityHistUnitTest) then // 02/06/2015 cnwdb2
			continue ; 
		endif;
		
		if (app.relativeMachineTime() - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then
			if (not cmifMonitor.updateProgress(cmifMonitor.message, partsInJob, partsDone)) then
				break;
			endif;
			lastUpdate := app.relativeMachineTime();
		endif;
		
	    // cnwjk3 PAR 18356 - Date - 03/11/2008
		if activity.dateTime &lt; startTS then
			break;
		endif;

		partsDone := partsDone + 1;
		
		if stopWhenChange then
			if activity.activityType &lt;&gt; tmpCurrentButton then
				break;
			endif;
		else
			if (not self.includeActivityHistory(activity, tmpCurrentButton)) then
				continue;
			endif;
		endif;

		if not self.displayHistory(activity, 0) then
			break;	//16 Jul 2010	NDL Par 17868
		endif;

		if not invalidActivity then
			// cnwjk3 PAR 18356 - Date - 03/11/2008
			num := num + 1;
		endif;

	endwhile;
	
	cmifMonitor.updateProgress(cmifMonitor.message, partsInJob, partsInJob);

    return num;

epilog
	delete iter;
	delete cmifMonitor;
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;	
end;</source>
        <Parameter name="_coll" type="CM_MemberKeyDictionary"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="displayHistory" id="3942cdfc-8b04-4cc4-8f27-0b4975443c37">
        <updating/>
        <source>displayHistory(_activity : CM_ActivityHistory; _row : Integer):Boolean protected, updating;


// 13 Jul 2016	NDL Make Activity History form use column organiser

vars
	idx 			: Integer;
	tmpStr		: String;
	exOccurred : Boolean;
	pictureCol : Integer;
begin

	on Exception do self.tableRowLimitException(exception, self.tblActivity, exOccurred);	// 16 July 2010	NDL	Par 17868
	
//	if _activity.myTerminal = null then
//		terminalD := app.getErrorString(System_GC);
//		isSystem := true;	
//	else
//		terminalD := _activity.myTerminal.code;
//	endif;	
//	tmpStr := Tab &amp; terminalD &amp; Tab &amp; _activity.systemToLocalTime(_activity.dateTime).shortCurrentLocaleFormat() &amp; Tab
//		&amp;_activity.getTypeDescription() &amp; Tab &amp; _activity.getDisplayStringForAttribute(ETRow_Description,false);	//	cnwmp6	TFS 488 - Multi timezone changes 13/4/2016
	tmpStr := _activity.getAttributeStringForDefArray( self.tblActivity.allTblDataEntRows );
	if _row = 0 then
		idx := self.tblActivity.addItemObject(_activity, tmpStr);
		
		if exOccurred or idx = 0 then	// 16 July 2010	NDL	Par 17868, extended to idx test for TFS 1788
			return false;
		endif;
		
	else
		idx := _row;
		self.tblActivity.addItemAt(tmpStr, idx);
		
		if exOccurred then	// 16 July 2010	NDL	Par 17868
			return false;
		endif;
		
		self.tblActivity.accessRow(idx).itemObject := _activity;
	endif;

	pictureCol := self.tblActivity.getColumnByRowName( ETRow_Pic );
	if pictureCol &gt; 0 then
		if _activity.myTerminal = null  then
			self.tblActivity.accessCell(idx,pictureCol).picture := self.picGlobal.picture;
		else
			self.tblActivity.accessCell(idx,pictureCol).picture := self.picTerminal.picture;
		endif;
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_activity" type="CM_ActivityHistory"/>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
