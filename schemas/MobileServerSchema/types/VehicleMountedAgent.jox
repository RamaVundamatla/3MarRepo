    <JadeMethod name="doActionDirectorTasksBody" id="d1dbf565-b88b-41b0-8963-2cc87dfda3ef">
        <updating/>
        <source>doActionDirectorTasksBody(_ti,
						_tiTwin : CM_TrackedItem ;
						_bbQuantity : Integer;
						_moveWeight : Decimal;
						_errorMsgs : DTO_HandHeldGateErrorDict input	) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 January 2013	cnwndl1	Initial creation	Par 30920
14 Sep 2017 cnwer1	TFS 6863 changed to use objects instead of ids so break bulk works correctly
*/

vars
	result : Boolean;	
begin
		
	while true do
		self.initialiseForNewRequest(_errorMsgs);
		
		//epr TFS 995 16/5/17
		app.myTrxUA.trxMachineDirectorTask(self.myMachine,_ti, _tiTwin,  self.doesSeperatePickupSetdown(), _bbQuantity, _moveWeight,app.myPassport);
		
		//app.myTrxRT.trxActionDirectorTask(_tiId, _tiTwinId, self.myMediator, false, self.doesSeperatePickupSetdown(), null,_bbQuantity, _moveWeight,app.myPassport); //cnwrd1 par 25048 addded twin id 5.7.2011
		
		if app.myPassport.hadReplayableDeadlock() then	//15 Jan 2013	NDL	Par 30920
			return;
		endif;
		
		if app.myPassport.trxCompletedOK then
			break;
		endif;
		result:= self.createErrorsFromPassport(_errorMsgs);
		if result then
			break;
		else
			continue;
		endif;
	endwhile;
epilog

end;</source>
        <access>protected</access>
