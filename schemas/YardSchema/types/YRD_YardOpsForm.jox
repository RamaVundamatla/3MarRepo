    <JadeMethod name="setStatusBarCaption" id="713705a9-8b6d-43eb-bc21-03d7a981cff0">
        <source>setStatusBarCaption();
/*

Purpose:			

Parameters:			

Return Value:		

Date		   Who		Reason
30 March 2023 navdp20  ChangeRequest 57304:[57305] EUP - [Framework] - Add selection counter and Text Filtering on Yard Operation screen
*/

vars
	jobArray     : CM_JobArray;
	selectedRows : Integer;
begin
	inheritMethod();
	if self.myCurrentJob &lt;&gt; null then 
		selectedRows := self.tblJobs.allSelectedObjects.size();
		self.frmModeStatusBar.myFrameCaption.caption := (self.numRows).String  &amp; " rows found.  "  &amp; selectedRows.String &amp; " rows selected " &amp; self.myCurrentJob.statusString &amp; ' ' &amp; self.myCurrentJob.jobId;
    elseif self.myCurrentWLE &lt;&gt; null then
		selectedRows := self.tblWorkEntries.allSelectedObjects.size();
		self.frmModeStatusBar.myFrameCaption.caption := (self.numRows).String  &amp; " rows found.  " &amp; selectedRows.String &amp; "  rows selected   " &amp; self.myCurrentWLE.getFullDescription();
	endif;
epilog

end;</source>
    </JadeMethod>
