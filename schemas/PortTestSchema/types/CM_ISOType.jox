<Class name="CM_ISOType">
    <JadeMethod name="exportMeAttrIgnoreXML" id="b28e25e6-0256-4640-a503-77cb2ea31e41">
        <source>exportMeAttrIgnoreXML(_attrName: String): Boolean;

vars
	resultL: Boolean;
begin
	if _attrName = "tiType" then
		return true;
	else
		return false;
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="exportMyReferencesXML" id="c766d824-e1a3-40e1-8960-d074033abc69">
        <source>exportMyReferencesXML(_file: File; _objArray: ObjectArray io);

vars

begin
	if self.myCargoType &lt;&gt; null then
		_file.writeLine('&lt;myCargoType&gt;'&amp;self.myCargoType.id.String&amp;'&lt;/myCargoType&gt;');
	endif;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="importMyReferencesXML" id="8d52a174-d31f-4e30-9e6e-a8ebea1c23cc">
        <updating/>
        <source>importMyReferencesXML(_referencesBlock: String) updating;

vars
	theCode: Integer;
begin
	theCode := _referencesBlock.cnEcGetTagValueOfName('myCargoType').Integer;
	self.myCargoType := app.myRoot.allCargoTypesById[theCode];
end;</source>
        <Parameter name="_referencesBlock" type="String"/>
    </JadeMethod>
</Class>
