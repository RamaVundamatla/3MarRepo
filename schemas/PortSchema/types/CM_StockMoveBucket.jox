    <JadeMethod name="addFixup" id="76330f3b-c2cb-47a1-a93f-b33632c70686">
        <updating/>
        <source>addFixup(_type : Integer; _quantity: Integer; _weight : Decimal; _volume : Decimal) updating;
// ---------------------------------------------------------------------------
// Created:     20 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	stkMove	: CM_StockMovement;
	
begin

	exclusiveLock(self);

	stkMove := self.allStockMovements[_type];
	if stkMove = null then
		create stkMove as self.getStockMovementClass() persistent;
		stkMove.init(_type, self);
	endif;

	self.adjustQuantity		:= self.adjustQuantity + _quantity;
	self.adjustVolume		:= self.adjustVolume + _volume;
	self.adjustWeightKgs 	:= self.adjustWeightKgs + _weight;

	stkMove.addFixup(_quantity, _weight, _volume);

end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_volume" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="addTrackedItem" id="53d7d8e0-e67e-4d95-b4c1-755fe0ad580d">
        <updating/>
        <source>addTrackedItem(_type : Integer; _ti : CM_TrackedItem; _quantity: Integer; _weight : Decimal;
			   _volume : Decimal; _txn : CM_TITransaction input) updating;
// ---------------------------------------------------------------------------
// Created:     20 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  The ti to add and a flag to indicate if the move is in or out
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	stkMove	: CM_StockMovement;
	
begin

	exclusiveLock(self);

	stkMove := self.allStockMovements[_type];
	if stkMove = null then
		create stkMove as self.getStockMovementClass() persistent;
		stkMove.init(_type, self);
	endif;

	self.adjustQuantity		:= self.adjustQuantity + _quantity;
	self.adjustVolume		:= self.adjustVolume + _volume;
	self.adjustWeightKgs 	:= self.adjustWeightKgs + _weight;

	stkMove.addTrackedItem(_ti, _quantity, _weight, _volume, _txn);

end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_txn" type="CM_TITransaction" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="3862e1ce-9691-4fcc-ae20-9b668f923962">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     29 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.allStockMovements.instantiate;
end;</source>
    </JadeMethod>
