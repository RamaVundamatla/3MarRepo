    <JadeMethod name="actionItems" id="40e91cb7-17a7-4abe-a118-c950c3e1a922">
        <updating/>
        <source>actionItems(_woActionIF: CMIF_WorkOrderAction; _passport: CM_Passport input) updating;
/*
Purpose:	TFS 42241		
Date				Who			Reason
NOVEMBER 2018		CNWAB1		Initial creation
*/

vars
	voyage : CM_Voyage;
	departure : HMS_VoyageMovement;
	pxyResused, resused : HMS_ResourceUsed;
begin
	// change my voyage's departure date / time
	voyage := self.getMyVoyageObject;
	if voyage &lt;&gt; null then
		// ### FIND THE HMS RES USED AND CHANGE IT
		resused := voyage.getExtensionResourceUsed();
		
		if resused &lt;&gt; null then
			if self.newFromDateTime.isValid
			and self.newToDateTime.isValid
			and self.newToDateTime &gt; self.newFromDateTime then
			
				pxyResused := app.createUpdateProxy(resused).HMS_ResourceUsed;
			
				pxyResused.setUnitsUsed( 0 ); // This will make the invoice line re calc the units if the calc type is the time based one
				pxyResused.setDetailsFromWorkOrder( self.newFromDateTime, self.newToDateTime );
				pxyResused.setMyVoyageMovement(resused.myVoyageMovement);
			
				app.myUtilityUA.utlUpdateHMSResourceUsed(pxyResused, resused, app.myPassport);
			endif;
		endif;
	endif;
	
	
	if _passport.noErrors then
		self.setIsComplete;
		// create the appropriate transaction for billing purposes
		self.createWorkOrderTransaction(TRANS_TYPE_WO_BILLINGADJ);		
	endif;
epilog
	delete pxyResused;
end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="e4159c18-df58-4dff-94e3-08f11e43a563">
        <source>getDisplayString(_useShortDesc: Boolean): String;
/*
Purpose:	TFS 42241		
Date				Who			Reason
NOVEMBER 2018		CNWAB1		Initial creation
29 Sep 2021 		navma1 		ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
*/

vars
	displayString : String;
	typeDesc      : String;
begin
	typeDesc := self.getTypeDescription();								  //29.09.2021 navma1 #51925
	
	if _useShortDesc then
		displayString := typeDesc;
	else
		displayString := self.getLongDescription(typeDesc,null);		//29.09.2021 navma1 #51925
	endif;
	
	return displayString;
epilog

end;</source>
        <Parameter name="_useShortDesc" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
