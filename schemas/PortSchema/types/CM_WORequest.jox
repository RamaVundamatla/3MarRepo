    <JadeMethod name="getDisplayStringForAttribute" id="d1a9d7c7-28a2-4f76-9a94-ecbc1efb2dd4">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jun 2023 navma1 ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation

*/

vars

begin
	
	if _attrName = ETRow_CargoTypeDescr then
		if self.myReserveDetail &lt;&gt; null then
			return self.myReserveDetail.getCargoTypeDescr;
		endif;
		return null;
	elseif _attrName = ETRow_Id then
		return self.getId();
	elseif _attrName = ETRow_IsoGroup then	
		if self.myReserveDetail &lt;&gt; null then
			return self.myReserveDetail.getISOGroupCode;
		endif;
	elseif _attrName = ETRow_IsoType then	
		if self.myReserveDetail &lt;&gt; null then
			return self.myReserveDetail.getISOTypeCode;
		endif;
	elseif _attrName = ETRow_ReleaseRequest then
		return self.getReleaseNumber();
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
