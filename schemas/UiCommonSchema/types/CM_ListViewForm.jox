    <JadeMethod name="zDoAdd" id="ae754482-2722-4533-b804-cf7631a8fdb6">
        <updating/>
        <source>zDoAdd(_placeHolderHeirarchy : Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     21 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.allowUpdate = false then
		return;
	endif;
	
	if self.mode &lt;&gt; Mode_View then
		//Must not be already editing an object
		return;
	endif;

	self.zClearProxyDetails();
	self.myLastCurrentObject := self.myCurrentObject;
	self.myCurrentObject := null;
	self.clearErrorWarnings();

	self.mode := Mode_Add;
	self.zSetControlsForAddEdit();

	self.createPlaceHolder(_placeHolderHeirarchy);
	self.addTreeObject('new', self.myPlaceHolderObject, 1, false);

	self.showThumbnailData(self.myPlaceHolderObject);
	self.zLstDataSelectObject(self.myPlaceHolderObject);

end;</source>
        <access>protected</access>
        <Parameter name="_placeHolderHeirarchy" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zDoCancel" id="64a3162a-2935-4cac-aa70-e3e52affdc35">
        <updating/>
        <source>zDoCancel() updating, protected;
// ---------------------------------------------------------------------------
// Created:     31 January 2001 by cnwrs2
//
// Purpose:     Called when the cancel button is pressed.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	app.mousePointer := Window.MousePointer_HourGlass;

	self.zSetControlsForView();
	self.zClearProxyDetails();
	self.clearErrorWarnings();
	
	if self.mode = Mode_Update then
		self.zDoLstDataRefresh();
		if self.myCurrentObject &lt;&gt; null then
			self.zShowThumbnailData(self.myCurrentObject);
		else
			self.zClearThumbnailData();
		endif;

	elseif self.mode = Mode_Add then
		self.zClearPlaceHolderObject(false);
		// cancelled an add so reselect the last selected object
		self.zLstDataSelectObject(self.myLastCurrentObject);
	endif;

	self.mode := Mode_View;

epilog
	app.mousePointer := Window.MousePointer_Default;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoDelete" id="c5342021-741c-40f8-ba50-b8334d50bbc1">
        <updating/>
        <source>zDoDelete() updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin

	if self.lstData.listIndex &lt;&gt; -1 then
		if app.msgBox(app.getErrorString2(ConfirmDelete, 'this item', ''), 'Are you sure', MsgBox_OK_Cancel) = MsgBox_Return_OK then
			if self.doDelete() then
				// may need to redisplay table here!
				//will need to redisplay table as item has been deleted
			//	PAR 13862 ----after re -opening   to place the cursor at correct position after deleting also
				//self.myCurrentObject := null;
				//self.zLstDataShow();
		
				//self.zLstDataSelectObject(self.myCurrentObject);
						
				
				
			endif;
		endif;
	else
		app.msgBox('You must select an object to delete', 'Error', MsgBox_OK_Only);
	endif;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoEdit" id="39da302f-bc9e-4c79-99f2-bd7945af2810">
        <updating/>
        <source>zDoEdit() updating, protected;
// ---------------------------------------------------------------------------
// Created:     16 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	17/5/01			AA		Can only start edit if in view mode &amp; updates allowed
//	12/10/2009	cnwcs5		par 20790 - comments added
// ---------------------------------------------------------------------------
vars
	obj			: Object;
	tmpProxy	: CM_Object;
begin

 if not global.isValidObject(self.myCurrentObject) then  // par 18090 cnwrd1 6.3.09
 	self.zDoCancel(); 
	return;
 endif;

	if self.allowUpdate = false then 
		return;
	endif;
	
	if self.mode &lt;&gt; Mode_View then 
		//Must not be already editing an object
		return;
	endif;
	
	self.clearErrorWarnings();
	self.zClearProxyArray;

	
	if self.myCurrentObject &lt;&gt; null then
		if self.useProxyObject then
			self.myProxyObject := app.createUpdateProxy(self.myCurrentObject);
			// if the create of the proxy fails - because we are already editing the object  
			// an exception will have been thrown and the remainder of this method will not be 
			// executed
			self.allProxyObjects.add(self.myProxyObject);
		endif;
		//PAR 20790 - set mode only after we know we have created any proxy object
		self.mode 			:= Mode_Update;
		self.objectEdition	:= self.myCurrentObject.edition;
		
		// Redisplay to ensure latest version of object is shown
		// app.createUpadteProxy will have ensured latest version is in cache
		self.zShowThumbnailData(self.myCurrentObject);
		// With latest version confirm that the object can be editted.
		if self.canDoEdit() then
			self.zSetControlsForAddEdit();
		else 
			self.zDoCancel();
		endif;
	else
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), app.getErrorString (Error), MsgBox_OK_Only);
		self.zDoCancel(); //rs oct 2004 reset the form
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
