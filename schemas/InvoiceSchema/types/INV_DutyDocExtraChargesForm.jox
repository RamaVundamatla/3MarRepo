    <JadeMethod name="translateForm" id="e97da1a0-0078-4ec1-8b83-747abef24f7f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 September 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019237, locale);
	btnCancel.translateCaption(Xlat_0019238, locale);
	btnSave.translateCaption(Xlat_0019239, locale);
	btnVoidLine.translateCaption(Xlat_0019240, locale);
	lblDebtor.translateCaption(Xlat_0019241, locale);
	lblInvNumber.translateCaption(Xlat_0019242, locale);
	lblInvType.translateCaption(Xlat_0019243, locale);
	lblLineType.translateCaption(Xlat_0019244, locale);
	lblLines.translateCaption(Xlat_0019245, locale);
	lblNarration.translateCaption(Xlat_0019246, locale);
	lblQty.translateCaption(Xlat_0019247, locale);
	lblStartDate.translateCaption(Xlat_0019248, locale);
	mnuContext.translateCaption(Xlat_0019249, locale);
	mnuInspect.translateCaption(Xlat_0019250, locale);
	mnuVoid.translateCaption(Xlat_0019251, locale);
end;</source>
    </JadeMethod>
</GUIClass>
