    <JadeMethod name="getCargoWeightDisplay" id="38a72521-0492-440f-ac2a-15aa976e72dd">
        <source>getCargoWeightDisplay():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2016	cnwndl1	Initial creation	TFS 2959 / 2420

*/

vars

	product : CM_Product;
	measureType : CM_MeasurementType;

begin

	if self.cargoWeight = 0 then
		return null;
	endif;

	if self.myTrackedItem &lt;&gt; null then
		product := self.myTrackedItem.getProductForMeasurementConv();
	endif;
	
	if product &lt;&gt; null and product.getMyWeight.isViewable then										
		measureType := product.getMyWeight.myMeasurementType;	
	endif;
	
	if measureType = null then
		measureType := app.getDefaultMeasurementForType( Type_Weight );
	endif;

	if measureType &lt;&gt; null then
		return measureType.convertMeasurementForDisplay( self.cargoWeight ) &amp; " " &amp; measureType.shortName;
	endif;

	return self.cargoWeight.asStringJMT;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
