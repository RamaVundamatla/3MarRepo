<Class name="CM_EnqControllerVehicleBooking" id="d5af7af1-d1b0-41f2-9277-051de2e74e6e">
    <superclass name="CM_EnquiryController"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <PrimAttribute name="endDateTime" id="fc74b6bc-5a66-41e6-988e-4bf6ce46a2fb">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myCarrier" id="306c4646-0167-48b8-ad67-378a299b832b">
