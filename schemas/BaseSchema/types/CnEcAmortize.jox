    <PrimAttribute name="loanPrincipal" id="9ae6bd3c-6ad0-4571-a4fd-852ed14621ec">
        <precision>18</precision>
        <scaleFactor>2</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="numberOfInstalments" id="7a897461-f3da-44a7-8cdb-01c11d353448">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="calculateInstalments" id="d7e582fa-18bf-4fcf-a719-6d913f572774">
        <source>calculateInstalments();
// --------------------------------------------------------------------------------
// Created:		29 October 2001 by cnwdad1
//
// Purpose:		Populates the receiver's array of loan instalments with details of
//				all instalments until the loan is repaid.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	openingBalance		: Decimal[18,2];
	closingBalance		: Decimal[18,2];
	principalAmount		: Decimal[18,2];
	interestAmount		: Decimal[12,2];
	instalmentAmount	: Decimal[12,2];
	allInstalments		: CnEcLoanInstalmentArray;
	
begin
	allInstalments		:=	self.allLoanInstalments;
	
	allInstalments.purge();
	
	instalmentAmount	:=	self.getInstalmentAmount();
	openingBalance		:=	self.loanPrincipal;
	
	while true do
		interestAmount	:=	self.getInstalmentInterest(openingBalance);
		
		if openingBalance &lt; instalmentAmount then
			principalAmount	:=	openingBalance - interestAmount;
		else
			principalAmount	:=	instalmentAmount - interestAmount;
		endif;
		
		closingBalance	:=	allInstalments.addInstalment(openingBalance, principalAmount, interestAmount);
		
		if closingBalance &lt;= 0 then
			break;
		else
			openingBalance	:=	closingBalance;
		endif;
	endwhile;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="700a3008-44ed-4458-99b2-121feb70708d">
        <updating/>
        <source>delete() updating;
// --------------------------------------------------------------------------------
// Created:		30 October 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allLoanInstalments.purge();
end;</source>
    </JadeMethod>
    <JadeMethod name="getFinalInstalment" id="6b078bfa-7acd-4d76-b913-7b47ea510279">
        <source>getFinalInstalment():Decimal;
// --------------------------------------------------------------------------------
// Created:		29 October 2001 by cnwdad1
//
// Purpose:		Returns the final instalment value.
//
// Parameters:	None
//
// Returns:		The amount of the final instalment.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	instalmentObj	: CnEcLoanInstalment;
	
begin
	if self.allLoanInstalments.isEmpty() then
		return 0;
	else
		instalmentObj	:=	self.allLoanInstalments[self.allLoanInstalments.size()];
		
		return instalmentObj.instalmentAmount;
	endif;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getInstalmentAmount" id="071da31f-bb37-49e0-b510-e5d2d57f3dd7">
        <source>getInstalmentAmount():Decimal;
// --------------------------------------------------------------------------------
// Created:		29 October 2001 by cnwdad1
//
// Purpose:		Calculates the instalment amount for the loan, and returns the result.
//
//				P = Principal
//				R = Annual Interest Rate
//				r = Compound Interest Rate (i.e. R/1200)
//				N = Number of instalments
//				I = Instalment amount
//
//					Pr(1+r)^N
//				I = ----------
//					(1+r)^N -1
//
// Parameters:	None
//
// Returns:		The loan instalment amount.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	compoundRate		: Real;
	instalmentAmount	: Decimal[12,2];
	
begin
	compoundRate		:=	self.interestRate / 1200;
	
	instalmentAmount	:=	((self.loanPrincipal * compoundRate) * ((1 + compoundRate) ^ self.numberOfInstalments)) /
							(((1 + compoundRate) ^ self.numberOfInstalments) - 1);
epilog
	return instalmentAmount;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getInstalmentInterest" id="da8de4cc-e46a-473e-be24-305ea1c60bae">
        <source>getInstalmentInterest(pPrincipal:Decimal):Decimal;
// --------------------------------------------------------------------------------
// Created:		29 October 2001 by cnwdad1
//
// Purpose:		Calculates the monthly interest for the requested principal.
//
// Parameters:	pPrincipal - The principal who's interest to calculate.
//
// Returns:		The principal's interest amount.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	instalmentInterest	: Decimal[12,2];
	
begin
	instalmentInterest	:=	((pPrincipal / 12) * (self.interestRate / 100)).roundedTo(2);
epilog
	return instalmentInterest;
end;</source>
        <Parameter name="pPrincipal" type="Decimal"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getTotalInterest" id="3ba934a3-f728-4122-ae6f-4455aef1aa1c">
        <executionLocation>server</executionLocation>
        <source>getTotalInterest():Decimal serverExecution;
// --------------------------------------------------------------------------------
// Created:		29 October 2001 by cnwdad1
//
// Purpose:		Returns the total interest for the loan.
//
// Parameters:	None
//
// Returns:		The total amount of interest.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	instalmentObj	: CnEcLoanInstalment;
	totalInterest	: Decimal[18,2];
	
begin
	if self.allLoanInstalments.isEmpty() then
		totalInterest	:=	0;
	else
		foreach instalmentObj in self.allLoanInstalments do
			totalInterest	:=	totalInterest + instalmentObj.interestAmount;
		endforeach;
	endif;
epilog
	return totalInterest;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getTotalRepayment" id="cbc50f99-6703-44a5-9361-ee6dfb421d2f">
        <executionLocation>server</executionLocation>
        <source>getTotalRepayment():Decimal serverExecution;
// --------------------------------------------------------------------------------
// Created:		29 October 2001 by cnwdad1
//
// Purpose:		Returns the total repayment for the loan.
//
// Parameters:	None
//
// Returns:		The total repayment amount.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	instalmentObj	: CnEcLoanInstalment;
	totalRepayment	: Decimal[18,2];
	
begin
	if self.allLoanInstalments.isEmpty() then
		totalRepayment	:=	0;
	else
		foreach instalmentObj in self.allLoanInstalments do
			totalRepayment	:=	totalRepayment + instalmentObj.instalmentAmount;
		endforeach;
	endif;
epilog
	return totalRepayment;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="6a19487b-cada-4ebe-9d1a-2e2b3e0046af">
        <updating/>
        <source>updateMe(	pLoanAmount:Decimal;
			pInterestRate:Decimal;
			pInstalments:Integer;
			pFirstPaymentDate:Date) updating;
// --------------------------------------------------------------------------------
// Created:		29 October 2001 by cnwdad1
//
// Purpose:		Updates the receiver's properties.
//
// Parameters:	pLoanAmount - The value of the loan.
//				pInterestRate - The interest rate.
//				pInstalments - The number of instalments.
//				pFirstPaymentDate - The date of the first payment.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.loanPrincipal &lt;&gt; pLoanAmount then
		self.loanPrincipal			:=	pLoanAmount;
	endif;
	
	if self.interestRate &lt;&gt; pInterestRate then
		self.interestRate		:=	pInterestRate;
	endif;
	
	if self.numberOfInstalments &lt;&gt; pInstalments then
		self.numberOfInstalments	:=	pInstalments;
	endif;
	
	if self.firstPaymentDate &lt;&gt; pFirstPaymentDate then
		self.firstPaymentDate	:=	pFirstPaymentDate;
	endif;
end;</source>
        <Parameter name="pLoanAmount" type="Decimal"/>
        <Parameter name="pInterestRate" type="Decimal"/>
        <Parameter name="pInstalments" type="Integer"/>
        <Parameter name="pFirstPaymentDate" type="Date"/>
    </JadeMethod>
</Class>
