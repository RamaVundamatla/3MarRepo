//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
//	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 14, "incorrect number of EDI trackedItems");
	ti := self.getTrackedItem(CONTAINER01);
	self.assertNull(ti);
//	self.assertEqualMsg(ti.getSealNumTerminalOperator(), "TermOpSeal1", "Incorrect Terminal Operator Seal");
	ti := self.getTrackedItem(CONTAINER02);
	self.assertNull(ti);
	ti := self.getTrackedItem(CONTAINER03);
	self.assertNull(ti);
//	self.assertEqualMsg(ti.getSealNumShipper(), "SHSEAL1", "Incorrect Shipper Seal");
	ti := self.getTrackedItem(CONTAINER04);
	self.assertNull(ti);

	ediText :=
'
&lt;?xml version="1.0"?&gt;
