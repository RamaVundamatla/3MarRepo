    <JadeMethod name="doPrintConnectReport" id="64b26ba9-8581-48ac-9d7d-139c7ecc0cc4">
        <updating/>
        <source>doPrintConnectReport(_profName: String; _jrwManager: JadeReportWriterManager) updating, protected;
//----------------------------------------------------------------
//	Created:	18 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*
Date		Who		Reason
18 Mar 2010	consw1	PAR #22886 - Leaking report transients
*/
vars
	jadeReport		: JadeReport;
	jrwReport		: JadeReportWriterReport;
	reportString	: String;
	ls,
	printPrev		: Boolean;
	findPrinterValue: Integer;
	printerName		: String;
begin
	
	printerName := null;
	// If printer name is null then Jade uses default printer.
	findPrinterValue :=  app.printer.setPrinter(printerName);
	app.writeLog('Set Printer Return Value = ' &amp; findPrinterValue.String, LogINFO);
	if findPrinterValue &lt;&gt; Printer_Ok then
		app.msgBox("Printer could not be set to default." &amp; CrLf &amp;
					"Check this printer is available in your list of printers.", self.caption, MsgBox_OK_Only);
		return;
	endif;
	
	printPrev := self.chkPrintPreview.value;
	if printPrev then
		create jadeReport transient;
		jadeReport.description := self.myQryConnectionReport.heading;
		app.printer.setReport(jadeReport);
	endif;	
	
	reportString := self.myQryConnectionReport.jrwReportName.first;
	jrwReport := _jrwManager.getReport(reportString);

	if jrwReport = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "report with name " &amp; reportString &amp; " does not exist");
		return;
	endif;

	if _profName &lt;&gt; null then
		jrwReport.setProfile(_profName);
	endif;

	jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
	
	///jrwReport.setPageOptions(Print_A4, Print_Landscape, 1, 0, 0, 0, 20, 0, false, 0);
	jrwReport.setPageOptions(Print_A4, Print_Landscape, 1, 0, 0, 10, 10, 0, false, 0);		// 06/10/2010 cnwmh5 #25944
	if printPrev then
		jrwReport.setPreviewOptions(false, true, false, true, null);
	endif;
//	app.cmsBeginLoad(ls);

	jrwReport.run;

	if printPrev then
		app.printPreview(jadeReport, true);
	else
		delete jadeReport;
	endif;		

epilog
//	app.cmsEndLoad(ls);
	delete jrwReport;
end;</source>
        <access>protected</access>
        <Parameter name="_profName" type="String"/>
        <Parameter name="_jrwManager" type="JadeReportWriterManager"/>
    </JadeMethod>
    <JadeMethod name="doPrintLabels" id="e42492a2-ef36-469d-ba0c-ddfaff35eba6">
        <updating/>
        <source>doPrintLabels(_jrwManager: JadeReportWriterManager) updating, protected;
//----------------------------------------------------------------
//	Created:	18 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*
Date		Who		Reason
18 Mar 2010	consw1	PAR #22886 - Leaking report transients
11 Oct 2012	cnwdap1	PAR #30552 - Inter terminal reefers that were connected in the previous terminal
					should be treated as never connected, not disconnected
*/
vars
	jrwReport		: JadeReportWriterReport;
	reportString	: String;
	thePrinterName	: String;
	findPrinterValue: Integer;
	tisRemove		: CM_TISet;
	ti				: CM_TrackedItem;
	tmpPrinterDef	: CM_PrinterDef;
	tmpTISet		: CM_TISet;
	defaultPrinter	:	String;
	msg : String;
begin
	defaultPrinter := app.printer.getPrinterName;		//PAR13455
	tmpPrinterDef := self.cmbPrinters.listObject.CM_PrinterDef;
	
	if tmpPrinterDef = null then
		//don't use the default - must be different to default - force setup of special label printer
		app.msgBox("Please select a printer to print the labels to." &amp; CrLf &amp;
					"The default printer is not valid for printing labels - a dedicated printer must be setup.", self.caption, MsgBox_OK_Only);
		return;
	endif;
	
	thePrinterName := tmpPrinterDef.physicalPrinterName;
/*	findPrinterValue :=  app.printer.setPrinter(thePrinterName);
	app.writeLog('Set Printer for (' &amp; thePrinterName &amp; ') Return Value = ' &amp; findPrinterValue.String, LogAlways);
	
	if findPrinterValue &lt;&gt; Printer_Ok then
		app.msgBox("Printer could not be set to " &amp; thePrinterName &amp; "." &amp; CrLf &amp;
					"Check this printer is available in your list of printers.", self.caption, MsgBox_OK_Only);
		return;
	endif; */
	
	if not app.validatePrinterName( thePrinterName, true, true ) then
		msg := app.getErrorString2( Printer_not_known_locally, tmpPrinterDef.description, thePrinterName);
		app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only );
		thePrinterName := null;
	endif;
	app.printer.setPrinter(thePrinterName);
	
	create tisRemove transient;
	
	if app.myQAFilter.allJRWTransients.isNotEmpty() then
	
		tmpTISet := app.myQAFilter.allJRWTransients.first.CM_JRWContainer.allTrackedItems;

		foreach ti in tmpTISet do
			if ti.operatorCode &lt;&gt; "MSK" then
				//write ("Remove NON MSK ----" &amp; ti.id &amp; "  " &amp; ti.operatorCode);
				tisRemove.add(ti);
				continue;
			endif;
			if self.chkIgnoreTShip.value then
				if ti.isTranshipItem then
					tisRemove.add(ti);	
					continue;
				else
					
				endif;
			endif;
			// PAR 13363 - should not print labels for containers that have been connected previously
			if ti.isContainer and
			   ti.CM_Container.getLastConnectDT.isValid then
				// PAR #30552 only remove if this reefer isn't an inter terminal transfer with its connection date coming from the previous terminal
				if ti.CM_Container.myMoveCloneFromTI = null or ti.CM_Container.getLastConnectDT &lt;&gt; ti.CM_Container.myMoveCloneFromTI.getLastConnectDT then
					tisRemove.add(ti);	
					continue;
				endif;
			endif;
		endforeach;
		
		if not tisRemove.isEmpty() then
			foreach ti in tisRemove do
				tmpTISet.remove(ti);
			endforeach;
		endif;

	endif;
	//change end
	
	reportString := 'MSK_ReeferSticker';
	jrwReport := _jrwManager.getReport(reportString);

	if jrwReport = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "report with name " &amp; reportString &amp; " does not exist");
		return;
	endif;

	jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
	
	//might have to set the page size options here - don't know if label printer can handle it
	jrwReport.setPageOptions(Print_A4, Print_Portrait, 1, 0, 0, 0, 20, 0, true, 0);

	endLoad;
	beginLoad;
	
	jrwReport.run();
epilog
	endLoad;
	delete jrwReport;
	delete tisRemove;
	//Reset the printer back to what it was to begin with.
	app.printer.setPrinter(defaultPrinter);
	
end;</source>
        <access>protected</access>
        <Parameter name="_jrwManager" type="JadeReportWriterManager"/>
    </JadeMethod>
    <JadeMethod name="doReport" id="68c84a41-184e-43d0-9642-f75508191b40">
        <updating/>
        <source>doReport() protected, updating;
//----------------------------------------------------------------
//	Created:	18 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	profileName				: String;
	filterObject			: CMQF_ReeferCon;
	numItems				: Integer;
	jrwManager				: JadeReportWriterManager;
	jrwTransient		: CM_JRWContainer;
	

begin

	jrwManager := self.myJadeReportWriterManager;

	if self.useSelected then
		jrwTransient := app.myQAFilter.createJRWTransient(CM_JRWContainer).CM_JRWContainer;
		
		if jrwTransient = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Failed to create JRW transient singleton');
			return;
		endif;
		
		jrwTransient.allTrackedItems.clear();
		self.allTIsToPrint.copy(jrwTransient.CM_JRWContainer.allTrackedItems);
		
		if self.chkSaveToWkList.value then
			app.myTrxUA.trxUpdateReeferConnectList(self.allTIsToPrint, app.myPassport);
		endif;
		
		numItems := self.allTIsToPrint.size;
	else
		filterObject := self.myQryConnectionReport.createFilter().CMQF_ReeferCon;
		if filterObject &lt;&gt; null then
			filterObject.initialize();
			filterObject.allQueryReportParams.clear();
			if self.cmbVoyages.listObject &lt;&gt; null then	
				filterObject.setMyVoyage( self.cmbVoyages.listObject.CM_Voyage );
			endif;
			filterObject.saveToWorkList := self.chkSaveToWkList.value;
			filterObject.allTerminals.add(self.myTerminal);
			filterObject.includeTranships := true;			// 06/10/2010 cnwmh5 #25944
		endif;

		numItems := self.myQryConnectionReport.doFilter(filterObject, app.myPassport);
	endif;

	profileName := self.cmbRptProfile.text;

	if numItems = 0 then
		global.beep;
		app.msgBox(app.getErrorString(No_Print_Output), "No output", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	if self.chkConnReport.value then
		self.doPrintConnectReport(profileName, jrwManager);
	endif;
	
	if self.chkPrintLabels.value then
		//changed by cnwyl1 for par 12891
		//it was...
		//self.doPrintLabels(jrwManager);
		if app.msgBox("Only print labels for MSK containers, continue?", $Warning, MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then 
			self.doPrintLabels(jrwManager);
		else
			return;
		endif;
		//change end
	endif;

	if self.useSelected and
	   self.chkSaveToWkList.value then
		// for self.useSelected = false this is done in the
		// self.myQryConnectionReport.doFilter(..) method
		app.myTrxUA.trxUpdateReeferConnectList(self.allTIsToPrint, app.myPassport);
	endif;

epilog
	if global.isValidObject(filterObject) then
		delete filterObject;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="fe0edd84-d626-40ec-aca4-6da37f74fec0">
        <updating/>
        <source>doResize() updating;
//----------------------------------------------------------------
//	Created:	18 May 2006	by Jason Chapman  (cnwjc2)
