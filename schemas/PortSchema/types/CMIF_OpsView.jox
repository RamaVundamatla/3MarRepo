    <JadeMethod name="generateGKey" id="ddc9a626-9cc9-4975-9e82-332fa6540772">
        <source>generateGKey(_any : Any): Integer64;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data
*/

vars
	oidFormatted,
	key        		: String;
	licenseInt 		: Integer64;
	obj             : CM_Object;
	term            : CM_Terminal;
	termIdStr,
	objIdStr 	    : String;
	
begin
	
	if app.myRoot.licenseName &lt;&gt; null then
		licenseInt   := app.myRoot.licenseName.getStringValueAsInteger64;
	endif;
	
	
	if _any &lt;&gt; null then
		if _any.isKindOf(CM_Object)then
			objIdStr	:= self.getObjectId(_any);
			
			if not _any.isKindOf(CM_Terminal) then
				term := obj.getMyTerminal();
				if  term &lt;&gt; null then
					termIdStr   := self.getObjectId(term);
				endif;
			endif;
			
		endif;
	endif;
	
	if termIdStr &lt;&gt; null then
		oidFormatted := termIdStr &amp; objIdStr;
	else
		oidFormatted := objIdStr;
	endif;
	
	key := app.myRoot.systemMode.String &amp; licenseInt.String &amp; oidFormatted;
	
	
	return key.Integer64;
epilog

end;

</source>
        <Parameter name="_any" type="Any"/>
        <ReturnType type="Integer64"/>
    </JadeMethod>
    <JadeMethod name="getObjectId" id="80163f95-0ac0-4419-b550-c623a7f8d29d">
        <source>getObjectId(_any : Any):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data

*/

vars
	id  : String;
	str : String;
	idx : Integer;
	obj : CM_Object;
begin
	if _any.isKindOf(CM_Object) then
		obj := _any.CM_Object;
		id	:= obj.cnGetInstanceId64(obj).String;
	
	elseif _any.isKindOf(String) then
		str	:= _any.String;
		idx := str.pos('.',1);
		id  := str[idx+1:str.length];
	endif;
	
	return id;
end;</source>
        <Parameter name="_any" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initialize" id="8bc0ab6c-681c-4cfe-bd38-2b3d0d5890a1">
        <updating/>
        <source>initialize(_bgpRequest : BGP_OpsViewWSRequest) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data

*/

vars
	terminal : CM_Terminal;
	obj      : Object;
	oidStr   : String;
begin
	if _bgpRequest = null then
		return;
	endif;
	
	self.updateAction    := _bgpRequest.updateAction;
	self.updateType 	 := _bgpRequest.updateType;	
	self.updateTimeStamp := app.actualTimeServer().asEpochFormat();
	
	if _bgpRequest.myTerminal &lt;&gt; null then
		terminal := _bgpRequest.myTerminal;
	endif;
	
	
	if _bgpRequest.myObject &lt;&gt; null then
		obj 		:= _bgpRequest.myObject;
		oidStr  	:= obj.getOidString;
		
		if obj &lt;&gt; null and terminal = null  then       // will be removed later 
			terminal 	:= obj.getMyTerminal();
		endif;
	elseif _bgpRequest.objectOid &lt;&gt; null then
		oidStr := _bgpRequest.objectOid;
	endif;
	
	
	
	if terminal &lt;&gt; null then
		self.facilityGkey 	:= self.generateGKey(terminal);
		self.facilityId   	:= terminal.code;
	endif;
	
	if oidStr &lt;&gt; null then
		self.oid := oidStr;
	endif;
	
	self.sequenceNumber := "";
epilog

end;</source>
        <Parameter name="_bgpRequest" type="BGP_OpsViewWSRequest"/>
    </JadeMethod>
    <JadeMethod name="initializeForActivity" id="b886ed8c-aef1-4a1f-8ed0-40ee1718a42f">
        <updating/>
        <source>initializeForActivity(_opsviewActivity : CM_EWSActivityOpsview) updating;
/*
Purpose:			

Date		Who		Reason
27AUG2021	NAVAB1	TFS 51853
*/


vars
	terminal : CM_Terminal;
	obj      : Object;
	oidStr   : String;
begin
	if _opsviewActivity = null then
		return;
	endif;
	
	self.updateAction    := _opsviewActivity.dataAction;
	self.updateType 	 := _opsviewActivity.dataType;	
	self.updateTimeStamp := app.actualTimeServer().asEpochFormat();
	
	if _opsviewActivity.myTerminal &lt;&gt; null then
		terminal := _opsviewActivity.myTerminal;
	endif;
	
	
	if _opsviewActivity.myOpsviewObject &lt;&gt; null then
		obj 		:= _opsviewActivity.myOpsviewObject;
		oidStr  	:= obj.getOidString;
		
		if obj &lt;&gt; null and terminal = null  then       // will be removed later 
			terminal 	:= obj.getMyTerminal();
		endif;
	elseif _opsviewActivity.objectOid &lt;&gt; null then
		oidStr := _opsviewActivity.objectOid;
	endif;
	
	
	
	if terminal &lt;&gt; null then
		self.facilityGkey 	:= self.generateGKey(terminal);
		self.facilityId   	:= terminal.code;
	endif;
	
	if oidStr &lt;&gt; null then
		self.oid := oidStr;
	endif;
	
	self.sequenceNumber := _opsviewActivity.getSequence().String; // NAVAB1 21OCT2021
epilog

end;</source>
        <Parameter name="_opsviewActivity" type="CM_EWSActivityOpsview"/>
    </JadeMethod>
</Class>
