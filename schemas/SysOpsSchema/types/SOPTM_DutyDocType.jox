    <JadeMethod name="doSave" id="befc0fb0-7a29-469f-b5b2-e00affead48b">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwmc5	Initial creation HAT 2189

*/

vars
	proxyDutyDocType		: CM_DutyDocType;
	theForm 				: SOP_TableMaintForm;
	
	lCode					: String;
	lDescription			: String;
	lDutyCharged			: Boolean;
	imex 					: Integer;
begin
	theForm := self.myForm; 
	
	lCode := theForm.tblInput1.getValueByName(ETRow_Code).String;
	lDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;
	lDutyCharged := theForm.tblInput1.getValueByName(ETRow_DutyCharged).Boolean;	
	imex:= self.getImex(theForm.comboBox1.text);
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_DutyDocType transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyDutyDocType := theForm.myProxyObject.CM_DutyDocType;
	proxyDutyDocType.setProxy(lCode, lDescription, lDutyCharged,imex);

	if theForm.mode = theForm.Mode_Add then
		 app.myTrxCA.trxCreateDutyDocType(proxyDutyDocType, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateDutyDocType(proxyDutyDocType, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
