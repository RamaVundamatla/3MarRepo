    <JadeMethod name="isPostedOrReversal" id="0a79db62-a0b3-4741-8924-294ee341318a">
        <source>isPostedOrReversal():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2017	jlgndl1	Initial creation	TFS 6759

*/

vars

begin

	if self.status = CM_Invoice.INVOICE_POSTED then
		return true;
	endif;
	
	if self.status = CM_Invoice.INVOICE_POSTED_CREDIT then
		return true;
	endif;
	
	if self.status = CM_Invoice.INVOICE_POSTED_REVERSE then
		return true;
	endif;

	// TFS 39618 PATCH 1 if (self.myInvoiceProcess.isLinxProcess() and self.status = CM_Invoice.INVOICE_APPROVED) then
	// TFS 39618 PATCH 1 	return false;
	// TFS 39618 PATCH 1 endif;

	if self.status = CM_Invoice.INVOICE_PENDING_REVERSE then //31.10.2018 cnwma1 TFS #41703
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isPostedReturned" id="1373a7cf-4379-4ebc-89e4-23b0d46c6863">
