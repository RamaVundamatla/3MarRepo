    <JadeMethod name="setupForm" id="3aadf189-91b3-4878-888e-768f89008a3c">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 Nov 2009	cnwrd1	Initial creation
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
*/

vars

begin
	inheritMethod();
	
	//29.09.2021 navma1 #51925
