    <JadeMethod name="outputFile" id="36c9f8ad-1219-46a1-ab84-6bb95ff17c4b">
        <updating/>
        <source>outputFile(_protocol: CM_CamProtocol input; _camAgent: CM_CamControllerAgent; _camFile: CM_CamFile input; _runDateTime: TimeStamp; _camTaskHistory: CM_CamTaskHistory input; _unhSeqNumber: Integer io; _seqNumber: Integer; _terminal: CM_Terminal; _contextObj : CM_Object; _transactions : CM_TITransactionSet) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Sep 2016	cnwndl1	Initial creation	2276 / 2565
03 Mar 2017	cnwgb1  TFS 3643
09 Jan 2020	jlgdap1	TFS 48016 SNO Deletion CODECO - new _transactions parameter
*/

vars
	camVoyage 		: CM_CamVoyage;
	camMessage 		: CM_CamMessage;
	str, outputStr 		: String;
	messageType 	: String;
	singleQuote	:Character;
	strLine : String;
begin

	singleQuote	:= _protocol.segmentTerminator;
	
	app.writeLog("===================================", LogWARN);
	
	if _camFile.camVoyages.size &gt; 0 then
        _camFile.incrementMessageCount(); // TFS 3643 cnwgb1 3 Mar 2017
		foreach camVoyage in _camFile.camVoyages do
			foreach camMessage in camVoyage.camMessages do
				
				foreach str in camMessage.group3 do
				
					if str[str.length:1] = singleQuote then
						outputStr := outputStr &amp; str;
						strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, outputStr, null);
						outputStr := null; //reset this now
					else
						//we dont end with a segment terminator so lets just collect data						
						outputStr := outputStr &amp; str;
					endif;
									
				endforeach;
				
				
			endforeach;
		endforeach;
	endif;

	app.writeLog("===================================", LogWARN);
	_camTaskHistory.setRawDataString(outputStr);
end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_contextObj" type="CM_Object"/>
        <Parameter name="_transactions" type="CM_TITransactionSet"/>
    </JadeMethod>
    <JadeMethod name="outputFileMessage" id="2c9cd8b0-7556-4d8a-9680-7bd6a3ab3a91">
        <updating/>
        <source>outputFileMessage(_camTaskHistory: CM_CamTaskHistory input; _message: String; _coll: HugeStringArray input): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2016	cnwndl1	Initial creation	TFS 2561 / 2277

*/

vars
    str : String;
begin
	
	str := _message;
	
	if _coll &lt;&gt; null then
		if str.length &gt; 511 then
			str := str [1:511];
		endif;
		
		_coll.add (str);
	endif;
	
	return str;
end;</source>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_message" type="String"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processEvent" id="5baeec21-c880-40db-9fa0-ced5c81150f7">
        <updating/>
        <source>processEvent(_transaction: CM_EventTransaction; _camProtocol: CM_CamProtocol; _camAgent: CM_CamControllerAgent input; _camFile: CM_CamFile input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 September 2016	cnwndl1	Initial creation	TFS 2276 / 2565

*/
  
vars

   	ediRecievedEvent :CMEVT_EDIFileReceived;
    camMessage : CM_CamMessage;
    strMsg : String;
	eventType : CM_EventType;
	oidString : String;
	obj : Object;
	ediPreNote : CM_EDIPrenoteTI;
	prenoteDateStr : String;
	preNoteTimeStr : String;
	ediFile: CM_EDIFile;
	origMessTS : TimeStamp;
	origMessDateStr : String;
	origMessTimeStr : String;
	origRefNum : String;
	edition : Integer;	//23 May 2017	NDL	TFS 4525
	invalid : Boolean;	//23 May 2017	NDL	TFS 4525
	
begin

	_camAgent.writeDebugLog(class.name&amp;'::'&amp;method.name&amp;" process "&amp;_transaction.type.asStringJMT);
    
    if _transaction = null then
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, 'There is no Event transaction');
			return;
		endif;
	endif;
	
	if not _transaction.isKindOf(CMEVT_EDIFileReceived) then
		//wrong type
		if _camAgent.logExcludedTransactions then
			eventType := app.myRoot.allEventTypesByType[_transaction.type];
			if eventType &lt;&gt; null then
				strMsg := eventType.name;
			else
				strMsg := _transaction.type.asStringJMT;
			endif;
			_camAgent.logReasonForExclusion(_transaction, 'The Event '&amp;strMsg&amp;' is not an EDI File Receive Event');
		endif;
		return;
    endif;
	
    ediRecievedEvent := _transaction.CMEVT_EDIFileReceived;
	
	if ediRecievedEvent.fileType &lt;&gt; EDIFileType_XMLOneStopPre then
		if _camAgent.logExcludedTransactions then
			eventType := app.myRoot.allEventTypesByType[_transaction.type];
			if eventType &lt;&gt; null then
				strMsg := eventType.name;
			else
				strMsg := _transaction.type.asStringJMT;
			endif;
			_camAgent.logReasonForExclusion(_transaction, 'The Event '&amp;strMsg&amp;' is not an EDI File Receive Event for a "One Stop Prenote XML file".');
		endif;
		return;
	endif;
	
	//the oid of the EDI Prenote is stored on the EDIFileReceived as an oid in the file number.
	oidString :=  _transaction.CMEVT_EDIFileReceived.fileNumber;
	if oidString &lt;&gt; null then
		obj := oidString.asOid;
		if obj &lt;&gt; null and CM_EDIPrenoteTI.hasInstance(obj) then
			ediPreNote := obj.CM_EDIPrenoteTI;
			//23 May 2017	NDL	TFS 4525
			on Exception do app.handleDeletedObject( exception, ediPreNote, invalid );
			edition := ediPreNote.edition;
			if invalid then
				ediPreNote := null;
			endif;
		endif;
	endif;
	
	if ediPreNote = null then
		if _camAgent.logExcludedTransactions then
			eventType := app.myRoot.allEventTypesByType[_transaction.type];
			if eventType &lt;&gt; null then
				strMsg := eventType.name;
			else
				strMsg := _transaction.type.asStringJMT;
			endif;
			_camAgent.logReasonForExclusion(_transaction, 'The EDI Prenote can not be resolved from the Event '&amp;strMsg&amp;'".');
		endif;
		return;
	endif;
 	
	camMessage := self.getCamMessage(_camFile, "", null, 0, _camProtocol.singleContainerPerBGM); 
	
	prenoteDateStr := ediPreNote.createdTime.Date.asXMLFormat();
	preNoteTimeStr := ediPreNote.createdTime.Time.asXMLFormat();
	
	ediPreNote.getOneStopAperakValues( ediFile, origRefNum, origMessTS );
	
	origMessDateStr := origMessTS.Date.asXMLFormat();
	origMessTimeStr := origMessTS.Time.asXMLFormat();
	
    //output is 3 separate lines.
	strMsg := "00,APERAK,,,9" &amp; Lf;
	strMsg := strMsg &amp; "20," &amp; prenoteDateStr &amp; "," &amp; preNoteTimeStr &amp; ",999999," &amp; ediPreNote.id &amp; ",ERA0100,AP," &amp; origRefNum &amp; "," &amp; origMessDateStr &amp; "," &amp; origMessTimeStr &amp; ",,Message received,EQD" &amp; Lf;
	strMsg := strMsg &amp; "99,APERAK";
	
    self.addMessage(camMessage.group3, strMsg );
    
epilog
   
end;</source>
        <Parameter name="_transaction" type="CM_EventTransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
