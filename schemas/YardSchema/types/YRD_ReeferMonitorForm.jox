        <source>unload() updating;
// ---------------------------------------------------------------------------
// Created:		09 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
20 May 2014	cnwkpd1	JADE PAR #61256 - Issue with endNotificationForSubscriber with null parameter
	
*/

vars

begin
	inheritMethod();
	if self.myDisplayedReefer &lt;&gt; null then
		self.endNotificationForSubscriber(self.myDisplayedReefer);
	endif;
	self.endNotificationForSubscriber(self);
end;</source>
    </JadeMethod>
