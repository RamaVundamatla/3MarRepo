    <JadeMethod name="addRow" id="6107649f-6c9a-4ddd-aaf9-3d814a73aab2">
        <source>addRow(pAttrName : String; pHeading : String; pValue : Any; pSheet : JadeTableSheet) protected;
// ---------------------------------------------------------------------------
// Created:     18 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	heading	: String;
	
begin

	if pHeading = null then
		heading := self.getHeading(pHeading, pAttrName);
	else
		heading := pHeading;
	endif;

	if pSheet &lt;&gt; null then
		pSheet.addItemAt(heading &amp; Tab &amp; pValue.String, pSheet.rows+1);
		
	elseif self.myDataReturnObject &lt;&gt; null and self.dataReturnMethodName &lt;&gt; null then
		self.myDataReturnObject.sendMsgWithParams(self.dataReturnMethodName, heading, pValue);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Sheet and DataReturnObject are null - cannot return data');
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="pHeading" type="String"/>
        <Parameter name="pValue" type="Any"/>
        <Parameter name="pSheet" type="JadeTableSheet"/>
    </JadeMethod>
    <JadeMethod name="customExportEntryNumber" id="3efd6b9e-fc07-4e78-af8e-fc2fa0f78c9d">
        <source>customExportEntryNumber(pHeading : String; pSheet : JadeTableSheet);

vars

begin
		self.addRow(method.name, pHeading, self.myTrackedItem.customExportEntryNumber, pSheet);

end;</source>
        <Parameter name="pHeading" type="String"/>
        <Parameter name="pSheet" type="JadeTableSheet"/>
    </JadeMethod>
    <JadeMethod name="doTimeStampDisplay" id="c31ee2f5-18d8-4b04-acb4-7473a16230d2">
        <source>doTimeStampDisplay(pTimeStamp : TimeStamp) : String protected;
// ---------------------------------------------------------------------------
// Created:     04 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str	: String;
	
begin

	if pTimeStamp &lt;&gt; null then
		str := pTimeStamp.Date.shortFormatJMT() &amp; ' ' &amp; pTimeStamp.Time.shortFormatJMT();
		//	changed from hh to HH for 24-hour clock for PAR 1490 / PNL316 RDD 16/10/01
	endif;
	
	return str;

end;</source>
        <access>protected</access>
        <Parameter name="pTimeStamp" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHeading" id="d2f76004-bca0-4596-bb67-fbc68a31a9d4">
        <source>getHeading(pHeading, pName : String) : String protected;

vars
	entTableRow	: EntTableRow;
	
begin
	if pHeading &lt;&gt; null or
	   self.myEntTableGroup = null then
	   	if self.myEntTableGroup = null then
	   	
	   	endif;
		return pHeading;
	endif;
	entTableRow := self.myEntTableGroup.allEntTableRowsByName[pName];
	if entTableRow &lt;&gt; null then
		return entTableRow.getHeading(null, null, app.myCurrentLocale);
	else
		
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="pHeading" type="String"/>
        <Parameter name="pName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="inputDT" id="d31ca458-d543-4e9a-9bb3-648eff176790">
        <source>inputDT(pHeading : String; pSheet : JadeTableSheet);
vars

begin
	self.addRow(method.name, pHeading, self.doTimeStampDisplay(self.myTrackedItem.inputDT), pSheet);
end;</source>
        <Parameter name="pHeading" type="String"/>
        <Parameter name="pSheet" type="JadeTableSheet"/>
    </JadeMethod>
    <JadeMethod name="inspectDT" id="4e0cade7-5ab6-4a70-97aa-40e282905a7a">
        <source>inspectDT(pHeading : String; pSheet : JadeTableSheet);
vars

begin
	self.addRow(method.name, pHeading, self.doTimeStampDisplay(self.myTrackedItem.inspectDT), pSheet);
end;</source>
        <Parameter name="pHeading" type="String"/>
        <Parameter name="pSheet" type="JadeTableSheet"/>
    </JadeMethod>
    <JadeMethod name="queuedLocn" id="6f9310b6-8d72-4483-bee1-a8efee56ae02">
        <source>queuedLocn(pHeading : String; pSheet : JadeTableSheet);
vars
	str	: String;
	tmpLC	: CM_LocationsController;
	
begin
	tmpLC := self.myTrackedItem.getPrimaryLocation(QUEUE_MODE);
	if tmpLC &lt;&gt; null then
		str := tmpLC.getID;
	endif;
	self.addRow(method.name, pHeading, str, pSheet);
end;</source>
        <Parameter name="pHeading" type="String"/>
        <Parameter name="pSheet" type="JadeTableSheet"/>
    </JadeMethod>
</Class>
