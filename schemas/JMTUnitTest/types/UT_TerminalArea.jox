    <JadeMethod name="autoDirectReleaseSetupCleanup" id="43dd406b-f4c8-437e-8bac-faa2da7301a6">
        <source>autoDirectReleaseSetupCleanup(	_createData : Boolean;
								_bs : CM_TerminalAreaMaster output;
								_voyage : CM_Voyage output;
								_transType : CM_TransactionType output
								);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2018	jlgndl1	Initial creation

*/

constants

	DirReleaseAreaBName : String = "DREL1";
	VesselName1 : String = "DRVESS1";
	VoyageName1 : String = "DRVOY1";
	Cargo_Type : String = "UTREBAR";
	ContainerName1 : String = "DREL0010002";
	BreakBulkName1 : String = "UTBBDREL001";
	TransTypeInt : Integer = 10099001;
	
vars

	pxyBlockStack : CM_BlockStack;
	pDO : CM_YADeckingOptionsTA;
	oper : CM_Operator;
	vessel : CM_Vessel;
	cargoType : CM_CargoType;
	cargoOnship : CM_TrackedItem;
	proxyTT : CM_TransactionType;

begin

	oper := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).CM_Operator;
	cargoType := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);

	//Clean up old data.
	self.deleteTerminalArea( DirReleaseAreaBName );
	self.deleteVoyage( VoyageName1 );
	self.deleteVessel( VesselName1 );
	self.deleteContainer( ContainerName1 );
	self.deleteCargo( BreakBulkName1, cargoType );
	self.deleteTransactionType( TransTypeInt );
	
	if not _createData then
		return;
	endif;
	
	// Create new data
	vessel := self.addVesselCellularWithCode(VesselName1, VesselName1, oper);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; VesselName1.display &amp; ' failed');
	
	_voyage := self.addVoyageWithInwardCode(        VoyageName1, 
                                                    null,
													VesselName1,
													oper.code, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(_voyage, 'Add voyage ' &amp; VoyageName1 &amp; ' failed');
	
	
	cargoOnship := self.addCargoBreakBulkAtLocation( BreakBulkName1, cargoType, 50, _voyage.myShipBlockStack, null, TI_IMEX_STATUS_IMPORT, _voyage, oper );
	self.assertTrueMsg( cargoOnship &lt;&gt; null, BreakBulkName1 &amp; " rebar not created. " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	cargoOnship := null;
	cargoOnship := self.addContainerAtLocation( ContainerName1, oper, "2200", "MT", TI_IMEX_STATUS_IMPORT, _voyage.myShipBlockStack );
	self.assertTrueMsg( cargoOnship &lt;&gt; null, ContainerName1 &amp; " container not created. " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	create proxyTT transient;
	proxyTT.setProxy(	"Unit Test User Defined Release",
						TransTypeInt,
						3,
						"CM_Release",
						false,
						app.myRoot);
	app.myTrxCA.trxCreateTransactionType( proxyTT, _transType, app.myPassport );
	self.assertTrueMsg( _transType &lt;&gt; null, " Transaction Type not created. " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	create pxyBlockStack transient;
	pxyBlockStack.setProxy(DirReleaseAreaBName, 
							"",
							TA_TYPE_RELTRANS, 
							1,
							5,
							5,
							false,
							"", 
							99,
							true, 
							null,
							self.getTerminal,
							false,
							false,
							false,
							false,
							false,
							null,
							null,
							false
							);
	create pDO transient;
	pDO.setProxy(false, true, pxyBlockStack);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);
	
	pxyBlockStack.setAutoRelease(	true,	//_autoRelease : Boolean;
									TransTypeInt	//_trxTypeOnRelease : Integer
									);
	
	app.myTrxCA.trxCreateTerminalArea(pxyBlockStack, _bs, app.myPassport);

epilog

	delete pxyBlockStack;
	delete proxyTT;

end;</source>
        <Parameter name="_createData" type="Boolean"/>
        <Parameter name="_bs" type="CM_TerminalAreaMaster" usage="output"/>
        <Parameter name="_voyage" type="CM_Voyage" usage="output"/>
        <Parameter name="_transType" type="CM_TransactionType" usage="output"/>
    </JadeMethod>
    <JadeMethod name="checkUnavailableReeferWalkPath" id="b358eeb8-03a1-41bb-91fa-afcb4cfa929e">
        <source>checkUnavailableReeferWalkPath(_reeferWalkPositionArray : CM_ReeferBlockPositionArray; _padHeight : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2023	navpw1	Initial creation TFS: 57947 (59757)

*/

vars
	availability				: Integer;
	reeferBlockPosName			: String;
	reeferBlockPosition			: CM_ReeferBlockPosition;
	containsAsterix				: Boolean;
	gridController				: CM_GridController;
	
begin
	foreach reeferBlockPosition in _reeferWalkPositionArray do
		if not reeferBlockPosition.myLocationController.isGridLocation then
			continue;
		endif;
		
		gridController := reeferBlockPosition.myLocationController.CM_GridController;
		
		availability := gridController.getAvailability(); //availability lives on CM_StackController &amp; CM_RTGController &amp; CM_OverhangController and is not inherited
		
		if availability = PAD_AVAILABLE then
			continue;
		endif;
		
		//Check to make sure it is _padHeight
		self.assertTrueMsg(availability = _padHeight, "Pad Height is incorrect. Expected: '" &amp; _padHeight.String &amp; "' | Actual: '" &amp; availability.String &amp; "'");
		
		if reeferBlockPosition.tier &lt; 3 then
			continue;
		endif;
		
		//Check display for unavailable tiers gives it a Asterix
		reeferBlockPosName := reeferBlockPosition.getDisplay(true);
		containsAsterix := reeferBlockPosName.pos("*", 1) &gt; 0;
		self.assertTrueMsg(containsAsterix, "Expected Reeefer block position to contain Asterix '*': Expected '" &amp; true.String &amp; "' | Actual '" &amp; containsAsterix.String &amp; "'");
		
	endforeach;
	
end;</source>
        <Parameter name="_reeferWalkPositionArray" type="CM_ReeferBlockPositionArray"/>
        <Parameter name="_padHeight" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createGCOnVoyage" id="2dcc0653-14ae-4254-80a8-0a24a36f4f3b">
        <source>createGCOnVoyage(_delete : Boolean; _contractId,_id : String; _cargoType : CM_CargoType; _operator : CM_Operator; _voyage : CM_Voyage; _port : CM_Port; _weight : Decimal; _volume : Decimal; _quantity : Integer; _cargoGroup : CM_CargoGroup input) : CM_TrackedItem;
/*
Purpose:			

Date		Who		Reason
// ### TFS CR 58499 TASK 61456 04JAN2024 NAVAB1
*/

vars
	cargo : CM_TrackedItem;
	lc : CM_LocationsController;
	product : CM_Product;
	prevOp : CM_Operator;
begin
	if _delete then
		self.deleteCargo(_id, _cargoType);
	endif;
	
	lc := _voyage.myShipBlockStack;
	
	
	product := _cargoType.allProducts.first;   ////////getProductFromCode("12POUNDER-12");
	if product&lt;&gt; null
	and product.myOperator &lt;&gt; null 
	and product.myOperator &lt;&gt; _operator then
		prevOp := product.myOperator;
		beginTransaction;
		product.setMyOperator(_operator);
		commitTransaction;
	endif;
	//create cargo on ship
	self.opts.addAssoc("Product", product);
	self.opts.addAssoc("TotalQuantity",_quantity); 
	cargo := lc.createNewCargoForLCDetailed(_cargoType,product, _id, _port.code, TI_IMEX_STATUS_IMPORT, _voyage,_operator, _quantity, _cargoGroup).CM_Cargo;// ### TFS CR 59942 TASK 59943 23AUG2023 NAVAB1
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(cargo);
	self.opts.addAssoc("Commodity", "COM2");
	self.opts.addAssoc("TotalVolume", _volume);
	self.opts.addAssoc("CargoLength", 111.0);
	self.opts.addAssoc("CargoWidth", 222.0);
	self.opts.addAssoc("CargoHeight", 333.0);
	self.opts.addAssoc("Description", "CargoDesc2");
	self.opts.addAssoc("ClientRef", "ClientRef2");
	self.opts.addAssoc("Consignee", "UTDDC");
	self.opts.addAssoc("Consignor", "UTMO1");
	self.opts.addAssoc("ContractId",_contractId);
	self.opts.addAssoc("TotalWeight", _weight.Integer);
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); // ### TFS CR 59615 TASK 59620 15AUG2023 NAVAB1
	
	self.updateTI(cargo);
	assertEqual(cargo.totalQuantity, _quantity);
	assertEqual(cargo.totalWeight, _weight.Decimal);

	self.assertTrueMsg(cargo.contractId = _contractId, "Cargo Contract Id is wrong");
	
	if prevOp &lt;&gt; null then
		beginTransaction;
		product.setMyOperator(prevOp);
		commitTransaction;
	
	endif;
	
	return cargo;
epilog

end;</source>
        <Parameter name="_delete" type="Boolean"/>
        <Parameter name="_contractId" type="String"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_port" type="CM_Port"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_cargoGroup" type="CM_CargoGroup" usage="input"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createUpdateGcAllocAreaProxy" id="17bf2a13-271c-48f0-ae87-93f5d326923c">
        <source>createUpdateGcAllocAreaProxy(	_realGcAllocRowArea : CM_GeneralCargoAllocRowArea;
								_colArray : StringArray input;
								_divArray : StringArray input
								) : CM_GeneralCargoAllocRowArea;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2021	navndl1	Initial creation	TFS 49912

*/

vars

	pxyGcAllocRowArea : CM_GeneralCargoAllocRowArea;
	load : Boolean;
	rowAreaRow : CM_RowAreaRow;
	rowCont : CM_RowController;
	count : Integer;

begin

	_colArray.clear();
	_divArray.clear();

	app.cmsBeginLoad(load);
	pxyGcAllocRowArea := _realGcAllocRowArea.pxyCreateUpdateProxy();
	
	foreach rowAreaRow in _realGcAllocRowArea.allRows do
		rowCont := rowAreaRow.allRowControllers.first;
		_colArray.add( rowCont.ident );
	endforeach;
	
	foreach rowCont in _realGcAllocRowArea.allRowControllersById do
		count := count + 1;
		if count &gt; 1 then
			_divArray.add( rowCont.ident[1] );
		endif;
	endforeach;
	
	pxyGcAllocRowArea.createProxyLCsAndGroups(_colArray, _divArray);
	
	return pxyGcAllocRowArea;

epilog

	app.cmsEndLoad(load);

end;</source>
        <Parameter name="_realGcAllocRowArea" type="CM_GeneralCargoAllocRowArea"/>
        <Parameter name="_colArray" type="StringArray" usage="input"/>
        <Parameter name="_divArray" type="StringArray" usage="input"/>
        <ReturnType type="CM_GeneralCargoAllocRowArea"/>
    </JadeMethod>
