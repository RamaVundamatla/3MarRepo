    </ImplicitInverseRef>
    <ImplicitInverseRef name="myCurrentVoyage" id="fad7a2f7-0869-4f67-abe4-16f57f80dafb">
        <embedded/>
        <type name="CM_Voyage"/>
        <access>readonly</access>
