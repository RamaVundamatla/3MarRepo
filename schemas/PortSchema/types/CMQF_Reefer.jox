<Class name="CMQF_Reefer" id="07a4daa7-c5d6-4787-947d-5cea83bf7c0f">
    <superclass name="CMQF_Container"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>This needs sorting a bit.</text>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="7ef86686-34be-4df4-a3d6-80f41994dcf2">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:		29 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	ta			: CM_TerminalArea;
	ti			: CM_TrackedItem;
	lc			: CM_LocationsController;
	terminal	: CM_Terminal;
	breakOut	: Boolean;
begin
	ta := self.getMyTerminalArea;
	
	if ta &lt;&gt; null then
		foreach lc in ta.allLocationsControllers discreteLock do
			foreach ti in lc.allTrackedItems discreteLock do
				if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//				if self.includesObject(ti, _passport, breakOut) then
					if not _collection.includes(ti) then
						_collection.add(ti);
					endif;
				endif;
				
//				if breakOut then
//					return;
//				endif;
			endforeach;
		endforeach;
	else
		foreach terminal in self.allTerminals do
			//search onsite ti's
			//TI_STATE_NORMAL		
			foreach ti in terminal.allOnsiteTIsByIdCargoType discreteLock do
				if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//				if self.includesObject(ti, _passport, breakOut) then
					if not _collection.includes(ti) then
						_collection.add(ti);
					endif;
				endif;
				
//				if breakOut then
//					return;
//				endif;
			endforeach;
		endforeach;
	endif;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
