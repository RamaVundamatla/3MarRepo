    <JadeMethod name="createEmailBaseData" id="640a8682-f7b0-45f0-9cfd-e4a21cd38850">
        <updating/>
        <source>createEmailBaseData(pComputerName:String;
					pEmailClientName:String;
					pEmailReturnAddress:String;
					pEmailServerName:String;
					pLdapBase:String;
					pLdapHost:String;
					pMyEmailBaseRoot:CnEcEmailRoot;			
					pCnEcEmailBaseDataNew : CnEcEmailBaseData output): String updating; 

// This method created by JediMethodGenerator at 15:53:23 on 14 March 2001
// It will create a CnEcEmailBaseData Object.

vars
	errorMessage	: String;
	vCnEcEmailBaseData	: CnEcEmailBaseData;

begin
	create vCnEcEmailBaseData;

	errorMessage := vCnEcEmailBaseData.initializeMe(
			pComputerName,
			pEmailClientName,
			pEmailReturnAddress,
			pEmailServerName,
			pLdapBase,
			pLdapHost,
			pMyEmailBaseRoot);

	pCnEcEmailBaseDataNew := vCnEcEmailBaseData;
epilog
	return errorMessage;
end;</source>
