    <JadeMethod name="listPopulate" id="3e81f0df-e499-45a8-add6-c6bad3348da4">
        <source>listPopulate(_iarray: IntegerArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2016	cnwmp6	Initial creation	TFS 2443

*/

vars

begin
	self.tblActions.clear();
	
	if _iarray &lt;&gt; null and _iarray.includes(TRANS_TYPE_PackComplete) then
		tblActions.addItem(TableCheckBox_Selected &amp; Tab &amp; StopApplyPackCompleteStr);
	else
		tblActions.addItem(TableCheckBox_NotSelected &amp; Tab &amp; StopApplyPackCompleteStr);
	endif;

	if _iarray &lt;&gt; null and _iarray.includes(TRANS_TYPE_UnpackComplete) then
		tblActions.addItem(TableCheckBox_Selected &amp; Tab &amp; StopApplyUnpackCompleteStr);
	else
		tblActions.addItem(TableCheckBox_NotSelected &amp; Tab &amp; StopApplyUnpackCompleteStr);
	endif;

	if _iarray &lt;&gt; null and _iarray.includes(TRANS_TYPE_REPAIR) then
		tblActions.addItem(TableCheckBox_Selected &amp; Tab &amp; app.getErrorString(Repair));
	else
		tblActions.addItem(TableCheckBox_NotSelected &amp; Tab &amp; app.getErrorString(Repair));
	endif;
epilog

end;</source>
        <Parameter name="_iarray" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="populateCriteriaFrames" id="792d1bb1-144e-40e5-b874-563458c33c34">
        <updating/>
        <source>populateCriteriaFrames(_autoSetFocus: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2013	cnwndl1	Initial creation
18/08/2023			navkc1	CR 59603 Task 59604: UI - CustDocs More Stop Criteria
*/

vars
	i: Integer;
	criteria: CM_YACriteria;
	criteriaFrame: CMUI_YACriteriaCntl;
	saveChangeMethod: String;
	cmifObject: CMIF_Object;
	tabIndex: Integer;
	adjustment: Real;
	new: Boolean;
	defaultNumCriteria : Integer;
begin

	tabIndex := self.frmCriteria.tabIndex;					

	self.hideAllOpCriteriaFrames();
	
	if self.myObjectMatchCriteria &lt;&gt; null then
		self.txtGroupName.text := self.myObjectMatchCriteria.priority.String;
		if self.myObjectMatchCriteria.isReportFormatMatch then
			self.txtYACode.text := self.myObjectMatchCriteria.CM_ReportFormatMatchCriteria.reportName;
		endif;
	endif;
	
	/* // 28/11/2023	navkc1 Bug 60782
	//21 Oct 2019	NDL	TFS 46911
	if self.context = CM_ObjectMatchCriteria.RoadGateCargoCheckInt then
		defaultNumCriteria := 3;
	elseif self.context = CM_ObjectMatchCriteria.StopCriteriaInt then
		defaultNumCriteria := 15; //18/08/2023	navkc1	CR 59603 Task 59604
	else
		defaultNumCriteria := 5;
	endif;
	*/
	
	// 28/11/2023	navkc1 Bug 60782
	defaultNumCriteria := self.getNumCriteriaToDisplay();
	
	while i &lt; defaultNumCriteria do
		i := i + 1;
		criteria := null;
		if myObjectMatchCriteria &lt;&gt; null and not myObjectMatchCriteria.allCriteria.isEmpty and myObjectMatchCriteria.allCriteria.size &gt;= i then
			criteria := myObjectMatchCriteria.allCriteria[i];
		endif;
		if criteria = null then
			criteriaFrame := self.addCriteriaFrame(i, null, tabIndex);
		else
			criteriaFrame := self.addCriteriaFrame(i, criteria.myYACriteriaType, tabIndex);
		endif;
		saveChangeMethod := criteriaFrame.formCriteriaChangeMethodName;
		criteriaFrame.formCriteriaChangeMethodName := null;  // prevent invoke of criteria change method
		criteriaFrame.setCriteria( criteria );
		criteriaFrame.setMasterControl(self.frmCriteria);	//cnwmc5 - PAR 31255	
		criteriaFrame.formCriteriaChangeMethodName := saveChangeMethod;
		//02 Nov 2015	NDL	Par 37094
		if criteria &lt;&gt; null and self.excludeCriteriaType(criteriaFrame, criteria.myYACriteriaType) then
			criteriaFrame.setCriteria( null );
		endif;
		// 04/11/2009 cnwmh5 PAR20740
		// Set the focus to the first item for entry
		if _autoSetFocus and i = 1 then
			criteriaFrame.CMUI_YACriteriaCntl.txtCriteriaValue.setFocus();
		endif;
	endwhile;
	
	self.disableExcludedCriteria();	//02 Nov 2015	NDL	Par 37094
	
epilog
end;</source>
        <Parameter name="_autoSetFocus" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateForm" id="7372d535-5ccb-4047-aa0d-5a12ff66c9d0">
        <updating/>
        <source>populateForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2013	cnwndl1	Initial creation

*/

vars
	criteria : CM_YACriteria;

begin
	on Exception do self.handleBadCriteriaValue(exception);  
	
	defaultYACodeChanged	:= false;

	self.doSetupCriteriaFrames();
	
	if self.context = CM_ObjectMatchCriteria.WagonRestrictionInt then
		if self.myObjectMatchCriteria &lt;&gt; null then
			self.cmbTerminal.enabled := false;
			self.clrYAColour.setColor( myObjectMatchCriteria.CM_CargoRestrictionCriteria.colour );
		endif;
		
	elseif self.context = CM_ObjectMatchCriteria.TaskCriteriaInt then	// 16/8/16 MAP TFS 2443
		if self.myObjectMatchCriteria.CM_TaskCriteria &lt;&gt; null then
			self.cmbMovePopulate(self.cmbMoveCreate, self.myObjectMatchCriteria.CM_TaskCriteria.moveOnCreation);
			self.cmbMovePopulate(self.cmbMoveComplete, self.myObjectMatchCriteria.CM_TaskCriteria.moveOnCompletion);
			self.listPopulate(self.myObjectMatchCriteria.CM_TaskCriteria.allAutoApplyActions);
		else
			self.cmbMovePopulate(self.cmbMoveCreate, -1);
			self.cmbMovePopulate(self.cmbMoveComplete, -1);
			self.listPopulate(null);
		endif;
		
		// ### TFS 58761 (60739) 16Nov2023 NAVPW1
		if app.myPassport.isVASEnabled then
			self.populateMultiSelectGroupBoxes(self.myObjectMatchCriteria.CM_TaskCriteria);
		endif;
		// ### TFS 58761 (60739) 16Nov2023 NAVPW1

	elseif self.context = CM_ReportFormatMatchCriteria.InterchangeCriteriaInt then	//11 Jan 2019	NDL	TFS 40479
		self.cmbPrinters.clear();
		create self.myAssistant transient;
		self.myAssistant.comboBoxPrinterDefs(self.cmbPrinters, false, null);
		self.txtPrintCopies.text := "1";
		if self.myObjectMatchCriteria &lt;&gt; null then
			if self.myObjectMatchCriteria.CM_InterchangeReportFormat.myPrinter &lt;&gt; null then
				self.cmbPrinters.listIndex := self.cmbPrinters.findObject( self.myObjectMatchCriteria.CM_InterchangeReportFormat.myPrinter );
			endif;
			self.txtPrintCopies.text := self.myObjectMatchCriteria.CM_InterchangeReportFormat.numCopies.String;
		endif;
		
	endif;
	
epilog

	delete self.myAssistant;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateMultiSelectGroupBoxes" id="07eaa596-f5ac-4a19-b2e0-fc7894ac4ca1">
        <source>populateMultiSelectGroupBoxes(_taskCriteria : CM_TaskCriteria) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 November 2023	navpw1	Initial creation TFS: 58761 (60739)

*/

vars
	allResourceTypeGroups,
	availableResourceGroups,
	mandatoryResourceGroups		: CM_ResourceTypeGroupByCode;
	
begin
	allResourceTypeGroups := app.myRoot.allResourceTypeGroups;
	
	if _taskCriteria &lt;&gt; null then
		availableResourceGroups := _taskCriteria.allAvailableResourceGroups;
		mandatoryResourceGroups := _taskCriteria.allMandatoryResourceGroups;
	endif;
	
	self.mulAvailableResourceGroups.setupControl(app.getErrorString(Available_groups), allResourceTypeGroups, CMUI_ObjectCriteriaLineForm::getResourceTypeGroupCode.name);
	self.mulAvailableResourceGroups.setSelected(availableResourceGroups);
	self.mulAvailableResourceGroups.availableHeading := app.getErrorString(Available_groups);
	self.mulAvailableResourceGroups.selectedHeading := app.getErrorString(Visible_groups);
	self.mulAvailableResourceGroups.myBaseForm	:= self;
	
	self.mulMandatoryResourceGroups.setupControl(app.getErrorString(Mandatory_groups), availableResourceGroups, CMUI_ObjectCriteriaLineForm::getResourceTypeGroupCode.name);
	self.mulMandatoryResourceGroups.setSelected(mandatoryResourceGroups);
	self.mulMandatoryResourceGroups.availableHeading := app.getErrorString(Available_groups);
	self.mulMandatoryResourceGroups.selectedHeading := app.getErrorString(Mandatory_groups);
	self.mulMandatoryResourceGroups.myBaseForm	:= self;
	
end;</source>
        <access>protected</access>
        <Parameter name="_taskCriteria" type="CM_TaskCriteria"/>
    </JadeMethod>
    <JadeMethod name="resizeForReportFormatMatch" id="244584fc-f762-431a-9755-53741bcd839d">
        <updating/>
        <source>resizeForReportFormatMatch() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
11 December 2013	cnwndl1	Initial creation
04/01/2017          cnwrh7     TFS    2899 Cargo Attribute Filter for Driver Instructions
28 March 2018		jlgsl4	TFS 37410 Import MTs IMEX transition status
04 May 2018			jlgsl4	TFS 38467 Criteria Selection in front of Transition Maintenance
6/07/2022 			navhl20 TFS 53697 EUP - VBS MTN - [1] - VBS Slot Types
11/07/2022          navds20 ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
09/08/2023			navkc1	CR 59580	Task 59588: UI - CustDocs Customs Shipping Line Status
28/11/2023			navkc1 Bug 60782: FR | 54089 EUP -Invoice Contracts - Criteria screen width issues
25th Jan 2024 		navra1  TFS 62081 - CUX | Auto-setdown of cargo that doesn't require a machine move
07 Mar 2024         navrv30 Bug 61941: FR | 53383 - Release Request by Type - Cargo Group (part II)
18 Apr 2025         navbs1 Bug MTN-34563: Road Receipt configuration
*/

vars

	criteriaFrame: CMUI_YACriteriaCntl;
	newHeight : Real;
	diff : Integer;
	left : Real;
	top : Real;
	height : Real;
	halfWidth : Real;
	
begin

	//hide these
	self.frmHeader.visible := false;
	self.shtOptions.visible := false;
	self.shtRemarks.visible := false;
	self.lblYAColour.visible := false;
	self.clrYAColour.visible := false;
	self.lblYATemplate.visible := false;
	self.cmbYATemplate.visible := false;
	self.btnFindTemplate.visible := false;
	self.lblCriteria.visible := false;
	self.lblCriteriaDesc.visible := false;
	self.btnTmplCritEdit.visible := false;
	self.chkTestOverstow.visible := false;

	//Reuse these existing fields
	self.grpTemplate.visible := true;
	self.grpTemplate.parent := self.fldYardAlloc.parent;
	self.grpTemplate.borderStyle := 0;
	self.grpTemplate.top := 2;
	self.grpTemplate.left := 1;
	self.grpTemplate.width := self.grpTemplate.parent.width - 4;
	if self.grpTemplate.parent.isKindOf(Form) then	//11 Jan 2018	NDL	TFS 40479
		self.grpTemplate.width := self.grpTemplate.parent.Form.clientWidth - 2;	
	endif;
	
	//28/11/2023	navkc1 Bug 60782
	self.grpTemplate.parentAspect := Control.ParentAspect_None;
	
	/* // 28/11/2023	navkc1 Bug 60782
	self.lblGroupName.visible := true;
	self.lblGroupName.top := 5;
	*/
	
	if self.context = CM_ObjectMatchCriteria.WagonRestrictionInt
	or self.context = CM_ObjectMatchCriteria.VBSExclusionInt	//15 May 2015	NDL	Par 36234
	then
		self.lblGroupName.caption := app.getErrorString(Terminal) &amp; ":";
	elseif self.context = CM_ObjectMatchCriteria.ReleaseByTypeInt or //11 Jun 2015	NDL	Par 36338 // TFS 37410
			self.context = CM_ObjectMatchCriteria.VBSMatchingCriteriaInt or 	//6/07/2022 navhl20 TFS 53697
			self.context = CM_ReportFormatMatchCriteria.ImexTransitionInt or // TFS 37410
			self.context = CM_ObjectMatchCriteria.VvrPackageInt or // 1/5/18 MAP TFS37340
			self.context = CM_ObjectMatchCriteria.StopCriteriaInt  or	//08/07/2022 navds20 TFS 53862
			self.context = CM_ObjectMatchCriteria.ShipLineStatusInt or //09/08/2023	navkc1	CR 59580	Task 59588
			self.context = CM_ObjectMatchCriteria.RoadGateAutoCompleteInt	//navra1 - 25th Jan 2024 - TFS 62081
			then 
		self.lblGroupName.visible := false;
	else
		self.lblGroupName.caption := app.getErrorString(Seq) &amp; ":";
	endif;
	self.lblGroupName.parent := self.grpTemplate;
	self.lblGroupName.transparent := true;
	
	// 28/11/2023	navkc1 Bug 60782
	self.lblGroupName.visible := true;
	self.lblGroupName.top := 5;
	self.lblGroupName.parentAspect := Control.ParentAspect_None;		//18/04/2025 navbs1 34563
	
	if self.context = CM_ObjectMatchCriteria.WagonRestrictionInt
	or self.context = CM_ObjectMatchCriteria.ReleaseByTypeInt	//11 Jun 2015	NDL	Par 36338
	or self.context = CM_ObjectMatchCriteria.VBSMatchingCriteriaInt 	//6/07/2022 navhl20 TFS 53697
	or self.context = CM_ObjectMatchCriteria.VBSExclusionInt	//15 May 2015	NDL	Par 36234
	or self.context = CM_ObjectMatchCriteria.TaskCriteriaInt	//15 Aug 2016	MAP TFS 2443
	or self.context = CM_ObjectMatchCriteria.ImexTransitionInt // TFS 37410
	or self.context = CM_ObjectMatchCriteria.VvrPackageInt		// 1/5/18 MAP TFS37340
	or self.context = CM_ObjectMatchCriteria.StopCriteriaInt //08/07/2022 navds20 TFS 53862
	or self.context = CM_ObjectMatchCriteria.ShipLineStatusInt //09/08/2023	navkc1	CR 59580	Task 59588
	or self.context = CM_ObjectMatchCriteria.RoadGateAutoCompleteInt	//navra1 - 25th Jan 2024 - TFS 62081
	then
		self.txtGroupName.visible := false;
	else
		self.txtGroupName.visible := true;
		self.txtGroupName.parent := self.grpTemplate;						//18/04/2025 navbs1 34563
		self.txtGroupName.top := self.lblGroupName.top;
		self.txtGroupName.width := 30;
		self.txtGroupName.dataType := 1; // Numeric
		//self.txtGroupName.parent := self.grpTemplate;						//18/04/2025 navbs1 34563
		self.txtGroupName.parentAspect := Control.ParentAspect_None;		//18/04/2025 navbs1 34563
	endif;
	
	if self.context = CM_ObjectMatchCriteria.WagonRestrictionInt
	or self.context = CM_ObjectMatchCriteria.VBSExclusionInt	//15 May 2015	NDL	Par 36234
	then
		self.cmbTerminal.visible := true;
		self.cmbTerminal.top := self.lblGroupName.top;
		self.cmbTerminal.width := 250;
		self.cmbTerminal.parent := self.grpTemplate;
		self.cmbTerminalPopulate();
	else
		self.cmbTerminal.visible := false;
	endif;
	
	self.lblYACode.visible := true;
	self.lblYACode.left := 2;
	self.lblYACode.top := self.lblGroupName.top + self.lblGroupName.height + 5;
	self.lblYACode.width := self.grpTemplate.width - 6;
	self.lblYACode.transparent := true;
	
	if self.context = CM_ObjectMatchCriteria.WagonRestrictionInt
	or self.context = CM_ObjectMatchCriteria.ReleaseByTypeInt	//11 Jun 2015	NDL	Par 36338
	or self.context = CM_ObjectMatchCriteria.VBSMatchingCriteriaInt 	//6/07/2022 navhl20 TFS 53697
	or self.context = CM_ObjectMatchCriteria.VBSExclusionInt	//15 May 2015	NDL	Par 36234
	or self.context = CM_ObjectMatchCriteria.StopCriteriaInt  // 08/07/2022 navds20 TFS 53862  
	or self.context = CM_ObjectMatchCriteria.TaskCriteriaInt	//15 Aug 2016	MAP TFS 2443
	or self.context = CM_ObjectMatchCriteria.ImexTransitionInt // TFS 37410
	or self.context = CM_ObjectMatchCriteria.VvrPackageInt		// 1/5/18 MAP TFS37340
	or self.context = CM_ObjectMatchCriteria.RoadGateCargoCheckInt //21 Oct 2019	NDL	TFS 46911
	or self.context = CM_ObjectMatchCriteria.ShipLineStatusInt //09/08/2023	navkc1	CR 59580	Task 59588
	or self.context = CM_ObjectMatchCriteria.RoadGateAutoCompleteInt	//navra1 - 25th Jan 2024 - TFS 62081
	then
		self.txtYACode.visible := false;
		self.txtYACode.top := 0;
		self.txtYACode.height := 0;
	else
		self.lblYACode.visible := true;
	endif;
	self.txtYACode.left := 2;
	self.txtYACode.top := self.lblYACode.top + self.lblYACode.height + 5;
	self.txtYACode.width := self.lblYACode.width;
	
	if context &gt; 0 then
		if self.context = CM_ObjectMatchCriteria.VBSExclusionInt then	//15 May 2015	NDL	Par 36234
			self.lblYACode.caption := app.getErrorString(Skip_assoc_form_when_cargo_mat);
			self.lblYACode.alignment := self.lblYACode.Alignment_Left_Middle;
		elseif self.context = CM_ObjectMatchCriteria.WagonRestrictionInt then
			self.lblYACode.caption := app.getErrorString1(Selec_crite_that_cargo_wagon_m, self.contextObject.CM_WagonMaster.id );
			self.lblYACode.alignment := self.lblYACode.Alignment_Left_Middle;
		elseif self.context = CM_ReportFormatMatchCriteria.RoadReceiptReportInt then
			self.lblYACode.caption := app.getErrorString(Enter_alter_road_recei_repor_n);
			self.lblYACode.alignment := self.lblYACode.Alignment_Left_Middle;
		elseif self.context = CM_ReportFormatMatchCriteria.ReleaseByTypeInt then
			self.lblYACode.caption := CM_ReportFormatMatchCriteria.ReleaseByTypeName;
			self.lblYACode.alignment := self.lblYACode.Alignment_Left_Middle;
		elseif self.context = CM_ReportFormatMatchCriteria.VBSMatchingCriteriaInt then		//6/07/2022 navhl20 TFS 53697
			self.lblYACode.caption := CM_ReportFormatMatchCriteria.VBSMatchingCriteriaName;
			self.lblYACode.alignment := self.lblYACode.Alignment_Left_Middle;
		elseif self.context = CM_TaskCriteria.TaskCriteriaInt then		//15 Aug 2016	MAP TFS 2443
			self.lblYACode.visible := false;
			self.lblYACode.alignment := self.lblYACode.Alignment_Left_Middle;
		elseif self.context = CM_ReportFormatMatchCriteria.DriverCriteriaInt then				//+TFS2899
			self.lblYACode.caption := app.getErrorString(Enter_alter_driver_instruct);
			self.lblYACode.alignment := self.lblYACode.Alignment_Left_Middle;	
		elseif self.context = CM_ReportFormatMatchCriteria.RpDriverCriteriaInt then				//+TFS2899
			self.lblYACode.caption := app.getErrorString(Enter_alter_rp_driver_instruct);		
			self.lblYACode.alignment := self.lblYACode.Alignment_Left_Middle;	
		elseif self.context = CM_ReportFormatMatchCriteria.VvrPackageInt then		// 2/3/18 MAP TFS37340
			self.lblYACode.caption := CM_ReportFormatMatchCriteria.VvrPackageName;
			self.lblYACode.alignment := self.lblYACode.Alignment_Left_Middle;
		elseif self.context = CM_ReportFormatMatchCriteria.StopCriteriaInt then		// 08/07/2022 navds20 TFS 53862
			self.lblYACode.caption := CM_ReportFormatMatchCriteria.StopCriteriaName; //08/07/2022 navds20 TFS 53862
			self.lblYACode.alignment := self.lblYACode.Alignment_Left_Middle;
		elseif self.context = CM_ReportFormatMatchCriteria.ImexTransitionInt then	// TFS 37410
			self.lblYACode.visible := false;	// TFS 37410
			self.lblYACode.alignment := self.lblYACode.Alignment_Left_Middle; // TFS 37410
			self.centreOverParent(0);	// TFS 38467
		elseif self.context = CM_ReportFormatMatchCriteria.RoadGateAutoCompleteInt then			//navra1 - 25th Jan 2024 - TFS 62081
			self.lblYACode.visible := false;													//navra1 - 25th Jan 2024 - TFS 62081
			self.lblYACode.alignment := self.lblYACode.Alignment_Left_Middle; 					//navra1 - 25th Jan 2024 - TFS 62081
			self.centreOverParent(0);															//navra1 - 25th Jan 2024 - TFS 62081
		elseif self.context = CM_ReportFormatMatchCriteria.InterchangeCriteriaInt then	//11 Jan 2019	NDL	TFS 40479
			self.lblYACode.caption := app.getErrorString(Alternate_interchang_reports);
			self.lblYACode.alignment := self.lblYACode.Alignment_Left_Middle;
		elseif self.context = CM_ReportFormatMatchCriteria.ShipLineStatusInt then //09/08/2023	navkc1	CR 59580	Task 59588
			self.lblYACode.caption := CM_ReportFormatMatchCriteria.ShipLineStatusName;
			self.lblYACode.alignment := self.lblYACode.Alignment_Left_Middle;
		else
			self.lblYACode.caption := method.qualifiedName &amp; " Unknown report!!";
		endif;
	elseif self.contextObject &lt;&gt; null then
		self.lblYACode.caption := method.qualifiedName &amp; " Unknown object type!!";
	endif;
	
	self.grpTemplate.height := self.txtYACode.top + self.txtYACode.height + 5;
	
	
	if self.context = CM_ReportFormatMatchCriteria.InterchangeCriteriaInt then	//11 Jan 2019	NDL	TFS 40479	
		left := 10;
		top := self.grpTemplate.height;
		height := 20;
		halfWidth := (self.grpTemplate.clientWidth / 2) - 6;
		self.lblPrinter.visible := true;
		self.lblPrinter.move( left, top + 2, self.lblPrinter.width, height );  // label is auto size
		left := self.lblPrinter.left + self.lblPrinter.width + 1;
		self.cmbPrinters.visible := true;
		self.cmbPrinters.move( left, top, halfWidth - (self.lblPrinter.width +self.lblPrinter.left + 1 ), height );
		left := halfWidth + 10;
		self.lblCopies.visible := true;
		self.lblCopies.move( left, top + 2, self.lblCopies.width, height ); // label is autoSize
		left := self.lblCopies.left + self.lblCopies.width + 1;
		self.txtPrintCopies.visible := true;
		self.txtPrintCopies.move( left, top, height, height );
		
		self.grpTemplate.height := self.grpTemplate.height + 25;
	endif;
	
	self.fldYardAlloc.top := self.grpTemplate.top + self.grpTemplate.height + 15;

	// setup criteria fields
	self.clrYAColour.top := self.picCriteria.height + self.frmCriteria.height + 10; 
	self.lblYAColour.top := self.clrYAColour.top; 
	self.clrYAColour.left := 157;
	self.lblYAColour.left := 22;
	
	criteriaFrame := self.frmCriteria.getControl( 1 );
	if criteriaFrame &lt;&gt; null then
		self.lblYAColour.alignment := TextBox.Alignment_Left;
		self.lblYAColour.left := criteriaFrame.lblCriteriaType.left;	//10
		self.lblYAColour.width := criteriaFrame.lblCriteriaType.width; //118;
		self.clrYAColour.left := criteriaFrame.txtCriteriaValue.left;	//130;
		self.clrYAColour.width := criteriaFrame.txtCriteriaValue.width;	//181;
	endif;
	
	if self.context = CM_ObjectMatchCriteria.WagonRestrictionInt then
		criteriaFrame := self.frmCriteria.getControl( 5 );
		self.lblYAColour.visible := true;
		self.clrYAColour.visible := true;
		self.picCriteria.height := self.picCriteria.height + criteriaFrame.height + 10;
		self.lblYAColour.parent := self.picCriteria;
		self.clrYAColour.parent := self.picCriteria;
		self.lblYAColour.top := criteriaFrame.top + criteriaFrame.height + 5;
		self.clrYAColour.top := self.lblYAColour.top;	
	elseif self.context = CM_ObjectMatchCriteria.VBSExclusionInt then	//15 May 2015	NDL	Par 36234
		criteriaFrame := self.frmCriteria.getControl( 5 );
		self.lblYAColour.visible := false;
		self.clrYAColour.visible := false;
	endif;
	
	if self.context = CM_ObjectMatchCriteria.ReleaseByTypeInt
	or self.context = CM_ObjectMatchCriteria.TaskCriteriaInt //11 Jun 2015	NDL	Par 36338	// TFS 2443
	or self.context = CM_ObjectMatchCriteria.VBSMatchingCriteriaInt	//6/07/2022 navhl20 TFS 53697
	or self.context = CM_ReportFormatMatchCriteria.ImexTransitionInt	 // TFS 37410
	or self.context = CM_ReportFormatMatchCriteria.RoadGateAutoCompleteInt	 //navra1 - 25th Jan 2024 - TFS 62081
	or self.context = CM_ObjectMatchCriteria.VvrPackageInt
	or self.context = CM_ObjectMatchCriteria.StopCriteriaInt //08/07/2022 navds20 TFS 53862
	or self.context = CM_ObjectMatchCriteria.RoadGateCargoCheckInt //21 Oct 2019	NDL	TFS 46911
	or self.context = CM_ObjectMatchCriteria.ShipLineStatusInt	//09/08/2023	navkc1	CR 59580	Task 59588
	then
		self.grpTemplate.visible := false;
		self.fldYardAlloc.top := 10;
		self.picCriteria.top := 10;
	endif;
	
	if self.context = CM_ObjectMatchCriteria.TaskCriteriaInt then	// 15 Aug 2016 MAP TFS 2443
		criteriaFrame := self.frmCriteria.getControl(5);
		self.lblGroupName.visible := false;
		self.lblAutoActions.visible := true;
		self.lblAutoActions.left := criteriaFrame.lblCriteriaType.left;
		self.lblAutoActions.top := criteriaFrame.top + criteriaFrame.height + 10;
		self.tblActions.visible := true;
		self.tblActions.top := self.lblAutoActions.top + 20;
		self.tblActions.left := self.lblAutoActions.left;
		self.tblActions.width := frmCriteria.width - frmCriteria.btnValuePicker.width;
		self.lblMoveCreate.visible := true;
		self.lblMoveCreate.left := self.tblActions.left;
		self.lblMoveCreate.top := self.tblActions.top + self.tblActions.height + 10;
		self.cmbMoveCreate.visible := true;
		self.cmbMoveCreate.left := 150;
		self.cmbMoveCreate.top := self.lblMoveCreate.top;
		self.lblMoveComplete.visible := true;
		self.lblMoveComplete.left := lblMoveCreate.left;
		self.lblMoveComplete.top := self.lblMoveCreate.top + 30;
		self.cmbMoveComplete.visible := true;
		self.cmbMoveComplete.left := self.cmbMoveCreate.left;
		self.cmbMoveComplete.top := self.lblMoveComplete.top;
	else
		self.lblAutoActions.visible := false;
		self.tblActions.visible := false;
		self.lblMoveCreate.visible := false;
		self.cmbMoveCreate.visible := false;
		self.lblMoveComplete.visible := false;
		self.cmbMoveComplete.visible := false;
	endif;

	if self.context = CM_ObjectMatchCriteria.TaskCriteriaInt then	// 15 Aug 2016 MAP TFS 2443
		// ### TFS 58761 (60739) 16Nov2023 NAVPW1
		if app.myPassport.isVASEnabled then
			newHeight := self.picCriteria.height + 160;
			self.height := self.fldYardAlloc.top + newHeight + 80;
			self.fldYardAlloc.height := newHeight;
			self.picCriteria.height := newHeight - 5;
			self.grpResourceGroups.visible := true;													
			self.grpResourceGroups.height := 270;
			self.grpResourceGroups.top := self.picCriteria.top + self.picCriteria.height -5;
			self.height := self.fldYardAlloc.top + newHeight + self.grpResourceGroups.height + 117;
			
			self.mulAvailableResourceGroups.height := 120;
			self.mulAvailableResourceGroups.width := self.grpResourceGroups.width - self.mulAvailableResourceGroups.left - 10;
			self.mulMandatoryResourceGroups.top := self.mulAvailableResourceGroups.top + self.mulAvailableResourceGroups.height + 10;
			self.mulMandatoryResourceGroups.height := 120;
			self.mulMandatoryResourceGroups.width := self.grpResourceGroups.width - self.mulMandatoryResourceGroups.left - 10;
		else
			newHeight := self.picCriteria.height + 230;
			self.height := self.fldYardAlloc.top + newHeight + 80;
			self.fldYardAlloc.height := newHeight;
			self.picCriteria.height := newHeight - 5;
		endif;
		// ### TFS 58761 (60739) 16Nov2023 NAVPW1
		
		// ### TFS 63920 (63924) 01May2024 NAVPW1
		if self.contextObject.CM_ToDoTaskDesc.type &lt;&gt; TODO_TYPE_GROUP_CARGOGROUP and 
			self.contextObject.CM_ToDoTaskDesc.type &lt;&gt; TODO_TYPE_GROUP_TI
		then
			self.picCriteria.visible := false;
			self.grpResourceGroups.top := 2;
			self.height := self.grpResourceGroups.height;
		endif;
		// ### TFS 63920 (63924) 01May2024 NAVPW1
		
	elseif self.context = CM_ObjectMatchCriteria.StopCriteriaInt  // ### TFS CR 59942 TASK 59943 23AUG2023 NAVAB1
		or self.context = CM_ObjectMatchCriteria.ReleaseByTypeInt then  //07 Mar 2024 navrv30 Bug 61941
		//newHeight := self.picCriteria.top + self.picCriteria.height + 230;	// 28/11/2023	navkc1 Bug 60782
		newHeight := self.picCriteria.top + self.picCriteria.height; 			// 28/11/2023	navkc1 Bug 60782
		
		self.fldYardAlloc.height := newHeight - 200;
		self.fldYardAlloc.parentBottomOffset := (self.btnSave.height + 20).Integer;
		self.picCriteria.height := self.fldYardAlloc.height - 40;
		self.height := self.fldYardAlloc.top + 80;
	else
		//newHeight := self.picCriteria.top + self.picCriteria.height + 30;
		newHeight := self.picCriteria.top + self.picCriteria.height + 230;	// 28/11/2023	navkc1 Bug 60782
		self.height := self.fldYardAlloc.top + newHeight + 80;
		self.fldYardAlloc.height := newHeight;
		self.picCriteria.height := self.fldYardAlloc.height - 35; // 28/11/2023	navkc1 Bug 60782
	endif;

	self.btnNext.visible := false;
	self.btnSave.left := self.btnNext.left;
	if self.context = CM_ObjectMatchCriteria.VBSExclusionInt then	//15 May 2015	NDL	Par 36234
		self.setCaption( app.getErrorString(VBS_Associatio_exclusion_crit) );
	elseif self.context = CM_ObjectMatchCriteria.WagonRestrictionInt then
		self.setCaption( app.getErrorString1(Wagon_cargo_restric_criteri,self.contextObject.CM_WagonMaster.id) );
	elseif self.context = CM_ObjectMatchCriteria.ReleaseByTypeInt then
		self.setCaption( CM_ObjectMatchCriteria.ReleaseByTypeName );
	elseif self.context = CM_ObjectMatchCriteria.StopCriteriaInt then		//11 July 2022 navhl20 TFS 53862
		self.setCaption( CM_ObjectMatchCriteria.StopCriteriaName );
	elseif self.context = CM_ObjectMatchCriteria.TaskCriteriaInt then	// 19 Aug 2016	MAP	TFS 2443
		self.setCaption(app.getErrorString(Task_match_criteria));
	elseif self.context = CM_ObjectMatchCriteria.ImexTransitionInt then // TFS 37410
		self.setCaption(CM_ObjectMatchCriteria.ImexTransitionName); // TFS 37410
	elseif self.context = CM_ObjectMatchCriteria.RoadGateAutoCompleteInt then 		//navra1 - 25th Jan 2024 - TFS 62081
		self.setCaption(CM_ObjectMatchCriteria.RoadGateAutoCompleteName); 			//navra1 - 25th Jan 2024 - TFS 62081
	elseif self.context = CM_ObjectMatchCriteria.RoadGateCargoCheckInt then	//21 Oct 2019	NDL	TFS 46911
		self.setCaption(CM_ObjectMatchCriteria.RoadGateCargoCheckName);
	elseif self.context = CM_ObjectMatchCriteria.VBSMatchingCriteriaInt then  	//6/07/2022 navhl20 TFS 53697
		self.setCaption( CM_ObjectMatchCriteria.VBSMatchingCriteriaName );
	elseif self.context = CM_ObjectMatchCriteria.StopCriteriaInt then //08/07/2022 navds20 TFS 53862
		self.setCaption(CM_ObjectMatchCriteria.ShipLineStatusName);
	else
		self.setCaption(app.getErrorString(Report_format_match_criteri));
	endif;
	
	if self.context &lt;&gt; CM_ObjectMatchCriteria.ReleaseByTypeInt  then
		self.txtGroupName.setFocus();
	endif;
	
	//28/11/2023			navkc1 Bug 60782
	self.minimumHeight := self.height.Integer;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="saveData" id="b5e3282c-51cd-4e14-bf99-122ea05623b5">
        <updating/>
        <source>saveData(_saveAs: Boolean): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
11 December 2013	cnwndl1	Initial creation
04/01/2017          cnwrh7  TFS    2899 Cargo Attribute Filter for Driver Instructions
28 March 2018		jlgsl4	TFS 37410 Import MTs IMEX transition status
23 june 2022	 navtnr20	ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
11 July 2022 	 navhl20	TFS 53862 EUP - WMS - Damage Recording Extra Details
09/08/2023		 navkc1		CR 59580	Task 59588: UI - CustDocs Customs Shipping Line Status
25th Jan 2024 	navra1 		 TFS 62081 - CUX | Auto-setdown of cargo that doesn't require a machine move
*/

vars

	seqNumber : Integer;
	reportName : String;
	allTransientCriteriaObj	: CMIF_Array;
	cmif_object : CMIF_Object;
	pxyObjMatch : CM_ObjectMatchCriteria;
	loadState : Boolean;
	result : Integer;
	wagonMaster : CM_WagonMaster;
	terminal : CM_Terminal;
	colour : Integer;
	vbst : CM_VehicleBookingTerminal;
	reserveSelection : CM_ReserveSelection;
	errMsg : String;
	actions: IntegerArray;
	bool: Boolean;
	str: String;
	index: Integer;
	creation,
	completion: Integer;
	deleteProxy: Boolean;
	vvrObject: CM_PackageVVR;
	transitionProxy : CM_IMEXTransitionCriteria; // TFS 37410
	roadGateAutoCompleteCriteria : CM_RoadGateAutoComplete;			//navra1 - 25th Jan 2024 - TFS 62081
	printerDef : CM_PrinterDef;
	numCopies : Integer;
	stopsTable	: CM_StopsTable;
	vbsTime :	CM_VehicleBookingTimeSlotType;
	shippingLineStatus : CM_ShippingLineStatus;
	availableResourceGroups,								// ### TFS 58761 (60739) 16Nov2023 NAVPW1
	mandatoryResourceGroups : CM_ResourceTypeGroupByCode;	// ### TFS 58761 (60739) 16Nov2023 NAVPW1
	
begin
	
	if self.context = CM_ObjectMatchCriteria.VBSExclusionInt then	//15 May 2015	NDL	Par 36234
		vbst := self.contextObject.CM_VehicleBookingTerminal;
		
	elseif self.context = CM_ObjectMatchCriteria.VBSMatchingCriteriaInt then	//24.06.2022 navtnr20	TFS 53697
		vbsTime := self.contextObject.CM_VehicleBookingTimeSlotType;
		
	elseif self.context = CM_ObjectMatchCriteria.WagonRestrictionInt then
		wagonMaster := self.contextObject.CM_WagonMaster;
		terminal := self.cmbTerminal.listObject.CM_Terminal;
		colour := self.clrYAColour.getColor;
		self.setMyTerminal( terminal );
		app.myPassport.setMyTerminal( terminal );
	elseif self.context = CM_ObjectMatchCriteria.ReleaseByTypeInt then
		reserveSelection := self.contextObject.CM_ReserveSelection;
	elseif self.context = CM_ObjectMatchCriteria.StopCriteriaInt then //05/07/2022 navds20 53862
		stopsTable := self.contextObject.CM_StopsTable; //05/07/2022 navds20 53862
	elseif self.context = CM_ObjectMatchCriteria.VvrPackageInt then
		vvrObject := self.contextObject.CM_PackageVVR;
	elseif self.context = CM_ObjectMatchCriteria.ImexTransitionInt then // TFS 37410
		transitionProxy := self.contextObject.CM_IMEXTransitionCriteria; // TFS 37410
	elseif self.context = CM_ObjectMatchCriteria.ShipLineStatusInt then //09/08/2023	navkc1	CR 59580	Task 59588
		shippingLineStatus:= self.contextObject.CM_ShippingLineStatus;
		terminal := shippingLineStatus.myTerminal;
	elseif self.context = CM_ObjectMatchCriteria.RoadGateAutoCompleteInt then 						//navra1 - 25th Jan 2024 - TFS 62081
		roadGateAutoCompleteCriteria := self.contextObject.CM_RoadGateAutoComplete; 				//navra1 - 25th Jan 2024 - TFS 62081
	else
		seqNumber := self.txtGroupName.text.Integer;
		reportName := self.txtYACode.text;
	endif;
	
	create allTransientCriteriaObj transient;
	self.getCriteriaAllCMIF( allTransientCriteriaObj );
	
	if self.myObjectMatchCriteria &lt;&gt; null and not self.myObjectMatchCriteria.isTransient then
		deleteProxy := true;
		app.cmsBeginLoad(loadState);
		pxyObjMatch := self.myObjectMatchCriteria.pxyCreateUpdateProxy();
		app.cmsEndLoad(loadState);
	elseif self.myObjectMatchCriteria &lt;&gt; null and self.myObjectMatchCriteria.isTransient then
		// let the real updating occur on the source from
		pxyObjMatch := self.myObjectMatchCriteria;
	else
		deleteProxy := true;
		if self.context &gt; 0 then
			if self.context = CM_ObjectMatchCriteria.VBSExclusionInt then	//15 May 2015	NDL	Par 36234
				create pxyObjMatch as CM_VBSExclusionCriteria transient;
			elseif self.context = CM_ObjectMatchCriteria.WagonRestrictionInt then
				create pxyObjMatch as CM_CargoRestrictionCriteria transient;
			elseif self.context = CM_ObjectMatchCriteria.RoadReceiptReportInt then
				create pxyObjMatch as CM_RoadReceiptFormat transient;
			elseif self.context = CM_ObjectMatchCriteria.ReleaseByTypeInt then
				create pxyObjMatch as CM_ReleaseByTypeCriteria transient;
			elseif self.context = CM_ObjectMatchCriteria.StopCriteriaInt then //05/07/2022 navds20 53862
				create pxyObjMatch as CM_StopCriteria transient;//05/07/2022 navds20 53862
			elseif self.context = CM_ObjectMatchCriteria.TaskCriteriaInt then	// TFS 2443
				create pxyObjMatch as CM_TaskCriteria transient;
			elseif self.context = CM_ObjectMatchCriteria.DriverCriteriaInt then //+ TFS2899
				create pxyObjMatch as CM_DriverInstructionFormat transient;
			elseif self.context = CM_ObjectMatchCriteria.RpDriverCriteriaInt then //+TFS2899
				create pxyObjMatch as CM_RpDriverInstructionFormat transient;
			elseif self.context = CM_ObjectMatchCriteria.VvrPackageInt then		// 2/3/18 MAP TFS37340
				create pxyObjMatch as CM_VVRPackageCriteria transient;
			elseif self.context = CM_ObjectMatchCriteria.ImexTransitionInt then // TFS 37410
				create pxyObjMatch as CM_IMEXTransitionCriteria transient;	// TFS 37410
			elseif self.context = CM_ObjectMatchCriteria.RoadGateAutoCompleteInt then 	//navra1 - 25th Jan 2024 - TFS 62081
				create pxyObjMatch as CM_RoadGateAutoComplete transient;				//navra1 - 25th Jan 2024 - TFS 62081
			elseif self.context = CM_ObjectMatchCriteria.InterchangeCriteriaInt then	//11 Jan 2019	NDL	TFS 40479
				create pxyObjMatch as CM_InterchangeReportFormat transient;
			elseif self.context = CM_ObjectMatchCriteria.RoadGateCargoCheckInt then	//21 Oct 2019	NDL	TFS 46911
				create pxyObjMatch as CM_RoadGateCargoCheckCriteria transient;
				
			elseif self.context = CM_ObjectMatchCriteria.VBSMatchingCriteriaInt then	//24.06.2022	navtnr20 TFS 53697
				create pxyObjMatch as CM_VBSSlotTypeCriteria transient;
			elseif self.context = CM_ObjectMatchCriteria.ShipLineStatusInt then 	//09/08/2023	navkc1	CR 59580	Task 59588
				create pxyObjMatch as CM_ShippingLineStatusCriteria transient;
			else
				app.msgBox("Report Type not coded for", app.getErrorString(Error), MsgBox_OK_Only);
				return false;
			endif;
		elseif self.contextObject &lt;&gt; null then
			app.msgBox("Object type not coded for", app.getErrorString(Error), MsgBox_OK_Only);
			return false;
		endif;
	endif;
	
	pxyObjMatch.setProxy( 	allTransientCriteriaObj,	//_criterias: CMIF_Array;
							seqNumber	//_priority : Integer
							);
							
	if self.context = CM_ObjectMatchCriteria.VBSExclusionInt then	//15 May 2015	NDL	Par 36234
		pxyObjMatch.CM_VBSExclusionCriteria.setProxyBaseData(	vbst//_vbst : CM_VehicleBookingTerminal
																	);
	elseif self.context = CM_ObjectMatchCriteria.VBSMatchingCriteriaInt then	//24.06.2022 navtnr20 TFS 53697
		pxyObjMatch.CM_VBSSlotTypeCriteria.setProxyBaseData(vbsTime);																														
		pxyObjMatch := null; // don't want to delete it in the epilog
		
		self.unloadForm;
	
		return true;
		
	elseif self.context = CM_ObjectMatchCriteria.WagonRestrictionInt then
		pxyObjMatch.CM_CargoRestrictionCriteria.setProxyBaseData(	colour,	//_colour : Integer;	
																	wagonMaster,	//_wagonMaster : CM_WagonMaster;
																	self.myTerminal// : CM_Terminal
																	);
	elseif self.context = CM_ObjectMatchCriteria.ReleaseByTypeInt then
		pxyObjMatch.CM_ReleaseByTypeCriteria.setProxyBaseData(	reserveSelection// : CM_ReserveSelection
																);
		errMsg := pxyObjMatch.CM_ReleaseByTypeCriteria.validateTransient;
		pxyObjMatch := null; // don't want to delete it in teh epilog
		if errMsg &lt;&gt; null then
			app.msgBox( errMsg, app.getErrorString(Error), MsgBox_OK_Only );
			return false;
		endif;
		
		self.unloadForm;
	
		return true;
		
	//Start //05/07/2022 navds20 53862
	elseif self.context = CM_ObjectMatchCriteria.StopCriteriaInt then
		pxyObjMatch.CM_StopCriteria.setProxyBaseData(	stopsTable// : CM_StopsTable
																);
		pxyObjMatch := null; // don't want to delete it in teh epilog
		
		self.unloadForm;
	
		return true;
	
	//End //05/07/2022 navds20 53862
	elseif pxyObjMatch.isReportFormatMatch then
		pxyObjMatch.CM_ReportFormatMatchCriteria.setProxyBaseReportData(	reportName,	//_reportName : String;
																			self.myTerminal// : CM_Terminal
																			);
																			
		if pxyObjMatch.CM_ReportFormatMatchCriteria.includePrintDets() then	//11 Jan 2019	NDL	TFS 40479
			printerDef := self.cmbPrinters.listObject.CM_PrinterDef;
			numCopies := self.txtPrintCopies.text.Integer;
			pxyObjMatch.CM_ReportFormatMatchCriteria.setPrintDets(	printerDef,	//_myPrinter : CM_PrinterDef;
																	numCopies	//_numCopies : Integer
																	);
		endif;
		
	elseif self.context = CM_ObjectMatchCriteria.TaskCriteriaInt then	// 16/8/16 MAP TFS 2443
		create actions transient;
		foreach index in 1 to self.tblActions.rows do
			bool := self.tblActions.accessCell(index, 1).text = TableCheckBox_Selected;
			if bool then
				str := self.tblActions.accessCell(index, 2).text;
				if str = app.getErrorString(Repair) then
					actions.add(TRANS_TYPE_REPAIR);
				elseif str = StopApplyPackCompleteStr then
					actions.add(TRANS_TYPE_PackComplete);
				elseif str = StopApplyUnpackCompleteStr then
					actions.add(TRANS_TYPE_UnpackComplete);
				endif;
			endif;
		endforeach;
		create availableResourceGroups transient;
		create mandatoryResourceGroups transient;
		
		self.mulAvailableResourceGroups.getSelected(availableResourceGroups);
		self.mulMandatoryResourceGroups.getSelected(mandatoryResourceGroups);
		
		creation := self.cmbMoveCreate.itemData[self.cmbMoveCreate.listIndex];
		completion := self.cmbMoveComplete.itemData[self.cmbMoveComplete.listIndex];
		pxyObjMatch.CM_TaskCriteria.setProxyBaseData(actions, completion, creation, self.myTerminal, self.contextObject.CM_ToDoTaskDesc, 
														availableResourceGroups, mandatoryResourceGroups);
		
	elseif self.context = CM_ObjectMatchCriteria.VvrPackageInt then
		pxyObjMatch.CM_VVRPackageCriteria.setProxyBaseData(vvrObject);
		//errMsg := pxyObjMatch.CM_ReleaseByTypeCriteria.validateTransient;
		pxyObjMatch := null; // don't want to delete it in teh epilog
		if errMsg &lt;&gt; null then
			app.msgBox( errMsg, app.getErrorString(Error), MsgBox_OK_Only );
			return false;
		endif;
		
		self.unloadForm;
	
		return true;
	elseif self.context = CM_ObjectMatchCriteria.ImexTransitionInt then // TFS 37410
		transitionProxy.setProxy(allTransientCriteriaObj, // TFS 37410
							seqNumber // TFS 37410
							); // TFS 37410
		allTransientCriteriaObj := null; // clear reference so criteria aren't disposed of		
		self.unloadForm; // TFS 37410
		return true; // TFS 37410
	elseif self.context = CM_ObjectMatchCriteria.RoadGateAutoCompleteInt then 			//navra1 - 25th Jan 2024 - TFS 62081
		roadGateAutoCompleteCriteria.setProxy(allTransientCriteriaObj, 					//navra1 - 25th Jan 2024 - TFS 62081
							seqNumber 													//navra1 - 25th Jan 2024 - TFS 62081
							); 															//navra1 - 25th Jan 2024 - TFS 62081
		allTransientCriteriaObj := null; 												//navra1 - 25th Jan 2024 - TFS 62081
		self.unloadForm; 																//navra1 - 25th Jan 2024 - TFS 62081
		return true; 																	//navra1 - 25th Jan 2024 - TFS 62081
	elseif self.context = CM_ObjectMatchCriteria.RoadGateCargoCheckInt then		//21 Oct 2019	NDL	TFS 46911
		pxyObjMatch.CM_RoadGateCargoCheckCriteria.setProxyBaseData(	self.myTerminal//_myTerminal : CM_Terminal
																	);
	elseif self.context = CM_ObjectMatchCriteria.ShipLineStatusInt then //09/08/2023	navkc1	CR 59580	Task 59588
		pxyObjMatch.CM_ShippingLineStatusCriteria.setProxyBaseData(terminal, shippingLineStatus);
		pxyObjMatch := null;
		self.unloadForm();
		return true;
	endif;

	while true do
	
		if self.myObjectMatchCriteria = null then
			app.myTrxCA.trxCreateObjMatchCrit( pxyObjMatch, self.myObjectMatchCriteria, app.myPassport );
		else
			app.myTrxUA.trxUpdateObjMatchCrit(pxyObjMatch, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Rail_colour_coding), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

		endif;
		
		return false;
		
	endwhile;
	
	self.unloadForm;
	
	return true;
	
epilog
	if deleteProxy then
		delete pxyObjMatch;
	//	if not allTransientCriteriaObj.isEmpty then	//14 Jan 2018	NDL	TFS 40479
		if allTransientCriteriaObj &lt;&gt; null and not allTransientCriteriaObj.isEmpty then	//23 Jan 2018	NDL	TFS 43045
			allTransientCriteriaObj.purge();
		endif;
	endif;
	
	delete allTransientCriteriaObj;
	app.cmsEndLoad(loadState);
	delete actions;
	delete availableResourceGroups;	// ### TFS 58761 (60739) 16Nov2023 NAVPW1
	delete mandatoryResourceGroups;	// ### TFS 58761 (60739) 16Nov2023 NAVPW1
end;</source>
        <Parameter name="_saveAs" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setBaseData" id="f1086fc1-f648-429d-ba11-c971f896fed6">
