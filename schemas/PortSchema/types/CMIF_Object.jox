    <JadeMethod name="getAuditTextForProperty" id="a5d79404-30bd-4474-842d-0b7571500fea">
        <source>getAuditTextForProperty( _property : Property; _ignoreNull : Boolean ) : String;

/*

Purpose:		This is based on the CM_Object::getAuditTextForProperty method and is being used to
				get the value of the property in a known format.
				
				NOTE: Cannot use the CM_Object class because it is abstract and
				need to include sub-classes of CMIF_Object.
				
				If the ignoreNull boolean is set then if the property has a null value then a null string is returned.

Date				Who		Reason
15 May 2009			cnwrl1	Initial creation as part of PAR 19668 - CCMS 1814 - Interface History

*/
	
constants
	AuditNullString		: String = AuditStringSeparator &amp; '4' &amp; AuditStringSeparator &amp; 'null' &amp; AuditStringSeparator;
	
vars
	rootCls				: Class;
	propName,
	text, 
	tempStr				: String;
	int					: Integer;
	type				: Type;
	obj 				: Object;
	date				: Date;
	time				: Time;
	timeStamp			: TimeStamp;
	invalidObject		: Boolean;
	
begin
	type := _property.type;
	if type = null then
		return null;
	endif;
	
	propName := _property.name;

	if type = String then				//most common check first
		tempStr	:= self.getPropertyValue( propName ).String.trimRight;
		if _ignoreNull and tempStr = null then
			return null;
		endif;
		text	:= self.formatAuditText( propName, tempStr );
	elseif type = Boolean then
		if self.getPropertyValue( propName ).Boolean then
			tempStr	:= AuditStringValue_Yes;
		else
			if _ignoreNull then
				return null;
			endif;
			tempStr	:= AuditStringValue_No;
		endif;
		text	:= self.formatAuditText( propName, tempStr );
		
	elseif type = Date then
		date := self.getPropertyValue( propName ).Date;
		if date = null or not date.isValid then
			if _ignoreNull then
				return null;
			endif;
			tempStr	:= "null";
		else
			tempStr	:= date.String;
		endif;
		text	:= self.formatAuditText( propName, tempStr );
		
	elseif type = Time then
		time := self.getPropertyValue( propName ).Time;
		if not time.isValid then
			if _ignoreNull then
				return null;
			endif;
			tempStr	:= "null";
		else
			tempStr	:= time.String;
		endif;
		text	:= self.formatAuditText( propName, tempStr );
		
	elseif type = TimeStamp then
		timeStamp := self.getPropertyValue( propName ).TimeStamp;
		if timeStamp = null or not timeStamp.isValid then
			if _ignoreNull then
				return null;
			endif;
			tempStr	:= "null";
		else
			tempStr	:= timeStamp.String;
		endif;
		text	:= self.formatAuditText( propName, tempStr );
		
	elseif type = Integer then	// 30 Mar 2011	NDL	Par 27290	
		int	:= self.getPropertyValue( propName ).Integer;
		if _ignoreNull and int = 0 then
			return null;
		endif;
		tempStr := int.String;
		text	:= self.formatAuditText( propName, tempStr );
		
	elseif type.isKindOf(Class) then
		rootCls := type.rootType.Class;
		if rootCls &lt;&gt; null then
			if rootCls = CM_Object or rootCls.inheritsFrom( CM_Object ) then
				obj := self.getPropertyValue( propName ).Object;
				if obj = null then
					if _ignoreNull then
						return null;
					endif;
					text	:= propName &amp; AuditNullString;
				else
					on Exception do app.handleDeletedObject( exception, obj, invalidObject );
					tempStr	:= obj.CM_Object.auditIdDisplay;
					if invalidObject then
						if _ignoreNull then
							return null;
						endif;
						text	:= propName &amp; AuditNullString;
					else
						text	:= self.formatAuditText( propName, tempStr );
					endif;
				endif;
			elseif rootCls = CM_ObjectArray or rootCls.inheritsFrom( CM_ObjectArray ) then
				obj := self.getPropertyValue( propName ).Object;
				if obj = null then
					if _ignoreNull then
						return null;
					endif;
					text	:= propName &amp; AuditNullString;
				else
					tempStr	:= obj.CM_ObjectArray.auditIdDisplay();
					if tempStr = null then
						if _ignoreNull then
							return null;
						endif;
						text	:= propName &amp; AuditNullString;
					else
						text	:= self.formatAuditText( propName, tempStr );
					endif;
				endif;
			elseif rootCls = CM_MemberKeyDictionary or rootCls.inheritsFrom( CM_MemberKeyDictionary ) then
				obj := self.getPropertyValue( propName ).Object;
				if obj = null then
					if _ignoreNull then
						return null;
					endif;
					text	:= propName &amp; AuditNullString;
				else
					tempStr	:= obj.CM_MemberKeyDictionary.auditIdDisplay();
					text	:= self.formatAuditText( propName, tempStr );
				endif;
			endif;
		endif;
	elseif type &lt;&gt; Binary then
		tempStr	:= self.getPropertyValue( propName ).String.trimRight;
		if _ignoreNull and tempStr = null then
			return null;
		endif;
		text	:= self.formatAuditText( propName, tempStr );
	endif;
	
	return text;
	
epilog
	
end;
</source>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_ignoreNull" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="d56e64d8-3436-4356-9b24-f57935e9dad4">
