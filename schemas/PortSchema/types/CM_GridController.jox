    <JadeMethod name="getPreviousControllerOfType" id="9bb91cf7-af5d-4aaa-a088-cba505d9293f">
        <source>getPreviousControllerOfType(typeClass : Class) : CM_GridController;
/*
 ------------------------------------------------------------------------
Created:			16 January 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	gc : CM_GridController;
begin
	gc := self.myPreviousController;
	if gc = null then
		return null;
	endif;
	if not gc.isKindOf(typeClass) then
		return null;
	endif;
	return gc;
end;</source>
        <Parameter name="typeClass" type="Class"/>
        <ReturnType type="CM_GridController"/>
    </JadeMethod>
    <JadeMethod name="getPrimaryIDforOddLengths" id="447a31da-ac75-42c5-821d-7a876b3e72ae">
        <source>getPrimaryIDforOddLengths(_lengthAttr: Integer): String;
/* ---------------------------------------------------------------------------
Created:     16 October 2008 by cnwrs2

Purpose:     PAR 18215 refer note on CM_LocationsController implementation
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	priorLC	: CM_LocationsController;
begin

	if _lengthAttr = TI_Attrib_IsFortyFive then
		if self.is45ft and
		   self.offset45 = CM_LocationsController.Offset45_Unavailable then
			priorLC := self.myPreviousController;
			if priorLC &lt;&gt; null and priorLC.offset45 = CM_LocationsController.Offset45_Unavailable then
				priorLC := priorLC.CM_GridController.myPreviousController;
			endif;
		else
			return self.getFullId();
		endif;
		
	elseif _lengthAttr = TI_Attrib_IsThirty then
		if  self.is30ft and
		  (self.offset30 = CM_LocationsController.Offset30_Unavailable 
		  or self.offset30 = CM_LocationsController.Offset30_3) then
			priorLC := self.myPreviousController;
			if priorLC &lt;&gt; null and priorLC.offset30 = CM_LocationsController.Offset30_Unavailable then
				priorLC := priorLC.CM_GridController.myPreviousController;
			endif;
		else
			return self.getFullId();
		endif;

	elseif _lengthAttr = TI_Attrib_IsFiftyThree then
		if  self.is53ft and
		  (self.offset53 = CM_LocationsController.Offset53_Unavailable 
		  or self.offset53 = CM_LocationsController.Offset53_8) then
			priorLC := self.myPreviousController;
			if priorLC &lt;&gt; null and priorLC.offset53 = CM_LocationsController.Offset53_Unavailable then
				priorLC := priorLC.CM_GridController.myPreviousController;
			endif;
		else
			return self.getFullId();
		endif;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled length attribute (' &amp; _lengthAttr.String &amp; ')');
		return null;
	endif;
	
	if priorLC = null then
		return null;
	else
		if self.class &lt;&gt; priorLC.class then
			return null;
		endif;
		return priorLC.getFullId();
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_lengthAttr" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getProximity" id="ee1029b4-a982-4b57-9d50-fca33e57676f">
        <source>getProximity(_otherLC: CM_GridController; vertProx: Integer output; horzProx: Integer output; depthProx: Integer output);
/*
----------   ----------  --------------------------------------------------
Created:	27 November 2006 By cnwth2

Purpose:	vertical span = accross rows
			horizontal span = accross columns
			depth span = N/A at this time

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	colIdx,
	rowIdx,
	fromIdx, 
	toIdx			: Integer;
	gridCol			: CM_GridColumn;
	gridRow			: CM_GridRow;
	gridArea		: CM_GridArea;
	
begin
	//vertProx := (self.row - _otherLC.row).positive;
	//th2 changed to skip gap columns when working out vertical proximity
	gridArea := self.myGridArea;
	fromIdx := self.row.min(_otherLC.row);
	toIdx := self.row.max(_otherLC.row);
	vertProx := -1;
	foreach rowIdx in fromIdx to toIdx do
		gridRow := gridArea.allGridRows[rowIdx];
		if gridRow = null or gridRow.hasGap then
			continue;
		endif;
		
		vertProx := vertProx + 1;
	endforeach;

	//horzProx := (self.column - _otherLC.column).positive;
	fromIdx := self.column.min(_otherLC.column);
	toIdx := self.column.max(_otherLC.column);
	horzProx := -1;
	foreach colIdx in fromIdx to toIdx do
		gridCol := gridArea.allGridColumns[colIdx];
		if gridCol = null or gridCol.hasGap then
			continue;
		endif;
		
		horzProx := horzProx + 1;
	endforeach;

end;


</source>
        <Parameter name="_otherLC" type="CM_GridController"/>
        <Parameter name="vertProx" type="Integer" usage="output"/>
        <Parameter name="horzProx" type="Integer" usage="output"/>
        <Parameter name="depthProx" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getRowColumn" id="f8c8ab55-4478-4190-adbd-7e158064d8c5">
        <source>getRowColumn(_row: Integer output; _column: Integer output; _flippedH, _flippedV : Boolean);
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aGA : CM_GridArea;
begin
	if self.myGridRow = null then
		return;
	endif;
	
	// ### NOT FLIPPED
	if not _flippedH and not _flippedV then
		if self.isStraddleController() then
			_row := self.myGridRow.row;
			_column := self.myGridColumn.column;
		elseif self.isForkLiftController() then
			_column := self.myGridRow.row;
			_row := self.myGridColumn.column;
		else
			_row := self.myGridRow.row;
			_column := self.myGridColumn.column;
		endif;
	else
		aGA := self.myGridArea;
		// ### FLIPPED BOTH WAYS
		if  _flippedH and _flippedV then
			if self.isStraddleController() then
				_row := (aGA.allGridRows.last.row - self.myGridRow.row) + 1;
				_column := (aGA.allGridColumns.last.column - self.myGridColumn.column) + 1;
			elseif self.isForkLiftController() then
				_column := (aGA.allGridRows.last.row - self.myGridRow.row) + 1;
				_row := (aGA.allGridColumns.last.column - self.myGridColumn.column) + 1;
			else
				_row := (aGA.allGridRows.last.row - self.myGridRow.row) + 1;
				_column := (aGA.allGridColumns.last.column - self.myGridColumn.column) + 1;
			endif;
		// ### FLIPPED VERTICALLY ONLY
		elseif  _flippedV then
			if self.isStraddleController() then
				_row := (aGA.allGridRows.last.row - self.myGridRow.row) + 1;
				_column := self.myGridColumn.column;
			elseif self.isForkLiftController() then
				_column := (aGA.allGridRows.last.row - self.myGridRow.row) + 1;
				_row := self.myGridColumn.column;
			else
				_row := (aGA.allGridRows.last.row - self.myGridRow.row) + 1;
				_column := self.myGridColumn.column;
			endif;
		// ### FLIPPED HORIZONTALLY ONLY
		else
			if self.isStraddleController() then
				_row := self.myGridRow.row;
				_column := (aGA.allGridColumns.last.column - self.myGridColumn.column) + 1;
			elseif self.isForkLiftController() then
				_column := self.myGridRow.row;
				_row := (aGA.allGridColumns.last.column - self.myGridColumn.column) + 1;
			else
				_row := self.myGridRow.row;
				_column := (aGA.allGridColumns.last.column - self.myGridColumn.column) + 1;
			endif;

		endif;
	endif;
end;</source>
        <Parameter name="_row" type="Integer" usage="output"/>
        <Parameter name="_column" type="Integer" usage="output"/>
        <Parameter name="_flippedH" type="Boolean"/>
        <Parameter name="_flippedV" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getRowIndexForYALocnCell" id="0d53d5a5-e67d-4289-b2e5-d53d2441b8ed">
        <source>getRowIndexForYALocnCell(_stackHeight: Integer; _forIn: Boolean): Integer;
//----------------------------------------------------------------
//	Created:	19 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if _stackHeight &gt; self.allYAYardLocationCells.size 
	or self.myGridRow = null then
		return 0;
	endif;
	
	if _forIn then
		if self.myGridRow.myDeckingOptions &lt;&gt; null then
			return self.myGridRow.myDeckingOptions.allYALocationCellsIn.indexOf(self.allYAYardLocationCells[_stackHeight]);
		else
			return 0;
		endif;
	else
		if self.myGridRow.myDeckingOptions &lt;&gt; null then
			return self.myGridRow.myDeckingOptions.allYALocationCellsOut.indexOf(self.allYAYardLocationCells[_stackHeight]);
		else
			return 0;
		endif;
	endif;

end;</source>
        <Parameter name="_stackHeight" type="Integer"/>
        <Parameter name="_forIn" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRowLabel" id="e7db8570-02d9-4bbc-9b2e-9c665f78abb0">
        <source>getRowLabel() : String;
/*
 ------------------------------------------------------------------------
Created:			15 January 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if self.myGridRow = null then
		return null;
	endif;
	return self.myGridRow.label;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSideAccess" id="2feae071-9e8f-4ca5-a2e6-886ca1eb19ae">
        <source>getSideAccess(	_yaBlock : CM_YABlock ) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 December 2009	cnwer1	Initial creation

*/

vars

begin
	if _yaBlock &lt;&gt; null then
		return _yaBlock.getSideAccess(self,false);
	else
		return self.getDefaultDeckingSideAccess;
	endif;
epilog

end;</source>
        <Parameter name="_yaBlock" type="CM_YABlock"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSideAccessRestrictingLCs" id="8b22915e-25de-42d0-8a71-cd01689425ae">
        <source>getSideAccessRestrictingLCs(	_sideAccess: Integer;
								_restrictingLCs : CM_LCSet input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 January 2010	cnwer1	Initial creation

*/

vars
	currentGridCol : CM_GridColumn;
	iter : Iterator;
	gridController : CM_GridController;
begin

	
	//Nedd to handle containers &gt; 20 ft
	
	currentGridCol:=self.myGridArea.allGridColumns[self.column];
	iter:=currentGridCol.allControllersByRow.createIterator;
	currentGridCol.allControllersByRow.startKeyGeq(self.row,iter);

	
	if _sideAccess = CM_YABlock.SideAccess_Front or 
		_sideAccess = CM_YABlock.SideAccess_Both then
		while iter.next(gridController) do
			if gridController = self then
				continue;
			endif;
			if not _restrictingLCs.includes(gridController) then
				_restrictingLCs.add(gridController);
			endif;
		endwhile;
	endif;
	
	if _sideAccess = CM_YABlock.SideAccess_Back or 
		_sideAccess = CM_YABlock.SideAccess_Both then 
		while iter.back(gridController) do
			if gridController = self then
				continue;
			endif;
			if not _restrictingLCs.includes(gridController) then
				_restrictingLCs.add(gridController);
			endif;
		endwhile;
	endif;

	if not _restrictingLCs.includes(self) then	
		_restrictingLCs.add(self);
	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="_sideAccess" type="Integer"/>
        <Parameter name="_restrictingLCs" type="CM_LCSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSpannedToLCs" id="dbff8a14-972b-478e-8535-a682269482ca">
        <source>getSpannedToLCs(control: CMIF_MoveController input): Boolean;
/*
 ------------------------------------------------------------------------
Created:			28 September 2001 by cnwdwq1
Purpose:			Returns the EXTRA LC's this TI will need to sit over.
							We DONT check capacity at this point
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	units 	: Real;
	tArray 	: CM_LCArray;
	lc 		: CM_GridController;
	count 	: Integer;
begin
	inheritMethod(control);		//Clears toSecondaryLocations coll
	//Determine the # of spaces this TI will take up
	units := control.myTrackedItem.getLengthInUnits();
	if units &lt;= 2 then
		//---------------
		//This controller will carry it off (2 * 10' units = my size. i.e. 1 * 20' unit)
		//---------------
		return true;
	endif;
	//---------------
	//Convert to 20' scale
	//---------------
	units := units div 2;
	
	//---------------
	//Because each of me is a 20' unit, I need one for each 2 units returned from the call
	//as they are 10' units.
	//---------------
	create tArray transient;
	lc := self.myNextController;

	if lc = null then
		//There is NO next LC!
		return false;
	endif;
	count := 1;
	while true do
		if lc.isSuitableForTI(control) = false then
			//An LC is not suitable for the TI
			break;
		endif;
		tArray.add(lc);
		count := count + 1;
		if count = units then
			break;
		endif;
		lc := self.myNextController;	
		if lc = null then
			break;
		endif;
	endwhile;	
	//--------------------
	//Return whether there are enough positions
	//--------------------
	if (tArray.size ) &lt;&gt; units - 1 then
		//Subtract 1 for the current lc where we started from (its NOT in the array returned)
		return false;
	endif;
	//Set the array
	control.setMyToSecondaryLocations(tArray);
	return true;
epilog
	delete tArray;
end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSpannedToLCsNEW" id="e6affd54-ea60-4688-8e63-df0d48e5c625">
        <source>getSpannedToLCsNEW(control: CMIF_MoveController input): String;
/*
 ------------------------------------------------------------------------
Created:			28 September 2001 by cnwdwq1
Purpose:			Returns the EXTRA LC's this TI will need to sit over.
							We DONT check capacity at this point
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	units 	: Real;
	tArray 	: CM_LCArray;
	lc 		: CM_GridController;
	count 	: Integer;
	
begin

	//Determine the # of spaces this TI will take up
	units := control.myTrackedItem.getLengthInUnits();

	// PAR 18682
	if not control.myTrackedItem.isThirty() and units &lt;= 2 then
	
		//09 Sep 2020	NDL	TFS 49984
		if control.isForcedMove = false and self.isSuitableForTI(control) = false then
			return self.notSuitableForTIString();
		endif;
		
		return null;
	endif;
/* PAR 18682
	if units &lt;= 2 then
		//---------------
		//This controller will carry it off (2 * 10' units = my size. i.e. 1 * 20' unit)
		//---------------
		return null;
	endif;
	*/
	//---------------
	//Convert to 20' scale
	//---------------
//	units := units div 2;

	units := self.getNumUnitsFlexiOffset(control.myTrackedItem); // PAR 18682 #############################
	
	if units = 1 then
		if control.myTrackedItem.isThirty() then
			lc := self.myNextController;
			if lc &lt;&gt; null then
				if lc.allTrackedItems.isEmpty() then
					return null;
				endif;
				
				return self.isThereRoomForTI(lc, control, control.myTrackedItem);
			endif;
		endif;
		return null;
	endif;
	
	//---------------
	//Because each of me is a 20' unit, I need one for each 2 units returned from the call
	//as they are 10' units.
	//---------------
	create tArray transient;
	lc := self.myNextController;

	if lc = null then
		//There is NO next LC!
		//return "Greater than 20' and no pad.";
		return app.getErrorString1(ERR_No_Room, null); // PAR 18682
	endif;
	count := 1;
	while true do
		if lc.isSuitableForTI(control) = false then
			return lc.notSuitableForTIString();
		endif;
		 // AKB2003JUNE from here - converted Fork Stacks have gap controllers with zero width
		if lc.isKindOf(CM_GapController) then
			if lc.CM_GapController.width = 0 then 
				lc := lc.myNextController; 
				if lc &lt;&gt; null then
					if lc.isSuitableForTI(control) = false then
						return lc.notSuitableForTIString();
					endif;
				else
					//return "Greater than 20' and no pad.";
					return app.getErrorString1(ERR_No_Room, null); // PAR 18682
				endif;
			endif; // AKB2003JUNE
		endif; // AKB2003JUNE to here
		
		tArray.add(lc);
		count := count + 1;
		if count = units then
			break;
		endif;	
		if lc.myNextController = null then
			break;
		endif;
// PAR 18682		lc := self.myNextController; // AKB2002JULY added incase we are looking &gt; 40
		lc := lc.myNextController; // AKB2002JULY added incase we are looking &gt; 40
	endwhile;	
	//--------------------
	//Return whether there are enough positions
	//--------------------
	if (tArray.size ) &lt;&gt; units - 1 then
		//Subtract 1 for the current lc where we started from (its NOT in the array returned)
		//return "Not enough Pads";
		return app.getErrorString1(ERR_No_Room, null); // PAR 18682
	endif;
	//Set the array
	control.setMyToSecondaryLocations(tArray);
	return null;
epilog
	delete tArray;
end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStackHeightOfTIs" id="b5090b58-0d9f-4787-8d2a-4067857ddc18">
        <source>getStackHeightOfTIs(mode : Integer; _ti : CM_TrackedItem)	:	Integer protected;
//Looks at the TI's in this area, evaluates them in terms of their REAL height
//and returns the height. (a full height box = 2, a 1/2 height box = 1)
//so, 2 fulls and a 1/2 height will return 5. Multiply the parent's area.height
//by 2 to get the maximum height allowable.
vars
	ti	:	CM_TrackedItem;
	array :	CM_TIArray;
	totalHeight	:	Integer;
begin
	create array transient;
	
	self.getTIs(array, mode, true); // PAR 27749
	foreach ti in array do
		if _ti &lt;&gt; null and _ti = ti then
			continue;
		endif;
		totalHeight := totalHeight + ti.getHeightOfTI();
	endforeach;

	if totalHeight &lt; 0 then
		totalHeight := 0;
	endif;
	return totalHeight;
epilog
	delete array;
end;</source>
        <access>protected</access>
        <Parameter name="mode" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getStackHeightOfTIsArray" id="d0ce7723-4139-4ba8-93eb-1f8de4843811">
        <source>getStackHeightOfTIsArray(_mode : Integer;_array :	CM_TIArray input)	:	Integer protected;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//Looks at the TI's in this area, evaluates them in terms of their REAL height
//and returns the height. (a full height box = 2, a 1/2 height box = 1)
//so, 2 fulls and a 1/2 height will return 5. Multiply the parent's area.height
//by 2 to get the maximum height allowable.
vars
	ti	:	CM_TrackedItem;
	totalHeight	:	Integer;
begin
//	return self.allTrackedItems.size;


	_array.clear;
	self.getTIs(_array, _mode, true); // PAR 27749
	foreach ti in _array do
		totalHeight := totalHeight + ti.getHeightOfTI();
	endforeach;
	return totalHeight;
end;</source>
        <access>protected</access>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_array" type="CM_TIArray" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getStackHeightOfTIsColour" id="ac1cbd50-f031-4317-b2f4-7761f89d9f22">
        <source>getStackHeightOfTIsColour() : Integer;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		

// ---------------------------------------------------------------------------
vars
begin
	
	return -1;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getStackHeightOfTIsOthers" id="8f9d5adf-e478-4ed9-a636-df00eca0cd6d">
        <source>getStackHeightOfTIsOthers(_control : CMIF_MoveController) : Integer;
// ---------------------------------------------------------------------------
// Created:     12 January 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	ti	:	CM_TrackedItem;
	array :	CM_TIArray;
	totalHeight	:	Integer;
begin
	create array transient;
	
	self.getTIs(array, _control.moveMode, true); // PAR 27749
	foreach ti in array do
		if _control.myTrackedItem &lt;&gt; null and _control.myTrackedItem = ti then
			continue;
		endif;
		if _control.allOtherTrackedItems.includes(ti) then
			continue;
		endif;
		
		totalHeight := totalHeight + ti.getHeightOfTI();
	endforeach;

	if totalHeight &lt; 0 then
		totalHeight := 0;
	endif;
	return totalHeight;
epilog
	delete array;

end;</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTIsRestrictingAccess" id="977abd13-76f1-4216-8f5e-d81ce8d09be6">
        <updating/>
        <source>getTIsRestrictingAccess(sourceTI : CM_Container; tiToMoveLocn : CM_LocationsController; a40InFront : Boolean; a40SameOrdColAs20 : Boolean; tisInTheWay : CM_TIArray input) updating;
// ---------------------------------------------------------------------------
// Created:		September 2001 By Andrew Bishop cnwab1
//
// Purpose:		get all the TIs in the given location that need to be moved out of the way. 
//				this code should also pick off 20s in the stack next to us if a 40 is involved
//				Note. Every Location controller has a gap controller next to it. The gap controller may not be available.
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
	tiToMove, tiNextToUs				: CM_TrackedItem;
	sourceIs40 : Boolean;
	i, lAccess, lRow, lCol, tiIndex,
	numTINextDoor		: Integer;
	lStackControllerInQuestion : CM_GridController;
begin

//	sourceIs40 := sourceTI.is40;
	sourceIs40 := sourceTI.requiresMoreThan1TwentyLC();// PAR 16415 CCMS 1029
	// if the source is a 20 but there are 40s infront of it we need to check for 20s to the side
	// RIGHT HANDSIDE OF 40. The 20 may be 'under' the right or the left hand side of the 40
//	if a40SameOrdColAs20 and tiToMoveLocn.CM_StackController.next &lt;&gt; null then
	if a40SameOrdColAs20 and tiToMoveLocn.CM_GridController.testMyNextController(self.class) then
		// only look at the location next to us if the gap next to us is not available
		if sourceTI.getPrimaryLocation(REAL_MODE).CM_GridController.testMyNextController(self.class) then // FLS Location Controllers always have a gap controller
			lStackControllerInQuestion := tiToMoveLocn.CM_GridController.myNextController.CM_GridController;
			numTINextDoor := lStackControllerInQuestion.allTrackedItems.size;
			if not sourceIs40 
			and a40InFront
			// the tiToMoveLocn that is passed in, is each location in front/behind of us i.e. in the same column
			// this code is getting rid of any 20's that are in the column next to the source TIs column, that are above the height of the 
			// TIs in the location that we are checking that is in the same column as the source TI, so that the 2 columns are even.
			// the next bit of code then takes the TIs evenly from this column and the next column
			and tiToMoveLocn.CM_GridController.allTrackedItems.size &lt; numTINextDoor then
				foreach tiToMove in lStackControllerInQuestion.allTrackedItems reversed do : thisLoop
					tiIndex := lStackControllerInQuestion.allTrackedItems.indexOf(tiToMove);
					if tiToMoveLocn.CM_GridController.allTrackedItems.size &gt;= tiIndex then
						break thisLoop;
					endif;
					if tiToMove.CM_Container.is40 then
		//write "AKB" &amp; " " &amp; class.name &amp; '::' &amp; method.name &amp; " 1. tiToMove " &amp; tiToMove.id;
						app.setContinueCMExceptions(false);
						app.raiseCMException(ERR_40_FOOT_OVERSTOWED, null, null);
						tisInTheWay.clear;
						return;					
					else
						tisInTheWay.add(tiToMove);
					endif;
				endforeach;
			endif;
		endif;
	endif;
	// LEFT HANDSIDE OF 40. The 20 may be 'under' the right or the left hand side of the 40
	// get rid of TIs in the previous location
//	if not a40SameOrdColAs20 and tiToMoveLocn.CM_StackController.previous &lt;&gt; null then
	if not a40SameOrdColAs20 and tiToMoveLocn.CM_GridController.myPreviousController &lt;&gt; null then
		// only look at the location next to us if the gap next to us is not available
		if sourceTI.getPrimaryLocation(REAL_MODE).CM_GridController.testMyPreviousController(self.class) then
			lStackControllerInQuestion :=  tiToMoveLocn.CM_GridController.myPreviousController.CM_GridController;
			numTINextDoor := lStackControllerInQuestion.allTrackedItems.size;

			if not sourceIs40 
			and a40InFront
			// the tiToMoveLocn that is passed in, is each location in front/behind of us i.e. in the same column
			// this code is getting rid of any 20's that are in the column next to the source TIs column, that are above the height of the 
			// TIs in the location that we are checking that is in the same column as the source TI, so that the 2 columns are even.
			// the next bit of code then takes the TIs evenly from this column and the next column
			and tiToMoveLocn.CM_GridController.allTrackedItems.size &lt; numTINextDoor then
				foreach tiToMove in lStackControllerInQuestion.allTrackedItems reversed do : thisLoop
					tiIndex := lStackControllerInQuestion.allTrackedItems.indexOf(tiToMove);
					if tiToMoveLocn.CM_GridController.allTrackedItems.size &gt;= tiIndex then
						break thisLoop;
					endif;
					if tiToMove.CM_Container.is40 then
		
						app.setContinueCMExceptions(false);
						app.raiseCMException(ERR_40_FOOT_OVERSTOWED, null, null);
						tisInTheWay.clear;
						return;					
					else
						tisInTheWay.add(tiToMove);
					endif;
				endforeach;
			endif;
		endif;
	endif;
	// if we are moving a 40 check whether there is possibly a stack of 20s in the way on the right hand side of the 40
	if tiToMoveLocn.CM_GridController.testMyNextController(self.class) then
		lStackControllerInQuestion := tiToMoveLocn.CM_GridController.myNextController.CM_GridController;
		numTINextDoor := lStackControllerInQuestion.allTrackedItems.size;
		if sourceIs40 and tiToMoveLocn.CM_GridController.allTrackedItems.size &lt;  numTINextDoor then
			foreach tiToMove in lStackControllerInQuestion.allTrackedItems reversed do : thisLoop
				tiIndex := lStackControllerInQuestion.allTrackedItems.indexOf(tiToMove);
				if tiToMoveLocn.CM_GridController.allTrackedItems.size &gt;= tiIndex then
					break thisLoop;
				endif;
				if tiToMove.CM_Container.is40 then
	
					app.setContinueCMExceptions(false);
					app.raiseCMException(ERR_40_FOOT_OVERSTOWED, null, null);
					tisInTheWay.clear;
					return;					
				else
					tisInTheWay.add(tiToMove);
				endif;
			endforeach;
		endif;
	endif;
	foreach tiToMove in tiToMoveLocn.CM_GridController.allTrackedItems reversed do : outerLoop
		if tiToMove = sourceTI then
			break outerLoop;
		endif;
		
		// if the ti that we are wanting to move is a 40 that is not actually on top of our source 20 then 
		// stop as it is too complicated to move. NOTE tiToMove is not the source
		// this means that the 20 must have the same ordinal column or 1 less as the 40
//		if tiToMove.CM_Container.is40 and sourceTI.getPrimaryLocation(REAL_MODE).CM_StackController.ordinalColumn &lt;&gt;  tiToMove.getPrimaryLocation(REAL_MODE).CM_StackController.ordinalColumn then
		if tiToMove.CM_Container.is40 and sourceTI.getPrimaryLocation(REAL_MODE).CM_GridController.column 
									  &lt;&gt;  tiToMove.getPrimaryLocation(REAL_MODE).CM_GridController.column then
			// if the source 20 is not actually under the 40, it could result in hundreds of moves so stop
//			if (sourceTI.getPrimaryLocation(REAL_MODE).CM_StackController.ordinalColumn - 1) &lt;&gt;  tiToMove.getPrimaryLocation(REAL_MODE).CM_StackController.ordinalColumn then
			if (sourceTI.getPrimaryLocation(REAL_MODE).CM_GridController.column - 1) 
			&lt;&gt;  tiToMove.getPrimaryLocation(REAL_MODE).CM_GridController.column then

				app.setContinueCMExceptions(false);
				app.raiseCMException(ERR_40_FOOT_OVERSTOWED, null, null);
				tisInTheWay.clear;
				return;					
			endif;
		endif;
		tisInTheWay.add(tiToMove);
		// if we are moving a 40 but this is a 20 then see if there is another 20 next to it
		if sourceIs40 and not tiToMove.CM_Container.is40 then
			if tiToMoveLocn.CM_GridController.testMyNextController(self.class) then
				tiIndex := tiToMoveLocn.allTrackedItems.indexOf(tiToMove);
				lStackControllerInQuestion := tiToMoveLocn.CM_GridController.myNextController.CM_GridController;
				if lStackControllerInQuestion.allTrackedItems.size &gt;= tiIndex then
					tiNextToUs := lStackControllerInQuestion.allTrackedItems[tiIndex];
					if tiNextToUs &lt;&gt; null then
						if tiNextToUs.CM_Container.is40 then

							app.setContinueCMExceptions(false);
							app.raiseCMException(ERR_40_FOOT_OVERSTOWED, null, null);
							tisInTheWay.clear;
							return;					
						else
						tisInTheWay.add(tiNextToUs);
						endif;
					endif;
				endif;
			endif;
		endif;
		
		// if there are 40s infront/behind and the source is a 20 then we need to pick off the 20s that are next to us, 
		// we are not interested in 20s next to 40s
		// we are not interested in picking off 20s in the stck next to the source 20
		if not sourceIs40 // 20 foot only
		and a40InFront // there are 40s in the way
		and not tiToMove.CM_Container.is40 // this ti to move is a 20
		and sourceTI.getPrimaryLocation(REAL_MODE) &lt;&gt; tiToMove.getPrimaryLocation(REAL_MODE) then // only look at locations in front or behind us, but not us
			// RIGHT HANDSIDE OF 40. The 20 may be 'under' the right or the left hand side of the 40
			// if the 40 has the same ordinal column as the 20 then we should look at the TIs in the locations that are next to this location i.e to the right
			if a40SameOrdColAs20 then
				if tiToMoveLocn.CM_GridController.getNextControllerOfType(self.class) &lt;&gt; null then
					// only look at the location next to us if the gap next to us is not available
					if sourceTI.getPrimaryLocation(REAL_MODE).CM_GridController.testMyNextController(CM_GridController) then
						lStackControllerInQuestion := tiToMoveLocn.CM_GridController.myNextController.CM_GridController;
						tiIndex := tiToMoveLocn.CM_GridController.allTrackedItems.indexOf(tiToMove);
						if lStackControllerInQuestion.allTrackedItems.size &gt;= tiIndex then
							tiNextToUs := lStackControllerInQuestion.allTrackedItems[tiIndex];
							if tiNextToUs &lt;&gt; null then
								if tiNextToUs.CM_Container.is40 then
		
									app.setContinueCMExceptions(false);
									app.raiseCMException(ERR_40_FOOT_OVERSTOWED, null, null);
									tisInTheWay.clear;
									return;					
								else
								tisInTheWay.add(tiNextToUs);
								endif;
							endif;
						endif;
					endif;
				endif;
			endif;
			// LEFT HANDSIDE OF 40. The 20 may be 'under' the right or the left hand side of the 40
			// if the 40 has a different ordinal column from the 20 then we should look at the TIs in the locations that are prior to this location i.e to the left
			if not a40SameOrdColAs20 then
				if tiToMoveLocn.CM_GridController.getPreviousControllerOfType(self.class) &lt;&gt; null then
					// only look at the location next to us if the gap next to us is not available
					if sourceTI.getPrimaryLocation(REAL_MODE).CM_GridController.testMyPreviousController(self.class) then
						lStackControllerInQuestion := tiToMoveLocn.CM_GridController.myPreviousController.CM_GridController;
						tiIndex := tiToMoveLocn.allTrackedItems.indexOf(tiToMove);
						if lStackControllerInQuestion.allTrackedItems.size &gt;= tiIndex then
							tiNextToUs := lStackControllerInQuestion.allTrackedItems[tiIndex];
							if tiNextToUs &lt;&gt; null then
								if tiNextToUs.CM_Container.is40 then
											app.setContinueCMExceptions(false);
									app.raiseCMException(ERR_40_FOOT_OVERSTOWED, null, null);
									tisInTheWay.clear;
									return;					
								else
								tisInTheWay.add(tiNextToUs);
								endif;
							endif;
						endif;
					endif;
				endif;
			endif;
		endif;
	endforeach;


end;</source>
        <Parameter name="sourceTI" type="CM_Container"/>
        <Parameter name="tiToMoveLocn" type="CM_LocationsController"/>
        <Parameter name="a40InFront" type="Boolean"/>
        <Parameter name="a40SameOrdColAs20" type="Boolean"/>
        <Parameter name="tisInTheWay" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTopStowKeys" id="1448663f-6274-4264-8080-0534cee55a2c">
        <source>getTopStowKeys(_term : String output; _row, _col : Integer output);
// ---------------------------------------------------------------------------
// Created:		25 June 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	inheritMethod(_term, _row, _col);
	
	self.getRowColumn(_row, _col,false,false);
end;</source>
        <Parameter name="_term" type="String" usage="output"/>
        <Parameter name="_row" type="Integer" usage="output"/>
        <Parameter name="_col" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getTopTI" id="23fcb1f0-c8fb-405d-b039-dfdb13553951">
        <source>getTopTI(moveMode : Integer)	:	CM_TrackedItem;
//Method to retrieve the topmost TI in a stack, if 1st MT, will
//return NULL.
vars
	move : CM_FutureMove;
	ti		: CM_TrackedItem;

begin

	if moveMode = REAL_MODE then
		return self.allTrackedItems.last();

	elseif moveMode = PLANNING_MODE then
		if self.allPlannedFutureMoves.isEmpty then
			return null;
		endif;
		foreach move in self.allPlannedFutureMoves reversed, discreteLock  do
			// not EDI future moves - see self.getAllFutureMovesOfType or similar
			if move.moveType &lt;&gt; TI_FutureMoveEDI then
				return move.CM_FutureMovePlanned.myTrackedItem;
			endif;
		endforeach;

	elseif moveMode = QUEUE_MODE then
		if self.allQueuedFutureMoves.isEmpty then
			return null;
		endif;

		foreach move in self.allQueuedFutureMoves reversed, discreteLock do
			//20/06/03  Needed this check because overstows was breaking future move. 
			ti := move.CM_FutureMoveQueued.myTrackedItem;
			if ti &lt;&gt; null then
				return ti;
			endif;
		endforeach;
	endif;

	return null;
	
end;</source>
        <Parameter name="moveMode" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getTopmostQueuedTI" id="b439fbf6-d484-452c-b6b0-feb6afa43302">
        <source>getTopmostQueuedTI(underneathMe : CM_TrackedItem)	:	CM_TrackedItem;
//Returns the topmost TI under the passed in tI. If you pass in null, we search
//from the top of the stack
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	myIndex : Integer;
	indexToCheck : Integer;
	tmpTI	:	CM_TrackedItem;
begin
	if self.allTrackedItems.size = 1 then	
		//I'm the only one here! (I think)
		return null;
	endif;
	if underneathMe &lt;&gt; null then
		myIndex := self.allTrackedItems.indexOf(underneathMe);
		if (myIndex -1) &lt;= 0 then
			return null;
		endif;
	else
		myIndex := self.allTrackedItems.size;
	endif;

	indexToCheck := myIndex;

	while true do
		indexToCheck := indexToCheck -1;
		if indexToCheck &lt; 1 then 
			break;
		endif;
		tmpTI := self.allTrackedItems[indexToCheck];
		// DVB changed 10/08/06
		if  tmpTI.isQueued then //epr par 35597 30/1/15
			return tmpTI;
		endif;
	endwhile;
	return null;
end;</source>
        <Parameter name="underneathMe" type="CM_TrackedItem"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
