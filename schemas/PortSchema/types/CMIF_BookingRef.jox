end;</source>
        <Parameter name="br" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="929e56e5-cb95-413d-b758-ac4c938e3412">
        <updating/>
        <source>setProxy(pBookingRef : String;
		pStatus:Integer;
		pCargoType : Integer;
		pClean : Boolean;
		pCommodity, pConsignorRef, pDescription, pDestinationPort, pDischargePort : String;
		pTranshipToPort	: CM_Port;
		pDischargePorts : StringArray;
		pHazards : ObjectArray;
		pHumidity : Decimal;
		pInspected : Boolean;
		pIsoType : String;
		pConsignor : CM_ConsigneeConsignor; 
		pConsignee : CM_ConsigneeConsignor; 
		pOperator : CM_Operator; 
		pVoyage : CM_Voyage; 
		pQuantity : Integer;
		pBookingRemarks : String;
		pRemarks : String;
		pTemperature : Real;
		pVentilation : Decimal; //par19252 cnwrs1 may 2009
		pHeight,
		pLength,
		pWidth 	: Decimal; //02.2.09 cnwrd1 par #18821 
		pHeightStr,
		pLengthStr,
		pWidthStr,
		pTypeStr 	: String;
		pDensity : Integer;
		pVolume : Real;
		pProductQuantity : Integer;
		pWeight : Decimal;
		pCubicMetres : Real;
		pTerminal : CM_Terminal;
		pProduct : CM_Product;
		pIsMultiItem : Boolean;
		pIsStockBookingRef : Boolean; //aer 29/05/08 CCMS 1618
		pEDIBookingRefTI : CM_EDIBookingRefTI; 
		_rawEDIData : String;
		pShippingRef  	: String; // AER 30/06/2008
		_carrierReference	:String;	// par 27460 cnwcs5
		pDirectDelivery : Boolean
		) updating;
// ---------------------------------------------------------------------------
// Created:     30 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// adm 160310 Par 22937 remove bolType
// 21 May 2011	cnwcs5		CCMS SCT 2058/par 27460 - add carrier reference
vars
	interfaceItem	: CMIF_BookingRefItem;
	
begin
	interfaceItem	:=	self.allCMIF_BRItems.first(); // interface items have already had data loaded

	self.myProxyBookingRef.setProxyFromInterface(pBookingRef,   // will have to save all fields on the main object in the meantime
												pStatus,
												pConsignorRef,
												pDestinationPort,
												pDischargePort,
												pTranshipToPort,
												pDischargePorts,
												pConsignor,
												pConsignee,
												pOperator,
												pVoyage,
												pBookingRemarks,
												pTerminal,
												pIsMultiItem,
												pIsStockBookingRef,
												interfaceItem,
												pShippingRef,
												_carrierReference,
												pDirectDelivery
												);
end;</source>
        <Parameter name="pBookingRef" type="String"/>
        <Parameter name="pStatus" type="Integer"/>
        <Parameter name="pCargoType" type="Integer"/>
        <Parameter name="pClean" type="Boolean"/>
        <Parameter name="pCommodity" type="String"/>
        <Parameter name="pConsignorRef" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="pDestinationPort" type="String"/>
        <Parameter name="pDischargePort" type="String"/>
        <Parameter name="pTranshipToPort" type="CM_Port"/>
        <Parameter name="pDischargePorts" type="StringArray"/>
        <Parameter name="pHazards" type="ObjectArray"/>
        <Parameter name="pHumidity" type="Decimal"/>
        <Parameter name="pInspected" type="Boolean"/>
        <Parameter name="pIsoType" type="String"/>
        <Parameter name="pConsignor" type="CM_ConsigneeConsignor"/>
        <Parameter name="pConsignee" type="CM_ConsigneeConsignor"/>
        <Parameter name="pOperator" type="CM_Operator"/>
        <Parameter name="pVoyage" type="CM_Voyage"/>
        <Parameter name="pQuantity" type="Integer"/>
        <Parameter name="pBookingRemarks" type="String"/>
        <Parameter name="pRemarks" type="String"/>
        <Parameter name="pTemperature" type="Real"/>
        <Parameter name="pVentilation" type="Decimal"/>
        <Parameter name="pHeight" type="Decimal"/>
        <Parameter name="pLength" type="Decimal"/>
        <Parameter name="pWidth" type="Decimal"/>
        <Parameter name="pHeightStr" type="String"/>
        <Parameter name="pLengthStr" type="String"/>
        <Parameter name="pWidthStr" type="String"/>
        <Parameter name="pTypeStr" type="String"/>
        <Parameter name="pDensity" type="Integer"/>
        <Parameter name="pVolume" type="Real"/>
        <Parameter name="pProductQuantity" type="Integer"/>
        <Parameter name="pWeight" type="Decimal"/>
        <Parameter name="pCubicMetres" type="Real"/>
        <Parameter name="pTerminal" type="CM_Terminal"/>
        <Parameter name="pProduct" type="CM_Product"/>
        <Parameter name="pIsMultiItem" type="Boolean"/>
        <Parameter name="pIsStockBookingRef" type="Boolean"/>
        <Parameter name="pEDIBookingRefTI" type="CM_EDIBookingRefTI"/>
