	self.btnPenFlat.visible		:= false;
	self.btnPenOpentop.visible		:= false;
	self.btnPenTank.visible		:= false;
	self.btnPenCrib.visible		:= false;
	self.btnPenFrame.visible		:= false;	//05 Feb 2018	NDL	TFS 36752
	self.btnCCScreen.visible		:= false;
	self.btnPenHeavy.visible		:= true;
	self.btnPenVoltage.visible		:= true;

	self.hideShowViewModes(false);
