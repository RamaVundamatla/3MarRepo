    <JadeMethod name="shouldAuditProperty" id="972cb969-d543-464a-859e-ff05aa3b9554">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 December 2016	cnwma1	Initial creation
// 02 Feb 2017 TFS #3286:Issues with Invoicing Audits
*/
vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_DebtorInvoiceLineDesc::bOneLinePerFinancialPeriod.name or
		propName = CM_DebtorInvoiceLineDesc::bPrintTrackedItems.name or
		propName = CM_DebtorInvoiceLineDesc::bShipService.name  or
		propName = CM_DebtorInvoiceLineDesc::bank.name or
		propName = CM_DebtorInvoiceLineDesc::chargeByOpCon.name or
		propName = CM_DebtorInvoiceLineDesc::chargeByUnits.name or
		propName = CM_DebtorInvoiceLineDesc::group.name or
		propName = CM_DebtorInvoiceLineDesc::invoiceType.name or
		propName = CM_DebtorInvoiceLineDesc::isVoid.name or
		propName = CM_DebtorInvoiceLineDesc::minimumChargeAmount.name or
		propName = CM_DebtorInvoiceLineDesc::minimumChargeGroupBy.name or
		propName = CM_DebtorInvoiceLineDesc::minimumChargeInvoiceLineType.name or
		propName = CM_DebtorInvoiceLineDesc::myCalculationType.name  or
		propName = CM_DebtorInvoiceLineDesc::myChildQuantityMap.name or
		propName = CM_DebtorInvoiceLineDesc::isNotAvailableForEntry.name or
		propName = CM_DebtorInvoiceLineDesc::myBankDebtor.name or
		propName = CM_DebtorInvoiceLineDesc::myDebtorType.name or
		propName = CM_DebtorInvoiceLineDesc::printingOrder.name then
		
		
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
	


epilog
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="afed02e7-301b-427d-aa6e-b0513f28e011">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin

	if self.narration.trimBlanks =  null then
		app.raiseCMException(Invoi_line_type_must_have_narr,null,null);
	endif;
	
	if self.myBankDebtor.allInvoiceLineDescDebtors[self.narration] &lt;&gt; null then
		app.raiseCMException1(Invoi_line_type_with_narra_alr, self.narration,null,null);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="5ed60e40-a5ab-448e-b731-af62b01f23e8">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="bd1aa2a9-f21f-41ad-8f31-f1a29920bd4d">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	other,
	real	: CM_InvoiceLineDesc;

begin

	if self.narration.trimBlanks =  null then
		app.raiseCMException(Invoi_line_type_must_have_narr,null,null);
	endif;
	
	real := self.pxyGetRealObject();
	other := self.myBankDebtor.allInvoiceLineDescDebtors[self.narration];
		
	if other &lt;&gt; null then
		if (real = null or (real &lt;&gt; null and real &lt;&gt; other)) then
			app.raiseCMException1(Invoi_line_type_with_narra_alr, self.narration, null,null);
		endif;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="d79cc3e3-7ec8-4ac0-9935-0a29c4631090">
        <source>validateMe();
// ---------------------------------------------------------------------------
// Created:		31 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aDILD, realME : CM_DebtorInvoiceLineDesc;
	myILD, aILD : CM_InvoiceLineDesc;
	ildMess, debtMess : String;
	myDebtor : CM_Debtor;
	found : Boolean;
	errorCodes : IntegerArray;
begin
	realME := self;
	
	create errorCodes transient;	//13 Sep 2012	NDL	Par 30366
	
	foreach aILD in realME.myBankDebtor.allInvoiceLineDescDebtors do
		aDILD := aILD.CM_DebtorInvoiceLineDesc;
		
		if aDILD = realME then
			continue;
		endif;
		found := false;
		foreach myILD in realME.allConsolidatingInvLineDesc do
			if aDILD.allConsolidatingInvLineDesc.includes(myILD) then

				foreach myDebtor in realME.allConsolidatingDebtor do
					if aDILD.allConsolidatingDebtor.includes(myDebtor) then
						found := true;
						if ildMess = null then
							//ildMess := "'" &amp; myILD.narration &amp; "' is already consolidated to " &amp; myDebtor.name &amp; "'" &amp; " " ;
							ildMess := app.getErrorString2(Already_consolidated, myILD.narration, myDebtor.name) &amp; " ";	//13 Sep 2012	NDL	Par 30366
							errorCodes.add(Already_consolidated);	//13 Sep 2012	NDL	Par 30366
						else
							//ildMess := ildMess &amp; ", '" &amp; myILD.narration &amp; "' is already consolidated to " &amp; myDebtor.name &amp; "'" &amp; " ";
							ildMess := ildMess &amp; ", " &amp; app.getErrorString2(Already_consolidated, myILD.narration, myDebtor.name) &amp; " ";	//13 Sep 2012	NDL	Par 30366
						endif;
					endif;
				endforeach;
			endif;
		endforeach;
		if found then
			ildMess := ildMess &amp; " for '" &amp; aDILD.narration &amp; "'";
		endif;
	endforeach;

	if ildMess &lt;&gt; null then
		if ildMess.length &gt; 600 then //PAR 15181
			ildMess := ildMess[1:600];
		endif;
//		app.raiseCMException1(Full_Replacement_Message,ildMess,null,null);	// cnwrl1 09/11/2009 PAR 17334 - what it was
//		app.raiseCMException1(Error_DebtorInvoiceLineDesc,ildMess,null,null);
		app.raiseMultiReasonExcOrWarning( errorCodes, ildMess, false, null,  null );	//13 Sep 2012	NDL	Par 30366
	endif;
epilog
	delete errorCodes;	//13 Sep 2012	NDL	Par 30366
end;</source>
    </JadeMethod>
</Class>
