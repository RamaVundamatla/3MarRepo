    <JadeMethod name="trxWorkOrderAction" id="11aaabcb-f51d-42bd-8a2f-9365cfb18df5">
        <updating/>
        <source>trxWorkOrderAction(_woActionIF : CMIF_WorkOrderAction input;
				  _realJob	   : CM_Job io;
				  _grpMethod   : CM_WorkOrderJobGroupMethod input;
				  _passport    : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Apr 2023 navma1 ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks
19 Sep 2023 navhl20 ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes
15/07/2025	navcs2	MTN-35210 Add Deferred Updates for WO Transaction During Transport Manifest and Call-Off Loading to Reduce Deadlocks

*/

vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	
	// Set to use deffered updates
	_passport.useTITransactionDeferUpdate := true;							// 15/07/2025	navcs2	MTN-35210
	_passport.useWOTransactionDeferUpdate := true;							// 15/07/2025	navcs2	MTN-35210	
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;
	
	//app.myUtilityUA.utlWorkOrderAction( _woActionIF,_realJob,_passport);				//19.9.2023 navhl20 #60063
	app.myUtilityUA.utlWorkOrderAction( _woActionIF,_realJob,_grpMethod,_passport);		//19.9.2023 navhl20 #60063
	
epilog
	if _passport.noErrors() then				// 15/07/2025	navcs2	MTN-35210
		_passport.doDeferredUpdates();			// 15/07/2025	navcs2	MTN-35210							
	endif;										// 15/07/2025	navcs2	MTN-35210
	
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction" usage="input"/>
        <Parameter name="_realJob" type="CM_Job" usage="io"/>
        <Parameter name="_grpMethod" type="CM_WorkOrderJobGroupMethod" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxYABuildCriteriaPriorities" id="03b372ed-031d-4f95-9b77-c262db1a32aa">
        <updating/>
        <source>trxYABuildCriteriaPriorities(pAllTransientsObj:CMIF_Array; _passport : CM_Passport input) updating;
/* --------------------------------------------------------------------------------
// Created:		21 March 2005 by cnwdad1
//
// Purpose:		Persists an array of transient Criteria/Priority objects, and their
//				data values.
//
// Parameters:	pAllTransientsObj - A reference to an array of transient objects,
//					each of which represent either a Criteria or a Priority. There
//					should never be a mix of the two.
//				_passport - A reference to the user's Passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 28/08/2008	Simon Ward	SFW1030 - Revised auditing during rework of yard allocations
10 Sep 2012		cnwer1		PAR 29524 -Intended release mode 
// --------------------------------------------------------------------------------*/
vars
	cmifObject		: CMIF_Object;
	transientObj	: CMIF_YACriteriaPriority;
	proxyObj		: CM_YACriteriaPriority;
	realCPObj		: CM_YACriteriaPriority;
	terminalObj		: CM_Terminal;
	priorityObj		: CM_YAPriority;
	expectedEdition	: Integer;
	priorityValue	: Real;
	sortValue		: Real;	//26 Feb 2020	NDL	TFS 48689 - Jade requires this to be the same type as the receiver in order to get the full number without blowing up
	isCreateDone	: Boolean;
	isDeleteDone	: Boolean;
	isUpdateDone	: Boolean;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	sortValue	:=	0;
	
	// Now calculate the Yard Allocation priority values on the proxy objects, working
	// backwards from the least important.
	
	foreach cmifObject in pAllTransientsObj reversed do
		transientObj	:=	cmifObject.CMIF_YACriteriaPriority;
		
		if transientObj.isDeleted then
			continue;
		endif;
		
		proxyObj		:=	transientObj.myProxy;
		priorityValue	:=	2^sortValue;
		proxyObj.setPriorityValue(priorityValue);
		sortValue		:=	sortValue + 1;
	endforeach;
	
	beginTransaction;
	
	// Validate editions here, instead of in the normal Utility method.
	
	foreach cmifObject in pAllTransientsObj do
		transientObj	:=	cmifObject.CMIF_YACriteriaPriority;
		proxyObj		:=	transientObj.myProxy;
		
		if transientObj.isNew then
			continue;
		endif;
		
		proxyObj.pxyGetRealObjectAndEdition(realCPObj, expectedEdition);
		
		if realCPObj = null then	
			//app.raiseCMException1(ProxyMgrCannotLocateReal, CM_YACriteriaPriority.name, null, null);
			continue;
		endif;

		exclusiveLock(realCPObj);
		
		if _passport.noErrors and realCPObj.edition &lt;&gt; expectedEdition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, "YA Criteria/Priority", null, null);
			return;
		endif;
	endforeach;
	
	terminalObj	:=	app.getMyTerminalDO_NOT_USE();

	//  Priority values are audited with the YA configuration parameters
	
	if _passport.noErrors and terminalObj.myYAConfig &lt;&gt; null then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(terminalObj.myYAConfig, true);
	endif;

	// Resequence the priorityValues of the original objects so that we don't get 
	// duplicate errors when new, deleted and moved Criteria/Priorities are updated.
	
	foreach priorityObj in terminalObj.allYAPriorities reversed do
		priorityObj.setPriorityValue(priorityObj.priorityValue * -1);
	endforeach;
	
	// Finally, persist, update or delete the Criteria/Priorities.
	
	isCreateDone	:=	false;
	isUpdateDone	:=	false;
	isDeleteDone	:=	false;
	
	foreach cmifObject in pAllTransientsObj do
		transientObj	:=	cmifObject.CMIF_YACriteriaPriority;
		proxyObj		:=	transientObj.myProxy;
		realCPObj		:=	transientObj.myCriteriaPriority;
		
		// Do "New" first, because the "changed" flag can be set if a new Criteria/Priority
		// is changed after it is added, but before it is saved to the database.
		
		if transientObj.isNew then
			app.myUtilityCA.utlCreateYACriteriaPriority(proxyObj, realCPObj, _passport);
			isCreateDone	:=	true;
			
		elseif transientObj.isChanged then
			app.myUtilityUA.utlUpdateYACriteriaPriority(realCPObj, proxyObj, _passport);
			isUpdateDone	:=	true;
			
		elseif transientObj.isDeleted then
			if realCPObj = null then
				//was added &amp; deleted on the form
				continue;
			endif;
			app.myUtilityDA.utlDeleteYACriteriaPriority(realCPObj, _passport);
			isDeleteDone	:=	true;
		
		else
			// The Criteria/Priority has not been touched, however, we still need to update
			// it because all priority values have been made negative, because they all need
			// to be resequenced for new or deleted Criteris/Priorities.
			app.myUtilityUA.utlUpdateYACriteriaPriority(realCPObj, proxyObj, _passport);
			
		endif;
		
		if _passport.hasErrors  then
			return;
		endif;
		
	endforeach;
	
	// Now we need to recalculate the priority value(s) for all of the Terminal's Yard
	// Allocations and their Criteria.
	
	terminalObj.yaRecalculatePriorities();

	if _passport.noErrors and terminalObj.myYAConfig &lt;&gt; null then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(terminalObj.myYAConfig, false);
	endif;

	if isCreateDone or isDeleteDone or isUpdateDone then
		terminalObj.causeEvent(terminalObj.getTerminalEvent(EVENT_YA_CP_UPDATE), false, process);
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="pAllTransientsObj" type="CMIF_Array"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
