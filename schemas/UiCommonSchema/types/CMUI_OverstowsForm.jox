    <JadeMethod name="doMnuMove" id="1bf0e945-135b-4a20-aad5-8113c220c5a2">
        <source>doMnuMove( menuItem : MenuItem );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 October 2011	cnwndl1	Initial creation	Par 28466

*/

vars

	allMenuTableObjects : CM_ObjectArray;
	myAssistant : CMUI_Assistant;
	objArray : CM_TIArray;

begin
	
	allMenuTableObjects := menuItem.userObject.CM_ObjectArray;	
	if allMenuTableObjects = null or allMenuTableObjects.isEmpty then
		return;
	endif;
	
	create objArray transient;			
	allMenuTableObjects.copy( objArray );
	
	myAssistant := self.myAssistant;	
	if myAssistant = null then
		return;
	endif;
	
	myAssistant.showMoveItForm(objArray, QUEUE_MODE);

epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem"/>
