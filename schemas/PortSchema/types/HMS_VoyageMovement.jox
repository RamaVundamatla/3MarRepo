    <JadeMethod name="adjustSternMarkToLOA" id="218130a4-4b4b-4b61-9359-b79eb8cde2f8">
        <updating/>
        <source>adjustSternMarkToLOA(_newLOA : Decimal)updating;
//--------------------------------------------------
// Created:	21 March 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.bowMarkTo &gt; self.sternMarkTo then
		self.sternMarkTo := self.bowMarkTo - _newLOA;
	else		
		self.sternMarkTo := self.bowMarkTo + _newLOA;
	endif;
end;</source>
        <Parameter name="_newLOA" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="archive" id="dc3b7cf1-9b37-47d5-96c6-5abc88e94dba">
        <updating/>
        <source>archive(_archiveDT : TimeStamp; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 28 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	iter : Iterator;
	permResourceUsed:		HMS_ResourceUsed;
begin

	if self.isTransient then
		return;
	endif;
			
	exclusiveLock(self);
	// booking has not been cancelled, only archived
	iter := self.allResourceUsed.createIterator();
  	while iter.next(permResourceUsed) do
  		// archive resource
		permResourceUsed.archive(self, _archiveDT, _passport);
  	endwhile;

	if (not app.isConverting) then
		self.createTransaction(TRANS_TYPE_ArchiveMovement, null, null, _passport);
	endif;
	// Set archive status
	self.setArchiveStatus(_archiveDT);

epilog
	delete iter;
end;</source>
        <Parameter name="_archiveDT" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="berthing_AutoPositionOnBerth" id="df400f9c-cb83-435f-8058-e3a42baac536">
        <updating/>
        <source>berthing_AutoPositionOnBerth() updating, protected;
//06 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
begin
	// This method attempts to automatically position a ship on the requested berth

	// Set bow and stern marks
	
	// If this is a logical berth then randonise the berth position.
	
	// else do the centreing.
	self.berthing_CentreShip();

	//Calculate and set clearances for marks
	self.berthing_RecalculateClearances();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="berthing_CentreShip" id="0035d21a-7088-4797-a761-15b939e507ac">
        <updating/>
        <source>berthing_CentreShip() updating, protected;

vars

begin
	// This method sets the bow and stern marks for the ship centred on the berth.
	
	if self.getMyBerth() &lt;&gt; null then
		self.getMyBerth().getMarksForCentringOnBerth(self.myHMSVoyageData.dim_LengthOverall, self.sideTo, self.bowMarkTo, self.sternMarkTo);
	else
		return;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="berthing_GetBerthFromMarks" id="2f31c51d-a77c-4ffd-a7f3-e0f2bc69f4f1">
        <source>berthing_GetBerthFromMarks(_wharf : HMS_Wharf): HMS_Berth protected;

vars
	centreBerth,
	berth,
	previousBerth	: HMS_Berth;
	centreMark,
	previousMeter,
	currentMeter,
	int				: Decimal[12,2];
begin
	// Calculate centre of ship
	if self.bowMarkTo &gt; self.sternMarkTo then
		centreMark := self.sternMarkTo + ((self.bowMarkTo-self.sternMarkTo)/2);
	else
		centreMark := self.bowMarkTo + ((self.sternMarkTo-self.bowMarkTo)/2);
	endif;

	previousMeter := 0;

	// find centre berth
	foreach berth in _wharf.allBerths do
		currentMeter := berth.startPosition;
		if centreMark&gt;=berth.startPosition and centreMark&lt;=(berth.startPosition + berth.length) then
			centreBerth:=berth;
			break;
		endif;
		// check if the vessel has been dropped into a dead zone (zone that is not considered a normal part of the berth)
		if centreMark &gt;= previousMeter and centreMark &lt;= currentMeter then
			if previousMeter = 0 then
				centreBerth := berth;
			else	
				int := ((currentMeter - previousMeter)/2);
				if centreMark &lt;= (previousMeter + int) then
					if previousBerth &lt;&gt; null then
						centreBerth := previousBerth;
					else
						centreBerth := berth;
					endif;	
				else
					centreBerth := berth;
				endif;
			endif;
		endif;
		previousBerth := berth;
		previousMeter := berth.startPosition + berth.length;
	endforeach;

	return centreBerth;

end;</source>
        <access>protected</access>
        <Parameter name="_wharf" type="HMS_Wharf"/>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="berthing_RandomPosition" id="e689f733-c3db-401b-bce9-43ca7aa199c7">
        <updating/>
        <source>berthing_RandomPosition() updating, protected;
// --------------------------------------------------------------------------------
// Created:		09 March 2007 by cnwdad1
//
// Purpose:		Randomly positions the movement on the berth.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	voyageDataObj	: HMS_VoyageData;
	wharfObj		: HMS_Wharf;
	berthObj		: HMS_Berth;
	startPoint		: Decimal[12,2];
	endPoint		: Decimal[12,2];
	overhang		: Decimal[12,2];
	isWaterOnLeft	: Boolean;
	
begin

	voyageDataObj	:=	self.myHMSVoyageData;


	berthObj		:=	self.getMyBerth();
	if berthObj =  null then
		return;
	endif;
	wharfObj		:=	berthObj.myWharf;
	
	if wharfObj = null then // we are at a virtual berth
		return;
	endif;
	
 	isWaterOnLeft	:=	wharfObj.waterOnLeft;
	
	if berthObj.length - voyageDataObj.dim_LengthOverall &lt; 0 then
		startPoint	:=	app.random(berthObj.length);
	else
		startPoint	:=	app.random((berthObj.length - voyageDataObj.dim_LengthOverall).Integer);
	endif;
	
	if startPoint &lt; berthObj.startPosition then
		startPoint	:=	berthObj.startPosition;
	endif;
	
	endPoint	:=	startPoint + voyageDataObj.dim_LengthOverall;
	
	if endPoint &gt; berthObj.length then
		// The end point is beyond the end of the berth.
		overhang	:=	endPoint - berthObj.length;
		
		if startPoint &gt;= overhang then
			// Just back the vessel up for the length of the over hang.
			startPoint	:=	startPoint - overhang;
		else
			// All we can do is pretend this tub is smaller than it really is.
			endPoint	:=	berthObj.length;
		endif;
	endif;
	
    if isWaterOnLeft = true and self.sideTo = OrientPortSideTo then
    	// CASE A: Water on left of wharf, ship is PortSideTo, bowMarkTo=min, sternMarkTo=max
    	self.bowMarkTo		:=	startPoint;
    	self.sternMarkTo	:=	endPoint;
		
    elseif isWaterOnLeft = true and self.sideTo = OrientStarboardSideTo then
    	// CASE B: Water on left of wharf, ship is StarboardSideTo, bowMarkTo=max, sternMarkTo=min
    	self.bowMarkTo		:=	endPoint;
    	self.sternMarkTo	:=	startPoint;
		
    elseif not isWaterOnLeft and self.sideTo = OrientPortSideTo then
    	// CASE C: Water on right of wharf, ship is PortSideTo, bowMarkTo=max, sternMarkTo=min
    	self.bowMarkTo		:=	endPoint;
    	self.sternMarkTo	:=	startPoint;
		
    elseif not isWaterOnLeft and self.sideTo = OrientStarboardSideTo then
    	 // CASE D: Water on right of wharf, ship is StarboardSideTo, bowMarkTo=min, sternMarkTo=max
    	self.bowMarkTo		:=	startPoint;
    	self.sternMarkTo	:=	endPoint;
		
    endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="berthing_RecalculateClearances" id="26987047-fda8-4964-afdb-1cbefbfa3342">
        <updating/>
        <source>berthing_RecalculateClearances() updating, protected;
//--------------------------------------------------
// Created:	21 March 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpDict : HMS_VoyageMovementByDateDict;   	
begin
	if self.myHarbour &lt;&gt; null then		// 30/8/19 MAP TFS46373
		create tmpDict transient;
		self.myHarbour.buildMoveCollToValidate(tmpDict, self.occursOnDTNEW, null);	
		self.berthing_SetClearances(tmpDict);
	endif;

epilog
	delete tmpDict;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="berthing_SetClearances" id="833d181d-a7a5-4840-a552-8c78be644446">
        <updating/>
        <source>berthing_SetClearances(_movesToCheck : HMS_VoyageMovementByDateDict) updating, protected;

vars
	loa:				Decimal[6,2];
	minClearance,
	berthStart,
	berthEnd:			Integer;	
	zeroSideClearance,
	maxSideClearance,
	zeroSideMark,
	maxSideMark:		Decimal[12,2];
	bowAtZeroSide:		Boolean;
begin

	// Overview of method steps is as follows
	// 1. calc clearances for this position. If clearances are valid, return this position.
	//    If both clearances (fore and aft) are invalid, then give msg "ship cannot
	//    be berthed here" and return false. Else if only one clearance is invalid,
	//    see whether the ship can be moved so that both clearances become valid
	//    and that the ship's centre mark is still over the requested berth. If it is, 
	//    then return this position. 
	//  
	// 2. NOTE. The move position referred to above is calculated by:
	//		mark from centering + current clearance + min clearance
	
			
    minClearance := self.myHarbour.minimumClearance;
    loa := self.myHMSVoyageData.dim_LengthOverall;
    berthStart := self.getMyBerth().startPosition;
    berthEnd := (self.getMyBerth().startPosition)+(self.getMyBerth().length);

	//Set fore and Aft clearances
	self.calc_Set_Clearances(_movesToCheck);
		
    if (self.foreClearanceTo &lt; minClearance and self.aftClearanceTo &gt; minClearance)
    or (self.foreClearanceTo &gt; minClearance and self.aftClearanceTo &lt; minClearance) then
    	// CASE B: Fore or aft clearance is invalid - check to see if the ship could be moved so that there
    	// is sufficient clearance on both sides

		// Get marks and clearances
		if self.bowMarkTo &lt; self.sternMarkTo then
			zeroSideMark := self.bowMarkTo;
			maxSideMark := self.sternMarkTo;
			zeroSideClearance := self.foreClearanceTo;
			maxSideClearance := self.aftClearanceTo;
			bowAtZeroSide := true;
		else
			zeroSideMark := self.sternMarkTo;
			maxSideMark := self.bowMarkTo;
			zeroSideClearance := self.aftClearanceTo;
			maxSideClearance := self.foreClearanceTo;
			bowAtZeroSide := false;
		endif;		
    	
    	if zeroSideClearance + maxSideClearance &gt; (2*minClearance) then
    		// Combined clearances are greater than minimum allowance - calc new position for ship 
    		// and then check to see that its centre in still over the target berth
    		if zeroSideClearance &lt; maxSideClearance then
    			// Zero side clearance is invalid - move ship up wharf to the first valid position
    			zeroSideMark := zeroSideMark+(minClearance-zeroSideClearance);
    			maxSideMark := maxSideMark+(minClearance-zeroSideClearance);
    			// Set new clearances
    			if maxSideClearance = ClearanceUnbounded then
    				maxSideClearance := ClearanceUnbounded;
    			else
    				maxSideClearance := maxSideClearance+(minClearance-zeroSideClearance);
    			endif;
    			zeroSideClearance := minClearance;
    		else
    			// Max side clearance is invalid - move ship down wharf to the first valid position
    			zeroSideMark := zeroSideMark-(minClearance-maxSideClearance);
    			maxSideMark := maxSideMark-(minClearance-maxSideClearance);
    			// Set new clearances
    			if zeroSideClearance = ClearanceUnbounded then
    				zeroSideClearance := ClearanceUnbounded;
    			else 
    				zeroSideClearance := zeroSideClearance-(minClearance-maxSideClearance);
    			endif;
    			maxSideClearance := minClearance;
    		endif;

    		// Check that centre of ship is still on target berth
    		
            if ((zeroSideMark+(loa/2))&lt;=berthEnd) and ((zeroSideMark+(loa/2))&gt;=berthStart) then
            	// Centre of ship is still on target berth
            	// Set bow and stern marks for auto set postion
    			if bowAtZeroSide = true then 
    				self.bowMarkTo := zeroSideMark;
					self.sternMarkTo := maxSideMark;
					self.foreClearanceTo := zeroSideClearance;
					self.aftClearanceTo := maxSideClearance;
				else
					self.bowMarkTo := maxSideMark;
					self.sternMarkTo := zeroSideMark;
					self.foreClearanceTo := maxSideClearance;
					self.aftClearanceTo := zeroSideClearance;
				endif;
			endif;
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_movesToCheck" type="HMS_VoyageMovementByDateDict"/>
    </JadeMethod>
    <JadeMethod name="berthing_StartEndFromOrient" id="151b7ad4-76f0-4e40-a58d-6c571df1b5a3">
        <source>berthing_StartEndFromOrient(startPos, endPos : Decimal io; bowMark, sternMark : Decimal);

vars

begin
 	// This method takes the bow and stern marks of a ship along the wharf and returns its start and end positions
 	// based on the orientation of the ship:wharf:sea

 	if bowMark&gt;sternMark then
 		startPos:=sternMark;
 		endPos:=bowMark;
 	else
 		startPos:=bowMark;
 		endPos:=sternMark;
 	endif;	
end;</source>
        <Parameter name="startPos" type="Decimal" usage="io"/>
        <Parameter name="endPos" type="Decimal" usage="io"/>
        <Parameter name="bowMark" type="Decimal"/>
        <Parameter name="sternMark" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="calcClearancesAtMoveTime" id="ade66f08-7cd0-4b6a-825e-2eb2689cd993">
        <source>calcClearancesAtMoveTime(foreClear, aftClear: Real io);

vars
	tmpDict : HMS_VoyageMovementByDateDict;
	overlapsWharf : Boolean;
	moveStart,
	moveEnd : TimeStamp;
begin
	// This method calculates the clearance between ships only for the time
	// at which the movement takes place.

	// Note: In order to aviod performance issues, this search mechanism only checks voyages that fall
	// within a specific number of days of the target movement. - this number of days is defined on 
	// the system setup sheet - default is 30 days 
	create tmpDict transient;
	moveStart := self.occursOnDTNEW.cnEcAddDays(-self.myHarbour.shippingReportOffsetDays);
	moveEnd := self.occursOnDTNEW.cnEcAddDays(self.myHarbour.shippingReportOffsetDays);

	if self.myHarbour &lt;&gt; null then		// 30/8/19 MAP TFS45926
		self.myHarbour.buildMoveCollToValidate(tmpDict, moveStart, moveEnd);
	
		self.getForeAftClearances(tmpDict, foreClear, aftClear, overlapsWharf);
	endif;

epilog
	delete tmpDict;
end;</source>
        <Parameter name="foreClear" type="Real" usage="io"/>
        <Parameter name="aftClear" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="calcClosestTidalWindow" id="38b5e962-a66e-4def-804f-7a6516a62115">
        <source>calcClosestTidalWindow(_tidalClass : HMS_TidalClass; _headings: StringArray input; _data: HugeStringArray input);
//--------------------------------------------------
// Created:	06 April 2004 By: cnwgd1
//--------------------------------------------------

/*

Date		Who		Reason
27 Mar 2008	cnwkpd1	PAR #16289 - Change Drafts to Decimal[8,2]

*/

vars
	regionToCheck:		HMS_HarbourRegion;
	earliestTime:		TimeStamp;
	latestTime:			TimeStamp;
	currentLimitPosv:	Decimal[5,1];
	currentLimitNegv:	Decimal[5,1];
	draftLimit:			Decimal[8,2];		// PAR #16289
	offsetTime:			Integer;
	offsetAsTime:		Time;
	enterLeaveStatus:	String;
	moveDT:				TimeStamp;
	current:			Real;
	draft:				Real;
	//vesselData : HMS_VesselData;
	previousMove : HMS_VoyageMovement;
begin

	// This method calculates the closest tidal window to the current movement time
	offsetTime := 0;
	enterLeaveStatus := null;

	// Get region, offset to checkpoint and the harbour enterLeaveStatus for this movement
	regionToCheck := self.getFirstRegionWithChkPts(offsetTime, enterLeaveStatus, self.getVoyageMovementPrevious);

	if regionToCheck = null then 
		// No checkpoints to check - set tidal textboxes to 'N/A'
		_headings.add(app.getErrorString(HMSPredictedCurrentFlow));
		_data.add('N/A');
		_headings.add(app.getErrorString(HMSPredictedFlowDirection));
		_data.add('N/A');		
		_headings.add(app.getErrorString(HMSEarliestPossibleMovement));
		_data.add('N/A');		
		_headings.add(app.getErrorString(HMSLatestPossibleMovement));
		_data.add('N/A');		
		_headings.add(app.getErrorString(Actual_Time));
		_data.add('N/A');		
		_headings.add(app.getErrorString(HMSRelativeTime));
		_data.add('N/A');
		_headings.add(app.getErrorString(HMSPredictDepth));
		_data.add('N/A');								
		_headings.add(app.getErrorString(HMSFirstCheckpointReached));
		_data.add('N/A');		
	else	
   		// Display details for first checkpoint reached for the movement
		// Get current and draft limits
		if _tidalClass &lt;&gt; null then
			if enterLeaveStatus = HMSMovementTypeEntering then
				currentLimitPosv := _tidalClass.allMaximumCurrents[1];
				currentLimitNegv := (_tidalClass.allMaximumCurrents[2])*-1;
			else
				currentLimitPosv := _tidalClass.allMaximumCurrents[3];
				currentLimitNegv := (_tidalClass.allMaximumCurrents[4])*-1;
			endif;
		endif;

		//vesselData := self.myHMSVoyageData.getMyHMSVesselData();
		
		if self.myHMSVoyageData.dim_DraftFore &lt; self.myHMSVoyageData.dim_DraftAft then
			draftLimit := self.myHMSVoyageData.dim_DraftFore;
		else
			draftLimit := self.myHMSVoyageData.dim_DraftAft;
		endif;

		// Get moveDT 
		moveDT := self.occursOnDTNEW;

		// Get closest tidal window times
		if app.myHMSRvTide.getClosestWindow(earliestTime,latestTime,regionToCheck,moveDT,currentLimitPosv,currentLimitNegv,draftLimit,offsetTime,current,draft)=app.getErrorString(MoveUnrestricted) then
			_headings.add(app.getErrorString(HMSEarliestPossibleMovement));
			_data.add(app.getErrorString(MoveUnrestricted));					        	
			_headings.add(app.getErrorString(HMSLatestPossibleMovement));
			_data.add(app.getErrorString(MoveUnrestricted));
		else
			if offsetTime &lt; 0 then
				offsetAsTime.setTime(0,((offsetTime)*-1),0,0);
				earliestTime := earliestTime+offsetAsTime;
				latestTime := latestTime+offsetAsTime;
				_headings.add(app.getErrorString(HMSEarliestPossibleMovement));
				_data.add(earliestTime.date.shortFormatJMT() &amp; ", " &amp; (earliestTime).Time.shortFormatJMT());
				_headings.add(app.getErrorString(HMSLatestPossibleMovement));
				_data.add(latestTime.date.shortFormatJMT() &amp; ", " &amp; (latestTime).Time.shortFormatJMT()); 
			else
				offsetAsTime.setTime(0,offsetTime,0,0);
				earliestTime := earliestTime-offsetAsTime;
				latestTime := latestTime-offsetAsTime;
				_headings.add(app.getErrorString(HMSEarliestPossibleMovement));
				_data.add(earliestTime.date.shortFormatJMT() &amp; ", " &amp; (earliestTime).Time.shortFormatJMT());				
				_headings.add(app.getErrorString(HMSLatestPossibleMovement));
				_data.add(latestTime.date.shortFormatJMT() &amp; ", " &amp; latestTime.date.shortFormatJMT() &amp; ", " &amp; (latestTime).Time.shortFormatJMT());
			endif;
		endif;

		_headings.add(app.getErrorString(HMSRelativeTime));
		_data.add(offsetTime.String);

		if offsetTime&lt;0 then
			offsetAsTime.setTime(0,((offsetTime)*-1),0,0);
			_headings.add(app.getErrorString(Actual_Time));
			_data.add((moveDT-offsetAsTime).Time.shortFormatJMT());
		else
			offsetAsTime.setTime(0,offsetTime,0,0);
			_headings.add(app.getErrorString(Actual_Time));
			_data.add((moveDT+offsetAsTime).Time.shortFormatJMT());
		endif;

		if current &lt; 0 then
			_headings.add(app.getErrorString(HMSPredictedCurrentFlow));
			_data.add((current*-1).roundedTo(1).String);
			_headings.add(app.getErrorString(HMSPredictedFlowDirection));
			_data.add(app.getErrorString(Ebb));	
		else
			_headings.add(app.getErrorString(HMSPredictedCurrentFlow));
			_data.add(current.roundedTo(1).String);				
			_headings.add(app.getErrorString(HMSPredictedFlowDirection));
			_data.add(app.getErrorString(Flood));
		endif;

		_headings.add(app.getErrorString(HMSPredictDepth));
		_data.add(draft.roundedTo(2).String);		
		_headings.add(app.getErrorString(HMSFirstCheckpointReached));
		_data.add(regionToCheck.description);			
	endif;


end;</source>
        <Parameter name="_tidalClass" type="HMS_TidalClass"/>
        <Parameter name="_headings" type="StringArray" usage="input"/>
        <Parameter name="_data" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="calc_ClearancesWharfSection" id="9fee9b77-9323-4b24-b147-8eb2a01df26f">
        <source>calc_ClearancesWharfSection(_foreClearance, _aftClearance : Decimal io;
							 _overlapsWharfSection : Boolean io; moveWharf : HMS_Wharf;
							 currentStartPosn, currentEndPosn, moveBowMark, moveSternMark : Decimal) : Boolean protected;
//--------------------------------------------------
// Created:	1 April 2005 By: cnwgd1
//--------------------------------------------------
// Also see CMIF_HMS_WorkingMovement::calc_Clearances()
//-------------------------------------------------
/*

Date		Who		Reason
30 Mar 2008	cnwkpd1	PAR #16367 - Protect against no previous movement being found

*/

vars
	minClearance : Integer;
   	section : HMS_WharfSection;
   	distToSectionLimit : Decimal[12,2];
	prevMove		: HMS_VoyageMovement;
	
begin
	if self.isMovementTypeDeparture() then // dh 25/3/2008 par 16146 added this first condition
		prevMove := self.getVoyageMovementPrevious();			// PAR #16367
		if prevMove &lt;&gt; null and prevMove.isLogicalBerth then 	// dh
			return true;									// dh
		endif;												// dh
	else													// dh
		if self.isLogicalBerth() then
			return true;
		endif;
	endif;													// dh end of changes for par 16146
	if moveWharf = null then
		return true;
	endif;
	
	minClearance := moveWharf.getHarbourReal.minimumClearance;
	
	_overlapsWharfSection := false;
	// Calc clearances to wharf section ends if less than current clearances
	foreach section in moveWharf.allWharfSections do
		// Check to see if ship is within any part of this section
		if currentEndPosn &gt;= section.startMeterage 
		and currentStartPosn &lt;= section.endMeterage then
			// Ship overlaps some portion of this section.
			// Calc clearances to sections ends
			// Ship is closer to start of wharf than the end of this section
			distToSectionLimit := (section.endMeterage)-currentEndPosn;
			if moveBowMark &gt; moveSternMark then
				if distToSectionLimit &lt; _foreClearance then
					// Bow closer to section end than stern and....
					// Section end is closer than current foreClearance - reduce clearance;
					_foreClearance := distToSectionLimit;
					_overlapsWharfSection := _foreClearance &lt; minClearance;			
				endif;
			else
				if distToSectionLimit &lt; _aftClearance then
					// Stern closer to section end than bow and....
					// Section end is closer than current aftClearance - reduce clearance;
					_aftClearance := distToSectionLimit;
					_overlapsWharfSection := _aftClearance &lt; minClearance;			
				endif;
			endif;
			// Ship is closer to end of wharf than section start
			distToSectionLimit := currentStartPosn-(section.startMeterage);
			if moveBowMark &gt; moveSternMark then
				if distToSectionLimit &lt; _aftClearance then
					// Stern closer to section start than bow and....
					// Section start is closer than current aftClearance - reduce clearance;
					_aftClearance := distToSectionLimit;
					_overlapsWharfSection := _aftClearance &lt; minClearance;			
				endif;
			else
				if distToSectionLimit &lt; _foreClearance then
					// Bow closer to section start than stern and....
					// Section start is closer than current foreClearance - reduce clearance;
					_foreClearance := distToSectionLimit;
					_overlapsWharfSection := _foreClearance &lt; minClearance;			
				endif;
			endif;
		endif;
	endforeach;

	return _overlapsWharfSection;
	
end;</source>
        <access>protected</access>
        <Parameter name="_foreClearance" type="Decimal" usage="io"/>
        <Parameter name="_aftClearance" type="Decimal" usage="io"/>
        <Parameter name="_overlapsWharfSection" type="Boolean" usage="io"/>
        <Parameter name="moveWharf" type="HMS_Wharf"/>
        <Parameter name="currentStartPosn" type="Decimal"/>
        <Parameter name="currentEndPosn" type="Decimal"/>
        <Parameter name="moveBowMark" type="Decimal"/>
        <Parameter name="moveSternMark" type="Decimal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="calc_Set_Clearances" id="e04d5849-18dc-48d3-b7d1-59f724510b52">
        <updating/>
        <source>calc_Set_Clearances(_movesToCheck : HMS_VoyageMovementByDateDict) updating;
//--------------------------------------------------
// Created:	27 April 2004 By: cnwgd1
//--------------------------------------------------
// 30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
vars
	overlapsWharf : Boolean;
	newForeClearance,
	newAftClearance : Real;
begin

	// This method calculates the default stern (and bow marks if required) and the fore and aft clearances
	self.getForeAftClearances(_movesToCheck, newForeClearance, newAftClearance, overlapsWharf);
	// Update clearances
	if newForeClearance &lt;&gt; self.foreClearanceTo
	or newAftClearance &lt;&gt; self.aftClearanceTo
	or overlapsWharf &lt;&gt; self.overlapsWharfSection then
		//Cause event to update HMS Graphical view
		self.updateObjectEdition(self.myHMSVoyageData);	// par 30292
	endif;

	self.foreClearanceTo := newForeClearance;
	self.aftClearanceTo := newAftClearance;
	self.overlapsWharfSection := overlapsWharf;

end;</source>
        <Parameter name="_movesToCheck" type="HMS_VoyageMovementByDateDict"/>
    </JadeMethod>
    <JadeMethod name="canUserAccessSelf" id="a9fee4d1-ea61-40a9-92e2-289c828e3d23">
        <source>canUserAccessSelf(_user : CM_User; _failedDAC  :CM_DataAccessController output; _passport: CM_Passport): Boolean;
//--------------------------------------------------
// Created:	31 August 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.myHMSVoyageData &lt;&gt; null then
		return self.myHMSVoyageData.canUserAccessSelf(_user, _failedDAC, _passport);
	else
		return inheritMethod(_user, _failedDAC, _passport);
	endif;

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="changeMyBerth" id="ace9fe26-9763-4beb-98f4-606a3941317b">
        <updating/>
        <source>changeMyBerth(_berth: HMS_Berth) updating;
//-----------------------------------------------------------------------
//	Created:	07 March 2007 Lorcan Bolster  (cnwlb1/lorcan)
//06 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
//-----------------------------------------------------------------------
begin
	inheritMethod(_berth);
	self.berthing_CentreShip();
end;</source>
        <Parameter name="_berth" type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="check_Clearances" id="2800c276-6193-4288-8323-bee74b9492cd">
        <source>check_Clearances(	conflictsManager: CMIF_HMS_ConflictsManager;
					_raiseWarning : Boolean;
					_invalidType : Integer io;
					_passport : CM_Passport input;
					_errorInfo:String output): Boolean protected;

vars
	prevMove,
	nextMove2,
	nextMove,
   	movement:			HMS_VoyageMovement;
   	voyageForMoves:		HMS_VoyageData;
   	closestStartPosn,
   	closestEndPosn,
   	moveStartPosn,
   	moveEndPosn,
   	currentStartPosn,
   	currentEndPosn,
   	bowMark,
   	sternMark,
   	newAftClearance,
   	newForeClearance:	Decimal[12,2];
   	minClearance:		Integer;
   	tmpWharf:			HMS_Wharf;
   	berthCode,
   	voyageCode:			String;
   	voyageOverlapped: 	CM_Voyage;
   	tmpOverlapsWharfSection : Boolean;
   	nextOccursDT,
   	moveOccursDT : TimeStamp;
	movesToValidate : HMS_VoyageMovementByDateDict;
   	tmpLockout:				HMS_WharfLockout;	
begin
// cnwdad1 26/02/2007.
	if not self.myHarbour.isDoClearanceCheck then
		return true;
	endif;
	
	// This method calculates the minimum fore and aft clearances for a movement's duration at a berth, 
	// based the following supplied information	bowMark, sternMark, and the wharf that these marks apply to.
	if conflictsManager = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null conflictsManager');
		return false;
	endif;

	movesToValidate := conflictsManager.allMovesToValidate;
	_invalidType := 0; //reset
	minClearance := self.myHarbour.minimumClearance;
	voyageForMoves := self.myHMSVoyageData;

	// Initialise the closestStartPosn and closestEndPosn variables
	closestStartPosn := -1*(ClearanceUnbounded);
	closestEndPosn := ClearanceUnbounded;
   	newAftClearance := self.aftClearanceTo;
   	newForeClearance:= self.foreClearanceTo;
   	   	
	if self.moveType = HMSMovementTypeDeparture then
		prevMove := self.getVoyageMovementPrevious();
		bowMark := prevMove.bowMarkTo;
		sternMark := prevMove.sternMarkTo;
		nextMove := prevMove.getVoyageMovementNext();
		nextOccursDT := self.occursOnDTNEW;				
	else
		bowMark := self.bowMarkTo;
		sternMark := self.sternMarkTo;
		nextMove := self.getVoyageMovementNext();
		
		if nextMove &lt;&gt; null then
			nextOccursDT	:=	nextMove.occursOnDTNEW;
		endif;
	endif;

	moveOccursDT := self.occursOnDTNEW;

	self.berthing_StartEndFromOrient(currentStartPosn, currentEndPosn, bowMark, sternMark);
	
	tmpWharf := self.getMyBerth().myWharf;
	voyageCode := self.myHMSVoyageData.getDisplayString();
	berthCode := self.getMyBerth().description;

 	foreach movement in movesToValidate 
 	where (movement.myHMSVoyageData &lt;&gt; voyageForMoves) do

 		if movement.getMyBerth() = null then
 			continue;
 		endif;
 		
		if (tmpWharf &lt;&gt; movement.getMyBerth().myWharf) then
			continue;
		endif;

		nextMove2 := movement.getVoyageMovementNext();
		if nextMove2 = null then
			continue;
		endif; 				

		if movement.occursOnDTNEW &lt;= nextOccursDT and nextMove2.occursOnDTNEW &gt;= moveOccursDT then
			// ie. this movement is in existance (overlaps) at the same time as the movementToCheck occurs
			self.berthing_StartEndFromOrient(moveStartPosn, moveEndPosn, movement.bowMarkTo, movement.sternMarkTo);
			// Check this see is ships are trying to occupy the same berth
			if moveEndPosn &gt;= bowMark
			and moveStartPosn &lt;= sternMark then
				// moveToCheck is try to occupy the same berth as an existing movement
				voyageOverlapped := movement.getMyVoyage();
				if voyageOverlapped = null then
					//Should not be null but you never know
					continue;
				endif;
				_invalidType := ValidateClearances;
				if _raiseWarning then
					app.raiseCMWarning5(HMSMovementOverlap, voyageCode, berthCode, movement.getDisplayString(), voyageOverlapped.arrivedDT.shortCurrentLocaleFormat(), voyageOverlapped.departedDT.shortCurrentLocaleFormat(), null, null, self);			
				else
					_errorInfo	:=	app.getErrorString5(HMSMovementOverlap, voyageCode, berthCode, movement.getDisplayString(), voyageOverlapped.arrivedDT.shortCurrentLocaleFormat(), voyageOverlapped.departedDT.shortCurrentLocaleFormat());
					return false; 
				endif;
			endif;

			if	moveStartPosn &gt; currentStartPosn then
				// this movement starts further up the wharf than the movementToCheck
				if moveStartPosn &lt; closestEndPosn then
					// This is the closest movement on the far end side
					closestEndPosn := moveStartPosn;
				endif;
			else
				// this movement start further down the wharf than the movementToCheck 
				if moveEndPosn &gt; closestStartPosn then
					// This is the closest movement on the start (0m) side
					closestStartPosn := moveEndPosn;
				endif;	
			endif;
		endif;
	endforeach;

	// check - calculate wharf lock out clearances	
	foreach tmpLockout in tmpWharf.allWLockoutsByBothDT 
	where tmpLockout.startOfLockoutDT &lt; nextOccursDT
	and tmpLockout.endOfLockoutDT &gt; moveOccursDT do
		
		// Check to see if ship is within any part of this lockout
		// and is closer than any other ship
		if tmpLockout.startMarkOnWharf &gt; currentStartPosn then
			// this movement starts further up the wharf than the movementToCheck
			if tmpLockout.startMarkOnWharf &lt; closestEndPosn then
				// This lockout is closest to movement on the far end side
				closestEndPosn := tmpLockout.startMarkOnWharf;
			endif;
		else
			// this lockout start further down the wharf than anything else 
			if tmpLockout.endMarkOnWharf &gt; closestStartPosn then
				// This lockout is closest to movement on the start (0m) side
				closestStartPosn := tmpLockout.endMarkOnWharf;
			endif;	
		endif;	

	endforeach;	

	// Calculate clearances
	if bowMark &gt; sternMark then
		if closestEndPosn &lt; ClearanceUnbounded then
			newForeClearance := closestEndPosn-currentEndPosn;
		else
			// Fore clearance is unrestricted
			newForeClearance := ClearanceUnbounded; 
		endif;
		if closestStartPosn &gt; (-1*(ClearanceUnbounded)) then
			newAftClearance := currentStartPosn-closestStartPosn;
		else
			// Aft clearance is unrestricted
			newAftClearance := ClearanceUnbounded;
		endif;		
	else
		if closestEndPosn &lt; ClearanceUnbounded then
			newAftClearance := closestEndPosn-currentEndPosn;
		else
			// Fore clearance is unrestricted
			newAftClearance := ClearanceUnbounded; 
		endif;
		if closestStartPosn &gt; (-1*(ClearanceUnbounded)) then
			newForeClearance := currentStartPosn-closestStartPosn;
		else
			// Aft clearance is unrestricted
			newForeClearance := ClearanceUnbounded;
		endif;	
	endif;

	// Calc clearances to wharf ends if unlimited by other vessels.
	if bowMark &gt; sternMark then
		if newForeClearance = ClearanceUnbounded then
			// Calc clearance from bow to max metre end of wharf
			newForeClearance := ((tmpWharf.length) - bowMark);
			tmpOverlapsWharfSection := newForeClearance &lt; minClearance;
		endif;
		if newAftClearance = ClearanceUnbounded then
			// Calc clearance from stern to zero metre end of wharf
			newAftClearance := sternMark;
			tmpOverlapsWharfSection := newAftClearance &lt; minClearance;			
		endif;
	else
		if newAftClearance = ClearanceUnbounded then
			// Calc clearance from stern to max metre end of wharf
			newAftClearance := ((tmpWharf.length) - sternMark);
			tmpOverlapsWharfSection := newAftClearance &lt; minClearance;			
		endif;
		if newForeClearance = ClearanceUnbounded then
			// Calc clearance from bow to zero metre end of wharf
			newForeClearance := bowMark;
			tmpOverlapsWharfSection := newForeClearance &lt; minClearance;			
		endif;	
	endif;
	

	if newForeClearance &lt; ClearanceUnbounded and newForeClearance &lt; minClearance then
		_invalidType := ValidateClearances;
		if _raiseWarning then
			app.raiseCMWarning3(HMSClearance, 'Fore', newForeClearance.String, minClearance.String, null, null, self);		
		else
			_errorInfo	:=	app.getErrorString3(HMSClearance, 'Fore', newForeClearance.String, minClearance.String);
			return false;
		endif;
	elseif newAftClearance &lt; ClearanceUnbounded and  newAftClearance &lt; minClearance then
		// Aft clearance is less than the minimum clearance and is not unbounded
		_invalidType := ValidateClearances;		
		if _raiseWarning then
			app.raiseCMWarning3(HMSClearance, 'Aft', newAftClearance.String, minClearance.String, null, null, self);				
		else
			_errorInfo	:=	app.getErrorString3(HMSClearance, 'Aft', newAftClearance.String, minClearance.String);
			return false;
		endif;
	endif;	

	if self.moveType = HMSMovementTypeDeparture then
		if prevMove &lt;&gt; null then
			// may have already been validated
			if prevMove.occursOnDTNEW &lt; conflictsManager.fromDT then
				self.calc_ClearancesWharfSection(newForeClearance, newAftClearance, tmpOverlapsWharfSection, prevMove.getMyBerth().myWharf,	currentStartPosn, currentEndPosn, bowMark, sternMark);			
			endif;
		endif;
	else
		self.calc_ClearancesWharfSection(newForeClearance, newAftClearance, tmpOverlapsWharfSection, tmpWharf,	currentStartPosn, currentEndPosn, bowMark, sternMark);
	endif;

	if tmpOverlapsWharfSection then
		// overlaps an undefined section of the wharf
		_invalidType := ValidateShipPosn;		
		if _raiseWarning then
			app.raiseCMWarning2(HMSWharfSectionUndefined, voyageCode, tmpWharf.code, null, null, self);				
		else
			_errorInfo	:=	app.getErrorString2(HMSWharfSectionUndefined, voyageCode, tmpWharf.code);
			return false;
		endif;
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="conflictsManager" type="CMIF_HMS_ConflictsManager"/>
        <Parameter name="_raiseWarning" type="Boolean"/>
        <Parameter name="_invalidType" type="Integer" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_errorInfo" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="check_DepthsAlongWharf" id="097f3bca-7678-4a44-890c-31dae0a003c1">
        <source>check_DepthsAlongWharf(	_vesselCode : String;
						_minDraft: Decimal;
						_fromBerth: HMS_Berth;
						_toBerth: HMS_Berth;
						_raiseWarning : Boolean;
						_errorInfo:String output):Boolean protected;

vars
 	startBerthMark:	Integer;
 	endBerthMark:	Integer;
 	berth:			HMS_Berth;
 	rtnValue:		Boolean;
begin
	// This method check the depth of all berths between fromBerth and toBerth on the 
	// same wharf against the minimum depth for a ship
	rtnValue := true;
	if _fromBerth.startPosition &lt; _toBerth.startPosition then
		startBerthMark := _fromBerth.startPosition + _fromBerth.length;
		endBerthMark := _toBerth.startPosition;
	else
		startBerthMark := _toBerth.startPosition + _toBerth.length;
		endBerthMark := _fromBerth.startPosition;
	endif;

	foreach berth in _fromBerth.myWharf.allBerths do
		if berth.startPosition &gt;= startBerthMark and 
		   berth.startPosition &lt; endBerthMark then
			// Check the depth at this berth
			if berth.minimumDepth &lt; _minDraft then
				// Min draft for ship exceeded
				rtnValue := false;
				if _raiseWarning then
					app.raiseCMWarning5(HMSDepthsAtToFromBerths, 'Minimum', _minDraft.String, _vesselCode, berth.minimumDepth.String, berth.code, null, null, self);				
				else
					_errorInfo	:=	app.getErrorString5(HMSDepthsAtToFromBerths, 'Minimum', _minDraft.String, _vesselCode, berth.minimumDepth.String, berth.code);
					return false;				
				endif;
			else
				// Draft OK
			endif;
		endif;
	endforeach;

	return rtnValue;
end;</source>
        <access>protected</access>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_minDraft" type="Decimal"/>
        <Parameter name="_fromBerth" type="HMS_Berth"/>
        <Parameter name="_toBerth" type="HMS_Berth"/>
        <Parameter name="_raiseWarning" type="Boolean"/>
        <Parameter name="_errorInfo" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="check_DepthsAtToFromBerths" id="8d3e9407-aac1-4e69-95a0-2a88c569a5a9">
        <source>check_DepthsAtToFromBerths(_raiseWarning : Boolean; _errorInfo:String output):Boolean protected;

/*

Date		Who		Reason
27 Mar 2008	cnwkpd1	PAR #16289 - Change Drafts to Decimal[8,2]
30 Mar 2008	cnwkpd1	PAR #16367 - Change to use reworked HMS_VoyageMovement::getVoyageMovementPrevious

*/

vars
	toBerth:			HMS_Berth;
	fromBerth:			HMS_Berth;
	foreDraft:			Decimal[8,2];			// PAR #16289
	aftDraft:			Decimal[8,2];			// PAR #16289
	pathToCheck:		HMS_MovementPath;
	path:				HMS_MovementPath;
	regA:				HMS_HarbourRegion;
	regB:				HMS_HarbourRegion;
	minDraft:			Decimal[8,2];			// PAR #16289
	movePrev:			HMS_VoyageMovement;
	vesselCode,
	tmpBerthCode,
	enterLeaveStatus:	String;
	rtnValue:			Boolean;
begin
	// This method checks that the all checkpoints and berth depth checks for this movement are valid 
	
	// Set fore and aft draft
	foreDraft := self.myHMSVoyageData.dim_DraftFore;
	aftDraft := self.myHMSVoyageData.dim_DraftAft;
	vesselCode := self.myHMSVoyageData.myVoyage.code;
	rtnValue := true;

	movePrev := self.getVoyageMovementPrevious();		// PAR #16367 - moved up to here

	if self.moveType = HMSMovementTypeArrival then
		// Arrival movement ie fromBerth=null
		toBerth := self.getMyBerth();
		fromBerth := null;
		if self.myHarbour.defaultArrvBerth &lt;&gt; null then
			regA := self.myHarbour.defaultArrvBerth.myHarbourRegion;
		endif;
		regB := toBerth.myHarbourRegion;	
	elseif self.moveType = HMSMovementTypeDeparture then
		// Departure movement ie toBerth=null
		toBerth := null;
		if movePrev &lt;&gt; null then						// PAR #16367
			fromBerth := movePrev.getMyBerth();
			regA := fromBerth.myHarbourRegion;
		endif;
		if self.myHarbour.defaultDepartBerth &lt;&gt; null then
			regB := self.myHarbour.defaultDepartBerth.myHarbourRegion;
		endif;
	else
		// Shift movement
		toBerth := self.getMyBerth();
		if movePrev &lt;&gt; null then						// PAR #16367
			fromBerth := movePrev.getMyBerth();
			regA := fromBerth.myHarbourRegion;
		endif;
		regB := toBerth.myHarbourRegion;
	endif;
	
	// Check depth for 'From Berth'
	if fromBerth &lt;&gt; null then
		tmpBerthCode := fromBerth.code;
		if (not fromBerth.isLogicalBerth()) then
			if foreDraft &gt; fromBerth.minimumDepth then
				// Vessel draft exceeds berth minimum depth
				rtnValue := false;
				if _raiseWarning then
					app.raiseCMWarning5(HMSDepthsAtToFromBerths, 'Fore', foreDraft.String, vesselCode, fromBerth.minimumDepth.String, tmpBerthCode, null, null, self);				
				else
					_errorInfo	:=	app.getErrorString5(HMSDepthsAtToFromBerths, 'Fore', foreDraft.String, vesselCode, fromBerth.minimumDepth.String, tmpBerthCode);
					return false;
				endif;
			elseif aftDraft &gt; fromBerth.minimumDepth then
				// Vessel draft exceeds berth minimum depth
				rtnValue := false;
				if _raiseWarning then
					app.raiseCMWarning5(HMSDepthsAtToFromBerths, 'Aft', aftDraft.String, vesselCode, fromBerth.minimumDepth.String, tmpBerthCode, null, null, self);				
				else
					_errorInfo	:=	app.getErrorString5(HMSDepthsAtToFromBerths, 'Aft', aftDraft.String, vesselCode, fromBerth.minimumDepth.String, tmpBerthCode);
					return false;				
				endif;
			endif;
		endif;
	endif;

	// Check depth for 'To Berth'
	if toBerth &lt;&gt; null then
		tmpBerthCode := toBerth.code;
		if (not toBerth.isLogicalBerth()) then
			if foreDraft&gt;toBerth.minimumDepth then
				// Vessel draft exceeds berth minimum depth
				rtnValue := false;
				if _raiseWarning then
					app.raiseCMWarning5(HMSDepthsAtToFromBerths, 'Fore', aftDraft.String, vesselCode, toBerth.minimumDepth.String, tmpBerthCode, null, null, self);				
				else
					_errorInfo	:=	app.getErrorString5(HMSDepthsAtToFromBerths, 'Fore', aftDraft.String, vesselCode, toBerth.minimumDepth.String, tmpBerthCode);
					return false;				
				endif;
			elseif aftDraft &gt; toBerth.minimumDepth then
				// Vessel draft exceeds berth minimum depth
				rtnValue := false;
				if _raiseWarning then				
					app.raiseCMWarning5(HMSDepthsAtToFromBerths, 'Aft', aftDraft.String, vesselCode, toBerth.minimumDepth.String, tmpBerthCode, null, null, self);				
				else
					_errorInfo	:=	app.getErrorString5(HMSDepthsAtToFromBerths, 'Aft', aftDraft.String, vesselCode, toBerth.minimumDepth.String, tmpBerthCode);
					return false;				
				endif;
			endif;
		endif;
	endif;

	// Get Enter/Leaving harbour status for movement
	enterLeaveStatus := self.getShipEnterLeaveStatus(regA,regB,movePrev);

	// Check to see if a path is defined. If it is, then check checkpoints on path
	pathToCheck := app.myRoot.getMovementPath(regA, regB, true);
	
    /*
	foreach path in self.myHarbour.allMovementPaths do
    	if path.myRegionFrom = regA and path.myRegionTo = regB then
    		pathToCheck := path;
    	elseif path.myRegionTo = regB and path.myRegionFrom = regA then
    		pathToCheck := path;
    	endif;
    endforeach;
	*/

   	if pathToCheck &lt;&gt; null then
   		return rtnValue;
   	endif;
   	
	// If path is not defined and to &amp; from berths are on the same wharf, check
	// all berth depths in between.
	if fromBerth &lt;&gt; null and toBerth &lt;&gt; null then
		if fromBerth.myWharf = toBerth.myWharf and (not fromBerth.isLogicalBerth()) then
			// Both berths are on the same wharf and the wharf is a physical wharf
			// Check the depths along the wharf
			if foreDraft &lt; aftDraft then
				minDraft := foreDraft;
			else
				minDraft := aftDraft;
			endif;	
			return self.check_DepthsAlongWharf(vesselCode, minDraft,fromBerth,toBerth, _raiseWarning, _errorInfo);
		endif;
	else
		return rtnValue;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_raiseWarning" type="Boolean"/>
        <Parameter name="_errorInfo" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="check_TidalWindow" id="a125a668-cf89-4839-9478-0931124eca75">
        <source>check_TidalWindow(_raiseWarning : Boolean; _errorInfo:String output):Boolean protected;

/*

Date		Who		Reason
27 Mar 2008	cnwkpd1	PAR #16289 - Change Drafts to Decimal[8,2]
30 Mar 2008	cnwkpd1	PAR #16367 - Change to use reworked HMS_VoyageMovement::getVoyageMovementPrevious

*/

vars
	toBerth				: HMS_Berth;
	fromBerth			: HMS_Berth;
	foreDraft			: Decimal[8,2];				// PAR #16289
	aftDraft			: Decimal[8,2];				// PAR #16289
	pathToCheck			: HMS_MovementPath;
	path				: HMS_MovementPath;
	regA				: HMS_HarbourRegion;
	regB				: HMS_HarbourRegion;
	baseTimeAtRegA		: Boolean;
	harbour				: HMS_Harbour;
	directionFwd		: Boolean;
	basetime			: TimeStamp;
	pathSegment			: HMS_PathSegment;
	regToCheck			: HMS_HarbourRegion;
	regionObj			: HMS_HarbourRegion;
	offSetTime			: Time;
	errMsg				: String;
	movePrev			: HMS_VoyageMovement;
	enterLeaveStatus	: String;
	rtnValue			: Boolean;	
begin

	// Set reference to harbour
	harbour := self.myHarbour;
	
	//if harbour.tidalModelType &lt;&gt; app.getErrorString(HMSTidalModelType_Otago) then
	//	return true;
	//endif;
	rtnValue := true;
	// Set fore and aft draft
	foreDraft := self.myHMSVoyageData.dim_DraftFore;
	aftDraft := self.myHMSVoyageData.dim_DraftAft;

	movePrev := self.getVoyageMovementPrevious();		// PAR #16367 - moved up to here
	
	if self.moveType = HMSMovementTypeArrival then
		// Arrival movement ie fromBerth=null
		toBerth := self.getMyBerth();
		fromBerth := null;
		if harbour.defaultArrvBerth &lt;&gt; null then
			regA := harbour.defaultArrvBerth.myHarbourRegion;
		endif;
		if toBerth &lt;&gt; null then
			regB := toBerth.myHarbourRegion;
		endif;
		// Determine which end of the path the base time needs to be associated with
   		if harbour.baseTimeArrive = AtSea then
   			baseTimeAtRegA := true;
   		endif;		
	elseif self.moveType = HMSMovementTypeDeparture then
		// Departure movement ie toBerth=null
		toBerth := null;
		if movePrev &lt;&gt; null then
			fromBerth := movePrev.getMyBerth();
			regA := fromBerth.myHarbourRegion;
		endif;
		if harbour.defaultDepartBerth &lt;&gt; null then
			regB := harbour.defaultDepartBerth.myHarbourRegion;
		endif;
		// Determine which end of the path the base time needs to be associated with
   		if harbour.baseTimeDepart = AtWharf then
   			baseTimeAtRegA := true;
   		endif;
	else
		// Shift movement
		toBerth := getMyBerth();
		if movePrev &lt;&gt; null then
			fromBerth := movePrev.getMyBerth();
			regA := fromBerth.myHarbourRegion;
		endif;
		regB := toBerth.myHarbourRegion;
		// Determine which end of the path the base time needs to be associated with
   		if harbour.baseTimeDepart = AtBerthDepartingFrom and
   		   fromBerth &lt;&gt; null and 
   		   (not fromBerth.isLogicalBerth()) then
   			baseTimeAtRegA := true;
   		endif;
	endif;

	// Get Enter/Leaving harbour status for movement
	enterLeaveStatus := self.getShipEnterLeaveStatus(regA,regB,movePrev);

	// Check to see if a path is defined. If it is, then check checkpoints on path
    foreach path in harbour.allMovementPaths do
    	if path.myRegionFrom = regA and 
    	   path.myRegionTo = regB then
    		pathToCheck := path;
    		// Set direction along path to fwd=true ie. The ship is travelling
    		// from regA to regB
    		directionFwd := true;
    	elseif path.myRegionFrom = regB and 
    	   path.myRegionTo = regA then
    		pathToCheck := path;
    		// Set direction along path to fwd=false ie. The ship is travelling
    		// from regB to regA
    		directionFwd := false;
    		// Swap BT for reverse direction
    		baseTimeAtRegA := not (baseTimeAtRegA);
    	endif;
    endforeach;
	
// cnwdad1 19/10/2007 - When using Voyage Commodity Planning license, Harbour::allMovementPaths is empty,
//	so we have to get to them via the Harbour Regions first.
	if pathToCheck = null then
		foreach regionObj in harbour.allRegions do
			foreach path in regionObj.allMovementPaths do
				if path.myRegionFrom = regA and path.myRegionTo = regB then
					pathToCheck := path;
					// Set direction along path to fwd=true ie. The ship is travelling
					// from regA to regB
					directionFwd := true;
				elseif path.myRegionFrom = regB and path.myRegionTo = regA then
					pathToCheck := path;
					// Set direction along path to fwd=false ie. The ship is travelling
					// from regB to regA
					directionFwd := false;
					// Swap BT for reverse direction
					baseTimeAtRegA := not (baseTimeAtRegA);
				endif;
			endforeach;
		endforeach;
	endif;
	
   	if pathToCheck = null then
   		return true;
   	endif;
	// Check this path
	// Step through all regions along path and check their respective checkpoints
	// at the appropriately offset times
	
   	if baseTimeAtRegA = true
   	and directionFwd = true then
		// Check regions along path in direction = from 'A' to 'B'
			// Set basetime=movement time
			basetime := self.occursOnDTNEW;
			// Check checkpoints at reg A at basetime
			if regA.hasCheckpointsWithTidalModel() then
				// Checkpoints to check
				if app.myHMSRvTide.getPermMoveChkPtState(regA,self,self.moveType,basetime,errMsg,enterLeaveStatus) = false then
					// Check point at region A has failed
					rtnValue := false;
					if _raiseWarning then
						if self.myHarbour.suppressTidalWarnings then					// PAR #33337
							rtnValue := true;											// PAR #33337
						else															// PAR #33337
							app.raiseCMWarning2(HMSTidalWindow, regA.code, errMsg, null, null, self);
						endif;															// PAR #33337
					else
						_errorInfo	:=	app.getErrorString2(HMSTidalWindow, regA.code, errMsg);
						return false;
					endif;
				endif;
			endif;
			foreach pathSegment in pathToCheck.allPathSegments do
				regToCheck := pathSegment.myRegionTo;
				offSetTime.setTime(0, pathSegment.steamingTimeAB, 0, 0);
				basetime := basetime + offSetTime;
				if regToCheck.hasCheckpointsWithTidalModel() then
					if app.myHMSRvTide.getPermMoveChkPtState(regToCheck,self,self.moveType,basetime,errMsg,enterLeaveStatus) = false then
						// Check point at region B has failed
						rtnValue := false;
						if _raiseWarning then						
							if self.myHarbour.suppressTidalWarnings then				// PAR #33337
								rtnValue := true;										// PAR #33337
							else														// PAR #33337
								app.raiseCMWarning2(HMSTidalWindow, regToCheck.code, errMsg, null, null, self);
							endif;														// PAR #33337
						else
							_errorInfo	:=	app.getErrorString2(HMSTidalWindow, regToCheck.code, errMsg);
							return false;
						endif;
					endif;
				endif;
			endforeach;
	elseif baseTimeAtRegA = false and 
	   directionFwd = true then
		// Check regions along path in direction = from 'B' to 'A'
			// Set basetime = movement time
			basetime := self.occursOnDTNEW;
			// Check checkpoints at reg B at basetime
			if regB.hasCheckpointsWithTidalModel() then
				// Checkpoints to check
				if app.myHMSRvTide.getPermMoveChkPtState(regB,self,self.moveType,basetime,errMsg,enterLeaveStatus) = false then
					// Check point at region B has failed
					rtnValue := false;
					if _raiseWarning then					
						if self.myHarbour.suppressTidalWarnings then					// PAR #33337
							rtnValue := true;											// PAR #33337
						else															// PAR #33337
							app.raiseCMWarning2(HMSTidalWindow, regB.code, errMsg, null, null, self); 
						endif;															// PAR #33337
					else
						_errorInfo	:=	app.getErrorString2(HMSTidalWindow, regB.code, errMsg);
						return false;
					endif;
				endif;
			endif;
			foreach pathSegment in pathToCheck.allPathSegments reversed do
				regToCheck := pathSegment.myRegionFrom;
				offSetTime.setTime(0,pathSegment.steamingTimeAB,0,0);
				basetime := basetime - offSetTime;
				if regToCheck.hasCheckpointsWithTidalModel() then
					if app.myHMSRvTide.getPermMoveChkPtState(regToCheck,self,self.moveType,basetime,errMsg,enterLeaveStatus) = false then
						// Check point at region A has failed
						rtnValue := false;
						if _raiseWarning then						
							if self.myHarbour.suppressTidalWarnings then				// PAR #33337
								rtnValue := true;										// PAR #33337
							else														// PAR #33337
								app.raiseCMWarning2(HMSTidalWindow, regToCheck.code, errMsg, null, null, self); 
							endif;														// PAR #33337
						else
							_errorInfo	:=	app.getErrorString2(HMSTidalWindow, regToCheck.code, errMsg);
							return false;
						endif;
						
					endif;
				endif;
			endforeach;
	elseif baseTimeAtRegA = true and 
	   directionFwd = false then
		// Check regions along path in direction = from 'B' to 'A'
			// Set basetime=movement time
			basetime := self.occursOnDTNEW;
			// Check checkpoints at reg A at basetime
			if regA.hasCheckpointsWithTidalModel() then
				// Checkpoints to check
				if app.myHMSRvTide.getPermMoveChkPtState(regA,self,self.moveType,basetime,errMsg,enterLeaveStatus) = false then
					// Check point at region A has failed
					rtnValue := false;
					if _raiseWarning then
						if self.myHarbour.suppressTidalWarnings then					// PAR #33337
							rtnValue := true;											// PAR #33337
						else															// PAR #33337
							app.raiseCMWarning2(HMSTidalWindow, regA.code, errMsg, null, null, self);
						endif;															// PAR #33337
					else
						_errorInfo	:=	app.getErrorString2(HMSTidalWindow, regA.code, errMsg);
						return false;
					endif;
				endif;
			endif;
			foreach pathSegment in pathToCheck.allPathSegments do
				regToCheck := pathSegment.myRegionTo;
				offSetTime.setTime(0, pathSegment.steamingTimeBA, 0, 0);
				basetime := basetime - offSetTime;
				if regToCheck.hasCheckpointsWithTidalModel() then
					if app.myHMSRvTide.getPermMoveChkPtState(regToCheck,self,self.moveType,basetime,errMsg,enterLeaveStatus) = false then
						// Check point at region B has failed
						rtnValue := false;
						if _raiseWarning then						
							if self.myHarbour.suppressTidalWarnings then				// PAR #33337
								rtnValue := true;										// PAR #33337
							else														// PAR #33337
								app.raiseCMWarning2(HMSTidalWindow, regToCheck.code, errMsg, null, null, self);   							
							endif;														// PAR #33337
						else
							_errorInfo	:=	app.getErrorString2(HMSTidalWindow, regToCheck.code, errMsg);
							return false;
						endif;
					endif;
				endif;
			endforeach;
	elseif baseTimeAtRegA=false and 
	   directionFwd=false then
		// Check regions along path in direction = from 'B' to 'A'
		// Set basetime=movement time
		basetime := self.occursOnDTNEW;
		// Check checkpoints at reg B at basetime
		if regB.hasCheckpointsWithTidalModel() then
			// Checkpoints to check
			if app.myHMSRvTide.getPermMoveChkPtState(regB,self,self.moveType,basetime,errMsg,enterLeaveStatus) = false then
				// Check point at region B has failed
				rtnValue := false;
				if _raiseWarning then
					if self.myHarbour.suppressTidalWarnings then						// PAR #33337
						rtnValue := true;												// PAR #33337
					else																// PAR #33337
						app.raiseCMWarning2(HMSTidalWindow, regB.code, errMsg, null, null, self);   							   						
					endif;																// PAR #33337
				else
					_errorInfo	:=	app.getErrorString2(HMSTidalWindow, regB.code, errMsg);
					return false;
				endif;
			endif;
		endif;
		foreach pathSegment in pathToCheck.allPathSegments reversed do
			regToCheck := pathSegment.myRegionFrom;
			offSetTime.setTime(0, pathSegment.steamingTimeBA, 0, 0);
			basetime := basetime + offSetTime;
			if regToCheck.hasCheckpointsWithTidalModel() then
				if app.myHMSRvTide.getPermMoveChkPtState(regToCheck,self,self.moveType,basetime,errMsg,enterLeaveStatus) = false then
					// Check point at region A has failed
					rtnValue := false;
					if _raiseWarning then					
						if self.myHarbour.suppressTidalWarnings then					// PAR #33337
							rtnValue := true;											// PAR #33337
						else															// PAR #33337
							app.raiseCMWarning2(HMSTidalWindow, regToCheck.code, errMsg, null, null, self);   							
						endif;															// PAR #33337
					else
						_errorInfo	:=	app.getErrorString2(HMSTidalWindow, regToCheck.code, errMsg);
						return false;
					endif;
				endif;
			endif;
		endforeach;
	endif;
	
	return rtnValue;	

end;</source>
        <access>protected</access>
        <Parameter name="_raiseWarning" type="Boolean"/>
        <Parameter name="_errorInfo" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="check_WharfLockouts" id="d698cf91-6a78-48e8-94f8-8fc022d9f991">
        <source>check_WharfLockouts(_raiseWarning : Boolean; _errorInfo:String output):Boolean protected;

vars
	currentMove,
	nextMove:		HMS_VoyageMovement;
	lockout:		HMS_WharfLockout;
	moveStart:		TimeStamp;
	moveEnd:		TimeStamp;
	shipStart,
	shipEnd:		Real;
	lockDetails:	String;
	theWharf:		HMS_Wharf;
begin
	// This method checks the current movement to see if any section of the 
	// wharf that it is occuping is locked out at any stage before the next
	// movement in this voyage.

	currentMove := self;
	if currentMove.moveType = HMSMovementTypeDeparture then
		// Checks N/A
		currentMove := self.getVoyageMovementPrevious();
	endif;
	
	// Get next move in voyage
	nextMove := currentMove.getVoyageMovementNext;
	moveStart := currentMove.occursOnDTNEW;
	
	if nextMove &lt;&gt; null then
		moveEnd := nextMove.occursOnDTNEW;
	endif;

	// Check that berth for current move is not logical
	if currentMove.isLogicalBerth() then
		// Wharf is logical - check N/A
		return true;
	else
		// Get ship position on wharf
		if currentMove.bowMarkTo &lt; currentMove.sternMarkTo then
			shipStart := currentMove.bowMarkTo;
			shipEnd := currentMove.sternMarkTo;
		else
			shipStart := currentMove.sternMarkTo;
			shipEnd := currentMove.bowMarkTo;
		endif;
		
		theWharf := currentMove.getMyBerth().myWharf;
		// Wharf is physical - check for lockouts
		foreach lockout in myHarbour.allWLockoutsByStartDT 
		where lockout.startOfLockoutDT &lt; moveEnd 
		and lockout.endOfLockoutDT &gt; moveStart do
			// These lockouts occur within the time that the movement stay at the toBerth
			if lockout.myWharf = theWharf then
				// Lockout applies to same wharf as move.myBerth
				// Check position along wharf
				if shipStart &lt; lockout.endMarkOnWharf and 
				   shipEnd &gt; lockout.startMarkOnWharf then
					// This section of the wharf is locked out
					if _raiseWarning then
						app.raiseCMWarning4(HMSWharfLockout, theWharf.code, lockout.startMarkOnWharf.String, lockout.endMarkOnWharf.String, lockout.reason, null, null,self);
					else
						_errorInfo	:=	app.getErrorString4(HMSWharfLockout, theWharf.code, lockout.startMarkOnWharf.String, lockout.endMarkOnWharf.String, lockout.reason);
						return false;
					endif;
				endif;
			endif;
		endforeach;
		
		// No lockout conflicts
		return true;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_raiseWarning" type="Boolean"/>
        <Parameter name="_errorInfo" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="check_WharfOverhang" id="347008f4-ae42-46dc-81d6-8316fb00ef32">
        <source>check_WharfOverhang(_raiseWarning : Boolean; _errorInfo:String output):Boolean protected;

vars
	theWharf:			HMS_Wharf;
	wharfMin,
	wharfMax,
	newBowMark,
	newSternMark:		Real;		
begin
	// This method retruns true is the bow and stern marks for the ships position 
	// are valid for the wharf in question - this takes into account overhang allowances

	theWharf	:=	self.getMyBerth().myWharf;
	wharfMin	:=	0-(theWharf.overhangZeroMetreEnd);
	wharfMax	:=	(theWharf.length)+(theWharf.overhangMaxMetreEnd);

	// Get new bow and stern marks for changed ship size
	//permMove_ResizeMarks(newBowMark,newSternMark);
	newBowMark		:=	self.bowMarkTo;
	newSternMark	:=	self.sternMarkTo;
	
	if newBowMark &lt; wharfMin then
		if _raiseWarning then
			app.raiseCMWarning4(HMSWharfOverhang, 'Bow Mark', newBowMark.String, wharfMin.String, theWharf.code, null, null, self);
		else
			_errorInfo	:=	app.getErrorString4(HMSWharfOverhang, 'Bow Mark', newBowMark.String, wharfMin.String, theWharf.code);
		endif;
		
		return false;
		
	elseif newSternMark &lt; wharfMin then
		if _raiseWarning then	
			app.raiseCMWarning4(HMSWharfOverhang, 'Stern Mark', newSternMark.String, wharfMin.String, theWharf.code, null, null, self);
		else
			_errorInfo	:=	app.getErrorString4(HMSWharfOverhang, 'Stern Mark', newSternMark.String, wharfMin.String, theWharf.code);
		endif;
		
		return false;
		
	elseif newBowMark &gt; wharfMax then
		if _raiseWarning then	
			app.raiseCMWarning4(HMSWharfOverhang, 'Bow Mark', newBowMark.String, wharfMax.String, theWharf.code, null, null,self);
		else
			_errorInfo	:=	app.getErrorString4(HMSWharfOverhang, 'Bow Mark', newBowMark.String, wharfMax.String, theWharf.code);
		endif;
		
		return false;
		
	elseif newSternMark &gt; wharfMax then
		if _raiseWarning then
			app.raiseCMWarning4(HMSWharfOverhang, 'Stern Mark', newSternMark.String, wharfMax.String, theWharf.code, null, null, self);
		else
			_errorInfo	:=	app.getErrorString4(HMSWharfOverhang, 'Stern Mark', newSternMark.String, wharfMax.String, theWharf.code);
		endif;
		
		return false;
	else
		return true;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_raiseWarning" type="Boolean"/>
        <Parameter name="_errorInfo" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cloneMyResourcesUsed" id="ada7bbe6-ffa3-491d-8bfb-1013c63c76be">
        <source>cloneMyResourcesUsed(_origMovement : HMS_VoyageMovement; _transient : Boolean) protected;
//--------------------------------------------------
// Created:	24 February 2005 By: cnwgd1
//--------------------------------------------------
vars
	newResourceUsed,
	tmpResourceUsed 	: HMS_ResourceUsed;
begin
	if _origMovement = null then
		return;
	endif;
	//Create resources used
	foreach tmpResourceUsed in _origMovement.allResourceUsed do
		newResourceUsed := tmpResourceUsed.cloneMySelf(_transient);
		self.allResourceUsed.add(newResourceUsed);
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_origMovement" type="HMS_VoyageMovement"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cloneMySelf" id="0d3e604c-1752-425d-be56-57decbc96f3e">
        <source>cloneMySelf(_transient : Boolean) : SelfType protected;
//--------------------------------------------------
// Created:	21 February 2005 By: cnwgd1
/* Changes

Date		Name	TFS#		Description
============================================================================
23 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
23 Sep 2019 jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
============================================================================*/

vars
	newMovement : HMS_VoyageMovement;
	newMvmntPilotDetails, // TFS 44438
	tempMvmntPilotDetails : HMS_MovementPilotDetails; // TFS 44438
begin
	
	newMovement := self.cloneSelf(_transient);
	
	newMovement.setMyBerth( self.getMyBerth);
	newMovement.myBerthPrevious := self.myBerthPrevious;
	
	newMovement.myContact := self.myContact;
	newMovement.myHarbour := self.myHarbour;
	newMovement.myHMSVoyageData := self.myHMSVoyageData;
//	newMovement.myPilot := self.myPilot;
	
	// 30 Oct 2018	NDL	TFS 41662
	newMovement.setUnusedMyPilotRefToNull();
	newMovement.allMovementPilotDetails.clear(); // --&gt; TFS 44438
	if not self.allMovementPilotDetails.isEmpty then
		foreach tempMvmntPilotDetails in self.allMovementPilotDetails do
			newMvmntPilotDetails := tempMvmntPilotDetails.cloneMySelf(_transient);
			newMovement.allMovementPilotDetails.add(newMvmntPilotDetails);
		endforeach;
	endif; // &lt;-- TFS 44438
	//newMovement.allPilots.clear(); // TFS 44438
	//if not self.allPilots.isEmpty then // TFS 44438
	//	self.allPilots.copy( newMovement.allPilots ); // TFS 44438
	//endif; // TFS 44438
	//if self.getUnConvertedMyPilotRef &lt;&gt; null then // to allow for conversion of single pilots to multi pilot // TFS 44438
	//	newMovement.allPilots.addNoDuplicates( self.getUnConvertedMyPilotRef, false ); // TFS 44438
	//endif; // TFS 44438
	
	//newMovement.myPilotLaunch := self.myPilotLaunch; // TFS 44438
	newMovement.myLineCompany := self.myLineCompany;
	newMovement.myShippingAgent := self.myShippingAgent;
	newMovement.myShippingLine := self.myShippingLine;
	newMovement.myTidalClass := self.myTidalClass;
	newMovement.myMaster:=self.myMaster; //epr par 18551 27/11/08
	
	self.allTugsUsed.copy(newMovement.allTugsUsed);	
	
	//19 Jun 2018	NDL	TFS 39296
	if self.myMarineServiceTimings &lt;&gt; null then
		self.myMarineServiceTimings.cloneOnto( newMovement );
	endif;
	
	//Do not clone resources here as they differ between move types, to set resources
	//call newMovement::setDefaultResourcesUsed(_transient, _passport);, otherwise
	//newMovement.cloneMyResourcesUsed(self, _transient); will clone all the original movement resources

	return newMovement;
end;</source>
        <access>protected</access>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="cloneMySelfAsMoveType" id="1689563b-3f51-423a-9f50-dea8437392d6">
        <source>cloneMySelfAsMoveType(_moveType : String; _occursOnDT : TimeStamp; _transient : Boolean; _passport : CM_Passport input) : SelfType;
//--------------------------------------------------
// Created:	21 February 2005 By: cnwgd1
//--------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
17/04/2018	jlgdap1	TFS 38112 	DQM Error 1090 on Movement Maintenance screen
23/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
============================================================================*/
vars
	numOfHours 			: Integer;
	arrvMove			: HMS_VoyageMovement;
	nextMove			: HMS_VoyageMovement;
	newMovement 		: HMS_VoyageMovement;
	numOfMinutes		: Integer;					// TFS 38112
	
begin
	
	newMovement := self.cloneMySelf(_transient);

	// no need to copy over cargo operations intervals
	// we will still set these old properties to null just in case we 
	// clone an old movement for which they are still set
	newMovement.cargoOperationStart		:=	null;
	newMovement.cargoOperationEndInt	:=	null;
	newMovement.cargoOperationStartInt	:=	null;
	newMovement.cargoOperationEnd		:=	null;
	
	newMovement.moveType				:=	_moveType;
	//newMovement.arrivalTimeAtFromRegionLocked := false; // jlgka1 TFS 45620
	//newMovement.steamingTimeLocked		:=	false;    // jlgka1 TFS 45620
	//newMovement.departureTimeLocked		:=	false;    // jlgka1 TFS 45620
	//newMovement.isBerthLocked			:=	false;		  // jlgka1 TFS 45620

 	// Set move occursOnDT if not supplied
 	if (not _occursOnDT.isValid) then
 		// Set default DT for the movement to be half way between the arrival movement and the next movement for the voyage
 		arrvMove := self.myHMSVoyageData.allVoyageMovements.first.HMS_VoyageMovement;
 		nextMove := self.myHMSVoyageData.allVoyageMovements.getAtKeyGtr(arrvMove.occursOnDTNEW).HMS_VoyageMovement;
	
		// Calculate the number of hours between the arrival move and the next move for the voyage
		numOfHours := arrvMove.occursOnDTNEW.differenceInHours(nextMove.occursOnDTNEW);
		
		// TFS 38112 If the number of hours is 1 or less, calculate the number of minutes between movements		// TFS 38112
		if numOfHours &lt;= 1 then																					// TFS 38112
			numOfMinutes := arrvMove.occursOnDTNEW.cnMinutesDifference(nextMove.occursOnDTNEW);					// TFS 38112
		endif;																									// TFS 38112
		
		// if the length of stay is less than two days then set the movement time to be
		// the arrival time + one hour, otherwise problems occur when trying to set date and time
		// TFS 38112 If we have minutes not hours, adjust by half the minutes									// TFS 38112
		if numOfMinutes &lt;&gt; null then																			// TFS 38112
			newMovement.occursOnDTNEW := arrvMove.occursOnDTNEW.changeByXXMinutes((numOfMinutes/2).Integer);	// TFS 38112
		else																									// TFS 38112
			newMovement.occursOnDTNEW := arrvMove.occursOnDTNEW.changeByXXHours((numOfHours/2).Integer);
		endif;																									// TFS 38112
		
		// not sure about what to set steaming time to ??
		newMovement.steamingTime := 0;
	endif;
	
	//CCMS1299 create default resources from vessel movement resource used
	newMovement.setDefaultResourcesUsed(_transient, _passport);		
	
	return newMovement;
end;</source>
        <Parameter name="_moveType" type="String"/>
        <Parameter name="_occursOnDT" type="TimeStamp"/>
        <Parameter name="_transient" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="copyMovement" id="6b0e6df8-7743-4647-898c-176105c69738">
        <updating/>
        <source>copyMovement(_fromMovement : CMIF_HMS_WorkingMovement input;
			_nextTransientMovement : CMIF_HMS_WorkingMovement input;
			_workingVoyage : CMIF_HMS_WorkingVoyage;
			_transType : Integer;
			_passport : CM_Passport input) updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
22/05/2014	cnwdap1	PAR #34209 	Prevent erroneous "Orientation changed" messages by keeping voyage orientation aligned with movement orientation
04/03/2019	jlgdap1	TFS 43667 	PNL Two Pilots on Departure Resources Used
23 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
05 Jun 2019	jlgsl4	TFS 45049 - PEL1 - Delete to-be-deleted movement pilot details objects
18/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
14/09/2022  navgm20 TFS 54739 	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards

============================================================================*/
vars
 	moveForDetails: Object;
 	actionType:		Integer;
 	oldValue:		String;
 	newValue:		String;
 	workResourceUsed:		CMIF_HMS_ResourceUsed;
 	permResourceUsed,
 	newPermResourceUsed:	HMS_ResourceUsed;
 	permResourceToDeleteSet,
 	permResourceStillUsed:	HMS_ResourceUsedSet;
 	tug:					HMS_Tug;
 	now:					TimeStamp;
	persistentMove	: HMS_VoyageMovement;
	tmpVoyage		: CM_Voyage;
	marineTimings : HMS_MarineServicesTimings;
	pilot			: HMS_Pilot;							// TFS 43667
	permMvmntPilotDetails,
	newMvmntPilotDetails,
	workMvmntPilotDetails : HMS_MovementPilotDetails; // TFS 44438
	permMmvntPilotDtlsToDelSet : HMS_MovementPilotDetailsSet; // TFS 44438
begin

 	// This method copies permanent movement information to a working movement and 
	// vice versa 
	if _transType = TRANS_TYPE_AddMovement then
		//Par9359 14/12/2004 cnwsh3 A shift movement could be added to a scenario voyage so there is a chance
		// we are attempting to update a persistent reference with a transient.  
		//Check this here.
		if _fromMovement.myHMSVoyageData &lt;&gt; null then
			if (not _fromMovement.myHMSVoyageData.isTransient) then
				self.myHMSVoyageData := _fromMovement.myHMSVoyageData;
			endif;
		endif;
		if self.myHMSVoyageData = null then
			self.myHMSVoyageData := _fromMovement.myWorkingVoyage.ofPermanentVoyage.myHMSVoyageData;
		endif;
	endif;
	
	self.createTransaction(_transType, _fromMovement , null, _passport);		

	// Modified by Russell 16/08/99
	// --------------------------------------------------------------------------------------------------------
	// Create Move Time Edit or Move Confirmed Transactions as required
	self.createTrans_AdjustMoveTime(_fromMovement , null, _passport);
	// --------------------------------------------------------------------------------------------------------

	// This method copies permanent movement information to a working movement and 
	// vice versa 
	self.aftClearanceTo 	:= _fromMovement.aftClearanceTo;
	self.isAgentDefault 	:= _fromMovement.isAgentDefault;
	self.bowMarkTo 			:= _fromMovement.bowMarkTo;
	self.foreClearanceFrom 	:= _fromMovement.foreClearanceFrom;
	self.foreClearanceTo 	:= _fromMovement.foreClearanceTo;
	self.locationPilotLaunch := _fromMovement.locationPilotLaunch;
	self.locationTug 		:= _fromMovement.locationTug;
	self.moveType 			:= _fromMovement.moveType;
	self.numLineCrewRequired := _fromMovement.numLineCrewRequired;

    self.moveStatusNEW := _fromMovement.moveStatus;

	// Do not recalc steaming times from here as the Graphical View does not show
	// steaming times.
	if self.isMovementTypeDeparture then
		self.setTimingsForward(_fromMovement.occursOnDT, self.steamingTime, true); //jlgka1 TFS 45620
	else
		self.setTimings(_fromMovement.occursOnDT, self.steamingTime, false);	   //jlgka1 TFS 45620
	endif;
	
	if self.myPreviousMovement &lt;&gt; null and
	   self.myPreviousMovement.occursOnDTNEW &gt; self.occursOnDTNEW then
		app.raiseUnexpectedProgramError(class.name, method.name, 'This change has resulted in the time for the ' &amp;
			self.moveType &amp; ' movement (' &amp; self.getDescription &amp; ') of ' &amp; self.occursOnDTNEW.asStringJMT &amp;
			' being before the time for the previous movement (' &amp; 
			self.myPreviousMovement.moveType &amp; ' ' &amp; self.myPreviousMovement.getDescription &amp; ') of ' &amp;
			self.myPreviousMovement.occursOnDTNEW.asStringJMT);
		return;
	endif;
	
	//epr par 15667 11/1/2008
//	if self.departureTimeFromFromRegion &lt;&gt; null then
//		self.steamingTime:= self.departureTimeFromFromRegion.minutesDiff(arrivalTimeAtToRegion).Integer;
//	endif;	
	
	self.relativeOrderTimeLines := _fromMovement.relativeOrderTimeLines;
	self.relativeOrderTimePlaunch := _fromMovement.relativeOrderTimePlaunch;
	self.relativeOrderTimeTugs := _fromMovement.relativeOrderTimeTugs;
	self.remarks := _fromMovement.remarks;

	self.overlapsWharfSection := _fromMovement .overlapsWharfSection;
	self.pilotExempt := _fromMovement .pilotExempt;
	self.shipsMaster := _fromMovement .shipsMaster;

	self.chargeForMove := _fromMovement .chargeForMove;
	self.sideTo := _fromMovement .sideTo;
	self.sternMarkTo := _fromMovement .sternMarkTo;

    // Modified by Russell 09/08/99
    // ---------------------------------------------------------------------

 	// Update references
 	//self.myPilot 		:= _fromMovement.myPilot;
	
	// 31 Oct 2018	NDL	TFS 41662
	self.setUnusedMyPilotRefToNull();
	create permMmvntPilotDtlsToDelSet transient; // --&gt; TFS 44438
	self.allMovementPilotDetails.copy(permMmvntPilotDtlsToDelSet);
	self.allMovementPilotDetails.clear();
 	foreach	workMvmntPilotDetails in _fromMovement.allMovementPilotDetails do
 		if workMvmntPilotDetails.isTransient then
	 		permMvmntPilotDetails := workMvmntPilotDetails.pxyGetRealObject;
	 	else
	 		permMvmntPilotDetails := workMvmntPilotDetails;
	 	endif;		
 		if permMvmntPilotDetails = null then
 			// Create new permanent movementPilotDetails object
 			create newMvmntPilotDetails;
			// Add movementPilotDetails to permanent collection
			self.allMovementPilotDetails.add(newMvmntPilotDetails);
			// Set newMmvntPilotDetails attributes
			newMvmntPilotDetails.setForCreate(workMvmntPilotDetails, _passport);			
  		else
  			// Remove movementPilotDetails from to-be-deleted collection
  			permMmvntPilotDtlsToDelSet.remove(permMvmntPilotDetails);
  			self.allMovementPilotDetails.add(permMvmntPilotDetails);
  			permMvmntPilotDetails.setForUpdate(workMvmntPilotDetails, _passport);
  		endif;
		permMvmntPilotDetails := null;
  	endforeach; // &lt;-- TFS 44438

	foreach workMvmntPilotDetails in permMmvntPilotDtlsToDelSet do // --&gt; TFS 45049
		delete workMvmntPilotDetails; // delete the to-be-deleted movement pilot details
	endforeach; // &lt;-- TFS 45049

	/* self.allPilots.clear(); // --&gt; TFS 44438
	if not _fromMovement.allPilots.isEmpty then
		_fromMovement.allPilots.copy( self.allPilots );
	endif;*/ // &lt;-- TFS 44438

 	self.myMaster 		:= _fromMovement.myMaster;
 	//self.myPilotLaunch 	:= _fromMovement.myPilotLaunch; // TFS 44438
 	self.myLineCompany 	:= _fromMovement.myLineCompany;
 	self.myShippingAgent := _fromMovement.myShippingAgent;
 	self.myShippingLine := _fromMovement.myShippingLine; 	
 	self.myContact 		:= _fromMovement.myContact;

    self.draftFwd		:=	_fromMovement.draftFwd;	//4.1.1 Draft enhancement
    self.draftAft		:=	_fromMovement.draftAft;
	self.vesselDraft	:=	_fromMovement.vesselDraft;

 	// Deselect tugs that are no longer selected
 	self.allTugsUsed.clear();
 	_fromMovement.allTugsUsed.copy(self.allTugsUsed);

 	self.setMyBerth(_fromMovement.myBerth);
 	self.myTidalClass 	:= _fromMovement.myMoveTidalClass;
 	self.myHarbour 	:= _fromMovement.myHarbour;
	
	//14/09/2022 navgm20 TFS 54739- Start
	self.bowToBollard	:= _fromMovement.bowToBollard;
	self.sternToBollard	:= _fromMovement.sternToBollard;
	self.bridgeToBollard	:= _fromMovement.bridgeToBollard;
	self.myBowBollard	:= _fromMovement.myBowBollard;
	self.mySternBollard	:= _fromMovement.mySternBollard;
	self.myBridgeBollard	:= _fromMovement.myBridgeBollard;
	//14/09/2022 navgm20 TFS 54739- End
	
	/*  epr 10/12/07 removed - checkVesselArrayPosn is an empty method
 	// Update voyage arrival date if this is an arrival movement
 	if moveType = HMSMovementTypeArrival then
		// Update the vessel's collection of allPermVoyages
		self.myHMSVoyageData.checkVesselArrayPosn;
		// ------------------------------------------------------------------------------
 	endif;

 	// Update voyage departure date if this is a departure movement
 	if self.moveType = HMSMovementTypeDeparture then
		// Update the vessel's collection of allPermVoyages
		self.myHMSVoyageData.checkVesselArrayPosn;
		// ------------------------------------------------------------------------------
 	endif;*/

	// when creating a voyage from a scenario one, Arrival and Departure haven't got myVoyageGlobal. Par16752 May 2009
	if self.moveType &lt;&gt; HMSMovementTypeShift and self.myVoyageGlobal = null then
		tmpVoyage := self.getMyVoyage();
		if tmpVoyage &lt;&gt; null then
			self.myVoyageGlobal := tmpVoyage.myVoyageGlobalArrival;
		endif;
	endif;
	
	// -----------------------------------------------------------------------------
	// Par 15582. For Shift movement we need to find myVoyageGlobal. 
	// Arrival and Departure have already got myVoyageGlobal after creating a voyage.
	// -----------------------------------------------------------------------------
 	if self.moveType = HMSMovementTypeShift then
		persistentMove := _fromMovement.myPersistentMovement;
		if persistentMove = null then	// when creating Shift movement
			if self.myHMSVoyageData &lt;&gt; null then
				if self.myHMSVoyageData.allVoyageMovements.size &gt; 0 then
					// so, by default Shift.myVoyageGlobal = Arrival.myVoyageGlobal
					self.myVoyageGlobal := self.myHMSVoyageData.allVoyageMovements.first.myVoyageGlobal;
				endif;
			endif;
		else	// when editing Shift movement
			if persistentMove.myVoyageGlobal &lt;&gt; null then	
				self.myVoyageGlobal := persistentMove.myVoyageGlobal;	
			endif;
		endif;
	endif;
	
 	// Update set of allResourceUsed
 	create permResourceStillUsed transient;
 	foreach	workResourceUsed in _fromMovement .allWorkingResUsed do
 		if workResourceUsed.myResourceType = null then
 			// can't be null
 			continue;
 		endif;
 		// Check to see if a permanent resource used object exists for this
 		// working resourceUsed object.
 		permResourceUsed := workResourceUsed.myPersistentResourceUsed;
 		if permResourceUsed = null then
 			// Create new permanent resource used object
 			create newPermResourceUsed;
			newPermResourceUsed.setFromWorkingResourceUsed(workResourceUsed, self, TRANS_TYPE_ResourceBooked, _passport);
			// Add resource to perm coll still used
			permResourceStillUsed.add(newPermResourceUsed);
			// Create 'Resource Booking' Tranaction			
  		else
  			// Add resource to perm coll still used
  			permResourceUsed.setFromWorkingResourceUsed(workResourceUsed, self, null, _passport);
  			permResourceStillUsed.add(permResourceUsed);	
  		endif;
  	endforeach;

  	// Archive permResourcesUsed that are no longer in the allWorkingResUsed collection
  	create permResourceToDeleteSet transient;
  	foreach permResourceUsed in self.allResourceUsed do
  		// Check to see if resource is still used
  		if (not permResourceStillUsed.includes(permResourceUsed)) then //workResourceUsed=null then
  			// Add permResourceUsed to temporary permResourceToDeleteSet for Archive 
  			permResourceToDeleteSet.add(permResourceUsed);
  		endif;
  	endforeach;

  	// Archive all permResourceUsed objs marked for deletion
  	foreach permResourceUsed in permResourceToDeleteSet do
  		permResourceUsed.cancelBooking(self, _passport);
  	endforeach;

	if self.moveType = HMSMovementTypeArrival then
		if self.myHMSVoyageData.getMyBerth &lt;&gt; self.getMyBerth() then
			self.myHMSVoyageData.setMyBerth(self.getMyBerth);
		endif;
	endif;  	
	
	// PAR #34209 Check whether we need to change the voyage's orientation
	if self.moveType.isOneOf(HMSMovementTypeArrival, HMSMovementTypeShift) and not self.getMyBerth.isLogicalBerth then 
		if self.myHMSVoyageData.myVoyage.starboardBerthed and self.sideTo = OrientPortSideTo then
			self.myHMSVoyageData.myVoyage.setStarboardBerthed(false);
		elseif not self.myHMSVoyageData.myVoyage.starboardBerthed and self.sideTo = OrientStarboardSideTo then
			self.myHMSVoyageData.myVoyage.setStarboardBerthed(true);
		endif;
	endif;
	// PAR #34209 end
	
	if _fromMovement.myProxyMarineServicesTimings &lt;&gt; null then
		if self.myMarineServiceTimings &lt;&gt; null then
			marineTimings := self.myMarineServiceTimings;
		elseif self.myMarineServiceTimings = null then
			create marineTimings persistent;
		endif;
		marineTimings.setForUpdate( _fromMovement.myProxyMarineServicesTimings, app.myPassport );
		marineTimings.setMyVoyageMovement( self );
	endif;
	
	// TFS 43667 Check the Pilot Resource Used to see if we need to change the pilot on it.
	// Otherwise if a pilot has been changed after invoice generation, and the invoices are 
	// generated again, an extra Pilot resource will be created
	foreach permResourceUsed in self.allResourceUsed do
		if permResourceUsed.myHMSObject.isKindOf(HMS_Pilot) then
			if self.allMovementPilotDetails/*allPilots*/.isEmpty then // TFS 44438
				pilot := self.getUnConvertedMyPilotRef;
			else
				pilot := self.getFirstPilot(); //allPilots.first; // TFS 44438
			endif;
			if pilot &lt;&gt; null and permResourceUsed.myHMSObject &lt;&gt; pilot then
				permResourceUsed.setHMSObject(pilot);
			endif;
			break;
		endif;
	endforeach;
	// TFS 43667 end
	
	// Cannot do this here as it relies on all movements in dict being in the correct
	// order.  We may not have updated later movements so they will be out of order
	// and set the myNextMovement / myPrevMovement incorrectly
	//	self.maintainLinkedList();


epilog
	delete permResourceToDeleteSet; 	
	delete permResourceStillUsed;
	delete permMmvntPilotDtlsToDelSet; // TFS 44438
end;</source>
        <Parameter name="_fromMovement" type="CMIF_HMS_WorkingMovement" usage="input"/>
        <Parameter name="_nextTransientMovement" type="CMIF_HMS_WorkingMovement" usage="input"/>
        <Parameter name="_workingVoyage" type="CMIF_HMS_WorkingVoyage"/>
        <Parameter name="_transType" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createPropertyChanges" id="df62908c-bacc-4575-8119-0614ca7e5489">
        <source>createPropertyChanges(_transaction : HMS_Transaction; _fromMovement : CMIF_HMS_WorkingMovement input);
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 27/02/2019	jlgdap1		TFS 43667 PNL Two Pilots on Departure Resources Used
// 13 May 2019	jlgsl4		TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
vars
	oldStr,
	newStr:						String;
	propertyChange:				HMS_PropertyChange;
    moveForDetails:				HMS_VoyageMovement;
    tug:						HMS_Tug;
    tugsUsedHasChanged:			Boolean;
    addMode:					Boolean;
    orientationChanged:			Boolean;
    propertyChanged:			Boolean;
    positionHasChanged:			Boolean;
    timePilot:					Integer;
    timeTugs:					Integer;
    timeLines:					Integer;
    launchLocation:				Integer;
    tugsLocation:				Integer;
    defContact:					CM_EmailAddress2;
    defAgent:					CM_ShippingAgent;
    defShippingLine:			CM_ShippingLine;
    agentIsDefault:				Boolean;
	berth: 						HMS_Berth;
begin
	// NOTE: new values come from '_fromMovement', old values come from 'self' - these
	// transaction methods are called before the _fromMovement properties are copied
	// to self - therefore self is an image of the old data at this stage.

	// This method creates a transaction for all the changes that take place when the 
	// permanent movement is updated (ie either ADD or EDIT changes)
	// NOTE: A single transaction may cover changes to one or more properties

	if _fromMovement = null then
		return;
	endif;
	
 	// Get action type - ADD or EDIT for perm move updates
	if _transaction.type = TRANS_TYPE_AddMovement then
		// ADD mode 
		addMode:=true;
	elseif _transaction.type = TRANS_TYPE_EditMovement then
		// EDIT mode
		addMode:=false;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid transaction type (' &amp; _transaction.type.String &amp; ')');
		return;
	endif;
	
	inheritMethod(_transaction, _fromMovement);

	// Get initialise values in in Add mode
	if addMode then
		_fromMovement.init_MarineServOrderTimes(timePilot,timeTugs,timeLines);
		_fromMovement.init_MarineServOrderLocations(launchLocation,tugsLocation);
	endif;

	berth:=self.getMyBerth;
    // Check all properties for changes
    // ------------------------------------------------------------------------

	// ************************************************************************
	//								GENERAL
	// ************************************************************************

    // Check wharf position and orientation
    if bowMarkTo&lt;&gt;_fromMovement.bowMarkTo and berth = _fromMovement.myBerth then
    	// Property has changed, berth still the same		
    	if sideTo&lt;&gt;_fromMovement.sideTo and sternMarkTo=_fromMovement.bowMarkTo then
    		orientationChanged:=true;
    		if addMode then
    			if _fromMovement.init_Orientation&lt;&gt;_fromMovement.sideTo then
    				// Orientation only has changed
    				orientationChanged:=true;
    			else 
    				// Orientation is same as initialise value
    				orientationChanged:=false;
    			endif;
    		else
    			// Orientation only has changed
    			orientationChanged:=true;
    		endif; 
    		if orientationChanged=true then
	    		create propertyChange;
	    		if sideTo=OrientPortSideTo then
	 				oldStr := app.getErrorString(PortSideToBerth);
	 			else
	 				oldStr:=app.getErrorString(StarboardSideToBerth);
	 			endif;	
	 			if _fromMovement.sideTo=OrientPortSideTo then
	 				newStr := app.getErrorString(PortSideToBerth);
	 			else
	 				newStr:=app.getErrorString(StarboardSideToBerth);
	 			endif;	
	    		propertyChange.set(_transaction, "Ship Orientation", oldStr, newStr);
			endif;
    	elseif sideTo=_fromMovement.sideTo then
    		// Wharf position has changed; orientation still same
    		create propertyChange;
	    	// Old position
	    	if berth = null then
	    		oldStr:="No Berth Selected";
	    	else
		    	oldStr:="Berth '" &amp; berth.description &amp; "'";
		    	if self.isLogicalBerth() then
		    		// Logical wharf - exclude bow/stern positions
		    	else
		    		// Physical wharf - include bow/stern positions
		    		oldStr:=oldStr &amp; "; Bow " &amp; bowMarkTo.String &amp; " m";
		    		oldStr:=oldStr &amp; "; Stern " &amp; sternMarkTo.String &amp; " m.";
		    	endif;
		    endif;
	    	// New position
	    	if _fromMovement.myBerth=null then
	    		newStr:="No Berth Selected";
	    	else
		    	newStr:="Berth '" &amp; _fromMovement.myBerth.description &amp; "'";
		    	if _fromMovement.isLogicalBerth() then
		    		// Logical wharf - exclude bow/stern positions
		    	else
		    		// Physical wharf - include bow/stern positions
		    		newStr:=newStr &amp; "; Bow " &amp; _fromMovement.bowMarkTo.String &amp; " m";
		    		newStr:=newStr &amp; "; Stern " &amp; _fromMovement.sternMarkTo.String &amp; " m.";
		    	endif;
		    endif;
	    	propertyChange.set(_transaction, "Wharf position", oldStr, newStr);
    	else
    		// Wharf position and orientation have changed
    		// Orientation has changed
    		orientationChanged:=true;
    		if addMode then
    			if _fromMovement.init_Orientation&lt;&gt;_fromMovement.sideTo then
    				// Orientation only has changed
    				orientationChanged:=true;
    			else 
    				// Orientation is same as initialise value
    				orientationChanged:=false;
    			endif;
    		else
    			// Orientation only has changed
    			orientationChanged:=true;
    		endif; 
    		if orientationChanged=true then
	    		create propertyChange;
	    		if sideTo=OrientPortSideTo then
	 				oldStr:=app.getErrorString(PortSideTo);
	 			else
	 				oldStr:=app.getErrorString(StarboardSideTo);
	 			endif;	
	 			if _fromMovement.sideTo=OrientPortSideTo then
	 				newStr:=app.getErrorString(PortSideTo);
	 			else
	 				newStr:=app.getErrorString(StarboardSideTo);
	 			endif;	
	    		propertyChange.set(_transaction, "Ship Orientation", oldStr, newStr);
			endif;

			// Wharf position has changed
    		create propertyChange;
	    	// Old position
	    	if berth = null then
	    		oldStr:="No Berth Selected";
	    	else
		    	oldStr:="Berth '" &amp; berth.description &amp; "'";
		    	if self.isLogicalBerth() then
		    		// Logical wharf - exclude bow/stern positions
		    	else
		    		// Physical wharf - include bow/stern positions
		    		oldStr:=oldStr &amp; "; Bow " &amp; bowMarkTo.String &amp; " m";
		    		oldStr:=oldStr &amp; "; Stern " &amp; sternMarkTo.String &amp; " m.";
		    	endif;
		    endif;
	    	// New position
	    	if _fromMovement.myBerth=null then
	    		newStr:="No Berth Selected";
	    	else
		    	newStr:="Berth '" &amp; _fromMovement.myBerth.description &amp; "'";
		    	if _fromMovement.isLogicalBerth() then
		    		// Logical wharf - exclude bow/stern positions
		    	else
		    		// Physical wharf - include bow/stern positions
		    		newStr:=newStr &amp; "; Bow " &amp; _fromMovement.bowMarkTo.String &amp; " m";
		    		newStr:=newStr &amp; "; Stern " &amp; _fromMovement.sternMarkTo.String &amp; " m.";
		    	endif;
		    endif;
    		propertyChange.set(_transaction, "Wharf position", oldStr, newStr);
    	endif;
    else
    	// Berth may have changed or position is still the same.
    	// Check to see if wharf position and orientation have changed
    		// Orientation has changed?
    		orientationChanged:=true;
    		if addMode then
    			if _fromMovement.init_Orientation&lt;&gt;_fromMovement.sideTo then
    				// Orientation only has changed
    				orientationChanged:=true;
    			else 
    				// Orientation is same as initialise value
    				orientationChanged:=false;
    			endif;
    		else
    			// Orientation only has changed
    			if sideTo&lt;&gt;_fromMovement.sideTo then
    				orientationChanged:=true;
    			else
    				orientationChanged:=false;	
    			endif;
    		endif; 
    		if orientationChanged=true then
	    		create propertyChange;
	    		if sideTo=OrientPortSideTo then
	 				oldStr:=app.getErrorString(PortSideTo);
	 			else
	 				oldStr:=app.getErrorString(StarboardSideTo);
	 			endif;	
	 			if _fromMovement.sideTo=OrientPortSideTo then
	 				newStr:=app.getErrorString(PortSideTo);
	 			else
	 				newStr:=app.getErrorString(StarboardSideTo);
	 			endif;	
	    		propertyChange.set(_transaction, "Ship Orientation", oldStr, newStr);
			endif;

			// Wharf position has changed?
			if bowMarkTo=_fromMovement.bowMarkTo and berth=_fromMovement.myBerth then
				// Wharf position has not changed
				positionHasChanged:=false;
			else
				// Wharf position HAS changed
				positionHasChanged:=true;
			endif;
			if positionHasChanged=true then
				create propertyChange;
		    	// Old position
		    	if berth=null then
		    		oldStr:="No Berth Selected";
		    	else
			    	oldStr:="Berth '" &amp; berth.description &amp; "'";
			    	if self.isLogicalBerth() then
			    		// Logical wharf - exclude bow/stern positions
			    	else
			    		// Physical wharf - include bow/stern positions
			    		oldStr:=oldStr &amp; "; Bow " &amp; bowMarkTo.String &amp; " m";
			    		oldStr:=oldStr &amp; "; Stern " &amp; sternMarkTo.String &amp; " m.";
			    	endif;
			    endif;
		    	// New position
		    	if _fromMovement.myBerth=null then
		    		newStr:="No Berth Selected";
		    	else
			    	newStr:="Berth '" &amp; _fromMovement.myBerth.description &amp; "'";
			    	if _fromMovement.isLogicalBerth() then
			    		// Logical wharf - exclude bow/stern positions
			    	else
			    		// Physical wharf - include bow/stern positions
			    		newStr:=newStr &amp; "; Bow " &amp; _fromMovement.bowMarkTo.String &amp; " m";
			    		newStr:=newStr &amp; "; Stern " &amp; _fromMovement.sternMarkTo.String &amp; " m.";
			    	endif;
			    endif;
	    		propertyChange.set(_transaction, "Wharf position", oldStr, newStr);
			endif;
	endif;

	// ************************************************************************
	//								MARINE SERVICES
	// ************************************************************************

	// ***** PILOT AND PILOT LAUNCH *****	
	// Pilot exempt status
	if pilotExempt&lt;&gt;_fromMovement.pilotExempt then
		// Property has changed
		create propertyChange;
   		if pilotExempt=true then
			oldStr:="Exempt";
		else
			oldStr:="NOT Exempt";
		endif;	
		if _fromMovement.pilotExempt=true then
			newStr:="Exempt";
		else
			newStr:="NOT Exempt";
		endif;	
   		propertyChange.set(_transaction, "Pilot Exempt Status", oldStr, newStr);
	endif;

	// Master
	propertyChanged:=false;
	if addMode=true then
		if _fromMovement.init_Master&lt;&gt;_fromMovement.myMaster then
			// Property has changed
			propertyChanged:=true;
		else
			// Property same
			propertyChanged:=false;
		endif;
	elseif myMaster &lt;&gt;_fromMovement.myMaster then
		// Property has changed
		propertyChanged:=true;
	endif;
	
	// Pilot
	//31 Oct 2018	NDL	TFS 41662
	propertyChanged:=false;
	if addMode=true then
		if _fromMovement.getPilotsString() &lt;&gt; null then //not _fromMovement.allPilots.isEmpty then // TFS 44438
			// Property has changed
			propertyChanged:=true;
		else
			// Property same
			propertyChanged:=false;
		endif;
	elseif self.getPilotsString(true) &lt;&gt; _fromMovement.getPilotsString() then // TFS 44438
		// Property has changed
		propertyChanged:=true;
	endif;
	if propertyChanged=true then
		// Property has changed
		create propertyChange;
   		oldStr :=self.getPilotsString(true);
		if oldStr = null then
			oldStr:="Not Specified";
		endif;	
		newStr := _fromMovement.getPilotsString(); // TFS 44438
		if newStr = null then
			newStr:="Not Specified";
		endif;	
   		propertyChange.set(_transaction, "Pilot", oldStr, newStr);
	endif;

	// Pilot Launch
	propertyChanged:=false;
	if addMode=true then
		if _fromMovement.init_PilotLaunch &lt;&gt; _fromMovement.getFirstPilotLaunch() /*myPilotLaunch*/ then // TFS 44438 after 040 cut/release
			// Property has changed
			propertyChanged:=true;
		else
			// Property same
			propertyChanged:=false;
		endif;
	elseif self.getFirstPilotLaunch() &lt;&gt; _fromMovement.getFirstPilotLaunch() then //myPilotLaunch&lt;&gt;_fromMovement.myPilotLaunch then // TFS 44438 after 040 cut/release
		// Property has changed
		propertyChanged:=true;
	endif;
	if propertyChanged=true then
		// Property has changed
		create propertyChange;
   		if self.getFirstPilotLaunch()/*myPilotLaunch*/ &lt;&gt; null then // TFS 44438 after 040 cut/release
			oldStr := /*myPilotLaunch*/self.getFirstPilotLaunch().description; // TFS 44438 after 040 cut/release
		else
			oldStr:="Not Specified";
		endif;	
		if _fromMovement.getFirstPilotLaunch()/*myPilotLaunch*/ &lt;&gt; null then // TFS 44438 after 040 cut/release
			newStr := _fromMovement.getFirstPilotLaunch()/*myPilotLaunch*/.description; // TFS 44438 after 040 cut/release
		else
			newStr:="Not Specified";
		endif;	
   		propertyChange.set(_transaction, "Pilot Launch", oldStr, newStr);
	endif;

	// Ships Master
	if shipsMaster&lt;&gt;_fromMovement.shipsMaster then
		// Property has changed
		create propertyChange;
   		if shipsMaster&lt;&gt;null or shipsMaster&lt;&gt;"" then
			oldStr:=shipsMaster;
		else
			oldStr:="Not Specified";
		endif;	
		if _fromMovement.shipsMaster&lt;&gt;null or _fromMovement.shipsMaster&lt;&gt;"" then
			newStr:=_fromMovement.shipsMaster;
		else
			newStr:="Not Specified";
		endif;	
   		propertyChange.set(_transaction, "Ships Master", oldStr, newStr);
	endif;

	// Pilot Launch Relative Order Time
	propertyChanged:=false;
	if addMode=true then
		if timePilot&lt;&gt;_fromMovement.relativeOrderTimePlaunch then
			// Property has changed
			propertyChanged:=true;
		else
			// Property same
			propertyChanged:=false;
		endif;
	elseif relativeOrderTimePlaunch&lt;&gt;_fromMovement.relativeOrderTimePlaunch then
		// Property has changed
		propertyChanged:=true;
	endif;
	if propertyChanged=true then
		create propertyChange;
   		if relativeOrderTimePlaunch&gt;=0 then
			oldStr:="+" &amp; relativeOrderTimePlaunch.String &amp; " (mins)";
		else
			oldStr:=relativeOrderTimePlaunch.String &amp; " (mins)";
		endif;	
		if _fromMovement.relativeOrderTimePlaunch&gt;=0 then
			newStr:="+" &amp; _fromMovement.relativeOrderTimePlaunch.String &amp; " (mins)";
		else
			newStr:=_fromMovement.relativeOrderTimePlaunch.String &amp; " (mins)";
		endif;	
   		propertyChange.set(_transaction, "Pilot Launch (Relative Order Time)", oldStr, newStr);
	endif;

	// Pilot Launch Order Location
	propertyChanged:=false;
	if addMode=true then
		if launchLocation&lt;&gt;_fromMovement.locationPilotLaunch then
			// Property has changed
			propertyChanged:=true;
		else
			// Property same
			propertyChanged:=false;
		endif;
	elseif locationPilotLaunch&lt;&gt;_fromMovement.locationPilotLaunch then
		// Property has changed
		propertyChanged:=true;
	endif;
	if propertyChanged=true then
		// Property has changed
		create propertyChange;
   		if locationPilotLaunch=AlongSide then
			oldStr:=app.getErrorString(LocationAS);
		else
			oldStr:=app.getErrorString(On_Station);
		endif;	
		if _fromMovement.locationPilotLaunch=AlongSide then
			newStr:=app.getErrorString(LocationAS);
		else
			newStr:=app.getErrorString(On_Station);
		endif;	
   		propertyChange.set(_transaction, "Pilot Launch Location", oldStr, newStr);
	endif;

	// ***** TUGS *****	
	// Tugs Used
	tugsUsedHasChanged:=false;
	if allTugsUsed.size&lt;&gt;_fromMovement.allTugsUsed.size then
		// Tugs added or removed - ie Tug assignment has changed
		tugsUsedHasChanged:=true;
	else
		// Number of tugs used is same - directly compare members of each collection
		foreach tug in allTugsUsed do
			if _fromMovement.allTugsUsed.includes(tug)=false then
				tugsUsedHasChanged:=true;
			endif;
		endforeach;
		foreach tug in _fromMovement.allTugsUsed do
			if allTugsUsed.includes(tug)=false then
				tugsUsedHasChanged:=true;
			endif;
		endforeach;
	endif;
	if tugsUsedHasChanged=true then
		oldStr := null;									// TFS 43667
		newStr := null;									// TFS 43667
		// Tug assignments have changed
		// Property has changed
		create propertyChange;
   		if allTugsUsed.size&gt;0 then
	   		foreach tug in allTugsUsed do
	   			oldStr:=oldStr &amp; tug.description &amp; "; ";
			endforeach;
			// Trim last "; "
			oldStr:=oldStr[1:(oldStr.length-2)];
		else
			oldStr:="None Selected";
		endif;

		if _fromMovement.allTugsUsed.size&gt;0 then
	   		foreach tug in _fromMovement.allTugsUsed do
	   			newStr:=newStr &amp; tug.description &amp; "; ";
			endforeach;
			// Trim last "; "
			newStr:=newStr[1:(newStr.length-2)];
		else
			newStr:="None Selected";
		endif;
   		propertyChange.set(_transaction, "Tugs Used", oldStr, newStr);		
	endif;

	// Tugs Relative Order Time
	propertyChanged:=false;
	if addMode=true then
		if timeTugs&lt;&gt;_fromMovement.relativeOrderTimeTugs then
			// Property has changed
			propertyChanged:=true;
		else
			// Property same
			propertyChanged:=false;
		endif;
	elseif relativeOrderTimeTugs&lt;&gt;_fromMovement.relativeOrderTimeTugs then
		// Property has changed
		propertyChanged:=true;
	endif;
	if propertyChanged=true then
		// Property has changed
		create propertyChange;
   		if relativeOrderTimeTugs&gt;=0 then
			oldStr:="+" &amp; relativeOrderTimeTugs.String &amp; " (mins)";
		else
			oldStr:=relativeOrderTimeTugs.String &amp; " (mins)";
		endif;	
		if _fromMovement.relativeOrderTimeTugs&gt;=0 then
			newStr:="+" &amp; _fromMovement.relativeOrderTimeTugs.String &amp; " (mins)";
		else
			newStr:=_fromMovement.relativeOrderTimeTugs.String &amp; " (mins)";
		endif;	
   		propertyChange.set(_transaction, "Tugs Launch (Relative Order Time)", oldStr, newStr);		
	endif;	

	// Tugs Order Location
	propertyChanged:=false;
	if addMode=true then
		if tugsLocation&lt;&gt;_fromMovement.locationTug then
			// Property has changed
			propertyChanged:=true;
		else
			// Property same
			propertyChanged:=false;
		endif;
	elseif locationTug&lt;&gt;_fromMovement.locationTug then
		// Property has changed
		propertyChanged:=true;
	endif;
	if propertyChanged=true then
		// Property has changed
		create propertyChange;
   		if locationTug=AlongSide then
			oldStr:=app.getErrorString(LocationAS);
		else
			oldStr:=app.getErrorString(On_Station);
		endif;	
		if _fromMovement.locationTug=AlongSide then
			newStr:=app.getErrorString(LocationAS);
		else
			newStr:=app.getErrorString(On_Station);
		endif;	
   		propertyChange.set(_transaction, "Tug/s Location", oldStr, newStr);		
	endif;	

	// ***** LINESMEN *****	
	// Lines Company
	propertyChanged:=false;
	if addMode=true then
		if _fromMovement.init_LineCompany&lt;&gt;_fromMovement.myLineCompany then
			// Property has changed
			propertyChanged:=true;
		else
			// Property same
			propertyChanged:=false;
		endif;
	elseif myLineCompany&lt;&gt;_fromMovement.myLineCompany then
		// Property has changed
		propertyChanged:=true;
	endif;
	if propertyChanged=true then
		// Property has changed
		create propertyChange;
   		if myLineCompany&lt;&gt;null then
			oldStr:=myLineCompany.description;
		else
			oldStr:="Not Specified";
		endif;	
		if _fromMovement.myLineCompany&lt;&gt;null then
			newStr:=_fromMovement.myLineCompany.description;
		else
			newStr:="Not Specified";
		endif;	
   		propertyChange.set(_transaction, "Line Company", oldStr, newStr);		
	endif;

	// Number of Lines Crew
	propertyChanged:=false;
	if addMode=true then
		if _fromMovement.init_NumLinesCrewReqd&lt;&gt;_fromMovement.numLineCrewRequired then
			// Property has changed
			propertyChanged:=true;
		else
			// Property same
			propertyChanged:=false;
		endif;
	elseif numLineCrewRequired&lt;&gt;_fromMovement.numLineCrewRequired then
		// Property has changed
		propertyChanged:=true;
	endif;
	if propertyChanged=true then
		// Property has changed
		create propertyChange;
   		oldStr:=numLineCrewRequired.String &amp; " crew";
   		newStr:=_fromMovement.numLineCrewRequired.String &amp; " crew";
   		propertyChange.set(_transaction, "No. Lines Crew Required", oldStr, newStr);
	endif;

	// Lines Relative Order Time
	propertyChanged:=false;
	if addMode=true then
		if timeLines&lt;&gt;_fromMovement.relativeOrderTimeLines then
			// Property has changed
			propertyChanged:=true;
		else
			// Property same
			propertyChanged:=false;
		endif;
	elseif relativeOrderTimeLines&lt;&gt;_fromMovement.relativeOrderTimeLines then
		// Property has changed
		propertyChanged:=true;
	endif;
	if propertyChanged=true then
		// Property has changed
		create propertyChange;
   		if relativeOrderTimeLines&gt;=0 then
			oldStr:="+" &amp; relativeOrderTimeLines.String &amp; " (mins)";
		else
			oldStr:=relativeOrderTimeLines.String &amp; " (mins)";
		endif;	
		if _fromMovement.relativeOrderTimeLines&gt;=0 then
			newStr:="+" &amp; _fromMovement.relativeOrderTimeLines.String &amp; " (mins)";
		else
			newStr:=_fromMovement.relativeOrderTimeLines.String &amp; " (mins)";
		endif;	
   		propertyChange.set(_transaction, "Lines (Relative Order Time)", oldStr, newStr);
	endif;	

	// ************************************************************************
	//								TIDAL INFORMATION
	// ************************************************************************

	/*  now done in inheritMethod(..)
	
	// Move Tidal Class
	propertyChanged:=false;
	if addMode=true then
		if _fromMovement.init_MoveTidalClass&lt;&gt;_fromMovement.myMoveTidalClass then
			// Property has changed
			propertyChanged:=true;
		else
			// Property same
			propertyChanged:=false;
		endif;
	elseif myTidalClass&lt;&gt;_fromMovement.myMoveTidalClass then
		// Property has changed
		propertyChanged:=true;
	endif;
	if propertyChanged=true then
		// Property has changed
		create propertyChange;
   		if myTidalClass&lt;&gt;null then
			oldStr:=myTidalClass.description;
		else
			oldStr:="Not Specified";
		endif;	
		if _fromMovement.myMoveTidalClass&lt;&gt;null then
			newStr:=_fromMovement.myMoveTidalClass.description;
		else
			newStr:="Not Specified";
		endif;	
   		propertyChange.set(_transaction, "Movement Tidal Class", oldStr, newStr);
	endif;
	*/

	// ************************************************************************
	//								CUSTOMER
	// ************************************************************************

	// Movement Chargable Status
	if chargeForMove&lt;&gt;_fromMovement.chargeForMove then
		// Property has changed
		create propertyChange;
   		if chargeForMove=true then
			oldStr:="Charge";
		else
			oldStr:="Don't Charge";
		endif;	
		if _fromMovement.chargeForMove=true then
			newStr:="Charge";
		else
			newStr:="Don't Charge";
		endif;	
   		propertyChange.set(_transaction, "Movement Chargable Status", oldStr, newStr);
	endif;

	// Customer for movement
	propertyChanged := false;
	if addMode=true then
		self.init_CustomerForMove(defAgent, defShippingLine, agentIsDefault, defContact);
		if defAgent &lt;&gt; _fromMovement.myShippingAgent then
			// Property has changed
			propertyChanged := true;
		endif;
		if defShippingLine &lt;&gt; _fromMovement.myShippingLine then
			// Property has changed
			propertyChanged := true;
		endif;
	else
		if self.myShippingAgent &lt;&gt;_fromMovement.myShippingAgent then
			// Property has changed
			propertyChanged:=true;
		endif;
		if self.myShippingLine &lt;&gt; _fromMovement.myShippingLine then
			// Property has changed
			propertyChanged:=true;
		endif;
	endif;
	if propertyChanged = true then
		// Property has changed
		create propertyChange;
   		if isAgentDefault then
   			if self.myShippingAgent &lt;&gt; null then
				oldStr:=myShippingAgent.description &amp; " (Shipping Agent)";
			else
				oldStr:="None Selected";
			endif;	
		else
			if self.myShippingLine &lt;&gt; null then
				newStr := self.myShippingLine.description &amp; " (Shipping Line)";
			else
				newStr := "None Selected";
			endif;		
		endif;
   		propertyChange.set(_transaction, "Customer for movement", oldStr, newStr);
	endif;

	// Main Contact
	propertyChanged := false;
	if addMode = true then
		if defContact &lt;&gt; _fromMovement.myContact then
			// Property has changed
			propertyChanged:=true;
		else
			// Property same
			propertyChanged:=false;
		endif;
	elseif self.myContact &lt;&gt; _fromMovement.myContact then
		// Property has changed
		propertyChanged:=true;
	endif;
	if propertyChanged = true then
		// Property has changed
		create propertyChange;
   		if self.myContact &lt;&gt; null then
			oldStr := self.myContact.name;
		else
			oldStr := "None Selected";
		endif;	
		if _fromMovement.myContact &lt;&gt; null then
			newStr := _fromMovement.myContact.name;
		else
			newStr := "None Selected";
		endif;	
   		propertyChange.set(_transaction, "Customer contact", oldStr, newStr);
	endif;

end;</source>
        <Parameter name="_transaction" type="HMS_Transaction"/>
        <Parameter name="_fromMovement" type="CMIF_HMS_WorkingMovement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createPropertyChangesFromProxy" id="15b4b924-50b1-4831-8f18-cafbf39423d3">
        <source>createPropertyChangesFromProxy(_transaction : HMS_Transaction; _pxyMovement : HMS_VoyageMovement input);
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
// 23 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
vars
	oldStr,
	newStr:						String;
	propertyChange:				HMS_PropertyChange;
    tug:						HMS_Tug;
    tugsUsedHasChanged:			Boolean;
    addMode:					Boolean;
    orientationChanged:			Boolean;
    propertyChanged:			Boolean;
    positionHasChanged:			Boolean;
    timePilot:					Integer;
    timeTugs:					Integer;
    timeLines:					Integer;
    launchLocation:				Integer;
    tugsLocation:				Integer;
    agentIsDefault:				Boolean;

begin
	// NOTE: new values come from '_pxyMovement', old values come from 'self' - these
	// transaction methods are called before the _pxyMovement properties are copied
	// to self - therefore self is an image of the old data at this stage.

	// This method creates a transaction for all the changes that take place when the 
	// permanent movement is updated (ie either ADD or EDIT changes)
	// NOTE: A single transaction may cover changes to one or more properties

	if _pxyMovement = null then
		return;
	endif;
	
 	// Get action type - ADD or EDIT for perm move updates
	if _transaction.type = TRANS_TYPE_AddMovement then
		// ADD mode 
		addMode := true;
	elseif _transaction.type = TRANS_TYPE_EditMovement then
		// EDIT mode
		addMode := false;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid transaction type (' &amp; _transaction.type.String &amp; ')');
		return;
	endif;
	
	inheritMethod(_transaction, _pxyMovement);
	
	if _pxyMovement.moveStatusNEW &lt;&gt; self.moveStatusNEW then
		create propertyChange;
   		propertyChange.set(_transaction, "Move Status", app.movementStatusNumToString(self.moveStatusNEW), app.movementStatusNumToString(_pxyMovement.moveStatusNEW));			
		//Note: move status have own trans class see self.createTrans_AdjustMoveTime(); why? I don't know
	endif;

	// ************************************************************************
	//								GENERAL
	// ************************************************************************

    // Check wharf position and orientation
    if bowMarkTo &lt;&gt; _pxyMovement.bowMarkTo and getMyBerth() = _pxyMovement.getMyBerth() then
    	// Property has changed, berth still the same		
    	if sideTo &lt;&gt; _pxyMovement.sideTo and sternMarkTo = _pxyMovement.bowMarkTo then
    		orientationChanged := true;
    		if addMode then
    			if _pxyMovement.init_Orientation &lt;&gt; _pxyMovement.sideTo then
    				// Orientation only has changed
    				orientationChanged := true;
    			else 
    				// Orientation is same as initialise value
    				orientationChanged := false;
    			endif;
    		else
    			// Orientation only has changed
    			orientationChanged := true;
    		endif; 
    		if orientationChanged = true then
	    		create propertyChange;
	    		if sideTo = OrientPortSideTo then
	 				oldStr := app.getErrorString(PortSideToBerth);
	 			else
	 				oldStr := app.getErrorString(StarboardSideToBerth);
	 			endif;	
	 			if _pxyMovement.sideTo = OrientPortSideTo then
	 				newStr := app.getErrorString(PortSideToBerth);
	 			else
	 				newStr := app.getErrorString(StarboardSideToBerth);
	 			endif;	
	    		propertyChange.set(_transaction, "Ship Orientation", oldStr, newStr);
			endif;
    	elseif sideTo = _pxyMovement.sideTo then
    		// Wharf position has changed; orientation still same
    		create propertyChange;
	    	// Old position
	    	if getMyBerth() = null then
	    		oldStr := "No Berth Selected";
	    	else
		    	oldStr := "Berth '" &amp; self.getMyBerth().description &amp; "'";
		    	if self.isLogicalBerth() then
		    		// Logical wharf - exclude bow/stern positions
		    	else
		    		// Physical wharf - include bow/stern positions
		    		oldStr := oldStr &amp; "; Bow " &amp; bowMarkTo.String &amp; " m";
		    		oldStr := oldStr &amp; "; Stern " &amp; sternMarkTo.String &amp; " m.";
		    	endif;
		    endif;
	    	// New position
	    	if _pxyMovement.getMyBerth() = null then
	    		newStr := "No Berth Selected";
	    	else
		    	newStr := "Berth '" &amp; _pxyMovement.getMyBerth().description &amp; "'";
		    	if _pxyMovement.isLogicalBerth() then
		    		// Logical wharf - exclude bow/stern positions
		    	else
		    		// Physical wharf - include bow/stern positions
		    		newStr := newStr &amp; "; Bow " &amp; _pxyMovement.bowMarkTo.String &amp; " m";
		    		newStr := newStr &amp; "; Stern " &amp; _pxyMovement.sternMarkTo.String &amp; " m.";
		    	endif;
		    endif;
	    	propertyChange.set(_transaction, "Wharf position", oldStr, newStr);
    	else
    		// Wharf position and orientation have changed
    		// Orientation has changed
    		orientationChanged := true;
    		if addMode then
    			if _pxyMovement.init_Orientation &lt;&gt; _pxyMovement.sideTo then
    				// Orientation only has changed
    				orientationChanged := true;
    			else 
    				// Orientation is same as initialise value
    				orientationChanged := false;
    			endif;
    		else
    			// Orientation only has changed
    			orientationChanged := true;
    		endif; 
    		if orientationChanged = true then
	    		create propertyChange;
	    		if sideTo = OrientPortSideTo then
	 				oldStr := app.getErrorString(PortSideTo);
	 			else
	 				oldStr := app.getErrorString(StarboardSideTo);
	 			endif;	
	 			if _pxyMovement.sideTo = OrientPortSideTo then
	 				newStr := app.getErrorString(PortSideTo);
	 			else
	 				newStr := app.getErrorString(StarboardSideTo);
	 			endif;	
	    		propertyChange.set(_transaction, "Ship Orientation", oldStr, newStr);
			endif;

			// Wharf position has changed
    		create propertyChange;
	    	// Old position
	    	if self.getMyBerth() = null then
	    		oldStr := "No Berth Selected";
	    	else
		    	oldStr := "Berth '" &amp; getMyBerth().description &amp; "'";
		    	if self.isLogicalBerth() then
		    		// Logical wharf - exclude bow/stern positions
		    	else
		    		// Physical wharf - include bow/stern positions
		    		oldStr := oldStr &amp; "; Bow " &amp; bowMarkTo.String &amp; " m";
		    		oldStr := oldStr &amp; "; Stern " &amp; sternMarkTo.String &amp; " m.";
		    	endif;
		    endif;
	    	// New position
	    	if _pxyMovement.getMyBerth() = null then
	    		newStr := "No Berth Selected";
	    	else
		    	newStr := "Berth '" &amp; _pxyMovement.getMyBerth().description &amp; "'";
		    	if _pxyMovement.isLogicalBerth() then
		    		// Logical wharf - exclude bow/stern positions
		    	else
		    		// Physical wharf - include bow/stern positions
		    		newStr := newStr &amp; "; Bow " &amp; _pxyMovement.bowMarkTo.String &amp; " m";
		    		newStr := newStr &amp; "; Stern " &amp; _pxyMovement.sternMarkTo.String &amp; " m.";
		    	endif;
		    endif;
    		propertyChange.set(_transaction, "Wharf position", oldStr, newStr);
    	endif;
    else
    	// Berth may have changed or position is still the same.
    	// Check to see if wharf position and orientation have changed
   		// Orientation has changed?
   		orientationChanged := true;
   		if addMode then
   			if _pxyMovement.init_Orientation &lt;&gt; _pxyMovement.sideTo then
   				// Orientation only has changed
   				orientationChanged := true;
   			else 
   				// Orientation is same as initialise value
   				orientationChanged := false;
   			endif;
   		else
   			// Orientation only has changed
   			if sideTo &lt;&gt; _pxyMovement.sideTo then
   				orientationChanged := true;
   			else
   				orientationChanged := false;	
   			endif;
   		endif; 
   		if orientationChanged = true then
    		create propertyChange;
    		if sideTo = OrientPortSideTo then
 				oldStr := app.getErrorString(PortSideTo);
 			else
 				oldStr := app.getErrorString(StarboardSideTo);
 			endif;	
 			if _pxyMovement.sideTo = OrientPortSideTo then
 				newStr := app.getErrorString(PortSideTo);
 			else
 				newStr := app.getErrorString(StarboardSideTo);
 			endif;	
    		propertyChange.set(_transaction, "Ship Orientation", oldStr, newStr);
		endif;

		// Wharf position has changed?
		if bowMarkTo = _pxyMovement.bowMarkTo and self.getMyBerth() = _pxyMovement.getMyBerth() then
			// Wharf position has not changed
			positionHasChanged := false;
		else
			// Wharf position HAS changed
			positionHasChanged := true;
		endif;
		if positionHasChanged = true then
			create propertyChange;
	    	// Old position
	    	if getMyBerth() = null then
	    		oldStr := "No Berth Selected";
	    	else
		    	oldStr := "Berth '" &amp; self.getMyBerth().description &amp; "'";
		    	if self.isLogicalBerth() then
		    		// Logical wharf - exclude bow/stern positions
		    	else
		    		// Physical wharf - include bow/stern positions
		    		oldStr := oldStr &amp; "; Bow " &amp; bowMarkTo.String &amp; " m";
		    		oldStr := oldStr &amp; "; Stern " &amp; sternMarkTo.String &amp; " m.";
		    	endif;
		    endif;
	    	// New position
	    	if _pxyMovement.getMyBerth() = null then
	    		newStr := "No Berth Selected";
	    	else
		    	newStr := "Berth '" &amp; _pxyMovement.getMyBerth().description &amp; "'";
		    	if _pxyMovement.isLogicalBerth() then
		    		// Logical wharf - exclude bow/stern positions
		    	else
		    		// Physical wharf - include bow/stern positions
		    		newStr := newStr &amp; "; Bow " &amp; _pxyMovement.bowMarkTo.String &amp; " m";
		    		newStr := newStr &amp; "; Stern " &amp; _pxyMovement.sternMarkTo.String &amp; " m.";
		    	endif;
		    endif;
    		propertyChange.set(_transaction, "Wharf position", oldStr, newStr);
		endif;
	endif;

	// ************************************************************************
	//								MARINE SERVICES
	// ************************************************************************

	// ***** PILOT AND PILOT LAUNCH *****	
	// Pilot exempt status
	if pilotExempt &lt;&gt; _pxyMovement.pilotExempt then
		// Property has changed
		create propertyChange;
   		if pilotExempt = true then
			oldStr := "Exempt";
		else
			oldStr := "NOT Exempt";
		endif;	
		if _pxyMovement.pilotExempt then
			newStr := "Exempt";
		else
			newStr := "NOT Exempt";
		endif;	
   		propertyChange.set(_transaction, "Pilot Exempt Status", oldStr, newStr);
	endif;

	// Pilot
	//31 Oct 2018	NDL	TFS 41662
	propertyChanged := false;
	if addMode = true then
		if not _pxyMovement.allMovementPilotDetails.isEmpty then//allPilots.isEmpty then // TFS 44438
			// Property has changed
			propertyChanged:=true;
		else
			// Property same
			propertyChanged:=false;
		endif;
	elseif self.getPilotsString(true) &lt;&gt;_pxyMovement.getPilotsString(true) then
		// Property has changed
		propertyChanged:=true;
	endif;
	if propertyChanged=true then
		// Property has changed
		create propertyChange;
		oldStr := self.getPilotsString(true);
   		if oldStr = null then
			oldStr:="Not Specified";
		endif;	
		newStr := _pxyMovement.getPilotsString(true);
		if newStr = null then
			newStr:="Not Specified";
		endif;	
   		propertyChange.set(_transaction, "Pilot", oldStr, newStr);
	endif;

	// Pilot Launch
	propertyChanged:=false;
	if addMode=true then
		if _pxyMovement.init_PilotLaunch&lt;&gt;_pxyMovement.getFirstPilotLaunch() /*myPilotLaunch*/ then // TFS 44438 after 040 cut/release
			// Property has changed
			propertyChanged:=true;
		else
			// Property same
			propertyChanged:=false;
		endif;
	elseif self.getFirstPilotLaunch() &lt;&gt; _pxyMovement.getFirstPilotLaunch() then //myPilotLaunch&lt;&gt;_pxyMovement.myPilotLaunch then // TFS 44438 after 040 cut/release
		// Property has changed
		propertyChanged:=true;
	endif;
	if propertyChanged=true then
		// Property has changed
		create propertyChange;
   		if self.getFirstPilotLaunch()/*myPilotLaunch*/ &lt;&gt; null then // TFS 44438 after 040 cut/release
			oldStr := /*myPilotLaunch*/self.getFirstPilotLaunch().description; // TFS 44438 after 040 cut/release
		else
			oldStr:="Not Specified";
		endif;	
		if _pxyMovement.getFirstPilotLaunch()/*myPilotLaunch*/ &lt;&gt; null then // TFS 44438 after 040 cut/release
			newStr:=_pxyMovement.getFirstPilotLaunch()/*myPilotLaunch*/.description; // TFS 44438 after 040 cut/release
		else
			newStr:="Not Specified";
		endif;	
   		propertyChange.set(_transaction, "Pilot Launch", oldStr, newStr);
	endif;

	// Ships Master
	if shipsMaster&lt;&gt;_pxyMovement.shipsMaster then
		// Property has changed
		create propertyChange;
   		if shipsMaster&lt;&gt;null or shipsMaster&lt;&gt;"" then
			oldStr:=shipsMaster;
		else
			oldStr:="Not Specified";
		endif;	
		if _pxyMovement.shipsMaster&lt;&gt;null or _pxyMovement.shipsMaster&lt;&gt;"" then
			newStr:=_pxyMovement.shipsMaster;
		else
			newStr:="Not Specified";
		endif;	
   		propertyChange.set(_transaction, "Ships Master", oldStr, newStr);
	endif;

	// Pilot Launch Relative Order Time
	propertyChanged:=false;
	if addMode=true then
		if timePilot&lt;&gt;_pxyMovement.relativeOrderTimePlaunch then
			// Property has changed
			propertyChanged:=true;
		else
			// Property same
			propertyChanged:=false;
		endif;
	elseif relativeOrderTimePlaunch&lt;&gt;_pxyMovement.relativeOrderTimePlaunch then
		// Property has changed
		propertyChanged:=true;
	endif;
	if propertyChanged=true then
		create propertyChange;
   		if relativeOrderTimePlaunch&gt;=0 then
			oldStr:="+" &amp; relativeOrderTimePlaunch.String &amp; " (mins)";
		else
			oldStr:=relativeOrderTimePlaunch.String &amp; " (mins)";
		endif;	
		if _pxyMovement.relativeOrderTimePlaunch&gt;=0 then
			newStr:="+" &amp; _pxyMovement.relativeOrderTimePlaunch.String &amp; " (mins)";
		else
			newStr:=_pxyMovement.relativeOrderTimePlaunch.String &amp; " (mins)";
		endif;	
   		propertyChange.set(_transaction, "Pilot Launch (Relative Order Time)", oldStr, newStr);
	endif;

	// Pilot Launch Order Location
	propertyChanged:=false;
	if addMode=true then
		if launchLocation&lt;&gt;_pxyMovement.locationPilotLaunch then
			// Property has changed
			propertyChanged:=true;
		else
			// Property same
			propertyChanged:=false;
		endif;
	elseif locationPilotLaunch&lt;&gt;_pxyMovement.locationPilotLaunch then
		// Property has changed
		propertyChanged:=true;
	endif;
	if propertyChanged=true then
		// Property has changed
		create propertyChange;
   		if locationPilotLaunch=AlongSide then
			oldStr:=app.getErrorString(LocationAS);
		else
			oldStr:=app.getErrorString(On_Station);
		endif;	
		if _pxyMovement.locationPilotLaunch=AlongSide then
			newStr:=app.getErrorString(LocationAS);
		else
			newStr:=app.getErrorString(On_Station);
		endif;	
   		propertyChange.set(_transaction, "Pilot Launch Location", oldStr, newStr);
	endif;

	// ***** TUGS *****	
	// Tugs Used
	tugsUsedHasChanged:=false;
	if allTugsUsed.size&lt;&gt;_pxyMovement.allTugsUsed.size then
		// Tugs added or removed - ie Tug assignment has changed
		tugsUsedHasChanged:=true;
	else
		// Number of tugs used is same - directly compare members of each collection
		foreach tug in allTugsUsed do
			if _pxyMovement.allTugsUsed.includes(tug)=false then
				tugsUsedHasChanged:=true;
			endif;
		endforeach;
		foreach tug in _pxyMovement.allTugsUsed do
			if allTugsUsed.includes(tug)=false then
				tugsUsedHasChanged:=true;
			endif;
		endforeach;
	endif;
	if tugsUsedHasChanged=true then
		// Tug assignments have changed
		// Property has changed
		create propertyChange;
   		if allTugsUsed.size&gt;0 then
	   		foreach tug in allTugsUsed do
	   			oldStr:=oldStr &amp; tug.description &amp; "; ";
			endforeach;
			// Trim last "; "
			oldStr:=oldStr[1:(oldStr.length-2)];
		else
			oldStr:="None Selected";
		endif;

		if _pxyMovement.allTugsUsed.size&gt;0 then
	   		foreach tug in _pxyMovement.allTugsUsed do
	   			newStr:=newStr &amp; tug.description &amp; "; ";
			endforeach;
			// Trim last "; "
			newStr:=newStr[1:(newStr.length-2)];
		else
			newStr:="None Selected";
		endif;
   		propertyChange.set(_transaction, "Tugs Used", oldStr, newStr);		
	endif;

	// Tugs Relative Order Time
	propertyChanged:=false;
	if addMode=true then
		if timeTugs&lt;&gt;_pxyMovement.relativeOrderTimeTugs then
			// Property has changed
			propertyChanged:=true;
		else
			// Property same
			propertyChanged:=false;
		endif;
	elseif relativeOrderTimeTugs&lt;&gt;_pxyMovement.relativeOrderTimeTugs then
		// Property has changed
		propertyChanged:=true;
	endif;
	if propertyChanged=true then
		// Property has changed
		create propertyChange;
   		if relativeOrderTimeTugs&gt;=0 then
			oldStr:="+" &amp; relativeOrderTimeTugs.String &amp; " (mins)";
		else
			oldStr:=relativeOrderTimeTugs.String &amp; " (mins)";
		endif;	
		if _pxyMovement.relativeOrderTimeTugs&gt;=0 then
			newStr:="+" &amp; _pxyMovement.relativeOrderTimeTugs.String &amp; " (mins)";
		else
			newStr:=_pxyMovement.relativeOrderTimeTugs.String &amp; " (mins)";
		endif;	
   		propertyChange.set(_transaction, "Tugs Launch (Relative Order Time)", oldStr, newStr);		
	endif;	

	// Tugs Order Location
	propertyChanged:=false;
	if addMode=true then
		if tugsLocation&lt;&gt;_pxyMovement.locationTug then
			// Property has changed
			propertyChanged:=true;
		else
			// Property same
			propertyChanged:=false;
		endif;
	elseif locationTug&lt;&gt;_pxyMovement.locationTug then
		// Property has changed
		propertyChanged:=true;
	endif;
	if propertyChanged=true then
		// Property has changed
		create propertyChange;
   		if locationTug=AlongSide then
			oldStr:=app.getErrorString(LocationAS);
		else
			oldStr:=app.getErrorString(On_Station);
		endif;	
		if _pxyMovement.locationTug=AlongSide then
			newStr:=app.getErrorString(LocationAS);
		else
			newStr:=app.getErrorString(On_Station);
		endif;	
   		propertyChange.set(_transaction, "Tug/s Location", oldStr, newStr);		
	endif;	

	// ***** LINESMEN *****	
	// Lines Company
	propertyChanged:=false;
	if addMode=true then
		if _pxyMovement.init_LineCompany&lt;&gt;_pxyMovement.myLineCompany then
			// Property has changed
			propertyChanged:=true;
		else
			// Property same
			propertyChanged:=false;
		endif;
	elseif myLineCompany&lt;&gt;_pxyMovement.myLineCompany then
		// Property has changed
		propertyChanged:=true;
	endif;
	if propertyChanged=true then
		// Property has changed
		create propertyChange;
   		if myLineCompany&lt;&gt;null then
			oldStr:=myLineCompany.description;
		else
			oldStr:="Not Specified";
		endif;	
		if _pxyMovement.myLineCompany&lt;&gt;null then
			newStr:=_pxyMovement.myLineCompany.description;
		else
			newStr:="Not Specified";
		endif;	
   		propertyChange.set(_transaction, "Line Company", oldStr, newStr);		
	endif;

	// Number of Lines Crew
	propertyChanged:=false;
	if addMode=true then
		if _pxyMovement.init_NumLinesCrewReqd&lt;&gt;_pxyMovement.numLineCrewRequired then
			// Property has changed
			propertyChanged:=true;
		else
			// Property same
			propertyChanged:=false;
		endif;
	elseif numLineCrewRequired&lt;&gt;_pxyMovement.numLineCrewRequired then
		// Property has changed
		propertyChanged:=true;
	endif;
	if propertyChanged=true then
		// Property has changed
		create propertyChange;
   		oldStr:=numLineCrewRequired.String &amp; " crew";
   		newStr:=_pxyMovement.numLineCrewRequired.String &amp; " crew";
   		propertyChange.set(_transaction, "No. Lines Crew Required", oldStr, newStr);
	endif;

	// Lines Relative Order Time
	propertyChanged:=false;
	if addMode=true then
		if timeLines&lt;&gt;_pxyMovement.relativeOrderTimeLines then
			// Property has changed
			propertyChanged:=true;
		else
			// Property same
			propertyChanged:=false;
		endif;
	elseif relativeOrderTimeLines&lt;&gt;_pxyMovement.relativeOrderTimeLines then
		// Property has changed
		propertyChanged:=true;
	endif;
	if propertyChanged=true then
		// Property has changed
		create propertyChange;
   		if relativeOrderTimeLines&gt;=0 then
			oldStr:="+" &amp; relativeOrderTimeLines.String &amp; " (mins)";
		else
			oldStr:=relativeOrderTimeLines.String &amp; " (mins)";
		endif;	
		if _pxyMovement.relativeOrderTimeLines&gt;=0 then
			newStr:="+" &amp; _pxyMovement.relativeOrderTimeLines.String &amp; " (mins)";
		else
			newStr:=_pxyMovement.relativeOrderTimeLines.String &amp; " (mins)";
		endif;	
   		propertyChange.set(_transaction, "Lines (Relative Order Time)", oldStr, newStr);
	endif;	

	// ************************************************************************
	//								TIDAL INFORMATION
	// ************************************************************************

	/* moved to inheritMehtod(..)
	// Move Tidal Class
	propertyChanged:=false;
	if addMode=true then
		if _pxyMovement.init_MoveTidalClass &lt;&gt; _pxyMovement.myTidalClass then
			// Property has changed
			propertyChanged:=true;
		else
			// Property same
			propertyChanged:=false;
		endif;
	elseif myTidalClass&lt;&gt;_pxyMovement.myTidalClass then
		// Property has changed
		propertyChanged:=true;
	endif;
	if propertyChanged=true then
		// Property has changed
		create propertyChange;
   		if myTidalClass&lt;&gt;null then
			oldStr:=myTidalClass.description;
		else
			oldStr:="Not Specified";
		endif;	
		if _pxyMovement.myTidalClass&lt;&gt;null then
			newStr:=_pxyMovement.myTidalClass.description;
		else
			newStr:="Not Specified";
		endif;	
   		propertyChange.set(_transaction, "Movement Tidal Class", oldStr, newStr);
	endif;
	*/

	// ************************************************************************
	//								CUSTOMER
	// ************************************************************************

	// Movement Chargable Status
	if chargeForMove&lt;&gt;_pxyMovement.chargeForMove then
		// Property has changed
		create propertyChange;
   		if chargeForMove=true then
			oldStr:="Charge";
		else
			oldStr:="Don't Charge";
		endif;	
		if _pxyMovement.chargeForMove=true then
			newStr:="Charge";
		else
			newStr:="Don't Charge";
		endif;	
   		propertyChange.set(_transaction, "Movement Chargable Status", oldStr, newStr);
	endif;

	// Customer for movement
	propertyChanged:=false;
	if addMode=true then
		if self.myShippingAgent &lt;&gt; _pxyMovement.myShippingAgent then
			// Property has changed
			propertyChanged:=true;
		endif;
		if self.myShippingLine &lt;&gt; _pxyMovement.myShippingLine then
			// Property has changed
			propertyChanged:=true;
		endif;
	else
		if self.myShippingAgent &lt;&gt;_pxyMovement.myShippingAgent then
			// Property has changed
			propertyChanged:=true;
		endif;
		if self.myShippingLine &lt;&gt; _pxyMovement.myShippingLine then
			// Property has changed
			propertyChanged:=true;
		endif;
	endif;
	if propertyChanged=true then
		// Property has changed
		create propertyChange;
   		if self.isAgentDefault then
   			if self.myShippingAgent &lt;&gt; null then
				oldStr := self.myShippingAgent.description &amp; " (Shipping Agent)";
			else
				oldStr := "None Selected";
			endif;	
		else
			if self.myShippingLine &lt;&gt; null then
				newStr := self.myShippingLine.description &amp; " (Shipping Line)";
			else
				newStr:="None Selected";
			endif;		
		endif;
   		propertyChange.set(_transaction, "Customer for movement", oldStr, newStr);
	endif;

	// Main Contact
	propertyChanged:=false;
	if addMode=true then
		if self.myContact &lt;&gt; _pxyMovement.myContact then
			// Property has changed
			propertyChanged:=true;
		else
			// Property same
			propertyChanged:=false;
		endif;
	elseif myContact &lt;&gt; _pxyMovement.myContact then
		// Property has changed
		propertyChanged:=true;
	endif;
	if propertyChanged=true then
		// Property has changed
		create propertyChange;
   		if myContact&lt;&gt;null then
			oldStr:=myContact.name;
		else
			oldStr:="None Selected";
		endif;	
		if _pxyMovement.myContact&lt;&gt;null then
			newStr:=_pxyMovement.myContact.name;
		else
			newStr:="None Selected";
		endif;	
   		propertyChange.set(_transaction, "Customer contact", oldStr, newStr);
	endif;

end;</source>
        <Parameter name="_transaction" type="HMS_Transaction"/>
        <Parameter name="_pxyMovement" type="HMS_VoyageMovement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createTrans_AdjustMoveTime" id="279faeb0-3248-461b-a2c4-bcb4bd95b7cb">
        <updating/>
        <source>createTrans_AdjustMoveTime(_fromMovement : CMIF_HMS_WorkingMovement; 
						   _pxyMovement : HMS_VoyageMovement;
						   _passport : CM_Passport input) updating, protected;

vars
	tmpStatus : Integer;
	tmpDT : TimeStamp;
 	addMode : Boolean;
begin
	// This method check to see whether
	// 		(a) The movement status has changed
	//		(b) The movement time (actual or planned) has been edited
	
	if _fromMovement &lt;&gt; null then
		
		addMode := _fromMovement.myPersistentMovement = null;
		tmpStatus := _fromMovement.moveStatus;
		tmpDT := _fromMovement.occursOnDT;
		
	elseif _pxyMovement &lt;&gt; null then
		
		addMode := (_pxyMovement.pxyGetRealObject() = null);
		tmpStatus := _pxyMovement.moveStatusNEW;
		tmpDT := _pxyMovement.occursOnDTNEW;
			
	endif;

	// Check to see if movement status has changed
	if self.moveStatusNEW &lt;&gt; tmpStatus then
		// ie. Move has been either 'Plan Confirmed' or 'Actual Confirmed'
		if tmpStatus = MovementStatus_Actual then
			// Status has changed from planned to actual
			self.createTransaction(TRANS_TYPE_ConfirmActualMove, _fromMovement, _pxyMovement, _passport);
  	 	
  	 	elseif tmpStatus = MovementStatus_ConfirmedPlan then
  	 		// Status has changed from planned to confirmed planned move
			self.createTransaction(TRANS_TYPE_ConfirmPlanMove, _fromMovement, _pxyMovement, _passport);
  	 	endif;
	endif;  	 
	
	if (not addMode) then
		// Check to see if Movement Time has been edited
		if self.occursOnDTNEW &lt;&gt; tmpDT then
			self.createTransaction(TRANS_TYPE_EditMovementTime, _fromMovement, _pxyMovement, _passport);
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_fromMovement" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="_pxyMovement" type="HMS_VoyageMovement"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createTrans_AdjustMoveTimeOLD" id="6ccbfc9e-950f-4a05-9dea-981f1e15c933">
        <updating/>
        <source>createTrans_AdjustMoveTimeOLD(fromMovement : CMIF_HMS_WorkingMovement; 
						   workingVoyage: CMIF_HMS_WorkingVoyage;
						   _passport : CM_Passport input) updating, protected;

vars
 	addMode:		Boolean;
begin
	// This method check to see whether
	// 		(a) The movement status has changed
	//		(b) The movement time (actual or planned) has been edited

	if fromMovement.myPersistentMovement = null then
		// ADD mode 
		addMode := true;
	endif;

	// Check to see if movement status has changed
	if self.moveStatusNEW &lt;&gt; fromMovement.moveStatus then
		// ie. Move has been either 'Plan Confirmed' or 'Actual Confirmed'
		if fromMovement.moveStatus = MovementStatus_Actual then
			// Status has changed from planned to actual
			self.createTransaction(TRANS_TYPE_ConfirmActualMove, fromMovement, null, _passport);
  	 	
  	 	elseif fromMovement.moveStatus = MovementStatus_ConfirmedPlan then
  	 		// Status has changed from planned to confirmed planned move
			self.createTransaction(TRANS_TYPE_ConfirmPlanMove, fromMovement, null, _passport);
  	 	endif;
	
	elseif (not addMode) then
		// Check to see if Movement Time has been edited
		if self.occursOnDTNEW &lt;&gt; fromMovement.occursOnDT then
			self.createTransaction(TRANS_TYPE_EditMovementTime, fromMovement, null, _passport);
		endif;
		/*// Check Actual Time
  	 	if self.moveDTActual &lt;&gt; fromMovement.moveDTActual then  	 	
			self.createTransaction(TRANS_TYPE_EditMovementTime, fromMovement, null, _passport);
  	 	elseif self.moveDTPlanned &lt;&gt; fromMovement.moveDTPlanned and addMode=false then  	 	
  	 		// Planned Time has changed
			self.createTransaction(TRANS_TYPE_EditMovementTime, fromMovement, null, _passport);
  	 	endif;*/
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="fromMovement" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="workingVoyage" type="CMIF_HMS_WorkingVoyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createTransaction" id="b48bc8db-f71b-41b5-8b70-6497812a887a">
        <source>createTransaction(_type: Integer; _workingMovement : CMIF_HMS_WorkingMovement; _pxyMovement : HMS_VoyageMovement; _passport: CM_Passport input) protected;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
 	cmifTrans : CMIF_HMS_TransactionController;
begin

	// This method creates a cmifTrans for all the changes that take place when the 
	// permanent voyage is added NOTE: A single cmifTrans may cover changes to one or more properties
	create cmifTrans transient;

	// Set general cmifTrans properties and references
	cmifTrans.myVoyageMovement := self;
	cmifTrans.myWorkingMovement := _workingMovement;
	cmifTrans.myHMSVoyageData := self.myHMSVoyageData;
	cmifTrans.myTerminal := self.myHMSVoyageData.getMyTerminal();
	cmifTrans.myProxyHMSObject := _pxyMovement;
	cmifTrans.type := _type;
	
	cmifTrans.createTransaction(_passport);

epilog
	delete cmifTrans;
end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_workingMovement" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="_pxyMovement" type="HMS_VoyageMovement"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="draftAft" id="88f4b0f6-08a8-4393-88a6-0ae41a0fd216">
