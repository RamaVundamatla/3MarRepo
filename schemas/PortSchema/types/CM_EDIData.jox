    <JadeMethod name="getUnprocessedExpiryDate" id="3506d7dc-0f10-4601-8f4f-467dc5adb91f">
        <source>getUnprocessedExpiryDate(_type :String):Date protected;
/*
Date		Who		Reason
14 Aug 2012	cnwcs5	Initial creation - par 30136
*/
vars
	terminal	:CM_Terminal;
	purgeDays	:Integer;
	result		:Date;
begin
	terminal	:= self.getMyTerminal;
	purgeDays 	:= terminal.getConfig(_type).Integer;
	result		:= null;
		
	if purgeDays &gt; 0 then
		result 	:= app.actualTimeServer.date - purgeDays;
	endif;
	
	return result;
epilog

end;</source>
