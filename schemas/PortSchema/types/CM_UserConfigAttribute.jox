<Class name="CM_UserConfigAttribute" id="e74f8ec1-1ee9-406f-a472-94ce21745b32">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>CCMS 1776 Cargo Enquiry user-definable layout</text>
    <DbClassMap file="terminal"/>
    <ExplicitInverseRef name="myEntTableRow" id="e089891e-feb5-4dd8-ba4d-0d6ccab7a403">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="EntTableRow"/>
        <access>readonly</access>
        <Inverse name="EntTableRow::allUserConfigAttributes"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myUserConfigTab" id="436864e1-3ada-4d4b-8c2a-d9912523f010">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_UserConfigTab"/>
        <access>readonly</access>
        <Inverse name="CM_UserConfigTab::allAttributes"/>
    </ExplicitInverseRef>
    <JadeMethod name="getHeading" id="a07fadc5-08b0-4dcd-9ca2-0608589f029e">
        <source>getHeading(_cargoBOLType : CM_CargoBOLType; _terminal : CM_Terminal; _locale : CM_Locale) : String;

begin

	return self.myEntTableRow.getHeading(_cargoBOLType, _terminal, _locale);
end;</source>
        <Parameter name="_cargoBOLType" type="CM_CargoBOLType"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_locale" type="CM_Locale"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTabDescription" id="cde9752b-4ac0-4617-9dd5-6b1ab529c554">
        <source>getTabDescription() : String;

vars
	tabDescription	: String;
begin
	if self.myUserConfigTab &lt;&gt; null then
		tabDescription := myUserConfigTab.description;
	endif;
	
	return tabDescription;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setup" id="d01dba2c-dcf0-4ee3-bc02-b1af369ee93b">
        <updating/>
        <source>setup(_tab : CM_UserConfigTab; _row : EntTableRow) updating;

vars

begin
	self.myUserConfigTab := _tab;
	self.myEntTableRow := _row;
end;
</source>
        <Parameter name="_tab" type="CM_UserConfigTab"/>
        <Parameter name="_row" type="EntTableRow"/>
    </JadeMethod>
</Class>
