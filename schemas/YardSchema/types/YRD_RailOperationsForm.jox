    <JadeMethod name="showInfoForWagonGridPoint" id="09d179be-cced-4ff2-98b2-f1176c59a50e">
        <updating/>
        <source>showInfoForWagonGridPoint(_gridPoint : CMUI_GridPoint; _x, _y : Real) protected, updating;
// ---------------------------------------------------------------------------
// Created:      10 July 2003 by cnwsgp1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/08/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	bulkRelease		: CM_BulkRelease;
	wgnController 	: CM_WagonController;
	wle				: CM_WorkListEntry;
	obj				: Object;
	numRows,
	row 			: Integer;
	ti				: CM_TrackedItem;
	wagonCntrl		: CM_WagonController;
	tbl				: CM_DataTable;
begin
	if _gridPoint = null then
		return;
	endif;
	//grid point can be eith YRD_WagonPoint, YRD_WagonBody or YRD_WagonWheels
	//if YRD_WagonPoint, there may be container at this point so display container info
	//else display wagon info
	if YRD_WagonPoint.hasInstance(_gridPoint) then
		ti := _gridPoint.YRD_WagonPoint.getTI(_x, _y); //_gridPoint.x1,_gridPoint.y1);
		if _gridPoint.isBoxcar then	//20 Mar 2013	NDL	Par 31278
			ti := null;
		endif;
		if ti = null then
			bulkRelease := _gridPoint.YRD_WagonPoint.getBulkRelease(_x, _y);
		endif;
	endif;
	
	if CM_WagonController.hasInstance(_gridPoint.myLocationsController) then
		self.myCurrentWagon := _gridPoint.myLocationsController.CM_WagonController.myWagon;
	endif;
	
	self.myCurrentTrackedItem := ti;
	
	if self.myCurrentTrackedItem &lt;&gt; null then
		self.displayExtraInfoForObj(ti);
		//select it in the table and make it the top row
		self.tblWorkEntries.findObjectInRow(self.myCurrentTrackedItem.getIncompleteRailReceiveWle(), row);
		tbl := self.tblWorkEntries;
		numRows := tbl.rows;
		foreach row in tbl.fixedRows + 1 to numRows do
			tbl.accessRow(row).selected := false;
			obj := tbl.accessedRow.itemObject;
			if (not CM_WorkListEntry.hasInstance(obj)) then
				continue;
			endif;
			if obj.CM_WorkListEntry.myTrackedItem = ti then
				tbl.accessedRow.selected := true;
				tbl.topRow := row;
			endif;
		endforeach;

	elseif bulkRelease &lt;&gt; null then
		self.displayExtraInfoForObj(bulkRelease);
		
	elseif self.myCurrentWagon &lt;&gt; null then
		if YRD_WagonColorCode.hasInstance(_gridPoint) then
			self.displayExtraInfoForObj(myCurrentWagon.getRailAllocation);
		else
			self.displayExtraInfoForObj(myCurrentWagon);
		endif;
	endif;
		
end;</source>
        <access>protected</access>
        <Parameter name="_gridPoint" type="CMUI_GridPoint"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="showPopupMenu" id="6cbc5346-e04d-402f-b69b-89b306b17405">
        <source>showPopupMenu(pMenu : MenuItem input; pLeft: Integer; pTop : Integer);
// ---------------------------------------------------------------------------
// Created:		December  2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lWagon : CM_Wagon;
begin
	/*mnuRakeClear.visible := false;
	mnuRakeConfirmWagon.visible := false;
	mnuRakeJobAdd.visible := false;
	mnuRakeJobDelete.visible := false;
	mnuRakeJobEdit.visible := false;
	mnuRakeJobAssign.visible := false;
	mnuRakePrint.visible := false;
	mnuRakeRebuild.visible := false;
	mnuRakeConfirmRake.visible := false;
	mnuRakeWagonAdd.visible := false;
	mnuRakeWagonEdit.visible := false;
	mnuRakeWagonDelete.visible := false;*/


	lWagon := self.myCurrentWagon;
	pMenu.visible := true;
	pMenu.enabled := true;	
	
	self.mnuInspectObject.visible := app.isAllowedToInspect;
		//th2 changed 26/06/2007 - always make adding a rail release available

	self.mnuJobAdd.visible := true;
	
	if pMenu = mnuRailLinePrint then
		// show the rake rebuild as well
		mnuRebuild.visible := true;
		mnuRebuild.enabled := true;
	elseif pMenu = mnuConfirmWagon then
		// show the confirm rake as well
		self.mnuConfirmRailLine.visible := true;
		self.mnuConfirmRailLine.enabled := true;
		if self.myCurrentTrain &lt;&gt; null then
			self.mnuConfirmTrain.visible 	:= true;
			//self.mnuConfirmTrain.caption := 'Confirm Train: ' &amp; self.myAssistant.displayEntryTrain(self.myCurrentTrain); //- cnwmd1, CCMS 1067, Par 19710
			self.mnuConfirmTrain.caption := app.getErrorString1(Confirm_train_WithParam, self.myAssistant.displayEntryTrain(self.myCurrentTrain)); //+ cnwmd1, CCMS 1067, Par 19710
		endif;
		
	elseif pMenu = mnuJobEdit then
		// show the job delete as well
		mnuJobDelete.visible := true;
		mnuJobDelete.enabled := true;
		mnuJobAssign.visible := true;
		self.doBuildMenuRailLines(mnuJobAssign, Rail_JSIO_Type_Out);	
		mnuJobAssign.enabled := true;
		self.mnuInspectObject.userObject := myCurrentRailJob;
		if self.allSelectedRailJobs.isEmpty
		and self.myCurrentRailJob = null then
			mnuJobAssign.enabled := false;
		elseif  self.allSelectedRailJobs.size &gt; 1 then
			mnuJobDelete.enabled := false;
			mnuJobEdit.enabled := false;
		endif;
	elseif pMenu = mnuWagonAdd then

	elseif pMenu = mnuRailLineWagonEdit then
		if lWagon &lt;&gt; null then
			//self.mnuRailLineWagonEdit.caption := lWagon.id &amp; " Edit" &amp; '...'; //- cnwmd1, CCMS 1067, Par 19710
			self.mnuRailLineWagonEdit.caption := lWagon.id &amp; " " &amp; app.getErrorString(Edit) &amp; '...';//+ cnwmd1, CCMS 1067, Par 19710
			self.mnuRailLineWagonEdit.userObject := lWagon;
			if lWagon.confirmed then
				mnuConfirmRailLine.visible := false;
				mnuConfirmRailLine.enabled := false;
			else
				mnuConfirmRailLine.visible := true;
				mnuConfirmRailLine.enabled := true;
			endif;

			self.mnuInspectObject.userObject := lWagon;
		endif;
	endif;

	popupMenu(mnuRake, pLeft.Integer, pTop.Integer);


end;</source>
        <Parameter name="pMenu" type="MenuItem" usage="input"/>
        <Parameter name="pLeft" type="Integer"/>
        <Parameter name="pTop" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showPrintFrame" id="220afc82-73bf-4450-8d44-1a5faf5781bd">
        <source>showPrintFrame();
// ---------------------------------------------------------------------------
// Created:     11 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	self.frmPrint2.backColor := self.backColor;
	self.grpPrint.backColor := self.backColor;
	
