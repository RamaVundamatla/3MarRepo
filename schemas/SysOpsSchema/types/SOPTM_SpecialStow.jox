    </JadeMethod>
    <JadeMethod name="doSave" id="96d7d78e-1279-4fea-9aae-fd9ba66eb710">
        <updating/>
        <source>doSave(): Boolean updating;
//-----------------------------------------
//
// Created : by cnwaer1 19 August 2008
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------
// 12/05/2015	cnwdap1		PAR #36206 TFS 324/334 Graphical Representation of Special Stow
//-----------------------------------------
vars
	proxySpecialStow:CM_SpecialStow;
	lCode,lDescription:String;
	theForm : SOP_TableMaintForm;
	pxyDraw : CM_DrawingAttribute;						// PAR #36206
	font : String;										// PAR #36206
	character : String;									// PAR #36206
begin
	theForm := self.myForm; 
	lCode := theForm.tblInput1.getValueByName(ETRow_Code).String;
	lDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;

	font := theForm.tblInput1.getValueByName(ETRow_Font).String;						// PAR #36206
	character := theForm.tblInput1.getValueByName(ETRow_Character).String;				// PAR #36206
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_SpecialStow transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxySpecialStow := theForm.myProxyObject.CM_SpecialStow;
	proxySpecialStow.setProxy(lCode, lDescription);

	if proxySpecialStow.myDrawingAttribute &lt;&gt; null then									// PAR #36206
		pxyDraw := proxySpecialStow.myDrawingAttribute;									// PAR #36206
	else																				// PAR #36206
		create pxyDraw transient;														// PAR #36206
	endif;																				// PAR #36206
	if not self.doSaveDrawingAttributePxy(pxyDraw) then									// PAR #36206
		delete pxyDraw;																	// PAR #36206	
	endif;																				// PAR #36206

	if theForm.mode = theForm.Mode_Add then
		 //app.myTrxCA.trxCreateSpecialStow(proxySpecialStow, theForm.myCurrentObject,app.myPassport);			// PAR #36206
		 app.myTrxCA.trxCreateSpecialStow(proxySpecialStow, theForm.myCurrentObject, pxyDraw, app.myPassport);	// PAR #36206
	elseif theForm.mode = theForm.Mode_Update then
		//app.myTrxUA.trxUpdateSpecialStow(proxySpecialStow, app.myPassport);									// PAR #36206
		app.myTrxUA.trxUpdateSpecialStow(proxySpecialStow, pxyDraw, app.myPassport);							// PAR #36206
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
