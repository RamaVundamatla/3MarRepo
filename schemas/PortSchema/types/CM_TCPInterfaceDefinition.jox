    <JadeMethod name="getContainerAttributesString" id="13a540da-5b75-434e-b9c5-f0e3b8ffa6c8">
        <source>getContainerAttributesString(_functionName : String;
							 _task,
							 _twinTask : CM_RTQueueTask) : String;

/*

Purpose:			Get the container attributes string the receiver interface
					for the passed in Container
					
Parameters:			Current Function, Task, and optional current twin task

Return Value:		Attributes string


Date		Who		Reason
19 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
24 Nov 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes
					Change to Hook Code signature
02 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift

*/

vars
	returnVal		: String;
	selfParam		: SelfType;
	cmifParams		: CMIF_ContainerAttrParams;

begin
	if _task = null or _task.ti = null then
		return null;
	endif;
	
	// If there is one defined, then pass the container to the User Hook
	if self.myContainerXlateHookCode &lt;&gt; null then
		selfParam := self;
		
		create cmifParams transient;
		
		cmifParams.functionName := _functionName;
		cmifParams.myQueueTask := _task;
		cmifParams.myTrackedItem := _task.ti;
		
		if _twinTask &lt;&gt; null then
			cmifParams.myQueueTask2 := _twinTask;
			cmifParams.myTrackedItem2 := _twinTask.ti;
		endif;
		
		returnVal := app.myHookAgent.runHookLinkPublic(HookType_ContainerAttributes,	// _hookType : Integer;
													   self,							// _hookObject : CM_Object;
													   self,							// _receiver : Object;
																						// _paramListType : ParamListType io
													   selfParam,							// _interfaceDef:CM_InterfaceDefinition;
													   cmifParams).String;					// _containerParams:CMIF_ContainerAttrParams
	else
		returnVal := null;
	endif;

	return returnVal;
	
	
epilog
	delete cmifParams;
	
end;</source>
        <Parameter name="_functionName" type="String"/>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <Parameter name="_twinTask" type="CM_RTQueueTask"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getContainerUniqueValue" id="a2da7007-bf5b-496b-a629-9fb8b895c424">
        <source>getContainerUniqueValue(	_functionName : String;
							_task : CM_RTQueueTask):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 March 2011	cnwndl1	Initial creation	Par 27290

*/

vars

	returnVal : Boolean;
	selfParam		: SelfType;
	cmifParams		: CMIF_ContainerAttrParams;

begin


	// If there is one defined, then pass the container to the User Hook
	if self.myUniqueContainerHookCode &lt;&gt; null then
		selfParam := self;
		
		create cmifParams transient;
		
		cmifParams.functionName := _functionName;
		cmifParams.myQueueTask := _task;
		cmifParams.myTrackedItem := _task.ti;
		
		returnVal := app.myHookAgent.runHookLinkPublic(HookType_ContainerUnique,	// _hookType : Integer;
													   self,							// _hookObject : CM_Object;
													   self,							// _receiver : Object;
																						// _paramListType : ParamListType io
													   selfParam,							// _interfaceDef:CM_InterfaceDefinition;
													   cmifParams).Boolean;					// _containerParams:CMIF_ContainerAttrParams
	else
		returnVal := false;
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_functionName" type="String"/>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getJadeHookCode" id="44d75556-3f98-4698-8a13-6b58d65c03a1">
        <source>getJadeHookCode(_hookType:Integer):String;
// --------------------------------------------------------------------------------
// Created:		18 September 2008 by cnwdad1
//
// Purpose:		Returns the Jade source code for the specified User Hook.
//
// Parameters:	_hookType - The User Hook code (Global Constant).
//
// Returns:		The Jade source code, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	hookTypeObj	: CM_HookType;
	
begin
	if _hookType = HookType_ContainerAttributes then
		if self.myContainerXlateHookCode = null then
			hookTypeObj	:=	app.myRoot.allHookTypes[HookType_ContainerAttributes];
			
			if hookTypeObj = null then
				return null;
			else
				return hookTypeObj.hookMethodTemplate;
			endif;
		else
			return self.myContainerXlateHookCode.getCurrentJadeCode();
		endif;

	// 29 Mar 2011	NDL	Par 27290
	elseif _hookType = HookType_ContainerUnique then
		if self.myUniqueContainerHookCode = null then
			hookTypeObj	:=	app.myRoot.allHookTypes[HookType_ContainerUnique];
			
			if hookTypeObj = null then
				return null;
			else
				return hookTypeObj.hookMethodTemplate;
			endif;
		else
			return self.myUniqueContainerHookCode.getCurrentJadeCode();
		endif;
		
	elseif _hookType = HookType_LocationTranslation then
		if self.myLocationXlateHookCode = null then
			hookTypeObj	:=	app.myRoot.allHookTypes[HookType_LocationTranslation];
			
			if hookTypeObj = null then
				return null;
			else
				return hookTypeObj.hookMethodTemplate;
			endif;
		else
			return self.myLocationXlateHookCode.getCurrentJadeCode();
		endif;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_hookType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationTranslationString" id="bbb5eaa0-cc80-4b11-97e5-df2c8e72f84a">
        <source>getLocationTranslationString(_functionName : String;
							 _task,
							 _twinTask : CM_RTQueueTask;
							 _location : CM_LocationsController;
							 _isSource : Boolean) : String;

/*

Purpose:			Get the translated Location Description for the receiver interface
					for the passed in Locations Controller, depending on whether or not it
					is the source or target location

Parameters:			Current function name, Queue Task(s), Location, and whether or not it is the source of a move

Return Value:		Translated string


Date		Who		Reason
19 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
24 Nov 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes
					Rework to use CMIF_LocationTransParams for hook code
02 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift

*/

vars
	returnVal		: String;
	terminalArea	: CM_TerminalAreaMaster;
	selfParam		: SelfType;
	cmifParams		: CMIF_LocationTransParams;
	
begin
	if _location = null then
		return null;
	endif;
	
	// Create the parameter
	create cmifParams transient;
	
	cmifParams.functionName := _functionName;
	
	// Get the default location description
	cmifParams.defaultDescription := _location.getFullIdForTI(not _isSource);
	
	// And if there is one defined, then pass the built up parameter to the User Hook
	if self.myLocationXlateHookCode &lt;&gt; null then
		selfParam := self;
		
		// Get this interface's translation of the Terminal Area this Location belongs to
		terminalArea := _location.myTerminalArea;
		cmifParams.translatedTADesc := self.getTATranslationString(terminalArea, _isSource);
	
		cmifParams.myLocation := _location;
		cmifParams.isSource := _isSource;
		
		if _task &lt;&gt; null then
			cmifParams.myQueueTask := _task;
			cmifParams.myTrackedItem := _task.ti;
			if _task.myEntry &lt;&gt; null then
				cmifParams.myWorkListEntry := _task.myEntry.myWorkListEntry;
			endif;
		endif;
		
		if _twinTask &lt;&gt; null then
			cmifParams.myQueueTask2 := _twinTask;
			cmifParams.myTrackedItem2 := _twinTask.ti;
			if _twinTask.myEntry &lt;&gt; null then
				cmifParams.myWorkListEntry2 := _twinTask.myEntry.myWorkListEntry;
			endif;
		endif;
			
		returnVal := app.myHookAgent.runHookLinkPublic(HookType_LocationTranslation,	// _hookType : Integer;
													   self,							// _hookObject : CM_Object;
													   self,							// _receiver : Object;
																						// _paramListType : ParamListType io
													   selfParam,							// _interfaceDef:CM_InterfaceDefinition;
													   cmifParams).String;					// _locationParams:CMIF_LocationTransParams

	else
		returnVal := cmifParams.defaultDescription;
	endif;

	return returnVal;
	
	
epilog
	delete cmifParams;
	
end;</source>
        <Parameter name="_functionName" type="String"/>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <Parameter name="_twinTask" type="CM_RTQueueTask"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_isSource" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUserHookLink" id="d6680f2d-b172-4db1-b0a3-d17a1ff25ac1">
        <source>getUserHookLink(_hookType:Integer):CM_HookLink protected;
// --------------------------------------------------------------------------------
// Created:		18 September 2008 by cnwdad1
//
// Purpose:		Returns a reference to the specified User Hook's CM_HookLink object.
//
// Parameters:	_hookType - The User Hook Type code (Global Constant).
//
// Returns:		A reference to the Hook Link object, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	hookLinkObj	: CM_HookLink;
	
begin
	foreach hookLinkObj in self.allCurrentHookLinkObjects do
		if hookLinkObj.hookType = _hookType then
			return hookLinkObj;
		endif;
	endforeach;
	
	return null;
end;</source>
        <access>protected</access>
        <Parameter name="_hookType" type="Integer"/>
        <ReturnType type="CM_HookLink"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="c2cca812-ac4a-40fc-baa6-7c0feaa293ca">
        <source>pxyCreateUpdateProxy(): SelfType;
// --------------------------------------------------------------------------------
// Created:		04 September 2008 by cnwdad1
//
// Purpose:		Standard method to instantiate and return a proxy of the receiver.
//
// Parameters:	None
//
// Returns:		A reference to the transient proxy object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// --------------------------------------------------------------------------------
vars
	proxyObj	: SelfType;
	completedOK		: Boolean;
	
begin
	beginLoad;
	
	proxyObj	:=	inheritMethod();
	
	if self.myContainerXlateHookCode &lt;&gt; null then
		proxyObj.myContainerXlateHookCode	:=	self.myContainerXlateHookCode.pxyCreateUpdateProxyWithCode();
	endif;
	
	//31 Mar 2011	NDL	Par 27290
	if self.myUniqueContainerHookCode &lt;&gt; null then
		proxyObj.myUniqueContainerHookCode	:=	self.myUniqueContainerHookCode.pxyCreateUpdateProxyWithCode();
	endif;
	
	if self.myLocationXlateHookCode &lt;&gt; null then
		proxyObj.myLocationXlateHookCode	:=	self.myLocationXlateHookCode.pxyCreateUpdateProxyWithCode();
	endif;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyObj;
epilog
	endLoad;
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyObj;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="ee4fc07c-5a0b-47ab-bf94-53ce19abff7b">
        <updating/>
        <source>setForCreate(_proxyObj:SelfType) updating;
// --------------------------------------------------------------------------------
// Created:		04 September 2008 by cnwdad1
//
// Purpose:		Standard method that is invoked from a transaction when the receiver
//				is created.
//
// Parameters:	_proxyObj - A reference to a proxy of the receiver.
