    <JadeMethod name="utlCreateWinCESerialDetails" id="2331695a-c22a-4ca2-9b3b-e445a296b45d">
        <updating/>
        <source>utlCreateWinCESerialDetails(_pxyWinCESerialDetails : CM_WinCEJadeSerialDetails input;
							_realWinCESerialDetails : CM_WinCEJadeSerialDetails output;
							_device : CM_RadioTelemetryDevice;
							_passport : CM_Passport input;
							_weighBridgeObj : CM_WeighBridgeObj) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
28 February 2007	cnwer1	Initial creation - PAR#xxxx
//22/01//17 cnwns1 TFS3153:PKT - Bulk Process - WeighBridge Integration
*/
vars

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	self.raiseExceptionIfNull(_pxyWinCESerialDetails, "Win CE Serial Details Proxy");
	
	if _device = null and _weighBridgeObj = null then
		app.raiseCMException1(Input_required_field_Required, "Radio Telemetry Device or weighbridge", null, null);
	endif;
	
	//self.raiseExceptionIfNull(_device, "Radio Telemetry Device");
	
	app.setContinueCMExceptions(false);

	create _realWinCESerialDetails persistent;
	_realWinCESerialDetails.setForCreate(_pxyWinCESerialDetails,_device,_weighBridgeObj);

	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_realWinCESerialDetails);
	endif;

epilog

end;</source>
