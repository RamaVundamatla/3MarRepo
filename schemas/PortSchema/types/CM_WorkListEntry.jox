    <JadeMethod name="setWorkOrderComplete" id="c2eccbac-7664-4d32-8eda-ae9ecb59a5eb">
        <updating/>
        <source>setWorkOrderComplete()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 Nov 2009	cnwrd1	Initial creation
27 Mar 2023 navma1  ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
17 Apr 2023 navma1  ChangeRequest 55440:[54990] EUP - Release Cargo Work Order - Enhancement
24 May 2023 navmv20 CR 57925 Task 57921: UI - WO Enquiry To Do Tasks
06 Jun 2023 navma1  ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
19 Jun 2023	navma1	Defect 58633: MTN - The WO status is not updated even if the Move Task is Complete
04 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
21 Dec 2023 navhl20 ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request
04 Jan 2023 navhl20 ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request
*/

vars
	woDetail		: CM_WorkOrderTIDtl;
	ti              : CM_TrackedItem;
	operWle			: CM_WorkListEntry;
begin

	woDetail := self.getWorkOrderTIDtl();
	
	/*
		17.04.2023 navma1 #55440:[54990]
		Update Work list entry
	*/

	if  woDetail &lt;&gt; null then
		if self.isWorkOrderWle then
			operWle := self.CM_WOWLE.myOperationalWLE;
		endif;
		if self.myTrackedItem = null then
			if operWle &lt;&gt; null then
				ti := operWle.myTrackedItem;
			endif;
		
			if ti &lt;&gt; null then
				self.setMyTrackedItem(ti);     //update WoWle
				if self.quantity &lt;&gt; ti.totalQuantity then
					self.setQuantity(ti.totalQuantity);
				endif;
				/*
				Add Tracked Item to collections
				*/
				woDetail.allSelectedTIs.addNoDuplicates(ti,false);
				woDetail.myParent.CM_WorkOrderTI.allTIs.addNoDuplicates(ti,false);
			endif;
		endif;
		
		if operWle &lt;&gt; null then
			woDetail.doCompleteTask(operWle,self,null);
		elseif woDetail.isKindOf(CM_WodMove) then							//19.06.2023 navma1 #58633
			
			woDetail.setTIComplete(self.myTrackedItem,null);
		elseif woDetail.isKindOf(CM_WodReceive) or woDetail.isKindOf(CM_WodRelease) then						//04.12.2023 navhl20 #58400[61617]
			if woDetail.isKindOf(CM_WodRelease) and woDetail.CM_WodRelease.isRelaseByType() then				//04.01.2023 navhl20 #61092[61621]
				woDetail.allSelectedTIs.addNoDuplicates(self.myTrackedItem,false);								//21.12.2023 navhl20 #61092[61621]
			endif;
			woDetail.setTIComplete(self.myTrackedItem,null);
		endif;
	endif;
	
	/*
	06.06.2023 navma1 #58339
	if  woDetail &lt;&gt; null then
		if not self.isForToDoWOTransaction() then
			woDetail.setTIComplete(self.myTrackedItem,null);			//27.03.2023 navma1 #56614:[56615]
		endif;
	endif;
	*/
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="ff773393-7ff3-4f1d-bb64-e818ebb047c0">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;

vars
	propName	: String;
	
begin
	propName := _property.name;
	if propName = CM_WorkListEntry::myRequest.name or
	   propName = CM_WorkListEntry::allRTQueueEntries.name then
	   	return false;
	endif;
	
	return inheritMethod(_rootClass, _property);
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="shouldQueueForRoadJob" id="ec24d708-1219-4362-93f1-298e5e7c99fb">
        <updating/>
        <source>shouldQueueForRoadJob() : Boolean updating;
/*

Date		Who		Reason
04 September 2014	cnwer1	Initial creation PAR
14/06/2022 	navcs2 		ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
*/

vars
	hasChassis : Boolean;
	chassis : CM_TILC;
		lcSet : CM_LCSet;
begin
	if self.isKindOf(CM_WOToDoWLE) then //14/06/2022 navcs2 TFS 53038
		return false;
	endif;
	
	if self.isReleaseToPack then
		return false;
	endif;
	
	self.rebuildStatus;
	if self.status = WLE_COMPLETED  then
		return false;
	endif;
	
	if self.isReceipt and self.myTrackedItem = null then // receival by type dont need to be queued. cnwrd1 par 33650
		return false;
	endif;

	if self.job = null or not self.job.isKindOf(CM_RoadJob) then
		return false;
	endif;
	
	chassis:=self.job.CM_RoadJob.getChassis(false,hasChassis);
	if hasChassis and chassis &lt;&gt; null then
		create lcSet transient;
		chassis.allLCs.copy(lcSet);
	endif;
	//epr par 32550 if it is a release and the ti is already on the release chassis then no need to try and queue the wle as it is already in its target location
	if self.job.isRelease and chassis &lt;&gt; null then
		if  self.myTrackedItem &lt;&gt; null and lcSet.includes( self.myTrackedItem.myPrimaryActualLocation ) then
			return false;
		endif;
	endif;
	
	return true;
epilog	
	delete lcSet;
end;	</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showDirectDeliveryInHoldForms" id="3f39df62-4556-4b93-aaaf-d774fcce3f8c">
        <source>showDirectDeliveryInHoldForms() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/11/2021	navdap1		Initial creation TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
// 19/02/2022	navdap1		TFS 52801 SAL Direct Delivery - End of Shift Job Transfer
//
vars
	ti, prenote : CM_TrackedItem;

begin
	ti := self.myTrackedItem;
	if ti = null or ti.hasBeenMerged then
		return false;
	endif;
	prenote := ti.myVoyage.allNotifiedTIsByIdCargoType[ti.id, ti.cargoType];
	// we don't want WLEs that only exist as supporting data on a Yard WLE while we're on the truck
	// we DO want these WLEs if the prenote no longer exists because this TI is the last of the prenote moved on-site
	//if (ti &lt;&gt; null and ti.wasPrenotified and prenote = null) 
	//or self.myDirectDeliveryParentWLE = null or self.status = WLE_COMPLETED then
	// TFS 52801 We now do need to include some WLEs that exist as supporting data on a yard WLE,
	// because we may have just replanned them to another job when the prenote was removed from its 
	// previous job and replanned
	if self.myDirectDeliveryParentWLE = null or self.status = WLE_COMPLETED
	or (ti.wasPrenotified and prenote = null and ti.allPlannedFutureMoves.isEmpty) 
	or (ti.wasPrenotified and prenote = null and self.isKindOf(CM_VoyageWLE) and self.CM_VoyageWLE.subSeqNum &lt;&gt; null 
		and (self.myDirectDeliveryParentWLE = null or self.myDirectDeliveryParentWLE.status &lt;&gt; WLE_COMPLETED)) 
	or (ti.wasPrenotified and prenote &lt;&gt; null and self.myDirectDeliveryParentWLE &lt;&gt; null 		// TFS 52801
		and ti.receivedDT.isValid and ti.receivedDT &lt; self.job.createdTime) then				// TFS 52801
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="statusString" id="5fd64572-338a-4feb-9e0c-5a91ad1c36c3">
        <methodInvocation>mapping</methodInvocation>
        <source>statusString(set: Boolean; value: String io) mapping;
//See sub class implementations
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if self.status = WLE_UNACTIONED then
		value := "Unactioned";
	elseif self.status = WLE_PART_COMPLETE then
		value := "Part Complete"; 
	elseif self.status = WLE_CAN_RELEASE then
		value := "Can complete Job"; 
	elseif self.status = WLE_ASSIGNED then
		value := "Assigned"; 
	elseif self.status = WLE_COMPLETED then
		value := "Completed"; 
	else
		value := "Unknown";
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="swapReleaseTI" id="60038f7e-6134-4098-ae9a-01e9356901a7">
        <updating/>
        <source>swapReleaseTI(_newTrackedItem : CM_TrackedItem input; _passport : CM_Passport input) updating;
/*

Date		Who		Reason
21 May 2014	cnwer1	Initial creation PAR 34174

*/

vars
	oldTI : CM_TrackedItem;
	gateEntity 	:  CMGTE_Entity;
	request : CM_Request;
	tiUpdateCntrlr 	: CMIF_TIUpdateController;
	moveController : CMIF_MoveController;
	toLocn : CM_LocationsController;
	visit	:CM_VehicleVisitRecord;
begin
	if self.isReceipt then
		return;
	endif;
	
	if _newTrackedItem = null then
		return;
	endif;
	
	if not self.myRequest.isKindOf(CM_TIRequest) then
		return;
	endif;
	
	if not self.status = WLE_UNACTIONED then
		return;
	endif;
	
	tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_RELEASE, app.myPassport.userCode, null);
	_newTrackedItem.validateTrackedItem(tiUpdateCntrlr, app.myPassport);
	
	
	if  _passport.hasErrors then
		return;
	endif;
	
	
	oldTI:=self.myTrackedItem;
	self.unassignTI();
	
	self.setMyTrackedItem(_newTrackedItem);
	//update road job ti collections and the VVR ti collections
	job.updateTICollections(_newTrackedItem,self); 
	
	gateEntity :=self.myRequest.CM_YardRequest.myGateEntity;
	if gateEntity &lt;&gt; null then
		gateEntity.CMGTE_Release.setMyTrackedItem(_newTrackedItem);
		_newTrackedItem.setMyBookRefItemActual(gateEntity.myBookingRefItem);	
	endif;
	
	self.myRequest.CM_TIRequest.setTrackedItem(_newTrackedItem);
	if self.myRequest.myOriginatingBulkRelease &lt;&gt; null and self.myRequest.myOriginatingBulkRelease.isSystemGenerated then
		
		self.myRequest.myOriginatingBulkRelease.setDetailsFromTI(_newTrackedItem);

		//update from new ti details
		foreach request in self.myRequest.myOriginatingBulkRelease.requests where request.isKindOf(CM_TIRequest) do
			if request.CM_TIRequest.trackedItem = oldTI then
				request.CM_TIRequest.setTrackedItem(_newTrackedItem);
			endif;
		endforeach;
		
	endif;
	
	self.myRequest.CM_YardRequest.validate(null);
	
	
	if self.allRTQueueEntries.size &gt; 0 then
		app.myUtilityUA.utlUpdateWLEUnqueue(self,_passport);
		create moveController transient;
		moveController.setMoveMode(QUEUE_MODE);
		toLocn := self.getLocationForMode(PLANNING_MODE);
		if toLocn = null then
			toLocn := self.getLocationForMode(QUEUE_MODE);		
		endif;
		moveController.setMyTrackedItem(_newTrackedItem);
		moveController.setMyToPrimaryLocation(toLocn);
		self.doMoveToLocn(moveController, _passport);
	endif;
	
	if not _passport.hasErrors then
		if self.job.isRoadJob then
			visit := self.job.CM_RoadJob.myVehicleVisit;
			//update VVR with some detail about the swap
			if visit &lt;&gt; null then
				visit.createVisitRecordDetail (VisitRecord_SwapReleaseCargo, oldTI, null); 
			endif;
		endif;
		
		app.myEventManager.createSingleObjInfoNoteEvt(self,_newTrackedItem.myTerminal.getTerminalEvent(WLE_Update_Event), self);
		app.myEventManager.createSingleObjInfoNoteEvt(self.job,_newTrackedItem.myTerminal.getTerminalEvent(RoadJob_Update_Event), self.job);
	
	endif;

epilog
	delete tiUpdateCntrlr;
	delete moveController;
end;</source>
        <Parameter name="_newTrackedItem" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="typeString" id="fb6cf0d7-7d40-4297-8309-b81d058a7a58">
