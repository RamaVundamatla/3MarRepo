    <JadeMethod name="loadImages" id="970e1d54-50c7-4a7e-84c3-33c14e82940e">
        <source>loadImages();
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12 Jan 2026 navhl20 Bug MTN-36897: PEN - Transient File Growth in PEN Production Environment
// ---------------------------------------------------------------------------
vars
	js	: JadeSkin;
	f	: File;
	dir	: String;
	propCol	: PropertyColl;
	prop	: Property;
	
begin

	dir := txtImageDir.text;	// 'c:\share\Portec_blue';
	
	js := cmbSkins.listObject.JadeSkin;
	
	if js = null then
		app.msgBox('You must select a skin to load images into', 'Error', MsgBox_OK_Only);
		return;
	endif;
	
	create f transient;
	f.mode := File.Mode_Input;
	f.kind := File.Kind_Binary;
	
	propCol := JadeSkin.allProperties();
	
	beginTransaction;
	
	foreach prop in propCol do
		if prop.name[1:3] = 'img' then
			f.fileName := dir &amp; '\' &amp; prop.name &amp; '.png';
	
			if f.isAvailable then
				f.open; 
	 
				js.setPropertyValue(prop.name, f.readBinary(f.fileLength));
	
				f.close;
			else
				app.msgBox('No image file found for ' &amp; prop.name, 'Warning', MsgBox_OK_Only);
			endif;
		endif;
	endforeach;

	commitTransaction;
		
epilog
	delete f;
	delete propCol;			//12.01.2026 navhl20 #36897
end;</source>
    </JadeMethod>
</GUIClass>
