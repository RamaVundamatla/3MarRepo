    <JadeMethod name="doMnuContext3Click" id="a961c3aa-1375-4b8a-8929-d5389ff1aadd">
        <updating/>
        <source>doMnuContext3Click(theMenuItem: MenuItem) updating;
//
// 09 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
//
vars
	table : CM_DataTable;
	obj : Object;
	ediSenderHist : CM_EDISenderRecipFileTypeHist;
	coll : ObjectArray;
	ediData : CM_EDIData;
	ediAgent : CMUI_EDIAgent;
	deleted : Boolean;
	terminal : CM_Terminal;
	auditConfig : CM_AuditConfig;
	auditObject : CM_AuditObject;
	foundAuditObject : CM_AuditObject;
	oldValue : String;
	newValue : String;
begin
	table := self.myForm.tblDataView1;
	
	obj := table.accessRow(table.row).itemObject;
	if obj = null then
		if table.row &gt; table.fixedRows then
			app.msgBox(app.getErrorString(ERR_CAMS_OPENFILE),  app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Information_Icon);
		endif;
		return;
	endif;
	ediSenderHist := obj.CM_EDISenderRecipFileTypeHist;
	terminal := ediSenderHist.myEDISenderRecipFileType.myTerminal;
	ediData := ediSenderHist.getMyEDIData(deleted);
	if ediData = null then
		if deleted then
			// find audit
			app.mousePointer := MP_HOURGLASS;
			auditConfig := app.myRoot.allAuditConfigs[CM_EDIData.name];
			foreach auditObject in auditConfig.allAuditObjects do
				if auditObject.type = AuditDeleted then
					if auditObject.getOldNewValueForTag(ETRow_Terminal, oldValue, newValue) then
						if oldValue = terminal.code then
							if auditObject.getOldNewValueForTag(ETRow_Number, oldValue, newValue) then
								if oldValue.Integer = ediSenderHist.getConfigNumber then
									//write class.name&amp;'::'&amp;method.name&amp;' got the b';
									foundAuditObject := auditObject;
									break;
								endif;
							endif;
							//write class.name&amp;'::'&amp;method.name&amp;' ediSenderHist.number='&amp;ediSenderHist.number.String&amp;' oldValue='&amp;oldValue;
						endif;
					endif;
				endif;
			endforeach;
			if foundAuditObject = null then
				foreach auditObject in auditConfig.allAuditObjects do
					if auditObject.type = AuditCreated then
						if auditObject.getOldNewValueForTag(ETRow_Terminal, oldValue, newValue) then
							if oldValue = terminal.code then
								if auditObject.getOldNewValueForTag(ETRow_Number, oldValue, newValue) then
									if oldValue.Integer = ediSenderHist.getConfigNumber then
										//write class.name&amp;'::'&amp;method.name&amp;' got the b';
										foundAuditObject := auditObject;
										break;
									endif;
								endif;
								//write class.name&amp;'::'&amp;method.name&amp;' ediSenderHist.number='&amp;ediSenderHist.number.String&amp;' oldValue='&amp;oldValue;
							endif;
						endif;
					endif;
				endforeach;
			endif;
			if foundAuditObject &lt;&gt; null then
				app.viewAuditForm(foundAuditObject, CMUI_Assistant, terminal);
			endif;	
		else
			app.msgBox(app.getErrorString(ERR_CAMS_OPENFILE),  app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Information_Icon);
			return;
		endif;
	else
		// find ediData
		create ediAgent transient;
		ediAgent.setMyTerminal(terminal);
		create coll transient;
		coll.add(ediData);
		ediAgent.showEDIFormWithColl(coll, null, false);	
	endif;
epilog
	delete ediAgent;
	delete coll;
end;
</source>
        <Parameter name="theMenuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="54879676-3632-4adf-9788-7e3da8a070de">
        <updating/>
        <source>doSave(): Boolean updating;
//
//10 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//
// 04 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
//
vars
	processInDateOrder : Boolean;
	processInSeqOrder : Boolean;
	theForm	: SOP_TableMaintForm;
	pxyEdiSenderRecip : CM_EDISenderRecipFileType;
begin
	theForm := self.myForm; 
	processInDateOrder := theForm.tblInput1.getValueByName(ETRow_ProcessInDateOrder).Boolean;
	processInSeqOrder := theForm.tblInput1.getValueByName(ETRow_ProcessInSeqOrder).Boolean;
	
	if theForm.myProxyObject = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
		return false;
	endif;

	pxyEdiSenderRecip := theForm.myProxyObject.CM_EDISenderRecipFileType;
	pxyEdiSenderRecip.setForUpdateUser(processInDateOrder, processInSeqOrder);
	
	if theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateEDISendRecipFileType(pxyEdiSenderRecip, null, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
