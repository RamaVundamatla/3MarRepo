    <JadeMethod name="getAmtDPP" id="6bcf4080-5b55-47b0-bd43-37049131fe66">
        <source>getAmtDPP(_invLine : CM_InvoiceLine):Decimal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 October 2018	cnwma1	ChangeRequest 41132: PEL1 - SAP Integration : Additional Changes
18 October 2018 cnwma1	Bug 42945: PEL1 - SAP Integration INT Invoices conversion and rounding
*/

vars
	amtDPP 	: Decimal[23,6];
begin
	//jlier1 TFS 51963 15/10/21
	if _invLine.invoice.bank.code.toUpper.cnContains("DOM") then
		amtDPP       :=  _invLine.lineTotal.roundedTo(0);
	else
		amtDPP       :=  _invLine.getAmountForCurrencyCode("USD").roundedTo(0);
	endif;
	
	return amtDPP;
epilog

end;</source>
        <Parameter name="_invLine" type="CM_InvoiceLine"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getAmtDocCurAR" id="88464bfc-03d6-4bb4-bdd9-d70e905cd277">
        <source>getAmtDocCurAR(_invLine : CM_InvoiceLine):Decimal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 Oct 2018	cnwma1	ChangeRequest 41132: PEL1 - SAP Integration : Additional Changes
22 Nov 2018	cnwma1	ChangeRequest 42118: PEL1 - Generate tax number and invoice date
18 Jan 2018 cnwma1	Bug 42945: PEL1 - SAP Integration INT Invoices conversion and rounding
*/

vars
	amtDocCurAr,
	amtDPP 		 : Decimal[23,6];
	taxCode      : String;
	invoice      : CM_Invoice;
begin

	invoice := _invLine.invoice;
	taxCode := self.getTaxCode(invoice);
	amtDPP  := self.getAmtDPP(_invLine);
	
	if taxCode = "A0" and _invLine.getTaxRateForLine &lt;&gt; 0 then
	
		amtDocCurAr  :=  (amtDPP + ( amtDPP / _invLine.getTaxRateForLine));
	else
		amtDocCurAr  := amtDPP; 
	
	endif;
	
	amtDocCurAr := amtDocCurAr.truncatedTo(1);
	
	return amtDocCurAr;
epilog

end;</source>
        <Parameter name="_invLine" type="CM_InvoiceLine"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getAmtDocCurGL" id="c00a64fb-6267-41ae-af0b-5cdcd5b1bd4f">
        <source>getAmtDocCurGL(_invline : CM_InvoiceLine):Decimal;

/*

Purpose:
	Used to Map the AmtDocCurGL in the GL table for the following WSDL
	
	37189.006 Send Invoice/Data for Pre-Billing Customer
	WSDL 1.5: Pre-Billing - Revenue Journal + Incoming Cash Journal
	PaymentType_PrePay
Parameters:			

Return Value:		


Date		Who		Reason
06 Oct 2018	cnwma1	Initial creation
18 Oct 2018 cnwma1  Bug 42945: PEL1 - SAP Integration INT Invoices conversion and rounding

*/

vars
	amtDocCurGL : Decimal[23,6];
begin
	
	amtDocCurGL := self.getAmtDPP(_invline);
	
	return amtDocCurGL;
epilog

end;</source>
        <Parameter name="_invline" type="CM_InvoiceLine"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getCommodityName" id="d096ab34-58f2-4c48-b7be-94e87d8898ad">
        <source>getCommodityName(_ti : CM_TrackedItem):String;

/*

Purpose:			
SAP COMMODITY CODE		
									DOMESTIK	INTERNASIONAL
OTH_VISIT_04010101	IMPORT 20 FULL	22GENLID	22GENLII

Parameters:			

Return Value:		


Date		Who		Reason
09 October 2018	jlgma1	ChangeRequest 41234: PEL1 - SAP Integration - Mapping fields

*/

vars
	bu 		: CM_Bank;
	str,
 	buStr,
	imexStr : String;
begin
	
	
	if _ti.isContainer then
		//Iso
		if _ti.CM_Container.is20 then
			str :="22";
		elseif _ti.CM_Container.is40 then
			str :="42";
		elseif _ti.CM_Container.is45 then
			str :="45";
		endif;
		//Comm
		str := str &amp;_ti.commodity;
		//imex
		imexStr := _ti.getImExStatusStringDesc(false)[1:1];
		str := str &amp;imexStr;
		//Bank
		buStr := _ti.companyCode[1:1];
		str:= str &amp; buStr;
	else
	
		str := _ti.getCommodityDesc();
	endif;
	
	return str;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDocType" id="d74be150-dcb4-42e0-9dd7-a7609083a436">
        <source>getDocType(_invoice : CM_Invoice;_default : String):String;

/*

Purpose:			
	a.	The "Doc Type" field in WSDL 1.3, WSDL 1.5, and WSDL 1.7 should have a value of "S7" which indicates Invoice Correction if the Invoice is a replacement invoice. 
	b.	When an invoice correction is generated in Master Terminal, SAP will be able to tell that the invoice sent is an invoice correction by the value in the "Doc Type" field and by the value of the original Invoice ID in the "Ref Doc No" field.  

Parameters:			

Return Value:		


Date		Who		Reason
27 September 2018	cnwma1	ChangeRequest 41132: PEL1 - SAP Integration : Additional Changes

*/

vars
	value : String;
begin
	if _invoice.myPostedPendingInvoice &lt;&gt; null then
		value := "S7";
		return value;
	else
		return _default;
	endif;
	
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_default" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEstimationIdString" id="5a9564ac-7e5e-41fc-9c75-beb74af51e3a">
        <source>getEstimationIdString(_activityHistory: CM_ActivityHistoryExtInterface input): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2019	jlgndl1	Initial creation	TFS 46758

*/

vars

	estimationID : String;
	
begin

	if _activityHistory &lt;&gt; null then
		if _activityHistory.myCashReceipt &lt;&gt; null then
			estimationID := _activityHistory.myCashReceipt.externalInvoiceNumber ; 
		endif;
	endif;
	
	return 'Estimation :'	&amp; estimationID;

epilog

end;</source>
        <Parameter name="_activityHistory" type="CM_ActivityHistoryExtInterface" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceIdString" id="fffc84b2-fa3d-4e2d-8b14-35850a23dc96">
        <source>getInvoiceIdString(_activityHistory: CM_ActivityHistoryExtInterface input): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2019	jlgndl1	Initial creation	TFS 46758

*/

vars

	invoiceID : String;
	
begin

	if _activityHistory &lt;&gt; null then
		if _activityHistory.myInvoice &lt;&gt; null then
			invoiceID := _activityHistory.myInvoice.exportCurrencyCode.String; 
		elseif _activityHistory.myCashReceipt &lt;&gt; null then
			if _activityHistory.myCashReceipt.myCashInvoice &lt;&gt; null then
				invoiceID := _activityHistory.myCashReceipt.myCashInvoice.exportCurrencyCode.String; 
			endif;
		endif;
	endif;
	
	return 'Invoice :'	&amp; invoiceID;

epilog

end;</source>
        <Parameter name="_activityHistory" type="CM_ActivityHistoryExtInterface" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMovementForDateTime" id="6bdc8f34-e173-4066-b34d-164b3038a245">
        <source>getMovementForDateTime(_voyage : CM_Voyage ; _dateTime : TimeStamp): HMS_VoyageMovement;

/*

Purpose:			
	This will be used to return the current Movement at the time of the transaction 
	Receive Ship and Release Ship or any 
	Currently it is used to find which berth the cargo was discharged or loaded
	
	Used for following segments
	"profitCtr"               [movementBerth.externalReference1]
	"profitCenter"            [movementBerth.externalReference1]
	"equipmentItem.prodCode"  [movementBerth.externalReference1]
	
	facilityItem.facilityName [movementBerth.externalReference1]
	serviceItem.prodCode      [movementBerth.externalReference1]
	
	copaItem.character        [movementBerth.externalReference3]
	facilityItem.facilityID   [movementBerth.externalReference4]
Parameters:			

Return Value:		


Date		Who		Reason
05 October 2018	jlgma1	ChangeRequest 41132: PEL1 - SAP Integration : Additional Changes

*/

vars
	tmpMovement	: HMS_Movement;

begin
	if _voyage .myHMSVoyageData = null then
		return null;
	endif;

	if _voyage .myHMSVoyageData.allVoyageMovements = null then
		return null;
	endif;
	
	if _voyage .myHMSVoyageData.allVoyageMovements.size &lt; 1 then
		return null;
	endif;
	
	//match movement to date
	return _voyage.myHMSVoyageData.allVoyageMovements.getAtKeyLeq(_dateTime);
	

end;

</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <ReturnType type="HMS_VoyageMovement"/>
    </JadeMethod>
