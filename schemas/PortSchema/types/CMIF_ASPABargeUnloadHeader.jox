    <JadeMethod name="computeAverage" id="c0873e7d-df74-4805-9023-05265afeed6a">
        <source>computeAverage();
/*

Purpose: Compute for the Unload Averages. This is the last step after data gathering.

Parameters:			

Return Value:		

Date		Who		TFS		Reason
19 Aug 2019	jlgdi1	45678	Initial creation

*/

vars
	bargeUnloadDetail : CMIF_ASPABargeUnloadsDetail;
	
begin
	// sections need for average
	// 1. Start - Finish Hours
	// 2. Tons per Hour
	// 3. Arrive to Start
	// 4. Arrive to Place
	// 5. Place to Pull
	foreach bargeUnloadDetail in self.allASPABargeUnloadDetails do
		if bargeUnloadDetail.type = UnloadingBySite then
		
			// 1. Start - Finish Hours
			// 3. Arrive to Start
			// 4. Arrive to Place
			// 5. Place to Pull
			if bargeUnloadDetail.siteWorkPointCountCUR &gt; 0 then 
				bargeUnloadDetail.siteCURAveStartFinishHours := bargeUnloadDetail.siteCURAveStartFinishHours / bargeUnloadDetail.siteWorkPointCountCUR;
				bargeUnloadDetail.siteCURAveArriveStartHours := bargeUnloadDetail.siteCURAveArriveStartHours/ bargeUnloadDetail.siteWorkPointCountCUR;
				bargeUnloadDetail.siteCURAveArrivePlaceHours := bargeUnloadDetail.siteCURAveArrivePlaceHours/ bargeUnloadDetail.siteWorkPointCountCUR;
				bargeUnloadDetail.siteCURAvePlacePullHours := bargeUnloadDetail.siteCURAvePlacePullHours/ bargeUnloadDetail.siteWorkPointCountCUR;
			endif;
			
			if bargeUnloadDetail.siteWorkPointCountMTD &gt; 0 then 
				bargeUnloadDetail.siteMTDAveStartFinishHours := bargeUnloadDetail.siteMTDAveStartFinishHours / bargeUnloadDetail.siteWorkPointCountMTD;
				bargeUnloadDetail.siteMTDAveArriveStartHours := bargeUnloadDetail.siteMTDAveArriveStartHours / bargeUnloadDetail.siteWorkPointCountMTD;
				bargeUnloadDetail.siteMTDAveArrivePlaceHours := bargeUnloadDetail.siteMTDAveArrivePlaceHours / bargeUnloadDetail.siteWorkPointCountMTD;
				bargeUnloadDetail.siteMTDAvePlacePullHours := bargeUnloadDetail.siteMTDAvePlacePullHours / bargeUnloadDetail.siteWorkPointCountMTD;
			endif;
			
			if bargeUnloadDetail.siteWorkPointCountYTD &gt; 0 then 
				bargeUnloadDetail.siteYTDAveStartFinishHours := bargeUnloadDetail.siteYTDAveStartFinishHours / bargeUnloadDetail.siteWorkPointCountYTD;
				bargeUnloadDetail.siteYTDAveArriveStartHours := bargeUnloadDetail.siteYTDAveArriveStartHours / bargeUnloadDetail.siteWorkPointCountYTD;
				bargeUnloadDetail.siteYTDAveArrivePlaceHours := bargeUnloadDetail.siteYTDAveArrivePlaceHours / bargeUnloadDetail.siteWorkPointCountYTD;
				bargeUnloadDetail.siteYTDAvePlacePullHours := bargeUnloadDetail.siteYTDAvePlacePullHours / bargeUnloadDetail.siteWorkPointCountYTD;
			endif;
			
			// 2. Tons Hour
			bargeUnloadDetail.siteCURAveStartFinishTons := self.convertMeasurement(bargeUnloadDetail.siteCURAveStartFinishTons, null);
			bargeUnloadDetail.siteMTDAveStartFinishTons := self.convertMeasurement(bargeUnloadDetail.siteMTDAveStartFinishTons, null);
			bargeUnloadDetail.siteYTDAveStartFinishTons := self.convertMeasurement(bargeUnloadDetail.siteYTDAveStartFinishTons, null);
			
			if bargeUnloadDetail.siteCURAveStartFinishHours &gt; 0 then
				bargeUnloadDetail.siteCURAveStartFinishTonsHour := bargeUnloadDetail.siteCURAveStartFinishTons/ bargeUnloadDetail.siteCURAveStartFinishHours;
			endif;
			if bargeUnloadDetail.siteMTDAveStartFinishHours &gt; 0 then
				bargeUnloadDetail.siteMTDAveStartFinishTonsHour := bargeUnloadDetail.siteMTDAveStartFinishTons/ bargeUnloadDetail.siteMTDAveStartFinishHours;
			endif;
			if bargeUnloadDetail.siteYTDAveStartFinishHours &gt; 0 then
				bargeUnloadDetail.siteYTDAveStartFinishTonsHour := bargeUnloadDetail.siteYTDAveStartFinishTons/ bargeUnloadDetail.siteYTDAveStartFinishHours;
			endif;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="convertMeasurement" id="e1f9b807-6f92-44a2-8af3-9965be23ff85">
        <source>convertMeasurement(_value : Decimal; _toMeasurement : CM_MeasurementType) : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Aug 2019	jlgdi1	Initial creation

*/

vars
	defMeasurement	: CM_MeasurementType;
	defMeasurementTo : CM_MeasurementType;
	newValueString : String;
	newValue : Decimal[23,2];
	
begin
	defMeasurement := app.getDefaultMeasurementForType(Type_Weight);
	
	// if no chosen measurement, use Metric Tons by default
	if _toMeasurement = null then 
		defMeasurementTo := app.myRoot.allMeasurementTypesByShortName["MT"];
	else
		defMeasurementTo := _toMeasurement;
	endif;
	
	if defMeasurementTo &lt;&gt; null then 		
		return app.convertMeasurementFromTo(defMeasurement.shortName, defMeasurementTo.shortName, _value).Decimal;
	else
		return _value;
	endif;
end;</source>
        <Parameter name="_value" type="Decimal"/>
        <Parameter name="_toMeasurement" type="CM_MeasurementType"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getEventTransactionByType" id="67277c38-bc7c-4669-9138-45343073311c">
        <source>getEventTransactionByType(_voyage : CM_Voyage; _eventType : Integer) : CM_EventTransaction;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		TFS		Reason
19 Aug 2019	jlgdi1	45678	Initial creation

*/

vars
	eventTransaction : CM_EventTransaction;
	iter : Iterator;

begin
	iter := _voyage.allEventTransactionsByType.createIterator();
	_voyage.allEventTransactionsByType.startKeyGeq(_eventType, null, iter);
	while iter.next(eventTransaction) do 
		if eventTransaction.type &lt;&gt; _eventType then 
			break;
		else
			return eventTransaction;
		endif;
	endwhile;
	
	return null;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_eventType" type="Integer"/>
        <ReturnType type="CM_EventTransaction"/>
    </JadeMethod>
    <JadeMethod name="getHoursDuration" id="4c68845b-92a6-4b0a-b495-43d275e6274e">
        <source>getHoursDuration(_startTimeStamp : TimeStamp; _endTimeStamp : TimeStamp) : Decimal;
/*

Purpose: Returns the difference of two timestamp in hours

Parameters:			

Return Value:		

Date		Who		TFS		Reason
19 Aug 2019	jlgdi1	45678	Initial creation

*/

vars
	timeInterval : TimeStampInterval;
	
begin
	timeInterval := _endTimeStamp - _startTimeStamp;
	return timeInterval.getMilliseconds() / MillisecondsPerHour;
end;</source>
        <Parameter name="_startTimeStamp" type="TimeStamp"/>
        <Parameter name="_endTimeStamp" type="TimeStamp"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getMonthToDate" id="8a4339e5-f461-447b-9ac6-665b10d0f953">
        <source>getMonthToDate(_runDate : TimeStamp) : TimeStamp;
/*

Purpose:

Parameters:			

Return Value:		

Date		Who		TFS		Reason
16 Aug 2019	jlgdi1	45678	Initial creation

*/

vars
	firstOfMonth : TimeStamp;
begin
	firstOfMonth.setDate(_runDate.date.cnEcGetFirstDayOfMonth);
	firstOfMonth.setTime(_runDate.time.addMinutes(OneMinute));
	
	return firstOfMonth;
end;</source>
        <Parameter name="_runDate" type="TimeStamp"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getPrev24Hrs" id="447a8d9c-d84e-4150-8c59-399fa8dcb1bd">
        <source>getPrev24Hrs(_runDate : TimeStamp) : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		TFS		Reason
16 Aug 2019	jlgdi1	45678	Initial creation

*/
	
vars
	prev24Hours : TimeStamp;
	
begin
	prev24Hours := _runDate.subtractHoursAndMinutes(Hour24);
	return prev24Hours.addMinutes(OneMinute);
end;</source>
        <Parameter name="_runDate" type="TimeStamp"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getRunDateTime" id="602a1aea-dfcd-4875-965f-1e00f3eea202">
        <source>getRunDateTime() : TimeStamp;
/*

Purpose: Get the run date based on the report parametets

Parameters:			

Return Value:		

Date		Who		TFS		Reason
19 Aug 2019	jlgdi1	45678	Initial creation

*/

vars
	runDate : TimeStamp;
	
begin
	runDate.setDate(self.dateToRun);
	runDate.setTime(self.timeToRun);
	return runDate;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getTotalDelays" id="3041ffd1-2f4c-47d8-9274-a7f91cd7b565">
        <source>getTotalDelays(_workPoint : CM_WorkPoint;
			   _startVoyageOperation : TimeStamp;
			   _finishVoyageOperation : TimeStamp) : Decimal;
/*

Purpose: Get total delay duration with in the Voyage Operation (start - finish) in work point

Parameters:			

Return Value:		

Date		Who		TFS		Reason
19 Aug 2019	jlgdi1	45678	Initial creation

*/

vars
	delay : CM_Delay;
	duration : Decimal[23,2];
	
begin
	foreach delay in _workPoint.allDelays do 
		if (delay.startDT &gt;= _startVoyageOperation) and (delay.endDT &lt;= _finishVoyageOperation) then
			duration := duration + delay.getDelayDuration;
		endif;
	endforeach;
	
	return duration;
end;</source>
        <Parameter name="_workPoint" type="CM_WorkPoint"/>
        <Parameter name="_startVoyageOperation" type="TimeStamp"/>
        <Parameter name="_finishVoyageOperation" type="TimeStamp"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getUnloadTonsPerHour" id="322af145-3fe0-4601-a36b-0c06b5479d30">
        <source>getUnloadTonsPerHour(_voyage : CM_Voyage;
					 _startOperation : TimeStamp;
					 _finishOperation : TimeStamp;
					 _runDate : TimeStamp;
					 _tonsCur : Decimal io;
					 _tonsMTD : Decimal io;
					 _tonsYTD : Decimal io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2019	jlgdi1	Initial creation

*/

vars
	jobSheet : CM_VoyageJobSheet;
	tiTransaction : CM_TITransaction;
	receiveShip : CM_ReceiveShip;
	machineMove : CM_MachineMoveHistory;
	runDate : TimeStamp;
	transDateTime : TimeStamp;
	
begin
	foreach jobSheet in _voyage.allJobSheets do 
		if jobSheet.isKindOf(CM_VoyageJobSheet) then
			if jobSheet.allShipReceivals.size &gt; 0 then
				foreach tiTransaction in jobSheet.allShipReceivals do 
					if tiTransaction.isKindOf(CM_ReceiveShip) then 
						receiveShip := tiTransaction.CM_ReceiveShip;
						transDateTime := receiveShip.dateTime;						
						if (transDateTime &gt;= _startOperation) and (transDateTime &lt;= _finishOperation) then
							if withinCurrent(transDateTime, runDate) then 
								_tonsCur := _tonsCur + receiveShip.totalWeight;
							endif;
							if withinMTD(transDateTime, runDate) then 
								_tonsMTD := _tonsMTD + receiveShip.totalWeight;
							endif;
							if withinYTD(transDateTime, runDate) then 
								_tonsYTD := _tonsYTD + receiveShip.totalWeight;
							endif;
						endif;
					endif;
				endforeach;
			endif;
		endif;
	endforeach;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_startOperation" type="TimeStamp"/>
        <Parameter name="_finishOperation" type="TimeStamp"/>
        <Parameter name="_runDate" type="TimeStamp"/>
        <Parameter name="_tonsCur" type="Decimal" usage="io"/>
        <Parameter name="_tonsMTD" type="Decimal" usage="io"/>
        <Parameter name="_tonsYTD" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getYearToDate" id="9b39e433-4a96-4909-a803-4d1c42bed567">
        <source>getYearToDate(_runDate : TimeStamp) : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		TFS		Reason
16 Aug 2019	jlgdi1	45678	Initial creation

set based on Report Parameter , remove constant for the meantime

*/

vars
	startOfTheYear : Date;
	yearToDate : TimeStamp;
	
	startDay : Integer;
	startMonth : Integer;
begin
	startDay := self.dateYearStart.day();
	startMonth := self.dateYearStart.month();
	
	startOfTheYear.setDate(startDay, startMonth, _runDate.date.year - 1);
	yearToDate.setDate(startOfTheYear);
	yearToDate.setTime(_runDate.time.addMinutes(OneMinute));
	
	return yearToDate;
end;</source>
        <Parameter name="_runDate" type="TimeStamp"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="init" id="a827ee8a-22c3-4dfa-bc64-120798680b24">
        <updating/>
        <source>init(_dateToRun : Date;
	 _timeToRun : Time;
	 _dateYearStart : Date;
	 _allTerminals : CM_TerminalByCodeDict;
	 _allBargeVessels : CM_VesselSet;	 
	 _allUnloadEvents : CM_EventTypeByCatDict;
	 _eventStart : CM_EventType;
	 _eventFinish : CM_EventType;
	 _eventPlaced : CM_EventType;
	 _eventPulled : CM_EventType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2019	jlgdi1	Initial creation

*/
vars 
	allTerminals : CM_TerminalByCodeDict;
	allVessels : CM_VesselSet;
	allUnloadEvents : CM_EventTypeByCatDict;
begin
	create allTerminals transient;
	create allVessels transient;
	create allUnloadEvents transient;
	
	self.dateToRun := _dateToRun;
	self.timeToRun := _timeToRun;
	self.dateYearStart := _dateYearStart;
	
	_allTerminals.copy(allTerminals);
	self.allTerminals := allTerminals;
	
	_allBargeVessels.copy(allVessels);
	self.allBargeVessels := allVessels;
	
	_allUnloadEvents.copy(allUnloadEvents);	
	self.allUnloadEvents := allUnloadEvents;
	
	self.myEventStart := _eventStart;
	self.myEventFinish := _eventFinish;
	self.myEventPlaced := _eventPlaced;
	self.myEventPulled := _eventPulled;
end;</source>
        <Parameter name="_dateToRun" type="Date"/>
        <Parameter name="_timeToRun" type="Time"/>
        <Parameter name="_dateYearStart" type="Date"/>
        <Parameter name="_allTerminals" type="CM_TerminalByCodeDict"/>
        <Parameter name="_allBargeVessels" type="CM_VesselSet"/>
        <Parameter name="_allUnloadEvents" type="CM_EventTypeByCatDict"/>
        <Parameter name="_eventStart" type="CM_EventType"/>
        <Parameter name="_eventFinish" type="CM_EventType"/>
        <Parameter name="_eventPlaced" type="CM_EventType"/>
        <Parameter name="_eventPulled" type="CM_EventType"/>
    </JadeMethod>
    <JadeMethod name="processBargeVessels" id="0d1f7862-af3e-4b1c-bba8-7543eccbb2bc">
        <source>processBargeVessels();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		TFS		Reason
16 Aug 2019	jlgdi1	45678	Initial creation

*/

vars
	vessel : CM_Vessel;
	
begin
	// process vessels based on Report Parameters
	foreach vessel in self.allBargeVessels do 
		self.processVoyages(vessel);
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="processEventTransactions" id="d228b25a-2a8f-416d-b0db-8d05ab8aed0c">
        <source>processEventTransactions(_voyage : CM_Voyage);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2019	jlgdi1	Initial creation

*/

vars
	eventTransaction : CM_EventTransaction;
	iter : Iterator;
	dateYearStart : TimeStamp;
	runDate : TimeStamp;
	
begin
	runDate := self.getRunDateTime();
	dateYearStart := self.getYearToDate(runDate);
	
	iter := _voyage.allEventTransactionsByDateTime.createIterator();
	_voyage.allEventTransactionsByDateTime.startKeyGeq(dateYearStart, iter);
	while iter.next(eventTransaction) do 
		if eventTransaction.dateTime &gt; runDate then
			break;
		endif;
		
		if eventTransaction.isVoyageEvent() then
			// Report Detail One
			self.summarizeBargeUnloads(eventTransaction);
			
		endif;
	endwhile;

epilog
	delete iter;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="processVoyages" id="68aaf359-ff9d-4f80-8a87-400daf82d098">
        <source>processVoyages(_vessel : CM_Vessel);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2019	jlgdi1	Initial creation

*/

vars
	iter : Iterator;
	terminal : CM_Terminal;
	voyage : CM_Voyage;
	
begin
	foreach voyage in _vessel.allVoyagesByTermCodeArrival do
		terminal := voyage.myTerminal;
		if self.allTerminals.includes(terminal) then
			// Report Detail Two (Barges Currently Available) - arrived but not departed
			self.summarizeAvailableForUnload(voyage);
		
			// Report Detail Three - must have hold jobs
			self.summarizeUnloadsBySite(voyage);
		
			self.processEventTransactions(voyage);
		endif;
	endforeach;
	
	self.computeAverage();
	
epilog
	delete iter;
end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="summarizeAvailableForUnload" id="b875c18b-2703-4bfc-bc20-7ee398e5d39f">
        <source>summarizeAvailableForUnload(_voyage : CM_Voyage);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2019	jlgdi1	Initial creation

*/

vars
	arrivedEvent : CM_EventType;
	departedEvent : CM_EventType;
	cargo : CM_TrackedItem;
	
begin
	arrivedEvent := app.myRoot.allEventTypesByType[EVT_VoyageArrival];
	departedEvent := app.myRoot.allEventTypesByType[EVT_VoyageDeparture];
	if (_voyage.hasEventOfType(arrivedEvent)) and not (_voyage.hasEventOfType(departedEvent)) then 
		// OnShip
		if _voyage.allOnshipTIsByCargoTypeId.size &gt; 0 then
			cargo := _voyage.allOnshipTIsByCargoTypeId.first();
			updateAvailableForUnload(cargo);
		endif;
		
		// OnSite
		if _voyage.allOnsiteTIsByCargoTypeId.size &gt; 0 then
			cargo := _voyage.allOnsiteTIsByCargoTypeId.first();
			updateAvailableForUnload(cargo);
		endif;
		
		// OffSite
		if _voyage.allOffsiteTIsByCargoTypeId.size &gt; 0 then
			cargo := _voyage.allOffsiteTIsByCargoTypeId.first();
			updateAvailableForUnload(cargo);
		endif;
	endif;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="summarizeBargeUnloads" id="8a89540b-6024-4b05-b8d2-de66f671f6ee">
        <source>summarizeBargeUnloads(_eventTransaction : CM_EventTransaction);
/*

Purpose: Report Detail One

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2019	jlgdi1	Initial creation

*/

vars
	eventType : CM_EventType;
	
begin
	eventType := _eventTransaction.myEventType;	
	if self.allUnloadEvents.includes(eventType) then
	   updateBargeUnloads(_eventTransaction);
	endif;
end;</source>
        <Parameter name="_eventTransaction" type="CM_EventTransaction"/>
    </JadeMethod>
    <JadeMethod name="summarizeUnloadsBySite" id="ea7f4898-0a56-4ea4-b1ff-cf75827fd0c2">
        <source>summarizeUnloadsBySite(_voyage : CM_Voyage);
/*

Purpose: Report Detail # 3 - Barges Unload by Site/Work Point
		 

Parameters:			

Return Value:		

Date		Who		TFS#	Reason
16 Aug 2019	jlgdi1	45678	Initial creation
12 Nov 2019	jlgdi1	47290	Added condition check to include jobsheet having ship receival only
*/

vars
	jobsheet : CM_VoyageJobSheet;
	
begin
	if _voyage.allJobSheets.size &gt; 0 then 
		foreach jobsheet in _voyage.allJobSheets do 
			// process if voyage hold job type
			if (jobsheet.isKindOf(CM_VoyageHoldJobSheet)) and 
			   (jobsheet.myWorkPoint &lt;&gt; null) and 
			   (jobsheet.allShipReceivals.size &gt; 0)
			then 
				self.updateUnloadsBySite(jobsheet.myWorkPoint, _voyage);
				break;
			endif;
		endforeach;
	endif;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="updateArriveToPlaceHours" id="93f8780f-61e3-4966-9a8f-69b28441c82c">
        <source>updateArriveToPlaceHours(_bargeUnloadDetail : CMIF_ASPABargeUnloadsDetail io;
						 _referenceDate : TimeStamp;
						 _runDate : TimeStamp;
						 _unLoadHrLessDelay : Decimal);
/*

Purpose: Barge Unload Hours from Arrive Operation to Place Operation (minus delay)

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2019	jlgdi1	Initial creation
10 Sep 2019	jlgsl4	TFS 46513 - ASPA - Load/Unload Summary Report errors
*/

begin
	if _bargeUnloadDetail = null then // --&gt; TFS 46513 - don't use _bargeUnloadDetail if null
		return;
	endif; // &lt;-- TFS 46513
	if withinCurrent(_referenceDate, _runDate) then 
		_bargeUnloadDetail.siteCURAveArrivePlaceHours := _bargeUnloadDetail.siteCURAveArrivePlaceHours + _unLoadHrLessDelay;
	endif;
	if withinMTD(_referenceDate, _runDate) then 
		_bargeUnloadDetail.siteMTDAveArrivePlaceHours := _bargeUnloadDetail.siteMTDAveArrivePlaceHours + _unLoadHrLessDelay;
	endif;
	if withinYTD(_referenceDate, _runDate) then 
		_bargeUnloadDetail.siteYTDAveArrivePlaceHours:= _bargeUnloadDetail.siteYTDAveArrivePlaceHours + _unLoadHrLessDelay;
	endif;
end;</source>
        <Parameter name="_bargeUnloadDetail" type="CMIF_ASPABargeUnloadsDetail" usage="io"/>
        <Parameter name="_referenceDate" type="TimeStamp"/>
        <Parameter name="_runDate" type="TimeStamp"/>
        <Parameter name="_unLoadHrLessDelay" type="Decimal"/>
    </JadeMethod>
