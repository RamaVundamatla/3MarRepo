    <JadeMethod name="addError" id="3fcd139d-30d8-43ab-9da5-33f3fd6b6261">
        <source>addError(_errorNum: Integer; _errorDescr: String; _errorMsgs: DTO_HandHeldGateErrorDict input) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2010	cnwer1	Initial creation

*/

vars

begin
	if self.myVMInterface = null then
		if _errorMsgs &lt;&gt; null then
			inheritMethod(_errorNum,_errorDescr,_errorMsgs);
		endif;
	else
		
		self.myVMInterface.doSendErrorMessage(app.getErrorString(Error),_errorDescr);
	endif;
	//inheritMethod(_errorNum, _errorDescr, _errorMsgs);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_errorNum" type="Integer"/>
        <Parameter name="_errorDescr" type="String"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="allowChangeGetTaskMode" id="38e5bc43-548d-4e4f-bce9-b616c8a0a164">
        <methodInvocation>mapping</methodInvocation>
        <source>allowChangeGetTaskMode(set : Boolean; _value : Boolean io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2010	cnwer1	Initial creation

*/

vars

begin
	
	if self.myMachine = null or
		self.myRTVehicleConfig = null then
		_value:=false;
		return;
	endif;
	
	
	if self.myMachine.machineType = MACHINETYPE_IMV then
		_value:=false;
	else
		_value:=self.myRTVehicleConfig.taskViewMode = CM_RTVehicleConfig.TASKVIEW_BOTH;
	
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
