    <JadeMethod name="getCargoTypes" id="d7c6eb66-4cca-4f0d-b68e-b5749a3bfca0">
        <source>getCargoTypes() : IntegerArray;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2023	navmv20	Bug 60677: FR | EUP 54086 - Invoicing Maintenance enhancements - Selector Query - Invoice mode

*/

vars
	cargoTypeArray : IntegerArray;
	invoiceLine : CM_InvoiceLine;
	cargoType : Integer;
begin
	create cargoTypeArray transient;
	foreach invoiceLine in self.invoiceLines do
		cargoType := invoiceLine.getTrackedItemCargoType();
		if cargoType &lt;&gt; null and not cargoTypeArray.includes(cargoType) then
			cargoTypeArray.add(cargoType);
		endif;
	endforeach;
	return cargoTypeArray;
epilog

end;</source>
        <ReturnType type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="getCargoWeighedWarning" id="dc419a07-68d0-4b00-8db5-41976b68f066">
        <source>getCargoWeighedWarning();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 July 2019	jlgndl1	Initial creation	TFS 44965
19 Aug 2019		NDL - rewrite to combine 'same id' but different cargo objects into one line now. 

*/

vars

	finIOClass : CM_ExtFinanceIO;
	invLine : CM_InvoiceLine;
	tiArray : CM_TIArray;
	tiIdArray : StringArray;
	ti : CM_TrackedItem;
	trx : CM_TITransaction;
	tiInvLineTrxWeightArray : DecimalArray;
	tiWeighedAtWeightArray : DecimalArray;
	tiIdGatedWeightArray : DecimalArray;
	tiIdInvoiceWeightArray : DecimalArray;
	invLineUsedArray : ObjectArray;	//08 Aug 2019	NDL	TFS 44965, need to check trx Type and invLine Type, not just trx type
	index : Integer;
	commodity : CM_Commodity;
	tiId : String;
	invoicedWeight : Decimal[14,4];
	weighedAtWeight : Decimal[16,4];
	usedInvLine : CM_InvoiceLine;	//08 Aug 2019	NDL	TFS 44965, need to check trx Type and invLine Type, not just trx type
	tiIdIndex : Integer;
	tiIdGatedWeight : String;
	tiIdInvoiceWeight : String;
	
begin

	finIOClass := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	if finIOClass = null or not finIOClass.isKindOf( CM_Pelindo1Interface ) then
		return;
	endif;
	
	if not isCargoInvoice then
		return;
	endif;
	
	create tiArray transient;
	create invLineUsedArray transient;
	create tiInvLineTrxWeightArray transient;
	create tiWeighedAtWeightArray transient;
	
	//1/. get an array of unique cargo items based on the invoice lines that are marked as require weighing
	//2/. get the weight of each cargo item from the inv line transaction (so that we only pick up the weight of the bit being moved/received at the time when dealing with split-able)
	//3/. get the total of the 'weighed at' transactions for cargo for that 'id' (when its split-able) i.e. on-site and off-site
	foreach invLine in self.invoiceLines discreteLock do
		ti := invLine.trackedItem;
		trx := invLine.myTransactionTI;
		if trx = null then
			continue;
		endif;
		if ti = null then
			ti := trx.myTrackedItem;
		endif;
		if ti = null then
			continue;
		endif;
		if not ti.myCargoType.requiresWeighing then
			continue;
		endif;
		commodity := ti.getCommodityObject();
		if commodity &lt;&gt; null then
			if not commodity.requiresWeighing then
				continue;
			endif;
		endif;
		
		if not tiArray.includes( ti ) then
			tiArray.add( ti );
			index := tiArray.size;
			invLineUsedArray.add( invLine );
			tiInvLineTrxWeightArray.add( trx.totalWeight );
			tiWeighedAtWeightArray.add( self.myTerminal.getWeighedAtWeightForId( ti ) );
			
		elseif ti.myCargoType.allowDuplicates then
			index := tiArray.indexOf( ti );
			usedInvLine := invLineUsedArray[index].CM_InvoiceLine;
			if usedInvLine &lt;&gt; null
			and usedInvLine.myTransactionTI.type = trx.type
			and usedInvLine.invoiceLineDesc = invLine.invoiceLineDesc
			then
				//same trx type AND same inv line type, means we need to add the trx weight of this bit too.
				tiInvLineTrxWeightArray[index] := tiInvLineTrxWeightArray[index] + trx.totalWeight;
			endif;
			
		endif;

	endforeach;
	
	//Now combine like cargo ids. ( I.e. 3 trucks out with the same id  would be 3 distinct cargo items needing to merge);
	create tiIdArray transient;
	create tiIdGatedWeightArray transient;
	create tiIdInvoiceWeightArray transient;
	
	foreach index in 1 to tiArray.size do
		// get the data to potentially combine
		tiId := tiArray[ index ].id;
		invoicedWeight := tiInvLineTrxWeightArray[ index ];
		weighedAtWeight := tiWeighedAtWeightArray[ index ];
		
		///establish if we already have this id...
		tiIdIndex := tiIdArray.indexOf( tiId );
		if tiIdIndex &lt; 1 then
			//no we don't set up the first one
			tiIdArray.add( tiId );
			tiIdGatedWeightArray.add( weighedAtWeight );
			tiIdInvoiceWeightArray.add( invoicedWeight );
		else
			//yes we do, just add the invoiced weight for this one,
			//the gated weight is already terminal wide for this id, see "self.myTerminal.getWeighedAtWeightForId( ti )" above.
			tiIdInvoiceWeightArray[tiIdIndex] := ( tiIdInvoiceWeightArray[tiIdIndex] + invoicedWeight );
		endif;
	endforeach;
	
	// now raise the combined value warnings 
	foreach index in 1 to tiIdArray.size do
		tiId := tiIdArray[ index ];
		tiIdGatedWeight := tiIdGatedWeightArray[ index ].Integer.String;
		tiIdInvoiceWeight := tiIdInvoiceWeightArray[ index ].Integer.String;
	//	write "Cargo Item '" &amp; tiId &amp; "', Weighed at : " &amp; tiIdGatedWeight &amp; " kg, Invoiced for : " &amp; tiIdInvoicedWeight &amp; " kg";
		app.raiseCMWarning3( Cargo_weighed_invoiced, tiId, tiIdGatedWeight, tiIdInvoiceWeight, null, null, null );
	endforeach;
	

epilog

	delete tiArray;
	delete tiIdArray;
	delete tiInvLineTrxWeightArray;
	delete tiWeighedAtWeightArray;
	delete invLineUsedArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="getCashAsSummaryStats" id="28ea07a6-c518-49f6-aef6-38fed9b3660c">
        <source>getCashAsSummaryStats(glSumm : CM_GLSummaryByGLCodeRateDict input);
// add a cash CM_GLSummary for the total cash payments, if any, for invoice extract
vars
//	total	: Decimal[12,2];
	glCode	: String;
	gl : CM_GLSummary;
	total	: Decimal[16,2];	//11 May 2018	NDL	TFS 38528

begin
	total := self.getCashPaid();
	if total = 0 then
		return;
	endif;

	create gl transient;
	glCode := self.myTerminal.getConfig(CashACforGL).String;	// 31427
	gl.glCode := glCode;
	gl.amount := -total;
	glSumm.add(gl);

end;</source>
        <Parameter name="glSumm" type="CM_GLSummaryByGLCodeRateDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCashPaid" id="d4176d85-2e83-4728-8171-3f1124509f15">
        <source>getCashPaid() : Decimal;

vars
	payment	: CM_CashPayment;
	//total	: Decimal[16,6];
	total	: Decimal[23,6];	//11 May 2018	NDL	TFS 38528
begin
	foreach payment in self.allCashPayments do
		// 35232 skip voided payments
		if payment.voided then
			continue;
		endif;
		total := total + payment.cashValue;
	endforeach;
	
	return total;
end;
</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
