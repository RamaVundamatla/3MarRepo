    <JadeMethod name="translateForm" id="2de89c91-c789-4c85-a62b-54cd1d1cacdb">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 30 January 2018 11:14:54.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014257, locale);
	chkIsCertified.translateCaption(Xlat_0014258, locale);
	lblAuthor.translateCaption(Xlat_0021253, locale);
	lblCargoWeight.translateCaption(Xlat_0022190, locale);
	lblCertify.translateCaption(Xlat_0021254, locale);
	lblIsCertified.translateCaption(Xlat_0014259, locale);
	lblTareWeight.translateCaption(Xlat_0022191, locale);
	lblTotalWeight.translateCaption(Xlat_0014260, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
