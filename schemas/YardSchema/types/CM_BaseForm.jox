<GUIClass name="CM_BaseForm">
    <JadeMethod name="doWagonColorCode" id="3314a41a-7c99-499a-91c0-c33411e08a0d">
        <source>doWagonColorCode(_wagon: CM_Wagon input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwndl1	Initial creation

*/

vars
	wagonColl : ObjectSet;
begin

	create wagonColl transient;
	wagonColl.add(_wagon);
	
	self.myAssistant.YRD_Assistant.showColorCodeWagons(wagonColl, self.myMasterMenuAction);
	
epilog
	delete wagonColl;
end;</source>
        <Parameter name="_wagon" type="CM_Wagon" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doWagonColourCodeRemove" id="1d39dbf4-a57f-447d-9fa6-d6d2a70ba222">
        <source>doWagonColourCodeRemove( wagonColl : ObjectSet io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwndl1	Initial creation

*/

vars
	
begin

	if warnedOfNoSelectedData( wagonColl, app.getErrorString(Wagon) ) then
		return;
	endif;
	
	if  app.msgBox(app.getErrorString(Sure_that_wish_remov_colou_cod), app.getErrorString(Colour_coding), MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	
	app.myTrxDA.trxDeleteRailAllocsForWagons(wagonColl, app.myPassport);
	
epilog
	
end;</source>
        <Parameter name="wagonColl" type="ObjectSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="gridAreaMultiDragCargoSort" id="cd4402d0-016e-481b-935a-b8a7e60299db">
        <source>gridAreaMultiDragCargoSort( _win: Window input;
							_allCargoUNSorted : CM_TIArray;
							_allCargoSorted : CM_TIArray io
							);

/*

Purpose:			

Parameters:		We are in the throws of a drag and drop for multiple cargo items, and need to work out the order to 
				process the cargo so as to get teh bext chance of producing moves that are in a logical order that will work
				( without producing overstow moves ).

Return Value:		


Date		Who		Reason
26 August 2011	cnwndl1	Initial creation	Par 28035

*/

vars

	firstSourceLocation : CM_LocationsController;
	sourceTermArea : CM_TerminalArea;
	contForm : CM_ContainerEnqForm;

begin

	if _win.isKindOf(CMUI_GridAreaFrame) and _win.CMUI_GridAreaFrame.form.isKindOf(YRD_RailOperationsForm) then
		// We are doing a Drag and Drop of multiple cargo items from the Rail Operationss form
		self.myAssistant.doReorderCargoLongestFirst( _allCargoUNSorted, _allCargoSorted );
		
	else
		// Multi cargo Drag and Drop from a Source that is NOT Rail Operations...
		if not _allCargoUNSorted.isEmpty then
		
			if _win.isKindOf(CM_DataTable) then
				if _win.CM_DataTable.form.isKindOf(CM_ContainerEnqForm) then
					contForm := _win.CM_DataTable.form.CM_ContainerEnqForm;
				endif;
			endif;
			
			firstSourceLocation := _allCargoUNSorted.first.CM_TrackedItem.myPrimaryActualLocation;
			if contForm &lt;&gt; null then
				// the source is the cargo enquiry form, could be cargo from any location !!!
				_allCargoUNSorted.copy( _allCargoSorted );	// could be any kind of mixture you get what you got.
				
			elseif firstSourceLocation &lt;&gt; null and firstSourceLocation.isKindOf( CM_SlotController ) then
				// source of drag and drop is on a ship, sort into planned discharge sequenece order within job.
				self.myAssistant.doReorderCargoShipJobSequence( _allCargoUNSorted, _allCargoSorted );
				
			elseif firstSourceLocation &lt;&gt; null and firstSourceLocation.myTerminalArea &lt;&gt; null then
				// source of drag and drop is a terminal area, sort in decking out order based on the ternminal area.
				sourceTermArea := firstSourceLocation.myTerminalArea;
				sourceTermArea.setCargoArrayInDeckOutOrder(_allCargoUNSorted, _allCargoSorted);
				
			else
				// none of the above take it as it is.
				_allCargoUNSorted.copy( _allCargoSorted );
				
			endif;
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="_win" type="Window" usage="input"/>
        <Parameter name="_allCargoUNSorted" type="CM_TIArray"/>
        <Parameter name="_allCargoSorted" type="CM_TIArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="gridAreaMultiDragGetCargoMode" id="6daf57ee-b1f3-4368-ac7d-205e5bba03b2">
        <source>gridAreaMultiDragGetCargoMode( 	_win: Window input;
								_moveMode : Integer output;
								_theTIs : CM_TIArray io
								);

/*

Purpose:			

Parameters:		We are doing a cargo drag and drop and need to get the collection of cargo involved
				to see if its actually a 'multi cargo' drag and drop targeting a gridded area...	

Return Value:		


Date		Who		Reason
26 August 2011	cnwndl1	Initial creation	Par 28035

*/

constants
	WorkMode_Plan : Integer = 2; // Same value as used as on SHP_VoyageAreaForm2
vars

	baseForm : CM_BaseForm;
	displayMode : Integer;
	workingMode : Integer;
	gridDrawCont : CMUI_GridDrawingController;
	railOpsForm : YRD_RailOperationsForm;
	sourceGridAreasForm : YRD_GridAreasForm;
	obj : Object;
	sourceDrawingController : CMUI_GridDrawingController;

begin

	if  ( 	_win.isKindOf(CMUI_GridAreaDrawingFrame)
			and _win.CMUI_GridAreaDrawingFrame.form &lt;&gt; null
			and _win.CMUI_GridAreaDrawingFrame.form.name = "SHP_VoyageAreaForm2"
		) then
			// Ok this is a SHP_VoyageAreaForm2 down in the ShipSchema that we can't see...
			baseForm := _win.CMUI_GridAreaDrawingFrame.form.CM_BaseForm;
			if baseForm.getShipVoyFormDispAndWorkModes(displayMode,workingMode) then
				if displayMode = ShpDisplayMode_ColCodeDisch	// Ship discharge
				and workingMode = WorkMode_Plan	// Planning mode
				then
					//SHP_VoyageAreaForm2 is in Discharge Planning mode, the drawing controller will be the subclass SHP_BayDrawingFrame
					gridDrawCont := _win.CMUI_GridAreaDrawingFrame.getMyBayDrawingController;
					if gridDrawCont &lt;&gt; null then
						_moveMode := PLANNING_MODE;
						gridDrawCont.getAllSelectedDischgPlanTis(_theTIs);
					endif;
				endif;
			endif;
		
	elseif _win.isKindOf(CMUI_GridAreaFrame) and _win.CMUI_GridAreaFrame.form.isKindOf(YRD_RailOperationsForm) then
		// multi cargo move from Rail Operations.
		railOpsForm := _win.CMUI_GridAreaFrame.form.YRD_RailOperationsForm;
		_moveMode := railOpsForm.moveModeForm;
		railOpsForm.getAllSelectedTIs(_theTIs);
		
	elseif _win.isKindOf(CMUI_GridAreaDrawingFrame) and _win.CMUI_GridAreaDrawingFrame.form.isKindOf(YRD_GridAreasForm) then
		// multi cargo move from Yard Grid Areas Form.
		// source of drag is not necessarily the same form we are on.
		sourceGridAreasForm := _win.CMUI_GridAreaDrawingFrame.form.YRD_GridAreasForm;
		_moveMode := sourceGridAreasForm.moveModeForm;
		// source of drag is not necessarily the last frame traversed over by the mouse, or even the same form.
		foreach obj in sourceGridAreasForm.allDrawingControllers do
			gridDrawCont := obj.CMUI_GridDrawingController; 
			if gridDrawCont.allSelectedObjects.includes(app.myDraggedTrackedItem) then
				sourceDrawingController := gridDrawCont;
				break;
			endif;
		endforeach;
		if sourceDrawingController &lt;&gt; null then
			sourceDrawingController.getAllSelectedTIs(_theTIs);
		endif;
		
	elseif _win.isKindOf(CM_DataTable) and _win.CM_DataTable.form.isKindOf(CM_ContainerEnqForm) then
		_moveMode := _win.CM_DataTable.form.CM_BaseForm.getMoveMode;
		if _moveMode = PLANNING_MODE or _moveMode = QUEUE_MODE then
			foreach obj in _win.CM_DataTable.allSelectedObjects do
				if obj.isKindOf( CM_TrackedItem ) then
					_theTIs.addExclusive( obj.CM_TrackedItem );
				endif;
			endforeach;
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="_win" type="Window" usage="input"/>
        <Parameter name="_moveMode" type="Integer" usage="output"/>
        <Parameter name="_theTIs" type="CM_TIArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="gridAreaMultiDragUnsortedFilta" id="6fc0f279-0fa1-4f01-b94f-f91b40bfa974">
        <source>gridAreaMultiDragUnsortedFilta(	_allCargoUNSorted : CM_TIArray io;
								_theTIs : CM_TIArray input;
								_theDragTI : CM_TrackedItem;
								_moveMode : Integer
								):Boolean;

/*

Purpose:			

Parameters:			
				We are doing a multi cargo move to a gridded area and need to sort out any cargo that we
				shouldn't allow to be selected.... because it is alreday planned or queued and we are in
				that mode...
Return Value:		


Date		Who		Reason
26 August 2011	cnwndl1	Initial creation	Par 28035

*/

vars

	ti : CM_TrackedItem;
	msg : String;
	includesQueued : Boolean;
	includesPlanned : Boolean;
	queuedCount : Integer;
	plannedCount : Integer;

begin

	
	if _theDragTI &lt;&gt; null then
		//19 Dec 2011	NDL	Par 28821
		if _theTIs = null or not _theTIs.includes(_theDragTI) then // because otherwise we could change the order.  Which is only important
																	// if we don't end up sorting into a decking order....
			if _moveMode = QUEUE_MODE then
				if not _theDragTI.isQueued then
					_allCargoUNSorted.add(_theDragTI);
				else
					includesQueued := true;
					queuedCount := queuedCount + 1;
				endif;
			elseif _moveMode = PLANNING_MODE then
				if not _theDragTI.isPlanned(PLANNING_MODE) then
					_allCargoUNSorted.add(_theDragTI);
				else
					includesPlanned := true;
					plannedCount := plannedCount + 1;
				endif;
			endif;
			
		endif;
	endif;
	
	if _theTIs &lt;&gt; null then
		foreach ti in _theTIs do
			if _moveMode = QUEUE_MODE then
				if not ti.isQueued then
					_allCargoUNSorted.addExclusive(ti);
				else
					includesQueued := true;
					queuedCount := queuedCount + 1;
				endif;
			elseif _moveMode = PLANNING_MODE then
				if not ti.isPlanned(PLANNING_MODE) then
					_allCargoUNSorted.addExclusive(ti);
				else
					includesPlanned := true;
					plannedCount := plannedCount + 1;
				endif;
			endif;	
		endforeach;
	endif;
	
	//If we have some cargo selected that we are going to ignore, advise the user
	if includesQueued then
		msg := app.getErrorString1(Includes_Already_Queued, queuedCount.String);
		app.msgBox(msg, app.getErrorString(Multi_move), MsgBox_OK_Only);
		if _allCargoUNSorted.isEmpty then
			return false;
		endif;
	elseif includesPlanned then
		msg := app.getErrorString1(Includes_Already_Planned, plannedCount.String);
		app.msgBox(msg, app.getErrorString(Multi_move), MsgBox_OK_Only);
		if _allCargoUNSorted.isEmpty then
			return false;
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_allCargoUNSorted" type="CM_TIArray" usage="io"/>
        <Parameter name="_theTIs" type="CM_TIArray" usage="input"/>
        <Parameter name="_theDragTI" type="CM_TrackedItem"/>
        <Parameter name="_moveMode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="warnedOfNoSelectedData" id="aaeb3457-2040-4e47-b4d5-bee076ecec28">
        <source>warnedOfNoSelectedData( selectedObjs : Collection; objectType : String ) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwndl1	Initial creation

*/

vars

begin
	if selectedObjs.isEmpty then
		app.msgBox(app.getErrorString1(Must_Select_Object_First,objectType),app.getErrorString(CMUI_Nothing_Selected),MsgBox_OK_Only);
		return true;
	else
		return false;
	endif;
epilog

end;</source>
        <Parameter name="selectedObjs" type="Collection"/>
        <Parameter name="objectType" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
