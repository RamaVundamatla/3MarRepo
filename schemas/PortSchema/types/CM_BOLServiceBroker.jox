    <JadeMethod name="getDebtorForBOLTransaction" id="e260e961-6c8c-4a3e-a5f7-5e5f072c9e00">
        <source>getDebtorForBOLTransaction( trans : CM_BOLTransaction ): CM_DebtorNode;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

	aDM : CM_DebtorMap;
	aDebtor : CM_DebtorNode;

begin
	
	if self.allDebtorMapsByDebtor.isEmpty then
		return null;
	endif;

	foreach aDM in self.allDebtorMapsByDebtor do
		aDebtor := aDM.getDebtorFromBOLTransaction(trans);
		if aDebtor = aDM.myDebtorNode then
			return aDebtor;
		endif;
	endforeach;

	return null;

epilog

end;</source>
        <Parameter name="trans" type="CM_BOLTransaction"/>
        <ReturnType type="CM_DebtorNode"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="a1221950-504d-48c3-8335-b9f0dda69220">
        <source>getDescription(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars
	
	returnVal		: String;
	eventType		: Integer;
	
begin
	
	eventType := self.transactionType;
	if eventType = null then
		return null;
	endif;
	
	returnVal := self.getBOLTypeDesc();
	
	return returnVal;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceLineDesc" id="dd6644a2-91f6-45d6-bceb-c6d723c0a46f">
        <source>getInvoiceLineDesc(_aSBController: CMIF_ServiceBroker input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Nov 2019	jlgndl1	Initial creation	TFS 47100
10 Oct 2022 navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
18 Oct 2024 navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	lineDescription  : CM_InvoiceLineDesc;
	tmpDebtor		 : CM_Debtor;
	aDM 			 : CM_DebtorMap;
	ti				 : CM_TrackedItem;
	trans 			 : CM_BOLTransaction;
	canLogExtra		 : Boolean;
begin
	canLogExtra	:= app.canLogExtraDetail();				//10.10.2022 navma1 #52967
	trans 		:= _aSBController.myBOLTransaction;	
	if trans &lt;&gt; null then
	
		if _aSBController.myInvoiceLineDesc &lt;&gt; null then
			tmpDebtor := trans.getDebtorForInvoiceLine( _aSBController.myInvoiceLineDesc );
			if tmpDebtor &lt;&gt; null then
				if canLogExtra then							//10.10.2022 navma1 #52967
					app.invLog("Debtor " &amp; tmpDebtor.name, LogINFO.String);
				endif;
				
				aDM := self.allDebtorMapsByDebtor[tmpDebtor.name];		
				if aDM &lt;&gt; null then
					if canLogExtra then						//25.02.2025 navah1	#34141							
						app.invLog("Debtor map for " &amp; tmpDebtor.name, LogINFO.String);
					endif;
					_aSBController.myDebtor := tmpDebtor;	//29 Nov 2019	NDL	TFS 47100
					aDM.getInvoiceLineDesc(_aSBController);
					return;
				endif;
			endif;
		endif;
		
		//29 Nov 2019	NDL	TFS 47100
		if tmpDebtor = null then
			if not self.allDebtorMapsByDebtor.isEmpty then
				tmpDebtor := self.getDebtorForBOLTransaction(trans).CM_Debtor;
				if  tmpDebtor &lt;&gt; null then
					aDM := self.allDebtorMapsByDebtor[tmpDebtor.name];		
					if aDM &lt;&gt; null then
						if canLogExtra then							//10.10.2022 navma1 #52967
							app.invLog("Debtor map found for " &amp; tmpDebtor.name, LogINFO.String);
						endif;
						_aSBController.myDebtor := tmpDebtor;	//29 Nov 2019	NDL	TFS 47100
						aDM.getInvoiceLineDesc(_aSBController);
						return;
					endif;
				endif;
			endif;
		endif;

	endif;
	if canLogExtra then							//10.10.2022 navma1 #52967
		app.invLog("Debtor map for DEFAULT", LogINFO.String);
	endif;
	self.myChildQuantityMap.getInvoiceLineDesc(_aSBController);
	
end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTranMapBreadCrumb" id="ebec94b3-5610-4ccd-b8e9-25eaf76e0495">
        <source>getTranMapBreadCrumb(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin

	return self.myTransMap.getTranMapBreadCrumb() &amp; "/" &amp; self.getBOLClassName();

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="d27d79b5-1323-4629-8da4-e9f82d03845e">
