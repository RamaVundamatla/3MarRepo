    <PrimAttribute name="addUpdateTransactionComplete" id="09b09b57-dcca-493a-ad32-79180855a80b">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
        <text>
This can be set in a subform after the transaction is complete (in the
doSave method) but prior to returning if you want to display a message
box, etc.  It means some actions (e.g. notifications are ignored).</text>
    </PrimAttribute>
