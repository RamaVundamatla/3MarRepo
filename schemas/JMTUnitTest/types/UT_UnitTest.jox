    <JadeMethod name="assertDeleted" id="bdb1a34b-3cbe-4557-800f-e3591d17463d">
        <source>assertDeleted(_oid: String) protected;
// Date: 07 October 2009
// Author: cnwdw1	 
// Description: Check that the oid does not exist in the database
vars

begin
	assertNullMsg(_oid.asOid, "AssertDeleted: Oid: " &amp; _oid &amp; " does exist");
end;</source>
        <access>protected</access>
        <Parameter name="_oid" type="String"/>
    </JadeMethod>
    <JadeMethod name="assertEdiTrxErrorMsg" id="c58eefe3-9d4a-43ac-ab3b-f7f1b3d073e1">
        <source>assertEdiTrxErrorMsg(_ediData : CM_EDIData; _errorCode : Integer; _message : String);
//
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
//
vars
	error: CM_Error;
	ediError : CM_EDIError;
begin
	foreach ediError in _ediData.allErrorWarnings do
		if ediError.warningOnly then
			continue;
		endif;
		if ediError.errorCode = _errorCode then
			return;
		endif;
	endforeach;
		
	foreach error in app.myPassport.allErrors do
		if error.errorCode &lt;= app.myRoot.baseErrorNum then
			self.assertTrueMsg(false, error.text);
			return;
		endif;	
	endforeach;

	foreach error in app.myPassport.allErrors do
		if error.errorCode = _errorCode then
			return;
		endif;
	endforeach;
	// didn't find the error so force a failure
	self.assertTrueMsg(false, _errorCode.String&amp;' '&amp;_message);
end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_errorCode" type="Integer"/>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
    <JadeMethod name="assertEqual" id="054bec13-b09b-4788-905c-f6066bb02bc9">
        <source>assertEqual(actual: Any; expected: Any) protected;
//16 July 2008	cnwdw1	
//
begin
	self.assertEqualMsg(actual, expected, null);
end;</source>
        <access>protected</access>
        <Parameter name="actual" type="Any"/>
        <Parameter name="expected" type="Any"/>
    </JadeMethod>
    <JadeMethod name="assertEqualMsg" id="94fed3b3-9bff-4dff-a19f-45fc91bb9a19">
        <source>assertEqualMsg(actual: Any; expected: Any; message : String) protected;
//16 July 2008	cnwdw1	
//
begin
	self.assertTrueMsg(actual = expected, "  Actual: " 			 &amp; 
					   actual.String.removeTabCrLfs 	  			 &amp; CrLf &amp; 
					   "Expected: " &amp; expected.String.removeTabCrLfs &amp; CrLf &amp; message);
end;</source>
        <access>protected</access>
        <Parameter name="actual" type="Any"/>
        <Parameter name="expected" type="Any"/>
        <Parameter name="message" type="String"/>
    </JadeMethod>
    <JadeMethod name="assertExceptionRaised" id="5b16c0b0-fd6d-44ad-99ef-6737c932cf59">
        <updating/>
        <source>assertExceptionRaised(_exceptionCode: Integer; _message: String) protected, updating;
//05 August 2008	cnwdw1	
//
vars
	failException : UT_TestFailureException;
begin
	// Did we get an exception?
	if not assertException then
		create failException transient;
		failException.message := _message &amp; CrLf &amp; self.exceptionMessage;
		failException.errorCode := 99999;
		raise failException;
		return;
	endif;
	
	// Did we get the right exception
	if _exceptionCode &lt;&gt; self.exceptionCode then
		create failException transient;
		failException.message := "Expecting exception " &amp; _exceptionCode.String &amp; " but got " &amp; self.exceptionCode.String &amp; " - " &amp; _message &amp; CrLf &amp; self.exceptionMessage;
		failException.errorCode := self.exceptionCode;
		raise failException;
		return;
	endif;
	
	self.assertException := false;
	self.exceptionCode := 0;
	self.exceptionMessage := null;

end;</source>
        <access>protected</access>
        <Parameter name="_exceptionCode" type="Integer"/>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
