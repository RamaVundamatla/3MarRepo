    <JadeMethod name="isRailQueue" id="0d63735d-7618-4838-a956-b67f6dac65bf">
        <source>isRailQueue() : Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
13 June 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	taMaster : CM_TerminalAreaMaster;

begin
	if not self.allMoveFromTAMasters.isEmpty() then
		foreach taMaster in self.allMoveFromTAMasters do
			if taMaster.isRailAreaType() then
				return true;
			endif;
		endforeach;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isRailQueueFromTo" id="c528a17f-2009-4e72-a8bf-dcb44417c679">
        <source>isRailQueueFromTo(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 January 2016	cnwmc5	Initial creation

*/

vars

	taMaster : CM_TerminalAreaMaster;

begin
	if not self.allMoveFromTAMasters.isEmpty() then
		foreach taMaster in self.allMoveFromTAMasters do
			if taMaster.isRailAreaType() then
				return true;
			endif;
		endforeach;
	endif;
	
	if not self.allMoveToTAMasters.isEmpty() then
		foreach taMaster in self.allMoveToTAMasters do
			if taMaster.isRailAreaType() then
				return true;
			endif;
		endforeach;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
