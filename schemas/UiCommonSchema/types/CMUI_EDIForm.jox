    <JadeMethod name="hasVerifyErrorsToShow" id="e80283db-a7cc-4a69-92ad-3864f97d903b">
        <source>hasVerifyErrorsToShow(_ediData :CM_EDIData):Boolean protected;
/*
Date		Who		Reason
07 Aug 2012	cnwcs5	Initial creation - par 30136
19/08/2013	cnwcs5 	ccms POL 2221 / par 32094(2)
*/
vars

begin
	if _ediData.storePersistentErrors then
		return _ediData.allErrorWarnings.size &gt; 0;
	else
		return app.myPassport.allErrorWarnings.size &gt; 0;
	endif;
	
	return false;	// will never get to here :-)
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
