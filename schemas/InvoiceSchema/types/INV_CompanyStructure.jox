    <JadeMethod name="addCompanyAt" id="4e75b553-cb91-4ac9-be6f-ca82b273968e">
        <source>addCompanyAt(co: CM_Bank; listbox: ListBox; level: Integer; index: Integer; _update : Boolean);

// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	str:  String;
	pic:  Picture;
begin
	if co.isBusinessUnit then
		pic := self.picBU;
	else
		pic := self.picCompany;
	endif;

	str := co.code &amp; " - " &amp; co.mailingName;
	if co.isSuspended then
		str := str &amp; " (" &amp; app.getErrorString(INV_Suspended) &amp; ")";
	endif;
	if _update then
		listbox.itemText[index] := str;
	else
		listbox.addItemAt(str, index);	
	endif;
	listbox.itemLevel[index] := level;
	listbox.itemObject[index] := co;
	listbox.itemPicture[index] := pic.picture;

end;</source>
        <Parameter name="co" type="CM_Bank"/>
        <Parameter name="listbox" type="ListBox"/>
        <Parameter name="level" type="Integer"/>
        <Parameter name="index" type="Integer"/>
        <Parameter name="_update" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="e65870db-553f-401f-bcde-48ad883f0f51">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 30/12/2022	navkc1	TFS CR 55300 TASK 55525 - Business Unit Maint changes  for auto id
// ---------------------------------------------------------------------------

vars
	frm				: CMUI_Toolbar;
begin	

	frm := self.frmToolbar;
	frm.addButton(self.btnPrintList, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnNewCompany, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnUpdate, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnSusp, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnAutoId, CMUI_Toolbar.Control_Alignment_Left); // 30/12/2022	navkc1	TFS CR 55300 TASK 55525
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

	frm.positionToolbarControls();
	frm.visible := true;
	
	frm := self.frmPropToolbar;
	frm.addButton(self.btnPropSave, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPropCancel, CMUI_Toolbar.Control_Alignment_Right);
	frm.positionToolbarControls();
	frm.visible := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnAutoId_click" id="c5a6a591-1e67-484e-87c7-c9cf14b0a084">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAutoId_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 January 2023	navkc1	Initial creation TFS CR 55300 TASK 55525

*/

vars
	form 		: CMUI_AutoIdConfiguration;
	terminal 	: CM_Terminal;
	bank 		: CM_Bank;
	
begin
	
	terminal := self.myTerminal;
	
	if terminal = null then
		return;
	endif;
	
	bank := self.myCurrentBU;
	
	if bank = null then
		app.msgBox(app.getErrorString(Select_business_unit), app.getErrorString(Bank_selected), MsgBox_Information_Icon);
		return;
	endif;
	
	app.mousePointer := MousePointer_Default;
	
	form := app.loadForm(CMUI_AutoIdConfiguration, CMUI_Assistant, false, false, false, terminal, null).CMUI_AutoIdConfiguration;
	
	if form = null then
		return;
	endif;
	
	form.setMyBusinessUnit(bank);
	form.myParentForm := self;
	form.setForIdType(0, terminal);
	form.show();
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnDelete_click" id="038571cf-ff3e-4f41-8f91-f5b8bfac4ad3">
