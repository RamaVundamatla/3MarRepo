    <JadeMethod name="doCheckReportQueue" id="e21b2e32-cc24-4756-a82b-6b01a86051ce">
        <updating/>
        <source>doCheckReportQueue() updating, protected;
// --------------------------------------------------------------------------------
// Created:		23 July 2000 by cnwdad1
//
// Purpose:		Check the report queue to see whether there's a print job to run,
//				and if one is found, it will be started.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	queueEntry		: CnEcReportQueueEntry;
	jobIterator		: Iterator;
	timeStamp		: TimeStamp;
	reportForm		: CnEcReport;
	reportClass		: Class;
	jobStatus		: Integer;
	jobDetails		: String;
	errorMessage	: String;

begin
	jobIterator	:=	app.myBaseRoot.allReportQueueEntries.createIterator();

	while jobIterator.next(queueEntry) do
		self.reportStatus	:=	CNEC_REPORT_PREVIEW;
		
		if queueEntry.timeStamp &gt; timeStamp then
			break;
		endif;

		if	queueEntry.printStatus = CNEC_REPORT_PENDING										and
			tryLock(queueEntry, Exclusive_Lock, Transaction_Duration, LockTimeout_Immediate)	then

			if currentSchema.findName(queueEntry.myReportDefinition.formName) = null then
				jobDetails	:=	queueEntry.timeStamp.String;
				jobDetails	:=	jobDetails &amp; " - " &amp; queueEntry.myReportDefinition.reportDescription &amp; ": " &amp; $CNEC_ERROR;
				self.myTA.trxReportQueueEntrySetStatus(queueEntry, 0, CNEC_REPORT_ERROR, jobDetails);
			else
				reportClass	:=	currentSchema.getClass(queueEntry.myReportDefinition.formName);
				create reportForm as reportClass;

				jobDetails	:=	queueEntry.timeStamp.String;
				jobDetails	:=	jobDetails &amp; " - " &amp; queueEntry.myReportDefinition.reportDescription &amp; ": " &amp; $CNEC_PRINTING &amp; "...";
				self.myTA.trxReportQueueEntrySetStatus(queueEntry, 0, CNEC_REPORT_PRINTING, jobDetails);

				on Exception do self.xHandlerReportApp(exception);
				jobStatus	:=	reportForm.printReport(queueEntry, false, errorMessage);
				on Exception do null;
				delete reportForm;

				if self.reportStatus = CNEC_REPORT_ERROR then
					jobStatus	:=	CNEC_REPORT_ERROR;
				endif;

				if jobStatus = CNEC_REPORT_PRINTED then
					jobDetails	:=	queueEntry.timeStamp.String;
					jobDetails	:=	jobDetails &amp; " - " &amp; queueEntry.myReportDefinition.reportDescription &amp; ": " &amp; $CNEC_PRINTED;
					self.myTA.trxReportQueueEntryDelete(queueEntry);
				elseif jobStatus = CNEC_REPORT_CANCELLED then
					jobDetails	:=	queueEntry.timeStamp.String;
					jobDetails	:=	jobDetails &amp; " - " &amp; queueEntry.myReportDefinition.reportDescription &amp; ": " &amp; $CNEC_CANCELLED;
					self.myTA.trxReportQueueEntryDelete(queueEntry);
				else
					jobDetails	:=	queueEntry.timeStamp.String;
					jobDetails	:=	jobDetails &amp; " - " &amp; queueEntry.myReportDefinition.reportDescription &amp; CrLf &amp; CrLf &amp; $CNEC_ERROR &amp; ": " &amp; errorMessage;
					self.myTA.trxReportQueueEntrySetStatus(queueEntry, 0, jobStatus, jobDetails);
				endif;
			endif;	// where the queued job's report is valid.
		elseif	queueEntry.printStatus = CNEC_REPORT_CANCELLED											and
				tryLock(queueEntry, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined)	then

			jobDetails	:=	queueEntry.timeStamp.String;
			jobDetails	:=	jobDetails &amp; " - " &amp; queueEntry.myReportDefinition.reportDescription &amp; ": " &amp; $CNEC_CANCELLED;
			self.myTA.trxReportQueueEntryDelete(queueEntry);
		endif;	// where queued report job is pending and we've successfully got a lock.
	endwhile;
epilog
	delete jobIterator;

	beginTimer((CHECK_INTERVAL * 1000), Timer_Continuous, 0);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doStart" id="d91f51f0-a493-42fd-b1e2-dbea165ab042">
        <updating/>
        <source>doStart() updating;
// --------------------------------------------------------------------------------
// Created:		23 July 2000 by cnwdad1
//
// Purpose:		Starts the timer which periodically checks the queue for reports to
//				process.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	beginTimer((self.CHECK_INTERVAL * 1000), Timer_Continuous, 0);
	self.isTimerActive	:=	true;
end;</source>
    </JadeMethod>
    <JadeMethod name="doStop" id="cc562ff5-6087-4dcb-8a08-0807d9d13b19">
        <updating/>
        <source>doStop() updating;
// --------------------------------------------------------------------------------
// Created:		10 August 2000 by cnwdad1
//
// Purpose:		Stops the print queue timer.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On Changed By Reason
// ---------- ---------- ----------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	endTimer(0);
end;</source>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="58ef43c5-24b3-44e4-ad94-01c7c4012f5d">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		23 July 2000 by cnwdad1
//
// Purpose:		Checks the print queue for any reports to process.
//
// Parameters:	eventTag - The timer event tag.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	endTimer(0);
	self.doCheckReportQueue();
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xHandlerReportApp" id="1f047482-7874-4612-ad35-fd3d128a5c73">
        <updating/>
        <source>xHandlerReportApp(pException:Exception):Integer updating, protected;
// --------------------------------------------------------------------------------
// Created:		23 July 2000 by cnwdad1
//
// Purpose:		Exception handler to log the details of the error and attempt to
//				resume processing from the next job in the queue.
//
// Parameters:	pException - The exception object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.cnEcLog(pException.cnEcGetDetails());
	
	if process.isInTransactionState then
		abortTransaction;
	endif;
	
	self.reportStatus := CNEC_REPORT_ERROR;
	return Ex_Resume_Next;
end;</source>
        <access>protected</access>
        <Parameter name="pException" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
