    <JadeMethod name="pxyRemoveAllUsages" id="08b4c890-93ff-46c5-b72b-fff8597814d5">
        <source>pxyRemoveAllUsages(_in :Boolean);
// ---------------------------------------------------------------------------
// Created:     31 July 2009 by cnwcs5:1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	coll	:CM_GateAreaUsageArray;
begin
	if _in then
		coll := self.allGateAreas_IN;
	else
		coll := self.allGateAreas_OUT;
	endif;
	
	while not coll.isEmpty do
		coll.first.erase (NORMAL_ERASE);
	endwhile;
epilog

end;</source>
        <Parameter name="_in" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyRemoveGateAreaUsage" id="93f5f38a-d66a-4966-83ca-da398ade7f70">
        <source>pxyRemoveGateAreaUsage(_usage :CM_GateAreaUsage io);
// ---------------------------------------------------------------------------
// Created:     22 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient (method);
	
	_usage.erase (NORMAL_ERASE);
epilog

end;</source>
        <Parameter name="_usage" type="CM_GateAreaUsage" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyRemoveGateAreaUsagesByType" id="e885c239-0649-4c4d-8468-d00be636cd0e">
        <source>pxyRemoveGateAreaUsagesByType(_in :Boolean; _areaType :Integer)protected;
// ---------------------------------------------------------------------------
// Created:     04 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	coll	:CM_GateAreaUsageArray;
	usage	:CM_GateAreaUsage;
	set		:CM_GateAreaUsageSet; 
begin
	self.raiseExceptionIfNotTransient (method);
	
	if _in then
		coll := self.allGateAreas_IN;
	else
		coll := self.allGateAreas_OUT;
	endif;
	
	// copy array to set so I don't have to jump through hoops to
	// delete array entries while iterating
	create set transient;
	
	coll.copy (set);
	
	foreach usage in set do
		if usage.myGateArea.areaType &lt;&gt; _areaType then
			continue;
		endif;
		usage.erase (NORMAL_ERASE);
	endforeach;
epilog
	delete set;
end;</source>
        <access>protected</access>
        <Parameter name="_in" type="Boolean"/>
        <Parameter name="_areaType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="d4ba7333-241f-429a-ac5f-8d12117a338c">
        <updating/>
        <source>setForCreate(_proxy :CM_Gate)updating;
// ---------------------------------------------------------------------------
// Created:     12 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.myTerminal	:= _proxy.myTerminal;
		
	self.setForUpdate (_proxy);
epilog

end;</source>
        <Parameter name="_proxy" type="CM_Gate"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="b0cc6377-fbf9-457c-a372-eeea45b7c5b0">
        <updating/>
        <source>setForUpdate(_proxy :CM_Gate)updating;
// ---------------------------------------------------------------------------
// Created:     12 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/02/2010	cnwcs5		par 18061 - RFID tag prompt
// ---------------------------------------------------------------------------
vars
	usageSet, areaSet		:CM_ObjectSet;
	gateArea, pxyGateArea	:CM_GateArea;
	usage, pxyUsage			:CM_GateAreaUsage;
	obj						:Object;
begin
	self.name						:= _proxy.name;
	self.isInGate					:= _proxy.isInGate;
	self.isOutGate					:= _proxy.isOutGate;
	self.promptForRFIDTag			:= _proxy.promptForRFIDTag;	// 23/02/2010 cnwcs5
	self.myDefaultInterchangeArea	:= _proxy.myDefaultInterchangeArea;	// could be null
	self.useBarrierCodes			:=_proxy.useBarrierCodes; //jlier1 TFS 57936 19/5/23	
	
	create usageSet transient;
	create areaSet transient;
	
	// copy all current gate area usages to temporary collection 
	// so we know if there are any that should be deleted
	self.allGateAreas_IN.copyNoDuplicates (usageSet);
	self.allGateAreas_OUT.copyNoDuplicates (usageSet);
	
	// copy all current gate area usages to temporary collection 
	// if an area is used by more than one usage we don't want to
	// update the area more than once.
	self.allGateAreas_IN.clear;		// resets myGate reference
	self.allGateAreas_OUT.clear;	// resets myGate reference
	
	foreach pxyUsage in _proxy.allGateAreas_IN do
		// we will update the gate area B4 the usage so we don't end up doing
		// it twice - once for in and once for out
		pxyGateArea 					:= pxyUsage.myGateArea;
		gateArea						:= pxyGateArea.pxyGetRealObject;
		
		if gateArea = null then
			create gateArea;	
			gateArea.setForCreate (pxyGateArea, app.myPassport);	
			app.myProxyManager.createProxyLink (gateArea, pxyGateArea);
		else
			gateArea.setForUpdate (pxyGateArea);
		endif;
		
		// keep track of gate areas that have already been updated
		areaSet.addNoDuplicates (pxyGateArea, false);		
		
		usage := pxyUsage.pxyGetRealObject;
		
		if usage = null then
			// new usage
			create usage;
			usage.setForCreate (pxyUsage);
			
			app.myProxyManager.createProxyLink (usage, pxyUsage);
		else
			// existing usage - nothing gets updated
			usageSet.removeIfPresent (usage);
		endif;
		
		self.allGateAreas_IN.add (usage);	// sets myGate reference
	endforeach;
	
	foreach pxyUsage in _proxy.allGateAreas_OUT do
		pxyGateArea 	:= pxyUsage.myGateArea;
		
		if not areaSet.includes (pxyUsage.myGateArea) then
			// the gate area has already been updated
			gateArea	:= pxyGateArea.pxyGetRealObject;
		
			if gateArea = null then
				create gateArea;	
				gateArea.setForCreate (pxyGateArea, app.myPassport);	
				app.myProxyManager.createProxyLink (gateArea, pxyGateArea);
			else
				gateArea.setForUpdate (pxyGateArea);
			endif;
			
			areaSet.addNoDuplicates (pxyGateArea, false);
		endif;

		usage 	:= pxyUsage.pxyGetRealObject;

		if usage = null then
			// new usage
			create usage;
			usage.setForCreate (pxyUsage);
			
			app.myProxyManager.createProxyLink (usage, pxyUsage);
		else
			// existing usage
			usageSet.removeIfPresent (usage);
		endif;
		
		self.allGateAreas_OUT.add (usage);	// usageSets myGate reference
	endforeach;
	
	// now that we have updated everything - usageSet contains usage objects
	// that we no longer need.  we can delete these which may in turn
	// result in deleting the gate area
	foreach obj in usageSet do
		usage 		:= obj.CM_GateAreaUsage;
		
		usage.erase (NORMAL_ERASE);
	endforeach;
	
	//+cnwml2 PAR23715 SFW CCMS1131
	self.sealCheckReceival := _proxy.sealCheckReceival;
	self.sealCheckRelease := _proxy.sealCheckRelease;
epilog
	delete usageSet;
	delete areaSet;
end;</source>
        <Parameter name="_proxy" type="CM_Gate"/>
    </JadeMethod>
