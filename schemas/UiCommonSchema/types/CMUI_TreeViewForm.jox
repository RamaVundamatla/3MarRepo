    <JadeMethod name="zCloneMenu" id="b59f302e-c3b4-4876-86c1-c7aec0cee4f0">
        <updating/>
        <source>zCloneMenu(_cloneMaster, _sourceMenu : MenuItem input; _loadAsSubMenu : Boolean): MenuItem updating, protected;
// ---------------------------------------------------------------------------
// Created:     22 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	oidStr	: String;
	newMenu	: MenuItem;
	
begin
	
	oidStr := _sourceMenu.description;
	if oidStr &lt;&gt; null then
		newMenu := oidStr.asOid.MenuItem;
	endif;

	if newMenu = null then
		self.clonedMenuCount := self.clonedMenuCount + 1;
		
		if _loadAsSubMenu then
			newMenu := _cloneMaster.loadSubMenu(self.clonedMenuCount);
		else
			newMenu := _cloneMaster.loadMenu(self.clonedMenuCount);
		endif;
		newMenu.userObject	:= _sourceMenu;
		
		_sourceMenu.description	:= newMenu.getOidString;
	endif;
	
	newMenu.caption 		:= _sourceMenu.caption;
	newMenu.checked 		:= _sourceMenu.checked;
	newMenu.disableReason	:= _sourceMenu.disableReason;
	newMenu.enabled			:= _sourceMenu.enabled;
	newMenu.helpContextId	:= _sourceMenu.helpContextId;
	newMenu.helpKeyword		:= _sourceMenu.helpKeyword;
	newMenu.picture			:= _sourceMenu.picture;
	newMenu.visible 		:= _sourceMenu.visible;
	
	return newMenu;
	
end;</source>
        <access>protected</access>
        <Parameter name="_cloneMaster" type="MenuItem" usage="input"/>
        <Parameter name="_sourceMenu" type="MenuItem" usage="input"/>
        <Parameter name="_loadAsSubMenu" type="Boolean"/>
        <ReturnType type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="zDoCancel" id="56bcb565-53ad-4641-819a-12a9d0d90e78">
        <updating/>
        <source>zDoCancel() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	11 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.mode &lt;&gt; self.Mode_View and self.tblEntry.hasChanged then
		if app.msgBox(app.getErrorString(EditChangedAndClosing),app.getErrorString(Are_You_Sure), MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;
	endif;
	
	if self.closeOnSave then
		self.unloadForm();
		return;
	endif;
	
	if self.mySelectedObject &lt;&gt; null and (app.isValidObject(self.mySelectedObject)) then
		self.mySelectedObject := self.mySelectedObject.pxyGetRealObject();
	endif;
	
	self.doCancel();//re-implement if need something here
	
	self.mode := self.Mode_View;
	self.setControlsForView();
	delete self.myMasterProxyObject;
	self.tblEntry.clearValues();
	self.loadTree();
	
	if self.mySelectedObject &lt;&gt; null and (app.isValidObject(self.mySelectedObject)) then
		self.selectObject(self.mySelectedObject);
	endif;
epilog
	if app.isValidObject(self.myMasterProxyObject) then	// 13 Dec 2010	NDL	Par 26527 - can be already deleted 
		delete self.myMasterProxyObject;
	endif;
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoDelete" id="54face80-a0f2-4c4f-a5c7-64e65f821ec6">
        <final/>
        <updating/>
        <source>zDoDelete() protected, updating, final;
/*
----------   ----------  --------------------------------------------------
Created:	29 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	idx					: Integer;
	nextObjUp				: CM_Object;
begin
	idx := self.lstTree.listIndex;
	
	if self.doDelete() then
		idx := idx - 1;
		if idx &gt; 0 then
			nextObjUp := self.lstTree.itemObject[idx].CM_Object;
			self.selectObject(nextObjUp);
		endif;
	endif;

end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoEdit" id="53f2f345-ec2a-4abc-92ba-b8df06e8c2ff">
        <final/>
        <updating/>
        <source>zDoEdit() updating, protected, final;
/*
----------   ----------  --------------------------------------------------
Created:	27 April 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	loadState			: Boolean;
	objToSelect			: CM_Object;
begin
	if self.mode &lt;&gt; self.Mode_View then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Already in edit mode.');
	endif;
	
	if self.myMasterObject = null then
		app.msgBox(app.getErrorString(Select_something_to_edit),app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	delete self.myMasterProxyObject;
	app.cmsBeginLoad(loadState);
	self.myMasterProxyObject := self.myMasterObject.pxyCreateUpdateProxy();
	
	self.mode := self.Mode_Update;
	self.setControlsForAddEdit();
	if (not app.isValidObject(self.mySelectedObject)) then
		self.mySelectedObject := null;
	endif;
	
	if self.mySelectedObject &lt;&gt; null then
		objToSelect := self.mySelectedObject.pxyGetProxyObject();
	endif;
	
	self.loadTree();
	self.selectObject(objToSelect);
	self.zSetTblEntryFocus();
	
epilog
	endLoad;
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoLstTreeDragObjects" id="e04e4a92-4eaf-4458-a103-eff654fc6e6b">
        <final/>
        <updating/>
        <source>zDoLstTreeDragObjects() updating, protected, final;
/*
----------   ----------  --------------------------------------------------
Created:	24 May 2007 By cnwth2

Purpose:	for dragging and dropping within the tree, this method
			populates the draged object(s) references and changes the mouse cursor.
			
			What happens in the drop requires re-implementation of doLstTreeDragDropEvent

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	obj			: Object;
	otherTI,
	primaryTI	: CM_TrackedItem;
	pic			: Picture;
	
begin
	//deleting app.myMoveController here to save any potential confusion in
	//a re-implentation of doLstTreeDragDropEvent testing for app.myMoveController
	//to know whether the user is dragging and dropping from a different screen, or within
	//the tree
	delete app.myMoveController;
	self.allSelectedDragDropObjects.clear();
	self.mySelectedDragDropObject := self.mySelectedObject;
	if self.mySelectedDragDropObject = null then
		return;
	endif;

	self.allSelectedObjects.copy(self.allSelectedDragDropObjects);
	self.lstTree.dragMode := DragMode_Drag;

	create pic transient;
	self.setPictureDragCursor(pic);
	if pic.picture &lt;&gt; null then
		self.lstTree.dragCursor := pic.picture;
	endif;

epilog
	delete pic;
	
end;




</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoNext" id="e78b2999-2f83-40da-8dff-de9be5509fbe">
        <final/>
        <updating/>
        <source>zDoNext()updating, protected, final;
/*
----------   ----------  --------------------------------------------------
Created:	23 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.mode = self.Mode_View then
		return;
	endif;
	
	self.saveUserEntry();
	self.doNext();

end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoSave" id="e908bf1a-eff2-4a70-b2fb-1d7a2a91356f">
        <updating/>
        <source>zDoSave() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	11 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.saveUserEntry();
	
	if (not self.doSave) then
		return;
	endif;
	
	if self.closeOnSave then//sub-class to handle
		self.unloadForm();
		return;
	endif;
	
	self.mode := self.Mode_View;
	self.setControlsForView;
	self.loadTree();
	if self.myMasterObject &lt;&gt; null and app.isValidObject(self.myMasterObject) then
		self.selectObject(self.myMasterObject);
	endif;
	self.lstTree.setFocus;
	
end;


</source>
        <access>protected</access>
    </JadeMethod>
