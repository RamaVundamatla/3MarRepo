    <JadeMethod name="canOverstow" id="34945fc7-5672-40d2-ac56-350de250e1e2">
        <source>canOverstow(_location : CM_YardController; _currentTi : CM_TrackedItem; _yaAgent : CM_YAAutoplanAgent input) : Boolean;
// -------------------------------------------
// Created 13 September 2005 by cnwdvb1
// -------------------------------------------
// Changed On 	By			Reason
// ----------	--------	--------------------------------------------------
// 12/05/2010	cnwdap1		CCMS 1116 Tranship changes
vars

	attribute			: CM_YAOverstowAttribute;
	isCurrentPlannedAway,
	isTopPlannedAway,
	isTopQueuedAway		: Boolean;
	futureMove			: CM_FutureMove;
	aLocation			: CM_LocationsController;
	jobTop,
	jobCurrent			: CM_VoyageJob;
	currentTi,
	topTI				: CM_TrackedItem;

begin

	// Should only be dealing with top boxes that are there in
	// real mode or top boxes that are queued to be there.
	// Should be no boxes that are planned to this location.

	topTI := _location.getTopTI(QUEUE_MODE);	

	// Changed 09/05/06 DVB
	if topTI = null then
		topTI := _location.getTopTI(PLANNING_MODE);	
	endif;

	if topTI = null then
	 	//----------------
		//Test for a real mode TI
	 	//----------------
		topTI := _location.getTopTI(REAL_MODE);	
	else
		//if topTI.myTranshipExport &lt;&gt; null then	// PAR #23645 CCMS 1116
			//topTI := topTI.myTranshipExport;		// PAR #23645 CCMS 1116
		//endif;									// PAR #23645 CCMS 1116
	endif;

	if topTI = null then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'No overstowing box to evaluate...', true);
	 	return true;
	endif;
	
	// Tranship stuff for overstows.
	//if _currentTi.myTranshipExport &lt;&gt; null then	// PAR #23645 CCMS 1116
		//currentTi := _currentTi.myTranshipExport;	// PAR #23645 CCMS 1116
	//else											// PAR #23645 CCMS 1116
		currentTi := _currentTi;
	//endif;										// PAR #23645 CCMS 1116
	
	if currentTi &lt;&gt; null then
		isCurrentPlannedAway := currentTi.isPlanned(PLANNING_MODE);
//		isTopPlanned := topTI.isPlanned(PLANNING_MODE);

		// To check for queued or planned we need to check whether the future moves are for
		// locations other than self. If they are then the boxes are moving away and shouldn't
		// be stopped by putting something on top.
		// If the location is _location then they are moving to this location.
		foreach futureMove in topTI.allPlannedFutureMoves do
			aLocation := futureMove.CM_FutureMovePlanned.allLocationsControllers.first;
			if (aLocation &lt;&gt; null) and aLocation &lt;&gt; _location then
				isTopPlannedAway := true;
				break;
			endif;
		endforeach;			
		foreach futureMove in topTI.allQueuedFutureMoves do
			aLocation := futureMove.CM_FutureMoveQueued.allLocationsControllers.first;
			if (aLocation &lt;&gt; null) and aLocation &lt;&gt; _location then
				isTopQueuedAway := true;
				break;
			endif;
		endforeach;
				
		// Neither planned so go home.
		if not isCurrentPlannedAway and not isTopPlannedAway and not isTopQueuedAway then
			// Do nothing.
		elseif isTopPlannedAway and not isCurrentPlannedAway then
			// Don't put unplanned boxes on top of planned boxes.
			_yaAgent.addLogEntry(AP_Log_YA_Default,"Unable to place cargo on top of " &amp; topTI.id.trimRight &amp; " which is planned", true);
			return false;
		elseif isTopQueuedAway then
			// Don't put boxes on top of queue boxes.
			_yaAgent.addLogEntry(AP_Log_YA_Default,"Unable to place cargo on top of " &amp; topTI.id.trimRight &amp; " which is queued to " &amp; aLocation.getFullId(), true);
			return false;
		// DON'T KNOW WHETHER TO STOP THESE OR NOT
		//elseif (isCurrentPlanned and isTopPlanned) and self.getYAOverstowAttribute(TI_Test_Voyage) = null then
			// Can't test voyage rules so no go.
		//	_yaAgent.addLogEntry("Unable to place cargo on top of " &amp; _topTi.id.trimRight &amp; " which is planned. Voyage attribute not configured", true, false);
		//	return false;
		else
			// Should be that both boxes are either queued or planned. Need to check voyage later.
		endif;
	endif;
	
	foreach attribute in self.allYAOverstowAttributes discreteLock do
		if not attribute.canOverstow(_location, topTI, _yaAgent) then
			return false;
		endif;
	endforeach;
	
	return true;

end;</source>
        <Parameter name="_location" type="CM_YardController"/>
        <Parameter name="_currentTi" type="CM_TrackedItem"/>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="detachRuleFromImex" id="6d60c20a-8ae8-4d51-8670-77a47e43bead">
        <source>detachRuleFromImex(_imexStatus : CM_IMEXStatus);
// -------------------------------------------
// Created 13 September 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.allImexStatuses.remove(_imexStatus);


end;</source>
        <Parameter name="_imexStatus" type="CM_IMEXStatus"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="30f3ece5-87b1-4ec0-bcb4-2e982b6ccf60">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     June 2006 cnsrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	txt,
	tmpStr : String;
	overstowA : CM_YAOverstowAttribute;
	imexStatus : CM_IMEXStatus;
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	foreach imexStatus in self.allImexStatuses do
		tmpStr := imexStatus.auditId();
		if tmpStr &lt;&gt; null then
			txt := txt &amp; imexStatus.auditIdDisplay() &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		endif;
	endforeach;
	foreach overstowA in self.allYAOverstowAttributes do
		tmpStr := overstowA.getAuditText();
		if tmpStr &lt;&gt; null then
			txt := txt &amp; overstowA.auditIdDisplay() &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		endif;
	endforeach;
	return txt;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYAOverstowAttribute" id="42c4e59b-9c98-431c-bb8d-bc0009b47984">
        <source>getYAOverstowAttribute(_type	: Integer) : CM_YAOverstowAttribute protected;
// -------------------------------------------
// Created 13 September 2005 by cnwdvb1
// -------------------------------------------
vars

	attribute	: CM_YAOverstowAttribute;

begin

	foreach attribute in self.allYAOverstowAttributes discreteLock do
		if attribute.type = _type then
			return attribute;
		endif;
	endforeach;
	
	return null;


end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="CM_YAOverstowAttribute"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="977c87de-9fdd-4897-9a9c-a59d1cce1435">
        <source>pxyCreateUpdateProxy(): SelfType;
// -------------------------------------------
// Created 13 September 2005 by cnwdvb1
// -------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars

	pxyRule	: SelfType;
	pxyAttrib,
	attrib	: CM_YAOverstowAttribute;
	completedOK		: Boolean;
	
begin
	
	pxyRule := inheritMethod();
	
	self.allImexStatuses.copy(pxyRule.allImexStatuses);
	
	foreach attrib in self.allYAOverstowAttributes do
		pxyAttrib := attrib.pxyCreateUpdateProxy();
		pxyAttrib.setMyYaOverstowRule(pxyRule);
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyRule;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyRule;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="53ea7664-1abf-4895-871e-2b2ee13d0ea9">
        <updating/>
        <source>setForCreate(_proxyRule	: SelfType) updating;
// -------------------------------------------
// Created 13 September 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	// Just call set for update method. It does it all.
	self.setForUpdate(_proxyRule);


end;</source>
        <Parameter name="_proxyRule" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="5a1146c3-1d1e-41e7-9396-b693a61c1934">
        <updating/>
        <source>setForUpdate(_proxyRule	: SelfType) updating;
// -------------------------------------------
// Created 13 September 2005 by cnwdvb1
// -------------------------------------------
vars

	attribute,
	realAttribute	: CM_YAOverstowAttribute;
	set				: ObjectSet;
	imex			: CM_IMEXStatus;
	rule			: SelfType;
	terminal		: CM_Terminal;

begin

	terminal := _proxyRule.myTerminal;
	create set transient;
	
	// Get existing persistent overstow attributes.
	self.allYAOverstowAttributes.copy(set);
	
	foreach attribute in _proxyRule.allYAOverstowAttributes do
		// Try and locate an existing attribute of the proxy's type.
		realAttribute := self.getYAOverstowAttribute(attribute.type);
		
		if realAttribute = null then
			// We don't have one so create a new version.
			create realAttribute persistent;
			// Update the little sucker.
			realAttribute.setForUpdate(attribute, self);
		else
			// We have found an existing attribute so take it out of delete set.
			set.remove(realAttribute);
		endif;
	endforeach;
	
	self.allImexStatuses.clear();
	
	foreach imex in _proxyRule.allImexStatuses do
		// Find a rule for the terminal.
		rule := imex.getYAOverstowRuleForTerminal(terminal);
		if rule &lt;&gt; null then
			// We have a rule which isn't the currently processing rule.
			// Have already warned the user at this point.
			if rule &lt;&gt; self then
				// Detach other rule from the imex.
				rule.detachRuleFromImex(imex);
				// Add rule to currently processing rule.
				self.allImexStatuses.add(imex);
			endif;
		else
			// Just add the sucker.
			self.allImexStatuses.add(imex);
		endif;
	endforeach;
	
	self.description				:= _proxyRule.description;
	self.overstowLaterVoyages		:= _proxyRule.overstowLaterVoyages;
	self.doVoyageJobChecks			:= _proxyRule.doVoyageJobChecks;
	self.numberOfFreeTEUs 			:= _proxyRule.numberOfFreeTEUs;	
	self.myTerminal					:= terminal;
	self.code						:= _proxyRule.code;

	// Get rid of old attributes that aren't needed.
	set.purge();
	
epilog
	delete set;
end;</source>
        <Parameter name="_proxyRule" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="f327d8e8-e310-49c6-bddd-0eed307057b7">
        <updating/>
        <source>setProxy(	_code,
			_description			: String;
			_numberOfFreeTEUs 		: Integer;
			_attributeArray 		: IntegerArray input;
			_allImexStatusDefaults	: CM_IMEXStatusByCodeDict;
			_overstowLaterVoyages	: Integer;
			_doVoyageJobChecks		: Boolean;
			_terminal				: CM_Terminal) updating;
// -------------------------------------------
// Created 13 September 2005 by cnwdvb1
// -------------------------------------------
vars

	i				: Integer;
	attribute		: CM_YAOverstowAttribute;
	rule			: SelfType;
	voyageIncluded	: Boolean;
	obj				: Object;

begin

	self.raiseExceptionIfNotTransient(method);
	
	// Don't need these proxies any more. Only needed to
	// prefil screen.
	self.allImexStatuses.clear();
	self.allYAOverstowAttributes.purge();
	
	// Create new proxy attributes.
	foreach i in _attributeArray do
		create attribute transient;
		attribute.setProxy(i, self);
	endforeach;
	
	if _attributeArray.includes(TI_Test_Voyage) then
		self.overstowLaterVoyages := _overstowLaterVoyages;
		self.doVoyageJobChecks		:= _doVoyageJobChecks;
	else
		self.overstowLaterVoyages	:= 0;
		self.doVoyageJobChecks		:= false;
	endif;
	
	self.description	:= _description;
	self.code			:= _code;
	self.myTerminal		:= _terminal;
	self.numberOfFreeTEUs := _numberOfFreeTEUs;	
	foreach obj in _allImexStatusDefaults do
		self.allImexStatuses.add(obj.CM_IMEXStatus);
	endforeach;

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_numberOfFreeTEUs" type="Integer"/>
        <Parameter name="_attributeArray" type="IntegerArray" usage="input"/>
        <Parameter name="_allImexStatusDefaults" type="CM_IMEXStatusByCodeDict"/>
        <Parameter name="_overstowLaterVoyages" type="Integer"/>
        <Parameter name="_doVoyageJobChecks" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="71fd7f51-a5d4-41bf-bb91-d6cb507c05c7">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;

vars

begin
	if _property.name = CM_YAOverstowRule::myTerminal.name or
	   _property.name = CM_YAOverstowRule::allYardAllocations.name then
		return false;
	endif;
	return inheritMethod(_rootClass, _property);
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="8e028f7c-5f59-4bbc-b350-9946c6785ba0">
        <source>showThumbnailData(pHeadings, pData : HugeStringArray input; _terminal : CM_Terminal);
// -------------------------------------------
// Created 21 September 2005 by cnwdvb1
// -------------------------------------------
vars

	imex		: CM_IMEXStatus;
	str			: String;
	attribute	: CM_YAOverstowAttribute;

begin

	pHeadings.clear;
	pData.clear;
	
	pHeadings.add('Code'); pData.add(self.code);
	pHeadings.add('Description'); pData.add(self.description);
	//pHeadings.add('This Rule Is The Default Rule For IMEX Statuses');
	pHeadings.add('Default Rule For IMEX Statuses');	// 28/03/2008 cnwar2 #16316
	
	foreach imex in self.allImexStatuses discreteLock do
		 str := str &amp; ',' &amp; imex.description;
	endforeach;
	
	if str.length &gt; 1 then
		str := str[2:end];
	endif;
	pData.add(str);
	
	str := null;
	
	pHeadings.add('Selected Overstow Attributes');
	
	foreach attribute in self.allYAOverstowAttributes discreteLock do
		str := str &amp; ',' &amp; attribute.getTypeAsString(null);
	endforeach;
	
	if str.length &gt; 1 then
		str := str[2:end];
	endif;
	pData.add(str);
	
	if self.getYAOverstowAttribute(TI_Test_Voyage) &lt;&gt; null then
		pHeadings.add('Overstow Later Voyage');
		if self.overstowLaterVoyages = CM_YAOverstowRule.NeverOverstowLaterVoyage then
			pData.add('Never');
		else
			pData.add('Last Resort');
		endif;
		
		pHeadings.add('Do Voyage Checks');
		pData.add(self.doVoyageJobChecks.getYesNo());
	endif;
	
	//pHeadings.add('Number Of Free 20 Foot Spaces');
	pHeadings.add('Number Of Free 20ft Spaces');	// 28/03/2008 cnwar2 #16316
	pData.add(self.numberOfFreeTEUs.String);
end;</source>
        <Parameter name="pHeadings" type="HugeStringArray" usage="input"/>
        <Parameter name="pData" type="HugeStringArray" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="76662fed-1821-43b9-b243-8d93188ab1ea">
        <source>validateMe(_proxyRule, _realRule  : CM_YAOverstowRule; _terminal : CM_Terminal);
// -------------------------------------------
// Created 21 September 2005 by cnwdvb1
// -------------------------------------------
vars

	rule	: SelfType;
	imex	: CM_IMEXStatus;

begin

	// Need a code. Can be a duplicate.
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Code', null, null);
		app.raiseCMException(Input_required_field_code, null, null); // cnwdb2	PAR 35364
	endif;
	
	// Must have the old terminal reference.
	if self.myTerminal = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, 'Terminal reference is null', null, null);
	endif;
	
	// Warn user if the imex statuses are already pointing at other rules.
	foreach imex in self.allImexStatuses discreteLock do
		rule := imex.getYAOverstowRuleForTerminal(_terminal);
		if rule &lt;&gt; null then
			if _realRule = null or rule &lt;&gt; _realRule then
				app.raiseCMWarning2(Rule_alread_defaul_rule_imex, rule.code, imex.description, null, null, _realRule);
			endif;
		endif;
	endforeach;
	
	
	// Need at least one attribute.
	if self.allYAOverstowAttributes.isEmpty() then
		app.raiseCMException(Please_enter_least_attribu, null, null);
	endif;
	
end;</source>
        <Parameter name="_proxyRule" type="CM_YAOverstowRule"/>
        <Parameter name="_realRule" type="CM_YAOverstowRule"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
</Class>
