    <JadeMethod name="initializeMe" id="94082edd-331d-4197-87bb-cde2ff8ec20c">
        <updating/>
        <source>initializeMe(pKeyName:String; pIsDescending:Boolean; pIsCaseSensitive:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		13 March 2001 by cnwdad1
//
// Purpose:		Initializes the receiver's property values.
//
// Parameters:	pKeyName - The name of the sort key property.
//				pIsDescending - A boolean flag to indicate whether the values are to
//					be sorted in descending order.
//				pIsCaseSensitive - A boolean flag to indicate whether sorting should
//					be case-sensitive.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.keyName			:=	pKeyName;
	self.isDescending		:=	pIsDescending;
	self.isCaseSensitive	:=	pIsCaseSensitive;
end;</source>
        <Parameter name="pKeyName" type="String"/>
        <Parameter name="pIsDescending" type="Boolean"/>
        <Parameter name="pIsCaseSensitive" type="Boolean"/>
    </JadeMethod>
</Class>
