									app.invoiceStatusEnumToString(CM_InvoiceProcessLinx.firstInstance, CM_Invoice.INVOICE_APPROVEDRETURNED),
									'Invoice', sa);								
									
 	self.setupInvStatusEmailDefault(PINEmail_InvProcPel1Offset + CM_Invoice.INVOICE_OPEN, // ie. 340
									app.invoiceStatusEnumToString(CM_InvoiceProcessPel1.firstInstance, CM_Invoice.INVOICE_OPEN),
