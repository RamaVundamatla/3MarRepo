    <JadeMethod name="delete" id="a4217b81-aa47-4e5c-a0ed-7ecd9c9afd91">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Jan 2015	cnwmc5	Initial creation
08 Jan 2026 navma1 MTN-36897 PEN - Transient File Growth in PEN Production Environment 
*/

vars

begin
	if self.carrier &lt;&gt; null then
		delete self.carrier;
	endif;
	
	if self.driver &lt;&gt; null then
		delete self.driver;
	endif;
	
	if self.allDetails &lt;&gt; null and not self.allDetails.isEmpty() then
		self.allDetails.purge();
	endif;
	
	self.allPINs.purge();		//08.01.2026 navma1 #MTN-36897
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="daca58bb-5379-499e-b8d9-7e8681fe4f39">
        <updating/>
        <source>setProxyFromObject(_vvr: CM_VehicleVisitRecord) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 January 2015	cnwmc5	Initial creation

*/

vars
	carrier		: CM_Carrier;
	driver		: CM_DriverDetails;
	preNote		: CM_TrackedItem;
	releaseReq	: CM_Release;
	detail		: CM_VehicleVisitRecordDetail;
	
	wsCarrier	: WS_Carrier;
	wsDriver	: WS_Driver;
	wsDetail	: WS_VehicleVisitDetail;
	
begin
	inheritMethod(_vvr);
	
	self.visitNumber := _vvr.visitNumber;
	self.regNumber := _vvr.regNumber;
	self.timeIn := _vvr.timeIn.asStringForWebInterface();
	self.timeOut := _vvr.timeOut.asStringForWebInterface();
	self.gateName := _vvr.getGateInName();
	
	if _vvr.myVehicleBookingTimeslot &lt;&gt; null then
		self.vehicleBookingNumber := _vvr.myVehicleBookingTimeslot.id;
	endif;
	
	carrier := _vvr.getCarrier();
	if carrier &lt;&gt; null then
		create wsCarrier transient;
		wsCarrier.setProxyFromObject(carrier);
		self.carrier := wsCarrier;
	endif;
	
	driver := _vvr.myDriverDetails;
	if driver  &lt;&gt; null then
		create wsDriver transient;
		wsDriver.setProxyFromObject(driver); 
		self.driver := wsDriver;
	endif;
	
	foreach detail in _vvr.allVehicleVisitRecordDetails do
		create wsDetail transient;
		wsDetail.setProxyFromObject(detail);
		self.allDetails.add(wsDetail);
	endforeach;

epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="setVehicleVisitProxy" id="91aa0b64-d613-4615-b201-f10adf27c57e">
        <source>setVehicleVisitProxy(_vvr : CM_VehicleVisitRecord io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 January 2015	cnwmc5	Initial creation
13/05/2022 		navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
*/

vars
	terminal		: CM_Terminal;
	pinNo			: CM_PinNo;
	item			: Object;
	ti				: CM_TrackedItem;
	br				: CM_BulkRelease;
	gteEntity		: CMGTE_Entity;
	gate			: CM_Gate;
	gateArea		: CM_GateArea;
	gateLane		: CM_YardController;
	
	pinNoString		: String;
	
	pxyVBTS,
	vbts			: CM_VehicleBookingTimeSlot;
	loadState 		: Boolean;
	
	tmpController 	: CMIF_FlexiGateController;
	reserveDetail	: CM_ReserveDetail;
	reserveTI		: CM_ReserveTI;
	reserveSelection : CM_ReserveSelection;
	
	cargoType 		: CM_CargoType;
	
	driverCode 		: String;
	driverName 		: String;
	
begin
	terminal := app.myPassport.myTerminal;
	
	vbts := terminal.myVehicleBookingTerminal.allVBTimeslotsById[self.vehicleBookingNumber.trimBlanks];
	
	if vbts &lt;&gt; null then
		app.cmsBeginLoad(loadState);
		pxyVBTS := vbts.pxyCreateUpdateProxy().CM_VehicleBookingTimeSlot;
		app.cmsEndLoad(loadState);
		
		_vvr.setVehicleBookingTimeslotIfPxy(pxyVBTS);
	endif;
	
	gate := terminal.getGate(self.gateName);
	if gate &lt;&gt; null then
		gateArea := gate.getFirstAGate_IN;
		if gateArea &lt;&gt; null then
			gateLane := gateArea.getLaneByNumber(self.gateLane.Integer);
		endif;
	endif;
	
	if self.driver &lt;&gt; null then
		driverCode := self.driver.code;
		driverName := self.driver.name;
	endif;
	
	_vvr.setProxyFlexiGate(	driverCode,
							driverName,
							self.carrier.code,
							null,					//13/05/2022 navhl20 TFS 53430
							self.regNumber,
							null,
							null,
							terminal,
							gate,
							gateLane,
							null);
	
	_vvr.setIsUpdatable(false);
	
	foreach pinNoString in self.allPINs do
		pinNo := terminal.allPinNos[pinNoString];
		if pinNo = null then
			app.raiseCMException(WARNING_PIN_NOT_ACTIVE_RR, null, null);
			return;
		endif;
		
		foreach item in pinNo.allItems do
			create tmpController transient;
			tmpController.myTerminal			:= terminal;
			tmpController.myVehicleVisitRecord 	:= _vvr;
			
			if item.isKindOf(CM_TrackedItem) then
				ti := item.CM_TrackedItem;
				
				if ti.isKindOf(CM_Container) then
					if ti.isEmpty then
						tmpController.jobType 	:= CMGTE_Entity.JobType_EmptyIN;
					else 
						tmpController.jobType 	:= CMGTE_Entity.JobType_FullIN;
					endif;
				elseif ti.isChassis then
					tmpController.jobType 		:= CMGTE_Entity.JobType_ChassisIN;
				else					
					tmpController.jobType 		:= CMGTE_Entity.JobType_GeneralIN;
				endif;
				
				create gteEntity as ti.getGTEClassToCreate() transient;
				gteEntity.setPXYFromController(tmpController);
				gteEntity.setPxyFromTI(ti);
				gteEntity.setMyVVRifPxy(_vvr);
				
			elseif item.isKindOf(CM_BulkRelease) then
				br := item.CM_BulkRelease;
				if terminal.allBulkReleasesByCodeDate.includes(br) then
					 if not br.isActiveRoadRelease() then
						app.raiseCMException(WARNING_PIN_NOT_ACTIVE_RR, null, null);
						return;
					 endif;
				endif;
				
				if br.mySubTerminal &lt;&gt; null then
					tmpController.subTerminalCode		:= br.mySubTerminal.code;
				endif;
				tmpController.mtOnly				:= br.isForMTs;
				tmpController.myBulkRelease			:= br;
				tmpController.operatorCode			:= br.getOperatorCode();
				
				foreach reserveDetail in br.allReserveDetails do
					if reserveDetail.isComplete then
						continue;
					endif;
					
					create gteEntity as CMGTE_Release transient;
					gteEntity.CMGTE_Release.setPXYFromBulkRelease(br, reserveDetail);
					gteEntity.setMyVVRifPxy(_vvr);
					
					tmpController.myReserveDetail 	:= reserveDetail;
					
					if reserveDetail.isKindOf(CM_ReserveTI) then
						reserveTI := reserveDetail.CM_ReserveTI;
						ti := reserveTI.getTI();
						
						gteEntity.setPXYFromController(tmpController);
						gteEntity.setPxyFromTI(ti);
					elseif reserveDetail.isKindOf(CM_ReserveSelection) then
						reserveSelection := reserveDetail.CM_ReserveSelection;
						
						cargoType := reserveDetail.getCargoType();
						if cargoType &lt;&gt; null then
							tmpController.cargoType		:= cargoType.id;
						endif;
						tmpController.isoTypeCode		:= reserveDetail.getISOTypeCode();
						tmpController.myProduct 		:= reserveDetail.getMyProduct();
						tmpController.numItems			:= reserveDetail.totalRequested;
						
						if cargoType.id = TI_CargoType_Container then
							if br.fullRelease then
								tmpController.jobType 		:= CMGTE_Entity.JobType_FullOUT;
							else
								tmpController.jobType 		:= CMGTE_Entity.JobType_EmptyOUT;
							endif;
						elseif cargoType.isTrailer then
							tmpController.jobType		:= CMGTE_Entity.JobType_ChassisOut;
						else
							tmpController.jobType		:= CMGTE_Entity.JobType_GeneralOUT;
						endif;
						
						gteEntity.setPXYFromController(tmpController);
					endif;		
				endforeach;
			endif;
			
			delete tmpController;
		endforeach;
		
	endforeach;
	
epilog
	app.cmsEndLoad(loadState);
	
	delete tmpController;
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="io"/>
    </JadeMethod>
</Class>
