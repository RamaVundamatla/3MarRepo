    <JadeMethod name="getTIsFor" id="1ee41857-af05-4a8b-aaea-b3de61017783">
        <source>getTIsFor( _items : CM_DutyDocItemSet; _allTis : CM_TISet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2012	cnwndl1	Initial creation

*/

vars

	item : CM_DutyDocItem;
	ti : CM_TrackedItem;

begin

	_allTis.clear();
	
	if _items = null then
		return;
	endif;

	foreach item in _items do
		ti := item.getMyTrackedItem();
		if ti &lt;&gt; null then
			_allTis.addNoDuplicates(ti,false);
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_items" type="CM_DutyDocItemSet"/>
        <Parameter name="_allTis" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTotalDutyOf" id="1506289c-aad3-4d8f-ba14-1f9af9f58657">
        <source>getTotalDutyOf( _items : CM_DutyDocItemSet ):Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

	decimal : Decimal [16,4];
	item : CM_DutyDocItem;

begin

	if self.dutyDeposit &lt;&gt; 0 then	// PAR 31516
		return 0;
	endif;
	
	if _items &lt;&gt; null then
		foreach item in _items do
			decimal := decimal + item.duty;
		endforeach;
	endif;

epilog

	return decimal;

end;</source>
        <Parameter name="_items" type="CM_DutyDocItemSet"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
