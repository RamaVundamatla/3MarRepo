    <JadeMethod name="getSealNumberAny" id="4cb5037f-0b1e-45bf-be8e-4b50564cf587">
        <source>getSealNumberAny():String;
//----------------------------------------------------------------
//	Created:	08 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Reports - dont change signature
vars

begin
	//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNum'
	if self.getSealNum.trimBlanks = "" then
		//15 Sep 2010	NDL	Par 25608 - change to using method 'getSealNumCustomsFirst' or 'getSealNumCustoms'
		if self.getSealNumCustomsFirst.trimBlanks = "" then
			//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNumShipper'
			return self.getSealNumShipper;	//dont care if blank
		else
			//15 Sep 2010	NDL	Par 25608 - change to using method 'getSealNumCustoms' or 'getSealNumCustomsFirst'
			return self.getSealNumCustomsFirst;
		endif;
	else 
		return self.getSealNum;
	endif;

end;</source>
