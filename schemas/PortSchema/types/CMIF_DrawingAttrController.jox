    <JadeMethod name="handleMTGrade" id="4e04946d-dd63-49e1-ad74-2f7d4cf08ca0">
        <source>handleMTGrade( _ti : CM_TrackedItem; _theColour : Integer output );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

	mtGrade : CM_MTGrade;

begin

	if _ti.isContainer then
		mtGrade := _ti.cargoIF_GetObjectForETRow(ETRow_AvailabilityGradeCode).CM_MTGrade;
	endif;

	if mtGrade &lt;&gt; null then
		_theColour := mtGrade.colour;
	else
		_theColour := White;
	endif;
	
	if mtGrade &lt;&gt; null then
		if not self.allAvailGrades.includes(mtGrade) then
			self.allAvailGrades.add(mtGrade);
			self.beginNotification(mtGrade, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_theColour" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleMTGradeObj" id="8b9cd758-2e52-40e7-a432-b099826d18c4">
        <source>handleMTGradeObj(_mtGrade : CM_MTGrade; _codesArray : StringArray input; _colorArray :IntegerArray input;_objArray : ObjectArray input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

	theCode : String;
	theColor : Integer;

begin
	
	if _mtGrade = null then
		_codesArray.atPut(TI_ColourMode_MTGrade, null);
		_colorArray.atPut(TI_ColourMode_MTGrade, NullColour);
		return;
	endif;

	theCode		:= _mtGrade.description;
	theColor	:= _mtGrade.colour;
	
	if not self.allAvailGrades.includes(_mtGrade) then
		self.allAvailGrades.add(_mtGrade);
		self.beginNotification(_mtGrade, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
	endif;

	_codesArray.atPut(TI_ColourMode_MTGrade, theCode);
	_colorArray.atPut(TI_ColourMode_MTGrade, theColor);
	_objArray.atPut(TI_ColourMode_MTGrade, _mtGrade);

end;</source>
        <Parameter name="_mtGrade" type="CM_MTGrade"/>
        <Parameter name="_codesArray" type="StringArray" usage="input"/>
        <Parameter name="_colorArray" type="IntegerArray" usage="input"/>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="handleOperator" id="96084ee2-76bb-4f5e-8e54-7ded544741d5">
        <source>handleOperator(_operatorCode : String; _operator : CM_Operator; _viewModeCode : String; _code : String output; _color :Integer output; _object : Object output) protected;
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
// ////12/12/2014   cnwma1 PAR #35353  Satellite view by operator generates error
// Purpose:     
// ---------------------------------------------------------------------------
vars
	iter		: Iterator;
	trimCode,
	theCode,
	codeKey		: String;
	theColor,
	colorKey	: Integer;
	theObject : Object;
	invalidOperator : Boolean;
begin

	trimCode := _operatorCode.trimBlanks;

	if trimCode = null or (_viewModeCode &lt;&gt; null and _viewModeCode &lt;&gt; trimCode) then
		_code 	:= null;
		_color	:= NullColour;
		return;
	endif;

	iter := self.myIterOperator;
	self.allOperators.startKeyGeq(trimCode, 0, iter);
	self.allOperators.getIteratorKeys(codeKey, colorKey, iter);
	
	theCode		:= null;
	theColor	:= NullColour;
	if codeKey = trimCode then
		// found the right one
		theCode		:= trimCode;
		theColor	:= colorKey;
		iter.next(theObject);
	else
		if _operator &lt;&gt; null then
			invalidOperator := false;
			on Exception do app.handleDeletedObject(exception,_operator,invalidOperator);  // 12/12/2014 cnwma1 PAR #35353	
			self.allOperators.addNoDuplicates(_operator,false);
			self.beginNotification(_operator, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
			theCode		:= trimCode;
			theColor	:= _operator.colour;
			theObject := _operator;
			
			if invalidOperator then 
				return; 
			endif;
		endif;
	endif;

	_code	:= theCode;
	_color	:= theColor;
	_object := theObject;

end;</source>
        <access>protected</access>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_viewModeCode" type="String"/>
        <Parameter name="_code" type="String" usage="output"/>
        <Parameter name="_color" type="Integer" usage="output"/>
        <Parameter name="_object" type="Object" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleOperator2" id="6f3edaa3-d27d-4220-9e7d-99d819e2a5a9">
        <source>handleOperator2(_code : String; _operator : CM_Operator; _codesStr, _colourStr, _objStr : String io);
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theCode		: String;
	theColour	: Integer;
	theObject	: Object;

begin
	self.handleOperator(_code, _operator, null, theCode, theColour,theObject);

	_codesStr := _codesStr &amp; theCode &amp; GridData_SubDelimiter;
	_colourStr	:= _colourStr &amp; theColour.String &amp; GridData_SubDelimiter;
	_objStr	:= _objStr &amp; self.getOidStringForObject(theObject) &amp; GridData_SubDelimiter;
//	_objStr := _objStr &amp; GridData_SubDelimiter;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_codesStr" type="String" usage="io"/>
        <Parameter name="_colourStr" type="String" usage="io"/>
        <Parameter name="_objStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="handleOperatorObj" id="55124891-c8f3-4aa7-86cf-cb4fc5d81145">
        <source>handleOperatorObj(_code : String; _codesArray : StringArray input; _colorArray :IntegerArray input;_objArray : ObjectArray input);
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	iter		: Iterator;
	trimCode,
	theCode,
	codeKey		: String;
	theColor,
	colorKey	: Integer;
	tmpOperator	: CM_Operator;

begin

	trimCode := _code.trimBlanks;

	iter := self.myIterOperator;
	self.allOperators.startKeyGeq(trimCode, 0, iter);
	self.allOperators.getIteratorKeys(codeKey, colorKey, iter);
	
	if codeKey = trimCode then
		// found the right one
		theCode		:= _code;
		theColor	:= colorKey;
	else
		tmpOperator := self.myRoot.allOperators[trimCode];
		if tmpOperator &lt;&gt; null then
			self.allOperators.add(tmpOperator);
			theCode		:= trimCode;
			theColor	:= tmpOperator.colour;
		else
			theCode		:= null;
			theColor	:= NullColour;
		endif;
	endif;

	_codesArray.atPut(TI_ColourMode_Operator, theCode);
	_colorArray.atPut(TI_ColourMode_Operator, theColor);
	_objArray.atPut(TI_ColourMode_Operator, tmpOperator);

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_codesArray" type="StringArray" usage="input"/>
        <Parameter name="_colorArray" type="IntegerArray" usage="input"/>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="handleOperatorXML" id="b073e756-9594-4f59-97a9-e9300365af5b">
