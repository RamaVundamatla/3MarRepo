    </PrimAttribute>
    <PrimAttribute name="releaseRequestNum" id="c1cd467c-f253-4b35-a11f-483a8025d169">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="releaseRequestOid" id="dd420802-4c60-4370-8e3d-43f806702d8b">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="createProxyWorkOrder" id="fcf39497-438e-4d02-99b6-ce6a3a5a1159">
        <source>createProxyWorkOrder(): CM_WorkOrderTIDtl;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2018	jlger1	Initial creation

*/

vars
	pxyWorkOrder : CM_WodRelease;
begin
	create pxyWorkOrder transient;
	
	
	return pxyWorkOrder;

epilog

end;</source>
        <ReturnType type="CM_WorkOrderTIDtl"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="81aa4df5-1790-4682-ae47-6ff1b99c6451">
        <updating/>
        <source>setProxyFromObject(_object: CM_WodRelease) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16/05/2018	jlger1	Initial creation 38520
12/02/2019	jlgdap1	TFS 43062 PEL1 Container Services - Changes in Web Portal
//1/04/2019	JLGNS1	Bug 44134: PEL1 - Container Services - Release Extension (Release Work Order drop down not responding)
*/

vars
	relReq : CM_BulkRelease;
begin
	inheritMethod(_object);
	relReq := _object.getMyReleaseRequest();				//Bug 44134
	if relReq &lt;&gt; null then									//Bug 44134
		self.releaseRequestOid := relReq.getOidAsString;	//Bug 44134
		self.releaseRequestNum := relReq.code;				//Bug 44134
	endif;
	
	self.setProxyToDoTasks(_object);
	
	self.customsClearanceNumber := _object.customsClearanceNumber;		// TFS 43062
epilog

end;</source>
        <Parameter name="_object" type="CM_WodRelease"/>
    </JadeMethod>
    <JadeMethod name="updateProxyWorkOrder" id="b3178c4f-96e5-4ab1-87f7-b34d983fabdb">
        <source>updateProxyWorkOrder(_pxyWorkOrder: CM_WorkOrderTIDtl input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/05/2018	jlger1	Initial creation
12/02/2019	jlgdap1	TFS 43062 PEL1 Container Services - Changed in Web Portal
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
18 Mar 2023 navhl20 Defect 57168: MTN - Unable to create a Release work order using web portal
*/

vars
	bulkRelease  : CM_BulkRelease;
begin
	inheritMethod(_pxyWorkOrder);
	
	/*
	12.01.2023 navma1 #56141 Task#56147
	bulkRelease:= app.myPassport.getObjectOfTypeFromOid(self.releaseRequestOid,CM_BulkRelease).CM_BulkRelease;
	if bulkRelease &lt;&gt; null then
		if _pxyWorkOrder.myParent &lt;&gt; null and _pxyWorkOrder.myParent.CM_WorkOrderTI.mySource &lt;&gt; null then
			_pxyWorkOrder.myParent.CM_WorkOrderTI.mySource.proxyAddBulkRelease(bulkRelease);
		endif;	
	endif;
	*/
	
	self.updateProxyToDoTasks(_pxyWorkOrder);
	
	bulkRelease:= app.myPassport.getObjectOfTypeFromOid(self.releaseRequestOid,CM_BulkRelease).CM_BulkRelease;		//18.3.2023 navhl20 #57168
	_pxyWorkOrder.CM_WodRelease.setBulkRelease(bulkRelease); 														//18.3.2023 navhl20 #57168
	_pxyWorkOrder.CM_WodRelease.setCustomsClearanceNumber(self.customsClearanceNumber); 		// TFS 43062
epilog

end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WorkOrderTIDtl" usage="input"/>
    </JadeMethod>
</Class>
