// 27 Mar 2013	PJS		PAR # 31232
//--------------------------------------------------
vars

begin
	
	//self.type := CellularStructure;  // 31232
end;</source>
    </JadeMethod>
    <JadeMethod name="createDefaultDischargeCC" id="adc3a0cc-da7b-4ccb-b6b7-310b641022b5">
        <updating/>
        <source>createDefaultDischargeCC(_passport : CM_Passport input) updating;
/*
------------------------------------------------------------------------
Created:			26 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	bayVoyageIter : Iterator;
	bayVoyage : CM_BayVoyage;
begin
	exclusiveLock(self);
	
	bayVoyageIter := self.allBayVoyagesByOrdinal.createIterator;
	while bayVoyageIter.next(bayVoyage) do	
		bayVoyage.createDefaultDischargeCC(_passport);
	endwhile;

	// PAR 27749
	if self.myVoyage.myROROStructure &lt;&gt; null then
		self.myVoyage.myROROStructure.createDefaultDischargeCC(_passport);
	endif;

	// ################################
	// This will update the display on screen of this voyage
	self.causeEvent(self.myVoyage.myTerminal.getTerminalEvent(EVENT_REFRESH_VOYAGE_AREA), false, null);
epilog
	delete bayVoyageIter;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createPlanningStructures" id="e5f78548-6658-43d6-ba5b-85439f3f505d">
        <updating/>
        <source>createPlanningStructures(_vesselStructure : CM_CellularVesselStructure) updating;
/*
------------------------------------------------------------------------
Created:			17 January 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		As above. Special comment:
Returns:			As above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
27/3/2013		PJS				PAR # 31232	
09 Jun 2017	NDL	TFS 4662 - Remove dev errors if no structure found.												
------------------------------------------------------------------------
*/
vars
	bayVoyage : CM_BayVoyage;
	bay : CM_BayDefn;
	aftBay : CM_BayVoyage;
	tmpCargoVessel : CM_CellularVesselStructure;
	aVessel : CM_Vessel;
begin

	exclusiveLock(self);
	if _vesselStructure = null then
		aVessel := self.myVoyage.getMyVessel();
		if aVessel = null then
		//if (not CM_CellularVessel.hasInstance(aVessel)) then
		//	app.raiseCMException2(MethodWithNullParam, method.qualifiedName, 'Cellular Vessel Reference', null, null);
			return;
		else
			tmpCargoVessel := aVessel.myCellularVesselStructure;
		endif;
	else
		tmpCargoVessel := _vesselStructure;
	endif;

	if tmpCargoVessel = null then
	//	app.raiseCMException2(MethodWithNullParam, method.qualifiedName, 'Cellular Vessel Reference', null, null);
		return;
	endif;
		
	if (not self.allBayVoyagesByOrdinal.isEmpty) then
		//---------------------------
		//The bayVoyages are already here.
		//We should at some point consider a "fixup" situation where we compare to vessel what we have here, and
		//then go and attempt to make this voyage's defns the same. 
		//---------------------------
		return;
	endif;
	//-----------------
	//OK, now copy over the complicated stuff
	//-----------------
	aftBay := null;	//1st time through, no aft bay.
	foreach bay in tmpCargoVessel.allBaysByOrdinal do
		//-----------------
		//Copy..
		//-----------------
		bayVoyage := bay.cloneSelfAs(CM_BayVoyage, false).CM_BayVoyage;
		bayVoyage.setMyVoyageStructure(self);
		if aftBay &lt;&gt; null then
			aftBay.setMyAftBay(bayVoyage);
		endif;
		bayVoyage.createPlanningStructures(bay);
		aftBay := bayVoyage;
		// Par 13170
		bayVoyage.setSequenceNums();
	endforeach;

	// ### Very important - link all the slots from bay to bay - backwards &amp; forwards, up and down etc
	foreach bayVoyage in self.allBayVoyagesByOrdinal do// AKB2003FEB added
		bayVoyage.updateSlotLinks(); // AKB2003FEB added
	endforeach;// AKB2003FEB added
	
	self.bridgeAfterBay := tmpCargoVessel.bridgeAfterBay;
	self.use40Id := tmpCargoVessel.use40Id;
	self.isoHalfHeights := tmpCargoVessel.isoHalfHeights;
	//epr par 27566 20/5/2011 
//	self.setType(tmpCargoVessel.myVessel.structureType);	// //cnwas3 par23535   // 31232
	
	self.xmlSideProfilePort := self.getXMLGridSideProfile(true, ShpDisplayMode_Defn, null, true);
	self.xmlSideProfileStarboard := self.getXMLGridSideProfile(true, ShpDisplayMode_Defn, null, false);

end;</source>
        <Parameter name="_vesselStructure" type="CM_CellularVesselStructure"/>
    </JadeMethod>
    <JadeMethod name="doObjectVolatilityConversion" id="03e2aa08-9e05-45a4-927d-9c6a7411647a">
        <updating/>
        <source>doObjectVolatilityConversion(_converter: CM_ObjectVolatilityConverter input; _logIndent: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2010	cnwkpd1	PAR #23525 - System performance enhancements

*/

vars
	bay				: CM_BayVoyage;
	
begin
	inheritMethod(_converter, _logIndent);
	
	_converter.doChangeVolatilityOfObject(self.allBayVoyagesById, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allBayVoyagesById40, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allBayVoyagesByOrdinal, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allHatchLids, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allHolds, _logIndent);
	
	foreach bay in self.allBayVoyagesById discreteLock do
		bay.doObjectVolatilityConversion(_converter, _logIndent);
	endforeach;
	
	
epilog

end;</source>
        <Parameter name="_converter" type="CM_ObjectVolatilityConverter" usage="input"/>
        <Parameter name="_logIndent" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="eraseAllVoyagePlanning" id="6b8b0725-4131-4833-af77-07585f6e034b">
        <updating/>
        <source>eraseAllVoyagePlanning() updating;
// ---------------------------------------------------------------------------
// Created:		June 2006 cnwrs1 ccms 1022
// ---------------------------------------------------------------------------
vars
	iter : Iterator;
	aVoyageJob : CM_VoyageJob;
	aBayVoyage : CM_BayVoyage;
	aRequest : CM_SlotRequest;
	slot : CM_SlotController;
begin
	foreach aBayVoyage in self.allBayVoyagesByOrdinal do
		iter := aBayVoyage.allSlotRequestByMoveType.createIterator();
		while iter.next(aRequest) do
			// PAR 29033 aRequest.erase(NORMAL_ERASE);
			slot := aRequest.mySlotController;// PAR 29033 
			slot.eraseSlotRequest(aRequest);// PAR 29033 
		endwhile;
		delete iter;
	endforeach;
	iter := self.myVoyage.allVoyageJobs.createIterator();
	while iter.next(aVoyageJob) do
		if aVoyageJob.myTerminal &lt;&gt; null then	
			aVoyageJob.causeTerminalEvent(CM_VoyageJob.Event_Mode_Delete);
		endif;
		aVoyageJob.erase(NORMAL_ERASE);
	endwhile;
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="findLocation" id="28ac0ecc-91d8-493d-a066-2ed120ed90f5">
        <source>findLocation(_strs : StringArray; _noException : Boolean; _foundLC : CM_LocationsController io; _foundHeight : Integer io);
/// ---------------------------------------------------------------------------
// Created:     05 July 2001 cnwdwq1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// 27 Mar 2013	PJS			PAR #31232
// ---------------------------------------------------------------------------
// 03 Feb 2014	cnwer1		PAR 33223 -remove code to return ship block controller if nwnp needs to return to search general cargo holds

vars
	bay : CM_Bay;
	remainingStrs : StringArray;
	tStr : String;
	tStr2 : String;
begin
	//OK, we have to process the passed in strs. It MUST == a valid bayid OR nothing IF
	//we are a non-planned voyage.
	if _foundLC &lt;&gt; null then
		return;
	endif;
	
	//th2 added 26/09/06 - avoid index out of bounds exception
	if _strs.isEmpty then
		return;
	endif;
	
	tStr := _strs[1].trimBlanks;

	if tStr = null then
		return;
	endif;	
	//------------------
	//Extract the bay id portion of the string
	//------------------
	bay := self.getBayFromString(tStr);
	if bay = null then
		// We are looking for a location which we may not find.  Returning null (_foundLC = null) is valid.
		// Blowing up here is not nice/necessary.  JC 12/10/2004
		//app.raiseCMException2(ERR_FIELD_VALUE, tStr, 'bayID', null, null);
		return;
	endif;
	
	//------------------------
	//Ask bay to find LC
	//------------------------
	create remainingStrs transient;
	_strs.copy(remainingStrs);
	//Chop off the bayId position before we pass to the bay to find the rest
	if remainingStrs.size &gt; 1 then
		remainingStrs[1] := remainingStrs[2];
	else
		if remainingStrs[1].length &lt;= tStr.length then
			remainingStrs[1] := null;
		else
			remainingStrs[1] := remainingStrs[1][(tStr.length + 1) : end];
		endif;
	endif;
	//--------------------
	//We have the bay, ask it to retrieve the LC 
	//--------------------
	bay.findLocation(remainingStrs, _noException, _foundLC, _foundHeight);
	

epilog
	delete remainingStrs;
end;</source>
        <Parameter name="_strs" type="StringArray"/>
        <Parameter name="_noException" type="Boolean"/>
        <Parameter name="_foundLC" type="CM_LocationsController" usage="io"/>
        <Parameter name="_foundHeight" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllUnLinkedRequests" id="9209e975-775b-4c28-80e0-e3981a1fccc2">
        <updating/>
        <source>getAllUnLinkedRequests(_allRequests : CM_RequestArray input; _typeDischarge : Boolean;_moveType : Integer; _clear : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	aBay : CM_BayVoyage;
	aSlot : CM_LocationsController;
	aRequest,linkRequest : CM_Request;
begin
	if _clear then // PAR 28968
	_allRequests.clear;
	endif;
	
	foreach aBay in self.allBayVoyagesById do
		foreach aRequest in aBay.allSlotRequestByMoveType do
// PAR 28968 			if _typeDischarge &lt;&gt; aRequest.isDischarge then // get only loads or discharges
			if _typeDischarge = aRequest.isReleaseType then // get only loads or discharges
				continue;
			endif;
			if aRequest.getMoveType() &lt;&gt; _moveType then // SOB or DLR
				continue;
			endif;
			if aRequest.getAttrIsBackend() then // PAR 21746
			// PAR 21746 if aRequest.fortyBack  // no back ends
			// PAR 21746 or aRequest.isBackend then // PAR 19945
				continue;
			endif;
			
			// 11/07/2013 cnwmh5 #31938 rewrite
			if aRequest.getMoveType() = _moveType then
				linkRequest := aRequest.getDLRSOBRequestLink();
				// not linked
				if linkRequest = null then
					_allRequests.add(aRequest);
				endif;
			endif;
			
		endforeach;
	endforeach;
end;</source>
        <Parameter name="_allRequests" type="CM_RequestArray" usage="input"/>
        <Parameter name="_typeDischarge" type="Boolean"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getBayFromString" id="50080208-3f32-4ac0-ba3b-09a5c56eddec">
        <source>getBayFromString(bayStr: String io ) : CM_Bay protected;
/*
 ------------------------------------------------------------------------
Created:			04 November 2002 by cnwdwq1
Purpose:			Attempts to retrieve the bay id from the passed in string
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
constants
	CELL_BAY_LEN = 2;
vars
	bayId : String;
	possBay : CM_Bay;
	newBayStr : String;
begin
	newBayStr := bayStr.trimBlanks;
	if newBayStr.trimBlanks = null then
		return null;
	endif;
	//------------------
	//For a cell voyage, our bayIds are currently 2 chars long
	//------------------
	if newBayStr.length &lt; CELL_BAY_LEN then
		return null;
	endif;
	
	bayId := newBayStr[1 : CELL_BAY_LEN].trimBlanks;
	//Now, set the string we got passed in to the new bayid (what we think it is)
	bayStr := bayId;
	
	possBay := self.allBayVoyagesById[bayId];
	if possBay &lt;&gt; null then
		return possBay;
	endif;
	return self.allBayVoyagesById40[bayId];
end;</source>
        <access>protected</access>
        <Parameter name="bayStr" type="String" usage="io"/>
        <ReturnType type="CM_Bay"/>
    </JadeMethod>
    <JadeMethod name="getColourCodeSummary" id="a7268940-0063-48a9-b15c-c784cf731b4c">
        <source>getColourCodeSummary( _ccSumDict : CMIF_CCSumryByDishPtCmdtyGrp input; _tis : CM_TIArray) ;//serverExecution;
// ---------------------------------------------------------------------------
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

constants
	NULL_DISPORT = "????";
	NULL_CMDTYGRP = "????";
vars
	bayVoyage : CM_BayVoyage;
	slot : CM_SlotController;
	scArray : CM_SlotControllerArray;
	summObj	:	CMIF_ColourCodeSummary;
	key1, key2	:	String;
	ti	:	CM_TrackedItem;
	defGroup	:	String;
begin

	if _ccSumDict = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'Summary dictionary', null, null);
		return;
	endif;
	if _tis = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'TIs dictionary', null, null);
		return;
	endif;
	_ccSumDict.clear;
	
	defGroup := self.myVoyage.myTerminal.getConfig(DefCommodityGroup).String.trimRight;
 	if defGroup = null then
		defGroup := NULL_CMDTYGRP;
 	endif;
	create scArray transient;
	foreach bayVoyage in self.allBayVoyagesByOrdinal do
		bayVoyage.getActiveSlotLCsForColourCode(LOAD_COLOURCODE, scArray);
		foreach slot in scArray do
			if slot.mySlotRequestLoad.moveType &lt;&gt; LOAD_MOVETYPE and 
			   slot.mySlotRequestLoad.moveType &lt;&gt; DLR_MOVETYPE and 
			   slot.mySlotRequestLoad.moveType &lt;&gt; SOB_MOVETYPE then
				continue;
			endif;
			if slot.mySlotRequestLoad.getAttrIsBackend() then // PAR 21746
			// PAR 21746 if slot.mySlotRequestLoad.fortyBack 
			// PAR 21746 or slot.mySlotRequestLoad.isBackend then // PAR 19945
				//We only count 30's, 40's, 45's once
				continue;
			endif;
			//------------------
			//Build the keys			
			//------------------
			key1 := slot.mySlotRequestLoad.getDischargePort();
			key2 := slot.mySlotRequestLoad.getCommodityGroup();
			if key2 = null then
				key2 := defGroup;
			endif;
			//------------------
			//See if it exists
			//------------------
			summObj := _ccSumDict[key1, key2];
			if summObj = null then
				create summObj transient;			
				summObj.dischargePort := key1;
				summObj.commodityGroup := key2;
				_ccSumDict.add(summObj);
			endif;
			//---------------
			//OK, a LOAD CC slot Request
			//---------------
			summObj.addSlotRequestItem(slot.mySlotRequestLoad);
		endforeach;
	endforeach;	
	//----------------
	//Update the tracked items into the mix
	//----------------
	foreach ti in _tis do
		if ti = null then
			continue;
		endif;
		
		if ti.isChild then
			continue;
		endif;
		//if not ti.isExport and not ti.isRehandle then									// PAR #25021
		if not ti.isExport and not ti.isTranshipOutbound and not ti.isRehandle then		// PAR #25021
			continue;
		endif;
		//---------------------
		//Locate the sunmmaryobject for the key
		//---------------------
		summObj := _ccSumDict[ti.dischargePort.trimRight, ti.commodityGroup.trimRight];
		if summObj = null then
			//-----------------
			//Hmm, try and locate using the default commodityGroup object
			//-----------------
			summObj := _ccSumDict[ti.dischargePort.trimRight, defGroup];
			if summObj = null then
				//----------------
				//AAarrggghh, still no summary object. Create one, it wont have ANY CC stuff
				//in it... But at least they can see it
				//----------------
				key1 := ti.dischargePort.trimRight;
				if key1 = null then
					key1 := NULL_DISPORT;
				endif;
				key2 := ti.commodityGroup.trimRight;
				if key2 = null then
					key2 := NULL_CMDTYGRP;
				endif;
				summObj := _ccSumDict[key1, key2];
				if summObj = null then
					create summObj transient;
					summObj.dischargePort := key1;
					summObj.commodityGroup := key2;
					_ccSumDict.add(summObj);
				endif;
			endif;
		endif;
		summObj.addTrackedItem(ti);
	endforeach;
epilog
	delete scArray;
end;</source>
        <Parameter name="_ccSumDict" type="CMIF_CCSumryByDishPtCmdtyGrp" usage="input"/>
        <Parameter name="_tis" type="CM_TIArray"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="f6fc74ef-edc3-4348-8d69-9d047b385dfa">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	27 September 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _attrName = ETRow_NumberOfHolds then
		return self.allHolds.size.asStringJMT;
	elseif _attrName = ETRow_BayOrder then
		return self.getPhysicalBayOrder();
	elseif _attrName = ETRow_ISOVessel then
		return self.isoHalfHeights.asStringJMT;
	elseif _attrName = ETRow_BridgeAfterBay then
		return  self.bridgeAfterBay.asStringJMT();	
	elseif _attrName = ETRow_Use40Id then
		return  self.use40Id.asStringJMT();
	elseif _attrName =  ETRow_StowageNumbering or
		_attrName = 'stowageNumbering'then
		if self.useBayCellTierNumbering then
			return Vessel_Stowage_Type_BCT_Text;
		else
			return Vessel_Stowage_Type_BTC_Text;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGridDefinitionArray" id="f72850da-a717-48eb-a666-6f4770e098ee">
        <executionLocation>server</executionLocation>
        <source>getGridDefinitionArray(_theHolds : IntegerArray; _data : BinaryArray200 input) serverExecution;
// ---------------------------------------------------------------------------
// Created:		September 2003 By cnwrs2
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	s1, s2 : String;
	tmpCell : CM_CellDefn;
	tmpTier : CM_TierDefn;
	tmpSlot : CM_SlotDefn;
	
	tmpLid : CM_HatchLid;
	tmpHold : CM_Hold;
	ls : Boolean;
	tmpBay : CM_Bay;
	xml, sml : String;
	yml : String;
	zml : String;
	colour1,colour2,theCol,theRow,currentColour,colEnd,rowStart,rowEnd,colEndRows : Integer;
	numBays		: Integer;
	
begin

	beginLoad;

	// these are used for the hold colours to give us a checker board effect
	// this '4' will be 6 if there are triple bays
	colour1 := 14671839; //Yellow;
	colour2 := 12566463; //Red;

	if self.hasTripleBays then
		colEndRows := 6;
	else
		colEndRows := 4;
	endif;
	numBays := self.allBayVoyagesByOrdinal.size;
	if numBays &lt;= 12 then
		colEnd := numBays;
	else
		colEnd := (numBays / colEndRows).Integer + 1;
	endif;
	rowStart := 1;
	rowEnd := colEndRows;
	
	theRow := 0;
	theCol := 0;
	
	currentColour := colour1;
	foreach tmpHold in self.allHolds do

		theCol := theCol + 1;
		if theCol &gt; colEnd then
			currentColour := colour2;
			theCol := 1;
			rowStart := rowStart + colEndRows;
			rowEnd := rowStart + colEndRows - 1;
		endif;
		theRow := rowStart;

		if currentColour &lt;&gt; colour1 then
			currentColour := colour1;
		else
			currentColour := colour2;
		endif;

		foreach tmpBay in tmpHold.allBays do
			tmpBay.getGridDefinitionArray(theRow, theCol, currentColour, _data);
			theRow := theRow + 2;
		endforeach;

	endforeach;

epilog
	endLoad;
	
end;</source>
        <Parameter name="_theHolds" type="IntegerArray"/>
        <Parameter name="_data" type="BinaryArray200" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getHoldBeforeBridge" id="bd713384-7c5f-4f44-809f-af9340d179c4">
        <source>getHoldBeforeBridge() : CM_Hold;
// ---------------------------------------------------------------------------
// Created:		04 July 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpBay : CM_Bay;
begin
	tmpBay := self.allBayVoyagesById[self.bridgeAfterBay];
	if tmpBay &lt;&gt; null then
		return tmpBay.myHold;
	endif;
	
	return null;
	
end;</source>
        <ReturnType type="CM_Hold"/>
    </JadeMethod>
    <JadeMethod name="getLCsWithColourCoding" id="24b0b1ad-7ab1-4b63-9383-12a7f5244965">
        <source>getLCsWithColourCoding(_lcs: CM_LCSet input; _moveType : Integer);
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		Get the slot controllers with CC that is in a job and not planned
//
// ---------------------------------------------------------------------------

vars
	aBayVoyage : CM_BayVoyage;	
	aSlotReq : CM_SlotRequest;
	moveType : Integer;
	iter01 : Iterator;
	
	//cnwmc5 - 3 Jan 2014 - PAR 33400
	fm 			: CM_FutureMove;
	nonEDIFM 	: Boolean;
begin
	
	moveType := _moveType;
	
	
	foreach aBayVoyage in self.allBayVoyagesByOrdinal do
		iter01 := aBayVoyage.allSlotRequestByMoveType.createIterator();
		
		//cnwmc5 - 3 Jan 2014 - PAR 33400
		while iter01.next(aSlotReq) do
			if aSlotReq.moveType &lt;&gt; moveType then
				continue;
			endif;
			
			if aSlotReq.myJob = null then
				continue;
			endif;
			
			if not aSlotReq.mySlotController.allPlannedFutureMoves.isEmpty() then
				nonEDIFM := false;
				foreach fm in aSlotReq.mySlotController.allPlannedFutureMoves do
					if not fm.isKindOf(CM_FutureMovePlannedEDI) then
						nonEDIFM := true;
						break;
					endif;
				endforeach;
				if nonEDIFM then
					continue;
				endif;
			endif;
			
			_lcs.add(aSlotReq.mySlotController);
		endwhile;
		delete iter01;
	endforeach;
epilog
	delete iter01;
end;</source>
        <Parameter name="_lcs" type="CM_LCSet" usage="input"/>
        <Parameter name="_moveType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMatchingSlot" id="d2a9e7c8-1668-4720-9ee1-fb32bce50879">
        <source>getMatchingSlot(_refSlot: CM_SlotController): CM_SlotController;
//----------------------------------------------------------------
//	Created:	05 August 2004	by Jason Chapman  (cnwjc2)
//	
//	Return slot with matching ordinals
//
//----------------------------------------------------------------
vars
	bay		: CM_BayVoyage;
	tmpSlot	: CM_SlotController;
begin
	tmpSlot := _refSlot;
	
	if tmpSlot = null or
	tmpSlot.myBayVoyage = null then
		return null;
	endif;
	
	bay := self.allBayVoyagesByOrdinal[tmpSlot.myBayVoyage.ordinalBay];
	
	if bay = null then
		return null;
	endif;
	
	return bay.allSlotControllersByOrdinal[tmpSlot.ordinalDeck, tmpSlot.ordinalCell, tmpSlot.ordinalTier];

end;</source>
        <Parameter name="_refSlot" type="CM_SlotController"/>
        <ReturnType type="CM_SlotController"/>
    </JadeMethod>
    <JadeMethod name="getOOWCreation" id="3d566bed-9a3c-4908-b11f-683e235b01ce">
