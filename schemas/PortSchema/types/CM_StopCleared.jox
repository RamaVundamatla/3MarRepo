    <JadeMethod name="getCustDocObject" id="190ffaee-6fbc-4730-8bdc-698116331ef1">
        <source>getCustDocObject() : CM_CustomDocument;
/*
Purpose:			

Date		Who		Reason
12/02/2023	navkc1 Bug 62402: FR - 53715 - Customs status update on cancellation of first document.
*/

vars
	ti : CM_TrackedItem;
	custDoc : CM_CustomDocument;
begin
	if self.custDocCode = null then
		return null;
	endif;
	
	ti := self.myTrackedItem;
	
	if ti = null then
		return null;
	endif;
	
	if ti.allCustomDocuments.isEmpty then
		return null;
	endif;
	
	foreach custDoc in ti.allCustomDocuments discreteLock do
		if custDoc.code = self.custDocCode then
			return custDoc;
		endif;
	
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_CustomDocument"/>
    </JadeMethod>
