    <JadeMethod name="translateForm" id="4bf7fe4c-0b41-478d-a7a3-270136b9bf5b">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0010093, locale);
	btnClose.translateCaption(Xlat_0010094, locale);
	btnFind.translateCaption(Xlat_0010095, locale);
	btnTrouble.translateCaption(Xlat_0010096, locale);
	lblBOL.translateCaption(Xlat_0010097, locale);
	lblBookRef.translateCaption(Xlat_0010098, locale);
	lblDateFrom.translateCaption(Xlat_0010099, locale);
	lblDateTo.translateCaption(Xlat_0010100, locale);
	lblDriverID1.translateCaption(Xlat_0010101, locale);
	lblTerminal.translateCaption(Xlat_0010102, locale);
	lblTrans.translateCaption(Xlat_0010103, locale);
end;</source>
    </JadeMethod>
</GUIClass>
