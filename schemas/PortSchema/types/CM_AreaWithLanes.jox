    <JadeMethod name="setForUpdateInUse" id="0db07a00-f844-4a07-8f2c-544f9a78a5bd">
        <updating/>
        <source>setForUpdateInUse(_proxy: CM_AreaWithLanes; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	inheritMethod(_proxy, _passport);
	
	self.laneCount	:= _proxy.laneCount;
epilog

end;</source>
