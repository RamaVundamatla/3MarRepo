    <JadeMethod name="createBOLCargoScenario5" id="bd995639-a51f-4d89-a768-8b92dcd81ff9">
        <updating/>
        <source>createBOLCargoScenario5(_terminalId : String; _voyage : CM_Voyage; _containers : CM_TISet input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     17/02/2015	create on-site cargo directly
//				One container with a BOL, three children with no BOL, transit
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//25/07/2022    navgm20     ChangeRequest 54095: EUP - Outturn Remarks on BOL
// ---------------------------------------------------------------------------

constants
	BlockStack = "BS2";
vars
	terminalId,
	bolId,
	id			: String;
	bs: CM_BlockStack;
	packTIs	: CM_TIArray;
	wh: CM_IrregularBlockArea;
	cargoType: CM_CargoType;
	product	: CM_Product;
	location: CM_LocationsController;
	voy : CM_Voyage;
	parent : CM_TrackedItem;
	child1,
	child2,
	child3,
	child4	: CM_TrackedItem;
	realBOL	: CM_BOL;
	pxyBOL : CM_BOLIn;
	pxyBOLItem : CM_BOLDtl;
	subTerminal : CM_SubTerminal;

begin
	voy := _voyage;
	bolId := "MSCUAR721174S";
	terminalId := _terminalId;
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminalId);

	// create an actual BOL for this cargo
	// get the subterminal
	subTerminal := self.getSubTerminal(null);

	create pxyBOL transient;	
	pxyBOL.setProxy(bolId, voy, self.myOperator, null, 4, BOLType_GeneralBillOfLading, self.getTerminal, subTerminal, null, null, null, false, null, null, null,
																																						null);	//13/07/2022 navgm20 Tfs 54095
	// BOL weight is 12246
	pxyBOL.setPropertyValue("weightNet", 12246.Decimal);
	pxyBOL.setPropertyValue("weightGross", 12246.Decimal);
	
	create pxyBOLItem transient;
	pxyBOLItem.setProxy(pxyBOL, TI_CargoType_Container, "GENL", "colour", "mark", 4, 5, 6000, 200, 300, 400, "ACDG", "ACDG", "remarks");
	pxyBOL.allBOLDtls.add(pxyBOLItem);
	
	app.myTrxCA.trxCreateBOL(pxyBOL, realBOL, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	delete pxyBOLItem;
	delete pxyBOL;
	bs:= self.getTerminalArea(BlockStack).CM_BlockStack;

	// scenario 5 - 1 20ft FCL container with 3 children, 1 BOL, transit
	self.opts.addAssoc(UTTI_BOL, bolId);
	self.opts.addAssoc(UTTI_VoyageCode, voy.code);
	id := "INKX6557510";
	self.deleteContainer(id);
	parent := self.addContainerAtLocation( id, self.myOperator, "2210", "TR20", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
	self.opts.addAssoc("TotalWeight", parent.getTareWeight().Integer);
	self.updateTI(parent);		// set the total weight to the tare weight so that packing the children gets the total correct
	_containers.add(parent);

	wh := self.getTerminal.allTerminalAreas[self.getProfileSetting(UT_Profile.P_WAREHOUSE).asString].CM_IrregularBlockArea;
	location := wh.allLocationsControllers.first;

	// child 1, break-bulk, spare parts, no BOL
	cargoType := self.getCargoType("GENERAL");
	product := cargoType.allProducts[null, "SPARE PARTS"];
	
	id := "INKU6557510-1S";
	self.deleteCargo(id, cargoType);
	child1 := location.createCargoAtLocation(cargoType, product, self.myOperator, id);
	self.opts.removeAssoc("TotalWeight");
	self.opts.removeAssoc(UTTI_BOL);
	self.opts.addAssoc("TotalWeight", 4082);	// all children
	self.opts.addAssoc("TotalQuantity", 120);	// just this one
	self.opts.addAssoc("Voyage", voy);		// for all children
	self.opts.addAssoc("Commodity", "US20");
	self.updateTI(child1);
	self.assertLocationHasTI(location, child1);

	// child 2, vehicle, saloon
	cargoType := self.getCargoType("VEHICLE");
	product := cargoType.allProducts[null, "SALOON"];
	id := "2T1BR32E44C190373S";
	self.deleteCargo(id, cargoType);
	child2 := location.createCargoAtLocation(cargoType, product, self.myOperator, id);
	self.opts.removeAssoc("TotalQuantity");
	self.updateTI(child2);		// set the same total weight
	self.assertLocationHasTI(location, child2);

	// child 3, vehicle, mini
	cargoType := self.getCargoType("VEHICLE");
	product := cargoType.allProducts[null, "MINI"];
	id := "1FMZU77E63UA25029S";
	self.deleteCargo(id, cargoType);
	child3 := location.createCargoAtLocation(cargoType, product, self.myOperator, id);
	self.updateTI(child3);
	self.assertLocationHasTI(location, child3);

	// pack all children
	create packTIs transient;
	packTIs.add(child1);
	packTIs.add(child2);
	packTIs.add(child3);
	self.packContainer(parent.CM_Container, packTIs);
	self.packCompleteContainer(parent.CM_Container);
	self.assertEqualMsg(parent.numChildren, 3, "Container " &amp; parent.id &amp; " children incorrect");

epilog
	if pxyBOL &lt;&gt; null then   // 28.09.2017 cnwma1
		if pxyBOLItem &lt;&gt; null then
			delete pxyBOLItem;
		endif;
		delete pxyBOL;
	endif;
	delete packTIs;
end;</source>
        <access>protected</access>
