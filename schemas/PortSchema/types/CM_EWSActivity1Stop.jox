    <JadeMethod name="setForUpdate" id="e91f7b43-cf93-4ab8-9244-9fab56f1b9c9">
        <updating/>
        <source>setForUpdate(_proxy: SelfType) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14/02/2022	navdap1		Initial creation TFS 52268 AAT 1-Stop VBS Integration
//
vars

begin
	inheritMethod(_proxy);
	
	self.dataAction := _proxy.dataAction;
	self.dataType := _proxy.dataType;
	self.objectOid := _proxy.objectOid;
	self.myReleaseRequestObject := _proxy.myReleaseRequestObject;
epilog

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
