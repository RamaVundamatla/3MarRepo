    <JadeMethod name="getCalculationTypes" id="bf4c5255-89b0-45a0-bb8c-a7d0ea4bd21b">
        <source>getCalculationTypes() : String;
/*
Purpose:			

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
*/

vars
	detail : CM_InvoiceContractDetails;
	objset : ObjectSet;
	calcCsv : String;
	calcObj : CM_CalculationType;
begin
	create objset transient;
	foreach  detail in self.allInvoiceContractDetails discreteLock do
		if detail.myInvoiceLineType &lt;&gt; null
		and not objset.includes (detail.myCalculationType) then
			objset.add(detail.myCalculationType);
		endif;
	endforeach;
	
	foreach calcObj in objset as CM_CalculationType do
		if calcCsv = null then
			calcCsv := calcObj.code;
		else
			calcCsv := calcCsv&amp; "," &amp; calcObj.code;
		endif;
	endforeach;
	return calcCsv;
epilog
	delete objset;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getContractDetail" id="aee62387-c8ce-48ff-a51d-7359922fca95">
        <source>getContractDetail(_ti : CM_TrackedItem; _invLineType : CM_InvoiceLineDesc; _dateTime : TimeStamp) : CM_InvoiceContractDetails;
/*
Purpose:			

Date		Who		Reason
20 Jun 2023	navab1	CR 55653 TASK 55669 
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars
	detail 			: CM_InvoiceContractDetails;
	canLogExtraInfo : Boolean;
begin
	
	canLogExtraInfo := app.canLogExtraDetail();									//28.05.2024 navma1 #64224
	
	foreach detail in self.allInvoiceContractDetails discreteLock, reversed 
		where detail.myInvoiceLineType = _invLineType do

		if _dateTime &lt; detail.fromTS  or _dateTime&gt; detail.toTS then // detail not validate
			if canLogExtraInfo then		//28.05.2024 navma1 #64224
				app.invLog("Detail not valid. charge date is " &amp; _dateTime.String &amp; " Detail is " &amp; detail.fromTS.String &amp; " to " &amp; detail.toTS.String &amp; ".", LogINFO.String);
			endif;
			continue;
		endif;
		
		if detail.myInvoiceContractCriteria &lt;&gt; null // ### TFS CR 56806 TASK 56807 15MAR2023 NAVAB1
		and _ti &lt;&gt; null then  // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
			if not detail.myInvoiceContractCriteria.matches(_ti) then
				if canLogExtraInfo then		//28.05.2024 navma1 #64224
					app.invLog("CONT - Detail " &amp; detail.fromTS.String &amp; "/" &amp; detail.toTS.String &amp; " Ignore, does not match criteria :'" &amp; detail.myInvoiceContractCriteria.description &amp; "'", LogINFO.String);
				endif;
				continue;
			endif;
			if canLogExtraInfo then		//28.05.2024 navma1 #64224
				app.invLog("CONT - Detail " &amp; detail.fromTS.String &amp; "/" &amp; detail.toTS.String &amp; " MATCH, does match criteria :'" &amp; detail.myInvoiceContractCriteria.description &amp; "'", LogINFO.String);
			endif;
		else
			if canLogExtraInfo then		//28.05.2024 navma1 #64224
				app.invLog("CONT - Detail " &amp; detail.fromTS.String &amp; "/" &amp; detail.toTS.String &amp; " Using NO criteria'" , LogINFO.String);
			endif;
		endif;
		
		return detail;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_invLineType" type="CM_InvoiceLineDesc"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <ReturnType type="CM_InvoiceContractDetails"/>
    </JadeMethod>
    <JadeMethod name="getContractType" id="8baad242-2f97-4a06-bd31-ebaaf42e2369">
        <source>getContractType() : IntegerArray;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/

vars
	contractTypeArray : IntegerArray;
	contractDetail : CM_InvoiceContractDetails;
	contractType : Integer;
begin
	create contractTypeArray transient;
	foreach contractDetail in self.allInvoiceContractDetails do
		contractType := contractDetail.contractType;
		if not contractTypeArray.includes(contractType) then
			contractTypeArray.add(contractType);
		endif;
	endforeach;
	return contractTypeArray;
epilog

end;</source>
        <ReturnType type="IntegerArray"/>
    </JadeMethod>
