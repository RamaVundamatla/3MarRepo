    <JadeMethod name="pwDeCode" id="126f38cd-83d2-47e4-9d28-3a195bdbe74a">
        <source>pwDeCode( _obj : Object; _string : String ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2021	navndl1	Initial creation	TFS 51632

*/

vars

	str : String;
	bin : Binary;
	invalid : Boolean;

begin

	if _string.trimBlanks = null then
		return null;
	endif;

	on Exception do app.handleDecode1420Exc( exception, invalid );
	bin := _string.base64Decode();
	if invalid then
		if _obj &lt;&gt; null then
			app.writeLog("Failed to decrypt password on " &amp; _obj.String, LogINFO);
		else
			app.writeLog("Failed to decrypt password", LogINFO);
		endif;
	else
		str := bin.uncompressToString;
	endif;

	return str;
	

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_string" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pwEnCode" id="b7d1e795-f617-4298-9783-709b1f44f777">
        <source>pwEnCode( _string : String ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2021	navndl1	Initial creation	TFS 51632

*/

vars

	str : String;

begin

	if _string.trimBlanks = null then
		return null;
	endif;

	str := _string.Binary.compressToBinary( Binary.Compression_ZLibSmall ).base64Encode;
	
	return str;

epilog

end;</source>
        <Parameter name="_string" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="queryUserForInterrupt" id="c82d624b-b0ce-4dcf-9193-3d02e73b4d6d">
        <source>queryUserForInterrupt(errorCode: Integer; msgParam0: String; msgParam1: String; appendString: String; msgBoxTitle: String);
//DO NOT USE THIS METHOD FROM NOW ON.
//WE NOW PRESENT ALL MESSAGES BACK TO THE USERS VIA THE ERRORSLIST IN THE TRXS
//Dave.

vars
	msgDetail:     String;
	response:      Integer;
begin

	if msgParam0 = null then
		msgDetail := app.getErrorString(errorCode);
	elseif msgParam0 &lt;&gt; null and msgParam1 = null then
		msgDetail := app.getErrorString1(errorCode, msgParam0);
	elseif msgParam0 &lt;&gt; null and msgParam1 &lt;&gt; null then
		msgDetail := app.getErrorString2(errorCode, msgParam0, msgParam1);
	endif;	
	response := app.msgBox(msgDetail, msgBoxTitle,
		MsgBox_Yes_No + MsgBox_Default_Second + MsgBox_Exclamation_Mark_Icon);

	if response = MsgBox_Return_Yes then
		return;
	else
		app.setContinueCMExceptions(false);
		app.raiseCMException(VB_USER_CANCELED_TRANS, null, null);
		return;
	endif;
end;</source>
        <Parameter name="errorCode" type="Integer"/>
        <Parameter name="msgParam0" type="String"/>
        <Parameter name="msgParam1" type="String"/>
        <Parameter name="appendString" type="String"/>
        <Parameter name="msgBoxTitle" type="String"/>
    </JadeMethod>
