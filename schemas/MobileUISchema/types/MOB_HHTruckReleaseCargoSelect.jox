    <JadeMethod name="clearFields" id="ff0fc1bb-1636-46d2-8b6d-b26226bb2dd8">
        <updating/>
        <source>clearFields() updating;
/*

Date		Who		Reason
17 September 2015	cnwer1	Initial creation PAR

*/

vars

begin
	self.myCargo1 := null;
	self.myCargo2 := null;
	self.myWLE1:=	null;
	self.myWLE2:= 	null;
	self.lblCargo1.caption:=null;
	self.lblCargo2.caption:=null;
	self.txtCargo1.text:=null;
	self.txtCargo2.text:=null;
	self.txtCargo1.userObject:=null;
	self.txtCargo2.userObject:=null;
	self.txtCargo1.visible:=false;
	self.txtCargo2.visible:=false;
epilog

end;</source>
