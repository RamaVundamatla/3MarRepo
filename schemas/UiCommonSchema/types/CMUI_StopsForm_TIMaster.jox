    <JadeMethod name="loadStops" id="d1579e6e-8188-448c-85ec-b15710c448b6">
        <updating/>
        <source>loadStops(_tiMaster :CM_TIMaster)updating, protected;
// ---------------------------------------------------------------------------
// Created:     17 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	table			: CM_DataTable;
	stopTable		: CM_StopsTable;
	passport		: CM_Passport;
	user			: CM_User;
	viewColl, maintColl		: CM_StopsTableByIdDict;
	strCaption,
	strInfo			: String;
	row, maxLength,
	case, col			: Integer;
	gotException	: Boolean;
begin
	on Exception do app.handleDeletedObject (exception, _tiMaster, gotException);	
	
	// this next statement will cause an exception if _tiMaster has been deleted
	self.expectedEdition 	:= _tiMaster.edition;
	
	if gotException then
		// display message and close form
		self.unloadFormWithMessage;
	endif;

	self.expectedStops	:= self.getStopsString ();
	passport 			:= app.myPassport;
	user				:= passport.myUser;
	table				:= self.tblStopsAdd;
	
	table.rows := table.fixedRows;
	
	if user &lt;&gt; null then
		create maintColl transient;
		create viewColl transient;
		
		user.getStopsToMaintSys(maintColl); 
		user.getStopsToViewSys(viewColl); 
	else
		maintColl := app.myRoot.allStopsTable;
		viewColl := app.myRoot.allStopsTable;
	endif;
	
	
	
	// load stops to be added first
	foreach stopTable in maintColl do
		if not stopTable.isAvailable then
			continue;
		endif;
		if not stopTable.isValidForCargoType (_tiMaster.cargoType) then
			// this stop not relevant for current bol
			continue;
		endif;
		
		if _tiMaster.hasStopOfType( stopTable ) then
			// can't add it again
			continue;
		endif;
			
		row := table.addItemObject (stopTable, null.String);
		
		table.setCellValueByName (ETRow_Heading, row, stopTable.heading);
		
		if not self.canUpdate then
			col := table.getColumnByRowName (ETRow_Add);
			
			if col &lt;&gt; null then
				table.accessCell (row, col).inputType 	:= Table.InputType_None;
				table.accessedCell.text					:= null;
			endif;
		endif;
	endforeach;
	
	// sort in heading order
	col := table.getColumnByRowName (ETRow_Heading);
	
	if col &lt;&gt; null then
		table.sortColumn [1]	:= col;
		table.resort;
	endif;
	
	// now load stops that can be cancelled/deleted
	table 		:= self.tblStopsClear;
	table.rows 	:= table.fixedRows;
	
	foreach stopTable in viewColl do
		if not _tiMaster.hasStopOfType( stopTable ) then 
			// it's not set
			continue;
		endif;
		
		row := table.addItemObject (stopTable, null.String);
		
		table.setCellValueByName (ETRow_Heading, row, stopTable.heading);
		
		// check whether user has permission to maintain required infor for this stop
		col := table.getColumnByRowName (ETRow_Clear);
		
		if col &lt;&gt; 0 then
			if self.canUpdate and stopTable.userCanModify(null ) then
				table.accessCell (row, col).inputType	:= Table.InputType_CheckBox;
			else
				table.accessCell (row, col).inputType	:= Table.InputType_None;
				table.accessedCell.text					:= null;
			endif;
		endif;
	endforeach;	
	// sort in heading order
	col := table.getColumnByRowName (ETRow_Heading);
	
	if col &lt;&gt; null then
		table.sortColumn [1]	:= col;
		table.resort;
	endif;
epilog
	if maintColl.isTransient then	
		delete maintColl;
	endif;
	if viewColl.isTransient then
		delete viewColl;
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="_tiMaster" type="CM_TIMaster"/>
    </JadeMethod>
