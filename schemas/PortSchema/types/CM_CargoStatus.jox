    <JadeMethod name="setForCreate" id="ab53b691-792c-49b8-892d-ff0b176712de">
        <updating/>
        <source>setForCreate(pProxyStatus : SelfType ) updating;
/*
------------------------------------------------------------------------
Created:			06 June 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars

begin

	pProxyStatus.raiseExceptionIfNotTransient(method);

	self.code := pProxyStatus.code;
	self.description := pProxyStatus.description;
	self.abbreviation := pProxyStatus.abbreviation;
	
	setForUpdate(pProxyStatus);
	self.myRoot := app.myRoot;
end;</source>
        <Parameter name="pProxyStatus" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="d51695f1-b967-48cc-a1a9-f4e9dd184239">
        <updating/>
        <source>setForUpdate(pProxyStatus : SelfType) updating;
/*
------------------------------------------------------------------------
Created:			06 June 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
begin
	self.colour := pProxyStatus.colour;
	self.abbreviation:= pProxyStatus.abbreviation;
	self.description:= pProxyStatus.description;
end;</source>
        <Parameter name="pProxyStatus" type="SelfType"/>
    </JadeMethod>
