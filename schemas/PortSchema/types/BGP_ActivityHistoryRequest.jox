<Class name="BGP_ActivityHistoryRequest" id="45dcb026-7ba0-4765-989d-ad7a5747217d">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Activity History&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <ImplicitInverseRef name="myActivityHistory" id="7e863d95-f982-463c-9e36-f8c42c3f1302">
        <embedded/>
        <type name="CM_ActivityHistory"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="action" id="4f372c3c-5fea-4cde-8570-853c9f4cba9b">
        <updating/>
        <source>action(): Boolean updating;
// -------------------------------------------
// Created 29 March 2004 by cnwdvb1
// -------------------------------------------
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
vars

	errCode	: Integer;
	errTxt	: String;
	msg : String;
begin

	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, false, false);
	on LockException do app.alertLockExceptionHandler(exception);

	self.setUser();
	self.doSetInverseReferences();
epilog

	if errCode &lt;&gt; null then
		msg := 'Attempting to send message again';
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		// May as well have a little break while we are here.
		process.sleep(10000);
		app.myTrxUA.trxUpdateBGPRequest(self, false, 0, null, app.myPassport);
		self.causeEvent(BGP_Object.BGP_ActionRequest, true, null);
	endif;
	inheritMethod();
	return (errCode = null);

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="87c9bce1-3ce7-420d-bc20-7dfd7c8bf7a8">
        <updating/>
        <source>delete() updating;
// -------------------------------------------
// Created 06 April 2004 by cnwdvb1
// -------------------------------------------
// 14/05/2012	cnwcs5	par 29450 - change in signature of utlDeleteActivityHistory
//								  - remove resynchObject, use esxception handler instead of isValidObject
// 27 Jun 2019	jlgrs1	TFS45051 JMT terminate on a SDS secondary exception ie a takeover has happened.
vars
	history			:CM_ActivityHistory;
	gotException	:Boolean;
begin

// 	If we are getting deleted but we haven't processed our activity 
//	history then we have to delete it because it will be left floating.
	if self.isProcessed and errorCode = 0 then
		return;
	endif;
	
	on Exception do app.handleDeletedObject (exception, history, gotException);
	
	history := self.myActivityHistory;
	if history &lt;&gt; null then
		app.myUtilityDA.utlDeleteActivityHistory(history, app.myPassport);
	endif;
epilog	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSetInverseReferences" id="352cfebf-a059-4bfb-be52-0e4f30ae9117">
        <source>doSetInverseReferences() protected;
// -------------------------------------------
// Created 29 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if global.isValidObject(self.myActivityHistory) then
		// Any exceptions in here are handled by bgp exception handlers armed in action.
		app.myTrxUA.trxUpdateActivityRefences(self.myActivityHistory, app.myPassport);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="d883abc8-7598-49ee-a4ca-0133bc7498a0">
        <source>getDisplay(): String;

// cnwdvb1 17 February 2003 

vars

	str, detail : String;

begin
	
	str := inheritMethod();
	detail := app.getErrorString(Processing_Activity_History);
	return str &amp; Tab &amp; detail;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initActivityHistory" id="fdbf8f64-8b88-434f-a734-9ba9356ec793">
        <updating/>
        <source>initActivityHistory(_activityHistory : CM_ActivityHistory) updating;
// -------------------------------------------
// Created 29 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	self.myActivityHistory := _activityHistory;
	self.initRequestEvent(true, false, null);

end;</source>
        <Parameter name="_activityHistory" type="CM_ActivityHistory"/>
    </JadeMethod>
</Class>
