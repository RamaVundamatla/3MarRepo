    <JadeMethod name="doMnuCargoBulkAddTransClick" id="28d15c6e-6d06-45d9-8f0d-5c6ae73bce77">
        <updating/>
        <source>doMnuCargoBulkAddTransClick(theMenuItem : MenuItem) updating;
// ---------------------------------------------------------------------------
//07 Apr 2016	cnwrs1	TFS 1546 POL - Unpacking Process Options
// ---------------------------------------------------------------------------
vars
	transMaintForm : CMUI_TITransMaintModal;
	ti : CM_TrackedItem;
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	transMaintForm := app.loadForm(CMUI_TITransMaintModal, 
								CMUI_Assistant, 
								false, 
								false,
								false, 
								self.myTerminal,
								null).CMUI_TITransMaintModal;

	if transMaintForm = null then
		return;
	endif;
	transMaintForm.editModeOnly := true;
	transMaintForm.caption := self.caption;
	transMaintForm.isForCargoEdit := false;
//	configForm.cargoTypeId := self.filterCargoTypeId;
	// if showing cargo from selector or yard query etc
	if self.filterCargoTypeId = 0 and
	   self.myCurrentCargoBOLType &lt;&gt; null then
//		configForm.cargoTypeId := self.myCurrentCargoBOLType.id;
	endif;
	if 	self.useTblData	= false then 
		ti := self.myCurrentObject.CM_TrackedItem;
		transMaintForm.allTITrackitems.add(ti);	
	elseif CM_TrackedItem.hasInstance(self.myCurrentObject) then
		self.tblData.allSelectedObjects.copy(transMaintForm.allTITrackitems);
	endif;
	transMaintForm.myCurrentTrackedItem := transMaintForm.allTITrackitems.first;
	transMaintForm.myCurrentChargeSetting := self.defaultBulkAddCharge;
	transMaintForm.myCurrentTransactionType := self.defaultBulkAddTransType;
	if transMaintForm.myCurrentContainerEnqForm = null then
		transMaintForm.myCurrentChargeSetting := true;
	endif;
	transMaintForm.myCurrentContainerEnqForm := self;
	transMaintForm.showModal;

epilog
	self.mousePointer := Window.MousePointer_Default;
	delete transMaintForm;
end;</source>
        <Parameter name="theMenuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuCargoFSD" id="657517ed-631d-4a85-8daf-00bdfc05934c">
        <updating/>
        <source>doMnuCargoFSD(_menuItem: MenuItem input) updating;
// invoice contract prototype - mnuCargoPack hi-jacked for free storage via contract done with logging
// 23/05/2018 	Jlgns1	Bug 38662: STWO - Transaction resync for 2291 transactions gives error 14051
// 03/03/2021   cnwma1  Bug 50883: STWO - Storage Days Validation
// 26/01/2023	navkc1 	CR 61998 Task 62001: UI - Cargo Enquiry Re Eval Storage Free Multi Select

vars
	ti				: CM_TrackedItem;
	logger		    : CMIF_Logger;
	captionText		: String;
	dateTime		: TimeStamp;
	lDetails		: CMUI_SystemAlertsDetails;
	dataContainer	: CM_DataContainer;
	tableAgent		: CMUI_TableAgent;
	theReturn : Integer;
	tis				: CM_TISet; //26/01/2023	navkc1 CR 61998 Task 62001
begin
	ti := self.myCurrentObject.CM_TrackedItem;
	if ti = null then
		return;
	endif;
	
	/* // ### JIRA 33011 10OCT2024 NAVAB1
	if ti.hasTransactionOfType(TRANS_TYPE_FUTURE_STORAGE) then            //03.03.2021 cnwma1 #50883
		app.raiseCMException(ERR_UPDATE_REEVALUATE,null,ti);
		return;
	endif;
	*/
	
	create logger transient;
	app.setLogger(logger);
	
	//26/01/2023	navkc1 CR 61998 Task 62001
	create tis transient;
	self.tblData.allSelectedObjects.copy(tis);
	
	// ### TFS BUG 65860 30AUG2024 NAVAB1
	if tis.isEmpty then
		tis.add(ti);
	endif;
	
	// ### TFS BUG 60548 09OCT2023 NAVAB1 ti.evaluateFreeStorageDays(null);  // TFS 2937 added null
	
	// ### TFS BUG 60548 09OCT2023 NAVAB1 call TRX . The code used in evaluateFreeStorageDays() had beginTransaction and commit etc. So removing that and instead have a proper TRX
	while true do
		//26/01/2023	navkc1 CR 61998 Task 62001
		//app.myTrxUA.trxUpdateReEvalFreeStorageDate(ti, app.myPassport);
		app.myTrxUA.trxUpdateReEvalFreeStoDateTIs(tis, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Free Storage Reeval", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
	// show the logging
	// Update the navigator
	self.setNavigatorHeading("Free Storage"); 
	create lDetails;
	create dataContainer transient;
	
	logger.getLogsAsBlocks(dataContainer);
	
	lDetails.centreWindow();
	
	create tableAgent transient;
	dataContainer.headerColour	:=	self.colorHeadingColumn;
	dataContainer.valueColour	:=	self.colorValueColumn;
	dataContainer.displayMode	:=	2;
	captionText := "Free Storage logging " &amp; dateTime.asStringJMT;

	lDetails.show();
	lDetails.setCaption(captionText);
	tableAgent.addDataToTable(	dataContainer,
								lDetails.tblAlerts,
								true,
								2,
								false,
								1,
								1,
								1,
								1,
								null,
								true);	

	lDetails.setMyTerminal(self.myTerminal);
	

epilog
	if logger &lt;&gt; null then
		app.setLogger(null);	// this deletes the 'logger' instance
	endif;
	delete tableAgent;
	delete dataContainer;
	delete tis;
end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuCargoLabelPrint" id="f0583e28-a295-451b-8bf2-b286b2028951">
        <source>doMnuCargoLabelPrint();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 January 2010	cnwndl1	Initial creation	CCMS MES 1004

*/

vars
	tiArray : CM_ObjectArrayActual;
	obj : Object;
begin
	
	if self.tblData.allSelectedObjects.isEmpty and self.mnuCargoLabelPrint.userObject = null then
		return;
	endif;
	
	create tiArray transient;
	
	foreach obj in self.tblData.allSelectedObjects do
		if obj.isKindOf(CM_TrackedItem) then
			tiArray.add( obj.CM_TrackedItem );
		endif;
	endforeach;
	
	if self.mnuCargoLabelPrint.userObject &lt;&gt; null then
		if not tiArray.includes(self.mnuCargoLabelPrint.userObject.CM_TrackedItem) then
			tiArray.add( self.mnuCargoLabelPrint.userObject.CM_TrackedItem );
		endif;
	endif;
	
	if tiArray.isEmpty then
		return;
	endif;
	
	self.myAssistant.showCargoIdLabelPrintForm(tiArray);
	
	
epilog

	delete tiArray;
	
end;</source>
    </JadeMethod>
