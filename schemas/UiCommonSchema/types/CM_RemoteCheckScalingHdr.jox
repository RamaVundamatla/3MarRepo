<Class name="CM_RemoteCheckScalingHdr">
    <JadeMethod name="loadRemoteTable" id="0d8b92f3-43ce-4722-9dd9-db55b35efe81">
        <updating/>
        <source>loadRemoteTable(_table: CM_EntryTable io) updating;

// cnwdvb1 14 May 2003 

vars

	detail	: CM_RemoteDataDtl;
	count	: Integer;

begin

	inheritMethod(_table);
	foreach detail in self.allRemoteDataDtl do
		count := count + 1;
		self.addRemoteRow(_table, 'Transfer Detail ' &amp; count.String, Click, detail);
	endforeach;

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
</Class>
