    <JadeMethod name="uReleaseByType_ISOFromArea" id="55001c9c-5d75-492d-a75c-62d9f84491eb">
        <updating/>
        <source>uReleaseByType_ISOFromArea() updating;
// 8 Feb 2010	cnwjre1	
// Test gate out of a "by type" release request for ISO type from a nominated area, with no yard allocation active
vars
	releaseRequest: CM_BulkRelease;
	truck: CM_Vehicle;
	ti: CM_TrackedItem;
	vvr: CM_VehicleVisitRecord;
begin
	self.disableAllYA(true);
	deleteReleaseRequest("UTRRRoad");
	deleteVehicle("UTTRUCK");
	self.deleteContainer("TEST0000011");
	self.deleteTerminalArea("UTBS1");
	
	bs := self.addBlockStack("UTBS1", 100, null);
	
	ti := self.addContainer("TEST0000011", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "GENL", TI_IMEX_STATUS_IMPORT);
	self.move(ti, bs.myLocationsController);
	assertEqual(ti.myPrimaryActualLocation, bs.myLocationsController);
	
	// Create the Release
	self.opts.purge;
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("TerminalArea", bs);
	releaseRequest := addReleaseByTypeRequestOpts("UTRRRoad", BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	
	// Gate Out
	self.opts.purge;
	self.opts.addAssoc("release", releaseRequest);
	vvr := self.gateOutContainer("UTTRUCK", "", "UTDRIVER", null, true, singleGate , bs.id);
	
	truck := self.getVehicle("UTTRUCK");
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.first.getRTLetter(), "RT");
	assertEqual(truck.allRoadJobs.first.workListEntries.first.allRTQueueEntries.first.allTasks.first.sourceLocationId, bs.id);
	
	deleteReleaseRequest("UTRRRoad");
	deleteVehicle("UTTRUCK");

epilog
	self.disableAllYA(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="uSPTEST" id="627668b5-7ab8-41b9-a91c-f18b982df80d">
        <updating/>
        <source>uSPTEST() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2025	navsp1	Initial creation

*/


vars
	booking: CM_BookingRef;
	ti: CM_TrackedItem;
	vvr : CM_VehicleVisitRecord;
	voyage1 : CM_Voyage;
	vessel : CM_Vessel;
	isDoClearanceCheck : Boolean;
    i : Integer;
    cont : String;
    terminal : CM_Terminal;
begin
    terminal := app.myRoot.allTerminals["SPT"];
    app.myPassport.setMyTerminal(terminal);
	isDoClearanceCheck := terminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);

		//deleteVoyage("SPYVOY1");
	//deleteVessel("SPTVES1");
	//vessel := addVesselCellular("SPTVES1", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	//assertNotNull(vessel);
	voyage1 := terminal.allVoyagesByCode.getAtKeyGeq("VOYSP888", null);// addVoyageWithContainerStructur("SPYVOY1", "UTBOAT", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	assertNotNull(voyage1);

	while i &lt; 2 do
        i := i+1;
        cont := "TI16JUN25"&amp;i.String;
        	deleteContainer(cont);
	self.deleteBooking("SPTBK0"&amp;i.String);

self.deleteVehicle("TRK"&amp;i.String);
        booking := self.addBookingForContainer("SPTBK0"&amp;i.String, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage1, "AUPKL", "2200", "MT");
        assertNotNull(booking);
        
        ti := self.addPrenotedContainer(booking.allBookingRefItems.first,  cont);
        

        vvr := self.gateInContainer("TRK"&amp;i.String, cont, "2200", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, "GENL", singleGate);
        self.workVehicle(vvr);
	endwhile;
	assertEqual(vvr.myRoadJob.status, JOB_COMPLETE);
	
	self.roadExit(vvr);
	assertIsDeleted(vvr.myRoadJob);
	
	assertEqual(ti.state, TI_STATE_NORMAL);
	assertEqual(ti.getImExStatus, TI_IMEX_STATUS_STORAGE);

	
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
end;</source>
    </JadeMethod>
    <JadeMethod name="unitTestBeforeClass" id="5737d0c6-3823-4ccf-987b-b5fa86edaac5">
        <updating/>
        <source>unitTestBeforeClass() updating, protected;
//18 December 2008	cnwdw1	
//
vars
	boatName, voyageName: String;
	isDoClearanceCheck : Boolean;
begin

	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	
	inheritMethod;
	
	deleteVehicle("UTTRUCK");
	self.deleteTerminalArea(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString);
	bs := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString, 100, null);
	self.addYACatchAll(self.getProfileSetting(UT_Profile.P_YA).asString, bs);

	dualGate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	pin := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_PIN).asString);
	pout := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_POUT).asString);
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	operator := getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	voyageName := "UTVOY1"&amp;self.getProfileStr(UT_Profile.P_INITIAL);
	boatName := "UTBOAT"&amp;self.getProfileStr(UT_Profile.P_INITIAL);
	deleteVoyage(voyageName);
	deleteVessel(boatName);
	vessel := addVesselCellular(boatName, operator);
	voyage := addVoyageWithContainerStructur(voyageName, boatName, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	
	yic := self.getTerminalArea(self.getProfileSetting(UT_Profile.P_YIC).asString).CM_YardInterchangeArea;
	
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="xReeferGateIN" id="614a649e-29c5-4234-a3df-09a7a3311c43">
        <updating/>
        <source>xReeferGateIN()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2014	cnwma1	Initial creation

*/

constants
	CNTRID = "TRLU4284746";
	REFStack ="REF200";
	YAId     = "YAREF" ;
	BOOKING  = "BOOKREF";
	VOY			= "AMA1983";
vars
	termArea : CM_RTGArea;
	loc 	 : CM_GridController;
	ya		    : CM_YardAllocation;
	locations   : CM_LCArray;
	booking: CM_BookingRef;
	ti : CM_TrackedItem;
	vvr : CM_VehicleVisitRecord;
	gate : CM_Gate;
	voyage : CM_Voyage;
	gte :CMGTE_Entity;

begin
	
	
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	
	self.disableAllYA(true);
	self.deleteContainer(CNTRID);
	self.deleteTerminalArea(REFStack);
	self.deleteBooking("UT_MATBOOKING");
	self.deleteVoyage(VOY);
	self.deleteVehicle("T999");
	voyage := self.addVoyageWithContainerStructur(VOY,
													"AMA",
													"APL", 
													"APL");
										
	
	//Create RTG Stack Area
	termArea := self.addRTGArea(REFStack,12,6,5);	
	loc := termArea.allGridControllersByRowColumn[5,5];
	self.assertNotNull(loc);

	beginTransaction;
	loc.setPower(true);
	commitTransaction;
	
	create locations transient;
	locations.add(termArea.allLocationsControllers.first.CM_YardController);
	
	ya := self.addYA(YAId, YACriteriaType_Commodity , self.getCommodity("REEF"), 
						   YACriteriaType_ISO, 2231,
						   null, CM_YADataBoolean.VALUE_TRUE,
						   locations, null);	
	
	opts.purge;
	self.opts.addAssoc("Temp", -3.00);
	booking := self.addBookingForContainer(BOOKING, self.getOperator("APL"), voyage, "NZAKL", "2231", "REEF");
	assertNotNull(booking);
	
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first,CNTRID);
	self.assertNotNull(ti);

	/*vvr := self.addVehicleVisitRecord("T999","MA","Mohamed Adwy",singleGate.name.asStringJMT);
	self.assertNotNull(vvr);
	
	gte := self.createGateEntity(vvr,CNTRID,"2231","APL","REEF");
	self.assertNotNull(gte);
	workVehicle(vvr);
	*/
	
	vvr := self.gateInContainer("T999",CNTRID, "2231","APL", "REEF",singleGate.name.asStringJMT);
	self.assertNotNull(vvr);
	
	self.workVehicle(vvr);
	self.roadExit(vvr);
	


epilog
	self.disableAllYA(false);
	delete locations;




end;</source>
    </JadeMethod>
    <JadeMethod name="xReleaseCargoFromArea" id="f4286d3b-92c8-4385-8cf9-f0aecf0b4d5f">
        <source>xReleaseCargoFromArea();
// 08/02/2010	cnwjre1
// in progress - needs a gateOutCargo copy of gateOutContainer
vars
	ti: CM_TrackedItem;
	truck: CM_Vehicle;
	vvr: CM_VehicleVisitRecord;
	cargo: CM_Cargo;
	product: CM_Product;
begin
	deleteContainer("UUT12345678");
	deleteVehicle("UTTRUCK");
	
	deleteCargo("UTCARGO00001", self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString));
	deleteProduct("UT MDF 12mm", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString));
	product := addProduct("UT MDF 12mm", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString));

	cargo := self.addCargoAtLocation("UTCARGO00001", product, product.myOperator, bs.myLocationsController).CM_Cargo;
	assertLocationHasTI(bs.myLocationsController, cargo);

	//vvr := gateOutCargo("UTTRUCK", "", "UTDRIVER", cargo, true, dualGate, bs.myLocationsController.id, null);
	
	assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem, cargo);
	
end;</source>
