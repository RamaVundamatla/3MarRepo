    <JadeMethod name="getExtraInfo_BulkGateAreaCont" id="d90eda27-bce1-48c5-b6f1-12d3a2185cbb">
        <source>getExtraInfo_BulkGateAreaCont():CM_GateAreaLaneController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2017	jlgns1	Initial creation

*/

vars

	gateAreaLaneController : CM_GateAreaLaneController;
	invalidObject : Boolean;
begin

	if self.myExtraInfoObject = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject (exception, gateAreaLaneController, invalidObject);
	
	if not self.myExtraInfoObject.isKindOf(CM_GateAreaLaneController) then
		return null;
	endif;
		
	gateAreaLaneController := 	self.myExtraInfoObject.CM_GateAreaLaneController;	
	return gateAreaLaneController;
epilog

end;</source>
