        <source>resizeColumn(table: Table input; column: Integer input; previousWidth: Integer input) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		1 February 2010 by cnwjo3
//
// Purpose:		resize columsn so they look good.
//
vars
	allSizes	: StringArray;
begin
	create allSizes transient;
	allSizes.add(ETRow_Total20);
	allSizes.add(ETRow_Total30);
	allSizes.add(ETRow_Total40);
	allSizes.add(ETRow_Total45);
	allSizes.add(ETRow_Total53);
	allSizes.add(ETRow_ColTotalTotal);  //cnwjo3 par 21189
	self.adjustStatHeading(app.getErrorString(YAM_Stats_Total),allSizes, self.getSubTitleWidth(allSizes));
		
	allSizes.clear();
	allSizes.add(ETRow_Used20);
	allSizes.add(ETRow_Used30);
	allSizes.add(ETRow_Used40);
	allSizes.add(ETRow_Used45);
	allSizes.add(ETRow_Used53); 
	allSizes.add(ETRow_ColTotalUsed);  //cnwjo3 par 21189
	self.adjustStatHeading(app.getErrorString(YAM_Stats_Used),allSizes, self.getSubTitleWidth(allSizes));

	allSizes.clear();
	allSizes.add(ETRow_QueuedIn20);
	allSizes.add(ETRow_QueuedIn30);
	allSizes.add(ETRow_QueuedIn40);
	allSizes.add(ETRow_QueuedIn45);
	allSizes.add(ETRow_QueuedIn53);
	allSizes.add(ETRow_ColTotalQIn);  //cnwjo3 par 21189
	self.adjustStatHeading(app.getErrorString(YAM_Stats_QueuedIn), allSizes,self.getSubTitleWidth(allSizes));

	allSizes.clear();
	allSizes.add(ETRow_QueuedOut20);
	allSizes.add(ETRow_QueuedOut30);
	allSizes.add(ETRow_QueuedOut40);
	allSizes.add(ETRow_QueuedOut45);
	allSizes.add(ETRow_QueuedOut53); 
	allSizes.add(ETRow_ColTotalQOut);  //cnwjo3 par 21189
	self.adjustStatHeading(app.getErrorString(YAM_Stats_QueuedOut),allSizes, self.getSubTitleWidth(allSizes));

	allSizes.clear();
	allSizes.add(ETRow_Free20);
	allSizes.add(ETRow_Free30);
	allSizes.add(ETRow_Free40);
	allSizes.add(ETRow_Free45);
	allSizes.add(ETRow_Free53); 
	allSizes.add(ETRow_ColTotalFree);  //cnwjo3 par 21189
	self.adjustStatHeading(app.getErrorString(YAM_Stats_Free), allSizes,self.getSubTitleWidth(allSizes));

	allSizes.clear();
	allSizes.add(ETRow_Projected20);
	allSizes.add(ETRow_Projected30);
	allSizes.add(ETRow_Projected40);
	allSizes.add(ETRow_Projected45);
	allSizes.add(ETRow_Projected53);
	allSizes.add(ETRow_ColTotalProjected);  //cnwjo3 par 21189
	self.adjustStatHeading(app.getErrorString(YAM_Stats_Projected), allSizes,self.getSubTitleWidth(allSizes));

	allSizes.clear();
	allSizes.add(ETRow_PlannedIn20);
	allSizes.add(ETRow_PlannedIn30);
	allSizes.add(ETRow_PlannedIn40);
	allSizes.add(ETRow_PlannedIn45);
	allSizes.add(ETRow_PlannedIn53);
	allSizes.add(ETRow_ColTotalPlanIn);  //cnwjo3 par 21189
	self.adjustStatHeading(app.getErrorString(YAM_Stats_PlanIn), allSizes,self.getSubTitleWidth(allSizes));

	allSizes.clear();
	allSizes.add(ETRow_PlannedOut20);
	allSizes.add(ETRow_PlannedOut30);
	allSizes.add(ETRow_PlannedOut40);
	allSizes.add(ETRow_PlannedOut45);
	allSizes.add(ETRow_PlannedOut53);
	allSizes.add(ETRow_ColTotalPlanOut);  //cnwjo3 par 21189
	self.adjustStatHeading(app.getErrorString(YAM_Stats_PlanOut), allSizes,self.getSubTitleWidth(allSizes));
	
	if table.accessColumn(column).width &lt; 35 then
		table.accessColumn(column).width := 35;
	endif;	
epilog
	delete allSizes;
end;</source>
