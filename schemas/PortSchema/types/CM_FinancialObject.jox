    <JadeMethod name="hasFinancialAudits" id="e1f52881-3279-49ec-bb66-a828dd6d0c32">
        <source>hasFinancialAudits() : Boolean;
/*

Date		Who		Reason
25 September 2015	cnwer1	Initial creation PAR 36958

*/

vars

begin
	if self.qualifiedAudits.size &gt; 0 then
		return true;
	endif;
	
	if self.unqualifiedAudits.size &gt; 0 then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="healthCheckCollection" id="148ef75f-4d3a-45c5-ada5-eb1ff6fc37de">
        <source>healthCheckCollection(_col : Collection; _resultType : Integer output) : Boolean;
/*
Purpose:			
Date		Who		Reason
13 September 2016	cnwab1	Initial creation
*/

vars

begin
	if _col = null then
		_resultType := CMIF_InvoiceHealthAgent.ResultType_Null; //  "Null Reference";
		return false;
	endif;
	if _col.isEmpty() then
		_resultType := CMIF_InvoiceHealthAgent.ResultType_Empty; //  "Empty";
		return false;
	
	endif;
	return true;
epilog

end;</source>
        <Parameter name="_col" type="Collection"/>
        <Parameter name="_resultType" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="healthCheckObject" id="83534b09-08bf-4084-bca7-17ca629a25c2">
        <source>healthCheckObject(_object : Object; _resultType : Integer output) : Boolean;
/*
Purpose:			
Date		Who		Reason
13 September 2016	cnwab1	Initial creation
*/

vars

begin
	if _object = null then
		_resultType := CMIF_InvoiceHealthAgent.ResultType_Null; // "Null Reference";
		return false;
	endif;
	if not global.isValidObject(_object) then
		_resultType := CMIF_InvoiceHealthAgent.ResultType_Invalid; //  "Invalid Reference";
		return false;
	
	endif;
	if global.isValidObject(_object) then
		_resultType := CMIF_InvoiceHealthAgent.ResultType_Valid; //  "Valid Reference";
		return true;
	
	endif;
	return true;
epilog

end;</source>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_resultType" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
