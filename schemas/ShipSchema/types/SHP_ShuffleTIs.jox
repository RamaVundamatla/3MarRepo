    <JadeMethod name="displayStuff" id="b7fe6a2c-617f-412c-b31b-3f88e1c2a233">
        <source>displayStuff(_theObject : Object) : String;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aBay : CM_Bay;
	aFM : CM_FutureMove;
	aTrackedItem : CM_TrackedItem;
	theString : String;
begin
	
	if _theObject &lt;&gt; null then
		if self.mode = self.Mode_TIs then
			aTrackedItem := _theObject.CM_TrackedItem;
			//theString := aTrackedItem.id &amp; " - " &amp; aTrackedItem.getISOType &amp; " - " &amp; aTrackedItem.weight.asStringWeightJMT() &amp; " kg";				//-cnwml2 MSL CCMS 1017
			theString := aTrackedItem.id &amp; " - " &amp; aTrackedItem.getISOType &amp; " - " &amp; aTrackedItem.totalWeight.asStringWeightJMT() &amp; app.getString(Space_Kg);			//+cnwml2 MSL CCMS 1017
		else
			aFM := _theObject.CM_FutureMove;
			aTrackedItem := aFM.getTrackedItem();
			if aTrackedItem &lt;&gt; null then
				//theString := aTrackedItem.id &amp; " - " &amp; aTrackedItem.getISOType &amp; " - " &amp; aTrackedItem.weight.asStringWeightJMT() &amp; " kg";				//-cnwml2 MSL CCMS 1017
				theString := aTrackedItem.id &amp; " - " &amp; aTrackedItem.getISOType &amp; " - " &amp; aTrackedItem.totalWeight.asStringWeightJMT() &amp; app.getString(Space_Kg);			//+cnwml2 MSL CCMS 1017
			else
				theString := "No Cargo";
			endif;
		endif;
		return  theString;
	else
		return "Null Object";
	endif;

end;</source>
        <Parameter name="_theObject" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
