	error: CM_Error;
	permissions: BooleanArray;
	theUser: CM_User;
	userProxy,userReal: CM_User;
	daSet:CM_DataAccessControllerSet;

begin
epilog
	return app.myPassport.trxCompletedOK;

end;</source>
        <Parameter name="_userName" type="String"/>
        <Parameter name="__password" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="defaultBGPSetup" id="1986a4cb-47af-45f3-b6a9-9d54e1f9fdf8">
        <source>defaultBGPSetup() :Boolean;
// -----------------------------------------------------------------------------
// Created:		Mar 2004  by cnwrs1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 09 Aug 2016	cnwrs1	TFS 2514 - Remove BGP Entrities from Startup App
// -----------------------------------------------------------------------------
vars

	bgpObject: BGP_Manager;
	user: CM_User;
	returnCode: Boolean;	
begin
	returnCode := false;
	app.initialize;
	app.myPassport.setMyUserFromCode('SUPERUSER');
	create bgpObject transient;
	user := bgpObject.createBGPUser();
	if user = null then
		return returnCode;
	endif;
	bgpObject.initAutoManager(user);
	bgpObject.initReports(2, user);
	bgpObject.initCamsRefEdiEtc(2, user);
//	bgpObject.initChangeControl(user);
//	bgpObject.initBackup(user);
	returnCode := true;
epilog
	delete bgpObject;
	return returnCode;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deleteAllObjects" id="a8a147b4-3356-4a29-ab4b-eb8dc7e28e10">
        <source>deleteAllObjects() :Boolean;
// ---------------------------------------------------------------------------
// Created:     4 March 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	objArray: ObjectArray;
	object: Object;
	root: CM_Root;
	returnCode: Boolean;
	count: Integer;	
begin
	returnCode := false;
	root := CM_Root.firstInstance;
	if root &lt;&gt; null then
		beginTransaction;
		root.erase(NORMAL_ERASE);
		commitTransaction;
	endif;
	self.lblStatus.caption := "delete remaining CM_Objects";
	create objArray transient;
	CM_Object.allInstances(objArray,0,true);
	beginTransaction;
	foreach object in objArray do
		if global.isValidObject(object) then
			object.CM_Object.erase(NORMAL_ERASE);
			count := count + 1;
			if count mod 10 = 0 then
				commitTransaction;
				beginTransaction;
			endif;
		endif;
	endforeach;
	global.myCM_Root := null;
	app.setPropertyValue("myRoot", null);
	// remove any portschema release records
	commitTransaction;
	self.lblStatus.caption := "Delete Others";
	beginTransaction;
	objArray.clear;
	PortSchemaRelease.allInstances(objArray,0,true);
	foreach object in objArray do
		if global.isValidObject(object) then
			delete object;
		endif;
	endforeach;
	// remove any bgp_object release records
	objArray.clear;
	BGP_Object.allInstances(objArray,0,true);
	foreach object in objArray do
		if global.isValidObject(object) then
			delete object;
		endif;
	endforeach;
	commitTransaction;
	returnCode := true;
epilog
	delete objArray;
	return returnCode;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="9139b91b-604d-4641-bbb5-786eb94a4c27">
        <updating/>
        <source>doFormLoad() updating;
// -----------------------------------------------------------------------------
// Created:		18 February 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	create myInitAgent transient;
	
	self.centreWindow();
//	self.frmToolbarBtns.visible := false;
//	self.handleMenusForModalDisplay();
	self.modalResult := MsgBox_Return_Cancel;
//	self.menuFile.visible := false;
//	self.menuHelp.visible := false;
//	self.menuWindow.visible := false;
	self.shtUserPassword.visible := false;
	self.btnReLicense.enabled := false;
	if CM_Root.firstInstance &lt;&gt; null then
		self.btnReLicense.enabled := true;
	endif;
	// for testing pre fill the txt boxes	
	self.intialTestSettings;	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doFormUnload" id="689c5aba-f217-41c7-a6cd-9ebe44a03dbc">
