        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="e9242ed8-4106-4563-b305-3a6553ae4ec4">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------------------
//Created: 16 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	str			: String;
	isoType 	: CM_ISOType;
	isoGroup 	: CM_ISOTypeGroup;
	cargoType	: CM_CargoType;
	dischargePort : CM_Port;
begin

	if _attrName = ETRow_ReleaseNumber then
		return self.id;
	elseif _attrName = ETRow_DestinationPort then
		return self.consigneeCode;		
	elseif _attrName = ETRow_DoorDirection then
		return null; //self.getDoorsDirection;				
	elseif _attrName = ETRow_DischargePort then
		dischargePort:= self.getAttrDischargePort;		
		if dischargePort &lt;&gt; null then
			return dischargePort.code;
		endif;
		return self.dischargePort;
	elseif _attrName = ETRow_IsoType then
		if self.isBulkRelease() then
			return self.getBulkReleaseReserveDetail().getISOTypeCode();
		endif;
		return null;
	// 25/11/2015 cnwar2 #37151
	elseif _attrName = ETRow_IsoGroup then
		if self.isBulkRelease() then
			return self.getBulkReleaseReserveDetail().getISOGroupCode();
		endif;
		return null;
	elseif _attrName = ETRow_OperatorCode and self.isBulkRelease() then
		return self.getBulkRelease().getOperatorCode();
	elseif _attrName = ETRow_DoorsForward then
		return null; //self.doorsDirection;
	elseif _attrName = ETRow_Id then
	
		// this section added by cnwrd1 par 24522 29.6.2010
		if self.myBulkReleaseReserveDetail = null then // should be a slot request by type but...
			return inheritMethod(_attrName, _short);
		endif;
		
		str := self.getDisplayStringForAttribute(ETRow_OperatorCode, _short);
		
		isoType := self.myBulkReleaseReserveDetail.getISOType();		
		if isoType &lt;&gt; null then
			return str &amp; ' ' &amp; isoType.code;
		endif;
		
		isoGroup := self.myBulkReleaseReserveDetail.getISOGroup();		
		if isoGroup &lt;&gt; null then
			return str &amp; ' ' &amp; isoGroup.code;
		endif;
		
		cargoType := self.myBulkReleaseReserveDetail.getCargoType();
		if cargoType &lt;&gt; null then
			return str &amp; ' ' &amp; cargoType.abbreviation;
		endif;
		
		return str;
		
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDoorDirectionDescription" id="a14b4f16-596d-4f0a-ad2b-0463f26618f5">
        <source>getDoorDirectionDescription(_targetLocation : CM_LocationsController; _ti : CM_TrackedItem): String;

vars
	doorDir : Integer;
	isoTypeGroup	: CM_ISOTypeGroup;
	str				: String;
begin
	
	if _targetLocation &lt;&gt; null and _ti &lt;&gt; null then
		isoTypeGroup := _ti.getISOTypeGroup();
		if isoTypeGroup &lt;&gt; null then
			str := _targetLocation.getDoorDirectionWording(isoTypeGroup);
			if str &lt;&gt; null then
				return str;
			endif;
		endif;
	endif;

	doorDir := self.doorsDirection;
	if doorDir = TI_DOORSDIRN_FWD then
		return app.getErrorString(CM_Fwd);
	elseif doorDir = TI_DOORSDIRN_AFT then
		return app.getErrorString(CM_Aft);
	else
		return null;
	endif;
end;</source>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDoorsDirection" id="74b2ad3b-27dc-46b4-849e-01d18b58272c">
        <source>getDoorsDirection(): Integer;
// -------------------------------------------
// Created 18 September 2003 by cnwdvb1
// -------------------------------------------
vars

begin
	
	return self.doorsDirection;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="6543d630-9bc4-4fb4-afea-76d3bf0d3cfa">
        <source>getExtraInfo(_dataCont: CM_DataContainer) ;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theAttibuteString : String;
	aDrawingAttribute : CM_DrawingAttribute;
	block : CM_DataContainerBlock;
	theRoot : CM_Root;
	isForty : Boolean;
begin
	inheritMethod(_dataCont);

	self.getExtraInfoData(_dataCont);
	self.getExtraInfoIcons(_dataCont);
end;</source>
        <Parameter name="_dataCont" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoAddIcon" id="13eeff89-1361-4f9c-a15b-2fb5b1cba9fd">
        <source>getExtraInfoAddIcon(_theRoot : CM_Root; _dataCont: CM_DataContainer; _theAttibuteString : String;_block : CM_DataContainerBlock io) protected;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Chnaged On	By			Reason
// ----------	--------	--------------------------------------------------
// 20/05/2015	cnwdap1		PAR #36206 Graphical Representation of Hazard Class and Special Stow
// 01/10/2015	cnwdap1		PAR #36999 Allocation criteria could have comma-delimited hazard codes - just get the first
//17 Oct 2017	cnwma1  	TFS #7431 JMT - Refactoring - Drawing Attributes Labels
vars
	aDrawingAttribute : CM_DrawingAttribute;
	theRoot : CM_Root;
	criteria : CM_YACriteria;						// PAR #36206
	hazardClass : CM_HazardClass;					// PAR #36206
	specialStows : CM_ObjectSet;					// PAR #36206
	label : String;									// PAR #36206
	dataValue : String;						// PAR #36999
	hazCode : String;						// PAR #36999
	pos : Integer;							// PAR #36999
	
begin
	theRoot := _theRoot;
	
	if _theAttibuteString = PicTIHazard then													// PAR #36206
		criteria := self.getAttrByType(YACriteriaType_Hazardous);								// PAR #36206
		if criteria &lt;&gt; null then																// PAR #36206
			dataValue := criteria.myYAData.getDataValue.String;													// PAR #36999
			if dataValue.pos(",", 1) &lt;&gt; null then																// PAR #36999
				pos := 1;																						// PAR #36999
				hazCode := dataValue.cnGetToken(pos, ",");														// PAR #36999
			else																								// PAR #36999
				hazCode := dataValue;																			// PAR #36999
			endif;																								// PAR #36999
			//hazardClass := app.myRoot.allHazardClasses[criteria.myYAData.getDataValue.String];// PAR #36206	// PAR #36999
			hazardClass := app.myRoot.allHazardClasses[hazCode];								// PAR #36206	// PAR #36999
			//epr par 37366 5/1/16 hazard class can be null if it is deleted
			if hazardClass &lt;&gt; null then
				aDrawingAttribute := hazardClass.myDrawingAttribute;								// PAR #36206
				label := app.getErrorString(Hazards);												// PAR #36206
			endif;
		endif;																					// PAR #36206
	
	elseif _theAttibuteString = PicSpecialStow then												// PAR #36206
		criteria := self.getAttrByType(YACriteriaType_SpecialStow);								// PAR #36206
		if criteria &lt;&gt; null then																// PAR #36206
			specialStows := criteria.myYAData.getDataValue.CM_ObjectSet;						// PAR #36206
			if not specialStows.isEmpty then													// PAR #36206
				aDrawingAttribute := specialStows.first.CM_SpecialStow.myDrawingAttribute;		// PAR #36206
				label := app.getErrorString(SpecialStow);										// PAR #36206
			endif;																				// PAR #36206
		endif;																					// PAR #36206
	endif;																						// PAR #36206
	if aDrawingAttribute = null then															// PAR #36206
		aDrawingAttribute := theRoot.allDrawingAttributes[_theAttibuteString];
		if aDrawingAttribute &lt;&gt; null then														// PAR #36206
			//label := aDrawingAttribute.getLabel();											// PAR #36206 //17.10.2017	cnwma1  TFS #7431
			label := aDrawingAttribute.label;												    //17.10.2017	cnwma1  TFS #7431
		endif;																					// PAR #36206
	endif;																						// PAR #36206
	if aDrawingAttribute &lt;&gt; null then
		if _block = null then	
			_block := _dataCont.addNewBlock();
		endif;
	
		//_block.addNewItem(aDrawingAttribute.getLabel(), DC_IconLabel, 1, null);				// PAR #36206
		_block.addNewItem(label, DC_IconLabel, 1, null);										// PAR #36206
		_block.addNewIcon(aDrawingAttribute.fontCharacter.Character, 1, null,
							aDrawingAttribute.fontName, aDrawingAttribute.colour);
	endif;	
end;</source>
        <access>protected</access>
        <Parameter name="_theRoot" type="CM_Root"/>
        <Parameter name="_dataCont" type="CM_DataContainer"/>
        <Parameter name="_theAttibuteString" type="String"/>
        <Parameter name="_block" type="CM_DataContainerBlock" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoBulkRelease" id="e821fb12-5199-4a5f-8b30-36d630597a09">
        <source>getExtraInfoBulkRelease(_dataContainer: CM_DataContainer);

vars
	block	: CM_DataContainerBlock;
	data	: String;
	
begin
	if self.isBulkRelease() then
		block := _dataContainer.addNewBlock();
		block.addNewItem("Release Request" , DC_Label, 1, null);
		data := self.getBulkRelease().code;
		block.addNewItem(data, DC_Data, 1, null);
		block.addNewItem("Release Detail" , DC_Label, 1, null);
		data	:=	self.getBulkRelease().myOperator.code &amp; " " &amp;
					self.getBulkReleaseReserveDetail().getISOTypeCode() &amp; " " &amp;
					self.getBulkRelease().myDischargePort.code;
		block.addNewItem(data, DC_Data, 1, null);
		
// cnwdad1 19/10/2009 - PAR #21381.
		if self.myBulkReleaseReserveDetail &lt;&gt; null then
			if self.myBulkReleaseReserveDetail.myReserveHeader &lt;&gt; null then
				if self.myBulkReleaseReserveDetail.myReserveHeader.mySubTerminal &lt;&gt; null then
					block	:=	_dataContainer.addNewBlock();
					block.addNewItem(app.getString(SubTerminal_GC), DC_Label, 1, null);
					data	:=	self.myBulkReleaseReserveDetail.myReserveHeader.mySubTerminal.code;
					block.addNewItem(data, DC_Data, 1, null);
				endif;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoData" id="002bc276-ef55-43e5-b1cb-075c4d4b15cb">
        <source>getExtraInfoData(_dataContainer: CM_DataContainer) protected;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars

	theTI,tmpTI				: CM_TrackedItem;
	tmpSC : CM_LocationsController;
	theSlotController 		: CM_SlotController;
	idx		: Integer;
	aString 				: String;
	useCellTier				: Boolean;
	theTIs 					: CM_TIArray;
	block 					: CM_DataContainerBlock;
	theBay 					: CM_Bay;
	theWLE 					: CM_WorkListEntry;
	tmpSlotReq 				: CM_SlotRequest;
	invalid 				: Boolean;
	commGrp 				: CM_CommodityGroup;
	ed 						: Integer;
	cargoType 				: CM_CargoType; //cnwas3 par 24273
	dischargePort 			: CM_Port; //cnwas3 PAR 24273
	linkReq : CM_Request;
begin
	// PAR 35031
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Custom_sequenced), DC_Label, 1,null);			
	block.addNewItem( self.isCustomSequenced().String,	DC_Data, 1, self);		

	theSlotController := self.mySlotController;
	theBay := self.myBay;
	if theBay = null then
		theBay := theSlotController.myBayVoyage;
	endif;
	
	
	
	aString := self.getAllocationName(); // PAR 35325
	if aString &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(Voyage_allocation), DC_Label, 1, self);
			block.addNewItem(aString, DC_Data, 1, self);
	
	endif;
	
	block := _dataContainer.addNewBlock; // PAR 35502
	block.addNewItem(app.getErrorString(CM_Twin_Lift), DC_Label, 1, self);		 // PAR 35502
	block.addNewItem(isTwinLift(false).cnEcGetYesNo(),	DC_Data, 1, self); // PAR 35502
	
	// ##############################
	// ### DISCHARGE
	// ##############################
	
	dischargePort := self.getAttrDischargePort();			//cnwas3 PAR 24273
	if self.moveType = DISCHARGE_MOVETYPE or self.moveType = SOB_MOVETYPE or self.moveType = DLR_MOVETYPE then
		create theTIs transient;
		self.getAllTrackedItems(theTIs);


		linkReq := self.getLinkedRequest(self.isReleaseType);
// PAR 28968		if self.mySlotRequestDLRSOBLoad &lt;&gt; null then
		if linkReq &lt;&gt; null then
			tmpSC := linkReq.getLC(); // PAR 28968
			if tmpSC &lt;&gt; null then // PAR 28968
				block := _dataContainer.addNewBlock;
				block.addNewItem(app.getErrorString(Linked_load), DC_Label, 1, null);
//				block.addNewItem(self.mySlotRequestDLRSOBLoad.mySlotController.getFullId, DC_Data, 1, null);
				block.addNewItem(tmpSC.getFullId, DC_Data, 1, null);
			endif;
		endif;		

		if theTIs.size &gt; 1 then
			aString := null;
			idx := 0;
			foreach theTI in theTIs do
				idx := idx + 1;
				aString := aString &amp; theTI.id &amp; ", ";
				if idx mod 2 = 0 then
					aString := aString &amp; Cr;
				endif;
			endforeach;
			aString := aString[1 : aString.reversePos(",") - 1];
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(Multi_cargo), DC_Label, 1, null);
			block.addNewItem(aString, DC_Data, 1, null);
		elseif theTIs.size = 1 then
			theTI := theTIs.first;
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(Cargo), DC_Label, 1, null);
			block.addNewItem(theTI.id, DC_Data, 1, null);
		endif;



		if self.myJob &lt;&gt; null then
			aString := null;
			if theTI &lt;&gt; null then	
				aString := theTI.getShipReceiveJobsString();
			endif;
			if aString = null then
				aString := self.myJob.jobId;
				if self.myJob.isJobComplete then
					aString := aString &amp; " " &amp; app.getErrorString(Complete);
				endif;
			endif;
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(Discharge_job), DC_Label, 1, null);
			block.addNewItem(aString, DC_Data, 1, null);
			// ###################
			// SEQUENCE NUMBER
			aString := self.getSeqNum.String;
			if aString &lt;&gt; null then
				if app.isSpecial() then
					theWLE := self.allWorkListEntries.first;
					if theWLE &lt;&gt; null then
						aString := aString &amp; "/" &amp; theWLE.CM_VoyageWLE.seqNumWorkOrder.String;
					endif;
				endif;
				
				block := _dataContainer.addNewBlock;
				block.addNewItem(app.getErrorString(Sequence_number), DC_Label, 1, null);
				block.addNewItem(aString, DC_Data, 1, null);
			endif;
		endif;
		if dischargePort &lt;&gt; null then		//cnwas3 PAR 24273
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(Destination), DC_Label, 1, dischargePort);		//cnwas3 PAR 24273
			block.addNewItem(dischargePort.code.trimBlanks &amp; " - " &amp; dischargePort.description.trimBlanks,		//cnwas3 PAR 24273
					DC_Data, 1, null);
		endif;
		if self.isRehandle then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(Double_lift_restow), DC_Label, 1, null);
			block.addNewItem(app.getErrorString(Yes), DC_Data, 1, null);
		endif;
		if self.isSOB then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(Shift_board), DC_Label, 1, null);
			block.addNewItem(app.getErrorString(Yes), DC_Data, 1, null);
		endif;

	// ##############################
	// ### LOAD
	// ##############################
	else
		linkReq := self.getLinkedRequest(self.isReleaseType);
// PAR 28968		if self.mySlotRequestDLRSOBDischarge &lt;&gt; null then
		if linkReq &lt;&gt; null then
// PAR 28968			tmpSC := self.mySlotRequestDLRSOBDischarge.mySlotController;
			tmpSC := linkReq.getLC(); // PAR 28968
			if tmpSC &lt;&gt; null then // PAR 28968
				block := _dataContainer.addNewBlock;
				block.addNewItem(app.getErrorString(Linked_discharge), DC_Label, 1, null);
				tmpTI := tmpSC.allTrackedItems.first;
				if tmpTI &lt;&gt; null then
					block.addNewItem(tmpSC.getFullId &amp; " (" &amp; tmpTI.id &amp; ")", DC_Data, 1, null);
				else
					block.addNewItem(tmpSC.getFullId , DC_Data, 1, null); // PAR 28968
				endif;
			endif;
		endif;

		if not self.useVoyageAllocations and self.weight &gt; 0 then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(Colour_coded_weight), DC_Label, 1, self);
			block.addNewItem(self.weight.asStringWeightJMT(), DC_Data, 1, self);
		
		endif;
		
		 // DOORS
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Door_direction), DC_Label, 1, null);
		if self.doorsDirection = TI_DOORSDIRN_FWD then	
			block.addNewItem(app.getErrorString(Forward), DC_Data, 1, null);
		elseif self.doorsDirection = TI_DOORSDIRN_AFT then	
			block.addNewItem(app.getErrorString(AftWord), DC_Data, 1, null);
		else
			block.addNewItem(app.getErrorString(NotApplicable), DC_Data, 1, null);
		endif;			
		if theSlotController.hasPlannedTIs(true) then //theSlotController.hasTIsOfMode(PLANNING_MODE) then
			create theTIs transient;
			theSlotController.getTIs(theTIs,PLANNING_MODE, true); // PAR 27749
			foreach theTI in theTIs do
				block := _dataContainer.addNewBlock;
				block.addNewItem(app.getErrorString(Planned_cargo), DC_Label, 1, theTI);
				block.addNewItem(theTI.id &amp; " (" &amp; theTI.getPrimaryLocationId(REAL_MODE) &amp; ") " &amp; theTI.totalWeight.asStringWeightJMT(), DC_Data, 1, theTI);
			endforeach;
		endif;
		if self.myJob &lt;&gt; null then
			aString := null;
			foreach tmpSlotReq in self.mySlotController.allSlotRequestsLoad do			
				if tmpSlotReq.myJob &lt;&gt; null then
					aString := aString &amp;  tmpSlotReq.myJob.jobId &amp; " ";
					if tmpSlotReq.myJob.isJobComplete then
						aString := aString &amp; "(C) ";
					endif;
				endif;
			endforeach;
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(Load_job), DC_Label, 1, null);
			block.addNewItem(aString, DC_Data, 1, null);

			// ###################
			// SEQUENCE NUMBER
			aString := self.getSeqNum.String;
			if aString &lt;&gt; null then
				if app.isSpecial() then
					theWLE := self.allWorkListEntries.first;
					if theWLE &lt;&gt; null then
						aString := aString &amp; "/" &amp; theWLE.CM_VoyageWLE.seqNumWorkOrder.String;
					endif;
				endif;
				block := _dataContainer.addNewBlock;
				block.addNewItem(app.getErrorString(Sequence_number), DC_Label, 1, null);
				block.addNewItem(aString, DC_Data, 1, null);
			endif;
		endif;
		cargoType := self.getAttrCargoType();	//cnwas3 PAR 24273 begin
		if cargoType &lt;&gt; null then			
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(CargoType), DC_Label, 1, cargoType);
			block.addNewItem(cargoType.description, DC_Data, 1, cargoType);	//cnwas3 PAR 24273 end
		endif;
		if dischargePort &lt;&gt; null then	//cnwas3 PAR 24273
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(Destination), DC_Label, 1, dischargePort);			//cnwas3 PAR 24273
			block.addNewItem(dischargePort.code.trimBlanks &amp; " - " &amp; dischargePort.description.trimBlanks,	//cnwas3 PAR 24273
					DC_Data, 1, dischargePort);			//cnwas3 PAR 24273
		endif;
		
		commGrp := self.getAttrCommodityGroup();
		if commGrp &lt;&gt; null then
			invalid := false;
			on Exception do app.handleDeletedObject(exception, commGrp, invalid);
			// Dereference to check it is valid
			ed := commGrp.edition();
			if not invalid then
				block := _dataContainer.addNewBlock;
				block.addNewItem(app.getErrorString(Commodity), DC_Label, 1, commGrp);
				block.addNewItem(commGrp.code.trimBlanks &amp; " - " &amp; commGrp.description.trimBlanks,
						DC_Data, 1, commGrp);
			endif;
		endif;
		if self.isRehandle then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(Double_lift_restow), DC_Label, 1, null);
			block.addNewItem(app.getErrorString(Yes), DC_Data, 1, null);
		endif;
		if self.isSOB then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(Shift_board), DC_Label, 1, null);
			block.addNewItem(app.getErrorString(Yes), DC_Data, 1, null);
		endif;
	endif;

	// ############################
	// always show this stuff
	if theBay.isKindOf(CM_BayVoyage) then
		useCellTier := theBay.CM_BayVoyage.myCellularVoyageStructure.useBayCellTierNumbering;
	endif;
	
	aString := "[" &amp; theBay.myHold.ordinalHold.String.padLeadingZeros(2) &amp; "]";
	aString := aString &amp; " (" &amp;  theBay.id &amp; ")";
	if theBay.idBay40 &lt;&gt; null then
		aString := aString &amp; " {" &amp;  theBay.idBay40 &amp; "}";
	endif;

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Position) , DC_Label, 1, null);
	block.addNewItem(aString, DC_Data, 1, null);						// 11/01/2013 cnwmh5 31005
	
	if app.isSpecial() then
		tmpSlotReq := self.mySlotController.mySlotRequestLoad;
		 if tmpSlotReq &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem("Load Request", DC_Label, 1, tmpSlotReq);
			block.addNewItem(tmpSlotReq.String, DC_Data, 1,	tmpSlotReq);
			theWLE := tmpSlotReq.allWorkListEntries.first;
			block := _dataContainer.addNewBlock;
			block.addNewItem("Load WLE", DC_Label, 1,theWLE );
			block.addNewItem(theWLE.String, DC_Data, 1, theWLE);

		endif;
		tmpSlotReq := self.mySlotController.mySlotRequestDischarge;
		 if tmpSlotReq &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem("Discharge Request", DC_Label, 1, tmpSlotReq);
			block.addNewItem(tmpSlotReq.String, DC_Data, 1,tmpSlotReq);
			theWLE := tmpSlotReq.allWorkListEntries.first;
			block := _dataContainer.addNewBlock;
			block.addNewItem("Discharge WLE", DC_Label, 1,theWLE );
			block.addNewItem(theWLE.String, DC_Data, 1, theWLE);
		endif;

		block := _dataContainer.addNewBlock;
		block.addNewItem("Slot Controller", DC_Label, 1, self.mySlotController);
		block.addNewItem(self.mySlotController.String, DC_Data, 1, self.mySlotController);

		block := _dataContainer.addNewBlock;
		block.addNewItem("Bay", DC_Label, 1, theBay);
		block.addNewItem(self.myBay.String, DC_Data, 1, theBay);

		block := _dataContainer.addNewBlock;
		block.addNewItem("Slot Definition", DC_Label, 1, self.mySlotDefinition);
		block.addNewItem(self.mySlotDefinition.String, DC_Data, 1, self.mySlotDefinition);
	endif;

epilog
	delete theTIs;
end;</source>
        <access>protected</access>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoIcons" id="0258bcef-05e5-4991-aeae-515520e67e45">
        <source>getExtraInfoIcons(_dataCont: CM_DataContainer) protected;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	block : CM_DataContainerBlock;
	theRoot : CM_Root;
	isThirty  : Boolean;	//09 Apr 2010 NDL	Par 22526
	isFortyFive  : Boolean;	//09 Apr 2010 NDL	Par 22526
	isFiftyThree : Boolean;	//09 Apr 2010 NDL	Par 22526
	isForty : Boolean;
	isBackEnd : Boolean; 	//cnwas3 PAR 24273
	motorDir 	: Integer;
begin

	theRoot := app.myRoot;

	// ###########
	// SPECIAL STOW CODE	PAR 34899
	if self.getAttrIsSpecialStow() then
		self.getExtraInfoAddIcon(theRoot,_dataCont,PicSpecialStow,block);
	endif;

	// ###########
	// FLAT	
	if self.getAttrFlatRack() then
		self.getExtraInfoAddIcon(theRoot,_dataCont,PicTIFlat,block);
	endif;

	// ###########
	// TANK	
	if self.getAttrTank() then
		self.getExtraInfoAddIcon(theRoot,_dataCont,PicTITank,block);
	endif;

	// ###########
	// CRIB	
	if self.getAttrCrib() then
		self.getExtraInfoAddIcon(theRoot,_dataCont,PicTICrib,block);
	endif;
	
	// ###########	05 Feb 2018	NDL	TFS 36752
	// FRAME	
	if self.getAttrFrame() then
		self.getExtraInfoAddIcon(theRoot,_dataCont,PicTIFrame,block);
	endif;

	// ###########
	// FANTAINER	
	if self.getAttrFantainer() then
		self.getExtraInfoAddIcon(theRoot,_dataCont,PicTIFantainer,block);
	endif;

	// ###########
	// OPENTOP	
	if self.getAttrOpenTop() then
		self.getExtraInfoAddIcon(theRoot,_dataCont,PicTIOpentop,block);
	endif;

	// ###########
	// UNAVAILABLE	
	if self.unavailable then
		self.getExtraInfoAddIcon(theRoot,_dataCont,PicTIUnavail,block);
		return;
	endif;

	isBackEnd := self.getAttrIsBackend();	//cnwas3 PAR 24273
	// ###########
	// FORTYFOOT
	if self.getAttrIs40() then
		isForty := true;
		if isBackEnd then // PAR 21746			//cnwas3 PAR 24273
			self.getExtraInfoAddIcon(theRoot,_dataCont,PicTI40FooterBackEnd,block);
		else
			self.getExtraInfoAddIcon(theRoot,_dataCont,PicTI40Footer,block);
		endif;
	endif;

	// PAR 18682
	// ###########
	// FORTY FIVE FOOT	
	if self.getAttrIs45() then
		isFortyFive := true;	//09 Apr 2010 NDL	Par 22526
		if isBackEnd then // PAR 21746			//cnwas3 PAR 24273
		// PAR 21746 if self.isBackend then
			self.getExtraInfoAddIcon(theRoot,_dataCont,PicTI45FooterBackEnd,block);
		else
			self.getExtraInfoAddIcon(theRoot,_dataCont,PicTI45Footer,block);
		endif;
	endif;

	// PAR 16415 CCMS 1029
	// ###########
	// THIRTY FOOT	
	if self.getAttrIs30() then
		isThirty := true;	//09 Apr 2010 NDL	Par 22526
		if isBackEnd then // PAR 21746		//cnwas3 PAR 24273
		// PAR 21746 		if self.isBackend then
			self.getExtraInfoAddIcon(theRoot,_dataCont,PicTI30FooterBE,block);
		else
			self.getExtraInfoAddIcon(theRoot,_dataCont,PicTI30Footer,block);
			if self.has30FootBackendSlotRequest(self.isLoad) &lt;&gt; null then
				self.getExtraInfoAddIcon(theRoot,_dataCont,PicTI30FooterBE,block);
			endif;
		endif;
	endif;
	// PAR 16415 CCMS 1029
	// ###########
	// FIFTY THREE FOOT	
	if self.getAttrIs53() then
		isFiftyThree := true;	//09 Apr 2010 NDL	Par 22526
		if isBackEnd then // PAR 21746			//cnwas3 PAR 24273
		// PAR 21746 		if self.isBackend then
			self.getExtraInfoAddIcon(theRoot,_dataCont,PicTI53FooterBE,block);
		else
			self.getExtraInfoAddIcon(theRoot,_dataCont,PicTI53Footer,block);
		endif;
	endif;
	
	
	// ###########
	// WATERCOOLED	
	if self.getAttrWaterCooled() then
		self.getExtraInfoAddIcon(theRoot,_dataCont,PicTIWaterCooled,block);
	endif;

	// ###########
	// POWERED
	if self.getAttrPowerRequired() then
		self.getExtraInfoAddIcon(theRoot,_dataCont,PicTIConnected,block);
	endif;
	// ###########
	// HAZARD
	if self.getAttrHazardous() then
		self.getExtraInfoAddIcon(theRoot,_dataCont,PicTIHazard,block);
	endif;
	
	// ###########
	// OVERSIZED
	if self.getAttrOverDimensioned() then
		self.getExtraInfoAddIcon(theRoot,_dataCont,PicTIOversized,block);
	endif;
	
	// ###########
	// HIGH CUBED	
	if self.getAttrHiCubed() then
		self.getExtraInfoAddIcon(theRoot,_dataCont,PicTIHiCube,block);
	endif;

	// ###########
	// HALF HEIGHT	
	if self.getAttrHalfHeight() then
		self.getExtraInfoAddIcon(theRoot,_dataCont,PicTIHalfHeight,block);
	endif;


	motorDir:= self.getMotorDirection;
	if ( isForty or isFortyFive or isFiftyThree ) then	//09 Apr 2010 NDL	Par 22526
		//epr TFS 7006 29/9/17
		if  motorDir = Motor_Aft then
			self.getExtraInfoAddIcon(theRoot,_dataCont,PicTIMotorAft40,block);
		elseif  motorDir = Motor_Forward then
			self.getExtraInfoAddIcon(theRoot,_dataCont,PicTIMotorFwd40,block);
		endif;

		
		if  self.doorsDirection = TI_DOORSDIRN_AFT then
			self.getExtraInfoAddIcon(theRoot,_dataCont,PicTIDoorsAft40,block);
		elseif  self.doorsDirection = TI_DOORSDIRN_FWD then
			self.getExtraInfoAddIcon(theRoot,_dataCont,PicTIDoorsFwd40,block);
		endif;	
	else
		// #############
		// MOTOR DIRECTION
		if  motorDir = Motor_Forward then
			self.getExtraInfoAddIcon(theRoot,_dataCont,PicTIMotorFwd,block);
		elseif  motorDir = Motor_Aft then
			self.getExtraInfoAddIcon(theRoot,_dataCont,PicTIMotorAft,block);			
		endif;
		// DOOR DIRECTION
		if  self.doorsDirection = TI_DOORSDIRN_FWD then
			self.getExtraInfoAddIcon(theRoot,_dataCont,PicTIDoorsFwd,block);
		elseif  self.doorsDirection = TI_DOORSDIRN_AFT then
			self.getExtraInfoAddIcon(theRoot,_dataCont,PicTIDoorsAft,block);
		endif;
	endif;

	// MTs ONLY
	if self.getAttrEmpty() then
		self.getExtraInfoAddIcon(theRoot,_dataCont,PicTIEmpty,block); //PicTIMTOnly
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_dataCont" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getFirstAllocation" id="85bfc32b-ba44-42ae-be47-f4868d4f08d4">
        <source>getFirstAllocation() : CM_VoyageAllocation;
/*
Purpose:			
Date		Who		Reason
27 June 2011	cnwab1	Initial creation
*/

vars
	allocation : CM_VoyageAllocation;
begin
	allocation := self.allAllocations.first.CM_VoyageAllocation;
	if allocation &lt;&gt; null then
		return allocation;
	endif;

	return null;

epilog

end;</source>
        <ReturnType type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="getForwardSlotRequest" id="6f8751d2-7b33-4c6a-90d0-5aa6441804f2">
        <source>getForwardSlotRequest() : CM_SlotRequest;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     Gets the slot request for the previous slot. Used for 40' rear end slots
//              which don't have a direct job reference
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	sc : CM_SlotController;
begin

// PAR 32318	 return self.mySlotRequestForward;

	// // PAR 32318 put back the code uncommented by 31217 below
	if self.mySlotController = null then
		return null;
	endif;
	sc := self.mySlotController.myForwardSlot;
	if sc = null then
		return null;
	endif;
	if self.isDischarge then
		return sc.mySlotRequestDischarge;
	else
		return sc.mySlotRequestLoad;
	endif;

	 
/*	 PAR 31217
	if self.mySlotController = null then
		return null;
	endif;
	sc := self.mySlotController.myForwardSlot;
	if sc = null then
		return null;
	endif;
	resynchObject(sc);
	if self.isDischarge then
		return sc.mySlotRequestDischarge;
	else
		return sc.mySlotRequestLoad;
	endif;
	*/
end;</source>
        <ReturnType type="CM_SlotRequest"/>
    </JadeMethod>
    <JadeMethod name="getGridXMLdisch" id="67b49159-c5d8-4cde-923b-59235d5fe068">
        <source>getGridXMLdisch(_isStarBoard : Boolean; _removeZeros : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	s1,s2,s3,s4,s5,s6,s7,s8,s9,s10,s11,s12,s13,s14,s15,s16,s17,s18,s20,s21,s22,s23,s24,s25,s26,s27,s28,s29, theXML : String;
	theTI : CM_TrackedItem;
	myWLE : CM_WorkListEntry;
	cargoType : CM_CargoType;	//cnwas3 PAR 24273
	commodityGroup : CM_CommodityGroup; //cnwas3 PAR 24273
	dischargePort : CM_Port;  	//cnwas3 PAR 24273
begin
	cargoType := self.getAttrCargoType();		//cnwas3 PAR 24273
	s1 := getOidStringForObject(cargoType);		//cnwas3 PAR 24273
	commodityGroup := self.getAttrCommodityGroup();//cnwas3 PAR 24273
	s2 := getOidStringForObject(commodityGroup);//cnwas3 PAR 24273
	dischargePort := self.getAttrDischargePort();//cnwas3 PAR 24273
	s3 := getOidStringForObject(dischargePort);	//cnwas3 PAR 24273
	s4 := self.moveType.String;
	s5 := getOidStringForObject(self.myJob);
	s11 := self.getSeqNumStringForXML(false, _isStarBoard, false,_removeZeros, false);
	s12 := self.mySlotController.hasTIsOfMode(PLANNING_MODE).Integer.String;


	s20 := self.mySlotController.hasTIsOfMode(PLANNING_MODE).Integer.String;
	s21 := self.getAttrHazardous().Integer.String;
	s22 := self.getAttrOverDimensioned().Integer.String;
	s23 := self.getAttrIs40().Integer.String; //  is there a 40 here
	s24 := self.getAttrEmpty().Integer.String;
	s25 := self.getAttrHiCubed().Integer.String;
	s26 := self.getAttrPowerRequired().Integer.String;
// PAR7496 AKB2004FEB		s27 := self.reefer.Integer.String;
	s27 := "0";
	s28 := self.unavailable.Integer.String ;
	s29 := self.getAttrWaterCooled().Integer.String;
//	s24 := self.motorDirection.Integer.String;
//	s25 := self.doorsDirection.Integer.String;
//	s27 := self.halfHeight.Integer.String;


	if dischargePort &lt;&gt; null then		//cnwas3 PAR 24273
		s13 := dischargePort.colour.String;	//cnwas3 PAR 24273
	endif;
/*
	if self.myJob &lt;&gt; null then
		s14 := self.areWLEsAllStatus(WLE_COMPLETED).Integer.String; //self.myJob.isJobComplete.Integer.String;
		if s14 = "1" then
			theTI := self.getTrackedItem();
			if theTI &lt;&gt; null then
				s18 := theTI.id;
			endif;
		endif;
	endif;
*/
	if self.myJob &lt;&gt; null then
		if not self.allWorkListEntries.isEmpty then
			myWLE := self.allWorkListEntries.first.CM_VoyageWLE;
			if myWLE &lt;&gt; null then
				s14 := (myWLE.status = WLE_COMPLETED).Integer.String;
			endif;
		endif;
		if s14 = "1" then
			theTI := self.getTrackedItem();
			if theTI &lt;&gt; null then
				s18 := theTI.id;
			endif;
		endif;
	endif;









	if cargoType &lt;&gt; null then		//cnwas3 PAR 24273
		s6 := cargoType.id.String;	//cnwas3 PAR 24273
	endif;
	if commodityGroup &lt;&gt; null then	//cnwas3 PAR 24273
		s7 := commodityGroup.code;	//cnwas3 PAR 24273
	endif;
	if dischargePort &lt;&gt; null then	//cnwas3 PAR 24273
		s8 := dischargePort.code;		//cnwas3 PAR 24273	
		s9 := dischargePort.colour.String;	//cnwas3 PAR 24273
	endif;
// PAR 29698 	s15 := (self.mySlotRequestDLRSOBLoad &lt;&gt; null).Integer.String;
	s15 := (self.getLinkedRequest(true) &lt;&gt; null ).Integer.String; //mySlotRequestDLRSOBLoad &lt;&gt; null).Integer.String;
	
	theXML := "&lt;ct&gt;" &amp; s1 &amp; "&lt;/ct&gt;&lt;cm&gt;" &amp; s2 &amp; "&lt;/cm&gt;&lt;dp&gt;" &amp; s3  &amp; "&lt;/dp&gt;&lt;dpc&gt;" &amp; s13 &amp; "&lt;/dpc&gt;&lt;MT&gt;" &amp; s4 &amp; "&lt;/MT&gt;&lt;djb&gt;" &amp; s5 &amp; "&lt;/djb&gt;&lt;djc&gt;" &amp; s14 &amp; "&lt;/djc&gt;" &amp; 
			"&lt;ccd&gt;" &amp; s7 &amp; "&lt;/ccd&gt;&lt;pcd&gt;" &amp; s8 &amp; "&lt;/pcd&gt;&lt;pcl&gt;" &amp; s9 &amp; "&lt;/pcl&gt;&lt;rl&gt;" &amp; s15 &amp; "&lt;/rl&gt;&lt;sn&gt;" &amp; s11 &amp; "&lt;/sn&gt;&lt;hp&gt;" &amp; s12 &amp; "&lt;/hp&gt;&lt;id&gt;" &amp; s18 &amp; "&lt;/id&gt;"; 
	theXML := theXML &amp; "&lt;hz&gt;" &amp; s21 &amp; "&lt;/hz&gt;&lt;od&gt;" &amp; s22 &amp; "&lt;/od&gt;&lt;f40&gt;" &amp; s23 &amp; "&lt;/f40&gt;&lt;mt&gt;" &amp; s24 &amp; "&lt;/mt&gt;&lt;hc&gt;" &amp; s25 &amp; "&lt;/hc&gt;&lt;pw&gt;" &amp; s26 &amp; "&lt;/pw&gt;&lt;rf&gt;" 
				&amp; s27 &amp; "&lt;/rf&gt;&lt;na&gt;" &amp; s28 &amp; "&lt;/na&gt;&lt;wc&gt;" &amp; s29 &amp; "&lt;/wc&gt;"; 

	return theXML;
end;</source>
        <Parameter name="_isStarBoard" type="Boolean"/>
        <Parameter name="_removeZeros" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGridXMLload" id="f1a5cda2-8f3e-4039-a3e9-0a7199cdfddc">
        <source>getGridXMLload(_isStarBoard : Boolean; _removeZeros : Boolean; _showOnlyDoorDirections : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	s1,s2,s3,s4,s5,s6,s7,s8,s9,s10,s11,s12,s13,s14,s15,s16,s17,s18,s19,s20,s21,s22,s23,s24,s25, theXML : String;
	theSeqParams : 	CMIF_SeqParams;
	myWLE : CM_VoyageWLE;
	commodityGroup : CM_CommodityGroup; //cnwas3 PAR 24273
	dischargePort  : CM_Port;		//cnwas3 PAR 24273 
	
begin
	// sequence number
/*
	create theSeqParams;
	theSeqParams.isDischarge := false;
	theSeqParams.isStarBoard := self.mySlotController.myVoyage.starboardBerthed;
	theSeqParams.showWithSuffix := false;
	theSeqParams.isForty := self.fortyFront;
*/
	s21 := self.getSeqNumStringForXML(false, _isStarBoard, false,_removeZeros, false);



	s1 := self.getAttrHazardous().Integer.String;
	s2 := self.getAttrOverDimensioned().Integer.String;
	s3 := self.getAttrIs40().Integer.String; //  is there a 40 here

//	if _showOnlyDoorDirections then // PAR 8190
		s4 := Motor_Null.String; // PAR 8190
//	else
		//s4 := self.motorDirection.Integer.String;
//	endif;
	s5 := self.doorsDirection.Integer.String;
	s6 := self.getAttrEmpty().Integer.String;
	s7 := self.getAttrHalfHeight().Integer.String;
	s8 := self.getAttrHiCubed().Integer.String;
	s9 := self.getAttrPowerRequired().Integer.String;
// PAR7496 AKB2004FEB		s10 := self.reefer.Integer.String;
	s10 := "0";
	s11 := self.unavailable.Integer.String ;
	s12 := self.getAttrWaterCooled().Integer.String;
	s13 := self.moveType.String;
	s14 := getOidStringForObject(self.getAttrCargoType());
	commodityGroup := self.getAttrCommodityGroup();				//cnwas3 PAR 24273
	s15 := getOidStringForObject(commodityGroup);				//cnwas3 PAR 24273
	dischargePort := self.getAttrDischargePort();			//cnwas3 PAR 24273
	s16 := getOidStringForObject(dischargePort);		//cnwas3 PAR 24273
	s17 := getOidStringForObject(self.myJob);
	if commodityGroup &lt;&gt; null then			//cnwas3 PAR 24273
		s18 := commodityGroup.code;			//cnwas3 PAR 24273
	endif;
	if dischargePort &lt;&gt; null then			//cnwas3 PAR 24273 begin
		s19 := dischargePort.code;
		s20 := dischargePort.colour.String;			//cnwas3 PAR 24273 end
	endif;
	
	s22 := self.mySlotController.hasTIsOfMode(PLANNING_MODE).Integer.String;
	if self.myJob &lt;&gt; null then
		if not self.allWorkListEntries.isEmpty then
			myWLE := self.allWorkListEntries.first.CM_VoyageWLE;
			if myWLE &lt;&gt; null then
				s23 := (myWLE.status = WLE_COMPLETED).Integer.String;
	//s23 := self.areWLEsAllStatus(WLE_COMPLETED).Integer.String; //self.myJob.isJobComplete.Integer.String;
			endif;
		endif;
	endif;
// PAR 28968	s24 := (self.mySlotRequestDLRSOBDischarge &lt;&gt; null).Integer.String;
	s24 := (self.getLinkedRequest(true) &lt;&gt; null).Integer.String;
	if commodityGroup &lt;&gt;  null then			//cnwas3 PAR 24273
		s25 := commodityGroup.hasTemp.Integer.String;		//cnwas3 PAR 24273
	endif;
	theXML := "&lt;hz&gt;" &amp; s1 &amp; "&lt;/hz&gt;&lt;od&gt;" &amp; s2 &amp; "&lt;/od&gt;&lt;f40&gt;" &amp; s3 &amp; "&lt;/f40&gt;&lt;m20&gt;" &amp; s4 &amp; "&lt;/m20&gt;&lt;m40&gt;" &amp; s4 &amp; "&lt;/m40&gt;&lt;dd20&gt;" &amp; s5 &amp; "&lt;/dd20&gt;&lt;dd40&gt;" &amp; s5 &amp; "&lt;/dd40&gt;&lt;mt&gt;" &amp; s6 &amp; "&lt;/mt&gt;&lt;hh&gt;" &amp; 
		s7 &amp; "&lt;/hh&gt;&lt;hc&gt;" &amp; s8 &amp; "&lt;/hc&gt;&lt;pw&gt;" &amp; s9 &amp; "&lt;/pw&gt;&lt;rf&gt;" &amp; s10 &amp; "&lt;/rf&gt;&lt;na&gt;" &amp; s11 &amp; "&lt;/na&gt;&lt;wc&gt;" &amp; s12 &amp; "&lt;/wc&gt;&lt;rl&gt;" &amp; s24 &amp; "&lt;/rl&gt;" &amp; 
				"&lt;MT&gt;" &amp; s13 &amp; "&lt;/MT&gt;&lt;ct&gt;" &amp; s14 &amp; "&lt;/ct&gt;&lt;cm&gt;" &amp; s15 &amp; "&lt;/cm&gt;&lt;dp&gt;" &amp; s16 &amp; "&lt;/dp&gt;&lt;ljb&gt;" &amp; s17 &amp; "&lt;/ljb&gt;&lt;ljc&gt;" &amp; s23 &amp; "&lt;/ljc&gt;" &amp; 
				"&lt;ccd&gt;" &amp; s18 &amp; "&lt;/ccd&gt;&lt;pcd&gt;" &amp; s19 &amp; "&lt;/pcd&gt;&lt;pcl&gt;" &amp; s20 &amp; "&lt;/pcl&gt;&lt;sn&gt;" &amp; s21 &amp; "&lt;/sn&gt;&lt;hp&gt;" &amp; s22 &amp; "&lt;/hp&gt;&lt;ht&gt;" &amp; s25 &amp; "&lt;/ht&gt;"; 
	return theXML;
	
epilog
//	delete theSeqParams;
end;</source>
        <Parameter name="_isStarBoard" type="Boolean"/>
        <Parameter name="_removeZeros" type="Boolean"/>
        <Parameter name="_showOnlyDoorDirections" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getId" id="bafe529c-856c-4237-8270-7289667f4db8">
        <source>getId(): String;
//--------------------------------------------------------------
//Created: 08 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	str			: String;
	isoType 	: CM_ISOType;
	isoGroup 	: CM_ISOTypeGroup;
	cargoType	: CM_CargoType;
begin

	// this section added by cnwrd1 par 24525 30.6.2010
	if self.myBulkReleaseReserveDetail = null then // not a slot request by type so return the default self.id
	
		if self.getFirstAllocation &lt;&gt; null then
			return self.getFirstAllocation.code;
		endif;
		return self.id;
	endif;
	
	str := self.getDisplayStringForAttribute(ETRow_OperatorCode, true);
	
	isoType := self.myBulkReleaseReserveDetail.getISOType();		
	if isoType &lt;&gt; null then
		return str &amp; ' ' &amp; isoType.code;
	endif;
	
	isoGroup := self.myBulkReleaseReserveDetail.getISOGroup();		
	if isoGroup &lt;&gt; null then
		return str &amp; ' ' &amp; isoGroup.code;
	endif;
	
	cargoType := self.myBulkReleaseReserveDetail.getCargoType();
	if cargoType &lt;&gt; null then
		return str &amp; ' ' &amp; cargoType.abbreviation;
	endif;
	
	return str;


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
