<Class name="CM_Message" id="18c75c7b-3cfc-42c0-8115-75b51252ca3f">
    <superclass name="CM_Object"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="terminal"/>
    <ExplicitInverseRef name="allUsersRead" id="bdc959fc-098b-4487-be38-5b5dbfb3e41f">
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_UserSet"/>
        <access>readonly</access>
        <Inverse name="CM_User::allMessagesRead"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="allUsersToRead" id="cc45fcbd-b555-496d-bf96-7fc8d2886e6c">
        <transientToPersistentAllowed/>
        <type name="CM_UserSet"/>
        <access>readonly</access>
        <Inverse name="CM_User::allMessagesToRead"/>
    </ExplicitInverseRef>
    <PrimAttribute name="createdDateTime" id="fa6ff912-ca02-4be7-a7ee-9e2e8475f49c">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="deleteWhenAllRead" id="5080cf5f-bc9a-4f1c-9803-48e3361f3f03">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="expiryDateTime" id="652df462-5dc2-4935-b744-4fb7a922f403">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="heading" id="80380be0-5b6d-431f-8e10-3aadaa6eb0cb">
        <length>101</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myRoot" id="e3c06af4-5fd6-4eeb-ac30-b71133b0b1f2">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Root"/>
        <access>protected</access>
        <Inverse name="CM_Root::allMessages"/>
    </ExplicitInverseRef>
    <PrimAttribute name="text" id="7901400f-1f0c-44b3-9388-ee6a336aaf6e">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getInfoTableString" id="16080ffb-c244-42a3-9ec9-a8d73457052f">
        <source>getInfoTableString(): String;
//----------------------------------------------------------------
//	Created:	12 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	return self.heading &amp; Tab &amp; self.text;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreateFromProxy" id="c71cc9bc-801e-4417-9284-e760e781b7d7">
        <updating/>
        <source>setForCreateFromProxy(_pxyMessageUser: CM_MessageUser) updating;
//----------------------------------------------------------------
//	Created:	10 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.createdDateTime	:= app.actualTimeServer;
	self.deleteWhenAllRead	:= _pxyMessageUser.deleteWhenAllRead;
	
	if _pxyMessageUser.expiryDateTime.isValid then
		self.expiryDateTime	:= _pxyMessageUser.expiryDateTime;
	else
		self.expiryDateTime	:= null;
	endif;
	
	self.heading	:= _pxyMessageUser.heading;
	self.text		:= _pxyMessageUser.text;
	
	self.myRoot		:= app.myRoot;
	_pxyMessageUser.allUsersToRead.copy(self.allUsersToRead);

end;</source>
        <Parameter name="_pxyMessageUser" type="CM_MessageUser"/>
    </JadeMethod>
    <JadeMethod name="setForCreateSuperClass" id="9683ace5-ef27-4e74-a54a-41c188adefce">
        <updating/>
        <source>setForCreateSuperClass(_heading, _text : String; _users : Collection; 
			_deleteWhenAllRead : Boolean; _expiryDT : TimeStamp) updating;
// ---------------------------------------------------------------------------
// Created:     15 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.createdDateTime	:= app.actualTimeServer;
	self.deleteWhenAllRead	:= _deleteWhenAllRead;
	
	if _expiryDT.isValid then
		self.expiryDateTime	:= _expiryDT;
	else
		self.expiryDateTime	:= null;
	endif;
	
	self.heading	:= _heading;
	self.text		:= _text;
	
	self.myRoot		:= app.myRoot;
	
	if _users &lt;&gt; null then
		_users.copy(self.allUsersToRead);
	endif;

end;</source>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_text" type="String"/>
        <Parameter name="_users" type="Collection"/>
        <Parameter name="_deleteWhenAllRead" type="Boolean"/>
        <Parameter name="_expiryDT" type="TimeStamp"/>
    </JadeMethod>
</Class>
