    <JadeMethod name="clearAllSelected" id="4456c4f7-837b-4252-9bda-2308ff652376">
        <source>clearAllSelected();
// ---------------------------------------------------------------------------
// Created:     10 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.allSelectedObjects.clear();
	
	inheritMethod();

end;</source>
    </JadeMethod>
    <JadeMethod name="clearAllViewObjects" id="a18aee69-e7a6-43c8-8343-47dd8ba8283b">
        <source>clearAllViewObjects( eventType : Integer );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 March 2021	navndl1	Initial creation	TFS 50935

*/

vars

	obj : Object;

begin

	if eventType &gt; 0 then
		foreach obj in self.allViewObjects do
			self.form.endNotification( obj, eventType );
		endforeach;
	endif;
	
	self.allViewObjects.clear();
	self.allCurrentViewObjects.clear();

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clearViewObject" id="8c9c2be9-b260-47a3-886e-245cbc8be792">
        <updating/>
        <source>clearViewObject( _obj : Object; _eventType : Integer )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 March 2021	navndl1	Initial creation	TFS	50935 

*/

vars

	index : Integer;

begin

	if self.allViewObjects.includes( _obj ) then
		self.form.endNotification( _obj, _eventType );
		self.allViewObjects.remove( _obj );
	endif;
	
	if self.allCurrentViewObjects.includes( _obj ) then
		self.allCurrentViewObjects.remove( _obj );
		self.findObjectInRow( _obj, index );
		self.removeItem( index );
		self.setCurrentViewObjects();
	endif;
	
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_eventType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcResizeContents" id="ff128d62-0148-4f69-9184-7d92c681ca74">
        <updating/>
        <source>cnEcResizeContents() updating;
// ---------------------------------------------------------------------------
// Created:     16 November 2000 by cnwrs2
//
// Purpose:     Resize the contents of the table after a resize of its parent form
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02 Jul 2008	cnwkpd1		PAR #14904 - Change to use client height and width of parent,
//							to match repositionAfterResize and to ensure correct resizing 
//							inside a container with borders, etc
// ---------------------------------------------------------------------------
vars
	parentWidth,
   	parentHeight	: Real;
begin
	if (not self.visible) then
		return;
	endif;
	
	inheritMethod();

	if self.stretchToParent then
		// PAR #14904 - get client height and width from parent
		if self.parent.isKindOf(Form) then
			parentWidth  := self.parent.Form.clientWidth;
			parentHeight := self.parent.Form.clientHeight;
		elseif self.parent.isKindOf(Control) then
			parentWidth  := self.parent.Control.clientWidth;
			parentHeight := self.parent.Control.clientHeight;
		else
			parentWidth  := self.parent.width;
			parentHeight := self.parent.height;
		endif;
	
		self.move(0, 0, parentWidth, parentHeight);		// PAR #14904
	endif;
	
	//We have changed the size of the area we are viewing, refresh the current view.
	self.setCurrentViewObjects();	//19 Mar 2021	NDL	TFS 50935

end;</source>
    </JadeMethod>
