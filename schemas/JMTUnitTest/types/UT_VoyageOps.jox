	slots.copy(jobSlots);
	
	
	voyageJob:=self.addVoyageJob(voyage,"CRN2",jobSlots, true);	//CM_VoyageJob::setRequestSeqNumbers  172
	assertTrue(voyageJob &lt;&gt; null);
	assertTrueMsg(voyageJob.isTwinLift, "Job " &amp; voyageJob.jobNum &amp; " Should be TWIN  LIFT");
	
	aSlot := self.getJobLOLOControllerByID("UTBISH_SL1", "09", "090688"); 
