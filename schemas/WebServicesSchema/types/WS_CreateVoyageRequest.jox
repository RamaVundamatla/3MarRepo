    <JadeMethod name="createProxyVoyage" id="f963b55e-8185-47ed-9d3c-2df83a6eb6e2">
        <source>createProxyVoyage() : CM_Voyage  ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/06/2018	jlger1	Initial creation tfs 39129
19/10/2018	jlgdap1	TFS 41305 PEL1 Voyage and Cargo Operator in Web Portal
16/09/2021 	jlier1	TFS 51963 
*/

vars
	vessel : CM_Vessel;
	cargoLoadOperator,
	cargoDischargeOperator,
	operator : CM_Operator;
	departureTS,
	arrivalTS : TimeStamp;
	pxyVoyage : CM_Voyage;
	terminal : CM_Terminal;
	externalRef : String;
	lastPort,
	lastPortOfCall,
	nextPortOfCall,
	originPort: CM_Port;
	visitType : HMS_VisitType;
	vesselCategory : HMS_VesselCategory;
	voyageProcess : CM_VoyageProcess;	//27 Sep 2018	NDL	TFS 41109
	voyCode : String;
begin
	vessel:= app.myRoot.allVessels[self.vessel];
	if vessel = null and self.vessel &lt;&gt; null then
		vessel:=app.myPassport.getObjectOfTypeFromOid(self.vessel,CM_Vessel).CM_Vessel;
	endif;
	
	operator:= app.myRoot.allOperators[self.operator];
	if operator = null and self.operator &lt;&gt; null then
		operator:=app.myPassport.getObjectOfTypeFromOid(self.operator,CM_Operator).CM_Operator;
	endif;
	
	arrivalTS:=null;	
	arrivalTS.setDate(self.arrivalDate.asDateFromWebInterface);
	arrivalTS.setTime(self.arrivalTime.asTimeFromWebInterface);
	
	if vessel = null then
		app.raiseCMException(Input_required_field_vessel,null,null);
		return null;
	endif;
	
	voyCode:=self.voyageCode;

		
	if  arrivalTS = null or  not arrivalTS.isValid then
		app.raiseCMException(Input_required_field_arrDatTim,null,null);
		return null ;
	endif;
	
	if self.departureDate = null then
		//departureTS:=arrivalTS;
		departureTS:=arrivalTS.addDecimalDays(self.daysInPort.asDecimalFromWebInterface);
	else
	
		departureTS:=null;	
		departureTS.setDate(self.departureDate.asDateFromWebInterface);
		departureTS.setTime(self.departureTime.asTimeFromWebInterface);
	endif;
	terminal:=app.myPassport.myTerminal;

	
	lastPort:=app.myRoot.allPorts[self.lastPort];
	lastPortOfCall:=app.myRoot.allPorts[self.lastPortOfCall];
	nextPortOfCall:=app.myRoot.allPorts[self.nextPortOfCall];
	originPort :=app.myRoot.allPorts[self.originPort];
   
   
	
	if self.visitType &lt;&gt; null then
		visitType := app.myRoot.allVisitTypes[self.visitType]; // TFS 54298 jlizm1 18/08/2022
	endif;
	
	if self.vesselCategory &lt;&gt; null then
		// TFS 40029 vesselCategory:=app.myPassport.getObjectOfTypeFromOid(self.vesselCategory,HMS_VesselCategory).HMS_VesselCategory;
		vesselCategory:=app.myRoot.allVesselCategories[self.vesselCategory]; // TFS 40029
	endif;
	if self.operatorDischarge &lt;&gt; null then
		//cargoDischargeOperator:= app.myPassport.getObjectOfTypeFromOid(self.operatorDischarge,CM_Operator).CM_Operator;	// TFS 41305
		// TFS 41305 Pelindo are using Operator Data Access Groups to govern access to 
		// various things in the web portal, but also want ALL operators to be available 
		// for selection when defining Discharge and Load Cargo Operators. 
		// So we can't do getObjectOfTypeFromOid here because that does an access check which will fail
		cargoDischargeOperator := self.operatorDischarge.asOid.CM_Operator;				// TFS 41305			
		// TFS 41305 operatorDischarge may just be the operator code					// TFS 41305
		if cargoDischargeOperator = null then											// TFS 41305
			cargoDischargeOperator := app.myRoot.allOperators[self.operatorDischarge];	// TFS 41305
		endif;																			// TFS 41305
	endif;
	if self.operatorLoad &lt;&gt; null then
		//cargoLoadOperator:=app.myPassport.getObjectOfTypeFromOid(self.operatorLoad,CM_Operator).CM_Operator;				// TFS 41305
		// TFS 41305 Smae problem here as with the operatorDischarge - can't use getObjectOfTypeFromOid
		cargoLoadOperator := self.operatorLoad.asOid.CM_Operator;						// TFS 41305				
		// TFS 41305 operatorLoad may just be the operator code							// TFS 41305
		if cargoLoadOperator = null then												// TFS 41305
			cargoLoadOperator := app.myRoot.allOperators[self.operatorLoad];			// TFS 41305
		endif;																			// TFS 41305
	endif;
	
	externalRef:= self.voyageIn &amp; "|" &amp; self.voyageOut;
	
	voyageProcess := terminal.getDefaultVoyageProcess(); //jlier1 TFS 51963 8/10/21
	voyCode:=terminal.generateNextVoyWorkOrderId(null,null);	
		
	if voyCode = null then
		voyCode:=self.voyageCode;
	endif;
	//not sending has cargo until the user has updated and approves the work order
	pxyVoyage:= vessel.createProxyVoyageRequest(terminal,voyCode,operator,arrivalTS,departureTS,false,null, externalRef, 
	originPort,lastPortOfCall,nextPortOfCall,lastPort,vesselCategory,visitType,cargoLoadOperator,cargoDischargeOperator,voyageProcess,app.myPassport);
	

	if pxyVoyage &lt;&gt; null and pxyVoyage.myHMSVoyageData &lt;&gt; null then
		pxyVoyage.myHMSVoyageData.setRemarksGeneral(self.generalRemarks);
	endif;
	return pxyVoyage;
	
epilog
	
end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createVoyageRequest" id="b52e3cca-69a2-450b-85df-2f9d21741ea3">
        <source>createVoyageRequest(_isSubmit : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
08 November 2021	jlier1	Initial creation 52302
18 August 2022		jlizm1	TFS 54298 EUP - Simplified Voyage Work Order Process
26 March 2024		navpw1	TFS: 62849 (62927) - Reverted Code by adding beginLoad/endLoad

*/

vars
	vessel : CM_Vessel;
	proxyVoyage : CM_Voyage;
	voyageOp, loadOp, dischargeOp : CM_Operator;
	allDocuments		: ObjectArray;
	tmpHasCargo		: Boolean;
	terminal 		: CM_Terminal;
	voyageProcess 	: CM_VoyageProcess;
	
begin
	vessel:= self.getVessel;
	
	
	proxyVoyage:=self.createProxyVoyage();
	if proxyVoyage = null then	
		return ;
	endif;
	
	terminal:=app.myPassport.myTerminal;					// TFS 54298
	voyageProcess := terminal.getDefaultVoyageProcess();	// TFS 54298
	
	if _isSubmit then
		if voyageProcess.isEUPDefaultProcess then			// TFS 54298
			proxyVoyage.setStatusFromObject(app.myRoot.allVoyageStatuses[Voyage_Status_EUP_VoyReqSubm]);	// TFS 54298
		else
			proxyVoyage.setStatusFromObject(app.myRoot.allVoyageStatuses[Voyage_Status_VoyReqSubmitted]);
		endif;
	endif;
	
	if app.myPassport.hasErrors then
		return ;
	endif;
	
	tmpHasCargo := self.hasCargo;	// TFS 54298
	if voyageProcess &lt;&gt; null and voyageProcess.isEUPDefaultProcess then	// TFS 54298
		tmpHasCargo := true;		// TFS 54298
	endif;
	
	//jlier1 TFS 51963 8/10/21
	create allDocuments transient;
	beginLoad;
	self.allDocuments.setProxyDocuments(allDocuments);
	endLoad;
	// TFS 40029 get the operators for the wor order
	self.getOperators(voyageOp, loadOp, dischargeOp);
		
	app.myPassport.setWarningsIgnored(self.warningsAcknowledged);
	
	app.myTrxCA.trxCreateVoyageRequest(proxyVoyage,
										vessel,
										voyageOp, loadOp, dischargeOp,
										self.originPort, self.lastPortOfCall, self.nextPortOfCall, self.lastPort,	 // TFS 42024
										tmpHasCargo,
										self.generalRemarks, //TFS 51963
										allDocuments,
										app.myPassport);
epilog
	delete proxyVoyage;
	if allDocuments &lt;&gt; null then
		allDocuments.purge;
		delete allDocuments;
	endif;	
end;</source>
        <Parameter name="_isSubmit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="87c25b65-872b-4db9-9f18-52b0c3bbbd64">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 September 2021	jlier1	Initial creation

*/

vars

begin
	self.allDocuments.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getOperators" id="4fdf75d8-c673-46ba-bb1b-1d755f9f8b4c">
        <source>getOperators(_voyageOp, _loadOp, _dischargeOp : CM_Operator io);
/*

Purpose:			// TFS 40029

Parameters:			

Return Value:		

Date		Who		Reason
30/08/2018	jlgab1	Initial creation
06/11/2018	jlgdap1	TFS 41305 PEL1 Voyage and Cargo Operator in Web Portal
*/

vars

begin
	if self.operator &lt;&gt; null then
		_voyageOp := app.myRoot.allOperators[self.operator];
	endif;
	if self.operatorLoad &lt;&gt; null then
		// self.operatorLoad may be an oid								// TFS 41305
		_loadOp := self.operatorLoad.asOid.CM_Operator;					// TFS 41305		
		if _loadOp = null then											// TFS 41305
			_loadOp := app.myRoot.allOperators[self.operatorLoad];
		endif;															// TFS 41305
	endif;
	if self.operatorDischarge &lt;&gt; null then
		// self.operatorDischarge may be an oid							// TFS 41305
		_dischargeOp := self.operatorDischarge.asOid.CM_Operator;		// TFS 41305		
		if _dischargeOp = null then										// TFS 41305
			_dischargeOp := app.myRoot.allOperators[self.operatorDischarge];
		endif;															// TFS 41305
	endif;
epilog

end;</source>
        <Parameter name="_voyageOp" type="CM_Operator" usage="io"/>
        <Parameter name="_loadOp" type="CM_Operator" usage="io"/>
        <Parameter name="_dischargeOp" type="CM_Operator" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getVessel" id="e9c15ccf-e28e-4d3b-9c2a-639260a23c92">
        <source>getVessel() : CM_Vessel;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2021	jlier1	Initial creation 52302

*/

vars
	vessel : CM_Vessel;
begin
	vessel:= app.myRoot.allVessels[self.vessel];
	if vessel = null and self.vessel &lt;&gt; null then
		vessel:=app.myPassport.getObjectOfTypeFromOid(self.vessel,CM_Vessel).CM_Vessel;
	endif;
	
	return vessel;
epilog

end;</source>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="updatePxyVoyageRequest" id="12c3b9f8-2c00-4803-ad59-94776e7ea4e9">
        <source>updatePxyVoyageRequest(_pxyRequest : CM_WodVoyageRequest input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 September 2021	jlier1	Initial creation 51963

*/

vars
	departureTS,
	arrivalTS : TimeStamp;
	vesselCode : String;
	vessel : CM_Vessel;
	orginPort,lastPort,
	nextPortOfCall,lastPortOfCall  : String;
	operatorDischarge, operatorLoad	: CM_Operator;
	operatorDischargeCode,  operatorLoadCode  : String;
begin
	if _pxyRequest = null then
		return;
	endif;
	arrivalTS:=null;	
	arrivalTS.setDate(self.arrivalDate.asDateFromWebInterface);
	arrivalTS.setTime(self.arrivalTime.asTimeFromWebInterface);
	if  arrivalTS = null or  not arrivalTS.isValid then
		app.raiseCMException(Input_required_field_arrDatTim,null,null);
	endif;
	departureTS:=null;	
	departureTS.setDate(self.departureDate.asDateFromWebInterface);
	departureTS.setTime(self.departureTime.asTimeFromWebInterface);
	
	//epr TFS 51963 21/9/21
	vesselCode:= _pxyRequest.vesselCode;
	if self.vessel &lt;&gt; null then
		vessel:= app.myRoot.allVessels[self.vessel];
		if vessel = null and self.vessel.pos(".",1) &gt; 0 then
			vessel:=self.vessel.asOid.CM_Vessel;
		endif;
		if vessel &lt;&gt; null then
			vesselCode:=vessel.code;
		endif;
	endif;
	
	if self.originPort &lt;&gt; NULLINDEX.String then
		orginPort:=self.originPort;
	endif;
	if self.lastPort &lt;&gt; NULLINDEX.String then
		lastPort:=self.lastPort;
	endif;
	if self.nextPortOfCall &lt;&gt; NULLINDEX.String then
		nextPortOfCall:=self.nextPortOfCall;
	endif;
	if self.lastPortOfCall &lt;&gt; NULLINDEX.String then
		lastPortOfCall:=self.lastPortOfCall;
	endif;
	//jlier1 TFS 52303 4/11/21 - also don't check data access
	if self.operatorDischarge &lt;&gt; NULLINDEX.String then
		operatorDischarge:=self.operatorDischarge.asOid.CM_Operator;
		if operatorDischarge &lt;&gt; null then
			operatorDischargeCode:=operatorDischarge.code;
		endif;
	endif;
	if self.operatorLoad &lt;&gt; NULLINDEX.String then
		operatorLoad:=self.operatorLoad.asOid.CM_Operator;
		if operatorLoad &lt;&gt; null then
			operatorLoadCode:=operatorLoad.code;
		endif;
	endif;
	
	
	
	_pxyRequest.setProxyVoyageRequest(operatorDischargeCode,operatorLoadCode,_pxyRequest.commodityCode,
								arrivalTS,departureTS,_pxyRequest.externalCode,originPort ,lastPort,nextPortOfCall,
								lastPortOfCall ,self.vesselCategory,vesselCode,self.visitType,_pxyRequest.voyageCode,self.voyageIn,
								self.voyageOut,self.operator,self.generalRemarks,self.hasCargo);
epilog

end;</source>
        <Parameter name="_pxyRequest" type="CM_WodVoyageRequest" usage="input"/>
    </JadeMethod>
</Class>
