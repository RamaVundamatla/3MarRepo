    <JadeMethod name="notableObjectsClear" id="b7a86353-1113-49b3-afa7-82d5c32f4cfa">
        <source>notableObjectsClear();
// ---------------------------------------------------------------------------
// Created:     05 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpObj	: Object;
begin

	foreach tmpObj in self.allNotableObjects do
		self.notableObjectEndNotes(tmpObj);
	endforeach;

	self.allNotableObjects.clear;

end;</source>
