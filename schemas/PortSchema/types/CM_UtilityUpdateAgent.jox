    </JadeMethod>
    <JadeMethod name="utlUpdateLinkCreditToInvoice" id="fac6997b-1744-4b66-a0e4-694df1c43107">
        <source>utlUpdateLinkCreditToInvoice(_pxyCreditNote : CM_Invoice; _allInvoicesToLink : CM_InvoiceSet; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2023	navkc1	Initial creation TFS CR 55305 Task 55533: Jade - Invoice Credit Note Jade Code
24/01/2023		navkc1	TFS CR 55305 Task 55535: Jade - Invoice Credit Note Audits
*/

vars
	pxyInvoice,
	realInvoice,
	realCreditNote,
	otherInvoice	: CM_Invoice;
	expectedEdition : Integer;
	
	itemAudit 		: CM_UpdateTransactionAuditAgent;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	if _pxyCreditNote.isTransient() then
		_pxyCreditNote.pxyGetRealObjectAndEdition(realCreditNote, expectedEdition);
	else
		realCreditNote := _pxyCreditNote;
	endif;
	
	if realCreditNote = null then
		app.raiseCMException1(ProxyMgrCannotLocateReal, _pxyCreditNote.sequenceNum.String, null, null);
		return;
	endif;
	
	foreach pxyInvoice in _allInvoicesToLink do
		app.myValUA.valUpdateLinkCreditToInvoice(pxyInvoice);
	endforeach;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	create itemAudit transient;
	
	itemAudit.audUpdateGeneric(realCreditNote, true);
	
	foreach pxyInvoice in _allInvoicesToLink do
		pxyInvoice.pxyGetRealObjectAndEdition(realInvoice, expectedEdition);
		
		exclusiveLock(realInvoice);
		
		// 24/01/2023	navkc1	TFS CR 55305 TASK 55535
		if _passport.noErrors() then
			self.myUpdateAuditAgent.audUpdateGeneric(realInvoice, true);
		endif;
		
		if realInvoice.myOtherInvoice &lt;&gt; null then
			otherInvoice := realInvoice.myOtherInvoice;
		endif;
		
		if _passport.noErrors() then
			//realInvoice.setMyOtherInvoice(realCreditNote);
			//16/10/2024	navkc1	JIRA Bug MTN-12541
			realCreditNote.allCreditInvoices.tryAdd(realInvoice);
		endif;
		
		// 24/01/2023	navkc1	TFS CR 55305 TASK 55535
		if _passport.noErrors() then
			self.myUpdateAuditAgent.audUpdateGeneric(realInvoice, false);
			realInvoice.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, realInvoice);
			if otherInvoice &lt;&gt; null then
				otherInvoice.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, otherInvoice);
			endif;
		endif;
	endforeach;
	realCreditNote.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, realCreditNote);
	itemAudit.audUpdateGeneric(realCreditNote, false);
epilog
	delete itemAudit;
end;</source>
        <Parameter name="_pxyCreditNote" type="CM_Invoice"/>
        <Parameter name="_allInvoicesToLink" type="CM_InvoiceSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateLoadingCompany" id="fecd8f7c-5ec1-4af2-8ab7-541683dada56">
        <source>utlUpdateLoadingCompany(_proxyLoader : CM_LoadingCompany; _passport : CM_Passport input);
//---------------------------------------
// Created: April 2006 By: cnwgd1
//---------------------------------------
vars
	cancelSave : Boolean;
	realLoader : CM_LoadingCompany;
	expectedEdition : Integer;
begin

	self.initialiseActivity();

	_proxyLoader.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyLoader.pxyGetRealObjectAndEdition(realLoader, expectedEdition);
	
	if realLoader = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_LoadingCompany.name, null, null);
		return;
	endif;

//	_proxyLoader.validateUpdate(_passport);
	app.myValUA.valLoadingCompany(realLoader, _proxyLoader);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realLoader);

	if _passport.noErrors and realLoader.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Loader', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realLoader, true);
	endif;
	
	if _passport.noErrors then
		realLoader.setForUpdate(_proxyLoader, _passport);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realLoader, false);
	endif;

epilog
	
	
end;</source>
        <Parameter name="_proxyLoader" type="CM_LoadingCompany"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateLoadingContractor" id="8bb9cca6-80dd-457d-9535-3cff035286ad">
        <source>utlUpdateLoadingContractor(pProxyLoadingContractor:CM_HandlingContractor1 ; _passport : CM_Passport input);
