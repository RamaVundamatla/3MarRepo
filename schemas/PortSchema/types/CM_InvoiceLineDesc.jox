    <JadeMethod name="isWeightBased" id="c0326f77-4452-4a29-8bfa-efedf77835d1">
        <source>isWeightBased() : Boolean;
// TFS 1990 return true if the calculation type is weight-based
vars
	result	: Boolean;
	chgByUnits : Integer;
begin
	chgByUnits := self.getChargeByUnits();

	if chgByUnits = INV_CALC_TYPE_VESSEL_TON or
	   chgByUnits = INV_CALC_TYPE_CARGOWEIGHTCONVT or
	   chgByUnits = INV_CALC_TYPE_DAYS_WEIGHT or
	   chgByUnits = INV_CALC_TYPE_EVENT_GRT or
	   chgByUnits = INV_CALC_TYPE_REVENUE_TONS or
	   chgByUnits = INV_CALC_TYPE_VESSEL_TON or
	   chgByUnits = INV_CALC_TYPE_VESSEL_TON_QTY1 or
	   chgByUnits = INV_CALC_TYPE_VESSEL_TON_RANGE or
	   chgByUnits = INV_CALC_TYPE_WEIGHT or
	   chgByUnits = INV_CALC_TYPE_WEIGHT_TON or

	   // ### JIRA 35638 06AUG2025 NAVAB1
	   chgByUnits = INV_CALC_TYPE_BOL_WEIGHT or 
	   chgByUnits = INV_CALC_TYPE_INVENT_WEIGHT or 
	   chgByUnits = INV_CALC_TYPE_UNIT_DEADWEIGHT or 
	   chgByUnits = INV_CALC_TYPE_UNIT_GRT or 
	   chgByUnits = INV_CALC_TYPE_UNIT_NRT or 
	   chgByUnits = INV_CALC_TYPE_WO_CARGOWEIGHT then 

		result := true;
	endif;

	return result;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
