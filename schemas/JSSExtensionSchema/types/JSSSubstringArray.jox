    <JadeMethod name="addString" id="82a91c59-85bc-4252-838a-43aa2d95b458">
        <lockReceiver/>
        <updating/>
        <source>addString(pStringValue: String): Integer updating, lockReceiver;
// --------------------------------------------------------------------------------
// Created:		30 June 2001 by cnwdad1
//
// Purpose:		Adds a new element to the array with the specified string value.
//
// Parameters:	pStringValue (String) - The string value for the new array element.
//
// Returns:		Integer - The index of the new array element.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theSubstring	: JSSSubstringElement;
	index			: Integer;

begin
	theSubstring	:=	self.createEntry();
	theSubstring.setStringValue(pStringValue);
	index			:=	self.size() + 1;
	self.atPut(index, theSubstring);
epilog
	return index;
end;</source>
        <Parameter name="pStringValue" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addStringAt" id="ea7e3b52-edf7-42e1-a3a4-6a40242e703a">
        <lockReceiver/>
        <updating/>
        <source>addStringAt(pIndex: Integer; pStringValue: String) updating, lockReceiver;
// --------------------------------------------------------------------------------
// Created:		30 June 2001 by cnwdad1
//
// Purpose:		Inserts a new element into the array at the specified index position
//				and with the specified string value.
//
// Parameters:	pStringValue (String) - The string value for the new array element.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theSubstring	: JSSSubstringElement;

begin
	theSubstring	:=	self.createEntry();
	theSubstring.setStringValue(pStringValue);
	self.atPut(pIndex, theSubstring);
end;</source>
        <Parameter name="pIndex" type="Integer"/>
        <Parameter name="pStringValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="createEntry" id="9fb2f35e-26f8-4ed4-927c-6befa5ae57c6">
        <lockReceiver/>
        <updating/>
        <source>createEntry(): JSSSubstringElement updating, protected, lockReceiver;
// --------------------------------------------------------------------------------
// Created:		30 June 2001 by cnwdad1
//
// Purpose:		Private method to create a new JSSSubstringElement instance for a
//				new element in the array.
//
// Parameters:	None
//
// Returns:		JSSSubstringElement - The newly created array member.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theSubstringObject	: JSSSubstringElement;

begin
	if self.isTransient() then
		create theSubstringObject transient;
	else
		create theSubstringObject;
	endif;
epilog
	return theSubstringObject;
end;</source>
        <access>protected</access>
        <ReturnType type="JSSSubstringElement"/>
    </JadeMethod>
