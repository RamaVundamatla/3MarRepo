    <JadeMethod name="locateTaskForTI" id="99ebe531-91f2-4db9-ac47-c58c6d686a3c">
        <source>locateTaskForTI(tiToSearch : CM_TrackedItem; _taskType : Integer) : CM_RTQueueTask;
//Search here, and its other children if it has any...
vars
	foundTask	:	CM_RTQueueTask;
	voyCQueue	:	CM_RadioTelemetryQueue;
begin
	//-----------------
	//Search ourselves 1st...
	//-----------------
	foundTask := inheritMethod(tiToSearch, _taskType);
	if foundTask &lt;&gt; null then
		return foundTask;
	endif;
	//--------------------
	//OK, we didnt find anything in self, check our crane queues
	//--------------------
	foreach voyCQueue in self.allSubQueuesById discreteLock do
		foundTask := voyCQueue.locateTaskForTI(tiToSearch, _taskType);
		if foundTask &lt;&gt; null then
			return foundTask;
		endif;
	endforeach;
	return null;
end;</source>
        <Parameter name="tiToSearch" type="CM_TrackedItem"/>
        <Parameter name="_taskType" type="Integer"/>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="2d21714f-09e5-40c0-a4c3-02dc42513316">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------
// Created:	30 October 2003 By: cnwgd1
//--------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy : SelfType;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	proxy.myVoyage := self.myVoyage;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
