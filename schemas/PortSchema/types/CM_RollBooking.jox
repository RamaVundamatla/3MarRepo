<Class name="CM_RollBooking" id="1ff0b799-32d1-4215-8312-e52cfe6ba509">
    <superclass name="CM_SplitRollBooking"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <JadeMethod name="getDisplayStringForAttribute" id="50f3e8a2-53bf-432f-bacf-2fc7260cc1f8">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/10/2011	cnwdap1	Initial creation PAR #28524 CCMS POL 2096 Return old/new booking as "Details"
*/
vars
	str : String;

begin
	if _attrName = ETRow_Details then
		if self.deleted then
			return self.getDeletedDetails();		// 25/10/18 MAP TFS41191
		else
			if self.oldBookingReference &lt;&gt; self.newBookingReference then
				str := "Booking Reference " &amp; self.oldBookingReference &amp; " =&gt; " &amp; self.newBookingReference &amp; " ";
			endif;
			if self.oldDischargePort &lt;&gt; self.newDischargePort then
				str := str &amp; "Discharge Port " &amp; self.oldDischargePort &amp; " =&gt; " &amp; self.newDischargePort &amp; " ";
			endif;
			if self.oldVoyageCode &lt;&gt; self.newVoyageCode then
				str := str &amp; "Voyage " &amp; self.oldVoyageCode &amp; " = &gt; " &amp; self.newVoyageCode;
			endif;
			if self.remarks &lt;&gt; null then
				str := str &amp; " (" &amp; self.remarks &amp; ")";
			endif;
			return str;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
