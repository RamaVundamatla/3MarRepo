    <JadeMethod name="doDisplayContainerForCargoType" id="3ec0bc41-94c2-4f55-8f29-066fa47b0e3a">
        <updating/>
        <source>doDisplayContainerForCargoType() updating;
// ---------------------------------------------------------------------------
// Created:     16 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpCargoType			: CM_CargoType;
	containerID				: String;
	class					: Class;
	container				: CM_TrackedItem;
	aBulkRel, relReq				: CM_BulkRelease;
	res						: CM_ReserveDetail;
begin
	containerID := self.txt_ContainerID.text.toUpper;
	if containerID = null then
		return;
	endif;
	
	tmpCargoType := self.cmb_CargoType.listObject.CM_CargoType;
	if tmpCargoType = null then
		return;
	endif;
	aBulkRel := null;
	container := self.myMobileDataAgent.myTerminal.allOnsiteTIsByIdCargoType[containerID, tmpCargoType.id].CM_TrackedItem;
	self.myCargoTI := container;
	if container &lt;&gt; null then
		// looking up for a bulk release number associated with the Container TI
		foreach relReq in self.myCargoTI.allBulkReleasesAssigned do
			if relReq.status = BR_ACTIVE and relReq.type = BR_TYPE_PACKING then
				aBulkRel := relReq;
				break;
			endif;
		endforeach;
		
		if aBulkRel = null then
		//search trough all the reserve details release reversed, and we will display the last one that was actioned.(Richard)
			foreach res in container.allReserveDetailsReleased reversed do
				if res &lt;&gt; null then
					aBulkRel := res.myReserveHeader;
				endif;
				if aBulkRel &lt;&gt; null and aBulkRel.type = BR_TYPE_PACKING and aBulkRel.status = BR_ACTIVE then
					self.txt_RequestNo.text := aBulkRel.code;
					return;
				endif;
			endforeach;
			// clear textbox, we couldnt found anything to display
			self.txt_RequestNo.text := null;
		else
			self.txt_RequestNo.text := aBulkRel.code;
		endif;	
	endif;
end;	
</source>
    </JadeMethod>
    <JadeMethod name="doPackCargo" id="294e2b87-9cdb-466c-8c7a-5384c3ef3530">
        <updating/>
        <source>doPackCargo():Boolean updating;
// ---------------------------------------------------------------------------
// Created:     16 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	set			: CM_BulkReleaseSet;
	weight		: Integer;
	location: CM_LocationsController;
	
begin
	if not self.validateForPacking() then
		return false;
	endif;
	
	//Update Weight if changed.
	weight := self.txt_TareWeight.text.trimBlanks.Integer;
	
	//if weight &lt;&gt; self.myCargoTI.weight 				//-cnwml2 MSL CCMS 1017
	if weight &lt;&gt; self.myCargoTI.weightTare				//+cnwml2 MSL CCMS 1017
	and not myCargoTI.isTransient()
	then
		if not self.doSaveWeightForTI(weight) then
			app.msgBox("Weight not updated!", null, null);
			return false;
		endif;
	endif;

	location := self.myMobileDataAgent.findLocationByID(txt_Location.text.toUpper);
	
	create set transient;
	set.add(self.myRequest);
	app.myMobileGUIAgent.loadPackingForm(set, myCargoTI, location);
	
	return true;
epilog
	delete set;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveWeightForTI" id="292e1b32-6d98-4bf3-9e71-86ea1cf058d4">
        <updating/>
        <source>doSaveWeightForTI(_weight :Integer input): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     26 May 2008	cnwaer1
//
// Purpose:     save Weight for Container
//			 
// ----------   ----------  --------------------------------------------------
// 20/01/2010	cnwdap1		PAR #22084 Set total weight as well as tare weight if container is empty and has no children
// 26/08/2010	cnwdap1		PAR #25405 Set tare weight, not just weight
vars
	pxyObj					: CM_Object;
	pxyTI 					: CM_TrackedItem;
	result					: Integer;
begin	
	pxyTI := app.createUpdateProxy(self.myCargoTI).CM_TrackedItem;
	pxyTI.setWeight(_weight, null,app.myPassport);
	// PAR #22084 and total weight if we have no children and the container is empty
	//if self.myCargoTI.isContainer and self.myCargoTI.CM_Container.isEmpty and self.myCargoTI.allChildren.isEmpty then//PAR 22954
	if self.myCargoTI.isContainer and self.myCargoTI.CM_Container.isEmpty and not self.myCargoTI.hasChildren then
		pxyTI.setTotalWeight(_weight, null, app.myPassport);
	endif;
	// PAR #25405 and tare weight
	pxyTI.setWeightTare(_weight);
	
	while true do
		app.myTrxUA.trxUpdateTrackedItem(pxyTI,
											null,
											TI_UPDMODE_NORMAL, 
											null, 
											app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			return true;
		else
			result := app.showErrorWarningDialog('Tracked Item Update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;
		
epilog
	delete pxyTI;
end;
</source>
        <access>protected</access>
        <Parameter name="_weight" type="Integer" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterCargoType" id="4767dfb9-0d1c-4444-ac6b-a2517192d715">
        <source>filterCargoType(_type: CM_CargoType): Boolean;
/*
	Created on 19 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	return _type.CM_CargoType.type = TI_CargoType_Container 
	or (_type.CM_CargoType.isDynamicallyCreated);

end;</source>
        <Parameter name="_type" type="CM_CargoType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
