        <source>setupForCreate(_myToPrimaryLocation : CM_LocationsController;
			   _myOriginatingLocation : CM_LocationsController; 
			   _myTrackedItem :  CM_TrackedItem;
			   _moveMode : Integer;
			   _action : Integer
			   ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2008	conkc1	Initial creation

*/

vars

begin
