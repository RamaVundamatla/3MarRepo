    <JadeMethod name="doNotableAdd" id="cd3231bc-79f5-4d70-a608-8f40f3159fad">
        <source>doNotableAdd(_contract: CM_InvoiceContractDetails);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Feb 2023 navtnr20	TFS CR 55646 Task 55664: UI - Contracts Maint

*/

vars
	invalid : Boolean;
	ed : Integer;
begin
	
	self.allNotableObjects.add(_contract);
	beginNotification(_contract, self.myTerminal.getTerminalEvent(Event_InvContractDtlUpdate), Response_Continuous, null);
	beginNotification(_contract, EventFileAdd, Response_Continuous, null);
	beginNotification(_contract, EventFileDelete, Response_Continuous, null);

epilog

end;</source>
