    </JadeMethod>
    <JadeMethod name="updateTICollections" id="5fc5939a-3bcc-4b21-b6ee-343e417c4cc8">
        <updating/>
        <source>updateTICollections(_trackedItem: CM_TrackedItem; _extra :Any) updating;
//--------------------------------------------------------------
//Created: 11 February 2003 By: cnwgd1
//--------------------------------------------------------------
// 01/04/2010	cnwcs5	par 23383 - new parameter (_extra) not used
vars

begin
	inheritMethod(_trackedItem, _extra);	// 01/04/2010 cnwcs5 par 23383

	//this should probably check the door job and  swap job references too tho.
	/* //cnwrd1 par 22240 2.2.2010  can now have multiple yard internal jobs
	if not self.isDoorJob and (_trackedItem.jobYardInternal &lt;&gt; null and _trackedItem.jobYardInternal &lt;&gt; self) then //rs sept 2005 par 10712 cant assign a to to multiple jobs
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name,'Tracked Item already has an internal job pending.');
	endif;
	*/
	if (not app.myPassport.noErrors) then
		return;
	endif;
	
	if self.isSwapJob then
		if (not self.allTrackedItemsSwap.includes(_trackedItem)) then
			self.allTrackedItemsSwap.add(_trackedItem);
		endif;
		if self.allTrackedItems.includes(_trackedItem) then
			self.allTrackedItems.remove(_trackedItem);
		endif;
	elseif self.isDoorJob then
		if (not self.allTrackedItemsDoor.includes(_trackedItem)) then
			self.allTrackedItemsDoor.add(_trackedItem);
		endif;
		// i really don't think it will ever be included in the other collections
	
	else
		if (not self.allTrackedItems.includes(_trackedItem)) then
			self.allTrackedItems.add(_trackedItem);
		endif;
		if self.allTrackedItemsSwap.includes(_trackedItem) then
			self.allTrackedItemsSwap.remove(_trackedItem);
		endif;			
	endif;

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_extra" type="Any"/>
    </JadeMethod>
    <JadeMethod name="updateTICollectionsUnassign" id="9c64e4fc-510b-4411-b157-f3509cc2f557">
        <updating/>
        <source>updateTICollectionsUnassign(_trackedItem: CM_TrackedItem) updating;
//--------------------------------------------------
// Created:	23 September 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_trackedItem);
	if (not app.myPassport.noErrors) then
		return;
	endif;
	
	if self.isSwapJob then
		if self.allTrackedItemsSwap.includes(_trackedItem) then
			self.allTrackedItemsSwap.remove(_trackedItem);
		endif;
	else
		if self.allTrackedItems.includes(_trackedItem) then
			self.allTrackedItems.remove(_trackedItem);
		endif;
	endif;
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="892c7a32-a453-4112-9ba0-47fef8b80323">
        <source>validateForDelete() ;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	wlesCompleteOrUnactioned : Boolean;
	wle : CM_WorkListEntry;

begin
//	Removed inheritMethod as not required to call higher levels of validation for internal jobs.
//	Checks on higher levels pertain to road, rail etc.  We are only doing yard to yard for these.
//	inheritMethod();

	if self.status = JOB_UNACTIONED or self.status = JOB_COMPLETE  or self.allEntries.size = 0 then
		//Carry on.
	else
		
		//09 Mar 2012	NDL	Par 28671
		if self.status = JOB_PART_COMPLETE then
			wlesCompleteOrUnactioned := true;
			foreach wle in self.workListEntries do
				if wle.status &lt;&gt; WLE_UNACTIONED and wle.status &lt;&gt; WLE_COMPLETED then
					wlesCompleteOrUnactioned := false;
					break;
				endif;
			endforeach;
		endif;
		if wlesCompleteOrUnactioned then
		else
		
		// Par 9963. 
			app.setContinueCMExceptions(false);
			app.raiseCMWarning2(VB_JOB_NO_DELETE, self.jobId &amp; " oid - " &amp; self.String, self.statusString, null, null,self);
			return;
		endif;
	endif;

end;</source>
    </JadeMethod>
</Class>
