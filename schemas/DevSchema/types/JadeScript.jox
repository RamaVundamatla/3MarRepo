    <JadeMethod name="createJDOForComparisonMethod" id="fb332174-f52e-42f0-889a-fa4b72ac5abc">
        <source>createJDOForComparisonMethod(_file : File input; _dict : DynaDictionary io);

/*

Purpose:		Create the JDO used for the comparison		

Date			Who		Reason
01/02/2012		cnwmh5	Initial creation

*/
constants
	AlphaCharacter				: String = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz";
vars

	jdo							: JadeDynamicObject;
	
	nextLineOfFile 				: String;
	previousLineOfFile			: String;
	currentClassName			: String;
	currentMethodName			: String;
	attribute					: String;
	text						: String;
	propertyType				: String;
	jdoCommentedOut				: Boolean;
	
	isCommentedOut				: Boolean;
	pos							: Integer;

begin

	if not _file.isAvailable then
		return;
	endif;
	
	while not _file.endOfFile do
	
		isCommentedOut := false;
		_file.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version
		previousLineOfFile := nextLineOfFile;
		nextLineOfFile := _file.readLine();
		
		if nextLineOfFile.trimBlanks() = "{" then
			currentClassName := previousLineOfFile[1:previousLineOfFile.pos("::", 1) - 1];
			currentMethodName := previousLineOfFile[previousLineOfFile.pos("::", 1) + 2:end];
			continue;
		endif;
	
		if nextLineOfFile.trimBlanks() = "}" then
			currentClassName := null;
			currentMethodName := null;
			continue;
		endif;
	
		// if line doesn't contain ".translate" then don't want to know about it
		if not nextLineOfFile.cnContains(".translate") then
			continue;
		endif;
	
		// have a .tranlate line of code need to get the attribute, whether it's commented and create dynamic object
		nextLineOfFile.cnReplaceString(Tab, "");
		nextLineOfFile.cnReplaceString("( ", "(");
		nextLineOfFile.cnReplaceString(" )", ")");
		text := nextLineOfFile;
		
		// check to see if commented out
		pos := 1;
		if nextLineOfFile[1:2] = "//" then				
			isCommentedOut := true;
			pos := 3;
		endif;
		// get the starting point of the text
		nextLineOfFile.scanUntil(AlphaCharacter, pos);
		
		// get the attribute
		attribute := nextLineOfFile.scanUntil(".", pos);
		nextLineOfFile := nextLineOfFile[pos+1:end];
		
		// get what we are translation
		pos := 1;
		propertyType := nextLineOfFile.scanUntil("(", pos);
		propertyType := propertyType[10:end].trimBlanks();
		propertyType[1:1] := propertyType[1:1].toLower();
		
		jdo := _dict[currentClassName, currentMethodName, attribute, propertyType].JadeDynamicObject;
		write jdo.String &amp; Tab &amp; currentClassName &amp; Tab &amp; currentMethodName &amp; Tab &amp; attribute &amp; Tab &amp; propertyType &amp; Tab &amp; isCommentedOut.String;
		if jdo = null then
			create jdo transient;
			jdo.addProperty("className", String);
			jdo.setPropertyValue("className", currentClassName);
			jdo.addProperty("methodName", String);
			jdo.setPropertyValue("methodName", currentMethodName);
			jdo.addProperty("attribute", String);
			jdo.setPropertyValue("attribute", attribute);
			jdo.addProperty("propertyType", String);
			jdo.setPropertyValue("propertyType", propertyType);
			jdo.addProperty("isCommentedOut", Boolean);
			jdo.setPropertyValue("isCommentedOut", isCommentedOut);
			jdo.addProperty("text", String);
			jdo.setPropertyValue("text", text);
			_dict.putAtKey(currentClassName, currentMethodName, attribute, propertyType, jdo);
		else
			jdoCommentedOut := jdo.getPropertyValue("isCommentedOut").Boolean;
			write Tab &amp; jdoCommentedOut.String &amp; Tab &amp; text;
			
			if jdoCommentedOut then
				if not isCommentedOut then
					jdo.setPropertyValue('isCommentedOut', isCommentedOut);
				endif;
				jdo.setPropertyValue('text', text);
			else
				write jdo.String &amp; Tab &amp; currentClassName &amp; Tab &amp; currentMethodName &amp; Tab &amp; attribute &amp; Tab &amp; propertyType &amp; Tab &amp; isCommentedOut.String &amp; Tab &amp; 
					jdoCommentedOut.String &amp; Tab &amp; text;
				if not isCommentedOut then
					jdo.setPropertyValue('text', text);
				endif;
			endif;
		endif;	
		
	endwhile;
	
epilog

end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_dict" type="DynaDictionary" usage="io"/>
    </JadeMethod>
    <JadeMethod name="createSnapshotdata" id="c74999e2-f9ae-4db2-b52c-5bccf957c031">
        <source>createSnapshotdata();
// ---------------------------------------------------------------------------
// Created:     17 December 2009 by cnwcs5
// Purpose:     CCMS 1023 - snapshot summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	format_SS 	: CM_OutputFormat_SS;
	collection 	: Collection;
	user 		: CM_User;
	coll		:CM_ObjectSet;
	any			:Any;
begin

	app.initialize();
	app.myPassport.setMyUserFromCode("SUPERUSER");
//	app.myPassport.setMyTerminal("2351.53".asOid.CM_Terminal);	// NDL Terminal
	app.myPassport.setMyTerminal("2351.56".asOid.CM_Terminal);	// Christina's Terminal
	//app.myPassport.setMyTerminal(CM_Terminal.firstInstance);	// Christina's Terminal
	
	format_SS := "9611.57".asOid.CM_OutputFormat_SS;
	
	if format_SS = null then
		write "No format";
		return;
	endif;
	
	user := "2412.103".asOid.CM_User;
	
	collection := app.myPassport.myTerminal.allOnsiteTIsByIdCargoType;
	
	create coll transient;
	
	foreach any in collection reversed do
		coll.add (any.Object);
		
		if coll.size = 10 then
			//break;
		endif;
	endforeach;
	
	format_SS.generateSnapshotDataFromColl( coll,	//_coll : Collection
							"Jade script generated (CMS)",//_name : String
							app.actualTimeServer,	 	// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
							app.myPassport.myTerminal,
							user
							);
		
epilog


end;</source>
    </JadeMethod>
    <JadeMethod name="createStorageExpDetail" id="d9c4d05a-238e-4c95-a9ac-21a8786adbe6">
        <source>createStorageExpDetail();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 September 2023 navmv20 CR 58250 Task 58251: Jade - Upgrade script

*/

vars
	terminal : CM_Terminal;
	dict : Dictionary;
	iterator : Iterator;
	ti : CM_TrackedItem;
	storageExpDetl : CM_StorageExpiryDetail;
	operator : CM_Operator;
	operatorCode : String;
	transaction : CM_TITransaction;
	dateTime : TimeStamp;
	totalQuantity : Integer;
	totalWeight,
	totalVolume : Decimal[14,4];
begin
	app.initialize();
	
	beginTransaction;
	foreach terminal in app.myRoot.allTerminals do
		dict := terminal.getDictForTISelector(TI_SITE_ONSITE, null, false, false);
		iterator := dict.createIterator;
		while iterator.next(ti) do
			ti.allStorageExpiryDetails.purge();
			create storageExpDetl persistent;
			transaction := ti.allTransactions.findFirstReceivalTrans();
			if transaction &lt;&gt; null then
				dateTime := transaction.dateTime;
				totalQuantity := transaction.totalQuantity;
				totalWeight := transaction.totalWeight;
				totalVolume := transaction.totalVolume;
			else
				totalQuantity := 0;
				totalWeight := 0;
				totalVolume := 0;
				dateTime := null;
			endif;
			operator := ti.getReceiveOperator();
			if operator &lt;&gt; null then
				operatorCode := operator.code;
			endif;
			
			storageExpDetl.setProxy(ti.additionalStorageDays,dateTime,null,ti.getFreeDaysType(),null,ti.freeStorageDays,null,ti.getFreeStExpDTFirstTime().TimeStamp,ti.plannedDT,null,
			null,ti.getMatchingFreeStorageDetail(null),ti,operatorCode,null,ti.getFreeStorageChangeReason(),totalQuantity,totalVolume,totalWeight,ti.getChargedDaysType());
			
		endwhile;
	endforeach;
	commitTransaction;
epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="createSystemSealCheckTypes" id="045087c3-fd86-491b-83f7-9960ef7c43b3">
        <source>createSystemSealCheckTypes();
//
// 19 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//
vars
	sealType : CM_SealType;
	pxySealType : CM_SealType;
	entTableRowHdr : EntTableRowHeader;
	entTableRow : EntTableRow;
	description : String;
	allCargoTypes : CM_CargoTypeSet;
	converting : Boolean;
begin
	app.initialize;
	converting := app.isConverting;
	app.isConverting := true;
	create allCargoTypes transient;
	allCargoTypes.add( app.myRoot.allCargoTypesById.getAtKey(TI_CargoType_Container) );
	
	// Create the system Operators seal type if it doesn't exist.
	description := null;
	entTableRowHdr := app.myRoot.myEntTableDataRoot.allEntTableRowHeadersByName[ETRow_SealNum];
	if entTableRowHdr &lt;&gt; null then
		entTableRow := entTableRowHdr.allEntTableRows.first;
		if entTableRow &lt;&gt; null then
			description := entTableRow.getHeading(null, null, app.myCurrentLocale);
		endif;
	endif;
	if description = null then
		description := "Operator Seal";
	endif;
	sealType := app.myRoot.getSealType( SealType_Operator );
	if sealType = null then
		create pxySealType transient;
	else
		beginLoad;
		pxySealType := sealType.pxyCreateUpdateProxy();
		endLoad;
	endif;
	pxySealType.setProxy(	SealType_Operator,	//_sealType: String;
							description,	//_description: String;
							allCargoTypes,	//_allCargoTypes: CM_CargoTypeSet;
							true,	//_allowMultipleSealNums: Boolean;
							false,	//_notAvailableForEntry: Boolean;
							true,	//_showSealOnCheck: Boolean;
							true,	//_savePrevSeal : Boolean;
							false	//_useForTrucks : Boolean;
							);
	pxySealType.setIsInUse(true);						
	if sealType = null then
		app.myTrxCA.trxCreateSealType(pxySealType, sealType, app.myPassport);	
	else
		app.myTrxUA.trxUpdateSealType(pxySealType, app.myPassport);
	endif;
	
	delete pxySealType;

	// Create the system customs seal type if it doesn't exist.
	description := null;
	entTableRowHdr := app.myRoot.myEntTableDataRoot.allEntTableRowHeadersByName[ETRow_SealNumCustoms];
	if entTableRowHdr &lt;&gt; null then
		entTableRow := entTableRowHdr.allEntTableRows.first;
		if entTableRow &lt;&gt; null then
			description := entTableRow.getHeading(null, null, app.myCurrentLocale);
		endif;
	endif;
	if description = null then
		description := "MAF/Customs Seal";
	endif;
	sealType := app.myRoot.getSealType( SealType_Customs );
	if sealType = null then
		create pxySealType transient;
	else
		beginLoad;
		pxySealType := sealType.pxyCreateUpdateProxy();
		endLoad;
	endif;
	pxySealType.setProxy(	SealType_Customs,	//_sealType: String;
							description,	//_description: String;
							allCargoTypes,	//_allCargoTypes: CM_CargoTypeSet;
							true,	//_allowMultipleSealNums: Boolean;
							false,	//_notAvailableForEntry: Boolean;
							true,	//_showSealOnCheck: Boolean;
							false,	//_savePrevSeal : Boolean
							false	//_useForTrucks : Boolean
							);
	pxySealType.setIsInUse(true);						
	if sealType = null then
		app.myTrxCA.trxCreateSealType(pxySealType, sealType, app.myPassport);	
	else
		app.myTrxUA.trxUpdateSealType(pxySealType, app.myPassport);
	endif;
	
	delete pxySealType;
	
	// Create the system Shippers seal type if it doesn't exist.
	description := null;
	entTableRowHdr := app.myRoot.myEntTableDataRoot.allEntTableRowHeadersByName[ETRow_SealNumShippers];
	if entTableRowHdr &lt;&gt; null then
		entTableRow := entTableRowHdr.allEntTableRows.first;
		if entTableRow &lt;&gt; null then
			description := entTableRow.getHeading(null, null, app.myCurrentLocale);
		endif;
	endif;
	if description = null then
		description := "Shippers Seal";
	endif;
	sealType := app.myRoot.getSealType( SealType_Shipper );
	if sealType = null then
		create pxySealType transient;
	else
		beginLoad;
		pxySealType := sealType.pxyCreateUpdateProxy();
		endLoad;
	endif;
	pxySealType.setProxy(	SealType_Shipper,	//_sealType: String;
							description,	//_description: String;
							allCargoTypes,	//_allCargoTypes: CM_CargoTypeSet;
							true,	//_allowMultipleSealNums: Boolean;
							false,	//_notAvailableForEntry: Boolean;
							true,	//_showSealOnCheck: Boolean;
							false,	//_savePrevSeal : Boolean
							false	//_useForTrucks : Boolean
							);
	pxySealType.setIsInUse(true);						
	if sealType = null then
		app.myTrxCA.trxCreateSealType(pxySealType, sealType, app.myPassport);	
	else
		app.myTrxUA.trxUpdateSealType(pxySealType, app.myPassport);
	endif;
	
	delete pxySealType;
	
	// Create the system vent seal type if it doesn't exist.
	description := null;
	entTableRowHdr := app.myRoot.myEntTableDataRoot.allEntTableRowHeadersByName[ETRow_SealNumVent];
	if entTableRowHdr &lt;&gt; null then
		entTableRow := entTableRowHdr.allEntTableRows.first;
		if entTableRow &lt;&gt; null then
			description := entTableRow.getHeading(null, null, app.myCurrentLocale);
		endif;
	endif;
	if description = null then
		description := "Vent Seal";
	endif;
	sealType := app.myRoot.getSealType( SealType_Vent );
	if sealType = null then
		create pxySealType transient;
	else
		beginLoad;
		pxySealType := sealType.pxyCreateUpdateProxy();
		endLoad;
	endif;
	pxySealType.setProxy(	SealType_Vent,	//_sealType: String;
							description,	//_description: String;
							allCargoTypes,	//_allCargoTypes: CM_CargoTypeSet;
							true,	//_allowMultipleSealNums: Boolean;
							false,	//_notAvailableForEntry: Boolean;
							true,	//_showSealOnCheck: Boolean;
							false,	//_savePrevSeal : Boolean
							false	//_useForTrucks : Boolean
							);
	pxySealType.setIsInUse(true);						
	if sealType = null then
		app.myTrxCA.trxCreateSealType(pxySealType, sealType, app.myPassport);	
	else
		app.myTrxUA.trxUpdateSealType(pxySealType, app.myPassport);
	endif;
	
	delete pxySealType;
	
	// Create the system Terminal Operator seal type if it doesn't exist.
	description := null;
	entTableRowHdr := app.myRoot.myEntTableDataRoot.allEntTableRowHeadersByName[ETRow_SealNumTerminalOperator];
	if entTableRowHdr &lt;&gt; null then
		entTableRow := entTableRowHdr.allEntTableRows.first;
		if entTableRow &lt;&gt; null then
			description := entTableRow.getHeading(null, null, app.myCurrentLocale);
		endif;
	endif;
	if description = null then
		description := "Terminal Operator Seal";
	endif;
	sealType := app.myRoot.getSealType(SealType_TerminalOperator);
	if sealType = null then
		create pxySealType transient;
	else
		beginLoad;
		pxySealType := sealType.pxyCreateUpdateProxy();
		endLoad;
	endif;
	pxySealType.setProxy(	SealType_TerminalOperator,	//_sealType: String;
							description,	//_description: String;
							allCargoTypes,	//_allCargoTypes: CM_CargoTypeSet;
							true,	//_allowMultipleSealNums: Boolean;
							false,	//_notAvailableForEntry: Boolean;
							true,	//_showSealOnCheck: Boolean;
							false,	//_savePrevSeal : Boolean
							false	//_useForTrucks : Boolean
							);
	pxySealType.setIsInUse(true);						
	if sealType = null then
		app.myTrxCA.trxCreateSealType(pxySealType, sealType, app.myPassport);	
	else
		app.myTrxUA.trxUpdateSealType(pxySealType, app.myPassport);
	endif;
	delete pxySealType;

	// Create the system Unknown seal type if it doesn't exist.
	description := null;
	entTableRowHdr := app.myRoot.myEntTableDataRoot.allEntTableRowHeadersByName[ETRow_SealNumUnknown];
	if entTableRowHdr &lt;&gt; null then
		entTableRow := entTableRowHdr.allEntTableRows.first;
		if entTableRow &lt;&gt; null then
			description := entTableRow.getHeading(null, null, app.myCurrentLocale);
		endif;
	endif;
	if description = null then
		description := "Unknown Seal";
	endif;
	sealType := app.myRoot.getSealType(SealType_Unknown);
	if sealType = null then
		create pxySealType transient;
	else
		beginLoad;
		pxySealType := sealType.pxyCreateUpdateProxy();
		endLoad;
	endif;
	pxySealType.setProxy(	SealType_Unknown,	//_sealType: String;
							description,	//_description: String;
							allCargoTypes,	//_allCargoTypes: CM_CargoTypeSet;
							true,	//_allowMultipleSealNums: Boolean;
							false,	//_notAvailableForEntry: Boolean;
							true,	//_showSealOnCheck: Boolean;
							false,	//_savePrevSeal : Boolean
							false	//_useForTrucks : Boolean
							);
	pxySealType.setIsInUse(true);						
	if sealType = null then
		app.myTrxCA.trxCreateSealType(pxySealType, sealType, app.myPassport);	
	else
		app.myTrxUA.trxUpdateSealType(pxySealType, app.myPassport);
	endif;
	delete pxySealType;
epilog
	delete pxySealType;
	delete allCargoTypes;
	app.isConverting := converting;
end;</source>
    </JadeMethod>
    <JadeMethod name="createUNLForTranslateMethods" id="1f5e0e1c-b05c-4378-9699-d02f34ec131d">
        <source>createUNLForTranslateMethods();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwmh5	Initial creation

*/

vars

	schema				: Schema;
	class				: Class;
	meth				: Method;
	file				: File;

	classesArray		: ClassColl;
	schemaArray			: SchemaColl;
	
	schemaName			: String;

begin
	
	create schemaArray transient;
	schemaArray.add(rootSchema.getSchema(UiCommonSchemaName));
	schemaArray.add(rootSchema.getSchema(MobileUISchemaName));
	
	create classesArray transient;
	
	foreach schema in schemaArray do
		
		classesArray.clear();
		if schema.name &lt;&gt; MobileUISchemaName then
			schema.getClass(CM_BaseForm.name).allSubclasses(classesArray);
			schema.getClass(CM_BaseForm.name).allSubclassesInSubschemas(classesArray);
		else
			schema.getClass('MOB_BaseForm').allSubclasses(classesArray);
			schema.getClass('MOB_BaseForm').allSubclassesInSubschemas(classesArray);
		endif;
	
		foreach class in classesArray do
		
			write schemaName &amp; Tab &amp; class.schema.name &amp; Tab &amp; class.name;
			if schemaName &lt;&gt; class.schema.name then
				delete file;
				create file transient;
				file.fileName := "c:\translate22092012\translate_" &amp; class.schema.name &amp; ".unl";
				if file.isAvailable then
					file.purge;
				endif;
				schemaName := class.schema.name;
			endif;
		
			// check to see if the class has a translateForm method
			meth := class.getMethod("translateForm");
			if meth = null then
				continue;
			endif;
		
			file.writeLine("Method " &amp; class.name &amp; " " &amp; meth.name);
		
		endforeach;
	
		file.close();
	
	endforeach;
	
epilog

	delete classesArray;
	delete file;

end;</source>
    </JadeMethod>
    <JadeMethod name="dQMFixScript" id="92158da6-23f6-4200-9f6c-2501867837c5">
        <source>dQMFixScript();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 May 2018	jlgma1	Initial creation

*/

vars
	cargo : CM_TrackedItem;
	str : String;
terminal : CM_Terminal;
count : Integer;
voyage : CM_Voyage;
begin
 terminal := app.myRoot.allTerminals["PDC"];
beginTransaction;
	app.msgBox("Number of onsite TIs is " &amp; terminal.allOnsiteTIsByIdCargoType.size.String, "Result", MsgBox_OK_Only);
	foreach cargo in terminal.allOnsiteTIsByIdCargoType discreteLock where (cargo.myCargoType.isAllowDuplicates and not cargo.myCargoType.useTareCargoWeight) and cargo.weightCargo &lt;&gt; 0 do
		cargo.setPropertyValue(CM_TrackedItem::weightCargo.name, 0.Decimal );
		cargo.setPropertyValue(CM_TrackedItem::weightTare.name,  0.Decimal);
		str := str &amp; cargo.id &amp; Tab &amp; cargo.weightCargo.String &amp; CrLf;
		count := count + 1;
	endforeach;
	app.msgBox("NUmber of wonky TIs is " &amp; count.String &amp; CrLf &amp; str, "Result", MsgBox_OK_Only);
	
	str := null;
	count := null;
	app.msgBox("Number of prenote TIs is " &amp; terminal.allNotifiedTIsByIdCargoType.size.String, "Result", MsgBox_OK_Only);
	foreach cargo in terminal.allNotifiedTIsByIdCargoType discreteLock where (cargo.myCargoType.isAllowDuplicates and not cargo.myCargoType.useTareCargoWeight) and cargo.weightCargo &lt;&gt; 0 do
		cargo.setPropertyValue(CM_TrackedItem::weightCargo.name,  0.Decimal);
			cargo.setPropertyValue(CM_TrackedItem::weightTare.name, 0.Decimal);
		str := str &amp; cargo.id &amp; Tab &amp;   cargo.weightCargo.String &amp; CrLf;
		count := count + 1;
	endforeach;
	app.msgBox("NUmber of wonky prenotes is " &amp; count.String &amp; CrLf &amp; str, "Result", MsgBox_OK_Only);
	
	str := null;
	count := null;
	foreach voyage in terminal.allVoyagesByCode discreteLock do
		foreach cargo in voyage.allOnshipTIsByIdCargoType discreteLock where (cargo.myCargoType.isAllowDuplicates and not cargo.myCargoType.useTareCargoWeight) and cargo.weightCargo &lt;&gt; 0 do
			cargo.setPropertyValue(CM_TrackedItem::weightCargo.name,  0.Decimal);
				cargo.setPropertyValue(CM_TrackedItem::weightTare.name,  0.Decimal);
			str := str &amp; cargo.id &amp; Tab  &amp; cargo.weightCargo.String &amp; CrLf;
			count := count + 1;
		endforeach;
	endforeach;

	commitTransaction;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="dQMTest" id="1da5efbe-8b83-414c-85ca-90538db69664">
        <source>dQMTest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2017	jlgma1	Initial creation

*/

vars
	root : CM_Root;
	term : CM_Terminal;
	inv : CM_Invoice;
	invl : CM_InvoiceLine;
	bu : CM_Bank;
	fixup : CM_FixupHandlerAgent;
	errMsg : String;
	xMLFile : File;
	fileName : String;
	code : String;
begin


	create fixup transient;

	root := CM_Root.firstInstance;
	
	term := root.allTerminals["CASH"];
	
	bu := term.getDefaultCompanyBank();
	
	inv := bu.allInvoices[term,bu,1348];
	
	
	code := inv.sequenceNum.String;
	
	
	create xMLFile transient;
	//xMLFile.usePresentationFileSystem := false;
	fileName := "INVOICE-" &amp; code;
	fileName.replaceChar("\", "_");
	fileName.replaceChar("/", "_");
	xMLFile.openOutput("C:\temp\" &amp; fileName &amp; ".xml");
	
	if not xMLFile.isAvailable then
		errMsg := "File on the server could not be created for " &amp; code &amp; " - file name was " &amp; xMLFile.fileName;
		
	else
		
		xMLFile.writeLine('&lt;?xml version="1.0"?&gt;');
		xMLFile.writeLine(J_key_LessThan.Character &amp; inv.class.name &amp; " " &amp; 'type="' &amp;  inv.class.name &amp; '"' &amp; J_key_GreaterThan.Character);
		inv.exportAsXMLDoc(xMLFile);
		xMLFile.writeString(self.formatAsXMLSuffix(inv.class.name));

	endif;
	
epilog
	if xMLFile &lt;&gt; null then
		xMLFile.close;
	endif;
	delete xMLFile;


end;</source>
    </JadeMethod>
    <JadeMethod name="dataDumpBuildAllTables" id="9bd3f3a3-1cc4-4564-9e9d-93ac7472b0de">
        <source>dataDumpBuildAllTables();
//
//   Build All SQL Tables
//
constants
	DDxDefDescription = "ZMA1";
vars

	root                : CM_Root;
	terminal            : CM_Terminal;
	theUser             : CM_User;
	definition          : CM_DataDumpExtractDef;
	sqlTable            : CM_DataDumpExtractClass;
	newSqlColumn        : CM_DataDumpSQLColumn;
	proxySQLColumn      : CM_DataDumpSQLColumn;
	jadeClass           : CM_DataDumpClass;
	sqlColumn           : CM_DataDumpSQLColumn;
	sqlDataType         : CM_DataDumpSQLDataType;
	jadeFeature         : CM_DataDumpFeature;
	xdbAgent            : CM_ExternalDatabaseAgent;
//	description         : String;
	sqlTableName        : String;
	property            : String;
	value               : String;
	returnString        : String;
	dropString          : String;
	xdb                 : JMT_SQLNative;
	jMethod             : JadeMethod;
	cm_Weighed          : CM_Weighed;
	cm_Seal             : CM_Seal;
	cm_Move             : CM_Move;
	cm_ReceiveShip      : CM_ReceiveShip;
	count               : Integer;
	startTime           : Integer;
	endTime             : Integer;

	extDB : ExternalDatabase;
begin
	app.initialize;
	extDB := app.getExternalDatabase(JMT_SQLNative.getName);
	
	theUser := CM_Root.firstInstance.allUsers["SUPERUSER"];
	app.myPassport.setMyUser(theUser);
	app.setMyTerminal(CM_Terminal.firstInstance);

	root := CM_Root.firstInstance;
	terminal := root.allTerminals["MCT1"];
	
//	description := "KC SQL N 01";	
//	description := "KC One Only";
//	description := "25697";
//	description := "Joe's Test SQL Native";
//	description := "Testdb - SQL Server 2008";
	
	on Exception do null global;
	
	definition := root.allDataDumpExtractDefs[DDxDefDescription];
	create xdbAgent transient;
	xdbAgent.openDb(JMT_SQLNative, definition.edbConnectionString, definition.getPwForUse(null), 
			definition.edbServerName, definition.edbUserName, definition.edbMachineDSN);	

	startTime := app.clock;
	foreach sqlTable in definition.allDataDumpExtractClasses do
		dropString   := xdbAgent.buildDropTableString(sqlTable.sqlTableName);
		extDB.executeSQL(dropString);
		returnString := xdbAgent.buildCreateTableString(sqlTable);
		extDB.executeSQL(returnString);
	endforeach;

	endTime := app.clock;
	write "Time to load Tables - " &amp; ((endTime - startTime) / 1000).String;
	return;

epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="dataDumpBuildAllTablesToFile" id="b1aa1272-2a94-494b-9303-132a0672eec6">
        <source>dataDumpBuildAllTablesToFile();
//
//   Build All SQL Tables
//
constants
	DDxDefDescription = "Joe's Test SQL Native";
vars
	root                : CM_Root;
	terminal            : CM_Terminal;
	theUser             : CM_User;
	definition          : CM_DataDumpExtractDef;
	sqlTable            : CM_DataDumpExtractClass;
	newSqlColumn        : CM_DataDumpSQLColumn;
	proxySQLColumn      : CM_DataDumpSQLColumn;
	jadeClass           : CM_DataDumpClass;
	sqlColumn           : CM_DataDumpSQLColumn;
	sqlDataType         : CM_DataDumpSQLDataType;
	jadeFeature         : CM_DataDumpFeature;
	xdbAgent            : CM_ExternalDatabaseAgent;
//	description         : String;
	sqlTableName        : String;
	property            : String;
	value               : String;
	returnString        : String;
	dropString          : String;
	xdb                 : JMT_SQLNative;
	jMethod             : JadeMethod;
	cm_Weighed          : CM_Weighed;
	cm_Seal             : CM_Seal;
	cm_Move             : CM_Move;
	cm_ReceiveShip      : CM_ReceiveShip;
	count               : Integer;
	startTime           : Integer;
	endTime             : Integer;
	filePath : String;
	file : File;
	extDB : ExternalDatabase;
	dump : String;
begin
	app.initialize;
	extDB := app.getExternalDatabase(JMT_SQLNative.getName);
	
	theUser := CM_Root.firstInstance.allUsers["SUPERUSER"];
	app.myPassport.setMyUser(theUser);
	app.setMyTerminal(CM_Terminal.firstInstance);

	root := CM_Root.firstInstance;
	terminal := root.allTerminals["T01"];
	
//	description := "KC SQL N 01";	
//	description := "KC One Only";
//	description := "25697";
//	description := "Joe's Test SQL Native";
//	description := "RS SQL Native";
	
	on Exception do null global;
	
	definition := root.allDataDumpExtractDefs[DDxDefDescription];
	create xdbAgent transient;
//	xdbAgent.openDb(JMT_SQLNative, definition.edbConnectionString, definition.edbPassword, 
//			definition.edbServerName, definition.edbUserName, definition.edbMachineDSN);	

	startTime := app.clock;
	foreach sqlTable in definition.allDataDumpExtractClasses do
//		dropString   := xdbAgent.buildDropTableString(sqlTable.sqlTableName);
//		extDB.executeSQL(dropString);
		write sqlTable.sqlTableName;
		returnString := xdbAgent.buildCreateTableString(sqlTable);
		if dump = null then
			dump := returnString;
		else
			dump := dump&amp;CrLf&amp;returnString;
		endif;
//		extDB.executeSQL(returnString);
	endforeach;

	filePath := app.getFilePath(null, '*' &amp; '.sql', DDxDefDescription, false);
		
	if filePath = null then
		return;
	endif;	
	
	if filePath.toLower.pos('.sql', 1) &lt;= 0 then
		filePath := filePath &amp; '.sql';
	endif;
	
	create file transient;
	file.fileName := filePath;
	file.mode := File.Mode_Output;

	if (not file.tryOpen) then
		app.raiseCMException1(FileUnavailable, file.fileName, null, null);	
		return;
	endif;
		
	file.purge();
	file.writeLine(dump);
	endTime := app.clock;
	write "Time to load Tables - " &amp; ((endTime - startTime) / 1000).String;
	return;
epilog
	delete xdbAgent;
	if file &lt;&gt; null then
		file.close;
		delete file;
	endif;

end;

</source>
    </JadeMethod>
    <JadeMethod name="dataDumpBuildControl" id="449514d9-0c1b-41b4-84d7-05ddccc83b00">
        <source>dataDumpBuildControl();
//
//   Build All SQL Tables
//
vars

	root                : CM_Root;
	terminal            : CM_Terminal;
	theUser             : CM_User;
	xdbAgent            : CM_ExternalDatabaseAgent;
	dropString          : String;
	xdb                 : JMT_SQLNative;
	extDB               : ExternalDatabase;
	i : Integer64;
begin
	app.initialize;
	extDB := app.getExternalDatabase(JMT_SQLNative.getName);
	
	theUser := CM_Root.firstInstance.allUsers["SUPERUSER"];
	app.myPassport.setMyUser(theUser);
	app.setMyTerminal(CM_Terminal.firstInstance);

	root := CM_Root.firstInstance;
	terminal := root.allTerminals["DP1"];
	
	on Exception do null global;

	create xdbAgent transient;
	xdbAgent.openDb(JMT_SQLNative, "database=KCSQLDB", "kevin04", 
			"conkc1a\sqlexpress", "conkc1", "kcds");	

	xdbAgent.createJMTControlTable();
	xdbAgent.initialiseJMTControl();
	xdbAgent.updateJMTControl("5", Max_Integer);
	write xdbAgent.getJMTControlValues(i);
	write i;
	write xdbAgent.getColumnOrdinalPosition("Hmsresourcetypeformovement", "numTugsForMovement");

	write "Control Table Created";
	return;

epilog

end;</source>
    </JadeMethod>
