    <JadeMethod name="btnApply_click" id="596b3507-c12d-4fbe-8303-798f3537e0a2">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnApply_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		10 January 1999 cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 14/2/1999	cnwdad1		If the developer has reimplemented their own updating
//							logic, then make sure that we delete any transient file
//							objects loaded prior to the apply (update).
//
// --------------------------------------------------------------------------------
vars
	file	: File;
	index	: Integer;
	count	: Integer;

begin
	self.statusMsg('Updating object attributes...');

	if self.formValidate() then
		if self.userUpdateObject then
			// The Developer has implemented their own updating logic.
			count	:=	tblProperties.rows;
			index	:=	2;

			while index &lt;= count do
				file	:=	tblProperties.cnEcGetCellObject(index, 3).File;

				if file &lt;&gt; null then
					delete file;
					tblProperties.cnEcSetCellObject(index, 3, null);
					tblProperties.setCellText(index, 3, self.BINARY_LITERAL);
				endif;

				index	:=	index + 1;
			endwhile;
		else
			// Standard JDBrowser updating logic.
			self.formUpdate();
		endif;
	endif;
epilog
	self.statusMsg('');
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnCancel_click" id="79236b92-2a06-4b44-950b-60261ceb353d">
