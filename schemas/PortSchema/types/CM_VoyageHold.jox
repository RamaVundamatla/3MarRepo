<Class name="CM_VoyageHold" id="244c1b80-2b29-434b-9056-ac3f4dd08968">
    <superclass name="CM_Hold"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="voyages"/>
    <ExplicitInverseRef name="myCellularVoyageStructure" id="c52e8569-5d9d-4972-bd49-810820e5eef8">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_CellularVoyageStructure"/>
        <access>readonly</access>
        <Inverse name="CM_CellularVoyageStructure::allHolds"/>
    </ExplicitInverseRef>
    <JadeMethod name="hasJobsLoadedToOps" id="e54ad7ae-22db-4974-a26f-4d9b595fb8c9">
        <source>hasJobsLoadedToOps(_crane : CM_Crane) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2012	cnwer1	Initial creation CCMS MES 1026

*/

vars
	job : CM_Job;
	voyageJob : CM_VoyageJob;
	allBays : ObjectArray;
	bay, bay1, bay2 : CM_Bay;
begin
	create allBays transient;
	foreach bay in self.allBays do
		allBays.add(bay);
	endforeach;

	foreach job in self.myCellularVoyageStructure.myVoyage.allVoyageJobs do
		voyageJob:=job.CM_VoyageJob;
		if not voyageJob.isLoadedToOperations then
			continue;
		endif;
		
		bay1 := null;
		bay2 := null;
		// sob &amp; 40 ft bays
		voyageJob.getBays(bay1,bay2);
		if not allBays.includes(bay1) then 
			continue;
		endif;
		
		if  (bay2 &lt;&gt; null and not allBays.includes(bay2)) then
			continue;
		endif;
		
		if voyageJob.getJobCrane = _crane then
			return true;
		endif;
	endforeach;
	
	return false;
epilog
	delete allBays;
end;</source>
        <Parameter name="_crane" type="CM_Crane"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isBridgeAfterHold" id="da279079-7853-40de-85e4-e95d1ed320cb">
        <source>isBridgeAfterHold() : Boolean;

vars	
	aBay : CM_Bay;
begin
	foreach aBay in self.allBays do
		if aBay.id = self.myCellularVoyageStructure.bridgeAfterBay then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
