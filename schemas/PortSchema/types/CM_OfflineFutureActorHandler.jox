    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>JASSchema OfflineFutureActorAppHandler ported to here.</text>
    <DbClassMap file="cmtrans"/>
    <Constant name="Lock_Exception_Process_Delay" id="c1c5b327-9464-44bc-9aaf-2ee3ffb08096">
        <source>60000</source>
        <type name="Integer"/>
        <text>The number of milliseconds to wait before reprocessing an OfflineFutureActor which has
caused a lock exception.</text>
    </Constant>
    <Constant name="Standard_Timer_Delay" id="9fb8ac16-c709-4e0c-8368-456a10f59785">
        <source>3600000</source>
        <type name="Integer"/>
        <text>The maximum time to wait before checking for more OfflineFutureActor instances to 
process.</text>
    </Constant>
    <Constant name="Timer_Startup_Delay" id="4bb1f6dc-6ac7-442a-a906-44b3e8177786">
        <source>5000</source>
        <type name="Integer"/>
    </Constant>
