begin
	if self.isKindOf(Binary) then
		return (self.Binary &gt;= pCriteria.Binary);
	elseif self.isKindOf(Character) then
		return (self.Character &gt;= pCriteria.Character);
	elseif self.isKindOf(Date) then
		return (self.Date &gt;= pCriteria.Date);
	elseif self.isKindOf(Decimal) then
		return (self.Decimal &gt;= pCriteria.Decimal);
	elseif self.isKindOf(Integer) then
		return (self.Integer &gt;= pCriteria.Integer);
	elseif self.isKindOf(Real) then
		return (self.Real &gt;= pCriteria.Real);
	elseif self.isKindOf(Time) then
		return (self.Time &gt;= pCriteria.Time);
	elseif self.isKindOf(TimeStamp) then
		return (self.TimeStamp &gt;= pCriteria.TimeStamp);
	else
		return (self.String &gt;= pCriteria.String);
