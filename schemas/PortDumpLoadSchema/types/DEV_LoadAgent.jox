    <JadeMethod name="loadCheckPoint" id="2874e35d-9281-4a02-8e99-5509c80c15df">
        <source>loadCheckPoint(_checkPointProxy:HMS_CheckPoint io) :Boolean protected;

vars
	realObject: HMS_Object;
	proxyObject: HMS_BerthPreference;
	error: CM_Error;
	countError,countOK: Integer;
begin
//	_checkPointProxy.setPropertyValue("checkPointType", _type);
	realObject := _checkPointProxy.myHarbour.allCheckPoints[_checkPointProxy.code];
	if realObject = null then
		app.myTrxCA.trxCreateHMSObject(_checkPointProxy, realObject, app.myPassport);
	else
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_checkPointProxy.code&amp;" ERROR: "&amp;"Check Point already exists.",0);
		return false;
	endif;
	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then
		return true;
	else
		foreach error in app.myPassport.allWarnings do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_checkPointProxy.code&amp;" WARNING: "&amp;error.text,0);
		endforeach;
		foreach error in app.myPassport.allErrors do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_checkPointProxy.code&amp;" ERROR: "&amp;error.text,0);
		endforeach;
		return false;
	endif;
epilog

end;</source>
