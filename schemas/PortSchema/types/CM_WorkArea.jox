    <JadeMethod name="setForUpdate" id="368656c7-5707-4ba1-80b9-7a810eb976a4">
        <updating/>
        <source>setForUpdate( _proxy : CM_WorkArea ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

begin

	self.allTerminalAreas.clear();
	self.allGridObjects.clear();
	self.allLocationsControllers.clear();

	self.code := _proxy.code;
	self.description := _proxy.description;
	self.notAvailableForEntry := _proxy.notAvailableForEntry;
	
	_proxy.allTerminalAreas.copy( self.allTerminalAreas );
	_proxy.allGridObjects.copy( self.allGridObjects );
	_proxy.allLocationsControllers.copy( self.allLocationsControllers );

epilog

end;</source>
        <Parameter name="_proxy" type="CM_WorkArea"/>
    </JadeMethod>
    <JadeMethod name="setProxyBaseData" id="da4598e7-e161-4bfc-b0e5-5bf508c5041c">
        <updating/>
        <source>setProxyBaseData(	_code : String;
					_description : String;
					_notAvailable : Boolean;
					_allSelectedObjects : ObjectSet
					) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

	obj : Object;

begin

	self.code := _code;
	self.description := _description;
	self.notAvailableForEntry := _notAvailable;
	
	self.allTerminalAreas.clear();
	self.allGridObjects.clear();
	self.allLocationsControllers.clear();
	
	foreach obj in _allSelectedObjects do
		if obj.isKindOf( CM_TerminalArea ) then
			self.allTerminalAreas.addNoDuplicates( obj.CM_TerminalArea, false );
		elseif obj.isKindOf( CM_GridObject ) then
			self.allGridObjects.addNoDuplicates( obj.CM_GridObject, false );
		elseif obj.isKindOf( CM_LocationsController ) then
			self.allLocationsControllers.addNoDuplicates( obj.CM_LocationsController, false );
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_notAvailable" type="Boolean"/>
        <Parameter name="_allSelectedObjects" type="ObjectSet"/>
    </JadeMethod>
