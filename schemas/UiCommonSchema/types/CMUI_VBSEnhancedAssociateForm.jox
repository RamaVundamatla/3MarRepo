    <JadeMethod name="mnuInspectObject_click" id="5e8df6d3-478c-4d38-8b47-416bb25d0bfb">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuInspectObject_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Apr 2025	navnk30	JIRA 34267: TPT | FR 33661.050 VBS - One Release Request and Multiple VBS Appointments ? Off Schedule

*/

vars
	vbs : CM_VehicleBookingTimeSlot;
begin
	vbs := self.tblBookings.accessRow(self.tblBookings.row).itemObject.CM_VehicleBookingTimeSlot;
	
