    <JadeMethod name="jreFixTranMap" id="ec59610a-ea5d-4983-ad37-8734429b6e37">
        <source>jreFixTranMap();

vars
	bank	: CM_Bank;
	tranMap	: CM_TranMap;
	serv	: CM_TIServiceMap;
	pgm		: CM_ProductGroupMap;
	pm		: CM_ProductMap;
	imexMap	: CM_ImexServiceMap;
	cm		: CM_ContentsMap;
	cm2		: CM_CommodityMap;
	tsb		: CM_TransServiceBroker;
	count	: Integer;
begin
	foreach bank in CM_Bank.instances do
		if bank.code = "DFBU" and
		   bank.terminal.code = "BISH" then
			foreach tranMap in bank.myCurrentTranMapCargo do
				if tranMap.name = "OldStorage" then
					foreach serv in tranMap.allTIServices do
						foreach pgm in serv.allProductGroupMaps do
							foreach pm in pgm.allProductMaps do
								foreach imexMap in pm.allImExMaps do
									foreach cm in imexMap.contentsMaps do
										foreach cm2 in cm.commoditiesMap do
											beginTransaction;
											foreach tsb in cm2.allTransServiceBrokersByType do
												count := count + 1;
												if count = 3 then
													delete tsb;
													write "FOUND IT";
												endif;
											endforeach;
											commitTransaction;
											write "After commit";
										endforeach;
									endforeach;
								endforeach;
							endforeach;
						endforeach;
					endforeach;
				endif;
			endforeach;
			break;
		endif;
	endforeach;
end;
</source>
    </JadeMethod>
