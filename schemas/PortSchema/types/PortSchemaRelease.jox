		aStopTable.heading := "Operator";
		aStopTable.shortHeading := "Oper";
//		aStop.canIYardMove := true;
//		aStop.canIDeliveryRequest := true;
//		aStop.canIReleaseRequest := true;
		aStopTable.myRoot := theRoot;
	endif;
		
	// ##########################

	if theRoot.allStopsTable[TI_Stop_OperatorDocs] = null then
		create aStopTable;
		aStopTable.id := TI_Stop_OperatorDocs;
		// Give all the different types to all the stops
		//theCargoTypes.copy(aStopTable.allCargoTypesNew);	//25.10.2022	navhl20	TFS 53862
		aStopTable.code := "OD";
//		aStop.defaultImportStop := false;
		aStopTable.heading := "Operator Docs";
		aStopTable.shortHeading := "OperDocs";
//		aStop.canIYardMove := true;
//		aStop.canIDeliveryRequest := true;
//		aStop.canIReleaseRequest := true;
		aStopTable.myRoot := theRoot;
	endif;
		
	// ##########################

	if theRoot.allStopsTable[TI_Stop_ToBeInspected] = null then
		create aStopTable;
		aStopTable.id := TI_Stop_ToBeInspected;
		// Give all the different types to all the stops
		//theCargoTypes.copy(aStopTable.allCargoTypesNew);	//25.10.2022	navhl20	TFS 53862
		aStopTable.code := "I";
//		aStop.defaultImportStop := false;
		aStopTable.heading := "To Be Inspected";
		aStopTable.shortHeading := "Inspect";
//		aStop.canIYardMove := true;
//		aStop.canIDeliveryRequest := true;
//		aStop.canIReleaseRequest := true;
		aStopTable.myRoot := theRoot;
	endif;
			
	// ##########################

	if theRoot.allStopsTable[TI_Stop_Surveyed] = null then
		create aStopTable;
		aStopTable.id := TI_Stop_Surveyed;
		// Give all the different types to all the stops
		//aStopTable.allCargoTypesNew.add(CM_CargoType.firstInstance);	//25.10.2022	navhl20	TFS 53862
		aStopTable.code := "X";
//		aStop.defaultImportStop := false;
		aStopTable.heading := "Surveyed";
		aStopTable.shortHeading := "Survey";
//		aStop.canIYardMove := true;
//		aStop.canIDeliveryRequest := true;
//		aStop.canIReleaseRequest := true;
		aStopTable.myRoot := theRoot;
	endif;
		
	// ##########################

	if theRoot.allStopsTable[TI_Stop_IntendedOffsite] = null then
		create aStopTable;
		aStopTable.id := TI_Stop_IntendedOffsite;
		// Give all the different types to all the stops
		//aStopTable.allCargoTypesNew.add(CM_CargoType.firstInstance);	//25.10.2022	navhl20	TFS 53862
		aStopTable.code := "Y";
//		aStop.defaultImportStop := false;
		aStopTable.heading := "Intended Offsite";
		aStopTable.shortHeading := "Offsite";
//		aStop.canIYardMove := true;
//		aStop.canIDeliveryRequest := true;
//		aStop.canIReleaseRequest := true;
		aStopTable.myRoot := theRoot;
	endif;

	// ##########################
	// Add all of the stops to the security roles
	foreach aStopTable in theRoot.allStopsTable do
		aStopTable.allSecurityRolesMaint.clear;
		aStopTable.allSecurityRolesCancel.clear();		// cnwdad1 03/06/2010 - CCMS 1129.
		aStopTable.allSecurityRolesView.clear;
		foreach aRole in theRoot.allRoles do
			aStopTable.allSecurityRolesMaint.add(aRole);
			aStopTable.allSecurityRolesCancel.add(aRole);	// cnwdad1 03/06/2010 - CCMS 1129.
			aStopTable.allSecurityRolesView.add(aRole);
		endforeach;
	endforeach;
	
	commitTransaction;	
	
end;</source>
