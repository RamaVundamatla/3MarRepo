        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCraneForMove" id="b84e0a14-77e3-4a84-bcd4-d91916db8da0">
        <source>getCraneForMove(): CM_Machine;
/*
Purpose:			

Date		Who		Reason
03 February 2022	navab1	TFS 51855
*/

vars

	terminal	:CM_Terminal;
	machine		:CM_Machine;
	result		:CM_Crane;
begin
	if self.craneId &lt;&gt; null then
		terminal := self.myTerminal;
		
		machine := terminal.machines[self.craneId];
		
		if machine &lt;&gt; null and machine.isKindOf (CM_Crane) then
			return machine;
		endif;
	
	else
		return inheritMethod();
	endif;

epilog

end;</source>
        <ReturnType type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="isChargeable" id="92174ba8-21a4-47f3-a788-022a7f8f91af">
        <source>isChargeable(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/

vars

begin
	
	if app.myRoot.isClientEuroPorts then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
