    <JadeMethod name="getFilterDetailsForDisplay" id="f229e2b3-02e3-47f2-9b5c-02da90b4c658">
        <source>getFilterDetailsForDisplay():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 February 2012	cnwndl1	Initial creation

*/

vars

	returnString : String;
	filter : CM_ColumnFilter;

begin

	returnString := null;

	foreach filter in self.allFilterColumns do
		returnString := returnString &amp; "    " &amp; filter.getFilterDetailsAsString() &amp; CrLf;
	endforeach;
	
	if returnString = null then
	else
		returnString := CrLf &amp; CrLf &amp; returnString;
	endif;

	return returnString;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFilterValuesFromSource" id="5ff1b9d7-77df-4d35-bafa-cf0082bc3df2">
        <source>getFilterValuesFromSource(  _column : Integer; _strArray : StringArray io;  _intArray : IntegerArray io ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

	startRow : Integer;
	endRow : Integer;
	rowIndex : Integer;
	str : String;
	includedPos : Integer;
	
begin

	if self.myDataTable = null then
		return;
	endif;
	
	if _column &lt; 1 then
		return;
	endif;

	startRow := self.myDataTable.fixedRows + 1;
	endRow := self.myDataTable.rows;
	
	//if endRow &lt;= startRow then
	if endRow &lt; startRow then
		return;
	endif;
	
	
	foreach rowIndex in startRow to endRow do
		str := self.myDataTable.getCellText( rowIndex, _column ).trimBlanks;
		if str = null then
			str := CM_ColumnFilter.NullString;
		endif;
		if str.length &gt; 50 then
			str := str[1:50] &amp; "...";
		endif;
		if _strArray.isEmpty then
			includedPos := 0;
		else
			includedPos := _strArray.indexOf(str);
		endif;
		if includedPos = 0 then
			_strArray.add( str );
			_intArray.add( 1 );
		else
			_intArray[includedPos] := _intArray[includedPos] + 1;
		endif;
	endforeach;
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_column" type="Integer"/>
        <Parameter name="_strArray" type="StringArray" usage="io"/>
        <Parameter name="_intArray" type="IntegerArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getOriginalCollection" id="6361aff1-9dca-4cad-a28f-4aa06c5bbf99">
