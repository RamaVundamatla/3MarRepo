    <JadeMethod name="btnListening_click" id="835fdf60-5ba2-4f1b-8895-0cd57f7d6a41">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnListening_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2016	cnwrh7	Initial creation

*/

vars

begin
	if self.isValidWeight() then
		if self.myTCPConnection &lt;&gt; null then				//always clear
			self.myTCPConnection.close();	//connection can be closed in any state
			delete self.myTCPConnection;
		endif;
		self.setupTcpConnection();
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnStpListening_click" id="5f312e69-f228-446f-b286-6a6e8f019eec">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnStpListening_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2016	cnwrh7	Initial creation

*/

vars
	status : String;
begin
	if self.myTCPConnection &lt;&gt; null then
		self.myTCPConnection.close();
	endif;
	status := "TCP IP Connection Closed";
	self.updateStatusLine(status);
	self.txtWeightData.setFocus();
	self.btnListening.enabled := true;
	self.btnStpListening.enabled := false;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
