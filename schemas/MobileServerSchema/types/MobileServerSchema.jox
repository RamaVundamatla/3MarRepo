    <JadeMethod name="writeHandHeldLog" id="c5710140-ce8b-4d11-9bc8-cc31772776cb">
        <source>writeHandHeldLog(	_fileName : String;
					_message : String);
/*

Purpose:			


Return Value:		


Date		Who		Reason
28 November 2006	cnwer1	Initial creation - PAR#xxxx
22 Jan 2020	cnwkpd1	PAR #22185 - Fix up timestamp logging

*/

vars
	ts			: TimeStamp;
	logFile		: JadeLog;
	//cc			: CnCntrl;
	logStr		: String;

begin

	//cc := app.myCnCntrl;
	
	
	create logFile transient;
	//logFile.filePath		:= "D:\cnwdmast\logs";
	logFile.fileName		:= _fileName;
	logFile.versionFile		:= true;
	//logFile.maxFileSize		:= cc.logFileMaxSize;
	logFile.formatOutput	:= false;
	logFile.bufferOutput	:= false;
		
	
	ts := app.actualTimeServer();

	logStr := ts.date.format("ddMMMyy") &amp; ' ' &amp;  
			  ts.time.format("HH:mm:ss") &amp; '.' &amp;
			  ts.time.milliSecond.stringWithLeadingZeros(3) &amp; ' ' &amp;		// PAR #22185
			  _message &amp; '   &gt;&gt; ';
			  
	logFile.log(logStr);


epilog
	delete logFile;
end;

</source>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
    <JadeMethod name="xHandlerGeneral" id="15a7b730-a5c6-4cdf-8edc-7fe85e2f4c59">
        <source>xHandlerGeneral(pExceptionObj:Exception) protected;
// --------------------------------------------------------------------------------
// Created:		18 October 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.writeLog("Exception *** " &amp; pExceptionObj.errorCode.String &amp; ' ' &amp; pExceptionObj.text, LogINFO);
end;</source>
        <access>protected</access>
        <Parameter name="pExceptionObj" type="Exception"/>
    </JadeMethod>
</Class>
