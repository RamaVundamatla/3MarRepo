    </JadeMethod>
    <JadeMethod name="testAnyHavePower" id="0a1c1c15-a752-4473-bc7f-d603b58fa89c">
        <source>testAnyHavePower() : Boolean;
// ---------------------------------------------------------------------------
// Created:     14 January 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// PAR 18682
// ---------------------------------------------------------------------------

vars
	tmpLC : CM_LocationsController;
begin
	if self.myToPrimaryLocation.hasPower() then
		return true;
	endif;
	
	foreach tmpLC in self.allToLocations discreteLock do
		if tmpLC.hasPower() then
			return true;
		endif;
	endforeach;
	
	if self.myToPrimaryLocation.offsetFlexi &gt; 0 
	or self.myTrackedItem.isOverSizedContainer() 
	and tmpLC &lt;&gt; null then
		tmpLC := tmpLC.getNextControllerOfType(tmpLC.class);
		if tmpLC &lt;&gt; null then
			if tmpLC.hasPower() then
				return true;
			endif;
		
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tiTransType" id="3ddd78ca-0a58-444c-9a5a-0cf82578dafb">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>tiTransType(set: Boolean; _value: Integer io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     24 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		if _value &lt;&gt; 0 and
		   _value &lt;&gt; TRANS_TYPE_MOVE and
		   _value &lt;&gt; TRANS_TYPE_MOVE_PICKUP and
		   _value &lt;&gt; TRANS_TYPE_MOVE_SETDOWN and 
		   _value &lt;&gt; TRANS_TYPE_ReinstateReject then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid TiTransType for move (' &amp; _value.String &amp; ')');
			return;
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateAllToLocations" id="58ffdf5b-6b86-4efc-b32c-84545cfd11e6">
        <updating/>
        <source>updateAllToLocations(_lcs : CM_LCArray) updating;
/*
 ------------------------------------------------------------------------
Created:			20 December 2001 by cnwdwq1
Purpose:			Method that updates the array with BOTH the current primary location and any secondary 
							locations in one property.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	self.allToLocations.clear;
	
	if _lcs = null then
		if self.myToPrimaryLocation = null then
			return;
		endif;
		self.allToLocations.add(self.myToPrimaryLocation);
		self.myToSecondaryLocations.copy(self.allToLocations);
	else
		_lcs.copy(self.allToLocations);
	endif;
end;</source>
        <Parameter name="_lcs" type="CM_LCArray"/>
    </JadeMethod>
