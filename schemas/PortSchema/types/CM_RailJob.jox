    <JadeMethod name="addJobRequest" id="89739361-543b-4a3b-ae47-603d388c36b5">
        <updating/>
        <source>addJobRequest(	_ti: CM_TrackedItem input;
				_isReceipt: Boolean; 
				_quantity : Integer;
				_weight : Decimal; 
				_passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2013	cnwndl1	Initial creation Par 31102

*/

vars

	plannedFutureMove : CM_FutureMovePlanned;
	aWLE : CM_WorkListEntry;

begin

	inheritMethod(_ti, _isReceipt, _quantity,_weight, _passport);
	
	aWLE := self.getWLEForTI(_ti); // ### TFS 51855 06JAN2022 NAVAB1
	if aWLE &lt;&gt; null then // ### TFS 51855 06JAN2022 NAVAB1
		if _passport.isOpsViewEnabled(aWLE.getMyTerminal()) then // ### TFS 51855 06JAN2022 NAVAB1

			aWLE.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_WLE,aWLE); // ### TFS 51855 06JAN2022 NAVAB1
			
			if _ti.isContainer()  // ### TFS 53105 16JUN2022 NAVAB1
			and _ti.myPrimaryActualLocation &lt;&gt; null // ### TFS 52925 21FEB2022 NAVAB1
			and _ti.myPrimaryActualLocation.isWagon() then  // ### TFS 52925 21FEB2022 NAVAB1 -  Only for TI that are prenoted or on a vessel/train/truck
				_ti.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_TRACKEDITEM,_ti); // ### TFS 52925 21FEB2022 NAVAB1
			endif;
		endif;
	endif;
	
	aWLE := null; // ### TFS 51855 06JAN2022 NAVAB1
	
	if _ti &lt;&gt; null and _ti.directDelivery then
		plannedFutureMove := _ti.getFutureMoveOfType(PLANNING_MODE, TI_FutureMovePlanned).CM_FutureMovePlanned;
		if plannedFutureMove &lt;&gt; null then
			aWLE := plannedFutureMove.myWorkListEntry;
			if aWLE &lt;&gt; null then
				aWLE.setLocations(_ti.locationId, aWLE.locationTarget);
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_isReceipt" type="Boolean"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addWagon" id="ac93a3b3-ddd3-48ec-a60e-5b2e9dd679b7">
        <updating/>
        <source>addWagon(_trackedItem: CM_TrackedItem) updating;
//--------------------------------------------------------------
//Created: 11 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	theWagon : CM_Wagon;
begin

	if _trackedItem = null then
		return;
	endif;
	
	theWagon := _trackedItem.getMyWagon();
	if theWagon &lt;&gt; null then
		if (not self.allWagons.includes(theWagon)) then
			self.allWagons.add(theWagon);
		endif;
	endif;
	
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
