<Class name="CM_YARailConfig" id="de41fb2a-a517-4e90-8683-d1dfb18f6aff">
    <superclass name="CM_YAIMEXConfig"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="voyages"/>
    <ExplicitInverseRef name="myYAConfigRail" id="b1345b3f-93ae-4310-8714-cc71a35a1999">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_YAConfig"/>
        <access>readonly</access>
        <Inverse name="CM_YAConfig::allYARailConfigs"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="myYACriteriaTypeForColour" id="f526163a-adc7-494b-b441-94f578d059fa">
        <embedded/>
        <type name="CM_YACriteriaType"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="auditId" id="df7d7d8a-4260-4203-ba58-6e07bb4ba7ba">
        <source>auditId(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
04 August 2008	consw1	Initial creation

*/

vars

begin
	return self.myYAConfigRail.auditId &amp; " - Rail " &amp; self.myIMEXStatus.auditId; // PAR 21541

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="90130ce0-f499-40df-94cf-37ba5e44d71d">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
01 August 2008	consw1	Initial creation
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/

vars
	pxy	: CM_YARailConfig;
	completedOK		: Boolean;
	
begin
	pxy := inheritMethod();

	pxy.myYAConfigRail := self.myYAConfigRail;
	pxy.myYACriteriaTypeForColour := self.myYACriteriaTypeForColour;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="0060ffb1-66dd-437c-a7f7-5b333c1783e8">
        <updating/>
        <source>setForCreate( _yaConfig : CM_YAConfig; _imexStatus : Integer ; _defaultColourType : CM_YACriteriaType) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
31 July 2008	consw1	Initial creation

*/

vars

begin
	self.myIMEXStatus := app.myRoot.allImexStatuses[_imexStatus];
	self.myYAConfigRail := _yaConfig;
	self.myDefaultColourType := _defaultColourType;
epilog

end;</source>
        <Parameter name="_yaConfig" type="CM_YAConfig"/>
        <Parameter name="_imexStatus" type="Integer"/>
        <Parameter name="_defaultColourType" type="CM_YACriteriaType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="088d5713-cc4d-4a41-afea-80e39e51d413">
        <updating/>
        <source>setForUpdate(_proxyYAIMEXConfig: CM_YARailConfig) updating;
// ---------------------------------------------------------------------------
// Created:     January 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.allOpCriteria.clear;
	_proxyYAIMEXConfig.allOpCriteria.copy(self.allOpCriteria);
	
	self.myYACriteriaTypeForColour := _proxyYAIMEXConfig.myYACriteriaTypeForColour;
	
epilog

end;</source>
        <Parameter name="_proxyYAIMEXConfig" type="CM_YARailConfig"/>
    </JadeMethod>
    <JadeMethod name="setProxyRail" id="4c6ba8c9-4cbc-49ad-81ff-f00034afe474">
        <updating/>
        <source>setProxyRail(_opCriteriaColl, _groupLabelCriteriaColl : CM_YACriteriaTypeArray; _colour : Integer; _yaCriteriaType : CM_YACriteriaType ; _defaultColourType : CM_YACriteriaType) updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.setProxy(_opCriteriaColl, _groupLabelCriteriaColl, _colour, _defaultColourType);
	
	self.myYACriteriaTypeForColour := _yaCriteriaType;
epilog

end;</source>
        <Parameter name="_opCriteriaColl" type="CM_YACriteriaTypeArray"/>
        <Parameter name="_groupLabelCriteriaColl" type="CM_YACriteriaTypeArray"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_yaCriteriaType" type="CM_YACriteriaType"/>
        <Parameter name="_defaultColourType" type="CM_YACriteriaType"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="a305c226-af60-4f3d-8756-5e3e1d0bd1d7">
