    <JadeMethod name="doSetGTEWeights" id="56d378ec-0cc2-4d31-8456-35867c0c7131">
        <updating/>
        <source>doSetGTEWeights( _pxyVVR : CM_VehicleVisitRecord) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 December 2016	cnwndl1	Initial creation	TFS 2867

*/

vars

	ti : CM_TrackedItem;
	gteEntity : CMGTE_Entity;
	gteReceival : CMGTE_Receival;
	
begin
	
	foreach gteEntity in _pxyVVR.allGateEntities discreteLock do
		if not gteEntity.isCMGTE_Receival then
			continue;
		endif;
		gteReceival := gteEntity.CMGTE_Receival;
		ti := gteReceival.myTrackedItem;
		
		if ti = null then
			continue;
		endif;
		
		if ti.isPreNote() then
			gteReceival.setTotalWeightAndCertified(1,false);
			if  not ti.myCargoType.isTrackByWeight then
				gteReceival.setMyCargoVolume(1 / ti.getDensity);
				gteReceival.setTotalQuantity(1);
			endif;	
		endif;
	endforeach;	

epilog

end;</source>
        <Parameter name="_pxyVVR" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="getCollatedWarnings" id="60e0eb39-a103-4564-aa95-f952b31403a9">
        <source>getCollatedWarnings(_arrWarnings : HugeStringArray input) ;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason

*/

vars
	arrObjWarnings 	: HugeStringArray;
	obj				: Object;
	warning			: String;
begin
	foreach obj in self.allWarningsByOid do
		arrObjWarnings := obj.HugeStringArray;
		foreach warning in arrObjWarnings do
			_arrWarnings.add(warning);
		endforeach;
	endforeach;
epilog

end;</source>
        <Parameter name="_arrWarnings" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getGateFromSetup" id="72fb6dbb-61c8-48e1-9e1e-2a5ce149da60">
        <updating/>
        <source>getGateFromSetup() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 March 2017	cnwns1	Initial creation

*/

vars
	gate : CM_Gate;
	lane : CM_GateAreaLaneController;
begin

	if self.myWeighBridge &lt;&gt; null then
		if self.myWeighBridge.myGateLane &lt;&gt; null then
			lane := self.myWeighBridge.myGateLane;
			self.myGateAreaLaneController := lane;
			gate := lane.getGate;
			if gate &lt;&gt; null then
				self.myGate := gate;
				self.gateAndLaneSet := true;	
			endif;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getVehicleBookingTimeslotId" id="a335143f-9cd6-4857-b137-890c7025733b">
        <source>getVehicleBookingTimeslotId() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 December 2016	cnwns1	Initial creation

*/

vars

begin

	if self.myRealVVR &lt;&gt; null and self.myRealVVR.myVehicleBookingTimeslot &lt;&gt; null then	
	    return self.myRealVVR.myVehicleBookingTimeslot.id;
	endif;
	
	return null;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWeighbridgeForSelf" id="4a95f1ef-0cfb-446b-beaa-3d37d8e4382e">
        <source>getWeighbridgeForSelf(_computerName : String;_laneDirection : Integer) : CM_WeighBridgeObj;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 February 2017	cnwns1	Initial creation

*/

vars
	wBridge : CM_WeighBridgeObj;
begin

	if self.myTerminal = null then
		return null;
	endif;
	
	if self.myWeighBridge &lt;&gt; null then
		return self.myWeighBridge;
	endif;
		
	foreach wBridge in myTerminal.allWeighBridges discreteLock do
		if wBridge.computerName.toUpper() = app.computerName.toUpper() then
			if wBridge.myGateLane &lt;&gt; null then	//27 Aug 2019	NDL	Found to be null during testing
				if 	wBridge.myGateLane.getGateLaneDirection = _laneDirection  or wBridge.myGateLane.getGateLaneDirection = Both  then
					return wBridge;
				endif;
			endif;
		endif;	
	endforeach;
	
	return null;
	
	
epilog

end;</source>
        <Parameter name="_computerName" type="String"/>
        <Parameter name="_laneDirection" type="Integer"/>
        <ReturnType type="CM_WeighBridgeObj"/>
    </JadeMethod>
    <JadeMethod name="saveWarningsForObject" id="b0896928-dbd7-410e-8a22-ea6398b9803b">
        <updating/>
        <source>saveWarningsForObject(_passport : CM_Passport; _realObj : CM_Object; _clearExistingWarnings : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason

*/

vars
	warning 	: CM_Error;
	arrWarnings	: HugeStringArray;
begin

	if _realObj = null then
		return;
	endif;
		
	if _realObj.isTransient then 
		app.raiseUnexpectedProgramError(class.name, method.name, "Expecting real object but was passed a transient.");
		return;
	endif;
		
	// See if we already have saved warnings for this particular object
	arrWarnings := self.allWarningsByOid[_realObj.getOidString()].HugeStringArray;
	
	if arrWarnings = null then
		// we haven't had warnings for this instance beforem,  so we need to create an array to hold them 
		create arrWarnings transient;
		// Now key it into the collection
		self.allWarningsByOid[_realObj.getOidString()] := arrWarnings;
	elseif _clearExistingWarnings then
		arrWarnings.clear();
	endif;
	
	// Now add the warnings to the array for the object
	foreach warning in _passport.allErrorWarnings do
		arrWarnings.add(warning.text);
	endforeach;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_realObj" type="CM_Object"/>
        <Parameter name="_clearExistingWarnings" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDirection" id="3d144eae-89f3-4187-beff-f1c6072f1142">
        <updating/>
        <source>setDirection(isInward : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2016	cnwns1	Initial creation

*/

vars

begin
    if isInward then
		self.cargoDirection := Inward;
	else	
		self.cargoDirection := Outward;
	endif;
end;
</source>
        <Parameter name="isInward" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setErrorsToIgnore" id="7efb2db5-e9ba-47a9-b162-30709fe78e4d">
        <source>setErrorsToIgnore(_passport : CM_Passport input; terminal : CM_Terminal);
// ---------------------------------------------------------------------------
// Created:     08 September 2008 by cnwab1
//
//	Purpose: 	These errors will not abort teh transaction and stop the update, 
//					these errors and any warnings will be recorded for later processing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 
// ---------------------------------------------------------------------------

vars

begin
	_passport.clearErrorsToIgnore();
	process.needGateConfig(); // Quick Reference 	
	// ERROR for In Out COMMON
	_passport.errorsToIgnore.add(ERR_Driver_Unknown);
	_passport.errorsToIgnore.add(ERR_Carrier_Unknown);
	
	//cnwmc5 - 9 Sep 2015 - PAR 36814
	if not terminal.getConfig(KnownTruckRequired).Boolean then
		_passport.errorsToIgnore.add(ERR_Truck_Unknown);
	endif;
	
	_passport.errorsToIgnore.add(ERR_Carrier_Blank);
	_passport.errorsToIgnore.add(ERR_TruckNotForCarrier);
	_passport.errorsToIgnore.add(VehicleIsOnSite);
	_passport.errorsToIgnore.add(ERR_Generator_Wrong_Type);
	_passport.errorsToIgnore.add(ERR_noGenSetForNonReeferISOTyp);	//Par18790. April 209
	
	// ERRORs for create job
//	_passport.errorsToIgnore.add(ERR_Trouble_With_Job);
	_passport.errorsToIgnore.add(AutoPlanningYAError); // TI does not Autoplan
	
	
//	_passport.errorsToIgnore.add(ERR_GateLane_Unknown);		// Force gate to enter
	
	// ERRORS for IN EMPTY
	
//	_passport.errorsToIgnore.add(ERR_Cargo_Unknown);
	_passport.errorsToIgnore.add(ERROR_NOT_IN_FLEET_FILE);
	_passport.errorsToIgnore.add(ERR_TI_ONSITE);
	_passport.errorsToIgnore.add(ERR_ALREADY_ONSITE);
	_passport.errorsToIgnore.add(ERR_ALREADY_ATTACHED);
	_passport.errorsToIgnore.add(ERR_TI_HAS_BULK_REL);
	_passport.errorsToIgnore.add(WARN_BOOKING_REF);
	_passport.errorsToIgnore.add(ERR_TI_ALREADY_ALLOCATED);
	
	// ERRORS for IN FULL
//	_passport.errorsToIgnore.add(ERR_INVALID_ISOTYPE);

	// ERRORS for OUT EMPTY
	_passport.errorsToIgnore.add(ERR_TI_NOT_ONSITE);
//	_passport.errorsToIgnore.add(ERR_NotEmpty);
//	_passport.errorsToIgnore.add(ERR_NotFull);
	_passport.errorsToIgnore.add(ERR_Booking_Exceeded);
	
	
epilog
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setGate" id="e3b3ae34-1d80-4578-964d-0f13cd214799">
