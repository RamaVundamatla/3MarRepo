    <JadeMethod name="processAttributeDependencies" id="05c70f83-40fa-474f-b81b-73744982a204">
        <updating/>
        <source>processAttributeDependencies(_ediUserDefinedAssist : CMIF_EDIUserDefinedAssist input; _strIdentifier : String; _reset : Boolean; _xlationOperator :CM_Operator) updating;
//
// ccms 1976 cnwrs1 17 dec 2010
// Date				Who		Reason
// 28 Apr 2011		cnwrs1	ccms 2044 - added strIdentifier
// 11 April 2013	cnwcs5	CCMS POL 2097 / par 31259
//20 Mar 2015	cnwrs1	Par 34702 - Add support for JMT XML with implied header
vars
	terminal 	: CM_Terminal;	//ccms 1976 05 Jan 2011
	property 	: Property;
	properties 	: PropertyNDict;
	value 		: Any;
	propName 	: String;
	ediTI 		: CM_EDIPackTI;
	vessel		: CM_Vessel;
	vesselCode	: String;
begin
	// par 27575 the vessel xlate returns the code but we want the vessel name from that code
	// need to do this before the vessel voyage translations are called from the superclass method
	if _reset then 
		inheritMethod(_ediUserDefinedAssist, _strIdentifier, _reset, _xlationOperator);
	else
		vesselCode := self.vesselName;
		
		if vesselCode &lt;&gt; null then
			vessel := app.myRoot.allVessels[vesselCode];
			
			if vessel &lt;&gt; null then
				self.vesselName := vessel.name;
			endif;
		endif;
	
		inheritMethod(_ediUserDefinedAssist, _strIdentifier, _reset, _xlationOperator);
		
		if	_strIdentifier = "FonterraPack" then // 28 Apr 2011	cnwrs1	ccms 2044 - added strIdentifier
			ediTI 		:= self;
			terminal 	:= self.getMyTerminal();
			properties 	:= self.class.getProperties();
			
			foreach property in properties do
				propName	:= property.name;
				value 		:= getPropertyValue(propName);
				value		:= app.myHookAgent.runHookLinkPublic(HookType_EDIFonterraPack, terminal, self, ediTI, propName, value);
				
				if value &lt;&gt; null then
					self.setPropertyValue(propName, value);
				endif;
			endforeach;
		endif;
	endif;
end;
</source>
        <Parameter name="_ediUserDefinedAssist" type="CMIF_EDIUserDefinedAssist" usage="input"/>
        <Parameter name="_strIdentifier" type="String"/>
        <Parameter name="_reset" type="Boolean"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
