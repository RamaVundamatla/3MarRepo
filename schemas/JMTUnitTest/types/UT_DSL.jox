    <JadeMethod name="addVesselWithHolds" id="eb7a93d2-cb2e-4226-b83e-c751ea329e80">
        <source>addVesselWithHolds(name: String; holds: Integer; decks: Integer): CM_Vessel;
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------
// 27/08/2015	cnwdap1		PAR #36766 CCMS SFW 1334 Bulk Graphical Representation - new parameters
vars
	vessel: CM_Vessel;
	gcHoldLocnDefn : CM_GCHoldLocationDefn;
	i, j: Integer;
	loadState : Boolean;
begin
	self.deleteVessel(name);
	
	//Create a general cargo vessel
	vessel := self.addVesselGeneralCargo(name, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), 0);
	self.assertNotNullMsg(vessel, "Add vessel failed");
	
	foreach i in 1 to holds do
		foreach j in 1 to decks do
			self.addGCHoldDefn(vessel.myGeneralCargoVesselStructure,	//_gcVesselStruct: CM_GeneralCargoVesselStructure;
						i,	//_holdNum: Integer;
						j,	//_placeNum: Integer;
						false,	//_isOnDeck : Boolean;			// PAR #36766
						null, 	// _maxWeight : Integer;		// PAR #36766
						null,	// _maxVolume: Decimal;			// TFS 1601
						0,	// _maxHeight: Decimal;	//07 Feb 2017	NDL	TFS 3216
						1,		// _onShipCrane: Integer;		// TFS 1601
						"Hold" &amp; i.String &amp; " Deck" &amp; j.String
						);
		endforeach;
	endforeach;
	
	return vessel;
	
epilog
end;</source>
        <Parameter name="name" type="String"/>
        <Parameter name="holds" type="Integer"/>
        <Parameter name="decks" type="Integer"/>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="addVoyageAllocation" id="c7442760-ffe6-48cd-8cfe-fc6d429f5ade">
        <updating/>
        <source>addVoyageAllocation(_voyage : CM_Voyage input; _portCode, _isoGrpCode, _comCode : String; _cargoType : Integer; _reqPwr, _isOD : Boolean): CM_VoyageAllocation updating;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		NAVAB1		Initial creation
05/04/2013			cnwmh5		Change to pass commodity rather than commodity group, because if the commodity changes group and
								you can potentionaly pass the wrong commodity group so now use the commodity group for the commodity
								Change is being made becuase it has happened an is hard to track down especially if test is UT_KPIVoyage::tMain
								
NOTES:							To get the Commodity Group - Pass a Commodity from the group you want and in opts use either
								CommodityGroupOnly or SetCommodityGroup to specify that you want the Commodity Group
*/


vars
	proxyYAObj				: CM_VoyageAllocation;
	cmif_object : CMIF_Object;
	cmif_criteria : CMIF_YACriteriaPriority;
	pxyCriteria : CM_YACriteria;
	allTransientCriteriaObj	: CMIF_Array;
	realAlloc 				: CM_VoyageAllocation;
	voyCode, desc : String;
	objSet : ObjectSet;
	imexStatus : CM_IMEXStatus;
	port : CM_Port;
	isoGrp : CM_ISOTypeGroup;
	ct : CM_CargoType;
	comGrp : CM_CommodityGroup;
	portColor 	: Integer;
	anOperator : CM_Operator;
	isoTypeString,
	commodityString : String;
	isoType			: CM_ISOType;
	aCommodity 		: CM_Commodity;
	imexId : Integer; // PAR 37111
begin
	if _voyage = null then
		return null;
	else
		voyCode := _voyage.code;
	endif;
	
	create proxyYAObj transient;
	create objSet transient;
	proxyYAObj.setProxyProjectedValues(0,0,0,0,0,0);
	create allTransientCriteriaObj transient;
	
	
	imexId := TI_IMEX_STATUS_EXPORT; // PAR 37111
	if self.opts.includesKey(UTTI_IMEX) then // PAR 37111
		imexId := self.opts.int(UTTI_IMEX); // PAR 37111
	endif;
	

	// ### IMEX
	objSet.clear();
	imexStatus := app.myRoot.allImexStatuses[imexId]; // PAR 37111
	objSet.add( imexStatus );
	self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_ImexStatus], objSet );
	
	portColor:=Red;
	// ### DISPORT
	if _portCode &lt;&gt; null then
		objSet.clear();
		port := app.myRoot.allPorts[_portCode];
		if port &lt;&gt; null then
			if port.colour &lt;&gt; null then
				portColor:=port.colour;
			endif;
			objSet.add( port );
			self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_DischargePort], objSet );
		else
			self.assertTrueMsg(port &lt;&gt; null, "Port Code '" &amp; _portCode &amp; "' does not exist! Cannot create voyage allocation");
		endif;
	endif;
	// ### ISOGroup
	if _isoGrpCode &lt;&gt; null then
		objSet.clear();
		isoGrp := app.myRoot.allISOTypeGroups[_isoGrpCode];
		self.assertTrueMsg(isoGrp &lt;&gt; null, "ISOGroup Code '" &amp; _isoGrpCode &amp; "' does not exist! Cannot create voyage allocation");
		objSet.add( isoGrp );
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_ISOGroup], objSet );
	endif;
	// ### CargoType
	objSet.clear();
	ct := app.myRoot.allCargoTypesById[_cargoType];
	self.assertTrueMsg(ct &lt;&gt; null, "Cargotype Code '" &amp; _cargoType.String &amp; "' does not exist! Cannot create voyage allocation");
	objSet.add( ct );
	self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType], objSet );

	/*
	05/04/2013 cnwmh5 - See Commodity
	// ### CommodityGroup
	if _comGrpCode &lt;&gt; null then
		objSet.clear();
		comGrp := app.myRoot.allCommodityGroups[_comGrpCode];
		self.assertTrueMsg(comGrp &lt;&gt; null, "Commodity Group Code '" &amp; _comGrpCode.String &amp; "' does not exist! Cannot create voyage allocation");
		objSet.add(comGrp );
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_CommodityGroup], objSet );
	endif;
	*/

	// ### RequiresPower
	if _reqPwr then
		self.getCriteriaSingleCMIF(allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_RequiresPower], CM_YADataBoolean.VALUE_TRUE );
	else
		self.getCriteriaSingleCMIF(allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_RequiresPower], CM_YADataBoolean.VALUE_FALSE );
	endif;
	// ### IS Over Dimensional
	if _isOD then
		self.getCriteriaSingleCMIF(allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsOverDimension], CM_YADataBoolean.VALUE_TRUE );
	else
		self.getCriteriaSingleCMIF(allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsOverDimension], CM_YADataBoolean.VALUE_FALSE );
	endif;
	
	// ### operator
	if self.opts.includesKey("Operator") then 
		objSet.clear();		
		anOperator := self.opts.obj("Operator").CM_Operator;
		self.assertTrueMsg(anOperator &lt;&gt; null, "Operator does not exist! Cannot create voyage allocation");
		objSet.add(anOperator );
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_OperatorItem], objSet );
	endif;
	
	// ### ISO Type
	if self.opts.includesKey("ISOType") then	
		isoTypeString := self.opts.str('ISOType');
		objSet.clear();
		isoType := app.myRoot.allISOTypes[isoTypeString];
		self.assertTrueMsg(isoType &lt;&gt; null, "ISOType Code '" &amp; isoTypeString &amp; "' does not exist! Cannot create voyage allocation");
		objSet.add( isoType );
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_ISO], objSet );
	endif;
	
	
	// ### Commodity
	// 05/04/2013 cnwmh5 - Rewritten so that uses Commodity to get Commodity Group
	if _comCode &lt;&gt; null then	
		objSet.clear();
		aCommodity := app.myRoot.allCommodities[_comCode];
		self.assertTrueMsg(aCommodity &lt;&gt; null, "Commodity Code '" &amp; _comCode &amp; "' does not exist! Cannot create voyage allocation");
		if not self.opts.includesKey("CommodityGroupOnly") then
			objSet.add( aCommodity );
			self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_Commodity], objSet );
		endif;
		if self.opts.includesKey("CommodityGroupOnly") or self.opts.includesKey("SetCommodityGroup") then
			comGrp := aCommodity.myCommodityGroup;
			self.assertTrueMsg(comGrp &lt;&gt; null, "Commodity " &amp; _comCode &amp; " does not have a Commodity Group!  Cannot create voyage allocation");
			objSet.add(comGrp );
			self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_CommodityGroup], objSet );
		endif;
	endif;
	
	// ## isFiftyThree											// 18/07/2013 cnwmh5 
	if self.opts.includesKey("Is53Ft") then
		isoTypeString := self.opts.str('Is53Ft');
		objSet.clear();
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsFiftyThree], true );
	endif;
	
	// ## isFortyFive											// 18/07/2013 cnwmh5 
	if self.opts.includesKey("Is45Ft") then
		isoTypeString := self.opts.str('Is45Ft');
		objSet.clear();
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsFortyFive], true );
	endif;
	
	// ## isForty												// 18/07/2013 cnwmh5 
	if self.opts.includesKey("Is40Ft") then
		isoTypeString := self.opts.str('Is40Ft');
		objSet.clear();
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsForty], true );
	endif;
	
	// ## isThirty												// 18/07/2013 cnwmh5 
	if self.opts.includesKey("Is30Ft") then
		isoTypeString := self.opts.str('Is30Ft');
		objSet.clear();
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsThirty], true );
	endif;
	
	// ## Colour												// 18/07/2013 cnwmh5 
	if self.opts.includesKey("Colour") then
		portColor := self.opts.int("Colour");
	endif;
	
	
	/*
	// 05/04/2013 cnwmh5 - Replaced by above code
	if self.opts.includesKey("Commodity") then	
		commodityString := self.opts.str('Commodity');
		objSet.clear();
		aCommodity := app.myRoot.allCommodities[commodityString];
		self.assertTrueMsg(aCommodity &lt;&gt; null, "Commodity Code '" &amp; commodityString &amp; "' does not exist! Cannot create voyage allocation");
		objSet.add( aCommodity );
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_Commodity], objSet );
	endif;
	*/
	
	foreach cmif_object in allTransientCriteriaObj do
		cmif_criteria := cmif_object.CMIF_YACriteriaPriority;
		pxyCriteria := cmif_criteria.myProxy.CM_YACriteria;
		pxyCriteria.setYardAllocation(proxyYAObj);
	endforeach;

	desc := proxyYAObj.getDefaultDescription();
	proxyYAObj.setProxy(desc,desc,
								null,
								YAFillOption_InOrder,
								YAFillOption_InOrder,
								YAExpiryType_Never,
								null,
								portColor, 			
								null,  //cnwjo3 par 24145
								YAOverlap_Never,//allow others
								YANoLocation_Continue,
								null,
								0, //priority adjustment
								false,
								false,
								null,
								null,
								true,
								_voyage.myTerminal);

	app.myTrxUA.trxUpdateVoyageAlloc(false,_voyage, proxyYAObj,realAlloc,app.myPassport);
	self.assertNotNull( realAlloc );

	return realAlloc;

epilog	
	allTransientCriteriaObj.purge();
	delete allTransientCriteriaObj;
	delete proxyYAObj;
	delete objSet;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_portCode" type="String"/>
        <Parameter name="_isoGrpCode" type="String"/>
        <Parameter name="_comCode" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_reqPwr" type="Boolean"/>
        <Parameter name="_isOD" type="Boolean"/>
        <ReturnType type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="addVoyageCargoLOLO" id="30ec561a-441f-4182-b9a6-f71e83184a9d">
        <source>addVoyageCargoLOLO(_voyage : CM_Voyage; _startingSlotID : String; _numberOfSlots : Integer; _slotsToFill : StringArray);

/*

Purpose:		Create cargo on a LOLO Voyage

Date			Who		Reason
10/03/2014		cnwmh5	Initial creation

*/

vars

	theSlot							: CM_LocationsController;
	slot							: CM_SlotController;
	bay								: CM_BayVoyage;

	strs							: StringArray;
	slotsToFill						: CM_LCArray;
	
	iter							: Iterator;

	index 							: Integer;
	numberOfSlotToFill				: Integer;
	alreadyHaveSlots				: Boolean;
	idx								: Integer;
	
begin

	/*********************************************************************
	 * Get the slots to fill
	 *********************************************************************/
	create slotsToFill transient;
	
	if _slotsToFill &lt;&gt; null and not _slotsToFill.isEmpty then
		numberOfSlotToFill := _slotsToFill.size;
		alreadyHaveSlots := true;
	else
		numberOfSlotToFill := _numberOfSlots;
	endif;

	create strs transient;
	
	foreach index in 1 to numberOfSlotToFill step 1 do
	
		strs.clear;
		
		if alreadyHaveSlots then
			strs.add(_slotsToFill[index]);
		else
			if iter = null then
				strs.add(_startingSlotID);
			else
				//iter.next(slot);
				while iter.next(slot) and slot.mySlotDefnVoyage.unavailable do
				endwhile;
				if slot = null then
					break;
				endif;
				strs.add(slot.getFullId()[_voyage.code.length+1:end].trimBlanks);
			endif;
		endif;
		
		_voyage.findLocation(strs, false, theSlot, idx);
		slotsToFill.add(theSlot);
		

		
		if theSlot.isKindOf(CM_SlotController) and (self.opts.includesKey("ISOType") or 
				self.opts.includesKey("Is40")) then
			//self.xMakeSureSlotCanAccept(slotsToFill[slotsToFill.size]);
		//	aftSlot := slot.CM_SlotController.myAftSlot;
		//	self.xMakeSureSlotCanAccept(aftSlot);
		endif;
		
		if _startingSlotID &lt;&gt; null and iter = null then
			bay := _voyage.myCellularVoyageStructure.allBayVoyagesById[_startingSlotID[1:2]];
			delete iter;
			iter := bay.allSlotControllersByOrdinal.createIterator;
			while iter.next(slot) do
				if slot = theSlot then
					break;
				endif;
			endwhile;
		
		endif;
	
	endforeach;
	
	self.xCreateTIsForVoyCargoMeths(_voyage, slotsToFill);
	self.assertNoTrxErrorsOrWarnings();	

epilog

	delete slotsToFill;
	delete strs;
	delete iter;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_startingSlotID" type="String"/>
        <Parameter name="_numberOfSlots" type="Integer"/>
        <Parameter name="_slotsToFill" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="addVoyageCargoRORO" id="84ce42d7-0db9-40ce-b150-03d562640db4">
        <source>addVoyageCargoRORO(_voyage : CM_Voyage; _startingSlotLocnID : String; _numberOfSlots : Integer; _slotsLocnsToFill : StringArray);

/*

Purpose:		Create cargo on a RORO Voyage

Date			Who		Reason
11/03/2014		cnwmh5	Initial creation

*/

vars

	theSlot							: CM_LocationsController;
	slotDefn						: CM_ROROSlotDefn;
	locnDefn						: CM_ROROLocnDefn;
	aftSlotDefn						: CM_ROROSlotDefn;
	bay								: CM_BayVoyage;
	deck							: CM_DeckVoyage;
	deckItem						: CM_DeckItem;
	slotController					: CM_ROROSlotController;
	isoType							: CM_ISOType;

	strs							: StringArray;
	slotsToFill						: CM_LCArray;
	slotsLocnsToFill				: StringArray;
	
	iter							: Iterator;

	index 							: Integer;
	numberOfSlotToFill				: Integer;
	alreadyHaveSlots				: Boolean;
	idx								: Integer;
	totalNumberOfSlotsFound			: Integer;
	slotLocn						: String;
	timeToExitLoop					: Boolean;
	firstTime						: Boolean;
	getNextLocn						: Boolean;
	not20Foot						: Boolean;
	
begin
	
	/*********************************************************************
	 * Get the slots to fill
	 *********************************************************************/
	create slotsToFill transient;
	create strs transient;
	create slotsLocnsToFill transient;
	
	if _slotsLocnsToFill &lt;&gt; null and not _slotsLocnsToFill.isEmpty() then
		_slotsLocnsToFill.copy(slotsLocnsToFill);
	elseif _startingSlotLocnID &lt;&gt; null then
		slotsLocnsToFill.add(_startingSlotLocnID);
	endif;
	
	getNextLocn := true;
	
	if self.opts.includesKey("ISOType") then
		isoType := app.myRoot.allISOTypes[self.opts.str("ISOType")];
	endif;
	if (isoType &lt;&gt; null and not isoType.is20ftLong) or self.opts.includesKey("Is40") then
		not20Foot := true;
	endif;	
	
	while true do
	
		if getNextLocn then
			getNextLocn := false;
			index := index + 1;
			if not _slotsLocnsToFill.isEmpty() and index &gt; slotsLocnsToFill.size then
				break;
			endif;
			slotLocn := slotsLocnsToFill[index];
			
			foreach deck in _voyage.myROROStructure.allDecks do
				delete iter;
				iter := deck.allROROLocnDefnByOrdinal.createIterator;
				while iter.next(locnDefn) do
					if locnDefn.code = slotLocn then
						break;
					endif;
				endwhile;
				if locnDefn &lt;&gt; null then
					break;
				endif;
			endforeach;
		else
			iter.next(locnDefn);
		endif;
			
		if locnDefn &lt;&gt; null then
			write Tab &amp; "locnDefn";
			if locnDefn.isKindOf(CM_ROROLaneDefnVoyage) then
				slotsToFill.add(deckItem.CM_ROROLaneDefnVoyage.myLaneController);
			elseif locnDefn.isKindOf(CM_ROROGCDefnVoyage) then
				slotsToFill.add(deckItem.CM_ROROGCDefnVoyage.myGCController);
			elseif locnDefn.isKindOf(CM_ROROLocnDefnVoyage) then
				foreach slotDefn in locnDefn.CM_ROROLocnDefnVoyage.allROROSlotDefnByOrdinal discreteLock do
					if slotDefn.isAvailable and slotDefn.CM_ROROSlotDefnVoyage.mySlotController.allTrackedItems.isEmpty()  then
						slotsToFill.add(slotDefn.CM_ROROSlotDefnVoyage.mySlotController);
						if not20Foot then
							aftSlotDefn :=  slotDefn.CM_ROROSlotDefnVoyage.getAftSlotDefn();
							if slotDefn.CM_ROROSlotDefnVoyage.mySlotController.getFwdLC() &lt;&gt; null then
								slotsToFill[slotsToFill.size] := slotDefn.CM_ROROSlotDefnVoyage.mySlotController.getFwdLC();
							endif;
						endif;
						if _numberOfSlots &gt; 0 and _numberOfSlots = slotsToFill.size then
							timeToExitLoop := true;
							break;
						endif;
					endif;
				endforeach;
			endif;
		else
			theSlot := _voyage.getLocationByID(slotLocn);
			write Tab &amp; 'theSlot: ' &amp; theSlot.String;
			if theSlot &lt;&gt; null then
				slotsToFill.add(theSlot);
				if not20Foot then
					if theSlot.getFwdLC() &lt;&gt; null then
						slotsToFill[slotsToFill.size] := theSlot.getFwdLC();
					endif;
				endif;
				if _slotsLocnsToFill.isEmpty() then
					timeToExitLoop := true;
				endif;
			endif;
		endif;
		
		if timeToExitLoop or (_numberOfSlots = 0 and _slotsLocnsToFill.isEmpty()) then 
			break;
		endif;
		
		if not _slotsLocnsToFill.isEmpty() then
			getNextLocn := true;
		endif;
		
	endwhile;
	
	self.xCreateTIsForVoyCargoMeths(_voyage, slotsToFill);
	self.assertNoTrxErrorsOrWarnings();	

epilog

	delete slotsToFill;
	delete strs;
	delete iter;
	delete slotsLocnsToFill;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_startingSlotLocnID" type="String"/>
        <Parameter name="_numberOfSlots" type="Integer"/>
        <Parameter name="_slotsLocnsToFill" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="addVoyageCraneQueue" id="e62bd945-43fb-4258-ba01-1c325e5676af">
        <source>addVoyageCraneQueue(_voyage: CM_Voyage input; _voyageQueue: CM_VoyageQueue input; _crane: CM_Machine input) : CM_VoyageCraneQueue;
//24 November 2011	cnwdw1	
//
vars
	queue: CM_RadioTelemetryQueue;
begin
	self.deleteQueue(_voyageQueue.id &amp; ' ' &amp; _crane.id.trimBlanks);
	
	beginTransaction;
	_crane.setPropertyValue(CM_Crane::myPrimaryQueue.name, _voyageQueue);
	_voyageQueue.createCraneQueue(_crane.CM_Crane, queue);
	commitTransaction;
	
	//21 Apr 2020	NDL	TFS 49174/48549
	if self.opts.includesKey("LoadMachinesMode") then
		beginTransaction;
			queue.CM_VoyageCraneQueue.setPropertyValue(CM_VoyageCraneQueue::loadMachinesMode.name, self.opts.int("LoadMachinesMode") );
		commitTransaction;
	endif;
	
	self.assertNoTrxErrorsOrWarnings();
	return queue.CM_VoyageCraneQueue;

epilog
	abortTransaction;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_voyageQueue" type="CM_VoyageQueue" usage="input"/>
        <Parameter name="_crane" type="CM_Machine" usage="input"/>
        <ReturnType type="CM_VoyageCraneQueue"/>
    </JadeMethod>
    <JadeMethod name="addVoyageHoldJob" id="ff3f5e15-720a-46ee-9863-7fd0648a8152">
        <source>addVoyageHoldJob(_jobType : Integer; _voyage : CM_Voyage; _allWLEs : CM_WLEArray; _targetLC : CM_LocationsController; _workPoint : CM_WorkPoint) : CM_VoyageHoldJob;
/*

Purpose:			Does what it says on the tin

Parameters:			_jobType 	: JOB_TYPE_DISCHARGE or JOB_TYPE_LOAD
					_voyage		: the voyage	
					_alLWLEs	: colection of the wles to include on the job, only need TI, and quantity/weight
					_targetLC	: where is the cargo being planned to
					_workpoint	: the workpoint to work the job

Return Value:		the voyage hold job that was created, or not

Date				Who		Reason
21 August 2019		jlgzm1	Initial creation TFS 42872 Direct Release Between HOLD Voyages and Rail
07 December 2021	navdap1	TFS 52293 SAL Direct Loading - Marking Job as Direct Delivery
*/

vars
	newJob		: CM_VoyageHoldJob;
	pxyJob		: CM_VoyageHoldJob;
	jobParams 	: CMIF_VoyageJobParams;
	wle 		: CM_WorkListEntry;
	tis			: CM_TISet;
	jobId		: String;
	shift		: CM_Shift;
	allShifts 	: CM_ShiftStartDateCodeDict;
	startDT, 
	endDT 		: TimeStamp;
	outOfSeq	: Boolean;
	
begin

	if _voyage = null then
		return null;
	endif;
	
	jobId := _voyage.getNextJobNumber(null,null);

	outOfSeq := false;
	
	if self.opts.includesKey("Shift") then
		shift := self.opts.obj("Shift").CM_Shift;
	else
		create allShifts transient;
		startDT := _voyage.getArrivalDT;
		endDT.setDate(startDT.date + 1);
		_voyage.myTerminal.getShiftsFromRange(allShifts, startDT, endDT);
		shift := allShifts.first;
	endif;
	
	create tis transient;
	foreach wle in _allWLEs do
		tis.addNoDuplicates(wle.myTrackedItem, false);
	endforeach;
	
	create pxyJob transient;
	pxyJob.setProxy(jobId, _jobType);
	pxyJob.setMyVoyage(_voyage);
	pxyJob.setProxyVoyageHoldJob(null, jobId, null, null, false, _jobType, null, null, null, null, outOfSeq, shift, null, tis, null, null);
	if self.getTerminal.getConfig(DirectTruck2VesselMult).Boolean then		// TFS 52293
		pxyJob.setIsDirectDelivery(true);									// TFS 52293
	endif;																	// TFS 52293
	
	create jobParams transient;
	jobParams.myLocation := _targetLC;
	jobParams.myProxyJob := pxyJob;
	jobParams.myVoyage := _voyage;
	jobParams.myWorkPoint := _workPoint;
	jobParams.craneID := _workPoint.code;
	if self.getTerminal.getConfig(DirectTruck2VesselMult).Boolean then		// TFS 52293
		jobParams.isDirectDelivery := true;									// TFS 52293
	endif;																	// TFS 52293
	
	app.myTrxCA.trxCreateVoyageHoldJob(jobParams, newJob, app.myPassport, _allWLEs);
	
	return newJob;
	
epilog

	delete pxyJob;
	if allShifts &lt;&gt; null then
		beginTransaction;
		allShifts.purge();
		commitTransaction;
	endif;
	delete allShifts;
	delete tis;
	delete jobParams;
	
end;</source>
        <Parameter name="_jobType" type="Integer"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_allWLEs" type="CM_WLEArray"/>
        <Parameter name="_targetLC" type="CM_LocationsController"/>
        <Parameter name="_workPoint" type="CM_WorkPoint"/>
        <ReturnType type="CM_VoyageHoldJob"/>
    </JadeMethod>
    <JadeMethod name="addVoyageJob" id="cbd99bb8-818a-4a98-948f-2c64d4f209b9">
        <source>addVoyageJob(_voyage : CM_Voyage; _craneId :String; _allSlots : CM_SlotControllerArray; isDischarge : Boolean) : CM_VoyageJob;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2008	cnwer1	Initial creation

*/

vars
	theJobParams : CMIF_VoyageJobParams;
	theVoyageJS : CM_VoyageJobSheet;
	crane 		: CM_Crane;
	theRealVJob : CM_VoyageJob;
	slot 		: CM_SlotController;
	terminal	: CM_Terminal;
begin
	
	// 29099 Mar 2012
	terminal := self.getTerminal();
	if terminal &lt;&gt; null then
		crane := terminal.machines[_craneId].CM_Crane;
	endif;

	self.assertTrueMsg(crane &lt;&gt; null, "Crane " &amp; _craneId &amp; " does not exist!");
	
	create theJobParams transient;
	theJobParams.useNewMethod := true; //IMPORTANT TO SET THIS
	theJobParams.isDischarge		:=	isDischarge;
	theJobParams.jobNumLinkedLoad	:=null;
	theJobParams.craneID			:=	_craneId;
	theJobParams.myVoyage			:=	_voyage;
	theJobParams.myProxyJob			:=	null;
	theJobParams.resquence			:=	true;		//set true whenever there's the posibility of slots added/removed from a job
	theJobParams.isSeqForJob		:=	false;

	
	if self.opts.includesKey("OutOfOrder") then
		theJobParams.allowOutOfOrderLoading := self.opts.bool("OutOfOrder");
	endif;
	
	theVoyageJS :=  _voyage.allJobSheets[_craneId];
	theJobParams.id := self.opts.strDef("JobId", _voyage.getNextJobNumber(theVoyageJS, crane.IF_VoyageWorkPoint)); //
	//theJobParams.myBay := self.mnuGridNewJob.userObject.CM_Bay;
	_allSlots.copy(theJobParams.allSlotControllers);

	//can't just copy - this is an external key dict
	foreach slot in _allSlots do
		theJobParams.allObjectEditions.add(slot);
	endforeach;
	
	app.myPassport.setWarningsIgnored(true); // PAR 28968
	app.myTrxCA.trxCreateVoyageJob(theJobParams, theRealVJob, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	

	return theRealVJob;
epilog
	
	if theJobParams &lt;&gt; null then
		delete theJobParams.myProxyJob;
	endif;
	delete theJobParams;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_craneId" type="String"/>
        <Parameter name="_allSlots" type="CM_SlotControllerArray"/>
        <Parameter name="isDischarge" type="Boolean"/>
        <ReturnType type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="addVoyageJobTransferType" id="a00ee985-4e6e-4149-8dcd-42b1495f0710">
        <source>addVoyageJobTransferType( _description : String ):CM_VoyageJobTransferType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2019	jlgndl1	Initial creation	TFS 44773

*/

vars

	lastId : Integer;
	proxy : CM_VoyageJobTransferType;
	real : CM_VoyageJobTransferType;

begin

	real := app.myRoot.allVoyageJobTransferTypes.getMatchesDescription( _description );
	if real &lt;&gt; null then
		return real;
	endif;

	lastId := app.myRoot.allVoyageJobTransferTypes.last.id;
	if lastId &lt; 10000 then
		lastId := 10000;
	endif;

	create proxy transient;
	proxy.setProxy( lastId + 1, _description, null );
	app.myTrxCA.trxCreateVoyJobTfrType( proxy, real, app.myPassport );
	
	if not app.myPassport.trxCompletedOK() then
		return null;
	endif;
	
	return real;

epilog

	delete proxy;

end;</source>
        <Parameter name="_description" type="String"/>
        <ReturnType type="CM_VoyageJobTransferType"/>
    </JadeMethod>
    <JadeMethod name="addVoyageNonPlannedNonWorked" id="e8d145f2-85aa-4ebe-b20e-41fe9994c4d2">
        <source>addVoyageNonPlannedNonWorked(	_code : String; _vesselCode : String; _operatorName : String; _shippingLine : String) : CM_Voyage;
	
//16 December 2008	cnwdw1	
begin
    return self.addVoyageWithInwardCode( _code, "", _vesselCode, _operatorName, _shippingLine); //PAR 32247 cnwgb1 13.8.2013
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_operatorName" type="String"/>
        <Parameter name="_shippingLine" type="String"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="addVoyageQueue" id="aae73c83-bc95-4bbb-a563-07506c4a39a3">
        <source>addVoyageQueue(_voyage: CM_Voyage input): CM_VoyageQueue;
//24 November 2011	cnwdw1	
//
vars
	queue: CM_RadioTelemetryQueue;
begin
	self.deleteQueue(_voyage.code);

	beginTransaction;
	app.myPassport.clearErrorsWarnings();
	self.getTerminal.radioTelemetry.masterQueue.createVoyageQueue(_voyage, queue);
	commitTransaction;
	self.assertNoTrxErrorsOrWarnings();
	return queue.CM_VoyageQueue;

epilog
	abortTransaction;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <ReturnType type="CM_VoyageQueue"/>
    </JadeMethod>
    <JadeMethod name="addVoyageROROJob" id="f90ba1d3-59e6-45f8-bc90-bff432d0be4c">
        <source>addVoyageROROJob(_voyage : CM_Voyage; _deck : CM_DeckVoyage; _workPoint :String; _allSlots : CM_LCArray; isDischarge : Boolean) : CM_VoyageJob;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2008	cnwer1	Initial creation

*/

vars
	theJobParams : CMIF_VoyageJobParams;
	theVoyageJS : CM_VoyageJobSheet;
	theRealVJob : CM_VoyageJob;
	slot 		: CM_VoyageROROController;
	workPoint : CM_WorkPoint;
	voyage 		: CM_Voyage;
	operator 		: CM_Operator;
	vessel 			: CM_Vessel;
	lc : CM_LocationsController;
begin
	
	workPoint:=self.addWorkPoint(_workPoint, false);
	self.assertTrue(workPoint &lt;&gt; null);
	
	create theJobParams transient;

	theJobParams.useNewMethod := true; //IMPORTANT TO SET THIS
	theJobParams.isDischarge		:=	isDischarge;
	theJobParams.jobNumLinkedLoad	:=null;
	theJobParams.craneID			:=	_workPoint;
	theJobParams.myVoyage			:=	_voyage;
	theJobParams.myProxyJob			:=	null;
	theJobParams.resquence			:=	true;		//set true whenever there's the posibility of slots added/removed from a job
	theJobParams.isSeqForJob		:=	false;
	theJobParams.myDeck				:= _deck;
	theJobParams.myWorkPoint		:= workPoint;
		
	theJobParams.allowOutOfOrderLoading := self.opts.bool( 'OutOfSequenceVJ' );
	
	
	theVoyageJS :=  _voyage.allJobSheets[_workPoint];
	theJobParams.myJobSheet := theVoyageJS;
	theJobParams.id := _voyage.getNextJobNumber(theVoyageJS, workPoint.IF_VoyageWorkPoint); 
	_allSlots.copy(theJobParams.allROROControllers);

	//can't just copy - this is an external key dict
	foreach lc  in _allSlots do
		slot := lc.CM_VoyageROROController;
		
		theJobParams.allObjectEditions.add(slot);
	endforeach;
	
	
	app.myTrxCA.trxCreateVoyageJob(theJobParams, theRealVJob, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	return theRealVJob;
epilog
	
	if theJobParams &lt;&gt; null then
		delete theJobParams.myProxyJob;
	endif;
	delete theJobParams;


end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
        <Parameter name="_workPoint" type="String"/>
        <Parameter name="_allSlots" type="CM_LCArray"/>
        <Parameter name="isDischarge" type="Boolean"/>
        <ReturnType type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="addVoyageToEDIProcessing" id="d56caae2-beb6-4f7a-a066-d2356052878f">
        <source>addVoyageToEDIProcessing(_voyage : CM_Voyage);
// ---------------------------------------------------------------------------
// Created:	15 September 2010 By Graeme Black cnwgb1
// Purpose:	Puts the voyage in the terminal collection of voyages available for EDI processing
// ---------------------------------------------------------------------------
vars
	terminal : CM_Terminal;
	ediConfig : CM_EDIConfig;
	addedVoyToEDI : Boolean;
begin
	terminal := self.getTerminal();
	ediConfig := terminal.myEdiConfig;
	
	self.assertNotNull( ediConfig );
	
	//all we need to do here is add this voyage to the ediConfigs voyage list...
	beginTransaction;
	addedVoyToEDI := ediConfig.addVoyageToProcessing(_voyage, _voyage.code); 
	commitTransaction;
	assertTrueMsg( addedVoyToEDI, "Couldn't add voyage to edi processing collection" );
epilog
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="addVoyageWithConRORO" id="52bb1e45-2aa3-4da0-b162-166dc1253350">
        <source>addVoyageWithConRORO(_code : String; _vesselCode : String; _operatorName : String; _shippingLine : String; _tradeCode : String; _numberHatches : Integer; _isNonPlannedVoyage : Boolean; _isNonWorkedVoyage : Boolean) : CM_Voyage;
/****Changes

Date		Name	TFS#			Description
============================================================================	
29/03/2010 	cnwrs1	
29/07/2011	cnwmh5					Change to use UT_UnitTest.opts
26/03/2013	PJS		PAR # 31232
05/03/2015	cnwdap1	PAR #35826 
					CCMS SFW 1410 	Added expected arrival/departure date/time
11/04/2017	cnwdap1	TFS 4050 		LNX Job ID Enhancements
05/12/2018	jlgka1	TFS 37102		STWR - Add isBarges Flag.
============================================================================*/
vars
	vessel				  : CM_Vessel;
	pxyVoyage			  : CM_Voyage;
	voyage				  : CM_Voyage;
	pxyCellStructure	  : CM_CellularVoyageStructure;
	now					  : TimeStamp;
	arrivalDate		  	  : TimeStamp;
	departureDate		  : TimeStamp;
	pilotOnBoard		  : TimeStamp;
	labourOnBoard		  : TimeStamp;
	shipPilotReturnDT	  : TimeStamp;
	labourOnShore 		  : TimeStamp;
	pxyGlobalVoyage		  : CM_VoyageGlobal;
	trade				  : CM_Trade;
	pxyVoyagePortRotation : CM_PortRotation;
	portRotation		  : CM_PortRotation;
	outOfSequenceVJ 	  : Boolean;
	portRotationToDelete  : CM_PortRotationArray;						// 24/02/2014 cnwmh5
	inwardCode 			  : String;
begin
	
	vessel := getRoot.allVessels[_vesselCode];
	self.assertNotNullMsg(vessel, "Vessel");                // 04/10/2013 cnwmh5
	
	create portRotationToDelete transient;
	
	if _tradeCode = null then
		trade := getTrade();
	else
		trade := self.getRoot.allTradesByDescription[_tradeCode];
	endif;
	create pxyVoyage transient;							

	// PAR # 31232
	//pxyVoyage.setProxyForVoyageType(vessel.myCellularVesselStructure.type,vessel);

	pxyVoyage.setProxyForVoyageType(vessel.structureIncludesLOLO,
									vessel.structureIncludesRORO,
									vessel.structureIncludesHolds,
									vessel);

	create pxyGlobalVoyage transient;
	pxyGlobalVoyage.setProxy(_code, _vesselCode, null, null, null, null, null, 0, null, app.myRoot);
	
	pxyVoyage.setMyVoyageGlobalArrival(pxyGlobalVoyage);
	
	arrivalDate.setDate(now.date());
	arrivalDate.setTime(now.time());
	departureDate := arrivalDate.addDays(2);
	
	outOfSequenceVJ	:= self.opts.bool( 'OutOfSequenceVJ' );
	
	if self.opts.includesKey("InwardCode") then
		inwardCode := self.opts.str("InwardCode");
	else
		inwardCode := null;
	endif;
	
	pxyVoyage.setProxyVoyage(	null,
								self.opts.str( ETRow_CallSign ),
								_code,
								inwardCode,
								self.createdByUnitTest(null),					// 18/08/2015 cnwmh5
								vessel.code,
								vessel.name,
								self.opts.str( ETRow_LloydsNumber ),
								false,
/*		PAR 33644						_isNonPlannedVoyage,
								_isNonWorkedVoyage, */
								false,
								false,
								0,
								VoyageDisplayAlways,
								0,
								pxyVoyage.status,
								vessel.vesselType,
								null,
								arrivalDate,
								departureDate,
								pxyVoyage.loadStartDT,
								pxyVoyage.loadEndDT,
								null,
								null,
								null,
								null,
								getRoot.allOperators[_operatorName],
								trade,
								getRoot.allShippingLines[_shippingLine],
								self.getTerminal,
								pxyVoyage.myVoyageGlobalArrival,
								null,
								null,
								null,
								null,
								null,
								0,
								false,									// 27/05/2009 cnwar2 CCMS1040
								pxyVoyage.allOperators,
								pxyVoyage.allReceivalCutoffs,		// 27/05/2009 cnwar2 CCMS1040
								true, // use Voyage Allocations
								null, 
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								outOfSequenceVJ,
								null,							// PAR #35826
								null,
								null,	//_generalLandingDate : Date	//14 Mar 2016	TFS 1407
								null, 				// TFS 4050
								pxyVoyage.paymentType,
								pxyVoyage.isBarge,	//jlgka1 TFS 37102
								pxyVoyage.voyageGroupCode,
								false	// 31.Aug.2023 navsp1 TFS 57809
								);							
								
	// PAR # 31232 - RORO vessel - for consistenty with prior mode mark as LOLO vessel as well							
	//	pxyVoyage.setProxyForVoyageType(CellularStructureRORO,vessel);
	//pxyVoyage.setProxyForVoyageType(true,true,false,vessel);
	pxyVoyage.setProxyForVoyageType(vessel.structureIncludesLOLO,vessel.structureIncludesRORO,vessel.structureIncludesHolds,vessel);

	if not self.opts.includesKey("CopyVoyageVAConfig") then					// 29/01/2014 cnwmh5
		self.setProxyVoyageVAConfig(pxyVoyage); // AKB ADDED 18/8/11 RORO KPI
	endif;
	
	// Set the Port Rotations from the Trade
	foreach portRotation in trade.allPortRotations do
		create pxyVoyagePortRotation transient;
		portRotation.allTranshipPorts.copy(pxyVoyagePortRotation.allTranshipPorts);
		pxyVoyagePortRotation.setProxy(portRotation.myPort, pxyVoyage);
		portRotationToDelete.add(pxyVoyagePortRotation);
	endforeach;
	
	//cnwmc5 - 3/12/2012 - add all the trade operators to the voyage
	trade.operators.copyNoDuplicates(pxyVoyage.allOperators, false);
	
	//10 Apr 2012	NDL	Par 29369
	pilotOnBoard := arrivalDate.cnEcAddMinutes( -2 );
	pxyVoyage.setPropertyValue( CM_Voyage::pilotOnBoardDT.name, pilotOnBoard );
	labourOnBoard := arrivalDate;
	pxyVoyage.setPropertyValue( CM_Voyage::labourOnBoard.name, labourOnBoard );
	labourOnShore := arrivalDate.cnEcAddDays( 1 );
	pxyVoyage.setPropertyValue( CM_Voyage::labourOnShore.name, labourOnShore );
	shipPilotReturnDT := departureDate.cnEcAddMinutes( -2 );
	pxyVoyage.setPropertyValue( CM_Voyage::shipPilotReturnDT.name, shipPilotReturnDT );
	
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreateVoyage(pxyVoyage, voyage, vessel, null, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	return voyage;
epilog
	/*
	foreach pxyVoyagePortRotation in portRotationToDelete do						// 24/02/2014 cnwmh5 - Transient leaks
		delete pxyVoyagePortRotation;
	endforeach;
	*/
	if portRotationToDelete &lt;&gt; null then	// 11/07/2019 jlgzm1 1090 error
		portRotationToDelete.purge();
	endif;
	delete portRotationToDelete;

	if pxyVoyage &lt;&gt; null then
		delete pxyVoyage.myROROStructure;
		delete pxyVoyage.myCellularVoyageStructure;
		delete pxyVoyage.myGeneralCargoVoyage;
		delete pxyVoyage.myStructuralElements;
		delete pxyVoyage;
	endif;

	if global.isValidObject(pxyGlobalVoyage) then
		delete pxyGlobalVoyage; //cnwrs1 par23228 10 Mar 2010 now done in CM_Voayge setForCreate
	endif;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_operatorName" type="String"/>
        <Parameter name="_shippingLine" type="String"/>
        <Parameter name="_tradeCode" type="String"/>
        <Parameter name="_numberHatches" type="Integer"/>
        <Parameter name="_isNonPlannedVoyage" type="Boolean"/>
        <Parameter name="_isNonWorkedVoyage" type="Boolean"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="addVoyageWithContainerStructur" id="f5b0426f-d1e9-4edf-aa81-208aeee8fa41">
        <source>addVoyageWithContainerStructur(	_code : String; _vesselCode : String; _operatorName : String; _shippingLine : String ) : CM_Voyage;
/****Changes

Date		Name	TFS#			Description
============================================================================	
16/12/2008	cnwdw1	
05/03/2015 	cnwdap1	PAR #35826 
					CCMS SFW 1410 	Added expected arrival/departure date/time
11/04/2017	cnwdap1	TFS 4050 		LNX Job ID Enhancements
05/12/2018	jlgka1	TFS 37102		STWR - Add isBarges Flag.
// 10 Sep 2019	cnwrs1	TFS 46030
============================================================================*/
vars
	useHMSData				 : Boolean;
	vessel					 : CM_Vessel;
	pxyVoyage				 : CM_Voyage;
	voyage					 : CM_Voyage;
	inwardCode				 : String;
	cusresAltVoyageStr		 : String;							// cnwrl1 28/04/2010 PAR 23854
	cusresAltVoyage			 : CM_Voyage;						// cnwrl1 28/04/2010 PAR 23854
	pxyCellStructure		 : CM_CellularVoyageStructure;
	now						 : TimeStamp;
	arrivalDate				 : TimeStamp;
	departureDate 			 : TimeStamp;
	pxyGlobalVoyage			 : CM_VoyageGlobal;
	pxyHMSData				 : HMS_VoyageData;
	trade					 : CM_Trade;
	pxyVoyagePortRotation	 : CM_PortRotation;
	portRotation			 : CM_PortRotation;
	berth					 : HMS_Berth;
	term					 : CM_Terminal;
	useAllocations			 : Boolean;
	pxyPortRotationsToDelete : CM_PortRotationArray;				// 24/02/2014 cnwmh5 - transient leaks
	obj						 : Object;
	bank 					 : CM_Bank;
begin
	term := self.getTerminal();
	if self.opts.includesKey("dischargeCompany") then
		bank := self.opts.obj("dischargeCompany").CM_Bank;
	endif;
	//opts := self.getOpts(_opts);
	
	create pxyPortRotationsToDelete transient;
	
//	vessel := getRoot.allVessels[_vesselCode];		// cnwrl1 14/05/2010 PAR 24216 - what it was
	vessel := self.getVessel( _vesselCode );
	self.assertNotNullMsg(vessel, "Vessel");                // 04/10/2013 cnwmh5
	 
	trade := getTrade;
	
	create pxyVoyage transient;							
	
	create pxyCellStructure transient;
	pxyVoyage.setProxyVoyageCellullStructure(pxyCellStructure);
	pxyCellStructure.setProxyCellularVoyage(vessel.myCellularVesselStructure.bridgeAfterBay, 
											vessel.myCellularVesselStructure.isoHalfHeights,
											vessel.myCellularVesselStructure.use40Id, 
											vessel.myCellularVesselStructure.useBayCellTierNumbering);
	
	create pxyGlobalVoyage transient;
	pxyGlobalVoyage.setProxy(_code, _vesselCode, null, null, null, null, null, 0, null, app.myRoot);
	pxyVoyage.setMyVoyageGlobalArrival(pxyGlobalVoyage);
	
	arrivalDate.setDate(now.date());
	arrivalDate.setTime(now.time());
	departureDate := arrivalDate.addDays(2);

	if self.opts.includesKey("tsArrival") then // whole time stamp
		arrivalDate := self.opts.timestamp("tsArrival");
	elseif self.opts.includesKey("dateArrival") then // just a date
		arrivalDate.setDate(self.opts.date("dateArrival"));
	endif;
	
	if self.opts.includesKey("tsDeparture") then // whole time stamp
		departureDate := self.opts.timestamp("tsDeparture");
	elseif self.opts.includesKey("dateDeparture") then // just a date
		departureDate.setDate(self.opts.date("dateDeparture"));
	endif;
	inwardCode := self.opts.str('inwardCode');
	
	// cnwrl1 28/04/2010 PAR 23854 - start of coding
	cusresAltVoyageStr	:= self.opts.str( 'myCusresAltVoyage' );
	if cusresAltVoyageStr &lt;&gt; null then
		cusresAltVoyage	:=  self.getVoyage( cusresAltVoyageStr );
	endif;
	// cnwrl1 28/04/2010 PAR 23854 - end of coding
	

	useAllocations	:= self.opts.bool( 'UseAllocations' );

	pxyVoyage.setProxyVoyage(	null,
								self.opts.str( ETRow_CallSign ),
								_code.toUpper(),								// 23/01/2014 cnwmh5
								inwardCode,
								self.createdByUnitTest(null),					// 18/08/2015 cnwmh5
								vessel.code,
								vessel.name,
								self.opts.str( ETRow_LloydsNumber ),
								false,
/* PAR 33644								false,
								false, */
								false,
								false,
								0,
								VoyageDisplayAlways,
								0,
								pxyVoyage.status,
								vessel.vesselType,
								null,
								arrivalDate,
								departureDate,
								pxyVoyage.loadStartDT,
								pxyVoyage.loadEndDT,
								null,
								null,
								null, 
								bank,// BANK
								getRoot.allOperators[_operatorName],
								trade,
								getRoot.allShippingLines[_shippingLine],
								self.getTerminal,
								pxyVoyage.myVoyageGlobalArrival,
								null,
								null,
								null,
								null,
//								null,							// cnwrl1 28/04/2010 PAR 23854 - what it was
								cusresAltVoyage,
								0,
								false,									// 27/05/2009 cnwar2 CCMS1040
								pxyVoyage.allOperators,
								pxyVoyage.allReceivalCutoffs,		// 27/05/2009 cnwar2 CCMS1040
								useAllocations, //use voyage allocations
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,null,null,
								null,null,
								null,	//_generalLandingDate : Date	//14 Mar 2016	TFS 1407
								null,			// TFS 4050
								pxyVoyage.paymentType,
								pxyVoyage.isBarge, 	//jlgka1 TFS 37102
								pxyVoyage.voyageGroupCode,
								false	// 31.Aug.2023 navsp1 TFS 57809
								);					// PAR #35826
	
	
	self.createExchangeDates(pxyVoyage); // AKB 2010 AUG
	
	if self.opts.includesKey("useHMSData") then
		useHMSData := self.opts.bool("useHMSData");
	endif;
//	9/9/19 MAP always create HMS object
//	if useHMSData then
		berth := self.opts.obj("berth").HMS_Berth;
		create pxyHMSData transient;
		pxyHMSData.setPxyFromVessel(vessel, term);
		pxyHMSData.setMyBerth(berth);
		pxyHMSData.setTidalClasses(app.myRoot.allTidalClasses['A'], app.myRoot.allTidalClasses['B']);	//10 Sep 2019	cnwrs1	TFS 46030
		pxyVoyage.setHMSVoyageData(pxyHMSData);
		pxyHMSData.setProxyDefaultVoyageMovements(berth, null, app.myPassport);
//	endif;
	
	// Set the Port Rotations from the Trade
	foreach portRotation in trade.allPortRotations do
		create pxyVoyagePortRotation transient;
		portRotation.allTranshipPorts.copy(pxyVoyagePortRotation.allTranshipPorts);
		pxyVoyagePortRotation.setProxy(portRotation.myPort, pxyVoyage);
		pxyPortRotationsToDelete.add(pxyVoyagePortRotation);
	endforeach;
	
	if self.opts.includesKey("UseDefaultVAConfig") then
		self.setProxyVoyageVAConfig(pxyVoyage); // NAVLW1
	elseif not self.opts.includesKey("CopyVoyageVAConfig") then					// 29/01/2014 cnwmh5
		self.opts.addAssoc("UseVesselAllocations", true);
		self.opts.addAssoc("Vessel", vessel);
		self.setProxyVoyageVAConfig(pxyVoyage); // AKB ADDED 18/8/11 RORO KPI
	endif;
	
	
	//cnwmc5 - 3/12/2012 - add all the trade operators to the voyage
	trade.operators.copyNoDuplicates(pxyVoyage.allOperators, false);

	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreateVoyage(pxyVoyage, voyage, vessel, null, true, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();

	return voyage;
epilog

	delete pxyCellStructure;											// 24/02/2014 ccnwmh5 - Transient Leaks
	
	foreach pxyVoyagePortRotation in pxyPortRotationsToDelete do		// 24/02/2014 ccnwmh5 - Transient Leaks
		delete pxyVoyagePortRotation;
	endforeach;
	delete pxyPortRotationsToDelete;
	
	delete pxyVoyage;													// 24/02/2014 ccnwmh5 - Transient Leaks

	if global.isValidObject(pxyGlobalVoyage) then
		delete pxyGlobalVoyage; //cnwrs1 par23228 10 Mar 2010 now done in CM_Voayge setForCreate
	endif;
end;
</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_operatorName" type="String"/>
        <Parameter name="_shippingLine" type="String"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="addVoyageWithGCStructDates" id="0e0be272-cab7-430e-b2b2-fe6bf3092a55">
        <source>addVoyageWithGCStructDates(_code : String; _vesselCode : String; _operatorName : String; _shippingLine : String; _numberHatches : Integer;
							_arrive : TimeStamp; _depart : TimeStamp) : CM_Voyage;
//----------------------------------------------------------------------
// copy of addVoyageWithGeneralCargoStruc with explicit arrive and departure dates

/****Changes

Date		Name	TFS#			Description
============================================================================
05/03/2015	cnwdap1	PAR #35826 
					CCMS SFW 1410 	Added expected arrival/departure date/time
11/04/2017	cnwdap1	TFS 4050 		LNX Job ID Enhancements
05/12/2018	jlgka1	TFS 37102		STWR - Add isBarges Flag.
============================================================================*/
vars
	useHMSData				 : Boolean;
	vessel					 : CM_Vessel;
	pxyVoyage				 : CM_Voyage;
	voyage					 : CM_Voyage;
	pxyGeneralCargoStructure : CM_GeneralCargoVoyageStructure;
	now						 : TimeStamp;
	arrivalDate				 : TimeStamp;
	departureDate 			 : TimeStamp;
	pxyGlobalVoyage			 : CM_VoyageGlobal;
	trade					 : CM_Trade;
	berth					 : HMS_Berth;
	pxyHMSData				 : HMS_VoyageData;
	pxyVoyagePortRotation	 : CM_PortRotation;
	portRotation			 : CM_PortRotation;
	term					 : CM_Terminal;
	portRotationArray		 : CM_PortRotationArray;
begin
	self.deleteVoyage(_code);
	term := self.getTerminal();

	vessel := getRoot.allVessels[_vesselCode];
	self.assertNotNullMsg(vessel, "Vessel");
	 
	create portRotationArray transient;	
	
	trade := getTrade;
	create pxyVoyage transient;							

	create pxyGeneralCargoStructure transient;
	pxyVoyage.setProxyVoyageGeneralCargo(pxyGeneralCargoStructure);
	pxyGeneralCargoStructure.setProxyGCVoyage(_numberHatches);

	create pxyGlobalVoyage transient;
	pxyGlobalVoyage.setProxy(_code, _vesselCode, null, null, null, null, null, 0, null, app.myRoot);
	pxyVoyage.setMyVoyageGlobalArrival(pxyGlobalVoyage);
	
	arrivalDate := _arrive;
	departureDate := _depart;

	pxyVoyage.setProxyVoyage(	null,
								"",
								_code,
								"",
								self.createdByUnitTest(null),								// 18/08/2015 cnwmh5
								vessel.code,
								vessel.name,
								"",
								true,
/* PAR 33644								true,
								false,*/
								false,
								false,
								0,
								VoyageDisplayAlways,
								0,
								pxyVoyage.status,
								vessel.vesselType,
								null,
								arrivalDate,
								departureDate,
								pxyVoyage.loadStartDT,
								pxyVoyage.loadEndDT,
								null,
								null,
								null,
								null,
								getRoot.allOperators[_operatorName],
								trade,
								getRoot.allShippingLines[_shippingLine],
								self.getTerminal,
								pxyVoyage.myVoyageGlobalArrival,
								null,
								null,
								null,
								null,
								null,
								0,
								false,
								pxyVoyage.allOperators,
								pxyVoyage.allReceivalCutoffs,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,null,null,
								null,null,
								null,	//_generalLandingDate : Date	//14 Mar 2016	TFS 1407
								null,			// TFS 4050
								pxyVoyage.paymentType,
								pxyVoyage.isBarge,			//jlgka1 TFS 37102
								pxyVoyage.voyageGroupCode,   //03/06/2020 cnwma1 Tfs #49400
								false	// 31.Aug.2023 navsp1 TFS 57809
								);					
								
	if self.opts.includesKey("useHMSData") then
		useHMSData := self.opts.bool("useHMSData");
	endif;
	if useHMSData then
		berth := self.opts.obj("berth").HMS_Berth;
		create pxyHMSData transient;
		pxyHMSData.setPxyFromVessel(vessel, term);
		pxyHMSData.setMyBerth(berth);
		pxyVoyage.setHMSVoyageData(pxyHMSData);
		pxyHMSData.setProxyDefaultVoyageMovements(berth, null, app.myPassport);
	endif;

	// Set the Port Rotations from the Trade
	foreach portRotation in trade.allPortRotations do
		create pxyVoyagePortRotation transient;
		portRotation.allTranshipPorts.copy(pxyVoyagePortRotation.allTranshipPorts);
		pxyVoyagePortRotation.setProxy(portRotation.myPort, pxyVoyage);
		portRotationArray.add(pxyVoyagePortRotation);
	endforeach;
	
	//cnwmc5 - 3/12/2012 - add all the trade operators to the voyage
	trade.operators.copyNoDuplicates(pxyVoyage.allOperators, false);

	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreateVoyage(pxyVoyage, voyage, vessel, null, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	return voyage;
epilog

	delete pxyGeneralCargoStructure;
	delete pxyHMSData;
	foreach pxyVoyagePortRotation in portRotationArray do	
		delete pxyVoyagePortRotation;
	endforeach;
	delete portRotationArray;
	delete pxyVoyage;

	if global.isValidObject(pxyGlobalVoyage) then
		delete pxyGlobalVoyage;
	endif;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_operatorName" type="String"/>
        <Parameter name="_shippingLine" type="String"/>
        <Parameter name="_numberHatches" type="Integer"/>
        <Parameter name="_arrive" type="TimeStamp"/>
        <Parameter name="_depart" type="TimeStamp"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="addVoyageWithGeneralCargoStruc" id="f9cedafd-0874-48fc-a07f-406ff966a2c1">
        <source>addVoyageWithGeneralCargoStruc(_code : String; _vesselCode : String; _operatorName : String; _shippingLine : String; _numberHatches : Integer) : CM_Voyage;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		29 October 2009
//
// Implemented version: JMT 7.7.3
/****Changes

Date		Name	TFS#			Description
============================================================================
05/08/2011	cnwmh5					Change to use UT_UnitTest's opts
05/03/2015	cbwdap1	PAR #35826 
					CCMS SFW 1410 	Added expected arrival/departure date/time
11/04/2017	cnwdap1	TFS 4050 		LNX Job ID Enhancements
05/12/2018	jlgka1	TFS 37102		STWR - Add isBarges Flag.
============================================================================*/
vars
	useHMSData				 : Boolean;
	vessel					 : CM_Vessel;
	pxyVoyage				 : CM_Voyage; 
	voyage		 			 : CM_Voyage;
	pxyGeneralCargoStructure : CM_GeneralCargoVoyageStructure;
	now						 : TimeStamp;
	arrivalDate				 : TimeStamp; 
	departureDate 			 : TimeStamp;
	pxyGlobalVoyage			 : CM_VoyageGlobal;
	trade					 : CM_Trade;
	berth					 : HMS_Berth;
	pxyHMSData				 : HMS_VoyageData;
	pxyVoyagePortRotation	 : CM_PortRotation;
	portRotation			 : CM_PortRotation;
	term					 : CM_Terminal;
	portRotationArray		 : CM_PortRotationArray;								// 24/02/2014 cnwmh5 - Transient Leaks
begin
	self.deleteVoyage(_code);
	term := self.getTerminal();

	vessel := getRoot.allVessels[_vesselCode];
	self.assertNotNullMsg(vessel, "Vessel");                // 04/10/2013 cnwmh5
	 
	create portRotationArray transient;	
	
	trade := getTrade;
	
	create pxyVoyage transient;							

	create pxyGeneralCargoStructure transient;
	pxyVoyage.setProxyVoyageGeneralCargo(pxyGeneralCargoStructure);
	pxyGeneralCargoStructure.setProxyGCVoyage(_numberHatches);

	create pxyGlobalVoyage transient;
	pxyGlobalVoyage.setProxy(_code, _vesselCode, null, null, null, null, null, 0, null, app.myRoot);
	pxyVoyage.setMyVoyageGlobalArrival(pxyGlobalVoyage);
	
	arrivalDate.setDate(now.date());
	arrivalDate.setTime(now.time());
	departureDate := arrivalDate.addDays(2);

	pxyVoyage.setProxyVoyage(	null,
								"",
								_code,
								"",
								self.createdByUnitTest(null),								// 18/08/2015 cnwmh5
								vessel.code,
								vessel.name,
								"",
								true,
/* PAR 33644								true,
								false,*/
								false,
								false,
								0,
								VoyageDisplayAlways,
								0,
								pxyVoyage.status,
								vessel.vesselType,
								null,
								arrivalDate,
								departureDate,
								pxyVoyage.loadStartDT,
								pxyVoyage.loadEndDT,
								null,
								null,
								null,
								null,
								getRoot.allOperators[_operatorName],
								trade,
								getRoot.allShippingLines[_shippingLine],
								self.getTerminal,
								pxyVoyage.myVoyageGlobalArrival,
								null,
								null,
								null,
								null,
								null,
								0,
								false,									// 27/05/2009 cnwar2 CCMS1040
								pxyVoyage.allOperators,
								pxyVoyage.allReceivalCutoffs,		// 27/05/2009 cnwar2 CCMS1040
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,null,null,
								null,null,
								null,	//_generalLandingDate : Date	//14 Mar 2016	TFS 1407			
								null,			// TFS 4050
								pxyVoyage.paymentType,
								vessel.isBarge,  // ### TFS 51219 03JUN2021 NAVAB1 pxyVoyage.isBarge,	//jlgka1 TFS 37102
								pxyVoyage.voyageGroupCode,   //03/06/2020 cnwma1 Tfs #49400
								false	// 31.Aug.2023 navsp1 TFS 57809
								);					// PAR #35826
								
	if self.opts.includesKey("useHMSData") then
		useHMSData := self.opts.bool("useHMSData");
	endif;
	if useHMSData then
		berth := self.opts.obj("berth").HMS_Berth;
		create pxyHMSData transient;
		pxyHMSData.setPxyFromVessel(vessel, term);
		pxyHMSData.setMyBerth(berth);
		pxyVoyage.setHMSVoyageData(pxyHMSData);
		pxyHMSData.setProxyDefaultVoyageMovements(berth, null, app.myPassport);
	endif;

	// Set the Port Rotations from the Trade
	foreach portRotation in trade.allPortRotations do
		create pxyVoyagePortRotation transient;
		portRotation.allTranshipPorts.copy(pxyVoyagePortRotation.allTranshipPorts);
		pxyVoyagePortRotation.setProxy(portRotation.myPort, pxyVoyage);
		portRotationArray.add(pxyVoyagePortRotation);
	endforeach;
	
	//cnwmc5 - 3/12/2012 - add all the trade operators to the voyage
	trade.operators.copyNoDuplicates(pxyVoyage.allOperators, false);

	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreateVoyage(pxyVoyage, voyage, vessel, null, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	return voyage;
epilog

	// 24/02/2014 cnwmh5 - Transient Leaks
	delete pxyGeneralCargoStructure;
	delete pxyHMSData;
	if pxyVoyagePortRotation &lt;&gt; null then
		foreach pxyVoyagePortRotation in portRotationArray do	
			delete pxyVoyagePortRotation;
		endforeach;
	endif;
	delete portRotationArray;
	delete pxyVoyage;


	if global.isValidObject(pxyGlobalVoyage) then
		delete pxyGlobalVoyage; //cnwrs1 par23228 10 Mar 2010 now done in CM_Voayge setForCreate
	endif;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_operatorName" type="String"/>
        <Parameter name="_shippingLine" type="String"/>
        <Parameter name="_numberHatches" type="Integer"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="addVoyageWithInwardCode" id="3144d541-c6b2-44ba-9ce0-de72de13b7b6">
        <source>addVoyageWithInwardCode( _code : String; _inwardCode : String; _vesselCode : String; _operatorName : String; _shippingLine : String) : CM_Voyage;
/****Changes

Date		Name	TFS#			Description
============================================================================	
16/12/2008	cnwdw1	
29/07/2011	cnwmh5					Change to use UT_UnitTest.opts
05/03/2015	cnwdap1	PAR #35826 
					CCMS SFW 1410 	Added expected arrival/departure date/time
11/04/2017	cnwdap1	TFS 4050 		LNX Job ID Enhancements
05/12/2018	jlgka1	TFS 37102		STWR - Add isBarges Flag.
18/07/2024	navlw1	ChangeRequest   63839: NSW | OnePort - Uniqueness of Inward and External Code		
============================================================================*/

vars
	vessel				  : CM_Vessel;
	pxyVoyage			  : CM_Voyage;
	voyage				  : CM_Voyage;
	pxyCellStructure	  : CM_CellularVoyageStructure;
	now					  : TimeStamp;
	arrivalDate			  : TimeStamp;
	departureDate 		  : TimeStamp;
	pxyGlobalVoyage		  : CM_VoyageGlobal;
	trade				  : CM_Trade;
	pxyVoyagePortRotation : CM_PortRotation;
	portRotation		  : CM_PortRotation;
	portRotationArray	  : CM_PortRotationArray;								// 24/02/2014 cnwmh5 - Transient leaks
	externalCode		  : String;
	autoVoyageProcess,
	ignorePassportErrors  : Boolean;
begin
	vessel := getRoot.allVessels[_vesselCode];
	self.assertNotNullMsg(vessel, "Vessel");                // 04/10/2013 cnwmh5
	
	// navlw1 #63839
	if self.opts.includesKey(UT_OPTS_ExternalCode) then
		externalCode := self.opts.str(UT_OPTS_ExternalCode);
	endif;
	if self.opts.includesKey("AutoVoyageProcess") then
		autoVoyageProcess := self.opts.bool("AutoVoyageProcess");
	endif;
	if self.opts.includesKey("IgnorePassportErrors") then
		ignorePassportErrors := self.opts.bool("IgnorePassportErrors");
	endif;
	
	create portRotationArray transient;
	
	trade := getTrade;
	create pxyVoyage transient;							
	
	create pxyCellStructure transient;
	pxyVoyage.setProxyVoyageCellullStructure(pxyCellStructure);
	pxyCellStructure.setProxyCellularVoyage(vessel.myCellularVesselStructure.bridgeAfterBay,
											vessel.myCellularVesselStructure.isoHalfHeights,
											vessel.myCellularVesselStructure.use40Id,
											vessel.myCellularVesselStructure.useBayCellTierNumbering);
	
	create pxyGlobalVoyage transient;
	pxyGlobalVoyage.setProxy(	_code,
								_vesselCode,
								null,
								null,
								null,
								null,
								null,
								0,
								null,
								app.myRoot);
	
	pxyVoyage.setMyVoyageGlobalArrival(pxyGlobalVoyage);
	
	arrivalDate.setDate(now.date());
	arrivalDate.setTime(now.time());
	departureDate := arrivalDate.addDays(2);
	
	pxyVoyage.setProxyVoyage(	null,
								self.opts.str( ETRow_CallSign ),
								_code,
								_inwardCode,
								self.createdByUnitTest(null),											// 18/08/2015 cnwmh5
								vessel.code,
								vessel.name,
								self.opts.str( ETRow_LloydsNumber ),
								false,
/* PAR 33644								true,
								true, */
								false,
								false,
								0,
								VoyageDisplayAlways,
								0,
								pxyVoyage.status,
								vessel.vesselType,
								null,
								arrivalDate,
								departureDate,
								pxyVoyage.loadStartDT,
								pxyVoyage.loadEndDT,
								null,
								null,
								null,
								null,
								getRoot.allOperators[_operatorName],
								trade,
								getRoot.allShippingLines[_shippingLine],
								self.getTerminal,
								pxyVoyage.myVoyageGlobalArrival,
								null,
								null,
								null,
								null,
								null,
								0,
								false,									// 27/05/2009 cnwar2 CCMS1040
								pxyVoyage.allOperators,
								pxyVoyage.allReceivalCutoffs,		// 27/05/2009 cnwar2 CCMS1040
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,null,null,
								null,null,
								null,	//_generalLandingDate : Date	//14 Mar 2016	TFS 1407
								externalCode,
								pxyVoyage.paymentType,
								pxyVoyage.isBarge,		   //jlgka1 TFS 37102
								pxyVoyage.voyageGroupCode,  //03/06/2020 cnwma1 Tfs #49400
								false	// 31.Aug.2023 navsp1 TFS 57809
								);						

	// Set the Port Rotations from the Trade
	foreach portRotation in trade.allPortRotations do
		create pxyVoyagePortRotation transient;
		portRotation.allTranshipPorts.copy(pxyVoyagePortRotation.allTranshipPorts);
		pxyVoyagePortRotation.setProxy(portRotation.myPort, pxyVoyage);
		portRotationArray.add(pxyVoyagePortRotation);
	endforeach;
	
	//cnwmc5 - 3/12/2012 - add all the trade operators to the voyage
	trade.operators.copyNoDuplicates(pxyVoyage.allOperators, false);
	
	// navlw1 #63839
	if autoVoyageProcess then
		pxyVoyage.setVoyProcessFromTerm();
	endif;
	
	self.ignoreTrxWarnings(true);

	//app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreateVoyage(pxyVoyage, voyage, vessel, null, true, app.myPassport);
	
	// navlw1 #63839
	if ignorePassportErrors then
		return voyage;
	endif;
	
	self.assertNoTrxErrorsOrWarnings();
	return voyage;
epilog
	
	// 24/02/2014 cnwmh5 - Transient Leaks
	delete pxyCellStructure;
	foreach pxyVoyagePortRotation in portRotationArray do
		delete pxyVoyagePortRotation;
	endforeach;
	delete portRotationArray;
	delete pxyVoyage;
	
	if global.isValidObject(pxyGlobalVoyage) then
		delete pxyGlobalVoyage; //cnwrs1 par23228 10 Mar 2010 now done in CM_Voayge setForCreate
	endif;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_inwardCode" type="String"/>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_operatorName" type="String"/>
        <Parameter name="_shippingLine" type="String"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="addVoyageWorkPointQueue" id="5a69b46b-d24e-47cb-9411-2c7efba6ca6d">
        <source>addVoyageWorkPointQueue(_voyage: CM_Voyage input; _voyageQueue: CM_VoyageQueue input; _wp: CM_WorkPoint input) : CM_VoyageWorkPointQueue;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 January 2013	cnwrd1	Initial creation

*/

vars
	queue: CM_RadioTelemetryQueue;
begin
	self.deleteQueue(_voyageQueue.id &amp; ' ' &amp; _wp.code.trimBlanks);
	
	beginTransaction;
	//_wp.setPropertyValue(CM_WorkPoint::myPrimaryQueue.name, _voyageQueue);
	_voyageQueue.createWorkPointQueue(_wp, queue);
	commitTransaction;
	self.assertNoTrxErrorsOrWarnings();
	return queue.CM_VoyageWorkPointQueue;

epilog
	abortTransaction;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_voyageQueue" type="CM_VoyageQueue" usage="input"/>
        <Parameter name="_wp" type="CM_WorkPoint" usage="input"/>
        <ReturnType type="CM_VoyageWorkPointQueue"/>
    </JadeMethod>
    <JadeMethod name="addWPOpHrs" id="cdcb51fb-ecf5-4cb3-8cdb-4de5f4703e76">
        <source>addWPOpHrs( _voyage: CM_Voyage; _job : CM_VoyageJob; _doWPOpHrs : Integer );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	onBoardTS : TimeStamp;
	exchStartTS : TimeStamp;
	exchEndTS : TimeStamp;
	ashoresTS : TimeStamp;
	proxy : CM_WorkPointOperatingHours;
	wpOpHrs : CM_WorkPointOperatingHours;
	crane : CM_Crane;
	wp : CM_WorkPoint;
	user : CM_User;
begin

	onBoardTS := app.actualTimeServer;
	process.sleep(_doWPOpHrs);
	exchStartTS := app.actualTimeServer;
	process.sleep(_doWPOpHrs);
	process.sleep(_doWPOpHrs);
	exchEndTS := app.actualTimeServer;
	process.sleep(_doWPOpHrs);
	ashoresTS := app.actualTimeServer;
	
	crane := _job.myJobSheet.CM_VoyageJobSheet.getMyCrane;
	wp := _job.myJobSheet.CM_VoyageJobSheet.getMyWorkPoint;
	
	create proxy transient;
	proxy.setProxy(	exchStartTS,	//_exchangeStart : TimeStamp;
					exchEndTS,	//_exchangeEnd : TimeStamp;
					onBoardTS,	//_labourStart : TimeStamp;
					ashoresTS,	//_labourEnd : TimeStamp;
					"Unit Test generated data.",	//_remarks : String;
					crane,	//_myCrane : CM_Crane;
					wp,	//_myWorkPoint : CM_WorkPoint;
					_voyage,	//_myVoyage : CM_Voyage
					user
					);
					
	app.myTrxCA.trxCreateWpOperatingHrs( proxy, wpOpHrs, app.myPassport );

epilog

	delete proxy;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_job" type="CM_VoyageJob"/>
        <Parameter name="_doWPOpHrs" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addWagon" id="0369f563-6ea4-4a51-a6eb-1f339610bb30">
        <source>addWagon(_wagonCode, _wagonClassCode : String; _train : CM_Train) : CM_Wagon;
//09 July 2009	cnwmd1	
//04 Nov 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
vars
	proxyWagon, wagon : CM_Wagon;
	wagonClass : CM_WagonClass;
	railLine : CM_RailLine;
	terminal : CM_Terminal;
	ta : CM_TerminalArea;
	railArea : CM_Rail;
begin
	terminal := app.myPassport.myTerminal;
		foreach ta in terminal.allTerminalAreas do
		if ta.isKindOf(CM_Rail) then
			railArea := ta.CM_Rail;
			break;
		endif;
	endforeach;
	assertTrueMsg(railArea &lt;&gt; null , "No rail area");
	
	wagonClass := app.myRoot.allWagonClasses[_wagonClassCode];
	assertTrueMsg(wagonClass &lt;&gt; null, "Wagon Class does not exist");
	
	if self.opts.includesKey("RailLine") then						// 04/04/2014 cnwmh5
		railLine := self.opts.obj("RailLine").CM_RailLine;
	endif;	
	
	//create proxyWagon transient;
	create proxyWagon as wagonClass.getWagonVisitClassToCreate() transient;	//15 Mar 2013	NDL	Par 31278
	proxyWagon.setProxy(app.myPassport.myTerminal,
						_wagonCode,
						wagonClass,
						_train,
						_train,
						null,
						null,
						null,
						null,
						null,
						null,   //02.10.2020 cnwma1 TFS #50112
						null);  //02.10.2020 cnwma1 TFS #50112
						
	app.myTrxCA.trxCreateWagon(proxyWagon, wagon, railLine, null, null, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	return wagon;
epilog
	delete proxyWagon;
end;</source>
        <Parameter name="_wagonCode" type="String"/>
        <Parameter name="_wagonClassCode" type="String"/>
        <Parameter name="_train" type="CM_Train"/>
        <ReturnType type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="addWagonClass" id="67146f0c-1bf2-4faa-a48f-ae080ee2c0a9">
        <source>addWagonClass( classId : String ): CM_WagonClass;

/*

Purpose:			
				Creates a wagonclass called "ZZ" for testing.
				Please delete it with "deleteWagonClass" when finished.
Parameters:			

Return Value:		


Date		Who		Reason
09 July 2009	cnwndl1	Initial creation

*/

vars

	existingWagonClass : CM_WagonClass;
	loadState : Boolean;
	notAvailableForEntry : Boolean;
	
	wagonClass : CM_WagonClass;
	proxyWagonClass : CM_WagonClass;
	pLocationIds : StringArray;
	pConsigneeRestrictions	: CM_ConsignCodeArray;
	rule : CM_WagonPositionalRule;
	pxyRule : CM_WagonPositionalRule;
	pxyPosi : CM_WagonPosition;
	
	carrier					: CM_Carrier;
	maxLoadWeight : Decimal [12,2];
	maxPosiWeight : Decimal [12,2];
	maxPosiHeight : Decimal [12,2];
	deckHeight : Decimal [12,2];
	tareWeight : Decimal [12,2];	
	
	acceptsGenerator		: Boolean;
	doorsAccessible			: Boolean;
	wagonType : Integer;
	lenInUnits : Integer;
	intHeight : Decimal [6,2];	
	intLength : Decimal [6,2];
	intWidth : Decimal [6,2];
	extHeight : Decimal [6,2];
	extLength : Decimal [6,2];
	extWidth : Decimal [6,2];
	index : Integer;
	maxNumInStack : Integer;
	tierIds : StringArray;
	
	wellDef : CM_WagonWellDefinition;
	wellDeckHeight : Decimal [16,4];
	wellMaxCargoHeight : Decimal [16,4];
	wellCargoWeight : Decimal [16,4];
	wellTare : Decimal [16,4];
	wellLength : Decimal [16,4];
	wellWidth : Decimal [16,4];
	load : Boolean;
	pxy : CM_WagonWellDefinition;
	wellLocations : StringArray;
	string : String;
	pos : Integer;
	
	sealTypeStr : String;
	sealTypes : CM_SealTypeDict;
	sealType : CM_SealType;
		
begin

	//set up some default values.
	maxPosiWeight := 4100.00;
	maxPosiHeight := 300.00;
	deckHeight := 45.00;
	tareWeight := 5000.00;
	maxLoadWeight := 50000;
	notAvailableForEntry := false;
	maxNumInStack := 1;

	self.assertTrueMsg(classId.length &lt; 8, "Class ID value may be up to 7 characters long '" &amp; classId &amp; "' !!");
	
	existingWagonClass := app.myRoot.allWagonClasses.getAtKey(classId);

	self.assertTrueMsg(existingWagonClass = null, "Wagon class '" &amp; classId &amp; "' already exists !!");
	
	app.cmsBeginLoad(loadState);
	
	if self.opts.includesKey("AcceptsGenerator") then
		acceptsGenerator := self.opts.bool("AcceptsGenerator");
	endif;
	
	if self.opts.includesKey("DoorsAccessible") then
		doorsAccessible := self.opts.bool("DoorsAccessible");
	endif;
	
	if self.opts.includesKey("NotAvailableForEntry") then
		notAvailableForEntry := self.opts.bool("NotAvailableForEntry");
	endif;
	
	if self.opts.includesKey("LengthInUnits") then
		lenInUnits := self.opts.int("LengthInUnits");
	else
		lenInUnits := 8;
	endif;
	
	if self.opts.includesKey("WagonType") then
		wagonType := self.opts.int("WagonType");
	else
		wagonType := CM_WagonClass.Wagon_Flatcar;
	endif;
	
	if self.opts.includesKey("InternalHeight") then
		intHeight := self.opts.dec("InternalHeight");
	endif;
	if self.opts.includesKey("InternalLength") then
		intLength := self.opts.dec("InternalLength");
	endif;
	if self.opts.includesKey("InternalWidth") then
		intWidth := self.opts.dec("InternalWidth");
	endif;
	if self.opts.includesKey("ExternalHeight") then
		extHeight := self.opts.dec("ExternalHeight");
	endif;
	if self.opts.includesKey("ExternalLength") then
		extLength := self.opts.dec("ExternalLength");
	endif;
	if self.opts.includesKey("ExternalWidth") then
		extWidth := self.opts.dec("ExternalWidth");
	endif;
	
	if self.opts.includesKey("Tare") then
		tareWeight := self.opts.dec("Tare");
	endif;
	if self.opts.includesKey("MaxPosiWeight") then
		maxPosiWeight := self.opts.dec("MaxPosiWeight");
	endif;
	if self.opts.includesKey("MaxPosiHeight") then
		maxPosiHeight := self.opts.dec("MaxPosiHeight");
	endif;
	if self.opts.includesKey("DeckHeight") then
		deckHeight := self.opts.dec("DeckHeight");
	endif;
	if self.opts.includesKey("MaxLoadWeight") then
		maxLoadWeight := self.opts.dec("MaxLoadWeight");
	endif;
	
	if self.opts.includesKey("SealType") then
		sealTypeStr := self.opts.str("SealType");
		if sealTypeStr &lt;&gt; null then
			sealType := app.myRoot.allSealTypes.getAtKey(sealTypeStr);
			if sealType &lt;&gt; null then
				create sealTypes transient;
				sealTypes.add(sealType);
			endif;
		endif;
	endif;
	
	if self.opts.includesKey("Carrier") then
		carrier := self.opts.obj("Carrier").CM_Carrier;
	endif;
	if wagonType = CM_WagonClass.Wagon_Flatcar or wagonType = CM_WagonClass.Wagon_Wellcar then
		if self.opts.includesKey("MaxNumInStack") then
			maxNumInStack := self.opts.int("MaxNumInStack");
		endif;
	endif;
	
	create proxyWagonClass transient;
	create pConsigneeRestrictions transient;
	create pLocationIds transient;

	if wagonType = CM_WagonClass.Wagon_Wellcar then
		pLocationIds.add("A");
		if lenInUnits = 8 then
			pLocationIds.add("B");
		elseif lenInUnits = 12 then
			pLocationIds.add("C");
			pLocationIds.add("B");
		elseif lenInUnits =16 then
			pLocationIds.add("C");
			pLocationIds.add("D");
			pLocationIds.add("B");
		elseif lenInUnits = 20 then
			pLocationIds.add("C");
			pLocationIds.add("D");
			pLocationIds.add("E");
			pLocationIds.add("B");
		endif;
		if maxNumInStack = 2 then
			create tierIds transient;
			if self.opts.includesKey("TierIds") then
				string := self.opts.str("TierIds").String;
				foreach pos in 1 to string.length do
					tierIds.add(string[pos]);
				endforeach;
			else
				tierIds.add("B");
				tierIds.add("A");
			endif;
		endif;

		create wellLocations transient;
		wellLocations.add("1");
		wellLocations.add("2");
		wellLocations.add("3");
		wellLocations.add("4");
	else
		foreach index in 1 to lenInUnits do
			pLocationIds.add(index.String);
		endforeach;
	endif;

	proxyWagonClass.setProxy(	classId,	//pCode : String;
								acceptsGenerator,	//pAcceptsGenerator : Boolean;
								doorsAccessible,	//pDoorsAccessible : Boolean;
								notAvailableForEntry,	//isNotAvailableForEntry : Boolean; 
								maxLoadWeight,	//pMaxLoadWeight : Integer;
								maxNumInStack,	//pMaxNumInStack : Integer;
								lenInUnits,	//pLenInUnits : Integer;
								pLocationIds,	//pLocationIds : StringArray;
								pConsigneeRestrictions,	//pConsigneeRestrictions : CM_ConsignCodeArray;
								deckHeight,	//pDeckHeight : Decimal;
								maxPosiHeight,	//pMaxCargoHeight : Decimal;
								tareWeight,	//pTareWeight : Decimal;
								carrier,	//pMyCarrier : CM_Carrier
								intHeight,	//pInternalHeight : Decimal;	//18 Mar 2013	NDL	Par 31278
								intLength,	//pInternalLength : Decimal;	//18 Mar 2013	NDL	Par 31278
								intWidth,	//pInternalWidth : Decimal;	//18 Mar 2013	NDL	Par 31278
								extHeight,	//pOverallHeight : Decimal;	//18 Mar 2013	NDL	Par 31278
								extLength,	//pOverallLength : Decimal;	//18 Mar 2013	NDL	Par 31278
								extWidth,	//pOverallWidth : Decimal;	//18 Mar 2013	NDL	Par 31278
								wagonType,	//pWagonType : Integer;
								tierIds,		//pTierIds : StringArray;
								sealTypes,	//pSealTypes : CM_SealTypeDict	//10 Mar 2015	NDL	Par 35828
								CM_BoxcarVisit.BoxcarGraphicBreakBulk // TFS 49523
								);
								
	app.myTrxCA.trxCreateWagonClass(proxyWagonClass, wagonClass, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

	if wagonClass &lt;&gt; null and wagonType = CM_WagonClass.Wagon_Flatcar then
		create pxyRule transient;
		pxyRule.setProxy(	proxyWagonClass,	//_myWagonClass : CM_WagonClass;
							4,	//_numberOfPositions : Integer;
							null	//_allWagonPositions : CM_WagonPositionDict
							);
							
		foreach pxyPosi in pxyRule.allWagonPositions do
			pxyPosi.setProxy(	20,	//_cargoLength : Integer;
								45,	//_deckHeight : Decimal;
								maxPosiWeight,	//_maxWeight : Decimal;
								pxyPosi.position,	//_position : Integer;
								pxyRule	//_myWagonPositionalRule : CM_WagonPositionalRule
								);
		endforeach;
	
		app.myTrxCA.trxCreateWagonPositionalRule( pxyRule, rule, app.myPassport );
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
		
	elseif wagonClass &lt;&gt; null and wagonType = CM_WagonClass.Wagon_Wellcar then
	
		if self.opts.includesKey("WellDeckHeight") then
			wellDeckHeight := self.opts.dec("WellDeckHeight");
		else
			wellDeckHeight := deckHeight;
		endif;
		if self.opts.includesKey("WellMaxCargoHeight") then
			wellMaxCargoHeight := self.opts.dec("WellMaxCargoHeight");
		else
			wellMaxCargoHeight := maxPosiHeight;
		endif;
		if self.opts.includesKey("WellCargoWeight") then
			wellCargoWeight := self.opts.dec("WellCargoWeight");
		else
			wellCargoWeight := maxLoadWeight / pLocationIds.size;
		endif;
		if self.opts.includesKey("WellTare") then
			wellTare := self.opts.dec("WellTare");
		else
			wellTare := tareWeight / pLocationIds.size;
		endif;
		if self.opts.includesKey("WellLength") then
			wellLength := self.opts.dec("WellLength");
		endif;
		if self.opts.includesKey("WellWidth") then
			wellWidth := self.opts.dec("WellWidth");
		endif;
		
		foreach wellDef in wagonClass.allWagonWellDefArray do
			app.cmsBeginLoad(load);
			pxy := wellDef.pxyCreateUpdateProxy();
			app.cmsEndLoad(load);
			
			pxy.setProxy(	wellDeckHeight,	//_deckHeight : Decimal;			
							wellLocations.size,	//_lenInUnits : Integer;
							wellMaxCargoHeight,	//maxCargoHeight : Decimal;
							wellCargoWeight,	//_maxLoadWeight : Decimal;
							wellLength,	//_overallLength : Decimal;
							wellWidth,	//_overallWidth : Decimal;
							wellTare,	//_tareWeight : Decimal;
							pxy.wellId,	//_wellId : String;
							wellLocations	//_wellLocations : StringArray
							);
			app.myTrxUA.trxUpdateWagonWellDef(pxy, app.myPassport);
			self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
			delete pxy;
		endforeach;
		
	endif;
	
	self.assertTrueMsg(wagonClass &lt;&gt; null, "Wagon Class not created!");
	
	return wagonClass;
						
epilog

	app.cmsEndLoad(loadState);
	delete proxyWagonClass;
	delete pConsigneeRestrictions;
	delete pLocationIds;
	delete tierIds;
	delete pxy;
	delete wellLocations;
	delete sealTypes;
	
end;</source>
        <Parameter name="classId" type="String"/>
        <ReturnType type="CM_WagonClass"/>
    </JadeMethod>
    <JadeMethod name="addWagonInRailArea" id="23f1779d-c949-4c38-93cb-13b3778e1b2d">
        <source>addWagonInRailArea(_wagonCode, _wagonClassCode : String; _railArea : CM_Rail;  _train : CM_Train) : CM_Wagon;
//02 November 2009	cnwjo3	
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 22/08/2024   navsp1  TFS Bug 64805: EUP | FR 54536 - Damage and Repair - Field Corrections
vars
	proxyWagon, wagon : CM_Wagon;
	wagonClass : CM_WagonClass;
	//railLine : CM_RailLine;
	terminal : CM_Terminal;
	ta : CM_TerminalArea;
	railArea : CM_Rail;
	
	wagonUpdateCtrl : CMIF_WagonUpdateController;
	ls : Boolean;  //what do i do?
	carrier : CM_Carrier;	//TFS 64805
begin
	app.cmsBeginLoad(ls);
	create wagonUpdateCtrl transient;
	
	terminal := app.myPassport.myTerminal;
	railArea := _railArea;
	assertTrueMsg(railArea &lt;&gt; null , "No rail area");
	
	wagonClass := app.myRoot.allWagonClasses[_wagonClassCode];
	assertTrueMsg(wagonClass &lt;&gt; null, "Wagon Class does not exist");
	
	if self.opts.includesKey("CarrierObj") then				//TFS 64805
		carrier := self.opts.obj("CarrierObj").CM_Carrier;	//TFS 64805	
	endif;													//TFS 64805
	
//	create proxyWagon transient;
	create proxyWagon as wagonClass.getWagonVisitClassToCreate() transient;	//15 Mar 2013	NDL	Par 31278
	proxyWagon.setProxy(app.myPassport.myTerminal,
						_wagonCode,
						wagonClass,
						_train,
						_train,
						null,
						null,
						null,
						null,
						carrier,	//TFS 64805
						null,
						null);
	
	wagonUpdateCtrl.myProxyWagon := proxyWagon;
	
	if self.opts.includesKey("RailLine") then								// 14/04/2014 cnwmh5
		wagonUpdateCtrl.setPropertyValue("myRailLine", self.opts.obj("RailLine").CM_RailLine);
	endif;
	
	app.cmsEndLoad(ls);

	//i have to set the myProxyWagon at some point too :-(
	
	//we don't use CreateWagon.  we are using CreateWagonCMIF
	//app.myTrxCA.trxCreateWagon(proxyWagon, wagon, railLine, null, null, app.myPassport);
	wagonUpdateCtrl.isTrainMode := true;
	wagonUpdateCtrl.mode := 1; //Mode_Add;  //nice
	app.myTrxCA.trxCreateWagonFromCMIF(wagonUpdateCtrl, wagon, false, app.myPassport);
	
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	return wagon;
epilog
	app.cmsEndLoad(ls);					// 08/04/2011 cnwmh5 #27347
	delete proxyWagon;
	delete wagonUpdateCtrl;
end;</source>
        <Parameter name="_wagonCode" type="String"/>
        <Parameter name="_wagonClassCode" type="String"/>
        <Parameter name="_railArea" type="CM_Rail"/>
        <Parameter name="_train" type="CM_Train"/>
        <ReturnType type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="addWagonToTrainOption2" id="e3a3b2fa-c0e3-4554-a717-fd1d6434e143">
        <source>addWagonToTrainOption2( train           : CM_Train;	// mandatory
						wagonMaster     : CM_WagonMaster;	// mandatory
						allTrackedItems : CM_TIByIdDups;	//optional (containing as many 20 foot containers as will fit on the wagon)
						makeInTransit   : Boolean
						)			    : CM_Wagon;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Jul 2009	cnwndl1	Initial creation
02 Oct 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
*/

vars
	
	wagonUpdateCtrl : CMIF_WagonUpdateController;
	wagonLength     : Integer;
	tiArraySize     : Integer;
	ti 			    : CM_TrackedItem;
	pos 		    : Integer;
	wagonPosition   : CMIF_TIWagonPosition;
	tiArray 	    : CM_TIArray;
	proxyWagon      : CM_Wagon;
	wagon 		    : CM_Wagon;
	railLine 	    : CM_RailLine;
begin
	
	railLine := self.opts.obj("RailLine").CM_RailLine;
	
	// create Wagon on Train from WagonMaster, adds containers to wagon.
	create  wagonUpdateCtrl transient;	
	wagonUpdateCtrl.setBasicDetails(	CMIF_WagonUpdateController.Mode_Add,	//_mode : Integer;
										railLine,	//_rake : CM_RailLine;
										train,	//_train : CM_Train;
										train.allWagonsByIdInward.size + 1,	//_wagonPosition : Integer
										true//_trainMode : Boolean
										);
	
	if wagonMaster.myWagonClass &lt;&gt; null then
		wagonLength := wagonMaster.myWagonClass.getLenInUnits;
	else
		wagonLength := 8;	// default value
	endif;
	
	if allTrackedItems &lt;&gt; null then
		self.assertTrueMsg(( allTrackedItems.size * 2 ) &lt;= wagonLength, "Too many ti's for wagon");
	endif;
	
	create tiArray transient;
	if allTrackedItems &lt;&gt; null and not allTrackedItems.isEmpty then
		foreach ti in allTrackedItems do
			if ti.cargoType = TI_CargoType_Container then
				self.assertTrueMsg(ti.getActualLength = 20, "Container wrong size for this method, must be a 20 footer");
			endif;
			tiArray.add(ti);
			tiArray.add(ti);
		endforeach;
	endif;
	tiArraySize := tiArray.size;
	
	//09 Feb 2011	NDL	To fix up test after Par 26899 changes
	foreach ti in tiArray do
		beginTransaction;
		ti.changeState(TI_STATE_NOTIFIED, app.myPassport);
		if makeInTransit then
			ti.setImExStatus( TI_IMEX_STATUS_REMAINONBOARD);
		endif;
		commitTransaction;
	endforeach;
	
	foreach pos in 1 to wagonLength do
		create wagonPosition transient;
		wagonUpdateCtrl.allWagonPositions.add(wagonPosition);
		wagonPosition.position := pos;
		wagonPosition.available := true;
		wagonPosition.hasTwistLocks := true;
		wagonPosition.twistLocksAreUp := false;
		if tiArraySize &gt;= pos then
	//		wagonPosition.trackedItemId := tiArray[pos].id;
			if pos.isOdd then
			//	wagonPosition.myTrackedItem := tiArray[pos];
				//14 Oct 2014	NDL	Par 35040
				if tiArray[pos] &lt;&gt; null then
					wagonPosition.allTrackedItems.add(tiArray[pos]);
				endif;
			endif;
		endif;
	endforeach;
	
	if allTrackedItems &lt;&gt; null then
		allTrackedItems.copy(wagonUpdateCtrl.allTrackedItems);
	endif;
	
//	create proxyWagon transient;
	if wagonMaster.myWagonClass = null then	//22 Mar 2013	NDL	Par 31278
		create proxyWagon as app.getWagonVisitClassToCreate( null, train.myTerminal, wagonMaster.id, null )  transient;//22 Mar 2013	NDL	Par 31278
	else
		create proxyWagon as wagonMaster.myWagonClass.getWagonVisitClassToCreate() transient;	//15 Mar 2013	NDL	Par 31278
	endif;
	wagonUpdateCtrl.myProxyWagon := proxyWagon;
	
	proxyWagon.setProxy(train.myTerminal,			//_term			: CM_Terminal;
						wagonMaster.id,				//_id 			: String;
						wagonMaster.myWagonClass,	//_class 			: CM_WagonClass;
						train,						//_train			: CM_Train;
						train,						//_outTrain		: CM_Train;
						null,						//_remark 		: String;
						wagonMaster.maxCargoHeight,	//_maxCargoHeight	: Decimal; 
						wagonMaster.maxCargoWeight,	//_maxCargoWeight	: Decimal;
						wagonMaster.tareWeight,		//_tareWeight		: Decimal;
						wagonMaster.myCarrier,		//_carrier		: CM_Carrier
						null,                  		//02.10.2020 cnwma1 TFS #50112
						null                    	//02.10.2020 cnwma1 TFS #50112
						);
	
	if app.getMyTerminalConfigDO_NOT_USE(UseOutwardRailConfirm).Boolean then
		wagonUpdateCtrl.unconfirmWagonOutwards := true;
	endif;	
	wagonUpdateCtrl.doAutoPlan := true;
	wagonUpdateCtrl.unconfirmWagonInwards := true;
	
	app.myPassport.clearErrorsWarnings;
	self.ignoreTrxWarnings(true);
		
	app.myTrxCA.trxCreateWagonFromCMIF(wagonUpdateCtrl, wagon, false, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertTrueMsg(wagon &lt;&gt; null, "Wagon '" &amp; wagonMaster.id &amp; "' not created.");
	
epilog

	if not wagonUpdateCtrl.allWagonPositions.isEmpty then
		wagonUpdateCtrl.allWagonPositions.purge;
	endif;
	delete wagonUpdateCtrl;
	delete tiArray;
	delete proxyWagon;
	
	return wagon;
	
end;</source>
        <Parameter name="train" type="CM_Train"/>
        <Parameter name="wagonMaster" type="CM_WagonMaster"/>
        <Parameter name="allTrackedItems" type="CM_TIByIdDups"/>
        <Parameter name="makeInTransit" type="Boolean"/>
        <ReturnType type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="addWagonToTrainOption3" id="d92ede70-00bb-40d6-9de1-4c67745f256d">
        <source>addWagonToTrainOption3(	_train : CM_Train;	// mandatory
						_wagonId : String;
						_wagonClass : CM_WagonClass;
						_ti : CM_TrackedItem input;	//optional (One 20 foot container)
						_ignoreWarnings : Boolean;
						_makeIntransit : Boolean
						) : CM_Wagon;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Jul 2009	cnwndl1	Initial creation
02 Oct 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
*/

vars

	wagonUpdateCtrl : CMIF_WagonUpdateController;
	pos : Integer;
	wagonPosition : CMIF_TIWagonPosition;
	proxyWagon : CM_Wagon;
	wagon : CM_Wagon;

begin
	// create Wagon ( WagonMaster s/be created automatically )
	
	create  wagonUpdateCtrl transient;	
	wagonUpdateCtrl.setBasicDetails(	CMIF_WagonUpdateController.Mode_Add,	//_mode : Integer;
										null,	//_rake : CM_RailLine;
										_train,	//_train : CM_Train;
										_train.allWagonsByIdOutward.size + 1,	//_wagonPosition : Integer
										true//_trainMode : Boolean
										);
	
	self.assertTrueMsg(_wagonClass.getLenInUnits &gt;= 2, "Wagon class length in units too short.");
	
	foreach pos in 1 to _wagonClass.getLenInUnits do
		create wagonPosition transient;
		wagonUpdateCtrl.allWagonPositions.add(wagonPosition);
		wagonPosition.position := pos;
		wagonPosition.available := true;
		wagonPosition.hasTwistLocks := true;
		wagonPosition.twistLocksAreUp := false;
		if _ti &lt;&gt; null then
			if pos = 1 then
			//	wagonPosition.myTrackedItem := _ti;
				wagonPosition.allTrackedItems.add(_ti);	//14 Oct 2014	NDL	Par 35040
				
		//		wagonPosition.trackedItemId := _ti.id;
		//	elseif pos = 2 then
		//		wagonPosition.trackedItemId := _ti.id;
			endif;
		endif;
	endforeach;
	
	if _ti &lt;&gt; null then
		wagonUpdateCtrl.allTrackedItems.add(_ti);
		
		//09 Feb 2011	NDL	To fix up test after Par 26899 changes
		beginTransaction;
		_ti.changeState(TI_STATE_NOTIFIED, app.myPassport);
		if _makeIntransit then
			_ti.setImExStatus( TI_IMEX_STATUS_REMAINONBOARD);
		endif;
		commitTransaction;
	
	endif;
	
	//create proxyWagon transient;	
	
	//wagonUpdateCtrl.isTrainMode := true; 
	create proxyWagon as _wagonClass.getWagonVisitClassToCreate() transient;	//15 Mar 2013	NDL	Par 31278
	wagonUpdateCtrl.myProxyWagon := proxyWagon;
	proxyWagon.setProxy(_train.myTerminal,			//_term			: CM_Terminal;
						_wagonId,					//_id 			: String;
						_wagonClass,				//_class 			: CM_WagonClass;
						_train,						//_train			: CM_Train;
						_train,						//_outTrain		: CM_Train;
						null,						//_remark 		: String;
						_wagonClass.maxCargoHeight,	//_maxCargoHeight	: Decimal; 
						_wagonClass.maxLoadWeight,	//_maxCargoWeight	: Decimal;
						_wagonClass.tareWeight,  	//_tareWeight		: Decimal;
						_wagonClass.myCarrier,	   //_carrier		: CM_Carrier
						null,                      //02.10.2020 cnwma1 TFS #50112
						null
						);                     //02.10.2020 cnwma1 TFS #50112 
	
	if app.getMyTerminalConfigDO_NOT_USE(UseOutwardRailConfirm).Boolean then
		wagonUpdateCtrl.unconfirmWagonOutwards := true;
	endif;	
	wagonUpdateCtrl.doAutoPlan := true;
	wagonUpdateCtrl.unconfirmWagonInwards := true;
	
	self.ignoreTrxWarnings(_ignoreWarnings);
	//app.myPassport.setWarningsIgnored(_ignoreWarnings);
	app.myTrxCA.trxCreateWagonFromCMIF(wagonUpdateCtrl, wagon, false, app.myPassport);	
	if _ignoreWarnings then
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	endif;
	
epilog

	if not wagonUpdateCtrl.allWagonPositions.isEmpty then
		wagonUpdateCtrl.allWagonPositions.purge;
	endif;
	delete wagonUpdateCtrl;
	delete proxyWagon;
	
	return wagon;
end;</source>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_wagonId" type="String"/>
        <Parameter name="_wagonClass" type="CM_WagonClass"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_ignoreWarnings" type="Boolean"/>
        <Parameter name="_makeIntransit" type="Boolean"/>
        <ReturnType type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="addWaypoint" id="df8b405e-c1d9-4749-94d4-e504a27edd43">
        <source>addWaypoint(_waypointCode, _waypointDesc : String; _harbour : HMS_Harbour; _preferredBerth : HMS_Berth) : HMS_HarbourRegion;

/*

Purpose:		Add a WayPoint

Date			Who		Reason
12/01/2012		cnwmh5	Initial creation
*/

vars

	pxyWaypoint			: HMS_HarbourRegion;
	waypoint			: HMS_Object;
	restriction			: HMS_CheckPoint;
	terminal			: CM_Terminal;
	
	allCheckPoints 		: HMS_CheckPointByTypeDict;

begin

	self.deleteWaypoint(_waypointCode);

	create allCheckPoints transient;

	// Get any checkpoints (restrictions)
	if self.opts.includesKey("Restriction-UserHookCode") then
		restriction := app.myRoot.allHMSCheckpoints[self.opts.str("Restriction-UserHookCode")];
		if restriction &lt;&gt; null then
			allCheckPoints.add(restriction);
		endif;
	endif;
	if self.opts.includesKey("Restriction-Height") then
		restriction := app.myRoot.allHMSCheckpoints[self.opts.str("Restriction-Height")];
		if restriction &lt;&gt; null then
			allCheckPoints.add(restriction);
		endif;
	endif;
	if self.opts.includesKey("Restriction-TideState") then
		restriction := app.myRoot.allHMSCheckpoints[self.opts.str("Restriction-TideState")];
		if restriction &lt;&gt; null then
			allCheckPoints.add(restriction);
		endif;
	endif;
	if self.opts.includesKey("Terminal") then
		terminal := self.opts.obj("Terminal").CM_Terminal;
	endif;
	
	create pxyWaypoint transient;
	pxyWaypoint.setProxy(app.myRoot,  
						 _harbour,  
						 terminal,									// terminal
						 _preferredBerth,
						 allCheckPoints);
						 
	pxyWaypoint.setPropertyValue("code", _waypointCode);
	pxyWaypoint.setPropertyValue("description", _waypointDesc);
	if self.opts.includesKey("CanWaitHere") then
		pxyWaypoint.setPropertyValue("canWaitHere", self.opts.bool("CanWaitHere"));
	endif;
	
	app.myTrxCA.trxCreateHMSObject(pxyWaypoint, waypoint, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
		
	
	return waypoint.HMS_HarbourRegion;

epilog

	delete pxyWaypoint;
	delete allCheckPoints;
	
end;</source>
        <Parameter name="_waypointCode" type="String"/>
        <Parameter name="_waypointDesc" type="String"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_preferredBerth" type="HMS_Berth"/>
        <ReturnType type="HMS_HarbourRegion"/>
    </JadeMethod>
