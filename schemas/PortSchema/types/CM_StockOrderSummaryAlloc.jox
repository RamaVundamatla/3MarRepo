    <JadeMethod name="allocQuantity" id="4c35a71e-21d0-4926-ac21-2258dc8c83c2">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>allocQuantity(set: Boolean; _value: Decimal io) updating, mapping;
//-----------------------------------------
//Created: December 2002 By: cnwgd1
//-----------------------------------------
vars
	vol,
	lineQty	: Decimal[16,4];
begin
	
	//This was causing a double up
	if (not set) 
	and self.allocType = self.AllocType_Quantity then
		lineQty := self.myStockOrderSummary.calLineAllocRemAll(self.mySOHLocation);
		vol := self.mySOHLocation.currentVolume;
		if lineQty &lt; vol then 
			//Nothing added as all or remaining so return the set quantity
			inheritMethod(set, _value);	
		endif;
		if lineQty = vol then // PAR 11719 amount allocated matches the locations volume
			_value := lineQty;
		elseif _value &lt;&gt; vol then // not all allocated to orders
			_value := _value + lineQty;
		endif;
	else
		inheritMethod(set, _value);					
	endif;			

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="calAllocatedSoFar" id="db851405-bb8e-409e-b255-77603b359ea4">
        <source>calAllocatedSoFar() : Real;
//--------------------------------------------------------------
//Created: 09 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	return self.mySOHLocation.calAllocatedForSummary(self);
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="calLineAllocations" id="06b3dc15-688c-4158-9600-0209ded88801">
        <source>calLineAllocations() : Real;
//--------------------------------------------------
// Created:	08 July 2004 By: cnwgd1
//--------------------------------------------------
vars
	lineAllocation	: CM_StockOrderLineAlloc;
	numAllocated	: Decimal[16,4];
	
begin

	foreach lineAllocation in self.allStockOrderLineAllocations do
		numAllocated := numAllocated + lineAllocation.allocQuantity; 
	endforeach;
	
	return numAllocated;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="erase" id="d942b13c-79a5-4e7d-b198-4bd802a47a8d">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//--------------------------------------------------------------
//Created: 03 December 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	/*allocation 	: CM_StockOrderAllocation;
	tmpSummary	: CM_StockOrderSummaryAlloc;
	allocSet	: CM_StockOrderAllocationSet;*/
	lineAlloc	: CM_StockOrderLineAlloc;	
begin

	/*create allocSet transient;
	
	foreach allocation in self.myStockOrderHeader.allStockOrderAllocations do
		if allocation.isKindOf(CM_StockOrderLineAlloc) then
			lineAlloc := allocation.CM_StockOrderLineAlloc;
			tmpSummary := lineAlloc.myStockOrderLine.myStockOrderSummary.getSummaryAllocationObject(lineAlloc.mySOHLocation);
			if tmpSummary = self then
				allocSet.add(lineAlloc);
			endif;
		endif;
	endforeach;

	//Delete the associated line allocations
	allocSet.purge();*/
	
	foreach lineAlloc in self.allStockOrderLineAllocations do
		global.causeEvent(LogVoyageOps_Update_Event, false, lineAlloc.myStockOrderLine);
	endforeach;
	self.allStockOrderLineAllocations.purge();
	
	inheritMethod(_eraseLevel);
	
/*epilog
	delete allocSet;*/
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllocQtyDisplayStrForOrder" id="700ec0d1-5961-49a4-9fc8-48cde01d7396">
        <source>getAllocQtyDisplayStrForOrder(_order : CM_StockOrderLine):String;
//--------------------------------------------------
// Created:	19 July 2004 By: cnwgd1
//--------------------------------------------------
vars
	allocation 	: CM_StockOrderLineAlloc;
begin
	foreach allocation in self.allStockOrderLineAllocations do
		if allocation.myParent = _order then
			if allocation.allocType = self.AllocType_Quantity then
				return allocation.allocQuantity.asStringJMTWithPrecision($CM_Decimal3LeadingZero.decimalPlaces, true).String;
			else
				return allocation.allocTypeString;
			endif;
// changed as wanted decimal places shown.
//			return allocation.getAllocQuantityDisplayStr();
		endif;
	endforeach;
	return null;	
end;</source>
        <Parameter name="_order" type="CM_StockOrderLine"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoLogVoyOps" id="60ef8763-2f02-423c-8846-bf19688eb0a4">
        <source>getExtraInfoLogVoyOps(_array : HugeStringArray input; _terminalForTerminology : CM_Terminal);
//--------------------------------------------------------------
//Created: 07 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
	inheritMethod(_array, _terminalForTerminology);
	if self.myStockOrderSummary &lt;&gt; null then
		self.myStockOrderSummary.getExtraInfoLogVoyOps(_array, _terminalForTerminology);
	endif;
end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
        <Parameter name="_terminalForTerminology" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getOrderID" id="a0df322e-c2be-4233-9fce-04aa19f1d032">
        <source>getOrderID(): String;
//--------------------------------------------------
// Created:	13 December 2004 By: cnwgd1
//--------------------------------------------------
vars
	rtnStr : String;
	tmpOrderSummary : CM_StockOrderSummary;
begin
	
	tmpOrderSummary := self.myStockOrderSummary;
	if tmpOrderSummary &lt;&gt; null then
		rtnStr := tmpOrderSummary.myVoyage.code &amp; ' ' &amp; tmpOrderSummary.myOperator.code &amp;' '&amp; tmpOrderSummary.myProduct.code;
	endif;
	return rtnStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
