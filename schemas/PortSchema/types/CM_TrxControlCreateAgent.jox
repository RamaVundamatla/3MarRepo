    <JadeMethod name="trxEDICreateBulkRelease" id="25526930-cb75-48ac-999f-004181f9a9c6">
        <updating/>
        <source>trxEDICreateBulkRelease(_cmifRelease :CMIF_EDIReleaseRequest; _newRelease :CM_BulkRelease output; _validateOnly : Boolean; _passport :CM_Passport input) updating;
// ----------------	-----------------------------------------------------------
// Created:     15 December 2011
//
// Purpose:     CCMS POL 2122 par 28696
//
// ---------------------------------------------------------------------------
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/02/2012	cnwcs5	par 28756 - change to use utlCreateBulkRelease instead of utlCreateBulkRelease_CMIF (cmif_booking parameter was always null
// 25/07/0213	cnwcs5	CCMS POL 2221 / par 32094 - use CM_EDITrackedItem constants, Set status for all EDI TIs. Changed parameters
//11 Jul 2014	cnwrs1	Par 34566 CCMS 2346 Suzano - Viagram Prenote file 
// 18 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 20/07/2023	navdap1	TFS 58923 EUP CallOff EDI Data Type / Data Load
// 15/07/2025	navcs2	35210 Add Deferred Updates for WO Transaction During Transport Manifest and Call-Off Loading to Reduce Deadlocks
// 20/08/2025   navma1	MTN-35690 MTN - Object Not Found exception when db loding a Release Request.
// ---------------------------------------------------------------------------
vars
	ediTI		: CM_EDITrackedItem;
	newStatus	: Integer;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	
	// Set to use deffered updates
	_passport.useTITransactionDeferUpdate := true;							// 15/07/2025	navcs2	MTN-35210
	_passport.useWOTransactionDeferUpdate := true;							// 15/07/2025	navcs2	MTN-35210
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;
	
	if _validateOnly then													//20.08.2025 navma1 #MTN-35690
		app.myPassport.setPassportEdiMode(CM_Passport.EDI_MODE_VERIFY);		
	endif;
	
	_passport.setWarningsIgnored(true);
	app.myUtilityCA.utlCreateBulkRelease(_cmifRelease.myBulkRelease, _newRelease, null, null, null, _cmifRelease, _passport);	// TFS 58923
	
	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors then
			foreach ediTI in _cmifRelease.allEDITIs do
				ediTI.setStatus(CM_EDITrackedItem.EDI_STATUS_DBLOADED); 
			endforeach;
		else 
			// no point seetin status for failed ones as the trx will be aborted
		endif;
	endif;
epilog
	if _passport.noErrors() then				// 15/07/2025	navcs2	MTN-35210
		_passport.doDeferredUpdates();			// 15/07/2025	navcs2	MTN-35210	
	endif;										// 15/07/2025	navcs2	MTN-35210
	
	self.finaliseActivityWithPassport(_passport);
end;
</source>
        <Parameter name="_cmifRelease" type="CMIF_EDIReleaseRequest"/>
        <Parameter name="_newRelease" type="CM_BulkRelease" usage="output"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxImportCalcType" id="18b69ca5-d02b-4b0a-a7b1-985f9af77338">
        <updating/>
        <source>trxImportCalcType(_jadeXMLElement : JadeXMLElement input; _proxyArray : ObjectArray input; 
					   _errorStore : CM_ErrorSet input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
Aug 2016	cnwjre1	Copy calculation types between systems

*/

vars
	xmlNode			: JadeXMLNode;
	xmlElement		: JadeXMLElement;
	childNode		: JadeXMLNode;
	childElement	: JadeXMLElement;
	iter			: Iterator;
	index			: Integer;
	code, description		: String;
	notAvailableForEntry	: Boolean;
	calcType		: Integer;
	weightToUse		: Integer;
	weightToUseStr	: String;
	hoursFree		: Decimal[10, 2];
	hoursMax		: Decimal[10,2];
	hoursMin		: Decimal[10, 2];
	hoursBlock		: Decimal[10, 2];
	timeFrom		: Time;
	timeTo			: Time;
	minAmt			: Decimal[10, 2];
	maxAmt			: Decimal[10, 2];
	ctUnit			: Integer;
	quantityHookSource	: String;
	rateHookSource		: String;
	remarksHookSource	: String;
	isCargo			: Boolean;
	isVoyage		: Boolean;
	isEvent			: Boolean;
	isWO			: Boolean;
	rangeStart,
	rangeEnd,
	rangeType,
	daysIncrement	: IntegerArray;
	calNormal		: CM_Calendar;
	calExclusion	: CM_Calendar;
	mesType			: CM_MeasurementType;
	root			: CM_Root;
	booleans	: BooleanArray;
	integers	: IntegerArray;

	proxyCalcType,
	realCalcType		: CM_CalculationType;
	pxyQtyRange			: CM_QuantityRange;
	
	rateType : Integer;	//22 Mar 2019	NDL	TFS 43687
	isBol : Boolean; //31 Oct 2019	NDL	TFS 47100
	
begin
	if _jadeXMLElement = null then
		return;
	endif;
	
	root := app.myRoot;
	create booleans transient;
	create integers transient;
	create rangeEnd transient;
	create rangeStart transient;
	create rangeType transient;
	create daysIncrement transient;

	iter := _jadeXMLElement.childNodes.createIterator;
	while iter.next(xmlNode) do
		if not xmlNode.isKindOf(JadeXMLElement) then
			continue;
		endif;

		xmlElement := xmlNode.JadeXMLElement;
		// property values for this agent
		if xmlElement.tagName = "amountMax" then
			maxAmt := xmlElement.textData.Decimal;
		elseif xmlElement.tagName = "amountMin" then
			minAmt := xmlElement.textData.Decimal;
		elseif xmlElement.tagName = "type" then
			calcType := xmlElement.textData.Integer;
		elseif xmlElement.tagName = "code" then
			code := xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "description" then
			description := xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "hoursBlock" then
			hoursBlock := xmlElement.textData.Decimal;
		elseif xmlElement.tagName = "hoursFree" then
			hoursFree := xmlElement.textData.Decimal;
		elseif xmlElement.tagName = "hoursMax" then
			hoursMax := xmlElement.textData.Decimal;
		elseif xmlElement.tagName = "hoursMin" then
			hoursMin := xmlElement.textData.Decimal;
		elseif xmlElement.tagName = "isCargoCalcType" then
			isCargo := xmlElement.textData.Boolean;
		elseif xmlElement.tagName = "isEventCalcType" then
			isEvent := xmlElement.textData.Boolean;
		elseif xmlElement.tagName = "isWorkOrderType" then
			isWO := xmlElement.textData.Boolean;
		elseif xmlElement.tagName = "isBolCalcType" then	//31 Oct 2019	NDL	TFS 47100
			isBol := xmlElement.textData.Boolean;
		elseif xmlElement.tagName = "notAvailableForEntry" then
			notAvailableForEntry := xmlElement.textData.Boolean;
		elseif xmlElement.tagName = "isVoyageCalcType" then
			isVoyage := xmlElement.textData.Boolean;
		elseif xmlElement.tagName = "unit" then
			ctUnit := xmlElement.textData.Integer;
		elseif xmlElement.tagName = "timeFrom" then
			timeFrom := xmlElement.textData.Time;
		elseif xmlElement.tagName = "timeTo" then
			timeTo := xmlElement.textData.Time;
		elseif xmlElement.tagName = "calendar1" then
			calNormal := root.allCalendars[xmlElement.textData];
		elseif xmlElement.tagName = "calendar2" then
			calExclusion := root.allCalendars[xmlElement.textData];
		elseif xmlElement.tagName = "measurementType" then
			mesType := root.allMeasurementTypesByShortName[xmlElement.textData];
		elseif xmlElement.tagName = "quantityHook" then
			quantityHookSource := xmlElement.textData.xmlReplaceReservedChars(false);
		elseif xmlElement.tagName = "rateHook" then
			rateHookSource := xmlElement.textData.xmlReplaceReservedChars(false);
		elseif xmlElement.tagName = "remarksHook" then
			remarksHookSource := xmlElement.textData.xmlReplaceReservedChars(false);
		elseif xmlElement.tagName = "booleanList" then
			foreach childNode in xmlElement.childNodes do
				childElement := childNode.JadeXMLElement;
				booleans.add(childElement.text.Boolean);
			endforeach;
		elseif xmlElement.tagName = "integerRange1" then
			foreach childNode in xmlElement.childNodes do
				childElement := childNode.JadeXMLElement;
				integers.add(childElement.text.Integer);
			endforeach;
		elseif xmlElement.tagName = "quantityRange" then
			foreach childNode in xmlElement.childNodes do
				childElement := childNode.JadeXMLElement;
				if childElement.tagName = "rangeStart" then
					rangeStart.add(childElement.textData.Integer);
				elseif childElement.tagName = "rangeEnd" then
					rangeEnd.add(childElement.textData.Integer);
				elseif childElement.tagName = "rangeType" then
					rangeType.add(childElement.textData.Integer);
				elseif childElement.tagName = "daysIncrement" then
					daysIncrement.add(childElement.textData.Integer);
				endif;
			endforeach;
		elseif xmlElement.tagName = "rateType" then	//22 Mar 2019	NDL	TFS 43687
			rateType := xmlElement.textData.Integer;
		elseif xmlElement.tagName = "weightToUse" then //02/10/2025	navkc1 JIRA 36149
			weightToUseStr := xmlElement.textData; // Should be 'Cargo Weight' or 'Total Weight';
			weightToUse := CM_CalculationType@getWeightToUseInt(weightToUseStr);
		endif;
	endwhile;
	
	// add if new otherwise update existing object
	realCalcType := root.allCalculationTypesByCode[code];
	if realCalcType &lt;&gt; null then
		proxyCalcType := app.createUpdateProxy(realCalcType).CM_CalculationType;
		proxyCalcType.allQuantityRanges.purge();
	else
		create proxyCalcType transient;
	endif;
	foreach index in 1 to rangeStart.size do
		create pxyQtyRange transient;
		pxyQtyRange.setup("", proxyCalcType, daysIncrement[index], 0, rangeStart[index], rangeEnd[index], rangeType[index]);
	endforeach;
	

	proxyCalcType.setProxy(booleans, 
							calcType,
							code,
							description,
							hoursFree,
							hoursMax,
							hoursMin,
							hoursBlock,
							integers,
							notAvailableForEntry,
							timeFrom,
							timeTo,
							minAmt,
							maxAmt,
							ctUnit,
							quantityHookSource,
							rateHookSource,
							remarksHookSource,
							app.myPassport.userCode,
							isCargo,
							isVoyage, 
							isEvent,
							isWO, // TFS 39198
							
							calNormal,
							calExclusion,
							mesType,
							rateType,	//22 Mar 2019	NDL	TFS 43687
							isBol,	//31 Oct 2019	NDL	TFS 47100
							false, // ### TFS 51219 25MAY2021 NAVAB1
							weightToUse //02/10/2025	navkc1 JIRA 36149
							);

	_proxyArray.add(proxyCalcType);
	
epilog
	delete iter;
	delete booleans;
	delete integers;
	delete rangeEnd;
	delete rangeStart;
	delete rangeType;
	delete daysIncrement;
end;</source>
        <Parameter name="_jadeXMLElement" type="JadeXMLElement" usage="input"/>
        <Parameter name="_proxyArray" type="ObjectArray" usage="input"/>
        <Parameter name="_errorStore" type="CM_ErrorSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxImportCalcTypesFromFile" id="4a3305c0-e7f2-48c9-91d4-b648b7c2d254">
        <updating/>
        <source>trxImportCalcTypesFromFile( _file : File; _passport : CM_Passport input ) : Integer updating;

/*
Purpose:		DOHA copy invoicing details from Test to UAT

Parameters:		Import File and passport.  File format is XML, see CM_ExtractLoadAgent::extractCalculationTypes

Date		Who		Reason
Aug 2016	cnwjre1	
*/
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	hadException				: Boolean;
	count, numCodes, noLines 	: Integer;
	proxyCalcType, newCalcType	: CM_CalculationType;
	theRoot						: CM_Root;
	thePassport					: CM_Passport;
	err							: CM_Error;
	errorStore					: CM_ErrorSet;
	proxyArray					: ObjectArray;
	obj							: Object;

	xmlDocumentParser : JadeXMLDocumentParser;
	rootElement : JadeXMLElement;
	xmlDocument : JadeXMLDocument;
	rootNode	: JadeXMLNode;
	childElement	: JadeXMLElement;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	thePassport := _passport;
	theRoot 	:= app.myRoot;

	// Always initialize the activity first
	self.initialiseActivityWithPassport(thePassport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, thePassport);
	on LockException do agtPassportLockExHandler(exception, thePassport);
	app.setContinueCMExceptions(false);
	
	if not _file.tryOpen() then
		app.raiseCMException(VB_FILE_ERROR, app.getErrorString(File_open), null);	
		return 0;
	endif;
	
	progressTS := app.actualTimeServer();
	create proxyArray transient;
	create errorStore transient;
	
	create xmlDocumentParser transient;
	create xmlDocument transient;
	xmlDocumentParser.parseDocumentFile(xmlDocument, _file.fileName);
	rootElement := xmlDocument.rootElement;
	
	foreach rootNode in rootElement.childNodes do
		if rootNode.isKindOf(JadeXMLElement) then
			childElement := rootNode.JadeXMLElement;
			self.trxImportCalcType(childElement, proxyArray, errorStore);
			noLines := noLines + 1;
		endif;
	endforeach;

	if thePassport.myCMIFMonitor &lt;&gt; null then
		thePassport.myCMIFMonitor.updateProgress(app.getErrorString(Reading_import_file), 10, 10);
	endif;
	
	count:= 0;
	numCodes := proxyArray.size;
	
	// Start the transaction
	beginTransaction;
	
	// Perform the operation
	foreach obj in proxyArray do
		proxyCalcType	:= obj.CM_CalculationType;
		count := count + 1;
		progressInt := app.actualTimeServer() - progressTS;
		if thePassport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (count = numCodes)) then
			thePassport.myCMIFMonitor.updateProgress(app.getErrorString1(Creating_msg, 'Shipping Agent'), numCodes, count);
			progressTS := app.actualTimeServer();
		endif;
		
		// add if new otherwise update existing object
		if theRoot.allCalculationTypesByCode[proxyCalcType.code] = null then
			app.myUtilityCA.utlCreateCalculationType(proxyCalcType, newCalcType, app.myPassport);
		else
			app.myUtilityUA.utlUpdateCalculationType(proxyCalcType, app.myPassport);
		endif;

		if thePassport.hasErrors then
			foreach err in thePassport.allErrors do 
				err.setErrorText('Calculation type ' &amp; ' : ' &amp; proxyCalcType.code &amp; '  ' &amp; err.text, false);
				errorStore.add(err);
			endforeach;
			// clear errors from logic so that any successful updates will still be done but stop on any exception
			foreach err in thePassport.allErrors do
				if err.errorCode &lt; app.baseErrorNum then
					count := 0;
					hadException := true;
					break;
				endif;
				err.removeFromPassport;
			endforeach;
		endif;
		if hadException then
			break;
		endif;
	endforeach;
	
	self.trxWriteToLogFile(_file.fileName, noLines, count, thePassport, errorStore);
	
	return count;
	
epilog
	if proxyArray &lt;&gt; null then
		proxyArray.purge;
		delete proxyArray;
	endif;
	_file.close;
	delete xmlDocumentParser;
	delete xmlDocument;
	self.finaliseActivityWithPassport(thePassport);
	delete errorStore;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxImportConsignoreeFromFile" id="15ee54d9-f4ea-4644-845c-a1b1880d603e">
        <updating/>
        <source>trxImportConsignoreeFromFile( _file : File; _passport : CM_Passport input ) updating;

/*
Purpose:		MES 1010 Interface load	

Parameters:		Import File and passport	

Date		Who		Reason
13 August 2009	cnwjmn1	Initial creation
26/11/2009		cnwdad1	PAR 21650.  Changed to handle quoted fields.
06/07/2010	cnwrl1	PAR 24606 - Import order changed to match "JMT Default".
07/07/2010	cnwrl1	PAR 24848 - System Admin Import to allow minimum amount of data.
25/03/2015	cnwdap1	PAR #35895 CCMS PNL 2461 Added isUsedForPacking attribute
*/
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 04/08/2016	cnwdap1	TFS #2447 Ensure consignee/or code is uppercase
// 02 Aug 2017	cnwma1	TFS #5209:PEN - Release Request Stop
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	count				: Integer;
	numCodes			: Integer;
	noLines				: Integer;
	colour				: Integer;
	order				: Integer;
	fieldNo				: Integer;
	fieldValue			: String;
	consCode			: String;
	consDesc			: String;
	consGroup			: String;
	derogNo				: String;
	email				: String;
	debtor				: String;
	fileLine			: String;
	securePartner		: Boolean;
	showInRemarks		: Boolean;
	notAvailable		: Boolean;
	isConsignee			: Boolean;
	isConsignor			: Boolean;
	isRestricted		: Boolean;
	isFreightForwdr		: Boolean;
	fieldArray			: CnStringArray;
	newConsignor		: CM_ConsigneeConsignor;
	currentConsignor	: CM_ConsigneeConsignor;
	pxyConsignor		: CM_ConsigneeConsignor;
	consignorGroupObj	: CM_ConsigneeConsignorGroup;
	consignorColl		: CM_ConsignByCodeDict;
	emailPINAddresses 	: CM_EmailEntityByTypeNameDict;
	debtorObj			: CM_Debtor;
	theRoot				: CM_Root;
	thePassport			: CM_Passport;
	err					: CM_Error;
	errorStore			: CM_ErrorSet;
	
	//cnwmc5 - 19/12/2012 - HAT 2198
	license				: String;
	licenseExpiryDate	: Date;
	
	isUsedForPacking	: Boolean;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	thePassport := _passport;
	theRoot 	:= app.myRoot;

	// Always initialize the activity first
	self.initialiseActivityWithPassport(thePassport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, thePassport);
	on LockException do agtPassportLockExHandler(exception, thePassport);

	app.setContinueCMExceptions(false);
	
	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	if not _file.tryOpen() then
		app.raiseCMException(VB_FILE_ERROR, app.getErrorString(File_open), null);	
		return;
	endif;
	
	create consignorColl transient;
	create fieldArray transient;
	create errorStore transient;
	
	//ignore first line
	fileLine 	:= _file.readLine();
	noLines		:= 1;
	
	while not _file.endOfFile() do
		fileLine 	:= _file.readLine;
		noLines		:= noLines + 1;
		if fileLine = null then
			continue;
		endif;
		
		fieldArray.clear();
		fileLine.csvToStringArray(fieldArray, ",");
		
		/* cnwrl1 07/07/2010 PAR 24848 - what it was
		if fieldArray.size() &lt;&gt; 13 then
			create err transient;
			err.set(0, app.getErrorString1(Line_incorre_number_columns, noLines.String &amp; '  ' &amp; fieldArray.size.String ) , false, '', null, null);
			errorStore.add(err);
			continue;
		endif;
		cnwrl1 07/07/2010 PAR 24848 - end of what it was */
		
		// cnwrl1 07/07/2010 PAR 24848 - start of coding
		if fieldArray.isEmpty then
			continue;
		endif;
		consCode		:= null;
		consDesc		:= null;
		colour			:= null;
		consGroup		:= null;
		derogNo			:= null;
		email			:= null;
		securePartner	:= null;
		showInRemarks	:= null;
		notAvailable	:= null;
		isConsignee		:= null;
		isConsignor		:= null;
		isRestricted	:= null; // 2.8.2017 cnwma1 TFS #5209
		isFreightForwdr	:= null;
		debtor			:= null;
		// cnwrl1 07/07/2010 PAR 24848 - end of coding
		//cnwmc5 - 19/12/2012 - HAT 2198
		license 		:= null;
		licenseExpiryDate 	:= null;
		isUsedForPacking	:= false;					// PAR #35895
		
		/*
		The import layout for this table is exactly (or similar) to the column organiser "JMT Default".
		This is what has been supplied to Messina in document CCMS MES 1008, 1010 Interfaces Messages,
		also see the JMT User Guide section for System Codes Reference.
		*/
		fieldNo	:=	0;
		
		foreach fieldValue in fieldArray do
			fieldNo	:=	fieldNo + 1;
			
			// cnwrl1 06/07/2010 PAR 24606 - reorder import fields to match "JMT Default"
			if fieldNo = 1 then
				//consCode		:=	fieldValue.trimBlanks();					// TFS #2447
				consCode		:=	fieldValue.trimBlanks().toUpper;			// TFS #2447
			elseif fieldNo = 2 then
				consDesc		:=	fieldValue.trimBlanks();
			elseif fieldNo = 3 then
				colour			:=	fieldValue.Integer;
			elseif fieldNo = 4 then
				consGroup		:=	fieldValue.trimBlanks();
			elseif fieldNo = 5 then
				derogNo			:=	fieldValue.trimBlanks();
			elseif fieldNo = 6 then
				email			:=	fieldValue.trimBlanks();
			elseif fieldNo = 7 then
				securePartner	:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 8 then
				showInRemarks	:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 9 then
				notAvailable	:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 10 then
				isConsignee		:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 11 then
				isConsignor		:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 12 then
				isFreightForwdr	:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 13 then
				debtor			:=	fieldValue.trimBlanks();
			elseif fieldNo = 14 then	//cnwmc5 - 19/12/2012 - HAT 2198
				license			:= fieldValue.trimBlanks();
			elseif fieldNo = 15 then	//cnwmc5 - 19/12/2012 - HAT 2198
				licenseExpiryDate	:= fieldValue.trimBlanks().asDateJMT();
			elseif fieldNo = 16 then												// PAR #35895
				isUsedForPacking 	:= fieldValue.trimBlanks().asBooleanJMT();		// PAR #35895
			elseif fieldNo = 17 then
				isRestricted	:= fieldValue.trimBlanks().asBooleanJMT(); // 3.8.2017 cnwma1 TFS #5209
			endif;
		endforeach;
		
		if consGroup &lt;&gt; null then
			consignorGroupObj	:=	theRoot.allConsignGroups[consGroup];
			if consignorGroupObj = null then
				create err transient;
				err.set(0,
						app.getErrorString(Consignor_code) &amp; ' : ' &amp; consCode &amp; '  ' &amp; app.getErrorString(Invalid) &amp; app.getErrorString(Consignee_consignor_group) &amp; ' : ' &amp; consGroup,
						false,
						'',
						null,
						null);
				errorStore.add(err);
				continue;
			endif;
		else
			consignorGroupObj	:=	null;
		endif;
		
		if debtor &lt;&gt; null then
			debtorObj	:=	theRoot.myRootCompany.debtorNodes[debtor].CM_Debtor;
			
			if debtorObj = null then
				create err transient;
				err.set(0, app.getErrorString(Consignor_code) &amp; ' : ' &amp; consCode &amp; '  ' &amp; app.getErrorString(Invalid) &amp; app.getErrorString(Debtor_GC) &amp; ' : ' &amp; debtor , false, '', null, null);
				errorStore.add(err);
				continue;
			endif;
		else
			debtorObj	:=	null;
		endif;
		
// if consignee already exists get fields not in file so they aren't cleared
		currentConsignor	:= theRoot.allConsigneeConsignors[consCode];
		if currentConsignor &lt;&gt; null then
			order				:= 	currentConsignor.order;
			//05/07/2010 cnwdz2 par24597
			if emailPINAddresses = null then
				create emailPINAddresses transient;
			else
				emailPINAddresses.clear();
			endif;
			currentConsignor.allPINNotifyEmailAddresses.copy(emailPINAddresses);
			
			if colour = 0 then
				colour			:=	currentConsignor.colour;
			endif;
		else
			order				:= 0;
			emailPINAddresses	:=	null;
		endif;		
		
		if not consignorColl.includesKey(consCode) then
			create pxyConsignor transient;
			pxyConsignor.setProxy(	consCode,
									consDesc,
									notAvailable,
									securePartner,
									derogNo,
									email,
									colour,
									order,
									consignorGroupObj, 
									debtorObj,
									showInRemarks,
									isConsignee,
									isConsignor,
									isFreightForwdr,
									emailPINAddresses,
									license,			//cnwmc5 - 19/12/2012 - HAT 2198
									licenseExpiryDate,	//cnwmc5 - 19/12/2012 - HAT 2198
									isUsedForPacking,	// PAR #35895
									isRestricted,
									false);// 2.8.2017 cnwma1 TFS #5209
			consignorColl.add(pxyConsignor);
		else
			create err transient;
			err.set(0,
					app.getErrorString(Consignor_code) &amp; ' : ' &amp; app.getErrorString2(Line_duplicate_file, noLines.String, app.getErrorString(Consignors_consignees)) &amp; consCode,
					false,
					'',
					null,
					null);
			errorStore.add(err);
		endif;
	endwhile;
	
	if thePassport.myCMIFMonitor &lt;&gt; null then
		thePassport.myCMIFMonitor.updateProgress(app.getErrorString(Reading_import_file), 10, 10);
	endif;
	
	if thePassport.hasErrors() then
		return;
	endif;
	
	count		:=	0;
	numCodes	:=	consignorColl.size();
	
	// Start the transaction
	beginTransaction;
	
	// Perform the operation
	foreach pxyConsignor in consignorColl do
		count := count + 1;
		
		progressInt := app.actualTimeServer() - progressTS;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if thePassport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (count = numCodes)) then
			thePassport.myCMIFMonitor.updateProgress(app.getErrorString1(Creating_msg, app.getErrorString(Consignors_consignees)), numCodes, count);
			progressTS := app.actualTimeServer();		// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		currentConsignor	:=	theRoot.allConsigneeConsignors[pxyConsignor.code];
		
		if currentConsignor = null then
			app.myUtilityCA.utlCreateConsigneeConsignor(pxyConsignor, newConsignor, thePassport);
		else
			app.myProxyManager.createProxyLink(currentConsignor, pxyConsignor);
			app.myUtilityUA.utlUpdateConsigneeConsignor(pxyConsignor, thePassport);
		endif;
		
		if thePassport.hasErrors() then
			foreach err in thePassport.allErrors do
				err.setErrorText(app.getErrorString(Consignor_code) &amp; ' : ' &amp; pxyConsignor.code &amp; '  ' &amp; err.text, false);
				errorStore.add(err);
			endforeach;
			
			foreach err in thePassport.allErrors do
				err.removeFromPassport();
			endforeach;
		endif;
	endforeach;
	
	trxWriteToLogFile(_file.fileName, noLines, count, thePassport, errorStore);
	
epilog
	if consignorColl &lt;&gt; null then
		consignorColl.purge();
		delete consignorColl;
	endif;
	
	//05/07/2010 cnwdz2 par24597
	if emailPINAddresses &lt;&gt; null then
		emailPINAddresses.clear();
		delete emailPINAddresses;
	endif;
	
	delete fieldArray;
	_file.close();
	self.finaliseActivityWithPassport(thePassport);
	delete errorStore;
end;
</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxImportContractFromFile" id="a9e2ea2c-f8b3-4fa4-a718-19c442860d19">
        <updating/>
        <source>trxImportContractFromFile( _file : File; _bank : CM_Bank; _terminal : CM_Terminal; _format : Integer; _passport : CM_Passport input ) : Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 January 2023	navmv20	TFS 55650 Task 55702: Jade - Contracts XML Load TRX

*/
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	hadException,
	hadError							: Boolean;
	count, numCodes, noLines 			: Integer;
	proxyInvContract,
	proxyInvoiceContract1,
	realInvContract						: CM_InvoiceContract;
	proxyInvContractDtl,
	proxyInvContractDetl1,
	realInvContractDtl,
	myInvContractDetl					: CM_InvoiceContractDetails;
	proxyInvContractRate,
	proxyInvContractRate1,
	realInvContractRate,
	myInvContractRate					: CM_InvoiceContractRate;
	proxyInvContractRateEntry,
	proxyInvContractRateEntry1,			
	realInvContractRateEntry,
	myInvContractRateEntry				: CM_InvoiceContractRateEntry;
	theRoot								: CM_Root;
	thePassport							: CM_Passport;
	err									: CM_Error;
	errorStore							: CM_ErrorSet;
	proxyArray							: ObjectArray;
	obj									: Object;
	bank								: CM_Bank;

	xmlDocumentParser 		: JadeXMLDocumentParser;
	rootElement 			: JadeXMLElement;
	rootNode				: JadeXMLNode;
	xmlDocument 			: JadeXMLDocument;
	progressInt				: TimeStampInterval;
	progressTS			    : TimeStamp;
	
	agent : CMIF_InvoiceContract;
	fileName : String;
begin
	thePassport := _passport;
	theRoot 	:= app.myRoot;
	if thePassport.myTerminal = null then
		thePassport.setMyTerminal(_terminal);
	endif;

	// Always initialize the activity first 
	self.initialiseActivityWithPassport(thePassport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, thePassport);
	on LockException do agtPassportLockExHandler(exception, thePassport);
	app.setContinueCMExceptions(false);
	
	if not _file.tryOpen() then
		app.raiseCMException(VB_FILE_ERROR, app.getErrorString(File_open), null);	
		return 0;
	endif;
	
	progressTS := app.actualTimeServer();
	create proxyArray transient;
	create errorStore transient;
	
	app.setContinueCMExceptions(true);
	
	create agent transient;
	
	if _file.fileName.cnContains(".csv") and _format = CSV_FORMAT then
		agent.doLoadInvContractsCsvFile(_file, proxyArray, _bank, noLines); //Process CSV file
		
	elseif _file.fileName.cnContains(".xml") and _format = XML_FORMAT then
		agent.doLoadInvContractsXmlFile(_file, proxyArray, _bank, noLines); //Process XML file
	else
		app.raiseCMException(File_type_not_support, null, null);
	endif;
	
	app.setContinueCMExceptions(false);	
	
	if thePassport.hasErrors then
		foreach err in thePassport.allErrors do 
			err.setErrorText(err.text, false);
			errorStore.add(err);
		endforeach;
		return 0;
	endif;
	
	if thePassport.myCMIFMonitor &lt;&gt; null then
		thePassport.myCMIFMonitor.updateProgress(app.getErrorString(Reading_import_file), 10, 10);
	endif;
	
	count:= 0;
	numCodes := proxyArray.size;
	
	// Start the transaction

	beginTransaction;
	// Perform the operation
	foreach proxyInvContract in proxyArray as CM_InvoiceContract do : outerloop 
		
		progressInt := app.actualTimeServer() - progressTS;
		if thePassport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (count = numCodes)) then
			thePassport.myCMIFMonitor.updateProgress(app.getErrorString1(Creating_msg, app.getErrorString(Invoice_contracts)), numCodes, count);
			progressTS := app.actualTimeServer();
		endif;
	
		app.myPassport.setWarningsIgnored(true);
		bank := proxyInvContract.myBusinessUnit;
		
		realInvContract := bank.allInvoiceContractsById[proxyInvContract.contractId,proxyInvContract.myDebtor];
		
		// add if new otherwise update existing object
		if realInvContract = null then
			app.myUtilityCA.utlCreateInvContract(proxyInvContract,realInvContract,app.myPassport);
		else
			proxyInvoiceContract1 := app.createUpdateProxy(realInvContract).CM_InvoiceContract;
			proxyInvoiceContract1.setProxy(proxyInvContract.active, proxyInvContract.contractId, proxyInvContract.fromTS, proxyInvContract.toTS, 
			proxyInvContract.primary, bank, bank.terminal, proxyInvContract.myDebtor, proxyInvContract.description);
			
			app.myUtilityUA.utlUpdateInvContract(proxyInvoiceContract1,app.myPassport, false);
			realInvContract := proxyInvoiceContract1.pxyGetRealObject();
			
			delete proxyInvoiceContract1;
		endif;
		
		if thePassport.hasErrors then
			count := 0;
			app.setErrorStore(thePassport,app.getErrorString(Invoice_contract) &amp; ' : ' &amp; proxyInvContract.description,errorStore);
			break outerloop;
		endif;
		
		foreach proxyInvContractDtl in proxyInvContract.allInvoiceContractDetails do
			myInvContractDetl := null;
			foreach realInvContractDtl in realInvContract.allInvoiceContractDetails do
				if proxyInvContractDtl.id = realInvContractDtl.id then
					myInvContractDetl := realInvContractDtl;
					break;
				endif;
			endforeach;
			
			if  myInvContractDetl = null then
				proxyInvContractDtl.setProxy(proxyInvContractDtl.id,proxyInvContractDtl.contractType, proxyInvContractDtl.criteriaPriority,proxyInvContractDtl.fromTS,proxyInvContractDtl.toTS,
				proxyInvContractDtl.myCalculationType,realInvContract,proxyInvContractDtl.myInvoiceLineType, proxyInvContractDtl.myBusinessUnit, proxyInvContractDtl.myShippingTerm,
				proxyInvContractDtl.myUnitOfMeasure);
				app.myUtilityCA.utlCreateInvContractDtl(proxyInvContractDtl, myInvContractDetl,app.myPassport);
			else
				proxyInvContractDetl1 := app.createUpdateProxy( myInvContractDetl).CM_InvoiceContractDetails;
				proxyInvContractDetl1.setProxy(proxyInvContractDetl1.id,proxyInvContractDtl.contractType,proxyInvContractDtl.criteriaPriority,proxyInvContractDtl.fromTS,proxyInvContractDtl.toTS,
				proxyInvContractDtl.myCalculationType,realInvContract,proxyInvContractDtl.myInvoiceLineType, proxyInvContractDtl.myBusinessUnit, proxyInvContractDtl.myShippingTerm,
				proxyInvContractDtl.myUnitOfMeasure);
				
				if proxyInvContractDetl1.isKindOf(CM_InvoiceContractDtlsVolBased) and  proxyInvContractDtl.contractType = INV_CONTRACT_TYPE_VOLUME_BASED then
					proxyInvContractDetl1.CM_InvoiceContractDtlsVolBased.setProxyVolBased(proxyInvContractDtl.CM_InvoiceContractDtlsVolBased.accumulateForRailReceival,
					proxyInvContractDtl.CM_InvoiceContractDtlsVolBased.accumulateForRoadReceival, proxyInvContractDtl.CM_InvoiceContractDtlsVolBased.accumulateForShipReceival, 
					proxyInvContractDtl.CM_InvoiceContractDtlsVolBased.accumulationType);
				endif;
				
				app.myUtilityUA.utlUpdateInvContractDtl(proxyInvContractDetl1,app.myPassport);
				 myInvContractDetl := proxyInvContractDetl1.pxyGetRealObject();
				delete proxyInvContractDetl1;
			endif;
			
			if thePassport.hasErrors then
				count := 0;
				app.setErrorStore(thePassport,app.getErrorString(Invoice_contract_details) &amp; ' : ' &amp; proxyInvContract.description,errorStore);
				break outerloop;
			endif;
			
			myInvContractRate := null;
			
			foreach proxyInvContractRate in proxyInvContractDtl.allInvoiceContractRates do
				myInvContractRate := null;
				foreach realInvContractRate in myInvContractDetl.allInvoiceContractRates do
					if proxyInvContractRate.id = realInvContractRate.id then
						myInvContractRate := realInvContractRate;
						break;
					endif;
				endforeach;
				
				if  myInvContractRate = null then
					proxyInvContractRate.setProxy(proxyInvContractRate.id,proxyInvContractRate.myService,myInvContractDetl, proxyInvContractRate.myCalculationType); // ### TFS CR 61579 TASK 62453 12FEB2024 NAVAB1
					app.myUtilityCA.utlCreateInvContractDtlRt(proxyInvContractRate,myInvContractRate,app.myPassport);
				else
					proxyInvContractRate1 := app.createUpdateProxy(myInvContractRate).CM_InvoiceContractRate;
					proxyInvContractRate1.setProxy(proxyInvContractRate1.id,proxyInvContractRate.myService,myInvContractDetl, proxyInvContractRate1.myCalculationType);// ### TFS CR 61579 TASK 62453 12FEB2024 NAVAB1
					app.myUtilityUA.utlUpdateInvContractDtlRt(proxyInvContractRate1, app.myPassport);
					myInvContractRate:= proxyInvContractRate1.pxyGetRealObject();
					delete proxyInvContractRate1;
				endif;
				
				if thePassport.hasErrors then
					count := 0;
					app.setErrorStore(thePassport, app.getErrorString(Invoice_contract_rate) &amp; ' : ' &amp; proxyInvContract.description,errorStore);
					break outerloop;
				endif;
			    
					foreach proxyInvContractRateEntry in proxyInvContractRate.allInvoiceContractRateEntries do
						myInvContractRateEntry := null;
						foreach realInvContractRateEntry in myInvContractRate.allInvoiceContractRateEntries do
							if proxyInvContractRateEntry.id = realInvContractRateEntry.id then
								myInvContractRateEntry := realInvContractRateEntry;
								break;
							endif;
						endforeach;
						
						if myInvContractRateEntry = null then
							proxyInvContractRateEntry.setProxy(proxyInvContractRateEntry.id,proxyInvContractRateEntry.costPerUnit,proxyInvContractRateEntry.fromAmount,proxyInvContractRateEntry.toAmount,proxyInvContractRateEntry.fromTS,
							proxyInvContractRateEntry.toTS,myInvContractRate, proxyInvContractRateEntry.myBusinessUnit);
							app.myUtilityCA.utlCreateInvContractDtlRtEntry(proxyInvContractRateEntry,myInvContractRateEntry,app.myPassport);
						else
							proxyInvContractRateEntry1 := app.createUpdateProxy(myInvContractRateEntry).CM_InvoiceContractRateEntry;
							proxyInvContractRateEntry1.setProxy(proxyInvContractRateEntry1.id,proxyInvContractRateEntry.costPerUnit,proxyInvContractRateEntry.fromAmount,proxyInvContractRateEntry.toAmount,proxyInvContractRateEntry.fromTS,
							proxyInvContractRateEntry.toTS,myInvContractRate, proxyInvContractRateEntry.myBusinessUnit);
							app.myUtilityUA.utlUpdateInvContractDtlRtEntry(proxyInvContractRateEntry1,app.myPassport);
							myInvContractRateEntry := proxyInvContractRateEntry1.pxyGetRealObject();
							delete proxyInvContractRateEntry1;
						endif;
						
						if thePassport.hasErrors then
							app.setErrorStore(thePassport,app.getErrorString(Invoice_contrac_rate_entry) &amp; ' : ' &amp; proxyInvContract.description,errorStore);
							count := 0;
							break outerloop;
						endif;
						delete proxyInvContractRateEntry;
					endforeach;

				delete proxyInvContractRate;
			endforeach;
			delete proxyInvContractDtl;
		endforeach;
		count := count+1;
		delete proxyInvContract;
	endforeach;
	
	fileName := _file.fileName;
	
	self.trxWriteToLogFile2(fileName, noLines, count, errorStore);

	return count;
epilog

	_file.close;
	delete xmlDocumentParser;
	delete xmlDocument;
	self.finaliseActivityWithPassport(thePassport);
	delete errorStore;
	
	if proxyArray &lt;&gt; null then
		proxyArray.purge;
		delete proxyArray;
	endif;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_format" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxImportCustomsAgent" id="baf4750a-5e14-47e6-82a8-9b6dd8556d0d">
        <updating/>
        <source>trxImportCustomsAgent(_jadeXMLElement : JadeXMLElement input; _proxyArray : ObjectArray input; 
					   _errorStore : CM_ErrorSet input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
Apr 2012	cnwjre1	Copy customs agents for DOHA from test to UAT

*/

vars
	xmlNode			: JadeXMLNode;
	xmlElement		: JadeXMLElement;
	iter			: Iterator;
	code, name, debtorName	: String;
	isNotAvailableForEntry	: Boolean;

	proxyAgent				: CM_CustomsAgent;
	myDebtor				: CM_Debtor;
	
	err						: CM_Error;
begin
	if _jadeXMLElement = null then
		return;
	endif;
	
	code		:= null;
	name		:= null;
	isNotAvailableForEntry		:= null;
	debtorName	:= null;

	myDebtor := null;

	iter := _jadeXMLElement.childNodes.createIterator;
	while iter.next(xmlNode) do
		if not xmlNode.isKindOf(JadeXMLElement) then
			continue;
		endif;

		xmlElement := xmlNode.JadeXMLElement;
		// property values for this agent
		if xmlElement.tagName = "code" then
			code := xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "name" then
			name := xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "isNotAvailableForEntry" then
			isNotAvailableForEntry := xmlElement.textData.Boolean;
		elseif xmlElement.tagName = "debtor" then
			debtorName := xmlElement.textData.trimBlanks();
		endif;
	endwhile;
	
	// don't error from these being null, just skip it and sort out manually later
	if debtorName &lt;&gt; null then
		myDebtor := app.myRoot.myRootCompany.debtorNodes[debtorName].CM_Debtor;
	endif;
	
	create proxyAgent as CM_CustomsAgent transient;

	proxyAgent.setProxy(code,
						 name,
						 isNotAvailableForEntry,
						 myDebtor);

	_proxyArray.add(proxyAgent);
	
epilog
	delete iter;
end;</source>
        <Parameter name="_jadeXMLElement" type="JadeXMLElement" usage="input"/>
        <Parameter name="_proxyArray" type="ObjectArray" usage="input"/>
        <Parameter name="_errorStore" type="CM_ErrorSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxImportCustomsAgentsFromFile" id="567a6ce0-a735-4e00-b450-937c91b0839b">
        <updating/>
        <source>trxImportCustomsAgentsFromFile( _file : File; _passport : CM_Passport input ) updating;

/*
Purpose:		DOHA copy customs agents from Test to UAT

Parameters:		Import File and passport.  File format is XML, see CM_ExtractLoadAgent::extractCustomsAgents

Date		Who		Reason
Apr 2012	cnwjre1	Copy customs agents from one JMT copy to another
*/
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	hadException				: Boolean;
	count, numCodes, noLines 	: Integer;
	proxyAgent, newAgent		: CM_CustomsAgent;
	theRoot						: CM_Root;
	thePassport					: CM_Passport;
	err							: CM_Error;
	errorStore					: CM_ErrorSet;
	proxyArray					: ObjectArray;
	obj							: Object;

	xmlDocumentParser : JadeXMLDocumentParser;
	rootElement : JadeXMLElement;
	xmlDocument : JadeXMLDocument;
	rootNode	: JadeXMLNode;
	childElement	: JadeXMLElement;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	thePassport := _passport;
	theRoot 	:= app.myRoot;

	// Always initialize the activity first
	self.initialiseActivityWithPassport(thePassport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, thePassport);
	on LockException do agtPassportLockExHandler(exception, thePassport);
	app.setContinueCMExceptions(false);
	
	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	if not _file.tryOpen() then
		app.raiseCMException(VB_FILE_ERROR, app.getErrorString(File_open), null);	
		return;
	endif;
	
	create proxyArray transient;
	create errorStore transient;
	
	create xmlDocumentParser transient;
	create xmlDocument transient;
	xmlDocumentParser.parseDocumentFile(xmlDocument, _file.fileName);
	rootElement := xmlDocument.rootElement;
	
	foreach rootNode in rootElement.childNodes do
		if rootNode.isKindOf(JadeXMLElement) then
			childElement := rootNode.JadeXMLElement;
			self.trxImportCustomsAgent(childElement, proxyArray, errorStore);
			noLines := noLines + 1;
		endif;
	endforeach;
	
	if thePassport.myCMIFMonitor &lt;&gt; null then
		thePassport.myCMIFMonitor.updateProgress(app.getErrorString(Reading_import_file), 10, 10);
	endif;
	
	count:= 0;
	numCodes := proxyArray.size;
	
	// Start the transaction
	beginTransaction;
	
	// Perform the operation
	foreach obj in proxyArray do
		proxyAgent	:= obj.CM_CustomsAgent;
		progressInt := app.actualTimeServer() - progressTS;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if thePassport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (count = numCodes)) then
			thePassport.myCMIFMonitor.updateProgress(app.getErrorString1(Creating_msg, 'Customs Agent'), numCodes, count);
			progressTS := app.actualTimeServer();		// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		app.myUtilityCA.utlCreateCustomsAgent(proxyAgent, newAgent, app.myPassport);

		if thePassport.hasErrors then
			foreach err in thePassport.allErrors do 
				err.setErrorText('Customs Agent ' &amp; ' : ' &amp; proxyAgent.name &amp; '  ' &amp; err.text, false);
				errorStore.add(err);
			endforeach;
			// clear errors from logic so that any successful updates will still be done but stop on any exception
			foreach err in thePassport.allErrors do
				if err.errorCode &lt; app.baseErrorNum then
					count := 0;
					hadException := true;
					break;
				endif;
				err.removeFromPassport;
			endforeach;
		else
			count := count + 1;
		endif;
		if hadException then
			break;
		endif;
	endforeach;
	
	self.trxWriteToLogFile(_file.fileName, noLines, count, thePassport, errorStore);
	
epilog
	if proxyArray &lt;&gt; null then
		proxyArray.purge;
		delete proxyArray;
	endif;
	_file.close;
	delete xmlDocumentParser;
	delete xmlDocument;
	self.finaliseActivityWithPassport(thePassport);
	delete errorStore;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxImportDebtorNode" id="374b7397-230b-49b2-91a0-b5d87ab5ffc0">
        <updating/>
        <source>trxImportDebtorNode(_jadeXMLElement : JadeXMLElement input; _parentName : String; _controllerArray : ObjectArray input; _debtorArray : CnStringArray input; _errorStore : CM_ErrorSet input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
Apr 2012	cnwjre1	Copy debtors retaining groups and children for DOHA from test to UAT
14/03/2018	jlgdap1	TFS 36473 Expand fields included in Debtor extract, correct hadling of operators/carriers/consignors
09/08/2018	jlgdap1	TFS 40092 New parameter for CM_DebtorNode::setProxy
25/09/2018	jlgsl4	TFS 40294 PEL1 - extract/import new fields incl. Payment Type details
01/07/2019	jlgdap1	TFS 45436 ADP Unable to import debtors
28/03/2020  cnwma1	Bug 48994: ASPA - Debtor Uploads missing Attributes

*/

vars
	xmlAttribute	: JadeXMLAttribute;
	childNode		: JadeXMLNode;
	xmlNode			: JadeXMLNode;
	xmlElement		: JadeXMLElement;
	parentElement	: JadeXMLElement;
	iter			: Iterator;
	childIter		: Iterator;
	className		: String;
	debtorName, 
	debtorParent, 
	debtorType, 
	debtorAddress, 
	purchOrder, 
	externalRef,
	account, 
	terms, 
	carrier, 
	consignor, 
	operator, 
	remarks, 
	agent,
	longName,
	additionalInfo1, 
	additionalInfo2, 
	paymentTypeDesc,	
	debtorCode, 
	terminalCode			: String;	
	poMandatory, 
	zeroRated, 
	suspended,
	badCredit 				: Boolean;						
	cashTerminalCodes, 
	paymentTypeDescs 		: StringArray;

	existingDebtorNode,
	myParentDebtor, 
	pxyDebtorNode 			 : CM_DebtorNode;
	myTofT					 : CM_InvoiceTermsOfTrade;
	myCarrier			     : CM_Carrier;
	myCustomsAgent		 	 : CM_CustomsAgent;
	myOperator				 : CM_Operator;
	myConsignor				 : CM_ConsigneeConsignor;
	myDebtorType			 : CM_DebtorType;
	debtorNodeController	 : CMIF_DebtorNode;
	err						 : CM_Error;
	allAgentCodes		     : StringArray;				
	allAgents 				 : CM_CustomsAgentByCodeDict;			
	allCarrierCodes 		 : StringArray;					
	allCarriers 			 : CM_CarrierByCodeDict;			
	allConsignorCodes 		 : StringArray;				
	allConsignors 			 : CM_ConsignByCodeDict;			
	allContactCodes		     : StringArray;					
	allContacts 			 : CM_EmailEntityByTypeNameDict;		
	allDebtorTypeCodes 		 : StringArray;				
	allDebtorTypes 			 : CM_DebtorTypeByCodeDict;		
	allOperatorCodes 		 : StringArray;				
	allOperators 			 : CM_OperatorByCodeDict;		
	contact 				 : String;								
	code 					 : String;									
	myContact 				 : CM_EmailEntity;						
	debtorTerminalDetail 	 : CMIF_DebtorTerminalDetail; 
	allDebtorTerminalDetails : CM_DebtorTermDetailByTermDict; 

begin
	if _jadeXMLElement = null then
		return;
	endif;
	
	xmlAttribute := _jadeXMLElement.getAttributeByName('class');
	if xmlAttribute &lt;&gt; null then
		className := xmlAttribute.value.trimBlanks();
	endif;
	
	debtorName		:= null;
	debtorParent	:= _parentName;
	debtorAddress	:= null;
	remarks			:= null;
	account			:= null;
	purchOrder		:= null;
	poMandatory		:= null;
	terms			:= null;
	zeroRated		:= null;
	suspended		:= null;
	carrier			:= null;
	consignor		:= null;
	operator		:= null;
	debtorType		:= null;
	longName		:= null;

	create allAgentCodes      transient;	// TFS 36473
	create allAgents 	      transient;	// TFS 36473
	create allCarrierCodes 	  transient;	// TFS 36473
	create allCarriers 		  transient;	// TFS 36473
	create allConsignorCodes  transient;	// TFS 36473
	create allConsignors 	  transient;	// TFS 36473
	create allContactCodes 	  transient;	// TFS 36473
	create allContacts 		  transient;	// TFS 36473
	create allDebtorTypeCodes transient;	// TFS 36473
	create allDebtorTypes	  transient;	// TFS 36473
	create allOperatorCodes   transient;	// TFS 36473
	create allOperators 	  transient; 	// TFS 36473
	create cashTerminalCodes  transient;	// TFS 40294
	create paymentTypeDescs   transient;	// TFS 40294

	myTofT	       := null;
	myCarrier	   := null;
	myConsignor	   := null;
	myOperator	   := null;
	myCustomsAgent := null;

	iter := _jadeXMLElement.childNodes.createIterator;
	while iter.next(xmlNode) do
		if not xmlNode.isKindOf(JadeXMLElement) then
			continue;
		endif;


		xmlElement := xmlNode.JadeXMLElement;
		// property values for this debtor
		if xmlElement.tagName = "name" then
			debtorName 		:= xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "remarks" then
			remarks     	:= xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "isPurchaseOrderMandatory" then
			poMandatory 	:= xmlElement.textData.Boolean;
		elseif xmlElement.tagName = "isSuspended" then
			suspended 		:= xmlElement.textData.Boolean;
		elseif xmlElement.tagName = "isZeroRatedTax" then
			zeroRated 		:= xmlElement.textData.Boolean;
		elseif xmlElement.tagName = "hasBadCredit" then							// TFS 36473
			badCredit 		:= xmlElement.textData.Boolean;							// TFS 36473
		elseif xmlElement.tagName = "account" then
			account 		:= xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "purchaseOrderCode" then
			purchOrder 		:= xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "externalReference" then
			externalRef 	:= xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "longName" then
			longName 		:= xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "code" then // TFS 40294
			debtorCode      := xmlElement.textData.trimBlanks(); 		 // TFS 40294
		elseif xmlElement.tagName = "additionalInformation1" then 		 // TFS 40294
			additionalInfo1 := xmlElement.textData.trimBlanks();		 // TFS 40294
		elseif xmlElement.tagName = "additionalInformation2" then		 // TFS 40294
			additionalInfo2 := xmlElement.textData.trimBlanks();		 // TFS 40294
		elseif xmlElement.tagName = "address" then
			debtorAddress 	:= xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "customsAgent" then
			agent 			:= xmlElement.textData.trimBlanks();
			allAgentCodes.add(agent);													// TFS 36473
		elseif xmlElement.tagName = "operator" then
			operator 		:= xmlElement.textData.trimBlanks();
			allOperatorCodes.add(operator);												// TFS 36473
		elseif xmlElement.tagName = "carrier" then										// TFS 36473
			carrier 		:= xmlElement.textData.trimBlanks();						// TFS 36473
			allCarrierCodes.add(carrier);												// TFS 36473
		elseif xmlElement.tagName = "consignor" then									// TFS 36473
			consignor 		:= xmlElement.textData.trimBlanks();						// TFS 36473
			allConsignorCodes.add(consignor);											// TFS 36473
		elseif xmlElement.tagName = "contact" then										// TFS 36473
			contact 		:= xmlElement.textData.trimBlanks();								// TFS 36473
			allContactCodes.add(contact);												// TFS 36473
		elseif xmlElement.tagName = "debtorType" then									// TFS 36473
			debtorType 		:= xmlElement.textData.trimBlanks();								// TFS 36473
			allDebtorTypeCodes.add(debtorType);											// TFS 36473
		elseif xmlElement.tagName = "termsOfTrade" then									// TFS 36473
			terms 		  := xmlElement.textData.trimBlanks();									// TFS 36473
			myTofT 		  := app.myRoot.myRootCompany.allInvoiceTermsOfTrade[terms];			// TFS 36473
		elseif xmlElement.tagName = "terminalCode" then 								// TFS 40294 - have a cash-only terminal
			cashTerminalCodes.add(xmlElement.textData.trimBlanks()); 					// TFS 40294 - record the terminal code
			
			iter.next(xmlNode); 									// TFS 40294
			if not xmlNode.isKindOf(JadeXMLElement) then			// TFS 40294
				continue; 											// TFS 40294
			endif; 													// TFS 40294
			
			xmlElement := xmlNode.JadeXMLElement;					// TFS 40294
			if xmlElement.tagName &lt;&gt; "isCashOnly" then 				// TFS 40294 - if not "isCashOnly"
				continue; 									    	// TFS 40294 - something fishy's going on
			endif; 													// TFS 40294
			iter.next(xmlNode); 									// TFS 40294 - assuming cash-only existing means tag text is 'true'
			if not xmlNode.isKindOf(JadeXMLElement) then 			// TFS 40294
				continue; 											// TFS 40294
			endif; 													// TFS 40294		
			xmlElement := xmlNode.JadeXMLElement;					// TFS 40294
			if xmlElement.tagName &lt;&gt; "paymentTypeDesc" then	   	    // TFS 40294 - if not "paymentTypeDesc"
				continue; 											// TFS 40294 - something fishy's going on
			endif; 												    // TFS 40294
			paymentTypeDescs.add(xmlElement.textData.trimBlanks()); // TFS 40294			
		// children - separate debtors
		elseif xmlElement.tagName = "children" then
			// process after the parent
			parentElement := xmlElement;
		endif;
	endwhile;
	
	// ignore system-defined CM_RootDebtorGroup and CM_VoidDebtor - the root debtor group is used as the XML root
	//  and both are assumed to be already present
	if className &lt;&gt; "CM_RootDebtorGroup" and
	   className &lt;&gt; "CM_VoidDebtor" then
	
		if debtorParent &lt;&gt; null then
			myParentDebtor	:= app.myRoot.myRootCompany.debtorNodes[debtorParent];
			if myParentDebtor = null and			// not already there and
			not _debtorArray.includes(debtorParent) then		// not part of this load
				create err transient;
				err.set(0, app.getErrorString(INV_Debtor)    &amp; ' : ' &amp; debtorName &amp; '  ' &amp; 
						   app.getErrorString(Invalid)       &amp; ' '   &amp; 
						   app.getErrorString(Debtor_parent) &amp; ' : ' &amp; debtorParent, false, '', null, null);
				_errorStore.add(err);
			endif;
		else
			myParentDebtor	:= app.myRoot.myRootCompany.getRootDebtorGroup();
		endif;		
		if debtorType &lt;&gt; null then
			myDebtorType		:= app.myRoot.allDebtorTypes[debtorType];
			if myDebtorType = null then
				create err transient;
				err.set(0, app.getErrorString(INV_Debtor)  &amp; ' : ' &amp; debtorName &amp; '  ' &amp; 
						   app.getErrorString(Invalid)      &amp; ' ' &amp; 
						   app.getErrorString(Debtor_type)  &amp; ' : ' &amp; debtorType , false, '', null, null);
				_errorStore.add(err);
			endif;
		endif;			
		if operator &lt;&gt; null then
			myOperator			:= app.myRoot.allOperators[operator];
			// don't error from this being null, just skip it and sort out manually later
			foreach code in allOperatorCodes do									// TFS 36473
				myOperator := app.myRoot.allOperators[code];					// TFS 36473
				if myOperator &lt;&gt; null then										// TFS 36473
					allOperators.addNoDuplicates(myOperator, false);			// TFS 36473
				endif;															// TFS 36473
			endforeach;															// TFS 36473
		endif;			
		if agent &lt;&gt; null then
			myCustomsAgent		:= app.myRoot.allCustomsAgents[agent];
			// don't error from this being null, just skip it and sort out manually later
			foreach code in allAgentCodes do									// TFS 36473
				myCustomsAgent := app.myRoot.allCustomsAgents[code];			// TFS 36473
				if myCustomsAgent &lt;&gt; null then									// TFS 36473
					allAgents.addNoDuplicates(myCustomsAgent, false);			// TFS 36473
				endif;															// TFS 36473
			endforeach;															// TFS 36473
		endif;			
		if consignor &lt;&gt; null then												// TFS 36473
			foreach code in allConsignorCodes do								// TFS 36473
				myConsignor := app.myRoot.allConsigneeConsignors[code];			// TFS 36473
				if myConsignor &lt;&gt; null then										// TFS 36473
					allConsignors.addNoDuplicates(myConsignor, false);			// TFS 36473
				endif;															// TFS 36473
			endforeach;															// TFS 36473
		endif;																	// TFS 36473
		if carrier &lt;&gt; null then													// TFS 36473
			foreach code in allCarrierCodes do									// TFS 36473
				myCarrier := app.myRoot.allCarriers[code];						// TFS 36473
				if myCarrier &lt;&gt; null then										// TFS 36473
					allCarriers.addNoDuplicates(myCarrier, false);				// TFS 36473
				endif;															// TFS 36473
			endforeach;															// TFS 36473
		endif;																	// TFS 36473
		if contact &lt;&gt; null then													// TFS 36473
			foreach code in allContactCodes do									// TFS 36473
				myContact := app.myRoot.allEmailEntities[1, code];				// TFS 36473
				if myContact &lt;&gt; null then										// TFS 36473
					allContacts.addNoDuplicates(myContact, false);				// TFS 36473
				endif;															// TFS 36473
			endforeach;															// TFS 36473
		endif;																	// TFS 36473
		if debtorType &lt;&gt; null then												// TFS 36473
			foreach code in allDebtorTypeCodes do								// TFS 36473
				myDebtorType := app.myRoot.allDebtorTypes[code];				// TFS 36473
				if myDebtorType &lt;&gt; null then									// TFS 36473
					allDebtorTypes.addNoDuplicates(myDebtorType, false);		// TFS 36473
				endif;															// TFS 36473
			endforeach;															// TFS 36473
		endif;																	// TFS 36473
	
		if not _debtorArray.includes(debtorName) then
			create debtorNodeController transient;
			create allDebtorTerminalDetails transient; 							// TFS 40294	// TFS 45436
			if cashTerminalCodes.size &gt; 0 then 									// TFS 40294 - this debtor has cashTerminal details...
				foreach terminalCode in cashTerminalCodes do 					// TFS 40294
					create debtorTerminalDetail transient; 						// TFS 40294
					debtorTerminalDetail.setCashOnly(true); 					// TFS 40294
					debtorTerminalDetail.setPaymentTypeFromDescription(paymentTypeDescs[cashTerminalCodes.indexOf(terminalCode)]);  // TFS 40294
					debtorTerminalDetail.setMyTerminal(app.myRoot.allTerminals[terminalCode]); 										// TFS 40294
 // ### TFS 52237 27OCT2021 NAVAB1					debtorNodeController.allCashOnlyTerminals.addNoDuplicates(debtorTerminalDetail.myTerminal, false); 			    // TFS 40294
					allDebtorTerminalDetails.add(debtorTerminalDetail); 															// TFS 40294
				endforeach; 																										// TFS 40294
			endif; 
			
			debtorNodeController.setForImport(debtorName, 
											  debtorAddress,
											  remarks,
											  account,
											  purchOrder,
											  poMandatory, 
											  zeroRated, 
											  suspended, 
											  myParentDebtor, 
											  myTofT, 
											  myCarrier, 
											  myOperator, 
											  myConsignor,  
											  myDebtorType,
											  myCustomsAgent,
											  longName,
											  externalRef,
											  badCredit,
											  code,            //28.03.2020 cwma1 #48994
											  additionalInfo1, //28.03.2020 cwma1 #48994
											  additionalInfo2);//28.03.2020 cwma1 #48994

			debtorNodeController.parentNodeName := _parentName;
			debtorNodeController.code 			:= debtorCode;							    // TFS 40294			
			allCarriers.copyNoDuplicates(debtorNodeController.allCarriers, false);			// TFS 36473
			allAgents.copyNoDuplicates(debtorNodeController.allCustomsAgents, false);		// TFS 36473
			allConsignors.copyNoDuplicates(debtorNodeController.allConsignors, false);		// TFS 36473
			allContacts.copyNoDuplicates(debtorNodeController.allContacts, false);			// TFS 36473
			allDebtorTypes.copyNoDuplicates(debtorNodeController.allDebtorTypes, false);	// TFS 36473
			allOperators.copyNoDuplicates(debtorNodeController.allOperators, false);		// TFS 36473
			allDebtorTerminalDetails.copyNoDuplicates(debtorNodeController.allDebtorTerminalDetails, false); // TFS 40294

			if myParentDebtor = null then
				debtorNodeController.myParentDebtorNode := null;
			endif;

			// add or update
			existingDebtorNode := app.myRoot.myRootCompany.debtorNodes[debtorName];
			if existingDebtorNode &lt;&gt; null then
				beginLoad;
				pxyDebtorNode := existingDebtorNode.pxyCreateUpdateProxy();
				endLoad;
			else
				if className = "CM_DebtorGroup" then
					create pxyDebtorNode as CM_DebtorGroup transient;
				else
					create pxyDebtorNode as CM_Debtor transient;
				endif;
			endif;
			debtorNodeController.myPxyDebtorNode := pxyDebtorNode;
			pxyDebtorNode.setProxy(debtorNodeController.name, debtorNodeController.code);		// TFS 40092
			_controllerArray.add(debtorNodeController);
			_debtorArray.add(debtorName);
		else
			create err transient;
			err.set(0, app.getErrorString(INV_Debtor) 			&amp; ' : ' &amp; 
					   app.getErrorString2(Line_duplicate_file	, "", 
					   app.getErrorString(INV_Debtor_Register)) &amp; 
					   debtorName, false, '', debtorNodeController, null);
			_errorStore.add(err);
		endif;
	endif;
	
	// process the children after the parent
	if parentElement &lt;&gt; null then
		// if this is the top-level, the parent is the local CM_RootDebtorGroup - indicate this by passing a null parent name
		if className = "CM_RootDebtorGroup" then
			debtorName := null;
		endif;
		childIter := parentElement.childNodes.createIterator;
		while childIter.next(childNode) do
			if not childNode.isKindOf(JadeXMLElement) then
				continue;
			endif;
			cashTerminalCodes.clear;	 // TFS 40294 - clear Cash Terminal details before processing each debtor
			paymentTypeDescs.clear;  	 // TFS 40294			
			self.trxImportDebtorNode(childNode.JadeXMLElement, debtorName, _controllerArray, _debtorArray, _errorStore);
		endwhile;
	endif;

epilog
	delete iter;
	delete childIter;
	delete allAgentCodes;					// TFS 36473
	delete allAgents;						// TFS 36473
	delete allCarrierCodes;					// TFS 36473
	delete allCarriers;						// TFS 36473
	delete allConsignorCodes;				// TFS 36473
	delete allConsignors;					// TFS 36473
	delete allContactCodes;					// TFS 36473
	delete allContacts;						// TFS 36473
	delete allDebtorTypeCodes;				// TFS 36473
	delete allDebtorTypes;					// TFS 36473
	delete allOperatorCodes;				// TFS 36473
	delete allOperators; 					// TFS 36473
	delete allDebtorTerminalDetails;		// TFS 45436
end;</source>
        <Parameter name="_jadeXMLElement" type="JadeXMLElement" usage="input"/>
        <Parameter name="_parentName" type="String"/>
        <Parameter name="_controllerArray" type="ObjectArray" usage="input"/>
        <Parameter name="_debtorArray" type="CnStringArray" usage="input"/>
        <Parameter name="_errorStore" type="CM_ErrorSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxImportDebtorNodeFromFile" id="0c7fd9cc-d85c-4258-9ca8-324ebd4d559e">
        <updating/>
        <source>trxImportDebtorNodeFromFile( _file : File; _passport : CM_Passport input ) updating;

/*
Purpose:		MES 1010 Interface load	

Parameters:		Import File and passport	

Date		Who		Reason
19/08/2009	cnwjmn1	Initial creation
13/07/2010	cnwrl1	PAR 24848 - System Admin Import option to allow minimum number of fields.
01/05/2015	cnwjre1	36322 add longName
08/10/2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
16/05/2016	cnwns1	TFS 488 - Multi Timezone Support
09/08/2018	jlgdap1	TFS 40092 New parameter for CM_DebtorNode::setProxy
28/03/2020  cnwma1	Bug 48994: ASPA - Debtor Uploads missing Attributes
*/
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	count, 
	numCodes,
	noLines,
	fieldNo					: Integer;
	fieldValue,
	longName,
	debtorName,
	debtorParent,
	debtorType,
	debtorAddress,
	purchOrder,
	account,
	terms,
	carrier,
	consignor, 
	operator, 
	remarks,
	fileLine,
	code,
	extRef,
	addInfo1,
	addInfo2				: String;
	poMandatory,
	zeroRated,
	suspended,
	badCredit,
	reeferFlatRate,
	reeferDaily				: Boolean;
	fieldArray, 
	debtorArray				: CnStringArray;
	myParentDebtor,
	newDebtor, 
	pxyDebtorNode 			: CM_DebtorNode;
	myTofT					: CM_InvoiceTermsOfTrade;
	myCarrier				: CM_Carrier;
	myOperator				: CM_Operator;
	myConsignor				: CM_ConsigneeConsignor;
	myDebtorType			: CM_DebtorType;
	theRoot					: CM_Root;
	thePassport				: CM_Passport;
	debtorNodeController	: CMIF_DebtorNode;
	err						: CM_Error;
	errorStore				: CM_ErrorSet;
	controllerArray			: ObjectArray;
	obj						: Object;
	existingDebtorNode		: CM_DebtorNode;
	progressInt				: TimeStampInterval;
	progressTS			 	: TimeStamp;
begin
	thePassport := _passport;
	theRoot 	:= app.myRoot;

	// Always initialize the activity first
	self.initialiseActivityWithPassport(thePassport, method);

	// Arm our base exception handlers
	on Exception     do agtPassportExHandler(exception, thePassport);
	on LockException do agtPassportLockExHandler(exception, thePassport);
	app.setContinueCMExceptions(false);
	
	progressTS := app.actualTimeServer();
	if not _file.tryOpen() then
		app.raiseCMException(VB_FILE_ERROR, app.getErrorString(File_open), null);	
		return;
	endif;
	
	create controllerArray transient;
	create fieldArray	   transient;
	create debtorArray	   transient;
	create errorStore 	   transient;
	
	//ignore first line then process file
	fileLine 	:= _file.readLine;
	noLines		:= 1;
	
	while not _file.endOfFile() do
		fileLine 	:= _file.readLine;
		noLines		:= noLines + 1;
		if fileLine = null then
			continue;
		endif;
		
		fieldArray.clear;
		fileLine.csvToStringArray(fieldArray, ",");
		
		if fieldArray.isEmpty then
			continue;
		endif;
		
		debtorName		:= null;
		debtorParent	:= null;
		debtorAddress	:= null;
		remarks			:= null;
		account			:= null;
		purchOrder		:= null;
		poMandatory		:= null;
		terms			:= null;
		zeroRated		:= null;
		suspended		:= null;
		carrier			:= null;
		consignor		:= null;
		operator		:= null;
		debtorType		:= null;
		longName		:= null;
		code            := null;
		extRef          := null;
		addInfo1        := null;
		addInfo2        := null;
		badCredit       := false;
		
		fieldNo 		:=	0;
		
		foreach fieldValue in fieldArray do
			fieldNo	:=	fieldNo + 1;
			
			if fieldNo = 1 then
				debtorName		:= fieldValue.trimBlanks();
			elseif fieldNo = 2 then
				debtorParent	:= fieldValue.trimBlanks();
			elseif fieldNo = 3 then
				debtorAddress	:= fieldValue.trimBlanks();
			elseif fieldNo = 4 then
				remarks			:= fieldValue.trimBlanks();
			elseif fieldNo = 5 then
				account			:= fieldValue.trimBlanks();
			elseif fieldNo = 6 then
				purchOrder		:= fieldValue.trimBlanks();
			elseif fieldNo = 7 then
				poMandatory		:= fieldValue.trimBlanks().asBooleanJMT;
			elseif fieldNo = 8 then
				terms			:= fieldValue.trimBlanks();
			elseif fieldNo = 9 then
				zeroRated		:= fieldValue.trimBlanks().asBooleanJMT;
			elseif fieldNo = 10 then
				suspended		:= fieldValue.trimBlanks().asBooleanJMT;
			elseif fieldNo = 11 then
				carrier			:= fieldValue.trimBlanks();
			elseif fieldNo = 12 then
				consignor		:= fieldValue.trimBlanks();
			elseif fieldNo = 13 then
				operator		:= fieldValue.trimBlanks();
			elseif fieldNo = 14 then
				debtorType		:= fieldValue.trimBlanks();
			elseif fieldNo = 15 then
				longName		:= fieldValue.trimBlanks();		
			elseif fieldNo = 16 then
				code		:= fieldValue.trimBlanks();	
			elseif fieldNo = 17 then
				extRef		:= fieldValue.trimBlanks();	
			elseif fieldNo = 18 then
				addInfo1	:= fieldValue.trimBlanks();	
			elseif fieldNo = 19 then
				addInfo2	:= fieldValue.trimBlanks();	
			elseif fieldNo = 20 then
				badCredit	:= fieldValue.trimBlanks().asBooleanJMT;	
			endif;
		endforeach;
	
		
		if debtorParent &lt;&gt; null then
			myParentDebtor	:= theRoot.myRootCompany.debtorNodes[debtorParent];
			if myParentDebtor = null then
				create err transient;
				err.set(0, app.getErrorString(INV_Debtor)    &amp; ' : ' &amp; debtorName &amp; '  ' &amp; 
						   app.getErrorString(Invalid)       &amp; ' '   &amp; 
						   app.getErrorString(Debtor_parent) &amp; ' : ' &amp; 
						   debtorParent, false, '', null, null);
				errorStore.add(err);
			endif;
		else
			myParentDebtor	:= null;
		endif;		
		
		if terms &lt;&gt; null then
			myTofT				:= theRoot.myRootCompany.allInvoiceTermsOfTrade[terms];
			if myTofT = null then
				create err transient;
				err.set(0, app.getErrorString(INV_Debtor)     &amp; ' : ' &amp; debtorName &amp; '  ' &amp; 
						   app.getErrorString(Invalid)        &amp; ' '   &amp; 
						   app.getErrorString(Terms_of_trade) &amp; ' : ' &amp; 
						   terms , false, '', null, null);
				errorStore.add(err);
			endif;
		else
			myTofT	:= null;
		endif;	
		
		if carrier &lt;&gt; null then
			myCarrier			:= theRoot.allCarriers[carrier];
			if myCarrier = null then
				create err transient;
				err.set(0, app.getErrorString(INV_Debtor)    &amp; ' : ' &amp; debtorName &amp; '  ' &amp; 
						   app.getErrorString(Invalid)       &amp; ' '   &amp; 
						   app.getErrorString(Carrier)	     &amp; ' : ' &amp; 
						   carrier , false, '', null, null);
				errorStore.add(err);
			endif;
		else
			myCarrier	:= null;
		endif;	
		
		if operator &lt;&gt; null then
			myOperator			:= theRoot.allOperators[operator];
			if myOperator = null then
				create err transient;
				err.set(0, app.getErrorString(INV_Debtor)   &amp; ' : ' &amp; debtorName &amp; '  ' &amp; 
				app.getErrorString(Invalid) 				&amp; ' '   &amp; 
				app.getErrorString(Operator) 				&amp; ' : ' &amp; 
				operator , false, '', null, null);
				errorStore.add(err);
			endif;
		else
			myOperator	:= null;
		endif;		
		
		if consignor &lt;&gt; null then
			myConsignor			:= theRoot.allConsigneeConsignors[consignor];
			if myConsignor = null then
				create err transient;
				err.set(0, app.getErrorString(INV_Debtor) 		&amp; ' : ' &amp; debtorName &amp; '  ' &amp; 
						   app.getErrorString(Invalid) 			&amp; ' '   &amp; 
						   app.getErrorString(Consignor_code)   &amp; ' : ' &amp; 
						   consignor , false, '', null, null);
				errorStore.add(err);
			endif;
		else
			myConsignor	:= null;
		endif;		
		
		if debtorType &lt;&gt; null then
			myDebtorType		:= theRoot.allDebtorTypes[debtorType];
			if myDebtorType = null then
				create err transient;
				err.set(0, app.getErrorString(INV_Debtor) 		&amp; ' : ' &amp; debtorName &amp; '  ' &amp; 
				           app.getErrorString(Invalid) 		    &amp; ' '   &amp; 
						   app.getErrorString(Debtor_type)      &amp; ' : ' &amp; 
						   debtorType , false, '', null, null);
				errorStore.add(err);
			endif;
		else
			myDebtorType	:= null;
		endif;			
		
		if not debtorArray.includes(debtorName) then
			create debtorNodeController transient;
			debtorNodeController.setForImport(debtorName,
											debtorAddress, 
											remarks, 
											account, 
											purchOrder,
											poMandatory, 
											zeroRated, 
											suspended, 
											myParentDebtor,
											myTofT, 
											myCarrier, 
											myOperator, 
											myConsignor,
											myDebtorType,
											null,
											longName,
											extRef,
											badCredit,
											code,      //28.03.2020 cwma1 #48994
											addInfo1,  //28.03.2020 cwma1 #48994
											addInfo2); //28.03.2020 cwma1 #48994

			existingDebtorNode := app.myRoot.myRootCompany.debtorNodes[debtorName];
			if existingDebtorNode &lt;&gt; null then
				beginLoad;														
				pxyDebtorNode := existingDebtorNode.pxyCreateUpdateProxy();		
				endLoad;
			else
				create pxyDebtorNode as CM_Debtor transient;
			endif;
			
			debtorNodeController.myPxyDebtorNode := pxyDebtorNode;
			pxyDebtorNode.setProxy(debtorNodeController.name, debtorNodeController.code);		// TFS 40092
			controllerArray.add(debtorNodeController);
			debtorArray.add(debtorName);
		else
			create err transient;
			err.set(0, app.getErrorString(INV_Debtor) 	          &amp; ' : ' &amp; 
					   app.getErrorString2(Line_duplicate_file,   noLines.String, 
					   app.getErrorString(INV_Debtor_Register))   &amp; 
					   debtorName, false, '', debtorNodeController, null);
			errorStore.add(err);
		endif;		
	endwhile;
	
	if thePassport.myCMIFMonitor &lt;&gt; null then
		thePassport.myCMIFMonitor.updateProgress(app.getErrorString(Reading_import_file), 10, 10);
	endif;
	
	count:= 0;
	numCodes := controllerArray.size;
	
	// Start the transaction
	beginTransaction;
	
	// Perform the operation
	foreach obj in controllerArray do
		debtorNodeController	:= obj.CMIF_DebtorNode;
		count := count + 1;
		progressInt := app.actualTimeServer() - progressTS;	
		if thePassport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (count = numCodes)) then
			thePassport.myCMIFMonitor.updateProgress(app.getErrorString1(Creating_msg, app.getErrorString(INV_Debtor_Register)), numCodes, count);
			progressTS := app.actualTimeServer();			
		endif;
		
		if app.myRoot.myRootCompany.debtorNodes.includesKey(debtorNodeController.name) then		
			app.myUtilityUA.utlUpdateDebtorNode(debtorNodeController, thePassport);			
		else
			app.myUtilityCA.utlCreateDebtorNode(debtorNodeController, newDebtor, thePassport);
		endif;

		if thePassport.hasErrors then
			foreach err in thePassport.allErrors do 
				err.setErrorText(app.getErrorString(INV_Debtor) &amp; ' : ' &amp; debtorNodeController.name &amp; '  ' &amp; err.text, false);
				errorStore.add(err);
			endforeach;
			foreach err in thePassport.allErrors do 
				err.removeFromPassport;
			endforeach;
		endif;
	endforeach;
		
	trxWriteToLogFile(_file.fileName, noLines, count, thePassport, errorStore);
	
epilog
	delete debtorArray;
	delete fieldArray;
	if controllerArray &lt;&gt; null then
		foreach obj in controllerArray do						
			delete obj.CMIF_DebtorNode.myPxyDebtorNode;
			delete obj;
		endforeach;
		delete controllerArray;
	endif;
	_file.close;
	self.finaliseActivityWithPassport(thePassport);
	delete errorStore;
end;
</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxImportDebtorsFromFile" id="99e84f7d-b31e-4d15-92e0-13b9baa532a8">
        <updating/>
        <source>trxImportDebtorsFromFile( _file : File; _passport : CM_Passport input ) : Integer updating;

/*
Purpose:		DOHA copy debtors from Test to UAT

Parameters:		Import File and passport.  File format is XML, see CM_ExtractLoadAgent::extractDebtors

Date		Who		Reason
Apr 2012	cnwjre1	Copy debtors with groups from one JMT copy to another
*/
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	hadException						: Boolean;
	count, numCodes, noLines 			: Integer;
	debtorArray							: CnStringArray;
	newDebtor							: CM_DebtorNode;
	thePassport							: CM_Passport;
	debtorNodeController				: CMIF_DebtorNode;
	err									: CM_Error;
	errorStore							: CM_ErrorSet;
	controllerArray						: ObjectArray;
	obj									: Object;

	xmlDocumentParser : JadeXMLDocumentParser;
	rootElement : JadeXMLElement;
	xmlDocument : JadeXMLDocument;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	thePassport := _passport;

	// Always initialize the activity first
	self.initialiseActivityWithPassport(thePassport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, thePassport);
	on LockException do agtPassportLockExHandler(exception, thePassport);
	app.setContinueCMExceptions(false);
	
	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	if not _file.tryOpen() then
		app.raiseCMException(VB_FILE_ERROR, app.getErrorString(File_open), null);	
		return 0;
	endif;
	
	create controllerArray transient;
	create debtorArray transient;
	create errorStore transient;
	
	create xmlDocumentParser transient;
	create xmlDocument transient;
	xmlDocumentParser.parseDocumentFile(xmlDocument,_file.fileName);
	rootElement := xmlDocument.rootElement;
	
	self.trxImportDebtorNode(rootElement, "ROOT", controllerArray, debtorArray, errorStore);
	
	if thePassport.myCMIFMonitor &lt;&gt; null then
		thePassport.myCMIFMonitor.updateProgress(app.getErrorString(Reading_import_file), 10, 10);
	endif;
	
	count:= 0;
	numCodes := controllerArray.size;
	noLines := numCodes;
	
	// Start the transaction
	beginTransaction;
	
	// Perform the operation
	foreach obj in controllerArray do
		debtorNodeController	:= obj.CMIF_DebtorNode;
		progressInt := app.actualTimeServer() - progressTS;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if thePassport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (count = numCodes)) then
			thePassport.myCMIFMonitor.updateProgress(app.getErrorString1(Creating_msg, app.getErrorString(INV_Debtor_Register)), numCodes, count);
			progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		if app.myRoot.myRootCompany.debtorNodes[debtorNodeController.name] &lt;&gt; null then
			app.myUtilityUA.utlUpdateDebtorNode(debtorNodeController, thePassport);
		else
			app.myUtilityCA.utlCreateDebtorNode(debtorNodeController, newDebtor, thePassport);
		endif;

		// proxy/transient clean up
		delete debtorNodeController.myPxyDebtorNode;
		
		if thePassport.hasErrors then
			foreach err in thePassport.allErrors do 
				err.setErrorText(app.getErrorString(INV_Debtor) &amp; ' : ' &amp; debtorNodeController.name &amp; '  ' &amp; err.text, false);
				errorStore.add(err);
			endforeach;
			// clear errors from logic so that any successful updates will still be done but stop on any exception
			foreach err in thePassport.allErrors do
				if err.errorCode &lt; app.baseErrorNum then
					count := 0;
					hadException := true;
					break;
				endif;
				err.removeFromPassport;
			endforeach;
		else
			count := count + 1;
		endif;
		if hadException then
			break;
		endif;
	endforeach;
	
	self.trxWriteToLogFile2(_file.fileName, noLines, count, errorStore);
	
	return count;
	
epilog
	delete debtorArray;
	if controllerArray &lt;&gt; null then
		foreach obj in controllerArray do
			debtorNodeController := obj.CMIF_DebtorNode;
			// proxy/transient clean up
			delete debtorNodeController.myPxyDebtorNode;
		endforeach;
		controllerArray.purge;
		delete controllerArray;
	endif;
	delete xmlDocumentParser;
	delete xmlDocument;
	_file.close;
	self.finaliseActivityWithPassport(thePassport);
	delete errorStore;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxImportDutyDocHSCodesFromFil" id="91ecbd45-f393-4c6e-a9dd-0f7a4bc76cd4">
        <updating/>
        <source>trxImportDutyDocHSCodesFromFil( _file : File; _passport : CM_Passport input ) updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2012	cnwmc5	Initial creation HAT 2189
*/
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	count				: Integer;
	numCodes			: Integer;
	noLines				: Integer;
	fieldNo				: Integer;
	fieldValue			: String;
	fileLine			: String;
	fieldArray			: CnStringArray;
	thePassport			: CM_Passport;
	err					: CM_Error;
	errorStore			: CM_ErrorSet;

	newHSCode			: CM_DutyDocHSCode;
	currentHSCode		: CM_DutyDocHSCode;
	pxyHSCode			: CM_DutyDocHSCode;
	hsDutyDocColl		: CM_DutyDocHSCodesByCode;
	theRoot				: CM_DutyDocRoot;
	
	hsCode				: Integer64;
	hsLongDesc			: String;
	hsShortDesc			: String;
	hsDutyType			: String;
	hsDutyRate			: Decimal[5,2];
	hsDutyExempt		: Boolean;
	hsPriceCargo		: Boolean;
	hsChemicalCargo		: Boolean;
	hsNuclearCargo		: Boolean;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	thePassport := _passport;
	theRoot 	:= app.myDutyDocRoot;

	// Always initialize the activity first
	self.initialiseActivityWithPassport(thePassport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, thePassport);
	on LockException do agtPassportLockExHandler(exception, thePassport);

	app.setContinueCMExceptions(false);
	
	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	if not _file.tryOpen() then
		app.raiseCMException(VB_FILE_ERROR, app.getErrorString(File_open), null);	
		return;
	endif;
	
	create hsDutyDocColl transient;
	create fieldArray transient;
	create errorStore transient;
	
	//ignore first line
	fileLine 	:= _file.readLine();
	noLines		:= 1;
	
	while not _file.endOfFile() do
		fileLine 	:= _file.readLine;
		noLines		:= noLines + 1;
		if fileLine = null then
			continue;
		endif;
		
		fieldArray.clear();
		fileLine.csvToStringArray(fieldArray, ",");
		
		// cnwrl1 07/07/2010 PAR 24848 - start of coding
		if fieldArray.isEmpty then
			continue;
		endif;
		hsCode			:= null;
		hsLongDesc		:= null;
		hsShortDesc		:= null;
		hsDutyType		:= null;
		hsDutyRate 		:= null;
		hsDutyExempt	:= null;
		hsPriceCargo	:= null;
		hsChemicalCargo	:= null;
		hsNuclearCargo	:= null;
		// cnwrl1 07/07/2010 PAR 24848 - end of coding
		
		/*
		The import layout for this table is exactly (or similar) to the column organiser "JMT Default".
		This is what has been supplied to Messina in document CCMS MES 1008, 1010 Interfaces Messages,
		also see the JMT User Guide section for System Codes Reference.
		*/
		fieldNo	:=	0;
		
		foreach fieldValue in fieldArray do
			fieldNo	:=	fieldNo + 1;
			
			// cnwrl1 06/07/2010 PAR 24606 - reorder import fields to match "JMT Default"
			if fieldNo = 1 then
				continue;
			elseif fieldNo = 2 then
				hsCode			:=	fieldValue.trimBlanks().asIntegerJMT();
			elseif fieldNo = 3 then
				hsShortDesc		:=	fieldValue.trimBlanks();
			elseif fieldNo = 4 then
				hsLongDesc		:=	fieldValue.trimBlanks();
			elseif fieldNo = 5 then
				hsDutyType		:=	fieldValue.trimBlanks();
			elseif fieldNo = 6 then
				hsDutyRate		:= fieldValue.trimBlanks().asDecimalJMT();
			elseif fieldNo = 7 then
				hsDutyExempt	:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 8 then
				continue;
			elseif fieldNo = 9 then
				hsPriceCargo	:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 10 then
				hsChemicalCargo		:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 11 then
				hsNuclearCargo		:=	fieldValue.trimBlanks().asBooleanJMT();
			endif;
		endforeach;
		
		// if hs code already exists get fields not in file so they aren't cleared
		/*currentHSCode := theRoot.allDutyDocHSCodes[hsCode];
		if currentHSCode &lt;&gt; null then
			//order := currentConsignor.order;
			
			//05/07/2010 cnwdz2 par24597
			//if emailPINAddresses = null then
			//	create emailPINAddresses transient;
			//else
			//	emailPINAddresses.clear();
			//endif;
			//currentConsignor.allPINNotifyEmailAddresses.copy(emailPINAddresses);
			
			//if colour = 0 then
			//	colour			:=	currentConsignor.colour;
			//endif;
		//else
			//order				:= 0;
			//emailPINAddresses	:=	null;
		endif;*/
		
		if not hsDutyDocColl.includesKey(hsCode) then
			create pxyHSCode transient;
			pxyHSCode.setProxy(	hsCode,
								hsLongDesc,
								hsShortDesc,
								hsDutyType,
								hsDutyRate,
								hsDutyExempt,
								hsPriceCargo,
								hsChemicalCargo,
								hsNuclearCargo );
			
			hsDutyDocColl.add(pxyHSCode);
		else
			create err transient;
			err.set(0,
					app.getErrorString(Duty_code) &amp; ' : ' &amp; app.getErrorString2(Line_duplicate_file, noLines.String, app.getErrorString(HS_codes)) &amp; hsCode.String,
					false,
					'',
					null,
					null);
			errorStore.add(err);
		endif;
	endwhile;
	
	if thePassport.myCMIFMonitor &lt;&gt; null then
		thePassport.myCMIFMonitor.updateProgress(app.getErrorString(Reading_import_file), 10, 10);
	endif;
	
	if thePassport.hasErrors() then
		return;
	endif;
	
	count		:=	0;
	numCodes	:=	hsDutyDocColl.size();
	
	// Start the transaction
	beginTransaction;
	
	// Perform the operation
	foreach pxyHSCode in hsDutyDocColl do
		count := count + 1;
		
		progressInt := app.actualTimeServer() - progressTS;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if thePassport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (count = numCodes)) then
			thePassport.myCMIFMonitor.updateProgress(app.getErrorString1(Creating_msg, app.getErrorString(HS_codes)), numCodes, count);
			progressTS := app.actualTimeServer();		// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		currentHSCode := theRoot.allDutyDocHSCodes[pxyHSCode.code];
		
		if currentHSCode = null then
			app.myUtilityCA.utlCreateDutyDocHSCode(pxyHSCode, newHSCode, thePassport);
		else
			app.myProxyManager.createProxyLink(currentHSCode, pxyHSCode);
			app.myUtilityUA.utlUpdateDutyDocHSCode(pxyHSCode, thePassport);
		endif;
		
		if thePassport.hasErrors() then
			foreach err in thePassport.allErrors do
				err.setErrorText(app.getErrorString(Duty_code
				) &amp; ' : ' &amp; pxyHSCode.code.String &amp; '  ' &amp; err.text, false);
				errorStore.add(err);
			endforeach;
			
			foreach err in thePassport.allErrors do
				err.removeFromPassport();
			endforeach;
		endif;
	endforeach;
	
	trxWriteToLogFile(_file.fileName, noLines, count, thePassport, errorStore);
	
epilog
	delete pxyHSCode;
	if hsDutyDocColl &lt;&gt; null then
		hsDutyDocColl.purge();
		delete hsDutyDocColl;
	endif;
	
	delete fieldArray;
	_file.close();
	self.finaliseActivityWithPassport(thePassport);
	delete errorStore;
end;
</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxImportEDIXlationFromCSV" id="c8a2e0f7-e6bc-45c1-9dda-7dc8ed328d8a">
        <updating/>
        <source>trxImportEDIXlationFromCSV(_file : File;
							_type : Integer;
							_operator : CM_Operator; 
							_terminal : CM_Terminal;
							_cargoType : CM_CargoType;
							_ignoreFirstRow : Boolean;
							_colSystem, _colForeign, _colOut : Integer;	// 18/12/2024 navcs2 MTN-33462
							_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
31 January 2023		jlizm1	Initial creation TFS 56291 POB - CSV Import of translation terms
18 December 2024	navcs2	MTN-33462	EUP NTO-972 - EDI Data translation uploads do not save the Foreign Out Code
*/
vars
	noLines			: Integer;
	count		 	: Integer;
	proxyXlatIn		: CM_Xlation_In;
	newXlatIn		: CM_Xlation_In;
	proxyXlatOut	: CM_Xlation_Out;		// 18/12/2024 navcs2 MTN-33462
	newXlatOut		: CM_Xlation_Out;		// 18/12/2024 navcs2 MTN-33462
	xlatTable		: CM_XlationTable;
	pxyXlatTable	: CM_XlationTable;
	err				: CM_Error;
	errorStore		: CM_ErrorSet;
	obj				: Object;
	progressInt		: TimeStampInterval;
	progressTS 		: TimeStamp;
	file			: File;
	str				: String;
	array			: HugeStringArray;
	foreignCode		: String;
	systemCode		: String;
	foreignOutCode	: String;
	opTerm			: CM_OperatorTerminal;
	colMax			: Integer;
	fileSize		: Integer;
	bytesRead		: Integer;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	app.setContinueCMExceptions(false);
	
	file := _file;
	progressTS := app.actualTimeServer();
	
	if not file.tryOpen() then
		app.raiseCMException(VB_FILE_ERROR, app.getErrorString(File_open), null);
		return;
	endif;

	create errorStore transient;
	create array transient;
	
	if CM_XlationTable@isOperatorTerminalXlation(_type) then
		if _operator &lt;&gt; null and _terminal &lt;&gt; null then
			opTerm := _operator.allOperatorTerminals[_terminal];
			if opTerm = null then
				create opTerm transient;
				opTerm.setMyOperator(_operator);
				opTerm.setMyTerminal(_terminal);
			endif;
		endif;
	endif;
	
	fileSize := file.fileLength;
	if _colForeign &gt; _colSystem then
		colMax := _colForeign;
	else
		colMax := _colSystem;
	endif;
	
	if colMax &lt; _colOut then		// 18/12/2024 navcs2 MTN-33462
		colMax := _colOut;			// 18/12/2024 navcs2 MTN-33462
	endif;							// 18/12/2024 navcs2 MTN-33462
	
	if _ignoreFirstRow and not file.endOfFile then
		file.readLine();
		noLines := noLines + 1;
	endif;
	
	beginTransaction;
	while not file.endOfFile do
		progressInt := app.actualTimeServer() - progressTS;
		if _passport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= CMIF_Monitor.Monitor_TimeBetweenUpdates)) then
			_passport.myCMIFMonitor.updateProgress(app.getErrorString1(Creating_msg, 'EDI Xlation'), fileSize, bytesRead);
			progressTS := app.actualTimeServer();
		endif;
		
		str := file.readLine();
		noLines := noLines + 1;
		
		if str = null then
			continue;
		endif;
		
		bytesRead := bytesRead + str.lengthInBytes;
		str.parseCSV(array);
		if array.size &lt; colMax then
			create err transient;
			app.raiseCMException1(IncorrectNumberOfFields, noLines.asStringJMT(), null, null);
			return;
		endif;

		foreignCode := array[_colForeign].trimBlanks();
		systemCode := array[_colSystem].trimBlanks();
		if _colOut &lt;&gt; null then
			foreignOutCode := array[_colOut].trimBlanks();	// 18/12/2024 navcs2 MTN-33462
		endif;
		
		xlatTable := null;
		if opTerm &lt;&gt; null then
			xlatTable := opTerm.allXlationTables[_type, null];
		endif;
		
		if xlatTable &lt;&gt; null then
			beginLoad;
			pxyXlatTable := xlatTable.pxyCreateUpdateProxy();
			endLoad;
		else
			create pxyXlatTable transient;
			if CM_XlationTable@isSystemXlation(_type) then
				pxyXlatTable.setProxy(_type, app.myRoot, null, null, null, null);
			elseif _type = XLATION_TYPE_WORKPOINT then
				pxyXlatTable.setProxy(_type, null, null, null, null, _terminal);
			elseif CM_XlationTable@isOperatorTerminalXlation(_type) then
				pxyXlatTable.setProxy(_type, null, null, opTerm, null, null);
			elseif _type = XLATION_TYPE_CARGOSUBTYPE_BYOP then
				pxyXlatTable.setProxy(_type, null, _operator, null, _cargoType, null);
			else
				pxyXlatTable.setProxy(_type, null, _operator, null, null, null);
			endif;	
			
		endif;
		
		create proxyXlatIn transient;
		proxyXlatIn.setProxy(systemCode, foreignCode, pxyXlatTable);
		
		if _colOut &lt;&gt; null then
			create proxyXlatOut transient;											// 18/12/2024 navcs2 MTN-33462
			proxyXlatOut.setProxy(systemCode, foreignOutCode, pxyXlatTable);		// 18/12/2024 navcs2 MTN-33462
		endif;

		app.myUtilityUA.utlUpdateXlation(pxyXlatTable, _passport);
		
		if _passport.hasErrors then
			str := "";
			if not pxyXlatTable.allInwardTranslations.isEmpty then
				str := pxyXlatTable.allInwardTranslations.last.systemCode;
			endif;

			foreach err in _passport.allErrors do 
				err.setErrorText("Line " &amp; noLines.asStringJMT &amp; ' - edi Xlation ' &amp; ' : ' &amp; str &amp; '  ' &amp; err.text, false);
				errorStore.add(err);
			endforeach;
			
			count := 0;
			break;
		endif;
		
		delete proxyXlatIn;
		delete pxyXlatTable;	
	
		if opTerm &lt;&gt; null and opTerm.isTransient then
			opTerm := _operator.allOperatorTerminals[_terminal];
		endif;
		
		count := count + 1;
	endwhile;

	if _ignoreFirstRow and noLines &gt; 0 then
		// set number of lines to be number of data lines
		noLines := noLines -1;
	endif;
	
	self.trxWriteToLogFile2(_file.fileName, noLines, count, errorStore);

epilog
	self.finaliseActivityWithPassport(_passport);
	
	delete array;
	delete proxyXlatIn;
	delete pxyXlatTable;

	if app.isValidObject(opTerm) and opTerm.isTransient then
		delete opTerm;
	endif;
	
	delete errorStore;

end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_ignoreFirstRow" type="Boolean"/>
        <Parameter name="_colSystem" type="Integer"/>
        <Parameter name="_colForeign" type="Integer"/>
        <Parameter name="_colOut" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxImportGLCodeObject" id="74bdaaa9-f80c-4fa0-818d-6a31402bc383">
        <updating/>
        <source>trxImportGLCodeObject(_jadeXMLElement : JadeXMLElement input; _proxyArray : ObjectArray input; 
							   _errorStore : CM_ErrorSet input; _bank : CM_Bank) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
May 2015	cnwjre1	Copy GL codes from one JMT to another

*/

vars
	xmlNode			: JadeXMLNode;
	xmlElement		: JadeXMLElement;
	iter			: Iterator;

	isNotAvailableForEntry	: Boolean;
	code,
	remarks			: String;
	externalRef : String;

	realGLCode,
	proxyGLCode		: CM_GLCode;
	
begin
	if _jadeXMLElement = null then
		return;
	endif;
	
	code		:= null;
	remarks		:= null;
	isNotAvailableForEntry	:= null;

	iter := _jadeXMLElement.childNodes.createIterator;
	while iter.next(xmlNode) do
		if not xmlNode.isKindOf(JadeXMLElement) then
			continue;
		endif;

		xmlElement := xmlNode.JadeXMLElement;
		// property values for this GL code
		if xmlElement.tagName = "code" then
			code := xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "remarks" then
			remarks := xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "isNotAvailableForEntry" then
			isNotAvailableForEntry := xmlElement.textData.Boolean;
		elseif xmlElement.tagName = "externalRef" then	//28 May 2018	NDL	TFS 38896
			externalRef := xmlElement.textData.trimBlanks();
		endif;
	endwhile;
	
	// add if new otherwise update existing object
	realGLCode := _bank.glCodes[code];
	if realGLCode &lt;&gt; null then
		proxyGLCode := app.createUpdateProxy(realGLCode).CM_GLCode;
	else
		create proxyGLCode as CM_GLCode transient;
	endif;

	proxyGLCode.setProxy(_bank, code, remarks, isNotAvailableForEntry, externalRef);

	_proxyArray.add(proxyGLCode);
	
epilog
	delete iter;
end;</source>
        <Parameter name="_jadeXMLElement" type="JadeXMLElement" usage="input"/>
        <Parameter name="_proxyArray" type="ObjectArray" usage="input"/>
        <Parameter name="_errorStore" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="trxImportGLCodesFromFile" id="6382a588-ca0f-4701-81f7-6fea960eb0c8">
        <updating/>
        <source>trxImportGLCodesFromFile( _file : File; _bank : CM_Bank; _passport : CM_Passport input ) : Integer updating;

/*
Purpose:		ADP copy invoice GL codes from UAT to production

Parameters:		Import File, bank and passport.  File format is XML, see CM_ExtractLoadAgent::extractGLCodesForBank

Date		Who		Reason
May 2013	cnwjre1	Copy GL codes from one JMT copy to another
*/
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	hadException						: Boolean;
	count, numCodes, noLines 			: Integer;
	proxyGLCode, newGLCode				: CM_GLCode;
	theRoot								: CM_Root;
	thePassport							: CM_Passport;
	err									: CM_Error;
	errorStore							: CM_ErrorSet;
	proxyArray							: ObjectArray;
	obj									: Object;

	xmlDocumentParser : JadeXMLDocumentParser;
	rootElement : JadeXMLElement;
	rootNode	: JadeXMLNode;
	childElement	: JadeXMLElement;
	xmlDocument : JadeXMLDocument;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	thePassport := _passport;
	theRoot 	:= app.myRoot;
	if thePassport.myTerminal = null then
		thePassport.setMyTerminal(_bank.terminal);
	endif;

	// Always initialize the activity first
	self.initialiseActivityWithPassport(thePassport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, thePassport);
	on LockException do agtPassportLockExHandler(exception, thePassport);
	app.setContinueCMExceptions(false);
	
	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	if not _file.tryOpen() then
		app.raiseCMException(VB_FILE_ERROR, app.getErrorString(File_open), null);	
		return 0;
	endif;
	
	create proxyArray transient;
	create errorStore transient;
	
	create xmlDocumentParser transient;
	create xmlDocument transient;
	xmlDocumentParser.parseDocumentFile(xmlDocument,_file.fileName);
	rootElement := xmlDocument.rootElement;
	foreach rootNode in rootElement.childNodes do
		if rootNode.isKindOf(JadeXMLElement) then
			childElement := rootNode.JadeXMLElement;
			self.trxImportGLCodeObject(childElement, proxyArray, errorStore, _bank);
			noLines := noLines + 1;
		endif;
	endforeach;
	
	if thePassport.myCMIFMonitor &lt;&gt; null then
		thePassport.myCMIFMonitor.updateProgress(app.getErrorString(Reading_import_file), 10, 10);
	endif;
	
	count:= 0;
	numCodes := proxyArray.size;
	
	// Start the transaction
	beginTransaction;
	
	// Perform the operation
	foreach obj in proxyArray do
		proxyGLCode := obj.CM_GLCode;
		progressInt := app.actualTimeServer() - progressTS;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if thePassport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (count = numCodes)) then
			thePassport.myCMIFMonitor.updateProgress(app.getErrorString1(Creating_msg, 'Invoice GL Code'), numCodes, count);
			progressTS := app.actualTimeServer();			// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		// add if new otherwise update existing object
		if _bank.glCodes[proxyGLCode.code] = null then
			app.myUtilityCA.utlCreateGLCode(proxyGLCode, newGLCode, app.myPassport);
		else
			app.myUtilityUA.utlUpdateGLCode(proxyGLCode, app.myPassport);
		endif;

		if thePassport.hasErrors then
			foreach err in thePassport.allErrors do 
				err.setErrorText('Invoice GL Code ' &amp; ' : ' &amp; proxyGLCode.code &amp; '  ' &amp; err.text, false);
				errorStore.add(err);
			endforeach;
			// clear errors from logic so that any successful updates will still be done but stop on any exception
			foreach err in thePassport.allErrors do
				if err.errorCode &lt; app.baseErrorNum then
					count := 0;
					hadException := true;
					break;
				endif;
				err.removeFromPassport;
			endforeach;
		else
			count := count + 1;		// count the successes
		endif;
		if hadException then
			break;
		endif;
	endforeach;
	
	self.trxWriteToLogFile2(_file.fileName, noLines, count, errorStore);
	
	return count;
	
epilog
	if proxyArray &lt;&gt; null then
		proxyArray.purge;
		delete proxyArray;
	endif;
	_file.close;
	delete xmlDocumentParser;
	delete xmlDocument;
	self.finaliseActivityWithPassport(thePassport);
	delete errorStore;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxImportISOTypeFromFile" id="b8586e85-4455-4985-a263-7f9d3e79e065">
        <updating/>
        <source>trxImportISOTypeFromFile( _file : File; _passport : CM_Passport input ) updating;

/*
Purpose:		MES 1010 Interface load	

Parameters:		Import File and passport	

Date		Who		Reason
11 August 2009	cnwjmn1	Initial creation
20/11/2009		cnwdad1	PAR 21650.  Changed to handle quoted fields.
21/05/2010	cnwmh5	Par24264 - Change order to be entdef default so canTwinLift moves from 28 to 3
					Adjust all the other field accordingly
06/07/2010	cnwrl1	PAR 24606 - Import order changed to match "JMT Default".
07/07/2010	cnwrl1	PAR 24848 - System Admin Import to allow minimum amount of data.
*/
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 04/08/2016	cnwdap1	TFS #2447 Ensure iso type code is uppercase
//02/10/2025	navkc1 JIRA 36151 AAT | RotaBox ISO Type and New Attributes - JADE
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	fieldNo				: Integer;
	count				: Integer;
	numCodes			: Integer;
	noLines				: Integer;
	isoCargoType		: Integer;
	isoColour			: Integer;
	isoTareWeight		: Integer;
	isoMaxTareWt		: Integer;
	isoMaxTotalWt		: Integer;
	isoCode				: String;
	isoDesc				: String;
	cargo				: String;
	isoTypeGroup		: String;
	fileLine			: String;
	fieldValue			: String;
	fieldArray			: CnStringArray;
	newIso				: CM_ISOType;
	pxyIso				: CM_ISOType;
	currentIso			: CM_ISOType;
	isoGroupObj			: CM_ISOTypeGroup;
	cargoTypeObj		: CM_CargoType;
	isoColl				: CM_ISOTypeByCodeDict;
	theRoot				: CM_Root;
	thePassport			: CM_Passport;
	err					: CM_Error;
	errorStore			: CM_ErrorSet;
	isGeneral			: Boolean;
	isFlat				: Boolean;
	isCrib				: Boolean;
	isTank				: Boolean;
	isOpenTop			: Boolean;
	isReefer			: Boolean;
	isPorthole			: Boolean;
	isIntegral			: Boolean;
	isFan				: Boolean;
	isPowered			: Boolean;
	isFrame				: Boolean;
	isTwentyFt			: Boolean;
	isThirtyFt			: Boolean;
	isFortyFt			: Boolean;
	isFortyfiveFt		: Boolean;
	fiftyThreeFt		: Boolean;
	isEightFtHigh		: Boolean;
	isEightFtSixHigh	: Boolean;
	isNineFtSixHigh		: Boolean;
	isFourFtHigh		: Boolean;
	isFourFtThreeHigh	: Boolean;
	isNotAvail			: Boolean;
	canBeTwin			: Boolean;
	isHalf				: Boolean;
	isMach				: Boolean;
	isRotatable			: Boolean; //02/10/2025	navkc1 JIRA 36151
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	thePassport := _passport;
	theRoot 	:= app.myRoot;

	// Always initialize the activity first
	self.initialiseActivityWithPassport(thePassport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, thePassport);
	on LockException do agtPassportLockExHandler(exception, thePassport);

	app.setContinueCMExceptions(false);
	
	if not _file.tryOpen() then
		app.raiseCMException(VB_FILE_ERROR, app.getErrorString(File_open), null);	
		return;
	endif;
	
	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	create isoColl transient;
	create fieldArray transient;
	create errorStore transient;
	
	//ignore first line
	fileLine	:=	_file.readLine();
	noLines		:=	1;
	
	while not _file.endOfFile() do
		fileLine := _file.readLine;
		noLines	:= noLines + 1;
		
		if fileLine = null then
			continue;
		endif;
		
		fieldArray.clear();
		fileLine.csvToStringArray(fieldArray, ",");
		
		/* cnwrl1 07/07/2010 PAR 24848 - what it was
		if fieldArray.size() &lt;&gt; 30 then
			create err transient;
			err.set(0, app.getErrorString1(Line_incorre_number_columns, noLines.String &amp; '  ' &amp; fieldArray.size.String ) , false, '', null, null);
			errorStore.add(err);
			continue;
		endif;		
		cnwrl1 07/07/2010 PAR 24848 - end of what it was */
		
		// cnwrl1 07/07/2010 PAR 24848 - start of coding
		if fieldArray.isEmpty then
			continue;
		endif;
		isoCode				:= null;
		isoDesc				:= null;
		cargo				:= null;
		isoColour			:= null;
		isoTypeGroup		:= null;
		isGeneral			:= null;
		isFlat				:= null;
		isCrib				:= null;
		isTank				:= null;
		isOpenTop			:= null;
		isReefer			:= null;
		isPorthole			:= null;
		isIntegral			:= null;
		isFan				:= null;
		isPowered			:= null;
		isFrame				:= null;
		isTwentyFt			:= null;
		isThirtyFt			:= null;
		isFortyFt			:= null;
		isFortyfiveFt		:= null;
		fiftyThreeFt		:= null;
		isoTareWeight		:= null;
		isEightFtHigh		:= null;
		isEightFtSixHigh	:= null;
		isNineFtSixHigh		:= null;
		isFourFtHigh		:= null;
		isFourFtThreeHigh	:= null;
		isNotAvail			:= null;
		canBeTwin			:= null;
		isoMaxTareWt		:= null;
		isoMaxTotalWt		:= null;
		isRotatable			:= null; //02/10/2025	navkc1 JIRA 36151
		// cnwrl1 07/07/2010 PAR 24848 - end of coding
		
		/*
		The import layout for this table is exactly (or similar) to the column organiser "JMT Default".
		This is what has been supplied to Messina in document CCMS MES 1008, 1010 Interfaces Messages,
		also see the JMT User Guide section for System Codes Reference.
		*/
		fieldNo :=	0;
		
		foreach fieldValue in fieldArray do
			fieldNo	:=	fieldNo + 1;
			
			// cnwrl1 06/07/2010 PAR 24606 - reorder import fields to match "JMT Default"
			if fieldNo = 1 then
				//isoCode			:=	fieldValue.trimBlanks();			// TFS #2447
				isoCode				:=	fieldValue.trimBlanks().toUpper;	// TFS #2447
			elseif fieldNo = 2 then
				isoDesc				:=	fieldValue.trimBlanks();
			elseif fieldNo = 3 then
				cargo				:=	fieldValue.trimBlanks();
			elseif fieldNo = 4 then
				isoColour			:=	fieldValue.Integer;
			elseif fieldNo = 5 then
				isoTypeGroup		:=	fieldValue.trimBlanks();
			elseif fieldNo = 6 then
				isGeneral			:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 7 then
				isFlat				:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 8 then
				isCrib				:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 9 then
				isTank				:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 10 then
				isOpenTop			:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 11 then
				isReefer			:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 12 then
				isPorthole			:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 13 then
				isIntegral			:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 14 then
				isFan				:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 15 then
				isPowered			:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 16 then	
				isFrame				:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 17 then
				isTwentyFt			:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 18 then
				isThirtyFt			:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 19 then
				isFortyFt			:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 20 then
				isFortyfiveFt		:=	fieldValue.trimBlanks().asBooleanJMT();	
			elseif fieldNo = 21 then
				fiftyThreeFt		:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 22 then
				isoTareWeight		:=	fieldValue.Integer;
			elseif fieldNo = 23 then
				isEightFtHigh		:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 24 then
				isEightFtSixHigh	:=	fieldValue.trimBlanks().asBooleanJMT();	
			elseif fieldNo = 25 then
				isNineFtSixHigh		:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 26 then
				isFourFtHigh		:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 27 then
				isFourFtThreeHigh	:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 28 then
				isNotAvail			:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 29 then
				canBeTwin			:=	fieldValue.trimBlanks().asBooleanJMT();
			elseif fieldNo = 30 then
				isoMaxTareWt		:=	fieldValue.Integer;
			elseif fieldNo = 31 then
				isoMaxTotalWt		:=	fieldValue.Integer;
			elseif fieldNo = 32 then
				isRotatable 		:= fieldValue.trimBlanks().asBooleanJMT(); //02/10/2025	navkc1 JIRA 36151
			endif;
		endforeach;
		
		isoCargoType 		:= theRoot.getCargoTypeIDFromDescription(cargo);	
		cargoTypeObj		:= theRoot.allCargoTypesById[isoCargoType];
		
		if isoTypeGroup &lt;&gt; null then
			isoGroupObj	:=	theRoot.allISOTypeGroups[isoTypeGroup];
			
			if isoGroupObj = null then
				create err transient;
				err.set(0, app.getErrorString(ISO_Type) &amp; ' : ' &amp; isoCode &amp; '  ' &amp; app.getErrorString(Invalid) &amp; ' ' &amp; app.getErrorString(ISO_Group) &amp; ' : ' &amp;isoTypeGroup , 
																																		false, '', null, null);
				errorStore.add(err);
				continue;
			endif;
		else
			isoGroupObj	:=	null;
		endif;		
		
// if iso Type already exists get fields not in file so they aren't cleared
		currentIso	:= theRoot.allISOTypes[isoCode];
		
		if currentIso &lt;&gt; null then
			isHalf		:= 	currentIso.isHalfHeight;
			isMach		:=	currentIso.isMachinery;
			
			if isoColour = 0 then
				isoColour		:=	currentIso.colour;
			endif;
		else
			isHalf		:= 	false;
			isMach		:=	false;
		endif;
		
		create pxyIso transient;
		pxyIso.setProxy(isoCode,
						isoDesc,
						isoTareWeight,
						isoColour,
						cargoTypeObj,
						isoGroupObj,
						isTwentyFt,
						isThirtyFt,
						isFortyFt,
						isFortyfiveFt,
						fiftyThreeFt,
						isFourFtThreeHigh,
						isFourFtHigh,
						isEightFtSixHigh,
						isEightFtHigh,
						isHalf,
						isNineFtSixHigh,
						isCrib,
						isFan,
						isFlat,
						isGeneral,
						isIntegral,
						isMach,
						isOpenTop,
						isPorthole,
						isPowered,
						isReefer,
						isTank,
						isFrame,
						isRotatable, //02/10/2025	navkc1 JIRA 36151
						isNotAvail,
//						canBeTwin,		// cnwrl1 08/07/2010 PAR 24606 - what it was
						not canBeTwin,	// becomes the stupid database field is NOT canBeTwin
						isoMaxTotalWt,
						isoMaxTareWt );
		
		if not isoColl.includesKey(isoCode) then
			isoColl.add(pxyIso);
		else
			create err transient;
			err.set(0, app.getErrorString(ISO_Type) &amp; ' : ' &amp; app.getErrorString2(Line_duplicate_file, noLines.String, app.getErrorString(ISOTypes)) &amp; isoCode, false, '', pxyIso, null);
			errorStore.add(err);
		endif;
	endwhile;
	
	if thePassport.myCMIFMonitor &lt;&gt; null then
		thePassport.myCMIFMonitor.updateProgress(app.getErrorString(Reading_import_file), 10, 10);
	endif;
	
	count		:=	0;
	numCodes	:=	isoColl.size();
	
	// Start the transaction
	beginTransaction;
	
	// Perform the operation
	foreach pxyIso in isoColl do
		count := count + 1;
		progressInt := app.actualTimeServer() - progressTS;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if thePassport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (count = numCodes)) then
			thePassport.myCMIFMonitor.updateProgress(app.getErrorString1(Creating_msg, app.getErrorString(ISOTypes)), numCodes, count);
			progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		currentIso	:= theRoot.allISOTypes[pxyIso.code];
		
		if currentIso = null then
			app.myUtilityCA.utlCreateISOType(pxyIso, newIso, thePassport);
		else
			app.myProxyManager.createProxyLink (currentIso, pxyIso);
			app.myUtilityUA.utlUpdateISOType(pxyIso, thePassport);
		endif;
		
		if thePassport.hasErrors() then
			foreach err in thePassport.allErrors do
				err.setErrorText(app.getErrorString(ISO_Type) &amp; ' : ' &amp; pxyIso.code &amp; '  ' &amp; err.text, false);
				errorStore.add(err);
			endforeach;
			
			foreach err in thePassport.allErrors do
				err.removeFromPassport;
			endforeach;
		endif;
	endforeach;
	
	trxWriteToLogFile(_file.fileName, noLines, count, thePassport, errorStore);
	
epilog
	if isoColl &lt;&gt; null then
		isoColl.purge();
		delete isoColl;
	endif;
	
	_file.close();
	delete fieldArray;
	self.finaliseActivityWithPassport(thePassport);
	delete errorStore;
end;
</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxImportInvAllocMapFromFile" id="6e4f9f17-38dc-4d32-9ca5-eb3aed0900cd">
        <updating/>
        <source>trxImportInvAllocMapFromFile(_file : File; _bank : CM_Bank;_allocMapName : String; _passport : CM_Passport input;_realTM : CM_TranMapCargoAllocation output) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19Jun 2017	cnwma1	TFS #4498 JMT - Cargo Allocation Fix Up Export Script
15 Nov 2017 jlgmd1	TFS #7659 STWO - FW: Transaction Map: PROBLEM
28 Dec 2017	jlgrh7 	TFS #36438  STWO - Error when copying transaction map.

*/
constants
	ProgressBarRefresh	: Integer = 2000;
vars
	count, numCodes, noLines 			: Integer;
	hadException	: Boolean;
	theRoot			: CM_Root;
	thePassport		: CM_Passport;
	err				: CM_Error;
	errorStore		: CM_ErrorSet;
	proxyArray		: ObjectArray;
	obj			: Object;
	xmlDocumentParser : JadeXMLDocumentParser;
	rootElement : JadeXMLElement;
	rootNode	: JadeXMLNode;
	childElement	: JadeXMLElement;
	xmlDocument : JadeXMLDocument;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
	proxyTM,realTM : CM_TranMapCargoAllocation;
	opCriteriaColl : CM_YACriteriaTypeArray;
	yaCriteria : CM_YACriteria;
	realYAConfig, pxyYAConfig : CM_InvoiceAllocationConfig;
	realAlloc		: CM_InvoiceCargoAllocation;
	proxyYA,
	colYA			: CM_YardAllocation;
	allTransientCriteriaObj	: CMIF_Array;
	cmifCriteria : CMIF_YACriteriaPriority;
	sb : CM_CargoServiceBroker;
	bu : CM_Bank;
	pxyQM : CM_QuantityMap;
	pxyQRM : CM_QuantityRangeMap;
// TFS 40620	lines : CM_InvoiceLineDescMapDict;
	lines : CM_InvoiceLineDescSet;// TFS 40620
	tmilgt : CM_TranMapInvoiceLineGroupType;
	invLineMap : CM_TranMapInvoiceLineMapping;
	load, clear : Boolean;
	strData: String;
	realQRM : CM_QuantityRangeMap;
	iter : Iterator;
	
	realInventAlloc		: CM_InvoiceInventoryAllocation; // ### TFS 51219 28MAY2021 NAVAB1
	proxyInventTM,realInventTM : CM_TranMapInventoryAllocation; // ### TFS 51219 28MAY2021 NAVAB1
	isCargoTranMap : Boolean; // ### TFS 51219 28MAY2021 NAVAB1
	allAllocs : CM_YardAllocationsByCodeDict; // ### TFS 51219 28MAY2021 NAVAB1
begin
	thePassport := _passport;
	theRoot 	:= app.myRoot;
	if thePassport.myTerminal = null then
		thePassport.setMyTerminal(_bank.terminal);
	endif;

	// Always initialize the activity first
	self.initialiseActivityWithPassport(thePassport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, thePassport);
	on LockException do agtPassportLockExHandler(exception, thePassport);
	app.setContinueCMExceptions(false);
	
	if not _file.tryOpen() then
		app.raiseCMException(VB_FILE_ERROR, app.getErrorString(File_open), null);	
		return 0;
	endif;
	
	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	create errorStore transient;
	create xmlDocumentParser transient;
	create xmlDocument transient;
	
	xmlDocumentParser.parseDocumentFile(xmlDocument,_file.fileName);
	rootElement := xmlDocument.rootElement;
	childElement := rootNode.JadeXMLElement;
	
	isCargoTranMap := rootElement.localName = "invoiceAllocationMap"; // ### TFS 51219 28MAY2021 NAVAB1
	
	self.trxImportInvAllocMapObjects(rootElement, proxyTM, proxyInventTM, isCargoTranMap, errorStore, _bank, _allocMapName, opCriteriaColl); // ### TFS 51219 28MAY2021 NAVAB1
	
	if thePassport.myCMIFMonitor &lt;&gt; null then
		thePassport.myCMIFMonitor.updateProgress(app.getErrorString(Reading_import_file), 10, 10);
	endif;
	
	count:= 0;
	if proxyTM = null 
	and proxyInventTM = null then		 // ### TFS 51219 28MAY2021 NAVAB1
		if app.myPassport.hasErrors then
			foreach err in thePassport.allErrors do 
				err.setErrorText('Invoice Allocation ' &amp; ' : ' &amp; _allocMapName &amp; '  ' &amp; err.text, false);
				if not errorStore.includes(err) then
					errorStore.add(err);
				endif;
			endforeach;
			self.trxWriteToLogFile2(_file.fileName,noLines, count, errorStore);
			return count;
		endif;
	endif;
	
	if isCargoTranMap then // ### TFS 51219 28MAY2021 NAVAB1
		numCodes := proxyTM.allInvoiceCargoAllocations.size;
	else
		numCodes := proxyInventTM.allInvoiceInventoryAllocations.size; // ### TFS 51219 28MAY2021 NAVAB1
	endif;
	
	noLines	:= numCodes;

	/*progressInt := app.actualTimeServer() - progressTS;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if thePassport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (count = numCodes)) then
			thePassport.myCMIFMonitor.updateProgress(app.getErrorString1(Creating_msg, 'Service'), numCodes, count);
			progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
	// Start the transaction
	//beginTransaction;
	*/
	if isCargoTranMap then // ### TFS 51219 28MAY2021 NAVAB1
		foreach realTM in _bank.allCargoAllocTranMaps do
			if realTM.name.toUpper = proxyTM.name.toUpper then
				app.myTrxDA.trxDeleteInvoiceTranMapCA(realTM);	// Remove the existing map
				realTM := null;
				break;
			endif;
		endforeach;
		
		app.myTrxCA.trxCreateInvoiceTranMapCAlloc(proxyTM, realTM);		
	else
		 // ### TFS 51219 28MAY2021 NAVAB1
		foreach realInventTM in _bank.allInventoryAllocTranMaps do
			if realInventTM.name.toUpper = proxyInventTM.name.toUpper then
				app.myTrxDA.trxDeleteInvoiceTranMapInvent(realInventTM);	// Remove the existing map
				realInventTM := null;
				break;
			endif;
		endforeach;
		
		app.myTrxCA.trxCreateInvoiceTranMapInvent(proxyInventTM, realInventTM);		 // ### TFS 51219 28MAY2021 NAVAB1
	

	endif;
	
	if app.myPassport.hasErrors then
		foreach err in thePassport.allErrors do 
			err.setErrorText('Invoice Allocation ' &amp; ' : ' &amp; _allocMapName &amp; '  ' &amp; err.text, false); // ### TFS 51219 28MAY2021 NAVAB1 '_allocMapName' was 'proxyTM.name'
			if not errorStore.includes(err) then
				errorStore.add(err);
			endif;
		endforeach;
		self.trxWriteToLogFile2(_file.fileName,noLines, count, errorStore);
		
		return count;
	endif;
	
	if realTM = null and realInventTM = null then
	
	else
 // ### TFS 51219 28MAY2021 NAVAB1	if realTM &lt;&gt; null then
		if isCargoTranMap then // ### TFS 51219 28MAY2021 NAVAB1
			realYAConfig := realTM.myInvoiceAllocationConfig;
		else
			realYAConfig := realInventTM.myInvoiceAllocationConfig; // ### TFS 51219 28MAY2021 NAVAB1
		endif;
		
		if realYAConfig = null then
			foreach err in app.myPassport.allErrors do 
				err.setErrorText('Invoice Allocation Transaction Map  Config' &amp; ' : ' &amp; _allocMapName &amp; '  ' &amp; err.text, false); // ### TFS 51219 28MAY2021 NAVAB1 '_allocMapName' was 'proxyTM.name'
				errorStore.add(err);
			endforeach;
			self.trxWriteToLogFile2(_file.fileName,noLines, count, errorStore);
			return count;
		else
				pxyYAConfig := app.createUpdateProxy(realYAConfig).CM_InvoiceAllocationConfig;
				pxyYAConfig.setProxyInvoiceAllocation(opCriteriaColl, null, realTM, realInventTM); // ### TFS 51219 28MAY2021 NAVAB1
		endif;
		
		
		while true do
			app.myTrxUA.trxUpdateYAIMEXConfig(pxyYAConfig, app.myPassport);
			if app.myPassport.hasErrors then
				/*foreach err in app.myPassport.allErrors do 
					err.setErrorText('Invoice Allocation Transaction Map  Config' &amp; ' : ' &amp; proxyTM.name &amp; '  ' &amp; err.text, false);
					errorStore.add(err);
				endforeach;*/
			endif;
		
			if app.myPassport.trxCompletedOK then
				
				if isCargoTranMap then // ### TFS 51219 28MAY2021 NAVAB1
					allAllocs := proxyTM.allInvoiceCargoAllocations; // ### TFS 51219 28MAY2021 NAVAB1
				else
					allAllocs := proxyInventTM.allInvoiceInventoryAllocations; // ### TFS 51219 28MAY2021 NAVAB1
				endif;	
				
				foreach proxyYA in allAllocs do // ### TFS 51219 28MAY2021 NAVAB1
					// ### TFS 51219 28MAY2021 NAVAB1 proxyYA := proxyYA; 
					create allTransientCriteriaObj transient;				
					foreach yaCriteria in proxyYA.allCriteria do // ### TFS 51219 28MAY2021 NAVAB1
						cmifCriteria := yaCriteria.getTransient();
						cmifCriteria.setFlag(true, false, false);
						allTransientCriteriaObj.add(cmifCriteria);
					endforeach;										
					while true do
					/*  // ### TFS 51219 28MAY2021 NAVAB1
						if proxyYA.CM_InvoiceCargoAllocation.myQuantityMap &lt;&gt; null then
							if proxyYA.CM_InvoiceCargoAllocation.myQuantityMap.myCalculationType &lt;&gt; null then
								clear := true;
							else
								clear := false;
							endif;
						endif;
						*/
							// The keys are NOT unique here... so this doesn't work!
							//realAlloc :=realTM.allInvoiceCargoAllocations[proxyYA.CM_InvoiceCargoAllocation.code].CM_InvoiceCargoAllocation;	// TFS 7659
							
							if isCargoTranMap then  // ### TFS 51219 28MAY2021 NAVAB1
								realAlloc := null;
								iter := realTM.allInvoiceCargoAllocations.createIterator;
								realTM.allInvoiceCargoAllocations.startKeyGeq(proxyYA.code, iter);
							else
								realInventAlloc := null; // ### TFS 51219 28MAY2021 NAVAB1
								iter := realInventTM.allInvoiceInventoryAllocations.createIterator; // ### TFS 51219 28MAY2021 NAVAB1
								realInventTM.allInvoiceInventoryAllocations.startKeyGeq(proxyYA.code, iter); // ### TFS 51219 28MAY2021 NAVAB1
							endif;
							while iter.next(colYA) do
								// Gone too far, found nothing, bail
								if colYA.code &lt;&gt; proxyYA.code then // ### TFS 51219 28MAY2021 NAVAB1
									break;
								endif;
								
								// Code must match to get this far, lets check description
								if colYA.description = proxyYA.description then // ### TFS 51219 28MAY2021 NAVAB1
									if isCargoTranMap then // ### TFS 51219 28MAY2021 NAVAB1
										realAlloc := colYA.CM_InvoiceCargoAllocation; // ### TFS 51219 28MAY2021 NAVAB1
									else
										realInventAlloc := colYA.CM_InvoiceInventoryAllocation; // ### TFS 51219 28MAY2021 NAVAB1
									endif;
									break;
								endif;
							endwhile;
							delete iter;
							
							if isCargoTranMap then // ### TFS 51219 28MAY2021 NAVAB1
								if realAlloc &lt;&gt; null then
									load := true;
									if realAlloc.myQuantityMap.myCalculationType &lt;&gt; null then
										clear :=true;
									else
										clear :=false;
									endif;
								else
									load := false;
									if proxyYA.CM_InvoiceCargoAllocation.myQuantityMap.myCalculationType &lt;&gt; null then
										clear :=true;
									else
										clear :=false;
									endif;
								endif;
							else
								 // ### TFS 51219 28MAY2021 NAVAB1
								if realInventAlloc &lt;&gt; null then
									load := true;
									if realInventAlloc.myQuantityMap.myCalculationType &lt;&gt; null then
										clear :=true;
									else
										clear :=false;
									endif;
								else
									load := false;
									if proxyYA.CM_InvoiceInventoryAllocation.myQuantityMap.myCalculationType &lt;&gt; null then
										clear :=true;
									else
										clear :=false;
									endif;
								endif;
							endif;
												write proxyYA.description &amp; " _ " &amp;  clear.String;
												
						if isCargoTranMap then // ### TFS 51219 28MAY2021 NAVAB1
							app.myTrxUA.trxUpdateInvoiceCargoAlloc(false,load,clear,true,allTransientCriteriaObj, realTM, proxyYA.CM_InvoiceCargoAllocation,realAlloc);
						else
							app.myTrxUA.trxUpdateInvoiceInventAlloc(false,load,clear,true,allTransientCriteriaObj, realInventTM, proxyYA.CM_InvoiceInventoryAllocation,realInventAlloc);
						endif;
						
						// Clean up our proxy objects
						allTransientCriteriaObj.purge();
						delete allTransientCriteriaObj;
						
						if app.myPassport.trxCompletedOK then
						
							if isCargoTranMap then // ### TFS 51219 28MAY2021 NAVAB1
								if realAlloc &lt;&gt; null then
									sb := realAlloc.myServiceBroker; // ### TFS 51219 28MAY2021 NAVAB1
								endif;
							else
								// ### TFS 51219 28MAY2021 NAVAB1
								if realInventAlloc &lt;&gt; null then
									sb := realInventAlloc.myServiceBroker;
								endif;
							
							endif;
							bu := sb.getBank();
							pxyQM :=proxyYA.CM_InvoiceAllocation.myQuantityMap;
							
							if pxyQM.myCalculationType &lt;&gt; null then
								while true do
									create lines transient;
									foreach pxyQRM in pxyQM.allQuantityRanges   /* where pxyQM.myCalculationType &lt;&gt; null*/ do
										lines.clear;
										tmilgt := null;																																														//+TFS36348
										foreach invLineMap in pxyQRM.allTMInvoiceLineMappings do
											if invLineMap.myTMInvoiceLineDesc &lt;&gt; null then
												lines.add(invLineMap.myTMInvoiceLineDesc);
												tmilgt := app.myRoot.allTMInvLineGrpTypes[invLineMap.myTMInvoiceLineGroupType.type];				//+TFS36348
											endif;
										endforeach;
										//tmilgt := app.myRoot.allTMInvLineGrpTypes[invLineMap.myTMInvoiceLineGroupType.type];						//-TFS36348
										pxyQRM.setProxyInvoiceLineTypes(lines,tmilgt);
										pxyQRM.setProxy(sb.myChildQuantityMap,pxyQRM.rangeStart.Integer,pxyQRM.rangeEnd.Integer,pxyQRM.rangeType);
											
										app.myTrxUA.trxUpdateInvoiceCargoAllocMap(false, pxyQM,pxyQRM, sb ); 
										
										// Tidy up transients
										//delete lines;																																				//-TFS36348 
										pxyQRM.allTMInvoiceLineMappings.purge();
										delete pxyQRM;
										
										if not app.myPassport.trxCompletedOK then
	
											foreach err in app.myPassport.allErrors do 
												err.setErrorText('Invoice Allocation ' &amp; ' : ' &amp; _allocMapName &amp; '  ' &amp; err.text, false); // ### TFS 51219 28MAY2021 NAVAB1 '_allocMapName' was 'proxyTM.name'
													errorStore.add(err);
											endforeach;
											self.trxWriteToLogFile2(_file.fileName,noLines, count, errorStore);									
											return count;
										endif;
									endforeach;
									delete lines;																						//+TFS36348
									break;
								endwhile;
							endif;
						else
							foreach err in app.myPassport.allErrors do 
									err.setErrorText('Invoice Allocation ' &amp; ' : ' &amp; _allocMapName &amp; '  ' &amp; err.text, false); // ### TFS 51219 28MAY2021 NAVAB1 '_allocMapName' was 'proxyTM.name'
									errorStore.add(err);
							endforeach;
								self.trxWriteToLogFile2(_file.fileName,noLines, count, errorStore);
								return count;
						endif;
						break;
					endwhile;
				endforeach;
			endif;
			break;
		endwhile;
	endif;
	
	beginTransaction;
	// TFS #4542 - Need to rebuild the manual collection of allocations by transaction type after any update
	if isCargoTranMap then // ### TFS 51219 28MAY2021 NAVAB1
		realTM.recalcAllocationPriorities();
	else
		realInventTM.recalcAllocationPriorities(); // ### TFS 51219 28MAY2021 NAVAB1
	endif;
	commitTransaction;

	if thePassport.hasErrors then
			foreach err in thePassport.allErrors do 
				err.setErrorText('Invoice Allocation ' &amp; ' : ' &amp; _allocMapName &amp; '  ' &amp; err.text, false); // ### TFS 51219 28MAY2021 NAVAB1 '_allocMapName' was 'proxyTM.name'
				if not errorStore.includes(err) then
					errorStore.add(err);
				endif;
			endforeach;
		
	else
		count := count + 1;
	endif;
	
	// Tidy up transients
	if isCargoTranMap then // ### TFS 51219 28MAY2021 NAVAB1
		foreach proxyYA in proxyTM.allInvoiceCargoAllocations do
			if proxyYA.CM_InvoiceCargoAllocation.myQuantityMap &lt;&gt; null then
				delete proxyYA.CM_InvoiceCargoAllocation.myQuantityMap;
			endif;
			delete proxyYA;
		endforeach;
	else
		// ### TFS 51219 28MAY2021 NAVAB1
		foreach proxyYA in proxyInventTM.allInvoiceInventoryAllocations do
			if proxyYA.CM_InvoiceInventoryAllocation.myQuantityMap &lt;&gt; null then
				delete proxyYA.CM_InvoiceInventoryAllocation.myQuantityMap;
			endif;
			delete proxyYA;
		endforeach;

	endif;
	
	self.trxWriteToLogFile2(_file.fileName,noLines, count, errorStore);
	return count;

epilog
	_file.close;
	delete xmlDocumentParser;
	delete xmlDocument;	
//	errorStore.purge; // NAVAB1 03AUG2023 Fixing UTs. These objects are in the passport so do not purge as we want to see them in the UI
	delete errorStore;
	delete proxyTM;
	delete proxyInventTM;
	delete lines;
	if allTransientCriteriaObj &lt;&gt; null then
		allTransientCriteriaObj.purge();
		delete allTransientCriteriaObj;
	endif;
	delete pxyYAConfig;
	delete opCriteriaColl;
	delete iter;
	
	self.finaliseActivityWithPassport(thePassport);
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_allocMapName" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_realTM" type="CM_TranMapCargoAllocation" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxImportInvAllocMapObjects" id="65ac5a74-7a8e-4a73-80ca-a62f12d2d8c8">
        <updating/>
        <source>trxImportInvAllocMapObjects(_jadeXMLElement : JadeXMLElement input;
							_proxyTM : CM_TranMapCargoAllocation output; 
							_proxyInventTM : CM_TranMapInventoryAllocation output;  // ### TFS 51219 28MAY2021 NAVAB1
							_isCargoTranMap : Boolean; // ### TFS 51219 28MAY2021 NAVAB1
							  _errorStore : CM_ErrorSet input; 
							  _bank : CM_Bank;
							  _allocMapName : String;
							   _opCriteriaColl : CM_YACriteriaTypeArray output) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Jun 2017	cnwma1	TFS #4498 JMT - Cargo Allocation Fix Up Export Script
15 Nov 2017 jlgmd1	TFS #7659 STWO - FW: Transaction Map: PROBLEM
15/01/2025	navlw1	JIRA-12608: MTN - Invoice Cargo Allocations Review (Mapping and Extract/Load)

*/

vars
	tranMapName,tranMapdesc	: String;
	allocCode : String;
	//alloColor : Integer;
	allocPriority : Real;
	allocDesc : String;
	allocDefault : Boolean;
	
	//realAllocMap,			// TFS 7659
	proxyAllocMap			: CM_TranMapCargoAllocation;
	
	iter, iter2		: Iterator;
	xmlNode			: JadeXMLNode;
	xmlElement		: JadeXMLElement;
	
 // ### TFS 51219 28MAY2021 NAVAB1	allInvoiceCargoAllocations:CM_YardAllocationsByCodeDict;
	pxyInvCargoAllocation,invAlloc : CM_InvoiceCargoAllocation;
	xmlNodeInvoiceAlloc :JadeXMLNode;
	xmlTagStr,xmlNodeStr : String;
	
	allYACriteria :CM_YACriteriaByPriorityDict;
	yaCriteria,realYaCriteria : CM_YACriteria;
	xmlAllCriteriaNode : JadeXMLNode;
	xmlCriteriaNode : JadeXMLNode;
	
	
	critType : CM_YACriteriaType;
	critTypeStr,critItemCode,critItemValues,critItemPriority : String;
	calcTypeCode : String;
	chargeZero: Boolean;
	mappingType : Integer;
	qtyMap : CM_QuantityMap;
	qtyRangeMap : CM_QuantityRangeMap;
	
	xmlQuantityMapNode : JadeXMLNode;

	opCriteriaColl : CM_YACriteriaTypeArray;
	oprCriteria : CM_YACriteriaType;
	pxyServiceBroker : CM_CargoAllocServiceBroker;
	calcType : CM_CalculationType;
	
	xmlQtyMapNode ,
	xmlAllQtyMaps  : JadeXMLNode;
	rangeStart,rangeEnd : Integer;
	rangeType : Integer;
	
	xmlAllInvLineMap,xmlInvLineMap : JadeXMLNode;
	pxyInvLineMapping :CM_TranMapInvoiceLineMapping;
	mapValue : Integer;
	invoiceLineDescStr :String;
	invoiceLineDesc : CM_InvoiceLineDesc;
	xmlinvLineGroupType :JadeXMLNode;
	pxyInvLineGroupType : CM_TranMapInvoiceLineGroupType;
	invLineGrpName : String;
	invLineGrpType : Integer;
	root : CM_Root;
	
	xmlNodeOpCriteria : JadeXMLNode;
	criteriaType : CM_YACriteriaType;
	yacType : Integer;
	transObj	: Object;
	colYA		: CM_YardAllocation;
	isOk		: Boolean;
	transferType: CM_VoyageJobTransferType;
	transferTypeInt: Integer;
	vesselCategory: HMS_VesselCategory;
	vesselCatCode: String;
	
	
	pxyInvInventAllocation : CM_InvoiceInventoryAllocation; // ### TFS 51219 28MAY2021 NAVAB1
	proxyInventAllocMap	: CM_TranMapInventoryAllocation; // ### TFS 51219 28MAY2021 NAVAB1
begin
	if _jadeXMLElement = null then
		return;
	endif;
	
	tranMapName		:= null;
	tranMapdesc		:= null;
	root			:= app.myRoot;
	
	if _isCargoTranMap then // ### TFS 51219 28MAY2021 NAVAB1
		create proxyAllocMap as CM_TranMapCargoAllocation transient;
		proxyAllocMap.myBank := _bank;
		proxyAllocMap.name :=_allocMapName;
	else
		create proxyInventAllocMap as CM_TranMapInventoryAllocation transient;
		proxyInventAllocMap.myBank := _bank;
		proxyInventAllocMap.name :=_allocMapName;
	
	endif;
	
	create opCriteriaColl transient;
	iter := _jadeXMLElement.childNodes.createIterator;
	while iter.next(xmlNode) do
		xmlElement := xmlNode.JadeXMLElement;
		if xmlElement.tagName = "name" then
			tranMapName := xmlElement.textData.String;
		elseif xmlElement.tagName = "description" then
				
			tranMapdesc := xmlElement.textData.String;
			if _isCargoTranMap then  // ### TFS 51219 28MAY2021 NAVAB1
				proxyAllocMap.description := tranMapdesc;
			else
				proxyInventAllocMap.description := tranMapdesc; // ### TFS 51219 28MAY2021 NAVAB1
			endif;
		elseif xmlElement.tagName = "allOpCriteria" then
			foreach xmlNodeOpCriteria in xmlElement.childNodes do
				foreach xmlNode in xmlNodeOpCriteria.childNodes do
					xmlTagStr := xmlNode.JadeXMLElement.tagName;
					xmlNodeStr := xmlNode.JadeXMLElement.textData;
					if xmlTagStr = "type" then
						yacType := xmlNodeStr.Integer;
						criteriaType := app.myRoot.allYACriteriaTypes[yacType];
						if criteriaType &lt;&gt; null then
							opCriteriaColl.add(criteriaType);
						endif;
					endif;
				endforeach;
			endforeach;
		
		elseif xmlElement.tagName = "allInvoiceCargoAllocation" then
			 // ### TFS 51219 28MAY2021 NAVAB1 create allInvoiceCargoAllocations transient;
			foreach xmlNodeInvoiceAlloc in xmlElement.childNodes do

				//create  pxyInvCargoAllocation transient;
				if _isCargoTranMap then // ### TFS 51219 28MAY2021 NAVAB1
					pxyInvCargoAllocation := null;			//TFS 7659
				else
					pxyInvInventAllocation := null; // ### TFS 51219 28MAY2021 NAVAB1
				endif;
					
				foreach xmlNode  in xmlNodeInvoiceAlloc.childNodes do
					xmlTagStr := xmlNode.JadeXMLElement.tagName;
					xmlNodeStr := xmlNode.JadeXMLElement.textData;
					if xmlTagStr = "code" then
						allocCode :=xmlNodeStr.String;
						//TFS 7659 no longer need to update existing allocs
						/*if realAllocMap &lt;&gt; null then
							// The keys are NOT unique here... so this doesn't work!
							invAlloc := realAllocMap.allInvoiceCargoAllocations[allocCode].CM_InvoiceCargoAllocation;
							if invAlloc &lt;&gt; null then
								if pxyInvCargoAllocation= null then
									pxyInvCargoAllocation := app.createUpdateProxy(invAlloc).CM_InvoiceCargoAllocation;
								endif;
							else
								if pxyInvCargoAllocation= null then
									create pxyInvCargoAllocation  transient;
								endif;
							endif;
						else*/
						if _isCargoTranMap then // ### TFS 51219 28MAY2021 NAVAB1
							create pxyInvCargoAllocation  transient;
						else
							create pxyInvInventAllocation  transient; // ### TFS 51219 28MAY2021 NAVAB1
						endif;
						//endif;
					elseif  xmlTagStr = "color" then
						//alloColor := xmlNodeStr.Integer;		// TFS 7659
					elseif  xmlTagStr = "priority" then
						allocPriority := xmlNodeStr.Real;		// TFS 7659
					elseif  xmlTagStr = "description" then
						allocDesc := xmlNodeStr.String;
					elseif  xmlTagStr = "default" then
						allocDefault := xmlNodeStr.Boolean;
					elseif  xmlNode.JadeXMLElement.tagName = "allCriteria" then
						//create allYACriteria transient;
						foreach  xmlAllCriteriaNode in xmlNode.childNodes do
							create yaCriteria transient;
							
							foreach  xmlCriteriaNode in xmlAllCriteriaNode.childNodes do 
								xmlTagStr := xmlCriteriaNode.JadeXMLElement.tagName;
								xmlNodeStr := xmlCriteriaNode.JadeXMLElement.textData;
								if xmlTagStr = "myYACriteriaType" then
									critTypeStr :=xmlNodeStr.String;
								elseif xmlTagStr = "priorityValue"then
									critItemPriority := xmlNodeStr.String;
								elseif xmlTagStr = "code"then
									critItemCode := xmlNodeStr.String;
								elseif xmlTagStr = "myYAData"then
									critItemValues :=xmlNodeStr.String; // navlw1 #JIRA-12608 removed the toUpper
								endif;
							endforeach;
							critType := app.myRoot.allYACriteriaTypes.getAtKey(critTypeStr.Integer);	//Cargo Type
							// Start navlw1 #JIRA-12608
							if critType.saveCodeInUpper then
								critItemValues.toUpper();
							endif;
							// End navlw1 #JIRA-12608
							yaCriteria.setProxy(critType,critItemValues,critItemCode);
							yaCriteria.setPriorityValue(critItemPriority.asRealJMT);	
							if _isCargoTranMap then // ### TFS 51219 28MAY2021 NAVAB1
								yaCriteria.setYardAllocation(pxyInvCargoAllocation);
							else
								yaCriteria.setYardAllocation(pxyInvInventAllocation); // ### TFS 51219 28MAY2021 NAVAB1
							endif;
							
							// Make sure the transaction type actually exists, otherwise we'll have issues later			TFS 7659
							if critType.type = YACriteriaType_TransactionType then
								// At this stage, the data should have been resolved into objects, so if we have a pattern instead, then something is wrong
								if yaCriteria.myYAData.isKindOf(CM_YADataPattern) then
									// TODO: Create my own error message, and possibly just use exception1
									app.raiseCMException2(ErrYACriteriaNotFound, yaCriteria.myYAData.CM_YADataPattern.pattern, "Transaction Type", null, null);
								endif;
							endif;
							
							//allYACriteria.add(yaCriteria);
						endforeach;
					elseif  xmlNode.JadeXMLElement.tagName = "CM_QuantityMap" then
							create qtyMap transient;
							foreach xmlQuantityMapNode in xmlNode.childNodes do
								xmlTagStr := xmlQuantityMapNode.JadeXMLElement.tagName;
								xmlNodeStr := xmlQuantityMapNode.JadeXMLElement.textData;
								if xmlTagStr = "chargeZero" then
									chargeZero:= xmlNodeStr.Boolean;
									qtyMap.setChargeZero( chargeZero);
								elseif xmlTagStr = "mappingType" then
									mappingType :=xmlNodeStr.Integer;
									qtyMap.setMappingType(mappingType );
								elseif  xmlTagStr = "myCalculationType" then
									calcTypeCode:=xmlNodeStr.String;
									calcType :=app.myRoot.allCalculationTypesByCode[calcTypeCode];
									qtyMap.setMyCalculationType(calcType);
								elseif  xmlTagStr = "allQuantityRanges" then
										foreach  xmlAllQtyMaps in xmlQuantityMapNode.childNodes do
											create qtyRangeMap transient;
											foreach xmlQtyMapNode in xmlAllQtyMaps.childNodes do
												xmlTagStr := xmlQtyMapNode.JadeXMLElement.tagName;
												xmlNodeStr := xmlQtyMapNode.JadeXMLElement.textData;
												
												if xmlTagStr = "rangeStart" then
													rangeStart := xmlNodeStr.Integer;
												elseif  xmlTagStr = "rangeEnd" then
													rangeEnd := xmlNodeStr.Integer;
												elseif  xmlTagStr = "rangeType" then
													rangeType := xmlNodeStr.Integer;
												elseif  xmlTagStr = "allTMInvoiceLineMappings" then
													
													foreach xmlAllInvLineMap in xmlQtyMapNode.childNodes do
														create pxyInvLineMapping transient;
														
														foreach xmlInvLineMap in xmlAllInvLineMap.childNodes do
															xmlTagStr := xmlInvLineMap.JadeXMLElement.tagName;
															xmlNodeStr := xmlInvLineMap.JadeXMLElement.textData;
															if xmlTagStr = "mapValue" then
																mapValue :=xmlNodeStr.Integer;
															elseif  xmlTagStr =  "myTMInvoiceLineDesc" then
																invoiceLineDescStr := xmlNodeStr.String;
																invoiceLineDesc := _bank.invoiceLineDescriptors[invoiceLineDescStr];
															elseif  xmlTagStr =  "myTransferType" then
																transferTypeInt := xmlNodeStr.Integer;
																transferType := app.myRoot.allVoyageJobTransferTypes[transferTypeInt];
															elseif  xmlTagStr =  "myVesselCategory" then
																vesselCatCode := xmlNodeStr.String;
																vesselCategory := app.myRoot.allVesselCategories[vesselCatCode];
															elseif  xmlTagStr =  "CM_TranMapInvoiceLineGroupType" then 
																//create pxyInvLineGroupType transient;			// TFS 7659
																foreach xmlinvLineGroupType in xmlInvLineMap.childNodes do
																	if xmlinvLineGroupType.JadeXMLElement.tagName ="type" then
																		invLineGrpType :=xmlinvLineGroupType.JadeXMLElement.textData.Integer;
																	elseif  xmlinvLineGroupType.JadeXMLElement.tagName ="name" then
																		invLineGrpName :=xmlinvLineGroupType.JadeXMLElement.textData.String;
																	endif;
																endforeach;
																//pxyInvLineGroupType.update(invLineGrpName,invLineGrpType,root);			// TFS 7659
																pxyInvLineGroupType := app.myRoot.allTMInvLineGrpTypes[invLineGrpType];		// TFS 7659
																// Would this ever not exist ?
																
															endif;
														endforeach;
														
														pxyInvLineMapping.update(mapValue, invoiceLineDesc, qtyRangeMap, pxyInvLineGroupType, transferType, vesselCategory, null, null, null);
													endforeach;
												endif;
											endforeach;
											qtyRangeMap.setProxy(qtyMap,rangeStart,rangeEnd,rangeType);
										endforeach;
									
								endif;
							endforeach;
							qtyMap.setProxy(pxyServiceBroker,chargeZero,mappingType,calcType,null);
							
							if _isCargoTranMap then  // ### TFS 51219 28MAY2021 NAVAB1
								qtyMap.initialise(pxyInvCargoAllocation.myServiceBroker,_bank,false);
								pxyInvCargoAllocation.setQuantityMap(qtyMap);
							else
								qtyMap.initialise(pxyInvInventAllocation.myServiceBroker,_bank,false); // ### TFS 51219 28MAY2021 NAVAB1
								pxyInvInventAllocation.setQuantityMap(qtyMap); // ### TFS 51219 28MAY2021 NAVAB1

							endif;
							
					endif;
				endforeach;
				 
				if _isCargoTranMap then  // ### TFS 51219 28MAY2021 NAVAB1
					pxyInvCargoAllocation.setProxy(allocCode,allocDesc,null,
												YAFillOption_InOrder,
												YAFillOption_InOrder,
												YAExpiryType_Never,
												null,
												null,
												null, 
												YAOverlap_Never,
												YANoLocation_Continue,
												null,
												0, 
												false,
												false,
												null,
												null,
												true,_bank.getMyTerminal);
				
					pxyInvCargoAllocation.initialiseProxy(proxyAllocMap);
				else
					pxyInvInventAllocation.setProxy(allocCode,allocDesc,null, // ### TFS 51219 28MAY2021 NAVAB1
												YAFillOption_InOrder,
												YAFillOption_InOrder,
												YAExpiryType_Never,
												null,
												null,
												null, 
												YAOverlap_Never,
												YANoLocation_Continue,
												null,
												0, 
												false,
												false,
												null,
												null,
												true,_bank.getMyTerminal);
				
					pxyInvInventAllocation.initialiseProxy(proxyInventAllocMap); // ### TFS 51219 28MAY2021 NAVAB1
				
				endif;
				//pxyInvCargoAllocation.setPriorityValue(allocPriority);	// TFS 7659
				
				//[4-A] intialse Confifs											//-TFS 7659
				/*foreach yaCriteria in pxyInvCargoAllocation.allCriteria do		//-TFS 7659
					oprCriteria :=yaCriteria.myYACriteriaType;						//-TFS 7659
					//if oprCriteria.type &lt;&gt; YACriteriaType_TransactionType then	//-TFS 7659
						if not opCriteriaColl.includes(oprCriteria) then			//-TFS 7659
							opCriteriaColl.add(oprCriteria);						//-TFS 7659
						endif;														//-TFS 7659
					//endif;														//-TFS 7659
				endforeach;*/														//-TFS 7659
			endforeach;
		endif;
	endwhile;

	//proxyAllocMap.allInvoiceCargoAllocations.clear();	//TFS 7659
	if _isCargoTranMap then // ### TFS 51219 28MAY2021 NAVAB1
 // ### TFS 51219 28MAY2021 NAVAB1		allInvoiceCargoAllocations.copy(proxyAllocMap.allInvoiceCargoAllocations);
		_opCriteriaColl := opCriteriaColl;
		_proxyTM := proxyAllocMap;
	else
		_opCriteriaColl := opCriteriaColl; // ### TFS 51219 28MAY2021 NAVAB1
		_proxyInventTM := proxyInventAllocMap; // ### TFS 51219 28MAY2021 NAVAB1

	endif;
	
	isOk := true;
epilog
	delete iter;
	delete iter2;
	if not isOk then
		delete proxyAllocMap;
		delete proxyInventAllocMap;
		delete opCriteriaColl;
		delete qtyRangeMap;
		delete qtyMap;
 // ### TFS 51219 28MAY2021 NAVAB1		allInvoiceCargoAllocations.purge();
	endif; // ### TFS 51219 28MAY2021 NAVAB1 delete allInvoiceCargoAllocations;
end;</source>
        <Parameter name="_jadeXMLElement" type="JadeXMLElement" usage="input"/>
        <Parameter name="_proxyTM" type="CM_TranMapCargoAllocation" usage="output"/>
        <Parameter name="_proxyInventTM" type="CM_TranMapInventoryAllocation" usage="output"/>
        <Parameter name="_isCargoTranMap" type="Boolean"/>
        <Parameter name="_errorStore" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_allocMapName" type="String"/>
        <Parameter name="_opCriteriaColl" type="CM_YACriteriaTypeArray" usage="output"/>
    </JadeMethod>
    <JadeMethod name="trxImportInvLineTypesFromFile" id="90ff121e-fb0a-4803-8561-d097fcd792ae">
        <updating/>
        <source>trxImportInvLineTypesFromFile( _file : File; _bank : CM_Bank; _passport : CM_Passport input ) : Integer updating;

/*
Purpose:		DPH copy invoice line types from Test to UAT

Parameters:		Import File, bank and passport.  File format is XML, see CM_ExtractLoadAgent::extractInvoiceLineTypes

Date		Who		Reason
May 2013	cnwjre1	Copy invoice line types from one JMT copy to another
*/
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	hadException						: Boolean;
	count, numCodes, noLines 			: Integer;
	proxyILD, newILD					: CM_InvoiceLineDesc;
	theRoot								: CM_Root;
	thePassport							: CM_Passport;
	err									: CM_Error;
	errorStore							: CM_ErrorSet;
	proxyArray							: ObjectArray;
	obj									: Object;

	xmlDocumentParser : JadeXMLDocumentParser;
	rootElement : JadeXMLElement;
	rootNode	: JadeXMLNode;
	childElement	: JadeXMLElement;
	xmlDocument : JadeXMLDocument;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	thePassport := _passport;
	theRoot 	:= app.myRoot;
	if thePassport.myTerminal = null then
		thePassport.setMyTerminal(_bank.terminal);
	endif;

	// Always initialize the activity first
	self.initialiseActivityWithPassport(thePassport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, thePassport);
	on LockException do agtPassportLockExHandler(exception, thePassport);
	app.setContinueCMExceptions(false);
	
	if not _file.tryOpen() then
		app.raiseCMException(VB_FILE_ERROR, app.getErrorString(File_open), null);	
		return 0;
	endif;
	
	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	create proxyArray transient;
	create errorStore transient;
	
	create xmlDocumentParser transient;
	create xmlDocument transient;
	xmlDocumentParser.parseDocumentFile(xmlDocument,_file.fileName);
	rootElement := xmlDocument.rootElement;
	foreach rootNode in rootElement.childNodes do
		if rootNode.isKindOf(JadeXMLElement) then
			childElement := rootNode.JadeXMLElement;
			self.trxImportInvoiceLineTypeObject(childElement, proxyArray, errorStore, _bank);
			noLines := noLines + 1;
		endif;
	endforeach;
	
	if thePassport.myCMIFMonitor &lt;&gt; null then
		thePassport.myCMIFMonitor.updateProgress(app.getErrorString(Reading_import_file), 10, 10);
	endif;
	
	count:= 0;
	numCodes := proxyArray.size;
	
	// Start the transaction
	beginTransaction;
	
	// Perform the operation
	foreach obj in proxyArray do
		proxyILD := obj.CM_InvoiceLineDesc;
		progressInt := app.actualTimeServer() - progressTS;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if thePassport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (count = numCodes)) then
			thePassport.myCMIFMonitor.updateProgress(app.getErrorString1(Creating_msg, 'Invoice Line Type'), numCodes, count);
			progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		// 37466 recently added 'no services' warning is stopping subsequent invoice line types from being loaded
		app.myPassport.setWarningsIgnored(true);

		// add if new otherwise update existing object
		if _bank.invoiceLineDescriptors[proxyILD.narration] = null then
			app.myUtilityCA.utlCreateInvoiceLineDesc(proxyILD, newILD, app.myPassport);
		else
			app.myUtilityUA.utlUpdateInvoiceLineDesc(proxyILD, app.myPassport);
		endif;

		if thePassport.hasErrors then
			foreach err in thePassport.allErrors do 
				err.setErrorText('Invoice line type ' &amp; ' : ' &amp; proxyILD.narration &amp; '  ' &amp; err.text, false);
				errorStore.add(err);
			endforeach;
			// clear errors from logic so that any successful updates will still be done but stop on any exception
			foreach err in thePassport.allErrors do
				if err.errorCode &lt; app.baseErrorNum then
					count := 0;
					hadException := true;
					break;
				endif;
				err.removeFromPassport;
			endforeach;
		else
			count := count + 1;		// count the successes
		endif;
		if hadException then
			break;
		endif;
	endforeach;
	
	self.trxWriteToLogFile2(_file.fileName, noLines, count, errorStore);
	
	return count;
epilog
	if proxyArray &lt;&gt; null then
		proxyArray.purge;
		delete proxyArray;
	endif;
	_file.close;
	delete xmlDocumentParser;
	delete xmlDocument;
	self.finaliseActivityWithPassport(thePassport);
	delete errorStore;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxImportInvLnMappingFromFile" id="fd52b75a-05e3-4046-b0fa-f3446326eacf">
        <updating/>
        <source>trxImportInvLnMappingFromFile(_file : File; _bank : CM_Bank; _passport : CM_Passport input ) : Integer updating;
/*

Purpose:			Loads invoice line mappings from a file

Parameters:			_file		File		The file to use to import from
					_bank		CM_Bank		The bank we are importing to
					_passport	CM_Passport	The passport to use for the transaction

Return Value:		Integer Representing how many invoice line mappings were processed

Date		Who		Reason
06 October 2022	navpw1	Initial creation TFS: 54566

*/

constants
	ProgressBarRefresh	: Integer = 2000;
	
vars
	hadException				: Boolean;
	countC, numCodesC,
	countU, numCodesU,
	countD, numCodesD, noLines 	: Integer;
	proxyILM, newILM			: CM_InvoiceLineDescMapping;
	thePassport					: CM_Passport;
	err							: CM_Error;
	errorStore					: CM_ErrorSet;
	proxyCArray,
	proxyUArray,
	proxyDArray					: ObjectArray;
	progressInt					: TimeStampInterval;
	progressTS 					: TimeStamp;
	agent 						: CMIF_InvoiceLineMapping;
	
begin
	thePassport := _passport;
	if thePassport.myTerminal = null then
		thePassport.setMyTerminal(_bank.terminal);
	endif;
	
	// Always initialize the activity first
	self.initialiseActivityWithPassport(thePassport, method);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, thePassport);
	on LockException do agtPassportLockExHandler(exception, thePassport);
	app.setContinueCMExceptions(false);
	
	create agent transient; //Create agent to process file data
	
	if not _file.tryOpen() then
		app.raiseCMException(VB_FILE_ERROR, app.getErrorString(File_open), null);	
		return 0;
	endif;
	
	progressTS := app.actualTimeServer();
	create proxyCArray transient;
	create proxyUArray transient;
	create proxyDArray transient;
	create errorStore transient;
	
	if thePassport.myCMIFMonitor &lt;&gt; null then
		thePassport.myCMIFMonitor.updateProgress(app.getErrorString(Reading_import_file), 10, 0);
	endif;
	
	app.setContinueCMExceptions(true);	// ### TFS 55145 17Oct2022 NAVPW1
	
	//File processing different types of files
	if _file.fileName.cnContains(".csv") then
		agent.doLoadInvLnTypMapCsvFile(_file, proxyCArray, proxyUArray, proxyDArray, errorStore, _bank, noLines); //Process CSV file
		
	elseif _file.fileName.cnContains(".xml") then
		agent.doLoadInvLnTypMapXmlFile(_file, proxyCArray, proxyUArray, proxyDArray, errorStore, _bank, noLines); //Process XML file
		
	else
		app.raiseCMException(File_type_not_support, null, null);
	endif;
	
	app.setContinueCMExceptions(false);	// ### TFS 55145 17Oct2022 NAVPW1
	
	if thePassport.hasErrors then
		foreach err in thePassport.allErrors do
			err.setErrorText(err.text, false);
			errorStore.add(err);
		endforeach;
		return 0;
	endif;
	
	if thePassport.myCMIFMonitor &lt;&gt; null then
		thePassport.myCMIFMonitor.updateProgress(app.getErrorString(Reading_import_file), 10, 10);
	endif;
	
	countU:= 0;
	numCodesU := proxyUArray.size;
	
	countC:= 0;
	numCodesC := proxyCArray.size;
	
	// Start the transaction
	beginTransaction;
	
	// Perform the operation
	//Create Objects that were populated into proxyCArray
	foreach proxyILM in proxyCArray as CM_InvoiceLineDescMapping do
		progressInt := app.actualTimeServer() - progressTS;
		if thePassport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (countC = numCodesC)) then
			thePassport.myCMIFMonitor.updateProgress(app.getErrorString1(Creating_msg, "Invoice Line Mapping"), numCodesC, countC);
			progressTS := app.actualTimeServer();
		endif;
		
		app.myPassport.setWarningsIgnored(true);
		
		app.myUtilityCA.utlCreateInvoiceLineDescMap(proxyILM, newILM, app.myPassport);
		
		if thePassport.hasErrors then
			foreach err in thePassport.allErrors do 
				err.setErrorText(proxyILM.myDebtor.name &amp; " | " &amp; proxyILM.myInvoiceLineDesc.narration &amp; " | " &amp; proxyILM.myInvoiceType.description &amp; "  " &amp; err.text, false);
				errorStore.add(err);
			endforeach;
			// clear errors from logic so that any successful updates will still be done but stop on any exception
			foreach err in thePassport.allErrors do
				if err.errorCode &lt; app.baseErrorNum then
					countC := 0;
					hadException := true;
					break;
				endif;
				err.removeFromPassport;
			endforeach;
		else
			countC := countC + 1;		// count the successes
		endif;
		if hadException then
			break;
		endif;
	endforeach;
	
	//Update Objects that were populated into proxyUArray
	foreach proxyILM in proxyUArray as CM_InvoiceLineDescMapping do
		progressInt := app.actualTimeServer() - progressTS;
		if thePassport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (countU = numCodesU)) then
			thePassport.myCMIFMonitor.updateProgress(app.getErrorString1(Updating_msg, "Invoice Line Mapping"), numCodesU, countU);
			progressTS := app.actualTimeServer();
		endif;
		
		app.myPassport.setWarningsIgnored(true);
		
		app.myUtilityUA.utlUpdateInvLineDescMap(proxyILM, app.myPassport);
		
		if thePassport.hasErrors then
			foreach err in thePassport.allErrors do 
				err.setErrorText(proxyILM.myDebtor.name &amp; " | " &amp; proxyILM.myInvoiceLineDesc.narration &amp; " | " &amp; proxyILM.myInvoiceType.description &amp; "  " &amp; err.text, false);
				errorStore.add(err);
			endforeach;
			// clear errors from logic so that any successful updates will still be done but stop on any exception
			foreach err in thePassport.allErrors do
				if err.errorCode &lt; app.baseErrorNum then
					countU := 0;
					hadException := true;
					break;
				endif;
				err.removeFromPassport;
			endforeach;
		else
			countU := countU + 1;		// count the successes
		endif;
		if hadException then
			break;
		endif;
	endforeach;
	
	//Delete Objects that were populated into proxyDArray
	foreach proxyILM in proxyDArray as CM_InvoiceLineDescMapping do
		progressInt := app.actualTimeServer() - progressTS;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if thePassport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (countD = numCodesD)) then
			thePassport.myCMIFMonitor.updateProgress(app.getErrorString1(Deleting_msg, "Invoice Line Mapping"), numCodesD, countD);
			progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		app.myPassport.setWarningsIgnored(true);
		
		app.myUtilityDA.utlDeleteInvoiceLineDescMap(proxyILM, app.myPassport);
		
		if thePassport.hasErrors then
			foreach err in thePassport.allErrors do 
				err.setErrorText(proxyILM.myDebtor.name &amp; " | " &amp; proxyILM.myInvoiceLineDesc.narration &amp; " | " &amp; proxyILM.myInvoiceType.description &amp; "  " &amp; err.text, false);
				errorStore.add(err);
			endforeach;
			// clear errors from logic so that any successful updates will still be done but stop on any exception
			foreach err in thePassport.allErrors do
				if err.errorCode &lt; app.baseErrorNum then
					countD := 0;
					hadException := true;
					break;
				endif;
				err.removeFromPassport;
			endforeach;
		else
			countD := countD + 1;		// count the successes
		endif;
		if hadException then
			break;
		endif;
	endforeach;
	
	self.trxWriteToLogFile2(_file.fileName, noLines, countD, errorStore);
	
	return countC + countU + countD;
	
epilog
	delete agent;
	if proxyCArray &lt;&gt; null then
		proxyCArray.purge;
		delete proxyCArray;
	endif;
	
	if proxyUArray &lt;&gt; null then
		proxyUArray.purge;
		delete proxyUArray;
	endif;
	
	if proxyDArray &lt;&gt; null then
		//proxyDArray.purge;	// ### TFS 55145 14Oct2022 NAVPW1 - Array contains real objects that were deleted so cannot purge
		delete proxyDArray;
	endif;
	
	_file.close;
	self.finaliseActivityWithPassport(thePassport);
	delete errorStore;
	
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxImportInvLnTypTransFromFile" id="1ba56671-2e9c-4881-8f3d-4d2cf66690ec">
        <updating/>
        <source>trxImportInvLnTypTransFromFile(_file : File; _bank : CM_Bank; _passport : CM_Passport input ) : Integer updating;
/*

Purpose:			Imports Invoice Line Narrations into MTN

Parameters:			_file		File			The file to import the invoice line narrations from
					_bank		CM_Bank			The bank to import the invoce narrations into
					_passport	CM_Passport		The passport to hold all the errors and warnings encountered

Return Value:		Integer	Representing the amount of records imported

Date		Who		Reason
02 September 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

constants
	ProgressBarRefresh	: Integer = 2000;
	
vars
	hadException				: Boolean;
	countU, numCodesU,
	countD, numCodesD, noLines 	: Integer;
	proxyILTN, newILTN,
	invoiceLineNarration		: CM_InvoiceLineNarration;
	thePassport					: CM_Passport;
	err							: CM_Error;
	errorStore					: CM_ErrorSet;
	proxyUArray,
	proxyDArray					: ObjectArray;
	progressInt					: TimeStampInterval;
	progressTS 					: TimeStamp;
	found 						: Boolean;
	agent 						: CMIF_InvoiceLineNarration;
	
begin
	thePassport := _passport;
	if thePassport.myTerminal = null then
		thePassport.setMyTerminal(_bank.terminal);
	endif;

	// Always initialize the activity first
	self.initialiseActivityWithPassport(thePassport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, thePassport);
	on LockException do agtPassportLockExHandler(exception, thePassport);
	app.setContinueCMExceptions(false);
	
	create agent transient; //Create agent to process file data
	
	if not _file.tryOpen() then
		app.raiseCMException(VB_FILE_ERROR, app.getErrorString(File_open), null);	
		return 0;
	endif;
	
	progressTS := app.actualTimeServer();
	create proxyUArray transient;
	create proxyDArray transient;
	create errorStore transient;
	
	if thePassport.myCMIFMonitor &lt;&gt; null then
		thePassport.myCMIFMonitor.updateProgress(app.getErrorString(Reading_import_file), 10, 0);
	endif;
	
	app.setContinueCMExceptions(true);	// ### TFS 55150 17Oct2022 NAVPW1
	
	//File processing different types of files
	if _file.fileName.cnContains(".csv") then
		agent.doLoadInvLnTypTransCsvFile(_file, proxyUArray, proxyDArray, errorStore, _bank, noLines); //Process CSV file
		
	elseif _file.fileName.cnContains(".xml") then
		agent.doLoadInvLnTypTransXmlFile(_file, proxyUArray, proxyDArray, errorStore, _bank, noLines); //Process XML file
		
	else
		app.raiseCMException(File_type_not_support, null, null);
	endif;
	
	app.setContinueCMExceptions(false);	// ### TFS 55150 17Oct2022 NAVPW1
	
	if thePassport.hasErrors then
		foreach err in thePassport.allErrors do 
			err.setErrorText(err.text, false);
			errorStore.add(err);
		endforeach;
		return 0;
	endif;
	
	if thePassport.myCMIFMonitor &lt;&gt; null then
		thePassport.myCMIFMonitor.updateProgress(app.getErrorString(Reading_import_file), 10, 10);
	endif;
	
	countU:= 0;
	numCodesU := proxyUArray.size;
	
	// Start the transaction
	beginTransaction;
	
	// Perform the operation
	//Create/Update Objects that were populated into proxyUArray
	foreach proxyILTN in proxyUArray as CM_InvoiceLineNarration do
		progressInt := app.actualTimeServer() - progressTS;
		if thePassport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (countU = numCodesU)) then
			thePassport.myCMIFMonitor.updateProgress(app.getErrorString1(Creating_msg, "Invoice Line Type Narration"), numCodesU, countU);
			progressTS := app.actualTimeServer();
		endif;
		
		app.myPassport.setWarningsIgnored(true);
		
		found := false;
		
		// add if new otherwise update existing object
		foreach invoiceLineNarration in proxyILTN.myInvoiceLineType.allInvoiceLineNarrations do
			if invoiceLineNarration.myLocale.localeDescription &lt;&gt; proxyILTN.myLocale.localeDescription then
				continue;
				
			endif;
			
			found := true;
			break;
			
		endforeach;
		
		
		if found = null then
			app.myUtilityCA.utlCreateInvoiceLineNarr(proxyILTN, newILTN, app.myPassport);
		else
			app.myUtilityUA.utlUpdateInvoiceLineNarr(proxyILTN, app.myPassport);
		endif;
		
		if thePassport.hasErrors then
			foreach err in thePassport.allErrors do 
				err.setErrorText(proxyILTN.narration &amp; "  " &amp; err.text, false);
				errorStore.add(err);
			endforeach;
			// clear errors from logic so that any successful updates will still be done but stop on any exception
			foreach err in thePassport.allErrors do
				if err.errorCode &lt; app.baseErrorNum then
					countU := 0;
					hadException := true;
					break;
				endif;
				err.removeFromPassport;
			endforeach;
		else
			countU := countU + 1;		// count the successes
		endif;
		if hadException then
			break;
		endif;
	endforeach;
	
	//Delete Objects that were populated into proxyDArray
	foreach proxyILTN in proxyDArray as CM_InvoiceLineNarration do
		progressInt := app.actualTimeServer() - progressTS;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if thePassport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (countD = numCodesD)) then
			thePassport.myCMIFMonitor.updateProgress(app.getErrorString1(Deleting_msg, "Invoice Line Type Narration"), numCodesD, countD);
			progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		app.myPassport.setWarningsIgnored(true);

		foreach invoiceLineNarration in proxyILTN.myInvoiceLineType.allInvoiceLineNarrations do
			if invoiceLineNarration.myLocale.localeDescription &lt;&gt; proxyILTN.myLocale.localeDescription then
				continue;
				
			endif;
			
			found := true;
			break;
			
		endforeach;
		
		
		if found &lt;&gt; null then
			app.myUtilityDA.utlDeleteInvoiceLineNarr(proxyILTN, app.myPassport);
		else
			app.raiseCMException1(RequiredFields, "Invoice Line Narration (Delete)", null, null);
		endif;

		if thePassport.hasErrors then
			foreach err in thePassport.allErrors do 
				err.setErrorText(proxyILTN.narration &amp; "  " &amp; err.text, false);
				errorStore.add(err);
			endforeach;
			// clear errors from logic so that any successful updates will still be done but stop on any exception
			foreach err in thePassport.allErrors do
				if err.errorCode &lt; app.baseErrorNum then
					countD := 0;
					hadException := true;
					break;
				endif;
				err.removeFromPassport;
			endforeach;
		else
			countD := countD + 1;		// count the successes
		endif;
		if hadException then
			break;
		endif;
	endforeach;
	
	self.trxWriteToLogFile2(_file.fileName, noLines, countD, errorStore);
	
	return countU + countD;
	
epilog
	delete agent;
	if proxyUArray &lt;&gt; null then
		proxyUArray.purge;
		delete proxyUArray;
	endif;
	
	if proxyDArray &lt;&gt; null then
		//proxyDArray.purge;	// ### TFS 55150 17Oct2022 NAVPW1 - Array contains real objects that were deleted so cannot purge
		delete proxyDArray;
	endif;
	
	_file.close;
	self.finaliseActivityWithPassport(thePassport);
	delete errorStore;

end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxImportInvoiceLineTypeObject" id="5504e007-1399-4b1e-a1b5-5e4bc0f57f5a">
        <updating/>
        <source>trxImportInvoiceLineTypeObject(_jadeXMLElement : JadeXMLElement input; _proxyArray : ObjectArray input; 
							   _errorStore : CM_ErrorSet input; _bank : CM_Bank) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
May 2013	cnwjre1	Copy invoice line types from test to UAT for DPH
Sep 2015	cnwdap1	PAR #36909 CCMS ADP 2537 Minimum Charge Changes
31.01.2023	navvt20 TFS CR 56132 Task 56134: UI - Invoice Line Type - UOM
*/

vars
	serviceNode		: JadeXMLNode;
	xmlNode			: JadeXMLNode;
	xmlElement		: JadeXMLElement;
	serviceElement	: JadeXMLElement;
	iter			: Iterator;
	serviceIter		: Iterator;

	oneLinePerFP,
	printTrackedItems,
	isVoid			: Boolean;
	found			: Boolean;
	narration, remarks, unitNarration	: String;
	calcTypeCode	: String;
	invTypeDesc		: String;
	debtorTypeCode	: String;
	uomCode			: String; // 31 Jan 2023 navvt20 TFS 56134
	serviceName		: String;
	chargeByUnits,
	printingOrder	: Integer;
	
	minAmount		: Real;					// PAR #36909
	minGroup		: String;				// PAR #36909
	minType			: String;				// PAR #36909

	realILD,
	proxyILD			: CM_InvoiceLineDesc;
	myCalculationType	: CM_CalculationType;
	myInvoiceType		: CM_InvoiceDesc;
	invType 			: CM_InvoiceDesc;
	myDebtorType		: CM_DebtorType;
	myService			: CM_Service;
	services			: CM_ServiceByNameDict	;
	err					: CM_Error;
	isNotAvailableForEntry : Boolean;	//18 Apr 2017	NDL	TFS 3945
	currencyConversionNotRequired : Boolean;
	taxAlwaysCharged : Boolean;
	uom					: CM_InvoiceUnitOfMeasure; //31 Jan 2023 navvt20 TFS 56134
begin
	if _jadeXMLElement = null then
		return;
	endif;
	
	narration		:= null;
	remarks			:= null;
	unitNarration	:= null;
	calcTypeCode	:= null;
	invTypeDesc		:= null;
	chargeByUnits	:= null;
	calcTypeCode	:= null;
	isNotAvailableForEntry := false;	//18 Apr 2017	NDL	TFS 3945

	myCalculationType := null;
	create services transient;

	iter := _jadeXMLElement.childNodes.createIterator;
	while iter.next(xmlNode) do
		if not xmlNode.isKindOf(JadeXMLElement) then
			continue;
		endif;

		xmlElement := xmlNode.JadeXMLElement;
		// property values for this invoice line type
		if xmlElement.tagName = "oneLinePerFP" then
			oneLinePerFP := xmlElement.textData.Boolean;
		elseif xmlElement.tagName = "printTrackedItems" then
			printTrackedItems := xmlElement.textData.Boolean;
		elseif xmlElement.tagName = "chargeByUnits" then
			chargeByUnits := xmlElement.textData.Integer;
		elseif xmlElement.tagName = "isVoid" then
			isVoid := xmlElement.textData.Boolean;
		elseif xmlElement.tagName = "narration" then
			narration := xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "printingOrder" then
			printingOrder := xmlElement.textData.Integer;
		elseif xmlElement.tagName = "remarks" then
			remarks := xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "unitNarration" then
			unitNarration := xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "myCalculationType" then
			calcTypeCode := xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "invoiceType" then
			invTypeDesc := xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "myDebtorType" then		// 36399 was missing
			debtorTypeCode := xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "uom" then // 31 Jan 2023 navvt20 TFS 56134
			uomCode	:= xmlElement.textData.trimBlanks(); // 31 Jan 2023 navvt20 TFS 56134
		elseif xmlElement.tagName = "minimumChargeAmount" then				// PAR #36909
			minAmount := xmlElement.text.trimBlanks.Real;					// PAR #36909
		elseif xmlElement.tagName = "minimumChargeGroupBy" then				// PAR #36909
			minGroup := xmlElement.text.trimBlanks;							// PAR #36909
		elseif xmlElement.tagName = "minimumChargeInvoiceLineType" then		// PAR #36909
			minGroup := xmlElement.text.trimBlanks;							// PAR #36909
			
		elseif xmlElement.tagName = "isNotAvailableForEntry" then	//18 Apr 2017	NDL	TFS 3945
			isNotAvailableForEntry := xmlElement.textData.Boolean;
		elseif xmlElement.tagName = "currencyConversionNotRequired" then   //16.11.2018 cnwma1 TFS #42059
			currencyConversionNotRequired := xmlElement.textData.Boolean;  //16.11.2018 cnwma1 TFS #42059
		elseif xmlElement.tagName = "taxAlwaysCharged" then	//07 May 2019	NDL	TFS 44651
			taxAlwaysCharged := xmlElement.textData.Boolean;
		// services
		elseif xmlElement.tagName = "services" then
			serviceIter := xmlElement.childNodes.createIterator;
			while serviceIter.next(serviceNode) do
				if not serviceNode.isKindOf(JadeXMLElement) then
					continue;
				endif;
			serviceElement := serviceNode.JadeXMLElement;
			if serviceElement.tagName = "service" then
				serviceName := serviceElement.textData.trimBlanks();
				myService := _bank.services[serviceName];
				if myService &lt;&gt; null then
					services.add(myService);
				endif;
			endif;	
			endwhile;
		endif;
	endwhile;
	
	// don't error from these being null, just skip them and sort out manually later
	if calcTypeCode &lt;&gt; null then
		myCalculationType	:= app.myRoot.allCalculationTypesByCode[calcTypeCode];
	endif;
	if invTypeDesc &lt;&gt; null then
		found := false;
		foreach invType in _bank.invoiceTypes  discreteLock do
			if invType.description = invTypeDesc then
				found := true;
				break;
			endif;
		endforeach;
		if found then
			myInvoiceType := invType;
		endif;
	endif;
	if debtorTypeCode &lt;&gt; null then
		myDebtorType := app.myRoot.allDebtorTypes[debtorTypeCode];
	endif;
	// Start 2 Feb 2023 navvt20 TFS 56134
	if uomCode&lt;&gt; null then
		uom := app.myRoot.allInvoiceUnitOfMeasure[uomCode];
	endif;
	// End 2 Feb 2023 navvt20 TFS 56134
	// add if new otherwise update existing object
	realILD := _bank.invoiceLineDescriptors[narration];
	if realILD &lt;&gt; null then
		proxyILD := app.createUpdateProxy(realILD).CM_InvoiceLineDesc;
	else
		create proxyILD as CM_InvoiceLineDesc transient;
	endif;
	proxyILD.bank := _bank;

	proxyILD.setProxy(oneLinePerFP, printTrackedItems, 0, myDebtorType,
						myCalculationType, myInvoiceType, narration,
						printingOrder, remarks, unitNarration,
						//services, false);									// PAR #36909
						//services, false, minAmount, minGroup, minType);		// PAR #36909
						services, isNotAvailableForEntry, minAmount, minGroup, minType, currencyConversionNotRequired,	//18 Apr 2017	NDL	TFS 3945
						taxAlwaysCharged,	//07 May 2019	NDL	TFS 44651
						null,
						uom); // 31 Jan 2023 navvt20 TFS 56134

	_proxyArray.add(proxyILD);
	
epilog
	delete iter;
	delete serviceIter;
	delete services;
end;</source>
        <Parameter name="_jadeXMLElement" type="JadeXMLElement" usage="input"/>
        <Parameter name="_proxyArray" type="ObjectArray" usage="input"/>
        <Parameter name="_errorStore" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="trxImportInvoiceTypeObject" id="0431b4df-e208-4cec-b45d-e7720557f4a2">
        <updating/>
        <source>trxImportInvoiceTypeObject(_jadeXMLElement : JadeXMLElement input; _proxyArray : ObjectArray input; 
							   _errorStore : CM_ErrorSet input; _bank : CM_Bank) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
May 2015	cnwjre1	Copy invoice types from UAT to production for ADP
15/06/2023	navcs2	ChangeRequest 58434: [58452]: EUP | TAS Invoicing - Invoice Type Configuration

*/

vars
	xmlNode			: JadeXMLNode;
	xmlElement		: JadeXMLElement;
	iter			: Iterator;
	
	isAllowManEditExtRef, //08/12/2025	navkc1 JIRA 36262
	isNotAvailableForEntry,
	printSingleLineForDayType	: Boolean;
	description,
	externalReference	: String;
	finPEDesc		: String;
	termsCode		: String;
	accrualType,
	invoiceKey,
	invoiceType,
	number,
	triggerOnAction	: Integer;
	hsa				: HugeStringArray;

	invType,
	realInvType,
	proxyInvType			: CM_InvoiceDesc;
	myFinancialPeriodEnd	: CM_FinancialPeriodEnd;
	myInvTermsOfTrade		: CM_InvoiceTermsOfTrade;
	
begin
	if _jadeXMLElement = null then
		return;
	endif;
	
	description		:= null;
	externalReference	:= null;
	finPEDesc		:= null;
	termsCode		:= null;
	isNotAvailableForEntry	:= null;
	printSingleLineForDayType	:= null;
	accrualType		:= null;
	invoiceKey		:= null;
	invoiceType		:= null;
	number			:= null;
	triggerOnAction	:= null;

	myFinancialPeriodEnd := null;
	myInvTermsOfTrade	:= null;
	
	create hsa transient;

	iter := _jadeXMLElement.childNodes.createIterator;
	while iter.next(xmlNode) do
		if not xmlNode.isKindOf(JadeXMLElement) then
			continue;
		endif;

		xmlElement := xmlNode.JadeXMLElement;
		// property values for this invoice type
		if xmlElement.tagName = "accrualType" then
			accrualType := xmlElement.textData.Integer;
		elseif xmlElement.tagName = "narration" then
			hsa.add(xmlElement.textData.trimBlanks());
		elseif xmlElement.tagName = "description" then
			description := xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "externalReference" then
			externalReference := xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "invoiceKey" then
			invoiceKey := xmlElement.textData.Integer;
		elseif xmlElement.tagName = "invoiceType" then
			invoiceType := xmlElement.textData.Integer;
		elseif xmlElement.tagName = "isNotAvailableForEntry" then
			isNotAvailableForEntry := xmlElement.textData.Boolean;
		elseif xmlElement.tagName = "myFinancialPeriodEnd" then
			finPEDesc := xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "myInvTermsOfTrade" then
			termsCode := xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "number" then
			number := xmlElement.textData.Integer;
		elseif xmlElement.tagName = "printSingleLineForDayType" then
			printSingleLineForDayType := xmlElement.textData.Boolean;
		elseif xmlElement.tagName = "triggerOnAction" then
			triggerOnAction := xmlElement.textData.Integer;
		elseif xmlElement.tagName = "allowManEditExtRef" then
			isAllowManEditExtRef := xmlElement.textData.Boolean; //08/12/2025	navkc1 JIRA 36262
		endif;
	endwhile;
	
	// don't error from these being null, just skip them and sort out manually later
	if finPEDesc &lt;&gt; null then
		myFinancialPeriodEnd := app.myRoot.myRootCompany.allFinancialPeriods[finPEDesc];
	endif;
	if termsCode &lt;&gt; null then
		myInvTermsOfTrade := app.myRoot.myRootCompany.allInvoiceTermsOfTrade[termsCode];
	endif;

	// add if new otherwise update existing object
	realInvType := _bank.findInvoiceType(description);
	if realInvType &lt;&gt; null then
		proxyInvType := app.createUpdateProxy(realInvType).CM_InvoiceDesc;
	else
		create proxyInvType as CM_InvoiceDesc transient;
	endif;

	proxyInvType.setProxy(accrualType, hsa, description, invoiceKey,
						invoiceType, myFinancialPeriodEnd, myInvTermsOfTrade,
						printSingleLineForDayType, triggerOnAction, null, null, null,
						externalReference, isNotAvailableForEntry, false, false, isAllowManEditExtRef);  // 15.06.2023	navcs2	#58434:[58452]

	proxyInvType.setCompany(_bank);		// 35872

	_proxyArray.add(proxyInvType);
	
epilog
	delete iter;
	delete hsa;
end;</source>
        <Parameter name="_jadeXMLElement" type="JadeXMLElement" usage="input"/>
        <Parameter name="_proxyArray" type="ObjectArray" usage="input"/>
        <Parameter name="_errorStore" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="trxImportInvoiceTypesFromFile" id="f7b7cb87-4368-4088-8298-3c4a47e5cbac">
        <updating/>
        <source>trxImportInvoiceTypesFromFile( _file : File; _bank : CM_Bank; _passport : CM_Passport input ) : Integer updating;

/*
Purpose:		ADP copy invoice types from UAT to production

Parameters:		Import File, bank and passport.  File format is XML, see CM_ExtractLoadAgent::extractInvoiceTypes

Date		Who		Reason
May 2015	cnwjre1	Copy invoice types from one JMT copy to another
*/
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	hadException					: Boolean;
	count, numCodes, noLines 		: Integer;
	proxyID, newID					: CM_InvoiceDesc;
	theRoot							: CM_Root;
	thePassport						: CM_Passport;
	err								: CM_Error;
	errorStore						: CM_ErrorSet;
	proxyArray						: ObjectArray;
	obj								: Object;

	xmlDocumentParser : JadeXMLDocumentParser;
	rootElement : JadeXMLElement;
	rootNode	: JadeXMLNode;
	childElement	: JadeXMLElement;
	xmlDocument : JadeXMLDocument;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	thePassport := _passport;
	theRoot 	:= app.myRoot;

	// Always initialize the activity first
	self.initialiseActivityWithPassport(thePassport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, thePassport);
	on LockException do agtPassportLockExHandler(exception, thePassport);
	app.setContinueCMExceptions(false);
	
	if not _file.tryOpen() then
		app.raiseCMException(VB_FILE_ERROR, app.getErrorString(File_open), null);	
		return 0;
	endif;
	
	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	create proxyArray transient;
	create errorStore transient;
	
	create xmlDocumentParser transient;
	create xmlDocument transient;
	xmlDocumentParser.parseDocumentFile(xmlDocument,_file.fileName);
	rootElement := xmlDocument.rootElement;
	foreach rootNode in rootElement.childNodes do
		if rootNode.isKindOf(JadeXMLElement) then
			childElement := rootNode.JadeXMLElement;
			self.trxImportInvoiceTypeObject(childElement, proxyArray, errorStore, _bank);
			noLines := noLines + 1;
		endif;
	endforeach;
	
	if thePassport.myCMIFMonitor &lt;&gt; null then
		thePassport.myCMIFMonitor.updateProgress(app.getErrorString(Reading_import_file), 10, 10);
	endif;
	
	count:= 0;
	numCodes := proxyArray.size;
	
	// Start the transaction
	beginTransaction;
	
	// Perform the operation
	foreach obj in proxyArray do
		proxyID := obj.CM_InvoiceDesc;
		progressInt := app.actualTimeServer() - progressTS;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if thePassport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (count = numCodes)) then
			thePassport.myCMIFMonitor.updateProgress(app.getErrorString1(Creating_msg, 'Invoice Type'), numCodes, count);
			progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		// add if new otherwise update existing object
		if _bank.findInvoiceType(proxyID.description) = null then
			app.myUtilityCA.utlCreateInvoiceDesc(proxyID, newID, app.myPassport);
		else
			app.myUtilityUA.utlUpdateInvoiceDesc(proxyID, app.myPassport);
		endif;

		if thePassport.hasErrors then
			foreach err in thePassport.allErrors do 
				err.setErrorText('Invoice type ' &amp; ' : ' &amp; proxyID.description &amp; '  ' &amp; err.text, false);
				errorStore.add(err);
			endforeach;
			// clear errors from logic so that any successful updates will still be done but stop on any exception
			foreach err in thePassport.allErrors do
				if err.errorCode &lt; app.baseErrorNum then
					count := 0;
					hadException := true;
					break;
				endif;
				err.removeFromPassport;
			endforeach;
		else
			count := count + 1;
		endif;
		if hadException then
			break;
		endif;
	endforeach;
	
	self.trxWriteToLogFile2(_file.fileName, noLines, count, errorStore);
	
	return count;
epilog
	if proxyArray &lt;&gt; null then
		proxyArray.purge;
		delete proxyArray;
	endif;
	_file.close;
	delete xmlDocumentParser;
	delete xmlDocument;
	self.finaliseActivityWithPassport(thePassport);
	delete errorStore;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxImportPortFromFile" id="a402d0f8-3a98-494c-967e-9942e3f4b01c">
        <updating/>
        <source>trxImportPortFromFile( _file : File; _passport : CM_Passport input ) updating;

/*
Purpose:		MES 1010 Interface load	

Parameters:		Import File and passport	

Date		Who		Reason
11 August 2009	cnwjmn1	Initial creation
20/11/2009		cnwdad1	PAR 21650.  Changed to handle quoted fields.
06/07/2010	cnwrl1	PAR 24606 - Import order changed to match "JMT Default".
07/07/2010	cnwrl1		PAR 24848 - System Admin Import to allow minimum amount of data.
*/
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
//04/08/2016	cnwdap1	TFS #2447 Ensure Port Code and Port Short Code are upper case
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	count			: Integer;
	numCodes		: Integer;
	noLines			: Integer;
	portColour		: Integer;			// 20/05/2010 cnwmh5 #24264
	fieldNo			: Integer;
	fieldValue		: String;
	portCode		: String;
	portCodeShort	: String;
	portDesc		: String;
	portCntry		: String;
	fileLine		: String;
	codePrint		: String;
	fieldArray		: CnStringArray;
	isAvail			: Boolean;
	isRail			: Boolean;
	isRoad			: Boolean;
	isAirport		: Boolean;
	isPostal		: Boolean;
	isMulti			: Boolean;
	isFixed			: Boolean;
	isBorder		: Boolean;
	currentPort		: CM_Port;
	newPort			: CM_Port;
	pxyPort			: CM_Port;
	countryObj		: CM_Country;
	portGroupObj	: CM_PortGroup;
	portColl		: CM_PortByCodeDict;
	theRoot			: CM_Root;
	thePassport		: CM_Passport;
	err				: CM_Error;
	errorStore		: CM_ErrorSet;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	thePassport := _passport;
	theRoot 	:= app.myRoot;
	
	// Always initialize the activity first
	self.initialiseActivityWithPassport(thePassport, method);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, thePassport);
	on LockException do agtPassportLockExHandler(exception, thePassport);

	app.setContinueCMExceptions(false);
	
	if not _file.tryOpen() then
		app.raiseCMException(VB_FILE_ERROR, app.getErrorString(File_open), null);
		return;
	endif;
	
	create portColl transient;
	create fieldArray transient;
	create errorStore transient;
	
	//ignore first line
	fileLine 	:= _file.readLine();
	noLines		:= 1;
	
	while not _file.endOfFile() do
		fileLine 	:= _file.readLine();
		noLines		:= noLines + 1;
		
		if fileLine = null then
			continue;
		endif;
		
		fieldArray.clear();
		
		fileLine.csvToStringArray(fieldArray, ImportDelimiter.Character);
		
		/* cnwrl1 07/07/2010 PAR 24848 - what it was
		if fieldArray.size() &lt;&gt; 5 then				// 20/05/2010 cnwmh5 #24264
			create err transient;
			err.set(0, app.getErrorString1(Line_incorre_number_columns, noLines.String &amp; '  ' &amp; fieldArray.size.String), false, '', pxyPort, null);
			errorStore.add(err);
			continue;
		endif;
		cnwrl1 07/07/2010 PAR 24848 - end of what it was */
		
		// cnwrl1 07/07/2010 PAR 24848 - start of coding
		if fieldArray.isEmpty then
			continue;
		endif;
		portCode		:= null;
		portCodeShort	:= null;
		portDesc		:= null;
		portCntry		:= null;
		portColour 		:= null;
		// cnwrl1 07/07/2010 PAR 24848 - end of coding
		
		/*
		The import layout for this table is exactly (or similar) to the column organiser "JMT Default".
		This is what has been supplied to Messina in document CCMS MES 1008, 1010 Interfaces Messages,
		also see the JMT User Guide section for System Codes Reference.
		*/
		fieldNo :=	0;
		
		foreach fieldValue in fieldArray do
			fieldNo	:=	fieldNo + 1;
			
			// cnwrl1 06/07/2010 PAR 24606 - reorder import fields to match "JMT Default"
			if fieldNo = 1 then
				//portCode		:=	fieldValue.trimBlanks();					// TFS #2447
				portCode		:=	fieldValue.trimBlanks().toUpper;			// TFS #2447
			elseif fieldNo = 2 then
				//portCodeShort	:=	fieldValue.trimBlanks();					// TFS #2447
				portCodeShort	:=	fieldValue.trimBlanks().toUpper;			// TFS #2447
			elseif fieldNo = 3 then
				portDesc		:=	fieldValue.trimBlanks();
			elseif fieldNo = 4 then
				portCntry		:=	fieldValue.trimBlanks();
			elseif fieldNo = 5 then
				portColour 		:= 	fieldValue.Integer;
			endif;
		endforeach;
		
		if portCntry &lt;&gt; null then
			countryObj	:=	theRoot.allCountries[portCntry];
			
			if countryObj = null then
				create err transient;
				err.set(0, app.getErrorString(Info_PortCode) &amp; ' : ' &amp; portCode &amp; '  ' &amp; app.getErrorString(Invalid) &amp; app.getErrorString(Country_Code) &amp; ' : ' &amp; portCntry, false, '', pxyPort, null);
				errorStore.add(err);
				continue;
			endif;
		else
			countryObj	:=	null;
		endif;
		
// if port already exists get fields not in file so they aren't cleared
		currentPort := theRoot.allPorts[portCode];
		
		if currentPort &lt;&gt; null then
			codePrint		:= 	currentPort.ccodePrint;
			if portColour.String.length = 0 then
				portColour	:= 	currentPort.colour;
			endif;
			isAvail			:=	currentPort.isNotAvailableForEntry;
			isRail			:=	currentPort.bIsRail;
			isRoad			:=	currentPort.bIsRoad;
			isAirport		:=	currentPort.bIsAirport;
			isPostal		:=	currentPort.bIsPostalExchange;
			isMulti			:=	currentPort.bIsMultiModal;
			isFixed			:=	currentPort.bIsFixedTransport;
			isBorder		:=	currentPort.bIsBorderCrossing;
			portGroupObj	:=	currentPort.myPortGroup;
		else
			codePrint		:= 	null;
			isAvail			:=	false;
			isRail			:=	false;
			isRoad			:=	false;
			isAirport		:=	false;
			isPostal		:=	false;
			isMulti			:=	false;
			isFixed			:=	false;
			isBorder		:=	false;
			portGroupObj	:=	null;		
		endif;
		
		create pxyPort transient;
		pxyPort.setProxy(	portCode,
							portCodeShort,
							portDesc,
							codePrint,
							portColour,			// 20/05/2010 cnwmh5 #24264
							countryObj,
							portGroupObj,
							null, //US LOcation
							isAvail,
							true,				// isPort
							isRail,
							isRoad,
							isAirport,
							isPostal,
							isMulti,
							isFixed,
							isBorder );
		
		if not portColl.includesKey(portCode) then
			portColl.add(pxyPort);
		else
			create err transient;
			err.set(0, app.getErrorString(Info_PortCode) &amp; ' : ' &amp; app.getErrorString2(Line_duplicate_file, noLines.String, app.getErrorString(Ports)) &amp; portCode, false, '', pxyPort, null);
			errorStore.add(err);
		endif;
	endwhile;
	
	if thePassport.myCMIFMonitor &lt;&gt; null then
		thePassport.myCMIFMonitor.updateProgress(app.getErrorString(Reading_import_file), 10, 10);
	endif;
	
	count		:=	0;
	numCodes	:=	portColl.size();

	// Start the transaction
	beginTransaction;
	
	// Perform the operation
	foreach pxyPort in portColl do
		count := count + 1;
		progressInt := app.actualTimeServer() - progressTS;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if thePassport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (count = numCodes)) then
			thePassport.myCMIFMonitor.updateProgress(app.getErrorString1(Creating_msg, (app.getErrorString(Ports))), numCodes, count);
			progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		currentPort := theRoot.allPorts[pxyPort.code];
		
		if currentPort = null then
			app.myUtilityCA.utlCreatePort(pxyPort, newPort, thePassport);
		else
			app.myProxyManager.createProxyLink (currentPort, pxyPort);
			app.myUtilityUA.utlUpdatePort(pxyPort, true, thePassport);
		endif;
		
		if thePassport.hasErrors() then
			foreach err in thePassport.allErrors do
				err.setErrorText(app.getErrorString(Info_PortCode) &amp; ' : ' &amp; pxyPort.code &amp; '  ' &amp; err.text, false);
				errorStore.add(err);
			endforeach;
			
			foreach err in thePassport.allErrors do
				err.removeFromPassport();
			endforeach;
		endif;
	endforeach;
	
	trxWriteToLogFile(_file.fileName, noLines, count, thePassport, errorStore);
	
epilog
	delete fieldArray;
	
	if portColl &lt;&gt; null then
		portColl.purge();
		delete portColl;
	endif;
	
	_file.close();
	self.finaliseActivityWithPassport(thePassport);
	delete errorStore;
end;
</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxImportServPayTypesFromFile" id="f26ec140-c55c-486f-b734-524f3ab97085">
        <updating/>
        <source>trxImportServPayTypesFromFile( _file : File; _bank : CM_Bank; _passport : CM_Passport input ) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2018	jlgndl1	Initial creation	TFS 42060

*/

vars

	xmlDocumentParser : JadeXMLDocumentParser;
	rootElement : JadeXMLElement;
	xmlDocument : JadeXMLDocument;
	count : Integer;
	allNewProxys : CM_ServicePayTypeMapDebtorServ;
	newProxy : CM_ServicePayTypeMapping;
	real : CM_ServicePayTypeMapping;
	
	servicePaymentElements : JadeXMLElementArray;
	element : JadeXMLElement;
	allDebtors : CM_DebtorByNameDict;

begin

	_passport.setMyTerminal(_bank.terminal);

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	app.setContinueCMExceptions(true);
	
	if not _file.tryOpen() then
		app.raiseCMException(VB_FILE_ERROR, app.getErrorString(File_open), null);	
		return 0;
	endif;
	
	create allNewProxys transient;
	create xmlDocumentParser transient;
	create xmlDocument transient;
	create servicePaymentElements transient;
	create allDebtors transient;
	create allNewProxys transient;
	
	xmlDocumentParser.parseDocumentFile(xmlDocument,_file.fileName);
	rootElement := xmlDocument.rootElement;
	
	rootElement.getAllElementsByTagName("servicePaymentTypeMapping", servicePaymentElements );
	
	CM_Debtor.instances.copy( allDebtors );
	CM_VoidDebtor.instances.copy( allDebtors );
	
	//This an all or nothing process...
	//This load completely replaces the CM_Bank.allServicePayTypeMappings collection, so
	//before we do this for any of the items, lets check that ALL of the data we expect to link up 
	//already exists.
	foreach element in servicePaymentElements do
		app.myValCA.valImportServPayTypesXML( _bank, element, allDebtors, allNewProxys, _passport );
	endforeach;
	
	if _passport.hasErrors then
		self.trxWriteToLogFile2(_file.fileName, servicePaymentElements.size, 0, _passport.allErrorWarnings);	//17 Dec 2018 NDL
		return 0;
	endif;
	app.setContinueCMExceptions(false);
	
	// If we got this far, all of the data we need apparently exists, so we will have a go at
	// clearing any existing data and creating the surcharge structure for the line types in the file.
	
	
	// Start the transaction
	beginTransaction;
	
	//first get rid of all of the existing Service Payment Types for this bank.
	_bank.allServicePayTypeMappings.purge();
	
	foreach newProxy in allNewProxys do	
		app.myUtilityCA.utlCreatePaymentTypeMap( newProxy, real,  _passport );
		if _passport.hasErrors then
			return 0;
		endif;
		count := count + 1;
	endforeach;
	
	self.trxWriteToLogFile2(_file.fileName, servicePaymentElements.size, count, null);	//17 Dec 2018 NDL
	
	return count;
	
epilog

	if allNewProxys &lt;&gt; null then
		allNewProxys.purge;
		delete allNewProxys;
	endif;
	_file.close;
	delete xmlDocumentParser;
	delete xmlDocument;
	delete servicePaymentElements;
	delete allDebtors;
	
	self.finaliseActivityWithPassport( _passport );

end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxImportServiceObject" id="90f0b41e-1d66-4cf6-9029-8b38dbb64166">
        <updating/>
        <source>trxImportServiceObject(_jadeXMLElement : JadeXMLElement input; 
					   _parentGroup    : CM_ServiceGroup; 
					   _proxyArray     : ObjectArray input; 
					   _errorStore     : CM_ErrorSet input; 
					   _bank 	       : CM_Bank) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
Apr 2012	cnwjre1	Copy services retaining groups and children for DOHA from test to UAT
21 Dec 2020 cnwma1  Bug 50536: LNX-Error Code 1035
// 23/8/22	navkc1 	ChangeRequest #54569 - Add Service Types
15 Dec 2023 navbs1  ChangeRequest 61770: SAL - Service Schedule Data
*/

vars
	xmlAttribute	: JadeXMLAttribute;
	childNode		: JadeXMLNode;
	xmlNode			: JadeXMLNode;
	xmlElement		: JadeXMLElement;
	parentElement	: JadeXMLElement;
	iter			: Iterator;
	childIter		: Iterator;
	className		: String;
	serviceName, 
	genLCode, 
	taxCode, 
	calcType,
	remarks			: String;
	chargeByOpCon, 
	chargeByUnits, 
	defaultRateTable: Integer;

	realService,
	proxyService				: CM_ServiceObject;
	proxyGroup					: CM_ServiceGroup;
	parentGroup					: CM_ServiceGroup;
	myCalculationType			: CM_CalculationType;
	myGLCode					: CM_GLCode;
	myTaxCode					: CM_TaxCode;
	externalReference1			: String;    
	externalReference2			: String;
begin
	if _jadeXMLElement = null then
		return;
	endif;
	
	xmlAttribute := _jadeXMLElement.getAttributeByName('class');
	if xmlAttribute &lt;&gt; null then
		className := xmlAttribute.value.trimBlanks();
	endif;
	
	serviceName		:= null;
	remarks			:= null;
	serviceName		:= null;
	genLCode		:= null;
	taxCode			:= null;
	chargeByOpCon	:= null;
	chargeByUnits	:= null;
	defaultRateTable := null;
	calcType		:= null;
	externalReference1:=null; 		//15.12.2023 navbs1 #61770
	externalReference2:=null; 		//15.12.2023 navbs1 #61770

	myCalculationType := null;

	iter := _jadeXMLElement.childNodes.createIterator;
	while iter.next(xmlNode) do
		if not xmlNode.isKindOf(JadeXMLElement) then
			continue;
		endif;

		xmlElement := xmlNode.JadeXMLElement;
		// property values for this service
		if xmlElement.tagName = "name" then
			serviceName      := xmlElement.textData.trimBlankCharacters(); //21.12.2020 cnwma1 #50536
		elseif xmlElement.tagName = "remarks" then
			remarks 	     := xmlElement.textData.trimBlankCharacters(); //21.12.2020 cnwma1 #50536
		elseif xmlElement.tagName = "genLCode" then
			genLCode 	     := xmlElement.textData.trimBlankCharacters(); //21.12.2020 cnwma1 #50536
		elseif xmlElement.tagName = "taxCode" then
			taxCode 	     := xmlElement.textData.trimBlankCharacters(); //21.12.2020 cnwma1 #50536
		elseif xmlElement.tagName = "chargeByOpCon" then
			chargeByOpCon    := xmlElement.textData.Integer;
		elseif xmlElement.tagName = "chargeByUnits" then
			chargeByUnits 	 := xmlElement.textData.Integer;
		elseif xmlElement.tagName = "defaultRateTable" then
			defaultRateTable := xmlElement.textData.Integer;
		elseif xmlElement.tagName = "calculationType" then
			calcType 		 := xmlElement.textData.trimBlankCharacters(); //21.12.2020 cnwma1 #50536
		elseif xmlElement.tagName = "externalReference1" then               				//15.12.2023 navbs1 #61770
			externalReference1 		 := xmlElement.textData.trimBlankCharacters();  		
		elseif xmlElement.tagName = "externalReference2" then								//15.12.2023 navbs1 #61770
			externalReference2 		 := xmlElement.textData.trimBlankCharacters();

		// children - separate services
		elseif xmlElement.tagName = "children" then
			// process after the parent
			parentElement := xmlElement;
		endif;
	endwhile;
	
	// ignore system-defined CM_VoidService and initial "Root Service Group" - assumed to be already present
	if className &lt;&gt; "CM_VoidService" and
	   serviceName &lt;&gt; "Root Service Group" then
	
		if _parentGroup &lt;&gt; null then
			parentGroup := _parentGroup;
		else
			parentGroup	:= _bank.rootServiceGroup;
		endif;		
		// don't error from these being null, just skip it and sort out manually later
		if calcType &lt;&gt; null then
			myCalculationType			:= app.myRoot.allCalculationTypesByCode[calcType.removeCrLfs]; //21.12.2020 cnwma1 #50536
		endif;
		if genLCode &lt;&gt; null then
			myGLCode := _bank.glCodes[genLCode.removeCrLfs];  			//21.12.2020 cnwma1 #50536
		endif;
		if taxCode &lt;&gt; null then
			myTaxCode := _bank.allTaxCodes[taxCode.removeCrLfs];   	 	//21.12.2020 cnwma1 #50536
		endif;
	
		realService := _bank.serviceObjects[serviceName.removeCrLfs];   //21.12.2020 cnwma1 #50536
		// add if new otherwise update existing object
		if realService &lt;&gt; null then
			if realService.isKindOf(CM_ServiceGroup) then
				proxyService := app.createUpdateProxy(realService).CM_ServiceGroup;
				proxyGroup := proxyService.CM_ServiceGroup;
			elseif realService.isKindOf(CM_Service) then
				proxyService := app.createUpdateProxy(realService).CM_Service;
			endif;
		else
			if className = "CM_ServiceGroup" then
				create proxyService as CM_ServiceGroup transient;
				proxyGroup := proxyService.CM_ServiceGroup;
			else
				create proxyService as CM_Service transient;
			endif;
		endif;

		proxyService.setProxy(serviceName,
							 _bank,
							 remarks,
							 myGLCode,
							 parentGroup,
							 defaultRateTable,
						  	 myCalculationType,
							 myTaxCode,
							 false,externalReference1,externalReference2, 		//15.12.2023 navbs1 #61770
							 null); // 23/08/22	navkc1	#54569

		_proxyArray.add(proxyService);
	endif;
	
	// process the children after the parent
	if parentElement &lt;&gt; null then
		childIter := parentElement.childNodes.createIterator;
		while childIter.next(childNode) do
			if not childNode.isKindOf(JadeXMLElement) then
				continue;
			endif;
			self.trxImportServiceObject(childNode.JadeXMLElement, proxyGroup, _proxyArray, _errorStore, _bank);
		endwhile;
	endif;

epilog
	delete iter;
	delete childIter;
end;</source>
        <Parameter name="_jadeXMLElement" type="JadeXMLElement" usage="input"/>
        <Parameter name="_parentGroup" type="CM_ServiceGroup"/>
        <Parameter name="_proxyArray" type="ObjectArray" usage="input"/>
        <Parameter name="_errorStore" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="trxImportServicesFromFile" id="4283d10a-e0ef-4ff6-8758-5b84b4606687">
        <updating/>
        <source>trxImportServicesFromFile( _file : File; _bank : CM_Bank; _passport : CM_Passport input ) : Integer updating;

/*
Purpose:		DOHA copy services from Test to UAT

Parameters:		Import File and passport.  File format is XML, see CM_ExtractLoadAgent::extractServices

Date		Who		Reason
Apr 2012	cnwjre1	Copy services with groups from one JMT copy to another
*/
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 07/05/2017 	cnwrh7  TFS4689 STWO - Load Services Issue

constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	hadException						: Boolean;
	count, numCodes, noLines 			: Integer;
	index								: Integer;
	proxyService, newService			: CM_ServiceObject;
	serviceGroup						: CM_ServiceGroup;
	theRoot								: CM_Root;
	thePassport							: CM_Passport;
	debtorNodeController				: CMIF_DebtorNode;
	err									: CM_Error;
	errorStore							: CM_ErrorSet;
	proxyArray							: ObjectArray;
	proxyGroups, realGroups				: ObjectArray;
	obj, serviceObj						: Object;

	xmlDocumentParser : JadeXMLDocumentParser;
	rootElement : JadeXMLElement;
	xmlDocument : JadeXMLDocument;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
	
	tempXMLObj : Object;											//+TFS4689 Starts
	tempPxoyArray : ObjectArray;
	tempDupicateNameArray : StringArray;
	duplicatedServiceName : String;						//+TFS4689 Ends
	
begin
	thePassport := _passport;
	theRoot 	:= app.myRoot;
	if thePassport.myTerminal = null then
		thePassport.setMyTerminal(_bank.terminal);
	endif;

	// Always initialize the activity first
	self.initialiseActivityWithPassport(thePassport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, thePassport);
	on LockException do agtPassportLockExHandler(exception, thePassport);
	app.setContinueCMExceptions(false);
	
	if not _file.tryOpen() then
		app.raiseCMException(VB_FILE_ERROR, app.getErrorString(File_open), null);	
		return 0;
	endif;
	
	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	create proxyArray transient;
	create errorStore transient;
	create proxyGroups transient;
	create realGroups transient;
	
	create xmlDocumentParser transient;
	create xmlDocument transient;
		
	create tempPxoyArray transient;																	//+TFS4689
	create tempDupicateNameArray transient;												//+TFS4689
	
	xmlDocumentParser.parseDocumentFile(xmlDocument,_file.fileName);
	rootElement:=xmlDocument.rootElement;
	
	self.trxImportServiceObject(rootElement, null, proxyArray, errorStore, _bank);
	
	if thePassport.myCMIFMonitor &lt;&gt; null then
		thePassport.myCMIFMonitor.updateProgress(app.getErrorString(Reading_import_file), 10, 10);
	endif;
	
	count:= 0;
	numCodes := proxyArray.size;
	noLines	:= numCodes;
	// Doing Duplication checking  +TFS4689 Starts
	proxyArray.copy(tempPxoyArray);
	foreach obj in proxyArray do
		proxyService	:= obj.CM_ServiceObject;
		foreach tempXMLObj in tempPxoyArray do 
			if proxyService.CM_ServiceObject &lt;&gt; tempXMLObj.CM_ServiceObject 	and proxyService.name = tempXMLObj.CM_ServiceObject.name then
					if not tempDupicateNameArray.includes( proxyService.CM_ServiceObject .name) then
						tempDupicateNameArray.add(proxyService.CM_ServiceObject .name);
					endif;
			endif;
		endforeach;
	endforeach;
	
	if tempDupicateNameArray.size &gt;0 then
		foreach duplicatedServiceName in tempDupicateNameArray do 
				app.raiseCMException1(Already_exists_service,duplicatedServiceName,null,null ); 
		endforeach;
	endif;
	
	if thePassport.hasErrors then
			foreach err in thePassport.allErrors do 
				err.setErrorText('Service ' &amp; ' : ' &amp; proxyService.name &amp; '  ' &amp; err.text, false);
				errorStore.add(err);
			endforeach;
			// clear errors from logic so that any successful updates will still be done but stop on any exception
			foreach err in thePassport.allErrors do
				if err.errorCode &lt; app.baseErrorNum then
					hadException := true;
					break;
				endif;
				err.removeFromPassport;
			endforeach;
			self.trxWriteToLogFile2(_file.fileName, noLines, count, errorStore);
			return  count;												//return 0 for the number of service imported
	endif;																			//+TFS4689 Ends						

		
	// Start the transaction
	beginTransaction;
	// Perform the operation
	foreach obj in proxyArray do : firstProxyArray
		proxyService	:= obj.CM_ServiceObject;
	
		progressInt := app.actualTimeServer() - progressTS;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if thePassport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (count = numCodes)) then
			thePassport.myCMIFMonitor.updateProgress(app.getErrorString1(Creating_msg, 'Service'), numCodes, count);
			progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		// the group on the proxy service is also a transient proxy if it is anything other than the bank root group - 
		//   replace it with the just-created persistent instance
		if proxyService.group &lt;&gt; null and
		   proxyService.group.isTransient() then
			serviceGroup := proxyService.group;
			index := 0;
			foreach serviceObj in proxyGroups do
				index := index + 1;
				if serviceObj = serviceGroup then
					// replace with persistent equivalent
					serviceGroup := realGroups[index].CM_ServiceGroup;
					proxyService.group := serviceGroup;
					break;
				endif;
			endforeach;
		endif;

		if _bank.serviceObjects[proxyService.name] = null then
			app.myUtilityCA.utlCreateServiceObject(proxyService, newService, app.myPassport);
		else
			app.myUtilityUA.utlUpdateServiceObject(proxyService, app.myPassport);
			newService := proxyService.pxyGetRealObject();		// 36358 recut
		endif;
		if proxyService.isKindOf(CM_ServiceGroup) then
			proxyGroups.add(proxyService);
			realGroups.add(newService);
		endif;

		if thePassport.hasErrors then
			foreach err in thePassport.allErrors do 
				err.setErrorText('Service ' &amp; ' : ' &amp; proxyService.name &amp; '  ' &amp; err.text, false);
				errorStore.add(err);
			endforeach;
			// clear errors from logic so that any successful updates will still be done but stop on any exception
			foreach err in thePassport.allErrors do
				if err.errorCode &lt; app.baseErrorNum then
					count := 0;
					hadException := true;
					break;
				endif;
				err.removeFromPassport;
			endforeach;
		else
			count := count + 1;
		endif;
		if hadException then
			break;
		endif;
	endforeach;
	
	self.trxWriteToLogFile2(_file.fileName, noLines, count, errorStore);
	
	return count;
epilog
	if proxyArray &lt;&gt; null then
		proxyArray.purge;
		delete proxyArray;
	endif;
	_file.close;
	delete xmlDocumentParser;
	delete xmlDocument;
	delete proxyGroups;
	delete realGroups;
	self.finaliseActivityWithPassport(thePassport);
	delete errorStore;
	delete tempPxoyArray;													//+TFS4689
	delete tempDupicateNameArray;								//+TFS4689
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxImportShippingAgent" id="c7ccc9c4-9660-4f3a-9ece-1e95135a2828">
        <updating/>
        <source>trxImportShippingAgent(_jadeXMLElement : JadeXMLElement input; _proxyArray : ObjectArray input; 
					   _errorStore : CM_ErrorSet input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
Apr 2012	cnwjre1	Copy shipping agents for DOHA from test to UAT

*/

vars
	xmlNode			: JadeXMLNode;
	xmlElement		: JadeXMLElement;
	iter			: Iterator;
	code, description		: String;
	notAvailableForEntry	: Boolean;

	proxyAgent				: CM_ShippingAgent;
	
	err						: CM_Error;
begin
	if _jadeXMLElement = null then
		return;
	endif;
	
	code			:= null;
	description		:= null;
	notAvailableForEntry		:= null;

	iter := _jadeXMLElement.childNodes.createIterator;
	while iter.next(xmlNode) do
		if not xmlNode.isKindOf(JadeXMLElement) then
			continue;
		endif;

		xmlElement := xmlNode.JadeXMLElement;
		// property values for this agent
		if xmlElement.tagName = "code" then
			code := xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "description" then
			description := xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "notAvailableForEntry" then
			notAvailableForEntry := xmlElement.textData.Boolean;
		// and contacts if required
		endif;
	endwhile;
	
	create proxyAgent as CM_ShippingAgent transient;

	proxyAgent.setProxy(code,
						 description,
						 notAvailableForEntry);

	_proxyArray.add(proxyAgent);
	
epilog
	delete iter;
end;</source>
        <Parameter name="_jadeXMLElement" type="JadeXMLElement" usage="input"/>
        <Parameter name="_proxyArray" type="ObjectArray" usage="input"/>
        <Parameter name="_errorStore" type="CM_ErrorSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxImportShippingAgentsFromFil" id="c9105bac-0c07-466f-bb73-afff05db242c">
        <updating/>
        <source>trxImportShippingAgentsFromFil( _file : File; _passport : CM_Passport input ) updating;

/*
Purpose:		DOHA copy shipping agents from Test to UAT

Parameters:		Import File and passport.  File format is XML, see CM_ExtractLoadAgent::extractShippingAgents

Date		Who		Reason
Apr 2012	cnwjre1	Copy shipping agents from one JMT copy to another
*/
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	hadException				: Boolean;
	count, numCodes, noLines 	: Integer;
	proxyAgent, newAgent		: CM_ShippingAgent;
	theRoot						: CM_Root;
	thePassport					: CM_Passport;
	err							: CM_Error;
	errorStore					: CM_ErrorSet;
	proxyArray					: ObjectArray;
	obj							: Object;

	xmlDocumentParser : JadeXMLDocumentParser;
	rootElement : JadeXMLElement;
	xmlDocument : JadeXMLDocument;
	rootNode	: JadeXMLNode;
	childElement	: JadeXMLElement;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	thePassport := _passport;
	theRoot 	:= app.myRoot;

	// Always initialize the activity first
	self.initialiseActivityWithPassport(thePassport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, thePassport);
	on LockException do agtPassportLockExHandler(exception, thePassport);
	app.setContinueCMExceptions(false);
	
	if not _file.tryOpen() then
		app.raiseCMException(VB_FILE_ERROR, app.getErrorString(File_open), null);	
		return;
	endif;
	
	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	create proxyArray transient;
	create errorStore transient;
	
	create xmlDocumentParser transient;
	create xmlDocument transient;
	xmlDocumentParser.parseDocumentFile(xmlDocument, _file.fileName);
	rootElement := xmlDocument.rootElement;
	
	foreach rootNode in rootElement.childNodes do
		if rootNode.isKindOf(JadeXMLElement) then
			childElement := rootNode.JadeXMLElement;
			self.trxImportShippingAgent(childElement, proxyArray, errorStore);
			noLines := noLines + 1;
		endif;
	endforeach;
	
	if thePassport.myCMIFMonitor &lt;&gt; null then
		thePassport.myCMIFMonitor.updateProgress(app.getErrorString(Reading_import_file), 10, 10);
	endif;
	
	count:= 0;
	numCodes := proxyArray.size;
	
	// Start the transaction
	beginTransaction;
	
	// Perform the operation
	foreach obj in proxyArray do
		proxyAgent	:= obj.CM_ShippingAgent;
		count := count + 1;
		progressInt := app.actualTimeServer() - progressTS;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if thePassport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (count = numCodes)) then
			thePassport.myCMIFMonitor.updateProgress(app.getErrorString1(Creating_msg, 'Shipping Agent'), numCodes, count);
			progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		app.myUtilityCA.utlCreateShippingAgent(proxyAgent, newAgent, app.myPassport);

		if thePassport.hasErrors then
			foreach err in thePassport.allErrors do 
				err.setErrorText('Shipping Agent ' &amp; ' : ' &amp; proxyAgent.code &amp; '  ' &amp; err.text, false);
				errorStore.add(err);
			endforeach;
			// clear errors from logic so that any successful updates will still be done but stop on any exception
			foreach err in thePassport.allErrors do
				if err.errorCode &lt; app.baseErrorNum then
					count := 0;
					hadException := true;
					break;
				endif;
				err.removeFromPassport;
			endforeach;
		endif;
		if hadException then
			break;
		endif;
	endforeach;
	
	self.trxWriteToLogFile(_file.fileName, noLines, count, thePassport, errorStore);
	
epilog
	if proxyArray &lt;&gt; null then
		proxyArray.purge;
		delete proxyArray;
	endif;
	_file.close;
	delete xmlDocumentParser;
	delete xmlDocument;
	self.finaliseActivityWithPassport(thePassport);
	delete errorStore;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxImportStorageConfig" id="a5c1832a-1664-4d3c-9b30-00e7af120134">
        <updating/>
        <source>trxImportStorageConfig(_file : File; _term : CM_Terminal;_realConfig : CM_StorageConfig output) : Integer updating;
/*
Purpose:			
Date				Who			Reason
JULY 2017		CNWAB1		Initial creation
*/
vars
	realConfig : CM_StorageConfig;
	count, numLines : Integer;
	errorStore : CM_ErrorSet;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(app.myPassport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, app.myPassport);
	on LockException do agtPassportLockExHandler(exception, app.myPassport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	
	create errorStore transient;
	
	count := app.myUtilityCA.utlCreateImportStorageConfig(_file, _term, app.myPassport,_realConfig, errorStore, numLines);

	self.trxWriteToLogFile2(_file.fileName,numLines, count, errorStore);
	
	return count;
	
epilog
	errorStore.purge;
	delete errorStore;

	self.finaliseActivityWithPassport(app.myPassport);
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_realConfig" type="CM_StorageConfig" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxImportSurchargesFromFile" id="44582014-251d-4e30-bbd6-56931252cae6">
        <updating/>
        <source>trxImportSurchargesFromFile( _file : File; _bank : CM_Bank; _passport : CM_Passport input ) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 December 2018	jlgndl1	Initial creation	TFS 42061

*/

vars

	xmlDocumentParser : JadeXMLDocumentParser;
	rootElement : JadeXMLElement;
	xmlDocument : JadeXMLDocument;
	count : Integer;
	allNewProxys : CM_InvTypeSurchargeExemptSet;
	realInvType : CM_InvoiceDesc;
	newProxy : CM_InvoiceTypeSurchargeExempt;
	
	invTypeElements : JadeXMLElementArray;
	element : JadeXMLElement;
	allDebtors : CM_DebtorByNameDict;

begin

	_passport.setMyTerminal(_bank.terminal);

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	app.setContinueCMExceptions(true);
	
	if not _file.tryOpen() then
		app.raiseCMException(VB_FILE_ERROR, app.getErrorString(File_open), null);	
		return 0;
	endif;
	
	create allNewProxys transient;
	create xmlDocumentParser transient;
	create xmlDocument transient;
	create invTypeElements transient;
	create allDebtors transient;
	create allNewProxys transient;
	
	xmlDocumentParser.parseDocumentFile(xmlDocument,_file.fileName);
	rootElement := xmlDocument.rootElement;
	
	rootElement.getAllElementsByTagName("invType", invTypeElements );
	
	CM_Debtor.instances.copy( allDebtors );
	CM_VoidDebtor.instances.copy( allDebtors );
	
	//This an all or nothing process...
	//This load finds the CM_InvoiceDesc, and completely replaces the 'mySurchargeAndExemptions', so
	//before we do this for any of the items, lets check that ALL of the data we expect to link up 
	//already exists.
	foreach element in invTypeElements do
		app.myValCA.valImportSurchargesXML( _bank, element, allDebtors, allNewProxys, _passport );
	endforeach;
	
	if _passport.hasErrors then
		self.trxWriteToLogFile2(_file.fileName, invTypeElements.size, 0, _passport.allErrorWarnings);	//17 Dec 2018 NDL
		return 0;
	endif;
	app.setContinueCMExceptions(false);
	
	// If we got this far, all of the data we need apparently exists, so we will have a go at
	// clearing any existing data and creating the surcharge structure for the line types in the file.
	
	
	// Start the transaction
	beginTransaction;
	
	foreach newProxy in allNewProxys do	
		realInvType := newProxy.myInvoiceType;
		if realInvType = null then
			return 0;
		endif;
		app.myUtilityCA.utlImportSurcharges( realInvType, newProxy, _passport );
		if _passport.hasErrors then
			return 0;
		endif;
		count := count + 1;
	endforeach;
	
	self.trxWriteToLogFile2(_file.fileName, invTypeElements.size, count, null);	//17 Dec 2018 NDL
	
	return count;
	
epilog

	if allNewProxys &lt;&gt; null then
		allNewProxys.purge;
		delete allNewProxys;
	endif;
	_file.close;
	delete xmlDocumentParser;
	delete xmlDocument;
	delete invTypeElements;
	delete allDebtors;
	
	self.finaliseActivityWithPassport( _passport );

end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxImportTempConvsFromFile" id="d0cb8ded-b72c-4acb-b7fb-aa0352d23331">
        <updating/>
        <source>trxImportTempConvsFromFile( _file : File; _passport : CM_Passport input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2014	cnwmc5	Initial creation	PAR 34156
*/
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	count				: Integer;
	numConvs			: Integer;
	noLines				: Integer;
	fieldNo				: Integer;
	fieldValue			: String;
	fileLine			: String;
	fieldArray			: CnStringArray;
	thePassport			: CM_Passport;
	err					: CM_Error;
	errorStore			: CM_ErrorSet;

	newTempConv			: CM_TemperatureConversion;
	currentTempConv		: CM_TemperatureConversion;
	pxyTempConv			: CM_TemperatureConversion;
	tempConvDict		: CM_TempConvByCelsiusDict;
	theRoot				: CM_Root;
	
	celsius				: Real;
	fahren				: Real;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	thePassport := _passport;
	theRoot 	:= app.myRoot;

	// Always initialize the activity first
	self.initialiseActivityWithPassport(thePassport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, thePassport);
	on LockException do agtPassportLockExHandler(exception, thePassport);

	app.setContinueCMExceptions(false);
	
	if not _file.tryOpen() then
		app.raiseCMException(VB_FILE_ERROR, app.getErrorString(File_open), null);	
		return;
	endif;
	
	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	create tempConvDict transient;
	create fieldArray transient;
	create errorStore transient;
	
	//ignore first line
	fileLine 	:= _file.readLine();
	noLines		:= 1;
	
	while not _file.endOfFile() do
		fileLine 	:= _file.readLine;
		noLines		:= noLines + 1;
		if fileLine = null then
			continue;
		endif;
		
		fieldArray.clear();
		fileLine.csvToStringArray(fieldArray, ",");
		
		if fieldArray.isEmpty then
			continue;
		endif;
		celsius	:= null;
		fahren	:= null;
		
		/*
		The import layout for this table is exactly (or similar) to the column organiser "JMT Default".
		This is what has been supplied to Messina in document CCMS MES 1008, 1010 Interfaces Messages,
		also see the JMT User Guide section for System Codes Reference.
		*/
		fieldNo	:=	0;
		
		foreach fieldValue in fieldArray do
			fieldNo	:=	fieldNo + 1;
			
			if fieldNo = 1 then
				celsius	:= fieldValue.trimBlanks().asRealJMT();
			elseif fieldNo = 2 then
				fahren	:= fieldValue.trimBlanks().asRealJMT();
			endif;
		endforeach;
		
		if not tempConvDict.includesKey(celsius) then
			create pxyTempConv transient;
			pxyTempConv.setProxy(	celsius,
									fahren);
			
			tempConvDict.add(pxyTempConv);
		else
			create err transient;
			err.set(0,
					app.getErrorString(Temperature) &amp; ' : ' &amp; app.getErrorString2(Line_duplicate_file, noLines.String, app.getErrorString(Temperature)) &amp; celsius.String,
					false,
					'',
					null,
					null);
			errorStore.add(err);
		endif;
	endwhile;
	
	if thePassport.myCMIFMonitor &lt;&gt; null then
		thePassport.myCMIFMonitor.updateProgress(app.getErrorString(Reading_import_file), 10, 10);
	endif;
	
	if thePassport.hasErrors() then
		return;
	endif;
	
	count		:=	0;
	numConvs	:=	tempConvDict.size();
	
	// Start the transaction
	beginTransaction;
	
	// Perform the operation
	foreach pxyTempConv in tempConvDict do
		count := count + 1;
		
		progressInt := app.actualTimeServer() - progressTS;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if thePassport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (count = numConvs)) then
			thePassport.myCMIFMonitor.updateProgress(app.getErrorString1(Creating_msg, app.getErrorString(Temperature)), numConvs, count);
			progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		currentTempConv := theRoot.allTempsCelsius[pxyTempConv.celsius];
		
		if currentTempConv = null then
			app.myUtilityCA.utlCreateTemperatureConversion(pxyTempConv, newTempConv, thePassport);
		else
			app.myProxyManager.createProxyLink(currentTempConv, pxyTempConv);
			app.myUtilityUA.utlUpdateTemperatureConversion(pxyTempConv, thePassport);
		endif;
		
		if thePassport.hasErrors() then
			foreach err in thePassport.allErrors do
				err.setErrorText(app.getErrorString(Temperature) &amp; ' : ' &amp; pxyTempConv.celsius.String &amp; '  ' &amp; err.text, false);
				errorStore.add(err);
			endforeach;
			
			foreach err in thePassport.allErrors do
				err.removeFromPassport();
			endforeach;
		endif;
	endforeach;
	
	trxWriteToLogFile(_file.fileName, noLines, count, thePassport, errorStore);
	
epilog
	delete pxyTempConv;
	if tempConvDict &lt;&gt; null then
		tempConvDict.purge();
		delete tempConvDict;
	endif;
	
	delete fieldArray;
	_file.close();
	self.finaliseActivityWithPassport(thePassport);
	delete errorStore;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxImportUNDGCodesFromCSVFile" id="fd42f254-a3b9-4ed2-8e54-3486db8c99d6">
        <updating/>
        <source>trxImportUNDGCodesFromCSVFile(_file : File; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/04/2013	cnwer1	Initial creation CCMS DPH 2280
30/07/2015	cnwdap1	PAR #36421 Hazardous Materials Handling - remove Symbols, add Secondary Hazard Classes

08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
07/11/2016	cnwdap1	TFS 2841 STWR Hazardous Details Enhancements
12 Nov 2024 navsck1 MTN-3316 CUX - Import Dangerous Goods CSV fails
*/
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	obj  	: Object;
	property: Property;
	propertyArray : ObjectArray;
	fileLine			: String;
	entDef 		: EntTableDef;
	entRow 		: EntTableRow;
	fieldArray			: CnStringArray;
	fieldNo, numCodes, count : Integer;
	fieldValue			: String;
	pxyDG	, currentDG , newDG		 : CM_UNDangerousGoods;
	allPxyDGs		: CM_UNDGByCodeDict;
	//symbols				: String;							// PAR #36421
	secondaryClasses		: String;							// PAR #36421
	secondaryClassArray		: StringArray;						// PAR #36421
	secondaryArray			: CM_StringArray;					// PAR #36421
	secondary				: String;							// PAR #36421
	emergency				: String;
	marinePollutant		: String;
	additionalDesc			: String;
	class 				: CM_HazardClass;
	code,
	desc,
	packing, 
	doNotUse : String;
	i 	: Integer;
	grpArray		: StringArray;
	err					: CM_Error;
	errorStore			: CM_ErrorSet;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
	isMarinePoll : Integer;						// TFS 2841
	isMarinPollMand : Boolean;					// TFS 2841
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	if not _file.tryOpen() then
		app.raiseCMException(VB_FILE_ERROR, "file open", null);	
		return;
	endif;
	
	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	entDef:= app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_UNDGCodeMaint);
	create fieldArray transient;
	create propertyArray transient;
	create grpArray transient;
	create errorStore transient;
	create secondaryClassArray transient;										// PAR #36421
	create secondaryArray transient;											// PAR #36421
	//read first line get column headings match with object properties
	fileLine 	:= _file.readLine;
	fieldArray.clear();
	fileLine.csvToStringArray(fieldArray, ",");
	fieldNo	:=	0;
	
	foreach fieldValue in fieldArray do
		fieldNo	:=	fieldNo + 1;
		entRow:=entDef.getEntTableRowByHeading(fieldValue.trimBlanks);
		if entRow = null then
			app.raiseCMException2(Unknown_CSV_headings, fieldValue, entDef.allEntTableRows.listString(",", EntTableRow::heading.name),null, null);
			return;
		endif;
		
		if entRow.name  = ETRow_Code then
			propertyArray.add(CM_UNDangerousGoods::code);
		elseif entRow.name = ETRow_NameDesc then
			propertyArray.add(CM_UNDangerousGoods::description);
		elseif entRow.name = ETRow_HazardClass then
			propertyArray.add(CM_UNDangerousGoods::myHazardClass);
		//elseif entRow.name = ETRow_Symbols then							// PAR #36421
		//	propertyArray.add(CM_UNDangerousGoods::symbols);				// PAR #36421
		elseif entRow.name = ETRow_Emergency then
			propertyArray.add(CM_UNDangerousGoods::emergencyNumber);
		elseif entRow.name = ETRow_Additional then
			propertyArray.add(CM_UNDangerousGoods::additionalDesc);
		elseif entRow.name = ETRow_MarinePollutant then
			propertyArray.add(CM_UNDangerousGoods::marinePollutant);
		elseif entRow.name =  ETRow_AllPackingGroups then
			propertyArray.add(CM_UNDangerousGoods::allPackingGroups);
		elseif entRow.name = ETRow_NoLongerUsed then
			propertyArray.add(CM_UNDangerousGoods::noLongerUsed);
		elseif entRow.name = ETRow_SecondaryClasses then					// PAR #36421
			propertyArray.add(CM_UNDangerousGoods::allClassCodes);			// PAR #36421
		elseif entRow.name = ETRow_IsMarinePollutant then							// TFS 2841
			propertyArray.add(CM_UNDangerousGoods::isMarinePollutant);				// TFS 2841
		elseif entRow.name = ETRow_IsMarinePollutantMand then						// TFS 2841
			propertyArray.add(CM_UNDangerousGoods::isMarinePollutantMandatory);		// TFS 2841
		else
			propertyArray.add(null);
		endif;
		
	endforeach;
	
	// must have atleast code and description
	if not propertyArray.includes(CM_UNDangerousGoods::code) then
		//required field
		app.raiseCMException1(Column_required_file,"Code",null,null); 
		return;
	endif;
	
	// must have atleast code and description
	if not propertyArray.includes(CM_UNDangerousGoods::description) then
		//required field
		app.raiseCMException1(Column_required_file,"Name &amp; Description",null,null); 
		return;
	endif;
	
	create allPxyDGs transient;
	while not _file.endOfFile() do
		fileLine 	:= _file.readLine;
		if fileLine = null then
			continue;
		endif;
		fieldArray.clear();
		fileLine.csvToStringArray(fieldArray, ",");
		
		if fieldArray.size &lt;&gt; propertyArray.size then														// 12/11/2024 navsck1 #MTN-33163
			app.raiseCMException(VB_FILE_ERROR, null, null);												// 12/11/2024 navsck1 #MTN-33163
			return;																							// 12/11/2024 navsck1 #MTN-33163
		endif;																								// 12/11/2024 navsck1 #MTN-33163
		
		code:=null;
		desc:=null;
		class:=null;
		packing:=null;
		doNotUse:=null;
		marinePollutant:=null;
		isMarinePoll := null;				// TFS 2841
		isMarinPollMand := null;			// TFS 2841
		emergency:=null;
		additionalDesc:=null;
		//symbols :=null;									// PAR #36421
		secondaryClasses := null;							// PAR #36421
		secondaryClassArray.clear;							// PAR #36421
		grpArray.clear;
		
		i:=1;
		foreach obj in propertyArray do
			property:=obj.Property;
			fieldValue:=fieldArray[i];
			if fieldValue &lt;&gt; null then
				if property = CM_UNDangerousGoods::code then
					code:=fieldValue;
				elseif property =CM_UNDangerousGoods::description then
					desc:=fieldValue;
				elseif property = CM_UNDangerousGoods::myHazardClass then
					class:=app.myRoot.allHazardClasses[fieldValue];
				elseif property = CM_UNDangerousGoods::allPackingGroups then
					packing :=fieldValue;
					packing.asStringArrayByDelimiter(grpArray, ",");
				elseif property = CM_UNDangerousGoods::marinePollutant then
					marinePollutant:=fieldValue;
				elseif  property = CM_UNDangerousGoods::emergencyNumber then
					emergency:=fieldValue;
				elseif  property = CM_UNDangerousGoods::additionalDesc then
					additionalDesc := fieldValue;
				//elseif property = CM_UNDangerousGoods::symbols then						// PAR #36421
				//	symbols:=fieldValue;													// PAR #36421
				elseif property = CM_UNDangerousGoods::allClassCodes then					// PAR #36421
					secondaryClasses := fieldValue;											// PAR #36421
					secondaryClasses.convertToDelimitedArray(Comma, secondaryClassArray);	// PAR #36421
				elseif property = CM_UNDangerousGoods::isMarinePollutant then					// TFS 2841
					if fieldValue.toUpper.isOneOf("1", "Y", "YES", "TRUE") then					// TFS 2841
						isMarinePoll := MarinePollutant_Yes;									// TFS 2841
					elseif fieldValue.toUpper.isOneOf("0", "N", "NO", "FALSE") then				// TFS 2841
						isMarinePoll := MarinePollutant_No;										// TFS 2841
					else																		// TFS 2841
						isMarinePoll := MarinePollutant_Null;									// TFS 2841
					endif;																		// TFS 2841
				elseif property = CM_UNDangerousGoods::isMarinePollutantMandatory then			// TFS 2841
					isMarinPollMand := fieldValue.toUpper.isOneOf("1", "Y", "YES", "TRUE");		// TFS 2841
				elseif property = CM_UNDangerousGoods::noLongerUsed then
					doNotUse:=fieldValue;
				endif;
			endif;
			i:=i+1;
		endforeach;
		
		//epr par 33153
		if code.isInteger and code.Integer &lt; 1000 then
			code:=code.padLeadingZeros(4);
		endif;
		
		if allPxyDGs[code] &lt;&gt; null then
			continue;
		endif;
		
		create pxyDG transient;
		secondaryArray.clear;
		foreach secondary in secondaryClassArray do								// PAR #36421
			secondaryArray.add(secondary);										// PAR #36421
		endforeach;																// PAR #36421
		//pxyDG.setForProxy(code, desc, false, class, grpArray,symbols, emergency, marinePollutant,additionalDesc, doNotUse.Boolean);				// PAR #36421
		//pxyDG.setForProxy(code, desc, false, class, grpArray, null, emergency, marinePollutant,additionalDesc, secondaryArray, doNotUse.Boolean);	// PAR #36421					// TFS 2841
		pxyDG.setForProxy(code, desc, false, class, grpArray, null, emergency, marinePollutant, isMarinePoll, isMarinPollMand, additionalDesc, secondaryArray, doNotUse.Boolean);	// TFS 2841
		allPxyDGs.add(pxyDG);
	endwhile;
	
	
	if _passport.myCMIFMonitor &lt;&gt; null then
		_passport.myCMIFMonitor.updateProgress(app.getErrorString(Reading_import_file), 10, 10);
	endif;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	numCodes	:=allPxyDGs.size;
	// Start the transaction
	beginTransaction;
	
	// Perform the operation
	foreach pxyDG in allPxyDGs do
		count := count + 1;
		
		progressInt := app.actualTimeServer() - progressTS;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if _passport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (count = numCodes)) then
			_passport.myCMIFMonitor.updateProgress(app.getErrorString1(Creating_msg, app.getErrorString(Dangerous_goods_codes)), numCodes, count);
			progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
	
		currentDG:= app.myRoot.allUNDangerousGoodsCodes[pxyDG.code];
		if currentDG = null then
			// create 
			app.myUtilityCA.utlCreateUNDGCode(pxyDG,newDG,_passport);
			
		else
			//update 
			app.myProxyManager.createProxyLink(currentDG, pxyDG);
			app.myUtilityUA.utlUpdateUNDGCode(pxyDG,_passport);
		endif;
		
		if _passport.hasErrors() then
			foreach err in _passport.allErrors do
				err.setErrorText(app.getErrorString(Dangerous_goods_codes) &amp; ' : ' &amp; pxyDG.code &amp; '  ' &amp; err.text, false);
				errorStore.add(err);
			endforeach;
			
			foreach err in _passport.allErrors do
				err.removeFromPassport();
			endforeach;
		endif;
		
	endforeach;
	
epilog
	delete fieldArray;
	delete propertyArray;
	delete grpArray;
	if allPxyDGs &lt;&gt; null then
		allPxyDGs.purge;
	endif;
	delete allPxyDGs;
	delete errorStore;
	delete secondaryClassArray;								// PAR #36421
	delete secondaryArray;									// PAR #36421
	self.finaliseActivityWithPassport(_passport);
end;	</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxImportUNDGCodesFromXMLFile" id="2a7165cf-73c1-4490-9a74-cdc6e86f1c21">
        <updating/>
        <source>trxImportUNDGCodesFromXMLFile(_file: File; _passport: CM_Passport input) updating;
/*
File format is

&lt;dangerousGoodsList&gt;

&lt;dangerousGood&gt;
&lt;unCode&gt;0004&lt;/unCode&gt;
&lt;description&gt;AMMONIUM PICRATE dry or wetted with less than 10% water, by mass&lt;/description&gt;
&lt;/dangerousGood&gt;

&lt;dangerousGood&gt;
&lt;unCode&gt;0005&lt;/unCode&gt;
&lt;description&gt;CARTRIDGES FOR WEAPONS with bursting charge&lt;/description&gt;
&lt;/dangerousGood&gt;

&lt;/dangerousGoodsList&gt;

*/
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 07/11/2016	cnwdap1	TFS 2841 STWR Hazardous Details Enhancements
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	count, numCodes,
	posCode			: Integer;
	posCls			: Integer;
	posGrp			: Integer;
	dgCode,
	dgDesc,
	dgCls,
	dgGrp,
	dgXML			: String;
	dgList			: String;
	newUNDGCode,
	pxyUNDGCode		: CM_UNDangerousGoods;
	theFile			: File;
	undgColl		: CM_UNDGByCodeDict;
	clsArray,
	grpArray		: StringArray;
	theRoot			: CM_Root;
	thePassport		: CM_Passport;
	symbols				: String;
	emergency				: String;
	marinePollutant		: String;
	additionalDesc			: String;
	secondaryClasses : CM_StringArray;							// PAR #36421
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	thePassport := _passport;
	theRoot := app.myRoot;

	// Always initialize the activity first
	self.initialiseActivityWithPassport(thePassport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, thePassport);
	on LockException do agtPassportLockExHandler(exception, thePassport);

	app.setContinueCMExceptions(false);
	
	if not _file.tryOpen() then
		app.raiseCMException(VB_FILE_ERROR, "file open", null);	
		return;
	endif;
	
	create clsArray transient;
	create grpArray transient;
	create undgColl transient;
	create secondaryClasses transient;								// PAR #36421
	dgList := _file.readString(_file.fileLength()).cnEcGetTagValueOfName('dangerousGoodsList');
	
	if dgList = null then
		app.raiseCMException1(File_approp_expect_file_open, method.text, null, null);
		return;	
	endif;
	
	numCodes := dgList.length();
	posCode := 1;
	
	while posCode &gt; 0 do
		dgXML := dgList.cnEcGetNextTagValueOfName('dangerousGood', posCode);
		dgCode := dgXML.cnEcGetTagValueOfName('unCode');
		dgDesc := dgXML.cnEcGetTagValueOfName('description');
		
		progressInt := app.actualTimeServer() - progressTS;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if thePassport.myCMIFMonitor &lt;&gt; null and (progressInt.getMilliseconds &gt;= ProgressBarRefresh) then
			thePassport.myCMIFMonitor.updateProgress("Reading import file", numCodes, posCode);
			progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		if dgCode = null then
			continue;
		endif;
		
		//classes
		clsArray.clear();
		posCls := 1;
		
		while posCls &gt; 0 do
			dgCls := dgXML.cnEcGetNextTagValueOfName('class', posCls);
			
			if dgCls &lt;&gt; null then
				clsArray.add(dgCls);
			endif; 
		endwhile;
		
		//packGroups
		grpArray.clear();
		posGrp := 1;
		
		while posGrp &gt; 0 do
			dgGrp := dgXML.cnEcGetNextTagValueOfName('packingGroup', posGrp);
			if dgGrp &lt;&gt; null then
				grpArray.add(dgGrp);
			endif; 
		endwhile;
		
		create pxyUNDGCode transient;
		//pxyUNDGCode.setForProxy(dgCode, dgDesc, false, null, grpArray, symbols,emergency,marinePollutant,additionalDesc,  false);					// PAR #36421
		//pxyUNDGCode.setForProxy(dgCode, dgDesc, false, null, grpArray, symbols,emergency,marinePollutant,additionalDesc, secondaryClasses, false);	// PAR #36421				// TFS 2841
		pxyUNDGCode.setForProxy(dgCode, dgDesc, false, null, grpArray, symbols, emergency, marinePollutant, MarinePollutant_Null, false, additionalDesc, secondaryClasses, false);	// TFS 2841
		undgColl.add(pxyUNDGCode);
	endwhile;
	
	if thePassport.myCMIFMonitor &lt;&gt; null then
		thePassport.myCMIFMonitor.updateProgress("Reading import file", 10, 10);
	endif;
	
	if thePassport.hasErrors() then
		return;
	endif;
	
	count		:=	0;
	numCodes	:=	undgColl.size();
	// Start the transaction
	beginTransaction;
	
	// Perform the operation
	foreach pxyUNDGCode in undgColl do
		count := count + 1;
		if thePassport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (count = numCodes)) then
			thePassport.myCMIFMonitor.updateProgress("Creating UN Codes...", numCodes, count);
			progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		app.myUtilityCA.utlCreateUNDGCode(pxyUNDGCode, newUNDGCode, thePassport);
		
		if thePassport.hasErrors() then
			break;
		endif;
	endforeach;
epilog
	delete clsArray;
	delete grpArray;
	delete secondaryClasses;							// PAR #36421
	
	if undgColl &lt;&gt; null then
		undgColl.purge();
		delete undgColl;
	endif;
	
	_file.close();
	self.finaliseActivityWithPassport(thePassport);
end;</source>
        <text>&lt;dangerousGoodsList&gt;
	&lt;dangerousGood&gt;
	&lt;unCode&gt;0000&lt;/unCode&gt;
	&lt;description&gt;Dangerous Good Name&lt;/description&gt;
	&lt;class&gt;1.1&lt;/class&gt;
	&lt;packingGroup&gt;II&lt;/packingGroup&gt;
	&lt;/dangerousGood&gt;
	...
&lt;/dangerousGoodsList&gt;</text>
        <Parameter name="_file" type="File"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxImportUsersFromFile" id="5601d036-2426-4529-be65-552279328073">
        <updating/>
        <source>trxImportUsersFromFile(_file : File; _passport : CM_Passport input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 September 2025	navlw1	JIRA:35884 - 34574.014 - Provide User Name and Single Sign On Matching ID import functionality 
05 Novemeber 2025	navlw1	JIRA-36369: Add a new status “PENDING” for users and use this status for new imported users

*/
constants
	ProgressBarRefresh	: Integer = 2000;
vars
	count					: Integer;
	numCodes				: Integer;
	noLines					: Integer;
	fieldNo					: Integer;
	fieldValue				: String;
	fileLine				: String;
	fieldArray				: CnStringArray;
	thePassport				: CM_Passport;
	err						: CM_Error;
	errorStore				: CM_ErrorSet;
	userColl				: CM_UserByCodeDict;
	pxyUser,
	realUser,
	theUser					: CM_User;
	theRoot					: CM_DutyDocRoot;
	progressTS 				: TimeStamp;
	progressInt				: TimeStampInterval;
	userCode, userName,
	singleSignMatchId		: String;
	organisation			: CM_Organisation;
	daSet					: CM_DataAccessControllerSet;
	secRoleSystem			: CM_SecurityRoleSystem;
	allEmailAddresses		: CM_EmailEntityByTypeNameDict;
	setState				: Boolean;
begin
	thePassport := _passport;
	theRoot 	:= app.myDutyDocRoot;
	
	// Always initialize the activity first
	self.initialiseActivityWithPassport(thePassport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, thePassport);
	on LockException do agtPassportLockExHandler(exception, thePassport);

	app.setContinueCMExceptions(false);
	
	if not _file.tryOpen() then
		app.raiseCMException(VB_FILE_ERROR, app.getErrorString(File_open), null);	
		return;
	endif;
	
	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	create userColl transient;
	create fieldArray transient;
	create errorStore transient;
	create allEmailAddresses transient;
	
	//ignore first line
	fileLine	:=	_file.readLine();
	noLines		:=	1;
	while not _file.endOfFile() do
		fileLine := _file.readLine;
		noLines	:= noLines + 1;
		
		if fileLine = null then
			continue;
		endif;
		
		fieldArray.clear();
		fileLine.csvToStringArray(fieldArray, ",");
		
		if fieldArray.isEmpty then
			continue;
		endif;
		
		fieldNo :=	0;
		
		foreach fieldValue in fieldArray do
			fieldNo	:=	fieldNo + 1;
			if fieldNo = 1 then
				userCode := fieldValue.trimBlanks().toUpper;
			elseif fieldNo = 2 then
				singleSignMatchId := fieldValue.trimBlanks();
			elseif fieldNo = 3 then
				userName := fieldValue;
			elseif fieldNo = 4 then
				organisation := app.myRoot.allOrganisations[fieldValue];
			elseif fieldNo = 5 then
				secRoleSystem := app.myRoot.allRoles[fieldValue].CM_SecurityRoleSystem;
			endif;
		endforeach;
		
		theUser := app.myRoot.allUsers[userCode];
		if theUser = null then
			// create the user if it does not exist
			create pxyUser transient;
			pxyUser.setProxy(userCode,userName,PendingUser,organisation,app.myRoot,true,false,false,false,null,daSet,secRoleSystem,null,allEmailAddresses,null,null,app.myRoot.getDefaultLocale(true), false, false);
			// sso stuff
			pxyUser.setSSOMatchingId(singleSignMatchId);
			
			if not userColl.includesKey(userCode) then
				userColl.add(pxyUser);
			else
				create err transient;
				err.set(0, app.getErrorString(UserId) &amp; ' : ' &amp; app.getErrorString2(Line_duplicate_file, noLines.String, app.getErrorString(UserId)) &amp; userCode, false, '', pxyUser, null);
				errorStore.add(err);
			endif;
		else
			app.cmsBeginLoad(setState);
			pxyUser := theUser.pxyCreateUpdateProxy;
			app.cmsEndLoad(setState);
			
			// sso stuff
			pxyUser.setSSOMatchingId(singleSignMatchId);
			
			if not userColl.includesKey(userCode) then
				userColl.add(pxyUser);
			else
				create err transient;
				err.set(0, app.getErrorString(UserId) &amp; ' : ' &amp; app.getErrorString2(Line_duplicate_file, noLines.String, app.getErrorString(UserId)) &amp; theUser.code, false, '', pxyUser, null);
				errorStore.add(err);
			endif;
		endif;
	endwhile;
	
	count		:=	0;
	numCodes	:=	userColl.size();
	
	if thePassport.myCMIFMonitor &lt;&gt; null then
		thePassport.myCMIFMonitor.updateProgress(app.getErrorString(Reading_import_file), 10, 10);
	endif;
	
	// Start the transaction
	beginTransaction;
	
	// Perform the operation
	foreach pxyUser in userColl do
		count := count + 1;
		progressInt := app.actualTimeServer() - progressTS;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		
		if thePassport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (count = numCodes)) then
			thePassport.myCMIFMonitor.updateProgress(app.getErrorString1(Creating_msg, app.getErrorString(UserId)), numCodes, count);
			progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		theUser := app.myRoot.allUsers[pxyUser.code];
		if theUser = null then
			app.myUtilityCA.utlCreateUser(pxyUser, null, realUser, app.myPassport); // 
		else
			app.myUtilityUA.utlUpdateUser(pxyUser, null, app.myPassport);
		endif;
		if thePassport.hasErrors() then
			foreach err in thePassport.allErrors do
				err.setErrorText(app.getErrorString(UserId) &amp; ' : ' &amp; pxyUser.code &amp; '  ' &amp; err.text, false);
				errorStore.addNoDuplicates(err, false);
			endforeach;
			foreach err in thePassport.allErrors do
				err.removeFromPassport;
			endforeach;
		endif;
	endforeach;
	
	trxWriteToLogFile(_file.fileName, noLines, count, thePassport, errorStore);
epilog
	if userColl &lt;&gt; null then
		userColl.purge();
		delete userColl;
	endif;
	_file.close();
	delete fieldArray;
	delete allEmailAddresses;
	delete errorStore;
	self.finaliseActivityWithPassport(thePassport);
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxImportVehicleColoursFromFil" id="619ed1e2-5aa3-4a2c-a47d-e311e8981378">
        <updating/>
        <source>trxImportVehicleColoursFromFil( _file : File; _passport : CM_Passport input ) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/01/2013	cnwmc5	Initial creation HAT 2189
21/08/2013	cnwdap1	PAR #32303 Ensure colour is upper case
*/
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 02 Jul 2018	jlgmd1	TFS 39058 - 1035 String to long
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	count				: Integer;
	numCodes			: Integer;
	noLines				: Integer;
	fieldNo				: Integer;
	fieldValue			: String;
	fileLine			: String;
	fieldArray			: CnStringArray;
	thePassport			: CM_Passport;
	err					: CM_Error;
	errorStore			: CM_ErrorSet;

	newVehicleColour	: CM_VehicleColour;
	currentVehicleColour: CM_VehicleColour;
	pxyVehicleColour	: CM_VehicleColour;
	vehicleColourColl	: CM_VehicleColourByColour;
	theRoot				: CM_DutyDocRoot;
	colour				: String;
	progressInt			: TimeStampInterval;
	progressTS 			: TimeStamp;
begin
	thePassport := _passport;
	theRoot 	:= app.myDutyDocRoot;

	// Always initialize the activity first
	self.initialiseActivityWithPassport(thePassport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, thePassport);
	on LockException do agtPassportLockExHandler(exception, thePassport);

	app.setContinueCMExceptions(false);
	
	if not _file.tryOpen() then
		app.raiseCMException(VB_FILE_ERROR, app.getErrorString(File_open), null);	
		return;
	endif;
	
	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	create vehicleColourColl transient;
	create fieldArray transient;
	create errorStore transient;
	
	//ignore first line
	fileLine 	:= _file.readLine();
	noLines		:= 1;
	
	while not _file.endOfFile() do
		fileLine 	:= _file.readLine;
		noLines		:= noLines + 1;
		if fileLine = null then
			continue;
		endif;
		
		fieldArray.clear();
		fileLine.csvToStringArray(fieldArray, ",");
		
		if fieldArray.isEmpty then
			continue;
		endif;
		
		colour := null;
		
		/*
		The import layout for this table is exactly (or similar) to the column organiser "JMT Default".
		This is what has been supplied to Messina in document CCMS MES 1008, 1010 Interfaces Messages,
		also see the JMT User Guide section for System Codes Reference.
		*/
		fieldNo	:=	0;
		
		foreach fieldValue in fieldArray do
			fieldNo	:=	fieldNo + 1;
			
			// cnwrl1 06/07/2010 PAR 24606 - reorder import fields to match "JMT Default"
			if fieldNo = 1 then
				//colour :=	fieldValue.trimBlanks();				// PAR #32303
				colour :=	fieldValue.trimBlanks().toUpper()[1:CM_VehicleColour::colour.length-1];		// PAR #32303
			endif;
		endforeach;
		
		if not vehicleColourColl.includesKey(colour) then
			create pxyVehicleColour transient;
			pxyVehicleColour.setProxy(colour);
			
			vehicleColourColl.add(pxyVehicleColour);
		else
			create err transient;
			err.set(0,
					app.getErrorString(Vehicle_colour) &amp; ' : ' &amp; app.getErrorString2(Line_duplicate_file, noLines.String, app.getErrorString(Vehicle_colour)) &amp; colour.String,
					false,
					'',
					null,
					null);
			errorStore.add(err);
		endif;
	endwhile;
	
	if thePassport.myCMIFMonitor &lt;&gt; null then
		thePassport.myCMIFMonitor.updateProgress(app.getErrorString(Reading_import_file), 10, 10);
	endif;
	
	if thePassport.hasErrors() then
		return;
	endif;
	
	count		:=	0;
	numCodes	:=	vehicleColourColl.size();
	
	// Start the transaction
	beginTransaction;
	
	// Perform the operation
	foreach pxyVehicleColour in vehicleColourColl do
		count := count + 1;
		
		progressInt := app.actualTimeServer() - progressTS;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if thePassport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (count = numCodes)) then
			thePassport.myCMIFMonitor.updateProgress(app.getErrorString1(Creating_msg, app.getErrorString(Vehicle_colour)), numCodes, count);
			progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		currentVehicleColour := theRoot.allVehicleColours[pxyVehicleColour.colour];
		
		if currentVehicleColour = null then
			app.myUtilityCA.utlCreateVehicleColour(pxyVehicleColour, newVehicleColour, thePassport);
		else
			app.myProxyManager.createProxyLink(currentVehicleColour, pxyVehicleColour);
			app.myUtilityUA.utlUpdateVehicleColour(pxyVehicleColour, thePassport);
		endif;
		
		if thePassport.hasErrors() then
			foreach err in thePassport.allErrors do
				err.setErrorText(app.getErrorString(Vehicle_colour) &amp; ' : ' &amp; pxyVehicleColour.colour &amp; '  ' &amp; err.text, false);
				errorStore.add(err);
			endforeach;
			
			foreach err in thePassport.allErrors do
				err.removeFromPassport();
			endforeach;
		endif;
	endforeach;
	
	trxWriteToLogFile(_file.fileName, noLines, count, thePassport, errorStore);
	
epilog
	delete pxyVehicleColour;
	if vehicleColourColl &lt;&gt; null then
		vehicleColourColl.purge();
		delete vehicleColourColl;
	endif;
	
	delete fieldArray;
	_file.close();
	self.finaliseActivityWithPassport(thePassport);
	delete errorStore;
end;
</source>
