<Class name="SHP_BayAreaAboveDeck" id="669fef3a-edfa-47a9-a957-ac366ae7a031">
    <superclass name="SHP_BayArea"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="ship"/>
    <PrimAttribute name="topMarginRows" id="a5e25ba6-a315-4675-99e1-2af57dc1ef2e">
        <embedded/>
        <type name="Integer"/>
        <text>I added this so that some of the smaller on deck frames could have extra blank padding rows at the top of the frame
 to bring the on deck and under deck points closer on screen</text>
    </PrimAttribute>
    <JadeMethod name="drawHLabels" id="2809c615-1885-4f29-ace7-1fba5ed1f8c0">
        <updating/>
        <source>drawHLabels() updating, protected;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aCell : CM_CellDefn;
	aTier : CM_TierDefn;
	offSet : Real;
	aColumn : CMUI_GridColumn; //SHP_BayColumn;
	gridFrame	: CMUI_Frame;
	
	theRowHeight,
	theColWidth : Real;
	theLabel : String;
begin
	return;
	theRowHeight := RowHeight *  self.scaleYFactor;
	theColWidth	 := ColWidth * self.scaleXFactor;

	gridFrame := self.myHLabelsFrame;
	gridFrame.autoRedraw := true;
	gridFrame.visible := true;
	if gridFrame &lt;&gt; null then
		gridFrame.clearGraphics;
		foreach aColumn in self.allGridColumns do
//		foreach aCell in self.myBay.allCellsOnDeckByOrdinal do
//			aCell := aColumn.SHP_BayColumn.myCell;
			theLabel := aColumn.SHP_BayColumn.label;
			offSet := ((aColumn.SHP_BayColumn.allignment  ) * theColWidth) + LeftMargin + 10;
			offSet := offSet - theColWidth;
//			gridFrame.drawTextAt(aCell.id,offSet + 1,11,White);
//			gridFrame.drawTextAt(aCell.id,offSet,10,Black);
			gridFrame.drawTextAt(theLabel,offSet + 1,11,White);
			gridFrame.drawTextAt(theLabel,offSet,10,Black);
		endforeach;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawLidRow" id="8b298b84-f6c9-4886-b37e-c15d12cbf3a5">
        <source>drawLidRow();
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	gridPoint	: CMUI_GridPoint;
	gridFrame	: CMUI_GridAreaFrame;
	aRow : CMUI_GridRow;
begin
	gridFrame := self.myGridAreaFrame;
	if gridFrame &lt;&gt; null then
		aRow := self.allGridRows.last;
		if aRow = null then
			return;
		endif;
		aRow.setYPos(aRow.y1, aRow.y1 + 10);
		foreach gridPoint in aRow.allGridPointsByColumn do
			if SHP_LidPoint.hasInstance(gridPoint) then
				gridPoint.drawSelf(gridFrame);
			endif;
		endforeach;

	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawMinature" id="1a7e9a53-8dbc-4703-8b37-83246e168abe">
        <source>drawMinature(_frame: Frame input; _scale: Integer);
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	OFFSET = 4;
	WIDTH = 35;
	HEIGHT = 25;
	TOOLBAR_OFFSET = 25;
vars
	theX1,theX2,theY1,theY2, offsetY : Integer;
begin
	if self.drawMe = false then
		return;
	endif;
	if self.allGridPoints.isEmpty then
		return;
	endif;

	if _scale &gt; 0 then
		self.getXsYs(theX1,theX2,theY1,theY2);
		theX1 := (theX1 / _scale).Integer;
		theX2 := (theX2 / _scale).Integer;
		theY1 := (theY1 / _scale).Integer;
		theY2 := (theY2 / _scale).Integer;
	else
		theX1 := ((self.column - 1) * WIDTH);
		theX2 := theX1 + WIDTH;
		theY1 := ((self.row - 1) * HEIGHT);
		theY2 := theY1 + HEIGHT;
	endif;
	theX1 := theX1  + OFFSET;
	theX2 := theX2  - OFFSET;
	theY1 := theY1  + OFFSET + TOOLBAR_OFFSET;
	theY2 := theY2  - OFFSET + TOOLBAR_OFFSET;
		
	_frame.drawFillColor := 16764573;
	_frame.drawFilledRectangle(theX1, theY1, theX2, theY2, Blue);
	offsetY := 2;
	_frame.drawFontSize := 8;
	_frame.drawFontName := "Microsoft Sans Serif"; //"Wagon";
	_frame.drawTextAlign := Frame.DrawTextAlign_Center;
	_frame.drawTextAt(self.label,((theX2 - theX1) / 2) + theX1 , theY1 + offsetY,Black);
end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_scale" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawSpecialAfter" id="86109f40-4242-4be0-96fc-fb50859c35f3">
        <source>drawSpecialAfter();
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	offSet, rowOffset : Real;
	aColumn : CMUI_GridColumn;
	lastRow, aRow : CMUI_GridRow;
	theRowHeight,
	theColWidth, theScaleFactor : Real;
	firstPoint, lastPoint : CMUI_GridPoint;
	theY,theX,theMiddleX, theSpaceX,theSpaceY  : Integer;
	theLabel : String;
	theFrame : CMUI_GridAreaFrame;
	amPrinting,largeOutput,mediumOutput, smallOutput : Boolean;
begin
	if self.allGridPoints.isEmpty then
		return;
	endif;

	if self.allGridRows.size = 1 then
		return;
	endif;
	amPrinting := self.amPrinting;
	
	theScaleFactor := self.scaleYFactor;
	theFrame := self.myGridAreaFrame;
	largeOutput := (amPrinting and theScaleFactor = self.PrintScaleLarge);
	mediumOutput := (amPrinting and theScaleFactor = self.PrintScaleMedium);
	smallOutput := (amPrinting and theScaleFactor = self.PrintScaleSmall);
	
	if largeOutput then
		theRowHeight := self.PrintScaleLargeHeight;
		theColWidth	 := self.PrintScaleLargeWidth;
	else
	
		theRowHeight := RowHeight *  theScaleFactor;
		theColWidth	 := ColWidth * theScaleFactor;
	endif;
	self.myGridAreaFrame.setDefaultFont();
	
	if amPrinting then
		if  theScaleFactor = self.PrintScaleSmall then
			theSpaceX := 0;
		elseif  theScaleFactor = self.PrintScaleLarge then
			theSpaceX := 15;
		else
			theSpaceX := 5;
		endif;
		theSpaceY := self.getTopMargin();
		if  theScaleFactor = self.PrintScaleLarge then
			theSpaceY := theSpaceY + 10;
		endif;
	elseif theScaleFactor = 1 then
		theSpaceX := 0;
		theSpaceY := TopMargin ;
	elseif theScaleFactor = 1.5 then
		theSpaceX := 0;
		theSpaceY := TopMargin + 3;
	elseif theScaleFactor = 2 then
		theSpaceX := 5;
		theSpaceY := TopMargin + 6;
	elseif theScaleFactor = 3 then
		theSpaceX := 5;
		theSpaceY := TopMargin + 9;
	elseif theScaleFactor = 4 then
		theSpaceX := 10;
		theSpaceY := TopMargin + 12;
	elseif theScaleFactor = 6 then
		theSpaceX := 20;
		theSpaceY := TopMargin + 20;
	elseif theScaleFactor = 9 then
		theSpaceX := 35;
		theSpaceY := TopMargin + 40;
	endif;
	
	// try to work out the middle of our column
	firstPoint := self.allGridPoints.first; 
	lastPoint := self.allGridPoints.last; 
	// we want the last bay point, not the lid point.
	// the lid points are drawn down low to allow us to draw the pile weights
	// note if there is only 1 row on deck it is for the hatch lid row and it means that there are not ONDECK slots
	if lastPoint.isKindOf(SHP_LidPoint) and self.allGridRows.size &gt; 1 then
		//epr par 29558 14/5/12
		lastRow:=self.allGridRows.getAtKeyLeq(lastPoint.myGridRow.row - 1);
		//epr par 34819 1/9/14
		if lastRow.allGridPointsByColumn.size &gt; 0 then
			lastPoint := lastRow.allGridPointsByColumn.last; 
		endif;
	endif;

	theMiddleX := (firstPoint.x1 + (lastPoint.x2 - firstPoint.x1) / 2).Integer;
	theY := (firstPoint.y1 - TopMargin).Integer;
	
	theX := (self.width / 2).Integer + 30;
	theX := theMiddleX + 35;
	
	self.drawSpecialAfterBayId(theX,theY,true);

	theY := (firstPoint.y1 - 15).Integer;
	
	// do not print this stuff on the small print
	if theScaleFactor &gt; 1 and not smallOutput then
		// draw the column labels
		foreach aColumn in self.allGridColumns do
			theLabel := aColumn.SHP_BayColumn.label;
			offSet := ((aColumn.SHP_BayColumn.allignment ) * theColWidth) + LeftMargin + theSpaceX;
			offSet := offSet - theColWidth;
			self.myGridAreaFrame.drawTextAt(theLabel,offSet,theY,Black);

			if self.displayMode &lt;&gt; ShpDisplayMode_Defn 
			and not mediumOutput then 
				aColumn.SHP_BayColumn.drawPileWeight(self.myGridAreaFrame,theScaleFactor,false);
			endif;
		endforeach;
	
	
		offSet := theSpaceY;
		rowOffset := firstPoint.x1 - LeftMargin + 1;
		
		// Draw the row labels	
		foreach aRow in self.allGridRows do
			if aRow.label = "ZZ" then //  hatch lids
				continue;
			endif;
			theLabel := aRow.label;
			self.myGridAreaFrame.drawTextAt(theLabel,rowOffset,offSet,Black);

			if self.displayMode &lt;&gt; ShpDisplayMode_Defn 
			and not mediumOutput then 
				aRow.SHP_BayRow.drawTierWeight(self.myGridAreaFrame,theScaleFactor,false);
			endif;
			offSet := offSet + theRowHeight;
		endforeach;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getTopMargin" id="538dd96e-f787-400f-ac45-123de9c49508">
        <source>getTopMargin(): Integer;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theTopMargin : Integer;
begin
	if self.amPrinting then
		if self.scaleYFactor = self.PrintScaleSmall then
			theTopMargin := 2; // no bay id and no cell ids
		else
			theTopMargin := 15; // no bay id but has cell ids
		endif;
	elseif self.scaleYFactor = 1 then	
		theTopMargin := 25;
	else
		theTopMargin := TopMargin;
	endif;

	return theTopMargin;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="0a1f9c90-da03-472f-a4eb-ce720872e86c">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>setForCreate(_theBayDefn : CM_Bay; _theColumn : Integer; _theRow : Integer; _theMode : Integer) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	aBayRow		: SHP_BayRow;
	aBayCol		: SHP_BayColumn;
	aBayPoint		: SHP_BayPoint;
	aSlotC : CM_SlotController;
	aGridCol : CMUI_GridColumn;
	aCell : CM_CellDefn;
	aTier : CM_TierDefn;
	aSlot : CM_SlotDefn;
	aLidPoint : SHP_LidPoint;
	theXML : String;
	aLid : CM_HatchLid;
	cellODStart, cellUDStart,cellODEnd,cellUDEnd :	SHP_BayColumn;
	thePointsOD, thePointsUD : CMUI_GridPointsByColumnDict;
	ordinalODStartCell, ordinalODEndCell, ordinalUDStartCell, ordinalUDEndCell : Integer;
	startsMidCell, endsMidCell : Boolean;
	theLidTier : Integer;
	loadState : Boolean;
	theColumnOrdinal, theRowOrdinal : Integer;
begin

	if _theBayDefn = null then
		return;
	endif;

	if _theMode = ShpDisplayMode_GetAll then
		foreach aSlot in _theBayDefn.allSlotsOnDeck do
			// the ordinals for tiers are upside down, as far as the grid controll is concerned, so this flips the ordinal
			theRowOrdinal := _theBayDefn.allTiersOnDeck.size - (aSlot.ordinalTier - 1);
			// the ordinals for cells are NOT upside down
			theColumnOrdinal := aSlot.ordinalCell;
	
			aBayPoint := self.allGridPoints[theRowOrdinal,theColumnOrdinal].SHP_BayPoint;
			if aBayPoint &lt;&gt; null then
				aSlotC := aSlot.CM_SlotDefnVoyage.mySlotController;
				aBayPoint.setForCreateController(theColumnOrdinal, theRowOrdinal,aSlotC , self);
			endif;
		endforeach;
		return;
	endif;

	app.cmsBeginLoad(loadState);
	
	self.label := _theBayDefn.id;
	self.column := _theColumn;
	self.row := _theRow;
	self.displayMode := _theMode;
	self.myBay := _theBayDefn;
	self.drawMe := true;
	
	
	// nothing to draw if there are no slots!!!
	if _theBayDefn.allSlotsOnDeck.size = 0 then
		if _theBayDefn.allSlotsUnderDeck.size = 0 then
			return;
		endif;
		// if no ON deck use under deck to create a row so that they can draw hatch lids
		foreach aCell in _theBayDefn.allCellsUnderDeckByOrdinal do
			create aBayCol transient;
			aBayCol.setForCreate(aCell.id,aCell.ordinal, self,aCell.alignment,aCell);
		endforeach;
	else
	
	
		foreach aCell in _theBayDefn.allCellsOnDeckByOrdinal do
			create aBayCol transient;
			aBayCol.setForCreate(aCell.id,aCell.ordinal, self,aCell.alignment,aCell);
		endforeach;
		foreach aTier in _theBayDefn.allTiersOnDeck reversed do
			create aBayRow transient;
			theRowOrdinal := _theBayDefn.allTiersOnDeck.size - (aTier.ordinal - 1);
			aBayRow.setForCreate(aTier.id,theRowOrdinal, self);
		endforeach;
	endif;
	// this row is used for the hatch lids
	theLidTier := _theBayDefn.allTiersOnDeck.size + 1;
	create aBayRow transient;
	aBayRow.setForCreate("ZZ",theLidTier, self);
	aBayRow.setYPos(aBayRow.y1, aBayRow.y1 + 20);
	// for drawing a hatch lid create a point above each column in the grid and attach the lid to each of them
	// that way on the click on the lid we know what object to look at.
	// NOTE points get their X and Y from the column and row that they are referencing - the X and Y's  are virtual
	// A point cannot span multiple columns or rows, so create lots of points all looking at the same thing, in this case a lid

	foreach aLid in _theBayDefn.allHatchLids do
/*	
		theXML := aLid.getGridDefinitionXML();
		ordinalODStartCell :=  theXML.cnEcGetTagValueOfName("ODS").Integer;
		ordinalODEndCell :=  theXML.cnEcGetTagValueOfName("ODE").Integer;
		startsMidCell  :=  theXML.cnEcGetTagValueOfName("SMC").Integer.Boolean;
		endsMidCell  :=  theXML.cnEcGetTagValueOfName("EMC").Integer.Boolean;

		cellODStart := self.allGridColumns[ordinalODStartCell].SHP_BayColumn;
		cellODEnd := self.allGridColumns[ordinalODEndCell].SHP_BayColumn;
		cellUDStart := null;
		cellUDEnd := null;
*/

		ordinalODStartCell := aLid.ordinalODStartCell;
		ordinalODEndCell := aLid.ordinalODEndCell;
		ordinalUDStartCell := aLid.ordinalUDStartCell;
		ordinalUDEndCell := aLid.ordinalUDEndCell;
		startsMidCell := aLid.startsMidCell;
		endsMidCell := aLid.endsMidCell;
		cellODStart := self.allGridColumns[ordinalODStartCell].SHP_BayColumn;
		cellODEnd := self.allGridColumns[ordinalODEndCell].SHP_BayColumn;
		if cellODStart = null then
			cellODStart := self.allGridColumns[ordinalUDStartCell].SHP_BayColumn;
			ordinalODStartCell := ordinalUDStartCell;
		endif;
		if cellODEnd = null then
			cellODEnd := self.allGridColumns[ordinalUDEndCell].SHP_BayColumn;
			ordinalODEndCell := ordinalUDEndCell;
		endif;
		foreach aGridCol in self.allGridColumns do
		
			if aGridCol.column &gt;= ordinalODStartCell and aGridCol.column &lt;= ordinalODEndCell then
				if aGridCol.allGridPointsByRow[theLidTier] = null then
					create aLidPoint transient;
					aLidPoint.setForCreate( aGridCol.column,theLidTier,self, cellODStart, cellODEnd,cellUDStart,cellUDEnd ,startsMidCell, endsMidCell,aLid,aGridCol);
				endif;
			endif;
		endforeach;

	endforeach;
	
	foreach aSlot in _theBayDefn.allSlotsOnDeck do
		// the ordinals for tiers are upside down, as far as the grid controll is concerned, so this flips the ordinal
		theRowOrdinal := _theBayDefn.allTiersOnDeck.size - (aSlot.ordinalTier - 1);
		// the ordinals for cells are NOT upside down
		theColumnOrdinal := aSlot.ordinalCell;

		create aBayPoint transient;
		if self.displayMode = ShpDisplayMode_Defn then
			aBayPoint.setForCreate(theColumnOrdinal, theRowOrdinal,null , self,aSlot,true);
		elseif self.displayMode = ShpDisplayMode_GetAll then
			aSlotC := aSlot.CM_SlotDefnVoyage.mySlotController;
			aBayPoint.setForCreateController(theColumnOrdinal, theRowOrdinal,aSlotC , self);
		else
			aBayPoint.setForCreateEmpty(theColumnOrdinal, theRowOrdinal, self);
		endif;
	endforeach;
epilog
	app.cmsEndLoad(loadState);

end;</source>
        <Parameter name="_theBayDefn" type="CM_Bay"/>
        <Parameter name="_theColumn" type="Integer"/>
        <Parameter name="_theRow" type="Integer"/>
        <Parameter name="_theMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreateController" id="1deb4b8f-16aa-4d9a-af1c-620b26ca0052">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>setForCreateController(_theBay : CM_BayVoyage; _theColumn : Integer; _theRow : Integer; _theMode : Integer) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aBayRow		: SHP_BayRow;
	aBayCol		: SHP_BayColumn;
	aBayPoint		: SHP_BayPoint;
	aSlotC : CM_SlotController;
	aGridCol : CMUI_GridColumn;
	aCell : CM_CellDefn;
	aTier : CM_TierDefn;
	aSlot : CM_SlotDefn;
	aLidPoint : SHP_LidPoint;
	theXML : String;
	aLid : CM_HatchLid;
	cellODStart, cellUDStart,cellODEnd,cellUDEnd :	SHP_BayColumn;
	thePointsOD, thePointsUD : CMUI_GridPointsByColumnDict;
	ordinalODStartCell, ordinalODEndCell : Integer;
	startsMidCell, endsMidCell : Boolean;
	theLidTier : Integer;
	loadState : Boolean;
	theColumnOrdinal, theRowOrdinal : Integer;
	isAft : Boolean; 
	isFwd : Boolean; 
	bayType : Integer; 
	theBay : CM_BayVoyage;
	bayFwdID,bayAftID : String;
begin
	theBay := _theBay;
	if theBay = null then
		return;
	endif;
	isAft := theBay.isAftBay;
	isFwd := not isAft;
	bayType := theBay.bayType;
	bayFwdID := theBay.id;
	bayAftID := theBay.idBay40;

	self.label := theBay.id;
	self.column := _theColumn;
	self.row := _theRow;
	self.displayMode := _theMode;
	self.myBay := theBay;
	self.drawMe := true;
	
	
	// nothing to draw if there are no slots!!!
	if theBay.allSlotsOnDeck.size = 0 then
		if theBay.allSlotsUnderDeck.size = 0 then
			return;
		endif;
		// if no ON deck use under deck to create a row so that they can draw hatch lids
		foreach aCell in theBay.allCellsUnderDeckByOrdinal do
			create aBayCol transient;
			aBayCol.setForCreate(aCell.id,aCell.ordinal, self,aCell.alignment,aCell);
		endforeach;
	else
	
	
		foreach aCell in theBay.allCellsOnDeckByOrdinal do
			create aBayCol transient;
			aBayCol.setForCreate(aCell.id,aCell.ordinal, self,aCell.alignment,aCell);
		endforeach;
		foreach aTier in theBay.allTiersOnDeck reversed do
			create aBayRow transient;
			theRowOrdinal := theBay.allTiersOnDeck.size - (aTier.ordinal - 1);
			aBayRow.setForCreate(aTier.id,theRowOrdinal, self);
		endforeach;
	endif;
	// this row is used for the hatch lids
	theLidTier := theBay.allTiersOnDeck.size + 1;
	create aBayRow transient;
	aBayRow.setForCreate("ZZ",theLidTier, self);
	aBayRow.setYPos(aBayRow.y1, aBayRow.y1 + 20);
	// for drawing a hatch lid create a point above each column in the grid and attach the lid to each of them
	// that way on the click on the lid we know what object to look at.
	// NOTE points get their X and Y from the column and row that they are referencing - the X and Y's  are virtual
	// A point cannot span multiple columns or rows, so create lots of points all looking at the same thing, in this case a lid

	foreach aLid in theBay.allHatchLids do
	
		theXML := aLid.getGridDefinitionXML();
		ordinalODStartCell :=  theXML.cnEcGetTagValueOfName("ODS").Integer;
		ordinalODEndCell :=  theXML.cnEcGetTagValueOfName("ODE").Integer;
		startsMidCell  :=  theXML.cnEcGetTagValueOfName("SMC").Integer.Boolean;
		endsMidCell  :=  theXML.cnEcGetTagValueOfName("EMC").Integer.Boolean;

		cellODStart := self.allGridColumns[ordinalODStartCell].SHP_BayColumn;
		cellODEnd := self.allGridColumns[ordinalODEndCell].SHP_BayColumn;
		cellUDStart := null;
		cellUDEnd := null;

		foreach aGridCol in self.allGridColumns do
		
			if aGridCol.column &gt;= ordinalODStartCell and aGridCol.column &lt;= ordinalODEndCell then
				if aGridCol.allGridPointsByRow[theLidTier] = null then
					create aLidPoint transient;
					aLidPoint.setForCreate( aGridCol.column,theLidTier,self, cellODStart, cellODEnd,cellUDStart,cellUDEnd ,startsMidCell, endsMidCell,aLid,aGridCol);
				endif;
			endif;
		endforeach;

	endforeach;
//_slotController : CM_SlotController; _isAft : Boolean; _isFwd : Boolean; _bayType : Integer; theBay : CM_BayVoyage	
	
	foreach aSlot in theBay.allSlotsOnDeck do
		// the ordinals for tiers are upside down, as far as the grid controll is concerned, so this flips the ordinal
		theRowOrdinal := theBay.allTiersOnDeck.size - (aSlot.ordinalTier - 1);
		// the ordinals for cells are NOT upside down
		theColumnOrdinal := aSlot.ordinalCell;

		create aBayPoint transient;
		aSlotC := aSlot.CM_SlotDefnVoyage.mySlotController;
//		aBayPoint.setForCreate(theColumnOrdinal, theRowOrdinal, aSlotC,self,aSlot,false);
		aBayPoint.populateController(aSlotC,isAft,isFwd,bayType,theBay, theRowOrdinal,theColumnOrdinal,self,bayFwdID,bayAftID);
	endforeach;
epilog

end;</source>
        <Parameter name="_theBay" type="CM_BayVoyage"/>
        <Parameter name="_theColumn" type="Integer"/>
        <Parameter name="_theRow" type="Integer"/>
        <Parameter name="_theMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setGridRowColPositions" id="42437561-ec18-4aa7-b485-27fccd6f7c49">
        <updating/>
        <source>setGridRowColPositions() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
