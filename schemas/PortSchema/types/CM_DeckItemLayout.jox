    <JadeMethod name="isCoveredByOnLayer" id="7db41b8e-4567-446a-9280-0bf770a24d45">
        <source>isCoveredByOnLayer(_layoutType : Integer; _layerType : Integer; _checkVisible : Boolean) : Boolean;
/*
Purpose:			PAR 32374
Date		Who		Reason
AUG2013	cnwab1	Initial creation
*/

vars
	deckItemlayout : CM_DeckItemLayout;
begin
	foreach deckItemlayout in self.allCoveringPolygons discreteLock where deckItemlayout.type = _layoutType do
		if  _checkVisible and not deckItemlayout.isVisible then
			continue;
		endif;
		if deckItemlayout.myDeckLayer.type = _layerType then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_layoutType" type="Integer"/>
        <Parameter name="_layerType" type="Integer"/>
        <Parameter name="_checkVisible" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
