    <JadeMethod name="btnChosenTemp_click" id="2e0430c3-73ae-442a-8356-1339bfd43e84">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnChosenTemp_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2014	cnwndl1	Initial creation

*/

vars

	ti : CM_TrackedItem;
	lc : CM_LocationsController;
	foundHeight : Integer;

begin

	if btn.userObject &lt;&gt; null then
		ti := btn.userObject.CM_TrackedItem;
	endif;
	if ti = null or  ti.priorLocation.trimBlanks = null then
		return;
	endif;
	self.myTerminal.findLocationFromString( ti.priorLocation, true, lc, foundHeight );
	if lc = null then
		return;
	endif;

	self.clickButton( ti, lc );

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnDocActions_click" id="00370bee-fb5d-4b79-b952-097a10a1fde8">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDocActions_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 September 2016	cnwndl1	Initial creation	TFS 2647 / 2001

*/

vars

	reserveDetail : CM_ReserveDetail;
	resDetailSet : CM_ReserveDetailSet;

begin

	if self.myBulkRelease = null then	
		return;
	endif;

	create resDetailSet transient;
	self.myBulkRelease.allReserveDetails.copy( resDetailSet );
	//27 Jan 2017	NDL	TFS 3157
	if not self.myBulkRelease.allReservePackingChildren.isEmpty then
		self.myBulkRelease.allReservePackingChildren.copy( resDetailSet );
	endif;
	
	self.myMobileGenericAgent.setAllReserveDetails( resDetailSet );
	self.myMobileGenericAgent.setStringField1( self.fldCargo.topSheet.name );
	self.myMobileGenericAgent.setInward( self.isById );
	self.myMobileGenericAgent.setForward( self.isFIFO );
	self.myMobileGenericAgent.setMyNextTiToAction( null );
	self.gotoForm( MOB_HHDocumentActions, false );

epilog

	delete resDetailSet;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
