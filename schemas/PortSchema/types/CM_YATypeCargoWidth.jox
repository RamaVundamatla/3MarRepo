    <JadeMethod name="isCMIFDataMatch" id="7b8f50cd-8f5d-4b19-8a06-996538887798">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataString): Boolean;
//09 December 2009	cnwml2


vars

begin
	return _yaData.value = null or _cmifAutoPlan.isCargoWidth_Match(_yaData);

epilog

end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YADataString"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
