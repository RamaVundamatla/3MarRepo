    <JadeMethod name="translateForm" id="22ecdb48-22e3-4feb-a32a-c71442e319b8">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018769, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="33a42657-453b-4da7-b919-17c0f725066d">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 July 2009	cnwdap1	Initial creation
*/
vars

begin
	self.resetForm();

	if global.isValidObject(self.myMainForm) then // do not delete if this is the attachments
		self.myMainForm.enabled := true;
	endif;

	inheritMethod();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="unloadForm" id="ebb350a5-50ab-4bd9-95df-9e47328a0dd7">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>unloadForm(): Boolean updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Dec 2024	navbs1	Initial Creation Bug MTN-33524: MTN - Notifications in the work order details screen update the release request assigned as a new work order is created

*/

vars
	
	scm				: Schema;
	frmClass		: Class;
begin
	scm 			:= rootSchema.getSchema('YardSchema');
	frmClass 		:= scm.getClass('YRD_WorkOrder');
	if self.myParentForm &lt;&gt; null and self.myParentForm.isKindOf(frmClass) then 
		self.myParentForm.sendMsgWithParams("maintainBtnAttachCargo");
	endif;
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
