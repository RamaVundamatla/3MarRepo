    <JadeMethod name="canConvertToXML" id="6d8aff37-2154-42b9-a83a-c10056daf875">
        <source>canConvertToXML() : Boolean;

/*

Purpose:			Determines whether the receiver can be converted into XML or not.
					To be re-implemented as required on subclasses where this functionality
					is required


Return Value:		True if the receiver can be converted to XML, false otherwise


Date		Who		Reason
12 Dec 2007	cnwkpd1	CCMS TWLENH 1018 - RF Gun Web Service

*/

vars

begin
	return true;
	
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canCreateFromXML" id="8805823e-e7d0-4c8e-a9bb-f3f02c722cd0">
        <source>canCreateFromXML() : Boolean;

/*

Purpose:			Determines whether the receiver can be created from an XML document
					or not.
					To be re-implemented as required on subclasses where this functionality
					is required


Return Value:		True if the receiver can be created from XML, false otherwise


Date		Who		Reason
12 Dec 2007	cnwkpd1	CCMS TWLENH 1018 - RF Gun Web Service

*/

vars

begin
	return self.canConvertToXML;
	
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateFromXMLElement" id="cdbf1f1f-c85f-4586-82e0-b6bcf7270c08">
        <updating/>
        <source>populateFromXMLElement(_element : JadeXMLElement;
					   _createdObjects : ObjectSet input) updating;

/*

Purpose:			Inverse of populateXMLElement method.  Will populate the properties on
					the receiver with those from the passed in XML element


Return Value:		None
					Will populate _createdObjects with any other objects created below the receiver
					in a hierarchy, to allow the caller to tidy them up


Date		Who		Reason
12 Dec 2007	cnwkpd1	CCMS TWLENH 1018 - RF Gun Web Service
13 Feb 2009	cnwkpd1	PAR #17554 - JMT RIA Web Service - use xsi:type attribute to define class
					of subobjects

*/

vars
	props			: PropertyColl;
	property		: Property;
	propName		: String;
	propValue		: Any;
	obj				: Object;
	propElement		: JadeXMLElement;
	coll			: Collection;
	typeAttribute	: JadeXMLAttribute;
	propClass		: Class;
	
begin
	props := self.class.allProperties;
	foreach property in props do
		
		propName := property.name;
		if propName[1:1] = "_" then
			continue;
		endif;
		
		propElement := _element.getElementByTagNameNS("*", propName);
		if propElement = null then
			continue;
		endif;
		
		if property.type.isKindOf(CollClass) then			// Assume collections are exclusive
			propValue := self.getPropertyValue(propName);
			coll := propValue.Collection;
			coll.populateFromXMLElement(propElement, _createdObjects);
			
		elseif property.type.isKindOf(Class) then

			// Actual type of reference property might be a subclass of the definition,
			// so check for a type attribute
			typeAttribute := propElement.getAttributeByName(self.Attribute_XSI_Type);
			if typeAttribute &lt;&gt; null then
				propClass := currentSchema.getClass(typeAttribute.value);
			endif;
			if propClass = null then
				propClass := property.type.Class;
			endif;
			
			if self.isTransient then
				create obj as propClass transient;
			else
				create obj as propClass persistent;
			endif;
			if obj.canCreateFromXML then
				_createdObjects.add(obj);
				obj.populateFromXMLElement(propElement, _createdObjects);
			else
				delete obj;
			endif;
			self.setPropertyValue(propName, obj);
			
		else
			propValue := propElement.text.asAnyOfType(property.type);
			self.setPropertyValue(propName, propValue);
		
		endif;
		
	endforeach;
	
	
epilog
	delete props;
		
end;
</source>
        <Parameter name="_element" type="JadeXMLElement"/>
        <Parameter name="_createdObjects" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="populateXMLElement" id="53951a8d-85a5-45f0-aadc-4377dacd9502">
        <source>populateXMLElement(_element : JadeXMLElement input;
				   _processedObjects : ObjectSet input);

/*

Purpose:			


Return Value:		


Date		Who		Reason
12 December 2007	cnwkpd1	CCMS TWLENH 1018 - RF Gun Web Service

*/

vars
	props			: PropertyColl;
	property		: Property;
	propName		: String;
	propValue		: Any;
	obj				: Object;
	newElement		: JadeXMLElement;
	stringValue		: String;
	xml				: JadeXMLDocument;
	
begin
	// Prevent recursive calls with the same object
	if _processedObjects.includes(self) then
		return;
	else
		_processedObjects.add(self);
	endif;
	
	// Check this object can be serialised
	if not self.canConvertToXML then
//		_element.setText(self.String);			// debug
		return;
	endif;
	
	props := self.class.allProperties;
	foreach property in props where property.access = null do		// only public properties
		
		propName := property.name;
		if propName[1:1] = "_" then
			continue;
		endif;
		
		newElement := _element.addElement(propName);
		
		propValue := self.getPropertyValue(propName);
		
		if propValue.isKindOf(Object) then
			obj := propValue.Object;
			if obj &lt;&gt; null then
				newElement.addAttribute(self.Attribute_XSI_Type, obj.class.name);
				obj.populateXMLElement(newElement, _processedObjects);
			endif;
		elseif propValue.isKindOf(Binary) then
			stringValue := propValue.Binary.base64Encode();
			newElement.addAttribute(self.Attribute_XSI_Type, "xsd:base64");
			newElement.setText(stringValue);
		else
			stringValue := propValue.String;
//			if stringValue[1] = "&lt;" then
//				delete xml;
//				create xml transient;
//				xml.parseString(stringValue);
//				xml.rootElement.copyAsChildOf(newElement);
//			else
				newElement.setText(stringValue);
//			endif;
		endif;
	
	endforeach;
	
	
epilog
	delete props;
	delete xml;
	
end;</source>
        <Parameter name="_element" type="JadeXMLElement" usage="input"/>
        <Parameter name="_processedObjects" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="returnAsXMLDocument" id="62db0568-64ff-438d-b079-341783c9d180">
        <source>returnAsXMLDocument() : JadeXMLDocument;

/*

Purpose:			Return the receiver as an XML document, if appropriate


Return Value:		Object serialised as XML, or null if this object can't be converted to 
					XML


Date		Who		Reason
12 Dec 2007	cnwkpd1	CCMS TWLENH 1018 - RF Gun Web Service

*/

vars
	xml				: JadeXMLDocument;
	rootElement		: JadeXMLElement;
	processedObjs	: ObjectSet;
	
begin
	if not self.canConvertToXML then
		return null;
	endif;
	
	create xml transient;
	rootElement := xml.addElement(self.class.name);
	
	create processedObjs transient;
	
	self.populateXMLElement(rootElement, processedObjs);
	
	rootElement.addAttribute(self.Attribute_XMLNS_XSI_Name, self.Attribute_XMLNS_XSI_Value);
	rootElement.addAttribute(self.Attribute_XMLNS_S1_Name, self.Attribute_XMLNS_S1_Value);
	
	return xml;
	
	
epilog
	delete processedObjs;
	
end;</source>
        <ReturnType type="JadeXMLDocument"/>
    </JadeMethod>
    <JadeMethod name="returnAsXMLString" id="b858a1dc-a1fa-4e7a-9319-eafd1a20b505">
        <source>returnAsXMLString() : String;

/*

Purpose:			


Return Value:		


Date		Who		Reason
12 December 2007	cnwkpd1	CCMS TWLENH 1018 - RF Gun Web Service

*/

vars
	xml				: JadeXMLDocument;
	
begin
	xml := self.returnAsXMLDocument;
	if xml = null then
		return null;
	else
		xml.outputDeclaration := false;
		return xml.writeToString;
	endif;
	
	
epilog
	delete xml;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
