<PrimType name="Character">
    <JadeMethod name="jssGetMaskType" id="b6c7fe90-38fc-487d-b9d7-ef604001f4db">
        <source>jssGetMaskType():Integer;
// --------------------------------------------------------------------------------
// Created:		13 June 1999  by cnwdad1
//
// Purpose:		Gets the type of mask character.
//
// Parameters:	pValue (String) - The mask character.
//
// Returns:		Integer - The ASCII character number.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	ALPHA_LOWER		: Character = "a";
	ALPHA_UPPER		: Character = "A";
	ALPHANUM_LOWER	: Character = "x";
	ALPHANUM_UPPER	: Character = "X";
	NUMERIC			: Character = "9";

vars

begin
	if self = ALPHA_LOWER then
		return JSS_CHAR_ALPHA_LOWER;
	elseif self = ALPHA_UPPER then
		return JSS_CHAR_ALPHA_UPPER;
	elseif self = ALPHANUM_LOWER then
		return JSS_CHAR_ALPHANUM_LOWER;
	elseif self = ALPHANUM_UPPER then
		return JSS_CHAR_ALPHANUM_UPPER;
	elseif self = NUMERIC then
		return JSS_CHAR_NUMERIC;
	else
		return JSS_CHAR_SPECIAL;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssGetMaskedCharacterType" id="9390279b-7344-45f5-9874-7554a0f23fcf">
        <source>jssGetMaskedCharacterType():Integer;
// --------------------------------------------------------------------------------
// Created:		13 June 1999 by cnwdad1
//
// Purpose:		Gets the type of character in a string being compared to a mask.
//
// Parameters:	pValue (String) - The character in question.
//
// Returns:		Integer - The ASCII character number.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	ALPHA_LOWER_LOW			: Integer = 97;
	ALPHA_LOWER_HIGH		: Integer = 122;
	ALPHA_UPPER_LOW			: Integer = 65;
	ALPHA_UPPER_HIGH		: Integer = 90;
	NUM_LOW					: Integer = 48;
	NUM_HIGH				: Integer = 57;

vars
	ascii	: Integer;

begin
	ascii	:=	self.Integer;

	if (ascii &gt;= ALPHA_LOWER_LOW) and (ascii &lt;= ALPHA_LOWER_HIGH) then
		return JSS_CHAR_ALPHA_LOWER;
	elseif (ascii &gt;= ALPHA_UPPER_LOW) and (ascii &lt;= ALPHA_UPPER_HIGH) then
		return JSS_CHAR_ALPHA_UPPER;
	elseif (ascii &gt;= NUM_LOW) and (ascii &lt;= NUM_HIGH) then
		return JSS_CHAR_NUMERIC;
	else
		return JSS_CHAR_SPECIAL;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssHexToInt" id="f4d630be-fd85-43cf-9c82-c82a45444901">
        <source>jssHexToInt():Integer;
// --------------------------------------------------------------------------------
// Created:		03 January 2002 by cnwdad1
//
// Purpose:		Converts the receiver hex value into its equivalent integer value.
//
// Parameters:	None
//
// Returns:		The receiver converted into an integer.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
    if self &gt;= "0" and self &lt;= "9" then
		return self.Integer - 48;
	endif;

   if self = "A" or self = "a" then
		return 10;
	endif;

   if self = "B" or self = "b" then
		return 11;
	endif;

   if self = "C" or self = "c" then
		return 12;	endif;

   if self = "D" or self = "d" then
		return 13;
	endif;

   if self = "E" or self = "e" then
		return 14;
	endif;

   if self = "F" or self = "f" then
		return 15;
	endif;

	// Not a valid hex digit, so ...
	return -1;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
</PrimType>
