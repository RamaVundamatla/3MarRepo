    <JadeMethod name="addToolbarControls" id="fc20b1dc-6c3f-4265-aa61-586606064616">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*
------------------------------------------------------------------------
Created:			15 September 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	toolbar	: CMUI_Toolbar;

begin
	inheritMethod();
	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnExportCSV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnViewUsers, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewLocks, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnProcessCnt, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnTermProcess, CMUI_Toolbar.Control_Alignment_Left);
	if app.isSpecial() then
		toolbar.addButton(self.btnTermNode, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addValueToGraph" id="0a36008c-72bc-444f-b228-e0b33c7b295b">
        <source>addValueToGraph(_label1, _label2 : String; _value, _color : Integer io) protected;
// ---------------------------------------------------------------------------
// Created:     13 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.grfLocks.addValue(_label1, _label2, _value, _color);
	
	_value := 0;
	
	if _color = self.graphColor1 then
		_color := self.graphColor2;
	else
		_color := self.graphColor1;
	endif;


end;</source>
        <access>protected</access>
        <Parameter name="_label1" type="String"/>
        <Parameter name="_label2" type="String"/>
        <Parameter name="_value" type="Integer" usage="io"/>
        <Parameter name="_color" type="Integer" usage="io"/>
    </JadeMethod>
