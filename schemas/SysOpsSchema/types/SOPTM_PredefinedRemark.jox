    <JadeMethod name="setControlsForAddEdit" id="061bda8a-7564-463a-a6de-c7e74c39f243">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:     13 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin
  	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
			
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
//		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		// call this last as sets cell input type (case etc)
		// if not called can get problems with case on entry. 
		theForm.tblInput1.gotFocus(theForm.tblInput1);		
		
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_PredefinedRemark);
		// cannot update code
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
	endif;

	theForm.tblInput1.cnEcResizeContents();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="2d380528-0a36-4255-9335-6bed3170b5cf">
        <updating/>
        <source>setCtrlsForView() updating;
// ---------------------------------------------------------------------------
// Created:     12 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin
	//cnwmc5 - 17 Oct 2013 - PAR 32622
	inheritMethod();
	
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	//theForm.tblInput1.showRowByName('ports',false);
	theForm.tblInput1.cnEcResizeContents();
end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="8896fa03-3df7-4733-bdcf-f663d933351d">
        <source>setupThumbnailDetails();
// ---------------------------------------------------------------------------
// Created:     13 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_PredefRemarkMaintTbl);
	//theForm.zAddColumn('PredefinedRemark Id', 'code', Table.InputType_None, 30);
	//theForm.zAddColumn('Description', 'description', Table.InputType_None, 70);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_PredefRemarkMaint);
	theForm.shtTblInput1.visible := true;

	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="034cd623-9b61-471b-ab79-52b33a2aef90">
        <updating/>
        <source>showThumbnail(pPredefinedRemark: CM_PredefinedRemark) updating;
// ---------------------------------------------------------------------------
// Created:     13 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars

	theForm : SOP_TableMaintForm;
	first:Boolean;
	list:String;	
begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Code, pPredefinedRemark.code);
	theForm.tblInput1.setValueByName(ETRow_Description,	pPredefinedRemark.description);
	first := false;
end;</source>
        <Parameter name="pPredefinedRemark" type="CM_PredefinedRemark"/>
    </JadeMethod>
</Class>
