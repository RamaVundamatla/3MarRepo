<GUIClass name="CMUI_WHEmptySummary" id="c8e9c870-05e3-4052-9850-078d9a9b6342">
    <superclass name="CMUI_ReportBaseForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <Constant name="BaseColNum" id="1f7de499-329f-4ed2-af2a-9f43f7e1a8b5">
        <source>8</source>
        <type name="Integer"/>
    </Constant>
    <ImplicitInverseRef name="myJRWEmptySummary" id="e40557b0-5a03-4bc6-9123-16ce26618952">
        <embedded/>
        <type name="CM_JRWEmpty"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myReportGroupRoot" id="59c836a0-7668-40ea-b17c-0e72b7cb49af">
        <embedded/>
        <type name="CM_ReportGroupRoot"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="picJMTLogo" id="6b526f4a-56fb-4ba1-921e-3d155d04d383">
