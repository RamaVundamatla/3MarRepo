        <type name="CM_ContentsMap"/>
    </ImplicitInverseRef>
    <JadeMethod name="getItemLevel" id="e460a7b3-0e84-4e9e-b78b-87251e711822">
        <source>getItemLevel(): Integer;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	return CMIF_TranMapController.TM_Level_14_MoveTransactions;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMyTransactionMap" id="52f5ebd3-f0cb-4537-8ae4-447db4e00888">
        <source>getMyTransactionMap(): CM_TranMap;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
01 June 2018	jlgsl4	TFS 38711 - Initial Creation - STWO - 1090 on copy Move transaction

*/

vars

begin
	return myCommodityMap.contentsMap.imexMap.myProductMap.myProductGroupMap.myCargoTypeMap.transactionMap;
epilog

end;</source>
        <ReturnType type="CM_TranMap"/>
    </JadeMethod>
    <JadeMethod name="getPicture" id="56537fdf-139a-401d-99e0-94e5744d4080">
        <source>getPicture(form: INV_TransactionMap): Picture;

vars

begin
	if self.hidePictures then
		return null;
	endif;
	return form.picMove;

end;</source>
        <Parameter name="form" type="INV_TransactionMap"/>
        <ReturnType type="Picture"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="8660c0b6-27a3-4978-98cb-9223393fa918">
        <updating/>
        <source>initialise(_groupCount : Integer io) updating;

vars
	sb:     CM_MoveServiceBroker;
	tmcSB:  CMIF_TMCSBGroup;
begin
	self.myTMCController := self.myGroup.myTMCController;	// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
	self.hidePictures := self.myTMCController.hidePictures;
	foreach sb in self.myCommodityMap.moveMap do
		create tmcSB;
		tmcSB.myServiceBroker := sb;
		tmcSB.itemName := sb.moveFrom &amp; " -&gt; " &amp; sb.moveTo;
		tmcSB.extractName := tmcSB.itemName;	// 23659
		tmcSB.myGroup := self;
		tmcSB.initialise(_groupCount);
	endforeach;
	
	_groupCount:=_groupCount + 1;
end;</source>
        <Parameter name="_groupCount" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setControllerCurrent" id="bea038df-1c7e-4579-9f0c-79bfd0473d02">
        <source>setControllerCurrent() ;
// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
vars
	aCMap : CM_ContentsMap;
begin
	inheritMethod();

	myTMCController.myCurrentMapCommodity := self.myCommodityMap;
	aCMap := self.myCommodityMap.contentsMap;
	myTMCController.myCurrentMapContents := aCMap;
	myTMCController.myCurrentMapIMEX := aCMap.imexMap;
	myTMCController.myCurrentMapProduct := myTMCController.myCurrentMapIMEX.myProductMap;
	myTMCController.myCurrentMapProdGrp := myTMCController.myCurrentMapProduct.myProductGroupMap;
	myTMCController.myCurrentMapTIService := myTMCController.myCurrentMapProdGrp.myCargoTypeMap;
	myTMCController.myCurrentMapTM := myTMCController.myCurrentMapTIService.transactionMap;
end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="3ec90e2f-aeae-4dae-a655-8e6d89dffb76">
        <source>setEnableObjects(form: INV_TransactionMap io);
// 30 May 2018	jlgsl4	TFS 38711 - STWO - error copying Transaction Map transaction eg. Road-&gt;Yard

vars

begin

	inheritMethod(form);
	form.menuSItemNew.visible := true;  // MAIN CARGO NEW MENU
	form.menuTMVnew.visible := false;  // MAIN VTMIS NEW MENU
	form.mnuTMExport.visible := false;
	form.menuMappingSetActive.visible := false;
		
	form.modePropertyNew := INV_TransactionMap.ModeProperty_Move;
	form.modePropertyUpdate := INV_TransactionMap.ModeProperty_Move;
	form.modePropertyDelete := INV_TransactionMap.ModeProperty_Move;

	form.menuSItemNew.enabled := true;
	form.btnNew.enabled := true;

	form.mnuCopy.visible := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 38711 - show Move menu Copy
	form.btnCopy.enabled := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 38711
	
	form.menuSINewTranType.visible := true;
	form.menuMapNewTranMove.visible := true;
	form.menuMapNewTranMove.visible := true;

	form.menuSItemDelete.visible := true;
	form.menuSItemDelete.enabled := true; // TFS 38711
	form.btnDelete.enabled := true;
end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrent" id="1e8d1af9-bd88-4cbb-9a9f-0e7fb01c9cfa">
        <updating/>
        <source>setMyCurrent(form: INV_TransactionMap io) updating;
// ---------------------------------------------------------------------------
// Created:		March 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//07 June 2018	jlgsl4	TFS 38711 - STWO - error copying Transaction Map transaction eg. Road-&gt;Yard

vars
	aCMap : CM_ContentsMap;
begin
	inheritMethod(form);

	form.myCurrentMapServiceBroker := self.myCommodityMap.moveMap.first; // TFS 38711
	
	form.myCurrentMapCommodity := self.myCommodityMap;
	aCMap := self.myCommodityMap.contentsMap;
	form.myCurrentMapContents := aCMap;
	form.myCurrentMapIMEX := aCMap.imexMap;
	form.myCurrentMapProduct := form.myCurrentMapIMEX.myProductMap;
	form.myCurrentMapProdGrp := form.myCurrentMapProduct.myProductGroupMap;
	form.myCurrentMapTIService := form.myCurrentMapProdGrp.myCargoTypeMap;
	form.myCurrentMapTM := form.myCurrentMapTIService.transactionMap;

end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
</Class>
