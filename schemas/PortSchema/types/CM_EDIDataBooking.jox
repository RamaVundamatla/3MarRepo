// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
*/
vars

begin
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doesVesselNameExist" id="e0eb31ac-e2ac-4dc9-9818-5c88b2b54cfe">
        <source>doesVesselNameExist(_vesselName: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2023	navra1	Initial creation for 57263

*/

vars
	ediTi: CM_EDITrackedItem;
	bookingHeaderTI : CM_EDIBookingHeaderTI;
	terminal : CM_Terminal;
	voyage : CM_Voyage;
begin
	foreach ediTi in self.allEDITrackedItems do
		if ediTi.isKindOf(CM_EDIBookingHeaderTI) then
			bookingHeaderTI := ediTi.CM_EDIBookingHeaderTI;
			terminal := bookingHeaderTI.getMyTerminal;
			if terminal &lt;&gt; null then
				voyage := terminal.lookupVoyage(bookingHeaderTI.getVoyageCode(), null, false);
				if voyage &lt;&gt; null then
					if voyage.vesselName.toUpper().compareEql(_vesselName.toUpper(), true, false, null) then
						return true;
					endif;
				endif;
			endif;
		endif;
	endforeach;
	
	return false;

epilog

end;</source>
        <Parameter name="_vesselName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
