    <JadeMethod name="getDisplayStringForAttribute" id="024eeab3-1219-447e-be67-90d3a3bdc183">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	
begin
	if _attrName = ETRow_BatNumber or
	   _attrName = ETRow_BatNo then // JLGAB1 PEL1 Testing
		return null;
	elseif _attrName = ETRow_Is2040 then
	
	elseif _attrName = ETRow_Location then
		return self.getDescription();
	elseif _attrName = ETRow_NumEmptyD then

			return null;
	elseif _attrName = ETRow_NumFullD then
		return null;
	elseif _attrName = ETRow_NumEmptyRHD then
		return null;
	elseif _attrName = ETRow_NumFullRHD then
			return null;
	elseif _attrName = ETRow_SeqNumCustomPort then
		return null;
	elseif _attrName = ETRow_SeqNumCustomStarboard then
		return null;
	elseif _attrName = ETRow_SeqNumPort then
		return null;
	elseif _attrName = ETRow_SeqNumStarboard then
		return null;
	elseif _attrName = ETRow_SeqNumWorkOrder then
		return null;
	elseif _attrName = ETRow_SeqNumAsString then
		return null;				
	elseif _attrName = ETRow_IsoType then
		return null;	
	elseif _attrName = ETRow_Crane then
		if self.myJobSheet &lt;&gt; null and self.myJobSheet.isKindOf(CM_VoyageJobSheet) then
			return self.myJobSheet.CM_VoyageJobSheet.crane;
		endif;
		return null;
	elseif _attrName = ETRow_NewJobID then
		return self.jobNum;
	elseif _attrName = ETRow_CraneId then
		return self.craneId;
	elseif _attrName = ETRow_BayId then
		return self.bayId;
	elseif _attrName = ETRow_IsTwinLift then
		return app.getYesNo(self.isTwinLift);  //epr par 28389 10/10/11
	elseif _attrName = ETRow_SystemRemarks then
		return self.systemRemarks.removeTabCrLfs;
	elseif _attrName = ETRow_NumOfLids then
		return self.numOfLids.asStringJMT;
	elseif _attrName = ETRow_TimeToComplete then
		return self.estimatedTimeToCompleteMins.asStringJMT;
	elseif _attrName = ETRow_ActualStartDate then
		
		return self.systemToLocalTime(self.actualStartTs).date.asStringJMT;	// 20/5/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_ActualStartTime then
		if self.actualStartTs.date = null then
			return null;
		else
			return self.systemToLocalTime(self.actualStartTs).time.asStringJMT;	// 20/5/16 cnwmp6 TFS 488 - Multi timezone support
		endif;
	elseif _attrName = ETRow_ActualEndDate then
		return self.systemToLocalTime(self.actualEndTs).date.asStringJMT;	// 20/5/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_ActualEndTime then
		if self.actualEndTs.date = null then
			return null;
		else
			return self.systemToLocalTime(self.actualEndTs).time.asStringJMT;	// 20/5/16 cnwmp6 TFS 488 - Multi timezone support
		endif;
	elseif _attrName = ETRow_TheHatchLids then
		return null;
	elseif _attrName = ETRow_AutoSortIntoOrderOfWorks then
		return true.asStringJMT;
	elseif _attrName = ETRow_LoadedToOps then
		return self.isLoadedToOperations.getYesNo;
	elseif _attrName = ETRow_DeckId then
		return self.getDeckId;
	elseif _attrName = ETRow_LoadOutOfSequence then //cnwrd1 par 30626 ccms 2209 23.10.12
		return app.getYesNo(self.allowOutOfOrderLoading);
	else

		return inheritMethod(_attrName, _short);
	endif;


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEmptySlotLocIDInSequence" id="394e7793-18bd-4f98-aea0-10964a449bbc">
        <source>getEmptySlotLocIDInSequence(_slots: Array input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 October 2012	cnwrd1	Initial creation

*/

vars
	reqs : CM_RequestArray;
	theReq : CM_Request;
begin

	if _slots = null then
		return;
	endif;
	
	create reqs transient;
	self.doSortEmptyReqsInToSeqOrder(reqs);
	
	foreach theReq in reqs do
	//	_slotIDs.add(theReq.CM_SlotRequest.mySlotController.getStowageId(null));
		if theReq.isKindOf(CM_RORORequest) then
			_slots.add(theReq.CM_RORORequest.myROROController);
		else
			_slots.add(theReq.CM_SlotRequest.mySlotController);
		endif;
	endforeach;

epilog
	delete reqs;
end;</source>
        <Parameter name="_slots" type="Array" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getEndTsWithDelays" id="d88744b9-f9b9-4f0f-90c1-3e706fe1fc16">
        <source>getEndTsWithDelays(_estStartTime,_estEndTime : TimeStamp;
					_crane : CM_Crane;
					_voyageDelays : DynaDictionary) : TimeStamp;
/*

Purpose:			


Return Value:		


Date		Who		Reason
09 February 2007	cnwer1	Initial creation - PAR#xxxx
29 October 2007  	cnwer1  added _voyageDelays as a parameter to improve performance
*/
vars
	craneDelayIter :Iterator;
	voyageDelayIter : Iterator;
	delay : CM_Delay;
	newEstEndTime : TimeStamp;
	calcDelayEndTime,
	delayEndDT: TimeStamp;
	diff : Integer;
	newEstStartTime : TimeStamp;
	invalidDelay	: Boolean;
begin

	if _estStartTime = null or _estEndTime = null then
		return null;
	endif;

	newEstEndTime:=_estEndTime;
	newEstStartTime:=_estStartTime;
	
	//if self.myVoyage.allDelays.size &gt; 0 then
	//	voyageDelayIter:=self.myVoyage.allDelays.createIterator;
	
	if _voyageDelays.size &gt; 0 then
		on Exception do app.handleDeletedObject(exception, delay, invalidDelay); //20/12/2010 cnwdz2 26190
		
		voyageDelayIter:=_voyageDelays.createIterator;
		_voyageDelays.startKeyGeq( newEstStartTime, voyageDelayIter); //epr par 23034 should of started at startTime
		while voyageDelayIter.next(delay) do
			invalidDelay := false; //20/12/2010 cnwdz2 26190
			
			delayEndDT:=delay.getEndDT;
			
			//20/12/2010 cnwdz2 26190
			// If we had an exception accessing the node, then skip it
			if invalidDelay then
				continue;
			endif;
			
			if delayEndDT = null then
				continue;
			endif;
			if delay.startDT &gt;  newEstEndTime then
				break;
			endif;
			if delayEndDT &lt; newEstStartTime then //or delay.startDT &gt; newEstEndTime then 
				continue;
			endif;
			
			if delay.myMachine &lt;&gt; null and delay.myMachine &lt;&gt; _crane then
				continue;
			endif;
			
	
			if delay.startDT &lt; newEstStartTime then
				diff:=delayEndDT.getDifferenceInMinutes(_estStartTime);
				newEstStartTime:=newEstStartTime.addMinutes(diff);
				newEstEndTime:=newEstEndTime.addMinutes(diff);
				continue;
			elseif delayEndDT &gt; newEstEndTime then
				diff:=delayEndDT.getDifferenceInMinutes(newEstEndTime);
				newEstEndTime:=newEstEndTime.addMinutes(diff);
				continue;
			else
		
				diff:= delay.startDT.getDifferenceInMinutes(delayEndDT);	
				newEstEndTime:=newEstEndTime.addMinutes(diff);
				continue;
			endif;
		endwhile;
		delete voyageDelayIter;
	endif;

	return newEstEndTime;

epilog
	
end;</source>
        <Parameter name="_estStartTime" type="TimeStamp"/>
        <Parameter name="_estEndTime" type="TimeStamp"/>
        <Parameter name="_crane" type="CM_Crane"/>
        <Parameter name="_voyageDelays" type="DynaDictionary"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getEstJobTimeForJobStats" id="2d5706e1-221a-4b5a-a0cf-124016c515a6">
        <source>getEstJobTimeForJobStats(_crane : CM_Crane; _cmif_JobStats : CMIF_JobStats;_additionalMins : Integer  ) : Integer;
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 July 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	jobAdditionalMins : Integer;
	crane : CM_Crane;
	craneMoveRate : CM_CraneMoveRates;
	slodRate, //single lift on deck rate
	sludRate, //single lift under deck rate
	tlodRate, //twin lift on deck rate
	tludRate,	//twin lift under deck rate
	ovrDimRate 	: Real;
	jobMins :Real;
	ratePH, numHours : Decimal[12,4];
	numSecs : Integer;
begin
	if self.estimatedTimeToCompleteMins &lt;&gt; null then
		return self.estimatedTimeToCompleteMins;
	endif;
	if self.myVoyage &lt;&gt; null then
		jobAdditionalMins:=_additionalMins;//self.myVoyage.myTerminal.getConfig(JobAdditionalTime).Integer;
	endif;
	crane := _crane;
	
	if crane = null then
		return null;
	endif;
	slodRate:=crane.targetRatePH;
	sludRate:=crane.targetRatePH;
	tlodRate:=crane.targetRatePH;
	tludRate:=crane.targetRatePH;	
	ovrDimRate:=crane.targetRatePH;
	
	craneMoveRate:=getCraneMoveRate(crane);
	
	if craneMoveRate &lt;&gt; null then
		if craneMoveRate.ratePerHourSLOD &lt;&gt; 0 then
			slodRate:=craneMoveRate.ratePerHourSLOD;
		endif;
		if craneMoveRate.ratePerHourSLUD &lt;&gt; 0 then
			sludRate:=craneMoveRate.ratePerHourSLUD;
		endif;
		if craneMoveRate.ratePerHourTLOD &lt;&gt; 0 then
			tlodRate:=craneMoveRate.ratePerHourTLOD;
		endif;
		if craneMoveRate.ratePerHourTLUD &lt;&gt; 0 then
			tludRate:=craneMoveRate.ratePerHourTLUD;
		endif;
		if craneMoveRate.ratePerHourOD &lt;&gt; 0 then
			ovrDimRate:=craneMoveRate.ratePerHourOD;
		endif;
	endif;
	
//check so we don't get div by zero error;
	if _cmif_JobStats.incompleteSLOD &lt;&gt; 0 and slodRate &lt;&gt; 0 then
		numHours := numHours + (_cmif_JobStats.incompleteSLOD /slodRate );	
	endif;
	
	if _cmif_JobStats.incompleteSLUD &lt;&gt; 0 and sludRate &lt;&gt; 0 then
		numHours := numHours + (_cmif_JobStats.incompleteSLUD /sludRate  );
	endif;
	
	if _cmif_JobStats.incompleteTLOD &lt;&gt; null and tlodRate &lt;&gt; 0 then
		numHours := numHours + (_cmif_JobStats.incompleteTLOD /tlodRate);
	endif;
	
	if _cmif_JobStats.incompleteTLUD &lt;&gt; null and tludRate &lt;&gt; 0 then
		numHours := numHours + (_cmif_JobStats.incompleteTLUD /tludRate);
	endif;

	if _cmif_JobStats.incompleteOverDimesion &lt;&gt; 0 and ovrDimRate &lt;&gt; 0 then
		numHours := numHours + (_cmif_JobStats.incompleteOverDimesion/ ovrDimRate);
	endif;
	
	numSecs := (numHours * SecondsPerHour).Integer;
	
	return numSecs + (jobAdditionalMins * 60);


epilog

end;</source>
        <Parameter name="_crane" type="CM_Crane"/>
        <Parameter name="_cmif_JobStats" type="CMIF_JobStats"/>
        <Parameter name="_additionalMins" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getEstJobTimeUsingCraneRates" id="b50f437b-d9fc-4565-96c2-e69726946dd0">
        <source>getEstJobTimeUsingCraneRates(_crane : CM_Crane) : Integer;
/*

Purpose:			


Return Value:		


Date		Who		Reason
02 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	crane		: CM_Crane;
	wle			: CM_WorkListEntry;
	rate,
	slodRate, //single lift on deck rate
	sludRate, //single lift under deck rate
	tlodRate, //twin lift on deck rate
	tludRate,	//twin lift under deck rate
	ovrDimRate,  // over dimentional containers rate
	defaultTargetRate: Real;
	craneMoveRate : CM_CraneMoveRates;
	isOnDeck : Boolean;
	noSLOD,
	noSLUD,
	noTLOD,
	noTLUD,
	noOD : Real;
	jobAdditionalMins : Integer;
begin
	if self.estimatedTimeToCompleteMins &lt;&gt; null then
		return self.estimatedTimeToCompleteMins;
	endif;
	if self.myVoyage &lt;&gt; null then
		jobAdditionalMins:=self.myVoyage.myTerminal.getConfig(JobAdditionalTime).Integer;
	endif;
	crane := _crane;
	
	if crane = null then
		return null;
	endif;
	
	craneMoveRate:=self.getCraneMoveRate(crane);
	
	//epr par 25988 if the crane rate was saved but 0 needed to get the default
	defaultTargetRate:=crane.targetRatePH;
	if craneMoveRate = null then
		slodRate:=defaultTargetRate;
		sludRate:=defaultTargetRate;
		tlodRate:=defaultTargetRate;
		tludRate:=defaultTargetRate;
		ovrDimRate:=defaultTargetRate;
	else
		slodRate:=craneMoveRate.ratePerHourSLOD;
		if slodRate = 0 then
			slodRate:=defaultTargetRate;
		endif;
		sludRate:=craneMoveRate.ratePerHourSLUD;
		if sludRate = 0 then
			sludRate:=defaultTargetRate;
		endif;
		tlodRate:=craneMoveRate.ratePerHourTLOD;
		if tlodRate = 0 then
			tlodRate:=defaultTargetRate;
		endif;
		tludRate:=craneMoveRate.ratePerHourTLUD;
		if tludRate = 0 then
			tludRate:=defaultTargetRate;
		endif;
		ovrDimRate:=craneMoveRate.ratePerHourOD;
		if ovrDimRate = 0 then
			ovrDimRate:=defaultTargetRate;
		endif;
	endif;
	
	isOnDeck:=self.ordinalDeck = DeckOnDeck;
	

	noSLOD:=0;
	noSLUD:=0;
	noTLOD:=0;
	noTLUD:=0;
	noOD  :=0;
	//count number of lifts
	foreach wle in self.workListEntries do
		if self.actualStartTs &lt;&gt; null then
			if wle.status = WLE_COMPLETED then
				continue;
			endif;
		endif;
		if wle.myTrackedItem &lt;&gt; null and wle.myTrackedItem.isOverDimensions then
			noOD := noOD + 1;
		elseif wle.CM_VoyageWLE.isTwinLift then
			if isOnDeck then
				noTLOD:=noTLOD + 0.5;
			else
				noTLUD:=noTLUD + 0.5 ;
			endif;
		else
			if isOnDeck then
				noSLOD:=noSLOD + 1;
			else
				noSLUD:=noSLUD + 1;
			endif;
		endif;	
	endforeach;
	
	//check so we don't get div by zero error;
	if noSLOD &lt;&gt; 0 and slodRate &lt;&gt; 0 then
		rate := rate + (60/(slodRate/noSLOD)); 
	endif;
	
	if noSLUD &lt;&gt; 0 and sludRate &lt;&gt; 0 then
		rate := rate + (60/(sludRate/noSLUD)); 
	endif;
	
	if noTLOD &lt;&gt; null and tlodRate &lt;&gt; 0 then
		rate := rate + (60/(tlodRate/noTLOD)); 
	endif;
	
	if noTLUD &lt;&gt; null and tludRate &lt;&gt; 0 then
		rate := rate + (60/(tludRate/noTLUD)); 
	endif;
	
	if noOD &lt;&gt; null and ovrDimRate &lt;&gt; 0 then
		rate := rate + (60/(ovrDimRate/noOD)); 
	endif;

	return rate.Integer  + jobAdditionalMins; 
	
epilog

end;</source>
        <Parameter name="_crane" type="CM_Crane"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getEstJobTimeUsingWPRates" id="c7793e59-188d-40f9-9613-7a47828b9ef1">
