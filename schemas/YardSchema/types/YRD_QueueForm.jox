    <JadeMethod name="displayQueuedMachinesForQueue" id="16630f93-c651-45c9-a4ce-099d26306f15">
        <source>displayQueuedMachinesForQueue(_selectedQueue : CM_RadioTelemetryQueue) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2011	#cnwdz2	 27747
