    <JadeMethod name="addOneMessageTranslation" id="dedcd241-59d3-470b-8e3d-2c508e67857b">
        <source>addOneMessageTranslation();
/*
Purpose:			

Date		Who		Reason
27 October 2021	navab1	TFS 51853
*/
vars
	transAgent 	: CM_TranslationAgent;
	tmpArray : StringArray;
	err : Integer;
begin
	app.initialize();


	create transAgent transient;
