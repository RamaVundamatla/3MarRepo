    </JadeMethod>
    <JadeMethod name="loadDetails" id="9fa17b3e-6276-40ff-8afd-52f0e3b6e058">
        <updating/>
        <source>loadDetails() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 April 2011	cnwer1	Initial creation

*/

vars
	parentObject : CM_Object;
	allStateData : CM_StateDataDict;
	value 		: Any;
	roroDeckLabelPrefix,
	roroLaneLabelPrefix,
	roroRotatedLabel,
	roroSubDeckLabelPrefix	:String;
	roroAutoGenerateStartEnd,
	roroLaneNumberLength,
	roroLocationNumberLength	: Integer;
	roroLaneCodeIsZeroFilled ,
	roroOOTLS,
	roroGCS,
	roroLocationCodeIsZeroFilled: String;
	roroLinMeterWidth,
	roroLocnWidth, roroLocnLength, roroLocnGap : Decimal[12,2];
	roroLaneWidth, roroLaneLength, roroLaneGap : Decimal[12,2];
begin
	
	
	if self.myVessel  &lt;&gt; null then
		self.caption:=self.caption &amp; " - " &amp; app.getErrorString(Vessel) &amp; " " &amp; self.myVessel.code;
		allStateData:= self.myVessel.allStateData;
		if allStateData = null or allStateData.size = 0 then
			allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
		endif;
	else
		self.caption:=self.caption &amp; " - " &amp; app.getErrorString(System_GC);
		allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
	endif;
	
	
	global.getExtraData(allStateData,RoRoDeckLabelPrefix,roroDeckLabelPrefix);
	global.getExtraData(allStateData,RoRoAutoGenerateStartEnd,roroAutoGenerateStartEnd);
	global.getExtraData(allStateData,RoRoLaneCodeIsZeroFilled,roroLaneCodeIsZeroFilled);
	global.getExtraData(allStateData,RoRoLaneLabelPrefix,roroLaneLabelPrefix);
	global.getExtraData(allStateData,RoRoLaneNumberLength,roroLaneNumberLength);
	global.getExtraData(allStateData,RoRoLocationCodeIsZeroFilled,roroLocationCodeIsZeroFilled);
	global.getExtraData(allStateData,RoRoLocationNumberLength,roroLocationNumberLength);
	global.getExtraData(allStateData,RoRoRotatedLabel,roroRotatedLabel);
	global.getExtraData(allStateData,RoRoSubDeckLabelPrefix,roroSubDeckLabelPrefix);
	global.getExtraData(allStateData,RoRoOutOfTwistLockSuffix,roroOOTLS);
	global.getExtraData(allStateData,RoRoGeneralCargoSuffix,roroGCS);
	
	
	self.txtDeckPre.text:=roroDeckLabelPrefix;
	self.txtLanePre.text:=roroLaneLabelPrefix;
	self.txtRotatedLabel.text:=roroRotatedLabel;
	self.txtSubDeckPre.text:=roroSubDeckLabelPrefix;
	self.txtlLaneNumLen.text:=roroLaneNumberLength.asStringJMT;
	self.txtlLocNumLen.text:=roroLocationNumberLength.asStringJMT;
	self.chklLaneCodeZero.value:=roroLaneCodeIsZeroFilled.Boolean;
	self.chklLocCodeZero.value:=roroLocationCodeIsZeroFilled.Boolean;
	self.cmbAutoGen.setIndexForItemData(roroAutoGenerateStartEnd);
	self.txtOOTLS.text := roroOOTLS;
	self.txtGCS.text := roroGCS;

	global.getExtraData(allStateData,RoRoLaneWidth,roroLaneWidth);self.txtLaneWidth.text := roroLaneWidth.asStringJMTWithPrecision(1,false);
	global.getExtraData(allStateData,RoRoLaneLength,roroLaneLength);self.txtLaneLength.text := roroLaneLength.asStringJMTWithPrecision(1,false);
	global.getExtraData(allStateData,RoRoLaneGap,roroLaneGap);self.txtLaneGap.text:= roroLaneGap.asStringJMTWithPrecision(1,false);
	global.getExtraData(allStateData,RoRoLocationWidth,roroLocnWidth);self.txtContPosWidth.text := roroLocnWidth.asStringJMTWithPrecision(1,false);
	global.getExtraData(allStateData,RoRoLocationLength,roroLocnLength);self.txtContPosLength.text := roroLocnLength.asStringJMTWithPrecision(1,false);
	global.getExtraData(allStateData,RoRoLocationGap,roroLocnGap);self.txtContPosGap.text := roroLocnGap.asStringJMTWithPrecision(1,false);
	//global.getExtraData(allStateData,RoRoLinearMeteringWidth,roroLinMeterWidth);self.txtLinMeterWidth.text := roroLinMeterWidth.asStringJMTWithPrecision(2,false);
	
	self.txtDeckPre.setFocus();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="02786fe4-b2bf-459b-802d-dac43eb9d154">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 April 2011	cnwer1	Initial creation

*/

vars
	contl : Control;
	idx : Integer;
begin
	inheritMethod();
	
	self.myAssistant.comboBoxROROAutoGen(self.cmbAutoGen);
	self.loadDetails;
	
	// TFS 2101 CNWAB1
	if not app.myCurrentUserCan(null, self.permissionMaint) then
		self.btnSave.enabled := false;
		self.disableControlsByType(true,TextBox,false);
		self.disableControlsByType(true,ComboBox,false);
		self.disableControlsByType(true,CheckBox,false);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="skipToAttribute" id="8ad7b414-b8d3-47ec-8409-53e47c105e29">
        <updating/>
        <source>skipToAttribute(_attributeName: String; _shtName: String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 July 2012	cnwndl1	Initial creation

*/

vars

	index : Integer;
	control : Control;
	tmpSheet : CMUI_Sheet;
	folder : Folder;

begin

	foreach index in 1 to self.controlCount do
		control := self.controls(index);
		if control.isKindOf( CMUI_Sheet ) then
			tmpSheet := control.CMUI_Sheet;
		else
			continue;
		endif;
		if _shtName &lt;&gt; tmpSheet.caption then
			continue;
		endif;
		folder := tmpSheet.parent.Folder;
		folder.topSheet := tmpSheet;
	endforeach;

epilog

end;</source>
        <Parameter name="_attributeName" type="String"/>
        <Parameter name="_shtName" type="String"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="f67eb506-38b4-4a0c-aee1-5b72399d098f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016236, locale);
	btnCancel.translateCaption(Xlat_0016237, locale);
	btnSave.translateCaption(Xlat_0016238, locale);
	lbAutoGen.translateCaption(Xlat_0016239, locale);
	lblContPosGap.translateCaption(Xlat_0016240, locale);
	lblContPosLength.translateCaption(Xlat_0016241, locale);
	lblContPosWidth.translateCaption(Xlat_0016242, locale);
	lblDeckPre.translateCaption(Xlat_0016243, locale);
	lblGCS.translateCaption(Xlat_0016919, locale);
	lblLabels.translateCaption(Xlat_0016244, locale);
	lblLaneCodeZero.translateCaption(Xlat_0016245, locale);
	lblLaneGap.translateCaption(Xlat_0016246, locale);
	lblLaneLength.translateCaption(Xlat_0016247, locale);
	lblLaneNumLen.translateCaption(Xlat_0016248, locale);
	lblLanePre.translateCaption(Xlat_0016249, locale);
	lblLaneWidth.translateCaption(Xlat_0016250, locale);
	lblLocCodeZero.translateCaption(Xlat_0016251, locale);
	lblLocNumLen.translateCaption(Xlat_0016252, locale);
	lblOOTLS.translateCaption(Xlat_0016920, locale);
	lblRotatedLabel.translateCaption(Xlat_0016253, locale);
	lblSizes.translateCaption(Xlat_0016254, locale);
	lblSubDeckPre.translateCaption(Xlat_0016255, locale);
	shtLocnLabels.translateCaption(Xlat_0016256, locale);
	shtLocnSize.translateCaption(Xlat_0016257, locale);
end;</source>
    </JadeMethod>
</GUIClass>
