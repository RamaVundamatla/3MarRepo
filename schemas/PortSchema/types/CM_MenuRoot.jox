    <ExplicitInverseRef name="allMenuUserItemsWithAMenuItem" id="9e271641-23d1-407c-b9c3-8a64b89ac232">
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_MenuUserItemDictByMenuItem"/>
