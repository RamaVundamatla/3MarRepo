    <JadeMethod name="setControlsForAddEdit" id="ba6bad4d-f896-4170-8dae-b87ea1cf6c86">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:		05 August 2003 by cnwsb1
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
02 Feb 2012	cnwkpd1	PAR #28906 - Speed up performance of form load and edit
	
*/

vars
	extractFormat : Integer;
	isEnabled : Boolean;

begin
	inheritMethod();

	self.tblExtractDef.userInputEnabled := true;
	self.tblExtractClass.userInputEnabled := true;
	self.mulFeatures.userInputEnabled := true;
	self.mulObjects.userInputEnabled := true;
	
	extractFormat := self.getExtractFormat;

	self.shtExtractHist.enabled := false;
	self.shtExtractObject.enabled := false;
	self.btnExtDefAll.enabled := false;
	self.btnExtDefChg.enabled := false;
	self.btnExtractUpTo.enabled := false;
	self.btnViewChgTrkMon.enabled := false;
	self.cmbSelectedClass.enabled := false;
	//self.btnCheck.enabled := false;
	
	if self.mode = Mode_Add then
		if self.myProxyObject = null then
			create self.myProxyObject as CM_DataDumpExtractDef transient;
		endif;
		self.comboExtractFormatBuild();
		self.populateExtractClass();
		self.setNavigatorHeading(null);
		
		tblExtractDef.clearValues;
		tblExtractDef.showHideRowsByViewName(self.ViewXML,
				CM_EntryTable.ShowHideRows, false); //ShowRowsOnly or ShowHideRows or HideRowsOnly
		setRowState(tblExtractDef, ETRow_Description, true);
		tblExtractDef.adjustHeight(1000);
		shtExtractDef.caption := "New Extract Definition";
	
		self.tblExtractDef.moveFirst;
		self.tblExtractDef.setFocus;
		self.shtExtractClass.enabled := false;
		self.shtExtFeature.enabled := false;
	else
		self.fldInput.topSheet := self.shtExtractDef;		// PAR #28906
		if self.myCurrentObject &lt;&gt; null and 
		   self.myCurrentObject.CM_DataDumpExtractDef.extractFormat = CM_DataDumpExtractDef.FmtSQLNative then
			self.shtExtractClass.enabled := false;
			self.shtExtFeature.enabled := false;
		endif;
		self.comboExtractFormatBuildForEdit(extractFormat); //25/06/2010 cnwdz2 24526
		self.showThumbnailData(self.myProxyObject);
	endif;
	self.chkExtractAllBGP.enabled := false;  	//JIRA 23326
	//25 Aug 2021	NDL	TFS 51632 - Don't want to be on the password field
	// when we go into add/edit mode, it causes us to bypass the password form.
	if self.tblExtractDef.row = self.tblExtractDef.getRowByName( ETRow_EdbPassword ) then
		self.tblExtractDef.row := self.tblExtractDef.row + 1;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="c0b130e8-b3ed-4e05-9ea0-eee3912734e5">
        <updating/>
        <source>setControlsForView() updating;
// ---------------------------------------------------------------------------
// Created:		05 August 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	inheritMethod();

    self.allDataDumpClassProxiesDeleted.purge();
	
	self.btnExtDefAll.enabled := true;
	self.btnExtDefChg.enabled := true;
	self.btnExtractUpTo.enabled := true;
	self.btnViewChgTrkMon.enabled := true;

	self.tblExtractDef.userInputEnabled := false;
	self.tblExtractHist.userInputEnabled := false;	
	self.tblExtractClass.userInputEnabled := false;
	self.mulFeatures.userInputEnabled := false;
	self.mulObjects.userInputEnabled := true; // should be false; set to true for quick testing

	self.shtExtractHist.enabled := true;
	self.shtExtractObject.enabled := true;
	self.shtExtractClass.enabled := true;
	self.shtExtFeature.enabled := true;
	self.cmbSelectedClass.enabled := true;
	//self.btnCheck.enabled := true;
	self.chkExtractAllBGP.value := false;		//JIRA 23326
	self.chkExtractAllBGP.enabled := false;  	//JIRA 23326
end;</source>
    </JadeMethod>
    <JadeMethod name="setMyDataClass" id="cc8635b0-da9f-4325-a975-51269867a767">
        <updating/>
        <source>setMyDataClass() updating;
// ---------------------------------------------------------------------------
// Created:     01 August 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.myDataClass := CM_DataDumpExtractDef;
end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="6b7711f5-1b2c-430f-b6c5-3a23c8e53f65">
        <updating/>
        <source>setProxy():Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 April 2010	#cnwdz2	 

*/

vars
	descr 				: String;
	extractFormat 		: Integer;
	isActive, 
	createSQLStatements : Boolean;
	fileFolderName 		: String;
	edbConnection, 
	edbPassword, 
	edbServer, 
	edbUserName,
	edbMachineDSN 		: String;
	edbTerminalName     : String;
	oidFormat           : Integer;
	oidColumnName       : String;
	sqlDatabaseName     : String;
	sqlServerVersion    : String;
	terminal 			: CM_Terminal;
	definitionModified  : Boolean;
	useSQLControlTable  : Boolean;
	alertLimit          : Integer;
	ignoreUser 			: CM_User;	//07 Jan 2014	NDL	Par 33264
begin			
	if not self.getProxyObject() then
		return false;
	endif;
	
	descr := self.tblExtractDef.getValueByName(ETRow_Description).String;
	extractFormat := self.getExtractFormat;
	oidFormat     := self.getOIDFormat();
	oidColumnName := self.tblExtractDef.getValueByName(ETRow_OidColumnName).String;
	isActive := self.tblExtractDef.getValueByName(ETRow_IsActive).Boolean;
	createSQLStatements := self.tblExtractDef.getValueByName(ETRow_CreateSQLStatements).Boolean;
	fileFolderName := self.tblExtractDef.getValueByName(ETRow_FileFolderName).String;
	edbConnection := self.tblExtractDef.getValueByName(ETRow_EdbConnectionString).String;
	edbMachineDSN := self.tblExtractDef.getValueByName(ETRow_EdbMachineDSN).String;
//	edbPassword := self.tblExtractDef.getValueByName(ETRow_EdbPassword).String;
	edbPassword := self.enteredPassword;
	edbServer := self.tblExtractDef.getValueByName(ETRow_EdbServerName).String;
	edbUserName := self.tblExtractDef.getValueByName(ETRow_EdbUserName).String;
	sqlServerVersion := self.tblExtractDef.getValueByName(ETRow_SqlServerVersion).String;
	edbTerminalName := self.tblExtractDef.getValueByName(ETRow_Terminal).String;
	alertLimit := self.tblExtractDef.getValueByName(ETRow_AlertLimit).Integer;
	terminal := app.getTerminalByName(edbTerminalName);
	
	if extractFormat = CM_DataDumpExtractDef.FmtSQLNative then
		fileFolderName := self.tblExtractDef.getValueByName(ETRow_BulkDataLoadFileFolder).String;
		ignoreUser := self.cmbIgnoreDelUser.listObject.CM_User;	//07 Jan 2014	NDL	Par 33264
	endif;
	
	if self.myCurrentObject &lt;&gt; null then
		definitionModified := self.myCurrentObject.CM_DataDumpExtractDef.definitionModified;
	endif;
	
	self.myProxyObject.CM_DataDumpExtractDef.setProxy(descr, extractFormat, isActive, createSQLStatements, fileFolderName,
			edbConnection, edbPassword, edbServer, edbUserName, edbMachineDSN, 
			oidColumnName, oidFormat, sqlDatabaseName, sqlServerVersion, definitionModified,
			useSQLControlTable, terminal, alertLimit,
			ignoreUser	//_ignoreDeletesFromUser : CM_User	//07 Jan 2014	NDL	Par 33264
			);

	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setRowState" id="302a8ab3-20f1-4f08-bce8-98fbdd3fade2">
        <source>setRowState(_table : CM_EntryTable input; _constant : String; _enable : Boolean);
// ---------------------------------------------------------------------------
// Created:		05 August 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	if _enable then
		_table.enableRowByName(_constant);
	else
		_table.disableRowByName(_constant);
	endif;
end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="_constant" type="String"/>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupContextMenuItems" id="be895b75-7df1-4acd-b853-bdd5a5cf957a">
        <updating/>
        <source>setupContextMenuItems(conwin: Window input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 May 2010	#cnwdz2	 

*/

vars
	mnuChild : MenuItem;
begin
	inheritMethod(conwin);
	
	self.mnuSQLNativeLoadDef.visible := true;
	self.mnuSQLNativeSeparator.visible := true;
	if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.CM_DataDumpExtractDef.extractFormat = CM_DataDumpExtractDef.FmtSQLNative then
		if self.tblData.row &gt; self.tblData.fixedRows then
			self.mnuSQLNativeExportDef.visible := true;
			self.mnuSQLNativeCopyDef.visible := true;			
		else
			self.mnuSQLNativeExportDef.visible := false;
			self.mnuSQLNativeCopyDef.visible := false;
		endif;
	else
		self.mnuSQLNativeExportDef.visible := false;
		self.mnuSQLNativeCopyDef.visible := false;
	endif;
	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuSQLNativeLoadDef.visible := false;
		self.mnuSQLNativeSeparator.visible := false;
		self.mnuSQLNativeExportDef.visible := false;
		self.mnuSQLNativeCopyDef.visible := false;			

	endif;
	
	self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuSQLNativeSeparator, false);
	self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuSQLNativeCopyDef, false);
	self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuSQLNativeExportDef, false);
	self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuSQLNativeLoadDef, false);	
epilog

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="036f5f09-0e15-47db-8bb5-0452e8eced4e">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;
// ---------------------------------------------------------------------------
// Created:		05 August 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin	
	self.populateExtractDef(obj);
	self.populateExtractHistory;
	self.populateExtractClass;
	if self.fldInput.topSheet = self.shtExtFeature then
		self.mySelectedClass := null;//make this method reselect the currently selected class
		self.doShtExtFeatureClick(self.cmbSelectedClass);
	elseif self.fldInput.topSheet = self.shtExtractObject then
		self.mySelectedClass := null;//make this method reselect the currently selected class
		self.doShtExtFeatureClick(self.cmbSctObjClass);
	endif;
	
	//27 Mar 2019	NDL	TFS 43873 - Make 'Select Object' sheet available for SQL, and XML.
	self.cmbSctObjClass.listIndex := -1;
	self.mulObjects.setAvailable(null, true);
	self.mulObjects.setSelected(null);
//	if self.myCurrentObject &lt;&gt; null and 
//	   self.myCurrentObject.CM_DataDumpExtractDef.extractFormat = CM_DataDumpExtractDef.FmtSQLNative then
//		self.shtExtractObject.visible := false;
//	else
//		self.shtExtractObject.visible := true;
//	endif;
	
	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(null, self.permissionMaint) then
		self.tblExtractDef.userInputEnabled := false;
		self.tblExtractClass.userInputEnabled := false;
		self.mulFeatures.userInputEnabled := false;
		self.mulObjects.userInputEnabled := false;
		
		self.shtExtractHist.enabled := false;
		self.shtExtractObject.enabled := false;
		self.btnExtDefAll.enabled := false;
		self.btnExtDefChg.enabled := false;
		self.btnExtractUpTo.enabled := false;
		self.btnViewChgTrkMon.enabled := false;
		self.cmbSelectedClass.enabled := false;
	
	endif;
	
end;</source>
        <Parameter name="obj" type="Object"/>
