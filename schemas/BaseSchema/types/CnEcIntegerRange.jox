<Class name="CnEcIntegerRange" id="2c68964b-db84-4fc9-aace-21552243fb87">
    <superclass name="CnEcValueRange"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
