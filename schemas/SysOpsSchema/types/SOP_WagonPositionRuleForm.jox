    <JadeMethod name="doMustSelectRule" id="3079226c-7107-4608-ab56-d498c61b2844">
        <source>doMustSelectRule( rule : CM_WagonPositionalRule );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2009	cnwndl1	Initial creation

*/

vars

begin

	if rule = null then
		app.msgBox(app.getErrorString(Please_select_wagon_posi_rule) ,app.getErrorString(Wagon_positional_rule) ,MsgBox_OK_Only + MsgBox_Information_Icon);
	endif;
	
epilog

