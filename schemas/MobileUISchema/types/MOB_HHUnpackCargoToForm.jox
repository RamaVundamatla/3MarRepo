    <JadeMethod name="clickLocationsBtn" id="25d5c71d-f2fa-4edf-90b0-ba5d1e41a792">
        <updating/>
        <source>clickLocationsBtn( _obj : Object ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2015	cnwndl1	Initial creation	Par 36132

*/

vars

begin

	if _obj &lt;&gt; null and _obj.isKindOf(CM_LocationsController) then
		self.txtLocation.text := _obj.CM_LocationsController.getFullId;
		
	else
		self.txtLocation.text := null;
		
	endif;
	
	self.txtLocation_lostFocus( self.txtLocation );

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doFindLocation" id="3145ffa2-633f-4ff1-b70c-eb9f63fd856c">
        <updating/>
        <source>doFindLocation() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

	idString : String;
	tmpFoundLC: CM_LocationsController;
	tmpFoundHeight : Integer;
	errMess : String;

begin

	idString := txtLocation.text.trimBlanks.toUpper;
	if idString = null or idString = lblLocation.caption.toUpper then
		self.myLocation := null;
		return;
	endif;
	
	self.myTerminal.findLocationFromString(idString, true, tmpFoundLC, tmpFoundHeight);
	
	if tmpFoundLC = null then
		errMess := app.getErrorString1(Location_NotFound, "'" &amp; idString &amp; "'");
	else
		
		if not tmpFoundLC.isYardLocation then
			errMess := app.getErrorString(Location_must_yard);
	//31 July 2014	NDL	Par 34665
	//	elseif tmpFoundLC.isVehicle then
	//		errMess := app.getErrorString(Location_Not_vehicle);
		elseif tmpFoundLC.isMachineController then	
			errMess := app.getErrorString(Location_must_yard);
		endif;
		
	endif;
	
	if errMess &lt;&gt; null then
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
		self.txtLocation.setFocus();
		self.myLocation := null;
		return;
	endif;
	
	self.myLocation := tmpFoundLC;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="64f0fba3-e83d-4705-bbda-55fce74b45fe">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation	Par 35604
29 Apr 2015	NDL	Par 36132 TFS 300 / 318

*/

vars

	stdLeft : Real;
	top : Real;
	stdWidth : Real;
	stdHeight : Real;
	width : Real;
	tabIndex : Integer;
	locationsSet : CM_LCSet;	//29 Apr 2015	NDL	Par 36132
	location : CM_LocationsController;	//29 Apr 2015	NDL	Par 36132
	heightFactor : Integer;	//29 Apr 2015	NDL	Par 36132
	buttonWidth : Real;	//29 Apr 2015	NDL	Par 36132
	menuButton : MOB_Button;	//29 Apr 2015	NDL	Par 36132
	index : Integer;	//29 Apr 2015	NDL	Par 36132
	buttonHeight : Integer;	//29 Apr 2015	NDL	Par 36132
	buttonTop : Integer;	//29 Apr 2015	NDL	Par 36132
	fm: CM_FutureMove;	//29 Apr 2015	NDL	Par 36132
	amountString : String; //17 Mar 2017	NDL	TFS 3775

begin

	self.setResizeableMarginAndFontSize();
	tabIndex := 4000;
	stdLeft :=  self.resizedMargin;
	top := self.resizedMargin;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	buttonHeight := self.btnOne.height.Integer;	//29 Apr 2015	NDL	Par 36132
	
	//29 Apr 2015	NDL	Par 36132
	if _initialSetup then
		self.txtCargoId.text := myUnpackCargoItem.id;
	endif;
	
	create locationsSet transient;
	location := myUnpackCargoItem.myPrimaryQueuedLocation;
	if location &lt;&gt; null then
		locationsSet.addNoDuplicates(location,false);
	endif;
	location :=  myUnpackCargoItem.myPrimaryPlannedLocation;
	if location &lt;&gt; null then
		locationsSet.addNoDuplicates(location,false);
	endif;
	foreach fm in myUnpackCargoItem.allPlannedFutureMoves do
		location := fm.getPrimaryLocation;
		if location &lt;&gt; null then
			locationsSet.addNoDuplicates(location,false);
		endif;
	endforeach;
	location :=  self.myMobileGenericAgent.myUnpackDefaultLocation;
	if location &lt;&gt; null then
		locationsSet.addNoDuplicates(location,false);
	endif;
	
	
	self.setUpLocations(locationsSet);
	
	if _initialSetup then
		self.lblUnpack.setAndIncrementTabIndex( tabIndex );
		self.lblUnpack.visible := true;
	endif;
	self.lblUnpack.move(	stdLeft,
							top,
							stdWidth,
							stdHeight );
							
	top := self.lblUnpack.top + self.lblUnpack.height + self.resizedMargin;
	if _initialSetup then
		self.txtCargoId.setAndIncrementTabIndex( tabIndex );
		self.txtCargoId.visible := true;
		self.txtCargoId.enabled := false;
	endif;
	self.txtCargoId.move(	stdLeft,
							top,
							stdWidth,
							stdHeight );
	
	top := self.txtCargoId.top + self.txtCargoId.height + self.resizedMargin;
	if _initialSetup then
		self.lblFrom.setAndIncrementTabIndex( tabIndex );
		self.lblFrom.visible := true;
	endif;
	self.lblFrom.move(	stdLeft,
							top,
							stdWidth,
							stdHeight );
	if _initialSetup then
		self.lblFrom.caption := "from " &amp; self.myUnpackContainer.id &amp; " to";
	endif;
								
	top := self.lblFrom.top + self.lblFrom.height + self.resizedMargin;
	
	if _initialSetup then
		self.txtLocation.text := null;
		if locationsSet.size = 1 then
			self.txtLocation.text := locationsSet.first.getFullId;
		elseif locationsSet.size &gt; 1 then
			self.frmLocations.setAndIncrementTabIndex( tabIndex );
			self.frmLocations.visible := true;
		endif;
		self.txtLocation_lostFocus( self.txtLocation );
	endif;
	
	if self.locationsSetSize &gt; 1 then
		heightFactor := self.locationsSetSize;
		if heightFactor &gt; 3 then
			heightFactor := 3;
		endif;
		self.frmLocations.move(	stdLeft,
								top,
								stdWidth,
								( ( buttonHeight + self.resizedMargin ) * heightFactor ) + ( self.resizedMargin * 2 ) 
								);
								
		buttonWidth := getButtonWidthSetScrollBar( self.locationsSetSize, self.frmLocations, buttonHeight, self.scrLocations );
		buttonTop := self.resizedMargin - 1;
		foreach index in 1 to self.locationsSetSize do
			menuButton := self.btnLocationsTemp.getControl( index ).MOB_Button;
			if menuButton &lt;&gt; null then
				menuButton.width := buttonWidth;
				menuButton.height := buttonHeight;
				menuButton.top := buttonTop;
				menuButton.fontSize := self.btnLocationsTemp.fontSize;	
				buttonTop := buttonTop + buttonHeight + self.resizedMargin;
			endif;
		endforeach;
		
		top := self.frmLocations.top + self.frmLocations.height + self.resizedMargin;
	else
		self.frmLocations.visible := false;
	endif;
	
	
	if _initialSetup then
		self.txtLocation.setAndIncrementTabIndex( tabIndex );
		self.txtLocation.visible := true;
	endif;
	self.txtLocation.move(	stdLeft,
							top,
							stdWidth,
							stdHeight );
							

	//epr par 34472 3/7/14
	if self.myUnpackCargoItem.myCargoType.isBreakBulkMulti then
		top := self.txtLocation.top + self.txtLocation.height + self.resizedMargin;
		if _initialSetup then
			//17 Mar 2017	NDL	TFS 3775
			amountString := self.getAmountString();
			if amountString &lt;&gt; null then
				self.lblQuantity.caption := app.getErrorString(CM_Quantity) &amp; " (" &amp; amountString  &amp; ")";
			else
				self.lblQuantity.caption := app.getErrorString(CM_Quantity);
			endif;
			self.lblQuantity.setAndIncrementTabIndex( tabIndex );
			self.lblQuantity.visible := true;
		endif;
		self.lblQuantity.move(	stdLeft,
								top,
								stdWidth,
								stdHeight );
		top := self.lblQuantity.top + self.lblQuantity.height + self.resizedMargin;
		if _initialSetup then
			self.txtQuantity.setAndIncrementTabIndex( tabIndex );
			self.txtQuantity.visible := true;
		endif;
		self.txtQuantity.move(	stdLeft,
								top,
								stdWidth,
								stdHeight );
		
		//09 Feb 2017	NDL	TFS 3002
		if _initialSetup then
			if self.myTerminal.getConfig(HhUnPackQtyPreFill).Boolean then
				self.txtQuantity.text := self.myUnpackCargoItem.totalQuantity.String;
			endif;
		endif;
	
	endif;
	//epr par 34472 3/7/14
	if self.myUnpackCargoItem.myCargoType.isBulkMulti then
		
		top := self.txtLocation.top + self.txtLocation.height + self.resizedMargin;
		if _initialSetup then
			self.lblQuantity.setAndIncrementTabIndex( tabIndex );
			self.lblQuantity.visible := true;
		endif;
		self.lblQuantity.move(	stdLeft,
								top,
								stdWidth,
								stdHeight );
		if _initialSetup then
			if self.myUnpackCargoItem.myCargoType.isBulkByWeight then
				self.lblQuantity.caption := app.getErrorString(CM_Weight);
			elseif self.myUnpackCargoItem.myCargoType.isBulkByVolume then
				self.lblQuantity.caption := app.getErrorString(CM_Volume);
			endif;
		endif;
														
		top := self.lblQuantity.top + self.lblQuantity.height + self.resizedMargin;
		if _initialSetup then
			self.tblWeight.setAndIncrementTabIndex( tabIndex );
			self.tblWeight.visible := true;
		endif;
		self.tblWeight.move(	stdLeft,
								top,
								stdWidth,
								stdHeight + self.resizedMargin // extra height to allow combo to be seen in measurement control
								);
		if _initialSetup then
			//09 Feb 2017	NDL	TFS 3002
			if self.myTerminal.getConfig(HhUnPackQtyPreFill).Boolean then
				if self.myUnpackCargoItem.myCargoType.isBulkByWeight then
					self.setBulkWeightVolumeFields( self.myUnpackCargoItem, self.tblWeight, null, self.myUnpackCargoItem.totalWeight );
				elseif self.myUnpackCargoItem.myCargoType.isBulkByVolume then
					self.setBulkWeightVolumeFields( self.myUnpackCargoItem, self.tblWeight, null, self.myUnpackCargoItem.totalVolume );
				endif;
			else
				self.setBulkWeightVolumeFields( self.myUnpackCargoItem, self.tblWeight, null, 0.00 );
			endif;
		endif;
	endif;


	inheritMethod(_initialSetup);

epilog

	delete locationsSet;

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUnpack" id="0df7089f-d37b-43fa-8318-bb010f844dc1">
        <updating/>
        <source>doUnpack():Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars
	weight : Decimal [16,4];
	volume : Decimal [16,4];
begin
	//epr par 34472 3/7/14
	if self.myUnpackCargoItem.isBulkByWeight then
		weight := tblWeight.getConvertedValue();
	elseif self.myUnpackCargoItem.isBulkByVolume then
		volume := tblWeight.getConvertedValue();
		weight := volume * self.myUnpackCargoItem.getDensity;
	endif;
	
	
	return self.myMobileGenericAgent.doUnpackCargo(	self.myUnpackCargoItem,self.myLocation,txtQuantity.text.Integer,weight,null);
														
epilog
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAmountString" id="32624bbe-cb72-4cd0-9611-729d752d4d84">
        <source>getAmountString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2017	cnwndl1	Initial creation	TFS 3775

*/

vars

	amountString : String;
	measureType : CM_MeasurementType;

begin

	if self.myUnpackCargoItem = null then
		return null;
	endif;

	if self.myUnpackCargoItem.myCargoType.isBreakBulkMulti then
		amountString := "x" &amp; self.myUnpackCargoItem.totalQuantity.String;
	elseif self.myUnpackCargoItem.myCargoType.isBulkByWeight then
		amountString := self.myUnpackCargoItem.getDefaultMeasureTotalWeight;
		measureType := self.myUnpackCargoItem.myCargoType.getMeasurementTypeFor( Type_Weight, true );
		amountString := amountString &amp; measureType.shortName;
	elseif self.myUnpackCargoItem.myCargoType.isBulkByVolume then
		amountString := self.myUnpackCargoItem.getDefaultMeasureTotalVolume;
		measureType := self.myUnpackCargoItem.myCargoType.getMeasurementTypeFor( Type_Volume, true );
		amountString := amountString &amp; measureType.shortName;
	endif;
	
	return amountString;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="2bc5e691-3ffd-49c8-a11e-74b19e87bdb4">
        <updating/>
        <source>handleBtnOne() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

begin
	
	if doUnpack() then
		self.doBackButtonClick();
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
