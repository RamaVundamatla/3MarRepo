    <JadeMethod name="checkCanCancelRemove" id="68c685b6-e50f-4c41-a031-9950281b2160">
        <source>checkCanCancelRemove();
/*
Purpose:			

Date		Who		Reason
13 November 2023	navab1	 CR 60425 TASK 60828 
*/

vars
	ti : CM_TrackedItem;
	custDocMain,custDocOther : CM_CustomDocument;
	canShow : Boolean;
begin
	self.btnCancellation.enabled := true;
	self.btnRemove.enabled := true;

	
	
	if not app.myCurrentUserCan(self.myTerminal, PmInvCustomDocRemove) then
		self.btnRemove.enabled := false;
	endif;
	
	if not app.myCurrentUserCan(self.myTerminal, PmInvCustomDocCancel) then
		self.btnCancellation.enabled := false;
	endif;
	
	custDocMain := self.tblData.accessRow(self.tblData.row).itemObject.CM_CustomDocument;
	if custDocMain = null then
		app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	
	
	if custDocMain &lt;&gt; null then	
		canShow:= true;
		foreach ti in custDocMain.allTrackedItems discreteLock do
			custDocOther:= ti.allCustomDocuments.getLastActive(); // ### TFS CR 60425 TASK 60828 13NOV2023 NAVAB1
			if custDocOther &lt;&gt; null
			and custDocOther &lt;&gt; custDocMain then
				canShow := false;
				break;
			endif;
		endforeach;
		
		if self.btnCancellation.enabled then // ### TFS BUG 61884 23FEB2024 NAVAB1 if this button is not enabled the user does not have permission
			self.btnCancellation.enabled := canShow;
		endif;
		if self.btnRemove.enabled then // ### TFS BUG 61884 23FEB2024 NAVAB1 if this button is not enabled the user does not have permission
			self.btnRemove.enabled := canShow;
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
