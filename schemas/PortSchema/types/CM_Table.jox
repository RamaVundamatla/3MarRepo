    <JadeMethod name="addToSelectedCells" id="dd9d787a-ad62-48ef-8621-17a9599a6348">
        <updating/>
        <source>addToSelectedCells(r: Integer; c: Integer) updating;

constants
	TWO_BYTE_SHIFT = 2^16;
vars
	hashInt:   Integer;
begin
	if not readOnly then
		if selectRows then
			hashInt := r;
		else
			hashInt := c * TWO_BYTE_SHIFT + r;
		endif;
		selectedCells.add(hashInt);
	endif;
end;</source>
        <Parameter name="r" type="Integer"/>
        <Parameter name="c" type="Integer"/>
    </JadeMethod>
