    <JadeMethod name="validateMe" id="a229b47f-fb60-4da4-971f-106d4fc6c46e">
        <source>validateMe();
/*
Date		Who		Reason
20 May 2009	cnwar2	Initial creation
29/02/2012	cnwcs5	par 29158 - EDI Booking Cutoff.  Validate criteriaType/defaultRelativeTo
17/03/2012	cnwcs5	par 29257 - conversion of extension object properties
*/
vars
	recCutoff 	: CM_ReceivalCutoffTermDef;
	type, def	: Integer;
begin
	if self.code = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Code', null, null);
		app.raiseCMException(Input_required_field_code, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Description', null, null);
		app.raiseCMException(Input_required_field_Desc, null, null);
	endif;
	
	def := self.defaultRelativeTo;
	
	if def = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Default Relative To', null, null);
		app.raiseCMException(Input_required_field_defltRel, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.sortKey = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Sort Key', null, null);
		app.raiseCMException(Input_required_field_sortKey, null, null);
	endif;
	
	type := self.criteriaType;	// par 29257 - march 2012
	
	if type &lt;&gt; CM_ReceivalCutoffTermDef.CriteriaType_CARGO and
		type &lt;&gt; CM_ReceivalCutoffTermDef.CriteriaType_EDI then
		// criteria type is not valid - GUI should prevent this 
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Criteria type is not CARGO or EDI');
	endif;
	
	if type = CM_ReceivalCutoffTermDef.CriteriaType_CARGO and
		def &lt;&gt; null and 
		def &lt;&gt; DefaultRelativeTo_Arrival and
		def &lt;&gt; DefaultRelativeTo_Departure then
		// invalid value for default relative to - GUI should stop this
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Default relative to must be ' &amp; 
											DefaultRelativeTo_Arrival_Str &amp; ' or ' &amp; 
											DefaultRelativeTo_Depart_Str);
	endif;
	
	foreach recCutoff in self.myTerminal.allReceivalCutoffDefs do
		if self.sortKey = recCutoff.sortKey and self.code &lt;&gt; recCutoff.code then
				app.raiseCMException3(ERR_DuplicateItemWith, 'Receival Cutoff', 'Sort Key', self.sortKey.asStringJMT, null, null); 
			break;
		endif;
	endforeach;
	
	if self.defaultEarliestReceival &lt;&gt; 0 and 
		self.defaultCutoff &lt;&gt; 0 and 
		self.defaultEarliestReceival &lt;= self.defaultCutoff then
		//app.raiseCMException2(Must_greater_than, 'Default Earliest Receival', 'Default Cutoff', null, null); //04/03/2025	navkc1 JIRA Story MTN-34227
		//app.raiseCMException(EarlyReceiveGreaterCutOff, null, null); //04/03/2025	navkc1 JIRA Story MTN-34227
		app.raiseCMException1(EarlyReceiveGreaterCutOff, self.code, null, null); //08/04/2025	navkc1 JIRA Story MTN-34470
	endif;
	
	//04/03/2025	navkc1 JIRA Story MTN-34227 
	if 	self.defaultCutoffPN &lt;&gt; null and
		self.defaultEarliestReceivalPN &lt;&gt; null and
		self.defaultEarliestReceivalPN &lt;= self.defaultCutoffPN then
		//app.raiseCMException(EarlyReceivePNGreaterCutOffPN, null, null); //04/03/2025	navkc1 JIRA Story MTN-34227
		app.raiseCMException1(EarlyReceivePNGreaterCutOffPN, self.code, null, null); //08/04/2025	navkc1 JIRA Story MTN-34470
	endif;
end;</source>
    </JadeMethod>
</Class>
