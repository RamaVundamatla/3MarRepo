    <JadeMethod name="setControlsForAddEdit" id="96ef8a22-ea4c-44bf-a8f0-29c717565a4c">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;
	pxy		: CM_PINObjectDefaultEmail;
	
begin
  
    theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.mulSelect1.userInputEnabled := true;
	if theForm.mode = theForm.Mode_Add then
		theForm.cancelAddMode();
		app.raiseUnexpectedProgramError(class.name, method.name, 'Add mode not valid for this table');
	else
		pxy := theForm.myProxyObject.CM_PINObjectDefaultEmail;
		self.showThumbnail(pxy);
		theForm.tblInput1.disableRowByName(ETRow_Type);
		theForm.tblInput1.disableRowByName(ETRow_Name);
		theForm.tblInput1.disableRowByName(ETRow_ObjectType);
		//theForm.tblInput1.hideRowByName(ETRow_IsPrenote, true);
		
		if pxy.isPrenote then
			theForm.tblInput1.showRowByName(ETRow_AttachCartersNote, true);
		else
			theForm.tblInput1.hideRowByName(ETRow_AttachCartersNote, true);
		endif;

	endif;

end;
</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="05984348-8476-41e4-a07a-e9008657ad6b">
        <updating/>
        <source>setCtrlsForView() updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin
  	inheritMethod();
    theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.tblInput1.hideRowByName(ETRow_IsPrenote, true);
	theForm.tblData.userInputEnabled := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDefaults" id="522fb4c3-033c-4971-a4c0-f5e6e8d70929">
        <source>setupThumbnailDefaults();
// ---------------------------------------------------------------------------
// Created:     22 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();

	//users can never add or delete these
	self.myForm.allowAdd 	:= false;
	self.myForm.allowDelete := false;
	
	//tidies the buttons up
	self.myForm.frmToolbar.positionToolbarControls();

	

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="cd903e63-0719-4b90-a0d8-714714bc23bb">
        <updating/>
        <source>setupThumbnailDetails() updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;
begin
 
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_PINEmailTable);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Type, false);

//	theForm.shtTblInput1.caption := 'Details';	// cnwrl1 28/07/2009 PAR 20349
	theForm.shtTblInput1.caption := app.getString( Details );
	theForm.initTblInput(theForm.tblInput1, ETDef_PINEmailMaint);
	theForm.shtTblInput1.visible := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="d8310334-eba7-4f46-a993-8732ce779f12">
        <updating/>
        <source>showThumbnail(pEmailDefault: CM_PINObjectDefaultEmail) updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	theForm 		: SOP_TableMaintForm;
begin
  
  	theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Type, pEmailDefault.type);
	theForm.tblInput1.setValueByName(ETRow_Name,	pEmailDefault.name);
	theForm.tblInput1.setValueByName(ETRow_ObjectType,	pEmailDefault.objectType);
	theForm.tblInput1.setValueByName(ETRow_SubjectLine,	pEmailDefault.subjectLine);
	theForm.tblInput1.setValueByName(ETRow_Message,	pEmailDefault.message);
	theForm.tblInput1.setValueByName(ETRow_IsPrenote,	pEmailDefault.isPrenote);
	theForm.tblInput1.setValueByName(ETRow_AttachCartersNote,	pEmailDefault.attachCartersNote);
	theForm.tblInput1.setValueByName(ETRow_Enabled,	pEmailDefault.enabled);
	// cnwrl1 29/07/2009 PAR 20349 - start of coding
	theForm.tblInput1.setValueByName( ETRow_CopyTo, pEmailDefault.copyTo );
	theForm.tblInput1.setValueByName( ETRow_SendToCarrier, pEmailDefault.sendToCarrier );
	theForm.tblInput1.setValueByName( ETRow_SendToConsignee, pEmailDefault.sendToConsignee );
	// cnwrl1 29/07/2009 PAR 20349 - end of coding
	
	if pEmailDefault.isPrenote then
		theForm.tblInput1.showRowByName(ETRow_AttachCartersNote, true);
	else
		theForm.tblInput1.hideRowByName(ETRow_AttachCartersNote, true);
	endif;

	theForm.myAssistant.multiSelectEntityFields(theForm.mulSelect1, pEmailDefault.entTableName, pEmailDefault.allIncludedFields);
	
end;
</source>
        <Parameter name="pEmailDefault" type="CM_PINObjectDefaultEmail"/>
    </JadeMethod>
</Class>
