    <JadeMethod name="cmbReserveDetail_click" id="fea52d91-0e37-4965-9b03-c5ce5eb12a45">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbReserveDetail_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 September 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
03 May 2023 		navhl20	ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]
11 July 2024		navpw1	TFS: 61525 (61527) - Added setTblMaxWeight to setup the Max Weight Field
04 Dec	2024		navcs2	MTN-14819 EUP | Release By Weight - VBS Weight Limit Dev - Thin Client - Extra Changes
*/
vars 
	reserveDetail	: CM_ReserveDetail;			// 04 Dec	2024		navcs2	MTN-14819
begin
	if combobox.listCount &gt; 1 then								//03.5.2023 navhl20 #57402[57471]
		self.selectObjInTable();
	endif;
	self.setTblWeight();
	self.setTblMaxWeight(combobox.listObject.CM_ReserveDetail);	// ### TFS 61525 (61527) 11Jul2024 NAVPW1
	if self.cmbReserveDetail.getCurrentItemObject.isKindOf(CM_ReserveDetail) then			// 04 Dec	2024		navcs2	MTN-14819
		reserveDetail := self.cmbReserveDetail.getCurrentItemObject.CM_ReserveDetail;		// 04 Dec	2024		navcs2	MTN-14819
		if reserveDetail.byTypeByWeight then  												// 04 Dec	2024		navcs2	MTN-14819
			self.tblWeight.visible := false;												// 04 Dec	2024		navcs2	MTN-14819
			self.lblWeight.visible := false;												// 04 Dec	2024		navcs2	MTN-14819
		endif;																				// 04 Dec	2024		navcs2	MTN-14819
	endif;
	self.alignTable();											//03.5.2023 navhl20 #57402[57471]
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
