    <JadeMethod name="translateForm" id="ab7f2e42-7556-4638-a218-7271f6816749">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:40:02.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017251, locale);
	cmbDimType.translateCaption(Xlat_0011803, locale);
	lblDimensions.translateCaption(Xlat_0011804, locale);
	lblGeneral.translateCaption(Xlat_0011805, locale);
	lblOther.translateCaption(Xlat_0011806, locale);
	tblDensity.translateCaption(Xlat_0023230, locale);
	tblHeight.translateCaption(Xlat_0023231, locale);
	tblLength.translateCaption(Xlat_0023232, locale);
	tblTotalWeight.translateCaption(Xlat_0023233, locale);
	tblVolume.translateCaption(Xlat_0023234, locale);
	tblWidth.translateCaption(Xlat_0023235, locale);
 //	txtColour.translateCaption(Xlat_0011807, locale);		    // PAR #32331
 //	txtDescription.translateCaption(Xlat_0011809, locale);		   // PAR #32331
	txtHeightText.translateCaption(Xlat_0011811, locale);
	txtLengthText.translateCaption(Xlat_0011813, locale);
	txtMarkNumber.translateCaption(Xlat_0011814, locale);
	txtQuantity.translateCaption(Xlat_0011815, locale);
	txtRemarks.translateCaption(Xlat_0011816, locale);
	txtWidthText.translateCaption(Xlat_0011820, locale);
	txtYardInstruct.translateCaption(Xlat_0011821, locale);
end;</source>
    </JadeMethod>
</GUIClass>
