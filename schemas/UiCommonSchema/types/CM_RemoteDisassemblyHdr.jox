<Class name="CM_RemoteDisassemblyHdr">
    <JadeMethod name="isProcessAllowedInSystemAllert" id="99e604c9-6b00-4764-9c59-18b67155cce7">
        <source>isProcessAllowedInSystemAllert(): Boolean;
/* ---------------------------------------------------------------------------
Created:	23 February 2010	by cnwvu1

Purpose:	PAR 21218
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	return true;	//PAR 23972 10/05/2010
	
	/*	commented by PAR 23972 10/05/2010
	// it disables btnProcessT for CMUI_RemoteDataEditForm, that is called from CMUI_SystemAllerts
	// and populates "PLEASE RUN FROM FORM" on the form, see loadRemoteTable()
	return false;
	*/
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadRemoteTable" id="0ab2065b-778f-4df3-82e5-db69072dc938">
        <updating/>
        <source>loadRemoteTable(_table: CM_EntryTable io) updating;

// cnwdvb1 25 November 2002 

vars

	detail	: CM_RemoteDataDtl;

begin
	
	// Start. PAR 23972 10/052/2010 
	inheritMethod(_table);
	self.addRemoteRow(_table, 'Original Log', self.originalLog, null);
	self.addRemoteRow(_table, 'Residual Length', self.residualLength.String, null);
	self.addRemoteRow(_table, 'Residual Volume', self.residualVolume.String, null);
	self.addRemoteRow(_table, 'Reason Code', self.reason, null);
	self.addRemoteRow(_table, 'Recovery Code', self.recovery, null);
	self.addRemoteRow(_table, 'Comment', self.comment, null);
	foreach detail in self.allRemoteDataDtl do
		self.addRemoteRow(_table, 'New Disassembly Log ' &amp; detail.CM_RemoteDisassemblyDtl.newId, Click, detail);
	endforeach;
	// End. PAR 23972 10/052/2010 

/*	commented by PAR 23972 10/052/2010 
	_table.setColumnHeadings('Item', 'Value');
	self.addRemoteRow(_table, app.getErrorString(Please_run_from_Form), '*********', null);
*/

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
</Class>
