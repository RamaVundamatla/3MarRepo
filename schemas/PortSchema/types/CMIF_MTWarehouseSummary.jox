    <JadeMethod name="delete" id="78e93608-9876-4f43-881d-662eb48334fe">
        <updating/>
        <source>delete() updating;
//----------------------------------------------------------------
//	Created:	16 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.allPackAreaSummaries.purge;

end;</source>
    </JadeMethod>
    <JadeMethod name="getGrpSumDisplay" id="50bd36d0-99dd-4a46-9313-ddda72235aad">
        <updating/>
        <source>getGrpSumDisplay(_objectSet: ObjectSet): String updating;
//----------------------------------------------------------------
//	Created:	16 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	obj			: Object;
	tmpSumObj	: SelfType;
	setTAMTSums	: Boolean;
	taMTSumm	: CMIF_TAMTSummary;
	areaSummStr	: String;

begin
	if self.allPackAreaSummaries.isEmpty then
		setTAMTSums := true;
	endif;

	foreach obj in _objectSet do
		tmpSumObj := obj.CMIF_MTWarehouseSummary;
		if setTAMTSums then
			self.setTAMTSumsFromCMIF(tmpSumObj);
			setTAMTSums := false;
		endif;
		self.awaitingTask03				:= self.awaitingTask03	+ tmpSumObj.awaitingTask03;
		self.awaitingTask01				:= self.awaitingTask01	+ tmpSumObj.awaitingTask01;
		self.awaitingTask02				:= self.awaitingTask02	+ tmpSumObj.awaitingTask02;
		self.awaitingTask04				:= self.awaitingTask04	+ tmpSumObj.awaitingTask04;
		self.awaitingTask05				:= self.awaitingTask05	+ tmpSumObj.awaitingTask05;
		self.inAreaTask01				:= self.inAreaTask01	+ tmpSumObj.inAreaTask01;
		self.inAreaTask02				:= self.inAreaTask02	+ tmpSumObj.inAreaTask02;
		self.inAreaTask03				:= self.inAreaTask03	+ tmpSumObj.inAreaTask03;
		self.inAreaTask04				:= self.inAreaTask04	+ tmpSumObj.inAreaTask04;
		self.totalAvailable 			:= self.totalAvailable	+ tmpSumObj.totalAvailable;
		self.totalOnSite				:= self.totalOnSite		+ tmpSumObj.totalOnSite;
		self.totalWithStops				:= self.totalWithStops	+ tmpSumObj.totalWithStops;
		self.balanceTotal				:= self.balanceTotal	+ tmpSumObj.balanceTotal;
		self.totalPendingRequests		:= self.totalPendingRequests		+ tmpSumObj.totalPendingRequests;
		self.totalGeneralCargoRequests	:= self.totalGeneralCargoRequests	+ tmpSumObj.totalGeneralCargoRequests;
		self.totalTransportRequests		:= self.totalTransportRequests		+ tmpSumObj.totalTransportRequests;
		self.totalRoadRequests		:= self.totalRoadRequests		+ tmpSumObj.totalRoadRequests;//29 Dec 2010	NDL	Par 26650
		self.totalRailRequests		:= self.totalRailRequests		+ tmpSumObj.totalRailRequests;//29 Dec 2010	NDL	Par 26650
		foreach taMTSumm in self.allPackAreaSummaries do
			taMTSumm.numInArea := taMTSumm.numInArea + tmpSumObj.allPackAreaSummaries[taMTSumm.packAreaId].numInArea;
			taMTSumm.numRequired := taMTSumm.numRequired + tmpSumObj.allPackAreaSummaries[taMTSumm.packAreaId].numRequired;
		endforeach;
	endforeach;
	
	foreach taMTSumm in self.allPackAreaSummaries do
		areaSummStr := areaSummStr &amp; taMTSumm.numInAreaDisplay &amp; Tab &amp; taMTSumm.numRequiredDisplay &amp; Tab &amp; taMTSumm.balanceDisplay &amp; Tab &amp; Tab;
	endforeach;

	return	self.totalOnSite.String &amp; Tab &amp; 
			self.transRequestsDisplay.String &amp; Tab &amp; 
			self.genCargoRequestsDisplay.String &amp; Tab &amp; 
			self.pendingRequestsDisplay.String &amp; Tab &amp; 
			self.availableDisplay &amp; Tab &amp; 
			self.balanceTotal.String &amp; Tab &amp; Tab &amp; 
			areaSummStr;
end;</source>
        <Parameter name="_objectSet" type="ObjectSet"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReportTableDisplay" id="cbeb680b-61f8-440c-9efb-7ee43046e879">
        <source>getReportTableDisplay(): String;
//----------------------------------------------------------------
//	Created:	09 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

	areaSummStr		: String;
	areaSumm		: CMIF_TAMTSummary;
	
	
begin
	foreach areaSumm in self.allPackAreaSummaries do
		areaSummStr := areaSummStr &amp; areaSumm.numInAreaDisplay &amp; Tab &amp; areaSumm.numRequiredDisplay &amp; Tab &amp; areaSumm.balanceDisplay &amp; Tab &amp; Tab;
	endforeach;

	return	self.avaGradeCode.String &amp; " - " &amp; self.avaGradeDesc.String &amp; Tab &amp; 
			self.totalOnSite.String &amp; Tab &amp; 
			self.transRequestsDisplay.String &amp; Tab &amp; 
			self.genCargoRequestsDisplay.String &amp; Tab &amp; 
			self.pendingRequestsDisplay.String &amp; Tab &amp; 
			self.availableDisplay &amp; Tab &amp; 
			self.balanceTotal.String &amp; Tab &amp; Tab &amp; 
			areaSummStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreateFromFilter" id="931c1562-7b51-4033-98a4-c0635b855d42">
        <source>setForCreateFromFilter(_filter: CMQF_Container);
//----------------------------------------------------------------
//	Created:	16 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	area		: CM_TerminalArea;
	areaSumm	: CMIF_TAMTSummary;
begin
	inheritMethod(_filter);

	//setup the area summaries
	foreach area in _filter.allQryPackAreas do
		create areaSumm transient;
		areaSumm.packAreaId := area.id;
		self.allPackAreaSummaries.add(areaSumm);
	endforeach;
	
	//for areas not included in allQryPackAreas 
	create areaSumm transient;
	areaSumm.packAreaId := OTHER;
	self.allPackAreaSummaries.add(areaSumm);
	
end;</source>
        <Parameter name="_filter" type="CMQF_Container"/>
    </JadeMethod>
    <JadeMethod name="setFromBR" id="5dada118-4b39-49f6-a0fb-38b7bbcb728a">
        <updating/>
        <source>setFromBR(_bulkRel: CM_BulkRelease; _setKeys: Boolean) updating;
//----------------------------------------------------------------
//	Created:	16 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	summ	: CMIF_TAMTSummary;
	taID	: String;
begin

	inheritMethod(_bulkRel, _setKeys);

	if _bulkRel.allPackLocations.size = 1 then
		taID := _bulkRel.allPackLocations.first;
		summ	:= self.allPackAreaSummaries[taID];
	endif;
	
	if summ &lt;&gt; null then
		summ.numRequired := summ.numRequired + _bulkRel.getTotalStorageEmpties;
	else
		self.allPackAreaSummaries[OTHER].numRequired := self.allPackAreaSummaries[OTHER].numRequired + _bulkRel.getTotalStorageEmpties;
	endif;

end;</source>
        <Parameter name="_bulkRel" type="CM_BulkRelease"/>
        <Parameter name="_setKeys" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromTI" id="b04d4bb7-726c-4aaf-b2ff-e155cd638e45">
        <updating/>
        <source>setFromTI(_ti: CM_Container; _setKeys: Boolean) updating;
//----------------------------------------------------------------
//	Created:	16 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tiTA	: CM_TerminalArea;
	summ	: CMIF_TAMTSummary;
	isOtago	: Boolean;
begin

	inheritMethod(_ti, _setKeys);

	tiTA := _ti.myTerminalArea;
	
	
	if tiTA &lt;&gt; null then
		// Lorcan 19/6/2006 Hard code for Port Otago
		// If the TA is in a certain number of straddle stacks ie in PD PE, PF, ES, DN, and DW
		// then for the purposes of this report assume they are in PACKD
			//Par12374  cnwsh3/cnwyl1 11/09/2006 Changed to look at the new client property on root as this is relevant to Otago only and the value will remain more constant than port code on Terminal
		//isOtago := app.myPassport.myTerminal.getConfig(PortDestCode).String.trimBlanks = "POE";
		// ccms#1486 27/9/2006 - added DN1 area/location - Mohammad
		isOtago := app.myRoot.client = Client_PortOtago;
		if isOtago and (tiTA.id = "PD" or tiTA.id = "PE" or tiTA.id = "PF" or
						tiTA.id = "ES" or tiTA.id = "DN1" or tiTA.id = "DN" or tiTA.id = "DW" ) then
			summ	:= self.allPackAreaSummaries["PACKD"];
		else
			summ	:= self.allPackAreaSummaries[tiTA.id];
		endif;
	endif;
	
	if summ &lt;&gt; null then
		summ.numInArea := summ.numInArea + 1;
	else
		self.allPackAreaSummaries[OTHER].numInArea := self.allPackAreaSummaries[OTHER].numInArea + 1;
	endif;

end;</source>
        <Parameter name="_ti" type="CM_Container"/>
        <Parameter name="_setKeys" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTAMTSumsFromCMIF" id="aaa3a444-893c-4834-8026-5bada105d55d">
        <source>setTAMTSumsFromCMIF(_cmif: CMIF_MTWarehouseSummary);
//----------------------------------------------------------------
//	Created:	16 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	newTAMTSumm,
	taMTSumm	: CMIF_TAMTSummary;
begin
	foreach taMTSumm in _cmif.allPackAreaSummaries do
		create newTAMTSumm transient;
		newTAMTSumm.packAreaId := taMTSumm.packAreaId;
		self.allPackAreaSummaries.add(newTAMTSumm);
	endforeach;

end;</source>
        <Parameter name="_cmif" type="CMIF_MTWarehouseSummary"/>
    </JadeMethod>
</Class>
