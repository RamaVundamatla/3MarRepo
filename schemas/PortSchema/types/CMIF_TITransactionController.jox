    <JadeMethod name="createTransaction" id="ab35e130-608f-4480-8234-dc68f45b3b3f">
        <updating/>
        <source>createTransaction(_passport : CM_Passport input) : CM_Transaction updating;
// ---------------------------------------------------------------------------
// Created:     18 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07 Dec 2022 	navma1		ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
// ---------------------------------------------------------------------------
vars
	trans 			: CM_Transaction;
	theClass		: Class;
	containerId		: String;
	
begin
	
	if (not self.validate) then
		return null;
	endif;

	if app.myPassport.isInEdiVerifyMode then					//07.12.2022 navma1 #52499			
		return null;
	endif;
	
	theClass := global.getTiTxnClassForType(self.type, true);

	if theClass = null then
		return null;
	endif;
	
	create trans as theClass persistent;
	
	if trans.isKindOf(CM_TITransaction) and trans.CM_TITransaction.validateCMIF_TITransCntrl(self) then
	
		trans.CM_TITransaction.setFromCMIF_TITransactionCntrl(self, _passport);
		
	elseif trans.isKindOf(CM_BOLTransaction) then
	
		trans.CM_BOLTransaction.setFromCMIF_TITransactionCntrl(self, _passport);
		
	endif;
	
	// XPOSE 1647 AKB2002JAN
	if theClass = CM_Connect 
	or theClass = CM_ConnectPower 
	or theClass = CM_ConnectTower
	or theClass = CM_DisconnectPower 
	or theClass = CM_DisconnectTower
	then
		self.myTrackedItem.checkDateConnectDisconnect(self.dateTime, false);
	endif;

	if _passport.hasErrors() then 
		delete trans;
		trans := null;
		return null;
	endif;
	
	//If we get to here then the transaction is OK
	if trans.isKindOf(CM_TITransaction) then
		_passport.addTITransactionForDeferUpd(trans.CM_TITransaction, self.myTerminal);
	endif;
	
	return trans;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_Transaction"/>
    </JadeMethod>
    <JadeMethod name="deleteTransaction" id="47c4b342-836f-4815-a300-92634c3feec0">
        <updating/>
        <source>deleteTransaction(_passport : CM_Passport input; 
					_origTrans : CM_TITransaction input) updating;
// ---------------------------------------------------------------------------
// Created:     20 March 2003		cnwth2	
//
// Purpose:     Sets the deleted flag (bitwise on flags int array)		 
// ----------   ----------  --------------------------------------------------
vars

begin
	_origTrans.setForDelete(null);
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_origTrans" type="CM_TITransaction" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTrxQVWvalues" id="eca9107f-b9a3-41ab-9da8-b58ef8bf66c6">
        <source>getTrxQVWvalues(	_totQ : Integer output;
					_totV : Decimal output;
					_totW : Decimal output
					);
/*

Purpose:			

Parameters:			re-implemented on sub classes to reset as requuired

Return Value:		

Date		Who		Reason
06 November 2014	cnwndl1	Initial creation	Par 35105

*/

vars

begin

	if self.myTrackedItem &lt;&gt; null then
		_totQ := self.myTrackedItem.totalQuantity;
		_totV := self.myTrackedItem.totalVolume;
		_totW := self.myTrackedItem.totalWeight;
	endif;

epilog

end;</source>
        <Parameter name="_totQ" type="Integer" usage="output"/>
        <Parameter name="_totV" type="Decimal" usage="output"/>
        <Parameter name="_totW" type="Decimal" usage="output"/>
    </JadeMethod>
