<Class name="CM_RotatableContainerEmpty" id="690bfa1d-f3ce-4d97-9dc6-4211e9d766d3">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <PrimAttribute name="cargoSubTypeForContents" id="b1ecf1b7-0d96-4984-82b0-6b6b51b28872">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="cargoTypeForContents" id="df21e2d4-512f-4a34-93aa-b99bcd9fba98">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getCompletedTaskString" id="d213faa7-0ddf-44af-96c9-ab45fa433ac9">
        <source>getCompletedTaskString(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2025	jlier1	Initial creation 36155

*/
constants
	EditThing ="=&gt;";
vars
	cargoType : CM_CargoType;
	cargoTypeDesc : String;
	returnString : String;
	subType : CM_Product;
	subTypeDesc : String;
	measureType		: String;
begin
		
	cargoType:=app.myRoot.allCargoTypesById[self.cargoTypeForContents];
	cargoTypeDesc:=self.cargoTypeForContents.String;
	if cargoType &lt;&gt; null then
		cargoTypeDesc:=cargoType.description;
	endif;	
	
	returnString:=app.getErrorString(CM_CargoType_Contents) &amp; EditThing &amp; cargoTypeDesc;
	if self.cargoSubTypeForContents &lt;&gt; null then
		subTypeDesc:=self.cargoSubTypeForContents;
		if cargoType &lt;&gt; null then
			subType:=cargoType.getProductFromCode(self.cargoSubTypeForContents);
			if subType &lt;&gt; null then
				subTypeDesc:=subType.description;
			endif;
		endif;
		returnString:=returnString &amp; ": " &amp; app.getErrorString(CM_CargoSubType_Contents) &amp; EditThing &amp; subTypeDesc;
	endif;
	
	if self.commodity &lt;&gt; null then
		returnString:=returnString &amp; ": " &amp; app.getErrorString(CM_Commodity_GC) &amp; EditThing &amp; self.commodity;
	endif;
	
	measureType := app.getDefaultMeasurementForType(Type_Weight).shortName;	
	returnString:=returnString &amp; ": " &amp; app.getErrorString(CM_Cargo_Weight) &amp; EditThing &amp; app.convertMeasurementForDisplay(measureType, self.cargoWeight) &amp; Space &amp; measureType;
	
	return returnString;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="d778ff7c-c6ea-4ff5-9da1-ea518ff2866b">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 October 2025	jlier1	Initial creation 36155

*/

vars

begin
	inheritMethod(_tiTransCntrl, _passport);
	if _tiTransCntrl.isKindOf(CMIF_RotatableContEmptyCntlr) then
		self.cargoSubTypeForContents:=_tiTransCntrl.CMIF_RotatableContEmptyCntlr.cargoSubTypeForContents;
		self.cargoTypeForContents:=_tiTransCntrl.CMIF_RotatableContEmptyCntlr.cargoTypeForContents;
		self.commodity:=_tiTransCntrl.CMIF_RotatableContEmptyCntlr.commodity;
		self.cargoWeight:=_tiTransCntrl.CMIF_RotatableContEmptyCntlr.cargoWeight;
	endif;
epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
