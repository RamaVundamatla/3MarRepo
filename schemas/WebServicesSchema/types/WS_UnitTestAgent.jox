	request := parser.parse(json, WS_PostUnpackRequest, transientJSONObjs).WS_PostUnpackRequest;	
	
	webService.qsData.parseNameValuePair(_queryParams);
	response := webService.postUnpack(request);
	
	// If we're expecting to fail, then return early
	if expectErrors then
		if webService.httpStatusCode = HttpResponseCodePartialSuccess then
			return null;
		elseif webService.httpStatusCode = HttpResponseOK then				//JIRA 33031
			return "Failure expected, got 200 OK";							//JIRA 33031
		endif;																//JIRA 33031
		return response.allErrors.first.text;
	endif;
	
	if webService.httpStatusCode &lt;&gt; HttpResponseOK then
		if response.allErrors.size &gt; 0 then
			app.writeLog(response.allErrors.first.text, LogERROR);
		endif;
		return method.qualifiedName &amp; " Bad Response Code, expecting 200 OK, got " &amp; webService.httpStatusCode.String &amp; ". Check UnitTest runner logs for more details" &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	endif;
	
	// Bit of a hack to get the response back ;)
	json := parser.generateJson(response, JadeJson.Format_Json_Microsoft);
	
	return null;
	
	// Not used,just here to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsRESTPostUnPack.name;

epilog
	if webService.objectsToBeDeleted.isNotEmpty then
		webService.objectsToBeDeleted.purge;
	endif;
	dict := webService.qsData;
	dict.purge();
	delete webService;
	delete parser;
	delete requestLogin;
	delete request;
	transientJSONObjs.purge();
	delete transientJSONObjs;
