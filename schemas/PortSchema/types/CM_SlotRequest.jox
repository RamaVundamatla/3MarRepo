    <JadeMethod name="colorCodeType" id="fd94f7a9-4854-4acc-8486-e0a193dddc27">
        <methodInvocation>mapping</methodInvocation>
        <source>colorCodeType(set: Boolean; _value: Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:     15 April 2002 by cnwdwq1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if self.isLoad then
		_value := LoadColourCode;
	else
		_value := DischargeColourCode;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="createWLEs" id="02e8742d-13b2-40d2-9039-60fcaca86d4a">
        <updating/>
        <source>createWLEs() updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14/12 2010	cnwdap1		PAR #26426 CCMS MES 1102 Ship release request changes
//							Delete ti attached to the WLE if it's a TBA ti, and clear
//							my originating bulk release reference (I'm no longer being actioned)
// 22/12/2010	cnwdap1		PAR #26636 Delete of TBA Ti is now done in CM_WorkListEntry setMyTrackedItem method
// 30 Jun 2025  navma1 		MTN-34090  MTN | Dead lock (1081) on CM_TIByIdCargoTypeRelseDictRev
// ---------------------------------------------------------------------------

vars
	wle					: CM_WorkListEntry;
	aTI 				: CM_TrackedItem;
	isSlotBulkRelease	: Boolean;
	reserveLocation		: String;
begin

// ##### WHOLE METHOD
// #####			
	if self.allWorkListEntries.isEmpty then
		if self.isDischarge then
			if self.mySlotController &lt;&gt; null then
				if self.isBackend and self.getAttrIs30() then
					foreach aTI in self.mySlotController.allTrackedItemOSBackEnds do
						create wle as CM_VoyageWLE;
						wle.setForCreate(self.myJob, self);
						wle.setMyTrackedItem(aTI);
					endforeach;
				else
					foreach aTI in self.mySlotController.allTrackedItems do
						create wle as CM_VoyageWLE;
						wle.setForCreate(self.myJob, self);
						wle.setMyTrackedItem(aTI);
					endforeach;
				endif;
			endif;
		else
			create wle as CM_VoyageWLE;
			wle.setForCreate(self.myJob, self);
			if self.isBulkRelease() then
				wle.setLocations(self.getBulkReleaseReserveDetail().getLocation(), self.stowageId);
			endif;
		endif;
	else
		isSlotBulkRelease := self.isBulkRelease;								//30.06.2025 navma1 #MTN-34090
		if isSlotBulkRelease then
			reserveLocation := self.getBulkReleaseReserveDetail().getLocation(); //30.06.2025 navma1 #MTN-34090
		endif;
		
		foreach wle in self.allWorkListEntries do
			if wle.job = null then
				wle.setForCreate(self.myJob, self);
			endif;
			if isSlotBulkRelease then											//30.06.2025 navma1 #MTN-34090
				wle.setLocations(reserveLocation, self.stowageId);				//30.06.2025 navma1 #MTN-34090
				self.myOriginatingBulkRelease := null;					// PAR #26426
				wle.setMyTrackedItem(null);								// PAR 17327
			endif;
		
		endforeach;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="dischargePort" id="511ded51-c0ca-4217-a9b2-728d7c793290">
        <methodInvocation>mapping</methodInvocation>
        <source>dischargePort(set: Boolean; _value: String io) mapping;
// cnwrs1 June 2006 protected the old 3 digit codes
vars
	port : CM_Port;
	tmpDischargePort : CM_Port;  //cnwas3 PAR 24273
begin

	if not set then
		if self.dischargePort.length = 3 then
			port := app.myRoot.allLocodesByShortCode.getAtKeyGeq(self.dischargePort, null);
			if port &lt;&gt; null and port.portCode = self.dischargePort then
				_value := port.code;
			else			
				port := self.getAttrDischargePort();//cnwas3 PAR 24273
				if port &lt;&gt; null then
					_value := port.code;
				endif;
			endif;
		else
			port := self.getAttrDischargePort(); //cnwas3 PAR 24273
			if port &lt;&gt; null then
				_value := port.code;
			else
				_value := null;   // 26/07/2010 cnwmh5 #25159
			endif;

		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doIMatchCCType" id="cb2ffbd0-7fd7-4b3c-821b-46f5ebd6d634">
        <source>doIMatchCCType(_priority : Integer; _get40 : Boolean) : Boolean;
// ---------------------------------------------------------------------------
// Created:		11 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if _priority = JobTypePriority_DischargeDLR20  and not _get40 then
		if self.isDischarge
		and self.isRehandle
		and self.is20() then
			return true;
		endif;
	elseif _priority = JobTypePriority_DischargeDLR40 and  _get40 then
		if self.isDischarge
		and self.isRehandle
		and self.getAttrIs40() then
			return true;
		endif;
	elseif _priority = JobTypePriority_DischargeIMP20 and not _get40 then
		if self.isDischarge
		and not self.isRehandle
		and self.is20() then
			return true;
		endif;
	elseif _priority = JobTypePriority_DischargeIMP40 and  _get40 then
		if self.isDischarge
		and not self.isRehandle
		and self.getAttrIs40() then
			return true;
		endif;
	elseif _priority = JobTypePriority_LoadDLR20 and not _get40 then
		if self.isLoad
		and self.isRehandle
		and self.is20() then
			return true;
		endif;
	elseif _priority = JobTypePriority_LoadDLR40 and  _get40 then
		if self.isLoad
		and self.isRehandle
		and self.getAttrIs40() then
			return true;
		endif;
	elseif _priority = JobTypePriority_LoadExport20 and not _get40 then
		if self.isLoad
		and not self.isRehandle
		and self.is20() then
			return true;
		endif;
	elseif _priority = JobTypePriority_LoadExport40 and  _get40 then
		if self.isLoad
		and not self.isRehandle
		and self.getAttrIs40() then
			return true;
		endif;
	elseif _priority = JobTypePriority_SOB then
		if self.isSOB() then
			return true;
		endif;
	endif;

	return false;
end;</source>
        <Parameter name="_priority" type="Integer"/>
        <Parameter name="_get40" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="erase" id="1eb06a54-ed2b-4e2f-b4c7-1b8bcb260353">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*
------------------------------------------------------------------------
Created:			26 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	slotController : CM_SlotController;
	voy : CM_Voyage;
	voyAlloc : CM_VoyageAllocation;
begin
	slotController := self.mySlotController;

	if slotController &lt;&gt; null then
		voy := slotController.myVoyage;
		if voy.useVoyageAllocations then
			voyAlloc := self.allAllocations.first.CM_VoyageAllocation;
			if voyAlloc &lt;&gt; null then
				app.myEventManager.createSingleObjInfoNoteEvt(voy,voy.myTerminal.getTerminalEvent(EVENT_VOY_ALLOC_UPDATE),voyAlloc);		
			endif;
		else
				app.myEventManager.createSingleObjInfoNoteEvt(voy,voy.myTerminal.getTerminalEvent(EVENT_VOY_ALLOC_UPDATE),null);		
		endif;
		slotController.removeSlotRequest(self);
	endif;
	//	This is to make sure we cover the bases. Check the job's status etc (to be done)
	inheritMethod(_eraseLevel);

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getActualLength" id="4de0e205-fb7a-4e00-88cf-5714fdc6ad06">
        <source>getActualLength() : Integer;
// ---------------------------------------------------------------------------
// Created:		30 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.is20() then
		return 20;
	elseif self.getAttrIs30() then // PAR 16415 CCMS 1029
		return 30;
	elseif self.getAttrIs53() then // PAR 16415 CCMS 1029
		return 53;
	elseif self.getAttrIs45() then // PAR 18682 CCMS 1055
		return 45;
	elseif self.getAttrIs40() then
		return 40;
	endif;
	return 20;
		
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
