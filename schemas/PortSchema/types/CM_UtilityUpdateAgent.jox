    <JadeMethod name="utlUpdateCargoCheck" id="0798a0e5-8937-4a6b-9666-3590756e84fe">
        <source>utlUpdateCargoCheck(_proxyCargoCheck : CM_CargoCheck; _passport : CM_Passport input);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2010	cnwdap1	Initial creation
*/
vars
	cancelSave		: Boolean;
	realCargoCheck	: CM_CargoCheck;
	expectedEdition	: Integer;
	
begin
	self.initialiseActivity();

	_proxyCargoCheck.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyCargoCheck.pxyGetRealObjectAndEdition(realCargoCheck, expectedEdition);
	
	if realCargoCheck = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_CargoCheck.name, null, null);
		return;
	endif;

	app.myValUA.valCargoCheck(_proxyCargoCheck);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realCargoCheck);

	if _passport.noErrors and realCargoCheck.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'cargoCheck', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCargoCheck, true);
	endif;
	
	if _passport.noErrors then
		realCargoCheck.setForUpdate(_proxyCargoCheck);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCargoCheck, false);
	endif;

end;</source>
        <Parameter name="_proxyCargoCheck" type="CM_CargoCheck"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCargoCheckItem" id="4ead35f6-3b1d-4542-acc6-861b18d2ce91">
        <updating/>
        <source>utlUpdateCargoCheckItem(_pxyCargoCheckItem : CM_CargoCheckItem; _allCriteria : CMIF_Array input; _passport : CM_Passport input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2010	cnwdap1	Initial creation
*/
vars
	realCargoCheckItem	: CM_CargoCheckItem;
	expectedEdition		: Integer;
	
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValUA.valCargoCheckItem(_pxyCargoCheckItem);

	_pxyCargoCheckItem.pxyGetRealObjectAndEdition(realCargoCheckItem, expectedEdition);
	
	if realCargoCheckItem = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_CargoCheckItem.name, null, null);
		return;
	endif;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	app.setContinueCMExceptions(false);

	exclusiveLock(realCargoCheckItem);

	if _passport.noErrors and realCargoCheckItem.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Cargo Check Item', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCargoCheckItem, true);
	endif;
	
	if _passport.noErrors then
		realCargoCheckItem.setForUpdate(_pxyCargoCheckItem, _allCriteria);
	endif;
	
	// and persist the criteria
	if _passport.noErrors then
		realCargoCheckItem.persistCriteria(_allCriteria, _passport);
	endif;
end;</source>
        <Parameter name="_pxyCargoCheckItem" type="CM_CargoCheckItem"/>
