//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	return self.is40;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getMatchingOOWC" id="f4cc1152-41ba-4d41-b422-44848b864f26">
        <source>getMatchingOOWC() : CM_OOWCreationDetail;
// ---------------------------------------------------------------------------
// Created:		04 July 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	realOOWC : CM_OOWCreationDetail;
	found : Boolean;
begin
	foreach realOOWC in self.myVoyageStructure.allOOWCreations do
		if realOOWC = self then
			continue;
		endif;
		if realOOWC.myBay = self.myBay 
		and realOOWC.is40 = self.is40
		and realOOWC.ordinalDeck = self.ordinalDeck  then
			return realOOWC;
		endif;
	endforeach;

	return null;
end;</source>
        <ReturnType type="CM_OOWCreationDetail"/>
    </JadeMethod>
    <JadeMethod name="getNumberOfLifts" id="35682206-0440-46a9-a168-59a7465ceb3b">
        <source>getNumberOfLifts(): Real;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	sr : CM_SlotRequest;
	vwle : CM_VoyageWLE;
	wle : CM_WorkListEntry;
	done, notDone : Real;
begin
	foreach sr in self.allSlotRequests discreteLock do
		foreach wle in sr.allWorkListEntries discreteLock do
			wle.CM_VoyageWLE.getLiftTotals(done, notDone);
		endforeach;
	endforeach;
	return done + notDone;
epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getRowDetailString" id="b95c54a1-3681-4b0f-8cad-bd52a19fbf33">
        <source>getRowDetailString() : String;
// ---------------------------------------------------------------------------
// Created:		01 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	dTotal : Real;
	str, jStr, tlStr : String;
	aJob : CM_VoyageJob;
	
begin
	str := inheritMethod();

	foreach aJob in self.allJobs do
		tlStr := null;
		if aJob.isTwinLift then
			tlStr := " TL";
		endif;
		if jStr = "" then
			jStr := aJob.jobNum &amp; tlStr;
		else
			jStr := jStr &amp; ", " &amp; aJob.jobNum &amp; tlStr;
		endif; 
	endforeach;
	dTotal := self.getTotalItems();
	
	str := 	self.id &amp; Tab &amp; 	// BAY
			self.getDeckCode() &amp; Tab; // &amp; // DECK = UD or OD
			str := str &amp; jStr &amp; Tab &amp; Tab;
			
	str := str &amp; 	self.discIMP20.zeroNotAllowed() &amp; Tab &amp; 
			self.discIMP40.zeroNotAllowed() &amp;Tab &amp; Tab &amp; 
			self.loadEXP20.zeroNotAllowed() &amp; Tab &amp; 
			self.loadEXP40.zeroNotAllowed() &amp; Tab &amp; Tab &amp; 
			self.discDLR20.zeroNotAllowed() &amp; Tab &amp; 
			self.discDLR40.zeroNotAllowed() &amp;Tab &amp; 
			self.loadDLR20.zeroNotAllowed() &amp; Tab &amp; 
			self.loadDLR40.zeroNotAllowed() &amp; Tab &amp; Tab &amp; 

			(self.discSOB20 + self.loadSOB20).zeroNotAllowed() &amp; Tab &amp; 
			(self.discSOB40 + self.loadSOB40).zeroNotAllowed() &amp; Tab &amp; Tab &amp; 
			
			dTotal.String &amp; Tab &amp; // BAY TOTAL
			Tab &amp; // Fwd to Aft total
			Tab &amp; // AFt to Fwd total
			Tab &amp;  // Crane running total
			Tab &amp;  // Lifts running total
			(self.discREF20 + self.loadREF20).zeroNotAllowed() &amp; Tab &amp; 
			(self.discREF40 + self.loadREF40).zeroNotAllowed();

	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTotalItems" id="b94f124c-09ff-4b2a-b350-d0841bcd2b58">
        <source>getTotalItems() : Integer;
// ---------------------------------------------------------------------------
// Created:		01 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	dTotal : Integer;
begin
	dTotal := (self.discIMP20 + self.discDLR20  + self.discSOB20 +  self.loadDLR20 + self.loadEXP20  + self.loadSOB20);
	dTotal := dTotal + (self.discIMP40 + self.discDLR40 + self.discSOB40 +  self.loadDLR40 + self.loadEXP40 + self.loadSOB40);
	// PAR 16415 CCMS 1029
	dTotal := dTotal + (self.discIMP53 + self.discDLR53 + self.discSOB53 +  self.loadDLR53 + self.loadEXP53 + self.loadSOB53);
	dTotal := dTotal + (self.discIMP30 + self.discDLR30 + self.discSOB30 +  self.loadDLR30 + self.loadEXP30 + self.loadSOB30);
	
	return dTotal;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="incrementYourOrder" id="40cbe571-e3dc-494a-bca7-557f3cf82d9f">
        <updating/>
        <source>incrementYourOrder(_push: SelfType input; _up: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	num, nextNum : Integer;
	nextPushUp : SelfType;
begin
	if _push = null then
		return;
	endif;
	num := _push.order;
	nextNum := num + 1;
	
	nextPushUp := self.myVoyageStructure.allOOWCreations.getAtKeyGeq(nextNum,0);

	if nextPushUp &lt;&gt; null then
		if nextPushUp.order = nextNum then
			_push.incrementYourOrder(nextPushUp, _up);
		else
			if _up then
				_push.order := nextNum;
			else
				_push.order := num;
			endif;
		endif;
	else
		if _up then
			_push.order := nextNum;
		else
			_push.order := num;
		endif;
	endif;
	if _up then
		self.order := num;
	else
		self.order := nextNum;
	endif;

epilog

end;</source>
        <Parameter name="_push" type="SelfType" usage="input"/>
        <Parameter name="_up" type="Boolean"/>
    </JadeMethod>
