    <JadeMethod name="doesReceiptTransportModeExist" id="07ab895f-a776-4305-9e70-b86f7d904e06">
        <source>doesReceiptTransportModeExist(_receiptTransportMode: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
6 April 2023	navra1	Initial creation for 57263

*/

vars

begin
	//since the receipt transport mode would be TI_TRANSMODE_SHIP_STR for a bay plan edi file
	if _receiptTransportMode.toUpper().compareEql(TI_TRANSMODE_SHIP_STR.toUpper(), true, false, null) then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_receiptTransportMode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findHeadings" id="089590dc-e6b5-42b9-9ddd-c02bff00c5c6">
        <source>findHeadings(_tiName: String; _shortDesc: String io; _longDesc: String io; _width: Integer io; _num: Integer io);
// note: num does not have to be order but the largest num must be
//	   greater than the total number of properties.
//	   ie what is return by getNumColumns.
vars

begin
	if _tiName = "commodity" then
		_num := 11;
		_shortDesc := "Cmdty";
		_longDesc := "Commodity";
		_width := 50;
	elseif _tiName = "fullOrMT" then
		_num := 9;
		_shortDesc := "MT";
		_longDesc := "MT or Full (E/F)";
		_width := 30;
	elseif _tiName = "id" then
		_num := 1;
		_shortDesc := "Id";
		_longDesc := "Container Id";
		_width := 100;
	elseif _tiName = "imCodes" then
		_num := 15;
		_shortDesc := "IMCds";
		_longDesc := "IM Codes";
		_width := 50;
	elseif _tiName = "isoType" then
		_num := 8;
		_shortDesc := "ISO";
		_longDesc := "ISO Type";
		_width := 50;
	elseif _tiName = "operatorCode" then
		_num := 4;
		_shortDesc := "Oper";
		_longDesc := "Operator";
		_width := 50;
	elseif _tiName = "remarks" then
		_num := 14;
		_shortDesc := "Rmks";
		_longDesc := "Remarks";
		_width := 100;
	elseif _tiName = "commodityDescription" then
		_num := 12;
		_shortDesc := "Cmdy";
		_longDesc := "Commodity Description";
		_width := 120;
	elseif _tiName = "companyCode" then
		_num := 21;
		_shortDesc := "Coy";
		_longDesc := "Company Code";
		_width := 50;
	elseif _tiName = "couId" then
		_num := 20;
		_shortDesc := "CouId";
		_longDesc := "Cou Id";
		_width := 100;
	elseif _tiName = "destinationPort" then
		_num := 6;
		_shortDesc := "Dest";
		_longDesc := "Destination";
		_width := 50;
	elseif _tiName = "dischargePort" then
		_num := 5;
		_shortDesc := "Disch";
		_longDesc := "Discharge Port";
		_width := 50;
	elseif _tiName = "height" then
		_num := 16;
		_shortDesc := "Hght";
		_longDesc := "Height";
		_width := 30;
	elseif _tiName = "length" then
		_num := 17;
		_shortDesc := "Lght";
		_longDesc := "Length";
		_width := 30;
	elseif _tiName = "loadPort" then
		_num := 7;
		_shortDesc := "Load";
		_longDesc := "Load Port";
		_width := 50;
	elseif _tiName = "locationId" then
		_num := 2;
		_shortDesc := "Locn";
		_longDesc := "Location";
		_width := 50;
	elseif _tiName = "optDischargePorts" then
		_num := 19;
		_shortDesc := "OptDisch";
		_longDesc := "Optional Discharge Ports";
		_width := 100;
	elseif _tiName = "temperature" then
		_num := 13;
		_shortDesc := "Temp";
		_longDesc := "Temperature";
		_width := 30;
	elseif _tiName = "weight" then
		_num := 10;
		_shortDesc := "Wght";
		_longDesc := "Weight";
		_width := 50;
	elseif _tiName = "width" then
		_num := 18;
		_shortDesc := "Wdth";
		_longDesc := "Width";
		_width := 30;
	else
		_num := 0;
		_shortDesc := "";
		_longDesc := "";
		_width := 0;
	endif;
end;</source>
        <Parameter name="_tiName" type="String"/>
        <Parameter name="_shortDesc" type="String" usage="io"/>
        <Parameter name="_longDesc" type="String" usage="io"/>
        <Parameter name="_width" type="Integer" usage="io"/>
        <Parameter name="_num" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getCargoType" id="0b6d20c5-434d-4d64-9217-467d8963feef">
        <source>getCargoType(_cargoType : Integer) : Class;
// ---------------------------------------------------------------------------
// Created:     10 December 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	class : Class;
	cargoBOLType : CM_CargoBOLType;
	cargoType : CM_CargoType;
	terminal : CM_Terminal;
begin
	class := CM_Container;
	terminal := self.getMyTerminal();
	if terminal = null then
		return class;
	endif;
//	cargoBOLType := terminal.allCargoBOLTypes[_cargoType];
	if cargoBOLType = null then
		return class;
	endif;
	if not cargoBOLType.isKindOf(CM_CargoType) then
		return class;
	endif;
	cargoType := cargoBOLType.CM_CargoType;
	class := currentSchema.getClass(cargoType.classNameToCreate);
	return class;
end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="8a1804c4-5547-491a-842c-eed292be7d4b">
        <source>getDescription() : String;

// cnwdvb1 25 February 2003 

vars

begin

	if self.sendTime.isValid() then
		return self.operatorCode &amp; '/' &amp; self.vesselName &amp; '/' &amp; self.voyageCode &amp; '/' &amp; self.sendTime.cnEcShortPartFormat &amp; " ";
	else
		return self.operatorCode &amp; '/' &amp; self.vesselName &amp; '/' &amp; self.voyageCode &amp; " " ;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="19b5c81d-5355-41ec-b663-30ea79c9390f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		20 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// Changed On	Changed By	Reason
// ----------	----------	--------------------------------------------------
// 22/04/2010	cnwcs5		ccms sfw 1118/par 23580
// 31/08/2010	cnwdad1		PAR #25547 - Added fromPort and toPort.
// ---------------------------------------------------------------------------
vars
	str		: String;
begin
	if _attrName = ETRow_Items then
		//this can be locked by BGP - avoid if necessary
		if tryLock(self.allEDITrackedItems, Exclusive_Lock, Session_Duration, LockTimeout_Immediate) then
			str := self.allEDITrackedItems.size.String &amp; " (" &amp; self.loadRecordsForPort.String &amp; ")";
			unlock(self.allEDITrackedItems);
			return str;
		endif;
		return "UNK (" &amp; self.loadRecordsForPort.String &amp; ")";
	elseif _attrName = ETRow_DDate then
		return self.departTime.date.shortFormatJMT();
	elseif _attrName = ETRow_DTime then
		return self.departTime.Time.currentLocaleFormatJMT();
	elseif _attrName = ETRow_ADate then
		return self.arriveTime.date.shortFormatJMT();
	elseif _attrName = ETRow_ATime then
		return self.arriveTime.Time.currentLocaleFormatJMT();
	elseif _attrName = ETRow_ShipperDesc then
		return self.shipperCode;
// start 22/04/2010 cnwcs5 ccms sfw 1118/par 23580
	elseif _attrName = ETRow_VoyageCode then
		return self.voyageCode;
	elseif _attrName = ETRow_VesselName then
		return self.vesselName;
	elseif _attrName = ETRow_SendDate or	// 07/05/2010
		_attrName = ETRow_SendTime then		// 07/05/2010
		return self.sendTime.asStringJMT;	// 07/05/2010
// end 22/04/2010 cnwcs5 ccms sfw 1118/par 23580
	elseif _attrName = ETRow_FromPort then	// cnwdad1 31/08/2010 - PAR #25547.
		return self.fromPort;				// cnwdad1 31/08/2010 - PAR #25547.
	elseif _attrName = ETRow_ToPort then	// cnwdad1 31/08/2010 - PAR #25547.
		return self.toPort;					// cnwdad1 31/08/2010 - PAR #25547.
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
