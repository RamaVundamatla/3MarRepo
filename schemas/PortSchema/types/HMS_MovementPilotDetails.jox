    <JadeMethod name="setForUpdate" id="a803842a-3025-45a5-9859-636b868f97b5">
        <updating/>
        <source>setForUpdate(_pxyMvmntPilotDetails: HMS_MovementPilotDetails; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2019	jlgsl4	Initial creation

*/

vars

begin
	inheritMethod(_pxyMvmntPilotDetails, _passport);
	self.myPilot := _pxyMvmntPilotDetails.myPilot;
	self.myPilotLaunch := _pxyMvmntPilotDetails.myPilotLaunch;
epilog

end;</source>
