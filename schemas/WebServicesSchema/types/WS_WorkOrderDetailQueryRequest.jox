    <JadeMethod name="checkWorkOrder" id="f4dc75fd-731f-43bf-aa31-a993ccbaccae">
        <source>checkWorkOrder(_workOrderDetail : CM_WorkOrderDtl ;_voyageSet : CM_VoyageSet):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2019	cnwma1	Bug 46917: PEL1 - [Top Urgent] - No WO Additional Cargo appears on The Web Portal
30 Dec 2019  cnwma1	Bug 48082: PEL1 - Excessive webservice deadlocks
29 Jan 2020 jlger1	TFS 48179 - issues with checking status and type on work orders and not the details - some rework 
*/

vars
	workOrder 		: CM_WorkOrder;
	voyage 		 : CM_Voyage;
begin
	if _workOrderDetail = null then
		return false;
	endif;

	workOrder   := _workOrderDetail.getMyParent;

	if workOrder &lt;&gt; null and not workOrder.canAccessOnWeb() then
		return false;
	endif;
	
	if self.id = null then
		if not self.isMatchingWorkOrder(_workOrderDetail) then
			return false;
		endif;
		
		if not self.isMatchingStatus(_workOrderDetail) then
			return false;
		endif;
		if not self.isMatchingType(_workOrderDetail) then
			return false;
		endif;
		
		if _voyageSet &lt;&gt; null then
			voyage := _workOrderDetail.getMyVoyageObject;
			if voyage &lt;&gt; null then
				if  not _voyageSet.includes( voyage ) then
					return false;
				endif;
			endif;
		endif;
		
	endif;

	if not _workOrderDetail.canAccessOnWeb() then
		return false;
	endif;
	
	
	return true;
epilog

end;</source>
        <Parameter name="_workOrderDetail" type="CM_WorkOrderDtl"/>
        <Parameter name="_voyageSet" type="CM_VoyageSet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getWOVoyageDtlType" id="5b6dce78-5ff8-4014-a7d3-b81bac9e117a">
        <source>getWOVoyageDtlType(_voyage : CM_Voyage) : CM_WorkOrderVoyageDtl;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2019	cnwma1	Bug 46917: PEL1 - [Top Urgent] - No WO Additional Cargo appears on The Web Portal
11 OCt 2021	jlier1 	TFS 51963 removed inapornet 
*/

vars
	workOrderDetail : CM_WorkOrderVoyageDtl;
begin
	
	if self.type     = WO_TASK_NEWVOYAGE then
		workOrderDetail := _voyage.getWorkOrderForVoyageRequest();
	elseif self.type = WO_TASK_MARINEINITIAL then 				// TFS 40435	
		workOrderDetail := _voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_MARINEINITIAL).CM_WorkOrderVoyageDtl;
		
		if _voyage.arrMoveCountGtrThanIMSR() then 					//28 Nov 2018	NDL	TFS 42043
			return null;
		endif;
	elseif self.type = WO_TASK_MARINEDEPART then
		workOrderDetail := _voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_MARINEDEPART).CM_WorkOrderVoyageDtl;	
	elseif self.type = WO_TASK_CARGOINITIAL then             // TFS 40435
		workOrderDetail := _voyage.getWorkOrderForVoyCargoRequest(); // TFS 40435
	elseif self.type = WO_TASK_PERMIT then
		
		//for a shift or extension
		if self.permitFor = WO_TASK_SHIFTMOVEMENT then          //epr TFS 41310 15/10/18
			workOrderDetail := _voyage.allWorkOrders.getWODPermitForDetailType(WO_TASK_SHIFTMOVEMENT,WO_STATUS_COMPLETE).CM_WorkOrderVoyageDtl;

		elseif self.permitFor = WO_TASK_EXTENSION then
			workOrderDetail := _voyage.allWorkOrders.getWODPermitForDetailType(WO_TASK_EXTENSION,WO_STATUS_COMPLETE).CM_WorkOrderVoyageDtl;
		else
			if _voyage.status = Voyage_Status_ServicesPending then
				workOrderDetail := _voyage.allWorkOrders.getWODPermitForDetailType(WO_TASK_MARINEINITIAL,WO_STATUS_COMPLETE).CM_WorkOrderVoyageDtl;
				
			endif;
			
		endif;
	endif;
	
	return workOrderDetail;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="CM_WorkOrderVoyageDtl"/>
    </JadeMethod>
    <JadeMethod name="isMatchingStatus" id="3bc38994-8c3f-4d8d-b20e-e07a8e8f12d9">
        <source>isMatchingStatus(_workOrderDtl : CM_WorkOrderDtl):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2019	cnwma1	Bug 46917: PEL1 - [Top Urgent] - No WO Additional Cargo appears on The Web Portal
11 Oct 2021	jlier1		TFS 51963
*/

vars

begin	
		
	if  self.status &lt;&gt; null and self.status &lt;&gt; _workOrderDtl.getStatus then
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_workOrderDtl" type="CM_WorkOrderDtl"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMatchingType" id="c4ef547d-8c16-4502-9b3c-be8d13c9eb64">
        <source>isMatchingType(_workOrderDtl : CM_WorkOrderDtl):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2019	cnwma1	Bug 46917: PEL1 - [Top Urgent] - No WO Additional Cargo appears on The Web Portal

*/

vars
	
begin	
	if _workOrderDtl &lt;&gt; null and _workOrderDtl.isKindOf(CM_WodCargoRequest) then
		return true;
	endif;
	
	if self.type &lt;&gt; null then	
		if  _workOrderDtl &lt;&gt; null and _workOrderDtl.detailType &lt;&gt; self.type then
			return false;
		endif;
	endif;
	return true;
epilog

end;</source>
        <Parameter name="_workOrderDtl" type="CM_WorkOrderDtl"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMatchingWorkOrder" id="41a32cf1-1c9b-432e-b594-ad81852344a8">
        <source>isMatchingWorkOrder(_workOrder : CM_WorkOrderDtl): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2019	cnwma1	Bug 46917: PEL1 - [Top Urgent] - No WO Additional Cargo appears on The Web Portal

*/

vars

begin
	if  self.voyageWorkOrders  &lt;&gt; null  then
		if self.voyageWorkOrders= "yes" then
			if not _workOrder.isKindOf(CM_WorkOrderVoyageDtl) then
				return false;
			endif;
		else
			if not _workOrder.isKindOf(CM_WorkOrderTIDtl) then
				return false;
			endif;
		endif;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_workOrder" type="CM_WorkOrderDtl"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
