    <JadeMethod name="createGCAllocRowArea" id="1d316bba-b834-4bb3-afa3-5c5ac56d9cbe">
        <updating/>
        <source>createGCAllocRowArea(	_gcArea : CM_GeneralCargoAllocRowArea; 
						_assistant : CMUI_Assistant;
						_edit : Boolean;
						_form : YRD_LocationMaintForm;
						_areaMode : Integer		) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 30/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	loadStateSet : Boolean;
	lc : CM_LocationsController;
	group : CM_GeneralCargoAllocGroup;
	yardPadCol : YRD_PadColumn;
	yardPadRow : YRD_PadRow;
	idx : Integer;
	yardPadPoint : YRD_PadPoint;

begin
	app.cmsBeginLoad(loadStateSet);
	
	self.label			:= _gcArea.id;
	self.type			:= _gcArea.type;
	self.myAssistant	:= _assistant;
	
	if _areaMode = 0 then
		return;
	endif;
	
	self.areaMode := _areaMode;
	self.editMode := false;
	
	//epr 34985 3/10/14 use lane number for row not label
	foreach lc in _gcArea.allRowControllersById do
		group := lc.CM_GeneralCargoAllocGroup;
		idx := idx + 1;
		create yardPadCol transient;
		yardPadCol.setForCreateGCAllocRow(group.id, idx, self, group);
	endforeach;

	//at this point we only have 1 row
	create yardPadRow transient;
	
	yardPadRow.setForCreateGCAllocRow("", 1, self, group);
	
	idx := null;
	foreach lc in _gcArea.allRowControllersById do
		idx := idx + 1;
		group := lc.CM_GeneralCargoAllocGroup;
		create yardPadPoint transient;
		//epr 34985 3/10/14 use lane number for row not label
		yardPadPoint.setForCreateGCAllocRow(4, 2, 1, idx, group, self, null, group.allLabourRestrictions);
	endforeach;
	
epilog
	app.cmsEndLoad(loadStateSet);
end;</source>
        <Parameter name="_gcArea" type="CM_GeneralCargoAllocRowArea"/>
        <Parameter name="_assistant" type="CMUI_Assistant"/>
        <Parameter name="_edit" type="Boolean"/>
        <Parameter name="_form" type="YRD_LocationMaintForm"/>
        <Parameter name="_areaMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createGridArea" id="620f4dd8-0b69-48c2-91e9-5c51b83f5dc3">
        <updating/>
        <source>createGridArea(pGridArea : CM_GridArea; pAssistant : CMUI_Assistant; pEdit : Boolean; _form : YRD_LocationMaintForm; _areaMode : Integer) updating;//, serverExecution;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 27/1/2010	cnwjo3		copied from setFromCreate so we can create GridAreas and RoRoLaneAreas
// 07/11/2012	cnwcs5		par 30475 - remove references to CM_LocationRestrictionContainer
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------
vars
	cGridRow		: CM_GridRow;
	loadStateSet 	: Boolean;
	cGridCol		: CM_GridColumn;
	cGridController	: CM_GridController;
	yrdGridRow		: YRD_PadRow;
	yrdGridCol		: YRD_PadColumn;
	yrdGridPoint	: YRD_PadPoint;
	theSBS 			: CM_BlockStack;
begin

	app.cmsBeginLoad(loadStateSet);
	
	self.label		:= pGridArea.id;
	self.type		:= pGridArea.type;
	
	self.myAssistant	:= pAssistant;
	if _areaMode = 0 then
		return;
	endif;
	self.areaMode := _areaMode;
	self.editMode := false;
	foreach cGridRow in pGridArea.allGridRows do
		create yrdGridRow transient;
		yrdGridRow.setForCreate(cGridRow.getLabel, cGridRow.row, cGridRow.myGridArea.heightOfStack, self, cGridRow);
	endforeach;

	foreach cGridCol in pGridArea.allGridColumns do
		create yrdGridCol transient;
		yrdGridCol.setForCreate(cGridCol.label, cGridCol.column, self, cGridCol);
	endforeach;

	foreach cGridController in pGridArea.allGridControllersByRowColumn do
			
		create yrdGridPoint transient;
		
		theSBS := null;
		
		if cGridController.mySubBlockStack &lt;&gt; null then
			theSBS := cGridController.mySubBlockStack;
		endif;

		yrdGridPoint.setForCreate(2,2, cGridController.row, cGridController.column, cGridController,self, theSBS,cGridController.allLabourRestrictions );
	endforeach;
epilog
	app.cmsEndLoad(loadStateSet);

end;</source>
        <Parameter name="pGridArea" type="CM_GridArea"/>
        <Parameter name="pAssistant" type="CMUI_Assistant"/>
        <Parameter name="pEdit" type="Boolean"/>
        <Parameter name="_form" type="YRD_LocationMaintForm"/>
        <Parameter name="_areaMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createIrregularArea" id="6545fabb-86dd-4f43-ba34-cdaf5323f1da">
        <updating/>
        <source>createIrregularArea(_irregArea : CM_IrregularBlockArea; pAssistant : CMUI_Assistant; pEdit : Boolean; _form : YRD_LocationMaintForm; _areaMode : Integer) updating;
// TFS 3422 show irregular block areas for hazard maintenance
vars
	loadStateSet	: Boolean;
	row				: Integer;
	location		: CM_LocationsController;	
	yrdPadRow		: YRD_PadRow;
	yrdPadCol		: YRD_PadColumn;
	yrdPadPoint		: YRD_PadPoint;
begin
	app.cmsBeginLoad(loadStateSet);
	
	self.label			:= _irregArea.id;
	self.type			:= _irregArea.type;
	self.myAssistant	:= pAssistant;
	
	if _areaMode = 0 then
		return;
	endif;
	
	self.areaMode := _areaMode;
	self.editMode := false;
	
	// create a row for each locations controller
	foreach location in _irregArea.allLocationsControllers do
		row := row + 1;
		create yrdPadRow transient;
		yrdPadRow.setForCreateIrregularArea(location.ident, row, self, location);
	endforeach;

	// only show one column
	create yrdPadCol transient;
	
	yrdPadCol.setForCreateIrregularArea("", 1, self);
	row := 0;
	foreach location in _irregArea.allLocationsControllers do
		create yrdPadPoint transient;
		row := row + 1;
		yrdPadPoint.setForCreateIrregularArea(20, 2, row, 1, location, self);
	endforeach;
epilog
	app.cmsEndLoad(loadStateSet);

end;</source>
        <Parameter name="_irregArea" type="CM_IrregularBlockArea"/>
        <Parameter name="pAssistant" type="CMUI_Assistant"/>
        <Parameter name="pEdit" type="Boolean"/>
        <Parameter name="_form" type="YRD_LocationMaintForm"/>
        <Parameter name="_areaMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createRoRoLaneArea" id="743fe560-8e17-437e-95ae-ec587d96f426">
        <updating/>
        <source>createRoRoLaneArea(_roroArea : CM_RoRoLaneArea; pAssistant : CMUI_Assistant; pEdit : Boolean; _form : YRD_LocationMaintForm; _areaMode : Integer) updating;//, serverExecution;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 27/1/2010	cnwjo3		copied from setFromCreate so we can create GridAreas and RoRoLaneAreas
// 07/11/2012	cnwcs5		par 30475 - remove references to CM_LocationRestrictionContainer
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------
vars
	loadStateSet	: Boolean;
	cRoRoLane		: CM_RoRoController;	
	yrdPadRow		: YRD_PadRow;
	yrdPadCol		: YRD_PadColumn;
	yrdPadPoint		: YRD_PadPoint;
	theSBS 			: CM_BlockStack;
begin
	app.cmsBeginLoad(loadStateSet);
	
	self.label			:= _roroArea.id;
	self.type			:= _roroArea.type;
	self.myAssistant	:= pAssistant;
	
	if _areaMode = 0 then
		return;
	endif;
	
	self.areaMode := _areaMode;
	self.editMode := false;
	
	//epr 34985 3/10/14 use lane number for row not label
	foreach cRoRoLane in _roroArea.allLanesById do
		create yrdPadRow transient;
		yrdPadRow.setForCreateRoRoLane(cRoRoLane.id, cRoRoLane.laneNumber, self, cRoRoLane);
	endforeach;

	//at this point we only have 1 column!  its a RORO
	create yrdPadCol transient;
	
	yrdPadCol.setForCreateRoRoLane("", 1, self);

	foreach cRoRoLane in _roroArea.allLanesById do

		create yrdPadPoint transient;
		//epr 34985 3/10/14 use lane number for row not label
		yrdPadPoint.setForCreateRoRoLane(2,2, cRoRoLane.laneNumber,1, cRoRoLane,self, theSBS,cRoRoLane.allLabourRestrictions );
	endforeach;
epilog
	app.cmsEndLoad(loadStateSet);

end;</source>
        <Parameter name="_roroArea" type="CM_RoRoLaneArea"/>
        <Parameter name="pAssistant" type="CMUI_Assistant"/>
        <Parameter name="pEdit" type="Boolean"/>
        <Parameter name="_form" type="YRD_LocationMaintForm"/>
        <Parameter name="_areaMode" type="Integer"/>
    </JadeMethod>
