	if _passport.noErrors and
	   app.myRoot.myQueryMenuRoot &lt;&gt; null then
		app.myRoot.myQueryMenuRoot.causeEvent(Event_Selector_Create, false, _realQuery);	// 26608 Dec 2010 snap shot definition form issues
	endif;
