    <JadeMethod name="exHandlerAddWarningToPassport" id="de9da0b2-0884-4785-a5c3-7f88b32ef279">
        <source>exHandlerAddWarningToPassport(exObj: Exception; _passport : CM_Passport input): Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 July 2009	cnwndl1	Initial creation

*/

vars

begin

	if _passport &lt;&gt; null then
		if exObj.isKindOf(CM_Exception) and exObj.CM_Exception.isWarning then
			_passport.addWarningFull(exObj.errorCode,	//pErrorCode : Integer;
									exObj.extendedErrorText,	//pText : String;
									exObj.CM_Exception.userString,	//pField : String;
									exObj.CM_Exception.myUserObject,	//pObject : Object;
									exObj.CM_Exception.mySubject	//_subject : CM_Object
									);	   
			return Ex_Continue;
		endif;
	endif;

	return Ex_Pass_Back;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="exHandlerAssertException" id="39e40f41-0e4d-4e96-aff9-58a5f3b7bfa9">
        <updating/>
        <source>exHandlerAssertException(ex : Exception) : Integer updating, protected;
//16 July 2008	cnwdw1	
// Set up a handler for the assertException test
vars

begin
	if ex.isKindOf(UT_TestFailureException) then
		return Ex_Pass_Back;
	endif;
	self.assertException := true;
	self.exceptionCode := ex.errorCode;
	self.exceptionMessage := ex.cnEcGetDetails() &amp; CrLf;

	if ex.resumable then
		return Ex_Resume_Next;
	endif;		
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="ex" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="exHandlerTestFailure" id="3e9e69f1-32f5-4db1-b384-e6e1c38a5511">
        <updating/>
        <source>exHandlerTestFailure(ex : Exception) : Integer updating, protected;
//16 July 2008	cnwdw1	
//
/*

Date		Who		Reason
06 Aug 2013	cnwkpd1	Added abortTransaction before resuming to prevent 1025 exceptions when framework errors occur
	
*/

vars

begin
	if ex.isKindOf(UT_TestFailureException) then
		if ex.errorCode = ExceptionCode_TestFailure then
			self.assertException := true;
			self.exceptionCode := ex.errorCode;
			self.exceptionMessage := ex.UT_TestFailureException.message &amp; CrLf;
			self.exceptionMethodName :=  ex.UT_TestFailureException.methodName;
			self.exceptionMethodPosition := ex.UT_TestFailureException.methodPosition;
		endif;
	else
		// dump stack was commented out back in 2014... why ?
		// For the moment, lets just make sure we do it if running tests manually.
		if not app.isOvernightRun() then
			app.doDumpStack(ex);
		endif;
		
		self.exceptionFailure := true;
		self.exceptionCode := ex.errorCode;
		self.exceptionMessage := ex.cnEcGetDetails() &amp; CrLf;
	endif;
	
	if ex.resumable then
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="ex" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="expectTrxError" id="30abf5c9-9861-4396-9f9c-1623c215c9c0">
        <source>expectTrxError(_trxError: Integer) protected;

/*

Purpose:			Set up an expected trx error
					Should be used in conjuction with assertTrxError to check error actually occured

Parameters:			Error number

*/

vars

begin
	self.expectedTrxErrors.add(_trxError);
end;
</source>
        <access>protected</access>
        <Parameter name="_trxError" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="finalize" id="a6cbb702-a2e7-4370-9bee-a0d06999bed6">
        <source>finalize() protected;
//16 July 2008	cnwdw1	
// One time finalization for all tests
vars

begin
