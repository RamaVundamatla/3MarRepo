    <JadeMethod name="doActionTaskUnKnown" id="c67da29c-1e92-43ee-a990-92cffaa49bf1">
        <updating/>
        <source>doActionTaskUnKnown(_woActionIF   : CMIF_WorkOrderAction;
					_realJob	  : CM_Job io;
					_passport     : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Apr 2023 navma1  ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks
20 Apr 2023 navma1  ChangeRequest 57324:[57325] EUP - VAS Task linked with Release Cargo Work Order
17 Jul 2023	navma1	Bug 59158: MTN - Actioning ToDo work orders doesn't create Update Transaction
*/

vars
	jobParams,
	toDoJobParm		: CMIF_WorkOrderJobParams;
	woTrans     	: CM_WOTransaction;
	wodToDo			: CM_WodToDo;
	toDoJob			: CM_Job;
begin
	inheritMethod(_woActionIF,_realJob ,_passport);

	create jobParams transient;

	
	//Create Yard Job
	if _woActionIF.useYardJobs then
		self.createWOJobs(_woActionIF,jobParams,_realJob,_passport);		//12.04.2023 navma1 #57569:[57570]
		
		/*
		17.04.2023 navma1 #57324:[57325]
		*/
		wodToDo := self.getAttachedTodoDetail();							//17.04.2023 navma1 #57324:[57325]
		if wodToDo &lt;&gt; null then
			create toDoJobParm transient;
			toDoJobParm.setReserveDetail(self.myReserveDetail);				//17.04.2023 navma1 #57324:[57325]
			wodToDo.createWOJobs(_woActionIF,toDoJobParm,toDoJob,_passport);
		endif;
	endif;
epilog
	delete jobParams;
	delete toDoJobParm;
end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction"/>
        <Parameter name="_realJob" type="CM_Job" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAdvWOTransactionType" id="e4adeac7-bce4-48eb-b5e5-a700b618e2c3">
        <source>getAdvWOTransactionType(transType : Integer): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
17 October 2022		navcs2	ChangeRequest 56633:[56211] 54253.101 - Work order Transactions

*/

vars

begin
	if transType = TRANS_CREATED then
		return TRANS_TYPE_WO_TIREL_CREATED;
	elseif transType = TRANS_UPDATED then
		return TRANS_TYPE_WO_TIREL_UPDATED;
	else
		return TRANS_TYPE_WO_TIREL_COMPLET;
	endif;
epilog

end;</source>
        <Parameter name="transType" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
