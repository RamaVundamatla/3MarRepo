<Class name="CM_SmtpConnection" id="f6416d64-43c9-4647-b871-4694b11e23ea">
    <superclass name="CnSmtpConnection"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="cleanUpConnection" id="a7028184-225a-4414-95c2-b5eebcc84053">
        <updating/>
        <source>cleanUpConnection() updating;
// -------------------------------------------
// Created 27 November 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	app.writeLog('Deleting transient objects', LogINFO);
	self.deleteFile();
	delete self;


end;</source>
    </JadeMethod>
    <JadeMethod name="deleteFile" id="7fa3a54b-d81c-41ae-b177-682feb964454">
        <source>deleteFile() protected;
// -------------------------------------------
// Created 27 November 2003 by cnwdvb1
// -------------------------------------------

vars


	path,
	errorText	: String;
	fileError,
	fileNormal	: File;
	error		: Integer;
	attachment	: CnAttachment;


begin

	// FileError objects are removed in the delete method of the CnSmtpConnection object.
	// FileNormal object reference is deleted at end of this method.
	on Exception do app.alertExceptionHandler(exception, null,'SMTP', error, errorText, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	create fileNormal transient;
	foreach attachment in self.myAttachments do
		fileError := attachment.fileObject;
		if fileError &lt;&gt; null then
			app.writeLog('Deleting email attachment - ' &amp; fileError.fileName, LogINFO);
			fileError.close;
			fileError.purge;
		else
			fileNormal.kind 		:=  File.Kind_Unknown_Text; // 3/3/16  cnwns1 PAR 36286 unicode version
			fileNormal.mode			:=	File.Mode_Input;
			fileNormal.shareMode	:=	File.Share_Exclusive;
			fileNormal.fileName		:= 	attachment.fileName;
			if fileNormal.tryOpen then
				app.writeLog('Deleting email attachment - ' &amp; fileNormal.fileName, LogINFO);
				fileNormal.purge;
			endif;
		endif;
	endforeach;
epilog
	delete fileNormal;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="send" id="0b026756-1d28-49c3-971d-9c647348a8ff">
        <updating/>
        <source>send() updating;
// -------------------------------------------
// Created 27 November 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	on Exception do self.xHandler(exception);
	inheritMethod();


end;</source>
    </JadeMethod>
    <JadeMethod name="userNotification" id="30584b56-7edf-4c20-a8ad-e6293bd94fa4">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// -------------------------------------------
// Created 26 November 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	app.writeLog('Receiving note', LogINFO);
	inheritMethod(eventType, theObject, eventTag, userInfo);
	if eventType = CnSmtpConnection.Completion_Event_Type and theObject = self then
		self.cleanUpConnection();
	endif;



end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="xHandler" id="5a2c169d-5440-4ca4-9998-790b0f2486e9">
        <source>xHandler(exObj : Exception) : Integer protected;
// -------------------------------------------
// Created 27 November 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	app.writeLog('Exception (' &amp; exObj.errorCode.String &amp; ')', LogINFO);
	self.causeEvent(CnSmtpConnection.Completion_Event_Type, true, null);
	return Ex_Pass_Back;
	


end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
