    <JadeMethod name="utlUpdateDamageRepair" id="4df086e7-f4fa-42ac-89ac-5b1228c9ae56">
        <updating/>
        <source>utlUpdateDamageRepair(_pxyDamageRepairDict : CM_DamageInstanceSet input; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Mar 2023	navlw1	Initial creation tfs 53880 Repair extra details
30 Aug 2023 navlc30 Bug 59976: EUP | FR 53489 - Damage Recording Extra Details - Repair Date
*/

vars
	pxyDamageRepair, 
	realDamageRepair 	: CM_DamageInstance;
	expectedEdition 	: Integer;
	repaired 			: Boolean;
	
begin
	self.initialiseActivity();
	
	foreach pxyDamageRepair in _pxyDamageRepairDict do
		pxyDamageRepair.raiseExceptionIfNotProxy(method);
	endforeach;
	
	app.setContinueCMExceptions(true);
	
	app.myValUA.valDamageRepair(_pxyDamageRepairDict);				//30.08.2023 navma1 #59976
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	//Lock all our objects in one go in case someone grabs the last one and updates it
	foreach pxyDamageRepair in _pxyDamageRepairDict do
		pxyDamageRepair.pxyGetRealObjectAndEdition(realDamageRepair, expectedEdition);
		exclusiveLock(realDamageRepair);
	endforeach;
	
	//Loop through our transients and update the real object
	foreach pxyDamageRepair in _pxyDamageRepairDict do
		repaired := false;
		pxyDamageRepair.pxyGetRealObjectAndEdition(realDamageRepair, expectedEdition);
	
		if _passport.noErrors and realDamageRepair.edition &lt;&gt; expectedEdition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Damage Repair', null, null);
			return;
		endif;
		
		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(realDamageRepair, true);
		endif;
		
		if _passport.noErrors then
			realDamageRepair.setForUpdate(pxyDamageRepair,realDamageRepair.myTrackedItem,realDamageRepair.myTIMaster, false, repaired);
		endif;

		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(realDamageRepair, false);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_pxyDamageRepairDict" type="CM_DamageInstanceSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateDamageSeverity" id="2d7185df-8a1d-4ead-8227-ab755ceee046">
