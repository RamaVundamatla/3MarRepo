<CollClass name="CMIF_LocActRepThroughPutDict" id="11a9b3f0-9e0e-489b-a778-9bbba63834c1">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="CMIF_LocActRepThroughPut"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <MemberKey>
        <property name="CMIF_LocActRepThroughPut::myOperator"/>
    </MemberKey>
    <MemberKey>
        <property name="CMIF_LocActRepThroughPut::myCargoType"/>
    </MemberKey>
