    <JadeMethod name="doMnuTrainConfirm" id="eb888321-0a3e-4808-9576-edbba4cc8b72">
        <updating/>
        <source>doMnuTrainConfirm() updating;
// ---------------------------------------------------------------------------
// Created:		November  2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	railLine : CM_RailLine;
	autoPlan : Boolean;
	result	 : Integer;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	wagonMoveControl : CMIF_WagonMoveController;	//25 Feb 2021	NDL	TFS 50837
	
begin
	if self.myCurrentTrain = null then	
		//app.msgBox('Please select a train to confirm first','No train selected', MsgBox_Exclamation_Mark_Icon); //- cnwmd1, CCMS 1067, Par 19710
		app.msgBox(app.getErrorString(Please_select_train_confir_fir), app.getErrorString(No_Train_selected), MsgBox_Exclamation_Mark_Icon);//+ cnwmd1, CCMS 1067, Par 19710
		return;
	endif;
	
	//if app.msgBox('Are you sure that you want to confirm all wagons for train ' &amp; self.myAssistant.displayEntryTrain(self.myCurrentTrain) &amp; ' onto the tracks?', "Train Confirmation", MsgBox_Question_Mark_Icon + MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then //- cnwmd1, CCMS 1067, Par 19710
	if app.msgBox(app.getErrorString1(Sure_that_want_confi_wagon_tra, self.myAssistant.displayEntryTrain(self.myCurrentTrain)), app.getErrorString(Train_confirmation), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	//result := app.msgBox("Do you want the system to Autoplan the cargo?", "Auto Plan?", MsgBox_Question_Mark_Icon + MsgBox_Yes_No); //- cnwmd1, CCMS 1067, Par 19710
	result := app.msgBox(app.getErrorString(Want_system_autopla_cargo), app.getErrorString(Auto_plan_QuestionMark), MsgBox_Question_Mark_Icon + MsgBox_Yes_No);//+ cnwmd1, CCMS 1067, Par 19710
	if result = MsgBox_Return_Yes then
		autoPlan := true;
	endif;
	
	//25 Feb 2021	NDL	TFS 50837
	create wagonMoveControl transient;
	if not validateRetrospectiveTS( wagonMoveControl ) then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	foreach railLine in self.myCurrentRailArea.allRailLines do
		
		//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateWagonConfirmTrain(wagonMoveControl, true, self.myCurrentTrain, autoPlan, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog(app.getErrorString(Train_confirmation), app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
		
	endforeach;
	
	
epilog
	delete wagonMoveControl;
	app.mousePointer := MousePointer_Default;				
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuUnplanClick" id="b6de009e-db79-4ec7-8c37-34fd2f57aa65">
        <updating/>
        <source>doMnuUnplanClick(_menuItem : MenuItem input) updating, protected; 
// ---------------------------------------------------------------------------
// Created:      01 August 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin
	inheritMethod(_menuItem);
	if _menuItem.userObject.CM_TrackedItem.getPrimaryLocation(QUEUE_MODE) &lt;&gt; null then 

		doUnqueueTI(_menuItem.userObject.CM_TrackedItem);
	else
		doUnplanTI(_menuItem.userObject.CM_TrackedItem,(_menuItem.helpKeyword = "LOAD"));
	
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
