    <JadeMethod name="doSave" id="282939c3-5392-46d9-9656-b79587c57ea5">
        <updating/>
        <source>doSave(): Boolean updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	pxyPilot	:	HMS_Pilot;
	theForm		:	SOP_HMS_TableMaintForm;
	theHarbour: HMS_Harbour;		
begin
//	return inheritMethod();
	theForm := self.myForm.SOP_HMS_TableMaintForm;
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as HMS_Pilot transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy is null for update');
			return false;
		endif;
	endif;
	
	pxyPilot := theForm.myProxyObject.HMS_Pilot;
	theForm.tblInput1.setObjectFromTable(pxyPilot, null, false);
	theHarbour := theForm.cmbHarbour.listObject.HMS_Harbour;
	pxyPilot.setProxy(app.myRoot, theHarbour);
	self.doSaveResourcesTbl(pxyPilot);
	
	//Are we adding or updating
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateHMSObject(pxyPilot, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateHMSObject(pxyPilot, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name,
										method.name, 
										'  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
		
	return app.myPassport.trxCompletedOK;
		
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveResourcesTbl" id="5ad1ccd0-afb7-4ea8-9ccf-263a793ab0cd">
        <source>doSaveResourcesTbl(_pxyPilot : HMS_Pilot);
// ---------------------------------------------------------------------------
// Created:     18 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	theForm 	: SOP_TableMaintForm;
	idx			: Integer;
	tmpDataTable	: CM_DataTable;
	obj			: Object;
	harbour	: HMS_Harbour;
	prxyResourceForPilot	: HMS_ResourceForPilot;
	arrResource,
	depResource,
	shiftResource :	HMS_Resource;
	
begin

	theForm := self.myForm; 

	tmpDataTable := self.myForm.tblData1;
	foreach idx in 2 to tmpDataTable.rows do
		harbour 			:= tmpDataTable.accessRow(idx).itemObject.HMS_Harbour;
		arrResource 		:= tmpDataTable.accessCell(idx, 2).itemObject.HMS_Resource;
		depResource 		:= tmpDataTable.accessCell(idx, 3).itemObject.HMS_Resource;
		shiftResource 		:= tmpDataTable.accessCell(idx, 4).itemObject.HMS_Resource;		

		prxyResourceForPilot := _pxyPilot.allResourcesForPilot[harbour,_pxyPilot];
		
		if prxyResourceForPilot = null then
				create prxyResourceForPilot transient;
		endif;
		prxyResourceForPilot.setProxy(_pxyPilot,harbour,arrResource,depResource,shiftResource);

	endforeach;
end;</source>
        <Parameter name="_pxyPilot" type="HMS_Pilot"/>
    </JadeMethod>
