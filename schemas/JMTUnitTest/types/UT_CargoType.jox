    <JadeMethod name="tTestCarCargoType" id="1f03a743-e99e-4cec-8bc8-a0e1f63f05fa">
        <source>tTestCarCargoType();

/*

Purpose:		Test the Car Cargo Type (CCMS DPH 2290) (TestLink:- 01-1094: Car Cargo Type)

Date			Who		Reason
08/05/2015		cnwmh5	Initial creation

*/
constants

	CargoTypeAbberv					: String = "UT_CAR01";
	BookingCode						: String = "UTBOOKA001";
	PrenoteId						: String = "UTPRENOTE01";
	VoyageId						: String = "UT001VOY";
	VesselId						: String = "MESDIAM";
	TruckId							: String = "UTMHTRUCK";
	YAId							: String = "UTMHCCargoType";
	BlockStackId					: String = "UTMHCCT";
	
vars

	cargoType						: CM_CargoType;
	booking							: CM_BookingRef;
	operator						: CM_Operator;
	voyage							: CM_Voyage;
	ti								: CM_TrackedItem;
	vvr								: CM_VehicleVisitRecord;
	bs								: CM_BlockStack;
	ya								: CM_YardAllocation;
	
	locations 						: CM_LCArray;
	
begin

	self.disableAllYA(true);

	self.deleteVehicle(TruckId);
	
	self.opts.purge();
	self.opts.addAssoc("TrackAs", ProductType_Vehicle);
	cargoType := self.addCargoType(CargoTypeAbberv, false);
	self.assertNotNull(cargoType);
	
	operator := getOperator("UTOP");
	self.assertNotNull(operator);
	
	self.deleteVoyage(VoyageId);
	voyage := self.addVoyageWithConRORO(VoyageId, VesselId, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, 
		self.getProfileSetting(UT_Profile.P_TRADE).asString, 0, false, true);
	self.assertNotNull(voyage);
	
	bs := self.addBlockStack(BlockStackId, 99, null);
	self.assertNotNull(bs);
	
	create locations transient;
	locations.add(bs.allLocationsControllers.first);
	ya := self.addYA(YAId, YACriteriaType_VehicleMake, "FORD", null, null, null, null, locations, null);
	self.assertNotNull(ya);

	// Add booking
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(DISCH_PORT_NO_LONGER_VALID);
	self.deleteBooking(BookingCode);
	booking := self.addBookingForGeneralCargo(BookingCode, operator, voyage, "NZAKL", cargoType.id, 5);
	self.assertNotNull(booking);
	self.clearExpectedTrxErrors();
	
	// Add prenote
	ti := self.getTrackedItem(PrenoteId);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, false);
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("CargoType", cargoType.id);
	self.opts.addAssoc("Colour", "BLUE");
	self.opts.addAssoc("Make", "FORD");
	self.opts.addAssoc("Model", "FOCUS");
	self.opts.addAssoc("Type", "HATCHBACK");
	self.opts.addAssoc("Year", 2002);
	self.opts.addAssoc("TrackingNo1", "asdfh123");
	self.opts.addAssoc("NoDoors", 5);
	self.opts.addAssoc("NewVehicle", true);
	ti := self.addPrenoted(PrenoteId);
	self.assertNotNull(ti);
	
	// time to gate in the prenote
	vvr := self.gateInPrenote(TruckId, "", "", ti, self.getProfileSetting(UT_Profile.P_DGATE).asString);
	self.assertNotNull(vvr);
	
	self.workVehicle(vvr);
	
	self.roadExit(vvr);
	
epilog

	self.disableAllYA(false);	
	
	delete locations;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tTestCargoUnpack" id="5ec3abb0-bb0d-4da4-af75-685e05659e36">
        <updating/>
        <source>tTestCargoUnpack() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 February 2016	cnwmp6	Initial creation

*/
constants
	ContainerId = "UTMPP00001";
	CargoId = "UTMPC00001";

vars
	container: CM_TrackedItem;
	containerType: CM_CargoType;
	cargoType: CM_CargoType;
	attachment, attachment2: CMIF_InOutAttachment;
	attachments: CMIF_InOutAttachmentArray;
	tiCont: CMIF_TranshipTIController;
	bs			: CM_BlockStack;
	voyage			: CM_Voyage;
	voyageO			: CM_Voyage;
	operator		: CM_Operator;
	terminal: CM_Terminal;
	unpackTIs: CM_TIArray;

begin
	terminal := CM_Root.firstInstance.allTerminals[self.getProfileSetting(UT_Profile.P_TERMINAL).asString];
	assertNotNull(terminal);
	
	bs := self.addBlockStack("UTMPBS1", 999, null);
	self.assertNotNull(bs);
	
	operator := app.myRoot.allOperators["UTOP"];
	self.assertNotNull(operator);
	
	container := self.addContainerAtLocation(ContainerId, operator, "2200", "GENL", TI_IMEX_STATUS_IMPORT, bs.allLocationsControllers.first);
	self.assertNotNull(container);
	self.deleteStops(container);
	
	self.deleteVoyage("UTMPVOY1");
	voyage := self.addVoyageWithConRORO("UTMPVOY1", "MESDIAM", operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, 
		self.getProfileSetting(UT_Profile.P_TRADE).asString, 0, true, false);
	self.assertNotNull(voyage);	
	
	self.deleteVoyage("UTMPVOYO");
	voyageO := self.addVoyageWithConRORO("UTMPVOYO", "MESDIAM", operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, 
		self.getProfileSetting(UT_Profile.P_TRADE).asString, 0, true, false);
	self.assertNotNull(voyageO);
	
	self.opts.purge();
	self.opts.addAssoc("Voyage", voyage);
	self.updateTI(container);
	
	self.opts.purge();
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_IMPORT);
	self.updateTI(container);
	
	create tiCont transient;
	tiCont.allTrackedItems.add(container);
	tiCont.myExportDestPort  	:= app.myRoot.allPorts['NZAKA'];
	tiCont.myExportDisPort 		:= app.myRoot.allPorts['NZAKL'];
	tiCont.myExportVoyage 		:= voyageO;
	tiCont.remarks 				:= "Something really silly";
	//tiCont.removeStops 			:= true; // TFS 47222 jlgzm1 20/11/2019
	
	self.makeTrackedItemTranship(tiCont);
	assertTrueMsg(container.isTranshipItem, "Not tranship item");
	
	cargoType := self.getCargoType("LCL Cargo");
	assertNotNull(cargoType);

	create attachment transient;
	attachment.set(terminal, cargoType.id, "MAP1234", "", 100); 
	attachment.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;

	create attachment2 transient;
	attachment2.set(terminal, cargoType.id, "MAP2345", "", 190); 
	attachment2.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;

	create attachments transient;
	attachments.add(attachment);
	attachments.add(attachment2);
	
	addContainerChildren(container.CM_Container, attachments);
	assertEqualMsg(container.allChildren.size(), 2, "Doesn't have two children");
	
	create unpackTIs transient;
	unpackTIs.add(container.allChildren.first);
	
	self.unpackContainer(container, unpackTIs);
	assertEqualMsg(container.allChildren.size(), 1, "Doesn't have one child");
	assertEqualMsg(container.allChildren.first.id, "MAP2345", "Remaining cargo isn't MAP2345");

epilog
	delete tiCont;
	delete attachment;
	delete attachment2;
	delete attachments;
	delete unpackTIs;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tTestCertifiedWeight" id="6cd98d75-1dab-492f-9014-fcc4dba8d6f5">
        <source>tTestCertifiedWeight();
/*

Purpose:			Testlink test 01-185 Certified Weight

Date		Who		Reason
08/11/2016	cnwmk3	Initial creation
29/06/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
*/
constants
	ContId				= "CONTR185";
	BBCargoId			= "BBULK185";
	TRK1				= "TRK185";
vars
	cargoType1			: CM_CargoType;
	cargoType2			: CM_CargoType;
	ti1, ti2			: CM_TrackedItem;
	vvr					: CM_VehicleVisitRecord;
	controller			: CMIF_TIUpdateController;
begin
	cargoType1 := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	cargoType2 := app.myRoot.allCargoTypesById[TI_CargoType_BreakBulk];
	
	// prenote1
	ti1 := self.getTrackedItem(ContId);
	self.deleteTrackedItem(ti1, false);
	ti1 := self.getTrackedItem(ContId);
	self.assertNull(ti1);
	ti1 := self.addPrenoted(ContId);
	self.assertNotNull(ti1);
	
	// prenote2
	ti2 := self.getTrackedItem(BBCargoId);
	self.deleteTrackedItem(ti2, false);
	ti2 := self.getTrackedItem(BBCargoId);
	self.assertNull(ti2);
	self.opts.purge();
	self.opts.addAssoc("CargoType", cargoType2.id);
	self.opts.addAssoc("Commodity", "BBLK");
	ti2 := self.addPrenoted(BBCargoId);
	self.assertNotNull(ti2);
	
	// gate in cargo for prenote1 and prenote2
	self.deleteVehicle(TRK1);
	vvr := gateInContainer(TRK1, ContId, "2200", "UTOP", "MT", self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString()));
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	vvr := gateInGC(TRK1, "", "", BBCargoId, cargoType2.description, "UTOP", "MT", self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString()), 1);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	// 	Edit the cargo item that can have the weight certified. Should be able to set Is Weight Certified to true and save.
	ti1 := self.getTrackedItem(ContId);
	controller := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.getMyUserCode(), null);
	beginTransaction;
	ti1.setIsWeightCertified(true, controller, app.myPassport);
	//ti1.setWeightCertifiedName("TESTET1", controller, app.myPassport);			// TFS 4492
	//ti1.setWeightCertifiedReference("TESTET1", controller, app.myPassport);		// TFS 4492
	ti1.setMyVGMDetails(	"TESTET1", "TESTET1", null, null, null, null, null,		// TFS 4492
							null, null, null, null, null, null, controller	);		// TFS 4492
	commitTransaction;
	self.assertEqual(ti1.isWeightCertified, true);
	
epilog
	delete controller;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTestFindPartial" id="275b7408-6559-4961-9ea4-0467ddeadab0">
        <source>tTestFindPartial();
//
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
// 10 Sep 2019	cnwrs1	TFS 46030
// 27 May 2022	navdap1	Changes to search to fix Deleted Logs issue
//
constants
	VESSEL_CODE		: String = "UTMTREL";
	VOYAGE_CODE		: String = "UTMTREL100";
	CargoId1 = "PUKE";
	CargoId2 = "#691";
vars
	vesselObj : CM_Vessel;
	voyageObj : CM_Voyage;
	cargoId : String;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	ti2 : CM_TrackedItem;
	operator : CM_Operator;
	idx : Integer;
	state : Integer;
	site : Integer;
	foundTIs : CM_TISet;
	searchReversed : Boolean;
	containerEnqSearch : Boolean;
	bs			: CM_BlockStack;					// 24/01/2017 cnwmh5
	lc			: CM_LocationsController;			// 25/01/2017 cnwmh5
	commodity : String;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	searchReversed := false;
	containerEnqSearch := false;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.deleteVoyage(VOYAGE_CODE);
	self.deleteVessel(VESSEL_CODE);
	vesselObj := self.addVesselCellular(VESSEL_CODE, operator);
	voyageObj := self.addVoyageWithContainerStructur(VOYAGE_CODE, VESSEL_CODE, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString());
	self.assertNotNull(voyageObj);
	self.assertNotNull(vesselObj);
	
	// 24/01/2017 cnwmh5 - Set up block stack ann set in opts
	bs := self.addBlockStack("BSTFP", 99, null);	
	self.assertNotNull(bs);		
	
	create foundTIs transient;
	foreach cargoType in CM_CargoType.instances do
		if cargoType.id &gt; 10 then
			break;
		endif;
		foreach idx in 1 to TI_STATE_MAX - 1 do
			if idx = TI_STATE_EDI or
			   idx = TI_STATE_ARCHIVED or
			   idx = TI_STATE_MERGED or
			   idx = TI_STATE_TRANSFER or
			   idx = TI_STATE_TRANSFER_FROM or
			   idx = TI_STATE_TRANSFER_TO or
			   idx = TI_STATE_GHOST then
				continue;
			endif;
			state := idx;
			site := app.stateToSite(state);
			
			// 25/12/2017 cnwmh5
			if state = TI_STATE_ONSHIP then
				lc := voyageObj.getNextFreeSlotLCByDischargeCC(false);
			else
				lc :=  bs.myLocationsController;
			endif;
			
			cargoId := CargoId1&amp;idx.String&amp;cargoType.id.String&amp;CargoId2;
			ti := self.getTrackedItem(cargoId).CM_TrackedItem;
			self.deleteTrackedItem(ti, true);
			self.assertIsDeleted(ti);
			if cargoType.allCommodities.size &gt; 0 then
				commodity := cargoType.allCommodities.first.code;
			else
				commodity := null;
			endif;
			ti := self.createTrackedItem(cargoId, cargoType.id, commodity, operator, false, lc);
			beginTransaction;
			ti.setPropertyValue("state", state);
			ti.setPropertyValue("site", site);
			ti.setPropertyValue(CM_TrackedItem::myVoyage.name, voyageObj);
			ti.updateCollections();
			commitTransaction;
			cargoId := CargoId2&amp;idx.String&amp;cargoType.id.String&amp;CargoId1;
			ti := self.getTrackedItem(cargoId).CM_TrackedItem;
			self.deleteTrackedItem(ti, true);
			self.assertIsDeleted(ti);
			ti := self.createTrackedItem(cargoId, cargoType.id, commodity, operator, false, lc);
			state := idx;
			site := app.stateToSite(state);
			beginTransaction;
			ti.setPropertyValue("state", state);
			ti.setPropertyValue("site", site);
			ti.setPropertyValue(CM_TrackedItem::myVoyage.name, voyageObj);
			ti.updateCollections();
			commitTransaction;
		endforeach;
	endforeach;
	foreach cargoType in CM_CargoType.instances do
		if cargoType.id &gt; 10 then
			break;
		endif;
		foreach idx in 1 to TI_STATE_MAX - 1 do
			if idx = TI_STATE_EDI or
			   idx = TI_STATE_ARCHIVED or
			   idx = TI_STATE_MERGED or
			   idx = TI_STATE_TRANSFER or
			   idx = TI_STATE_TRANSFER_FROM or
			   idx = TI_STATE_TRANSFER_TO or
			   idx = TI_STATE_GHOST then
				continue;
			endif;
			state := idx;
			site := app.stateToSite(state);
			cargoId := CargoId1&amp;idx.String&amp;cargoType.id.String&amp;CargoId2;
			foundTIs.clear;
			self.getTerminal.findAllCargoStartsWithId(cargoId, cargoType.id, state, null, searchReversed, containerEnqSearch, foundTIs);
			self.assertEqualMsg(foundTIs.size, 1, "there should be 1");
		endforeach;
		foundTIs.clear;
		self.getTerminal.findAllCargoStartsWithId("PUKE", cargoType.id, 0, null, searchReversed, containerEnqSearch, foundTIs);
		if cargoType.id = TI_CargoType_Log then
			self.assertEqualMsg(foundTIs.size, 13, "there should be 13 " &amp; cargoType.abbreviation);
		else
			self.assertEqualMsg(foundTIs.size, 11, "there should be 11 " &amp; cargoType.abbreviation);
		endif;
		foundTIs.clear;
		self.getTerminal.findAllCargoStartsWithId("PUKE", 0, state, null, searchReversed, containerEnqSearch, foundTIs);
		self.assertEqualMsg(foundTIs.size, 18, "there should be 18");
	endforeach;
	foundTIs.clear;
	self.getTerminal.findAllCargoStartsWithId("PUKE", 0, 0, null, searchReversed, containerEnqSearch, foundTIs);
	self.assertEqualMsg(foundTIs.size, 99, "there should be 90");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete foundTIs;
end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;CreateTrackedItemFixed&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tTestFindPartial11" id="0dd8af68-82ba-4b0f-be88-214accf74e91">
        <source>tTestFindPartial11();
//
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
// 10 Sep 2019	cnwrs1	TFS 46030
// 27 May 2022	navdap1	Changes to Cargo enquiry to show Deleted logs if you enquire on state Deleted
//
constants
	VESSEL_CODE		: String = "UTMTREL";
	VOYAGE_CODE		: String = "UTMTREL100";
	CargoId1 = "PUKE";
	CargoId2 = "#691";
vars
	vesselObj : CM_Vessel;
	voyageObj : CM_Voyage;
	cargoId : String;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	ti2 : CM_TrackedItem;
	operator : CM_Operator;
	idx : Integer;
	state : Integer;
	site : Integer;
	foundTIs : CM_TISet;
	cargoTypeCount : Integer;
	stateCount : Integer;
	searchReversed : Boolean;
	containerEnqSearch : Boolean;
	bs			: CM_BlockStack;					// 24/01/2017 cnwmh5
	lc			: CM_LocationsController;			// 25/01/2017 cnwmh5
	commodity : String;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	searchReversed := false;
	containerEnqSearch := false;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.deleteVoyage(VOYAGE_CODE);
	self.deleteVessel(VESSEL_CODE);
	vesselObj := self.addVesselCellular(VESSEL_CODE, operator);
	voyageObj := self.addVoyageWithContainerStructur(VOYAGE_CODE, VESSEL_CODE, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString());
	self.assertNotNull(voyageObj);
	self.assertNotNull(vesselObj);
	
	// 24/01/2017 cnwmh5 - Set up block stack ann set in opts
	bs := self.addBlockStack("BSTFP", 99, null);	
	self.assertNotNull(bs);		
	
	create foundTIs transient;
	foreach cargoType in CM_CargoType.instances do
		if cargoType.id &gt; 10 then
			break;
		endif;
		cargoTypeCount := cargoTypeCount + 1;
		foreach idx in 1 to TI_STATE_MAX - 1 do
			if idx = TI_STATE_EDI or
			   idx = TI_STATE_ARCHIVED or
			   idx = TI_STATE_MERGED or
			   idx = TI_STATE_TRANSFER or
			   idx = TI_STATE_TRANSFER_FROM or
			   idx = TI_STATE_TRANSFER_TO or
			   idx = TI_STATE_GHOST then
				continue;
			endif;
			if cargoTypeCount = 1 then
				stateCount := stateCount + 1;
			endif;
			state := idx;
			site := app.stateToSite(state);
			
			// 25/12/2017 cnwmh5
			if state = TI_STATE_ONSHIP then
				lc := voyageObj.getNextFreeSlotLCByDischargeCC(false);
			else
				lc :=  bs.myLocationsController;
			endif;
			
			cargoId := CargoId1&amp;idx.String&amp;cargoType.id.String&amp;CargoId2;
			ti := self.getTrackedItem(cargoId).CM_TrackedItem;
			self.deleteTrackedItem(ti, true);
			self.assertIsDeleted(ti);
			if cargoType.allCommodities.size &gt; 0 then
				commodity := cargoType.allCommodities.first.code;
			else
				commodity := null;
			endif;
			ti := self.createTrackedItem(cargoId, cargoType.id, commodity, operator, false, lc);
			beginTransaction;
			ti.setPropertyValue("state", state);
			ti.setPropertyValue("site", site);
			ti.setPropertyValue(CM_TrackedItem::myVoyage.name, voyageObj);
			ti.updateCollections();
			commitTransaction;
			cargoId := CargoId2&amp;idx.String&amp;cargoType.id.String&amp;CargoId1;
			ti := self.getTrackedItem(cargoId).CM_TrackedItem;
			self.deleteTrackedItem(ti, true);
			self.assertIsDeleted(ti);
			if cargoType.allCommodities.size &gt; 0 then
				commodity := cargoType.allCommodities.first.code;
			else
				commodity := null;
			endif;
			ti := self.createTrackedItem(cargoId, cargoType.id, commodity, operator, false, lc);
			state := idx;
			site := app.stateToSite(state);
			beginTransaction;
			ti.setPropertyValue("state", state);
			ti.setPropertyValue("site", site);
			ti.setPropertyValue(CM_TrackedItem::myVoyage.name, voyageObj);
			ti.updateCollections();
			commitTransaction;
		endforeach;
	endforeach;
	foreach cargoType in CM_CargoType.instances do
		if cargoType.id &gt; 10 then
			break;
		endif;
		foreach idx in 1 to TI_STATE_MAX - 1 do
			if idx = TI_STATE_EDI or
			   idx = TI_STATE_ARCHIVED or
			   idx = TI_STATE_MERGED or
			   idx = TI_STATE_TRANSFER or
			   idx = TI_STATE_TRANSFER_FROM or
			   idx = TI_STATE_TRANSFER_TO or
			   idx = TI_STATE_GHOST then
				continue;
			endif;
			state := idx;
			site := app.stateToSite(state);
			cargoId := CargoId1&amp;idx.String&amp;cargoType.id.String&amp;CargoId2;
			foundTIs.clear;
			self.getTerminal.findAllCargoStartsWithId(cargoId, cargoType.id, state, null, searchReversed, containerEnqSearch, foundTIs);
			self.assertEqualMsg(foundTIs.size, 1, "there should be 1");
			foundTIs.clear;
			self.getTerminal.findAllCargoStartsWithId(cargoId, cargoType.id, 0, null, searchReversed, containerEnqSearch, foundTIs);

			if  state = 6 then
				if cargoType.id = TI_CargoType_Log then
					self.assertEqualMsg(foundTIs.size, 1, cargoType.abbreviation &amp; " there should be 1");
				else
					self.assertEqualMsg(foundTIs.size, 0, cargoType.abbreviation &amp; " there should be 0");
				endif;
			else
				self.assertEqualMsg(foundTIs.size, 1, "there should be 1");
			endif;
			foundTIs.clear;
			self.getTerminal.findAllCargoStartsWithId("PUKE", cargoType.id, state, null, searchReversed, containerEnqSearch, foundTIs);
			if state = 5 then
				self.assertEqualMsg(foundTIs.size, 1, "there should be 2");
			else
				self.assertEqualMsg(foundTIs.size, 2, "there should be 2");
			endif;
			foundTIs.clear;
			self.getTerminal.findAllCargoStartsWithId("PUKE", 0, state, null, searchReversed, containerEnqSearch, foundTIs);
			if state = 5 then
				self.assertEqualMsg(foundTIs.size, 9, "there should be "&amp;(cargoTypeCount*2).String);
			else
				self.assertEqualMsg(foundTIs.size, cargoTypeCount*2, "there should be "&amp;(cargoTypeCount*2).String);
			endif;
		endforeach;
		foundTIs.clear;
		self.getTerminal.findAllCargoStartsWithId("PUKE", cargoType.id, 0, null, searchReversed, containerEnqSearch, foundTIs);
		
		if cargoType.id = TI_CargoType_Log then
			self.assertEqualMsg(foundTIs.size, 13, "there should be "&amp;(stateCount*2).String);
		else
			self.assertEqualMsg(foundTIs.size, 11, "there should be "&amp;(stateCount*2).String);
		endif;
//		self.assertEqualMsg(foundTIs.size, stateCount*2, "there should be "&amp;(stateCount*2).String);
	endforeach;
	foundTIs.clear;
	self.getTerminal.findAllCargoStartsWithId("PUKE", 0, 0, null, searchReversed, containerEnqSearch, foundTIs);
	
	self.assertEqualMsg(foundTIs.size, 99, "there should be "&amp;(cargoTypeCount*stateCount*2).String);
//	self.assertEqualMsg(foundTIs.size, cargoTypeCount*stateCount*2, "there should be "&amp;(cargoTypeCount*stateCount*2).String);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete foundTIs;
end;
</source>
