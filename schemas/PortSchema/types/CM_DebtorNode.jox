    <JadeMethod name="getDebtors" id="4a20418d-2eba-43e6-8352-1add21386adc">
        <source>getDebtors(_theDebtors : CM_DebtorNodeByNameDict input);
// ---------------------------------------------------------------------------
// Created:     08 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	dn	: CM_DebtorNode;
begin
	if (not self.isGroup) then
		_theDebtors.add(self);
	endif;
	
	foreach dn in self.allChildDebtorNodes do
		dn.getDebtors(_theDebtors);
	endforeach;

end;</source>
        <Parameter name="_theDebtors" type="CM_DebtorNodeByNameDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDepthText" id="9520bfa6-7ffe-461f-a115-f0ec80e7561b">
        <source>getDepthText(startDepth: Integer) : String;

vars
	str : String;
	num : Integer;

begin

	num := getMyDepth - startDepth;

	while num &gt; 0 do
		str := str &amp; " " &amp; CrLf;
		num := num - 1;
	endwhile;
	return str;

end;</source>
        <Parameter name="startDepth" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="d55e07b5-e402-4928-91fd-37ed439d04c5">
        <source>getDisplayDetails(_short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     Aug 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------

vars

begin
	if _short then
		return self.name[1:10];
	else
		return self.name;
	endif;
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="ef142092-bcea-46de-9043-9c5dae45826e">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if _attrName = ETRow_IsZeroRated then
		return self.isZeroRatedTax.cnEcGetYesNo();
	elseif _attrName = ETRow_BadCredit then
		return self.badDebtor.cnEcGetYesNo();
	elseif _attrName = ETRow_Name then
		return self.name;
	elseif _attrName = ETRow_Remarks then
		return self.remarks;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="fac3c12f-9e05-4580-a0f5-401b2cf5e089">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		28 February 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	block : CM_DataContainerBlock;

begin
	inheritMethod(_dataContainer);

	block := _dataContainer.addNewBlock;
	block.addNewItem("Name", DC_Label, 1, self);
	block.addNewItem(self.getListName(), DC_Data, 1, self); // so default debtor is not 'RDG'

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getListName" id="5822e510-8254-404b-a974-404828f0b103">
        <source>getListName() : String;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.isSuspended then
		return self.name &amp; " (Suspended)";
	else
		return self.name ;
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMaxDepth" id="a61b3c95-1b8b-40c5-9948-d06fc0745083">
        <source>getMaxDepth() : Integer;

vars
	dn:     CM_DebtorNode;
	depth:  Integer;
begin

	foreach dn in self.allChildDebtorNodes do
		depth := depth.max(dn.getMaxDepth);
	endforeach;

	return depth + 1;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMyDepth" id="dd181a71-be32-4959-8eba-7ea619dfa301">
        <source>getMyDepth(): Integer;

vars

begin
	if self.myParentDebtorNode &lt;&gt; null then
		return self.myParentDebtorNode.getMyDepth + 1;
	else
		return 1;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getName" id="e070bbbb-ad6c-4921-b920-5be3cf18169d">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:     31 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return inheritMethod() &amp; ' ' &amp; self.name;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNumRateEntries" id="601495af-49a5-413f-901a-930ba4c09e2d">
        <source>getNumRateEntries(service : CM_Service) : Integer;

vars
	num : Integer;
	rate : CM_Rate;

begin

	rate := serviceRates[service];
	if rate &lt;&gt; null then
		num := rate.rateEntries.size;
	endif;

	if self.myParentDebtorNode &lt;&gt; null then
		num := num + self.myParentDebtorNode.getNumRateEntries(service);
	endif;

	return num;

end;</source>
        <Parameter name="service" type="CM_Service"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getServiceRateAtTime" id="f5e383f0-dc57-4328-a1c5-bc8779cf99f9">
        <source>getServiceRateAtTime(_service: CM_Service; _ts : TimeStamp) : CM_RateEntry;
// 23055 get the rate entry if any for this actual timestamp
vars
	rateEntry : CM_RateEntry;
begin
	if self.serviceRates[_service] = null then
		if self.myParentDebtorNode &lt;&gt; null then
			return self.myParentDebtorNode.getServiceRateAtTime(_service, _ts);
		else
			return null;
		endif;
	else
		rateEntry	:=	self.serviceRates[_service].getRateAtTime(_ts);
		
		if rateEntry &lt;&gt; null then
			return rateEntry;
		else
			if self.myParentDebtorNode &lt;&gt; null then
				return self.myParentDebtorNode.getServiceRateAtTime(_service, _ts);
			else
				return null;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_service" type="CM_Service"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="CM_RateEntry"/>
    </JadeMethod>
    <JadeMethod name="getServiceRateOwner" id="85e4a56c-e904-472d-955c-f23b54ca4786">
        <source>getServiceRateOwner(service : CM_Service) : CM_DebtorNode;

vars

begin

	if serviceRates[service] = null then
		if self.myParentDebtorNode &lt;&gt; null then
			self.myParentDebtorNode.getServiceRateOwner(service);
		else
			return null;    //problems, we have hit the root Group and not found the service owner
		endif;
	else
		return self;
	endif;

end;</source>
        <Parameter name="service" type="CM_Service"/>
        <ReturnType type="CM_DebtorNode"/>
    </JadeMethod>
    <JadeMethod name="getServiceTimeRate" id="d0279b92-9bdd-43a3-a3d2-43e93d4c55b7">
        <source>getServiceTimeRate(service: CM_Service; t : TimeStamp) : CM_RateEntry;
//05 Oct 2022  	navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
//22 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
//25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
vars
	rateEntry 			: CM_RateEntry;
	parentDebtorNode	: CM_DebtorNode;
	canLogExtra	  		: Boolean;	//25.02.2025 navah1	#34141	
 
begin

 // ### TFS 51219 25MAY2021 NAVAB1
	if service = null then
		return null;
	endif;
	
	canLogExtra := app.canLogExtraDetail();					//25.02.2025 navah1	#34141	
	parentDebtorNode := self.myParentDebtorNode;			//05.10.2022 navma1 #52967
	
	if canLogExtra then
		app.invLog(method.qualifiedName &amp; " STARTING", LogINFO.String);
	endif;
	 
	if self.serviceRates[service] = null then
		if parentDebtorNode &lt;&gt; null then
			if canLogExtra then				//25.02.2025 navah1	#34141
				app.invLog("Rate for '" &amp; service.name &amp; "' " &amp; t.asStringJMT() &amp; " derived from Debtor '" &amp;  parentDebtorNode.name &amp; "'", LogTRACE.String); // ### TFS 2682
			endif;
			return parentDebtorNode.getServiceTimeRate(service, t);
		else
			return null;
		endif;
	else
		rateEntry	:=	self.serviceRates[service].getTimeRate(service.bank, t);
		if canLogExtra then					//25.02.2025 navah1	#34141
			app.invLog("Rate for '" &amp; service.name &amp; "' derived from Debtor '" &amp;  self.name &amp; "' found", LogDEBUG.String);
		endif;
		if rateEntry &lt;&gt; null then
			return rateEntry;
		else
			if parentDebtorNode &lt;&gt; null then
				if canLogExtra then			 //25.02.2025 navah1 #34141
					app.invLog("Rate for '" &amp; service.name &amp; "' " &amp; t.asStringJMT() &amp; " derived from Debtor '" &amp;  parentDebtorNode.name &amp; "'", LogINFO.String);
				endif;
				return parentDebtorNode.getServiceTimeRate(service, t);
			else
				return null;
			endif;
		endif;
	endif;
end; </source>
        <Parameter name="service" type="CM_Service"/>
        <Parameter name="t" type="TimeStamp"/>
        <ReturnType type="CM_RateEntry"/>
    </JadeMethod>
    <JadeMethod name="getSpacers" id="37b4468f-47aa-4dae-b75a-b47d924e0010">
        <source>getSpacers(i : Integer) : String;

vars
	str : String;
	num : Integer;

begin

	num := i - 1;

	while num &gt; 0 do
		str := str &amp; "    ";
		num := num - 1;
	endwhile;
	return str;

end;</source>
        <Parameter name="i" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTotalCount" id="ff39c064-7fbf-410c-86da-b5fac2ea9ffd">
        <source>getTotalCount(count : Integer io);

vars
	dn : CM_DebtorNode;

begin

	count := count + self.allChildDebtorNodes.size;

	foreach dn in self.allChildDebtorNodes do
		dn.getTotalCount(count);
	endforeach;

end;</source>
        <Parameter name="count" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getTradeServiceTimeRate" id="7c7adca8-24ba-47c9-a622-cb27984621ba">
        <source>getTradeServiceTimeRate(service: CM_Service; invoiceLine : CM_InvoiceLine) : CM_RateEntry;

/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
14 Jul 2010	cnwdap1	PAR #25021 - review use of isImport/isExport for tranships
22 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	sl 				 : CM_ShippingLine;
	port 			 : CM_Port;
	shipPort 		 : CM_ShipPort;
	spg 	 		 : CM_ShipPortGroup;
	lgd 			 : CM_LineGroupDebtor;
	str 			 : String;
	theVoyage 		 : CM_Voyage;
	company			 : CM_Bank; 
	ti 				 : CM_TrackedItem; 
	t 				 : TimeStamp;
	invalid 		 : Boolean;
	returnVal 		 : CM_RateEntry;
	canLogExtra		 : Boolean;	//26.02.2025 navah1	#34141
	className,
	methodName 		 : String;	 
begin
	canLogExtra	:= app.canLogExtraDetail();	 //26.02.2025 navah1	#34141
	className   := Class.name;				 //5.3.2025 navma1	#34141
	methodName  := Method.name;
	
	if canLogExtra then	//26.02.2025 navah1	#34141
		app.invLog(className &amp; "::" &amp; methodName &amp; " - TRADE RATE", LogINFO.String); // TFS 4489
	endif;
	
	if invoiceLine.myTransactionTI = null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog(className &amp; "::" &amp; methodName &amp; " - TRADE RATE Transaction is null", LogTRACE.String); // TFS 4489
		endif;
		return null;
	endif;

	company := service.bank;
	ti := invoiceLine.trackedItem;
	if ti = null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog(className &amp; "::" &amp; methodName &amp; " - TRADE RATE TI is null", LogTRACE.String); // TFS 4489
		endif;
		return null;
	endif;

	t := invoiceLine.getChargeTime;

	 // VOYAGE - PAR 8352 - in case of trans ship always use the transaction at the time
	theVoyage := invoiceLine.myTransactionTI.getVoyage();
	if theVoyage = null then
		theVoyage := ti.myVoyage;
	endif;
	if theVoyage = null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog(className &amp; "::" &amp; methodName &amp; " - TRADE RATE Voyage is null", LogINFO.String); // TFS 4489
		endif;
		return null;
	endif;

	if app.myRoot.isClientPortOtago() then // TFS 4489
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog(className &amp; "::" &amp; methodName &amp; " - TRADE RATE Otago", LogINFO.String); // TFS 4489
		endif;
		port := app.myRoot.allPorts[invoiceLine.myTransactionTI.loadPort.trimBlanks];
		if port = null then
			//port := app.myRoot.allPorts[ti.dischargePort];
			port := app.myRoot.allPorts[ti.dischargePort];
		endif;
	else // TFS 4489
		if ti.isExport then // TFS 4489
			port := app.myRoot.allPorts[invoiceLine.myTransactionTI.dischargePort.trimBlanks]; // TFS 4489
		else
			port := app.myRoot.allPorts[invoiceLine.myTransactionTI.loadPort.trimBlanks]; // TFS 4489
		
		endif;
			
	endif;
	if port = null then 
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog(className &amp; "::" &amp; methodName &amp; " - TRADE RATE Port is null", LogINFO.String); // TFS 4489
		endif;
		return null; 
	endif;

	sl := theVoyage.myShippingLine;
//	if not global.isValidObject(sl) then
	if sl = null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog(className &amp; "::" &amp; methodName &amp; " - TRADE RATE Shipping Line is null", LogINFO.String); // TFS 4489
		endif;
		return null;
	endif;

	//if ti.isImport or ti.isExport  or ti.isStorage  then													// PAR #25021
	if ti.isImport or ti.isTranshipInbound or ti.isExport or ti.isTranshipOutbound or ti.isStorage  then	// PAR #25021
		shipPort := port.shippingPorts[sl.code]; 
		if shipPort = null then 
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog(className &amp; "::" &amp; methodName &amp; " - TRADE RATE ship port for IMEX is null", LogINFO.String); // TFS 4489
			endif;
			return null; 
		endif;
		spg := shipPort.shipPortGroup;
		if spg = null then 
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog(className &amp; "::" &amp; methodName &amp; " - TRADE RATE ship port group for IMEX is null", LogINFO.String); // TFS 4489
			endif;
			return null; 
		endif;

 // TFS 4489		str := spg.shippingLine.code.padBlanks(4) &amp; spg.code.padBlanks(4) &amp; name;
		str := spg.shippingLine.code.trimBlanks() &amp; " " &amp; spg.code.trimBlanks() &amp; " " &amp; name; // TFS 4489
		
		
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog(className &amp; "::" &amp; methodName &amp; " - TRADE RATE searching for LDG '" &amp; str &amp; "'", LogINFO.String); // TFS 4489
		endif;
		lgd := spg.lineGroupDebtors[str];
	elseif ti.isSOB then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog(className &amp; "::" &amp; methodName &amp; " - TRADE RATE SOB", LogINFO.String); // TFS 4489
		endif;
		lgd := theVoyage.myDefaultLineGroupDebtor;
	elseif ti.isRehandle then
		lgd := theVoyage.myDefaultLineGroupDebtor;
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog(className &amp; "::" &amp; methodName &amp; " - TRADE RATE DLR", LogINFO.String); // TFS 4489
		endif;
	elseif ti.isInTransitOnShip then
	endif;

	if lgd = null then 
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog(className &amp; "::" &amp; methodName &amp; " - TRADE RATE LGD is null", LogINFO.String); // TFS 4489
		endif;
		return null; 
	endif;

	if canLogExtra then	//26.02.2025 navah1	#34141
		app.invLog(className &amp; "::" &amp; methodName &amp; " - TRADE RATE deriving rate for LDG '" &amp; str &amp; "'", LogINFO.String); // TFS 4489
	endif;
	//now get the lgd rate
	on Exception do app.handleDeletedObject(exception, lgd, invalid);
	returnVal := lgd.getServiceTimeRate(company, service, t);
	
	return returnVal;

end;</source>
        <Parameter name="service" type="CM_Service"/>
        <Parameter name="invoiceLine" type="CM_InvoiceLine"/>
        <ReturnType type="CM_RateEntry"/>
    </JadeMethod>
    <JadeMethod name="hasBadCredit" id="2da523a2-5ce1-4300-94f5-91f9f05b472b">
        <source>hasBadCredit() : Boolean;
// ---------------------------------------------------------------------------
// Created:		27 October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.badDebtor = true then
		return true;
	endif;

	if self.myParentDebtorNode = null then
		return false;
	else
		return self.myParentDebtorNode.hasBadCredit();
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
