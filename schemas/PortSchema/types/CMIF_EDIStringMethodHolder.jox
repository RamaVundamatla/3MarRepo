    <JadeMethod name="formatBoolean_BlankIsFalse" id="6459e094-4cc6-4db0-90bd-81fb6048f400">
        <source>formatBoolean_BlankIsFalse(): Boolean;
//----------------------------------------------------------------
//	Created:	10 December 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.ediString.trimBlanks = "" then
		return false;
	endif;
	
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="formatBoolean_YorN" id="047944f7-a31a-47e4-9894-9dd8716f8748">
        <source>formatBoolean_YorN(): Boolean;
//----------------------------------------------------------------
//	Created:	10 December 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.ediString.trimBlanks.toUpper = "Y" then
		return true;
	elseif self.ediString.trimBlanks.toUpper = "N" then
		return false;
	endif;
		
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="formatBoolean_ZeroIsFalse" id="92ce0865-3fc1-41d3-9750-2d6d43396028">
        <source>formatBoolean_ZeroIsFalse(): Boolean;
//----------------------------------------------------------------
//	Created:	26 Jan 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	number	: Real;
begin
	if self.ediString.isReal then
		number := self.ediString.Real;
		return (number &lt;&gt; 0);
	endif;
	
	return self.formatBoolean_BlankIsFalse();

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="formatCOSTemperature" id="7b8fe898-7933-401a-b062-e7315f4983b1">
        <source>formatCOSTemperature() : Real;
//-----------------------------------------------------------------------
//	Created:	03 May 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	i : Integer;
begin
	if self.ediString = null then
		return 0.0;
	endif;

	i := self.ediString.pos('TEMP:',1);
	if i &lt;&gt; 0 then
		return self.ediString[i+5:end].Real;
	endif;
	
	return 0.0;
epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="formatCOSVents" id="5a4891e3-ed98-4013-acac-2802a3ebb650">
        <source>formatCOSVents() : Real;
//-----------------------------------------------------------------------
//	Created:	03 May 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	i : Integer;
begin
	if self.ediString = null then
