    <JadeMethod name="showColumnOrganiser" id="d624df52-7997-48e6-8d68-ec4c31390c8e">
        <updating/>
        <source>showColumnOrganiser(_dataTable : CM_DataTable input)updating;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 18 September 2003
//
//-----------------------------------------------------------------------

vars

begin
