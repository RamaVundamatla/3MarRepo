    <JadeMethod name="cnwcs5_checkSchemaXlations" id="67c98263-7636-47cf-acb5-a5251d23b361">
        <source>cnwcs5_checkSchemaXlations(_schema :Schema) protected;
/*
Date		Who		Reason
12 Nov 2012	cnwcs5	Initial creation - par 
*/
vars
	coll	: ObjectArray;
	dict	: SchemaNDict;
	schema	: Schema;
	locale	: Locale;
	constant	:Constant;
	set			:MethodSet;
	found		:Boolean;
begin
	
	create coll transient;
	create dict transient;
	create set transient;
	
	_schema.getBaseLocalesLocal (coll);
	
	locale := coll.first.Locale;
	
	//write locale.String &amp; ' of ' &amp; coll.size.String;
	
	if not locale.getAllTranslatableStrings.isEmpty then
		found := false;
		
		foreach constant in locale.getTranslatableStrings do
			set.clear;
			
			constant.getMethodRefs (set);
			
			if set.isEmpty then
				continue;
			endif;
			
			if not found then
				write '=====================================';
				write 'Checking ' &amp; _schema.name;
				write '=====================================';

				found := true;
			endif;
			write constant.name &amp; ' - has ' &amp; set.size.String;
		endforeach;
		
		if found then
			write ' ' ;
		endif;
	endif;
	_schema.getSubschemas (dict);
	
	foreach schema in dict do
		self.cnwcs5_checkSchemaXlations (schema);
	endforeach;
epilog
	delete coll;
	delete dict;
	delete set;
end;</source>
        <access>protected</access>
        <Parameter name="_schema" type="Schema"/>
    </JadeMethod>
    <JadeMethod name="convertFilesSoCanCompare" id="d72467c2-cd8b-4d2e-b994-87c8982ffaec">
        <source>convertFilesSoCanCompare();

/*

Purpose:		Convert the files so that only source is there so can compare them using a source compare program

Date			Who		Reason
19 January 2012	cnwmh5	Initial creation

*/

vars
	
	cmdFileOpen 			: CMDFileOpen ;
	file 					: File ;
	outputFile 				: File ;
	obj						: Object;
	schema					: Schema;
	klass					: Class;
	
begin
	
	// check that SchemaComparisonUtility schema exists
	schema := rootSchema.getSchema("SchemaComparisonUtility");
	if schema = null then
		write "Unable to find SchemaComparisonUtility.  Exiting JadeScript.";
		return;
	endif;
	
	klass := schema.getClass("SchemaComparisonUtility");
	if klass = null then
		write "Unable to find JadeScript.  Exiting JadeScript.";
		return;
	endif;
	create obj as klass transient;
	
	// Get the file convert
	create cmdFileOpen transient ;
	cmdFileOpen.initDir := "c:\temp";
	cmdFileOpen.dialogTitle := "Please select schema file to convert";
	cmdFileOpen.filter := "*.scm|*.scm";
	if not cmdFileOpen.open = 0 then
		return;
	endif;
	
	create file transient;
	file.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version
	file.fileName := cmdFileOpen.fileName;
	
	delete outputFile;
	create outputFile transient;
	outputFile.fileName := file.fileName[1:file.fileName.length - 4] &amp; "-Converted" &amp; ".txt";
	if outputFile.isAvailable then
		outputFile.purge;
	endif;
	
	obj.sendMsgWithIOParams('sortSCMByClassMethodWithParams', file, outputFile);
	
	file.close();
	outputFile.close();
	
epilog
	
	delete cmdFileOpen;
	delete file;
	delete outputFile;
	delete obj;
		
end;
</source>
    </JadeMethod>
    <JadeMethod name="convertHSCodeExcel" id="d74a29cc-8fb0-4a1b-97b9-2bb5087dd823">
        <source>convertHSCodeExcel();
/*

Purpose:	Jade can't read excel files with data in different sheets will need to create the CSV files

			I wrote a VBA script to do that
			Open excel Press Alt + F11 keys simultaneously to open the Microsoft Visual Basic for Application window.
			Click Insert &gt; Module, and then paste following VBA code into the new module window. Run it first folder dialog is to select source excel files. Second is the output folder where the CSVs will go
			
			
			Public Sub SaveWorksheetsAsCsv()

			Dim workFolder As FileDialog
			Dim workDir As String
			Set workFolder = Application.FileDialog(msoFileDialogFolderPicker)
			If workFolder.Show &lt;&gt; -1 Then Exit Sub
			workDir = workFolder.SelectedItems(1)

			Dim wb As Workbook

			Dim xWs As Worksheet
			Dim xDir As String
			Dim savefolder As FileDialog
			Set savefolder = Application.FileDialog(msoFileDialogFolderPicker)
			If savefolder.Show &lt;&gt; -1 Then Exit Sub
			xDir = savefolder.SelectedItems(1)

			Dim oFSO As Object
			Dim oFolder As Object
			Dim oFile As Object

			Set oFSO = CreateObject("Scripting.FileSystemObject")
			Set oFolder = oFSO.GetFolder(workDir)
			Dim section As String
			Dim chapter As String

			For Each oFile In oFolder.Files
			   If oFile.Name Like "*.xlsx" Then
					Set wb = Workbooks.Open(oFile.Name)
				section = Mid(oFile.Name, 5, 2)
					For Each xWs In wb.Worksheets
						If xWs.Name Like "Chapter*" = True And xWs.Name Like "*notes" = False Then
					chapter = Right(xWs.Name, 2)
							xWs.SaveAs xDir &amp; "\" &amp; "Chapter " &amp; section &amp; chapter, xlCSV
						End If
					If xWs.Name Like "Section*" = True Then
							 xWs.SaveAs xDir &amp; "\" &amp; xWs.Name, xlCSV
						End If
					Next
					
				End If
			Next

			Workbooks.Close

			End Sub

	==================================================================	

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2022	jlier1	Initial creation

*/

constants	
	TypeSection = "Section";
	TypeChapter = "Chapter";
	TypeHeading = "Heading";
	TypeCode = "Code";
	TypeSubCode = "SubCode";

vars
	ff : FileFolder;
	fn : FileNode;
	f, outputFile  : File;
	line,fileName : String;
	fields : StringArray;
	lineNum : Integer;
	type : String;
	code : String;
	extKey : Integer;
	description : String;
	unitQuantity : String;
	dynaDict : DynaDictionary;
	iter : Iterator;
	sectionStart,pos : Integer;
	chapterFilesRead,
	sectionFilesRead : Integer;
	sectionCode : String;
begin
	create ff transient;
	//choose where the csv files are
	ff.fileName := ff.browseForFolder("Select hs codes file directory","");
	
	//they have cancelled
	if ff.fileName = null then
		return;
	endif;
	create outputFile transient;
	outputFile.usePresentationFileSystem := ff.usePresentationFileSystem;
	outputFile.openOutput(ff.fileName &amp; "\mtn_hscodes_" &amp; app.actualTimeAppServer.formatAsYYYYMMDDHHmmSS &amp; ".csv");
		
	if outputFile.fileName = null then
		write "no output file created";
		return;
	endif;
	
	write "Starting reading  of files in " &amp; ff.fileName;
	create fields transient;
	
	//make sure all the section files are first 
	// then the chapter files 
	create dynaDict transient;
	dynaDict.setMembership(File);
	dynaDict.addExternalKey(Integer,100,false,false);
	dynaDict.endKeys(false);
	
	//order by section then the chapters in that section
	foreach fn in ff.files() do
		fileName:=fn.name;
		code:=null;
		if fileName.startsWith(TypeSection) then
			code:=fileName[9:2];
			extKey:=(code.Integer * 100);
			dynaDict.putAtKey(extKey,fn);
		elseif fileName.startsWith(TypeChapter) then
			extKey:=fileName[9:4].cnTrimLeadingZeros.Integer;		
			dynaDict.putAtKey(extKey,fn);
		endif;
	endforeach;
	
	iter:=dynaDict.createIterator;
	
	while iter.next(f) do
		
		f.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
		f.mode := File.Mode_Input;
		
		f.open();
		lineNum:=0;
		
		if f.name.startsWith(TypeChapter) then
			chapterFilesRead:=chapterFilesRead+1;
		elseif f.name.startsWith(TypeSection) then
			sectionFilesRead:=sectionFilesRead +1;	
		endif;
		
		while not f.endOfFile() do
			lineNum := lineNum + 1;
			line := f.readLine();
			//Line 6 is header everthing after that is data - although there is 
			if f.name.startsWith(TypeSection) then
				sectionStart:=0;
				if lineNum  = 6 then
					type:=TypeSection;
					sectionStart:=line.pos("SECTION",1);
					if sectionStart &gt; 0 then
						code:=line[sectionStart+8:2];
						description:=line[sectionStart+13:end];	
						description:= description.stripTrailingChar(Comma);
						description:= description.stripTrailingChar('"');
						description:=description.csvFormat;
						outputFile.writeLine(type &amp; Comma &amp; code &amp; Comma &amp; description);	
					endif;
					
					break;
				else 
					continue;
				endif;
			
			else
				if lineNum &lt; 6 then
					continue;
				endif;
				
			endif;
			
			fields.clear;
			line.csvToStringArray(fields, Comma); //this is truncating the strings to 62 characters
			if fields.size &lt; 6  then
				continue;
			endif;
			description:=fields[6].trimCharacters("-").csvFormat;
			type:=null;
			code:=null;
			unitQuantity:=fields[5];
			if fields[1] &lt;&gt; null then
				//this is the Chapter row 
				type:= TypeChapter;
				code:=fields[1];
				if code.length &gt; 2 then
					continue;
				endif;
				//write the line
				outputFile.writeLine(type &amp; Comma &amp; code &amp; Comma &amp; description &amp; Comma &amp; unitQuantity);
				//write type &amp; Comma &amp; code &amp; Comma &amp; description &amp; Comma &amp; unitQuantity;
				continue;
			endif;
			if fields[2] &lt;&gt; null then
				type:=TypeHeading;
				code:=fields[2];
				
				outputFile.writeLine(type &amp; Comma &amp; code &amp; Comma &amp; description &amp; Comma &amp; unitQuantity);
			endif;
			if fields[3] &lt;&gt; null then
				type:=TypeCode;
				code:=fields[3];
				pos:=code.pos('(',1);
				if  pos &gt; 0 then
					code:=code[1:pos-1];
				endif;
				outputFile.writeLine(type &amp; Comma &amp; code &amp; Comma &amp; description &amp; Comma &amp; unitQuantity);
			endif;
			if fields[4] &lt;&gt; null then
				type:=TypeSubCode;
				code:=fields[4];
				pos:=code.pos('(',1);
				if  pos &gt; 0 then
					code:=code[1:pos-1];
				endif;
				//subcodes can have notes like (a) to the appendices for more info need to remove those
				outputFile.writeLine(type &amp; Comma &amp; code &amp; Comma &amp; description &amp; Comma &amp; unitQuantity);
			endif;
		
		endwhile;
		f.close;
	
		
		
	endwhile;
	
	write "Output file created " &amp; outputFile.name  &amp; " processed " &amp; sectionFilesRead.String &amp; " section files and " &amp; chapterFilesRead.String &amp; " chapter files";
	
	outputFile.close;
epilog
	delete fields;
	delete ff;
	delete outputFile;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="countAllObjects" id="607a10e3-f4ef-4a43-a1d3-d12231f872bb">
        <executionLocation>client</executionLocation>
        <source>countAllObjects() clientExecution;

vars
	objArray: ObjectArray;
	class: Class;
	recSize, blobCount, space: Integer;
	schema : Schema;
begin
	app.initialize;
	create objArray transient;
	schema := rootSchema.getSchema(PortSchemaName) ;
	foreach class in schema.allClasses do
		objArray.clear;
		class.cnEcGetObjectSize(recSize, blobCount);
		class.allInstances(objArray,0,false);
		space := objArray.size * (recSize + (blobCount*512));
		if space &gt; 1500 and objArray.size &gt; 3000 then	//1500
			write((class.name&amp;" "&amp;space.String&amp;" "&amp;objArray.size.String&amp;' '&amp;recSize.String&amp;' '&amp;blobCount.String));
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="createDataOnlySchema" id="33294a40-3af1-4c36-bf04-7294772f4c32">
        <source>createDataOnlySchema();
// ---------------------------------------------------------------------------
// Created:     03 June 2003 by cnwrs1
//
// Purpose:     Remove the source from a schema file
//				ie make it a data definition only schema file
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	fileIn,fileOut: File;
	inputString: String;
	setToWrite,setInClass: Boolean;
begin
	create fileIn transient;
	fileIn.fileName := "C:\temp\hms\hmsschema3.scm";
	fileIn.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version
	fileIn.mode := File.Mode_Input;
	fileIn.open;
	create fileOut transient;
	fileOut.fileName := "C:\temp\hms\hmsschema3Out.scm";
	fileOut.mode := File.Mode_Output;
	fileOut.open;
	setToWrite := true;	
	while not fileIn.endOfFile do
		inputString := fileIn.readLine().trimBlanks;
		if inputString = "constantDefinitions" then
			fileOut.writeLine(inputString);		//need to writeout the line constantDefinitions
			setToWrite := false;
			setInClass := false;
		elseif inputString = "localeFormatDefinitions" then
			setToWrite := true; 
			setInClass := false;
		elseif inputString = "libraryDefinitions" then
			setToWrite := true; 
			setInClass := false;
		elseif inputString = "externalFunctionDefinitions" then
			setToWrite := true; 
			setInClass := false;
		elseif inputString = "typeHeaders" then
			setToWrite := true; 
			setInClass := false;
		elseif inputString = "membershipDefinitions" then
			setToWrite := true; 
			setInClass := false;
		elseif inputString = "typeDefinitions" then
			setToWrite := true;
			setInClass := true;
		elseif inputString = "inverseDefinitions" then
			setToWrite := true; 
			setInClass := false;
		elseif inputString = "databaseDefinitions" then
			setToWrite := true; 
			setInClass := false;
		elseif inputString = "schemaViewDefinitions" then
			setToWrite := true; 
			setInClass := false;
		elseif inputString = "externalFunctionSources" then
			setToWrite := true; 
			setInClass := false;
		elseif inputString = "typeSources" then
			fileOut.writeLine(inputString);		//write the header line
			return;
		endif;
		if setInClass then 
			if inputString = Tab&amp;"constantDefinitions" then
				setToWrite := false;
			elseif inputString = Tab&amp;"attributeDefinitions" then
				setToWrite := true;
			elseif inputString = Tab&amp;"referenceDefinitions" then
				setToWrite := true;
			elseif inputString = Tab&amp;"externalMethodDefinitions" then
				setToWrite := false; 
			elseif inputString = Tab&amp;"jadeMethodDefinitions" then
				setToWrite := false; 
			elseif inputString = Tab&amp;"eventMethodMappings" then
				setToWrite := false; 
			elseif inputString = Tab&amp;")" then
				setToWrite := true; 
			endif;
		endif;
		if setToWrite then
			fileOut.writeLine(inputString);
		endif; 
	endwhile;
epilog
	fileIn.close;
	fileOut.close;
	delete fileIn;
	delete fileOut;	
end;</source>
    </JadeMethod>
    <JadeMethod name="createDefaultProcessEmail" id="c733e0c9-0329-4691-b189-8f2011aa8af4">
