    <JadeMethod name="rel812_par30901" id="5a0db496-239c-4993-a26f-a10de6468ea5">
        <source>rel812_par30901();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2012	cnwer1	Initial creation HAT 2189
07 March 2013	NDL Par 30901

*/

vars
	dutyDocRoot : CM_DutyDocRoot;
	dutyDocTerminalRoot : CM_DutyDocTerminalRoot;
	terminal : CM_Terminal;
	root : CM_Root;
	etAgent	: EntTableAgent;
