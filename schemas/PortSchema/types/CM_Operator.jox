    <JadeMethod name="hasReceivalCutOffForVoyage" id="e0ec6be3-bcf9-4a03-882f-9a0e94245064">
        <source>hasReceivalCutOffForVoyage(_voyage : CM_Voyage; _trackedItem : CM_TrackedItem) : Boolean;
/*
Purpose:			
Date		Who		Reason
08 April 2015	cnwab1	Initial creation
2/09/2019 	JLGNS1	Bug 46164: LNX - Criteria of Voyage Cutoff Code Does Not Work
*/

vars
	cutoff : CM_ReceivalCutoff;
	now : TimeStamp;
begin
	//epr par 36539 22/7/15
	if _voyage = null then
		return false;
	endif;
	
	//epr par 36539 22/7/15
	now:=app.actualTimeServer;
	foreach cutoff in self.allReceivalCutoffsVoyage discreteLock do
		if cutoff.myReceivalCutoffTermDef &lt;&gt; null then 
			if  not cutoff.myReceivalCutoffTermDef.isAvailableForEntry then
				continue;
			endif;
						
			if _trackedItem &lt;&gt; null then															//Bug 46164
				if not   _trackedItem.matchesRecCutoffCriteria(cutoff.myReceivalCutoffTermDef) then	//Bug 46164
					continue;																		//Bug 46164
				endif;																				//Bug 46164
			endif;																					//Bug 46164
			
		endif;
		
		if cutoff.CM_ReceivalCutoffVoyage.myVoyage &lt;&gt; _voyage then
			continue;
		endif;
		
		if _trackedItem &lt;&gt; null and _trackedItem.isPreNote() then //04/03/2025	navkc1 JIRA Story MTN-34227
			if cutoff.cutoffDateTimePN &lt;&gt; null and now &gt; cutoff.cutoffDateTimePN then
				return true;
			endif;
			
			if cutoff.earliestDateTimePN &lt;&gt; null and now &lt; cutoff.earliestDateTimePN then
				return true;
			endif;
		else
			
			if 	(cutoff.cutoffDateTime &lt;&gt;  null and now &gt; cutoff.cutoffDateTime) then
				return true;
			endif;
			
			if (cutoff.earliestDateTime &lt;&gt; null and now &lt; cutoff.earliestDateTime) then
				return true;
			endif;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasStateDataRefToObj" id="e65c9e0a-590f-4988-95e6-ba152b92bae5">
        <source>hasStateDataRefToObj( _obj : Object; _key : String output ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 November 2020	jlgndl1	Initial creation	TFS 50279

*/

vars

begin

	
	if self.myStateObject = null then
		return false;
	endif;
	
	return self.myStateObject.hasStateDataRefToObj( _obj, _key );

epilog

end;</source>
