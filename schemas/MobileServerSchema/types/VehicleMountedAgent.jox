        <Parameter name="_allRTQueueEntries" type="CM_RTQueueEntryArray"/>
    </JadeMethod>
    <JadeMethod name="loadTaskTableNew" id="30f85254-fd22-4c02-97fd-3083c2842a40">
        <updating/>
        <source>loadTaskTableNew(_table : Table input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2010	cnwer1	Initial creation

*/

vars

begin
	

	self.myMachQEntryTableSynchAgent.initDetails(self,self.myMachine,self.getMaxDisplayQueueEntries,self.canDisplaySecondaryQueues);
	self.myMachQEntryTableSynchAgent.setTableDetails(_table,self.getEntTableView(_table),self.getHeaderTopRow(_table));
	self.myMachQEntryTableSynchAgent.doLoadAllQueueEntries(_table);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="queryDisplayRTEntry" id="87ddceef-af57-4aec-a3a5-5a26d1144e5a">
        <updating/>
        <source>queryDisplayRTEntry(_rtQueueEntry : CM_RTQueueEntry) : Boolean updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
24 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	rtQueueTask : CM_RTQueueTask;
	machineType : CM_MachineType;
begin
	
	rtQueueTask:=_rtQueueEntry.getFirstUncompletedTask;
	if rtQueueTask = null then
		return false;
	endif;
	
	if not self.canDisplayDirectorTasks and rtQueueTask.taskType = TASK_DIRECTOR then
		return false;
	endif; 
	
	//epr 25043 15/7/10
	if not queryValidQueue(_rtQueueEntry) then
		return false;
	endif;
	
	
	if not rtQueueTask.queryMachineAssign(self.myMachine,true,false,true,false,true,null)then
		return false;
	endif;

	
	
	
	return true;		
epilog

end;</source>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="queryValidQueue" id="3616a8c4-1fbc-494f-be8c-2084caf07534">
        <source>queryValidQueue(_rtQueueEntry : CM_RTQueueEntry) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 December 2010	cnwer1	Initial creation

*/

vars

begin
	//epr 25043 15/7/10
	if not (self.myMachine.getQueue = _rtQueueEntry.myQueue) then
		if self.canDisplaySecondaryQueues() then
			if  not self.myMachine.allQueues.includes( _rtQueueEntry.myQueue) then
				return false;
			endif;
		else
			return false;
		endif;
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="refreshTableEntry" id="5ebd4cbb-7d37-4824-bc06-6b40f957abfb">
        <updating/>
        <source>refreshTableEntry(	_table: Table input;
					_rtQueueEntry : CM_RTQueueEntry) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 Dec 2009	cnwer1	Initial creation
16 Dec 2009	cnwer1  EPR PAR 21996
02 Sep 2010 cnwer1 	PAR 25206
16 Dec 2010 cnwer1  par 26612 - can end up refresh entries not interested in until we have finished the current task
*/


vars
	dtoVehicleMountedInfo  : DTO_VehicleMountedInfo;
	rtQueueEntry : CM_RTQueueEntry;
	allRTQueueEntries  : CM_RTQueueEntryArray;
begin

	create allRTQueueEntries transient;
	allRTQueueEntries.add(_rtQueueEntry);
	self.removeQueuedNoteInfo(_rtQueueEntry);
	
	if not self.isBusy then
		foreach dtoVehicleMountedInfo in self.allQueuedNoteInfo do
			rtQueueEntry:=dtoVehicleMountedInfo.eventObject.CM_RTQueueEntry;
			if not allRTQueueEntries.includes(rtQueueEntry) then
				allRTQueueEntries.add(rtQueueEntry);
			endif;
		endforeach;	
	endif;
	
	self.myMachQEntryTableSynchAgent.setTableDetails(_table,self.getEntTableView(_table),self.getHeaderTopRow(_table));
	self.myMachQEntryTableSynchAgent.doRefreshQueueEntries(_table, allRTQueueEntries);
epilog
	if not self.isBusy then
		self.allQueuedNoteInfo.purge;
	endif;
	delete allRTQueueEntries;
	
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="removeQueuedNoteInfo" id="64e6f2cf-2700-4623-82a6-ab93ddf9fb56">
        <source>removeQueuedNoteInfo(_eventObject : Object) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2009	cnwer1	Initial creation

*/

vars
	dtoVehicleMountedInfo : DTO_VehicleMountedInfo;
	found					: Boolean;
begin
	if _eventObject = null then
		return;
	endif;
	found:=false;
	//check if one exist for rt Queue Entry
	foreach dtoVehicleMountedInfo in self.allQueuedNoteInfo do
		if dtoVehicleMountedInfo.eventObject = _eventObject then
			found :=true;
			break;
		endif;
	endforeach;

	if found then
		self.allQueuedNoteInfo.removeIfPresent(dtoVehicleMountedInfo);	
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_eventObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="resetNotes" id="59272eb0-d24b-4f97-b5bf-cea3c61e886a">
        <source>resetNotes() protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
19 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	terminal	: CM_Terminal;
	eventAdd,
	eventRemove,
	eventUpdate : Integer;
begin

	self.stopNotes();
	self.resetNotesForQueue(self.myRTQueue);
	
	if self.myMachine &lt;&gt; null then
		self.beginNotification(self.myMachine, EVENT_MACHQUEUE_ALTERED, Response_Continuous, 0);
		self.beginNotification(self.myMachine, EVENT_MACH_BROADCAST_MSG, Response_Continuous, 0);
		self.beginNotification(self.myMachine,EVENT_RESET_MEDIATOR,Response_Continuous,0);
	endif;
	
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resetNotesForQueue" id="537d7e15-51e2-4500-bdb6-b96e42f56145">
        <source>resetNotesForQueue(_rtQueue : CM_RadioTelemetryQueue input) : Boolean protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
02 August 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	
	eventRemove,
	eventUpdate : Integer;
begin
	if _rtQueue = null then
		return false;
	endif;
	if self.allNoteObjects.includes(_rtQueue) then
		return false;
	endif;


	eventRemove	:= self.myTerminal.getTerminalEvent(Event_Delete_Queue_Entry);
	eventUpdate := self.myTerminal.getTerminalEvent(Event_Update_Queue_Entry);

	self.beginNotification(_rtQueue, eventRemove, Response_Continuous, 0);
	self.beginNotification(_rtQueue, eventUpdate, Response_Continuous, 0);
	self.allNoteObjects.add(_rtQueue);

	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rtQueue" type="CM_RadioTelemetryQueue" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
