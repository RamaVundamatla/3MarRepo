    </JadeMethod>
    <JadeMethod name="doSequenceSort" id="cb4947be-2882-4a5a-9f5b-18ddc5cbef71">
        <updating/>
        <source>doSequenceSort(_sortType : String) updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 22/10/2024	navcs2		MTN-28961 EUP | Transaction Instrumentation - Voyage Planning
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)

vars
	tmpSeqNum		: Integer;
	tmpSeqObj		: CMIF_CustomSequenceObject;
	tmpSeqDict		: CMIF_CustomSeqObjectDictByReq;
	tmpSlotRequest	: CM_SlotRequest;
	isLocalDict,
	isSeqBoth		: Boolean;
	tmpObj			: Object;
begin
	if self.myCurrentJob = null then
		app.msgBox('You must select a job to sequence', 'Error', MsgBox_OK_Only);
		return;
	endif;

	if self.mySequenceSorter = null then
		create self.mySequenceSorter transient;
	endif;
	
	self.hasChanged := true;
	
	tmpSeqNum := self.txtSeqNum.text.Integer;
	if tmpSeqNum &lt;= 0 then
		tmpSeqNum := 1;
	endif;
	
	isSeqBoth := self.cmbSeqBoth.itemData[self.cmbSeqBoth.listIndex].Boolean;

	if self.seqAppliesToMode = self.SeqAppliesTo_Job then
		tmpSeqDict := self.allCustomSeqObjsByReq;
	elseif self.seqAppliesToMode = self.SeqAppliesTo_SelectedSlots then
		isLocalDict := true;
		create tmpSeqDict transient;
		foreach tmpObj in self.myBayDrawingController.allSelectedObjects do
			if (not CM_SlotController.hasInstance(tmpObj)) then
				continue;
			endif;

			tmpSeqObj := self.getSeqObjForSlot(tmpObj.CM_SlotController);

			if tmpSeqObj &lt;&gt; null then
				tmpSeqDict.add(tmpSeqObj);
			else	
				app.raiseUnexpectedProgramError(class.name, method.name, 'custSeq transient not found');
			endif;
		endforeach;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid seqAppliesToMode for method (' &amp; self.seqAppliesToMode.String &amp; ')');
		return;
	endif;

	self.mySequenceSorter.sort(	self.myCurrentJob,
								(self.seqAppliesToMode = self.SeqAppliesTo_Job),
								_sortType,
								tmpSeqNum,
								self.btnTwinLiftCrane.value,
								isSeqBoth,
								self.isSameTwinSeqReq,
								self.allocateCraneLane,
								tmpSeqDict);

	self.txtSeqNum.text := tmpSeqNum.asStringJMT;
	
	foreach tmpSeqObj in tmpSeqDict do
		if tmpSeqObj.mySlotController &lt;&gt; null then
			self.myBayDrawingController.drawObject(null, tmpSeqObj.mySlotController);
		endif;
	endforeach;

epilog
	if isLocalDict then
		delete tmpSeqDict;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_sortType" type="String"/>
    </JadeMethod>
    <JadeMethod name="doSetCombosFromMouseUp" id="f9b1ad50-0cfb-464b-98a4-cb4510d9ac14">
        <updating/>
        <source>doSetCombosFromMouseUp(_obj : Object; x: Real; y: Real; _shift : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpHatchLid	: CM_HatchLid;
	tmpSlotDefn	: CM_SlotDefnVoyage;
	theRequest : CM_SlotRequest;
	tmpSlotController	: CM_SlotController;
	aJob : CM_VoyageJob;
	tmpDisplayMode	: Integer;
	cmbText : String;
	voyAllocation : CM_VoyageAllocation;
	useAllocs : Boolean;
	
begin
	if self.cmbJob.listIndex = -1 then // PAR 8317. 
		cmbText := self.cmbJob.text; // PAR 8317
	endif;

	if _obj = null then
		self.cmbJob.listIndex := -1;
		self.chkOutOfSequence.value := self.myCurrentVoyage.createOutOfSequenceLoadJobs(); //cnwrd1 par 30626 ccms 2209 23.10.12
		return;
	endif;

	tmpDisplayMode := self.displayMode;

	if _obj.isKindOf(CM_HatchLid) then
		self.cmbJob.listIndex := -1;

		tmpHatchLid := _obj.CM_HatchLid;
		if self.workingMode = WorkMode_Job then
			if tmpDisplayMode = ShpDisplayMode_ColCodeLoad then
				if tmpHatchLid.allVoyageHatchLidJobs.isEmpty = false then
					foreach aJob in tmpHatchLid.allVoyageHatchLidJobs do
						if aJob.isDischarge = false then
							break;
						endif;
					endforeach;
				endif;
			elseif tmpDisplayMode = ShpDisplayMode_ColCodeDisch then
				if tmpHatchLid.allVoyageHatchLidJobs.isEmpty = false then
					foreach aJob in tmpHatchLid.allVoyageHatchLidJobs do
						if aJob.isDischarge then
							break;
						endif;
					endforeach;
				endif;
			endif;
			if aJob &lt;&gt; null then
				self.cmbCrane.setIndexFromObject(aJob.getJobCrane);
				self.doCmbJobBuild();
				self.cmbJob.setIndexFromObject(aJob);
				self.setCurrentJob(aJob);
			endif;
		
		endif;
		return;

	elseif _obj.isKindOf(CM_SlotController) then
		tmpSlotController := _obj.CM_SlotController;
		tmpSlotDefn := tmpSlotController.mySlotDefnVoyage;
		
		if tmpDisplayMode = ShpDisplayMode_ColCodeLoad then

			theRequest := tmpSlotController.mySlotRequestLoad;
			if theRequest = null then
				self.cmbJob.listIndex := -1;
				self.chkOutOfSequence.value := self.myCurrentVoyage.createOutOfSequenceLoadJobs(); //cnwrd1 par 30626 ccms 2209 23.10.12
				return;
			endif;
			
			self.txtWeight.text	:=	theRequest.weight.asStringWeightJMT();	// cnwdad1 30/07/2010 - PAR #24045.
			
			useAllocs := not theRequest.allAllocations.isEmpty();
			
			// if the colour coding or the selected job are not SOB then null the combo
			if (not theRequest.isSOB()) then
				self.cmbJob.listIndex := -1;
				self.cmbJob.text := cmbText; // PAR 8317. JADE 6. Setting list index to -1 clears combo text
			else
				if self.cmbJob.listObject &lt;&gt; null then
					if not self.cmbJob.listObject.CM_VoyageJob.isSOB() then
						self.cmbJob.listIndex := -1;
						self.cmbJob.text := cmbText; // PAR 8317. JADE 6. Setting list index to -1 clears combo text
					endif;
				endif;
			endif;
			
			/*if self.dkbCCPallette.visible and theRequest.allAllocations.size() &gt; 0 then			//cnwas3 ccms 1028
				voyAllocation := theRequest.allAllocations.first().CM_VoyageAllocation;
				self.tblCCAllocation.selectRow(self.tblCCAllocation.cnEcFindObjectRow(voyAllocation).row,true);
				self.tblCCAllocation.click(self.tblCCAllocation);
			endif;*/
			
			if useAllocs and ( self.myCCPalette &lt;&gt; null or self.myCCPaletteLoad &lt;&gt; null )  //24 Jan 2012	NDL	Par 28896
			and self.workingMode = self.WorkMode_None			//cnwas3 ccms 1028
			then
				voyAllocation := theRequest.allAllocations.first().CM_VoyageAllocation;
				//24 Jan 2012	NDL	Par 28896
				if self.myCCPaletteLoad &lt;&gt; null then
					self.myCCPaletteLoad.selectVoyageAllocationRow(voyAllocation);
				endif;
				if self.myCCPalette &lt;&gt; null then
					self.myCCPalette.selectVoyageAllocationRow(voyAllocation);
				endif;
				/*
				self.myCCPalette.selectVoyageAllocationRow(voyAllocation);
				*/
				//self.tblCCAllocation.selectRow(self.tblCCAllocation.cnEcFindObjectRow(voyAllocation).row,true);
				//self.tblCCAllocation.click(self.tblCCAllocation);
			endif;
			
			if not useAllocs then
				self.cmbCargoType.setIndexFromObject(theRequest.getAttrCargoType());
				self.cmbCommodity.setIndexFromObject(theRequest.getAttrCommodityGroup());
				self.cmbPortDis.setIndexFromObject(theRequest.getAttrDischargePort());
			endif;
			if self.workingMode = WorkMode_Job 
			or self.workingMode = WorkMode_Plan
			then
				aJob := theRequest.myJob.CM_VoyageJob;
				if aJob &lt;&gt; null then
					if self.workingMode = WorkMode_Job then
						self.cmbCrane.setIndexFromObject(aJob.getJobCrane);
						self.doCmbJobBuild();
						self.cmbJob.setIndexFromObject(aJob);
						self.setCurrentJob(aJob);
					elseif self.workingMode = WorkMode_Plan then
						self.btnTwinLiftCrane.value := aJob.isTwinLift; 
						self.setCaptionForModes(self.displayMode);
					endif;
				endif;
			endif;
			return;
			
		elseif tmpDisplayMode = ShpDisplayMode_ColCodeDisch then

			theRequest := tmpSlotController.mySlotRequestDischarge;
			if theRequest = null then
				self.cmbJob.listIndex := -1;
				return;
			endif;
			useAllocs := not theRequest.allAllocations.isEmpty();

			if (not theRequest.isSOB) and not _shift.isControlKeyPressed() then
				self.cmbJob.listIndex := -1;
				self.cmbJob.text := cmbText; // PAR 8317. JADE 6. Setting list index to -1 clears combo text
			endif;
			if not useAllocs then
				if theRequest.getAttrDischargePort() &lt;&gt; null then
					self.cmbPortDis.setIndexFromObject(theRequest.getAttrDischargePort());
				else
					self.doCmbPortDisDefault();
				endif;
			endif;
			
			if useAllocs and self.myCCPalette &lt;&gt; null // and global.isValidObject(self.myCCPalette)  
			and self.workingMode = self.WorkMode_None			//cnwas3 ccms 1028
			then
				voyAllocation := theRequest.allAllocations.first().CM_VoyageAllocation;
				self.myCCPalette.selectVoyageAllocationRow(voyAllocation);
				//self.tblCCAllocation.selectRow(self.tblCCAllocation.cnEcFindObjectRow(voyAllocation).row,true);
				//self.tblCCAllocation.click(self.tblCCAllocation);
			endif;
			
			if self.workingMode = WorkMode_Job then
				aJob := theRequest.myJob.CM_VoyageJob;
				if aJob &lt;&gt; null then
					self.cmbCrane.setIndexFromObject(aJob.getJobCrane);
					self.doCmbJobBuild();
					self.cmbJob.setIndexFromObject(aJob);
					self.setCurrentJob(aJob);
				endif;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="_shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doSetCustomSequencing" id="e546860e-d600-4b10-9d97-37e810bbba38">
        <updating/>
        <source>doSetCustomSequencing(_sortClass : Class; _isStarboardBerthed : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		Port Side Standard Sequencing - Set the sequence numbers of the requests for the selected job in Port Side Standard Sequencing
// ---------------------------------------------------------------------------
vars
	aRequest : CM_Request;
	aSlotRequest : CM_SlotRequest;
	aPoint : CMUI_GridPoint;
	theSeqNums : IntegerArray;
	idx : Integer;
	theSlots : MemberKeyDictionary;
	theSequence : CMIF_CustomSequence;
	removeSeqZeros : Boolean;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	
	if self.myCurrentJob = null then
		return;
	endif;
	create theSequence transient;
	theSequence.isStarboardBerthed := _isStarboardBerthed;
	
	aRequest := self.myCurrentJob.allRequests.first;
	if aRequest = null then
		return;
	endif;
	
	removeSeqZeros := self.myTerminal.getConfig(ShipRemoveLeadingZeros).Boolean;
	aSlotRequest := aRequest.CM_SlotRequest;
	create theSeqNums transient;
	create theSlots as _sortClass transient;
	
	// get the sequence numbers used for all the requests in this job. We are going to re use them. Sort in ascending order.
	if self.currentSeqNumber = 0 or (self.currentSeqNumber &lt;&gt; self.txtSeqNum.text.Integer) then
		foreach aRequest in self.myCurrentJob.allRequests do
			aSlotRequest := aRequest.CM_SlotRequest;
			theSeqNums.add(aSlotRequest.getSeqNumStringForXML(false, _isStarboardBerthed, false,removeSeqZeros, false).Integer);
		endforeach;
	else
		// use the start seq seed to generate new numbers
		foreach idx in self.currentSeqNumber to (self.currentSeqNumber + self.myCurrentJob.allRequests.size) do
			theSeqNums.add(idx);
		endforeach;
	endif;
	theSeqNums.cnEcSort(false);
	
	// this sorts our requests into deck cell tier order
	self.myCurrentJob.allRequests.copy(theSlots);

	// put the sorted numbers and requests into the CMIF object and pass to the TRX
	theSlots.copy(theSequence.allSlotRequests);
	theSeqNums.copy(theSequence.allSeqNumbers);
	if not theSequence.allSlotRequests.isEmpty then
		// points are redrawn by notification
		app.myTrxUA.trxUpdateSlotRequestSeqNum(theSequence, app.myPassport);
		self.currentSeqNumber := 0;
		global.beep;
	endif;
epilog
	delete theSlots;
	delete theSeqNums;
	delete theSequence;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_sortClass" type="Class"/>
        <Parameter name="_isStarboardBerthed" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSetJobSeedForCrane" id="47dcb18d-51af-43e2-8637-6672beb5aa49">
        <source>doSetJobSeedForCrane();
//----------------------------------------------------------------
