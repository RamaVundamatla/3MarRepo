    <JadeMethod name="machineCancelTask" id="1c7443c0-69c5-4268-975c-1e5e5ccecb93">
        <source>machineCancelTask(_machine: CM_Machine input) protected;
//07 January 2009	cnwdw1	
//
vars
	allTasks: CM_RTQueueTaskArray;
begin
	create allTasks transient;
	allTasks.add(_machine.currentQueueTask);
	app.myTrxUA.trxMachineRejectTasks(_machine,allTasks,false,app.myPassport);

	self.assertNoTrxErrorsOrWarnings();
epilog
	delete allTasks;
end;</source>
