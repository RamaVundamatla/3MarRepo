    <JadeMethod name="handleJobObject" id="39f7ada5-eba5-45cb-923a-37b918f68fd4">
        <source>handleJobObject(_theJob : CM_Job; _codesArray : StringArray input; _colorArray :IntegerArray input;_objArray : ObjectArray input);
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theCode		: String;
	theColor	,bc	: Integer;

begin


	if _theJob = null then
		theColor := CM_Job.Colour_ReceiptUnactioned;
		theCode := null;
	
	else
		_theJob.getRowColour(theColor,bc);
/*
	if _theJob.isJobComplete then
		theCode := _theJob.jobId;
		if _theJob.isRelease then
			theColor := CM_Job.Colour_ReleaseComplete;
		else
			theColor := CM_Job.Colour_ReceiptComplete;
		endif;
	else
		theCode := _theJob.jobId;
		if _theJob.isRelease then
			theColor := CM_Job.Colour_ReleasePartComplete;
		else
			theColor := CM_Job.Colour_ReceiptPartComplete;
		endif;
*/	
	endif;
	
	_codesArray.atPut(VIEW_JOB, theCode);
	_colorArray.atPut(VIEW_JOB, theColor);
	_objArray.atPut(VIEW_JOB, _theJob);

end;</source>
