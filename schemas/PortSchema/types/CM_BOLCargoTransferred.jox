<Class name="CM_BOLCargoTransferred" id="cc07005a-b793-4fe4-97bf-367e7c2a9b59">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transactbol"/>
    <PrimAttribute name="bolConsigneeCode" id="65ce80e2-a1d5-4c68-a98a-cebb64c21f9f">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="bolOperatorCode" id="3823bd97-52dc-47eb-a797-880e58276303">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="fromBolNumber" id="dc4b409f-d104-4e56-93de-dd7196d98783">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="toBolNumber" id="c695d600-6cd6-4410-b8fa-925c50c62104">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getDisplayID" id="691c1958-23e2-4132-8928-6b919d15e982">
        <source>getDisplayID():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

	str : String;

begin

	str := inheritMethod;
	
	str := str &amp; ", " &amp; app.getErrorString1( Transfered_from,  self.fromBolNumber );
	str := str &amp; " - ";
	str := str &amp; app.getErrorString1( Transfered_to,  self.toBolNumber );
	
	if self.bolConsigneeCode &lt;&gt; null then
		str := str &amp; " (" &amp; app.getErrorString( Consignee) &amp; "=" &amp;  self.bolConsigneeCode &amp; ")"; 
	endif;
	
	if self.bolOperatorCode &lt;&gt; null then
		str := str &amp; " (" &amp; app.getErrorString( Operator) &amp; "=" &amp;  self.bolOperatorCode &amp; ")"; 
	endif;
	
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="97e7fb91-52ed-4b68-8d1a-0ea00c1f5efb">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin
	if _attrName = ETRow_Details then
		return self.getDisplayID;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setDetails" id="279956db-91b4-4825-8fe7-fe0841ee1f2e">
        <updating/>
        <source>setDetails( _fromBol : CM_BOL;
			_toBol : CM_BOL;
			_conSeeCode : String;
			_operCode : String
			)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin

	if _fromBol &lt;&gt; null then
		self.fromBolNumber := _fromBol.number;
	endif;
	if _toBol &lt;&gt; null then
		self.toBolNumber := _toBol.number;
	endif;
	self.bolConsigneeCode := _conSeeCode;
	self.bolOperatorCode := _operCode;

epilog

end;</source>
        <Parameter name="_fromBol" type="CM_BOL"/>
        <Parameter name="_toBol" type="CM_BOL"/>
        <Parameter name="_conSeeCode" type="String"/>
        <Parameter name="_operCode" type="String"/>
    </JadeMethod>
</Class>
