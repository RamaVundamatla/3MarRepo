    <JadeMethod name="set" id="c961fc65-f295-490e-a083-1e717e5cc1e4">
        <updating/>
        <source>set(_name : String; _value : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
14 May 2020			jlgrr1	Initial creation
26 September 2024	navmd1	Avoid 1035 error when sending in really long query param keys

*/

vars

begin
	self.name := _name[1:30];
	self.value := _value;
epilog

end;</source>
