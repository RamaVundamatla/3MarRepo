        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbType_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     20 February 2008 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpType	: Integer;
begin
	if self.cmbType.listIndex &lt;= 0 then
		return;
	endif;
	
	tmpType := self.cmbType.itemData[self.cmbType.listIndex];

	if tmpType = HMS_TidalFile_QLD_HiLo or
	   tmpType = HMS_TidalFile_QLD_Height or
	   tmpType = HMS_TidalFile_QLD_Current then
		self.cmbMultiplier.text := HMS_TidalModelDefinition.VALUE_TYPE_MM;
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
