    <JadeMethod name="reverseRulesIn" id="6cb3bf1b-74bb-497c-b6bd-3334353e4124">
        <source>reverseRulesIn();
//----------------------------------------------------------------
//	Created:	18 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	deckingRuleIn	: CM_YADeckingRule;
begin

	self.raiseExceptionIfNotTransient(method);

	foreach deckingRuleIn in self.allDeckingRulesIn do
		deckingRuleIn.setProxyBasic(deckingRuleIn.getReverseRule(), deckingRuleIn.heightFrom, deckingRuleIn.heightTo, true);
	endforeach;

end;</source>
