    <JadeMethod name="getKPIArea" id="0e244982-cc58-49a4-bc4e-ee2656031d7a">
        <source>getKPIArea(_mode: Integer; _tis: CM_TIArray input; _area, _volume : Decimal output);
/*
Purpose:			
Date		Who		Reason
01 September 2011	cnwab1	Initial creation
*/

vars

begin
	_area :=  self.getAreaInSquareMetres();
	_volume := 0;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
        <Parameter name="_area" type="Decimal" usage="output"/>
        <Parameter name="_volume" type="Decimal" usage="output"/>
