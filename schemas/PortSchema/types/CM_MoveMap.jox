    <JadeMethod name="setForCreate" id="6e849149-78a5-460c-80de-3a7bff7fc294">
        <updating/>
        <source>setForCreate(_theProxy : SelfType) updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theMP : CM_MovePlan;
begin

	self.id := _theProxy.id;
	self.clonedFromId := _theProxy.clonedFromId;
	self.terminal 	:= _theProxy.terminal;
	self.remarks 	:= _theProxy.remarks;
	
	self.createMovePlan(SHIP, 			YARD, theMP);
	self.createMovePlan(YARD, 			SHIP, theMP);
	self.createMovePlan(ROAD, 			YARD, theMP);
	self.createMovePlan(RAIL, 			YARD, theMP);
	self.createMovePlan(ISOREQUEST, 	RAIL, theMP);
	self.createMovePlan(ISOREQUEST, 	ROAD, theMP);
	self.createMovePlan(YARD, 			YARD, theMP);
	self.createMovePlan(ISOREQUEST,		ISOREQ_DEPOT, theMP);

end;</source>
        <Parameter name="_theProxy" type="SelfType"/>
    </JadeMethod>
