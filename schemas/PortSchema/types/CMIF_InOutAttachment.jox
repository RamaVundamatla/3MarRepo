    <JadeMethod name="actionForCreate" id="7bb271fc-acdf-4393-98d7-c6330e445b45">
        <updating/>
        <source>actionForCreate(pProxy: CM_Object io; _passport : CM_Passport input): Boolean updating;
//if general docket then move it's TI planned location
//N.B these would have already been set in the CM_BOL::actionForCreate,
//but instead of re-hashing that, it is better to just do it here

vars
	
begin
	return true;
	
end;</source>
        <Parameter name="pProxy" type="CM_Object" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="actionForCreatePost" id="427a4a37-bc92-4d37-9916-28c53e280ee2">
        <updating/>
        <source>actionForCreatePost(_obj: Object; _passport: CM_Passport input): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     22 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	cont : CM_TrackedItem;
	child : CM_TrackedItem;
	//children : CM_TISet;
begin
	cont := _obj.CM_TrackedItem;
	
	if cont = null then
		return false;
	endif;
	
	if self.myProxyTrackedItem = null then
		return false;
	endif;
	//create children transient;//PAR 22954
	//cont.getAllChildren(children);//PAR 22954
	foreach child in cont.allChildren discreteLock do//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
		// by now the generator is real and is attached to the 'parent' 
		if child.id = self.myProxyTrackedItem.id then
			child.changeState(TI_STATE_NORMAL, app.myPassport);
			child.updateCollections();
			return true;
		endif;
	endforeach;
	return false;
epilog
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkFieldsNotNull" id="d4926c6f-87ef-45ca-ac30-c59ad93578d9">
        <updating/>
        <source>checkFieldsNotNull(pCargoType : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     08 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	strMsg : String;
begin

	if pCargoType = TI_CargoType_Log then	//Is a log
		if self.id = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Log Id', ETRow_LogId, null);
			app.raiseCMException(Input_required_field_logId, ETRow_LogId, null); // cnwdb2	PAR 35364
		endif;	
		if self.sedMax = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'SED Max', ETRow_SedMax, null);
			app.raiseCMException(Input_required_field_sedMax2, ETRow_SedMax, null); // cnwdb2	PAR 35364


		endif;
		if self.sedMin = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'SED Min', ETRow_SedMin, null);
			app.raiseCMException(Input_required_field_SedMin, ETRow_SedMin, null); // cnwdb2	PAR 35364
		endif;
				
	elseif pCargoType = TI_CargoType_BreakBulk then
		if self.id = null then
	//		app.raiseCMException1(REQUIRED_FIELD, 'ID number', ETRow_Id, null);
			app.raiseCMException(Input_required_field_IdNum, ETRow_Id, null); // cnwdb2	PAR 35364
		endif;
	else
		if self.cargoType = TI_CargoType_Null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'cargo type', ETRow_CargoType, null);
			app.raiseCMException(Input_required_field_cargoType, ETRow_CargoType, null); // cnwdb2	PAR 35364
		endif;
	
		if self.id = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'container number', ETRow_Id, null);
			app.raiseCMException(Input_required_field_contNumb, ETRow_Id, null); // cnwdb2	PAR 35364
		endif;
		
		if self.cargoType = TI_CargoType_Container or
		   self.cargoType = TI_CargoType_COU or
		   self.cargoType = TI_CargoType_Generator or
		   self.cargoType = TI_CargoType_Tower then
			if self.isoType = null then
			//	app.raiseCMException1(REQUIRED_FIELD, 'ISO Type', ETRow_IsoType, null);
				app.raiseCMException(Input_required_field_IsoType, ETRow_IsoType, null); // cnwdb2	PAR 35364
			endif;
		else
			if self.isoType &lt;&gt; null then
				strMsg := "'ISO Type'. An entry for this field is not requird for this item";
				app.raiseCMException2(ERR_ISOTYPE_FIELD, self.isoType, strMsg , ETRow_IsoType, null);
			endif;
		endif;
		/*if self.weight = null then
			app.raiseCMException1(REQUIRED_FIELD, 'weight', ETRow_Weight, null);
		endif;*/
	endif;			
	
end;</source>
        <Parameter name="pCargoType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cloneReferences" id="d56f21ff-e22d-4d26-b80d-1a8c5ac0163e">
        <updating/>
        <source>cloneReferences(_tmpAttach :CMIF_InOutAttachment) updating;
// ---------------------------------------------------------------------------
// Created:     15 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.myTerminal 	:= _tmpAttach.myTerminal;
	self.cargoType 		:= _tmpAttach.myCargoType.id;
	self.myTerminalArea := _tmpAttach.myTerminalArea;
	self.myLocationsController := _tmpAttach.myLocationsController;
	self.myProduct 		:= _tmpAttach.myProduct;
	self.myCustomsAgent := _tmpAttach.myCustomsAgent;	
	self.myProxyTrackedItem	:= _tmpAttach.myProxyTrackedItem;
	self.setMasterItem(_tmpAttach.myMasterObject);
	self.setTIHazards(_tmpAttach.allTIHazards);
	
	self.myGeneratorType := _tmpAttach.myGeneratorType;	// CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
	self.myTrailerType := _tmpAttach.myTrailerType;	//17 Oct 2012	NDL	Par 30095

end;</source>
        <Parameter name="_tmpAttach" type="CMIF_InOutAttachment"/>
    </JadeMethod>
    <JadeMethod name="delete" id="2b04c79b-81ed-4350-add3-0e3920c8c488">
