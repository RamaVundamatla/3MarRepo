    <JadeMethod name="translateForm" id="246828da-59eb-4af7-b0fa-2fe3550eb005">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 16 August 2024 10:24:22.
	// 04 Sep 2024 navrv30 Bug 65910: EUP | FR 53382 - COO Maint Incoterm and Storage Operator
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026193, locale);
	btnAddItems.translateCaption(Xlat_0026194, locale);
	btnApprove.translateCaption(Xlat_0026195, locale);
	btnAttachment.translateCaption(Xlat_0026196, locale);
	btnAudits.translateCaption(Xlat_0026197, locale);
 //	btnClear.translateCaption(Xlat_0026198, locale);
	btnClose.translateCaption(Xlat_0026199, locale);
	btnInvoiceIssus.translateCaption(Xlat_0026200, locale);
	btnRemove.translateCaption(Xlat_0026201, locale);
	btnSave.translateCaption(Xlat_0026202, locale);
	btnSaveDetails.translateCaption(Xlat_0026859, locale);
	btnUpdate.translateCaption(Xlat_0026203, locale);
	cargoDetails.translateCaption(Xlat_0026204, locale);
	chkSelectAll.translateCaption(Xlat_0026860, locale);
	chkShowSubDtls.translateCaption(Xlat_0026331, locale);
	//grpChargeStorage.translateCaption(Xlat_0026731, locale);   //04 Sep 2024 navrv30 Bug 65910
	grpCurrentOperator.translateCaption(Xlat_0026205, locale);
	grpNewOperator.translateCaption(Xlat_0026206, locale);
	grpOriOperator.translateCaption(Xlat_0026832, locale);
	grpRemarks.translateCaption(Xlat_0026207, locale);
	grpUpdateCargo.translateCaption(Xlat_0026732, locale);
	lblAddFreeDaysNew.translateCaption(Xlat_0026208, locale);
	lblCOOFreeDays.translateCaption(Xlat_0026209, locale);
	lblCondition.translateCaption(Xlat_0026210, locale);
	lblCurOprFreeStoExp.translateCaption(Xlat_0026833, locale);
	lblCurrentOperator.translateCaption(Xlat_0026211, locale);
	lblEffectiveDate.translateCaption(Xlat_0026212, locale);
	lblFreeDaysOld.translateCaption(Xlat_0026213, locale);
	lblFreeStorageExp.translateCaption(Xlat_0026214, locale);
	lblFreightForward.translateCaption(Xlat_0026215, locale);
	lblIncoterm.translateCaption(Xlat_0026216, locale);
	lblInvoiceContract.translateCaption(Xlat_0026965, locale);
	lblNewOperator.translateCaption(Xlat_0026217, locale);
	lblNumber.translateCaption(Xlat_0026218, locale);
	lblOriOprStoExp.translateCaption(Xlat_0026834, locale);
	lblStorageChargeOperator.translateCaption(Xlat_0026219, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0026220, locale);
	mnuContextMenu.translateCaption(Xlat_0026221, locale);
	mnuInspectObject.translateCaption(Xlat_0026222, locale);
	statusBar.translateCaption(Xlat_0026223, locale);
	statusline.translateCaption(Xlat_0026224, locale);
end;</source>
