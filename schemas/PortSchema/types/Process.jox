    <JadeMethod name="getUserCode" id="c16b19f3-025b-4761-bc5e-f423127807bc">
        <source>getUserCode() : String;
/*

Purpose:			Gets the usercode either from the passport or from the process

Parameters:			

Return Value:		

Date		Who		Reason
27 July 2022	navpw1	Initial creation

*/

vars
	userCode : String;
	index : Integer;
	user : CM_User;
	
begin
	//if we have a logged inh user get it from the passport
	if app.myPassport &lt;&gt; null then
		user := app.myPassport.myUser;
		
		if user &lt;&gt; null then
			return user.code;
		endif;
		
	endif;

	//if not get it from the process
	userCode := process.userCode;
	
	index := userCode.pos("_", 1);
	
	if index &gt; 0 then
		userCode := userCode[1:index-1];
	endif;
	
	return userCode;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleComputerNameFail" id="8da1c3fd-0b1b-43dd-be59-55a9978da727">
        <source>handleComputerNameFail(_exc : Exception; _invalidObject : Boolean io) : Integer protected;
// CCMS1150 cnwrs1 16 June 2011
//Date			Who		Reason
// 18/09/2023	navmd1	TFS 60524 Moved 'up' from CMUI_UserNodes
//
constants
	MgmtMsg	= 5905;
vars
	returnVal : Integer;
begin
	returnVal := Ex_Pass_Back;

	if _exc.errorCode = MgmtMsg then
		// Set _invalidObject, and resume in the calling method, which will then
		// interrogate excOccurred, to identify an invalid/deleted object
		_invalidObject := true;
		if _exc.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;
epilog
	return returnVal;
end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_invalidObject" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initiateTransientCompact" id="4be177ec-cb60-4609-acba-9479f6e3da93">
        <source>initiateTransientCompact();
/*

Purpose:			Initiate a timer on the current process to compact the transient database file,
					if one is not already pending

Parameters:			None

Return Value:		True if a timer is started, false if there is already one active

Date		Who		Reason
13 Dec 2017	jlgkpd1	Initial creation - TFS 8294

*/

vars
	option,
	timeRemaining	: Integer;
	status			: Boolean;
	
begin
	status := self.getTimerStatus(self.Compact_Transient_File, option, timeRemaining);
	
	if status then
		app.writeLog(method.qualifiedName &amp; " Compact_Transient_File timer already active", LogINFO);	//25 Nov 2019	NDL	TFS 47053
	else	
		self.beginTimer(0, Timer_OneShot, self.Compact_Transient_File);
		app.writeLog(method.qualifiedName &amp; " Compact_Transient_File timer started", LogINFO);	//25 Nov 2019	NDL	TFS 47053
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="isALTM" id="4cf438b5-aa7d-458d-80d9-f24dbd6271e0">
        <source>isALTM() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2022	navpw1	Initial creation

*/

vars
	user : CM_User;
	
begin

	executeWhen JMTDevelopmentEnvironment;
	
	// JMT
	if app.myPassport &lt;&gt; null then
		user := app.myPassport.myUser;
		
		if user &lt;&gt; null 
		and user.code = "NAVPW1"
		and user.userName = "Phillip Wells" then
			return true;
		endif;
	endif;
	
	endExecuteWhen;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
