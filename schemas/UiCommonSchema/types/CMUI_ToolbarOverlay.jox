    <ExplicitInverseRef name="myToolbarButton" id="5863ac36-0b89-475f-bee8-09a24b34aa82">
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CMUI_ToolbarButton"/>
        <access>protected</access>
        <Inverse name="CMUI_ToolbarButton::myToolbarOverlay"/>
    </ExplicitInverseRef>
    <JadeMethod name="click" id="7f447747-ddac-4bf9-92d0-d661f54fcc7f">
        <updating/>
        <source>click(pict: Picture input) updating;
// ---------------------------------------------------------------------------
// Created:     31 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpControl	: Control;
	tmpParent	: Window;
	
begin

	// The following code is to ensure that the lostFocus is fired
	// for controls that are embedded in tables, as often this is
	// what copies the value back into the table.
	
	tmpControl := app.activeControl;
	if tmpControl &lt;&gt; null then
		on Exception do self.clickExHandler(exception);
		/*
		tmpControl.sendMsgWithParams('lostFocus', tmpControl);
		tmpParent := tmpControl.parent;
		if tmpParent &lt;&gt; null and tmpParent.isKindOf(Table) then
			// for controls that are embedded in a table we need
			// to reset the focus to the table otherwise the embedded
			// control can retain the focus
			tmpParent.setFocus();
		endif;
		*/


		if tmpParent &lt;&gt; null and tmpParent.isKindOf(Table) then
			// for controls that are embedded in a table we need
			// to reset the focus to the table otherwise the embedded
			// control can retain the focus
			if tmpControl.automaticCellControl or tmpControl.name[1] = '_' then
				tmpParent.Table.lostFocus(tmpParent.Table);
			else
				tmpControl.sendMsgWithParams('lostFocus', tmpControl);
				tmpParent.setFocus();
			endif;
		else
			tmpControl.sendMsgWithParams('lostFocus', tmpControl);
		endif;
	endif;

	self.myToolbarButton.click(self.myToolbarButton);
end;</source>
        <Parameter name="pict" type="Picture" usage="input"/>
    </JadeMethod>
    <JadeMethod name="clickExHandler" id="92adabce-8211-46ac-a52d-5a2f45a44e41">
        <source>clickExHandler(_exObj : Exception) : Integer protected;
// ---------------------------------------------------------------------------
// Created:     21 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	MethodNotDefinedForType	: Integer = 1010;
	
vars

begin

	if _exObj.errorCode = MethodNotDefinedForType then
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;

end;</source>
        <access>protected</access>
        <Parameter name="_exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="ef00d892-23cb-4c8d-b24f-b7d5040c790c">
        <updating/>
        <source>mouseDown(pict: Picture input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     31 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.myToolbarButton.mouseDown(self.myToolbarButton, button, shift, x, y);
end;</source>
