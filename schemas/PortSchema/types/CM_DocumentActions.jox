    <JadeMethod name="getNewStopsTableToApply" id="31db6926-d813-4194-a8c3-8345a02bf2ea">
        <updating/>
        <source>getNewStopsTableToApply(  _proxy : CM_DocumentActions; _stopsToApply : CM_StopsTableSet output) updating;
/*
Purpose:	 // ### TFS 3283		
Date				Who			Reason
MARCH 2017		CNWAB1		Initial creation
*/

vars

	actualStop, pxyStop : CM_StopsTable;
	index : Integer;
	found : Boolean;
	proxyDA : CM_DocumentActions;
begin
	if _stopsToApply = null then
		create _stopsToApply transient;
	endif;

	proxyDA := _proxy;
	
	foreach pxyStop in proxyDA.allStopTablesToAdd do
		index := index + 1;
		
		found := false;
		
		foreach actualStop in self.allStopTablesToAdd do
			if pxyStop.code = actualStop.code then
				found := true;
				break;
			endif;
		
		endforeach;
		if not found then
			_stopsToApply.add(pxyStop); // new stop that we might have to apply to existing tis.
		endif;
	
	endforeach;
	

epilog
end;</source>
        <Parameter name="_proxy" type="CM_DocumentActions"/>
        <Parameter name="_stopsToApply" type="CM_StopsTableSet" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getNewTaskDescsToApply" id="a979ecb7-f050-4e46-993e-19e4bab917f0">
        <updating/>
        <source>getNewTaskDescsToApply(  _proxy : CM_DocumentActions; _remarksToApply : StringArray output;  _taskToApply : CM_ToDoTaskDescArray output) updating;
/*
Purpose:	 // ### TFS 3283		
Date				Who			Reason
MARCH 2017		CNWAB1		Initial creation
*/

vars

	actualTask, pxyTask : CM_ToDoTaskDesc;
	index : Integer;
	found : Boolean;
	proxyDA : CM_DocumentActions;
begin
	if _remarksToApply = null then
		create _remarksToApply transient;
	endif;
	if _taskToApply = null then
		create _taskToApply transient;
	endif;

	proxyDA := _proxy;
	
	foreach pxyTask in proxyDA.allTaskDescsToAdd do
		index := index + 1;
		
		found := false;
		
		foreach actualTask in self.allTaskDescsToAdd do
			if pxyTask.code = actualTask.code then
				found := true;
				break;
			endif;
		
		endforeach;
		if not found then
			_taskToApply.add(pxyTask); // new task that we might have to apply to existing tis.
			_remarksToApply.add(proxyDA.allTaskRemarkToAdd[index]); // new task that we might have to apply to existing tis.
		endif;
	
	endforeach;
	

epilog
end;</source>
        <Parameter name="_proxy" type="CM_DocumentActions"/>
        <Parameter name="_remarksToApply" type="StringArray" usage="output"/>
        <Parameter name="_taskToApply" type="CM_ToDoTaskDescArray" usage="output"/>
    </JadeMethod>
