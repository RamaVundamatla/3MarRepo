// --------------------------------------------------------------------------------
// Created:		05 September 2008 by cnwdad1:2
//
// Purpose:		Creates a new Interface Definition object.
//
// Parameters:	_pxyObject - A reference to a proxy Interface Definition object.
//				_realObject - A reference to the real Interface Definition object
//					that is returned to the calling method.
//				_passportObj - A reference to the current user's Passport object.
//
// Returns:		A reference to the new Interface Definition object, via the _realObject
//				parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passportObj, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passportObj);
	on LockException do agtPassportLockExHandler(exception, _passportObj);

	app.setContinueCMExceptions(false);
	
	// Start the transaction
	beginTransaction;
	app.myUtilityCA.utlCreateInterfaceDefinition(_pxyObject, _realObject, _passportObj);
epilog
	self.finaliseActivityWithPassport(_passportObj);
end;</source>
