    <JadeMethod name="updateBlockStack" id="f5f9905a-79b1-401f-9d9a-5fff37f3cf9b">
        <source>updateBlockStack(_bs: CM_BlockStack; _max: Integer);
//01 September 2008	cnwdw1	 
//
vars
	
	pxyBlockStack: CM_BlockStack;

begin
	pxyBlockStack := app.createUpdateProxy(_bs).CM_BlockStack;
	pxyBlockStack.maxCapacity := _max;
	if self.opts.includesKey("Id") then
		pxyBlockStack.setPropertyValue(CM_BlockStack::id.name, self.opts.str("Id"));
	endif;
	
	app.myTrxUA.trxUpdateTerminalArea(pxyBlockStack, app.myPassport);
