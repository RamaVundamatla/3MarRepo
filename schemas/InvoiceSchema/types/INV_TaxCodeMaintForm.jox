    <JadeMethod name="create" id="af100a52-c879-4b9e-930e-4278866833c1">
        <updating/>
        <source>create() updating;
//------------------------------------------------
// Created: 17 May 2006 By: cnwgd1
//------------------------------------------------
vars

begin
	//self.permissionView  := PmAdmInvoicePeriodView;
	//self.permissionMaint := PmAdmInvoicePeriodMaint;
	
	self.permissionView  := PmInvTaxCodeView;
	self.permissionMaint := PmInvTaxCodeMaint;
	
