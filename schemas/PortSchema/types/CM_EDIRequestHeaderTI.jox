    <JadeMethod name="setForUpdate" id="bf37df70-dded-49ab-aa1a-4c7a42e23a8c">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
//
//11 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
//
vars
	prop : Property;
	propDict : PropertyNDict;
begin
	inheritMethod(_proxyEDITI);
	
	propDict := self.class.getProperties;
	foreach prop in propDict do
		if self.canUserSet(prop.name) then
			// bypass all type integrity checking in the name of convenience!!!
			self.setPropertyValue(prop.name, _proxyEDITI.getPropertyValue(prop.name));
		endif;
	endforeach;
end;
</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setFromBulkRelease" id="88c0ebfd-dd75-49f5-b95a-97fc7801ff94">
        <updating/>
        <source>setFromBulkRelease(_bulkRelease : CM_BulkRelease) updating;
//
//19 December 2017	jlgrs1	Initial creation
//
vars

begin
	self.allowCargoMultiReleases := _bulkRelease.allowCargoOnMultipleReleases;
	self.bookingConfirmation := _bulkRelease.bookingConfirmation;
//	self.bookingRef := _bulkRelease.bookingRef;
//	self.businessUnit := _bulkRelease.businessUnit;
	self.canBeHiLoCube := _bulkRelease.canBeHiLoCube;
//	self.cargoSubType := _bulkRelease.cargoSubType;
	self.carrierCode := _bulkRelease.carrierId;
	self.consignee := _bulkRelease.consigneeCode;
	self.consignor := _bulkRelease.consignorCode;
	self.consignorVoyage := _bulkRelease.consignorVoyageCode;
	self.customsAgent := _bulkRelease.customsAgent;
	self.customsAssistance := _bulkRelease.customsAssistance;
	self.deliveryReason := _bulkRelease.deliveryReasonCode;
	self.deliveryReleaseNumber := _bulkRelease.deliveryReleaseNumber;
//	self.destTerminal := _bulkRelease.destTerminal;
//	self.destinationPort := _bulkRelease.destinationPort;
//	self.dischargePort := _bulkRelease.dischargePort;
//	self.estimatedRequiredDate := _bulkRelease.estimatedRequiredDate;
	self.expiryTimeStamp := _bulkRelease.expiryTimeStamp;
	self.freightForwarder := _bulkRelease.freightForwarderCode;
//	self.generatorType := _bulkRelease.generatorType;
//	self.loadPort := _bulkRelease.loadPort;
//	self.mtRelease := _bulkRelease.mtRelease;
	if _bulkRelease.myOperator &lt;&gt; null then
		self.operatorCode := _bulkRelease.myOperator.code;
	endif;
	if _bulkRelease.myOperatorGroup &lt;&gt; null then
		self.operatorGroup := _bulkRelease.myOperatorGroup.code;
	endif;
	self.releaseByType := _bulkRelease.releaseByType;
	self.releaseRequestNumber := _bulkRelease.code;
//	self.releaseType := _bulkRelease.releaseType;
//	self.releaseTypeStr := _bulkRelease.releaseTypeStr;
//	self.remarks := _bulkRelease.remarks;
	self.removeStops := _bulkRelease.removeStops;
//	self.requestDate := _bulkRelease.requestDate;
//	self.requestDateDoUpdate := _bulkRelease.requestDateDoUpdate;
//	self.senderCode := _bulkRelease.senderCode;
	self.statusBulkRelease := _bulkRelease.statusString;
//	self.trailerType := _bulkRelease.trailerType;
	if _bulkRelease.myVoyage &lt;&gt; null then
		self.vesselName := _bulkRelease.myVoyage.vesselName;
		self.voyageCode := _bulkRelease.myVoyage.code;
	endif;
epilog

end;</source>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
    </JadeMethod>
