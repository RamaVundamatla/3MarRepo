<Class name="UT_ReeferJobs" id="b66a5ea4-2b67-445c-a01a-ff8c50f26704">
    <superclass name="UT_DSL"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <JadeMethod name="addDelReeferCriteria" id="d5de0482-a8bf-4626-b034-64c620dae4e7">
        <source>addDelReeferCriteria( _setup : Boolean; _delete : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 August 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	seqNumber : Integer;
	allTransientCriteriaObj	: CMIF_Array;
	pxyObjMatch : CM_ObjectMatchCriteria;
	allTimes : TimeArray;
	variance : TimeStampInterval;
	real : CM_ObjectMatchCriteria;
	nowTime : Time;
	pxyCmifCriteria : CMIF_YACriteriaPriority;
	pxyCriteria: CM_YACriteria;
	data : ObjectSet;
	reeferJobCriteria : CM_ReeferJobCriteria;
	obj : CM_Object;

begin

	if _delete then
	
		reeferJobCriteria := self.getTerminal.allReeferJobCriteria.findByNamne( "UT TFS49581 First" );
		if reeferJobCriteria &lt;&gt; null then
			obj := reeferJobCriteria;
			app.myTrxDA.trxDeleteCMObject( obj, app.myPassport);
		endif;
	
	endif;


	if _setup then

		variance.set( 0, 14400000 );  //4 hours
		
		create allTransientCriteriaObj transient;
		create pxyCmifCriteria transient;
		allTransientCriteriaObj.add( pxyCmifCriteria );
		
		create data transient;
		data.add( app.myRoot.allCargoTypesById.getAtKey(TI_CargoType_Container) );
		
		create pxyCriteria transient;
		pxyCmifCriteria.setReferences( pxyCriteria );
		pxyCriteria.setProxy(	CM_YATypeCargoType.firstInstance,
								data,
								"Cargo Type"
								);
		
		create pxyObjMatch as CM_ReeferJobCriteria transient;
		
		pxyObjMatch.setProxy( 	allTransientCriteriaObj,	//_criterias: CMIF_Array;
								1	//_priority : Integer
								);
								
		create allTimes transient;
		allTimes.add( "00:30:00".Time );
		allTimes.add( "08:30:00".Time );
		allTimes.add( "16:30:00".Time );
							
		pxyObjMatch.CM_ReeferJobCriteria.setProxyBaseData(	true,	//_alarm : Boolean;
															allTimes,	//_allTimes : TimeArray;
															true,	//_connect : Boolean;
															10,	//_connectDelayMins : Integer;
															true,	//_disconnect : Boolean;
															2,	//_disconnectDelayMins : Integer;
															true,	//_monitor : Boolean;
															"UT TFS49581 First",	//_name : String;
															variance,	//_variance : TimeStampInterval;
															self.getTerminal	//_myTerminal : CM_Terminal
															);
		
		app.myTrxCA.trxCreateObjMatchCrit( pxyObjMatch, real, app.myPassport );
		self.assertTrueMsg( real &lt;&gt; null, "Failed to create Reefer Job Criteria - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	endif;
			
epilog

	delete pxyObjMatch;
	if allTransientCriteriaObj &lt;&gt; null and not allTransientCriteriaObj.isEmpty then	
		allTransientCriteriaObj.purge();
	endif;
	delete allTransientCriteriaObj;	
	delete allTimes;
	delete data;
	
		
end;</source>
        <Parameter name="_setup" type="Boolean"/>
        <Parameter name="_delete" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addReeferJob" id="9291b763-c7f8-4c1c-a299-8e19b97ab70d">
        <source>addReeferJob( _ti : CM_TrackedItem; reeferJobType : Integer; _now : TimeStamp ):CM_YardActivity;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	allSelected : CM_TISet;
	now : TimeStamp;
	reeferJob : CM_YardActivity;

begin

	create allSelected transient;
	
	allSelected.add( _ti );
	
	if _now.Date.isValid then
		now := _now;
	else
		now := app.actualTimeAppServer();
	endif;

	app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreateYardActivity( allSelected, reeferJobType, now, app.myPassport );
	
	reeferJob := _ti.allYardActivities.getAtKey( reeferJobType, now, _ti );
	
	self.assertTrueMsg( reeferJob &lt;&gt; null, "Reefer Job not created - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	return reeferJob;

epilog

	delete allSelected;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="reeferJobType" type="Integer"/>
        <Parameter name="_now" type="TimeStamp"/>
        <ReturnType type="CM_YardActivity"/>
    </JadeMethod>
    <JadeMethod name="assignedTeam" id="89bbef42-6767-40ca-abc7-6a2ef28bffd7">
        <options>4</options>
        <source>assignedTeam(): String typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2025	navsp1	Initial creation JIRA-34202

*/

vars

begin
	return UT_UnitTest.Team_Phil;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="tReeferJobs" id="1c2f094a-b623-4d2c-995d-f29ac8e85e71">
        <source>tReeferJobs();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 Aug 2020	jlgndl1	Initial creation	TFS 49581  Jade side of 'Reefer Native App' Reefer Jobs.
13 Apr 2021	navmd1	TFS 51044 Restrict walk block names to alphanumeric (no spaces)
14 Dec 2021	navdap1	Unit test fixups after DMAST -&gt; WMAST code overwrite
*/

constants

	ForkLiftStackId : String = "TFS49581";
	StradStackId : String = "SS49581";
	BaseCargoId : String = "CTFS49581";
	ReeferBlockName : String = "TFS49581ReeferWalk";
	VehicleId : String = "TRUK49581";
	CommodityCode : String = "APLI";
	ReeferTemp : Decimal = 1.0;
	
vars

	index : Integer;
	tiId : String;
	operator : CM_Operator;
	gridBS : CM_ForkLiftStack;
	sStack : CM_StraddleStack;
	lcArray : CM_LCArray;
	lcArray2 : CM_LCArray;
	rem : Integer;
	lcIndex : Integer;
	ti : CM_TrackedItem;
	tiArray : CM_TIArray;
	pxyReeferBlock : CM_ReeferBlock;
	tempReeferWalkPositionArray : CM_ReeferBlockPositionArray;
	reeferWalkPositionArray : CM_ReeferBlockPositionArray;
	lc : CM_LocationsController;
	count : Integer;
	tier : Integer;
	maxHeight : Integer;
	proxyReeferBlockPos : CM_ReeferBlockPosition;
	reeferBlock : CM_ReeferBlock;
	reeferBlockPosition : CM_ReeferBlockPosition;
	checkTiArray : CM_TIArray;
	iter : Iterator;
	checkArrayIndex : Integer;
	reeferJob : CM_YardActivity;
	now : TimeStamp;
	reefersArray : CM_TIArray;
	expectedTiArrayOrder : CM_TIArray;
	vvr : CM_VehicleVisitRecord;
	gate : CM_Gate;
	cargoType : CM_CargoType;
	preNote : CM_TrackedItem;
	wleArray : CM_WLEArray;	
	wlesWithWarnings : CM_WLEArray;	
	wle : CM_WorkListEntry;
	cont : CM_Container;
	yardAct : CM_YardActivity;
	timeInterval : TimeStampInterval;
	pxyGridBS : CM_ForkLiftStack;
	
begin

	// clean up
	foreach index in 1 to 27 do
		tiId := BaseCargoId &amp; index.padLeadingWith('0',2);
		self.deleteTrackedItem( tiId, false );
	endforeach;
	self.deleteTerminalArea( ForkLiftStackId );
	self.deleteTerminalArea( StradStackId );
	self.deleteVehicle(VehicleId);
	self.addDelReeferCriteria( false, true ); // just delete.
	
	
	// set up
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	cargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.opts.purge();
	self.opts.addAssoc("WithPower",true);
	gridBS := addForkLiftStack( ForkLiftStackId, 3, 3, 3 );
	self.assertTrueMsg( gridBS &lt;&gt; null, "Failed to set up Gridded Block Stack" );
	create lcArray transient;
	gridBS.allLocationsControllers.copy( lcArray );
	self.assertTrueMsg( lcArray.size = 9, "Gridded Block Stack, incorrect number of LCs found during setup" );
	self.opts.purge();
	self.opts.addAssoc("WITHPOWER",true);
	sStack := addStraddleStack( StradStackId, 2, 2, 1 );
	self.assertTrueMsg( sStack &lt;&gt; null, "Failed to set up Straddle Stack" );
	create tiArray transient;
	
	self.opts.purge();
	self.opts.addAssoc("temp",ReeferTemp);
	foreach index in 1 to 27 do  // 27 containers into 9 pad locations.
		tiId := BaseCargoId &amp; index.padLeadingWith('0',2);
		rem := index mod 3;
		if rem = 0 then
			lcIndex := (index / 3 ).Integer;
		else
			lcIndex := (( index + ( 3 - rem ) ) / 3 ).Integer; 
		endif;
		ti := self.addContainerAtLocation(tiId, operator, "2232", CommodityCode, TI_IMEX_STATUS_STORAGE, lcArray[lcIndex] );
		self.assertTrueMsg( ti &lt;&gt; null, tiId &amp; " container not created");
		tiArray.add( ti );
	endforeach;
	
	create tempReeferWalkPositionArray transient;
	create reeferWalkPositionArray transient;
	
	count := 0;
	//create the proxy walk positions
	foreach lc in gridBS.allLocationsControllers do
		maxHeight := lc.getMaxStackingHeight;
		if maxHeight &lt; 1 then
			continue;
		endif;
		tier := 1;
		foreach tier in 1 to maxHeight do  // repeat 9 pad positions x height of stack to get 27 walk positions
			count := count + 1;
			create proxyReeferBlockPos transient;	
			proxyReeferBlockPos.setDetails( lc, null, count, tier );
			tempReeferWalkPositionArray.add( proxyReeferBlockPos );
		endforeach;	
	endforeach;
	
	//re-order across level 1 backwards across 2 then forwards across 3 for the first block
	reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 25 ] );	// 000101 1  - CTFS4958125
	reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 16 ] );	// 000102 1  - CTFS4958116
	reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 07 ] );	// 000103 1  - CTFS4958107
	reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 08 ] );	// 000103 2  - CTFS4958108
	reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 17 ] );	// 000102 2  - CTFS4958117
	reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 26 ] );	// 000101 2  - CTFS4958126
	reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 27 ] );	// 000101 3  - CTFS4958127
	reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 18 ] );	// 000102 3  - CTFS4958118
	reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 09 ] );	// 000103 3  - CTFS4958109
	//Up down up
	reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 22 ] );	// 000201 1  - CTFS4958122
	reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 23 ] );	// 000201 2  - CTFS4958123
	reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 24 ] );	// 000201 3  - CTFS4958124
	reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 15 ] );	// 000202 3  - CTFS4958115
	reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 14 ] );	// 000202 2  - CTFS4958114
	reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 13 ] );	// 000202 1  - CTFS4958113
	reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 04 ] );	// 000203 1  - CTFS4958104
	reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 05 ] );	// 000203 2  - CTFS4958105
	reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 06 ] );	// 000203 3  - CTFS4958106
	// top across then middle across then bottom across all L -&gt; R
	reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 21 ] );	// 000301 3  - CTFS4958121
	reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 12 ] );	// 000302 3  - CTFS4958112
	reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 03 ] );	// 000303 3  - CTFS4958103
	reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 20 ] );	// 000301 2  - CTFS4958120
	reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 11 ] );	// 000302 2  - CTFS4958111
	reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 02 ] );	// 000303 2  - CTFS4958102
	reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 19 ] );	// 000301 1  - CTFS4958119
	reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 10 ] );	// 000302 1  - CTFS4958110
	reeferWalkPositionArray.add( tempReeferWalkPositionArray[ 01 ] );	// 000303 1  - CTFS4958101
	
	tempReeferWalkPositionArray.clear();

	create pxyReeferBlock transient;
	pxyReeferBlock.setProxy( ReeferBlockName, gridBS );
	pxyReeferBlock.allReeferPositions.copy( reeferWalkPositionArray );	
	
	//create a reefer walk path
	app.myPassport.setWarningsIgnored(false);
	app.myTrxCA.trxCreateReeferWalkPath( pxyReeferBlock, reeferWalkPositionArray, reeferBlock, app.myPassport );
	self.assertTrxWarningMsg(NReefer_Err_Name_To_Big, "Walk Patch name greater than 4 characters, expected warning to say as such");
	app.myPassport.warningsAcknowledged := true;
	self.assertNullMsg(reeferBlock, "Expected " &amp; ReeferBlockName &amp; " to not be created due to warnings not being acknowledged yet but was. reeferBlock");
	self.assertTrueMsg(gridBS.allReeferBlocks.size = 0, "Expected " &amp; ForkLiftStackId &amp; " to not have any Reefer Blocks, but found some");
	app.myTrxCA.trxCreateReeferWalkPath( pxyReeferBlock, reeferWalkPositionArray, reeferBlock, app.myPassport );
	self.assertTrueMsg( reeferBlock &lt;&gt; null, "Reefer Block not created - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	delete pxyReeferBlock;
	reeferWalkPositionArray.purge();
	
		
	//Add manual jobs of each sort and check reefer walk path methods return correct data in correct order. 'CM_ReeferBlock::getReefersWithCurrentJobs'	
	create reefersArray transient;
	
	now := app.actualTimeAppServer();
	reeferJob := self.addReeferJob( tiArray[1], CM_YardActivity.ReeferConnect, now );
	reeferJob := self.addReeferJob( tiArray[2], CM_YardActivity.ReeferConnect, now );
	reeferJob := self.addReeferJob( tiArray[3], CM_YardActivity.ReeferConnect, now );
	
	reeferJob := self.addReeferJob( tiArray[4], CM_YardActivity.ReeferMonitor, now );
	reeferJob := self.addReeferJob( tiArray[5], CM_YardActivity.ReeferMonitor, now );
	reeferJob := self.addReeferJob( tiArray[6], CM_YardActivity.ReeferMonitor, now );
	
	reeferJob := self.addReeferJob( tiArray[7], CM_YardActivity.ReeferAlarm, now );
	reeferJob := self.addReeferJob( tiArray[8], CM_YardActivity.ReeferAlarm, now );
	reeferJob := self.addReeferJob( tiArray[9], CM_YardActivity.ReeferAlarm, now );
	
	reeferJob := self.addReeferJob( tiArray[10], CM_YardActivity.ReeferDisconnect, now );
	reeferJob := self.addReeferJob( tiArray[11], CM_YardActivity.ReeferDisconnect, now );
	reeferJob := self.addReeferJob( tiArray[12], CM_YardActivity.ReeferDisconnect, now );
	
	create expectedTiArrayOrder transient;	//Just the 12 added and in the same order as the reefer walk
	expectedTiArrayOrder.add( tiArray[ 07 ] );	// 000103 1  - CTFS4958107
	expectedTiArrayOrder.add( tiArray[ 08 ] );	// 000103 2  - CTFS4958108
	expectedTiArrayOrder.add( tiArray[ 09 ] );	// 000103 3  - CTFS4958109	
	expectedTiArrayOrder.add( tiArray[ 04 ] );	// 000203 1  - CTFS4958104
	expectedTiArrayOrder.add( tiArray[ 05 ] );	// 000203 2  - CTFS4958105
	expectedTiArrayOrder.add( tiArray[ 06 ] );	// 000203 3  - CTFS4958106		
	expectedTiArrayOrder.add( tiArray[ 12 ] );	// 000302 3  - CTFS4958112
	expectedTiArrayOrder.add( tiArray[ 03 ] );	// 000303 3  - CTFS4958103	
	expectedTiArrayOrder.add( tiArray[ 11 ] );	// 000302 2  - CTFS4958111
	expectedTiArrayOrder.add( tiArray[ 02 ] );	// 000303 2  - CTFS4958102	
	expectedTiArrayOrder.add( tiArray[ 10 ] );	// 000302 1  - CTFS4958110
	expectedTiArrayOrder.add( tiArray[ 01 ] );	// 000303 1  - CTFS4958101
	
	reefersArray.clear();
	reeferBlock.getReefersWithCurrentJobs( reefersArray );
	foreach index in 1 to 12 do
		self.assertTrueMsg( expectedTiArrayOrder[ index ] = reefersArray[ index ], "[First Time] TI @ Reefer array index " &amp; index.String &amp; " should match expectedTiArrayOrder @ same index" );
	endforeach;
	
	//complete a monitor job while there is no automation, there should be no new monitor job added.
	app.myTrxUA.trxUpdYardActivityActioned( tiArray[ 05 ].allYardActivities.first, app.myPassport );
	self.assertTrueMsg( tiArray[ 05 ].allYardActivities.isEmpty, "Reefer Job not cleared - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	//Check moving reefer off-site with each of the jobs clears the jobs.  
	vvr := self.gateOutContainer(VehicleId, "", "", tiArray[ 03 ].CM_Container, true, gate, null);
	self.assertTrueMsg( vvr &lt;&gt; null, "Gate Out VVR not created for container '03' - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	self.workVehicle(vvr);
	self.roadExit(vvr);
	self.assertTrueMsg( tiArray[ 03 ].allYardActivities.isEmpty, "Road Exit didn't clear Connect Job for container '03' - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	vvr := self.gateOutContainer(VehicleId, "", "", tiArray[ 06 ].CM_Container, true, gate, null);
	self.assertTrueMsg( vvr &lt;&gt; null, "Gate Out VVR not created for container '03' - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	self.workVehicle(vvr);
	self.roadExit(vvr);
	self.assertTrueMsg( tiArray[ 06 ].allYardActivities.isEmpty, "Road Exit didn't clear Monitor Job for container '06' - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	vvr := self.gateOutContainer(VehicleId, "", "", tiArray[ 09 ].CM_Container, true, gate, null);
	self.assertTrueMsg( vvr &lt;&gt; null, "Gate Out VVR not created for container '03' - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	self.workVehicle(vvr);
	self.roadExit(vvr);
	self.assertTrueMsg( tiArray[ 09 ].allYardActivities.isEmpty, "Road Exit didn't clear Alarm Job for container '09' - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	vvr := self.gateOutContainer(VehicleId, "", "", tiArray[ 12 ].CM_Container, true, gate, null);
	self.assertTrueMsg( vvr &lt;&gt; null, "Gate Out VVR not created for container '03' - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	self.workVehicle(vvr);
	self.roadExit(vvr);
	self.assertTrueMsg( tiArray[ 12 ].allYardActivities.isEmpty, "Road Exit didn't clear Disconnect Job for container '12' - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	expectedTiArrayOrder.clear;	//Now check just the 7 still with jobs
	expectedTiArrayOrder.add( tiArray[ 07 ] );	// 000103 1  - CTFS4958107
	expectedTiArrayOrder.add( tiArray[ 08 ] );	// 000103 2  - CTFS4958108	
	expectedTiArrayOrder.add( tiArray[ 04 ] );	// 000203 1  - CTFS4958104	
	expectedTiArrayOrder.add( tiArray[ 11 ] );	// 000302 2  - CTFS4958111
	expectedTiArrayOrder.add( tiArray[ 02 ] );	// 000303 2  - CTFS4958102	
	expectedTiArrayOrder.add( tiArray[ 10 ] );	// 000302 1  - CTFS4958110
	expectedTiArrayOrder.add( tiArray[ 01 ] );	// 000303 1  - CTFS4958101
	
	reefersArray.clear();
	reeferBlock.getReefersWithCurrentJobs( reefersArray );
	foreach index in 1 to 7 do
		self.assertTrueMsg( expectedTiArrayOrder[ index ] = reefersArray[ index ], "[Second Time] TI @ Reefer array index " &amp; index.String &amp; " should match expectedTiArrayOrder @ same index" );
	endforeach;
	
	
	//Add Automation i.e. CM_ReeferJobCriteria.
	self.addDelReeferCriteria( true, false ); // just setup.
	
	// Create prenotes, Gate in, Rail in and Voyage In Reefers.	
	foreach index in 3 to 12 do 
		if index.isOneOf( 3, 6, 9, 12 ) then
			tiId := BaseCargoId &amp; index.padLeadingWith('0',2);	
			beginTransaction;
			preNote := self.getTerminal.createTI( cargoType, false );
			preNote.setPxyFromDefaultTI( self.getTerminal, cargoType.id, tiId, CommodityCode, operator );
			preNote.changeState(TI_STATE_NOTIFIED, app.myPassport );
			preNote.setISOType( "2232" );
			preNote.setTotalWeightWithoutTrans( 4000 );
			preNote.setTemperature( ReeferTemp );
			preNote.setRemarks(self.createdByUnitTest(ti.remarks), false);
			commitTransaction;	
			tiArray[ index ] := preNote; // same positions as the gated out cargo with the same id.
		endif;
	endforeach;
	
	reefersArray.clear();
	reeferBlock.getReefersWithCurrentJobs( reefersArray );
	self.assertTrueMsg( reefersArray.size = 7, "Adding Pre-notes should not have caused reefer jobs to be added." );

	//Gate in truck with prenote
	cont := tiArray[ 03 ].CM_Container;
	self.opts.purge();
	self.opts.addAssoc( "PreNote", cont );
	vvr := self.gateInContainer(VehicleId, cont.id, "2232", cont.operatorCode, CommodityCode, gate);
	self.assertTrueMsg( vvr &lt;&gt; null, "Gating in first prenote failed - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	create wleArray transient;
	create wlesWithWarnings transient;
	vvr.myRoadJob.getAllWLEs(wleArray);
	wle := wleArray.first;
	beginTransaction;
	wle.setNewLocationTarget( lcArray[1].CM_LocationsController ); // top of 000303
	commitTransaction;
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateWLEsDoMove(wleArray, wlesWithWarnings, REAL_MODE, false,null, app.myPassport);	
	self.assertTrueMsg( cont.allYardActivities.size = 2, "Move of pre-note '" &amp; cont.id &amp; "' to a yard position failed to create Reefer Jobs (S/be Connect and Monitor)- " &amp; app.myPassport.getErrorsAndWarningsAsString );
	yardAct := cont.allYardActivities.getLastActivityTypeOf( CM_YardActivity.ReeferConnect );
	self.assertTrueMsg( yardAct &lt;&gt; null, "Last Monitor Reefer Job for '" &amp; cont.id &amp; "'not found." );
	timeInterval := yardAct.actionTime - now;
	self.assertTrueMsg( timeInterval.asMinutes &gt; 9 and timeInterval.asMinutes &lt; 11, "Last Connect Reefer Job for '" &amp; cont.id &amp; "' time interval outside expected range 9 - 11 mins @ " &amp; timeInterval.asMinutes.String );
	
	//complete a connect job while there IS automation, there should be No new job added.
	app.myTrxUA.trxUpdYardActivityActioned( tiArray[ 01 ].allYardActivities.first, app.myPassport );
	self.assertTrueMsg( tiArray[ 01 ].allYardActivities.isEmpty, "S/be no reefer jobs for '" &amp; tiArray[ 01 ].id &amp; "' - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( tiArray[ 01 ].getLastTransOfClass( CM_Information ) &lt;&gt; null, "S/be an Info transaction '" &amp; tiArray[ 01 ].id &amp; "' - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	//complete a monitor job while there IS automation, there should be a new monitor job added.
	app.myTrxUA.trxUpdYardActivityActioned( tiArray[ 04 ].allYardActivities.first, app.myPassport );
	self.assertTrueMsg( not tiArray[ 04 ].allYardActivities.isEmpty, "Monitor Reefer Job for '" &amp; tiArray[ 04 ].id &amp; "'not created - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( tiArray[ 04 ].getLastTransOfClass( CM_Information ) &lt;&gt; null, "S/be an Info transaction '" &amp; tiArray[ 04 ].id &amp; "' - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	yardAct := tiArray[ 04 ].allYardActivities.getLastActivityTypeOf( CM_YardActivity.ReeferMonitor );
	self.assertTrueMsg( yardAct &lt;&gt; null, "Last Monitor Reefer Job for '" &amp; tiArray[ 04 ].id &amp; "'not found." );
	timeInterval := yardAct.actionTime - now;
	self.assertTrueMsg( timeInterval.asHours &gt;= 4 and timeInterval.asHours &lt;= 12, "Last Monitor Reefer Job for '" &amp; tiArray[ 04 ].id &amp; "' time interval outside expected range 4 - 12 hrs @ " &amp; timeInterval.asHours.String );
	
	//complete a alarm job while there IS automation, there should be NO new job added.
	app.myTrxUA.trxUpdYardActivityActioned( tiArray[ 07 ].allYardActivities.first, app.myPassport );
	self.assertTrueMsg( tiArray[ 07 ].allYardActivities.isEmpty, "S/be no reefer jobs for '" &amp; tiArray[ 07 ].id &amp; "' - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( tiArray[ 07 ].getLastTransOfClass( CM_Information ) &lt;&gt; null, "S/be an Info transaction '" &amp; tiArray[ 07 ].id &amp; "' - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	//complete a disconnect job while there IS automation, there should be NO new job added.
	app.myTrxUA.trxUpdYardActivityActioned( tiArray[ 11 ].allYardActivities.first, app.myPassport );
	self.assertTrueMsg( tiArray[ 11 ].allYardActivities.isEmpty, "S/be no reefer jobs for '" &amp; tiArray[ 11 ].id &amp; "' - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( tiArray[ 11 ].getLastTransOfClass( CM_Information ) &lt;&gt; null, "S/be an Info transaction '" &amp; tiArray[ 11 ].id &amp; "' - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	expectedTiArrayOrder.clear;	//Now check just the 5 still with jobs	
	expectedTiArrayOrder.add( tiArray[ 08 ] );	// 000103 2  - CTFS4958108	
	expectedTiArrayOrder.add( tiArray[ 04 ] );	// 000203 1  - CTFS4958104	- Future monitor ( circa 4-12 hours ) job to replace the one that was just actioned.
	expectedTiArrayOrder.add( tiArray[ 03 ] );	// 000303 3  - CTFS4958103 	- Future connect ( circa 10 minutes ) and monitor ( circa 4-12 hours ) jobs added when moved to location
	expectedTiArrayOrder.add( tiArray[ 02 ] );	// 000303 2  - CTFS4958102	
	expectedTiArrayOrder.add( tiArray[ 10 ] );	// 000302 1  - CTFS4958110
	
	reefersArray.clear();
	reeferBlock.getReefersWithJobs( reefersArray );
	foreach index in 1 to 5 do
		self.assertTrueMsg( expectedTiArrayOrder[ index ] = reefersArray[ index ], "[First Time ALL jobs] TI @ Reefer array index " &amp; index.String &amp; " should match expectedTiArrayOrder @ same index" );
	endforeach;
	
	expectedTiArrayOrder.clear;	//Now check just the 3 still with jobs	
	expectedTiArrayOrder.add( tiArray[ 08 ] );	// 000103 2  - CTFS4958108	
	expectedTiArrayOrder.add( tiArray[ 02 ] );	// 000303 2  - CTFS4958102	
	expectedTiArrayOrder.add( tiArray[ 10 ] );	// 000302 1  - CTFS4958110
	
	reefersArray.clear();
	reeferBlock.getReefersWithCurrentJobs( reefersArray );
	foreach index in 1 to 3 do
		self.assertTrueMsg( expectedTiArrayOrder[ index ] = reefersArray[ index ], "[Third Time Current Jobs] TI @ Reefer array index " &amp; index.String &amp; " should match expectedTiArrayOrder @ same index" );
	endforeach;
	
	create lcArray2 transient;
	sStack.allLocationsControllers.copy( lcArray2 );
	
	cont := tiArray[ 11 ].CM_Container;
	self.updateTIConnection( cont, false, true, now, null);
	
	self.moveQueued( cont, lcArray2.first );
	self.assertTrueMsg( cont.allYardActivities.size = 1, "S/be a disconnect reefer jobs for '" &amp; cont.id &amp; "' after queuing - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	yardAct := cont.allYardActivities.getLastActivityTypeOf( CM_YardActivity.ReeferDisconnect );
	self.assertTrueMsg( yardAct &lt;&gt; null, "Last Monitor Reefer Job for '" &amp; cont.id &amp; "'not found." );
	timeInterval := yardAct.actionTime - now;
	self.assertTrueMsg( timeInterval.asMinutes &gt; 1 and timeInterval.asMinutes &lt; 3, "Last Disconnect Reefer Job for '" &amp; cont.id &amp; "' time interval outside expected range 1 - 3 mins @ " &amp; timeInterval.asMinutes.String );
	
	
	app.myTrxUA.trxUpdYardActivityActioned( tiArray[ 11 ].allYardActivities.first, app.myPassport ); // complete the reefer disconnect job
	self.assertTrueMsg( tiArray[ 11 ].allYardActivities.isEmpty, "S/be no reefer jobs for '" &amp; tiArray[ 11 ].id &amp; "' - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	self.moveIT( tiArray[ 11 ], REAL_MODE );
	self.assertTrueMsg( tiArray[ 11 ].allYardActivities.size = 2, "S/be a connect and a monitor reefer job for '" &amp; tiArray[ 11 ].id &amp; "' after moving - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	
	expectedTiArrayOrder.clear;	//Now check just the 3 still with jobs	- Cos the two new ones for '11' added aboove are not in a reefer walk.
	expectedTiArrayOrder.add( tiArray[ 08 ] );	// 000103 2  - CTFS4958108	
	expectedTiArrayOrder.add( tiArray[ 02 ] );	// 000303 2  - CTFS4958102	
	expectedTiArrayOrder.add( tiArray[ 10 ] );	// 000302 1  - CTFS4958110
	
	reefersArray.clear();
	reeferBlock.getReefersWithCurrentJobs( reefersArray );
	foreach index in 1 to 3 do
		self.assertTrueMsg( expectedTiArrayOrder[ index ] = reefersArray[ index ], "[Third Time Current Jobs] TI @ Reefer array index " &amp; index.String &amp; " should match expectedTiArrayOrder @ same index" );
	endforeach;
	
	//simulate reefer alert  check for alarm.
	cont := tiArray[ 03 ].CM_Container;
	app.myTrxUA.trxUpdateReeferAlert( cont, SEVERE_REEFER, "UNITTEST: Testing off power alert for " &amp; cont.id, app.myPassport);
	cont := tiArray[ 05 ].CM_Container;
	app.myTrxUA.trxUpdateReeferDefrostAlert( cont, SEVERE_REEFER, "UNITTEST: Testing defrost alert for " &amp; cont.id, app.myPassport);
	
	expectedTiArrayOrder.clear;	//Now check the 5 still with jobs	- Cos the two alarms are always current and on the walk
	expectedTiArrayOrder.add( tiArray[ 08 ] );	// 000103 2  - CTFS4958108
	expectedTiArrayOrder.add( tiArray[ 05 ] );	// 000203 2  - CTFS4958105
	expectedTiArrayOrder.add( tiArray[ 03 ] );	// 000303 3  - CTFS4958103
	expectedTiArrayOrder.add( tiArray[ 02 ] );	// 000303 2  - CTFS4958102	
	expectedTiArrayOrder.add( tiArray[ 10 ] );	// 000302 1  - CTFS4958110
	
	reefersArray.clear();
	reeferBlock.getReefersWithCurrentJobs( reefersArray );
	foreach index in 1 to 5 do
		self.assertTrueMsg( expectedTiArrayOrder[ index ] = reefersArray[ index ], "[Third Time Current Jobs] TI @ Reefer array index " &amp; index.String &amp; " should match expectedTiArrayOrder @ same index" );
	endforeach;
	
	//08 Apr 2021	NDL	TFS 51042
	foreach index in 1 to 27 do
		tiId := BaseCargoId &amp; index.padLeadingWith('0',2);
		self.deleteTrackedItem( tiId, false );
	endforeach;
	pxyGridBS := app.createUpdateProxy( gridBS ).CM_ForkLiftStack;
	pxyGridBS.setProxy(ForkLiftStackId, 
						"",
						TA_TYPE_FORK_LIFT_STACK, 
						3, 
						2, 
						3,
						"Gridded Block Stack",
						true,  //back
						true, //front
						HEIGHT_FULL_HIGH_CUBE*3, //full height //
						HEIGHT_FULL_HIGH_CUBE*3, //MT height
						HEIGHT_FULL_HIGH_CUBE*3, //power height
						null,
						false, //release point
						self.getTerminal,
						false, //stock
						false, // hide ove
						0, //deck start type
						false, false, false, false, false, null,null, true, false,	
						"West", "East", "North", "South");
						
	delete pxyGridBS.allGridColumns.last(); // delete a row that includes reefer walk path positions.
	app.myTrxUA.trxUpdateTerminalArea(pxyGridBS, app.myPassport);
	self.assertTrueMsg( app.myPassport.allErrors.includesErrorCode(Colum_not_remov_still_decla_re), "Should have raised an error " &amp; Colum_not_remov_still_decla_re.String );
	
// clean up
//	foreach index in 1 to 27 do
//		tiId := BaseCargoId &amp; index.padLeadingWith('0',2);
//		self.deleteTrackedItem( tiId, false );
//	endforeach;
	self.deleteTerminalArea( ForkLiftStackId );
	self.deleteTerminalArea( StradStackId );
	self.deleteVehicle(VehicleId);
	self.addDelReeferCriteria( false, true ); // just delete.

epilog

	abortTransaction;

	delete pxyGridBS;
	delete pxyReeferBlock;
	if reeferWalkPositionArray &lt;&gt; null then
		reeferWalkPositionArray.purge();
	endif;
	delete reeferWalkPositionArray;
	delete lcArray;
	delete tiArray;
	delete checkTiArray;
	delete iter;
	delete reefersArray;
	delete tempReeferWalkPositionArray;
	delete expectedTiArrayOrder;
	delete wlesWithWarnings;
	delete wleArray;
	delete lcArray2;

end;

</source>
    </JadeMethod>
    <JadeMethod name="tValidateWalkPathName" id="2e1fbe3b-d7f2-4155-bc13-c0c81888e9db">
        <source>tValidateWalkPathName();
/*

Purpose:			Basically coppied from tReeferJobs, just to split this out

Parameters:			

Return Value:		

Date				Who		Reason
13 April 2021		navmd1	Initial creation TFS 51044 Force Reefer Walk Paths to only allow alphanumeric names

*/

constants
	ForkLiftStackId  : String = "TFS51044";
vars
	gridBS						: CM_ForkLiftStack;
	pxyReeferBlock,
	reeferBlock					: CM_ReeferBlock;
	reeferWalkPositionArray		: CM_ReeferBlockPositionArray;
	
begin
	// Clean up
	self.deleteTerminalArea( ForkLiftStackId );
	
	// Set up
	self.opts.purge();
	self.opts.addAssoc("WithPower",true);
	gridBS := addForkLiftStack( ForkLiftStackId, 3, 3, 3 );
	self.assertTrueMsg( gridBS &lt;&gt; null, "Failed to set up Gridded Block Stack" );

	create reeferWalkPositionArray transient;
	create pxyReeferBlock transient;
	
	// Create a reefer walk path with spaces
	pxyReeferBlock.setProxy( "TFS51044 Reefer Walk", gridBS );
	app.myTrxCA.trxCreateReeferWalkPath( pxyReeferBlock, reeferWalkPositionArray, reeferBlock, app.myPassport );
	self.assertTrxErrorMsg(NReefer_Err_Invalid_Char, "Expecting Invalid Character error");
	
	// Create a reefer walk path with hyphens
	pxyReeferBlock.setProxy( "TFS51044-Reefer-Walk", gridBS );
	app.myTrxCA.trxCreateReeferWalkPath( pxyReeferBlock, reeferWalkPositionArray, reeferBlock, app.myPassport );
	self.assertTrxErrorMsg(NReefer_Err_Invalid_Char, "Expecting Invalid Character error");

	// Create a reefer walk path with underscores
	pxyReeferBlock.setProxy( "TFS51044_Reefer_Walk", gridBS );
	app.myTrxCA.trxCreateReeferWalkPath( pxyReeferBlock, reeferWalkPositionArray, reeferBlock, app.myPassport );
	self.assertTrxErrorMsg(NReefer_Err_Invalid_Char, "Expecting Invalid Character error");
	
	// Create a reefer walk path with length &gt; 4
	pxyReeferBlock.setProxy( "TFS51044ReeferWalk", gridBS );
	app.myTrxCA.trxCreateReeferWalkPath( pxyReeferBlock, reeferWalkPositionArray, reeferBlock, app.myPassport );
	self.assertTrxWarningMsg(NReefer_Err_Name_To_Big, "Expecting Name Too Big warning");
	
	// Create a reefer walk path (without any errors or warnings)
	pxyReeferBlock.setProxy( "WKP1", gridBS );
	app.myTrxCA.trxCreateReeferWalkPath( pxyReeferBlock, reeferWalkPositionArray, reeferBlock, app.myPassport );
	self.assertNoTrxErrorsOrWarnings();
	
	// Clean up
	self.deleteTerminalArea( ForkLiftStackId );
	
epilog
	delete pxyReeferBlock;
	delete reeferWalkPositionArray;
end;</source>
    </JadeMethod>
</Class>
