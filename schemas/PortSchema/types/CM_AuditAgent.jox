    <JadeMethod name="auditUpdate" id="ddc59666-9db2-4106-99b5-519a8f2405a5">
        <updating/>
        <source>auditUpdate(pSubject : CM_Object; tag: String; currentValue: Any) updating;

vars
	anAudit: CM_AuditObject;
	currentValueString: String;
	tmpAuditConfig : CM_AuditConfig;

begin

	if self.auditDisabled or pSubject = null or 
	   pSubject.isTransient or pSubject.isKindOf(CM_AuditObject) then
		return;
	endif;
	
	if (not getAuditConfigForClass( pSubject, pSubject.class, tmpAuditConfig)) then
		return;
	endif;	
	
	currentValueString := getCurrentValueString(currentValue);
	if isBackGroundProcess then
		createAuditRequest(pSubject, tag, currentValueString, null, BGP_AuditRequest.Update, null);
		return;
	else
		anAudit := self.auditedObjects[pSubject];
		if anAudit = null then
			anAudit := self.createAuditObject(pSubject, AuditUpdated, tmpAuditConfig, null);
		else
			if anAudit.type = AuditCreated then
				return;
			endif; 
		endif;
			
		anAudit.addToText(tag, currentValueString);	
		//epr TFS 37199 15/3/18
		if pSubject.class = CM_User and tag = CM_User::numberOfFailedLogons.name then
			if anAudit.myUser &lt;&gt; null then
				anAudit.setMyUser(null);
			endif;
		endif;
		
	endif;
	
end;</source>
        <Parameter name="pSubject" type="CM_Object"/>
        <Parameter name="tag" type="String"/>
        <Parameter name="currentValue" type="Any"/>
    </JadeMethod>
    <JadeMethod name="auditUpdateTALocationsTrx" id="c0de1206-7934-420e-8703-a98ccc27aecc">
        <source>auditUpdateTALocationsTrx(_subject : CM_TerminalAreaMaster; _beforeText, _afterText : String; 
						_locations :CM_LCSet; _locType, _locMode :Integer; _details :String):CM_AuditTALocations;
// ---------------------------------------------------------------------------
// Created:     02 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	audit 			: CM_AuditTALocations;
	deltaBeforeText, 
	deltaAfterText 	: String;
	config 			: CM_AuditConfig;
	doProcess 		: Boolean;

begin
	if self.auditDisabled or
	   _subject = null or 
	   _subject.isTransient or 
	   _subject.isKindOf(CM_AuditObject)  then 
		return null;
	endif;

	if not self.getAuditConfigForClass( _subject, _subject.class, config) then
		return null;
	endif;

	// we create an audit even if the subject before and after images are then same
	// because we are auditing changes to the locations rather than the subject
	audit := self.createAuditTALocation(_subject, AuditUpdated, config, _locations, _locType, _locMode,_details);
	
	if _beforeText &lt;&gt; null or _afterText &lt;&gt; null then
		self.doTextComparison (_subject,_beforeText, _afterText, deltaBeforeText, deltaAfterText);
		
		audit.setAuditText(deltaBeforeText);
		audit.setPostAuditText(deltaAfterText);
	endif;
	
	return audit;
	
	return null;

end;</source>
        <Parameter name="_subject" type="CM_TerminalAreaMaster"/>
        <Parameter name="_beforeText" type="String"/>
        <Parameter name="_afterText" type="String"/>
        <Parameter name="_locations" type="CM_LCSet"/>
        <Parameter name="_locType" type="Integer"/>
        <Parameter name="_locMode" type="Integer"/>
        <Parameter name="_details" type="String"/>
        <ReturnType type="CM_AuditTALocations"/>
    </JadeMethod>
    <JadeMethod name="auditUpdateTrx" id="ae3e5972-4129-4cd1-b3db-9c38cb123d7d">
        <updating/>
        <source>auditUpdateTrx(subject : CM_Object; beforeText, afterText : String) : CM_AuditObject updating;
// ---------------------------------------------------------------------------
// Created:     12 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	anAudit 			: CM_AuditObject;
	deltaBeforeText, 
	deltaAfterText 		: String;
	tmpAuditConfig 		: CM_AuditConfig;
	doProcess 			: Boolean;

begin
	if self.auditDisabled or
	   beforeText = afterText or
	   subject = null or subject.isTransient or 
	   subject.isKindOf(CM_AuditObject)
	   then
		return null;
	endif;

	if not self.getAuditConfigForClass( subject, subject.class, tmpAuditConfig) then
		return null;
	endif;
		
	if self.isBackGroundProcess then
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  WARNING if implemented then also need to change ' &amp;
				' the way CM_TrackedITem.createEditTransactionFromAudit(ao); works and where called from');

		self.createAuditRequest(subject, beforeText, afterText, null, BGP_AuditRequest.UpdateTrx, null);
		return null;
	else
	
	
		if self.doTextComparison(subject,beforeText, afterText, deltaBeforeText, deltaAfterText) then
	
			anAudit := self.createAuditObject(subject, AuditUpdated, tmpAuditConfig, null);																								
			anAudit.setAuditText(deltaBeforeText);
			anAudit.setPostAuditText(deltaAfterText);
			return anAudit;
		else
			//if beforeText.countOccurrences(AuditStringSeparator) &gt; 3 then
				
				
			//endif;
		endif;
	endif;
	
		
	
	return null;

end;</source>
        <Parameter name="subject" type="CM_Object"/>
        <Parameter name="beforeText" type="String"/>
        <Parameter name="afterText" type="String"/>
        <ReturnType type="CM_AuditObject"/>
    </JadeMethod>
    <JadeMethod name="auditUpdateTrxExtra" id="4622aab3-9981-43ef-83c8-40bd5ec382b4">
        <updating/>
        <source>auditUpdateTrxExtra(subject : CM_Object; auditText: String; _extraInfo: String)  updating;
/* ---------------------------------------------------------------------------
Created:	31/10/2017	by jlgrh7

TFS 6947        POL - Missing Audit records for bookings
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/

vars
	anAudit 		: CM_AuditObject;
	tmpAuditConfig	: CM_AuditConfig;
	doProcess 		: Boolean;

begin

	if self.auditDisabled or
	   auditText = null or
	   subject = null or subject.isTransient or subject.isKindOf(CM_AuditObject)
	then
		return;
	endif;
	
	if not self.getAuditConfigForClass( subject, subject.class, tmpAuditConfig) then
		return;
	endif;
	
	if isBackGroundProcess then
		self.createAuditRequest(subject, auditText, null, null, BGP_AuditRequest.Update, _extraInfo);
		return;
	else
		anAudit := self.createAuditObject(subject, AuditUpdated, tmpAuditConfig, _extraInfo);
		anAudit.setAuditText(auditText);
		anAudit.setPostAuditText(null);
	endif;
end;</source>
        <Parameter name="subject" type="CM_Object"/>
        <Parameter name="auditText" type="String"/>
        <Parameter name="_extraInfo" type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="403542ec-ed20-4594-ae95-624780a06dfd">
        <updating/>
        <source>create() updating;

vars

begin

	if app.myRoot = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Reference to CM_Root is null');
		return;
	endif;
	
	app.myRoot.allAuditConfigs.copy(self.allAuditConfigs);
	
	setIsBackGroundProcess();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createAuditObject" id="7027c3dd-c499-489a-b401-cb7a43cc2d4a">
        <source>createAuditObject(subject: CM_Object; t: Integer; pAuditConfig : CM_AuditConfig; _extraInfo : String) : CM_AuditObject protected;
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 05/06/2025	navdap1		MTN-12349 EUP - Transport Manifest load after locking does not add all cargo to work order
vars
	anAudit: CM_AuditObject;
	invalid : Boolean;

begin
	on Exception do app.handleDeletedObject(exception, anAudit, invalid);	// MTN-12349
	
	anAudit := self.auditedObjects[subject];
	// MTN-12349 start
	if anAudit &lt;&gt; null then
		anAudit.edition;
		if invalid then
			anAudit := null;
		endif;
	endif;
	// MTN-12349 end

	if anAudit = null then
		if _extraInfo = null then
			create anAudit persistent;
		else
			create anAudit as CM_AuditObjectInformation persistent;
			anAudit.setInfo(_extraInfo);
		endif;
		anAudit.updateForCreate(subject, t, pAuditConfig);
		auditedObjects.add(anAudit);
	else
		if anAudit.type &lt;&gt; t then
			anAudit.setType(t);
		endif;
	endif;
	
	return anAudit;

end;</source>
        <access>protected</access>
        <Parameter name="subject" type="CM_Object"/>
        <Parameter name="t" type="Integer"/>
        <Parameter name="pAuditConfig" type="CM_AuditConfig"/>
        <Parameter name="_extraInfo" type="String"/>
        <ReturnType type="CM_AuditObject"/>
    </JadeMethod>
    <JadeMethod name="createAuditRequest" id="f64bb7ad-e8f8-471c-ab90-e78bdc39a789">
        <source>createAuditRequest(_subject : CM_Object; _beforeText, _afterText, _userCode : String; _mode : Integer; _extraInfo : String) protected;

vars

	audRequest	: BGP_AuditRequest;
	
begin

//	audRequest := self.allAuditRequests[_subject];	
	create audRequest persistent;
	audRequest.initAuditRequest(_subject, _beforeText, _afterText, _userCode, _mode, _extraInfo);
	

end;</source>
        <access>protected</access>
        <Parameter name="_subject" type="CM_Object"/>
        <Parameter name="_beforeText" type="String"/>
        <Parameter name="_afterText" type="String"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_extraInfo" type="String"/>
    </JadeMethod>
    <JadeMethod name="createAuditTALocation" id="393d49cd-da88-4da3-b8db-69e85983317e">
        <source>createAuditTALocation(_subject: CM_TerminalAreaMaster; _type: Integer; _config : CM_AuditConfig;
						_locations :CM_LCSet; _locType, _locMode :Integer; _details :String) : CM_AuditTALocations protected;
// ---------------------------------------------------------------------------
// Created:     02 March 2011 by cnwcs5 CCMS CPL 2027/PAR 27126
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	audit	: CM_AuditObject;
	iter	: Iterator;
begin 
	if _type = AuditUpdated then
		// if update type is updated then there can be only one CM_AuditObject/CM_AuditTALocation object for a subject
		audit := self.auditedObjects[_subject];
		
		if audit &lt;&gt; null and not audit.isKindOf (CM_AuditTALocations) then
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'Unexpected audit for subject');
		endif;
	elseif _type = AuditCreated then
		// look for an audit for the same subject, location update type, and location update mode
		// even though the _type parameter is AuditCreated, the actual audit will be an update of the terminal area
		// if there is one with matching details then that's the one we want
		iter := self.allAuditTALocations.createIterator;
		
		self.allAuditTALocations.startKeyGeq (_subject, AuditUpdated, _locType, _locMode, iter);
		
		while iter.next (audit) do
			if audit.mySubject &lt;&gt; _subject or
				audit.type &lt;&gt; AuditUpdated or
				audit.CM_AuditTALocations.locationUpdateType &lt;&gt; _locType or
				audit.CM_AuditTALocations.locationUpdateMode &lt;&gt; _locMode then
				break;
			endif;
			if audit.CM_AuditTALocations.locationUpdateDetails = _details then
				// just include all locations in the existing audit
				audit.CM_AuditTALocations.updateLocations (_locations);
				break;
			endif;
			
			audit := null;	// so we know we have not found one yet
		endwhile;
		
	endif;
	
	if audit = null then
		create audit as CM_AuditTALocations persistent;
	
		// these audits are always an update of terminal area
		audit.CM_AuditTALocations.setForCreate(_subject, AuditUpdated, _config, _locations, _locType, _locMode, _details);
		
		// we can have lots of audits for the same subject in a transaction but only one gets
		// added to the auditedObjects collection on the receiver and that is the one that has the
		// before and after images for the subject
		if _type = AuditUpdated then
			self.auditedObjects.add(audit);
		elseif _type = AuditCreated then
			self.allAuditTALocations.add (audit.CM_AuditTALocations);
		endif;
	endif;

	return audit.CM_AuditTALocations;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_subject" type="CM_TerminalAreaMaster"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_config" type="CM_AuditConfig"/>
        <Parameter name="_locations" type="CM_LCSet"/>
        <Parameter name="_locType" type="Integer"/>
        <Parameter name="_locMode" type="Integer"/>
        <Parameter name="_details" type="String"/>
        <ReturnType type="CM_AuditTALocations"/>
    </JadeMethod>
    <JadeMethod name="createCreateAuditFromRequest" id="2341c3f5-acfd-4417-982f-3b4af43849a9">
        <source>createCreateAuditFromRequest(_req : BGP_AuditRequest);

vars

	anAudit 		: CM_AuditObject;
	tmpAuditConfig	: CM_AuditConfig;

begin

	if not self.getAuditConfigForClass( _req.mySubject, _req.mySubject.class, tmpAuditConfig) then
		return;
	endif;
	anAudit := self.createAuditObject(_req.mySubject, AuditCreated, tmpAuditConfig, _req.extraInfo);
	anAudit.setAuditText(_req.beforeText);
	anAudit.setPostAuditText(null);
	
end;</source>
        <Parameter name="_req" type="BGP_AuditRequest"/>
    </JadeMethod>
    <JadeMethod name="createDeleteAuditFromRequest" id="0ecb607b-6789-46df-8d3c-f4c0f7a4451e">
