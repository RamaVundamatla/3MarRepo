    <JadeMethod name="setForCreate" id="a066431a-0e82-455a-bf01-8e47beb8b584">
        <updating/>
        <source>setForCreate(pProxy : CM_Code) updating;
// ---------------------------------------------------------------------------
// Created:     07 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
