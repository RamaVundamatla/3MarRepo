    <JadeMethod name="getBayCrane" id="1a59bf8f-c454-4b58-a2c7-303922960540">
        <source>getBayCrane() : Integer;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		Gets the ordinal of the bay that is currently being worked by the crane
//
// ---------------------------------------------------------------------------

vars
	aJob : CM_Job;
	aVJob : CM_VoyageJob;
	aBay : CM_Bay;
	aVoyage : CM_Voyage;
	minBay,maxBay : Integer;
begin
	aVoyage := self.myVoyage;
	minBay := 9999;
	
	foreach aJob in self.allJobsByOrder do
		aVJob := aJob.CM_VoyageJob;
		aBay := aVoyage.myCellularVoyageStructure.allBayVoyagesById[	aVJob.bayId];
		
		if aBay &lt;&gt; null then
			minBay := minBay.min(aBay.ordinalBay);	
			maxBay := maxBay.max(aBay.ordinalBay);	
		endif;
	endforeach;
	
	return maxBay;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getBayLids" id="5fdecf04-95d3-4230-8b96-4812a068cfc2">
        <source>getBayLids(_bay : CM_BayVoyage) : Integer;
// ---------------------------------------------------------------------------
// Created:		03 April 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	pJob, vJob : CM_VoyageJob;
	numLids : Integer;
	tmpTS : TimeStamp;
	bayOne, bayTwo: CM_Bay;
begin
		foreach vJob in self.allJobsByJobNum discreteLock do
			if vJob.isHatchLidJob() then
				vJob.getBays(bayOne, bayTwo);
				
				if (bayOne = _bay or bayTwo = _bay) then
					numLids := numLids + vJob.CM_VoyageHatchLidJob.allHatchLids.size;
				endif;
			endif;
		endforeach;
		return numLids;
end;</source>
        <Parameter name="_bay" type="CM_BayVoyage"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getBayOrdinals" id="ee7ad18a-e89a-444f-b00b-6696edf0f00b">
        <source>getBayOrdinals(_startBay : Integer output; _endBay : Integer output; _flipH : Boolean);
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aJob : CM_Job;
	aVJob : CM_VoyageJob;
	aBay : CM_Bay;
	structure : CM_CellularVoyageStructure;
	minBay,maxBay : Integer;
begin
	if self.myVoyage &lt;&gt; null then
		structure := self.myVoyage.myCellularVoyageStructure;
	endif;
	if structure = null then
		return;
	endif;
	
	minBay := 9999;
	
	foreach aJob in self.allJobsByOrder do
		aVJob := aJob.CM_VoyageJob;
		aBay := structure.allBayVoyagesById[aVJob.bayId];
		if aBay = null then		//PAR 12644
			aBay := structure.allBayVoyagesById40[aVJob.bayId];
		endif;
		
		if aBay &lt;&gt; null then
			minBay := minBay.min(aBay.ordinalBay);	
			maxBay := maxBay.max(aBay.ordinalBay);	
		endif;
	endforeach;
	
	
	if _flipH then
		_startBay := (structure.allBayVoyagesByOrdinal.size - maxBay + 1);
		_endBay := (structure.allBayVoyagesByOrdinal.size - minBay + 1);
	else
		_startBay := minBay;
		_endBay := maxBay;
	endif;	
end;</source>
        <Parameter name="_startBay" type="Integer" usage="output"/>
        <Parameter name="_endBay" type="Integer" usage="output"/>
        <Parameter name="_flipH" type="Boolean"/>
    </JadeMethod>
