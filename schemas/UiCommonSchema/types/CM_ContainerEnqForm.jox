    <JadeMethod name="initForTrackedItem" id="2130e918-a189-4d4c-b9e1-5d9103bf324e">
        <updating/>
        <source>initForTrackedItem(_ti : CM_TrackedItem) updating, protected;
//--------------------------------------------------------------
//	32673 Oct 2013 cnwjre1	set all internal references required when enquiring directly on a cargo item
//--------------------------------------------------------------
vars

begin

	if _ti = null then
		return;
	endif;

	self.myCurrentCargoBOLType := _ti.myCargoType;
	self.setMyDataClass();
end;</source>
