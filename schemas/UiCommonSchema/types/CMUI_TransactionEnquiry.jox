// ---------------------------------------------------------------------------
// Created:     28 March 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// ---------------------------------------------------------------------------

vars
	fileObj : File;
begin
	create fileObj transient;	
	fileObj.mode := File.Mode_Output; // 1/3/16  cnwns1 PAR 36286 unicode version
	if self.mode = self.Mode_CargoItem_Enquiry then
		self.tblTrans.cnEcExportToCSV(fileObj, true);
	else
		self.tblTransactions.cnEcExportToCSV(fileObj, true);
	endif;
epilog
	delete fileObj;

end;</source>
