    <JadeMethod name="isTransactionToBeProcessed" id="abc4334c-cfa0-400f-bc9e-8d2dd6be6d28">
        <source>isTransactionToBeProcessed(_camProtocol: CM_CamProtocol; _trans: CM_TITransaction; _camAgent: CM_CamControllerAgent): Boolean;
/*

Date		Who		Reason
15 February 2016	cnwer1	Initial creation PAR 37551

*/

vars

begin
	if not inheritMethod(_camProtocol, _trans, _camAgent)then
		return false;
	endif;
	//epr TFS 1429 15/2/16 
	if _trans.isKindOf(CM_Weighed) then
		if not _camProtocol.useVGM then
			if _camAgent &lt;&gt; null and
				_camAgent.logExcludedTransactions then
				_camAgent.logReasonForExclusion(_trans, "Weighed Transaction not included for protocols that do not use VGM");
			endif;
			return false;
		endif;
		
		if not _trans.CM_Weighed.isWeightCertified then
			if _camAgent &lt;&gt; null and
				_camAgent.logExcludedTransactions then
				_camAgent.logReasonForExclusion(_trans, "Weighed Transaction is not a Certified Weight");
			endif;
			return false;
		endif;
		
		if  _trans.isEmpty then
			if _camAgent &lt;&gt; null and
				_camAgent.logExcludedTransactions then
				_camAgent.logReasonForExclusion(_trans, "Weighed Transaction is for MT container");
			endif;
			return false;
		endif;
	endif;

	return true;
epilog

end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_trans" type="CM_TITransaction"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="makeLOC7Segment" id="ad11f124-6b52-44dc-854b-0e45f732f2f6">
        <source>makeLOC7Segment(_protocol : CM_CamProtocol; _group :HugeStringArray input; _code, _qual1, _qual2, _relQual1, _relQual2 : String; _ti : CM_TrackedItem; _release : Boolean) : String protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 03/02/2021	jlgdap1		Initial creation TFS 50726 GPHA CODECO Message to Differentiate Between Inter-Terminal Transfer and Delivery
//
constants
	MESSAGE	= "LOC";
	LOCTYPE = "7";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;

begin
	if _code = null then	// 13/09/2012 cnwar2 #30322
		return null;
	endif;

	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; plus &amp; 
		LOCTYPE &amp; plus &amp; 
		_code &amp; colon &amp;			// "our port" code
		_qual1 &amp; colon &amp; 		// "139"
		_qual2 &amp; plus;			// "6"
	
	// If this is an inter-terminal release, message is sending terminal and then receiving terminal
	if _release then
		msg := msg &amp; _ti.myTerminal.code &amp; colon &amp; _relQual1 &amp; colon &amp; _relQual2 &amp; plus &amp; 
					_ti.myMoveCloneToTI.myTerminal.code &amp; colon &amp; _relQual1 &amp; colon &amp; _relQual2;
	// if this is an inter-terminal receival, message is receiving terminal and then sending terminal
	else
		msg := msg &amp; _ti.myTerminal.code &amp; colon &amp; _relQual1 &amp; colon &amp; _relQual2 &amp; plus &amp; 
					_ti.myMoveCloneFromTI.myTerminal.code &amp; colon &amp; _relQual1 &amp; colon &amp; _relQual2;
	endif;
	
	if _group &lt;&gt; null then
		_group.add(msg);
	endif;
	
	msg := msg &amp; singleQuote;
	return msg;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_qual1" type="String"/>
        <Parameter name="_qual2" type="String"/>
        <Parameter name="_relQual1" type="String"/>
        <Parameter name="_relQual2" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_release" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageDAM" id="58a52ad3-9c34-42ef-a712-dcd0bef221c3">
        <source>makeMessageDAM(_camProtocol :CM_CamProtocol; _group :HugeStringArray input; _ti :CM_TrackedItem) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2019	cnwma1	Bug 44797: SNO - Testing reference 7813

*/

vars
	isProduceDAMSeg : Boolean;
	damCode,
	damDesc         : String;
	damageInstance  : CM_DamageInstance;
begin
	
	isProduceDAMSeg := _camProtocol.getProduceDAMSegment();
	
	if not isProduceDAMSeg then
		return;
	endif;
	
	foreach damageInstance in _ti.allDamageInstancesByPos discreteLock do
		//damDesc := "DAMAGED " &amp; damageInstance.description[1:70];
		damDesc := damageInstance.getDescriptionForCamsDAM;	//26 Aug 2019	NDL	TFS 46286
		damCode := damageInstance.getDamageCode;
		
		//DAM
		self.makeDAMSegment(_camProtocol, _group, '1', damCode, null, null, damDesc);
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="makeMessageDTM_VGM" id="13c5d26e-316c-4ed6-b937-36e18b468476">
        <source>makeMessageDTM_VGM(_protocol: CM_CamProtocol; _group: HugeStringArray input; _ti: CM_TrackedItem): String protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/08/2017	jlgdap1		Initial creation TFS 6691 Don't include 137 DTM in CODECO
//
vars
	msg : String;

begin
	if _ti.isKindOf(CM_Container) and _ti.CM_Container.myVGMDetails &lt;&gt; null then
		if _ti.CM_Container.myVGMDetails.vgmDeterminationDT &lt;&gt; null then
			msg := self.makeDTM_VGMSegment(_protocol, _group, "798", _ti.CM_Container.myVGMDetails.vgmDeterminationDT);
		endif;
	endif;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
