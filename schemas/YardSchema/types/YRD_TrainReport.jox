    <JadeMethod name="translateForm" id="fff62cc0-5445-41a0-8faa-e25d5e1659d6">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0012698, locale);
	chkPrintCargo.translateCaption(Xlat_0012699, locale);
	chkPrintCargoCON.translateCaption(Xlat_0012700, locale);
	chkPrintCargoOP.translateCaption(Xlat_0012701, locale);
	chkPrintCargoWAG.translateCaption(Xlat_0012702, locale);
	chkPrintManifest.translateCaption(Xlat_0014704, locale);
	chkPrintPM.translateCaption(Xlat_0014705, locale);
	chkPrintPreview.translateCaption(Xlat_0012704, locale);
	chkPrintStats.translateCaption(Xlat_0012705, locale);
	chkPrintTrains.translateCaption(Xlat_0014706, locale);
	chkPrintTrans.translateCaption(Xlat_0012706, locale);
	chkPrintWagons.translateCaption(Xlat_0012707, locale);
	chkPrintWarnings.translateBubbleHelp(Xlat_0014707, locale);
	chkPrintWarnings.translateCaption(Xlat_0014708, locale);
	grpReport.translateCaption(Xlat_0012708, locale);
	lblPrintName.translateCaption(Xlat_0012709, locale);
	lblTrainName.translateCaption(Xlat_0012710, locale);
	optAll.translateCaption(Xlat_0014709, locale);
	optCInwards.translateCaption(Xlat_0012711, locale);
	optCOutwards.translateCaption(Xlat_0012712, locale);
	optMInwards.translateCaption(Xlat_0012713, locale);
	optMOutwards.translateCaption(Xlat_0012714, locale);
	optPMIn.translateCaption(Xlat_0013850, locale);
	optPMOut.translateCaption(Xlat_0013851, locale);
end;</source>
    </JadeMethod>
