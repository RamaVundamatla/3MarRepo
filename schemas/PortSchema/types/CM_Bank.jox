    <JadeMethod name="getServicePayTypeMapping" id="e12ccd73-e443-4218-9383-7bf6bf0a6604">
        <source>getServicePayTypeMapping( _service : CM_Service; _dr : CM_Debtor; _tryDefaultDr : Boolean ):CM_ServicePayTypeMapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2018	jlgndl1	Initial creation	TFS 41281
24 Oct 2018	NDL	TFS 41281

*/

vars

	servicePayTypeMapping : CM_ServicePayTypeMapping;
	defaultDebtor  : CM_Debtor;

begin

	servicePayTypeMapping :=  self.allServicePayTypeMappings.getAtKey( _service, _dr );
	
	//Now have the concept of a value for the default debtor too
	if servicePayTypeMapping = null and _tryDefaultDr then
		defaultDebtor := app.myRoot.getDefaultDebtor(null);
		if defaultDebtor &lt;&gt; null and _dr &lt;&gt; defaultDebtor then
			servicePayTypeMapping := self.allServicePayTypeMappings.getAtKey( _service, defaultDebtor );
		endif;
	endif;
	
	return servicePayTypeMapping;

epilog

end;</source>
        <Parameter name="_service" type="CM_Service"/>
        <Parameter name="_dr" type="CM_Debtor"/>
        <Parameter name="_tryDefaultDr" type="Boolean"/>
        <ReturnType type="CM_ServicePayTypeMapping"/>
    </JadeMethod>
    <JadeMethod name="getSignOffUser" id="c1bc58e7-e996-4351-b6ed-79f8dbd1625e">
        <source>getSignOffUser( _asAtDateTime : TimeStamp ):CM_InvoiceSignoffUser;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2018	jlgndl1	Initial creation	TFS 38535

*/

vars

	ts : TimeStamp;
	signoff : CM_InvoiceSignoffUser;

begin

	if self.allInvoiveSignoffUsers.isEmpty then
		return null;
	endif;
	
	if _asAtDateTime = null or not _asAtDateTime.date.isValid then
		ts := app.actualTimeAppServer;
	else
		ts := _asAtDateTime;
	endif;
	
	signoff := self.allInvoiveSignoffUsers.getAtKeyLeq( ts );
	
	return signoff;

epilog

end;</source>
        <Parameter name="_asAtDateTime" type="TimeStamp"/>
        <ReturnType type="CM_InvoiceSignoffUser"/>
    </JadeMethod>
    <JadeMethod name="getStateData" id="87953378-4984-4fcf-a5dd-e756f1892a61">
        <source>getStateData( pKey : String) : Any protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2019	jlgndl1	Initial creation	TFS 40010

*/

vars

