<Class name="CM_LogRegradeCode" id="f11ccc22-8ed2-4045-a297-1e9197e58698">
    <superclass name="CM_Code"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <ExplicitInverseRef name="myRoot" id="87568e08-4df3-4451-8ee0-fb63c5ac8afa">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Root"/>
        <access>readonly</access>
        <Inverse name="CM_Root::allLogRegradeCodes"/>
    </ExplicitInverseRef>
    <JadeMethod name="create" id="50d01aa6-677b-47cd-9dfc-41c541581ec9">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     21 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.isCodeGroupNOTRequired := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="8117be5f-981a-4309-88c8-8635fc3bd2fe">
        <updating/>
        <source>setForCreate(pProxy: CM_LogRegradeCode) updating;
// ---------------------------------------------------------------------------
// Created:     21 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod(pProxy);
	self.myRoot := app.myRoot;

end;</source>
        <Parameter name="pProxy" type="CM_LogRegradeCode"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="123d0efb-3e16-4807-9663-b00cf2dcb4c4">
        <updating/>
        <source>setProxy(pCode, pDescription : String;_notAvailableForEntry:Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     21 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.setSuperClassDetailsForProxy(pCode, pDescription,_notAvailableForEntry,null);
	self.myRoot := app.myRoot;

end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="3707c283-3a8a-4ea0-b259-26da6778d5e8">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     21 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if app.myRoot.allLogRegradeCodes.includesKey(self.code) &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;
	inheritMethod();


end;</source>
    </JadeMethod>
</Class>
