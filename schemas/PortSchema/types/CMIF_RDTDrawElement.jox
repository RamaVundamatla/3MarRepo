    <JadeMethod name="gridPointsToElementPoints" id="eac9826d-df43-49fa-af7d-1cad7cef9525">
        <source>gridPointsToElementPoints(_x1, _y1, _x2, _y2 : Real io; _scalFactor : Real;  _isLandScape, _flipH, _flipV : Boolean);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwjk3	Initial creation

*/

vars
	tx, ty,
	xOffsetPixels,
	yOffsetPixels,
	widthPixels,
	lengthPixels	: Real;
begin
	xOffsetPixels := self.getSizeInPixels(self.leftGridOffsetFt, _scalFactor);
	yOffsetPixels := self.getSizeInPixels(self.topGridOffsetFt, _scalFactor);
	
	if _isLandScape then
		widthPixels := self.getSizeInPixels(self.heightFt, _scalFactor);
		lengthPixels := self.getSizeInPixels(self.widthFt, _scalFactor);	
		
		// New
		tx := xOffsetPixels;
		xOffsetPixels := yOffsetPixels;
		yOffsetPixels := tx;
		//
	else
		widthPixels := self.getSizeInPixels(self.widthFt, _scalFactor);
		lengthPixels := self.getSizeInPixels(self.heightFt, _scalFactor);		
	endif;
	
	if _flipH then 
		_x1 := _x2 - xOffsetPixels;
		_x2 := _x1 - widthPixels;
	else
		_x1 := _x1 + xOffsetPixels;
		_x2 := _x1 + widthPixels;		
	endif;
	
	if _flipV then
		_y1 := _y2 - yOffsetPixels;
		_y2 := _y1 - lengthPixels;
	else
		_y1 := _y1 + yOffsetPixels;
		_y2 := _y1 + lengthPixels;
	endif;
	
	// This makes things easier later on...
	if _x1 &gt; _x2 then
		tx := _x1;
		_x1 := _x2;
		_x2 := tx;
	endif;
	if _y1 &gt; _y2 then
		ty := _y1;
		_y1 := _y2;
		_y2 := ty;
	endif;

epilog

end;</source>
        <Parameter name="_x1" type="Real" usage="io"/>
        <Parameter name="_y1" type="Real" usage="io"/>
        <Parameter name="_x2" type="Real" usage="io"/>
        <Parameter name="_y2" type="Real" usage="io"/>
        <Parameter name="_scalFactor" type="Real"/>
        <Parameter name="_isLandScape" type="Boolean"/>
        <Parameter name="_flipH" type="Boolean"/>
        <Parameter name="_flipV" type="Boolean"/>
    </JadeMethod>
