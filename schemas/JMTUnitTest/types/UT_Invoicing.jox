    <JadeMethod name="cargoFreightTonnage" id="408ee7dc-dbee-4283-8ec5-24c0514db51e">
        <source>cargoFreightTonnage(_testType : Integer) protected;
// cnwjre1	test 29499 CCMS QNS 2177
// _testType parameter is: 1 = lowest, 2 = lowest + default, 3 = highest, 4 = highest + default, anything else is All
vars
	calcType	: CM_CalculationType;
	service		: CM_Service;
	ild			: CM_InvoiceLineDesc;
	invType		: CM_InvoiceDesc;
	services	: CM_ServiceByNameDict;
	allServices	: CM_ServiceByNameDict;
	operator	: CM_Operator;
	debtor : CM_DebtorNode;
	ti: CM_TrackedItem;
	selectedTypes: CM_CargoBOLTypeSet;
	stopsTable: CM_StopsTable;
	processAreas: IntegerArray;
	opts : CM_AssociationDict;
	trans : CM_TransactionSet;
	tran : CM_TITransaction;

begin


	// delete any old objects
	self.deleteContainer("TEST0000901");
	self.deleteStopsTable(99);
	self.deleteInvoiceService("UT_CFTService1", FORCED_ERASE);
	self.deleteInvoiceService("UT_CFTService2", FORCED_ERASE);
	self.deleteInvoiceService("UT_CFTService3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_CFTInvLineType1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_CFTInvLineType2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_CFTInvLineType3", FORCED_ERASE);
	
	// create new instances
	create services transient;
	create allServices transient;
	invType := self.getInvoiceType("UT_InvType");
	self.assertNotNullMsg(invType, "Invoice type UT_InvType not created");

	// three services and invoice line descs, for calc type of Quantity, Weight and Weight (tonnes)
	calcType := app.myRoot.allCalculationTypesByCode['CCT01'];		// Units (Qty)
	self.assertNotNullMsg(calcType, "Calculation type CCT01 not found");

	service := self.createInvoiceService("UT_CFTService1", "CFT Qty", calcType, null);
	self.assertNoTrxErrorsOrWarnings();
	allServices.add(service);
	
	services.add(service);
	ild := self.createInvoiceLineType("UT_CFTInvLineType1", calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	calcType := app.myRoot.allCalculationTypesByCode['CCT04'];		// Weight (kilos)
	self.assertNotNullMsg(calcType, "Calculation type CCT04 not found");

	service := self.createInvoiceService("UT_CFTService2", "CFT Qty", calcType, null);
	self.assertNoTrxErrorsOrWarnings();
	allServices.add(service);
	
	services.clear();
	services.add(service);
	ild := self.createInvoiceLineType("UT_CFTInvLineType2", calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	calcType := app.myRoot.allCalculationTypesByCode['CCT08'];		// Weight (tonnes)
	self.assertNotNullMsg(calcType, "Calculation type CCT08 not found");

	service := self.createInvoiceService("UT_CFTService3", "CFT Qty", calcType, null);
	self.assertNoTrxErrorsOrWarnings();
	allServices.add(service);
	
	services.clear();
	services.add(service);
	ild := self.createInvoiceLineType("UT_CFTInvLineType3", calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	self.tranMapLoadCFT(_testType);

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	
	debtor := operator.debtor;
	// set rates such that a known invoice line value is the lowest or highest 
	self.cargoTonnageRates1(_testType, allServices);

	// create a container
	ti := self.addContainerOpts("TEST0000901", "22G1", "GENL", operator);	
	create selectedTypes transient;
	selectedTypes.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	create processAreas transient;
	processAreas.add(StopProcessCopyToChild);
	create opts transient;
	opts.addAssoc(ETRow_ProcessStopAreas, processAreas);
	stopsTable := addStopsTable(99, "UT", "Unit Test", selectedTypes, opts);

	self.addStop(ti, stopsTable);

	foreach tran in ti.allTransactions do
		if tran.isKindOf(CM_StopAdd) and
		   tran.CM_StopAdd.stopID = 99 then
			self.validateCargoFreightTonnage(tran, _testType, 1);
			break;
		endif;
	endforeach;
	
	// change rates such that a known but different invoice line value is now the lowest or highest 
	self.cargoTonnageRates2(_testType, allServices);

	create trans transient;
	foreach tran in ti.allTransactions discreteLock where tran.isKindOf(CM_StopAdd) do
		trans.add(tran);
	endforeach;

	self.updateInvoiceReevaluate(trans, ti, null);

	foreach tran in ti.allTransactions do
		if tran.isKindOf(CM_StopAdd) and
		   tran.CM_StopAdd.stopID = 99 then
			self.validateCargoFreightTonnage2(tran, _testType, 2);
			break;
		endif;
	endforeach;

epilog
	self.resetDefaultTranMap();
	// delete this tran map so following tests can delete the invoice line descs etc
	self.deleteInvoiceTransactionMap(1, 'UT_CFT');
	
	delete services;
	delete allServices;
	delete selectedTypes;
	delete processAreas;
	delete opts;
	delete trans;
	
end;</source>
        <access>protected</access>
        <Parameter name="_testType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cargoFreightTonnageEscalating" id="3421bbf9-4cc8-4dba-90b9-57dfb85f7fe2">
        <source>cargoFreightTonnageEscalating() protected;
// cnwjre1	test 35365 escalating charging with weight/volume convert calculation type
//
// 07 May 2019	jlgrs1	TFS44650 STWO Invoice line incorrectly charged as NORMAL hours where OVERTIME is expected
//02/10/2025	navkc1 JIRA 36149 AAT | RotaBox ISO Type and New Attributes - Calculation Type
//
vars
	count		: Integer;
	tiId		: String;
	dateTime	: TimeStamp;
	now			: Date;
	backDate	: Date;
	calcType1,
	calcType2	: CM_CalculationType;
	mesType1,
	mesType2	: CM_MeasurementType;
	service		: CM_Service;
	ild			: CM_InvoiceLineDesc;
	invType		: CM_InvoiceDesc;
	services	: CM_ServiceByNameDict;
	allServices	: CM_ServiceByNameDict;
	operator	: CM_Operator;
	ti			: CM_TrackedItem;
	tran		: CM_TITransaction;
	invLine		: CM_InvoiceLine;
	transients	: ObjectArray;

begin

	tiId := "TEST0000902";
	// delete any old objects
	self.deleteContainer(tiId);

	self.deleteInvoiceService("UT_CFTService1", FORCED_ERASE);
	self.deleteInvoiceService("UT_CFTService2", FORCED_ERASE);
	self.deleteInvoiceService("UT_CFTService3", FORCED_ERASE);
	self.deleteInvoiceService("UT_CFTService4", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_CFTInvLineType1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_CFTInvLineType2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_CFTInvLineType3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_CFTInvLineType4", FORCED_ERASE);
	
	create transients transient;
	// create new instances
	create services transient;
	create allServices transient;
	invType := self.getInvoiceType("UT_InvType");
	self.assertNotNullMsg(invType, "Invoice type UT_InvType not created");

	self.deleteCalculationType("UTCARGOVOLC", NORMAL_ERASE);
	self.deleteCalculationType("UTCARGOWEIGHTC", NORMAL_ERASE);
	self.deleteMeasurementType("UTWeightC");
	self.deleteMeasurementType("UTVolumeC");

	// measurement type conversion rate is 1 - it is needed for this type of calculation type but we're not testing conversion rates as such
	mesType1 := self.createMeasurementType(1.0, 6.3, false, false, false, false, "UTWeightC", Type_Weight, "UT Weight Units C");
	self.assertNotNullMsg(mesType1, "Measurement type UTWeightC not created");
	mesType2 := self.createMeasurementType(1.0, 6.3, false, false, false, false, "UTVolumeC", Type_Volume, "UT Volume Units C");
	self.assertNotNullMsg(mesType2, "Measurement type UTVolumeC not created");
	calcType1 := self.addCalculationTypeFull(INV_CALC_TYPE_CARGOVOLUMECONVT, 'UTCARGOVOLC', 'UNIT TEST Cargo Volume Convert', null, null, null, 0, 0, 0, 0, true, false, false, false, INV_CALC_TYPE_DAYS_SINCE_RECVL, mesType2, null, null, null);
	calcType2 := self.addCalculationTypeFull(INV_CALC_TYPE_CARGOWEIGHTCONVT, 'UTCARGOWEIGHTC', 'UNIT TEST Cargo Weight Convert', null, null, null, 0,0,0,0, true, false, false, false, INV_CALC_TYPE_DAYS_SINCE_RECVL, mesType1, null, null, null);

	service := self.createInvoiceService("UT_CFTService1", "CFT Volume Normal", calcType1, null);
	self.assertNoTrxErrorsOrWarnings();
	allServices.add(service);
	
	services.add(service);
	ild := self.createInvoiceLineType("UT_CFTInvLineType1", calcType1, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	service := self.createInvoiceService("UT_CFTService2", "CFT Weight Normal", calcType2, null);
	self.assertNoTrxErrorsOrWarnings();
	allServices.add(service);
	
	services.clear();
	services.add(service);
	ild := self.createInvoiceLineType("UT_CFTInvLineType2", calcType2, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	service := self.createInvoiceService("UT_CFTService3", "CFT Volume Double", calcType1, null);
	self.assertNoTrxErrorsOrWarnings();
	allServices.add(service);
	
	services.clear();
	services.add(service);
	ild := self.createInvoiceLineType("UT_CFTInvLineType3", calcType1, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	service := self.createInvoiceService("UT_CFTService4", "CFT Weight Double", calcType2, null);
	self.assertNoTrxErrorsOrWarnings();
	allServices.add(service);
	
	services.clear();
	services.add(service);
	ild := self.createInvoiceLineType("UT_CFTInvLineType4", calcType2, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();

	self.tranMapLoadCFTEscalating();

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	
	// set rates such that a known invoice line value is the lowest or highest 
	self.cargoTonnageRatesEsc(allServices);

	// create a container and back-date it 28 days
	ti := self.addContainerOpts(tiId, "22G1", "GENL", operator);
	backDate := now - 28;
	dateTime.setDate(backDate);
	self.resetTransactionDate(ti, dateTime);
	self.createDatedTransaction(ti, dateTime, TRANS_TYPE_REC_SHIP);

	// create storage now
	dateTime.setDate(now);
	tran := self.createDatedTransaction(ti, dateTime, TRANS_TYPE_STORAGE);
	// 2 invoice lines, quantity 40000 ILD UT_CFTInvLineType2 and qty 32000 ILD UT_CFTInvLineType4
	// The total days is 28 with 10 free, 10 in the single rate period and the remaining 8 in the double period
	foreach invLine in tran.allInvoiceLines do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(invLine.quantity, 40000.Real, "First Storage transaction invoice quantity");		// weight 4000 times 10 days
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_CFTInvLineType2", "First Storage transaction invoice line type");
		elseif count = 2 then
			self.assertEqualMsg(invLine.quantity, 32000.Real, "Second Storage transaction invoice quantity");	// weight 4000 times 8 days
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_CFTInvLineType4", "Second Storage transaction invoice line type");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, "Storage transaction invoice lines");
	
epilog
	self.resetDefaultTranMap();
	// delete this tran map so following tests can delete the invoice line descs etc
	self.deleteInvoiceTransactionMap(1, 'UT_CFT2');
	
	delete services;
	delete allServices;
	if transients &lt;&gt; null then
		transients.purge();
		delete transients;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cargoGPHAInterfaceRates" id="0d32afd6-5155-4672-956f-fd41042046b8">
        <source>cargoGPHAInterfaceRates(_services : CM_ServiceByNameDict) protected;
// set the initial rates
vars
	lineCount	: Integer;
	service		: CM_Service;
	operator	: CM_Operator;
	start,
	expiry : TimeStamp;
	ignoreEntry : Boolean;
	costValue	: Decimal[8,4]; //19/05/2025	navkc1 JIRA EPIC-34131 STORY-34818
	costs : DecimalArray;
	debtor : CM_DebtorNode;
	debtorRate : CM_DebtorRate;
	rateEntry : CM_RateEntry;
	transients	: ObjectArray;

begin
	create transients transient;

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	
	debtor := operator.debtor;
	// set rates such that a known invoice line value is the lowest or highest 
	create costs transient;
	foreach service in _services do
		lineCount := lineCount + 1;
		costs.clear();
		costValue := 1.0;	// default value
		if lineCount = 1 then
			costValue := 0.084;		
		elseif lineCount = 2 then
			costValue := 0.10;		
		elseif lineCount = 3 then
			costValue := 110.0;		
		endif;

		costs.add(costValue);
		start.setDate("31/01/2010".Date);
		start.setTime("00:00".Time);
		expiry := null;
		debtorRate := debtor.serviceRates[service];
		if debtorRate = null then
			create debtorRate transient;
			debtorRate.setProxy(service, debtor);
			rateEntry := self.addInvoiceRateEntry(debtorRate, start, expiry, ignoreEntry, costs, 0, 0, null, null);
			transients.add(debtorRate);
		else
			rateEntry := debtorRate.rateEntries.first;
			self.updateInvoiceRateEntry(debtorRate, rateEntry, start, expiry, ignoreEntry, costs, 0, 0, null,null);
		endif;
		self.assertNoTrxErrorsOrWarnings();
	endforeach;


epilog

	if transients &lt;&gt; null then
		transients.purge();
		delete transients;
	endif;
	delete costs;
end;</source>
