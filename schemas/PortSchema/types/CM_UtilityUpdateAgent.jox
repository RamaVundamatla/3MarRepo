    <JadeMethod name="utlUpdateBGPReqPrinterName" id="5db22306-18fa-457c-9cf2-2ee1f8b6258a">
        <source>utlUpdateBGPReqPrinterName(_realRequest : BGP_ReportRequest input; _printerName : String; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 November 2017	jlgmd1	Initial creation TFS 7140 DPH - message box in bgp process

*/

vars
		
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	
	if _realRequest = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, BGP_ReportRequest.name, null, null);
		return;
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(_realRequest);

	if _passport.hasErrors then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, BGP_ReportRequest.name, null, null);
		return;
	endif;
	
	
	self.myUpdateAuditAgent.audUpdateGeneric(_realRequest, true);
	
	
	if _passport.noErrors then
		_realRequest.setPrinterName(_printerName);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_realRequest, false);
	endif;

epilog

end;</source>
        <Parameter name="_realRequest" type="BGP_ReportRequest" usage="input"/>
        <Parameter name="_printerName" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
