    <JadeMethod name="aUtlSample" id="9e600a6d-78ad-43ac-97c7-5a372ce7b3eb">
        <updating/>
        <source>aUtlSample(_pxyObject : CM_TrxTestObject; 
		_controller : CM_TrxTestController;
		_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     11 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realObject		: CM_TrxTestObject;
	expectedEdition	: Integer;

begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_pxyObject, 'Test Object');

	app.setContinueCMExceptions(true);
	
	app.myValUA.aValSample(_pxyObject, _controller);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	realObject := self.getRealObjectAndEditionCheck(_pxyObject, 'Test Object', _passport).CM_TrxTestObject;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, true);
	endif;

	if _passport.noErrors then
		// do updates
		realObject.setForUpdate(_pxyObject, _controller);
	endif;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, false);
	endif;

end;</source>
        <Parameter name="_pxyObject" type="CM_TrxTestObject"/>
        <Parameter name="_controller" type="CM_TrxTestController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="6f1fba7e-7a29-43b0-ae1d-f044e8c8703c">
