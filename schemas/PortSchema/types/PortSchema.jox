    <JadeMethod name="getCalcRateTypeStr" id="7eca0ebc-d67c-4b75-a471-c906664db669">
        <source>getCalcRateTypeStr( _int : Integer ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/03/2019	jlgndl1	Initial creation	TFS 43687
28/03/2019	jlgdap1	TFS 43694 PEL1 Charging for Vessels that use a Ramp
*/

vars

begin

	if _int = CM_CalculationType.RateTypeSingle then
		return CM_CalculationType.RateTypeSingleStr;
		
	elseif _int = CM_CalculationType.RateTypeHMSMovementType then
		return CM_CalculationType.RateTypeHMSMovementTypeStr;
		
	elseif _int = CM_CalculationType.RateTypeRamp then				// TFS 43694
		return CM_CalculationType.RateTypeRampStr;					// TFS 43694
		
	else
		return null;
	
	endif;

epilog

end;</source>
