    <JadeMethod name="setProxyFromObject" id="6a3d9028-566d-46df-9c68-ead54f9efdba">
        <updating/>
        <source>setProxyFromObject(_object: CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Sep 2017	jlghl1	Initial creation
13 May 2019	JLGNS1	ChangeRequest 44254: JMT Vehicle App - Graphical View Webservice
07 Apr 2021 cnwma1  Bug 50945: SNO - Vehicle App graphical view in TOP mode
*/

vars
	isoCode 		: String;
	isoType 		: CM_ISOType;
	invalidObject	: Boolean;
	isTIPlanned     : Boolean;
begin
	inheritMethod(_object);
	
	self.id := _object.id;
	isoCode := _object.getISOType;
	
	if isoCode &lt;&gt; null then
		isoType:= app.myRoot.allISOTypes[isoCode];
		if isoType &lt;&gt; null then
			if isoType.is20ftLong then
				self.isoType := 0;
			elseif isoType.is30ftLong then
				self.isoType := 1;
			elseif isoType.is40ftLong then
				self.isoType := 2;			
			elseif isoType.is45ftLong then
				self.isoType := 3;			
			elseif isoType.is53ftLong then
				self.isoType := 4;			
			endif;
		endif;
	endif;
	
	self.weight := _object.getConvertedTotalWeightIn("MT");
	
	if _object.myOperator &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, _object.myOperator, invalidObject);	
		self.operatorColour := _object.myOperator.colour.cnEcGetHexColor.String;
	endif;	

	// 07.04.2021 cnwma1 #50945
	isTIPlanned := _object.isPlanned(PLANNING_MODE);
	if _object.isQueued and isTIPlanned then
		self.moveType := 'PQ';
	elseif _object.isQueued then
		self.moveType := 'Q';
	elseif isTIPlanned then
		self.moveType := 'P';
	else
		self.moveType := '';
	endif;
	// 07.04.2021 cnwma1 #50945
epilog

end;</source>
        <Parameter name="_object" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
