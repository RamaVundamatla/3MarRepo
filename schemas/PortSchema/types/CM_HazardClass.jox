    <JadeMethod name="validateMe" id="4a777e61-963b-4965-b719-c035e2d41f8d">
        <source>validateMe() protected;

vars

begin
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'HazardClass Code', null, null);
		app.raiseCMException(Input_required_field_hazClsCde, null, null); // cnwdb2	PAR 35364


	endif;
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'HazardClass Description', null, null);
		app.raiseCMException(Input_required_field_hazClsDes, null, null); // cnwdb2	PAR 35364
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
