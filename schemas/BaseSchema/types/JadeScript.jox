    <JadeMethod name="cnwdad1_Test_File_Attributes" id="64dec20e-63ce-4976-8442-32d1fbae7cfc">
        <source>cnwdad1_Test_File_Attributes();
// -----------------------------------------------------------------------------
// Created:		18 January 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	folderObj	: FileFolder;
	fileObj		: File;
	attributes	: String;
	startTime	: Integer;
	
begin
	startTime	:=	app.clock();
	
	create folderObj transient;
	create fileObj transient;
	
	folderObj.fileName	:=	"c:\temp";
	
	if folderObj.isAvailable() then
		if folderObj.isValidPathName(folderObj.fileName) then
			attributes			:=	folderObj.cnEcGetAttributes();
			write "Attributes of " &amp; folderObj.fileName &amp; ": " &amp; attributes;
		else
			write folderObj.fileName &amp; " is not a valid path name.";
		endif;
	else
		write folderObj.fileName &amp; " is not available.";
	endif;
	
	fileObj.fileName	:=	"c:\temp\jade.log";
	
	if fileObj.isAvailable() then
		attributes			:=	fileObj.cnEcGetAttributes();
		write "Attributes of " &amp; fileObj.fileName &amp; ": " &amp; attributes;
	else
		write fileObj.fileName &amp; " is not available.";
	endif;
epilog
	delete folderObj;
	delete fileObj;
	
	write "File attributes completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_FindFileExact" id="ae24d1e2-9ec2-459b-8129-a084cd6887b2">
        <source>cnwdad1_Test_FindFileExact();
// -----------------------------------------------------------------------------
// Created:		21 January 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
constants
//	FILE_NODE_NAME	: String = "jade.ini";
//	FILE_PATH_NAME	: String = "d:\jade\system";
	FILE_NODE_NAME	: String = "Apps.hlp";
	FILE_PATH_NAME	: String = "c:\winnt";
	
vars
	folderSearchObj	: CnEcFolderSearch;
	allFileNodes	: FileNodeArray;
	theFileNode		: FileNode;
	startTime		: Integer;
	
begin
	startTime	:=	app.clock();
	
	create allFileNodes transient;
	create folderSearchObj transient;
	
	// Set the search criteria.
	
	folderSearchObj.fileName	:=	FILE_PATH_NAME;
	folderSearchObj.setSearchCriteria(FILE_NODE_NAME, false, false, true, false);
	
	// Initiate the search and show the results.
	
	if folderSearchObj.doSearch(allFileNodes) then
		write "Files Found:" &amp; CrLf &amp; "------------";
		
		foreach theFileNode in allFileNodes do
			write theFileNode.fileName;
		endforeach;
	else
		write FILE_NODE_NAME &amp; " not found.";
	endif;
epilog
	delete allFileNodes;
	delete folderSearchObj;
	
	write "Search completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_FindFileWildcard" id="7ad1da57-e2ae-43cf-8666-a9eacf84a0b2">
        <source>cnwdad1_Test_FindFileWildcard();
// -----------------------------------------------------------------------------
// Created:		22 January 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
constants
//	FILE_NODE_NAME	: String = "*.ini";
	FILE_NODE_NAME	: String = "win*.ini";
	FILE_PATH_NAME	: String = "c:\winnt";
	
//	FILE_NODE_NAME	: String = "jad*.*";
//	FILE_NODE_NAME	: String = "jadnet?.wav";
//	FILE_PATH_NAME	: String = "d:\jade\bin";
	
vars
	folderSearchObj	: CnEcFolderSearch;
	allFileNodes	: FileNodeArray;
	fileNodeObj		: FileNode;
	startTime		: Integer;
	
begin
	startTime	:=	app.clock();
	
	create allFileNodes transient;
	create folderSearchObj transient;
	
	// Set the search criteria.
	
	folderSearchObj.fileName	:=	FILE_PATH_NAME;
	folderSearchObj.setSearchCriteria(FILE_NODE_NAME, true, false, false, false);
	
	// Initiate the search and show the results.
	
	if folderSearchObj.doSearch(allFileNodes) then
		write "Files Found:" &amp; CrLf &amp; "------------";
		
		foreach fileNodeObj in allFileNodes do
			write fileNodeObj.fileName;
		endforeach;
	else
		write FILE_NODE_NAME &amp; " not found.";
	endif;
epilog
	delete allFileNodes;
	delete folderSearchObj;
	
	write "Search completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_FindTranslatable" id="84bc2fff-3552-4619-aacc-f2128899101c">
        <source>cnwdad1_Test_FindTranslatable();
// --------------------------------------------------------------------------------
// Created:		13 August 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allStringNames	: StringArray;
	stringName		: String;
	startTime		: Integer;
	
begin
	startTime	:=	app.clock();
	create allStringNames transient;
	
	global.cnEcFindTranslatableString(false, allStringNames);
	
	foreach stringName in allStringNames do
		write stringName;
	endforeach;
epilog
	delete allStringNames;
	
	write "Translatable string search completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_FreeDiskAndMemory" id="79114fba-5b66-4982-a08e-8d28187da950">
        <source>cnwdad1_Test_FreeDiskAndMemory();
// --------------------------------------------------------------------------------
// Created:		27 November 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	freeMemory	: Integer;
	freeDisk	: Decimal[23];
	driveName	: String;
	startTime	: Integer;
	
begin
	startTime	:=	app.clock();
	
	write "Client";
	write "======";
	system.cnEcGetDiskAndMemory(freeMemory, freeDisk, driveName);
	write "Free memory: " &amp; freeMemory.cnEcNumberFormat();
	write "Free disk: " &amp; freeDisk.cnEcNumberFormat();
	write "Drive name: " &amp; driveName;
	
	write "Server";
	write "======";
	system.cnEcGetDiskAndMemoryServer(freeMemory, freeDisk, driveName);
	write "Free memory: " &amp; freeMemory.cnEcNumberFormat();
	write "Free disk: " &amp; freeDisk.cnEcNumberFormat();
	write "Drive name: " &amp; driveName;
epilog
	write "Disk and Memory completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
