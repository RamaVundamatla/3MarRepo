    <JadeMethod name="filterObjects" id="60c494c2-a1b7-4339-bec1-ee6341457a2d">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theTI 			: CM_TrackedItem;
	theTermArea 	: CM_TerminalArea;
	theLocation 	: CM_LocationsController;
	aTaskDesc 		: CM_ToDoTaskDesc;
	aTask 			: CM_ToDoTask;
	aOK 			: Boolean;
	loadStateSet 	: Boolean;
	theDischargePort : CM_Port;
	terminal		: CM_Terminal;
	breakOut		: Boolean;
	querySelf		: CMQF_TrainLoadListTIs;
	train			: CM_Train;
	voyage : CM_Voyage;	//03 Nov 2009	NDL	Par 21519
	iter : Iterator;	//03 Nov 2009	NDL	Par 21519
	assignedTrain : CM_Train;	//20 Mar 2020	NDL	TFS 47004
	
begin
	
	querySelf := self;
	endLoad;
	
	train := self.allTrains.first;

	terminal := self.allTerminals.first;
	if terminal = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No terminal object passed into query!');
		return;
	endif;
	
	self.allQryTrackedItems.clear;

	foreach theTI in terminal.allOnsiteTIsByCargoTypeId discreteLock do : tiLoop
		if self.checkStatusIncludesObject(theTI, _passport, breakOut) and
		   (not querySelf.allQryTrackedItems.includes(theTI)) then
			querySelf.allQryTrackedItems.add(theTI);
		endif;
		
	endforeach;
	
	//20 Mar 2020	NDL	TFS 47004
	foreach theTI in terminal.allRRPTIsByCargoTypeId discreteLock do
		if not theTI.isRRPforRail then
			continue;
		endif;
		assignedTrain := theTI.myTrainAssigned;
		if assignedTrain = null then
			assignedTrain := theTI.myRRPTrain;
		endif;
		if assignedTrain &lt;&gt; null and train &lt;&gt; null then
			if not self.allTrains.includes( assignedTrain ) then
				continue;
			endif;
		endif;
		if self.checkStatusIncludesObject(theTI, _passport, breakOut) and
		   (not querySelf.allQryTrackedItems.includes(theTI)) then
			querySelf.allQryTrackedItems.add(theTI);
		endif;
		
	endforeach;
	
	if self.onSiteOnly then
		return;
	endif;
	
	foreach theTI in terminal.allNotifiedTIsByCargoTypeId discreteLock do : tiLoop
		if self.checkStatusIncludesObject(theTI, _passport, breakOut) and
		   (not querySelf.allQryTrackedItems.includes(theTI)) then
			querySelf.allQryTrackedItems.add(theTI);
		endif;
		
	endforeach;
	
	//02 Nov 2009	NDL	Par 21519
	if not self.allOnShipVoyages.isEmpty then
		iter := self.allOnShipVoyages.createIterator;
		while iter.next( voyage ) do
			foreach theTI in voyage.allOnshipTIsByCargoTypeId discreteLock do : tiLoop
				if not theTI.isImport then
					// not coming to this port.
					continue;
				endif;
				if not theTI.isIntendedForReleaseRail then
					// not intended for rail release.
					continue;
				endif;
				if self.checkStatusIncludesObject(theTI, _passport, breakOut) and
				   (not querySelf.allQryTrackedItems.includes(theTI)) then
					querySelf.allQryTrackedItems.add(theTI);
				endif;
				
			endforeach;
		endwhile;
		delete iter;
	endif;
	
epilog
	endLoad;
	delete iter;

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="63a8bae5-2bb0-4ec6-9815-205151202071">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     31 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	theDestinationPort 	: CM_Port;
	querySelf			: CMQF_TrainLoadListTIs;
	planedToTrain, includeIn		: Boolean;
	failedDAC  :CM_DataAccessController;
	theTrain : CM_Train;
begin
	querySelf := self;
	querySelf.numSearched := querySelf.numSearched + 1;
	

	if (not (_ti.canUserAccessSelf(null, failedDAC, _passport))) then
		return false;
	endif;

	if _ti.isChild then // PAR 8655
		return false;
	endif;
 
	if _ti.myPrimaryActualLocation &lt;&gt; null and _ti.myPrimaryActualLocation.isWagon() then
		theTrain := _ti.myPrimaryActualLocation.CM_WagonController.getMyTrain(false);
		// once the planned cargo is moved to the outward wagon it is no longer planned, so want to ignore it from the non planned list, however include if it is on a different train.
//		if theTrain &lt;&gt; null and querySelf.allTrains.includes(theTrain) then
			return false;
//		elseif querySelf.allTrains.isEmpty() then
//			return false;
//		endif;
	endif;
	if _ti.isOffSite() then // TRAIN has departed, TI has no primaryActualLocation but is nolonger a pre note
		return false;
	endif;
	
	planedToTrain := _ti.isPlannedToTrain();
	includeIn := _ti.isIntendedForReleaseRail();
	if includeIn then
		includeIn := (self.plannedToTrain = planedToTrain);
	endif;
	
	theDestinationPort := app.myRoot.allPorts[_ti.destinationPort.trimBlanks];
	
	if (querySelf.allCargoTypes.isEmpty or querySelf.allCargoTypes.includes(_ti.myCargoType)) and
	   (querySelf.allPortsDischarge.isEmpty or (theDestinationPort &lt;&gt; null and querySelf.allPortsDischarge.includes(theDestinationPort))) and
	   (querySelf.allOperators.isEmpty or querySelf.allOperators.includes(_ti.myOperator)) and
	   (querySelf.allTrains.isEmpty or querySelf.allTrains.includes(_ti.myTrainAssigned) or _ti.myTrainAssigned = null) and
	   includeIn and
	   (not querySelf.isGroundPos or querySelf.isGroundPos = _ti.isGroundPosNoOverstow) and
//	   (not querySelf.isOverDiffTrain or querySelf.isOverDiffVoy = _ti.isOverStowing) and
	   (not querySelf.isOverstowed or querySelf.isOverstowed = _ti.isOverStowed(REAL_MODE)) and
	   (not querySelf.useTopPosition or (_ti.isTopPositionCargo(querySelf.topPosition))) then
	   // 22206 Apr 2011 add option to exclude unassigned cargo
		if not querySelf.includeUnassignedCargo and
		   _ti.myTrainAssigned = null then
			return false;
		endif;
		querySelf.numFound := querySelf.numFound + 1;
		return true;
	endif;
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="reset" id="89eb0838-1e29-47ff-9e6b-4f44c4c2e414">
        <updating/>
        <source>reset() updating;
// ---------------------------------------------------------------------------
// Created:     16 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();

	self.allTrains.clear();
epilog

end;</source>
    </JadeMethod>
