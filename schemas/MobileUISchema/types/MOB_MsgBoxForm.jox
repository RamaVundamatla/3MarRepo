    <JadeMethod name="adjustSize" id="2ea07850-7f82-4ce9-afa0-1c1fe955c3f7">
        <updating/>
        <source>adjustSize() updating, protected;

vars
	textHeight		: Real;
	textLength		: Real;
	textFootPrint	: Real;
	lblFootPrint	: Real;
	factor			: Real;
	borderOffset	: Real;

begin
	textHeight		:=	self.txt_Text.getTextHeight(self.aMessage);
	textLength		:=	self.txt_Text.getTextExtent(self.aMessage);
	textFootPrint	:=	textHeight * textLength;
	lblFootPrint	:=	txt_Text.width * txt_Text.height;
	
	if (textFootPrint * 1.1 ) &gt; lblFootPrint then
		factor	:=	textFootPrint / lblFootPrint;
		
		if factor &lt; 1.5 then
			self.width	:=	self.width + 100;
			self.height	:=	self.height + 100;
		elseif factor &lt; 2 then
			self.width	:=	self.width + 200;
			self.height	:=	self.height + 100;
		elseif factor &lt; 5 then
			self.width	:=	self.width + 360;
			self.height	:=	self.height + 100;	
		elseif factor &lt; 10 then
			self.width	:=	self.width + 360;
			self.height	:=	self.height + 300;
		else
			self.width	:=	740;
			self.height	:=	478;		
		endif;
	endif;
	
	self.clearGraphics();
	self.autoRedraw		:=	true;
	self.drawWidth		:=	3;
	borderOffset		:=	2;
	self.drawRectangle(1, 1, self.clientWidth - borderOffset, self.clientHeight - borderOffset, Red);
end;
</source>
        <access>protected</access>
    </JadeMethod>
