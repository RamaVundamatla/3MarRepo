    <JadeMethod name="getOIDAndDescForAttribute" id="7ab6076a-dd1f-49f4-9991-f36525db0c59">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate: Boolean; _oid: String output): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 September 2014	cnwndl1	Initial creation
25/05/2022 			navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
24 May 2023 		navhl20 ChangeRequest 53902:[57781] EUP - VBS MTN - [6] - Selector Query and JRW
28 Aug 2023 		navhl20 Bug 60056: FR | 53429 - VBS Selector issues
*/

vars

	runDate : Date;

begin

	runDate := app.actualTimeServer().Date;	// 28/4/16 cnwmp6 TFS 488 - Multi timezone support
	
	if _attrName = ETRow_FromDate then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.getDateFromType, self.getDateFromFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.getDateFromType, self.getDateFromFactor);
		endif;
		
	elseif _attrName = ETRow_ToDate  then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.getDateToType, self.getDateToFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.getDateToType, self.getDateToFactor);
		endif;
		
	elseif _attrName = ETRow_CarrierFilter then	//28 Feb 2017	NDL	TFS 37304
		if self.myCarrier &lt;&gt; null then
			return self.myCarrier.code;
		else
			return Any_String;
		endif;
	
	//Start 25/05/2022 navhl20 TFS 53430 
	elseif _attrName = ETRow_SubCarrierFilter then
		if self.getMySubCarrier &lt;&gt; null then
			return self.getMySubCarrier.code;
		else
			return Any_String;
		endif;
	//end 25/05/2022 navhl20 TFS 53430
		
	elseif _attrName = ETRow_IncludeUnBooked then	//28 Feb 2017	NDL	TFS 37304
		if self.inclUnBooked then
			return "1";
		else
			return "0";
		endif;
	// navlw1	
	//24.5.2023 navhl20 #53902[57781]
	elseif _attrName = ETRow_VBSStatus then					//28.8.2023 navhl20 #60056
		return self.getVBSStatusString();					//28.8.2023 navhl20 #60056
	elseif _attrName = ETRow_PreGateInCheck then
		if self.preGateInCheck then
			return "1";
		else
			return "0";
		endif;
	elseif _attrName = ETRow_PreGateOutCheck then
		if self.preGateOutCheck then
			return "1";
		else
			return "0";
		endif;
	elseif _attrName = ETRow_KioskCheck then
		if self.kioskCheck then
			return "1";
		else
			return "0";
		endif;
	elseif _attrName = ETRow_IncludeDelivery then
		if self.includeDelivery then
			return "1";
		else
			return "0";
		endif;
	elseif _attrName = ETRow_IncludePickup then
		if self.includePickup then
			return "1";
		else
			return "0";
		endif;
	elseif _attrName = ETRow_ExternalRef then
		return self.externalReference;
	elseif _attrName = ETRow_BookingId then
		return self.bookingId;
	elseif _attrName = ETRow_Remarks then
		return self.remarks;
	elseif _attrName = ETRow_Id then
		return self.id;
	elseif _attrName = ETRow_BulkReleaseId then
		return self.bulkReleaseId;
	elseif _attrName = ETRow_VehicleVisitNumber then
		return self.vehicleVisitRecordNumber;
	elseif _attrName = ETRow_CargoId then
		return self.cargoId;
	//24.5.2023 navhl20 #53902[57781]
	elseif _attrName = ETRow_TsType then					//28.8.2023 navhl20 #60056
		return self.getVBSTsTypeString();
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate, _oid);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVBSStatusString" id="fa707777-578d-42a4-92d4-e963d0f14b84">
        <source>getVBSStatusString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Aug 2023 navhl20 Bug 60056: FR | 53429 - VBS Selector issues

*/

vars
	str	: String;
	idx	: Integer;
begin
	foreach idx in self.allVBSStatus do : wo_loop
		if str = null then
			str := str &amp; app.vbsStatusNumToString(idx);
		else
			str := str &amp; Comma &amp; app.vbsStatusNumToString(idx);
		endif;
	endforeach wo_loop;
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVBSStatusStringArray" id="26b76ee2-a375-493d-b83b-9903b6b2841a">
        <source>getVBSStatusStringArray( _strArray : StringArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Aug 2023 navhl20 Bug 60056: FR | 53429 - VBS Selector issues

*/
vars
	str	: String;
	idx	: Integer;
begin
	foreach idx in self.allVBSStatus do : wo_loop
		str := app.vbsStatusNumToString(idx);
		if str = null then
			continue wo_loop;
		endif;
		_strArray.add( str );
	endforeach wo_loop;
epilog
	
end;
</source>
        <Parameter name="_strArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getVBSTsTypeString" id="840a483c-199c-4576-8d82-7e7988f5af19">
        <source>getVBSTsTypeString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Aug 2023 navhl20 Bug 60056: FR | 53429 - VBS Selector issues

*/

vars
	str		: String;
	tsType	: CM_VehicleBookingTimeSlotType;
begin
	foreach tsType in self.allVBSTimeSlotTypes do : wo_loop
		if str = null then
			str := str &amp; tsType.description;
		else
			str := str &amp; Comma &amp; tsType.description;
		endif;
	endforeach wo_loop;
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVBSTsTypeStringArray" id="eb440197-1426-4d33-895d-176fbc8346c1">
        <source>getVBSTsTypeStringArray( _strArray : StringArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Aug 2023 navhl20 Bug 60056: FR | 53429 - VBS Selector issues

*/

vars
	tsType	: CM_VehicleBookingTimeSlotType;
	str		: String;
begin
	foreach tsType in self.allVBSTimeSlotTypes do : wo_loop
		str := tsType.description;
		if str = null then
			continue wo_loop;
		endif;
		_strArray.add( str );
	endforeach wo_loop;
epilog

end;</source>
        <Parameter name="_strArray" type="StringArray" usage="input"/>
    </JadeMethod>
