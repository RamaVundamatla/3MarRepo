	btnROROConfig.translateCaption(Xlat_0015824, locale);
	btnResetSearchMs.translateCaption(Xlat_0015825, locale);
	btnSearchMsg.translateCaption(Xlat_0015826, locale);
	btnSetClient.translateCaption(Xlat_0027027, locale);
	optClientGTUQ.translateCaption(Xlat_0027028, locale);
	grpClient.translateCaption(Xlat_0006978, locale);
	grpInteg.translateCaption(Xlat_0003801, locale);
	grpSetClient.translateCaption(Xlat_0027029, locale);
	lblClient1.translateCaption(Xlat_0015827, locale);
	lblClient2.translateCaption(Xlat_0015828, locale);
	lblSeachMsg.translateCaption(Xlat_0015829, locale);
	mnuContext.translateCaption(Xlat_0015830, locale);
