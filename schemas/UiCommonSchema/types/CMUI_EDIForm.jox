    <JadeMethod name="tblEDITIError_dblClick" id="3e4b867c-a945-4d49-9cc0-c3c603809307">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblEDITIError_dblClick(_table: CM_DataTable input) updating;
//----------------------------------------------------------------
//	Created:	16 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 13/07/2011	cnwcs5	par 26557 - use parameter instead of property self.&lt;property&gt;
// 07/08/2012	cnwcs5	par 30136
vars

begin 
	if _table.tag = self.NEED_TO_VERIFY then
		// TFS 2198 CNWAB1
		if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
			return;
		endif;

		_table.clearGraphics;
		
		self.doVerifyEDITIs;
		
		_table.tag := null;
		
	elseif _table.row = 1 then
		_table.resortTableByColumn(_table.column);
	else
		self.locateFileLine(true);
	endif;
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblEDITIError_mouseMove" id="689c56bc-d0bb-4656-925e-8b2b5a0e8651">
        <controlMethod name="Table::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblEDITIError_mouseMove(_table: CM_DataTable input; _button: Integer; _shift: Integer; _x: Real; _y: Real) updating;
//----------------------------------------------------------------
//	Created:	19 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	intRow	: Integer;
	obj		: CM_EDITrackedItem;
	err		: String;
begin
	_table.bubbleHelp := "";
	intRow := _table.getRowFromY(_y);
	
	if intRow &gt; _table.fixedRows and intRow &lt;= _table.rows then
	
		err := _table.accessCell(intRow, 4).text;
		if err = null then
			return;
		endif;
	else
		return;
	endif;
	
	_table.bubbleHelp := err;

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_button" type="Integer"/>
        <Parameter name="_shift" type="Integer"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
