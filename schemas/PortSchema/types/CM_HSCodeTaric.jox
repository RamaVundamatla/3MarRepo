    <JadeMethod name="pxyCreateUpdateProxy" id="503e7b14-e11b-499d-8224-05392a4f6f6a">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/02/2023	navkc1 CR 59577 Task 62410: Jade - New TRX for HS Taric

*/

vars
	proxy 			: CM_HSCodeTaric;
	completedOK 	: Boolean;

begin
	proxy := inheritMethod();
	
	proxy.myHSSubCode := self.myHSSubCode;
	
	completedOK := true;
	return proxy;
	
	
epilog
	if not completedOK then
		delete proxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="2e199e1f-ba8a-4168-baab-12e33e3433be">
        <updating/>
        <source>setForUpdate(_proxy: CM_HSCodeTaric) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/02/2023	navkc1 CR 59577 Task 62410: Jade - New TRX for HS Taric

*/

vars

begin
	inheritMethod(_proxy);
	
	if _proxy.myHSSubCode &lt;&gt; null then
		self.myHSSubCode := _proxy.myHSSubCode;
	else
		self.myHSSubCode := _proxy.getParentFromRoot();
	endif;
	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_HSCodeTaric"/>
    </JadeMethod>
