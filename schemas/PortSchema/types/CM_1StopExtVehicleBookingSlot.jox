        <embedded/>
        <type name="CM_Terminal"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ExplicitInverseRef name="myVehicleVisitRecord" id="5042d077-149f-4d07-9bc8-a8293419a5fd">
        <kind>child</kind>
