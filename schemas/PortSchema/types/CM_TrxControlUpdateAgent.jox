    <JadeMethod name="trxUpdateBarrierInTime" id="ab214778-628b-4d45-a8b2-7149a0411c5d">
        <updating/>
        <source>trxUpdateBarrierInTime(_vvr : CM_VehicleVisitRecord input; _barrierInTime : TimeStamp; _moveVehicleToYard : Boolean; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2023	jlier1	Initial creation 57936
10 May 2024	jlika1	TFS 64070 MTN - FR 53462 - Barrier IN Time not updated.
*/

vars
	vehicle : CM_Vehicle;
	newLocation : CM_YardController;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);

	beginTransaction;
	
	if _vvr = null then
		app.raiseCMException(Err_No_Vehicle_visit_found,null,null);
		return;
	endif;
	
	if not _barrierInTime.isValid then
		app.raiseCMException(Invalid_date,null,null);
	endif;
	
	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_vvr, true);
	
	if _moveVehicleToYard then
		vehicle:=_vvr.getVehicle;
		if vehicle = null then	
			app.raiseCMException(Err_Gate_VehicleId,null,null);
			return;
		endif;
		
		//jlier1 TFS 58617 19/6/23
		if  vehicle.isInGateLocation(null) or vehicle.isInPreGate() then
			app.myUtilityUA.utlMoveVehicle(vehicle,vehicle.getInTransitToYardLocation, _passport);
		endif;			
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
		
	if _barrierInTime.isValid then
		_vvr.myBarrierCodeIn.setBarrierDT(_barrierInTime);			
	endif;
	
	if _passport.noErrors then
			app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_vvr, false);
			self.updateObjectEdition(_vvr);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_barrierInTime" type="TimeStamp"/>
        <Parameter name="_moveVehicleToYard" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateBay" id="e3bb3e45-37e3-4a6a-a2b3-2692299f4f31">
        <updating/>
        <source>trxUpdateBay(_proxyBayDefn:CM_Bay; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 June 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

