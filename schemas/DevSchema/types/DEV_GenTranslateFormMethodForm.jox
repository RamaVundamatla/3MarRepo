    <JadeMethod name="unload" id="4e4c664c-3fd7-4763-9132-2ff3f0aaefdc">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

/*

Purpose:	unload form		

Date		Who		Reason
26/01/2012	cnwmh5	Initial creation
16/03/2015	cnwmh5	Transient Leak issue
//12/03/2019	jlgns1	TFS 36423 XLAT_FormCaptions need to be sorted out
*/

vars

begin

	self.dictFormChanges.clear();						
	self.dictLSconstantsToDisplay.clear();
	delete self.unitTestErrorArray;						// 24/02/2015 cnwmh5
	delete self.myLSschema;
	delete self.myFormAgent;
	if self.dictAllXlatConstants &lt;&gt; null then
		self.dictAllXlatConstants.clear();					//TFS 36423
	endif;
epilog

end;</source>
