    <JadeMethod name="loadConditionCodes" id="852f2d57-2f73-41ef-9d26-90106cca6edc">
        <source>loadConditionCodes(_ti : CM_TrackedItem) protected;
// ---------------------------------------------------------------------------
// Created:     18 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	cmb					: CMUI_ComboBox;
	code				: CM_Code;
	conditionDict		: CM_LogConditionCodesByCodeDict;
	
begin
	cmb := self.cmbCondition;
	cmb.clear();
	conditionDict := app.myRoot.allLogConditionCodes;
	
	foreach code in conditionDict do
		cmb.itemObject[cmb.addItem(code.code &amp; '  ' &amp; code.description)] := code;
	endforeach;
	
	if _ti.isKindOf(CM_Log) then
		cmb.listObject := app.myRoot.allLogConditionCodes[_ti.CM_Log.conditionCode];		
	endif;
	
	
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="loadCountryOfOrigin" id="1bb4d1df-04f9-4971-a0b8-1b1a3d1edf11">
        <source>loadCountryOfOrigin();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin

*/

vars
	country : CM_Country;
	combo : CMUI_ComboBox;
begin
	combo := self.cmbCountryOfOrigin;
	combo.clear();
	foreach country in app.myRoot.allCountries do
		if country.isNotAvailableForEntry then
			continue;
		endif;
		combo.addItemObject(country.description, country);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="547021a4-2766-4633-80a8-9b720dde9021">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:     23 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 16 Sep 2009	cnwkpd1		PAR #20686 - Initialise filterIMEXStatus to ensure
//							cargo is not excluded when form is opened from
//							Selector, etc

vars
	idCrit : CM_SelectorCriteriaLine;
	idRow : Integer;
	ctrl 	: Control;
begin

	self.txtID.automaticCellControl := true;
	self.cmbCargoType.automaticCellControl := true;				//+cnwml2 PAR21056

	if self.cmbFilterIMEX.listCount = 0 then
		self.myAssistant.comboBoxIMEXStatus(self.cmbFilterIMEX, null);
		self.cmbFilterIMEX.listIndex := -1;
		self.filterIMEXStatus := NULL_INTEGER;		// PAR #20686
	endif;

	inheritMethod();

	if self.allowSearch and self.useSelectorTable then
		idCrit :=self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::id.name);
		if idCrit &lt;&gt; null then	
			self.tblSearch.findObjectInRow(idCrit,idRow);
			if idRow &gt; 1 then
				self.tblSearch.row:=idRow;
				self.tblSearch.column:=CM_EntryTable.ColumnValue;
			endif;
		endif;
	
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadDebtorTypeCombos" id="161cf111-ff4c-4e60-812a-b4b100da7630">
        <source>loadDebtorTypeCombos();
// ---------------------------------------------------------------------------
// Created:	9 April 2008 By Graeme Black cnwgb1
// Status: Unfinished
// This is done on initialisation of the form. loadDebtorType is done
// for each cargo displayed. That sets the selected value when the 
// row is set up.
// ---------------------------------------------------------------------------
vars
	debtorType : CM_DebtorType;
	debtor : CM_Debtor;
	aDebtorTypeControl : CMUI_ComboBox; 
	controlId : Integer;
begin
	self.allDebtorTypeControls.clear();
	controlId := 13000; // What?
	// 35440 DO include not available for entry here as they are filtered out for individual items, to handle being used while
	//	not avialble
	foreach debtorType in app.myRoot.allDebtorTypes discreteLock do
		if not debtorType.allDebtors.isEmpty then
			controlId := controlId + 1;
			aDebtorTypeControl := cmbDebtorType.loadControl( controlId ).CMUI_ComboBox;
			aDebtorTypeControl.name := "cmbDebtorType" &amp; debtorType.code;
			aDebtorTypeControl.setEventMapping( "lostFocus", "cmbDebtorType_lostFocus");
			foreach debtor in debtorType.allDebtors do
				aDebtorTypeControl.addItem(debtor.name);
				aDebtorTypeControl.itemObject[aDebtorTypeControl.newIndex] := debtor;
			endforeach;
			aDebtorTypeControl.addItem("");
			self.allDebtorTypeControls.add( aDebtorTypeControl );
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDebtorTypes" id="0da040c6-bb25-45a0-b042-76afc9077dc5">
        <source>loadDebtorTypes(_tbl: CM_EntryTable io; _entDefName : String);
// ---------------------------------------------------------------------------
// Created:	9 April 2008 By Graeme Black cnwgb1 cp ccms 1047 par 16666
// These dynamic items are added into various cargo enquiry tables. The 
// tables have been constructed according to various historical constraints.
// Hence there are special ad-hoc rules being applied here.
//  35440 04/02/2014 cnwjre1 add not available for entry checks unless is used by current cargo item
// ---------------------------------------------------------------------------

vars
	debtorType : CM_DebtorType;
	debtor		: CM_Debtor;
	ti			: CM_TrackedItem;
	insertAfterRow : Integer;
	sortedList : CM_DebtorTypeByDescDict;
	debtorTable	: CM_EntryTable;
begin
	//03 Jun 2015	NDL	Par 36338
	if self.myCurrentObject.isKindOf(CM_CargoGroup) then
		return;
	endif;
	
	if self.myCurrentObject.isKindOf(CM_TrackedItem) then
		ti := self.myCurrentObject.CM_TrackedItem;
		if _entDefName = "Alphabetised definition" then
			foreach debtorType in app.myRoot.allDebtorTypes do
				// 35440 skip if not available and not used
				if debtorType.isNotAvailableForEntry then
					debtor := ti.allDebtorsByType[debtorType.code];
					if debtor = null then
						continue;
					endif;
				endif;
				if not debtorType.allDebtors.isEmpty then
					insertAfterRow := findAlphabetisedRow( _tbl, debtorType.description );
					self.insertDebtorType( _tbl, debtorType, insertAfterRow);
				endif;
			endforeach;
			_tbl.hideRowByName(ETRow_DebtorTypes, false);
		//elseif self.myCurrentCargoBOLType &lt;&gt; null then	// 11/02/2015 cnwar2 #35667 - no reason a cargo type needed
		else
			// 28459 show debtor types from DebtorTypes row, and hide the DebtorTypes row itself
			debtorTable := self.getTableForRow(ETRow_DebtorTypes);
			if debtorTable = null then
				return;
			endif;
			if _tbl.name &lt;&gt; debtorTable.name then
				return;
			endif;
			create sortedList transient;
			foreach debtorType in app.myRoot.allDebtorTypes do
				// 35440 skip if not available and not used
				if debtorType.isNotAvailableForEntry then
					debtor := ti.allDebtorsByType[debtorType.code];
					if debtor = null then
						continue;
					endif;
				endif;
				if not debtorType.allDebtors.isEmpty then
					sortedList.add(debtorType);
				endif;
			endforeach;
			insertAfterRow := debtorTable.getRow(ETRow_DebtorTypes);
			foreach debtorType in sortedList reversed do
				self.insertDebtorType( _tbl, debtorType, insertAfterRow);
			endforeach;
			debtorTable.hideRowByName(ETRow_DebtorTypes, false);
		endif;
	endif;
epilog
	delete sortedList;
end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="io"/>
        <Parameter name="_entDefName" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadInvoiceContractId" id="b9ea7acc-bfef-4b7a-abd7-31f31633bbce">
        <source>loadInvoiceContractId();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Feb 2023 navtnr20	TFS CR 55648 Task 55663: UI - Contract Id
// ### TFS 57309 24MAR2023 NAVAB1 re written
29/01/2023	navkc1 Bug 62020: MTN - Expired Contract in Cargo Enquiry
*/

vars
	contract : CM_InvoiceContract;
	combo : CMUI_ComboBox;
	bank : CM_Bank;
	businessUnits	: CM_CompanyByCodeDict;
	obj : Object;
	operator : CM_Operator;
	debtor : CM_Debtor;
	idx : Integer;
	currentTI : CM_TrackedItem;
	today	: Date;
begin

	combo := self.cmbInvoiceContractId;
	combo.clear();

	currentTI := self.myCurrentObject.CM_TrackedItem;
	
	if currentTI.companyOid &lt;&gt; null then
		bank := currentTI.companyOid;
		operator := self.cmbOperator.listObject.CM_Operator;
		if operator = null then 
			operator := currentTI.myOperator;
		endif;
		if operator &lt;&gt; null then
			debtor := operator.debtor;
		endif;
	
		if debtor &lt;&gt; null then
			foreach contract in debtor.allInvoiceContracts where contract.myBusinessUnit = bank do
				if 	contract.active and 
					contract.toTS.date() &gt; today //29/01/2023	navkc1 Bug 62020
												then 
					combo.addItemObject(contract.contractId, contract);
				endif;
			endforeach;
			
			contract := currentTI.myContract; // ### TFS BUG 57309 03APR2023 NAVAB1
			if combo.findObject(contract) &lt; 1 then
				idx := combo.addItemObject(currentTI.contractId, contract);
				combo.listIndex := idx; // ### TFS BUG 57309 03APR2023 NAVAB1
			else
				combo.listObject := contract;
			
			endif;
			
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadMeasurementTypes" id="f26a80ff-37a7-4a4a-9269-e42a6ece007c">
        <updating/>
        <source>loadMeasurementTypes(	_tbl : CM_EntryTable io; 
						_entDefName : String; 
						_allEntTableRows : ObjectArray; 
						_isForEdit : Boolean	) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
19/06/2013	cnwdap1	PAR #31754 Fix for Product Attribute measurements always showing the default
*/
vars
	obj					: Object;
	row					: EntTableRow;
	measure				: CM_MeasurementType;
	defaultMeasure		: CM_MeasurementType;
	insertAfterRow 		: Integer;
	controlId			: Integer;
	hideRow				: Integer;
	product				: CM_Product;
	attr				: CM_ProductAttr;
	seperateMeasureLines : Boolean;
begin

	if _entDefName = "Alphabetised definition" then	//31 Mar 2014	NDL	Par 33356
		controlId := 13000;
		self.allMeasurementControls.purge;
		self.allMeasurementControls.clear;
	else
		controlId := self.allMeasurementControls.getNextControlId;	//31 Mar 2014	NDL	Par 33356
		self.allMeasurementControls.deleteMeasurementTablesFor( _tbl );	//31 Mar 2014	NDL	Par 33356
	endif;
	//jlier1 MTN-34671 23/4/25 - just call getconfig once
	seperateMeasureLines:=app.myRoot.getConfig(MeasuresSeparateLines).Boolean ;
	if self.myCurrentObject.isKindOf(CM_TrackedItem) then
		// get product outside the loop like the CM_BaseForm version
		if self.myCurrentObject.CM_TrackedItem.myProduct &lt;&gt; null then
			product := self.myCurrentObject.CM_TrackedItem.myProduct;
		elseif self.myCurrentObject.CM_TrackedItem.myCargoType.mySystemProductType &lt;&gt; null then
			product := self.myCurrentObject.CM_TrackedItem.myCargoType.mySystemProductType;
		endif;
	
		foreach obj in _allEntTableRows do
			row := obj.EntTableRow;
			if row.measurementType = null then
				continue;
			endif;
			insertAfterRow := _tbl.getRowByName(row.name);
			
			if _entDefName = "Alphabetised definition" then
				// load the default measurement first, then the others
				defaultMeasure := app.getDefaultMeasurementForType(row.measurementType);
				if product &lt;&gt; null then
					attr := product.getProdAttrFromName(row.name);
					if attr &lt;&gt; null and attr.myMeasurementType &lt;&gt; null and attr.myMeasurementType &lt;&gt; defaultMeasure then
						defaultMeasure := attr.myMeasurementType;
					endif;
				endif;

				self.insertMeasurementType(_tbl, row, defaultMeasure, insertAfterRow, controlId, _isForEdit, self.myCurrentObject.CM_Object, null, product );						// PAR #31754
				
				if seperateMeasureLines then
					insertAfterRow := insertAfterRow + 1;
					if not _isForEdit then
						foreach measure in app.myRoot.allMeasurementTypesByShortName do
							if measure.isDefault or measure = defaultMeasure or not measure.isDisplay or measure.measurementType &lt;&gt; row.measurementType then
								continue;
							endif;
							if measure.isAvailableForEntry then
								//self.insertMeasurementType(_tbl, row, measure, insertAfterRow, controlId, _isForEdit, self.myCurrentObject.CM_Object);				// PAR #31754
								self.insertMeasurementType(_tbl, row, measure, insertAfterRow, controlId, _isForEdit, self.myCurrentObject.CM_Object, defaultMeasure, product);	// PAR #31754
							endif;
						endforeach;
					endif;
				endif;
				// hide the original measurement row
				hideRow := _tbl.getRowByName(row.name);
				_tbl.hideRow(hideRow);
			else
				if insertAfterRow &gt; 0 then
					// load the default measurement first, then the others
					defaultMeasure := app.getDefaultMeasurementForType(row.measurementType);
					if product &lt;&gt; null then
						attr := product.getProdAttrFromName(row.name);
						if attr &lt;&gt; null and attr.myMeasurementType &lt;&gt; null and attr.myMeasurementType &lt;&gt; defaultMeasure then
							defaultMeasure := attr.myMeasurementType;
						endif;
					endif;
					
					//self.insertMeasurementType(_tbl, row, defaultMeasure, insertAfterRow, controlId, _isForEdit, self.myCurrentObject.CM_Object);							// PAR #31754
					self.insertMeasurementType(_tbl, row, defaultMeasure, insertAfterRow, controlId, _isForEdit, self.myCurrentObject.CM_Object, null, product);						// PAR #31754
					
					if seperateMeasureLines then
						insertAfterRow := insertAfterRow + 1;
						if not _isForEdit then
							foreach measure in app.myRoot.allMeasurementTypesByShortName do
								if measure.isDefault or measure = defaultMeasure or not measure.isDisplay or measure.measurementType &lt;&gt; row.measurementType then
									continue;
								endif;
								if measure.isAvailableForEntry then
									//self.insertMeasurementType(_tbl, row, measure, insertAfterRow, controlId, _isForEdit, self.myCurrentObject.CM_Object);				// PAR #31754
									self.insertMeasurementType(_tbl, row, measure, insertAfterRow, controlId, _isForEdit, self.myCurrentObject.CM_Object, defaultMeasure, product);	// PAR #31754
								endif;
							endforeach;
						endif;
					endif;
					// hide the original measurement row
					hideRow := _tbl.getRowByName(row.name);
					_tbl.hideRow(hideRow);
				endif;
			endif;
			
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="io"/>
        <Parameter name="_entDefName" type="String"/>
        <Parameter name="_allEntTableRows" type="ObjectArray"/>
        <Parameter name="_isForEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadProductCombo" id="7c880f6c-37b9-4a33-95ac-e2888f15cefa">
        <source>loadProductCombo();
// ---------------------------------------------------------------------------
// Created:     18 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/05/2020	jlgdap1		TFS 49252 CPL Cargo Types not showing in System Admin
// ---------------------------------------------------------------------------
vars
	cargoBOLType		: CM_CargoBOLType;
	prod			: CM_Product;
begin
	self.cmbFiltProd.clear();
	cargoBOLType := self.myCurrentCargoBOLType;
	
	if (not cargoBOLType.isKindOf(CM_CargoType))
	or (cargoBOLType.id &lt; TI_CargoBOLType_Max)
	or (cargoBOLType.id &gt; TI_CargoBOLType_JMTMax)
	or (cargoBOLType.id &gt; TI_CargoBOLType_JMTMax and app.myRoot.isClientCentrePort)		// TFS 49252
	then
		return;//not a user cargo type - so no products associated
	endif;
	
	//cnwjo3 ccms 1071, don't show Product row if subcargo not required
	if cargoBOLType.CM_CargoType.isSubCargoTypeRequired = true then
		self.tblSearch.showRowByName(ETRow_FilterProduct,false);
		//epr tfs 1846 19/4/16
		self.cmbFiltProd.addItem(Any_String);
		foreach prod in cargoBOLType.CM_CargoType.allProducts where not prod.isNotActive do
			self.cmbFiltProd.addItemObject(prod.code,prod);
		endforeach;
		self.cmbFiltProd.listIndex:=1;
		self.tblSearch.setValueByName(ETRow_FilterProduct, Any_String);
	else
		self.tblSearch.hideRowByName(ETRow_FilterProduct,false);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadSealTypeTables" id="2691d9f9-b132-4eda-bb16-d2068267200a">
        <source>loadSealTypeTables();
//+cnwml2 PAR23715 SFW CCMS1131

vars
	sealType : CM_SealType;
	seal : CM_SealTI;
	aSealTypeControl : CM_Table; 
	controlId : Integer;
begin
	self.allSealTypeControls.clear();
	controlId := 13000; // What?
	foreach sealType in app.myRoot.allSealTypes discreteLock do
		if sealType.allowMultipleSealNums then
			controlId := controlId + 1;
			aSealTypeControl := self.tblSeals.loadControl( controlId ).CM_Table;
			aSealTypeControl.name := "tblSeals" &amp; sealType.sealType;
			aSealTypeControl.setEventMapping( "lostFocus", "tblSeals_lostFocus");
			aSealTypeControl.setEventMapping( "gotFocus", "tblSeals_gotFocus");
			aSealTypeControl.inputType := Table.InputType_TextBox;
			aSealTypeControl.userInputEnabled := true;
			aSealTypeControl.rows := 10;
			aSealTypeControl.selectMode := CM_Table.SelectMode_CurrentRow;
			self.allSealTypeControls.add( aSealTypeControl);
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadSealTypes" id="632f92d3-289b-4d6a-a63e-b954cb58f53e">
        <source>loadSealTypes(_tbl : CM_EntryTable io; _entDefName : String);
//17 August 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS1131
// Nov 2011 28459 this is for soft seals only, others such as Operator and Vent have explicit rows/attributes and are shown separately
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//
vars
	sealType : CM_SealType;
	cargoType : CM_CargoType;
	tableHasSeals	: Boolean;
	insertAfterRow : Integer;
begin
	//03 Jun 2015	NDL	Par 36338
	if self.myCurrentObject.isKindOf(CM_CargoGroup) then
		return;
	endif;
	
	if self.myCurrentObject.isKindOf(CM_TrackedItem) then
		cargoType := self.myCurrentObject.CM_TrackedItem.myCargoType;
		insertAfterRow := _tbl.getRowByName(ETRow_OtherSeals);	// 28459 Nov 2011 new marker for soft seals
		tableHasSeals := (insertAfterRow &gt; 0);
		if _entDefName = "Alphabetised definition" then
			foreach sealType in cargoType.allSealTypes do
				if sealType.sealType = SealType_Customs or
				   sealType.sealType = SealType_Operator or
				   sealType.sealType = SealType_Shipper or
				   sealType.sealType = SealType_Vent or
				   sealType.sealType = SealType_TerminalOperator or
				   sealType.sealType = SealType_Unknown then
					continue;
				endif;
				if not sealType.notAvailableForEntry then
					insertAfterRow := findAlphabetisedRow(_tbl, sealType.description);
					self.insertSealType(_tbl, sealType, insertAfterRow);
				endif;
			endforeach;
		else
			if tableHasSeals then
				foreach sealType in cargoType.allSealTypes do
					if sealType.sealType = SealType_Customs or
					   sealType.sealType = SealType_Operator or
					   sealType.sealType = SealType_Shipper or
					   sealType.sealType = SealType_Vent or
					   sealType.sealType = SealType_TerminalOperator or
					   sealType.sealType = SealType_Unknown then
						continue;
					endif;
					if not sealType.notAvailableForEntry then
						insertAfterRow := _tbl.getRowByName(ETRow_OtherSeals);
						self.insertSealType(_tbl, sealType, insertAfterRow);
					endif;
				endforeach;
			endif;
		endif;
	endif;
			
epilog

end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="io"/>
        <Parameter name="_entDefName" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadShippingLineCombo" id="6e2665e5-8b47-4b10-aea9-961f8dc71d7b">
        <source>loadShippingLineCombo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2022	navgm20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI

*/

vars

	shippingLine : CM_ShippingLine;
	combo : CMUI_ComboBox;
begin
	combo := self.cmbShippingLine;
	combo.clear();
	foreach shippingLine in app.myRoot.allShippingLines do
		combo.addItemObject(shippingLine.description, shippingLine);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadSiteCombo" id="4450f0b3-8759-4250-ab33-e2a895f8e8df">
        <source>loadSiteCombo();
/*

Date		Who		Reason
04 August 2016	cnwer1	Initial creation TFS 2433

*/

vars
	tmpCombo		: CMUI_ComboBox;
begin
	tmpCombo := self.cmbFiltSite;
	
	if tmpCombo.listCount &gt; 0 then
		return;
	endif;
	
	tmpCombo.clear;
	tmpCombo.addItem(ANYSITE_STRING);
	tmpCombo.addItem(ONSITE_STRING);
	tmpCombo.addItem(OFFSITE_STRING);
	tmpCombo.addItem(ONSHIP_STRING);
	tmpCombo.addItem(OFFLOADED_STRING);
	tmpCombo.addItem(NOTIFIED_STRING);
	tmpCombo.addItem(DELETED_STRING);
	
	// DVB changed to use new flags 05/04/05
	if app.isInterTerminalTransferEnabled() then
		tmpCombo.addItem(TRANSFER_STRING_TO);
		tmpCombo.addItem(TRANSFER_STRING_FROM);
	endif;
	tmpCombo.listIndex := 2;	//ONSITE IS DEFAULT
	tmpCombo.lostFocus(tmpCombo);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadStorageExpDetailsTable" id="b943a8ed-226a-4113-abb8-e33dc751a2a4">
        <source>loadStorageExpDetailsTable(_ti : CM_TrackedItem input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 September 2023 CR 58250 Task 58253: UI - Cargo Enquiry New Sheet
*/

vars
	iter : Iterator;
	storageExpDetail : CM_StorageExpiryDetail;
	row : Integer;
begin
	self.tblView2.rows:=1;
	row := self.tblView2.rows;

	iter:=_ti.allStorageExpiryDetails.createIterator;
	while iter.next(storageExpDetail) do	
		self.tblView2.addObject(storageExpDetail);
		row += 1;
		self.tblView2.beginNotification(storageExpDetail, Object_Update_Event, Response_Continuous, 0);
		self.doShowDataSpecial(self.tblView2, row, storageExpDetail);
	endwhile;
	
	self.tblView2.colourRows(self.colorRow1,self.colorRow2);
	self.setColorsForTable(self.tblView2);
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadSubTerminalFilter" id="c0d906be-2d2d-49dc-bfa2-442951623726">
        <source>loadSubTerminalFilter() protected;
// --------------------------------------------------------------------------------
// Created:		25 May 2009 by cnwdad1
//
// Purpose:		Populates the Sub-Terminal filter combobox.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	comboboxObj	: ComboBox;
	
begin
	comboboxObj	:=	cmbFiltSubTerm;
	comboboxObj.automaticCellControl	:=	true;
	
	if self.myTerminal &lt;&gt; null then
		comboboxObj.listCollection(self.myTerminal.allSubTerminals, true, Collection.CNEC_DISPLAY_ORDER_COLLECTION);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTILCLoadDetailsTable" id="152245e5-5b0a-45e6-b004-8b61c35dc270">
        <source>loadTILCLoadDetailsTable(_tilc : CM_TILC input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2022	jlier1	Initial creation 54700
 14/04/2023	navkc1	CR 57036 Task 57589: UI - Cargo Enquiry Drag Drop
*/

vars
	tis : CM_TISet;
	iter : Iterator;
	ti : CM_TrackedItem;
	row : Integer;
begin
	self.tblView2.rows:=1;
	row := self.tblView2.rows;
	create tis transient;
	_tilc.getAllOnboardTIs(tis);
	iter:=tis.createIterator;
	while iter.next(ti) do	
		self.tblView2.addObject(ti);
		// 14/04/2023	navkc1	CR 57036 Task 57589
		row += 1;
		self.tblView2.beginNotification(ti, Object_Update_Event, Response_Continuous, 0);
		self.allMAFIOnboardNotify.add(ti);
		self.doShowDataSpecial(self.tblView2, row, ti);
	endwhile;
	
	self.tblView2.colourRows(self.colorRow1,self.colorRow2);  // recolour after all added HJG
	self.setColorsForTable(self.tblView2);
epilog
	delete iter;
	delete tis;
end;</source>
        <access>protected</access>
        <Parameter name="_tilc" type="CM_TILC" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadTrailerCombo" id="62d8b504-94f6-4612-a9bf-23e1ae70bbc4">
        <source>loadTrailerCombo();
/*

Purpose:			


Return Value:		


Date		Who		Reason
06 May 2008	cnwer1	Initial creation - PAR#xxxx

*/
vars

	cargoBOLType		: CM_CargoBOLType;

begin
	cargoBOLType := self.myCurrentCargoBOLType;
	if cargoBOLType = null then
		return;
	endif;
	
	if (not cargoBOLType.isKindOf(CM_CargoType)) then
		return;//not a user cargo type - so no products associated
	endif;
	
/*	self.cmbFiltTrailer.clear();
	self.cmbFiltTrailer.sorted:=false;
	
	//epr 13/3/14 all we care about is if the cargo type has chassis types
	if cargoBOLType.CM_CargoType.allTILCTypes.size = 0 then
		return;
	endif;*/
	self.myAssistant.comboBoxTrailerType(self.cmbFiltTrailer,cargoBOLType.CM_CargoType,null,self.myTerminal);
	
	
	//self.cmbFiltTrailer.listCollectionWithAny(cargoBOLType.CM_CargoType.allTILCTypes, ETRow_Code);
