    <JadeMethod name="getMyTrackedItem" id="2d679b86-6f41-414c-8ffe-cfeeb7772654">
        <source>getMyTrackedItem():CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

	int : Integer;
	invalidObject : Boolean;

begin

	if self.myTrackedItem &lt;&gt; null then
		
		on Exception do app.handleDeletedObject( exception, self.myTrackedItem, invalidObject );
	
		int := self.myTrackedItem.edition;
		if not invalidObject then
			return self.myTrackedItem;
		endif;
	
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getMyVoyage" id="088cc9a8-915d-45b1-99c2-6934371f1387">
        <source>getMyVoyage() : CM_Voyage;
/*
Date				Who		Reason
01 November 2023	navmd1	TFS 61063 Unit Test - Handle/ignore null duty doc root
*/
vars
	term : CM_Terminal;
begin
	term := self.getMyTerminal;
	if term &lt;&gt; null then
		return term.allVoyagesByCode.getAtKeyGeq(self.voyage, null);
	endif;
	
	return null;
end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getNetValue" id="686f1280-9c95-4fe0-abbd-2f9a4e34bdd9">
        <source>getNetValue() : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2012	cnwer1	Initial creation HAT 2189

*/

vars
	netValue : Decimal[16,4];
begin
	if self.myDutyDoc = null then
		return null;
	endif;
	if self.myDutyDoc.invTerms = CIF then
		netValue := localValue;
	elseif self.myDutyDoc.invTerms = CNF then
		netValue := self.localValue + self.insurance;
	else	//if invTerms = FOB then
		netValue := self.localValue + self.freight + self.insurance;
	endif;
	
	return netValue;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getPackingTypeObject" id="30e81d98-0e79-4b04-aef5-48b88d025a95">
