    <JadeMethod name="addDamageRow" id="683f8b05-80e7-41c6-ac73-e255219161f3">
        <updating/>
        <source>addDamageRow(_damageInstance : CM_DamageInstance) protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	25 October 2006 By cnwth2

Purpose:	

/****Changes

Date		Name	TFS#	Description
============================================================================
30/11/2018	jlgka1	41225	Add repaired attribute so when creating a proxy when
							completing task all DamageInstance attribute is well
							preserve and not being overwritten.
30/04/2019	jlgdi1	44530	Store the CM_DamageInstance object for every row in the table
09/05/2019	jlgka1	44287	JMT - Damage Refactoring. Set repaired value to true when
							completing a to do task.
24 June 2022 navhl20 53862  EUP - WMS - Damage Recording Extra Details
14/11/2024	jlizm1	33161 	Damage check quantity not pre-populated
============================================================================*/
vars
	aRow 	 : Integer;
	repaired : Boolean;
	dsLevel	 : String;	//28 June 2022 navhl20 TFS 53862
begin
	if _damageInstance &lt;&gt; null then
		//aRow := self.addItem(app.getDamageDescrForLoc(_damageInstance.damageLocation) &amp; Tab &amp; 
		if _damageInstance.myDamagePosition = null then
			aRow := self.addItem(method.qualifiedName &amp; Tab &amp; _damageInstance.String &amp; Tab &amp; 'not converted');
		else
		repaired := _damageInstance.repaired;
		// jlgka1 TFS 44287 --&gt;
		if not repaired and self.parent.name = "CMUI_ToDoDamageTask" then
			repaired := true;
		endif;
		// jlgka1 TFS 44287 &lt;--
		
		//Start 28 June 2022 navhl20 TFS 53862
		if _damageInstance.myDamageSeverity &lt;&gt; null then
			dsLevel := _damageInstance.myDamageSeverity.level.String;
		endif;
		//End 28 June 2022 navhl20 TFS 53862
		
		aRow := self.addItem(_damageInstance.myDamagePosition.code &amp; Tab &amp; 
				_damageInstance.myDamageDefinition.code &amp; Tab &amp;
				//_damageInstance.severity.String &amp; Tab &amp;		//24 June 2022 navhl20 TFS 53862
				dsLevel &amp; Tab &amp;		//24 June 2022 navhl20 TFS 53862
				_damageInstance.quantity.String &amp; Tab &amp;	// 15 Oct 2013	NDL	Par 32803
				repaired.String); // jlgka1 TFS 41225
		endif;
		self.accessRow(aRow).itemObject := _damageInstance;	// TFS# 44530
	else
		aRow := self.addItem(null);
		
		//09 Apr 2014	Par 33934
		if self.myCmbPosition.listCount = 2 then
			self.myCmbPosition.listIndex := 2;
			self.setCellText(aRow,1,self.myCmbPosition.itemText[2]);
		endif;
		if self.myCmbCode.listCount = 2 then
			self.myCmbCode.listIndex := 2;
			self.setCellText(aRow,2,self.myCmbCode.itemText[2]);
		endif;
		// end of 33934
		
		// default qty to 1
		self.setCellText(aRow, 4, "1");
		
	endif;	
	
	self.accessCell(aRow,1).cellControl := self.myCmbPosition;
	self.accessCell(aRow,2).cellControl := self.myCmbCode;
	self.accessCell(aRow,3).cellControl := self.myCmbSeverity;
	
	self.accessCell(aRow,4).inputType := Table.InputType_TextNumeric;	// 15 Oct 2013	NDL	Par 32803
	self.accessCell(aRow,5).cellControl := self.myCmbRepaired; // jlgka1 TFS 41225
	
	//	09 May 2019	NDL	TFS 44680 - Commented out... This was stopping the ability for cellInputReady to fire and add a new line. 
//	self.accessCell(aRow,5).enabled := false; // jlgka1 TFS 41225 
	//self.myCmbRepaired.enabled := false;	//09 May 2019	NDL	TFS 44680  // jlgka1 TFS 44287 - do not disabled just default the value to true when to do task
end;


</source>
        <access>protected</access>
        <Parameter name="_damageInstance" type="CM_DamageInstance"/>
    </JadeMethod>
    <JadeMethod name="addNewRow" id="e6cdcb34-6086-4989-b590-9b7e11c846e7">
        <updating/>
        <source>addNewRow() updating;

/*

Purpose:			

Parameters:			

Return Value:		


/****Changes

Date		Name	TFS#			Description
============================================================================
08/12/2008	cnwrd1					Initial creation Needed to be able to 
									switch off the cellinputready event 
									and add rows manualy on mouseevents 
============================================================================*/

begin
	self.addDamageRow(null);
end;</source>
