    <JadeMethod name="validateMe" id="4ba9f3c6-ea4e-4196-bd2f-2adc961a2157">
        <source>validateMe() protected;
// ---------------------------------------------------------------------------
// Created:		26 March 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 08/12/2014   cnwdb2	PAR #35364
vars
	
	real			: SelfType;
	otherDevice		: CM_RadioTelemetryDevice;
	terminal		: CM_Terminal;
begin

	if self.type = null then
	//	app.raiseCMException1(REQUIRED_FIELD,'type',null,null);
		app.raiseCMException(Input_required_field_type,null,null);// cnwdb2	PAR 35364
	endif;
	if self.model = null then
	//	app.raiseCMException1(REQUIRED_FIELD,'model',null,null);
		app.raiseCMException(Input_required_field_model,null,null); // cnwdb2	PAR 35364
	endif;
	
	if self.id = null then
	//	app.raiseCMException1(REQUIRED_FIELD,'id',null,null);
		app.raiseCMException(Input_required_field_id,null,null); // cnwdb2	PAR 35364
	endif;

	real := self.pxyGetRealObject();
	if real = null or real.id &lt;&gt; self.id then
		if app.myPassport.myTerminal.radioTelemetry.allRTDevices[self.id] &lt;&gt; null then
		//	app.raiseCMException1(ERR_DUPLICATE_KEY, 'RT Device ' &amp; self.id, null, null);
			app.raiseCMException1(Already_exists_RTDevice, self.id, null, null); //cnwdb2	PAR 35364
		endif;
	endif;
	
	//th2 - needs to be unique over whole system - not just terminal - as this value
	//is used to during logon to determine the device and the terminal
	foreach terminal in app.myRoot.allTerminals discreteLock do
		if terminal.radioTelemetry =  null then
			continue;
		endif;
		
		foreach otherDevice in terminal.radioTelemetry.allRTDevices discreteLock do
			if otherDevice &lt;&gt; self.pxyGetRealObject and 
			   otherDevice.computerName &lt;&gt; null and 
			   self.computerName &lt;&gt; null and
			   self.computerName.toUpper.trimBlanks() = otherDevice.computerName.toUpper.trimBlanks() then
				app.raiseCMException1(ERR_DUPLICATE_COMPUTERNAME, otherDevice.id &amp; ' in terminal ' &amp; terminal.code, null, null);
				break;
			endif;
		endforeach;
	endforeach;
	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
