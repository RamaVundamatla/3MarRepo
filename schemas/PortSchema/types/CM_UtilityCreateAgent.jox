    <JadeMethod name="utlCreateInvoiceResourceCharge" id="290e9c9d-7361-4d1c-b0a6-249c52335edc">
        <source>utlCreateInvoiceResourceCharge(pxyResourceUsed : HMS_ResourceUsed; _passport : CM_Passport input; _validate : Boolean);
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	realResourceUsed : HMS_ResourceUsed;
	expectedEdition : Integer;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	pxyResourceUsed.pxyGetRealObjectAndEdition(realResourceUsed, expectedEdition);
	
	if realResourceUsed = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, HMS_ResourceUsed.name, null, null);
		return;
	endif;
	if _validate then
		app.myValCA.valResourceCharge(pxyResourceUsed,_passport);
	endif;
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realResourceUsed);

	if _passport.noErrors and realResourceUsed.edition &lt;&gt; expectedEdition then
//		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Resource Type Used Transaction', null, null);
//		return;
	endif;
	
	if _passport.noErrors then
		realResourceUsed.createInvoiceTransaction(_passport);
	endif;
end;</source>
        <Parameter name="pxyResourceUsed" type="HMS_ResourceUsed"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_validate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="utlCreateInvoiceShipMapping" id="0816fbb6-0900-4d33-a2e5-ad3f41dbe221">
        <source>utlCreateInvoiceShipMapping(_pxyInvoiceShipMapping : CM_InvoiceShipTermMapping input;
					  _realInvoiceShipTermMapping : CM_InvoiceShipTermMapping output;
					  _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Dec 2022 navtnr20	TFS CR 55622 Task 55690: Jade - Shipping Terms TRX

*/

vars

begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	app.myValCA.valInvShipMapping(_pxyInvoiceShipMapping);

	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	
	create _realInvoiceShipTermMapping persistent;
	_realInvoiceShipTermMapping.setForCreate(_pxyInvoiceShipMapping);
	
	if _passport.noErrors then
		// only required if the class is audited
		self.myCreateAuditAgent.audCreateGeneric(_realInvoiceShipTermMapping);
		app.myEventManager.createSingleObjInfoNoteEvt(_realInvoiceShipTermMapping.myShippingTerm.myBusinessUnit,app.myPassport.myTerminal.getTerminalEvent(Event_InvShipMappingCreate),_realInvoiceShipTermMapping);
	endif;
epilog

end;</source>
        <Parameter name="_pxyInvoiceShipMapping" type="CM_InvoiceShipTermMapping" usage="input"/>
        <Parameter name="_realInvoiceShipTermMapping" type="CM_InvoiceShipTermMapping" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
