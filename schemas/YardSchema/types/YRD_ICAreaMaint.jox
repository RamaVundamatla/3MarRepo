    <JadeMethod name="displayEntryICArea" id="7c58da44-1469-4a1e-9509-0a51ccb0e5a3">
        <source>displayEntryICArea(_area :CM_TerminalArea):String;
// ---------------------------------------------------------------------------
// Created:     26 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return _area.id;
epilog

end;</source>
        <Parameter name="_area" type="CM_TerminalArea"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="99aaaca5-026d-4551-8e4a-2e28d229cc4c">
        <updating/>
        <source>doSave():Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     26 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	area		:CM_TerminalArea;
	coll		:CM_InterchangeAreaArray;
	result		:Integer;
begin
	area := self.cmbTerminalArea.listObject.CM_TerminalArea;
	
	if area = null then
		return true;	// should not happen
	endif;
	// get the selected interchange areas in order
	create coll transient;
	self.mulICArea.getSelected (coll);
	
	while true do
		app.myTrxUA.trxUpdateTerminalAreaICAreas (area, coll, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			elseif (not app.myPassport.noErrors) then
				return false;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;	
	endwhile;
	
	self.setFormChanged (false, null, self.btnSave, null, null);
	self.resetFirstChangeFlag;
	return true;
epilog
	delete coll;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="firstChange" id="ae4eaac0-ab2c-45df-bfc1-f2ccd2ade1d8">
        <controlMethod name="Form::firstChange"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>firstChange(cntrl: Control input) updating;
// ---------------------------------------------------------------------------
// Created:     26 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if cntrl = self.cmbTerminalArea then
		return;
	endif;
	
	self.setFormChanged (true, null, self.btnSave, null, null);
epilog

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initICAreaList" id="d3aa43f0-4168-4b49-bfd6-df7adf2d153a">
        <source>initICAreaList() protected;
// ---------------------------------------------------------------------------
// Created:     26 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	list	:CMUI_MultiSelectGroupBox;
	type	:CM_TerminalAreaType;
	set		:CM_InterchangeAreaSet;
begin
	// get all the interchange areas that have been defined for this terminal
	create set transient;
	
	type := app.myRoot.allTerminalAreaTypes [TA_TYPE_YARD_INTERCHANGE];
	
	type.getAreasForTerminal (set, self.myTerminal);
	
	list := self.mulICArea;
	
	list.setTabIndex;
	list.setupControl(app.getErrorString (Interchange_areas), set, YRD_ICAreaMaint::displayEntryICArea.name);
	
	list.multiSelect				:= ListBox.MultiSelect_Extended;
	list.myAvailableListBox.sorted 	:= true;
	list.mySelectedListBox.sorted	:= false;
	
	list.setVisibleButtons (false, false, false);
epilog
	delete set;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTerminalAreaCombo" id="9ae7ab4a-1a6a-44df-90ee-e72ebc79886d">
        <source>loadTerminalAreaCombo()protected;
// ---------------------------------------------------------------------------
// Created:     26 May 2010 by cnwcs5
// Purpose:     Load combo with all terminal areas that can hace interchange areas set up
//				for them
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	type	:CM_TerminalAreaType;
	set		:CM_TerminalAreaSet;
	area		:CM_TerminalArea;
	combo		:CMUI_ComboBox;
	terminal	:CM_Terminal;
begin
	combo 		:= self.cmbTerminalArea;
	terminal	:= self.myTerminal;
	
	create set transient;
	// get all the terminal areas for our terminal
	foreach type in app.myRoot.allTerminalAreaTypes do
		if not type.canAssociateInterchangeAreas or
			not type.isUserMaintainable(terminal) then
			continue;
		endif;
		type.getAreasForTerminal (set, terminal);
	endforeach;
	// add areas into the combo
	foreach area in set do
		combo.addItemObject (area.id, area);
	endforeach;
	// select first entry inthe list
	if combo.listCount &gt; 0 then
		combo.listIndex := 1;
		
		self.showTerminalArea;
	endif;
epilog
	delete set;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="onTerminalAreaChange" id="d697d872-cdb1-405c-9753-e1afeef125ec">
        <updating/>
        <source>onTerminalAreaChange()updating, protected;
// ---------------------------------------------------------------------------
// Created:     26 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	combo	:CMUI_ComboBox;
	result	:Integer;
begin
	if self.isFormChanged then 
		result := app.msgBox(app.getErrorString(QueryRowChange),  
								app.getErrorString(Warning), MsgBox_Yes_No_Cancel + MsgBox_Question_Mark_Icon);
		
		if result = MsgBox_Return_Cancel then
			// stop now
			return;
		elseif result = MsgBox_Return_No then
			// drop through
		elseif result = MsgBox_Return_Yes then
			// save the existing item, if successful then move to the item;
			if not self.doSave() then
				return;
			endif;
		endif;		
	endif;
	
	self.showTerminalArea;
	
	self.setFormChanged (false, null, self.btnSave, null, null);
	self.resetFirstChangeFlag;
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setFormChanged" id="a5df5d76-0e19-45d9-a22c-9c6d23f33e68">
        <updating/>
        <source>setFormChanged(_value: Boolean; bNew: Button input; bUpdate: Button input; bDelete: Button input; bCancel: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     26 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_value, bNew, bUpdate, bDelete, bCancel);

	btnSaveClose.enabled := btnSave.enabled;
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
        <Parameter name="bNew" type="Button" usage="input"/>
        <Parameter name="bUpdate" type="Button" usage="input"/>
        <Parameter name="bDelete" type="Button" usage="input"/>
        <Parameter name="bCancel" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="31be3688-a052-47db-ac6f-2691c865f280">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     26 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
		
begin
	inheritMethod();
	
	self.initICAreaList;
	self.loadTerminalAreaCombo;
	
	self.btnOk.visible		:= false;
	self.btnCancel.caption	:= app.getErrorString (Close);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showTerminalArea" id="ae45f468-ff91-43d4-bd6d-0cb5704de8b4">
        <source>showTerminalArea()protected;
// ---------------------------------------------------------------------------
// Created:     26 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	area	:CM_TerminalArea;
begin
	area := self.cmbTerminalArea.listObject.CM_TerminalArea;
	
	if area = null then
		self.mulICArea.setSelected (null);
		return;
	endif;
	
	self.mulICArea.setSelected (area.allAssociatedInterchangeAreas);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="4dcfa9fe-5553-4b8a-b2bc-b72746c04761">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0015092, locale);
	btnSave.translateCaption(Xlat_0015093, locale);
	btnSaveClose.translateCaption(Xlat_0015094, locale);
	lblTerminalArea.translateCaption(Xlat_0015095, locale);
end;</source>
    </JadeMethod>
</GUIClass>
