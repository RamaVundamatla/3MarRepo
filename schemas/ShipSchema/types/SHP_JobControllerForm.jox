    <JadeMethod name="queryUnload" id="486fea98-7430-4bdd-8173-99de690acb7f">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
02 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self.myJobController &lt;&gt; null then
		if self.myJobController.hasChanged then
			if app.msgBox("You have unsaved changes. Are you sure you want to leave without saving?","Unsaved Changes", MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) &lt;&gt; MB_YES then
				cancel:=1;
			else
				cancel:=0;
			endif;
		endif;
	
	endif;
	return;

epilog

end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="resetJobMenuItems" id="ee5d2a60-40b7-4aff-ba75-459f2a47aaf1">
        <source>resetJobMenuItems();
/*

Purpose:			


Return Value:		


Date		Who		Reason
27 June 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.mnuJobMaintenance.visible:=false;
	self.allJobContMenuItems.purge;
	self.mnuShowCraneInJobOps.visible := false;
	self.mnuDelay.visible:=false;
	self.mnuDelayAdd.visible:=false;
	self.mnuDelayEdit.visible:=false;
	self.mnuEndDelay.visible:=false;	
	self.mnShowMain.visible:=self.windowState = Form.WindowState_Normal;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFormCaption" id="0cf91919-cb03-4811-a8ce-9178f65a250c">
        <updating/>
        <source>setFormCaption() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
08 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	formString,
	naviString : String;
begin
	if self.myVoyage &lt;&gt; null then
		naviString:=self.myVoyage.getDisplayDetails(false);
		formString:=app.getErrorString(Ship_job_controller) &amp; " " &amp; naviString;
	else
		formString:=app.getErrorString(Ship_job_controller);
		naviString:=app.getErrorString(Ship_job_controller);
	endif;
	self.setCaption(formString);
	self.setNavigatorHeading(naviString);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setSailingTimes" id="08097501-49a2-4517-b8a7-e93dc3dd54f3">
        <source>setSailingTimes();
/*

Purpose:			


Return Value:		


Date		Who		Reason
08 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.lblSailingTime.caption:=self.myVoyage.getDisplayDetails(false) &amp; "   Departure Target Date/Time: ";
	if  self.myVoyage.departTargetDT &lt;&gt; null then
		self.lblSailingTime.caption:=self.lblSailingTime.caption &amp; self.systemToLocalTime(self.myVoyage.departTargetDT).reportDisplay;	// 11/5/16 cnwmp6 TFS 488 - Multi timezone support
	endif;
	self.lblSailingTime.caption:=self.lblSailingTime.caption &amp; "   Estimated Completion Date/Time: " &amp; self.systemToLocalTime(self.myJobController.voyageEndTime).reportDisplay;	// 11/5/16 cnwmp6 TFS 488 - Multi timezone support

epilog

end;</source>
    </JadeMethod>
