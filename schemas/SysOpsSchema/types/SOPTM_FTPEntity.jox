    <JadeMethod name="setControlsForAddEdit" id="ecf01441-2f1b-48e6-b80e-683fd300ad37">
        <updating/>
        <source>setControlsForAddEdit() updating;
//
// CCMS 1143 cnwrs1 10 Aug 2010
//
vars
	theForm : SOP_TableMaintForm;
	entTableRow	: EntTableRow;
	entTableDef	: EntTableDef;
begin
   	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	entTableDef := app.myController.getEntTableDef(ETDef_FTPEntityMaint);
	
	foreach entTableRow in entTableDef.allEntTableRows do
		theForm.tblInput1.enableRowByName(entTableRow.name);
	endforeach;
	
	if theForm.mode = theForm.Mode_Add then 
		theForm.tblInput1.clearValues;
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.tblInput1.gotFocus(theForm.tblInput1);		
	else
		self.showThumbnail(theForm.myCurrentObject.CM_FTPEntity);
	endif;
    theForm.tblInput1.cnEcResizeContents;
end;
</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="f68f038a-6f59-4b19-a807-eca229e07643">
        <updating/>
        <source>setupThumbnailDetails() updating;
//
// CCMS 1143 cnwrs1 10 Aug 2010
//
//22 May 2013	cnwrs1	Par 31483 Ftp connect not always connecting
vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_FTPEntityTbl);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Id, false);

	theForm.txtBox01.passwordField := true;

	theForm.shtTblInput1.caption := 'FTP Entity Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_FTPEntityMaint);
	theForm.shtTblInput1.visible := true;
end;
</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="e89f207b-36e2-4bfc-9050-91735ac6fa81">
        <updating/>
        <source>showThumbnail(_ftpEntity: CM_FTPEntity) updating;
//
// CCMS 1143 cnwrs1 10 Aug 2010
//
//22 May 2013	cnwrs1	Par 31483 Ftp connect not always connecting
vars
	theForm : SOP_TableMaintForm;
	entTableDef	: EntTableDef;
	entTableRow	: EntTableRow;
begin
  	theForm := self.myForm;
	theForm.tblInput1.clearValues;
	entTableDef := app.myController.getEntTableDef(ETDef_FTPEntityMaint);
	foreach entTableRow in entTableDef.allEntTableRows do
		theForm.tblInput1.setValueByName(entTableRow.name, _ftpEntity.getDisplayStringForAttribute(entTableRow.name, false));
	endforeach;
	if _ftpEntity.password &lt;&gt; null then
		theForm.setEnteredPassword(_ftpEntity.password);
		theForm.tblInput1.setValueByName(ETRow_Password, '******');
	else	//25 Aug 2021	NDL	TFS 51632
		theForm.setEnteredPassword(_ftpEntity.password);
	endif;
end;
</source>
        <Parameter name="_ftpEntity" type="CM_FTPEntity"/>
    </JadeMethod>
</Class>
