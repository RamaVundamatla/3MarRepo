<Class name="CM_RemoteJobCompletionHdr" id="dd7ba46b-0cf3-4e0f-9313-658cf8bd0dda">
    <superclass name="CM_RemoteDataHdr"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Job Completion&lt;/display&gt;</text>
    <DbClassMap file="remoteDataProcessing"/>
    <PrimAttribute name="queueEntryOid" id="7e48f1ef-3ec4-49c5-b3ef-1037a04abcc9">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="taskType" id="260b859e-30d2-48c0-929a-c350dc10b070">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="doCompletionTaskUpdate" id="6b14c4cd-717e-432c-9d53-e38c40ec751c">
        <source>doCompletionTaskUpdate(_error : Integer output; _errorTxt : String output) : String protected;

vars

	queueEntry	: CM_RTQueueEntry;
	queueTask	: CM_RTQueueTask;
	
begin

	queueEntry := self.queueEntryOid.asOid.CM_RTQueueEntry;
	if queueEntry = null then
		_error := Err_QueueEntryNotFound;
		_errorTxt := app.getErrorString1(Err_QueueEntryNotFound, self.queueEntryOid);
		return null;
	endif;	
	
	foreach queueTask in queueEntry.allTasks do
		if queueTask.taskType = taskType then
			break;
		endif;
		queueTask := null;
	endforeach;
	if queueTask = null then
		_error := Err_InvalidTaskType;
		_errorTxt := app.getErrorString1(Err_InvalidTaskType, self.taskType.String);
		return null;
	endif;
	
	

	app.myTrxUA.trxUpdateQueueTaskStatus(queueTask, TASK_COMPLETE,  app.myPassport);
	if (not app.myPassport.trxCompletedOK) then
		_error 		:= Err_QueueTaskUpdate;
		_errorTxt	:= app.getErrorString1(Err_QueueTaskUpdate, null);
		return null;
	endif;

epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_error" type="Integer" usage="output"/>
        <Parameter name="_errorTxt" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMessageResponseType" id="a628ba56-f23f-4feb-928d-d7f22224053a">
        <source>getMessageResponseType(): String;

vars

begin
	
	if self.taskType =  TASK_PICKUP then
		return CM_RemoteDataManager.JOBPICKUPRSP;
	else
		return CM_RemoteDataManager.JOBCOMPLETIONRSP;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processExternal" id="b34c3367-9fce-4d53-83b9-437ee9ee7b4a">
        <updating/>
        <source>processExternal(_parseAgent: CM_RemoteParseAgent io): String updating;

vars

	err			: Integer;
	errTxt		: String;
	response	: String;
	headerCast	: CM_RemoteDataHdr;

begin

	response := inheritMethod(_parseAgent);
	if response = null then
		if _parseAgent.createJobCompletionDetail(self) then
			response := self.doCompletionTaskUpdate(err, errTxt);
			return self.doBuildMessage(self.xmlResponse(err, errTxt) &amp; response);
		endif;
		response := app.getErrorString1(Err_XML, 'Job Completion');
		return self.doBuildMessage(self.xmlResponse(Err_XML , response));
	endif;
	headerCast := self;
	return self.doBuildMessage(self.xmlDefaultResponse(headerCast, Err_XML , response));
			
end;</source>
        <Parameter name="_parseAgent" type="CM_RemoteParseAgent" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyForJobCompletionHdr" id="681ed2d4-0788-4bd6-bc2f-6df484736dae">
        <updating/>
        <source>setProxyForJobCompletionHdr(_queueEntry : String) updating;

vars

begin

	self.raiseExceptionIfNotTransient(method);
	if self.messageType = CM_RemoteDataManager.JOBPICKUPRQ then
		self.taskType := TASK_PICKUP;
	else
		self.taskType := TASK_SETDOWN;
	endif;
	self.queueEntryOid := _queueEntry;

end;</source>
        <Parameter name="_queueEntry" type="String"/>
    </JadeMethod>
</Class>
