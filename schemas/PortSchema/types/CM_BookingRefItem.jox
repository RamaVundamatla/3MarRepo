    <JadeMethod name="setCommodityWithDefaults" id="494b4821-5fee-4d5a-8025-082ff8a315f0">
        <updating/>
        <source>setCommodityWithDefaults( _commodity : String; _commodityDescription : String) updating, protected;
/*

Purpose:Does the EDI check for Terminal Defaults thing			

Parameters:			

Return Value: None, updates commodity directly

Date		Who		Reason
30 December 2014	cnwgb1	Initial creation for PAR 33710
//04/07/2018	jlgrh7 TFS #39128 ADP - FW: DL for Rotation 1801002901 in production
*/

vars
    tmpCommodity : CM_Commodity;
    terminal : CM_Terminal;
begin
    self.commodity := _commodity;
	if _commodity &lt;&gt; null then
		tmpCommodity := app.myRoot.allCommodities[_commodity.toUpper()];			//+TFS39128 commodity table's codes are all upper case
		if tmpCommodity = null then
			app.raiseCMWarning1(ERR_INVALID_COMMODITY, _commodity, app.getString(Commodity), self, null); 
            terminal := app.getMyTerminalDO_NOT_USE();
            if false then
                self.commodity := terminal.getDefaultEmptyCommodity();
            elseif not self.allTIHazards.isEmpty then
                self.commodity := terminal.getConfig(DefHazCommodity).String;
            elseif self.tempCelcius &lt;&gt; NULL_TEMPERATURE then
                self.commodity := terminal.getConfig(DefReeferComdty).String;			
            else
                self.commodity := terminal.getConfig(DefCommodity).String;
            endif;
        endif;
    endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_commodityDescription" type="String"/>
    </JadeMethod>
