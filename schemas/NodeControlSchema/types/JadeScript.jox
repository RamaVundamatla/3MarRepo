    <JadeMethod name="jhpFileCheck" id="5b7f5fa9-f245-4664-a609-0336733d2719">
        <source>jhpFileCheck();
vars
	s,t,u,v,folderName,folderMask,include,exclude:String;
	i,j,k,l,starttime,tottime,subcount,totcount:Integer;
	presentationFileSystem,foundSection:Boolean;
	ts,tsStart,tsEnd:TimeStamp;
	tt,tt2,tt3:Time;
	f,g:File;
	fn:FileNode;
	ff:FileFolder;
begin
	create f;
	create g;
	f.kind := File.Kind_Unknown_Text;	// 4/3/16 cnwmp6 PAR 36286 unicode version
	g.mode := File.Mode_Output;	// 4/3/16 cnwmp6 PAR 36286 unicode version
	f.fileName:="C:\a\Jade pars\44755\20080109\jommon.log";
	g.fileName:="C:\a\Jade pars\44755\20080109\jommon long locks.log";
//	presentationFileSystem:=true;
//	f.usePresentationFileSystem:=presentationFileSystem;
	while not f.endOfFile do
		s:=f.readLine; k:=k+1;
		if s.length &lt; 174 then continue; endif;
		/*if s[25:3] = " l " and s[170:4] = "00:0" then
			write s[170:8];
		endif;
		if k &gt; 6000 then break; endif;*/
		if s[25:3] = " l " and s[170:4] = "00:0" and s[174] &lt;&gt; "0" then
			g.writeLine(s);
		endif;
	endwhile;
epilog
	delete f;
	delete g;
	delete ff;
end;</source>
    </JadeMethod>
