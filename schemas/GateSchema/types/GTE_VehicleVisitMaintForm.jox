    <JadeMethod name="handleNotification" id="9d5e98b6-f1f5-407a-82fe-eb7f51ffb5bc">
        <source>handleNotification( eventType: Integer; theObject: Object; eventTag: Integer );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

	vvrd : CM_VehicleVisitRecordDetail;
	msg : String;
	invalid : Boolean;

begin

	if theObject = null or not theObject.isKindOf( CM_VehicleVisitRecordDetail ) then
		return;
	endif;
	
	vvrd := theObject.CM_VehicleVisitRecordDetail;
	
	on Exception do app.handleDeletedObject( exception, vvrd, invalid );
	
	if vvrd.myVehicleVisitRecord &lt;&gt; self.myVehicleVisitRecord then
		return;
	endif;
	
	if invalid then
		return;
	endif;
	
	msg := app.getErrorString1( Anoth_user_updat_this_curre_da, app.getErrorString(Vehicle_visit_record) );
	app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only );
	
	self.populateTblCargo();

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
