    <JadeMethod name="doCmbBUsBuild" id="e07caf46-4a66-4058-b22a-149eb03b0d81">
        <source>doCmbBUsBuild();
/*
Purpose:			
Date		Who		Reason
12 February 2015	cnwab1	Initial creation
*/

vars
	aTerm : CM_Terminal;
	combobox : ComboBox;
	def,
	co		: CM_Bank;
begin


	combobox := self.myForm.cmbBUs;

	combobox.clear;

	if self.myForm.myCurrentObject &lt;&gt; null then
		aTerm := self.myForm.myCurrentObject.CM_Terminal;
	elseif self.myForm.myProxyObject &lt;&gt; null then
		aTerm := self.myForm.myProxyObject.CM_Terminal;
	endif;
	
	if aTerm =  null then
		return;
	endif;
	
	def := aTerm.getDefaultCompanyBank();	
	foreach co in aTerm.companies do
		if co.isBusinessUnit and not co.isSuspended then
		
			combobox.addItem(co.mailingName);
			combobox.itemObject[combobox.newIndex] := co;
			if co = def then
				combobox.listIndex := combobox.newIndex;
			endif;
		endif;
	endforeach;

	if combobox.listIndex = -1 and combobox.listCount &gt; 0 then
		combobox.listIndex := 1;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbDamageSeverityBuild" id="6fe9d4c8-451b-4b59-9486-9ff414e9c074">
        <source>doCmbDamageSeverityBuild(_currentSetting : CM_DamageSeverity);
/*
Purpose:	 // ### TFS BUG 58862 27JUN2023 NAVAB1		

Date		Who		Reason
27JUN2023	NAVAB1	BUG 58862
*/

vars

	aTerm : CM_Terminal;
	combobox : ComboBox;
	tmpDamSeverity : CM_DamageSeverity;
	index : Integer;
	
begin

	combobox := self.myForm.cmbDamageSeverity;
	combobox.clear;

	if self.myForm.myCurrentObject &lt;&gt; null then
		aTerm := self.myForm.myCurrentObject.CM_Terminal;
	elseif self.myForm.myProxyObject &lt;&gt; null then
		aTerm := self.myForm.myProxyObject.CM_Terminal;
	endif; 
	
	if aTerm =  null then
		return;
	endif;
	
	foreach tmpDamSeverity in aTerm.allDamageSeverities discreteLock do
		index := combobox.addItem( tmpDamSeverity.description.trimBlankCharacters );
		combobox.itemObject[index] := tmpDamSeverity;
	endforeach;
	
	combobox.listIndex := combobox.findObject( _currentSetting );

epilog
	
end;</source>
        <Parameter name="_currentSetting" type="CM_DamageSeverity"/>
    </JadeMethod>
    <JadeMethod name="doCmbReeferOptionsBuild" id="ba1ac8d8-bb14-441c-8c6b-eecc586f1a65">
        <source>doCmbReeferOptionsBuild();
/*
Purpose:	PAR 33572		
Date				Who			Reason
FEBRUARY 2015		CNWAB1		Initial creation
*/

vars

begin

	self.myForm.cmbReeferOptions.clear;
	self.myForm.cmbReeferOptions.addItem(app.getErrorString(Charge_temperatur_readings));
	self.myForm.cmbReeferOptions.addItem(app.getErrorString(Charge_only_first_temper_readi));

end;</source>
