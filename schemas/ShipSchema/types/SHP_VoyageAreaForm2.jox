    <JadeMethod name="chkPrintWorked_click" id="3b9263f7-6d69-4589-afdd-db3e9d7fa098">
        <controlMethod name="CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkPrintWorked_click(checkbox: CheckBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 February 2018	jlgndl1	Initial creation	TFS 36914

*/

vars

begin

	if chkPrintWorked.value = true then
		self.grpPrintWorked.enabled := true;
		if self.optPrintLoad.value = false
		and self.optPrintDischarge.value = false
		and self.optPrintLoadAndDis.value = false
		then
			self.optPrintLoadAndDis.value := true;
		endif;
		
		self.grpPrintWorkedColour.enabled := true;
	else
		self.grpPrintWorked.enabled := false;
		self.optPrintLoad.value := false;
		self.optPrintDischarge.value := false;
		self.optPrintLoadAndDis.value := false;
		self.grpPrintWorkedColour.enabled := false;
	endif;

epilog

end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
