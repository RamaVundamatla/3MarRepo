    <JadeMethod name="doMnuSendToReportInvoice" id="3348745a-7d99-49ae-bc1d-2c9a53f1c602">
        <updating/>
        <source>doMnuSendToReportInvoice(_selectedOnly : Boolean) updating;
//----------------------------------------------------------------------
// Created by 	cnwjre1
// Date 		Sept 2010 CCMS 1155 par 23583 Invoice rate reporting
vars
	objArray : ObjectArray;
begin
	inheritMethod(_selectedOnly);
	
	// Report writer throws exceptions when in transaction state.
	// Added flag to app to ignore any transaction calls that are not in 
	// the trx layer (Eg, CM_Charge.evaluateRate).
	app.isReportWriter := true;
	
	create objArray transient;
	
	self.getRatesForReport(objArray, _selectedOnly);
	
	self.doSendToReport(objArray);
epilog
	if objArray &lt;&gt; null then
		objArray.purge;		// contains transients created for reporting
	endif;
	delete objArray;
	app.isReportWriter := false;
end;</source>
        <Parameter name="_selectedOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="c22741cf-e9fe-4b99-ad83-ca5ec7fd3f35">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:		23 February 2010 cnwjo3
//
// Purpose:		par 21915.  Each form should implement doNotableClear without an inheritMethod();
//
vars
	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		/*if anObject.isKindOf(____OBJECT TYPE____) then
			endNotification(anObject, self.myTerminal.getTerminalEvent(____EVENT_NAME_____));
			removedNotification := removedNotification + 1;
		endif;*/
	endforeach;

	validateNotificationRemoval(removedNotification,self.allNotableObjects.size);
	
	self.allNotableObjects.clear;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="44705ae4-e054-4399-8456-3b3329db8dbf">
        <updating/>
        <source>doPrint() updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	dateStr,mess, head : String;
	debtor : CM_DebtorNode;
	shippingLine : CM_ShippingLine;
	bank : CM_Bank;
begin
	bank := self.myCurrentBank;
	dateStr := self.txtDateDebtor.text;			//07.06.2018 cnwma1 ChangeRequest #38953
	if mode = self.Mode_Debtor then
		if self.allSelectedDebtors.size = 1 then
			debtor := self.allSelectedDebtors.first.CM_DebtorNode;
		endif;
		if debtor = null then
			mess := "Printing Rate Table for Selected Debtors";
		else
			mess := "Printing Rate Table for Debtor " &amp; debtor.name;
		endif;
	else
		shippingLine := self.cmbTrades.listObject.CM_ShippingLine;
		if shippingLine = null then 
			return; // null ref error was being caused print when button clicked but no data. hjg 01/03/05
		endif;
		mess :=  "Printing Rate Table for ShippingLine " &amp; shippingLine.code;
	endif;



	if mode = self.Mode_Debtor then
		if debtor = null then
			head := bank.mailingName &amp; " Rate Table for selected debtors as at " &amp; dateStr;
		elseif debtor.isKindOf(CM_RootDebtorGroup) then
			head := bank.mailingName &amp; " Rate Table as at " &amp; dateStr;
		elseif debtor.isKindOf(CM_DebtorGroup) then
			head := bank.mailingName &amp; " Rate Table for Group " &amp; 
				debtor.name &amp;  " as at " &amp; dateStr;
		elseif debtor.isKindOf(CM_Debtor) then
			head := bank.mailingName &amp; " Rate Table for Debtor " &amp; 
				debtor.name &amp;  " as at " &amp; dateStr;
		endif;
	else
		head := bank.mailingName &amp; " Rate Table for Shipping Line " &amp; 
			shippingLine.code &amp;  " as at " &amp; dateStr;
	endif;

	self.doTblDataPrint(mess,head,"Rate Table");

end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="c7e50dc8-0da1-4f67-bd6e-a6d217826e00">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 27/03/2018	jlgdap1		TFS 37794 PEL1 Vessel Rates
// 07 Jun 2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
vars

begin
	self.tblInfo.rows := 0;		// July 2010 cnwjre1	24018 show macro info for rates - clear any prior entry on query
	self.colouredRow := 0;

	if  self.fldQuery.topSheet = self.shtQuery1 then
		self.doQueryDebtor();
	elseif self.fldQuery.topSheet = self.shtQuery3 then		// TFS 37794
		self.doQueryVessel();								// TFS 37794
	elseif self.fldQuery.topSheet = self.shtQuery4 then		 //07.06.2018 cnwma1 ChangeRequest #38953
		self.doQueryVesselType();
	elseif self.fldQuery.topSheet = self.shtQuery5 then		 //07.06.2018 cnwma1 ChangeRequest #38953
		self.doQueryVisitType();
	elseif self.fldQuery.topSheet = self.shtQuery6 then		 //07.06.2018 cnwma1 ChangeRequest #38953
		self.doQueryBerth();
	else
		self.doQueryShippingLine();
	endif;

	self.frmQuery.visible := not (self.tblData.columns &gt; self.tblData.fixedColumns);
epilog
	self.internalQuery := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryBerth" id="68c5af6e-ffed-45a7-a64a-b59c17920ac0">
        <updating/>
        <source>doQueryBerth()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018 cnwma1	ChangeRequest 38953: PEL1 - Berth Rates, visit Type Rates, Visit Types

*/
constants
	MaxString = 500;
	
vars
	obj : Object;
	berth : HMS_Berth;
	services : CM_ObjectArray;
	dynaDict : DynaDictionary;
	service : CM_Service;
	tsSystem, tsLocal : TimeStamp;
	column : Integer;
	total : Integer;
	count : Integer;
	pd : CMS_Progress;
	i : Integer;
	j : Integer;
	ls : Boolean;
	key : String;
	text : String;
	rateTable : Table;
	bank : CM_Bank;
	savedChargedEffTS : TimeStamp;
	
begin
	savedChargedEffTS := app.getChargeRateEffectiveDate();
	app.setChargeRateEffectiveDate( self.effectiveDate.TimeStamp );
	
	self.allSelectedBerths.clear;
	self.allSelectedBerthServices.clear;
	
	self.msgbBerths.getSelected(self.allSelectedBerths);
	if self.allSelectedBerths.size = 0 then
		if not self.internalQuery then
			app.msgBox("Please choose a Berth Type to query", "Query Error", MsgBox_OK_Only);
		endif;
		return;
	endif;
	
	create services transient;
	self.msgbBerthServ.getSelected(services);
	if services.size = 0 then
		if not self.internalQuery then
			app.msgBox("Please choose a Service to query", "Query Error", MsgBox_OK_Only);
		endif;
		return;
	endif;
	
	// don't set the mode until actually doing the query otherwise other code goes astray
	self.mode := self.Mode_Berth;
	
	// show services either by service name or group then service name
	create dynaDict transient;
	dynaDict.setMembership(CM_Object);				// use for both debtors and services
	dynaDict.addExternalKey(String, MaxString, false, false);	// 500 byte String, ascending, case sensitive
	dynaDict.endKeys(true);							// duplicates true (mainly in case of MaxString length exceeded)

	foreach obj in services do
		service := obj.CM_Service;
		if self.servicesByGroup then
			key := service.getFullName()[1:MaxString];
		else
			key := service.name;
		endif;
		dynaDict.putAtKey(key, service);
	endforeach;
	self.allSelectedBerthServices.clear;
	foreach obj in dynaDict do
		self.allSelectedBerthServices.add(obj);
	endforeach;
	
	rateTable := self.tblData;
	bank := self.myCurrentBank;
	text := "Rate Table - ";
	if self.allSelectedBerths.size = 1 then
		berth := self.allSelectedBerths.first.HMS_Berth;
		text := text &amp; self.displayBerth(berth);
	else
		text := text &amp; self.allSelectedBerths.size.String &amp; " selected berth";
	endif;
	self.setCaption(text);
	self.setNavigatorHeading(self.caption);
	//self.lblDate.caption := self.txtDateBerth.text;			//07.06.2018 cnwma1 ChangeRequest #38953
	self.lblDate.caption := self.txtDateDebtor.text;             //07.06.2018 cnwma1 ChangeRequest #38953

	on CM_ProgressException do haltProgress(exception, true, ls);

	create pd;
	pd.setBackground(self.backColor);
	if not self.internalQuery then
		pd.show;
	endif;
	pd.setAction("Loading Rates...");

	app.cmsBeginLoad(ls);

	rateTable.columns := 1;
	rateTable.rows := 1;
	tsLocal.setDate(self.txtDateDebtor.text.asDate());    //07.06.2018 cnwma1 ChangeRequest #38953
	tsSystem:= self.localToSystemTime(tsLocal);
	self.effectiveDate := self.txtDateDebtor.getDate();    //07.06.2018 cnwma1 ChangeRequest #38953
	
	total := self.allSelectedBerths.size;
	rateTable.fixedRows := 1;
	rateTable.fixedColumns := 1;
	rateTable.columns := total + rateTable.fixedColumns;
	
	rateTable.row := 1;
	j := rateTable.fixedRows;
	rateTable.column := 1;
	rateTable.row := j;
	if self.servicesByGroup then
		rateTable.text := "Services by Group / Berths";
	else
		rateTable.text := "Services / Berths";
	endif;
	foreach obj in self.allSelectedBerthServices do
		service := obj.CM_Service;
		rateTable.column := 1;
		if self.servicesByGroup then
			text := service.getFullName();
		else
			text := service.name;
		endif;
		rateTable.CM_DataTable.addItemObject(service, text);
	endforeach;

	column := 1;
	foreach obj in self.allSelectedBerths do
		berth := obj.HMS_Berth;
		count := 1;
		berth.getTotalRateCount(count);
		pd.progress.partsInJob := count;
		column := column + 1;
		self.loadRateTableByColumnBerths(berth, bank, 1, rateTable, column, tsSystem, pd);
	endforeach;
	
	rateTable.row := 1;
	rateTable.column := 1;

	self.setTableAlignment();

	self.setEnableObjects();
	rateTable.accessColumn(2).width := 100;
	foreach i in 1 to rateTable.fixedRows do
		rateTable.accessRow(i).backColor := self.colorHeadingColumn;
	endforeach;
	foreach i in rateTable.fixedRows + 1 to rateTable.rows do
		rateTable.accessRow(i).backColor := self.colorControlBack;
	endforeach;
	
	rateTable.accessMode := Table.AccessMode_Cell;
	
epilog
	app.cmsEndLoad(ls);
	delete pd;
	delete services;
	delete dynaDict;
	app.setChargeRateEffectiveDate(savedChargedEffTS);
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryDebtor" id="64b42e5d-58c4-4eb5-ab04-ba3229760e71">
        <updating/>
        <source>doQueryDebtor() updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//				July 2010 cnwjre1 24019 add option to show services by group, 24052 add multi-selection
//										of debtors and services
// Purpose:		query of rates by debtor and service
//
// ---------------------------------------------------------------------------
// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
constants
	MaxString = 500;
vars
	obj:			  Object;
	dn:               CM_DebtorNode;
	debtorRoot:		  CM_DebtorNode;
	child:			  CM_DebtorNode;
	children:		  CM_DebtorNodeByNameDict;
	services:		  CM_ObjectArray;
	allChildren:	  CM_ObjectArray;
	dynaDict:		  DynaDictionary;
	service:		  CM_Service;
	tsSystem,tsLocal: TimeStamp;
	column:           Integer;
	total:			  Integer;
	count:            Integer;
	pd:               CMS_Progress;
	excessColumns:	  Integer;
	excessRows:       Integer;
	i:                Integer;
	j:				  Integer;
	level:			  Integer;
	ls			: Boolean;
	key:		 String;
	text:		 String;
	rateTable : Table;
	bank : CM_Bank;
	savedChargedEffTS : TimeStamp;
begin

	//19 Sep 2012	NDL	Par 30375
	savedChargedEffTS := app.getChargeRateEffectiveDate();
	app.setChargeRateEffectiveDate( self.effectiveDate.TimeStamp );
	
	
	// 24052 July 2010 multi-select of debtor and service
	self.allSelectedDebtors.clear;
	self.allNonChildDebtors.clear;
	
	self.msgbDebtors.getSelected(self.allSelectedDebtors);
	
	if self.allSelectedDebtors.size = 0 then
		if not self.internalQuery then
			app.msgBox("Please choose a debtor to query","Query Error",MsgBox_OK_Only);
		endif;
		return;
	endif;
	// 24052 multi-service selection
	create services transient;
	self.msgbServices.getSelected(services);
	if services.size = 0 then
		if not self.internalQuery then
			app.msgBox("Please choose a service to query","Query Error",MsgBox_OK_Only);
		endif;
		return;
	endif;
	// don't set the mode until actually doing the query otherwise other code goes astray
	self.mode := self.Mode_Debtor;

	// 24019 July 2010 show services either by service name or group then service name
	create dynaDict transient;
	dynaDict.setMembership(CM_Object);				// use for both debtors and services
	dynaDict.addExternalKey(String, MaxString, false, false);	// 500 byte String, ascending, case sensitive
	dynaDict.endKeys(true);							// duplicates true (mainly in case of MaxString length exceeded)

	foreach obj in services do
		service := obj.CM_Service;
		if self.servicesByGroup then
			key := service.getFullName()[1:MaxString];
		else
			key := service.name;
		endif;
		dynaDict.putAtKey(key, service);
	endforeach;
	self.allSelectedServices.clear;
	foreach obj in dynaDict do
		self.allSelectedServices.add(obj);
	endforeach;
	
	// 24052 multi-select of debtors may include children of other selections, filter these out as they will
	// 		be included with their parent debtors.  Don't show the default debtor with children, 
	// 			to allow selection of debtors to show with it.
	create children transient;
	create allChildren transient;
	foreach obj in self.allSelectedDebtors do
		dn := obj.CM_DebtorNode;
		if dn.isRootDebtorGroup then
			debtorRoot := dn;
			continue;
		endif;
		children.clear;
		level := 1;
		dn.getChildren(children, level);
		foreach child in children do
			if not allChildren.includes(child) then
				allChildren.add(child);
			endif;
		endforeach;
	endforeach;
	// write debtors to dynaDict to sort on name, excluding children of selected debtors
	// if the root debtor (default entry) is present, sort it to the start so it appears in the first column
	dynaDict.clear();
	foreach obj in self.allSelectedDebtors do
		dn := obj.CM_DebtorNode;
		key := dn.name;
		if dn.isRootDebtorGroup then
			key := " ";
		endif;
		if not allChildren.includes(dn) then
			dynaDict.putAtKey(key, dn);
		endif;
	endforeach;

	foreach obj in dynaDict do
		dn := obj.CM_DebtorNode;
		self.allNonChildDebtors.add(dn);
	endforeach;
	
	rateTable := self.tblData;
	bank := self.myCurrentBank;
	text := bank.code &amp; " Rate Table - ";
	if self.allSelectedDebtors.size = 1 then
		dn := self.allSelectedDebtors.first.CM_DebtorNode;
		text := text &amp; dn.getListName();
	else
		text := text &amp; self.allSelectedDebtors.size.String &amp; " selected debtors";
	endif;
	text := text &amp; " " &amp; self.txtDateDebtor.text &amp; " " &amp; bank.code; // 	TFS 2682
	self.setCaption(text);
	self.setNavigatorHeading(self.caption);
	self.lblDate.caption := self.txtDateDebtor.text;
	
	on CM_ProgressException do haltProgress(exception, true, ls);

	create pd;
	pd.setBackground(self.backColor);
	if not self.internalQuery then
		pd.show;
	endif;
	pd.setAction("Loading Rates...");

	app.cmsBeginLoad(ls);

	rateTable.columns := 1;
	rateTable.rows := 1;
	tsLocal.setDate(self.txtDateDebtor.getDate());	
	tsSystem := self.localToSystemTime(tsLocal);// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.effectiveDate := self.txtDateDebtor.getDate();
	
	// 24052 multi-select of debtor and service, get column and fixed row counts - children of root debtor are not automaticallly shown
	total := 0;
	foreach obj in self.allNonChildDebtors do
		dn := obj.CM_DebtorNode;
		count := 0;
		if not dn.isRootDebtorGroup then		
			excessRows := excessRows.max(dn.getMaxDepth - 1);
			dn.getTotalCount(count);
		endif;
		excessColumns := excessColumns + count;
		total := total + 1;
	endforeach;

	i := 1;
	while i &lt;= excessRows do
		rateTable.addItemAt("", 1);
		i := i + 1;
	endwhile;
	rateTable.fixedRows := excessRows + 1;
	rateTable.fixedColumns := 1;
	rateTable.columns := total + excessColumns + rateTable.fixedColumns;

	rateTable.row := 1;
	
	// create rows with the selected services
	j := rateTable.fixedRows;
	rateTable.column := 1;
	rateTable.row := j;
	if self.servicesByGroup then
		rateTable.text := "Services by Group / Debtors";
	else
		rateTable.text := "Services / Debtors";
	endif;
	foreach obj in self.allSelectedServices do
		service := obj.CM_Service;
		rateTable.column := 1;
		if self.servicesByGroup then
			text := service.getFullName();
		else
			text := service.name;
		endif;
		rateTable.CM_DataTable.addItemObject(service, text);
	endforeach;
	
	column := 1;
	foreach obj in self.allNonChildDebtors do
		dn := obj.CM_DebtorNode;
		count := 1;
		dn.getTotalCount(count);
		pd.progress.partsInJob := count;
		column := column + 1;
		self.loadRateTableByColumnDebtor(dn, bank, 1, rateTable, column, tsSystem, pd);

	endforeach;

	rateTable.row := 1;
	rateTable.column := 1;

	self.setTableAlignment();

	self.setEnableObjects();
	rateTable.accessColumn(2).width := 100;
	
	foreach i in 1 to rateTable.fixedRows do
		rateTable.accessRow(i).backColor := self.colorHeadingColumn;
	endforeach;
	foreach i in rateTable.fixedRows + 1 to rateTable.rows do
		rateTable.accessRow(i).backColor := self.colorControlBack;
	endforeach;

	rateTable.accessMode := Table.AccessMode_Cell;

epilog
	app.cmsEndLoad(ls);
	delete pd;
	delete children;
	delete allChildren;
	delete services;
	delete dynaDict;
	app.setChargeRateEffectiveDate( savedChargedEffTS );	//19 Sep 2012	NDL	Par 30375
end;</source>
    </JadeMethod>
    <JadeMethod name="doQuerySheetChange" id="0c27f10a-c56e-4558-be5c-2d3344cf6b16">
        <updating/>
        <source>doQuerySheetChange() updating;
//
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------
// 27/03/20018	jlgdap1		TFS 37794 PEL1 Vessel Rates
// 07 Jun 2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
vars

begin

	//07.06.2018 cnwma1 ChangeRequest #38953
	if self.fldQuery.topSheet = self.shtQuery2 then
		self.cmbTrades.setFocus;
	else
		self.txtDateDebtor.setFocus;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doQueryShippingLine" id="498a9911-16ac-492a-8865-2aa65e998d2c">
        <updating/>
        <source>doQueryShippingLine() updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
// ---------------------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 07 Jun 2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
vars

	tsSystem,tsLocal: TimeStamp;
	level:            Integer;
	column:           Integer;
	count:            Integer;
	pd:               CMS_Progress;
	sl:               CM_ShippingLine;
	i:                Integer;
	ls				: Boolean;

	rateTable : Table;
	bank : CM_Bank;
	savedChargedEffTS : TimeStamp;
begin
	if self.myCurrentTrade = null then
		if not self.internalQuery then
			app.msgBox("Please choose a trade to query","Query Error",MsgBox_OK_Only);
		endif;
		return;
	endif;
	
	//19 Sep 2012	NDL	Par 30375
	savedChargedEffTS := app.getChargeRateEffectiveDate();
	app.setChargeRateEffectiveDate( self.effectiveDate.TimeStamp );
	
	
	// don't set the mode until actually doing the query otherwise other code goes astray
	self.mode := self.Mode_Trade;
	
	rateTable := self.tblData;
	bank := self.myCurrentBank;
	self.setCaption("Rate Table - " &amp; self.myCurrentTrade.code &amp; " " &amp; self.txtDateDebtor.text &amp; " " &amp; bank.code);  //07.06.2018 cnwma1 ChangeRequest #38953
	self.setNavigatorHeading(self.caption);
	//self.lblDate.caption := self.txtDateTrade.text;     //07.06.2018 cnwma1 ChangeRequest #38953
	self.lblDate.caption := self.txtDateDebtor.text;       //07.06.2018 cnwma1 ChangeRequest #38953
	
	on CM_ProgressException do haltProgress(exception, true, ls);

	create pd;
	pd.setBackground(self.backColor);
	if not self.internalQuery then
		pd.show;
	endif;
	pd.setAction("Loading Rates...");

	app.cmsBeginLoad(ls);

	rateTable.columns := 1;
	rateTable.rows := 1;
	tsLocal.setDate(self.txtDateDebtor.text.asDate());		//07.06.2018 cnwma1 ChangeRequest #38953
	tsSystem:= self.localToSystemTime(tsLocal);// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support	
	self.effectiveDate := self.txtDateDebtor.getDate();

	rateTable.column := 1;
	rateTable.row := 1;
	rateTable.fixedRows := 1;

	sl := self.myCurrentTrade;
	if sl &lt;&gt; null then
		rateTable.fixedRows := 1;
		count := 1;
		sl.getTotalCount(count);
		pd.progress.partsInJob := count;
		rateTable.columns := count;
		level := 1;
		column := 2;
		rateTable.accessMode := Table.AccessMode_Cell;
		self.loadRateTableByColumnSL(sl,bank, level, rateTable, column, tsSystem, pd);
	endif;

	rateTable.row := 1;
	rateTable.column := 1;

	self.setTableAlignment();

	self.setEnableObjects();
	foreach i in 1 to rateTable.fixedRows do
		rateTable.accessRow(i).backColor := self.colorHeadingColumn;
	endforeach;

epilog
	app.cmsEndLoad(ls);
	delete pd;
	app.setChargeRateEffectiveDate( savedChargedEffTS );	//19 Sep 2012	NDL	Par 30375

end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryVessel" id="8083bd8d-d2e0-44b3-8d12-f6ed73b6aa09">
        <updating/>
        <source>doQueryVessel() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/03/2018	jlgdap1		Initial creation TFS 37794 PEL1 Vessel Rates
//
constants
	MaxString = 500;
	
vars
	obj : Object;
	vessel : CM_Vessel;
	services : CM_ObjectArray;
	dynaDict : DynaDictionary;
	service : CM_Service;
	tsSystem, tsLocal : TimeStamp;
	column : Integer;
	total : Integer;
	count : Integer;
	pd : CMS_Progress;
	i : Integer;
	j : Integer;
	ls : Boolean;
	key : String;
	text : String;
	rateTable : Table;
	bank : CM_Bank;
	savedChargedEffTS : TimeStamp;
	
begin
	savedChargedEffTS := app.getChargeRateEffectiveDate();
	app.setChargeRateEffectiveDate( self.effectiveDate.TimeStamp );
	
	self.allSelectedVessels.clear;
	self.allSelectedVesselServices.clear;
	
	self.msgbVessels.getSelected(self.allSelectedVessels);
	if self.allSelectedVessels.size = 0 then
		if not self.internalQuery then
			app.msgBox("Please choose a Vessel to query", "Query Error", MsgBox_OK_Only);
		endif;
		return;
	endif;
	
	create services transient;
	self.msgbVessServ.getSelected(services);
	if services.size = 0 then
		if not self.internalQuery then
			app.msgBox("Please choose a Service to query", "Query Error", MsgBox_OK_Only);
		endif;
		return;
	endif;
	
	// don't set the mode until actually doing the query otherwise other code goes astray
	self.mode := self.Mode_Vessel;
	
	// show services either by service name or group then service name
	create dynaDict transient;
	dynaDict.setMembership(CM_Object);				// use for both debtors and services
	dynaDict.addExternalKey(String, MaxString, false, false);	// 500 byte String, ascending, case sensitive
	dynaDict.endKeys(true);							// duplicates true (mainly in case of MaxString length exceeded)

	foreach obj in services do
		service := obj.CM_Service;
		if self.servicesByGroup then
			key := service.getFullName()[1:MaxString];
		else
			key := service.name;
		endif;
		dynaDict.putAtKey(key, service);
	endforeach;
	self.allSelectedVesselServices.clear;
	foreach obj in dynaDict do
		self.allSelectedVesselServices.add(obj);
	endforeach;
	
	rateTable := self.tblData;
	bank := self.myCurrentBank;
	text := "Rate Table - ";
	if self.allSelectedVessels.size = 1 then
		vessel := self.allSelectedVessels.first.CM_Vessel;
		text := text &amp; self.displayVessel(vessel);
	else
		text := text &amp; self.allSelectedVessels.size.String &amp; " selected Vessels";
	endif;
	self.setCaption(text);
	self.setNavigatorHeading(self.caption);
	//self.lblDate.caption := self.txtDateVessel.text;			//07.06.2018 cnwma1 ChangeRequest #38953
	self.lblDate.caption := self.txtDateDebtor.text;			//07.06.2018 cnwma1 ChangeRequest #38953

	on CM_ProgressException do haltProgress(exception, true, ls);

	create pd;
	pd.setBackground(self.backColor);
	if not self.internalQuery then
		pd.show;
	endif;
	pd.setAction("Loading Rates...");

	app.cmsBeginLoad(ls);

	rateTable.columns := 1;
	rateTable.rows := 1;
	tsLocal.setDate(self.txtDateDebtor.text.asDate());    //07.06.2018 cnwma1 ChangeRequest #38953
	tsSystem:= self.localToSystemTime(tsLocal);
	self.effectiveDate := self.txtDateDebtor.getDate();   //07.06.2018 cnwma1 ChangeRequest #38953
	
	total := self.allSelectedVessels.size;
	rateTable.fixedRows := 1;
	rateTable.fixedColumns := 1;
	rateTable.columns := total + rateTable.fixedColumns;
	
	rateTable.row := 1;
	j := rateTable.fixedRows;
	rateTable.column := 1;
	rateTable.row := j;
	if self.servicesByGroup then
		rateTable.text := "Services by Group / Vessels";
	else
		rateTable.text := "Services / Vessels";
	endif;
	foreach obj in self.allSelectedVesselServices do
		service := obj.CM_Service;
		rateTable.column := 1;
		if self.servicesByGroup then
			text := service.getFullName();
		else
			text := service.name;
		endif;
		rateTable.CM_DataTable.addItemObject(service, text);
	endforeach;

	column := 1;
	foreach obj in self.allSelectedVessels do
		vessel := obj.CM_Vessel;
		count := 1;
		vessel.getTotalRateCount(count);
		pd.progress.partsInJob := count;
		column := column + 1;
		self.loadRateTableByColumnVessel(vessel, bank, 1, rateTable, column, tsSystem, pd);
	endforeach;
	
	rateTable.row := 1;
	rateTable.column := 1;

	self.setTableAlignment();

	self.setEnableObjects();
	rateTable.accessColumn(2).width := 100;
	foreach i in 1 to rateTable.fixedRows do
		rateTable.accessRow(i).backColor := self.colorHeadingColumn;
	endforeach;
	foreach i in rateTable.fixedRows + 1 to rateTable.rows do
		rateTable.accessRow(i).backColor := self.colorControlBack;
	endforeach;
	
	rateTable.accessMode := Table.AccessMode_Cell;
	
epilog
	app.cmsEndLoad(ls);
	delete pd;
	delete services;
	delete dynaDict;
	app.setChargeRateEffectiveDate(savedChargedEffTS);
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryVesselType" id="5b4496db-c2a5-441b-9164-be6b92312f10">
        <updating/>
        <source>doQueryVesselType()updating;
/*

Purpose:			

Parameters:			

Return Value:		

