    <JadeMethod name="doBuildComboGraphics" id="bd356b3b-986e-47fa-bf15-121324da0480">
        <source>doBuildComboGraphics();
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theGraphic : CM_VoyageLayoutGraphic;
	idx : Integer;
	type : CM_TIBehaviourType;
begin
	self.cmbGraphics.sorted := false;
	self.cmbGraphics.clear;

	if self.mode = self.Mode_Ship then
		theGraphic := self.myGraphic.CM_VoyageLayoutGraphic;
	
		idx := self.cmbGraphics.addItem(CM_VoyageLayoutGraphic.LABEL_AFT);
		self.cmbGraphics.itemData[idx] := CM_VoyageLayoutGraphic.INDEX_AFT;
		idx := self.cmbGraphics.addItem(CM_VoyageLayoutGraphic.LABEL_BRIDGE);
		self.cmbGraphics.itemData[idx] := CM_VoyageLayoutGraphic.INDEX_BRIDGE;
		idx := self.cmbGraphics.addItem(CM_VoyageLayoutGraphic.LABEL_FORWARD);
		self.cmbGraphics.itemData[idx] := CM_VoyageLayoutGraphic.INDEX_FORWARD;
		idx := self.cmbGraphics.addItem(CM_VoyageLayoutGraphic.LABEL_CRANE1);
		self.cmbGraphics.itemData[idx] := CM_VoyageLayoutGraphic.INDEX_CRANE1;
	elseif self.mode = self.Mode_TIBehaviour then
		type := app.myRoot.allTIBehaviourTypes[TIBehaviourType_TermTrailer];
		idx := self.cmbGraphics.addItem(type.description);
		self.cmbGraphics.itemData[idx] := TIBehaviourType_TermTrailer;
		self.cmbGraphics.itemObject[idx] := type;

		type := app.myRoot.allTIBehaviourTypes[TIBehaviourType_RoadTrailer];
		idx := self.cmbGraphics.addItem(type.description);
		self.cmbGraphics.itemData[idx] := TIBehaviourType_RoadTrailer;
		self.cmbGraphics.itemObject[idx] := type;
	

		type := app.myRoot.allTIBehaviourTypes[TIBehaviourType_ReeferBase];
		idx := self.cmbGraphics.addItem(type.description);
		self.cmbGraphics.itemData[idx] := TIBehaviourType_ReeferBase;
		self.cmbGraphics.itemObject[idx] := type;

		type := app.myRoot.allTIBehaviourTypes[TIBehaviourType_Car];
		idx := self.cmbGraphics.addItem(type.description);
		self.cmbGraphics.itemData[idx] := TIBehaviourType_Car;
		self.cmbGraphics.itemObject[idx] := type;

		//cnwjo3 ccms 1018
		type := app.myRoot.allTIBehaviourTypes[TIBehaviourType_SUV];
		idx := self.cmbGraphics.addItem(type.description);
		self.cmbGraphics.itemData[idx] := TIBehaviourType_SUV;
		self.cmbGraphics.itemObject[idx] := type;

		type := app.myRoot.allTIBehaviourTypes[TIBehaviourType_Truck];
		idx := self.cmbGraphics.addItem(type.description);
		self.cmbGraphics.itemData[idx] := TIBehaviourType_Truck;
		self.cmbGraphics.itemObject[idx] := type;		

		type := app.myRoot.allTIBehaviourTypes[TIBehaviourType_Van];
		idx := self.cmbGraphics.addItem(type.description);
		self.cmbGraphics.itemData[idx] := TIBehaviourType_Van;
		self.cmbGraphics.itemObject[idx] := type;		

		type := app.myRoot.allTIBehaviourTypes[TIBehaviourType_Bike];
		idx := self.cmbGraphics.addItem(type.description);
		self.cmbGraphics.itemData[idx] := TIBehaviourType_Bike;
		self.cmbGraphics.itemObject[idx] := type;				

		type := app.myRoot.allTIBehaviourTypes[TIBehaviourType_Concrete];
		idx := self.cmbGraphics.addItem(type.description);
		self.cmbGraphics.itemData[idx] := TIBehaviourType_Concrete;
		self.cmbGraphics.itemObject[idx] := type;			
		
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboType" id="68a85e91-5f3c-40ed-90a3-8f1720dba5c6">
        <source>doBuildComboType();
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
begin
	self.cmbType.sorted := false;
	self.cmbType.clear;
	self.cmbType.visible := false;

	idx := self.cmbType.addItem(CM_GraphicCommand.LABEL_DRAW);
	self.cmbType.itemData[idx] := CM_GraphicCommand.TYPE_DRAW;
	idx := self.cmbType.addItem(CM_GraphicCommand.LABEL_ELIPSE);
	self.cmbType.itemData[idx] := CM_GraphicCommand.TYPE_ELIPSE;
	//epr 8/8/08 ccms 1045
	idx := self.cmbType.addItem(CM_GraphicCommand.LABEL_ARC);
	self.cmbType.itemData[idx] := CM_GraphicCommand.TYPE_ARC;
	
	idx := self.cmbType.addItem(CM_GraphicCommand.LABEL_FILL);
	self.cmbType.itemData[idx] := CM_GraphicCommand.TYPE_FILL;
	idx := self.cmbType.addItem(CM_GraphicCommand.LABEL_RECTANGLE);
	self.cmbType.itemData[idx] := CM_GraphicCommand.TYPE_RECTANGLE;
	idx := self.cmbType.addItem(CM_GraphicCommand.LABEL_LINE);
	self.cmbType.itemData[idx] := CM_GraphicCommand.TYPE_LINE;
	idx := self.cmbType.addItem(CM_GraphicCommand.LABEL_STOP);
	self.cmbType.itemData[idx] := CM_GraphicCommand.TYPE_STOP;
	idx := self.cmbType.addItem(CM_GraphicCommand.LABEL_STOP_FILL);
	self.cmbType.itemData[idx] := CM_GraphicCommand.TYPE_STOP_FILL;
	idx := self.cmbType.addItem(CM_GraphicCommand.LABEL_TEXT_POS);
	self.cmbType.itemData[idx] := CM_GraphicCommand.TYPE_TEXT_POS;
	idx := self.cmbType.addItem(CM_GraphicCommand.LABEL_FIRST_POINT);
	self.cmbType.itemData[idx] := CM_GraphicCommand.TYPE_FIRST_POINT;
	idx := self.cmbType.addItem(CM_GraphicCommand.LABEL_LAST_POINT);
	self.cmbType.itemData[idx] := CM_GraphicCommand.TYPE_LAST_POINT;
	idx := self.cmbType.addItem(CM_GraphicCommand.LABEL_STRETCHXY);
	self.cmbType.itemData[idx] := CM_GraphicCommand.TYPE_STRETCHXY;
	idx := self.cmbType.addItem(CM_GraphicCommand.LABEL_CLEARHEIGHT);
	self.cmbType.itemData[idx] := CM_GraphicCommand.TYPE_CLEARHEIGHT;
	idx := self.cmbType.addItem(CM_GraphicCommand.LABEL_CLEARWIDTH);
	self.cmbType.itemData[idx] := CM_GraphicCommand.TYPE_CLEARWIDTH;

end;</source>
    </JadeMethod>
    <JadeMethod name="doComboGraphicsClick" id="53987097-3aa5-4cac-9f2c-7c91838f0d51">
        <updating/>
        <source>doComboGraphicsClick() updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aPoint : Point;
	idx,b : Integer;
	theGraphic : CM_VoyageLayoutGraphic;
	theTIBGraphic : CM_TIBehaviourGraphic;
	aCommand : CM_GraphicCommand;
	aGraphic : CM_Graphic;
	theGraphics : CM_GraphicArray;
	type : Integer;
	theLine : String;
	tiBType : CM_TIBehaviourType;
begin
	if self.mode = self.Mode_Ship then
		theGraphic := self.myGraphic.CM_VoyageLayoutGraphic;
		if theGraphic = null then
			return;
		endif;
		type := self.cmbGraphics.itemData[self.cmbGraphics.listIndex];
		
		if type &lt; 1 then
			return;
		endif;
		theGraphics := theGraphic.getCommands(type);
	elseif self.mode = self.Mode_TIBehaviour then
		type := self.cmbGraphics.itemData[self.cmbGraphics.listIndex];
		tiBType := self.cmbGraphics.listObject.CM_TIBehaviourType;
		theTIBGraphic := tiBType.myGraphic;
		if theTIBGraphic = null then
			tiBType.createGraphic();
			theTIBGraphic := tiBType.myGraphic;
		endif;
		
		self.myGraphic := theTIBGraphic;
		theGraphics := theTIBGraphic.allCommands;
	endif;
	
	self.lblColour.backColor := Black;
	self.lblColour.foreColor := self.lblColour.backColor.getInverseColour();
	
	self.tblDim.rows := self.tblDim.fixedRows;
//	theTable.addItem("" &amp; Tab &amp; "Type" &amp; Tab &amp; "Colour" &amp; Tab &amp; "X1" &amp; Tab &amp; "Y1" &amp; Tab &amp; "X2" &amp; Tab &amp; "Y2" &amp; Tab &amp; "Note");
	
	foreach aGraphic in theGraphics do
		aCommand := aGraphic.CM_GraphicCommand;
		b := b + 1;
		theLine := b.String &amp; Tab &amp; aCommand.typeString &amp; Tab &amp; ""&amp; Tab &amp; ""  &amp; Tab &amp; aCommand.x1.String &amp; Tab &amp; aCommand.y1.String &amp; Tab &amp;  
						aCommand.x2.String &amp; Tab &amp; aCommand.y2.String &amp; Tab &amp; aCommand.startX.String &amp; Tab  &amp; aCommand.endX.String &amp; Tab &amp; aCommand.startY.String &amp; Tab &amp; aCommand.endY.String &amp; Tab &amp; aCommand.label;

		idx := self.tblDim.addItem(theLine);

		self.doSetInputTypeInTable(idx);
		self.tblDim.accessCell(idx,self.COLUMN_COLOUR).backColor := aCommand.lineColour;
		self.tblDim.accessCell(idx,self.COLUMN_FILL).backColor := aCommand.fillColour;

	endforeach;

	self.drawGraphic;
end;</source>
    </JadeMethod>
    <JadeMethod name="doComboTypeClick" id="0d4fa88c-9718-44b9-abdf-ddd48fb32049">
