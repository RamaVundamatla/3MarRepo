    <JadeMethod name="copyValuesNoDuplicates" id="accfeca4-ad54-49bd-8a67-667d70249484">
        <source>copyValuesNoDuplicates();
// ---------------------------------------------------------------------------
// Created:		29 March 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theValue,idx, sub, num : Integer;
	
	allSame : Boolean;
begin
	self.allTmpValues .clear;
	foreach idx in 1 to 5 do // DICE
		if not  self.allTmpValues.includes(self.allValues[idx]) then
			self.allTmpValues.add(self.allValues[idx]);
		else
			self.allTmpValues.add(999);
			
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="b7ae04d6-925f-4215-bddb-7b0573202ccb">
        <updating/>
        <source>doFormLoad() updating;
// ---------------------------------------------------------------------------
// Created:		27 March 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.allItemsLocked.clear;
	self.allItemsValues.clear;
	self.allItemsLocked[20] := false;
	self.allItemsValues[20] := 0;
	self.doReset();
end;</source>
    </JadeMethod>
    <JadeMethod name="doReset" id="de75a11b-5bc5-4821-a915-e5301552b75e">
        <updating/>
        <source>doReset() updating;
// ---------------------------------------------------------------------------
// Created:		24 March 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.btnRoll.enabled := true;
	self.numRolls := 0;
	self.doResetFrame(self.frmDi1);
	self.doResetFrame(self.frmDi2);
	self.doResetFrame(self.frmDi3);
	self.doResetFrame(self.frmDi4);
	self.doResetFrame(self.frmDi5);
	self.allValues.clear;
	self.allValues[5] := 0;

	if not self.allItemsLocked[self.Index_Item_AllOnes] then
		self.lblAllOnesValue.caption := null;
	endif;
	if not self.allItemsLocked[self.Index_Item_AllTwos] then
		self.lblAllTwosValue.caption := null;
	endif;
	if not self.allItemsLocked[self.Index_Item_AllThrees] then
		self.lblAllThreeValue.caption := null;
	endif;
	if not self.allItemsLocked[self.Index_Item_AllFours] then
		self.lblAllFoursValue.caption := null;
	endif;
	if not self.allItemsLocked[self.Index_Item_AllFives] then
		self.lblAllFivesValue.caption := null;
	endif;
	if not self.allItemsLocked[self.Index_Item_AllSixes] then
		self.lblAllSixValue.caption := null;
	endif;
	if not self.allItemsLocked[self.Index_Item_OfAKind3] then
		self.lblKind3Value.caption := null;
	endif;
	if not self.allItemsLocked[self.Index_Item_OfAKind4] then
		self.lblKind4Value.caption := null;
	endif;
	if not self.allItemsLocked[self.Index_Item_OfAKind5] then
		self.lblKind5Value.caption := null;
	endif;
	if not self.allItemsLocked[self.Index_Item_Chance] then
		self.lblChanceValue.caption := null;
	endif;
	if not self.allItemsLocked[self.Index_Item_FullHouse] then
		self.lblFullHseValue.caption := null;
	endif;
	if not self.allItemsLocked[self.Index_Item_StraightLong] then
		self.lblStrLongValue.caption := null;
	endif;
	if not self.allItemsLocked[self.Index_Item_StraightShort] then
		self.lblStrSmallValue.caption := null;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResetFrame" id="af3bf4cd-e250-4ecb-938f-0cc4a18a4922">
        <source>doResetFrame(_frame : Frame input);
// ---------------------------------------------------------------------------
// Created:		24 March 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	_frame.helpKeyword := null;
	_frame.clearGraphics();
end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTotals" id="ad89a612-5f76-4ed1-a9b5-614f5421a52b">
        <updating/>
        <source>doTotals(_value : Integer; _part : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		30 March 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if _part = 1 then
		self.totalPart1 := self.totalPart1 + _value;
	else
		self.totalPart2 := self.totalPart2 + _value;
	endif;
	self.totalGrand := self.totalPart1 + self.totalPart2;

	self.lblTotal1Value.caption  := self.totalPart1.String;
	self.lblTotal2Value.caption  := self.totalPart2.String;
	self.lblTotalGValue.caption  := self.totalGrand.String;
	
end;</source>
        <Parameter name="_value" type="Integer"/>
        <Parameter name="_part" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doValueLock" id="dfc30b3d-d552-4248-8333-342fb6827673">
        <updating/>
        <source>doValueLock(_label : Label input; _valueIndex : Integer; _partIndex : Integer; _value : Integer ) updating;
// ---------------------------------------------------------------------------
// Created:		30 March 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.allItemsLocked[_valueIndex] then
		return;
	endif;
	
	self.allItemsLocked[_valueIndex] := true;
	self.allItemsValues[_valueIndex] := _value;

	self.doTotals(self.allItemsValues[_valueIndex], _partIndex);	

	_label.foreColor := Red;
	_label.fontBold := true;
	self.doReset();

end;</source>
        <Parameter name="_label" type="Label" usage="input"/>
        <Parameter name="_valueIndex" type="Integer"/>
        <Parameter name="_partIndex" type="Integer"/>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
