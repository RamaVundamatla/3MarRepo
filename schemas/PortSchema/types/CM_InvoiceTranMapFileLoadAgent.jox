    <JadeMethod name="createContentsStatusMap" id="648f6ea5-eb87-405b-8bee-89e35f20182a">
        <updating/>
        <source>createContentsStatusMap(_contentsStatus : String;  _imexMapObj : CM_ImexServiceMap; _contentsMapObj : CM_ContentsMap output) : Boolean updating, protected;

vars
	found		: Boolean;
	isDefault	: Boolean;
	contentsStatusObj	: CM_CargoStatus;
	proxyContentsMap,
	contentsMapObj : CM_ContentsMap;
begin
	self.getContentsStatusDetails(_contentsStatus, isDefault, contentsStatusObj);

	if isDefault then
		foreach contentsMapObj in _imexMapObj.contentsMaps do
			if contentsMapObj.contentsType = 0 then
				found := true;
				break;
			endif;
		endforeach;
		if not found then
			contentsMapObj := null;
		endif;
	else
		contentsMapObj := _imexMapObj.contentsMaps[contentsStatusObj.code];
	endif;

	if contentsMapObj = null then
		create proxyContentsMap transient;
		proxyContentsMap.setProxy(contentsStatusObj.CM_ContentsStatus, _imexMapObj);
		app.myTrxCA.trxCreateInvoiceTMContents(proxyContentsMap, contentsMapObj, passport);
		if (not app.myPassport.trxCompletedOK) then
			self.setAllErrors('Creating contents status map (' &amp; _contentsStatus &amp; '), row ' &amp; rowCount.String);
			return false;
		endif;
		createCount := createCount + 1;
	endif;

	_contentsMapObj := contentsMapObj;
	return true;
epilog
	delete proxyContentsMap;
end;
</source>
        <access>protected</access>
