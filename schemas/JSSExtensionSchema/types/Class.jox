<Class name="Class">
    <JadeMethod name="jssCount" id="845a920c-46a3-4918-b19f-f71add780b2e">
        <source>jssCount(pCondition:String; pIsSubclasses:Boolean):Integer;
// --------------------------------------------------------------------------------
// Created:		20 December 2002 by cnwdad1
//
// Purpose:		This method will return a count of all instances of the receiver,
//				optionally executing JADE code against each object, such as some
//				condition to include or exclude particular objects in the count.
//				Note that the JADE code must not be enclosed in being/end statements.
//
//				For example:
//
//				write Customer.jssCount("balanceOwing &gt; 0", true);
//
// Parameters:	pCondition - JADE source code to execute against each instance.
//				pIsSubclasses - If true, instances of subclasses will also be counted.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theObject		: Object;
	allObjects		: ObjectArray;
	sourceCode		: String;
	objectCount		: Integer;
	errorCode		: Integer;
	errorPos		: Integer;
	errorLength		: Integer;
	theMethod		: JadeMethod;
	theException	: SystemException;
	
begin
	if pCondition &lt;&gt; null then
		sourceCode	:=	"begin return " &amp; pCondition &amp; "; end;";
		theMethod	:=	process.createTransientMethod(	"cnEcObjectFilter",
														self,
														currentSchema,
														sourceCode,
														true,
														Boolean,
														errorCode,
														errorPos,
														errorLength);
		
		if errorCode &lt;&gt; 0 then
			create theException transient;
			
			theException.errorCode	:=	errorCode;
			theException.errorItem	:=	sourceCode[errorPos:errorLength + 1];
			
			if theException.text.pos("Undefined message number", 1) &gt; 0 then
				theException.extendedErrorText	:=	process.getErrorText(errorCode);
			endif;
			
			raise theException;
			
			return null;
		endif;
	endif;
	
	create allObjects transient;
	allInstances(allObjects, 0, pIsSubclasses);
	
	if pCondition = null then
		return allObjects.size();
	else
		foreach theObject in allObjects where process.executeTransientMethod(theMethod, theObject).Boolean do
			objectCount	:=	objectCount + 1;
		endforeach;
		
		return objectCount;
	endif;
epilog
	if theMethod &lt;&gt; null then
		process.deleteTransientMethod(theMethod);
	endif;
	
	delete allObjects;
end;</source>
        <Parameter name="pCondition" type="String"/>
        <Parameter name="pIsSubclasses" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssGetAllMethods" id="dd64aea9-a627-4805-b952-bbc39f2e55f3">
        <source>jssGetAllMethods(pAllMethods:MethodSet io);
// --------------------------------------------------------------------------------
// Created:		18 April 2003 by cnwdad1
//
// Purpose:		Populates the specified set with the receiver's methods, plus the
//				methods inherited from all superclasses.
//
// Parameters:	pAllMethods - The method set to populate.
//
// Returns:		The populated method set.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allMethods(pAllMethods);
	
	if self.superclass &lt;&gt; null then
		self.superclass.jssGetAllMethods(pAllMethods);
	endif;
end;</source>
        <Parameter name="pAllMethods" type="MethodSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="jssGetBinaryPropertyLength" id="b5aadd87-bea7-41d1-b34c-3e98a03a4eec">
        <source>jssGetBinaryPropertyLength(pPropertyName : String) : Integer;
// --------------------------------------------------------------------------------
// Created:		10 April 2001 by cnwdad1
//
// Purpose:		Returns the length (in character units) of the requested binary
//				property.  Returns zero if the property doesn't exist, or if the
//				property is not a binary attribute. Unbounded blobs will return
//				a negative length.
//
// Parameters:	The name of the property.
//
// Returns:		The length of the binary property.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theProperty	: Property;
	theClass	: Class;
	
begin
	theClass	:=	self;
	
	while theClass &lt;&gt; null do
		theProperty	:=	theClass.rootType.properties[pPropertyName];
		
		if theProperty &lt;&gt; null
		and theProperty.isKindOf(Attribute)
		and theProperty.type = Binary
		then
			if app.isUnicode() then
				return (theProperty.getLength() div 2);// - 1;
			endif;
			
			return theProperty.getLength();// - 1;
		endif;
		
		theClass	:=	theClass.superclass;
	endwhile;
	
	return 0;
end;</source>
        <Parameter name="pPropertyName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssGetClassTreeName" id="d341a43a-3f20-447b-b0ff-d0c090d257a8">
        <source>jssGetClassTreeName():String;
// --------------------------------------------------------------------------------
// Created:		22 August 2000 by cnwdad1
//
// Purpose:		Returns a string with the name of the receiver's tree, in the
//				format of a DOS filename.
//
// Parameters:	None
//
// Returns:		The receiver's class hierarchy.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	classTree		: String;
	theSuperClass	: Class;

begin
	theSuperClass	:=	self;
	classTree		:=	self.name;

	while theSuperClass &lt;&gt; null do
		theSuperClass	:=	theSuperClass.superclass;

		if theSuperClass &lt;&gt; null then
			classTree	:=	theSuperClass.name &amp; "\" &amp; classTree;
		endif;
	endwhile;

	return classTree;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssGetObjectSize" id="7741ce89-f78e-48d2-84e5-eb180cb1d891">
        <source>jssGetObjectSize(pLength:Integer output; pBlobCount:Integer output);
// --------------------------------------------------------------------------------
// Created:		16 August 2001 by cnwdad1
//
// Purpose:		Returns the size (length) of the receiver, and the number of blobs
//				(and/or slobs) found.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//	27 Nov 2014	cnwkpd1	PAR #35261 - Changes to prepare for JADE 7.1
// --------------------------------------------------------------------------------
constants
	NO_SUBID = 0.Integer;
	
vars
	propertyCollObj	: PropertyColl;
	propertyObj		: Property;
	objectSize		: Integer;
	propertyLength	: Integer;
	blobCount		: Integer;
	referenceLen	: Integer;
	
begin
	if app.getSystemVersion &gt; '7.1' then
		referenceLen := 12;
	else
		referenceLen := 10;
	endif;

	propertyCollObj	:=	self.allProperties();
	
	foreach propertyObj in propertyCollObj do
		
		if propertyObj.virtual then
			continue;
		endif;
		
		if propertyObj.isKindOf(Attribute) then
			if propertyObj.Attribute.length &lt;&gt; -1 and propertyObj.Attribute.length &lt; 541 then
				propertyLength	:=	propertyObj.Attribute.length;
			else
				propertyLength	:=	8;
				blobCount		:=	blobCount + 1;
			endif;
				
		elseif propertyObj.getPropertyValue('subId').Integer = NO_SUBID then
			propertyLength	:=	referenceLen;
		else
			// It must be a sub-object.
			propertyLength := 0;
		endif;
		
		objectSize	:=	objectSize + propertyLength;

	endforeach;
	
	pLength		:=	objectSize;
	pBlobCount	:=	blobCount;
	
epilog
	delete propertyCollObj;
	
end;</source>
        <Parameter name="pLength" type="Integer" usage="output"/>
        <Parameter name="pBlobCount" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="jssGetStringPropertyLength" id="2b4ce71d-d8cb-47dd-8081-de0f9fc6747e">
        <source>jssGetStringPropertyLength(pPropertyName : String) : Integer;
// djc, 17 Aug 2000
// Returns the length (in character units) of the requested string property.
// Returns zero if the property doesn't exist, or if the property is not a
// string attribute. Unbounded slobs will return a negative length.
vars
	theProperty	: Property;
	theClass	: Class;
	
begin
	theClass	:=	self;
	
	while theClass &lt;&gt; null do
		theProperty	:=	theClass.rootType.properties[pPropertyName];
		
		if theProperty &lt;&gt; null
		and theProperty.isKindOf(Attribute)
		and theProperty.type = String
		then
			if app.isUnicode() then
				return (theProperty.getLength() div 2) - 1;
			endif;
			
			return theProperty.getLength() - 1;
		endif;
		
		theClass	:=	theClass.superclass;
	endwhile;
	
	return 0;
end;</source>
        <Parameter name="pPropertyName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssIsGUI" id="eb172809-caa5-44ed-a998-e2230464993b">
        <source>jssIsGUI():Boolean;
// --------------------------------------------------------------------------------
// Created:		07 March 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether or not the receiver is
//				a GUI class.
//
// Parameters:	None
//
// Returns:		True if he receiver is a GUI class, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.inheritsFrom(Window);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
