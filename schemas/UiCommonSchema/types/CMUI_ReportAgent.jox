    <JadeMethod name="loadControlsForReport" id="9f889a56-3c34-4b69-a4ad-ba5b7aa3a4f4">
        <updating/>
        <source>loadControlsForReport(_entDef : EntTableDef; _menuEntity : CM_MenuEntity) updating;
// ---------------------------------------------------------------------------
// Created:     08 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	entRow			: EntTableRow;
	entDef  		: EntTableDef;
	entView			: EntTableView;
	viewRows		: StringArray;
	defaultValue,
	rowName			: String;
	filterObject	: CMQF_FilterReports;
	qryReport		: CM_QryReport;
	idx 			: Integer;
	bgpRequest		: BGP_ReportRequest;
begin
	qryReport := self.myQryReport;
	if qryReport = null then
		return;
	endif;
	
	if _menuEntity &lt;&gt; null and CM_MenuUserReport.hasInstance(_menuEntity) then
		//PAR22361 - cnwsh3 - 18/02/2010 - Remove references to CM_MenuUserReport.myReportRequest 
		//mapped method.  Now using getBGPReportRequest method
		bgpRequest := _menuEntity.CM_MenuUserReport.getBGPReportRequest();
		
		//if _menuEntity.CM_MenuUserReport.myReportRequest &lt;&gt; null and
		//   _menuEntity.CM_MenuUserReport.myReportRequest.myFilter &lt;&gt; null then
		if bgpRequest &lt;&gt; null and
		   bgpRequest.myFilter &lt;&gt; null then
			filterObject := bgpRequest.myFilter;
		endif;
	else
		if qryReport.myFilterObject &lt;&gt; null then
			filterObject := qryReport.myFilterObject;
		endif;	
	endif;
	
	if CM_QryReportSystem.hasInstance(qryReport) then
		entView := _entDef.allEntTableViews[qryReport.tableDefViewName];
		if entView = null then
			if qryReport.tableDefViewName &lt;&gt; null then
				app.raiseUnexpectedProgramError(class.name, method.name, 'Failed to get an EntTableView for system report');
				return;
			endif;
			// CNWRS2 - added code here to handle where no view has been created (20 MAY 2008)
			foreach entRow in _entDef.allEntTableRows do
				self.loadParameterByName(filterObject, entRow, entRow.name, defaultValue);
			endforeach;
		else
			foreach entRow in entView.allEntTableRows do
				self.loadParameterByName(filterObject, entRow, entRow.name, defaultValue);
			endforeach;
		endif;
		
	elseif CM_QryReportUser.hasInstance(qryReport) then
		viewRows := qryReport.CM_QryReportUser.viewRows; //allIncludedRows
		entDef := qryReport.getETDef;
		
		foreach rowName in viewRows do
			if entDef &lt;&gt; null then
				idx := entDef.getRowByName(rowName);
				if idx = 0 then
					continue;
				endif;
				entRow := entDef.allEntTableRows[idx];
				rowName := entRow.name;
			endif;
			self.loadParameterByName(filterObject, entRow, rowName, defaultValue);
		endforeach;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'QryReport passed through is of invalid class type');
		return;
	endif;

end;</source>
        <Parameter name="_entDef" type="EntTableDef"/>
        <Parameter name="_menuEntity" type="CM_MenuEntity"/>
    </JadeMethod>
    <JadeMethod name="loadJRWParams" id="f8759756-9c66-4068-89dd-051cb7c1f8c2">
        <updating/>
        <source>loadJRWParams() updating;
// ---------------------------------------------------------------------------
// Created:     09 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	qryReport			: CM_QryReport;
	qryParam			: CM_QueryReportParam;
begin
	qryReport := self.myQryReport;
	self.maxParamDateBoxNum := null;
	self.maxParamTimeBoxNum := null;
	
	if qryReport = null then
		return;
	endif;

	foreach qryParam in qryReport.allQueryReportParams do
		self.addJRWParamRow(qryParam);
	endforeach;

end;</source>
    </JadeMethod>
