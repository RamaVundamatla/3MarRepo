    <JadeMethod name="tblMain_change" id="fa3cd088-1fd6-4adf-a4ad-787090e19845">
        <controlMethod name="CM_EntryTable::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMain_change(table: CM_EntryTable input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwas3	Initial creation

*/

vars
	tmpRow		: Integer;
	entRowTrans	: EntTableRowTransient;
	rowName		: String;
begin
	tmpRow := table.row;
	
	entRowTrans := table.accessRow(tmpRow).itemObject.EntTableRowTransient;
	if entRowTrans = null then
		return;
	endif;

	rowName := entRowTrans.name;
	
	if rowName = ETRow_PieceCountError then
		self.myAssistant.showHideDriverPieceCount(table,table.getValue(tmpRow).Boolean);
	endif;
epilog

end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblMain_dblClick" id="a19ec8a9-63bd-4326-b5ce-f483e80ecbf8">
        <controlMethod name="CM_EntryTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMain_dblClick(table: CM_EntryTable input) updating;
//--------------------------------------------------------------
//Created: 28 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpBOL			: CM_BOL;
	entRowTrans		: EntTableRowTransient;
begin
	entRowTrans := table.accessRow(table.row).itemObject.EntTableRowTransient;
	if entRowTrans = null then
		return;
	endif;
	if not entRowTrans.inputEnabled then
		//row is disabled, cannot change.
		return;
	endif;
	app.setContinueCMExceptions(false);	
	
	tmpBOL := self.myProxyObject.CM_BOL;

	if tmpBOL.bolType = BOLType_Log then
	
		if tmpBOL.myExtension &lt;&gt; null and
		   tmpBOL.myExtension.isKindOf(CM_BOLExtLogIn) then
			self.myAssistant.receival_tblDblClick(table, null,
		 									self.allAttachments,
		 									null, //default cargo type
											null,
											self.myCurrentObject.CM_BOL.bolType,
			   								tmpBOL.myExtension.CM_BOLExtLogIn.allTicketSequences,
			   								self.cmbSupplier.myObject.CM_Operator, null, null, null, null, null, null, null, null);
		endif;
			   									
	endif;

end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="4e0f8852-10c0-4a35-938a-05ed6ab60873">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007362, locale);
	btnReconciled.translateBubbleHelp(Xlat_0013423, locale);
	btnReconciled.translateCaption(Xlat_0013424, locale);
	btnShowBOLItems.translateBubbleHelp(Xlat_0014110, locale);
	btnShowBOLItems.translateCaption(Xlat_0014111, locale);
	mnuAdd.translateCaption(Xlat_0013427, locale);
	mnuDelete.translateCaption(Xlat_0013428, locale);
	mnuEdit.translateCaption(Xlat_0013429, locale);
	mnuMain.translateCaption(Xlat_0013430, locale);
	mnuPrintLabels.translateCaption(Xlat_0014545, locale);
	mnuReceived.translateCaption(Xlat_0014112, locale);
	mnuReconcileBOL.translateCaption(Xlat_0013431, locale);
end;</source>
    </JadeMethod>
