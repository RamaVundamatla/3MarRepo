<Class name="CM_YATemplateGroup" id="16c7d1b3-bc6e-47f4-b38b-d1f566f5f136">
    <superclass name="CM_YAEntity"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <ExplicitInverseRef name="allYardAllocations" id="c2b7ca8a-4a6c-4d39-8175-2042d2e7542b">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_YAByPriorityDict"/>
        <access>readonly</access>
        <Inverse name="CM_YardAllocationTemplate::myYATemplateGroup"/>
    </ExplicitInverseRef>
    <PrimAttribute name="code" id="8b3bf73e-52e1-4fd8-84d6-885b9c43980c">
        <length>51</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myRoot" id="cc91f832-a27c-46d7-a5da-9218e981108a">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
