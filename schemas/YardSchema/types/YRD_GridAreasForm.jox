    <JadeMethod name="getSelectedMultiMoveLocations" id="274ffd7e-0781-4448-9a56-4606a4f1f63a">
        <source>getSelectedMultiMoveLocations( _targetLocns : CM_LCArray io );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2011	cnwndl1	Initial creation	Par 28035

*/

vars

	obj : Object;
	yardCell : CM_YALocationCell;
	yardCellLocations : CM_LCArray;

begin

	_targetLocns.clear();
	if not self.mnuMultiMove.checked then
		return;
	endif;
	
	//get a collection of teh multi locations that we have selected
	create yardCellLocations transient;
	foreach obj in self.myCurrentDrawingController.allSelectedObjects do
		if obj.isKindOf( CM_YALocationCell ) and obj.CM_YALocationCell.myYardController &lt;&gt; null then
			yardCellLocations.add( obj.CM_YALocationCell.myYardController );
		endif;
	endforeach;
	
	foreach obj in self.myCurrentDrawingController.allSelectedObjects do
		if obj.isKindOf( CM_LocationsController ) then
			if not yardCellLocations.includes( obj.CM_LocationsController ) then
				// only select if wont be selected via a cell relationship.
				_targetLocns.add( obj.CM_LocationsController );
			endif;
		elseif obj.isKindOf( CM_YALocationCell ) and obj.CM_YALocationCell.myYardController &lt;&gt; null then
			_targetLocns.add( obj.CM_YALocationCell.myYardController );
		endif;
	endforeach;

epilog

	delete yardCellLocations;

end;</source>
        <Parameter name="_targetLocns" type="CM_LCArray" usage="io"/>
    </JadeMethod>
