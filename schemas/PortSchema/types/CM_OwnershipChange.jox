    <JadeMethod name="validateForUpdate" id="e91ebbf5-dd42-47ff-bb29-16557b10b737">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2023 navtnr20	TFS CR 58507	Task 58209: Jade - TRX CM_OwnershipChange
07 August 2023	navmv20	CR 59440 Task 59441: Jade - Ownership Change Release Request Validation
*/

vars
	realOwenerShip,
	pxyOwnerShip	: CM_OwnershipChange;
	myOwnerShip : CM_OwnershipChange;
	detail,
	subDetail	: CM_OwnershipChangeDetail; //07/08/2023	navmv20	CR 59440 Task 59441
	invoiceContractExists : Boolean;										//navra1 - TFS 64874 - 14th Aug 2024
	debtorInvoiceContracts : CM_InvContractByBankIdDict;					//navra1 - TFS 64874 - 14th Aug 2024
	invoiceContract : CM_InvoiceContract;									//navra1 - TFS 64874 - 14th Aug 2024
	
begin
	if self.refNumber = null then
		app.raiseCMException(Input_req_ref_number, null, self);
	endif;
	
	if self.dateTimeCOO	= null then
		app.raiseCMException(Input_req_dateTimeCOO, null, self);
	endif;
	
	if self.myOperatorNew = null then
		app.raiseCMException(Input_requird_opratorNew, null, self);
	elseif not app.isJMTUnitTest then // FIX UP LOADS OF UTs FAILING					
		//navra1 - DEFECT 65798 - 29th Aug 2024	- start		
		debtorInvoiceContracts  := self.myOperatorNew.debtor.allInvoiceContracts;
		foreach invoiceContract in debtorInvoiceContracts where invoiceContract.myTerminal.code = self.myTerminal.code do				//navra1 - DEFECT 65798 - 29th Aug 2024
			if invoiceContract.active = true then				
				invoiceContractExists := true;
			endif;
		endforeach;
		
		if invoiceContractExists &lt;&gt; true then		
			app.raiseCMWarning(No_Act_inv_cont_exist_for_op, 'Operator',null,null);
		endif;
		//navra1 - DEFECT 65798 - 29th Aug 2024	- end
	endif;
	realOwenerShip	:= self.pxyGetRealObject();
	if self.myOperatorNew &lt;&gt; null then
		
		foreach myOwnerShip in self.myOperatorNew.allOwnershipChangeNew do 
			if myOwnerShip &lt;&gt; realOwenerShip and self.refNumber = myOwnerShip.refNumber and self.dateTimeCOO = myOwnerShip.dateTimeCOO then
				app.raiseCMException3(Myope_refer_numbe_datet_shoul_, self.myOperatorNew.code,self.refNumber,self.dateTimeCOO.String, null,null);
			endif;
		endforeach;
		
		foreach myOwnerShip in self.myOperatorNew.allOwnershipChangeNew do 
			if myOwnerShip &lt;&gt; realOwenerShip and self.refNumber = myOwnerShip.refNumber then
				app.raiseCMWarning2(Myoper_refere_number_should_un, self.myOperatorNew.code,self.refNumber, null,null,null);
			endif;
		endforeach;
			
	endif;
	if self.myTerminal.getConfig(CooSplitOperator).Boolean then	//navtnr20 20-07-2023 58234
		if self.myOperatorOld &lt;&gt; self.myOperatorNew then
			app.raiseCMException(Curren_operat_operat_should_sa, null, self);
		endif;
	endif;
	
	//07/08/2023 navmv20 CR 59440 Task 59441 - start
	if self.pxyIsProxy() then
		foreach detail in self.allDetails do
			detail.validateForUpdate();
			foreach subDetail in detail.allSubDetails do
				subDetail.validateForUpdate();
			endforeach;
		endforeach;
	endif;
	//07/08/2023 navmv20 CR 59440 Task 59441 - end
epilog

end;</source>
    </JadeMethod>
</Class>
