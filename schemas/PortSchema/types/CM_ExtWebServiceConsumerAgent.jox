    <JadeMethod name="setIniFileOptionsForWinINET" id="fbca93ef-c347-444f-ad37-428f225938aa">
        <source>setIniFileOptionsForWinINET() protected;
/*

Purpose:			Set the JadeEnvironment options to ensure that WinINET is the dll used for any 
					Web Service Consumer communications, as WinHTTP does not work in all cases

Parameters:			None

Return Value:		None

Date		Who		Reason
12 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

constants
	JadeEnvironment	= "JadeEnvironment";
	EnableWinHTTP	= "EnableWinHTTP";
	EnableWinINET	= "EnableWinINET";
	Dummy			= "Dummy";
	
vars
	iniFileName		: String;
	iniValue		: String;
	
begin
	iniFileName := app.getIniFileNameAppServer();
	
	iniValue := app.getProfileStringAppServer(iniFileName, JadeEnvironment, EnableWinHTTP, Dummy);
	if iniValue = Dummy or iniValue.Boolean then
		app.writeLog(method.qualifiedName &amp; " setting [" &amp; JadeEnvironment &amp; "] " &amp; EnableWinHTTP &amp; " to false", LogINFO);	//25 Nov 2019	NDL	TFS 47053
		app.setProfileStringAppServer(iniFileName, JadeEnvironment, EnableWinHTTP, false.String);
	endif;
	iniValue := app.getProfileStringAppServer(iniFileName, JadeEnvironment, EnableWinINET, Dummy);
	if iniValue = Dummy or not iniValue.Boolean then
		app.writeLog(method.qualifiedName &amp; " setting [" &amp; JadeEnvironment &amp; "] " &amp; EnableWinINET &amp; " to true", LogINFO);	//25 Nov 2019	NDL	TFS 47053
		app.setProfileStringAppServer(iniFileName, JadeEnvironment, EnableWinINET, true.String);
	endif;
	
epilog

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupFromWebServiceDefinition" id="3a1e74a6-a109-4ea2-91ae-b769c9f8993c">
        <updating/>
        <source>setupFromWebServiceDefinition(_definition : CM_ExternalWebServiceDef) updating;
/*

Purpose:			Set up the receiver options from the passed in CM_ExternalWebServiceDef

Parameters:			Web Service defintion containing configuration options

Return Value:		None

Date		Who		Reason
13 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

begin
	self.usercode := _definition.userCode;
	self.password := _definition.getPwForUse(null);	//26 Aug 2021	NDl	TFS 51632
	self.setBaseEndpoint(_definition.baseEndpoint);
	self.timeoutSeconds := _definition.timeoutSeconds;
	self.definitionName :=_definition.name;
	self.raiseAlertOnFailure := _definition.raiseAlertOnFailure;	//15.Feb.24 navsp1 TFS 62068
	// When set from a Web Service Definition, default to creating Activity History
	self.createActivityHistory := true;
	
epilog

end;</source>
        <Parameter name="_definition" type="CM_ExternalWebServiceDef"/>
    </JadeMethod>
    <JadeMethod name="updateActivityHistory" id="b8b19784-e233-4750-a328-cc037f145441">
        <source>updateActivityHistory(success: Boolean);
/*

Purpose:			
	Update the Status of a message in Activity History
Parameters:			
	The success status (True / False ) to update the Activity History entry to
Return Value:		

Date		Who		Reason
14 October 2019	jlgrr1	Initial creation TFS47042	
05 August 2020	jlgndl1	Initial creation	TFS 49869 - Moved up a class

*/

vars
	pxyActivityHistory : CM_ActivityHistoryExtInterface;
begin

	if self.myLastActivityHistory &lt;&gt; null then
		beginLoad;
			pxyActivityHistory :=self.myLastActivityHistory.pxyCreateUpdateProxy().CM_ActivityHistoryExtInterface;
		endLoad;
		pxyActivityHistory.setSuccess(success);
		app.myTrxUA.trxUpdateActivityHistory(pxyActivityHistory, app.myPassport);
		if app.myPassport.hasErrors then
			app.writeLog(method.qualifiedName &amp; 
				" Update Activity History - ERRORS :	"  &amp; app.myPassport.getErrorsAndWarningsAsString ,LogINFO);
		endif;
	endif;
epilog
	delete pxyActivityHistory;
end;</source>
        <Parameter name="success" type="Boolean"/>
    </JadeMethod>
</Class>
