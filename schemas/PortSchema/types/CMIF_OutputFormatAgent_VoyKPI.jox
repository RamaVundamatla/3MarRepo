    <JadeMethod name="saveColoursToXML" id="bd49cfaf-2f06-45d5-b509-386f65e78ab0">
        <source>saveColoursToXML(_xml :String io);
/*
Date			Who		Reason
31 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars

begin
	_xml := _xml &amp; global.formatAsXML(self.XML_Colour_CargoType, self.colour_CargoType.asStringJMT());
	_xml := _xml &amp; global.formatAsXML(self.XML_Colour_Row1, self.colour_Row1.asStringJMT());
	_xml := _xml &amp; global.formatAsXML(self.XML_Colour_Row2, self.colour_Row2.asStringJMT());
	_xml := _xml &amp; global.formatAsXML(self.XML_Colour_Subtotal, self.colour_Total.asStringJMT());
epilog

end;</source>
        <Parameter name="_xml" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setColoursFromXML" id="a7b9f040-6e1c-4e34-af8e-f92a8a518bb5">
        <updating/>
        <source>setColoursFromXML(_xml :String)updating;
/*
Date		Who		Reason
30 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	value	:String;
begin
	value := _xml.cnEcGetTagValueOfName(self.XML_Colour_CargoType); 
		
	if value &lt;&gt; null then
		self.colour_CargoType := value.asIntegerJMT();
	endif;
	
		
	value := _xml.cnEcGetTagValueOfName(self.XML_Colour_Row1); 

	if value &lt;&gt; null then
		self.colour_Row1 := value.asIntegerJMT();
	endif;
	
	
	value := _xml.cnEcGetTagValueOfName(self.XML_Colour_Row2); 

	if value &lt;&gt; null then
		self.colour_Row2 := value.asIntegerJMT();
	endif;
	
	value := _xml.cnEcGetTagValueOfName(self.XML_Colour_Subtotal); 

	if value &lt;&gt; null then
		self.colour_Total := value.asIntegerJMT();
	endif;

epilog

end;</source>
        <Parameter name="_xml" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTableColours" id="67bf3454-f94c-46b1-8201-01d8717810d2">
