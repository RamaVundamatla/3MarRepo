    <JadeMethod name="jeCurrent_paint" id="3b41c41e-16f0-4c5c-8c9e-d85223dc3d27">
        <controlMethod name="JadeTextEdit::paint"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>jeCurrent_paint(textedit: JadeTextEdit input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

vars
	otherEditor				: JadeTextEdit;
	ourLastVisibleLine,
	otherMaxLines			: Integer;
begin
	otherEditor := self.jeLoaded;
	
	// Make the other text editor follow us
	if otherEditor.firstVisibleLine &lt;&gt; textedit.firstVisibleLine then
		// Last visible line = first + total visible lines
		ourLastVisibleLine := textedit.firstVisibleLine + textedit.lines;
		otherMaxLines := otherEditor.lineCount + 1;
		
		if ourLastVisibleLine &lt; otherMaxLines then
			otherEditor.firstVisibleLine := textedit.firstVisibleLine;
		else
			if otherEditor.firstVisibleLine + otherEditor.lines &lt; otherMaxLines then
				otherEditor.firstVisibleLine := otherMaxLines;
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="textedit" type="JadeTextEdit" usage="input"/>
    </JadeMethod>
    <JadeMethod name="jeLoaded_paint" id="cdd42233-6d89-42d6-b4e5-50f039110ffd">
        <controlMethod name="JadeTextEdit::paint"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>jeLoaded_paint(textedit: JadeTextEdit input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

vars
	otherEditor				: JadeTextEdit;
	ourLastVisibleLine,
	otherMaxLines			: Integer;
begin
	otherEditor := self.jeCurrent;
	
	// Make the other text editor follow us
	if otherEditor.firstVisibleLine &lt;&gt; textedit.firstVisibleLine then
		// Last visible line = first + total visible lines
		ourLastVisibleLine := textedit.firstVisibleLine + textedit.lines;
		otherMaxLines := otherEditor.lineCount + 1;
		
		if ourLastVisibleLine &lt; otherMaxLines then
			otherEditor.firstVisibleLine := textedit.firstVisibleLine;
		else
			if otherEditor.firstVisibleLine + otherEditor.lines &lt; otherMaxLines then
				otherEditor.firstVisibleLine := otherMaxLines;
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="textedit" type="JadeTextEdit" usage="input"/>
    </JadeMethod>
    <JadeMethod name="load" id="3dc1e360-2487-46dd-9f28-4bbc3a21f3b3">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 September 2022	navpw1	Initial creation

*/

vars
	inLoadState : Boolean;
	
begin
	self.frmToolbarBtns.visible := true;
	self.frmToolbarBtns.top := -1000;	// move out of visible area
	
	self.mnuViewToolbar.checked := (not app.toolbarHidden);
	
	self.frmToolbar.priorityRight := true;
	self.pbProgressBar.height := 20;		// set in painter when able
	
	app.cmsBeginLoad(inLoadState);					// 11/04/2011 cnwmh5 #27347
	self.translateForm();
	self.setupDefaultHelpKeyword();					// PAR #34210
	app.cmsEndLoad(inLoadState);					// 11/04/2011 cnwmh5 #27347
	
	self.initPosition();
	self.setupForm();
	//self.setMenus();
	//self.handleHelpMenuSetup();						// PAR #34210
	
	app.writeLog(self.class.name &amp; " open", LogINFO);	

	if self.toolbarStyle &lt;&gt; ToolbarStyle_None then
		self.zSetupToolbar();
	endif;

	if self.windowState &lt;&gt; self.WindowState_Minimized then
		// at startup we open windows minimised so don't 
		// bother resizing.  Resize will get done when
		// user first access them
		self.doResize();
	endif;

epilog
	app.cmsEndLoad(inLoadState);				// 11/04/2011 cnwmh5 #27347

end;</source>
    </JadeMethod>
    <JadeMethod name="loadDifferingMethods" id="2579430a-603d-417b-91ef-cef1f9aa2c10">
        <source>loadDifferingMethods(_report : DEV_SourceCompareReport; _searchString : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation
30 Jul 2025			navah1	Story 34749: MTN - Source Compare - Add counts to List Boxes and Heading Labels
*/ 
vars
	schema 			: DEV_Schema;
	class 			: DEV_Class;
	devMethod 		: DEV_Method;
	addedSchema,
	addedClass 		: Boolean;
	currentMethod	: Method;
	systemSchema	: Schema;
	systemClass		: Class;
	systemMethod	: Method;
	showResolved	: Boolean;
	jadeRegexReplacePat : JadeRegexPattern;
	classCount,							//30.07.2025 navah1 #34749
	methodCount,						//30.07.2025 navah1 #34749
	classIndex,							//30.07.2025 navah1 #34749
	schemaIndex		: Integer;      	//30.07.2025 navah1 #34749
begin
	showResolved := self.chkShowResolved.value;

	create jadeRegexReplacePat transient;
	jadeRegexReplacePat.compile("[\r\n\t\s]");
	jadeRegexReplacePat.setIgnoreCase(true);
	jadeRegexReplacePat.setExplicitCapture(true);
	
	/*
	* Differing Methods
	*/
	foreach schema in _report.allSchemas do
		systemSchema := rootSchema.getSchema(schema.name);
		addedSchema := false;
		classCount := 0; //30.07.2025 navah1 #34749
		
		foreach class in schema.allClasses where class.reason = DEV_SourceCompareReportAgent.Object_Link do
			systemClass := systemSchema.getClass(class.name);
			addedClass := false;
			methodCount := 0; //30.07.2025 navah1 #34749
			foreach devMethod in class.allMethods where devMethod.reason = DEV_SourceCompareReportAgent.Object_Different do
				
				// If someone else has already looked at this method, then don't display it
				if devMethod.resolvedBy &lt;&gt; null and not showResolved then
					continue;
				endif;
				
				systemMethod := systemClass.getMethod(devMethod.name);
				if _searchString &lt;&gt; null then
					// Filter by Usercode (assumes users start with 'nav')
					if _searchString.startsWith__("nav") or _searchString.startsWith__("jlg") or 
							_searchString.startsWith__("jli") or _searchString.startsWith__("cnw") or 
							_searchString = "JadeLoader" or _searchString = "&lt;unknown&gt;"then
						if devMethod.modifiedBy &lt;&gt; _searchString and (systemMethod &lt;&gt; null and systemMethod.getModifiedByJMT &lt;&gt; _searchString) then 
							continue;
						endif;
					else
						// Filter by method text
						if devMethod.desc.pos(_searchString, 1) = 0 then
							continue;
						endif;
					endif;
				endif;
				
				if not addedSchema then
					self.qlbDifferentMethods.addItem(schema.name);
					self.qlbDifferentMethods.itemObject[self.qlbDifferentMethods.newIndex] := schema;
					self.qlbDifferentMethods.itemLevel[self.qlbDifferentMethods.newIndex] := 1;
					self.qlbDifferentMethods.itemExpanded[self.qlbDifferentMethods.newIndex] := false;
					if schema.resolvedBy &lt;&gt; null then
						self.qlbDifferentMethods.itemForeColor[self.qlbDifferentMethods.newIndex] := Gray;
					else
						self.qlbDifferentMethods.itemForeColor[self.qlbDifferentMethods.newIndex] := Window.Color_WindowText;
					endif;
					addedSchema := true;
					schemaIndex := self.qlbDifferentMethods.newIndex; //30.07.2025 navah1 #34749
					self.beginNotification(schema, Object_Update_Event, Response_Continuous, null);
				endif;
				
				if not addedClass then
					self.qlbDifferentMethods.addItem(class.name);
					self.qlbDifferentMethods.itemObject[self.qlbDifferentMethods.newIndex] := class;
					self.qlbDifferentMethods.itemLevel[self.qlbDifferentMethods.newIndex] := 2;
					self.qlbDifferentMethods.itemExpanded[self.qlbDifferentMethods.newIndex] := false;
					if class.resolvedBy &lt;&gt; null then
						self.qlbDifferentMethods.itemForeColor[self.qlbDifferentMethods.newIndex] := Gray;
					else
						self.qlbDifferentMethods.itemForeColor[self.qlbDifferentMethods.newIndex] := Window.Color_WindowText;
					endif;
					addedClass := true;
					classIndex := self.qlbDifferentMethods.newIndex; //30.07.2025 navah1 #34749
					self.beginNotification(class, Object_Update_Event, Response_Continuous, null);
				endif;
				
				self.qlbDifferentMethods.addItem(devMethod.name);
				self.qlbDifferentMethods.itemObject[self.qlbDifferentMethods.newIndex] := devMethod;
				self.qlbDifferentMethods.itemLevel[self.qlbDifferentMethods.newIndex] := 3;
				self.qlbDifferentMethods.itemExpanded[self.qlbDifferentMethods.newIndex] := false;
				
				if systemMethod &lt;&gt; null and jadeRegexReplacePat.replaceAll(systemMethod.getSource(), "") = jadeRegexReplacePat.replaceAll(devMethod.desc, "") then
					self.qlbDifferentMethods.itemBackColor[self.qlbDifferentMethods.newIndex] := PalePink;
				endif;
				
				if devMethod.resolvedBy &lt;&gt; null then
					self.qlbDifferentMethods.itemForeColor[self.qlbDifferentMethods.newIndex] := Gray;
				else
					self.qlbDifferentMethods.itemForeColor[self.qlbDifferentMethods.newIndex] := Window.Color_WindowText;
				endif;
				
				methodCount += 1; //30.07.2025 navah1 #34749
				self.beginNotification(devMethod, Object_Update_Event, Response_Continuous, null);  
			endforeach;
			
			if methodCount &gt; 0 then //30.07.2025 navah1 #34749
				self.qlbDifferentMethods.itemText[classIndex] :=  app.getErrorString2(LabelWithValue, class.name, methodCount.String);
				classCount += methodCount; 
			endif; 
		endforeach;
		
		if classCount &gt; 0 then //30.07.2025 navah1 #34749
			self.qlbDifferentMethods.itemText[schemaIndex] := app.getErrorString2(LabelWithValue, schema.name, classCount.String);
		endif;
	endforeach;
	
epilog
	delete jadeRegexReplacePat;
	
end;</source>
        <access>protected</access>
        <Parameter name="_report" type="DEV_SourceCompareReport"/>
        <Parameter name="_searchString" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadGlobalConstants" id="06389192-15e7-46fe-87b4-e4395a176ce5">
        <source>loadGlobalConstants(_report : DEV_SourceCompareReport; _userCode : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation
30 Jul 2025			navah1	Story 34749: MTN - Source Compare - Add counts to List Boxes and Heading Labels
*/

vars
	schema 					: DEV_Schema;
	globalConstantCategory 	: DEV_GlobalConstantCategory;
	globalConstant 			: DEV_GlobalConstant;
	addedSchema,
	addedCategory 			: Boolean;
	systemSchema			: Schema;
	systemGlobalConstCategory	: ConstantCategory;
	systemGlobalConstant	: Constant;
	showResolved			: Boolean;
	jadeRegexReplacePat		: JadeRegexPattern;
	categoryCount,							//30.07.2025 navah1 #34749
	constantCount,							//30.07.2025 navah1 #34749
	categoryIndex,							//30.07.2025 navah1 #34749
	schemaIndex 			: Integer;		//30.07.2025 navah1 #34749
	
begin
	showResolved := self.chkShowResolved.value;
	
	create jadeRegexReplacePat transient;
	jadeRegexReplacePat.compile("[\r\n\t\s]");
	jadeRegexReplacePat.setIgnoreCase(true);
	jadeRegexReplacePat.setExplicitCapture(true);
	
	foreach schema in _report.allSchemas do
		systemSchema := rootSchema.getSchema(schema.name);
		addedSchema := false;
		categoryCount := 0;	//30.07.2025 navah1 #34749
		foreach globalConstantCategory in schema.allGlobalConstantCategories do
			addedCategory := false;
			systemGlobalConstCategory := systemSchema.getConstantCategory(globalConstantCategory.name);
			constantCount := 0; //30.07.2025 navah1 #34749
			// If someone else has already looked at this global constant category, then don't display it
			if globalConstantCategory.resolvedBy &lt;&gt; null and not showResolved then
				continue;
			endif;
			
			if globalConstantCategory.reason &lt;&gt; DEV_SourceCompareReportAgent.Object_Link then
				if _userCode &lt;&gt; null and 
					//(systemGlobalConstCategory &lt;&gt; null and
					//systemGlobalConstCategory.getModifiedByJMT.toUpper &lt;&gt; _userCode.toUpper()) or
					(globalConstantCategory.modifiedBy.toUpper &lt;&gt; _userCode.toUpper())
				then 
					continue;
				endif;
				
				if not addedSchema then
					self.qlbGlobalConstants.addItem(schema.name);
					self.qlbGlobalConstants.itemObject[self.qlbGlobalConstants.newIndex] := schema;
					self.qlbGlobalConstants.itemLevel[self.qlbGlobalConstants.newIndex] := 1;
					self.qlbGlobalConstants.itemExpanded[self.qlbGlobalConstants.newIndex] := false;
					if schema.resolvedBy &lt;&gt; null then
						self.qlbGlobalConstants.itemForeColor[self.qlbGlobalConstants.newIndex] := Gray;
					else
						self.qlbGlobalConstants.itemForeColor[self.qlbGlobalConstants.newIndex] := Window.Color_WindowText;
					endif;
					addedSchema := true;
					schemaIndex := self.qlbGlobalConstants.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				if globalConstantCategory.reason = DEV_SourceCompareReportAgent.Object_Missing then
					self.qlbGlobalConstants.addItem(globalConstantCategory.name &amp; " - Missing");
					
				elseif globalConstantCategory.reason = DEV_SourceCompareReportAgent.Object_Different then
					self.qlbGlobalConstants.addItem(globalConstantCategory.name &amp; " - Different");
				endif;
				
				self.qlbGlobalConstants.itemObject[self.qlbGlobalConstants.newIndex] := globalConstantCategory;
				self.qlbGlobalConstants.itemLevel[self.qlbGlobalConstants.newIndex] := 2;
				self.qlbGlobalConstants.itemExpanded[self.qlbGlobalConstants.newIndex] := false;
				if globalConstantCategory.resolvedBy &lt;&gt; null then
					self.qlbGlobalConstants.itemForeColor[self.qlbGlobalConstants.newIndex] := Gray;
				else
					self.qlbGlobalConstants.itemForeColor[self.qlbGlobalConstants.newIndex] := Window.Color_WindowText;
				endif;
				addedCategory := true;
				categoryIndex := self.qlbGlobalConstants.newIndex; //30.07.2025 navah1 #34749
			endif;
			
			foreach globalConstant in globalConstantCategory.allConstants do
				systemGlobalConstant := systemSchema.getConstant(globalConstant.name);
				if _userCode &lt;&gt; null and 
					//(systemGlobalConstant &lt;&gt; null and
					//systemGlobalConstant.getModifiedByJMT.toUpper &lt;&gt; _userCode.toUpper()) or
					(globalConstant.modifiedBy.toUpper &lt;&gt; _userCode.toUpper())
				then 
					continue;
				endif;
				
				// If someone else has already looked at this global constant category, then don't display it
				if globalConstant.resolvedBy &lt;&gt; null and not showResolved then
					continue;
				endif;
				
				if not addedSchema then
					self.qlbGlobalConstants.addItem(schema.name);
					self.qlbGlobalConstants.itemObject[self.qlbGlobalConstants.newIndex] := schema;
					self.qlbGlobalConstants.itemLevel[self.qlbGlobalConstants.newIndex] := 1;
					self.qlbGlobalConstants.itemExpanded[self.qlbGlobalConstants.newIndex] := false;
					if schema.resolvedBy &lt;&gt; null then
						self.qlbGlobalConstants.itemForeColor[self.qlbGlobalConstants.newIndex] := Gray;
					else
						self.qlbGlobalConstants.itemForeColor[self.qlbGlobalConstants.newIndex] := Window.Color_WindowText;
					endif;
					addedSchema := true;
					schemaIndex := self.qlbGlobalConstants.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				if not addedCategory then
					self.qlbGlobalConstants.addItem(globalConstantCategory.name);
					self.qlbGlobalConstants.itemObject[self.qlbGlobalConstants.newIndex] := globalConstantCategory;
					self.qlbGlobalConstants.itemLevel[self.qlbGlobalConstants.newIndex] := 2;
					self.qlbGlobalConstants.itemExpanded[self.qlbGlobalConstants.newIndex] := false;
					if globalConstantCategory.resolvedBy &lt;&gt; null then
						self.qlbGlobalConstants.itemForeColor[self.qlbGlobalConstants.newIndex] := Gray;
					else
						self.qlbGlobalConstants.itemForeColor[self.qlbGlobalConstants.newIndex] := Window.Color_WindowText;
					endif;
					addedCategory := true;
					categoryIndex := self.qlbGlobalConstants.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				if globalConstant.reason = DEV_SourceCompareReportAgent.Object_Missing then
					self.qlbGlobalConstants.addItem(globalConstant.name &amp; " - Missing");
				else
					self.qlbGlobalConstants.addItem(globalConstant.name &amp; " - Different");
					
					if self.isGuineaPig() and jadeRegexReplacePat.replaceAll(systemGlobalConstant.text, "") = jadeRegexReplacePat.replaceAll(globalConstant.documentationTextData, "") then
						self.qlbGlobalConstants.itemBackColor[self.qlbGlobalConstants.newIndex] := PalePink;
					endif;
				endif;
				
				self.qlbGlobalConstants.itemObject[self.qlbGlobalConstants.newIndex] := globalConstant;
				self.qlbGlobalConstants.itemLevel[self.qlbGlobalConstants.newIndex] := 3;
				self.qlbGlobalConstants.itemExpanded[self.qlbGlobalConstants.newIndex] := false;
				if globalConstant.resolvedBy &lt;&gt; null then
					self.qlbGlobalConstants.itemForeColor[self.qlbGlobalConstants.newIndex] := Gray;
				else
					self.qlbGlobalConstants.itemForeColor[self.qlbGlobalConstants.newIndex] := Window.Color_WindowText;
				endif;
				constantCount += 1; //30.07.2025 navah1 #34749
			endforeach;
			
			if constantCount &gt; 0 then //30.07.2025 navah1 #34749
				self.qlbGlobalConstants.itemText[categoryIndex] := app.getErrorString2(LabelWithValue, globalConstantCategory.name, constantCount.String);
				categoryCount += constantCount;
			endif;
		endforeach;
		
		if categoryCount &gt; 0 then //30.07.2025 navah1 #34749
			self.qlbGlobalConstants.itemText[schemaIndex] := app.getErrorString2(LabelWithValue, schema.name, categoryCount.String);
		endif;
	endforeach;
	
epilog
	delete jadeRegexReplacePat;
	
end;</source>
        <access>protected</access>
