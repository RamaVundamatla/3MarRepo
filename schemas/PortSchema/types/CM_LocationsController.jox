    <JadeMethod name="getNextTIToBeOfMode" id="cd220ae3-07a2-4de1-bf81-aae74c98413d">
        <source>getNextTIToBeOfMode(_mode : Integer) : CM_TrackedItem;
/*
Purpose:			
Date				Who		Reason
21 September 2011	cnwab1	Initial creation
24 July 2019		jlgzm1	TFS 42863 Direct Release Between RORO Voyages and Rail - Break Bulk Bulk
*/

vars
	aTI : CM_TrackedItem;
begin
	foreach aTI in self.allTrackedItems discreteLock do
		if _mode = PLANNING_MODE then
			/*
			if aTI.myPrimaryPlannedLocation = null 
			and aTI.getVoyageWLEUnactioned(false) &lt;&gt; null // PAR 31870 has colour coding
			then
			*/
			if aTI.getVoyageWLEUnusedForMode(PLANNING_MODE, false) &lt;&gt; null then // TFS 42863
				return aTI;
			endif;
		elseif _mode = QUEUE_MODE then
			/*
			if aTI.myPrimaryQueuedLocation = null
			and aTI.getVoyageWLEUnactioned(false) &lt;&gt; null // PAR 31870 has colour coding
			then
			*/
			if aTI.getVoyageWLEUnusedForMode(QUEUE_MODE, false) &lt;&gt; null then // TFS 42863
				return aTI;
			endif;
		else
			return aTI;
		endif;
	endforeach;

	return null;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
