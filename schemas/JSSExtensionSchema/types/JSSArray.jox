<CollClass name="JSSArray" id="fbcf444d-4905-4eb4-9aeb-966b981bcca0">
    <memberType name="JSSArrayElement"/>
    <superclass name="Array"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

