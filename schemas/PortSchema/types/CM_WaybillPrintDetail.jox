    <JadeMethod name="setVesselStr" id="69da890e-1af4-4999-a52d-f94fa56779fc">
        <updating/>
        <source>setVesselStr( _tiSet : CM_TISet; _nullVoyage: CM_Voyage; _delim : String ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2015	cnwndl1	Initial creation	Par 36777

*/

vars

	voyage : CM_Voyage;
	vessel : CM_Vessel;
	allVessels : CM_VesselSet;
	ti : CM_TrackedItem;
	vesselName : String;
	completeStr : String;

begin

	create allVessels transient;
	
	foreach ti in _tiSet do
		voyage := ti.myVoyage;
		if voyage = null or voyage = _nullVoyage then
			continue;
		endif;
		vessel := voyage.myVessel;
		if vessel &lt;&gt; null then
			allVessels.addNoDuplicates( vessel, false );
		endif;
	endforeach;
	
	foreach vessel in allVessels do
		vesselName  := vessel.name;
		if vesselName.trimBlanks &lt;&gt; null then
			if completeStr = null then
				completeStr := vesselName;
			else
				completeStr := completeStr &amp; _delim &amp; vesselName;
			endif;
		endif;
	endforeach;
	
	self.vesselStr := completeStr;

epilog

	delete allVessels;

end;</source>
