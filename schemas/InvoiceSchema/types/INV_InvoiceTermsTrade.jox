    <JadeMethod name="setupPermissions" id="964a47d3-f154-4fe4-8eff-ce248068d8b8">
        <updating/>
        <source>setupPermissions() updating;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if app.getMyUser.canDo(null, self.permissionMaint) then
		self.allowAdd	 := true;
		self.allowDelete := true;
		self.allowUpdate := true;
	else
		self.allowAdd	 := false;
		self.allowDelete := false;
		self.allowUpdate := false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="fff6a88d-f3b0-4a4b-a97b-e94af0269290">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theInvoiceTermsOfTrade 	: CM_InvoiceTermsOfTrade;
	theTable 				: CM_ThumbnailTable;
begin
	theInvoiceTermsOfTrade 	:= obj.CM_InvoiceTermsOfTrade;
	theTable 				:= self.tblThumb;
	
	theTable.rows := 0;
	self.tblThumb.columns := 2;
	self.showThumbnailForDef(ETDef_InvMaintTermsTrade, theInvoiceTermsOfTrade);
//	theTable.fitColumnWidths();

end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="98fd7967-980c-49c1-b1fa-8be25991e931">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006207, locale);
end;</source>
    </JadeMethod>
</GUIClass>
