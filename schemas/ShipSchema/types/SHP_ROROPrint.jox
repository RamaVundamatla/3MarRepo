    <JadeMethod name="printDeckStructure" id="4ffd6d60-ce66-4cd8-80a7-019a0e158dc7">
        <source>printDeckStructure(	_printFrame : CMUI_PointDrawingFrame input;
					_deck : CM_Deck input ) protected;
/*

Date		Who		Reason
05 November 2014	cnwer1	Initial creation PAR

*/

vars
	layerLayout : CM_DeckLayerLayout;
	deckItemLayout : CM_DeckItemLayout;
begin
	//epr make sure we only print visible STRUCTURAL layers and layer items
	foreach layerLayout in _deck.myDeckLayout.allDeckLayerLayouts reversed where layerLayout.isVisible and  layerLayout.type = ROROLayerType_Structure do // PAR 27595 added reversed
	
		foreach deckItemLayout in layerLayout.allDeckItemLayouts where deckItemLayout.isVisible do
			// do this so that the lines are thickness of one.
			_printFrame.doPointArrayAdd(deckItemLayout.drawLineColour, true, deckItemLayout.drawFillStyle, 1, deckItemLayout.drawFillColour, deckItemLayout);
		endforeach;
	endforeach;
	
	_printFrame.showText:=false;//self.chkPrintLabels.value;
	_printFrame.showColour:=self.chkPrintColour.value;
	
	_printFrame.drawAllPolygons(White);
	_printFrame.doBtnClearClickArrays;
	_printFrame.allPointGraphics.clear;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_printFrame" type="CMUI_PointDrawingFrame" usage="input"/>
        <Parameter name="_deck" type="CM_Deck" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCaption" id="f3af6262-60a1-47c6-b76c-0420e82414e8">
        <updating/>
        <source>setCaption(_caption: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	
	
	self.caption := _caption &amp; " - " &amp; self.getVoyageCode &amp; " " &amp; self.getModeString() ;
	
epilog

end;</source>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="99fffd4a-88d3-4bf0-a731-53c2fd4d77f0">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	inheritMethod();
	
	self.frmDeckPrint.width:=3000;
	app.printer.documentType := Print_A4;
	app.printer.orientation:=Print_Landscape;
	self.backColor := self.frmMain.backColor; //cnwas3 par 27659
	self.showPrinterName();
	
	if self.modeView &lt;&gt; 0 then
		self.chkPrintColour.value:=true;
		self.chkPrintColour.visible:=false;
		self.chkPrintLabels.value:=true;
		self.chkPrintLabels.visible:=false;
				
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupHeaderFooter" id="cff24cfc-a157-49f6-a935-3f6f99524bca">
        <source>setupHeaderFooter( _headerForm :CMUI_ReportLine input;_footerForm : CM_GenericTablePrint input; _deckToPrint : CM_Deck) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2011	cnwer1	Initial creation CCMS 1031
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	
	now	: TimeStamp;
begin
	
	_headerForm.initReport;
	_headerForm.lblTitle01.caption :=  app.getProductName;
	_headerForm.lblTitle03.caption :=   app.getErrorString(Deck_definition);
	_headerForm.lblTitle02.caption :=  self.getVoyageCode  ;
	_headerForm.lblTitle04.caption := self.getModeString();
	

	_headerForm.lblPrintedBy.caption := null;
	_headerForm.lblPrintedBylbl.caption := null;
	_headerForm.initReportForLandscape();
	
	app.printer.setMargins(Print_Landscape,5,5,Margin,Margin);
	app.printer.setHeader(_headerForm.frHeader);

	app.printer.suppressDialog := true;
	app.printer.documentType := Print_A4;
	
	now:=app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	_footerForm.frFooter.width := app.printer.pageWidth;
	_footerForm.lblTheUser.caption := app.getMyUserCode;
	_footerForm.lblTheDatePrinted.caption := self.systemToLocalTime(now).asStringJMT;	// 10/6/16 cnwmp6 TFS 488 - Multi timezone support
	app.printer.setFooter(_footerForm.frFooter);
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_headerForm" type="CMUI_ReportLine" usage="input"/>
        <Parameter name="_footerForm" type="CM_GenericTablePrint" usage="input"/>
        <Parameter name="_deckToPrint" type="CM_Deck"/>
    </JadeMethod>
    <JadeMethod name="setupPrintViewPortFrames" id="08117c91-a552-4276-a84d-c848761db798">
        <updating/>
        <source>setupPrintViewPortFrames(_printFrame : CMUI_PointDrawingFrame output;
						 _viewPort : CMUI_Frame output	) updating, protected;
/*

Date		Who		Reason
05 November 2014	cnwer1	Initial creation PAR

*/

vars

begin
	_viewPort := self.frmPrint.cloneSelf(true);
	self.addControl(_viewPort);
	_viewPort.transparent:=false;
	_viewPort.backColor:=White;
	_viewPort.borderStyle:=Control.BorderStyle_None;
	_viewPort.visible := true;
	_viewPort.autoRedraw := true;
	_viewPort.left:=0;
	_viewPort.top:=0;
	
	_printFrame := self.frmDeckPrint.cloneSelf(true);
	_printFrame.parent:=_viewPort;
	_printFrame.left:=0;
	_printFrame.top:=0;
	self.addControl(_printFrame);	

	_printFrame.borderStyle:=Control.BorderStyle_None;
	_printFrame.transparent := true;
	_printFrame.visible := true;
	_printFrame.autoRedraw := true;
	_printFrame.CMUI_PointDrawingFrame.mode := CMUI_PointDrawingFrame.Mode_DisplayOnly;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_printFrame" type="CMUI_PointDrawingFrame" usage="output"/>
        <Parameter name="_viewPort" type="CMUI_Frame" usage="output"/>
    </JadeMethod>
    <JadeMethod name="showPrinterName" id="86f84250-e499-40b3-9b50-2e988ddfedb3">
        <source>showPrinterName() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	self.picPrinter.bubbleHelp := app.getErrorString1(PRINT_MESS_PT1, app.printer.getPrinterName() ) &amp; Cr &amp;  app.getErrorString(PRINT_MESS_PT2);
	
epilog

end;</source>
