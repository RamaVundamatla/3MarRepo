    <JadeMethod name="doQuery" id="f18bd361-bae2-4792-9cbe-a73ba353dada">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tuckAwayRow,
	numCols,
	numRows 				: Integer;
	theFilter				: CMQF_TerminalTIs;
	theQryReport			: CM_QryReport;
	tbl						: CM_DataTable;
	ls						: Boolean;	
	cmifMonitor				: CMIF_Monitor;
	anObject : CM_Object;
begin
	
	self.mousePointer := Window.MousePointer_HourGlass;
	app.cmsBeginLoad(ls);

	self.tblInfo.rows := self.tblInfo.fixedRows;
	self.tblData.rows := self.tblData.fixedRows;
	self.tblData.clearAllSelected();
	
	tbl := self.tblData;
	self.doNotableClear();
	
	self.displayTable();
	self.setCaption(app.getErrorString(Train) &amp; " " &amp; app.getErrorString(Enquiry) &amp; " - " &amp; self.getQueryCaption());
	self.frmQuery.visible := (self.tblData.rows = self.tblData.fixedRows);	
	
epilog
	app.cmsEndLoad(ls);	
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
