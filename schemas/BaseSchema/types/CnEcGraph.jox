    <JadeMethod name="clearGraph" id="b999e3c1-271b-4693-82bb-831626c03f5b">
        <updating/>
        <source>clearGraph()updating;

begin
	//self.graphTitle	:=	"";
	self.allGraphValues.purge();
	self.allGraphColors.purge();
	self.allGraphLegends.purge();
	self.maxValue	:=	1;
	self.clearGraphics();
end;</source>
    </JadeMethod>
    <JadeMethod name="createTitleLabel" id="8b0582d2-1558-4d89-ae99-e6f937a68ed4">
        <updating/>
        <source>createTitleLabel() updating, protected;

vars
	labelObj	: Label;
	
begin
	if self.myTitleLabel &lt;&gt; null then
		delete self.myTitleLabel;
	endif;
	
	create labelObj transient;
	
	labelObj.name		:=	self.TITLE_LABEL;
	labelObj.parent		:=	self;
	labelObj.left		:=	1;
	labelObj.top		:=	1;
	
	if self.graphTitle &lt;&gt; "" then		
		labelObj.visible	:=	true;		
	else
		self.graphTitle		:=	"No Title";
		labelObj.visible	:=	false;
	endif;
	
	labelObj.caption	:=	self.graphTitle;
	labelObj.height		:=	labelObj.getTextHeight(self.graphTitle);
	labelObj.width		:=	self.width - 2;
	labelObj.backColor	:=	self.backColor;
	labelObj.foreColor	:=	Black;
	labelObj.alignment	:=	Label.Alignment_Center_Middle;
	
	form.addControl(labelObj);
	
	self.myTitleLabel		:=	labelObj;
	self.graphLabelHeight	:=	labelObj.height.Integer;				
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDataError" id="f385ccfb-3c7f-401c-8354-63f5cf8ec375">
        <updating/>
        <source>doDataError(pErrorMessage : String) updating, protected;

begin
	self.myTitleLabel.height	:=	self.getTextHeight(pErrorMessage);
	self.myTitleLabel.parent	:=	self;
	self.myTitleLabel.caption	:=	pErrorMessage;
end;</source>
        <access>protected</access>
        <Parameter name="pErrorMessage" type="String"/>
    </JadeMethod>
    <JadeMethod name="drawGraph" id="f5030b56-d540-46eb-bf0b-2de809ca19d5">
        <updating/>
        <source>drawGraph()updating;

begin
	if self.isInPainter() then
		self.setDefaultsInPainter();
	endif;
	
	self.createTitleLabel();
	
	if self.myLegend &lt;&gt; null then
		self.myLegend.setGraph(self, self.graphTitle);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setDefaultsInPainter" id="68e1fc0a-b7c0-473e-afe7-b569162d8250">
        <updating/>
        <source>setDefaultsInPainter() updating, protected;

begin
	if self.graphTitle = null then
		self.graphTitle	:=	self.name &amp; " - Sample data";
	endif;
	 
	self.allGraphValues.add(10);
	self.allGraphValues.add(20);
	self.allGraphValues.add(50);
	self.allGraphValues.add(30);
	self.allGraphValues.add(40);
	
	self.allGraphColors.add(Red);	
	self.allGraphColors.add(Green);
	self.allGraphColors.add(Blue);
	self.allGraphColors.add(Purple);
	self.allGraphColors.add(Yellow);
	
	self.transparent	:=	false;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMaxScaleLength" id="6dcd562a-c4c0-419a-a0c4-e51f55c62c08">
        <updating/>
        <source>setMaxScaleLength() updating, protected;

vars
	labelObj	: Label;
	scaleValue	: Real;
	
begin
	self.maxScaleLabelWidth	:=	0;
	
	foreach scaleValue in self.allGraphValues do
		if scaleValue &gt; self.maxValue then
			self.maxValue	:=	scaleValue.roundedUp();
		endif;
	endforeach;
	
	create labelObj transient;
	labelObj.caption		:=	scaleValue.String;
	self.maxScaleLabelWidth	:=	labelObj.width.Integer;	
epilog
	delete labelObj;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="6e6fbc29-a59d-4159-9652-f39c1e14026f">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// --------------------------------------------------------------------------------
// Created:		07 January 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(cntrl, persistCntrl);
	
	self.autoRedraw	:=	true;
	
	if self.isInPainter() then
		self.clearGraph();
		self.drawGraph();
	else
		self.drawGraph();
	endif;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
