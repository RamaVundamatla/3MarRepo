    <JadeMethod name="addTi" id="56a86673-47b6-49b7-a28a-ed3458fc64ce">
        <updating/>
        <source>addTi(	_ti : CM_TrackedItem; _inward : Boolean ) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	type : String;
	line : CMIF_TrainStatCargoLine;
	weight : Decimal [12,2];
	teu : Real;
	
begin

	type := _ti.getPlannerReportGroupDesc;
	weight :=  _ti.totalWeight;
	teu := _ti.getNumTEU;

	line := self.getExistingCargoLine( type );
	
	if line = null then
		create line transient;
		line.setBaseDetails(	type,	//_type : String;
								self	//_myCMIF_TrainStatCargoLineTot : CMIF_TrainStatCargoLineTotal
								);
	endif;
	
	line.addTi(	_inward,	//_inward : Boolean;
				_ti,	//_ti : CM_TrackedItem;
				teu,	//_teu : Real;
				weight	//_weight : Decimal
				);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_inward" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addTiForMSLReport" id="9d7b999c-ddf2-4aab-9920-e402092b92e3">
        <updating/>
        <source>addTiForMSLReport(	_ti : CM_TrackedItem;
					_firstWorked : TimeStamp;
					_lastWorked : TimeStamp
					) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	full : Boolean;
	is20 : Boolean;
	is40 : Boolean;
	isOther : Boolean;
	
begin

	full := _ti.isFull;
	is20 := _ti.isTwenty;
	is40 := _ti.isForty;
	isOther := not is20 and not is40;
	
	if full then
		if is20 then
			self.full20 := self.full20 + 1;
		elseif is40 then
			self.full40 := self.full40 + 1;
		elseif isOther then
			if _ti.is30 then
				self.full30 := self.full30 + 1;
			elseif _ti.is45 then
				self.full45 := self.full45 + 1;
			elseif _ti.is53 then
				self.full53 := self.full53 + 1;
			endif;
			self.fullOther := self.fullOther + 1;
		endif;
	
	elseif not full then
		if is20 then
			self.mt20 := self.mt20 + 1;
		elseif is40 then
			self.mt40 := self.mt40 + 1;
		elseif isOther then
			if _ti.is30 then
				self.mt30 := self.mt30 + 1;
			elseif _ti.is45 then
				self.mt45 := self.mt45 + 1;
			elseif _ti.is53 then
				self.mt53 := self.mt53 + 1;
			endif;
			self.mtOther := self.mtOther + 1;
		endif;
		
	endif;
	
	self.totalItems := self.totalItems + 1;
	
	self.totalTeu := self.totalTeu + _ti.getNumTEU.Integer;

	if _firstWorked &lt;&gt; null then
		if self.workStarted = null or  ( self.workStarted &gt; _firstWorked ) then
			self.workStarted := _firstWorked;
		endif;
	endif;

	if _lastWorked &lt;&gt; null then
		if self.workEnded = null or ( self.workEnded &lt; _lastWorked ) then
			self.workEnded := _lastWorked;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_firstWorked" type="TimeStamp"/>
        <Parameter name="_lastWorked" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="addWLE" id="ad788e99-4c12-4739-88fe-2049adb33f19">
        <updating/>
        <source>addWLE(_wle : CM_WorkListEntry; _inward : Boolean) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/11/2010	cnwdap1	Initial creation PAR #23794 CCMS MES 1102
*/
vars
	type	: String;
	line	: CMIF_TrainStatCargoLine;

begin
	type := _wle.getPlannerReportGroupDesc;
	line := self.getExistingCargoLine( type );
	
	if line = null then
		create line transient;
		line.setBaseDetails(	type,	//_type : String;
								self	//_myCMIF_TrainStatCargoLineTot : CMIF_TrainStatCargoLineTotal
								);
	endif;
	
	line.addWLE(_wle);	//_wle : CM_WorkListEntry;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_inward" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addWagon" id="2ac025f9-08de-4e2f-8b4d-08cd9783fee9">
        <updating/>
        <source>addWagon( _wagon : CM_Wagon; _inward : Boolean ) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	wagonClass : String;
	line : CMIF_TrainStatWagonLine;
	weight : Decimal [12,2];
	
begin

	if _wagon.myWagonClass = null then
		wagonClass := null;
	else
		wagonClass := _wagon.myWagonClass.code;
	endif;
	weight :=  _wagon.getWagonTareWeight;

	line := self.getExistingWagonLine( wagonClass );
	
	if line = null then
		create line transient;
		line.setBaseDetails(	wagonClass,	//_type : String;
								self	//_myCMIF_TrainStatCargoLineTot : CMIF_TrainStatCargoLineTotal
								);
	endif;
	
	line.addWagon(	_inward,	//_inward : Boolean;
					weight	//_weight : Decimal
					);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_inward" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCargoTotalStrings" id="2a0aa63f-f2e9-41fa-8026-dc46eab34302">
        <source>getCargoTotalStrings(	_type : String output;	
					_totItemsIn : String output;
					_totTeuIn : String output;
					_totWeightIn : String output;
					_totItemsOut : String output;
					_totTeuOut : String output;
					_totWeightOut : String output;
					_useSeperator : Boolean
					);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	iter : Iterator;
	line : CMIF_TrainStatCargoLine;
	totItemsIn : Integer;
	totTeuIn : Real;
	totWeightIn : Decimal [12,2];
	totItemsOut : Integer;
	totTeuOut : Real;
	totWeightOut : Decimal [12,2];
	
begin

	iter := self.allCMIF_TrainStatCargoLines.createIterator;
	
	while iter.next( line ) do

		totItemsIn := totItemsIn + line.itemsIn;
		totTeuIn := totTeuIn + line.teuIn;
		totWeightIn := totWeightIn + line.weightIn;
		totItemsOut := totItemsOut + line.itemsOut;
		totTeuOut := totTeuOut + line.teuOut;
		totWeightOut := totWeightOut + line.weightOut;
			
	endwhile;
	
	_type := app.getErrorString(Total) &amp; ":";
	_totItemsIn := totItemsIn.asStringJMTWithOptionalCommas(_useSeperator,true);
	_totTeuIn := totTeuIn.Integer.asStringJMTWithOptionalCommas(_useSeperator,true);
	_totWeightIn := totWeightIn.Integer.asStringJMTWithOptionalCommas(_useSeperator,true);
	_totItemsOut := totItemsOut.asStringJMTWithOptionalCommas(_useSeperator,true);
	_totTeuOut := totTeuOut.Integer.asStringJMTWithOptionalCommas(_useSeperator,true);
	_totWeightOut := totWeightOut.Integer.asStringJMTWithOptionalCommas(_useSeperator,true);
	
epilog

	delete iter;
	
end;</source>
        <Parameter name="_type" type="String" usage="output"/>
        <Parameter name="_totItemsIn" type="String" usage="output"/>
        <Parameter name="_totTeuIn" type="String" usage="output"/>
        <Parameter name="_totWeightIn" type="String" usage="output"/>
        <Parameter name="_totItemsOut" type="String" usage="output"/>
        <Parameter name="_totTeuOut" type="String" usage="output"/>
        <Parameter name="_totWeightOut" type="String" usage="output"/>
        <Parameter name="_useSeperator" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getExistingCargoLine" id="7fe0ef92-88a9-4f2d-851a-cd6e01c94895">
        <source>getExistingCargoLine( _type : String ) : CMIF_TrainStatCargoLine;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	iter : Iterator;
	line : CMIF_TrainStatCargoLine;
	
begin


	iter := self.allCMIF_TrainStatCargoLines.createIterator;
	while iter.next( line ) do
		if line.type &lt;&gt; _type then
			continue;
		endif;
		return line;
	endwhile;
	
	return  null;
	
epilog

	delete iter;
	
end;</source>
        <Parameter name="_type" type="String"/>
        <ReturnType type="CMIF_TrainStatCargoLine"/>
    </JadeMethod>
    <JadeMethod name="getExistingWagonLine" id="feda8dae-4fd2-4c20-97c6-1eda8e90bd03">
        <source>getExistingWagonLine( _wagonClass : String ) : CMIF_TrainStatWagonLine;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	iter : Iterator;
	line : CMIF_TrainStatWagonLine;
	
begin


	iter := self.allCMIF_TrainStatWagonLines.createIterator;
	while iter.next( line ) do
		if line.wagonClass &lt;&gt; _wagonClass then
			continue;
		endif;
		return line;
	endwhile;
	
	return  null;
	
epilog

	delete iter;
	
end;</source>
        <Parameter name="_wagonClass" type="String"/>
        <ReturnType type="CMIF_TrainStatWagonLine"/>
    </JadeMethod>
    <JadeMethod name="getName" id="b85bb598-75ee-4ee7-88e5-8475a4decb91">
        <source>getName(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	str : String;
	dirString : String;
	
begin

	if myTrain &lt;&gt; null and myShift &lt;&gt; null then
		if inward then
			dirString := "discharge";
		else
			dirString := "load";
		endif;
		str := myTrain.getCodeDateString &amp; " : " &amp; dirString &amp; " [" &amp; myShift.startDateTime.String &amp; "] : " &amp; totalItems.String;
	elseif myTrain &lt;&gt; null then
		str := myTrain.getCodeDateString &amp; " : Stats";
	endif;

	if str.trimBlanks = null then
		return inheritMethod();
	endif;
	
	return str.trimBlanks;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTrainTotalWeightStrings" id="e376e6a4-8616-4137-8e69-5c687f1bd1c0">
        <source>getTrainTotalWeightStrings( _totalInwardWeight : String output;
							_totalOutwardWeight : String output;
							_useSeperator : Boolean
							);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	iter : Iterator;
	cargoLine : CMIF_TrainStatCargoLine;
	wagonLine : CMIF_TrainStatWagonLine;
	totWeightIn : Decimal [12,2];
	totWeightOut : Decimal [12,2];
	totTareWeightIn : Decimal [12,2];
	totTareWeightOut : Decimal [12,2];
	
begin

	iter := self.allCMIF_TrainStatCargoLines.createIterator;
	while iter.next( cargoLine ) do

		totWeightIn := totWeightIn + cargoLine.weightIn;
		totWeightOut := totWeightOut + cargoLine.weightOut;
			
	endwhile;
	delete iter;
	
	iter := self.allCMIF_TrainStatWagonLines.createIterator;
	while iter.next( wagonLine ) do

		totTareWeightIn := totTareWeightIn + wagonLine.tareWeightIn;
		totTareWeightOut := totTareWeightOut + wagonLine.tareWeightOut;
			
	endwhile;
	delete iter;
	
	_totalInwardWeight := (totWeightIn + totTareWeightIn).Integer.asStringJMTWithOptionalCommas(_useSeperator,true);
	_totalOutwardWeight := (totWeightOut + totTareWeightOut).Integer.asStringJMTWithOptionalCommas(_useSeperator,true);

epilog
	
	delete iter;
	
end;</source>
        <Parameter name="_totalInwardWeight" type="String" usage="output"/>
        <Parameter name="_totalOutwardWeight" type="String" usage="output"/>
        <Parameter name="_useSeperator" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getWagonTotalStrings" id="84166115-d989-4d04-8ed0-e30aa6e6984f">
        <source>getWagonTotalStrings(	_wagonClass : String output;	
						_totWagonsIn : String output;
						_totTareWeightIn : String output;
						_totWagonsOut : String output;
						_totTareWeightOut : String output;
						_useSeperator : Boolean
						);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	iter : Iterator;
	line : CMIF_TrainStatWagonLine;
	totWagonsIn : Integer;
	totTareWeightIn : Decimal [12,2];
	totWagonsOut : Integer;
	totTareWeightOut : Decimal [12,2];
	
begin

	iter := self.allCMIF_TrainStatWagonLines.createIterator;
	
	while iter.next( line ) do

		totWagonsIn := totWagonsIn + line.numWagonsIn;
		totTareWeightIn := totTareWeightIn + line.tareWeightIn;
		totWagonsOut := totWagonsOut + line.numWagonsOut;
		totTareWeightOut := totTareWeightOut + line.tareWeightOut;
			
	endwhile;
	
	_wagonClass := app.getErrorString(Total) &amp; ":";
	_totWagonsIn := totWagonsIn.asStringJMTWithOptionalCommas(_useSeperator,true);
	_totTareWeightIn := totTareWeightIn.Integer.asStringJMTWithOptionalCommas(_useSeperator,true);
	_totWagonsOut := totWagonsOut.asStringJMTWithOptionalCommas(_useSeperator,true);
	_totTareWeightOut := totTareWeightOut.Integer.asStringJMTWithOptionalCommas(_useSeperator,true);
	
epilog

	delete iter;
	
end;</source>
        <Parameter name="_wagonClass" type="String" usage="output"/>
        <Parameter name="_totWagonsIn" type="String" usage="output"/>
        <Parameter name="_totTareWeightIn" type="String" usage="output"/>
        <Parameter name="_totWagonsOut" type="String" usage="output"/>
        <Parameter name="_totTareWeightOut" type="String" usage="output"/>
        <Parameter name="_useSeperator" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setBaseDataForMSLReport" id="d90f454f-0172-49cb-885b-deb85109b5e6">
        <updating/>
        <source>setBaseDataForMSLReport(	_inward : Boolean;
							_myShift : CM_Shift;
							_myTrain : CM_Train;
							_header : CMIF_TrainShiftHeaderMSL
							) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	iter : Iterator;
	tis : CM_TIArray;
	
begin

	self.inward := _inward;
	self.myShift := _myShift;
	self.myTrain := _myTrain;
	self.myCMIF_TrainShiftHeaderMSL := _header;
	
epilog

end;</source>
        <Parameter name="_inward" type="Boolean"/>
        <Parameter name="_myShift" type="CM_Shift"/>
        <Parameter name="_myTrain" type="CM_Train"/>
        <Parameter name="_header" type="CMIF_TrainShiftHeaderMSL"/>
    </JadeMethod>
    <JadeMethod name="setMyTrainAndCreateStats" id="2e79ad64-41bc-4964-91b0-7796e4d543d2">
        <updating/>
        <source>setMyTrainAndCreateStats( _train : CM_Train ) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/11/2009	cnwndl1	Initial creation	Par 21519
15/11/2010	cnwdap1	PAR #23794 CCMS MES 1102 Include WLEs in totals
*/
vars

	iter : Iterator;
	tiArray : CM_TIArray;
	ti : CM_TrackedItem;
	wagon : CM_Wagon;
	wleArray : CM_WLEArray;		// PAR #23794
	wleIter : Iterator;			// PAR #23794
	wle : CM_WorkListEntry;		// PAR #23794
	
begin

	self.allCMIF_TrainStatCargoLines.purge();
	
	if _train = null then
		self.myTrain := null;
		return;
	else
		self.myTrain := _train;
	endif;
	
	create tiArray transient;
	create wleArray transient;		// PAR #23794
	
	// ### CARGO INWARDS
	self.myTrain.getAllTrackedItems(true,tiArray);
	if not tiArray.isEmpty then
		iter := tiArray.createIterator;
		while iter.next( ti ) do
			self.addTi( ti, true);
		endwhile;
		delete iter;
	endif;
	
	// ### CARGO OUTWARDS
	tiArray.clear();
//	PAR 223113 self.myTrain.getAllTrackedItems(false,tiArray);
	self.myTrain.getAllTrackedItemsProposed(tiArray); // PAR 223113 - all outward cargo ACTUAL PLANNED AND QUEUED
	if tiArray.isEmpty and self.myTrain.isDeparted then	//13 Sep 2013	NDL	Par 32452
		self.myTrain.getAllTrackedItems( false, tiArray );
	endif;
	if not tiArray.isEmpty then
		iter := tiArray.createIterator;
		while iter.next( ti ) do
			self.addTi( ti, false);
		endwhile;
		delete iter;
	endif;
	
	// PAR #23794 Work List Entries included too (but not WLEs where the tracked item has already been found above)
	// ### WLES OUTWARDS
	self.myTrain.getAllWLEs(wleArray);
	if not wleArray.isEmpty then
		wleIter := wleArray.createIterator;
		while wleIter.next(wle) do
			if not tiArray.includes(wle.myTrackedItem) then
				self.addWLE(wle, false);
			endif;
		endwhile;
	endif;
	// PAR #23794 end
	
	// ### WAGONS
	if not myTrain.allWagonsByIdInward.isEmpty then
		iter := myTrain.allWagonsByIdInward.createIterator;
		while iter.next( wagon ) do
			self.addWagon( wagon, true);
		endwhile;
		delete iter;
	endif;
	
	if not myTrain.allWagonsByIdOutward.isEmpty then
		iter := myTrain.allWagonsByIdOutward.createIterator;
		while iter.next( wagon ) do
			self.addWagon( wagon, false);
		endwhile;
		delete iter;
	endif;
	
epilog

	delete tiArray;
	delete iter;
	delete wleArray;	// PAR #23794
	delete wleIter;		// PAR #23794
	
end;</source>
        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
</Class>
