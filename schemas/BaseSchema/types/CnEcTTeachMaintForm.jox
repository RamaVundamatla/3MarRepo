    <JadeMethod name="btnNextActivity_click" id="4e7b7686-1dcd-44e7-9da8-827bd7a0b00b">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNextActivity_click(juice: JadeMask input) updating;

begin
	btnSaveActivity1.click(btnSaveActivity1);
	btnNewActivity1.click(btnNewActivity1);
	aMyActivity := null;
end;</source>
        <Parameter name="juice" type="JadeMask" usage="input"/>
    </JadeMethod>
