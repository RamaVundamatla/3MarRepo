    <JadeMethod name="utlCreateEDIAction" id="7c29d421-96ca-434d-87a2-f3687a7cb6dc">
        <updating/>
        <source>utlCreateEDIAction(_pxyEDIAction: CM_EDIAction; _ediAction : CM_EDIAction io; _passport : CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	01 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.initialiseActivity();

	app.setContinueCMExceptions(false);

	if _pxyEDIAction = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'the proxy object is null');
		return;
	endif;
	
	_pxyEDIAction.validateForCreate();
	
	if _passport.hasErrors then
		return;
	endif;
	
	create _ediAction persistent;
	
	_ediAction.setForCreate(_pxyEDIAction);
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_ediAction);
	endif;
end;</source>
