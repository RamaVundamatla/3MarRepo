    <JadeMethod name="checkandsetCmbStatus" id="6ccaf90d-8902-4758-9c0a-7595a8f29f5c">
        <updating/>
        <source>checkandsetCmbStatus(voyageProcess : CM_VoyageProcess; currentStatus : Integer) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 07 August 2019
TFS#		: 45921
Function	: This functions check if the current voyage status, 
			  is found in the list of Voyages Statuses assigned to the Terminal Role of the current user.
			  If it is not found this will add the Voyage Status in the combobox then disable the control,
			  to make it impossible for the user to change the value, this is to fixed the bug where a user
			  edit a specific voyage where they don't have any access in the current Voyage Status of the Voyage then it will be set to Pending.

*** Changes ***
Date		Name	TFS#	Description
08/10/2019	jlgka1 	46918	PEL - ~TOP URGENT~ CANNOT CHANGE VOYAGE STATUS IN VOYAGE ENQUIRY. Initialised isCmbStatusEmpty value to false first.							
****************************************************/

vars
	status : CM_VoyageStatus; 
begin
	self.isCmbStatusEmpty := false; // jlgka1 	46918
	if voyageProcess = null then
		return;
	endif;
	
	if self.cmbStatus.listIndex = -1 then
		if currentStatus = null then
			status := voyageProcess.getInitialVoyageStatus;
		else
			status := app.myRoot.allVoyageStatuses[currentStatus];			
		endif;
		self.cmbStatus.addItemObject(status.description, status);
		self.cmbStatus.listIndex := self.cmbStatus.findString(0, app.voyageStatusEnumToString(status.id, false));						
		self.isCmbStatusEmpty := true;
	endif;

end;</source>
        <Parameter name="voyageProcess" type="CM_VoyageProcess"/>
        <Parameter name="currentStatus" type="Integer"/>
    </JadeMethod>
