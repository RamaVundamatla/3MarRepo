    <JadeMethod name="showCargoPicture" id="cfc7bab1-3f80-4997-b8fc-c2123e4fba31">
        <source>showCargoPicture(_theTI : CM_TrackedItem) : Binary;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	thePicture : Binary;
begin
	
	
	if _theTI = null then
		return null;
	endif;
 	if not self.myTerminal.getConfig(ShowCargoPicture).Boolean then
		return null;
 	endif;

	if _theTI.isPallet() then
		thePicture := self.picPallet.picture;
	else
		thePicture := _theTI.getPicture();
	endif;

	return thePicture;
	
	
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="showColumnOrganiser" id="e88041da-0198-4277-a6d3-e41e01c4f9a4">
        <updating/>
        <source>showColumnOrganiser(_dataTable : CM_DataTable input)updating;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 18 September 2003
//
//-----------------------------------------------------------------------

vars

begin
	if _dataTable = null then
		return;
	endif;
	_dataTable.showColumnOrgSizesForm(self.myTerminal, null);

end;
</source>
        <Parameter name="_dataTable" type="CM_DataTable" usage="input"/>
