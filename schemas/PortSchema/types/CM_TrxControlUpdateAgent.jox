        <source>trxUpdateInvoiceLineConvert(_controller : CMIF_InvoiceLineConvert;_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	pxyInvoiceLine : CM_InvoiceLine;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);

	beginTransaction;

	if not _controller.allInvoiceLines.isEmpty then
		foreach pxyInvoiceLine in _controller.allInvoiceLines do
			app.myUtilityUA.utlUpdateInvoiceLineConvert( pxyInvoiceLine, _controller.myInvoiceLineDesc, _passport);
		if _passport.hasErrors() then
			return;
		endif;
		endforeach;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
