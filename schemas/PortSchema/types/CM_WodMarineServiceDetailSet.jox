<CollClass name="CM_WodMarineServiceDetailSet" id="c9d63197-56e4-42b2-9a25-d42eea744a62">
    <loadFactor>98</loadFactor>
    <memberType name="CM_WodMarineServiceDetail"/>
    <superclass name="CM_ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="workorder"/>
    <JadeMethod name="findWodMarineServiceDet" id="4f7f66f4-4e94-4b6f-ae4e-bbc80c5e75d6">
        <source>findWodMarineServiceDet( _resource : HMS_Resource ):CM_WodMarineServiceDetail;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2018	jlgndl1	Initial creation	TFS 39248

*/

vars

	wodMarineServiceDet : CM_WodMarineServiceDetail;

begin

	foreach wodMarineServiceDet in self do
		if _resource = wodMarineServiceDet.myHMSResource then
			return wodMarineServiceDet;
		endif;
	endforeach;
	
	return null;

epilog

end;</source>
        <Parameter name="_resource" type="HMS_Resource"/>
        <ReturnType type="CM_WodMarineServiceDetail"/>
    </JadeMethod>
    <JadeMethod name="findWodMarineServiceDet2" id="98ab2e76-eb92-488b-a7ad-1b966426fc2c">
        <source>findWodMarineServiceDet2( _ref : CM_WodMarineServiceDetail ):CM_WodMarineServiceDetail;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2018	jlgndl1	Initial creation	TFS 41980

*/

vars

	wodMarineServiceDet : CM_WodMarineServiceDetail;
	real : CM_WodMarineServiceDetail;
	proxy : CM_WodMarineServiceDetail;

begin

	if _ref = null then
		return null;
	endif;
	
	if _ref.isTransient then
		proxy := _ref;
		real := _ref.pxyGetRealObject;
	else
		real := _ref;
		proxy := _ref.pxyGetProxyObject;
	endif;

	foreach wodMarineServiceDet in self do
		if wodMarineServiceDet = proxy then
			return wodMarineServiceDet;
		elseif wodMarineServiceDet = real then
			return wodMarineServiceDet;
		endif;
	endforeach;
	
	return null;

epilog

end;</source>
        <Parameter name="_ref" type="CM_WodMarineServiceDetail"/>
        <ReturnType type="CM_WodMarineServiceDetail"/>
    </JadeMethod>
</CollClass>
