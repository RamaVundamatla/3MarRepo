<Class name="AtcgCellMate" id="541415ab-7fd7-491e-be28-928046d4147f">
    <superclass name="AtcgCommonEntity"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="JtdCommon"/>
    <PrimAttribute name="column" id="b66da120-1d20-4bb8-ae09-341b416a44b3">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <ImplicitInverseRef name="control" id="3eb5bfd9-c6b9-431f-b9f8-396e00f3c3fc">
        <embedded/>
        <type name="Control"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="form" id="50b25d2e-7330-4471-a07d-7a0ea845ddf1">
        <embedded/>
        <type name="Form"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="meth" id="ba4c7ca6-9f74-4a08-b149-36ed22fb4b24">
        <embedded/>
        <type name="Method"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="receiver" id="69df75fa-f0b4-4f4c-bf1d-ea5cac8361e3">
        <embedded/>
        <type name="Object"/>
    </ImplicitInverseRef>
    <PrimAttribute name="row" id="fa6a1549-63c1-47df-b00b-b00bd52223a9">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <ImplicitInverseRef name="table" id="63da44d0-4e60-4381-83cd-4a21004ccb85">
        <embedded/>
        <type name="Table"/>
    </ImplicitInverseRef>
    <PrimAttribute name="text" id="e9bd1a75-2c30-4c25-87b4-c87f16a59c87">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="getName" id="193a696f-e91b-4153-8aae-c5a349c674b6">
        <source>getName():String;

vars
	s,t:String;
begin
	if app.isValidObject(form) then
		s:=s&amp;"form="&amp;form.name;
	else
		s:=s&amp;"form="&amp;form.String;
	endif;
	
	if app.isValidObject(table) then
		s:=s&amp;" table="&amp;table.name&amp;"("&amp;table.String&amp;")";
	else
		s:=s&amp;" table="&amp;table.String;
	endif;
	
	if app.isValidObject(control) then
		s:=s&amp;" control="&amp;control.name&amp;"("&amp;control.String&amp;")";
	else
		s:=s&amp;" control="&amp;control.String;
	endif;
	
	if app.isValidObject(meth) then
		s:=s&amp;" meth="&amp;meth.name;
	else
		s:=s&amp;" meth="&amp;meth.String;
	endif;
	
	s:=s&amp;" receiver="&amp;receiver.String&amp;" row="&amp;row.String&amp;" column="&amp;column.String&amp;" text="&amp;text;
	return s;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
