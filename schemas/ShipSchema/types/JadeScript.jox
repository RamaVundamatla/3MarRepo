<Class name="JadeScript">
    <JadeMethod name="aaaRJSTest1" id="9135ef45-91cc-41f1-b00f-14f93af16206">
        <source>aaaRJSTest1();
// ---------------------------------------------------------------------------
// Created:     09 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	testDataRoot	: CM_TestDataRoot;
	tmpTerminal		: CM_Terminal;
	tmpVoyage		: CM_Voyage;
	tmpForm			: SHP_VoyageAreaForm2;
	tmpSet			: ObjectSet;
begin

	app.initialize;
	
	tmpTerminal := CM_Terminal.firstInstance;

	app.myPassport.setMyUser(app.myRoot.allUsers['CNWRS2']);
	app.myPassport.setMyTerminal(tmpTerminal);
//	app.setPassBackExceptions(false, true);

//	on Exception do app.generalExceptionHandler(exception) global;

	create tmpForm transient;
	tmpForm.createMyAssistant(SHP_Assistant);
	tmpForm.setMyTerminal(tmpTerminal);
	tmpForm.show();
	
	tmpVoyage := tmpTerminal.lookupVoyage('ABGA', null, false);

	tmpForm.cmbVoyage.listObject := tmpVoyage;
	tmpForm.cmbVoyage.click(tmpForm.cmbVoyage);

	tmpForm.msgHolds.setAvailable(tmpVoyage.myCellularVoyageStructure.allHolds,true);
	
	create tmpSet transient;
	tmpSet.add(tmpVoyage.myCellularVoyageStructure.allHolds.first);
	tmpForm.msgHolds.setSelected(tmpSet);

	tmpForm.btnSelectVoyOK_click(tmpForm.btnSelectVoyOK);

epilog
	delete tmpSet;
end;</source>
    </JadeMethod>
