    <JadeMethod name="populateLineUp" id="c14afd76-94d9-44a5-8776-c841fa6d2fb7">
        <updating/>
        <source>populateLineUp(): String updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

	xxString : String;
	repDetails : String;
	
	baseStr1 : String;
	baseStr2 : String;
	baseStr3 : String;
	baseStr4 : String;
	baseStr5 : String;
	baseStr6 : String;
	lineUpString : String;
	obj : Object;
	label : CMUI_Label;
	
	///////////////////////
	
/*	firstLabel : CMUI_Label;
	charWidth : Integer;
	charHeight : Integer;
	labelWidth : Real;
	labelHeight : Real;
	numChars : Integer;
	str : String;
	strChar : String; */
	/////////////////////// 

begin

	repDetails := inheritMethod();
	
	//////////////////////////////
	//Test with labelnames
/*	process.isNDL;
	firstLabel := self.allLabelsArray.first.CMUI_Label;
	charWidth := firstLabel.getTextExtent( "X" );
	charHeight := firstLabel.getTextHeight( "X" );

	foreach obj in self.allLabelsArray do
		str := null;
		
		label := obj.CMUI_Label;
		labelWidth := label.width;
		labelHeight := label.height;
		numChars := ((labelWidth / charWidth).Integer + 1 ) * ((labelHeight / charHeight).Integer + 1 );
		strChar := label.name[4:end];
		while str.length &lt; ( numChars + 1 ) do
			str := str &amp; strChar;
		endwhile;
		label.caption := str;
	endforeach; */
	//////////////////////////////
	
	separator := Cr;
	baseStr1 := "AAAAAAAAAAAAAAA" &amp; self.separator;
	baseStr2 := "BBBBBBBBBBBBBBB" &amp; self.separator;
	baseStr3 := "CCCCCCCCCCCCCCC" &amp; self.separator;
	baseStr4 := "DDDDDDDDDDDDDDD" &amp; self.separator;
	baseStr5 := "EEEEEEEEEEEEEEE" &amp; self.separator;
	baseStr6 := "FFFFFFFFFFFFFFF";
	
	lineUpString := baseStr1 &amp;  baseStr2 &amp;  baseStr3 &amp;  baseStr4 &amp; baseStr5 &amp; baseStr6;
	
	foreach obj in self.itemLabelArray do
		label := obj.CMUI_Label;
		label.caption := lineUpString;
	endforeach; 
	
	xxString := self.lblF.caption;
	
	self.lblF.caption := "XX  '" &amp; repDetails &amp; "'  " &amp; xxString; 
	
	return repDetails;
	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="repositionLabels" id="7ddbb349-b354-44f3-a642-ef1542d15986">
        <source>repositionLabels() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

	topMMs : Real;
	leftMMs : Real;
	rightMMs : Real;
	bottomMMs : Real;

begin
	topMMs := 27;
	bottomMMs := 31;
	leftMMs := 20;	rightMMs := 49;		self.moveLabel( self.lblA, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 4
	leftMMs := 52;	rightMMs := 104;	self.moveLabel( self.lblB, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 3
	leftMMs := 117;	rightMMs := 147;	self.moveLabel( self.lblC, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 2
	leftMMs := 151;	rightMMs := 180;	self.moveLabel( self.lblD, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 1
	
	topMMs := 36;
	bottomMMs := 40;
	leftMMs := 0;	rightMMs := 49;		self.moveLabel( self.lblE, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 7
	leftMMs := 52;	rightMMs := 147;	self.moveLabel( self.lblF, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 6
	leftMMs := 151;	rightMMs := 200;	self.moveLabel( self.lblG, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 5
	
	topMMs := 45;
	bottomMMs := 49;
	leftMMs := 0;	rightMMs := 49;		self.moveLabel( self.lblH, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 10
	leftMMs := 52;	rightMMs := 147;	self.moveLabel( self.lblI, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 9
	leftMMs := 151;	rightMMs := 200;	self.moveLabel( self.lblJ, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 8
	
	topMMs := 54;
	bottomMMs := 58;
	leftMMs := 0;	rightMMs := 49;		self.moveLabel( self.lblK, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 13
	leftMMs := 52;	rightMMs := 147;	self.moveLabel( self.lblL, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 12
	leftMMs := 151;	rightMMs := 200;	self.moveLabel( self.lblM, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 11
	
	topMMs := 62;
	bottomMMs := 66;
	leftMMs := 0;	rightMMs := 49;		self.moveLabel( self.lblN, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 16
	leftMMs := 52;	rightMMs := 147;	self.moveLabel( self.lblO, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 15
	leftMMs := 151;	rightMMs := 200;	self.moveLabel( self.lblP, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 14
	
	topMMs := 72;
	bottomMMs := 92;
	leftMMs := 0;	rightMMs := 64;		self.moveLabel( self.lblBS, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 19
	leftMMs := 136;	rightMMs := 200;	self.moveLabel( self.lblBT, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 17
	
	topMMs := 70;	bottomMMs := 75;	leftMMs := 68;	rightMMs := 132;		self.moveLabel( self.lblBU, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 18	
	topMMs := 79;	bottomMMs := 84;	leftMMs := 68;	rightMMs := 132;		self.moveLabel( self.lblQ, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 20	
	topMMs := 88;	bottomMMs := 92;	leftMMs := 68;	rightMMs := 132;		self.moveLabel( self.lblR, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 21
	
	topMMs := 108;
	bottomMMs := 135;
	leftMMs := 0;	rightMMs := 19;		self.moveLabel( self.lblS, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 31
	leftMMs := 20;	rightMMs := 32;		self.moveLabel( self.lblT, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 30
	leftMMs := 33;	rightMMs := 45;		self.moveLabel( self.lblU, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 29
	leftMMs := 46;	rightMMs := 68;		self.moveLabel( self.lblV, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 28
	leftMMs := 69;	rightMMs := 80;		self.moveLabel( self.lblW, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 27
	leftMMs := 81;	rightMMs := 91;		self.moveLabel( self.lblX, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 26
	leftMMs := 92;	rightMMs := 116;	self.moveLabel( self.lblY, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 25
	leftMMs := 117;	rightMMs := 127;	self.moveLabel( self.lblZ, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 24
	leftMMs := 128;	rightMMs := 172;	self.moveLabel( self.lblAA, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 23
	leftMMs := 173;	rightMMs := 195;	self.moveLabel( self.lblAB, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 22
	
	topMMs := 151;
	bottomMMs := 178;
