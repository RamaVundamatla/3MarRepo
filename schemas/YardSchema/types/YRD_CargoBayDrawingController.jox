    <JadeMethod name="getMoveOverstowCargoForm" id="da2aaf97-c76a-44b0-9057-46d881738b3b">
        <source>getMoveOverstowCargoForm() : YRD_MoveOverstowCargoForm;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 February 2010	cnwer1	Initial creation

*/

vars
	form : Form;
begin
	if self.myDockBar &lt;&gt; null then
		if self.myDockBar.parent.isKindOf(Form) then
			form:=self.myDockBar.parent.Form;
		endif;
	endif;
	
	if form = null then
		return null;
	endif;
	
	if not form.isKindOf(YRD_MoveOverstowCargoForm) then
		return null;
	endif;
	
	return form.YRD_MoveOverstowCargoForm;
	
epilog

end;</source>
        <ReturnType type="YRD_MoveOverstowCargoForm"/>
    </JadeMethod>
    <JadeMethod name="getSelectedObjectsXYs" id="bb108729-4d5d-4e04-b233-2358a572ab1a">
        <updating/>
        <source>getSelectedObjectsXYs(_xys: IntegerArray input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 Feb 2010	cnwer1	Initial creation
16 Mar 2010 cnwer1  PAR 23086 issues with highlighting drawing 40ft overstowed containers
*/

vars
	form : YRD_MoveOverstowCargoForm;
	anObject : Object;

	tmpObj		: Object;
	x1, y1,
	x2, y2		: Integer;
	tmpIterator	: Iterator;
begin

	form:= self.getMoveOverstowCargoForm;
	
	if form = null then
		inheritMethod(_xys);
	else
	
		anObject:=form.myTrackedItem;
		tmpIterator := self.allGridObjects.createIterator;
		tmpIterator.startAtObject(anObject);
		//if it is a 40 ft there will be more than one container
		while  tmpIterator.next(tmpObj) do
			if tmpObj &lt;&gt; anObject then
				continue;
			endif;
			
			self.allGridObjects.getIteratorKeys(x1, y1, x2, y2, tmpIterator);

				
				_xys.add(x1);
				_xys.add(y1);
				_xys.add(x2);
				_xys.add(y2);
		endwhile;
	endif;

epilog
	delete tmpIterator;
end;</source>
        <Parameter name="_xys" type="IntegerArray" usage="input"/>
    </JadeMethod>
