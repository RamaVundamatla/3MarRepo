    <JadeMethod name="showAdditionalRemarks" id="8110161a-93b9-41bc-a2f7-4601b8ae1a59">
        <source>showAdditionalRemarks( _rem1 : String; _rem2 : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2025	navcs2	MTN-34773

*/

vars

	msg : String;

begin

	if _rem1.trimBlanks &lt;&gt; null then
		msg := app.getEntTableRowTranslation(ETRow_RemarksAdditional1,ETGrp_CargoDetails) &amp; ":" &amp; CrLf &amp; Tab &amp; _rem1;
	endif;
	if _rem2.trimBlanks &lt;&gt; null then
		if msg.trimBlanks &lt;&gt; null then
			msg := msg  &amp; CrLf;
		endif;
		msg := msg  &amp; app.getEntTableRowTranslation(ETRow_RemarksAdditional2,ETGrp_CargoDetails) &amp; ":" &amp; CrLf &amp; Tab &amp; _rem2;
	endif;

	if msg.trimBlanks &lt;&gt; null then	
		app.msgBox( msg, app.getErrorString(Attention), MsgBox_OK_Only );
	endif;

epilog

end;</source>
        <Parameter name="_rem1" type="String"/>
        <Parameter name="_rem2" type="String"/>
    </JadeMethod>
    <JadeMethod name="showCheckbox" id="faf1b08f-8f16-42d6-90e9-2d6abd0d0775">
        <source>showCheckbox();
/*
Purpose:			
Date		Who		Reason
07 April 2017	cnwab1	Initial creation
*/

vars
	value : Boolean;
	idx : Integer;
begin
	if tblList.rows &gt; 1 then
		foreach idx in 2 to tblList.rows do
			if tblList.accessRow(idx).itemObject &lt;&gt; null
			and tblList.accessRow(idx).itemObject.isKindOf(CM_TrackedItem)
			and tblList.accessRow(idx).itemObject.CM_TrackedItem.isPreNote then
				value := true;
				break;
			endif;
		endforeach;
	endif;

	self.chkPrenotesByBookItem.visible := value;
epilog

end;</source>
    </JadeMethod>
