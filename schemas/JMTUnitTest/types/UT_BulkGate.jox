    <JadeMethod name="tPrenoteBulkGateRecieval" id="677874f8-c009-4101-bfea-9e0895058e9e">
        <source>tPrenoteBulkGateRecieval();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 January 2017	cnwns1	Initial creation

*/

vars
	allVvrs : ObjectArray;
begin
	create allVvrs transient;
	self.doPrenoteBulkGateIn(allVvrs);
	
	self.doPrenoteBulkGateOut(allVvrs);
epilog
	if allVvrs &lt;&gt; null then
		beginTransaction;
		allVvrs.purge();
		commitTransaction;
	endif;	
	delete allVvrs;
end;</source>
