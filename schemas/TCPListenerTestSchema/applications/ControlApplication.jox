<Application name="ControlApplication" id="03000a1f-36e8-44c5-918b-4ee76e64b699">
    <applicationType>G</applicationType>
    <controlSpacing>4</controlSpacing>
    <finalizeMethod name="CardSchema::finalize"/>
    <fontName>MS Sans Serif</fontName>
    <fontSize>8.25</fontSize>
    <formMargin>7</formMargin>
    <heightSingleLineControl>14</heightSingleLineControl>
    <startupFormName>ControlAppStartForm</startupFormName>
    <threeDControls>
        <GUIClass name="CheckBox"/>
        <GUIClass name="GroupBox"/>
        <GUIClass name="OptionButton"/>
    </threeDControls>
    <useBorderStyleOnly/>
</Application>
