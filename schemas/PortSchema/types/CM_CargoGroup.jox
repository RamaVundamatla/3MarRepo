        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getReservedWeightForTI" id="5e90d44d-6299-4e63-93c5-155d86e3847d">
        <source>getReservedWeightForTI(_trackedItem : CM_TrackedItem) : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2025 navrv30 JIRA 33699 EUP| Reserved Qty and Details not showing up in COO and Cargo Review

*/

vars
	reserveDetail : CM_ReserveDetail;
	reservedWeight : Decimal[14,4];
	isExactMatch : Boolean;
begin
	
	foreach reserveDetail in self.allReserveDetailAssigned do
		reserveDetail.doesTIMatchForRelease(_trackedItem, isExactMatch);
		if not isExactMatch then
			continue;
		endif;
		reservedWeight := reservedWeight + reserveDetail.weightRequested;
	endforeach;
	return reservedWeight;
epilog

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getScannedCount" id="3836b602-17e7-45ff-8ce3-f583793bf95f">
        <source>getScannedCount():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	assignment : CM_CargoGroupAssignment;
	ti : CM_TrackedItem;
	count : Integer;

begin

	assignment := self.getMyCargoGroupAssignment();
	if assignment = null then
		return 0;
	endif;
	
	foreach ti in self.allAssignedTrackedItems discreteLock do
		if assignment.allProcessedTis.includes( ti ) then
			count := count + 1;
		endif;
	endforeach;
	
	return count;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalWeightScanned" id="bee86514-617d-4177-b9fa-f30397dd3476">
        <source>getTotalWeightScanned(_mode : String; _entity : Object):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Apr 2025	navhl20 Bug MTN-34624: EUP | 53856 - Scanning App - further issues

*/

vars
	ti,
	childTi		: CM_TrackedItem;
	totWeight	: Decimal[12,4];
	vehicle		: CM_Vehicle;
	wagon		: CM_Wagon;
	voyage		: CM_Voyage;
	wo			: CM_WorkOrderTI;
	txn			: CM_Transaction;
	weight		: Decimal[12,4];
	measureType : CM_MeasurementType;
	weightStr	: String;
	tiset		: CM_TISet;
	visitNum	: String;
begin
	
	if _mode = "ship" then
		voyage := _entity.CM_Voyage;
	elseif _mode = "road" then
		vehicle 	:= _entity.CM_Vehicle;
		visitNum 	:= vehicle.getCurrentVisit().visitNumber;
	elseif _mode = "rail" then
		wagon := _entity.CM_Wagon;
	elseif _mode = "unpack" then
		wo := _entity.CM_WorkOrderTI;
	endif;
	
	
	create tiset transient;
	self.allAssignedTrackedItems.copy(tiset);
	
	foreach ti in tiset discreteLock do
		weight := ti.totalWeight;
		
		if _mode = "ship" then
			if ti.myVoyage = voyage and ti.getLastTransOfClass(CM_ReceiveShip) &lt;&gt; null  then
				totWeight := totWeight + weight;
			endif;
		elseif _mode = "road" then
			if  ti.vehicle = vehicle.regNumber and ti.getVehicleVisitNumber() = visitNum and not ti.isOnVehicle(vehicle) 
			and ti.getLastTransOfClass(CM_ReceiveRoad) &lt;&gt; null then
				totWeight := totWeight + weight;					
			endif;		
		elseif _mode = "rail" then
			if  ti.wagon = wagon.id and not ti.isOnWagon() and ti.getLastTransOfClass(CM_ReceiveRail) &lt;&gt; null  then
				totWeight := totWeight + weight;
			endif;
		elseif _mode = "unpack" then
			if wo.allTIs.includes(ti.getMyUnpackedFromContainer()) then
				totWeight := totWeight + weight;
			endif;
		endif;
	endforeach;
	
	measureType := app.getDefaultMeasurementForType(Type_Weight);
	if measureType &lt;&gt; null then
		weightStr := app.convertMeasurementForDisplay(measureType.shortName,totWeight);
		if weightStr = "" then
			weightStr := totWeight.asStringWeightJMT;
		endif;
	else
		weightStr := totWeight.asStringWeightJMT;
	endif;
	
	return weightStr;
epilog
	delete tiset;
end;</source>
        <Parameter name="_mode" type="String"/>
        <Parameter name="_entity" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasNotOnSiteOnShip" id="885a0cbb-6a00-4532-9ba8-6771789823f0">
        <source>hasNotOnSiteOnShip() :  Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2023 navmv20 Bug 59697: EUP - Change of Ownership Cargo Review - Able to create COO for Offsite Cargo
24/03/2025	navkc1 JIRA Story MTN-34256: MTN | Cargo Group Details for non Euroports Clients
*/

vars
	cgDtl : CM_CargoGroupDetail;
	ti : CM_TrackedItem;
begin
	
	//24/03/2025	navkc1 JIRA Story MTN-34256
	if self.allCargoGroupDetails.isEmpty() then
		foreach ti in self.allAssignedTrackedItems discreteLock do
			if not (ti.site = TI_SITE_ONSITE or ti.site = TI_SITE_ONSHIP) then
				return true;
			endif;
		endforeach;
	else
		foreach cgDtl in self.allCargoGroupDetails do
			if not(cgDtl.site = TI_SITE_ONSITE or cgDtl.site = TI_SITE_ONSHIP) then
				return true;
			endif;
		endforeach;
		
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasOnsiteAssignedCargo" id="936d1c6e-4479-4758-a782-8a82c523f8d5">
        <source>hasOnsiteAssignedCargo():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Jun 2015	cnwndl1	Initial creation
26 Jun 2018	jlgkpd1	TFS 39132 - For performance reasons, just check for the first onsite TI

*/

vars
	iter 			: Iterator;
	ti 				: CM_TrackedItem;

begin
	iter := self.allAssignedTrackedItems.createIterator;
	while iter.next(ti) do
		if not ti.isOnSite then
			continue;
		endif;
		if ti.isNotified or ti.myPrimaryActualLocation = null then
			continue;
		endif;
		return true;
	endwhile;

	return false;
	
epilog
	delete iter;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasPrenotifiedAssignedCargo" id="40e5532b-063a-48ca-afa0-93c8c119dc6a">
        <source>hasPrenotifiedAssignedCargo():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Feb 2016	cnwndl1	Initial creation	Par 37544
26 Jun 2018	jlgkpd1	TFS 39132 - For performance reasons, just check for the first prenotified TI

*/

vars
	iter 			: Iterator;
	ti 				: CM_TrackedItem;

begin
	iter := self.allAssignedTrackedItems.createIterator;
	while iter.next(ti) do
		if not ti.isNotified then
			continue;
		endif;
		return true;
	endwhile;
	
	return false;
	
epilog
	delete iter;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
