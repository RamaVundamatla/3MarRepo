    <JadeMethod name="setTaxAmountFrom" id="0e1e433d-9330-4773-8181-a88c230a9c69">
        <updating/>
        <source>setTaxAmountFrom( localDict : CM_InvoiceLineBySeqNumDict ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21/08/2012	cnwndl1	Initial creation
31/01/2018	jlgns1	Bug 36580: ADP - Tax for Cash Module Part 3
21/10/2019  cnwma1  Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
*/

vars
	invLine 		: CM_InvoiceLine;
	proformaTotal	: Decimal[23,6];		//21.10.2019 cnwma1 TFS #47081
	total			: Real;
	voyage 		    : CM_Voyage;
	hookExempt      : Boolean;
begin

	self.taxAmount := 0.0;
	
	if self.myDebtor &lt;&gt; null and
	   self.myDebtor.isZeroRatedTax then
		return;
	endif;
	if self.myTrackedItem &lt;&gt; null then
		// TFS 37562
		voyage := self.myTrackedItem.myVoyage;
		if voyage &lt;&gt; null then
			hookExempt := app.myRoot.getVoyageTaxExempt( voyage.myTerminal, voyage ).Boolean;
			if hookExempt then
				return;
			endif;
		endif;
		
		
		
		// get existing invoice lines first
		// TFS 1990 24/05/2016 get the invoice lines from the tracked item not transactions to get those copied from split/merged items
		///foreach trx in self.myTrackedItem.allTransactions do
		///	if trx.isCharged then
				///foreach invLine in trx.allInvoiceLines where invLine.debtor.isCashOnlyDebtor(self.myTrackedItem.myTerminal) do
				foreach invLine in self.myTrackedItem.invoiceLines where invLine.debtor.isCashOnlyDebtor(self.myTrackedItem.myTerminal) do
					if invLine.voided then
						continue;
					endif;
					total := total + invLine.getTaxAmountForLine();
				endforeach;
			///endif;
		///endforeach;
		
		if self.myTrackedItem.myTerminal.getConfig(CashAllCashTax).String = null 			//Bug 36580
			and self.myTrackedItem.myTerminal.getConfig(InvoiceMultiTaxRates).Boolean then	//Bug 36580
			if localDict &lt;&gt; null then														//Bug 36580
				foreach invLine in localDict do												//Bug 36580
					proformaTotal := proformaTotal + invLine.getTaxAmountForLine();			//Bug 36580
				endforeach;																	//Bug 36580
			endif;																			//Bug 36580
			total := total + proformaTotal ;												//Bug 36580
		else																				//Bug 36580
			if localDict &lt;&gt; null then
				foreach invLine in localDict do
					//total := total + invLine.getTaxAmountForLine();
					proformaTotal := proformaTotal + invLine.totalAmount;// ### JIRA 35502 18JUL2025 NAVAB1 use totalAmount (Static)
				endforeach;
			endif;
			if self.myBank &lt;&gt; null then
				total := total + (proformaTotal * (self.myBank.taxPercentageRate / 100));
			endif;
		endif;																				//Bug 36580
	
	endif;
	
	// TFS 37562 for the voyage proforma
	voyage := self.getVoyage();
	if voyage &lt;&gt; null then
		hookExempt := app.myRoot.getVoyageTaxExempt( voyage.myTerminal, voyage ).Boolean;
		if hookExempt then
			return;
		endif;
	endif;
		
	
	self.taxAmount := total;

epilog

end;</source>
        <Parameter name="localDict" type="CM_InvoiceLineBySeqNumDict"/>
    </JadeMethod>
    <JadeMethod name="updateProformaPaid" id="114783b8-6f2a-4250-afbc-8fbd223b06b0">
        <source>updateProformaPaid() protected;
/*

Purpose:	 This method looks at the proforma invoice lines, that will be made into cash payments, it compares them with the real cash payments and when they match it adjusts the proforma invoice lines. 
					This may mean that get set to zero (becasue they have been fully paid previously) or adjusted becasue they have already paid some ie storage being extended.
					Proforma lines that are zero are ignored and not made into cash payments

Parameters:			

Return Value:		

Date		Who		Reason
					34917 GPHA 2368 update the proforma invoice lines to indicate which have been paid
21 Oct 2015 cnwma1	ADP 34909 2537 cnwdap1 21/10/2015 Build remarks from correct invoice type for minimum charges
17 Aug 2016	cnwrh7	TFS3154	 Second/Consecutive cash receipt wrong line amount calculation
21 Oct 2019 cnwma1  Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
05 Nov 2019 cnwma1	Bug 47056: JMT - Cash Collection - Not calculating additional days once you have paid for some
// ### JIRA 35502 rewrote to update the static totalAmount on invoice line, also refactored cos some variables where not being used etc.
*/
vars
	paymentTITrx		: CM_TITransaction;
	paymentInvLine,
	invoiceLine			: CM_InvoiceLine;
	paymentInvLineDesc	: CM_InvoiceLineDesc;
	payment				: CM_CashPayment;
	charge				: CM_Charge;
//	originalValue,
	paidValue			: Decimal[23, 6];   //21.10.2019 cnwma1 TFS #47081
	quantity,
	paidQuantity, 
	paidTotal,
	total				: Real;

begin
	
	//05.11.2019 cnwma1 #47056
	foreach invoiceLine in self.allProformaInvLines do
		paidValue     := 0;
		paidQuantity  := 0;		
		// ### JIRA 35502 18JUL2025 NAVAB1  not used - originalValue := invoiceLine.lineTotal;

		foreach payment in self.allCashPayments do
			
			//30/04/2025	navkc1 JIRA Bug MTN-34734
			if payment.isNotPaidByAPI() then
				continue;
			endif;
			
			paymentInvLine := payment.myInvoiceLine; //13/05/2025	navkc1 JIRA MTN-34857
			
			//13/05/2025	navkc1 JIRA MTN-34857
			if paymentInvLine &lt;&gt; null then
				paymentInvLineDesc := paymentInvLine.invoiceLineDesc;
				paymentTITrx := paymentInvLine.myTransactionTI;
			endif;
			
			if payment.myProformaDetail &lt;&gt; null then
				if  payment.myProformaDetail.myInvoiceLineType = invoiceLine.invoiceLineDesc and 
					payment.myProformaDetail.transactionType = invoiceLine.quantityNoMinMax  then
						paidValue    := paidValue	 + payment.cashValue;
						paidQuantity := paidQuantity + payment.myProformaDetail.quantity;	
				else
					//13/05/2025	navkc1 JIRA MTN-34857- QT has a scenario, Split cargo is loaded to Truck, then add a to do task. MTN is recalculating cash amount for receive ship transaction
					// So here we check, if it's a split off cargo, and we already have a cash payment that matches the proforma invoice line, we consider that as paid
					if self.myTrackedItem.isOnSite() and self.myTrackedItem.myMasterTi &lt;&gt; null then
						if 	paymentInvLine &lt;&gt; null and paymentInvLineDesc = invoiceLine.invoiceLineDesc and
							paymentTITrx &lt;&gt; null and paymentTITrx.type = invoiceLine.quantityNoMinMax  then
							paidValue    := paidValue	 + payment.cashValue;
							paidQuantity := paidQuantity + payment.myProformaDetail.quantity;	
						endif;
					endif;
				endif;
			else
				//13/05/2025	navkc1 JIRA MTN-34857- QT has a scenario, Split cargo is loaded to Truck, then add a to do task. MTN is recalculating cash amount for receive ship transaction
				// So here we check, if it's a split off cargo, and we already have a cash payment that matches the proforma invoice line, we consider that as paid
				if self.myTrackedItem.isOnSite() and self.myTrackedItem.myMasterTi &lt;&gt; null then
					if 	paymentInvLine &lt;&gt; null and paymentInvLineDesc = invoiceLine.invoiceLineDesc and
						paymentTITrx &lt;&gt; null and paymentTITrx.type = invoiceLine.quantityNoMinMax then
						paidValue    := paidValue	 + payment.cashValue;
						paidQuantity := paidQuantity + invoiceLine.quantity;
					endif;
				endif;
			endif;
		endforeach;
		
		if paidValue &lt;&gt; 0 then
			quantity := invoiceLine.quantity;// ### JIRA 35502 22JUL
			foreach charge in invoiceLine.charges do
				total := charge.total;
				if paidValue &lt; total then
					total     := total - paidValue;
				else
					total := 0;
				endif;
				
				if total &lt; 0.01 then
					total := 0;
				endif;

				invoiceLine.invoice := null; 
				
				if paidQuantity &lt; quantity then
					quantity := quantity - paidQuantity;
				else
					quantity := 0;
				endif;
				
				// from TFS 1990 testing check for very small value rather than zero
				if total = 0 then
					quantity := 0;
				endif;
				
			endforeach;
			
			// ### JIRA 35502 22JUL2025 NAVAB1 we have changed the charge total, this effects invoiceLine.lineTotal, so update static total
			invoiceLine.setManual(true);
			invoiceLine.setForUpdateQuantity(quantity);  
			invoiceLine.setManual(false);
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
