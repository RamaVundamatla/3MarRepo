    <JadeMethod name="setDataAccessControllers" id="c4c7b0be-6601-49b0-a1fc-cd9e08662cf9">
        <source>setDataAccessControllers(dacs : CM_DataAccessControllerSet);
// ---------------------------------------------------------------------------
// Created:			04 April 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	dac : CM_DataAccessController;
begin
	self.allDataAccessControllers.clear;
	foreach dac in dacs do
		//Add them in, this is a dict by class so will spew with an error if they try to add
		//more than 1 class type (which stuffs everything)
		self.allDataAccessControllers.add(dac);
	endforeach;
end;</source>
        <Parameter name="dacs" type="CM_DataAccessControllerSet"/>
    </JadeMethod>
