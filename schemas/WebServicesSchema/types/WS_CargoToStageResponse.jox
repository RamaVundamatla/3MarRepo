    </JadeMethod>
    <JadeMethod name="setWeightAndCounts" id="47a4ea95-6e9b-4e70-a60e-b69b122a0826">
        <updating/>
        <source>setWeightAndCounts(_reserveDetail : CM_ReserveDetail) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Jan 2023 navhl20 ChangeRequest 58760:[61583] EUP | VAS Mobile App - [53813.050] VAS Tasks for Release Cargo Work Order

*/

vars
	countLoaded, 
	countToLoad 	: Integer;
	weightLoaded, 
	weightToLoad 	: Decimal[16,4];
	measureType 	: CM_MeasurementType;
	allTis			: CM_TISet;
	ti				: CM_TrackedItem;
begin
	if _reserveDetail = null  then
		return;
	endif;
	
	create allTis transient;
	_reserveDetail.getAllTrackedItems(allTis,false);
	
	foreach ti in allTis do
		countLoaded := countLoaded + ti.totalQuantity;
	endforeach;
	
	self.countStaged  := countLoaded;
	self.countToStage := _reserveDetail.totalRequested - countLoaded;
	
	if self.countToStage = 0 then
		self.countToStage := countLoaded;
	endif;
	
	measureType := app.getDefaultMeasurementForType(Type_Weight);
	
	if measureType &lt;&gt; null then
		self.weightStaged  := app.convertMeasurementForDisplay(measureType.shortName, weightLoaded)&amp; " " &amp; measureType.shortName;
		self.weightToStage := app.convertMeasurementForDisplay(measureType.shortName, weightToLoad)&amp; " " &amp; measureType.shortName;
	else
		self.weightStaged := weightLoaded.asStringWeightJMT;
		self.weightToStage:= weightToLoad.asStringWeightJMT;
	endif;
epilog
	delete allTis;
end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
</Class>
