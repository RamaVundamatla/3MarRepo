<PrimType name="Any">
    <JadeMethod name="cnEcIsBetween" id="d9335afc-c866-44bd-a740-149f3c528683">
        <source>cnEcIsBetween(pLowCriteria:Any; pHighCriteria:Any):Boolean;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the value of the receiver
//				is between the specified low and high values.
//
// Parameters:	pLowCriteria - The low end of the range.
//				pHighCriteria - The high end of the range.
//
// Returns:		True if the receiver is between the specified values, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.cnEcIsGreaterThanOrEqual(pLowCriteria) and self.cnEcIsLessThanOrEqual(pHighCriteria));
end;</source>
        <Parameter name="pLowCriteria" type="Any"/>
        <Parameter name="pHighCriteria" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsGreaterThan" id="4365d9ec-b079-4789-a95c-a9548df41bb2">
        <source>cnEcIsGreaterThan(pCriteria:Any):Boolean;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the value of the receiver
//				is greater than specified value.
//
// Parameters:	pCriteria - The value to compare against.
//
// Returns:		True if the receiver is greater than the specified value, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isKindOf(Binary) then
		return (self.Binary &gt; pCriteria.Binary);
	elseif self.isKindOf(Character) then
		return (self.Character &gt; pCriteria.Character);
	elseif self.isKindOf(Date) then
		return (self.Date &gt; pCriteria.Date);
	elseif self.isKindOf(Decimal) then
		return (self.Decimal &gt; pCriteria.Decimal);
	elseif self.isKindOf(Integer) then
		return (self.Integer &gt; pCriteria.Integer);
	elseif self.isKindOf(Real) then
		return (self.Real &gt; pCriteria.Real);
	elseif self.isKindOf(Time) then
		return (self.Time &gt; pCriteria.Time);
	elseif self.isKindOf(TimeStamp) then
		return (self.TimeStamp &gt; pCriteria.TimeStamp);
	else
		return (self.String &gt; pCriteria.String);
	endif;
end;</source>
        <Parameter name="pCriteria" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsGreaterThanOrEqual" id="03b399bf-68be-4fff-a16b-78306e8b5540">
        <source>cnEcIsGreaterThanOrEqual(pCriteria:Any):Boolean;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the value of the receiver
//				is greater than, or equal to, the specified value.
//
// Parameters:	pCriteria - The value to compare against.
//
// Returns:		True if the receiver is greater than, or equal to, the specified
//				value, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isKindOf(Binary) then
		return (self.Binary &gt;= pCriteria.Binary);
	elseif self.isKindOf(Character) then
		return (self.Character &gt;= pCriteria.Character);
	elseif self.isKindOf(Date) then
		return (self.Date &gt;= pCriteria.Date);
	elseif self.isKindOf(Decimal) then
		return (self.Decimal &gt;= pCriteria.Decimal);
	elseif self.isKindOf(Integer) then
		return (self.Integer &gt;= pCriteria.Integer);
	elseif self.isKindOf(Real) then
		return (self.Real &gt;= pCriteria.Real);
	elseif self.isKindOf(Time) then
		return (self.Time &gt;= pCriteria.Time);
	elseif self.isKindOf(TimeStamp) then
		return (self.TimeStamp &gt;= pCriteria.TimeStamp);
	else
		return (self.String &gt;= pCriteria.String);
	endif;
end;</source>
        <Parameter name="pCriteria" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsLessThan" id="54962dfc-3766-4f54-a77e-83cd9132084f">
        <source>cnEcIsLessThan(pCriteria:Any):Boolean;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the value of the receiver
//				is less than the specified value.
//
// Parameters:	pCriteria - The value to compare against.
//
// Returns:		True if the receiver is less than the specified value, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isKindOf(Binary) then
		return (self.Binary &lt; pCriteria.Binary);
	elseif self.isKindOf(Character) then
		return (self.Character &lt; pCriteria.Character);
	elseif self.isKindOf(Date) then
		return (self.Date &lt; pCriteria.Date);
	elseif self.isKindOf(Decimal) then
		return (self.Decimal &lt; pCriteria.Decimal);
	elseif self.isKindOf(Integer) then
		return (self.Integer &lt; pCriteria.Integer);
	elseif self.isKindOf(Real) then
		return (self.Real &lt; pCriteria.Real);
	elseif self.isKindOf(Time) then
		return (self.Time &lt; pCriteria.Time);
	elseif self.isKindOf(TimeStamp) then
		return (self.TimeStamp &lt; pCriteria.TimeStamp);
	else
		return (self.String &lt; pCriteria.String);
	endif;
end;</source>
        <Parameter name="pCriteria" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsLessThanOrEqual" id="1364428c-2345-42fc-94c0-60004f46015c">
        <source>cnEcIsLessThanOrEqual(pCriteria:Any):Boolean;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the value of the receiver
//				is less than, or equal to, the specified value.
//
// Parameters:	pCriteria - The value to compare against.
//
// Returns:		True if the receiver is less than, or equal to, the specified value,
//				otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isKindOf(Binary) then
		return (self.Binary &lt;= pCriteria.Binary);
	elseif self.isKindOf(Character) then
		return (self.Character &lt;= pCriteria.Character);
	elseif self.isKindOf(Date) then
		return (self.Date &lt;= pCriteria.Date);
	elseif self.isKindOf(Decimal) then
		return (self.Decimal &lt;= pCriteria.Decimal);
	elseif self.isKindOf(Integer) then
		return (self.Integer &lt;= pCriteria.Integer);
	elseif self.isKindOf(Real) then
		return (self.Real &lt;= pCriteria.Real);
	elseif self.isKindOf(Time) then
		return (self.Time &lt;= pCriteria.Time);
	elseif self.isKindOf(TimeStamp) then
		return (self.TimeStamp &lt;= pCriteria.TimeStamp);
	else
		return (self.String &lt;= pCriteria.String);
	endif;
end;</source>
        <Parameter name="pCriteria" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</PrimType>
