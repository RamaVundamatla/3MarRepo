    <JadeMethod name="getTroubleErrors" id="1ac824a0-a247-4cc6-b15f-38e6493e8e72">
        <source>getTroubleErrors(_coll :Collection input);
// ---------------------------------------------------------------------------
// Created:     15 October 2008 by concms1
// Purpose:     ccms 1035 - Gate ticket printing (APM)
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	error 	: CM_ErrorPersistent;
begin
	foreach error in self.allErrorsAndWarnings discreteLock do 
		if error.hasTrouble() then
			_coll.add (error);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_coll" type="Collection" usage="input"/>
    </JadeMethod>
