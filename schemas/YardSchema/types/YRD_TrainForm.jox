        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblTrans_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2009	cnwndl1	Initial creation

*/

vars

begin
	if doMnuContextBuildTblTrans(table, conwin, mouse, x, y) then
		return self.showContextMenu(mnuContext, table, conwin, mouse, x, y);
	else
		return false;
	endif;
epilog

end;</source>
