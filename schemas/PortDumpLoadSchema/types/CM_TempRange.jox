<Class name="CM_TempRange">
    <JadeMethod name="importPLXMLReference" id="61835279-a1b0-4606-abe5-e3bfa150f3f8">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_TempRange::myRoot.name then
		return app.myRoot;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
