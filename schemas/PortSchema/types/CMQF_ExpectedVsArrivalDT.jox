    <JadeMethod name="compareTimes" id="7ee84a54-f53b-434d-b4f5-10a5dee67711">
        <source>compareTimes(_ti : CM_TrackedItem) : Integer;
//12 February 2010	cnwml2


vars
	expectedDT : TimeStamp;
	receivedDT : TimeStamp;
	timeDiff : TimeStampInterval;
	dateDiff : Integer;
	minutesDiff : Integer;
	hoursDiff : Integer;
	daysDiff : Integer;
	totalDiff : Integer;
begin
	//expectedDT.setDate(_ti.expectedArrivalDate);
	//expectedDT.setTime(_ti.expectedArrivalTime);
	//29 Jul 2013	NDL	Par 31763
	expectedDT.setDate(_ti.getExpectedArrivalDate);
	expectedDT.setTime(_ti.getExpectedArrivalTime);
		
	receivedDT := _ti.receivedDT;
	
	timeDiff := expectedDT - receivedDT;
	minutesDiff := timeDiff.cnMinutes();
	hoursDiff := timeDiff.cnHours() * 60;
	daysDiff := timeDiff.cnDays() * 24 * 60;
	
	totalDiff := minutesDiff + hoursDiff + daysDiff;
		
	return totalDiff;
epilog
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="filterForTerminal" id="4aa0a7bf-efb3-499b-9723-7c4c9f23b2c2">
        <updating/>
        <source>filterForTerminal(_collection : Collection input; _passport : CM_Passport) updating, protected;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		17 March 2010
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
//----------------------------------------------------------------------
//17 Feb 2015	cnwkpd1	PAR #35704 - Changes to prevent extended locking

vars
	terminal 	: CM_Terminal;
	iter 		: Iterator;
	ti 			: CM_TrackedItem;
	breakOut 	: Boolean;
	int,
	cargoType	: Integer;
begin
	foreach terminal in self.allTerminals discreteLock do
		delete iter;
		if self.getMyCargoType &lt;&gt; null then
			cargoType := self.getMyCargoType.id;
		endif;
		iter := terminal.allOnsiteTIsByCargoTypeId.createIterator();
		terminal.allOnsiteTIsByCargoTypeId.startKeyGeq(cargoType, null, iter);
		
		while iter.next(ti) do
		int := int + 1;
			if self.getMyCargoType &lt;&gt; null and 
			   self.getMyCargoType &lt;&gt; ti.myCargoType then
				break;
			endif;
		
			if self.getMySubTerminal &lt;&gt; null and
			   self.getMySubTerminal &lt;&gt; ti.mySubTerminal then
				continue;
			endif;
			
			if self.myOperator &lt;&gt; null and
			   self.myOperator &lt;&gt; ti.myOperator then
				continue;
			endif;
			
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
				if (not _collection.includes(ti)) then
					_collection.add(ti);
				endif;
			endif;
		endwhile;
	endforeach;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterForVoyage" id="d964a622-8a89-427e-968a-d33f03979574">
        <updating/>
        <source>filterForVoyage(_collection : Collection input; _passport : CM_Passport) updating, protected;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		17 March 2010
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
//----------------------------------------------------------------------
vars
	ti 			: CM_TrackedItem;
	breakOut 	: Boolean;
	voyage 		: CM_Voyage;
	iter 		: Iterator;
	cargoType	: Integer;
begin
	voyage := self.getMyVoyage;
	iter := voyage.allOnsiteTIsByCargoTypeId.createIterator();
	
	if self.getMyCargoType &lt;&gt; null then
		cargoType := self.getMyCargoType.id;
		voyage.allOnsiteTIsByCargoTypeId.startKeyGeq(self.getMyCargoType.id, null, iter);				//+cnwml2 PAR23257
	endif;
	
	//voyage.allOnsiteTIsByCargoTypeId.startKeyGeq(self.myCargoType.id, null, iter);				//-cnwml2 PAR23257
	
	while iter.next(ti) do
		if self.getMyCargoType &lt;&gt; null and
		   self.getMyCargoType &lt;&gt; ti.myCargoType then
			break;
		endif;
		
		if self.getMySubTerminal &lt;&gt; null and
		   self.getMySubTerminal &lt;&gt; ti.mySubTerminal then
			continue;
		endif;
		
		if self.myOperator &lt;&gt; null and
		   self.myOperator &lt;&gt; ti.myOperator then
		    continue;
		endif;
		
		if self.checkStatusIncludesObject(ti, _passport, breakOut) and 
		   (not _collection.includes(ti)) then
		    _collection.add(ti);
		endif;
		
	endwhile;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="cb9d8618-0bf4-4e90-9d27-b93b805c8bc0">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
