    <JadeMethod name="utlCreateInternalOrganisation" id="99c58837-9b15-48ed-9343-32dcff9f57d1">
        <source>utlCreateInternalOrganisation(_name : String; _logo : Binary;  
			_dacs : CM_DataAccessControllerSet; 
			_newInternOrg : CM_InternalOrganisation output; _isNotAvailableForEntry : Boolean;
			_isAvailableForLabourRestrict : Boolean; _emails : CM_EmailAddressByAddressDict; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//29/07/2016	 cnwma1 TFS #2447:Adding duplicate gives error
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
// ---------------------------------------------------------------------------
vars
	trimmedName	: String;
	internOrg   : CM_Organisation;
begin

	self.initialiseActivity();

	trimmedName := _name.trimBlanks;
	if trimmedName = null then
		app.raiseCMException2(ERR_FIELD_VALUE, "null", "name", 'name', null);
		return;
	endif;
	
	foreach internOrg in app.myRoot.allOrganisations do                  //29/07/2016 cnwma1 TFS #2447
		if internOrg.name.toUpper =trimmedName.toUpper then
			//app.raiseCMException2(DuplicateItem, "Organisation Name", trimmedName, null, null); //14.06.2022 navds20 53760
			// Organisation Name already exists for %1 : Organis_name_already_exists
			app.raiseCMException1(Organis_name_already_exists, trimmedName, null, null); //14.06.2022 navds20 53760
			return;
		endif;
	endforeach;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	create _newInternOrg persistent;
	_newInternOrg.setForCreate(_name, _logo, _isNotAvailableForEntry,
				_isAvailableForLabourRestrict, _emails, app.myRoot, _passport);
	_newInternOrg.setDataAccessControllers(true,_dacs);

	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newInternOrg);
	endif;	

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_logo" type="Binary"/>
        <Parameter name="_dacs" type="CM_DataAccessControllerSet"/>
        <Parameter name="_newInternOrg" type="CM_InternalOrganisation" usage="output"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="_isAvailableForLabourRestrict" type="Boolean"/>
        <Parameter name="_emails" type="CM_EmailAddressByAddressDict"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateInternalWorkOrderJob" id="e7d796c6-7ff5-45af-9cae-0617c94579e3">
        <updating/>
        <source>utlCreateInternalWorkOrderJob(_wodDetail            : CM_WorkOrderDtl;
							  _cmifJobParam			: CMIF_Object;
							  _realJob				: CM_Job io;
							  _passport				: CM_Passport input) updating;
/*
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Sep 2021 navma1 	ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
14 Jun 2022	navcs2	ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
27 Sep 2022 navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs.
06 Jun 2023 navma1  ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
*/

vars
	wodJobClass : Class;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	
	wodJobClass := _wodDetail.getWodJobClass();						//06.06.2023 navma1 #58339
	
	if wodJobClass = null then
		return;
	endif;
	
	create _realJob  as wodJobClass persistent;
	
	if _realJob.isKindOf(CM_YardInternalJob) then
		_realJob.CM_YardInternalJob.setForCreateInternal(_cmifJobParam.CMIF_YardWorkJobParams,_wodDetail.getMyTerminal);		//06.06.2023 navma1 #58339
	else
		_realJob.CM_WorkOrderJob.setForCreateInternal(_cmifJobParam.CMIF_WorkOrderJobParams,_wodDetail.getMyTerminal);
	endif;
	/*
	Add To :
	Yard Job Sheet
	Work Order Job Sheet
	*/
	_realJob.CM_WorkOrderJob.addToJobSheet();		//02.06.2023 navma1 #58296
end;</source>
        <Parameter name="_wodDetail" type="CM_WorkOrderDtl"/>
        <Parameter name="_cmifJobParam" type="CMIF_Object"/>
        <Parameter name="_realJob" type="CM_Job" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
