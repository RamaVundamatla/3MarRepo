    <JadeMethod name="setButtonPenLabels" id="eb12440a-a561-4bae-b7e7-eb67a0291f55">
        <source>setButtonPenLabels();
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	label : String;
//	taType : Integer;
begin
//	taType := self.myCurrentObject.CM_TerminalArea.type;
	
	if self.myCurrentSOPGridArea.selectedColumn &lt;&gt; 0 then
		label := "Column";
	elseif self.myCurrentSOPGridArea.selectedRow &lt;&gt; 0 then
		label := "Row";
	else
		return;
	endif;

	self.btnPenDelete.caption := "&amp;Delete selected " &amp; label;
	self.btnPenInsert.caption := "&amp;Insert " &amp; label &amp; " before selected " &amp; label;
//	self.btnPenLabelsRow.caption := label  &amp; " &amp;Labels...";
	label := self.btnPenDelete.caption;
	label.replaceChar("&amp;"," ");
	self.btnPenDelete.bubbleHelp := label;

	label := self.btnPenInsert.caption;
	label.replaceChar("&amp;"," ");
	self.btnPenInsert.bubbleHelp := label;
	
//	label := self.btnPenLabelsRow.caption;
//	label.replaceChar("&amp;"," ");
//	self.btnPenLabelsRow.bubbleHelp := label;
end;</source>
    </JadeMethod>
    <JadeMethod name="setCMIFFromTable" id="9174909e-2591-43df-925e-061ab45a6a5d">
        <updating/>
        <source>setCMIFFromTable() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	27 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	cmifRTG				: CMIF_RTGArea;
	cmifTA 				: CMIF_TerminalArea;
	taType				: CM_TerminalAreaType;
begin
	cmifTA 						:= self.myCMIFTerminalArea;
	
	taType						:= self.cmbTAType.listObject.CM_TerminalAreaType;
	//th2 - there will always be a proxy terminal area to work with - even when
	//adding a new area one is created - see doComboTATypeSelect
	cmifTA.myPxyTerminalAreaMaster	:=  self.myProxyObject.CM_TerminalAreaMaster;
	cmifTA.myTerminalAreaMaster 		:= cmifTA.myPxyTerminalAreaMaster.pxyGetRealObject;
	cmifTA.myTerminal 			:= self.myTerminal;
	cmifTA.id 					:= tblMain.getValueByName(ETRow_Id).String[1:13];
	if taType &lt;&gt; null then	//16 June 2010	NDL	Par 24369 - Is set in the create of the cmif anyway
		cmifTA.taType 				:= taType.type;
	endif;
	cmifTA.stockControlled 		:= tblMain.getValueByName(ETRow_StockControlled).Boolean;
	cmifTA.actAsReleasePoint  	:= tblMain.getValueByName(ETRow_ActAsReleasePoint).Boolean;
	cmifTA.comment 				:= tblMain.getValueByName(ETRow_Comment).String;
	cmifTA.hideFromOverview		:= tblMain.getValueByName(ETRow_HideFromOverView).Boolean;
	cmifTA.autoRestrictionsEnabled := tblMain.getValueByName(ETRow_AutoRestrictionsEnabled).Boolean;
	cmifTA.deckingOption 		:= self.cmbRowDir.getCurrentItemData();

	cmifTA.height				:= tblMain.getValueByName(ETRow_Height).Integer;
	if cmifTA.height &lt; 1 then
		cmifTA.height := 1;
	endif;
	
	cmifTA.numRows 				:= tblMain.getValueByName(ETRow_Rows).Integer;
	cmifTA.numColumns			:= tblMain.getValueByName(ETRow_Cols).Integer;
	cmifTA.colour 				:= tblMain.getValueByName(ETRow_Colour).Integer;
	
	if  cmifTA.taType = TA_TYPE_RTG 
		or cmifTA.taType = TA_TYPE_RMG  or
			cmifTA.taType = TA_TYPE_FORK_LIFT_STACK or
			cmifTA.taType = TA_TYPE_STRADDLE_STACK then
		cmifTA.CMIF_GridArea.use40ftIds			:= tblMain.getValueByName(ETRow_Use40ftIds).Boolean;
	endif;
		
	
	
	if cmifTA.taType = TA_TYPE_LOGAREA then
		cmifTA.numColumns 		:= tblMain.getValueByName(ETRow_NumberOfRows).Integer;
		cmifTA.numRows 			:= 1;
		cmifTA.height 			:= 1;
		
	elseif cmifTA.taType = TA_TYPE_RTG or cmifTA.taType = TA_TYPE_RMG then
		cmifRTG 					:= cmifTA.CMIF_RTGArea;
		cmifTA.numColumns			:= tblMain.getValueByName(ETRow_Bays).Integer;
		// 27198 Apr 2011
		cmifRTG.maxHeight			:= tblMain.getValueByName(ETRow_MaxHeight).String.asRealJMT;	// 36603 was .Real
		
		cmifRTG.startNumRow			:= tblMain.getValueByName(ETRow_RowStartNum).Integer;
		cmifRTG.startNumColumn		:= tblMain.getValueByName(ETRow_ColStartNum).Integer;
		
		
		cmifRTG.decrementColNums 	:= tblMain.getValueByName(ETRow_DecColNums).Boolean;
		cmifRTG.sideInterchangePosition:= self.cmbSideICPos.getCurrentItemData();
				
		
		cmifRTG.prefixRowLabel		:= tblMain.getValueByName(ETRow_PrefixRow).String;
		cmifRTG.prefixColumnLabel	:= tblMain.getValueByName(ETRow_PrefixCol).String;
		cmifRTG.prefixLaneLabel		:= tblMain.getValueByName(ETRow_PrefixLane).String;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="f7353bf6-f077-4b3c-b73b-77ef2ecc88d5">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     29 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theBackColour : Integer;
begin
	inheritMethod(_colorControl);

	theBackColour := self.backColor;
	
	self.frmGrdArea.backColor := theBackColour;
	frmMain.backColor := theBackColour;
	frmMain.myDrawingFrame.backColor := theBackColour;
	frmMain.borderStyle := Frame.BorderStyle_None;
	frmMain.myDrawingFrame.borderStyle := Frame.BorderStyle_None;
	frmMain.myTopLeftFillerFrame.backColor := theBackColour;
	frmMain.myHLabels.backColor := theBackColour;
	frmMain.myVLabels.backColor := theBackColour;
	
	self.fldDefinition.backColor	:= theBackColour;
	
	self.shtAutoPlan.backColor		:= theBackColour;
	self.shtDefData.backColor		:= theBackColour;
	self.shtDefDesign.backColor		:= theBackColour;

	self.setColorsForEntryTable(self.tblAPYardStack);
	self.setColorsForEntryTable(self.tblExtra);
	self.setColorsForEntryTable(self.tblMain);
	
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setComboBoxTAType" id="24138d57-27f2-4c14-b9e2-9f0eba3e28b7">
        <source>setComboBoxTAType(pCmb : CMUI_ComboBox io; pTAType : CM_TerminalAreaType) protected;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30.6.2008	cnwrd1		par #17362
// ---------------------------------------------------------------------------
vars
	ta 					: CM_TerminalAreaType;
	iter 				: Iterator;
	str 				: String;	
	root				: CM_Root;
	isInterTermMulti	: Boolean;

begin
	root := app.myRoot;
	pCmb.sorted := true;
	isInterTermMulti := root.isInterTerminalTransferEnabled();
	iter := root.allTerminalAreaTypes.createIterator();
	
	while iter.next(ta) do
				
		if not self.isValidType(ta.type, isInterTermMulti) then
			continue;
		endif;
		//if ta.isNotAvailableSys then // cnwrd1 30.6.2008 par #17362 --
		if ta.getIsNotAvailableForEntry() then // cnwrd1 30.6.2008 par #17362 ++ remove the not available for entry TAtypes
			continue;
		endif;
		
		pCmb.itemObject[pCmb.addItem(ta.description.trimRight)] := ta;
	endwhile;
	
	if not root.allTerminalAreaTypes.isEmpty then
		pCmb.listIndex := 1;
	endif;

	if pTAType &lt;&gt; null then
		if pCmb.text &lt;&gt; null then
			pCmb.listObject := pTAType;
		endif;
	endif;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="pCmb" type="CMUI_ComboBox" usage="io"/>
        <Parameter name="pTAType" type="CM_TerminalAreaType"/>
    </JadeMethod>
    <JadeMethod name="setComboBoxTransferArea" id="b36a8105-f7a3-4d00-ba85-95992c4bab08">
        <source>setComboBoxTransferArea(pCmb : CMUI_ComboBox io; pTAType : Integer) protected;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ta 					: CM_TerminalArea;
	iter 					: Iterator;
	str 					: String;	
	transArea				: Integer;
begin
	pCmb.sorted := false;
	pCmb.clear;
	if pTAType = TA_TYPE_RAILWAY_TRACK then
		transArea := TA_TYPE_RAIL_TRANS;
	endif;
	
	iter := self.myTerminal.allTerminalAreas.createIterator;
	while iter.next(ta) do
		if not global.isValidObject(ta) then
			continue;
		endif;
		if ta.type &lt;&gt; transArea then
			continue;
		endif;
		pCmb.addItem(ta.id.trimBlanks &amp; " - " &amp; ta.typeString.trimBlanks);
		pCmb.itemObject[pCmb.newIndex ] := ta;
	endwhile;

	if pCmb.listCount &gt; 0 then
		pCmb.listIndex := 1;
	endif;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="pCmb" type="CMUI_ComboBox" usage="io"/>
        <Parameter name="pTAType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setContextMenu" id="0ecf0145-b768-44fb-9d26-434f41820ef7">
        <source>setContextMenu(_type : Integer) protected;
// ---------------------------------------------------------------------------
// Created:		August 2001 By Andrew Bishop cnwab1
//
// Purpose:		Clones menu items from the menuSetWidth. This builds sub menus with a width of 1 to 7 metres
//				The metres are the menuIndex value. The click event is on MmnuSetWidth
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	i				: Integer;
	lCaption		: String;
	mnuChild		: MenuItem;
	mnuIndex 		: Integer;
	taType 			: CM_TerminalAreaType;
begin

	
	foreach i in 2 to 7 reversed do
		lCaption := "Width of " &amp; i.String &amp; " Metres" ;
		mnuChild := mnuSetWidthX.getMenuItem(i); // check if the menu is already cloned
		if mnuChild = null then
			mnuChild := mnuSetWidthX.loadMenu(i); // Clone menu
			mnuChild.caption := lCaption;
			mnuChild.visible := true;
			mnuChild.enabled := true;
		endif;
	endforeach;
	if self.mode = Mode_Update  then
		taType := getTAStringToType(tblMain.getValueByName(ETRow_Type).String);
	else
		taType := getTAStringToType(cmbTAType.text.String.trimBlanks);
	endif;
	
	self.mnu40Labels.visible:=false;
	
	if _type = Labels_Tracked then		//label click, area has TIs
		mnuSetLabels.visible := true;
		mnuSetWidth.visible := false;
		mnuDelete.visible := false;
		mnuInsert.visible := false;
		mnuLabelsSeparator.visible := false;
		mnuSetPowerTower.visible := false;
		mnuSetGap.visible := false;
		mnuSetBuilding.visible := false;
		mnuSetUnavail.visible := false;
		mnuAvailable.visible := false;
		mnuSetLight.visible := false;
		mnuSetPower.visible := false;
		mnuSetReefer.visible := false;
		mnuZoomSeparator.visible := false;
		
	elseif _type = Grid_Menu then			//grid click, area has no TIs
		mnuSetLabels.visible := false;
		mnuSetWidth.visible := false;
		mnuDelete.visible := false;
		mnuInsert.visible := false;
		mnuLabelsSeparator.visible := false;
		mnuSetGap.visible := true;
		mnuSetBuilding.visible := true;
		mnuSetUnavail.visible := true;
		mnuAvailable.visible := true;
		mnuSetLight.visible := true;
		mnuSetReefer.visible := taType.type &lt;&gt; TA_TYPE_LOGAREA and taType.type &lt;&gt; TA_TYPE_FORK_LIFT_STACK;
		mnuZoomSeparator.visible := true;

		mnuSetPowerTower.visible := false;
		mnuSetPower.visible := taType.type &lt;&gt; TA_TYPE_LOGAREA ;
				
	elseif _type = Labels_Menu then		//label click, area has no TIs
		mnuSetLabels.visible := true;
		mnuSetWidth.visible := self.myCurrentSOPGridArea.canBeSized();//selectedColumn &gt; 0;
		mnu40Labels.visible:=self.myCurrentSOPGridArea.selectedColumn &lt;&gt; null and self.myCMIFTerminalArea.CMIF_GridArea.use40ftIds;
		mnuDelete.visible := true;
		mnuInsert.visible := true;
		mnuLabelsSeparator.visible := true;
		mnuSetGap.visible := true;
		mnuSetBuilding.visible := true;
		mnuSetUnavail.visible := true;
		mnuAvailable.visible := true;
		mnuSetLight.visible := true;
		mnuSetReefer.visible := taType.type &lt;&gt; TA_TYPE_LOGAREA and taType.type &lt;&gt; TA_TYPE_FORK_LIFT_STACK;
		mnuZoomSeparator.visible := true;

		mnuSetPowerTower.visible := false;
		mnuSetPower.visible := taType.type &lt;&gt; TA_TYPE_LOGAREA ;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="bc2db3b1-d53e-459f-9746-9332a87b9f1d">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18/06/2010	cnwcs5		par 24418 - vehicle machine access rules
//							also use local variable for seld.myProxyObject
// 22/08/2011	cnwdap1		PAR #28047 CCMS POL 2095 maintain machine / terminal area relationship
// 09/06/2020	jlgdap1		TFS 49453 ASPA Satellite Area Screen for Flexible Terminal Areas
// ---------------------------------------------------------------------------

vars
	taType 		: CM_TerminalAreaType;
	proxy		: CM_TerminalAreaMaster;	// par 24418
	int			: Integer;					// par 24418
begin
	inheritMethod();
	
	areaChanged := false;
	proxy		:= self.myProxyObject.CM_TerminalAreaMaster;	// par 24418
	
	self.setToolbarButtons(proxy, true);
	self.btnBlockNew.enabled := false; // adm 100708 Par 17487 do not enable button untill location is selected
	self.tblMain.userInputEnabled 	:= true;
	self.tblGateLanes.userInputEnabled:=true;
	self.tblExtra.userInputEnabled := true; //epr par 16510 3/7/08 
	self.frmMain.enabled := true;	
	self.frmMain.myVScroll.enabled := true;
	self.btnExtraDelete.enabled := true;
	self.btnExtraEdit.enabled := true;
	self.btnExtraNew.enabled := true;
	self.btnExtraSave.enabled := true;
	self.allCMIFGridLCsAssocICArea.purge;
	
	if mode = Mode_Add then
		self.sptThumbEdit.hideRightControl(true);
		self.clearDesignArea();
		self.tblExtra.clearValues();
		self.displayProductMinMaxs(null);
		self.tblMain.clearValues;
		self.tblMain.showHideRowsByViewName('ViewMain', CM_EntryTable.ShowHideRows, false); //ShowRowsOnly or ShowHideRows or HideRowsOnly
		self.tblMain.enableRowByName( ETRow_Type);
		self.tblMain.enableRowByName(ETRow_Id);
		self.tblMain.adjustHeight(1000);
		//self.shtDefDesign.caption 	:= "New Terminal Area";
		self.shtDefDesign.enabled 	:= false;	// 09/07/2008 cnwar2 #17467 - disabled until user selects type
		self.shtTerminalAreas.visible:=false;
		
		
		self.tblMain.moveFirst;
		self.tblMain.setFocus;
		self.tblMain.setValueByName(ETRow_StockControlled,myTerminal.getConfig(DefTAStockControlled).Boolean);
		
		
		//cnwer1 20/8/08 this was really annoying me if the filter type is set then users shouldn't have to re-select it
		if self.cmbTATypeFilter.listObject &lt;&gt; null then
			self.cmbTAType.text:=self.cmbTATypeFilter.listObject.CM_TerminalAreaType.description;
			self.tblMain.setValueByName(ETRow_Type,self.cmbTAType.text);
			self.doComboTATypeSelect();
		endif;
		self.tblAPYardStack.userInputEnabled := true;
		self.resetTblAPYardStack();
		self.tblMain.enableRowByName( ETRow_Terminal);
		self.fldDefinition.initSheetBackColors();
		
		self.listsTermAreas.setSelected(null);
		self.listsMachines.setSelected(null);		// PAR #28047
		// 28604 Nov 2011 only show un-attached work points
		if self.terminalAreaType = TA_TYPE_WORKPOINT_INTERCHANGE then
			self.doBuildComboWorkPoints(null);
		elseif self.terminalAreaType = TA_TYPE_IRREGULAR_BLOCK_AREA then // ### TFS CR 58499 TASK 61459 04JAN2024 NAVAB1
			self.shtGateLanes.visible	:= false; // ### TFS CR 58499 TASK 61459 04JAN2024 NAVAB1
		endif;


	elseif mode = Mode_Update then
		self.enableRows();
		taType := getTAStringToType(tblMain.getValueByName(ETRow_Type).String);
		self.btnPenReeferGant.enabled := taType.type &lt;&gt; TA_TYPE_LOGAREA and taType.type &lt;&gt; TA_TYPE_FORK_LIFT_STACK;
		self.btnPenPower.enabled := taType.type &lt;&gt; TA_TYPE_LOGAREA;
		self.tblMain.disableRowByName(ETRow_Type);
		self.tblMain.enableRowByName(ETRow_Id);
		
		
		if taType.isGridAreaType then
			self.doDrawGridArea(true);
			if taType.isGantryInterchangeArea then
				self.tblMain.disableRowByName( ETRow_InterchangePosition);
			endif;
			self.createAllCMIFGridLCsAssocIC();
		endif;
		
		if taType.type = TA_TYPE_IRREGULAR_BLOCK_AREA then
			self.doDrawBlockArea(proxy.CM_TerminalArea, true);
			self.displayProductMinMaxs(proxy);	//20 Jun 2016	NDL	TFS 1752
			self.cmbCargoType.listIndex:=-1;	//20 Jun 2016	NDL	TFS 1752
			self.doChangeCargoType();			//20 Jun 2016	NDL	TFS 1752
			self.shtGateLanes.visible	:= false; // ### TFS CR 58499 TASK 61459 04JAN2024 NAVAB1

		elseif taType.type = TA_TYPE_RAILWAY_TRACK then
			//self.tblMain.disableRowByName( ETRow_RailTransferArea);					// 13/12/2010 cnwar2 #25956
			self.doBuildRailTransferCombo(self.myCurrentObject.CM_Rail.myTransferArea);	// 13/12/2010 cnwar2 #25956
		elseif taType.type = TA_TYPE_BULK  or taType.type = TA_TYPE_BLOCK_STACK then
			self.displayProductMinMaxs(proxy);
			self.cmbCargoType.listIndex:=-1;
			self.doChangeCargoType();
			//self.cmbCargoType.lostFocus(self.cmbCargoType);
			
		elseif taType.type = TA_TYPE_YARD_INTERCHANGE then
			if self.cmbDefExitGate.findObject(proxy.CM_InterchangeArea.myDefaultOutGate) &gt; 0 then
				self.cmbDefExitGate.listObject := proxy.CM_InterchangeArea.myDefaultOutGate;
			endif;
			self.listsTermAreas.setSelected(self.myCurrentObject.CM_InterchangeArea.allAssociatedTerminalAreas);
			// par 24418 - vehicle machine access rules
			self.cmbVehicleAccess.listIndex := self.cmbVehicleAccess.findItemData (proxy.CM_InterchangeArea.vehicleMachineAccessRules);
			// par 24418 - end
			self.setControlsForLaneTable();
		// 20/08/2012 cnwar2 #30128
		elseif taType.type = TA_TYPE_WORKPOINT_INTERCHANGE then
			self.cmbWorkPoint.listObject := proxy.CM_WorkPointInterchangeArea.myWorkPoint;
			self.setControlsForLaneTable();
		elseif  taType.type = TA_TYPE_RORO_LANE_AREA  then
			self.setControlsForRoRoLaneTable();
			
		elseif taType.type = TA_TYPE_GEN_CARGO_ALLOC_ROW then		// TFS 49453
			self.displayProductMinMaxs(proxy);						// TFS 49453
			
		endif;
		
		self.tblAPYardStack.userInputEnabled := true;		
		self.tblMain.disableRowByName(  ETRow_Terminal);
	
		self.listsMachines.setSelected(self.myCurrentObject.CM_TerminalAreaMaster.allowedMachines);		// PAR #28047
		
		if proxy.isKindOf(CM_TerminalArea) and proxy.CM_TerminalArea.allAssociatedInterchangeAreas.size &gt; 0 then
			if self.cmbInterchange.findObject(proxy.CM_TerminalArea.allAssociatedInterchangeAreas.first) &gt; 0 then
				self.cmbInterchange.listObject := proxy.CM_TerminalArea.allAssociatedInterchangeAreas.first;
			endif;
		endif;
	endif;

//	tblMain.hideRowByName(ETRow_LaneSeqNo, false); 

	self.listsTermAreas.readOnly := false;
	self.listsMachines.readOnly := false;		// PAR #28047
	
	self.btnFlipHori.enabled := shtDefDesign.enabled;	
	self.btnFlipVertical.enabled := shtDefDesign.enabled;	
	

	
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForLaneTable" id="a018bbfe-bea3-479c-8f6d-2099ad0fc76a">
        <source>setControlsForLaneTable();
/*
Purpose:			
Return Value:		

Date				Who		Reason
22 September 2006	cnwer1	Initial creation - PAR#xxxx
11/09/2009			cnwcs5	remove old VTA columns
25/05/2010			cnwcs5	par 24292 - interchange area lane capacity
							Also removed ability to change lane # column as it does not get saved
*/
vars
	col		: Integer;
	tbl		: CM_DataTable;
begin
	if (not self.shtGateLanes.visible) then
		return;
	endif;
	
	self.myAssistant.comboBoxPrinterDefs(self.cmbPrinter, false, null);
	self.myAssistant.comboBoxRFIDTagReaders(self.cmbRFIDTags,false,null);  //cnwjo3, par 20552 ccms 1071
	
	tbl := self.tblGateLanes;
		
	tbl.getEntRowColumnByRowName(ETRow_GateLaneId, col);
	if col &gt; 0 then
		tbl.accessColumn(col).inputType := Table.InputType_None;				// par 24292 cnwcs5 25/05/2010
		tbl.accessedColumn.alignment	:= Table.Alignment_Center	;			// par 24292 cnwcs5 25/05/2010
	endif;
	
	
	
	tbl.getEntRowColumnByRowName(ETRow_IsClosed, col);
	if col &gt; 0 then
		tbl.accessColumn(col).inputType := Table.InputType_CheckBox;			// ...cnwgb1 12 May 2008 PAR 16483
		tbl.accessedColumn.alignment	:= Table.Alignment_Center;				// par 24292 cnwcs5 25/05/2010
	endif;
	
	tbl.getEntRowColumnByRowName(ETRow_RFIDTagReader, col);
	if col &gt; 0 then
		tbl.accessColumn(col).inputType := Table.InputType_TextBox;				//cnwjo3 par 20582, is now a combobox
		tbl.accessedColumn.cellControl := self.cmbRFIDTags;
	endif;
	
	tbl.getEntRowColumnByRowName(ETRow_Printer, col);
	if col &gt; 0 then
		tbl.accessColumn(col).inputType := Table.InputType_TextBox;
		tbl.accessedColumn.cellControl := self.cmbPrinter;
	endif;
	
	tbl.getEntRowColumnByRowName(ETRow_Capacity, col);						// par 24292 cnwcs5 25/05/2010
	if col &gt; 0 then
		tbl.accessColumn(col).inputType := Table.InputType_TextNumeric;			// par 24292 cnwcs5 25/05/2010
		tbl.accessedColumn.maxLength	:= 2;									// par 24292 cnwcs5 25/05/2010
		tbl.accessedColumn.alignment	:= Table.Alignment_Center;				// par 24292 cnwcs5 25/05/2010
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForRoRoLaneTable" id="f0e5b3ac-e069-40de-bb95-c901d128f8d6">
        <source>setControlsForRoRoLaneTable();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 November 2009	cnwjk3	ccms 1018

*/

vars
	col			: Integer;
	tbl			: CM_DataTable;
begin
	if (not self.shtGateLanes.visible) then
		return;
	endif;

	self.loadRoRoCombos();
	
	tbl := self.tblGateLanes;

	tbl.getEntRowColumnByRowName(ETRow_Id, col);
	tbl.accessColumn(col).inputType := Table.InputType_TextBox;
	tbl.accessColumn(col).maxLength := 3;	//08 Dec 2015	NDL	Par 37272
	tbl.accessColumn(col).cellControl.TextBox.case := TextBox.Case_Upper;
	
	
	tbl.getEntRowColumnByRowName(ETRow_Length, col);
	tbl.accessColumn(col).inputType := Table.InputType_TextNumeric;
	tbl.accessColumn(col).decimals := 2;	
	tbl.accessColumn(col).maxLength := 7;
	
	tbl.getEntRowColumnByRowName(ETRow_Width, col);
	tbl.accessColumn(col).inputType := Table.InputType_TextNumeric;
	tbl.accessColumn(col).decimals := 2;	
	tbl.accessColumn(col).maxLength := 5;
	
	tbl.getEntRowColumnByRowName(ETRow_StartOffset, col);
	tbl.accessColumn(col).inputType := Table.InputType_TextNumeric;
	tbl.accessColumn(col).decimals := 2;	
	tbl.accessColumn(col).maxLength := 5;
	
	tbl.getEntRowColumnByRowName(ETRow_NumberingDirection, col);
	tbl.accessColumn(col).inputType := Table.InputType_TextBox;
	tbl.accessedColumn.cellControl := self.cmbNumDir;

	tbl.getEntRowColumnByRowName(ETRow_ParkDirection, col);
	tbl.accessColumn(col).inputType := Table.InputType_TextBox;
	tbl.accessedColumn.cellControl := self.cmbParkDir;
	
	tbl.getEntRowColumnByRowName(ETRow_AccessDirection, col);
	tbl.accessColumn(col).inputType := Table.InputType_TextBox;
	tbl.accessedColumn.cellControl := self.cmbAccessDir;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="8d69fcec-f09e-4d05-9d06-36eaf0321c07">
        <updating/>
        <source>setControlsForView() updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();

	tblMain.userInputEnabled := false;
	tblExtra.userInputEnabled := false; //epr par 16510 3/7/08 

	self.btnExtraDelete.enabled := false;
	self.btnExtraEdit.enabled := false;
	self.btnExtraNew.enabled := false;	
	self.btnExtraSave.enabled := false;
	self.btnStackEdit.enabled := false; //07 Sep 2020	NDL	TFS 49984
	
	self.tblAPYardStack.userInputEnabled := false;	
	self.frmMain.enabled := true;	
	self.tblGateLanes.userInputEnabled:=false;
	self.setControlsForLaneTable;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="setConvertedDisplayValue" id="037876c3-e4df-4986-a018-a7a05a4d8172">
        <source>setConvertedDisplayValue(_table : CM_EntryTable input; _rowName : String; _rawValue : Decimal; _measureType : CM_MeasurementType ) protected;
/*

Date		Who		Reason
31 March 2014	cnwer1	Initial creation PAR

*/

vars
	rawValue : Decimal [16,4];
	convertedValue : String;
	prefix : String;
	
begin

	rawValue := _rawValue;

	convertedValue := app.convertMeasurementForDisplay(_measureType.shortName, rawValue) &amp; Space &amp; _measureType.shortName;
	if not app.myRoot.getConfig(MeasuresSeparateLines).Boolean then
		self.getMultiValueConvertedString( rawValue, _measureType, convertedValue );
	endif;
	
	prefix := app.getMeasurementPrefixFromType( _measureType.measurementType );

	_table.setValueByName(_rowName, convertedValue);
	_table.setValueByName( prefix &amp; _rowName &amp; "_" &amp; _measureType.shortName, convertedValue );

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_rawValue" type="Decimal"/>
        <Parameter name="_measureType" type="CM_MeasurementType"/>
    </JadeMethod>
    <JadeMethod name="setDefaultICAreas" id="5664e89e-054c-4b5c-9ab2-a97cbca25c29">
        <source>setDefaultICAreas() protected;
/*
Purpose:			
Parameters:			
Return Value:		

Date			Who		Reason
16 March 2010	cnwer1	Initial creation 22674
26/05/2010		cnwcs5	par24292 - allow for ordering of interchange areas.  Also use local variables 
						for controls that are referenced more than once
*/

vars
	terminalAreas 	: CM_TerminalAreaSet;
	list			: CMUI_MultiSelectGroupBox;	// par 24292
	sheet			: Sheet;					// par 24292
begin
	sheet	:= self.shtTerminalAreas;
	list	:= self.listsTermAreas;
	
	sheet.visible 	:= true;
	sheet.caption	:= app.getErrorString (Interchange_areas);
	
	list.readOnly  					:= true;
	list.mySelectedListBox.sorted	:= false; 	// 26/05/2010 cnwcs5 par 24292 - changed from true // epr par 20844 9/10/09
	list.displayOrderBtns(true, true);

	create terminalAreas transient;
	self.getValidInterchangeAreas(terminalAreas);
	
	list.setupControl(app.getErrorString(Interchange_areas), terminalAreas, SOP_TerminalAreaDefForm::listsTermAreasDisplayEntry.name);
epilog
	delete terminalAreas;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDefaultRoRoLabels" id="fc21317d-4e2b-4f51-9ac0-5a33e67d5e1d">
        <source>setDefaultRoRoLabels(_pxyArea : CM_RoRoLaneArea input ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 November 2009	cnwjk3	ccms 1018

*/

vars

begin
	_pxyArea.raiseExceptionIfNotTransient(method);
	_pxyArea.pxySetDefaultLabels();
	tblMain.setValueByName(ETRow_LeftLabel, _pxyArea.leftLabel);
	tblMain.setValueByName(ETRow_RightLabel, _pxyArea.rightLabel);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_pxyArea" type="CM_RoRoLaneArea" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setDefaultTAsForGantryLane" id="1876c17f-ea41-4805-a679-d66f2cab1b83">
        <source>setDefaultTAsForGantryLane(_type : CM_TerminalAreaType) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 March 2010	cnwer1	Initial creation

*/

vars
	terminalAreas	: CM_TerminalAreaSet;
begin
	shtTerminalAreas.visible 	:= true;
	listsTermAreas.mySelectedListBox.sorted:=false; //epr par 20844 9/10/09 we want this order retained
	listsTermAreas.displayOrderBtns(true, true);
	listsTermAreas.readOnly  	:= true;
		
	create terminalAreas transient;
	_type.getAllTAsForGantryLaneAreaType(self.myTerminal,terminalAreas);
	listsTermAreas.setupControl(app.getErrorString (TerminalAreas), terminalAreas, SOP_TerminalAreaDefForm::listsTermAreasDisplayEntry.name);	
epilog
	delete terminalAreas;
end;</source>
        <access>protected</access>
        <Parameter name="_type" type="CM_TerminalAreaType"/>
    </JadeMethod>
    <JadeMethod name="setDefaultTAsForInterchange" id="4d2d7281-8794-4d04-bf76-e32635980be0">
        <source>setDefaultTAsForInterchange(_currentTa : CM_TerminalArea)  protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 March 2010	cnwer1	Initial creation

*/

vars
	terminalAreas : CM_TerminalAreaSet;
begin
	shtTerminalAreas.visible 	:= true;
	listsTermAreas.readOnly  	:= true;
	listsTermAreas.mySelectedListBox.sorted:=true; //epr par 20844 9/10/09
	terminalAreas				:= self.getValidTerminalAreas(_currentTa);
	
	listsTermAreas.setupControl(app.getErrorString (TerminalAreas), terminalAreas, SOP_TerminalAreaDefForm::listsTermAreasDisplayEntry.name);
epilog
	delete terminalAreas;
end;</source>
        <access>protected</access>
        <Parameter name="_currentTa" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="setFilterDefaults" id="b887bd51-5c5a-43e2-a04d-aa2dad9b5762">
        <updating/>
        <source>setFilterDefaults() updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
//	cnwcs5	23/07/2009	ccms 1061 - changed to allow default TA type to be set on load
// 15/05/2010 	cnwcs5	par24292 - removed wirte statement.
vars

begin 
	self.myFilterTAType := null;
	self.filterType 	:= null;
	
	// cnwcs5 ccms 1061 23/07/2009 start
	if self.myFilterTAType_Default &lt;&gt; null then
		self.myFilterTAType 		:= self.myFilterTAType_Default;
		self.filterType 			:= self.myFilterTAType_Default.type;
		
		tblSearch.setValueByName(ETRow_FilterTAType, self.myFilterTAType.description);
		
		self.myFilterTAType_Default := null;	// only default for first time
	endif;
	// cnwcs5 ccms 1061 23/07/2009 end
end;</source>
    </JadeMethod>
    <JadeMethod name="setFilterValues" id="796be9e0-3431-4546-b3b2-9b252846a913">
        <updating/>
        <source>setFilterValues() updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	taType				: String;
	tat					: CM_TerminalAreaType;
	root				: CM_Root;
	isInterTermMulti	: Boolean;
begin
	root := app.myRoot;
	isInterTermMulti := root.isInterTerminalTransferEnabled();
	taType := tblSearch.getValueByName(ETRow_FilterTAType).String;
	
	foreach tat in app.myRoot.allTerminalAreaTypes do
		
		
		if not self.isValidType(tat.type, isInterTermMulti) then
			continue;
		endif;
		
		if tat.description.trimBlanks = taType.trimBlanks then
			//beginTransaction;
			self.filterType := tat.type;
			self.myFilterTAType := tat;
			//commitTransaction;
			break;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="setGapWidth" id="385c6cb0-98c1-45b1-9a48-4915037cfbb7">
        <source>setGapWidth(pWidth : Integer) protected;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		Set the attribute for the selected cells. By the time we get here we can assume that all the selected cells are for the same attribute
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	gridPoint : CMUI_GridPoint;

begin

	if self.myCurrentSOPGridArea.selectedColumn &lt;&gt; 0 then
		foreach gridPoint in self.myCurrentSOPGridArea.allGridPoints do
			if gridPoint.column = self.myCurrentSOPGridArea.selectedColumn then
				gridPoint.SOP_GridPoint.updateWidth(pWidth);
			endif;
		endforeach;
		 self.frmMain.drawSelf();
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="pWidth" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setGraphicLayout" id="abc0ed16-c6d7-498c-8e3d-557ced54f607">
        <updating/>
        <source>setGraphicLayout(_theColour : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	proxyTA 	: CM_TerminalArea;
begin
	proxyTA := self.myProxyObject.CM_TerminalArea;
	if proxyTA.myLayoutGraphic = null then
		proxyTA.initDefaultLayout();
	endif;

	proxyTA.myLayoutGraphic.setProxyColour(_theColour, White);

end;</source>
        <Parameter name="_theColour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setGridOffsets" id="53c9ee25-40d8-4b20-b7e6-74efd6da1d40">
        <updating/>
        <source>setGridOffsets(_pxyTA : CM_GridArea) updating, protected;
// ---------------------------------------------------------------------------
// Created:		May 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	cntrlDictOffset						: CM_RTGControllerBySeqRowCol; // This is actuall GridControllers
	gridCntrl : CM_GridController;
begin

	// PAR 16415 CCMS 1029
	// ### FORTY FIVE FOOTERS
	create cntrlDictOffset transient;
	foreach gridCntrl in _pxyTA.allGridControllersByRowColumn do
		if  gridCntrl.is45ft then
			cntrlDictOffset.add(gridCntrl);
		endif;
	endforeach;
	_pxyTA.set45ftControllers(cntrlDictOffset);

	// ### THIRTY FOOTERS
	cntrlDictOffset.clear();
	foreach gridCntrl in _pxyTA.allGridControllersByRowColumn do
		if  gridCntrl.is30ft then
			cntrlDictOffset.add(gridCntrl);
		endif;
	endforeach;
	_pxyTA.set30ftControllers(cntrlDictOffset);

	// ### FIFTY THREE FOOTERS
	cntrlDictOffset.clear();
	foreach gridCntrl in _pxyTA.allGridControllersByRowColumn do
		if  gridCntrl.is53ft then
			cntrlDictOffset.add(gridCntrl);
		endif;
	endforeach;
	_pxyTA.set53ftControllers(cntrlDictOffset);
	
	// PAR 18682
	// ### FORTY FOOTERS
	cntrlDictOffset.clear();
	foreach gridCntrl in _pxyTA.allGridControllersByRowColumn do
		if  gridCntrl.is40ft then
			cntrlDictOffset.add(gridCntrl);
		endif;
	endforeach;
	_pxyTA.set40ftControllers(cntrlDictOffset);
	// PAR 18682
	// ### TWENTY FOOTERS
	cntrlDictOffset.clear();
	foreach gridCntrl in _pxyTA.allGridControllersByRowColumn do
		if  gridCntrl.is20ft then
			cntrlDictOffset.add(gridCntrl);
		endif;
	endforeach;
	_pxyTA.set20ftControllers(cntrlDictOffset);


epilog
	delete cntrlDictOffset;	
end;</source>
        <access>protected</access>
        <Parameter name="_pxyTA" type="CM_GridArea"/>
    </JadeMethod>
    <JadeMethod name="setMyDataClass" id="592c5b4e-555e-4e87-9dd6-96633f80b128">
        <updating/>
        <source>setMyDataClass() updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin

	self.myDataClass := CM_TerminalArea;

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyGateLanes" id="5e49d123-e77d-4a4e-885f-9830ae2197f5">
        <source>setProxyGateLanes(_proxy : CM_InterchangeArea input) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	pxyLane			: CM_YardICAreaLaneController;
	myPrinter		: CM_PrinterDef;
	isClosed		: Boolean;
	tagReader		: CM_RFIDTagReader;
	closedCol,
	tagCol,
	capacityCol,				// par 24292 cnwcs5 25/05/2010
	printerCol,
	row,
	capacity		: Integer;
	array			: CM_ObjectArray;
	obj				: Object;
begin
	// create default lane for terminal area - in by default
	if not _proxy.pxyHasLanesDefined then 
		_proxy.pxyCreateNewLane (true);
	else 
	//copy values from GateLanes table into proxy's allGridControllers
		self.tblGateLanes.getEntRowColumnByRowName(ETRow_IsClosed, closedCol);
		self.tblGateLanes.getEntRowColumnByRowName(ETRow_RFIDTagReader, tagCol);
		self.tblGateLanes.getEntRowColumnByRowName(ETRow_Printer, printerCol);
		self.tblGateLanes.getEntRowColumnByRowName(ETRow_Capacity, capacityCol);	// par 24292 cnwcs5 25/05/2010
		
		// get lanes in lane number order
		create array transient;
		_proxy.getAllLaneControllers (array);

		row := self.tblGateLanes.fixedRows+1;
		foreach obj in array do
			// 28603 Nov 2011 new interchange area can have one row from pxyCreateNewLane above if second time around after fixing error but no lanes
			//  so check the table content
			if row &gt; self.tblGateLanes.rows then
				break;
			endif;
			if obj.isKindOf(CM_YardICAreaLaneController) then 
				pxyLane := obj.CM_YardICAreaLaneController;
				
				myPrinter 	:= self.tblGateLanes.accessCell(row, printerCol).itemObject.CM_PrinterDef;
				tagReader 	:= self.tblGateLanes.accessCell(row, tagCol).itemObject.CM_RFIDTagReader;
				isClosed 	:= self.tblGateLanes.accessCell(row, closedCol).text.Integer.Boolean;
				capacity 	:= self.tblGateLanes.accessCell(row, capacityCol).text.Integer;		// 25/05/2010 cnwcs5 par 24292
				
				if myPrinter = null and self.tblGateLanes.accessCell(row, printerCol).text &lt;&gt; null then
					//we only have the description, object not set in cell
					myPrinter := self.getPrinterByDescription(self.tblGateLanes.accessCell(row, printerCol).text);
				endif;
				
				if tagReader = null and self.tblGateLanes.accessCell(row, tagCol).text &lt;&gt; null then
					//we only have the description, object is not set
					tagReader := getRFIDTagReaderByDescOrCode(self.tblGateLanes.accessCell(row, tagCol).text);
				endif;
				
				pxyLane.setPrinter(myPrinter); 
				// interchange area rfid tag readers are always read devices right now
				pxyLane.setRFIDTagReader(tagReader,true);	// changed from false (cnwcs5 - 10/09/2009)
				
				pxyLane.setIsUnavailable(isClosed);
				pxyLane.setCapacity (capacity);				// 25/05/2010 cnwcs5 par24292
			endif;
			row := row + 1;
		endforeach;
	endif;
epilog
	delete array;
end;</source>
        <access>protected</access>
        <Parameter name="_proxy" type="CM_InterchangeArea" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTABlock" id="80a52467-8315-4a7f-8755-4d6efab06411">
        <updating/>
        <source>setTABlock() : Boolean updating, protected;
// 26/05/2010	cnwcs5	par 24292 - use array instead of set
vars
	taType 			: CM_TerminalAreaType;
	proxyTA			: CM_BlockStack;
	tmpId			: String;
	tmpType			: Integer;
	tmpHeight,
	tmpColour		: Integer;
	tmpTypeString	: String;
	tmpRel			: Boolean;
	tmpMax			: Integer;
	tmpComment,
	tmpID			: String;
	tmpAutoRestrict,
	tmpOverlapped,
	tmpStockControlled,
    tmpAutoPlanEnabled, 
	tmpHide			: Boolean;
	tmpInterchange	: String;
	interchangeArea	: CM_InterchangeArea;
	selectedInterchangeAreas : CM_InterchangeAreaArray;	// par 24292
	tmpRows : Integer;	//29 Aug 2011	NDL	Par 28076
	tmpColumns : Integer;	//29 Aug 2011	NDL	Par 28076
	tmpEnforceMaxCap : Boolean;	//29 Aug 2011	NDL	Par 28076
	tmpCreateDelTrx : Boolean;
	tmpAutoRelease : Boolean;	//28 May 2018	NDL	TFS 38897
	tmpAutoRelTrx : Integer;	//28 May 2018	NDL	TFS 38897
	trxType : CM_TransactionType;	//28 May 2018	NDL	TFS 38897
begin
	if (not self.getProxyObject(CM_BlockStack)) then
		return false;
	endif;
	
	taType	:= getTAStringToType(tblMain.getValueByName(ETRow_Type).String);
	proxyTA := self.myProxyObject.CM_BlockStack;

	tmpID 				:= tblMain.getValueByName(ETRow_Id).String[1:13];
	tmpType 			:= taType.type;
	tmpHeight	 		:= 3;
	tmpRows 			:= tblMain.getValueByName(ETRow_Rows).Integer;	//29 Aug 2011	NDL	Par 28076
	tmpColumns 			:= tblMain.getValueByName(ETRow_Cols).Integer;	//29 Aug 2011	NDL	Par 28076
	tmpEnforceMaxCap	:= tblMain.getValueByName(ETRow_EnforceMaxCapacity).Boolean;	//29 Aug 2011	NDL	Par 28076
	tmpTypeString 		:= tblMain.getValueByName(ETRow_Type).String.trimBlanks;
	tmpRel 				:= tblMain.getValueByName(ETRow_ActAsReleasePoint).Boolean;
	tmpMax 				:= tblMain.getValueByName(ETRow_MaxCapacity).Integer;
	tmpStockControlled 	:= tblMain.getValueByName(ETRow_StockControlled).Boolean;
	tmpOverlapped 		:= tblMain.getValueByName(ETRow_IsOverlapped).Boolean;
	tmpHide				:= tblMain.getValueByName(ETRow_HideFromOverView).Boolean;
	tmpAutoRestrict 	:= tblMain.getValueByName(ETRow_AutoRestrictionsEnabled).Boolean;
	tmpInterchange		:= tblMain.getValueByName(ETRow_InterchangeArea).String;
	interchangeArea		:= self.myTerminal.allTerminalAreas[tmpInterchange].CM_InterchangeArea;
	tmpCreateDelTrx		:= tblMain.getValueByName(ETRow_DoCreateLogicalDelTrx).Boolean;
	
	//28 May 2018	NDL	TFS 38897
	if tmpType = TA_TYPE_RELTRANS then
		tmpAutoRelease	:= tblMain.getValueByName(ETRow_AutoRelease).Boolean;
		if tmpAutoRelease then
			trxType := self.cmbTrxType.listObject.CM_TransactionType;
			if trxType &lt;&gt; null then
				tmpAutoRelTrx := trxType.trxType;
			endif;
		endif;
	else
		tmpAutoRelease := false;
		tmpAutoRelTrx := 0;
	endif;
	
	create selectedInterchangeAreas transient;
	listsTermAreas.getSelected(selectedInterchangeAreas);
	
	if tmpType = TA_TYPE_RAIL_TRANS then 
    	tmpAutoPlanEnabled := tblMain.getValueByName(ETRow_AutoPlanEnabled).Boolean;
    else
    	tmpAutoPlanEnabled := false;
    endif;	

	tmpColour := tblMain.getValueByName(ETRow_Colour).Integer;
	tmpComment := tblMain.getValueByName(ETRow_Comment).String;
	
	if proxyTA.myLayoutGraphic &lt;&gt; null then
		proxyTA.myLayoutGraphic.setProxyColour(tmpColour, White);
	else
		// 24/06/2009 - added next line to make sure the colour gets saved 
		// to the proxy even for a  new TA
		self.setGraphicLayout(tmpColour);
	endif;
	
	if self.mode = Mode_Add then
		proxyTA.setIsEmpty(true);
	endif;	
	proxyTA.setProxy(tmpID, 
					tmpComment,
					tmpType, 
					tmpHeight, 
					tmpRows,	//pRows : Integer;	//29 Aug 2011	NDL	Par 28076
					tmpColumns,	//pColumns : Integer;	//29 Aug 2011	NDL	Par 28076
					tmpEnforceMaxCap,	//pEnforceMaxCapacity : Boolean;	//29 Aug 2011	NDL	Par 28076
					tmpTypeString, 
					tmpMax,
					tmpRel,
					null, 
					self.myTerminal,
					tmpAutoRestrict,
					tmpAutoPlanEnabled,
					tmpStockControlled,
					tmpOverlapped,
					tmpHide,
					selectedInterchangeAreas,
					interchangeArea,
					tmpCreateDelTrx	//04 Aug 2017	NDL	TFS 5679
					);
	proxyTA.setAutoRelease( tmpAutoRelease, tmpAutoRelTrx );	//28 May 2018	NDL	TFS 38897
	self.createDeckingOptionsProxy(proxyTA);
	return true;
epilog
	delete selectedInterchangeAreas;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTABlockArea" id="b49b28ec-1687-4313-ac64-9a5e2857e21f">
        <updating/>
        <source>setTABlockArea(populateLocations : Boolean) : Boolean updating, protected;
// Set the proxy object from the values in the table
// Create the proxies for locations 
// 26/05/2010	cnwcs5	par 24292 - use array instead of set
vars
	proxyTA	: CM_IrregularBlockArea;
	location : CM_LocationsController;
	locationProxy : CM_IrregularBlockController;
	id : String;
	rows, columns : Integer;
	unit : Decimal[6, 2];
	comment	: String;
	autoRestrictions, stockControlled : Boolean;
	tmpInterchange	: String;
	interchangeArea	: CM_InterchangeArea;
	selectedInterchangeAreas : CM_InterchangeAreaArray;	// par 24292
	msg : String;
begin
	if (not self.getProxyObject(CM_IrregularBlockArea)) then
		return false;
	endif;

	proxyTA := self.myProxyObject.CM_IrregularBlockArea;
	id := tblMain.getValueByName(ETRow_Id).String[1:13];
	comment := tblMain.getValueByName(ETRow_Comment).String;
	rows := tblMain.getValueByName(ETRow_NumberOfRows).Integer;
	columns := tblMain.getValueByName(ETRow_NumberOfCols).Integer;
	unit := tblMain.getValueByName(ETRow_Unit).String.asDecimalJMT;		// 36603 was .Decimal
	stockControlled := tblMain.getValueByName(ETRow_StockControlled).Boolean;
	autoRestrictions := tblMain.getValueByName(ETRow_AutoRestrictionsEnabled).Boolean;
	tmpInterchange	:= tblMain.getValueByName(ETRow_InterchangeArea).String;
	interchangeArea	:= self.myTerminal.allTerminalAreas[tmpInterchange].CM_InterchangeArea;
	
	//21 Dec 2015	NDL	Par 37270
	if rows * columns &gt; 10000 then
		msg := app.getErrorString(About_creat_updat_area_that_wi);
		if app.msgBox( msg, app.getErrorString(Continue), MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
			return false;
		endif;
	endif;
	
	create selectedInterchangeAreas transient;
	listsTermAreas.getSelected(selectedInterchangeAreas);
	
	proxyTA.setProxy(id, comment, TA_TYPE_IRREGULAR_BLOCK_AREA, rows, columns, unit, null, null, 
		autoRestrictions, stockControlled, self.myTerminal, selectedInterchangeAreas,interchangeArea);
		
	// Populate proxy locations
	if populateLocations then
		proxyTA.allLocationsControllers.purge();
		foreach location in self.myCurrentObject.CM_IrregularBlockArea.allLocationsControllers do
			locationProxy := app.createUpdateProxy(location).CM_IrregularBlockController;
			locationProxy.setProxy(	proxyTA,
									location.ident,
									location.CM_IrregularBlockController.region,
									location.CM_IrregularBlockController.colour,	//_colour : Integer;
									location.CM_IrregularBlockController.defaultCapacity,	//_defaultCapacity : Integer;
									location.CM_IrregularBlockController.locationType,	//_locationType : Integer;
									location.CM_IrregularBlockController.maximumWeight,	//_maximumWeight : Real;
									location.CM_IrregularBlockController.myAssociatedInterchangeArea	//_myICArea : CM_InterchangeArea
									);
		endforeach;
	endif;
	
	self.createDeckingOptionsProxy(proxyTA);

	return true;
epilog
	delete selectedInterchangeAreas;
end;</source>
        <access>protected</access>
        <Parameter name="populateLocations" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTABuilding" id="8679a870-4460-4190-99b2-046eb849f81e">
        <updating/>
        <source>setTABuilding() : Boolean updating, protected;
