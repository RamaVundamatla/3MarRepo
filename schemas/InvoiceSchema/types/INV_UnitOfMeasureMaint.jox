    <JadeMethod name="setProxyFromTable" id="5e8d5ea5-275b-43e1-8658-c9df3c0e39a5">
        <source>setProxyFromTable(pxyInvUOM : CM_InvoiceUnitOfMeasure input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Dec 2022 navvt20 TFS CR 55621 Task 55695: UI - UOM Maint
13 Feb 2023	navvt20	TFS CR 56132 Task 56399: UI - UOM Maintenance - Type
*/

vars
	description : String;
	code		: String;
	idx			: Integer; // 13 Feb 2023 navvt20 TFS 56399
	tmpType		: Integer; // 13 Feb 2023 navvt20 TFS 56399
begin
	code := self.tblEntDetail.getValueByName(ETRow_Code).String;
	description := self.tblEntDetail.getValueByName(ETRow_Description).String;
	// Start 13 Feb 2023 navvt20 TFS 56399
	idx := self.cmbType.listIndex;
	if idx &gt; 0 then
		tmpType := self.cmbType.itemData[idx];
	endif;
	// End 13 Feb 2023 navvt20 TFS 56399
	pxyInvUOM.setProxy(tmpType,code,description); // 13 Feb 2023 navvt20 TFS 56399
epilog

end;</source>
        <Parameter name="pxyInvUOM" type="CM_InvoiceUnitOfMeasure" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupPermissions" id="dacc7848-24b2-4d7c-a226-65a28c683e11">
        <updating/>
        <source>setupPermissions() updating;
// ---------------------------------------------------------------------------

// 13 December 2022	navvt20	TFS CR 55621 Task 55695: UI - UOM Maint
// ---------------------------------------------------------------------------

vars

begin
	if app.getMyUser.canDo(null, self.permissionMaint) then
		self.allowAdd	 := true;
		self.allowDelete := true;
		self.allowUpdate := true;
	else
		self.allowAdd	 := false;
		self.allowDelete := false;
		self.allowUpdate := false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="9e1671c4-1a7e-4180-be6a-cae047b2c8ae">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;
// ---------------------------------------------------------------------------
//13 December 2022	navvt20	TFS CR 55621 Task 55695: UI - UOM Maint
//13 February 2023	navvt20		TFS CR 56132 Task 56399: UI - UOM Maintenance - Type
// ---------------------------------------------------------------------------

vars
	theInvoiceUOM 			: CM_InvoiceUnitOfMeasure;
	theTable 				: CM_ThumbnailTable;
begin
	theInvoiceUOM 	:= 		obj.CM_InvoiceUnitOfMeasure;
	theTable 				:= self.tblThumb;
	
	theTable.rows := 0;
	self.tblThumb.columns := 2;
	self.showThumbnailForDef(ETDef_InvoiceUOMThumb, theInvoiceUOM);
	self.doCmbTypeBuild(theInvoiceUOM.type); // 13 Feb 2023 navvt20 TFS 56399
//	theTable.fitColumnWidths();

end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b6997417-0278-42d6-9887-41588dbed5ea">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 04 January 2023 08:57:24.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025335, locale);
end;</source>
    </JadeMethod>
</GUIClass>
