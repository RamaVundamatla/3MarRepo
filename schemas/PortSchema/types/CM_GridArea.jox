    </JadeMethod>
    <JadeMethod name="getRowOrdinalsBySeperation" id="232f8184-2f3a-4b32-97b8-d0fe36e755f7">
        <source>getRowOrdinalsBySeperation(_rows : IntegerArray input; _sep : Integer; _getOrd : Boolean; _dynaDict	: DynaDictionary);
// ---------------------------------------------------------------------------
// Created:		21 November 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	row,ordinal, a, b, c, d : Integer;
	gridRow : CM_GridRow;
	tmpObj :Object;
begin
	c := self.allGridRows.size; // number of rows
	a := _sep.max(1); // seperation
	
	_rows.add(1);
	b := 1;
	row := b;
	while true do

		
		row := row + a;
		if row &gt; c then
			b := b + 1;
			if b &gt; a then
				break;
			endif;
			row := b;
		endif;
		if _getOrd then
			gridRow := self.allGridRows[row];
			ordinal := gridRow.row; // normally this 'row' is the same as the index, but in the older ports  there maybe gaps
		else
			ordinal := row;
		endif;
		
		// only put rows that we are interested in
		if _dynaDict = null then
			_rows.add(ordinal);
		else
			tmpObj := _dynaDict.getAtKey(self.id, ordinal);
			if tmpObj &lt;&gt; null then
				_rows.add(ordinal);
			endif;
		endif;
	endwhile;
end;</source>
        <Parameter name="_rows" type="IntegerArray" usage="input"/>
        <Parameter name="_sep" type="Integer"/>
        <Parameter name="_getOrd" type="Boolean"/>
        <Parameter name="_dynaDict" type="DynaDictionary"/>
    </JadeMethod>
