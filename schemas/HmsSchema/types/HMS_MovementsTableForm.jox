        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNew_click(btn: Button input) updating;
// -------------------------------------------
// Created 17 May 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	self.showWorkingMovementForm(false);
	/*if self.tblMovements.currentMovement &lt;&gt; null then
		if (not self.myViewController.lockHMSObject(self.tblMovements.currentMovement.myPersistentMovement)) then
			return;
		endif;		
