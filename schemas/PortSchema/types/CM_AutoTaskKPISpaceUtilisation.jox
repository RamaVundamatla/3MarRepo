<Class name="CM_AutoTaskKPISpaceUtilisation" id="524960a6-8a25-42e5-a310-6b5be3eee05f">
    <superclass name="CM_AutoTask"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Run KPI Space Utilisation&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <ImplicitInverseRef name="allQryCargoTypes" id="009d3ac6-b1ac-494d-ab10-3370b2bda177">
        <memberTypeInverse/>
        <type name="CM_CargoTypesByIdDict"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allQryTerminalAreas" id="dc680c9d-007a-4279-bcd7-7c17be526b7d">
        <memberTypeInverse/>
        <type name="CM_TerminalAreaMasterSet"/>
    </ImplicitInverseRef>
    <JadeMethod name="getEntryTableViewName" id="43d8f402-a365-469a-96fc-884076f3969d">
        <source>getEntryTableViewName(): String;
// -------------------------------------------
// Created 08 September 2003 by cnwdvb1
// -------------------------------------------
vars

begin
	return 'bgpAutoViewKPISpaceUtil';


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="1d3a607c-bf77-4c71-ae23-0049a10ec21b">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		17 January 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxyMe : SelfType;
	completedOK		: Boolean;
begin
	pxyMe :=  inheritMethod();

	self.allQryCargoTypes.copy(pxyMe.allQryCargoTypes);
	self.allQryTerminalAreas.copy(pxyMe.allQryTerminalAreas);
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyMe;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyMe;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="e22c7ec8-68ac-45a9-983b-60896ca3ef90">
        <updating/>
        <source>setForCreate(_pxyAutoTask: CM_AutoTaskKPISpaceUtilisation) updating;
// ---------------------------------------------------------------------------
// Created:		January 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_pxyAutoTask);
	self.requestClassName	:= BGP_KPISpaceUtilisationRequest.name;

	_pxyAutoTask.allQryCargoTypes.copy(self.allQryCargoTypes);
	_pxyAutoTask.allQryTerminalAreas.copy(self.allQryTerminalAreas);

end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskKPISpaceUtilisation"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="502c4ae7-589c-4023-bbd8-0a2e4851c806">
        <updating/>
        <source>setForUpdate(_pxyAutoTask : CM_AutoTaskKPISpaceUtilisation) updating;

// cnwdvb1 16 January 2003 

vars

begin

	self.description 		:= _pxyAutoTask.description;
	self.myTerminal			:= _pxyAutoTask.myTerminal;
	self.myUser				:= _pxyAutoTask.myUser;
	
	self.allQryCargoTypes.clear;
	self.allQryTerminalAreas.clear;
	
	_pxyAutoTask.allQryCargoTypes.copy(self.allQryCargoTypes);
	_pxyAutoTask.allQryTerminalAreas.copy(self.allQryTerminalAreas);

end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskKPISpaceUtilisation"/>
    </JadeMethod>
    <JadeMethod name="setValueForRow" id="56e09ccc-ce3f-47bf-9750-36bb6a114f85">
        <updating/>
        <source>setValueForRow(_rowName: String; _value: Any) updating;
// ---------------------------------------------------------------------------
// Created:		January 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin

	if _rowName = ETRow_BgpCargoTypes then
		self.allQryCargoTypes.clear;
		_value.ObjectArray.copy(self.allQryCargoTypes);
	elseif _rowName = ETRow_BgpTerminalAreas then
		self.allQryTerminalAreas.clear;
		_value.ObjectArray.copy(self.allQryTerminalAreas);
	else
		inheritMethod(_rowName, _value);
	endif;	
	

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
</Class>
