<GUIClass name="CM_FilterTableButton" id="3722fa88-3ebb-4d2e-8de2-767f1467eed5">
    <superclass name="CMUI_Button"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <JadeMethod name="click" id="5d8d92b9-83fd-4035-8906-03154b7cf979">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>click(btn: Button input) updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2015	cnwndl1	Initial creation

*/

vars

	filterTable : CM_FilterTable;

begin
	
	if self.parent.isKindOf( CMUI_FilterTableFrame ) then
		filterTable := self.parent.CMUI_FilterTableFrame.myFilterTable;
		if filterTable &lt;&gt; null then
			if self = filterTable.btnClearFilters then
				filterTable.btnClearFilters_click( self );
				return;
			elseif self = filterTable.btnShowHide then
				filterTable.btnShowHide_click( self );
				return;
			elseif self = filterTable.btnApplyFilterChg then
				filterTable.btnApplyFilterChg_click( self );
				return;
			elseif self = filterTable.btnCancelFilterChg then
				filterTable.btnCancelFilterChg_click( self );
				return;
			elseif self = filterTable.btnSelectAll then
				filterTable.btnSelectAll_Click( self );
				return;
			endif; 
			
			
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
