    <JadeMethod name="getTablePackedSettings" id="d4b1f066-ea6e-413f-b26a-c5f2081c7c3f">
        <source>getTablePackedSettings(_columns :Integer io; _header : String io);
// ---------------------------------------------------------------------------
// Created:     16 May 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	_columns := 2;
	_header := app.getErrorString(Id).toUpper &amp; Tab &amp; app.getErrorString(Container);
end;</source>
        <Parameter name="_columns" type="Integer" usage="io"/>
        <Parameter name="_header" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getTableToPackSettings" id="01f49271-9fca-43c2-8266-24beffd404e0">
        <source>getTableToPackSettings(_columns :Integer io; _header : String io);
// ---------------------------------------------------------------------------
// Created:     20 May 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	_columns := 2;
	_header := app.getErrorString(Id).toUpper &amp; Tab &amp; app.getErrorString(Location);
end;</source>
        <Parameter name="_columns" type="Integer" usage="io"/>
