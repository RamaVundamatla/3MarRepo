    <JadeMethod name="saveWarnings" id="966fa9b3-cfc7-49bf-8915-2861ac770a5f">
        <updating/>
        <source>saveWarnings() updating, protected;
// ---------------------------------------------------------------------------
// Created:     14 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	err	: CM_Error;

begin

	self.allSavedWarnings.clear;
	
	foreach err in self.allWarnings do
		self.allSavedWarnings.add(err.getDetailsAsString);
	endforeach;
	
	if self.debug then
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  saved ' &amp; self.allSavedWarnings.size.String &amp; ' warnings');
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
