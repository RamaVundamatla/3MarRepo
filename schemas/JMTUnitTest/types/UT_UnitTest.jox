    <JadeMethod name="stringIfDmast" id="4cb7473a-971f-463f-8652-72ff736352c8">
        <source>stringIfDmast(_dmastString, _wmastString : String) : String protected;
/*

Purpose:			Returns a string value if running tests in Dmast or a different value if running in Wmast

Parameters:			

Return Value:		

Date			Who		Reason
25 July 2024	navmd1	Initial creation

*/

vars

begin
	if app.isRunningInDMAST then
		return _dmastString;
	else
		return _wmastString;
	endif;
epilog

end;</source>
