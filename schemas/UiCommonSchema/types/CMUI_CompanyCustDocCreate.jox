    <JadeMethod name="doOK" id="391cb073-dfb9-4d09-b362-b526bfe3f655">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/10/2023	navkc1	CR 60422 Task 60917: JADE - Group Selected TIs by Transport

*/

vars
	agent	: CMIF_CompanyCustDocAgent;
	done	: Boolean;
begin
	
	agent := self.cmifCompanyCustDocAgent;
	
	agent.lineNumber := self.txtLineNumber.text.asIntegerJMT();
	
	agent.description := self.txtDescription.text;
	
	agent.startTS.setDate(self.mskFromStart.getDate());
	agent.startTS.setTime(self.mskFromStartTime.getTime());
	agent.startTS := self.localToSystemTime(agent.startTS);
	
	agent.docSequence := self.txtSequence.text.asIntegerJMT();
	
	if self.cmbCustDocType.listIndex &gt; 0 then
		agent.myCustomDocumentType := self.cmbCustDocType.listObject.CM_CustomDocumentType;
	endif;
	
	if self.cmbAgent.listIndex &gt; 0 then
		agent.myCustomDocAgent := self.cmbAgent.listObject.CM_CustomsAgent;
	endif;
	
	if self.cmbCustLicense.listIndex &gt; 0 then
		agent.myCustomLicense := self.cmbCustLicense.listObject.CM_CustomLicense;
	endif;
	
	if self.cmbHSCode.listIndex &gt; 0 then
		agent.myHSCode := self.cmbHSCode.listObject.CM_HarmonizedSystem;
	endif;
	
	if self.cmbDirection.listIndex &gt; 0 then
		agent.direction := self.cmbDirection.listData();
	endif;
	
	agent.remarks := self.txtRemarks.text;
	
	agent.externalRef := self.txtExtRef.text;
	
	done := agent.doGenerate();
	
	if done then
		self.unloadForm();
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowHSCodeSearcherForm" id="fbd37871-66dc-4646-97e1-793685310f72">
        <source>doShowHSCodeSearcherForm();
/*
Purpose:			

Date		Who		Reason
14AUG2023	NAVAB1	 CR 59614 TASK 59619
*/

vars
	hsCode : CM_HarmonizedSystem;
begin

	hsCode := self.myAssistant.showHSCodeSearchForm(self, true);

	if hsCode &lt;&gt; null then		
		if self.cmbHSCode.findObject(hsCode) &lt; 0 then
			self.cmbHSCode.addItemObject(hsCode.getDisplayString(), hsCode);
		endif;
		self.cmbHSCode.listObject := hsCode;		
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="initDetailsFromFirstTI" id="792c9a33-1ca7-4525-b91b-e3269d34b62d">
        <updating/>
        <source>initDetailsFromFirstTI() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/10/2023	navkc1	CR 60422 Task 60917: JADE - Group Selected TIs by Transport

*/

vars
	ti			: CM_TrackedItem;
	custDoc		: CM_CustomDocument;
	custDocType	: CM_CustomDocumentType;
begin
	ti := self.cmifCompanyCustDocAgent.allTIs.first();
	
	if ti = null then
		return;
	endif;
	
	custDoc := ti.getPreviousCustomDocument(null);
	
	if custDoc &lt;&gt; null then
		self.txtSequence.text := (custDoc.sequence + 1).String;
		custDocType := custDoc.myCustomDocumentType;
		if self.cmbHSCode.findObject(custDoc.myHSCode) &gt; 0 then
			self.cmbHSCode.listObject := custDoc.myHSCode;
		endif;
		self.buildCmbCustDocType(custDocType);
		if self.cmbCustDocType.listCount() = 0 then
			app.msgBox("There is no custom document type available for the selected cargo", app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
			self.unloadForm();
		endif;
	else
		app.msgBox("There is no custom documents for the selected cargo", app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		self.unloadForm();
	endif;


	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1bbee8e6-9fb6-419e-a2eb-0ad2a6665cba">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/10/2023	navkc1	CR 60422 Task 60917: JADE - Group Selected TIs by Transport

*/

vars
	now : TimeStamp;
begin
	inheritMethod();
	self.handleMenusForModalDisplay();
	self.mskFromStart.setDate(now.date);
	self.mskFromStartTime.setTime(now.time);
	self.buildCmbCustomAgent();
	self.buildCmbHSCode();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="208a2938-537e-45f7-969b-e4babf4edb1c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 25 October 2023 11:43:50.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026526, locale);
	btnCancel.translateCaption(Xlat_0026527, locale);
	btnHSCode.translateCaption(Xlat_0026528, locale);
	btnOK.translateCaption(Xlat_0026529, locale);
	lblAgent.translateCaption(Xlat_0026530, locale);
	lblCode.translateCaption(Xlat_0026531, locale);
	lblCustDocLicense.translateCaption(Xlat_0026532, locale);
	lblCustDocType.translateCaption(Xlat_0026533, locale);
	lblDescription.translateCaption(Xlat_0026534, locale);
	lblDirection.translateCaption(Xlat_0026535, locale);
	lblDocSeq.translateCaption(Xlat_0026536, locale);
	lblEffectiveDate.translateCaption(Xlat_0026537, locale);
	lblExternalRef.translateCaption(Xlat_0026538, locale);
	lblHsCode.translateCaption(Xlat_0026539, locale);
	lblLineNumber.translateCaption(Xlat_0026540, locale);
	lblRemarks.translateCaption(Xlat_0026541, locale);
end;</source>
    </JadeMethod>
</GUIClass>
