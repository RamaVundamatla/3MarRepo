    <JadeMethod name="setShiftDay" id="9b2ddb11-ffaa-480c-91e2-8280dc95a72d">
        <updating/>
        <source>setShiftDay(pShift : CM_Shift io) updating;
// ---------------------------------------------------------------------------
// Created:     01 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//15/04/20116 cnwns1 TFS 488 Multi Timezone
// ---------------------------------------------------------------------------

vars
	shiftDay 	: Integer;
	shiftCode	: String;
	desc		: String;
	startTS ,endTS : TimeStamp;
begin
	if self.mode = self.MODE_EDIT and not pShift.pxyIsProxy() then
		return;
	endif;
	
	if self.mode = self.MODE_DELETE then
		return;
	endif;
	
	shiftCode 	:= self.txtCodeDay.text;
	desc 		:= self.txtDescDay.text;
	
	pShift.setProxy(shiftDay, null, null, shiftCode, desc, self.myTerminal, false);
	startTS.setDate(self.mskDateStart.getDate());
	startTS.setTime(self.timeStartTimeDay.getTime());
	//pShift.startDateTime.setDate(self.mskDateStart.getDate());
	//pShift.startDateTime.setTime(self.timeStartTimeDay.getTime());
	pShift.startDateTime := self.localToSystemTime( startTS);
	endTS.setDate(self.mskDateEnd.getDate());
	endTS.setTime(self.timeEndTimeDay.getTime());
	//pShift.endDateTime.setDate(self.mskDateEnd.getDate());
	//pShift.endDateTime.setTime(self.timeEndTimeDay.getTime());
	pShift.endDateTime := self.localToSystemTime( endTS);
	
end;
</source>
        <Parameter name="pShift" type="CM_Shift" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setShiftStd" id="1477c6d2-5a97-4fe9-bf0a-2541531c530f">
        <updating/>
        <source>setShiftStd(pShiftStd : CM_ShiftStd io) updating;
// ---------------------------------------------------------------------------
// Created:     01 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	shiftDay 	: Integer;
	startTime 	: Time;
	endTime		: Time;
	shiftCode	: String;
	desc		: String;
begin
	shiftDay 	:= self.cmbShiftType.listIndex;
	startTime 	:= self.timeStartTime.getTime();
	endTime 	:= self.timeEndTime.getTime();
	shiftCode 	:= self.txtCode.text;
	desc 		:= self.txtDesc.text;
	
	pShiftStd.setProxy(shiftDay, startTime, endTime, shiftCode, desc, self.myTerminal, false);
end;
</source>
        <Parameter name="pShiftStd" type="CM_ShiftStd" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="41a04ee4-03be-4dd9-ab86-4c18750331ad">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		April  2007 By Andrew Yi Liu (cnwyl1)
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
//15 9 16 TFS 2679:Multi-timezone issues cnwns1 
// ---------------------------------------------------------------------------

vars
	now : TimeStamp;
begin
	inheritMethod();
	
	now := self.systemToLocalTime(app.actualTimeServer);	//2679:Multi-timezone issues
	
	self.beginClassNotification(CM_ShiftEntity, false, self.myTerminal.getTerminalEvent(Event_Shift_Add), Response_Continuous, null);
	self.beginClassNotification(CM_ShiftEntity, false, self.myTerminal.getTerminalEvent(Event_Shift_Update), Response_Continuous, null);
	self.beginClassNotification(CM_ShiftEntity, false, self.myTerminal.getTerminalEvent(Event_Shift_Delete), Response_Continuous, null);
	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.frmToolbar.priorityRight := true;
	self.optStandard.value := true;
	self.setOptionFrame();
	self.frmAddDialog.visible := false;
	self.myTerminal := app.myPassport.myTerminal;
	self.initForm();
	self.getXMLSettingsForSetup();
	self.dmByDate.setDate(now.date());	//2679:Multi-timezone issues
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnNext.enabled:= false;
		self.btnAdd.enabled:= false;
		self.btnEdit.enabled:= false;
		self.btnDelete.enabled:= false;
		self.mnuAddShift.enabled:= false;
		self.mnuCopyShift.enabled:= false;
		self.mnuDelShift.enabled:= false;
		self.mnuEditShift.enabled:= false;

	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="showContextMenu" id="9a525c51-1f3c-47a6-9ae8-7dbac5e95775">
        <updating/>
        <source>showContextMenu(pMenuItem: MenuItem; cntrl: Control input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;

vars

begin
	return inheritMethod(pMenuItem, cntrl, conwin, mouse, x, y);
end;
</source>
        <Parameter name="pMenuItem" type="MenuItem"/>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblShift_contextMenu" id="e6098dfd-3c24-44b2-85c6-932942e62e23">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblShift_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

vars

begin
	self.mnuInspect.visible := app.isAllowedToInspect();
	
	if self.myCurrentShift &lt;&gt; null then
		self.mnuInspect.userObject := self.myCurrentShift;
		if self.mnuInspect.userObject.isTransient() then
			self.mnuInspect.caption := "Inspect Transient Object...";
		else
			self.mnuInspect.caption := "Inspect Persistent Object...";
		endif;
		
		return self.showContextMenu(mnuWSM, table, conwin, mouse, x, y);
	endif;
	
	
end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
