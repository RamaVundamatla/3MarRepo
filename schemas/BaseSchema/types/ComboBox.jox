<GUIClass name="ComboBox">
    <JadeMethod name="cnEcAddItemDataObject" id="e3171b7e-56aa-4616-bc6c-dbe1c9b2ccc7">
        <source>cnEcAddItemDataObject(pNewItem:String; pItemData:Integer; pItemObject:Object):Integer;
// --------------------------------------------------------------------------------
// Created:		12 February 2007 by cnwdad1
//
// Purpose:		Adds a new item to the receiver, and optionally sets an ItemData
//				value, and an ItemObject reference.
//
// Parameters:	pNewItem - The display text of the new item.
//				pItemData - An optional ItemData value.
//				pItemObject - An optional ItemObject reference.
//
// Returns:		The index at which the new item was added.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	
begin
	rowPointer	:=	self.addItem(pNewItem);
	
	if pItemData &lt;&gt; 0 then
		self.itemData[rowPointer]	:=	pItemData;
	endif;
	
	if pItemObject &lt;&gt; null then
		self.itemObject[rowPointer]	:=	pItemObject;
	endif;
	
	return rowPointer;
end;</source>
        <Parameter name="pNewItem" type="String"/>
        <Parameter name="pItemData" type="Integer"/>
        <Parameter name="pItemObject" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcAddItemDataObjectAt" id="84c61026-2962-4fa4-a503-a37e8b781157">
        <source>cnEcAddItemDataObjectAt(pIndex:Integer; pNewItem:String; pItemData:Integer; pItemObject:Object):Boolean;
// --------------------------------------------------------------------------------
// Created:		12 February 2007 by cnwdad1
//
// Purpose:		Adds a new item to the receiver, and optionally sets an ItemData
//				value, and an ItemObject reference.
//
// Parameters:	pIndex - The index at which to add the new item.
//				pNewItem - The display text of the new item.
//				pItemData - An optional ItemData value.
//				pItemObject - An optional ItemObject reference.
//
// Returns:		True if the item was successfully added, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	entryCount	: Integer;
	
begin
	entryCount	:=	self.listCount;
	
	if pIndex &gt; (entryCount + 1) then
		return false;
	endif;
	
	self.addItemAt(pNewItem, pIndex);
	
	if pItemData &lt;&gt; 0 then
		self.itemData[pIndex]	:=	pItemData;
	endif;
	
	if pItemObject &lt;&gt; null then
		self.itemObject[pIndex]	:=	pItemObject;
	endif;
	
	return true;
end;</source>
        <Parameter name="pIndex" type="Integer"/>
        <Parameter name="pNewItem" type="String"/>
        <Parameter name="pItemData" type="Integer"/>
        <Parameter name="pItemObject" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcFindItemData" id="8e7f3ca6-94e0-4cd7-89b6-76b07f9f6b8b">
        <source>cnEcFindItemData(pItemData:Integer; pStartIndex:Integer):Integer;
// --------------------------------------------------------------------------------
// Created:		12 August 2005 by cnwdad1
//
// Purpose:		Scans the receiver for the first entry who's itemData matches the
//				specified pItemData value.
//
// Parameters:	pItemData - The itemData value to match.
//				pStartIndex - The list index at which to begin the scan.
//
// Returns:		The index of the matching list item, or CNEC_NULL_INDEX if none of
//				the item data values matched the parameter value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listPointer	: Integer;
	itemCount	: Integer;
	startIndex	: Integer;
	
begin
	itemCount	:=	self.listCount();
	
	if pStartIndex &gt; 0 then
		startIndex	:=	pStartIndex;
	else
		startIndex	:=	1;
	endif;
	
	foreach listPointer in startIndex to itemCount do
		if self.itemData[listPointer] = pItemData then
			return listPointer;
		endif;
	endforeach;
	
	return CNEC_NULL_INDEX;
end;</source>
        <Parameter name="pItemData" type="Integer"/>
        <Parameter name="pStartIndex" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetChildNodes" id="872819a0-6049-494e-b79c-025dbf6a0922">
        <source>cnEcGetChildNodes(pParentIndex:Integer; pAllChildNodes:CnEcTreeNodeArray input):Boolean;
// --------------------------------------------------------------------------------
// Created:		11 November 2005 by cnwdad1
//
// Purpose:		Populates the array parameter with object representing each of the
//				parent's child nodes.
//
// Parameters:	pParentIndex - The index of the list item who's child nodes to get.
//				pAllChildNodes - A reference to an array of child nodes.
//
// Returns:		True if the child nodes were successfully fetched, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	lastIndex		: Integer;
	startIndex		: Integer;
	listPointer		: Integer;
	currentLevel	: Integer;
	parentLevel		: Integer;
	childLevel		: Integer;
	childNodeObj	: CnEcTreeNode;
		
begin
	lastIndex	:=	self.listCount();
	
	if pParentIndex &lt; 1 or pParentIndex &gt;= lastIndex then
		return false;
	endif;
	
	if not self.itemHasSubItems(pParentIndex) then
		return false;
	endif;
	
	startIndex	:=	pParentIndex + 1;
	parentLevel	:=	self.itemLevel[pParentIndex];
	childLevel	:=	self.itemLevel[startIndex];
	
	foreach listPointer in startIndex to lastIndex do
		currentLevel	:=	self.itemLevel[listPointer];
		
		if currentLevel &lt;= parentLevel then
			break;
		endif;
		
		if currentLevel = childLevel then
			create childNodeObj transient;
			
			childNodeObj.updateMe(	self.itemText[listPointer],
									listPointer,
									self.itemLevel[listPointer],
									self.itemForeColor[listPointer],
									self.itemBackColor[listPointer],
									self.itemData[listPointer],
									self.itemPicture[listPointer],
									self.itemObject[listPointer]);
			
			pAllChildNodes.add(childNodeObj);
			
			if self.itemHasSubItems(listPointer) then
				if not childNodeObj.getChildNodesCombo(self) then
					return false;
				endif;
			endif;
		endif;
	endforeach;
	
	return true;
end;</source>
        <Parameter name="pParentIndex" type="Integer"/>
        <Parameter name="pAllChildNodes" type="CnEcTreeNodeArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetCurrentItemData" id="edccc904-8d7b-43ae-9cd2-b50754fc9dd8">
        <source>cnEcGetCurrentItemData():Integer;
// --------------------------------------------------------------------------------
// Created:		15 March 2005 by cnwdad1
//
// Purpose:		Returns the item data for the currently selected list item.
//
// Parameters:	None
//
// Returns:		The item data value of the currently selected list item.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listPointer	: Integer;
	
begin
	listPointer	:=	self.listIndex;
	
	if listPointer &lt;= 0 then
		return 0;
	endif;
	
	return self.itemData[listPointer];
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetItemData" id="61befb79-16cb-489b-bd88-91a906aa05b7">
        <source>cnEcGetItemData(pListIndex:Integer):Integer;
// --------------------------------------------------------------------------------
// Created:		15 March 2005 by cnwdad1
//
// Purpose:		Returns the item data for the specified index.
//
// Parameters:	pListIndex - The index of the item data to return.
//
// Returns:		The requested item data value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pListIndex &lt;= 0 or pListIndex &gt; self.listCount then
		return 0;
	else
		return self.itemData[pListIndex];
	endif;
end;</source>
        <Parameter name="pListIndex" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetNodeWithChildren" id="4080eeaf-f759-4534-9c17-b69e9d64c89f">
        <source>cnEcGetNodeWithChildren(pParentIndex:Integer; pParentNodeObj:CnEcTreeNode output):Boolean;
// --------------------------------------------------------------------------------
// Created:		11 November 2005 by cnwdad1
//
// Purpose:		Returns a reference to a tree node object for the specified parent
//				list item index.  The tree object will include all of its child node
//				objects.
//
// Parameters:	pParentIndex - The index of the list item who's child nodes to get.
//				pParentNodeObj - A reference to the parent node tree object.
//
// Returns:		True if the child nodes were successfully fetched, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	parentNodeObj	: CnEcTreeNode;
		
begin
	if pParentIndex &lt; 1 or pParentIndex &gt; self.listCount() then
		return false;
	endif;
	
	create parentNodeObj transient;
	
	parentNodeObj.updateMe(	self.itemText[pParentIndex],
							pParentIndex,
							self.itemLevel[pParentIndex],
							self.itemForeColor[pParentIndex],
							self.itemBackColor[pParentIndex],
							self.itemData[pParentIndex],
							self.itemPicture[pParentIndex],
							self.itemObject[pParentIndex]);
	
	parentNodeObj.getChildNodesCombo(self);
	pParentNodeObj	:=	parentNodeObj;
	
	return true;
end;</source>
        <Parameter name="pParentIndex" type="Integer"/>
        <Parameter name="pParentNodeObj" type="CnEcTreeNode" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcMoveAll" id="0a2f4746-d93e-40d4-8ad7-4d1e7a0d3a09">
        <updating/>
        <source>cnEcMoveAll(pTargetComboObj:ComboBox input) updating;
// --------------------------------------------------------------------------------
// Created:		26 July 2000 by cnwdad1
//
// Purpose:		Moves all items from the receiver combobox into the combobox
//				specified as the input parameter.
//
// Parameters:	pTargetComboObj - The control to which the items will be moved.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	entryCount		: Integer;
	listPointer		: Integer;
	allChildNodes	: CnEcTreeNodeArray;
	childNodeObj	: CnEcTreeNode;
	
begin
	entryCount	:=	self.listCount();
	
	if listCount = 0 then
		return;
	endif;
	
	if self.hasPlusMinus or self.hasTreeLines then
		create allChildNodes transient;
		listPointer	:=	1;
		
		while listPointer &lt;= entryCount do
			pTargetComboObj.addItem(itemText[listPointer]);
			pTargetComboObj.itemObject[pTargetComboObj.newIndex]	:=	self.itemObject[listPointer];
			
			if self.itemHasSubItems(listPointer) then
				self.cnEcGetChildNodes(listPointer, allChildNodes);
				
				foreach childNodeObj in allChildNodes do
					listPointer	:=	childNodeObj.addToCombo(pTargetComboObj.listCount() + 1,
															pTargetComboObj);
				endforeach;
				
				allChildNodes.purge();
			endif;
			
			listPointer	:=	listPointer + 1;
		endwhile;
	else
		foreach listPointer in 1 to entryCount do
			pTargetComboObj.addItem(itemText[listPointer]);
			pTargetComboObj.itemObject[pTargetComboObj.newIndex]	:=	self.itemObject[listPointer];
		endforeach;
	endif;
	
	self.clear();
epilog
	delete allChildNodes;
end;</source>
        <Parameter name="pTargetComboObj" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cnEcMoveSelected" id="61cb3a1e-23bd-41dd-bcb5-f9b93b3bb3c9">
        <updating/>
        <source>cnEcMoveSelected(pTargetComboObj:ComboBox input) updating;
// --------------------------------------------------------------------------------
// Created:		26 July 2000 by cnwdad1
//
// Purpose:		Moves all selected items from the current combobox into the combobox
//				specified as the input parameter.
//
// Parameters:	pTargetComboObj - The control to which the selected items will be moved.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listPointer		: Integer;
	parentNodeObj	: CnEcTreeNode;

begin
	if self.hasPlusMinus or self.hasTreeLines then
		listPointer	:=	self.listIndex;
		
		if listPointer = CNEC_NULL_INDEX then
			return;
		endif;
		
		if not self.cnEcGetNodeWithChildren(listPointer, parentNodeObj) then
			return;
		endif;
		
		if parentNodeObj.itemLevel &gt; 1 then
			parentNodeObj.adjustItemLevel((parentNodeObj.itemLevel * -1) + 1);
		endif;
		
		parentNodeObj.addToCombo((pTargetComboObj.listCount() + 1), pTargetComboObj);
		self.cnEcRemoveSubItems(listPointer, false);
		self.removeItem(listPointer);
	else
		listPointer	:=	self.listIndex;
		
		if listPointer = CNEC_NULL_INDEX then
			return;
		endif;
		
		pTargetComboObj.itemObject[pTargetComboObj.addItem(itemText[listPointer])]	:=	itemObject[listPointer];
		removeItem(listPointer);
	endif;
epilog
	delete parentNodeObj;
end;</source>
        <Parameter name="pTargetComboObj" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cnEcMoveSelectedToSelected" id="8f387242-2fd3-4692-9008-137eddc8986f">
        <updating/>
        <source>cnEcMoveSelectedToSelected(pTargetComboObj:ComboBox input):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		16 November 2004 by cnwdad1
//
// Purpose:		Moves all selected items from the current combobox to the currently
//				selected index in the specified combobox parameter.
//
//				Note: The target combobox control must be configured for an hierarcical
//				style list.
//
// Parameters:	pTargetComboObj - The control to which the selected items will be moved.
//
// Returns:		True if the move was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listPointer		: Integer;
	parentNodeObj	: CnEcTreeNode;
	targetIndex		: Integer;
	targetLevel		: Integer;

begin
	targetIndex	:=	pTargetComboObj.listIndex;
	
	if targetIndex = CNEC_NULL_INDEX then
		return false;
	endif;
	
	if self.hasPlusMinus or self.hasTreeLines then
		listPointer	:=	self.listIndex;
		targetLevel	:=	pTargetComboObj.itemLevel[targetIndex];
		
		if not self.cnEcGetNodeWithChildren(listPointer, parentNodeObj) then
			return false;
		endif;
		
		parentNodeObj.adjustItemLevel(targetLevel - parentNodeObj.itemLevel + 1);
		parentNodeObj.addToCombo((pTargetComboObj.listIndex + 1), pTargetComboObj);
		self.cnEcRemoveSubItems(listPointer, false);
		self.removeItem(listPointer);
		
		delete parentNodeObj;
	else
		return false;
	endif;
	
	return true;
epilog
	delete parentNodeObj;
end;</source>
        <Parameter name="pTargetComboObj" type="ComboBox" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcRemoveObject" id="7667d421-1f99-45c9-a9f2-ec161ecd5aec">
        <source>cnEcRemoveObject(pObject:Object):Boolean;
// --------------------------------------------------------------------------------
// Created:		05 April 2005 by cnwdad1
//
// Purpose:		Removes the item entry for the specified object.
//
// Parameters:	pObject - A reference to the object who's entry to remove.
//
// Returns:		True if the remove was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	
begin
	rowPointer	:=	self.findObject(pObject);
	
	if rowPointer &lt;&gt; CNEC_NULL_INDEX then
		self.removeItem(rowPointer);
		return true;
	else
		return false;
	endif;
end;</source>
        <Parameter name="pObject" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcRemoveSelected" id="673ebe12-0951-4dd2-ae88-d1e02d2e93b8">
        <source>cnEcRemoveSelected():Boolean;
// --------------------------------------------------------------------------------
// Created:		05 April 2005 by cnwdad1
//
// Purpose:		Removes the currently selected item entry from the receiver.
//
// Parameters:	None
//
// Returns:		True if the remove was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	
begin
	rowPointer	:=	self.listIndex;
	
	if rowPointer = CNEC_NULL_INDEX then
		return false;
	endif;
	
	self.removeItem(rowPointer);
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcRemoveSubItems" id="c81c598a-ce76-418b-8091-ce6c2fada35f">
        <source>cnEcRemoveSubItems(pParentIndex:Integer; pIsDeleteItemObjects:Boolean);
// --------------------------------------------------------------------------------
// Created:		19 August 2000 by cnwdad1
//
// Purpose:		Removes all subitems from a tree hierarchy in the listbox.
//
// Parameters:	pParentIndex (Integer) - The index of the parent item whose subitems
//					are to be removed.
//				pIsDeleteItemObjects (Boolean) - A flag used to indicate whether
//					any objects of the "itemObject" property of child list entries
//					are to be deleted when the child item entry is removed.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	parentIndex	: Integer;
	parentLevel	: Integer;
	entryCount	: Integer;
	childLevel	: Integer;
	childIndex	: Integer;
	theObject	: Object;
	
begin
	parentIndex	:=	pParentIndex;
	entryCount	:=	self.listCount;
	parentLevel	:=	self.itemLevel[parentIndex];
	
	if parentIndex &lt; entryCount then	// If parent is last, it mustn't have any children.
		childIndex	:=	parentIndex + 1;
		
		// Must use "listCount" here because the size of the list
		// items will be changing as list entries are removed.
		
		while childIndex &lt;= self.listCount do
			childLevel	:=	self.itemLevel[childIndex];
			
			if childLevel &lt;= parentLevel then
				break;
			endif;
			
			if pIsDeleteItemObjects then
				theObject	:=	self.itemObject[childIndex];
				
				if theObject &lt;&gt; null then
					delete theObject;
				endif;
			endif;
			
			self.removeItem(childIndex);
		endwhile;
	endif;
end;</source>
        <Parameter name="pParentIndex" type="Integer"/>
        <Parameter name="pIsDeleteItemObjects" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcSet" id="8c318b98-5526-4adf-b22c-81cfd3561941">
        <updating/>
        <source>cnEcSet(pValue:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		13 August 2002 by cnwdad1
//
// Purpose:		Updates the receiver's listIndex with the specified value.
//
// Parameters:	pValue - The string value to set the text to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.listIndex &lt;&gt; pValue then
		self.listIndex	:=	pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetItemData" id="aa5d15a2-4577-4f37-ba40-3505eb1c84c9">
        <updating/>
        <source>cnEcSetItemData(pItemData:Integer):Integer updating;
// --------------------------------------------------------------------------------
// Created:		22 March 2005 by cnwdad1
//
// Purpose:		Sets the receiver's listIndex for the first entry which matches the
//				specified itemData value.
//
// Parameters:	pItemData - The itemData value to match.
//
// Returns:		The index of the new list item, or CNEC_NULL_INDEX if none of the
//				item datas matched the parameter value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listPointer	: Integer;
	itemCount	: Integer;
	
begin
	itemCount	:=	self.listCount();
	
	foreach listPointer in 1 to itemCount do
		if self.itemData[listPointer] = pItemData then
			self.listIndex	:=	listPointer;
			return listPointer;
		endif;
	endforeach;
	
	return CNEC_NULL_INDEX;
end;</source>
        <Parameter name="pItemData" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetObjectIndex" id="218d7160-802c-4885-8492-b47c9f5f9d76">
        <updating/>
        <source>cnEcSetObjectIndex(pTheObject:Object) updating;
// --------------------------------------------------------------------------------
// Created:		25 January 2001 by cnwdad2
//
// Purpose:		Sets the list index of the receiver to the index that contains the
//				specified object.
//
// Parameters:	pTheObject - The object who's index to scan for.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.listIndex	:=	self.findObject(pTheObject);
end;</source>
        <Parameter name="pTheObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetTextIndex" id="350fbc5d-e4ec-4c6d-93e9-73952eb6d5ab">
        <updating/>
        <source>cnEcSetTextIndex(pTextValue:String) updating;
// --------------------------------------------------------------------------------
// Created:		25 January 2001 by cnwdad2
//
// Purpose:		Sets the list index of the receiver to the index that contains the
//				specified text.
//
// Parameters:	pTextValue - The text to scan for.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.listIndex	:=	self.findStringExact(1, pTextValue);
end;</source>
        <Parameter name="pTextValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcSortBranch" id="3b2318c9-063e-482f-8985-d5ac5b545161">
        <updating/>
        <source>cnEcSortBranch(pParentIndex:Integer; pIsDescending:Boolean):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		26 October 2005 by cnwdad1
//
// Purpose:		Alphabetically sorts the child nodes of the specified parent node.
//
// Parameters:	pParentIndex - The index of the parent node.
//				pIsDescending - If true, the items will be sorted in descending order.
//
// Returns:		True if the sort succeeded, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	sorterObj			: CnEcSorter;
	keyObj				: Object;
	listPointer			: Integer;
	isExpanded			: Boolean;
	associatedObj		: Object;
	keyValue			: String;
	allChildNodes		: CnEcTreeNodeArray;
	childNodeObj		: CnEcTreeNode;
		
begin
	// Do preliminary checks.
	
	if pParentIndex &lt; 1 or pParentIndex &gt;= self.listCount() then
		return false;
	endif;
	
	if not self.itemHasSubItems(pParentIndex) then
		return false;
	endif;
	
	// Fetch the child list item nodes to be sorted.
	
	isExpanded	:=	self.itemExpanded[pParentIndex];
	
	create allChildNodes transient;
	
	if not self.cnEcGetChildNodes(pParentIndex, allChildNodes) then
		return false;
	endif;
	
	// Sort the list items.
	
	create sorterObj transient;
	sorterObj.setSortType(CnEcSorter.AS_STRING, pIsDescending);
	
	// Load the entries to sort, removing the list items as we go.
	// We do this in reverse order to preserve list indexes as we
	// remove each child node.
	
	foreach childNodeObj in allChildNodes reversed do
		sorterObj.addKeyWithObject(childNodeObj.itemText, childNodeObj);
		
		if childNodeObj.hasChildNodes() then
			self.cnEcRemoveSubItems(childNodeObj.listIndex, false);
		endif;
		
		self.removeItem(childNodeObj.listIndex);
	endforeach;
	
	// Now reload the entries in sorted order.
	
	listPointer	:=	pParentIndex + 1;
	
	foreach keyObj in sorterObj.allKeys reversed do
		keyValue		:=	keyObj.CnEcSortKey.getKeyWithObject(associatedObj).String;
		childNodeObj	:=	associatedObj.CnEcTreeNode;
		
		if childNodeObj.addToCombo(listPointer, self) = 0 then
				return false;
		endif;
	endforeach;
	
	if isExpanded then
		self.itemExpanded[pParentIndex]	:=	true;
	endif;
	
	return true;
epilog
	delete sorterObj;
	delete allChildNodes;
end;</source>
        <Parameter name="pParentIndex" type="Integer"/>
        <Parameter name="pIsDescending" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
