    <JadeMethod name="doSave" id="43dce468-b4cd-4cfa-912b-d5ec1ca97abe">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

	proxy : CM_RoadProcess;
	lCode : String;
	lDescription : String;
	theForm : SOP_TableMaintForm;
	
begin

	theForm := self.myForm; 
	lCode := theForm.tblInput1.getValueByName(ETRow_Code).String;
	lDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;

	if theForm.myProxyObject = null then	
		app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
		return false;
	endif;

	proxy := theForm.myProxyObject.CM_RoadProcess;
	proxy.setCode( lCode );
	proxy.setDescription( lDescription );

	app.myTrxUA.trxUpdateRoadProcess( proxy, app.myPassport );

	return app.myPassport.trxCompletedOK;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
