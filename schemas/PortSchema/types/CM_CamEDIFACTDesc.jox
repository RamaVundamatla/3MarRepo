    <JadeMethod name="makePIASegment" id="69ba4883-a14d-41b7-bedf-0e18bd373171">
        <source>makePIASegment(_protocol :CM_CamProtocol; _group :HugeStringArray input; _function :Integer; _itemNumber, _itemType:String):String protected;
/*
Purpose:	Make a PIA segment

Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
constants
	MESSAGE	= "PIA";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; plus &amp; 
			_function.String &amp; plus &amp;
			_itemNumber &amp; colon &amp; _itemType;
			
	msg := msg &amp; singleQuote;
			
	if _group &lt;&gt; null then
		_group.add (msg);
	endif;
	
	return msg;
epilog

end;</source>
