    <JadeMethod name="trxUpdateBOLandTIs" id="ae3a2f2e-9448-46ac-acec-793beff2a941">
        <updating/>
        <source>trxUpdateBOLandTIs(pIntFaceObj : CMIF_BOLIn input; pProxyBOL:CM_BOL input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     11 April 2006 by cnwrs2
//
// Purpose:     Updates a BOL and its associated TIs
//				The TI details are passed in on the pIntFaceObj.allSubItems collection
// ---------------------------------------------------------------------------
vars
	realDocket	: CM_BOL;
	item		: CMIF_TIObject;
	ti			: CM_TrackedItem;
	proxyBOL	: CM_Object;
	auditAgent: CM_UpdateTransactionAuditAgent;	
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;

	pProxyBOL.raiseExceptionIfNotProxy(method);
	app.setContinueCMExceptions(true);

	pIntFaceObj.validateForUpdate(_passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	auditAgent :=  app.myUtilityUA.myUpdateAuditAgent;
// need to determine rules here for updating TI's
// as could have split so cannot just delete and 
	if _passport.noErrors then
		pIntFaceObj.actionForUpdateGeneralDocket(proxyBOL, pIntFaceObj, auditAgent, _passport);
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
