/*

Purpose:			


Return Value:		


Date		Who		Reason
23 Aug 2006	cnwer1	Initial creation - PAR#xxxx
16 Oct 2009	cnwdap1	PAR #21320 Allow change of State with Reg Number
26 Feb 2010	consw1	PAR #21320 - Revise behaviour of Edit Registration for Vehicle Visit
*/
vars
	newVehicle,
	pxyVehicle	: CM_Vehicle;
	terminal	: CM_Terminal;
	tmpVVREC	: CM_VehicleVisitRecord;
	
begin
	self.initialiseActivity();
	self.raiseExceptionIfNull(_vehicle, 'Vehicle');
	
	if _vehicle.regNumber = _regNumber and
	   _vehicle.state = _state then
		return;
	endif;

	terminal	:= _vehicle.myTerminal;
	newVehicle 	:= terminal.vehicles[_regNumber, _state];

	if newVehicle = null then
		// Create new vehicle
		create pxyVehicle transient;
		pxyVehicle.setProxy(_regNumber, null, null, null, _vehicle.carrier, _state, false, terminal);
		app.myUtilityCA.utlCreateVehicle(pxyVehicle, newVehicle, _passport);
	else
		// Rego is for an existing vehicle
		if newVehicle.isOnsite then
			app.raiseCMException2(VehicleIsOnSite, newVehicle.regNumber, newVehicle.getMyPrimaryActualLocation().getNiceName(), null, null);
			return;
		endif;
		tmpVVREC := newVehicle.visitRecords.last;
		if tmpVVREC &lt;&gt; null then
			if tmpVVREC.status &lt;&gt; CM_VehicleVisitRecord.Status_Complete and
			   tmpVVREC.status &lt;&gt; CM_VehicleVisitRecord.Status_Cancelled then
				app.raiseCMException2(ERR_VehicleHasJob, newVehicle.getDisplayDetails(true), tmpVVREC.visitNumber, null, null);
			endif;
		endif;
	endif;
	
	if _passport.hasErrors() then
		return;
	endif;

	_vehicle.changeVehicleForVisit(newVehicle, _passport);
	
epilog
	delete pxyVehicle;
end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle" usage="input"/>
        <Parameter name="_regNumber" type="String"/>
        <Parameter name="_state" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVehicleType" id="fed224c5-cdfc-41fb-827c-1ea57808bee2">
        <source>utlUpdateVehicleType(_proxyVehicleType : CM_VehicleType input; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars
	cancelSave 			: Boolean;
	realVehicleType		: CM_VehicleType;
	expectedEdition 	: Integer;
	
begin
	self.initialiseActivity();

	_proxyVehicleType.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyVehicleType.pxyGetRealObjectAndEdition(realVehicleType, expectedEdition);
	
	if realVehicleType = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_VehicleType.name, null, null);
		return;
	endif;

	app.myValUA.valVehicleType(_proxyVehicleType, realVehicleType);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realVehicleType);

	if _passport.noErrors and realVehicleType.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(Vehicle_type), null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realVehicleType, true);
	endif;
	
	if _passport.noErrors then
		realVehicleType.setForUpdate(_proxyVehicleType);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realVehicleType, false);
	endif;

epilog
	
	
end;</source>
        <Parameter name="_proxyVehicleType" type="CM_VehicleType" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVehicleVisitFlexi" id="69e9acff-87ab-4bc1-94b4-6400b39f702f">
        <updating/>
        <source>utlUpdateVehicleVisitFlexi(_pxyVVR : CM_VehicleVisitRecord; _moveToGateIn : Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     September 2008 ANDREW BISHOP
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25/02/2014	cnwdap1		PAR #33582 For VVRs from security gate without a registration number,
//							we have a dummy vehicle and a dummy carrier. If the proxy has no
//							vehicle, this has to trigger an error. If the proxy has a vehicle,
// 							we need to delete the dummy vehicle and use the real instead
// 28/06/2023	navcs2	ChangeRequest 58433: [58454]: EUP | TAS Invoicing - Invoice Posting Confirmation Message
// 14/02/2024	navcs2	Bug 62454: FR | 53667 - Inspection App - Resend Message discrepancy (Changed Signature)
//19 May 2025	jlier1	MTN-34221 refactoring validation so is before trx 
// ---------------------------------------------------------------------------

vars
	realVVR			: CM_VehicleVisitRecord;
	gate			: CM_Gate;
	vehicle			: CM_Vehicle;
	vehicleChanged	: Boolean;
	oldVehicleLoc	: CM_YardController;
	origVehicle		: CM_Vehicle;							// PAR #33582
	newVehicle		: CM_Vehicle;							// PAR #33582
	origLocation	: CM_YardController;					// PAR #33582
	sendBarrierCode,
	createBarrierCode : Boolean;
	pxyRequest			: BGP_APIWSRequest;
	bgpRequest 			: BGP_ExternalWSRequest;
begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_pxyVVR, 'Vehicle Visit Record');

	
	realVVR := self.getRealObjectAndEditionCheck(_pxyVVR, 'Vehicle Visit Record', _passport).CM_VehicleVisitRecord;

	if _passport.noErrorsIgnored() then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realVVR, true);
	endif;

	origVehicle := realVVR.vehicle;														// PAR #33852
	if origVehicle &lt;&gt; null then															// PAR #33852
		origLocation := origVehicle.myPrimaryActualLocation;							// PAR #33852
	endif;																				// PAR #33852
	
	// cnwjk3 12/10/09 PAR 20915
	if _passport.noErrorsIgnored then
		if realVVR.regNumber &lt;&gt; _pxyVVR.regNumber or  realVVR.state &lt;&gt; _pxyVVR.state then
			// The vehicle details have changed
			vehicleChanged := true;
			if realVVR.vehicle &lt;&gt; null then
				oldVehicleLoc := realVVR.vehicle.myPrimaryActualLocation;
			endif;
			// Move the old vehicle offsite
			vehicle := realVVR.myTerminal.vehicles[realVVR.regNumber, realVVR.state];
			if vehicle &lt;&gt; null then
				vehicle.setMyPrimaryActualLocation(null,true);
			endif;		
		endif;
	endif;
	
	
	if _passport.noErrorsIgnored then
	
		sendBarrierCode:= realVVR.myBarrierCodeIn &lt;&gt; null and realVVR.gateInCheckStatus &lt;&gt; _pxyVVR.gateInCheckStatus and _pxyVVR.gateInCheckStatus = CM_VehicleVisitRecord.InspectionCompleted; // TFS 57936 15/5/23 changed to gate check completed and there is a barrier code then send it
		createBarrierCode:=realVVR.myBarrierCodeIn = null and (realVVR.gateInCheckStatus = CM_VehicleVisitRecord.InspectionPending or realVVR.gateInCheckStatus = CM_VehicleVisitRecord.InspectionNA); 
		// do updates
		realVVR.setForUpdateFlexi(_pxyVVR);
		
		realVVR.updateJobQueueOrder(null,null);
		// PAR #33582 If original vehicle was an unknown vehicle, we need to create 				// PAR #33582	
		// a new vehicle with the proxy vehicle and carrier details									// PAR #33582
		// but don't bother if we're cancelling the vehicle visit									// PAR #33582
		if realVVR.status &lt;&gt; realVVR.Status_Cancelled then											// PAR #33582
			if origVehicle &lt;&gt; null and origVehicle.isUnknownVehicle then							// PAR #33582
				newVehicle := _pxyVVR.vehicle;														// PAR #33582
				if newVehicle = null then															// PAR #33582
					newVehicle := _pxyVVR.myTerminal.vehicles[_pxyVVR.regNumber, _pxyVVR.state];	// PAR #33582
				endif;																				// PAR #33582
				if newVehicle = null then															// PAR #33582
					realVVR.createVehicle(_passport);												// PAR #33582
				endif;																				// PAR #33582
				if realVVR.vehicle &lt;&gt; null and realVVR.vehicle &lt;&gt; origVehicle then					// PAR #33582
					oldVehicleLoc := origLocation;													// PAR #33582
					if oldVehicleLoc = null then													// PAR #33582
						oldVehicleLoc := realVVR.myGateLaneController;								// PAR #33582
					endif;																			// PAR #33582
					origVehicle.erase(NORMAL_ERASE);												// PAR #33582
				endif;																				// PAR #33582
			endif;																					// PAR #33582
		endif;																						// PAR #33582
		//realVVR.myInOutCommon.setForUpdateErrorsFromPassport(realVVR, _passport);
	endif;

	//jlier1 TFS 57936 15/5/23 - gate in check status is complete set the barrier code validity start and end and send the code
	if _passport.noErrorsIgnored and sendBarrierCode then
		realVVR.myBarrierCodeIn.setValidityDTs(realVVR.gateInCheckTS,realVVR.gateInCheckTS.addMinutes(realVVR.myTerminal.getConfig(GateBarrierInBuffer).Integer));
		create pxyRequest transient;
		pxyRequest.setBarrierIn(true);		//14/02/2024	navcs2	Bug 62454	
		pxyRequest.setDetails(realVVR, null,null, realVVR.myTerminal, BGP_APIWSRequest.Type_Barrier);		// 28.06.2023	navcs2	#58433:[58454]	//14/02/2024	navcs2	Bug 62454
		
		app.myUtilityCA.utlCreateBGPRequestExtWS(pxyRequest, bgpRequest, app.myPassport);
			
	endif;
	
	if _passport.noErrorsIgnored and createBarrierCode then
		app.myUtilityCA.utlCreateBarrierCode(realVVR,true,false,_passport);
	endif;
	
	// cnwjk3 12/10/09 PAR 20915
	if _passport.noErrorsIgnored and vehicleChanged then
		// Move the new vehicle to where the old vehicle was
		gate := realVVR.getGateIn();
		if realVVR.vehicle &lt;&gt; null and gate &lt;&gt; null and realVVR.myGateLaneController &lt;&gt; null and oldVehicleLoc &lt;&gt; null then
			app.myUtilityUA.utlMoveVehicle(realVVR.vehicle, oldVehicleLoc, _passport);
			if _passport.hasErrorsIgnored then
				return;
			endif;
		endif;
	endif;
	
	//19 May 2025	jlier1	MTN-34221 refactoring moved so in utl not in all the trxs that call it
	// Create driver details if required
	if realVVR.myDriverDetails  = null and realVVR.driverCode &lt;&gt; null and realVVR.driversName &lt;&gt; null then
		//didn't find by on name if there is none by code
		if realVVR.myTerminal.findDriver(realVVR.driverCode) = null then
			realVVR.createDriver(_passport);
		endif;
		
		if _passport.hasErrorsIgnored then
			return;
		endif;
	endif;
	
	if realVVR.myDriverDetails &lt;&gt; null and	realVVR.vehicle &lt;&gt; null and realVVR.myDriverDetails.allCarriers.includes(realVVR.vehicle.carrier) then //and	// make sure driver and vehicle have same carrier		
		realVVR.myDriverDetails.allVehicleMachines.tryAdd(realVVR.vehicle); // link them if not already.
	endif;
	
	if  _moveToGateIn then
		// Move the truck to the physical lane it is currently parked in
		if  realVVR.myGateLaneController &lt;&gt; null and  realVVR.vehicle.myPrimaryActualLocation &lt;&gt; realVVR.myGateLaneController then
			app.myUtilityUA.utlMoveVehicle(realVVR.vehicle, realVVR.myGateLaneController, _passport);
			if _passport.hasErrorsIgnored() then
				return;
			endif;	
		endif;
	endif;

	if _passport.noErrorsIgnored then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realVVR, false);
		realVVR.causeEvent(realVVR.myTerminal.getTerminalEvent(EVENT_VEHICLEVISIT_UPDATE), false, realVVR);

		// ### TFS 51853 27AUG2021 NAVAB1
 // ### TFS 52914 23FEB2022 NAVAB1		if _passport.isOpsViewEnabled(realVVR.myTerminal) then
 // ### TFS 52914 23FEB2022 NAVAB1			realVVR.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_VVR, realVVR);		
 // ### TFS 52914 23FEB2022 NAVAB1		endif;
		
	endif;
epilog
	delete pxyRequest;
end;</source>
        <Parameter name="_pxyVVR" type="CM_VehicleVisitRecord"/>
        <Parameter name="_moveToGateIn" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVehicleVisitRecordTIs" id="290b6e81-613e-4abc-9cf4-b2bcd82f5a34">
        <updating/>
        <source>utlUpdateVehicleVisitRecordTIs(_job : CM_RoadJob input) updating;
/*

Purpose:	take job as parameter and not vvr because vvr does not have an inverse to the job ??? 
			-then update the vvr's tis to be the same as the jobs tis


Return Value:		


Date		Who		Reason
12 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	vvr : CM_VehicleVisitRecord;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);

	//do validation
	self.raiseExceptionIfNull(_job, 'Road Job');

	vvr:=_job.myVehicleVisit;
	
	vvr.allReceivedTrackedItems.clear;
	_job.allReceiveTrackedItems.copy(vvr.allReceivedTrackedItems);
	
	vvr.allReleasedTrackedItems.clear;
	_job.allReleaseTrackedItems.copy(vvr.allReleasedTrackedItems);

	
epilog

end;</source>
        <Parameter name="_job" type="CM_RoadJob" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVersion" id="185d0bd3-be46-4f93-9799-6b33b89c20bc">
        <source>utlUpdateVersion(_root : CM_Root input; _versionString, _patchLevel : String; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     12 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realVessel	: CM_Vessel;
	
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(false);

	exclusiveLock(_root);

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_root, true);
	endif;
	
	if _passport.noErrors then
		_root.setVersion(_versionString, _patchLevel);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_root, false);
	endif;

end;</source>
        <Parameter name="_root" type="CM_Root" usage="input"/>
        <Parameter name="_versionString" type="String"/>
        <Parameter name="_patchLevel" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVessMinimumChg" id="a13e66c2-b046-451d-a6f3-c2307a0f4748">
        <source>utlUpdateVessMinimumChg(_proxy : CM_InvTypeVesselMinCharge input; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2018	jlgndl1	Initial creation	TFS 38914

*/

vars

	real : CM_InvTypeVesselMinCharge;
	beforeAuditText, 
	afterAuditText: String;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_proxy, " Proxy is Null" );
	
	real := _proxy.pxyGetRealObject.CM_InvTypeVesselMinCharge;
	if real = null then
		self.raiseExceptionIfNull(_proxy, " Real is Null" );
	endif;

	app.setContinueCMExceptions(true);
	
	app.myValUA.valCM_Object(_proxy, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	if _passport.hasErrors then
		return;
	endif;
	
	beforeAuditText := real.getAuditText();
	
	real.setForUpdate(_proxy );
	
	afterAuditText := real.getAuditText();
	app.myAA.auditUpdateTrx(real, beforeAuditText, afterAuditText);

epilog

end;</source>
        <Parameter name="_proxy" type="CM_InvTypeVesselMinCharge" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVessel" id="7c0d43df-cf07-40e7-8ff4-66d8292e74b1">
        <source>utlUpdateVessel(_proxyVessel:CM_Vessel;  _updateFutureVoyages, _includeStructure : Boolean; _conflictManager : CMIF_HMS_ConflictsManager output; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs1
//21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice
// ---------------------------------------------------------------------------
vars
	realVessel:CM_Vessel;
	expectedEdition:Integer;
	origVesselCode : String;
	
begin
	self.initialiseActivity();
	
	_proxyVessel.raiseExceptionIfNotProxy(method);
	
	app.setContinueCMExceptions(true);
	_proxyVessel.pxyGetRealObjectAndEdition(realVessel, expectedEdition);
	
	if realVessel = null then
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_CellularVesselStructure.name, null, null);
		return;
	endif;
	
	app.myValUA.valVessel(realVessel, _proxyVessel, _includeStructure, _conflictManager, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realVessel);
	
	if _passport.noErrors() and realVessel.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Vessel', null, null);
		return;
	endif;
	
	origVesselCode := realVessel.code.trimBlanks();

	if _passport.noErrors() then
		self.myUpdateAuditAgent.audUpdateGeneric(realVessel, true);
	endif;
	
	if _passport.noErrors() then
		realVessel.setForUpdate(_proxyVessel, _includeStructure);
	endif;
	
	if _passport.noErrors()
	and _updateFutureVoyages
	then
		app.myRoot.updateVoyageDataFromVesselData(realVessel, origVesselCode, app.serverTimestampAtTrxStart, _passport);
	endif;
	
	if _passport.noErrors() then
		self.myUpdateAuditAgent.audUpdateGeneric(realVessel, false);
	endif;
	
	//21.09.2020 cnwma1 TFS #49906
	if _passport.isOpsViewEnabled(null) then
		realVessel.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,
								 BGP_OpsViewWSRequest.OPS_TYPE_VESSEL,
								 realVessel);
	endif;
	//21.09.2020 cnwma1 TFS #49906
end;</source>
        <Parameter name="_proxyVessel" type="CM_Vessel"/>
        <Parameter name="_updateFutureVoyages" type="Boolean"/>
        <Parameter name="_includeStructure" type="Boolean"/>
        <Parameter name="_conflictManager" type="CMIF_HMS_ConflictsManager" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVesselAllocEvents" id="6f8f226b-db5f-4963-8f57-5ced73666fc7">
        <source>utlUpdateVesselAllocEvents(_vessel : CM_Vessel input; 
							_vesselEventTypes : CM_EventTypesArray input;
							_passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2017	cnwns1	Initial creation
25/01/17 cnwns1 TFS3214 LNX - Voyage Operations Enhancements 
*/

vars

begin
	self.initialiseActivity();
	

	self.raiseExceptionIfNull(_vessel, 'Vessel');	
	self.raiseExceptionIfNull(_vesselEventTypes, 'VoyageEvents');	
	
	_vessel.setMyAllocatedEvents(_vesselEventTypes);
	
epilog

end;</source>
        <Parameter name="_vessel" type="CM_Vessel" usage="input"/>
        <Parameter name="_vesselEventTypes" type="CM_EventTypesArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVesselRampPosType" id="2bce37a2-2d50-4932-91db-ffe013fdb8a6">
        <source>utlUpdateVesselRampPosType(_vesselRampPositionType : CM_VesselRampPositionType; _passport : CM_Passport input);
/*
Date		    Who			Reason
18 April 2011	cnwas3	  Initial creation: CCMS 1031
*/


vars
