	self.unloadForm;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doEditYAOverstowHookCode" id="01334208-4fbc-4b5e-99eb-975124e5168f">
        <updating/>
        <source>doEditYAOverstowHookCode() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 September 2011	cnwrd1	Initial creation

*/

vars
hookTypeObj : CM_HookType;
sourceCode : String;
begin
	hookTypeObj := app.myRoot.allHookTypes[HookType_YardAllocationOS];
	
	if hookTypeObj = null then
		app.raiseUnexpectedProgramError(class.name,
		method.name,
		"User Hook type not found: " &amp;
		HookType_YardAllocationOS.String);
		return;
	endif;
	
	sourceCode := self.overstowHookCode;
	
	app.showHookCodeMaintForm(hookTypeObj, sourceCode, false);
	
	// Note that the "sourceCode" parameter will return the user's sourceCode.
	self.overstowHookCode := sourceCode;
end; </source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="60ecf31a-ee53-4f79-80de-babd2cfb4902">
        <updating/>
        <source>doRefresh() updating, protected;

/*

Purpose:		Refresh current form (Either main form or operational criteria)

Parameters:			

Return Value:		


Date			Who		Reason
30 July 2008	consw1	Initial creation

*/

vars

begin
	inheritMethod();

	delete self.myProxyYAConfig;
	self.myProxyYAConfig := app.createUpdateProxy(self.myTerminal.myYAConfig).CM_YAConfig;

	self.populateAPOverstow();  //cnwjo3 par 22338	
	self.populateMTReleaseStrategy();  // PAR 23677
	self.populateAutoPlan();
	self.populateDefaultCriteria();
	self.populateRTCriteria();
	self.populateOpCriteria();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="fe9340ca-ef11-427f-802d-52a2ff5c7bee">
        <updating/>
        <source>doSave() updating;

/*

Purpose:			Main form update (auto-planning and template sheets)

Parameters:			

Return Value:		


Date		Who			Reason
31 Jul 2008	consw1		Initial creation
16 Jun 2022 navhl20		TFS 53765 EUP - Warehouse Yard Allocation Desktop Application
25 Aug 2025	navdap1		MTN-35615 Bulk Creation of Yard Allocations
*/

vars
	configOpts : CMIF_YAConfig;
	searchCTColl : CM_YACriteriaTypeArray;
	templateCTColl : CM_YACriteriaTypeArray;
	bulkCTColl : CM_YACriteriaTypeArray;			// MTN-35615
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	create configOpts transient;
	configOpts.setFromTerminal(self.getRealYAConfig.myTerminal);

	configOpts.autoPlanAllowLogging				:= self.chkAPAllowLog.value;
	configOpts.autoPlanEnabled					:= self.chkAPEnabled.value;
	configOpts.autoPlanGenerateSwapForYardInt	:= self.chkAPGenSwapYard.value;
	configOpts.autoPlanGenerateSwapJob			:= self.chkAPGenSwapJob.value;
	configOpts.autoPlanPreNotiEmail				:= self.txtAPEmail.cnEcString();
	configOpts.autoPlanPreNotifications			:= self.chkAPPreNotif.value;
	configOpts.autoPlanUseOverstowRules			:= self.chkAPUseOstowRul.value;
	configOpts.autoPlanOsIgnorePandQ			:= self.chkOsIgnorePandQ.value;	//16 Jan 2018	NDL	TFS 42292
	configOpts.autoPlanYAGroupedBlocks			:= self.chkAPYAGroupBlk.value;
	configOpts.fillOption						:= self.cmbDefaultFill.itemData[ self.cmbDefaultFill.listIndex ];
	configOpts.autoPlanMTReleaseStrategy 		:= self.getMTReleaseStrategyCombo();   // PAR 23677
	configOpts.autoPlanUsePriorityLookup        := self.chkUsePriLookup.value;    // PAR 24673	
	configOpts.autoPlanUseBestPickDirector		:= self.chkUseBestPickDr.value; //cnwrd1 par 28628 3.11.11
	configOpts.autoPlanAllowFullGCArea			:= self.chkFullGCArea.value;		//16 June 2022 navhl20 TFS 53765
	configOpts.allRTAllocationCriteriaTypes.clear;
	self.mltRTCriteria.getSelected(configOpts.allRTAllocationCriteriaTypes);
	
	create searchCTColl transient;
	self.mltSearchDef.getSelected(searchCTColl);

	create templateCTColl transient;
	self.mltTemplateDef.getSelected(templateCTColl);
	
	create bulkCTColl transient;				// MTN-35615
	self.mltBulkDef.getSelected(bulkCTColl);	// MTN-35615

	self.myProxyYAConfig.setProxy(self.getRealYAConfig.myTerminal, templateCTColl, searchCTColl, bulkCTColl, self.overstowHookCode);	// MTN-35615
	self.myProxyYAConfig.setAutoPlanOverstowRule(self.getAPOverstowCombo());
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateYAConfig(self.myProxyYAConfig, configOpts, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.unloadForm();
			break;
		else
			theResult := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);		// MTN-35615
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog
	delete configOpts;
	delete searchCTColl;
	delete templateCTColl;
	delete bulkCTColl;			// MTN-35615
end;</source>
    </JadeMethod>
    <JadeMethod name="doUnload" id="4ac10ea9-38fd-4d60-803b-e8f0c3c5c3cf">
