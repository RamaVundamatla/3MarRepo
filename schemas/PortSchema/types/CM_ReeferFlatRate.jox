<Class name="CM_ReeferFlatRate" id="6eba6eba-355f-4d91-a021-a884085b298c">
    <superclass name="CM_ReeferMonitor"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="getDisplayStringForAttribute" id="45842403-1ea2-4d91-8c6f-45ae177da9dc">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			if self.myTrackedItem.isAttributeTrue(TI_Attrib_MonitorConnection) then
				return "Reefer monitored";
			else
				return "Reefer not monitored";
			endif;
			
		endif;
							
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="9085e65d-f2f4-487f-b520-33758d8616e3">
        <source>getEnquiryRow(): String;
//----------------------------------------------------------------
//	Created:	22 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.myTrackedItem.isAttributeTrue(TI_Attrib_MonitorConnection) then
		return inheritMethod() &amp; "Reefer monitored";
	else
		return inheritMethod() &amp; "Reefer not monitored";
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
