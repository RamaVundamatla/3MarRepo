        <type name="ListBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myDriverSchemaDescNameDict" id="e9c79307-21fa-4825-a6c5-d5289fadc369">
        <embedded/>
        <type name="DriverSchemaDescriptorNameDict"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="mySelectedSchema" id="cf4507ab-acfe-48e2-80cc-6345375f75f4">
        <embedded/>
        <type name="Schema"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="btnCancel_click" id="e9a36425-3e18-4808-a4aa-9976d4d1fc38">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;

begin
	self.modalResult := 1;
	self.unloadForm;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOK_click" id="dd035ab1-abe3-4706-99a6-de79c5cacf9b">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOK_click(btn: Button input) updating;

begin
	self.modalResult := 0;
	self.unloadForm;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="load" id="10263a2d-db18-47b6-b4db-1c12fa9eec26">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

vars
	dsdDict : DriverSchemaDescriptorNameDict;
	dsd : DriverSchemaDescriptor;
	dsdDictCreated : Boolean;
	
begin
	self.mySelectedSchema := null;
	
	if self.myDriverSchemaDescNameDict &lt;&gt; null then
		dsdDict := self.myDriverSchemaDescNameDict;
		dsdDictCreated := false;
	else
		create dsdDict transient;
		dsdDictCreated := true;
		rootSchema.getAllDriverSubschemaDescs(dsdDict);
	endif;
	
	foreach dsd in dsdDict do
		if dsd.mySchema &lt;&gt; null then
			lstSchemas.addItem(dsd.schemaName);
			lstSchemas.itemObject[lstSchemas.newIndex] := dsd.mySchema;
		endif;
	endforeach;

	lstSchemas.listIndex := -1;
	
	self.centreWindow;
		
epilog
	if dsdDict &lt;&gt; null and dsdDictCreated then
		dsdDict.purge;
		delete dsdDict;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="lstSchemas_click" id="da391655-81b8-4e09-a7a4-077ead379696">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstSchemas_click(listbox: ListBox input) updating;

begin
	if listbox.listIndex &lt; 1 or listbox.listIndex &gt; listbox.listCount then
		// belts and braces
		self.mySelectedSchema := null;
		return;
	endif;
	
	self.mySelectedSchema := listbox.itemObject[listbox.listIndex].Schema;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstSchemas_dblClick" id="5d77fd8e-02a1-4ed6-b6e1-4a647468b85c">
        <controlMethod name="ListBox::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstSchemas_dblClick(listbox: ListBox input) updating;

begin
	if listbox.listIndex &lt; 1 or listbox.listIndex &gt; listbox.listCount then
		// belts and braces
		self.mySelectedSchema := null;
	else
		self.mySelectedSchema := listbox.itemObject[listbox.listIndex].Schema;
	endif;
	
	self.btnOK_click(self.btnOK);
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
</GUIClass>
