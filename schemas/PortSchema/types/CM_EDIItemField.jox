    <JadeMethod name="getFileFormatXML" id="9ef9c49f-d8f6-4f99-96e9-42b7fb5094a6">
        <source>getFileFormatXML(_strXML: String io);
//----------------------------------------------------------------
//	Created:	08 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	_strXML := _strXML &amp; self.formatAsXML("name", self.name);
	_strXML := _strXML &amp; self.formatAsXML("required", self.required.String);
	_strXML := _strXML &amp; self.formatAsXML("stringFormatMethodName", self.stringFormatMethodName);
	_strXML := _strXML &amp; self.formatAsXML("systemName", self.systemName);
	_strXML := _strXML &amp; self.formatAsXML("systemTypeName", self.systemTypeName);
	_strXML := _strXML &amp; self.formatAsXML("className", self.className);
	
	

end;</source>
        <Parameter name="_strXML" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getMatchListDisplay" id="b60eb2e4-c2d9-495c-bd3b-a6ffaf46a789">
