    <JadeMethod name="doMatch" id="ddbeb8fd-d1e8-468a-a38c-2fe1fa2a1cff">
        <source>doMatch(_value: Any): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/

vars
	intValue : Integer;
begin
	if _value = null or _value.IntegerArray.isEmpty() then
		return false;
	endif;
	
	foreach intValue in _value.IntegerArray do
		if  intValue &lt; self.searchValue then
			return true;
		endif;	
	endforeach;
	
	return false;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Boolean"/>
