    <JadeMethod name="doGetSelectorTIsLoadList" id="56eea63d-bc10-4e1f-ae85-bf1f007153e5">
        <updating/>
        <source>doGetSelectorTIsLoadList(_objs : ObjectSet; _voyage : CM_Voyage) : CM_EnquiryController updating;
// ---------------------------------------------------------------------------
// Created:		14 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 20/05/2010	cnwdap1		CCMS 1116 Tranship changes
vars
	enqController			: CM_EnquiryController;
	queryDef				: CM_QueryDefinition;
	queryParams				: CM_QueryCriteriaLineHolder;
	anObject : Any;
	aTI : CM_TrackedItem;
	idx		: Integer;
	aTA : CM_TerminalArea;
	taStr : String;
	imex : IntegerArray;
	disPorts,
	taS :	ObjectSet;
	aPort : CM_Port;
	portStr : StringArray;
	
begin
	app.mousePointer := Window.MousePointer_HourGlass;

	queryDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 0];//mode = 0 for TrackedItem mode
	app.myQAFilter.createEnqControllerForMode(queryDef.mode, queryDef.type, enqController);
	
	create taS transient;
	create enqController.allObjects as CM_ObjectSet transient;
	create disPorts transient;
	create portStr transient;
	create imex transient;

	foreach anObject in _objs do
		aTI := anObject.CM_TrackedItem;
		if aTI.myTerminalArea &lt;&gt; null 
		and not taS.includes(aTI.myTerminalArea) then
			taS.add(aTI.myTerminalArea);
		endif;	
		if aTI.dischargePort &lt;&gt; null then
			aPort := app.myRoot.allPorts[aTI.dischargePort];
			if aPort &lt;&gt; null then
				if not disPorts.includes(aPort) then
					disPorts.add(aPort);
					portStr.add(aPort.code);
				endif;
			endif;
		endif;
	endforeach;

	imex.add(TI_IMEX_STATUS_EXPORT);
	
	imex.add(TI_IMEX_STATUS_REMAINONBOARD); // this will pick up DLRs
	
	imex.add(TI_IMEX_STATUS_TRANSHIP);	// PAR #23645 CCMS 1116 Include tranships
	
	delete queryParams;
	create queryParams transient;
	queryParams.collectionBelongsTo := CM_Terminal.firstInstance;//don't need this?
	
	//create criteria
	self.doSetSelectorCriteria(queryParams,queryDef,'myTerminal', CM_QueryOperator.Operator_Equal,self.myTerminal);
	self.doSetSelectorCriteria(queryParams,queryDef,'site', CM_QueryOperator.Operator_Equal,TI_SITE_ONSITE_str);
	self.doSetSelectorCriteria(queryParams,queryDef,'voyageCode', CM_QueryOperator.Operator_Equal,_voyage);
	self.doSetSelectorCriteria(queryParams,queryDef,'planningState', CM_QueryOperator.Operator_NotEqual,"Planned to Load");

	self.doSetSelectorCriteria(queryParams,queryDef,'myTerminalArea', CM_QueryOperator.Operator_IsOneOf,taS);
	self.doSetSelectorCriteria(queryParams,queryDef,'dischargePort', CM_QueryOperator.Operator_IsOneOf,portStr);
		
		self.doSetSelectorCriteria(queryParams,queryDef,'imexStatus', CM_QueryOperator.Operator_IsOneOf,imex);
		


	//execute query
	enqController.myCriteriaLineHolder := queryParams;
	enqController.doQuery(queryDef);

	return enqController;
epilog
	delete taS;
	delete disPorts;
	delete portStr;
	delete imex;
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="_objs" type="ObjectSet"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="CM_EnquiryController"/>
    </JadeMethod>
    <JadeMethod name="doSetSelectorCriteria" id="9fc29f01-d5aa-4c28-81d6-df6fa87ee5f5">
        <source>doSetSelectorCriteria(_queryParams: CM_QueryCriteriaLineHolder input;_queryDef	: CM_QueryDefinition;_property : String; _operator : String; _value : Any);
// ---------------------------------------------------------------------------
// Created:		Novemebr 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	criteria: CM_SelectorCriteriaLine;
	queryProperty,clonedProp			: CM_QueryProperty;
	queryOperator,clonedOp			: CM_QueryOperator;
	queryValue				: Any;
	obj : Object;
begin
	if _value.isKindOf(IntegerArray) then
		create criteria transient;
		queryProperty := _queryDef.allQueryProperties[_property];
		queryOperator := queryProperty.allAllowedOperators[_operator];
		clonedProp := queryProperty.cloneSelf(true);
		clonedOp := queryOperator.cloneSelf(true);
	
		clonedOp.setSearchValue(_value);	
		criteria.set(clonedProp, clonedOp, false);
		criteria.setMyCriteriaLineHolder(_queryParams);
	else
		create criteria transient;
		queryProperty := _queryDef.allQueryProperties[_property];
		queryOperator := queryProperty.allAllowedOperators[_operator];
		queryValue := queryProperty.translateToSearchValue(_value); 
		clonedProp := queryProperty.cloneSelf(true);
		clonedOp := queryOperator.cloneSelf(true);
	
		
		
		clonedOp.setSearchValue(queryValue);	
		criteria.set(clonedProp, clonedOp, false);
		criteria.setMyCriteriaLineHolder(_queryParams);
	endif;
end;</source>
        <Parameter name="_queryParams" type="CM_QueryCriteriaLineHolder" usage="input"/>
        <Parameter name="_queryDef" type="CM_QueryDefinition"/>
        <Parameter name="_property" type="String"/>
        <Parameter name="_operator" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
