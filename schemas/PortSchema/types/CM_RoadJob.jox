    <JadeMethod name="getOverride_YardICArea" id="8fa99b92-6d3a-4cf9-b0fa-5c4cff649b07">
        <source>getOverride_YardICArea():CM_YardInterchangeArea;
// ---------------------------------------------------------------------------
// Created:     17 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     The interchange area entered to override the default interchange
//				area at gate entry.  Can be null
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ta 	: CM_TerminalAreaMaster;
begin
	// if there is an interchange area id on the road job then send the vehicle there
	// this will be the case for jobs entered using the old gate in form (:-&lt;)
	if self.roadTransAreaId &lt;&gt; null then	
		if self.myTerminal &lt;&gt; null then
			ta:= self.myTerminal.allTerminalAreaMastersById[self.roadTransAreaId];
			
			if ta.isKindOf(CM_YardInterchangeArea) then	
				// there is a value
				return ta.CM_YardInterchangeArea;			
			endif;
		endif;	
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_YardInterchangeArea"/>
    </JadeMethod>
    <JadeMethod name="getReadyToLeaveLocation" id="5783ca28-d5e3-4764-9194-a8fb0e3dbad3">
        <source>getReadyToLeaveLocation():CM_YardController;
// ---------------------------------------------------------------------------
// Created:     24 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Location into which truck should go once all jobs are complete
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lc			:CM_YardController;
	icArea, 
	icAreaOut	:CM_InterchangeArea;
	gate		:CM_Gate;
begin
	lc	:= self.myVehicle.myPrimaryActualLocation;
	
//	1.  Get location from the default interchange area for the default 
//		out-gate for the current vehicle location
	icArea := lc.myAssociatedInterchangeArea;	// interchange area for current location
	
	if icArea &lt;&gt; null then
		gate := icArea.myDefaultOutGate;	// out gate for current location
		
		if gate &lt;&gt; null then
			icAreaOut := gate.myDefaultInterchangeArea;
			
			if icAreaOut &lt;&gt; null then
				return icAreaOut.myInTransitFromLocation;
			endif;
		endif;
	endif;
	
//	2.	Get location from the default interchange area for the default out-gate
//		for the terminal
	gate := self.myTerminal.getDefaultGate_OUT;
	
	if gate &lt;&gt; null then
		icAreaOut	:= gate.myDefaultInterchangeArea;
		
		if icAreaOut &lt;&gt; null then
			return icAreaOut.myInTransitFromLocation;
		endif;
	endif;
	
//	3.	Get location from the default interchange area for the gate
//		through which the vehicle entered the terminal
	
	gate := self.getGateIn;
	
	if gate &lt;&gt; null then
		return gate.myDefaultInterchangeArea.myInTransitFromLocation;
	endif;
	
//	if we get to here the road job does not have a gate. Our conversion should set the gate for any road jobs
//  currently in the terminal so this would be genuine bug.	
	app.raiseUnexpectedProgramError (self.class.name, method.name, 'Unable to set in-transit-out location from road job');
epilog

end;</source>
        <ReturnType type="CM_YardController"/>
    </JadeMethod>
    <JadeMethod name="getReleaseNumber" id="c51d773e-b0ff-400c-9592-0ede6f8a6a25">
        <source>getReleaseNumber() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Aug 2025	naviv1	Initial creation - MTN-35544 : FR 35007.010 Display Release Request ID in Road Ops

*/

vars
	request : CM_Request;
	releaseNum : String;
begin
	if self.allRequests.isEmpty then
		return null;
	endif;
	foreach request in self.allRequests do
		releaseNum.addStringToList(request.getReleaseNumber(),',');
	endforeach;
	return releaseNum;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
