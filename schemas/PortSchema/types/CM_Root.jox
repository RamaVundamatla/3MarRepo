epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="passwordMinLength" id="65b10c07-90cf-4355-a387-36f42c31621d">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
