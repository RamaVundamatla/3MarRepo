    <JadeMethod name="doLoad" id="313b88c6-da5f-4f51-a2b0-5628df01d1e9">
        <updating/>
        <source>doLoad() updating, protected;

vars

begin
	
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar	:= true;
	
	self.centreWindow();
	self.tblRemote.parentTopMargin := self.tblRemote.top;
	self.tblRemote.parentBottomMargin := 20;
	self.tblRemote.setDistanceFromRight(23);
	self.tblRemote.lockBottom := true;
	self.tblRemote.lockRight := false;
	self.tblRemote.stretchHeight := true;
	self.tblRemote.stretchWidth := true;
	self.tblRemote.setDistanceFromBottom(20);
	
// Removed as table is intended to reflect exact XML entered and allow editting of this
// It should NOT sort the data (par 15684) 
	//added by cnwyl1 for par 15684 16/01/2008
	//tblRemote needs to be sorted by column.
//	self.tblRemote.sortType[1] := Table.SortType_Alpha;
//	self.tblRemote.sortAsc[1] := true;
//	self.tblRemote.sortColumn[1] := 1;
	////////////////////////////////////////
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doProcessing" id="a1a07e7a-8575-441b-85cc-14571cfeed66">
        <updating/>
        <source>doProcessing() protected, updating;

vars

	result 		: Integer;

begin

	app.mousePointer := MousePointer_HourGlass;	
	if self.myRemoteHdr &lt;&gt; null then
		while true do
			if self.myRemoteHdr.runBackGroundProcess(false) then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				self.unloadForm();
				break;
			else
				result := app.showErrorWarningDialog('Process Remote Data', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if self.myEditManager.isArray then
					self.doBack();
				endif;
				if app.myPassport.noErrors and
			   		result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				else
					break;
				endif;
			endif;
		endwhile;
	endif;
	
epilog	
	app.mousePointer := MousePointer_Default;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="90691c1e-8929-4607-a28a-64919ed4ae43">
        <updating/>
        <source>doResize() updating;
// -------------------------------------------
// Created 03 October 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.frmRemote.visible then
		self.frmRemote.top 	:= self.frmToolbar.height;
	endif;
	inheritMethod();


end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="16c9e147-4096-43ae-839d-780bbc470014">
        <updating/>
        <source>doSave() updating, protected;

vars

	rtnValue : Boolean;

begin

	app.mousePointer := MousePointer_HourGlass;	
	rtnValue := self.myEditManager.save();
	if rtnValue then
		self.setButtonState(true);
	endif;

epilog
	if not rtnValue then
		self.setAllErrorWarnings(app.myPassport);
	endif;
	app.mousePointer := MousePointer_Default;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUnload" id="840d323a-6fe3-4e36-8491-3041066e4c77">
        <updating/>
        <source>doUnload() updating, protected;

vars

begin

	delete self.myEditManager;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initialize" id="eb80af90-b7fd-44dd-8082-8488b08eab9e">
        <updating/>
        <source>initialize(_remoteHdr : CM_RemoteDataHdr io) updating;

vars

	remoteDataHdr : CM_RemoteDataHdr;

begin
	
	self.doLoad();
	self.btnSaveBase.enabled := false;
	self.myRemoteHdr := _remoteHdr;
	create self.myEditManager transient;
	self.myEditManager.initialize(self.tblRemote);
	self.lblDescription.caption := self.myEditManager.loadTable(_remoteHdr);
	self.setButtonState(true);	//PAR 21218 23/02/2010
	resize();
	
end;</source>
        <Parameter name="_remoteHdr" type="CM_RemoteDataHdr" usage="io"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="e0483ef8-89b5-4297-9e84-5b111ea92a84">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;


vars
	theActiveControl	: Control;
	
begin

	theActiveControl := app.activeControl;
	if theActiveControl.parent.isKindOf(CM_EntryTable) then
		theActiveControl := theActiveControl.parent.Control;
	endif;
	if keyCode = J_key_Tab then
		self.tblRemote.handleFormTab(keyCode, shift, self.btnBackT, self.btnSaveBase);
		if theActiveControl.isKindOf(CM_EntryTable) and theActiveControl.visible then
			theActiveControl.CM_EntryTable.handleTableTab(shift);
		endif;
	endif;
	
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setButtonState" id="52383d3d-2fbf-46c7-87c0-aec06bbb2854">
        <updating/>
        <source>setButtonState(_processEnabled : Boolean) protected, updating;

vars

begin

	if self.myRemoteHdr.isProcessAllowedInSystemAllert() then	//PAR 21218. button is disabled for some classes
		self.btnSaveBase.enabled	:= not _processEnabled;
		self.btnProcessT.enabled	:= _processEnabled;
	else
		self.btnSaveBase.enabled	:= false;
		self.btnProcessT.enabled	:= false;
		self.btnBackT.enabled		:= false;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_processEnabled" type="Boolean"/>
    </JadeMethod>
