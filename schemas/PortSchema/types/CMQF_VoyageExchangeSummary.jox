<Class name="CMQF_VoyageExchangeSummary" id="c3fd9205-ad31-4758-b389-c2a7eb9cdf27">
    <superclass name="CMQF_VoyageSummary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="createPreDefinedSummaryObj" id="81fff3f7-cbdf-413e-b73d-741eae088723">
        <source>createPreDefinedSummaryObj(_dict: Dictionary input);
// ---------------------------------------------------------------------------
// Created:     30 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 04/10/2010	cnwdap1		PAR #25943 Add voyage to summary object for use by tranship tests
vars
	voySum			: CMIF_VoyageSummary;

begin

	_dict.purge();	
	create voySum transient;
	voySum.keyValue1 := self.TOTALS_ID;
	voySum.heading := 'Total';
	voySum.myVoyage := self.getMyVoyage;		// PAR #25943
	_dict.add(voySum);

	/*if they need a coastal total - assuming from the CCMS#1273 attachment that they don't
	create voySum transient;
	voySum.keyValue1 := self.TOTALS_ID_COASTAL;
	voySum.heading := 'Total Coastal';
	_dict.add(voySum);
	*/

end;</source>
        <Parameter name="_dict" type="Dictionary" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTotalsForTI" id="81f647e1-6771-4b00-9b71-3d1ea475a946">
        <source>doTotalsForTI(_key: String; _voyageSum: CMIF_VoyageSummaryByValueDict input; _ti: CM_TrackedItem) protected;
//----------------------------------------------------------------
//	Created:	29 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 04/10/2010	cnwdap1		PAR #25943 Correct totals for tranships, update voyage on summary object
vars

	summaryObj			: CMIF_VoyageSummary;
	only20sAnd40s : Boolean;
	
begin

	only20sAnd40s := true;
	summaryObj := _voyageSum[_key, null];
					
	if summaryObj = null then
		create summaryObj transient;
		summaryObj.keyValue1 := _key;
		summaryObj.keyValue2 := null;
		summaryObj.myVoyage := self.getMyVoyage;		// PAR #25943
		_voyageSum.add(summaryObj);
	endif;

	//15 Apr 2010	NDL	Par 23048 - Now only processes 20s &amp; 40s and uses the new common code.
//	summaryObj.totalSelfForExchangeSummaryTI(_ti, false);
	summaryObj.totalSelfForExchangeSummaryAll(_ti, null, only20sAnd40s, false);
//	summaryObj.totalDescriptorsForTI(_ti);
	summaryObj.totalDescriptorsForAll(_ti, null, only20sAnd40s);
	
	//totals objects
//	_voyageSum[self.TOTALS_ID, null].totalSelfForExchangeSummaryTI(_ti, true);
	_voyageSum[self.TOTALS_ID, null].totalSelfForExchangeSummaryAll(_ti, null, only20sAnd40s, true);


end;</source>
        <access>protected</access>
        <Parameter name="_key" type="String"/>
        <Parameter name="_voyageSum" type="CMIF_VoyageSummaryByValueDict" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doTotalsForTxn" id="be9c3120-1dfd-40b3-b961-43fbffafbf55">
        <source>doTotalsForTxn(_key: String; _voyageSum: CMIF_VoyageSummaryByValueDict input; _txn: CM_TITransaction) protected;
//----------------------------------------------------------------
//	Created:	29 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 04/10/2010	cnwdap1		PAR #25943 Correct totals for tranships, update voyage on summary object
vars

	summaryObj			: CMIF_VoyageSummary;
	only20sAnd40s : Boolean;
	
begin

	only20sAnd40s := true;
	summaryObj := _voyageSum[_key, null];
		
	if summaryObj = null then
		create summaryObj transient;
		summaryObj.keyValue1 := _key;
		summaryObj.keyValue2 := null;
		summaryObj.heading := _key;
		summaryObj.myVoyage := self.getMyVoyage;		// PAR #25943
		_voyageSum.add(summaryObj);
	endif;

	//15 Apr 2010	NDL	Par 23048 - Now only processes 20s &amp; 40s and uses the new common code.
//	summaryObj.totalSelfForExchangeSummaryTxn(_txn, false);
	summaryObj.totalSelfForExchangeSummaryAll(null, _txn, only20sAnd40s, false);
//	summaryObj.totalDescriptorsForTxn(_txn);
	summaryObj.totalDescriptorsForAll(null, _txn, only20sAnd40s);

	//totals objects
//	_voyageSum[self.TOTALS_ID, null].totalSelfForExchangeSummaryTxn(_txn, true);
	_voyageSum[self.TOTALS_ID, null].totalSelfForExchangeSummaryAll(null, _txn, only20sAnd40s, true);

end;</source>
        <access>protected</access>
        <Parameter name="_key" type="String"/>
        <Parameter name="_voyageSum" type="CMIF_VoyageSummaryByValueDict" usage="input"/>
        <Parameter name="_txn" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="filterForActual" id="974b5edc-c95e-442d-a859-c8a0b76612fb">
        <updating/>
        <source>filterForActual(_voySummaryDict: CMIF_VoyageSummaryByValueDict input; _passport: CM_Passport) protected, updating;
// ---------------------------------------------------------------------------
// Created:     30 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	startTS,
	endTS			: TimeStamp;
	txnBucket		: CM_TITransactionByTypeDateDict;
	breakOut		: Boolean;
	querySelf		: CMQF_VoyageExchangeSummary;

begin

	querySelf := self;
	
	if (not self.startDate.isValid()) then
		startTS.setDate('01/01/0001'.Date);
	else
		startTS.setDate(self.startDate);
	endif;
	startTS.setTime('00:00:00:000'.Time);
	
	if (not self.endDate.isValid()) then
		endTS.setDate(app.actualTimeServer.date);
	else
		endTS.setDate(self.endDate);
	endif;
	
	endTS.setTime('23:59:59:999'.Time);
	
	create txnBucket transient;
	
	querySelf.getMyVoyage.getTITxns(TRANS_TYPE_REC_SHIP, startTS, endTS, true, 'includesTxn', self, txnBucket);
	querySelf.getMyVoyage.getTITxns(TRANS_TYPE_REL_SHIP, startTS, endTS, true, 'includesTxn', self, txnBucket);
	querySelf.getMyVoyage.getTITxns(TRANS_TYPE_MOVE, startTS, endTS, true, 'includesTxn', self, txnBucket);
	
	querySelf.processTxns(txnBucket, _voySummaryDict, _passport);

epilog
	delete txnBucket;
end;</source>
        <access>protected</access>
        <Parameter name="_voySummaryDict" type="CMIF_VoyageSummaryByValueDict" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterForProposed" id="31f18301-2a3b-4eb1-a998-b5c568b4aefb">
        <updating/>
        <source>filterForProposed(_voySummaryDict: CMIF_VoyageSummaryByValueDict input; _passport: CM_Passport) updating, protected;
// ---------------------------------------------------------------------------
// Created:     30 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 09/11/2005	cnwmh5		PAR21537 - Don't require child items to be included
// 04/10/2010	cnwdap1		PAR #25943 Correct tranship handling
vars
	
	hold				: CM_Hold;
	bay					: CM_Bay;
	slotController		: CM_SlotController;
	sotRequest			: CM_SlotRequest;
	ti					: CM_TrackedItem;
	summaryObj			: CMIF_VoyageSummary;
	futureMove			: CM_FutureMove;
	querySelf			: CMQF_VoyageSummary;
	isCoastal,
	breakOut			: Boolean;
	terminal			: CM_Terminal;
	key1				: String;
	tiArray				: CM_TIArray;
	txn					: CM_TITransaction;
begin
	querySelf := self;
	if querySelf.getMyVoyage = null then
		return;
	endif;
	
	if querySelf.getMyVoyage.myCellularVoyageStructure &lt;&gt; null then//added by cnwyl1 24052006
		querySelf.getMyVoyage.myCellularVoyageStructure.allHolds.copy(querySelf.allHolds);
		querySelf.allHolds.removeInvalidObjects();	//18 July 2016	NDL	TFS 2329
		create tiArray transient;
		foreach hold in querySelf.allHolds do : holdLoop
	
			foreach bay in hold.allBays discreteLock do
				if not CM_BayVoyage.hasInstance(bay) then
					continue;
				endif;
	
				foreach slotController in bay.CM_BayVoyage.allSlotControllersByOrdinal discreteLock do
					//will pickup exports/DLRs/SOBs but not imports planned off
					//slotController.getProposedTIs(tiArray);
					//will pickup imports planned off
					slotController.getExchangeTIs(tiArray);
					//what we have is the proposed list including unmoved transit boxes 
					foreach ti in tiArray do : tiLoop
						//if slotController.isTIBackEndForProposed(ti) ... now
						if (slotController.isFortyBack and ti.isAttributeTrue(TI_Attrib_IsForty))
						or (ti.getTransitStatus = TI_TransitStatusNull and ti.getImExStatus = TI_IMEX_STATUS_REMAINONBOARD) then
							//a back end or
							//not an import or an export or a DLR or SOB
							continue tiLoop;					
						endif;	
						// 09/11/2009 cnwmh5 PAR21537 - Start
						if ti.isChild then
							continue tiLoop;
						endif;
						// 09/11/2009 cnwmh5 PAR21537 - End
						if not querySelf.checkStatusIncludesObject(ti, _passport, breakOut) then	
							continue tiLoop;
						endif;
						
						//TI has been picked from the planning info.
						//For this report to work while the ship is being worked we need to allow for imports
						//that have been changed since discharge (the import may now be an export for another
						//voyage and taking the keys from the ti would put things out of whack).
						//Look for the presence of a ship discharge with imex = import (duh), compare voyage to
						//self.myVoyage.  If it all matches use the txn to key the move.  Otherwise use the ti.
						//PAR 10648
						txn := ti.getLastTransOfType(TRANS_TYPE_REC_SHIP);
						if txn &lt;&gt; null
						and (txn.imExStatus = TI_IMEX_STATUS_IMPORT or txn.imExStatus = TI_IMEX_STATUS_STORAGE
								or txn.imExStatus = TI_IMEX_STATUS_TRANSHIP and txn.getVoyage = self.getMyVoyage)	// PAR #25943
						and txn.transitStatus &lt;&gt; TI_TransitStatusDLR
						and txn.getVoyage() = self.getMyVoyage then
							key1 := self.getKeyFromTxn(self.orderKey1, txn);
							self.doTotalsForTxn(key1, _voySummaryDict, txn);
						else
							key1 := self.getKeyFromTI(self.orderKey1, ti);
							self.doTotalsForTI(key1, _voySummaryDict, ti);
						endif;	
						
						/* now done in doTotalsForTI
						summaryObj := _voySummaryDict[key1, null];
						
						if summaryObj = null then
							create summaryObj transient;
							summaryObj.keyValue1 := key1;
							summaryObj.keyValue2 := null;
							_voySummaryDict.add(summaryObj);
						endif;
					
						summaryObj.totalSelfForExchangeSummaryTI(ti, false);
						summaryObj.totalDescriptorsForTI(ti);
						
						//totals objects
						_voySummaryDict[self.TOTALS_ID, null].totalSelfForExchangeSummaryTI(ti, true);
						*/	
					endforeach;
				endforeach;
			endforeach;
		endforeach;
	endif;//added by cnwyl1 24052006
	
epilog
	delete tiArray;
end;</source>
        <access>protected</access>
        <Parameter name="_voySummaryDict" type="CMIF_VoyageSummaryByValueDict" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="a3848d8a-70bb-4064-b86b-0d8fa22e2441">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     30 August 2004	cnwth2
//
// Purpose:     This report is for CCMS#1273 Exchange Summary Report
//				Populate the collection of summary objects keyed by operatorCode, isCoastal.
//				isCoatal := other NZ ports not terminal.loadPort - not coastal = all other international ports
//
//				Also populates collection of summary descriptors used on the second design.
//			 
// ----------   ----------  --------------------------------------------------
vars
	voySummaryDict	: CMIF_VoyageSummaryByValueDict;
	
begin
	if self.getMyVoyage = null then
		return;
	endif;
	
	if self.getMyVoyage.myOperator = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "voyages operator", 'myOperator', null);
		app.raiseCMException(Input_required_field_voyageOp, 'myOperator', null); // cnwdb2	PAR 35364
		return;
	endif;
	
	if (not CMIF_VoyageSummaryByValueDict.hasInstance(_collection)) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid collection type for query method');
		return;
	endif;

	self.initFields();
	voySummaryDict := _collection.CMIF_VoyageSummaryByValueDict;
	
	self.createPreDefinedSummaryObj(voySummaryDict);
	
	if self.actualProposedOption = null or self.actualProposedOption = self.MODE_OPT_ACTUAL then
		self.filterForActual(voySummaryDict, _passport);
	else
		self.filterForProposed(voySummaryDict, _passport);
	endif;

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getKeyFromTI" id="82ec17cd-5313-4c75-867a-e729dbf6472e">
        <source>getKeyFromTI(_orderKey : String; _ti : CM_TrackedItem): String protected;
// ---------------------------------------------------------------------------
// Created:     30 August 2004	cnwth2
//
// Purpose:     Re-implemented - purpose specific for the Exchange summary report
//				will either return the operator code key, or key &amp; 'Coastal'
//			 
// ----------   ----------  --------------------------------------------------
vars

	isCoastal			: Boolean;
	cont				: CM_Container;
	theOperator			: CM_Operator;
	txn					: CM_TITransaction;
begin
	if _ti = null then
		return null;
	endif;
	
	if _ti.getTransitStatus = TI_TransitStatusDLR
	or _ti.getTransitStatus = TI_TransitStatusSOB then
		// for restows summarise on the voyage operator	- JC PAR 9901
		theOperator := _ti.myVoyage.myOperator;
	else
		theOperator := _ti.myOperator;
	endif;
	
	if not _ti.isCoastal then
		if theOperator = null then//_ti.operatorCode.trimBlanks = null then	- JC PAR 9901
			return 'No Operator';
		else
			return theOperator.code.trimBlanks;		
		endif;
	else
		if theOperator = null then//_ti.operatorCode.trimBlanks = null then	- JC PAR 9901
			return 'No Operator Coastal';
		else
			return theOperator.code.trimBlanks &amp; ' Coastal';		
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_orderKey" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getKeyFromTxn" id="1eab70e7-1484-4142-83d1-c911bcb77d9f">
        <source>getKeyFromTxn(_orderKey: String; _txn : CM_TITransaction): String protected;
// ---------------------------------------------------------------------------
// Created:     30 August 2004	cnwth2
//
// Purpose:     Re-implemented - purpose specific for the Exchange summary report
//				will either return the operator code key, or key &amp; 'Coastal'
//			 
// ----------   ----------  --------------------------------------------------
vars
	ti					: CM_TrackedItem;
	isCoastal			: Boolean;
	cont				: CM_Container;
	theOperator			: CM_Operator;
begin
	if _txn = null then
		return null;
	endif;

	if _txn.transitStatus = TI_TransitStatusDLR
	or _txn.transitStatus = TI_TransitStatusSOB then
		// for restows summarise on the voyage operator	- JC PAR 9901
		theOperator := self.getMyVoyage.myOperator;
	else
		theOperator := app.myRoot.allOperators[_txn.operatorCode];
	endif;
		
	if (not _txn.isCoastal) then
		if theOperator = null then //_txn.operatorCode.trimBlanks = null then	- JC PAR 9901
			return 'No Operator';
		else
			return theOperator.code.trimBlanks;		
		endif;
	else
		if theOperator = null then //_txn.operatorCode.trimBlanks = null then	- JC PAR 9901
			return 'No Operator Coastal';
		else
			return theOperator.code.trimBlanks &amp; ' Coastal';		
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_orderKey" type="String"/>
        <Parameter name="_txn" type="CM_TITransaction"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="0af8ec3b-738f-474b-882b-5977a7e9b6ce">
        <updating/>
        <source>includesObject(_obj: CM_Object; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
//----------------------------------------------------------------
//	Created:	17 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	isRestow	: Boolean;
	tranStatus	: Integer;
	ti			: CM_TrackedItem;
	failedDAC  :CM_DataAccessController;
begin
	if (not CM_TrackedItem.hasInstance(_obj)) then
		return false;
	endif;
	
	ti := _obj.CM_TrackedItem;

	self.numSearched := self.numSearched + 1;
	
	if self.myOperator &lt;&gt; null then
		tranStatus := ti.getTransitStatus;
		if tranStatus = TI_TransitStatusDLR
		or tranStatus = TI_TransitStatusSOB then
			isRestow := true;
		endif;
		
		//do the operator test
		if not self.testOperator(isRestow, ti.operatorCode) then
			return false;		
		endif;		
	endif;

	if (self.getMySubTerminal &lt;&gt; null and ti.mySubTerminal &lt;&gt; self.getMySubTerminal) then //29/04/2009 cnwdz2 ccms1735
		return false;
	endif;
	
	if (not ti.canUserAccessSelf(null, failedDAC, _passport)) then
		return false;
	endif;

	self.numFound := self.numFound + 1;
	return true;

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesTxn" id="dcfb7d9d-b012-4f03-805f-439ad033f5d1">
        <updating/>
        <source>includesTxn(_txn : CM_TITransaction; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     30 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	isRestow	: Boolean;
	tranStatus	: Integer;
	failedDAC  :CM_DataAccessController;
begin

	if self.myOperator &lt;&gt; null then
		tranStatus := _txn.transitStatus;
		if tranStatus = TI_TransitStatusDLR
		or tranStatus = TI_TransitStatusSOB then
			isRestow := true;
		endif;
		
		//do the operator test
		if not self.testOperator(isRestow, _txn.operatorCode) then
			return false;		
		endif;		
	endif;

	if (not _txn.canUserAccessSelf(null, failedDAC,_passport)) then
		return false;
	endif;

	return true;

end;</source>
        <Parameter name="_txn" type="CM_TITransaction"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initFields" id="99660f4c-57b2-43bf-9cd1-f4e81fa91802">
        <updating/>
        <source>initFields() updating;
// ---------------------------------------------------------------------------
// Created:     30 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.doFilterLoadPorts := false;
	self.orderKey1 := self.ORDERED_BY_OPERATOR;//they don't get to pick the sort order for this report
end;</source>
    </JadeMethod>
    <JadeMethod name="processTxns" id="aa8e1582-4680-4a51-ba66-774a5f4f287f">
        <source>processTxns(_txnBucket : CM_TITransactionByTypeDateDict;
					_voySummaryDict : CMIF_VoyageSummaryByValueDict input;
					_passport : CM_Passport) protected;
// ---------------------------------------------------------------------------
// Created:     20 July 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 09/11/2005	cnwmh5		PAR21537 - Don't require child items to be included
//
vars
	txn				: CM_TITransaction;
	summaryObj		: CMIF_VoyageSummary;	
	key1			: String;
	allProcessedIDs	: StringArray;
	snapShot		: CM_TISnapShot;
begin
	
	create allProcessedIDs transient;//used to not count DLRs and SOBs twice

	foreach txn in _txnBucket do
		snapShot := txn.mySnapShot.CM_TISnapShot;
		
		if snapShot = null then
			continue;
		endif;
	
		// 09/11/2009 cnwmh5 PAR21537 - Start
		if txn.myTrackedItem.isChild or
		   txn.isChild then		// par 27796 Aug 2011 extend test for items unpacked since
			continue;
		endif;
		// 09/11/2009 cnwmh5 PAR21537 - End
	
		if snapShot.transitStatus = TI_TransitStatusDLR or
		   snapShot.transitStatus = TI_TransitStatusSOB then
			if allProcessedIDs.includes(snapShot.id) then
				continue;
			endif;
			
			allProcessedIDs.add(snapShot.id);
		endif;
		
		key1 := self.getKeyFromTxn(self.orderKey1, txn);
		self.doTotalsForTxn(key1, _voySummaryDict, txn);
		/* now done in above method
		summaryObj := _voySummaryDict[key1, null];
		
		if summaryObj = null then
			create summaryObj transient;
			summaryObj.keyValue1 := key1;
			summaryObj.keyValue2 := null;
			summaryObj.heading := key1;
			_voySummaryDict.add(summaryObj);
		endif;
	
		summaryObj.totalSelfForExchangeSummaryTxn(txn, false);
		if (not txn.isCoastal) then
			summaryObj.totalDescriptorsForTxn(txn);
		endif;
		//totals objects
		_voySummaryDict[self.TOTALS_ID, null].totalSelfForExchangeSummaryTxn(txn, true);
		//_voySummaryDict[self.TOTALS_ID_COASTAL, null].totalSelfForExchangeSummaryTxn(txn);
		*/
	endforeach;

epilog
	delete allProcessedIDs;
end;</source>
        <access>protected</access>
        <Parameter name="_txnBucket" type="CM_TITransactionByTypeDateDict"/>
        <Parameter name="_voySummaryDict" type="CMIF_VoyageSummaryByValueDict" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="testOperator" id="85c085ad-8856-440a-aedb-f85cb1bec4ed">
        <source>testOperator(_isRestow: Boolean; _objOperatorCode: String): Boolean;
//----------------------------------------------------------------
//	Created:	17 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	//need to account for the fact we display rehandles under the voyage operator

	if self.myOperator &lt;&gt; self.getMyVoyage.myOperator then
		//exclude restow stuff
		if _objOperatorCode &lt;&gt; self.myOperator.code
		or _isRestow then
			return false;
		endif;
	else
		//always include restows when the report is for the voyage operator
		if not _isRestow
		and _objOperatorCode &lt;&gt; self.myOperator.code then
			return false;
		endif; 
	endif;
	
	return true;
end;</source>
        <Parameter name="_isRestow" type="Boolean"/>
        <Parameter name="_objOperatorCode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
