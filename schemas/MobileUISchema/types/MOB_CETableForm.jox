    <JadeMethod name="setupForm" id="b50a1b71-e373-4f02-89fa-d66e39070a8f">
        <updating/>
        <source>setupForm() updating, protected;
/*
	Created on 28 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	inheritMethod();
	self.setupItemTable(self.tbl_Items);
	self.loadTable;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupItemTable" id="bb9d42cc-9ea6-4201-894f-5be25ce4e795">
        <source>setupItemTable(tbl : CM_MobTable input);

/*
	Created on 28 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	intColumns 		: Integer;
	strHeader 		: String;
begin		
	self.getTableSettings(intColumns, strHeader);
	tbl.setMargins();
	tbl.selectMode := tbl.SelectMode_CurrentRow;
	tbl.fontSize := 14;
	
	tbl.columns := intColumns;
	tbl.rows := 0;
	tbl.addItem(strHeader);
	tbl.fixedRows := 1;
	tbl.defaultRowHeight := 30;
	tbl.accessRow(1);
	tbl.accessedRow.fontBold := true;

	tbl.gridLines := true;
	tbl.gridColor := Black;
	tbl.setUseHighlightColours(false);
	tbl.setFixedColours();
end;</source>
        <Parameter name="tbl" type="CM_MobTable" usage="input"/>
    </JadeMethod>
