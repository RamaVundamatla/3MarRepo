    <JadeMethod name="doTblDataDBClick" id="28674634-56ce-4873-9241-759ae7bc99cd">
        <updating/>
        <source>doTblDataDBClick(table: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2018	jlgndl1	Initial creation	TFS 41281

*/

vars

begin
	
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	if table.column &lt;= table.fixedColumns then
		return;
	endif;
	
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;
	
	self.showPropertyFrame();
	
epilog

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblDataRowColChange" id="9f16f0cd-6b7b-4090-8b26-3df13d64b3b8">
        <updating/>
        <source>doTblDataRowColChange(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2018	jlgndl1	Initial creation	TFS 41281

*/

vars

	theRow, theCol : Integer;
	payType : CM_ServicePayTypeMapping; 
	
begin

	self.myCurrentDebtor := null;
	self.myCurrentService := null;
	self.myCurrentPaymentType := null;
	self.myCurrentMapping := null; 
	
	inheritMethod(table);
	
	theRow := table.row;
	theCol := table.column;
	
	if theRow &gt; table.fixedRows then
		self.myCurrentService := table.accessRow(theRow).itemObject.CM_Service;
		if theCol &gt; table.fixedColumns then
			self.myCurrentDebtor := table.accessColumn(theCol).itemObject.CM_DebtorNode;
			payType := table.accessCell(theRow,theCol).itemObject.CM_ServicePayTypeMapping;
			self.myCurrentMapping := payType;
			if payType = null then
				self.myCurrentPaymentType := 0;
			else
				self.myCurrentPaymentType := payType.paymentType;
			endif;
			
		endif;
	endif;
	self.cmbDebtors.listIndex := self.cmbDebtors.findObject( self.myCurrentDebtor );
	self.cmbServices.listIndex := self.cmbServices.findObject(self.myCurrentService);
	self.cmbPaymentTypes.listIndex := self.cmbPaymentTypes.findStringExact( 1, app.paymentTypeEnumToString( self.myCurrentPaymentType ) );
	
	self.setEnableObjects();
		
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnEditItem.enabled := false;
	endif;
	
end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="haltProgress" id="b2ac16aa-66a4-45b9-9a49-799fcd6df8dc">
        <source>haltProgress(pe : CM_ProgressException; ls : Boolean io) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2018	jlgndl1	Initial creation

*/

vars

	wasSet : Boolean;
	
begin

	wasSet := ls;
	app.cmsEndLoad(ls);		

	if app.msgBox(self.myCurrentBank.getMsgString(WARN_CANCEL_PROGRESS ,
										"",
										"",""),
										"Cancel Progress",
										MsgBox_Exclamation_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then

		cmbDebtor.listIndex := 1;
		self.tblData.columns := 1;
		return Ex_Abort_Action;
	else
		if wasSet then
			app.cmsBeginLoad(ls);
		endif;
		return Ex_Continue;
	endif;

end;</source>
        <Parameter name="pe" type="CM_ProgressException"/>
        <Parameter name="ls" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
