    <JadeMethod name="doEIRSearch" id="262eb753-48c9-46c5-ab03-c32a9355a83f">
        <updating/>
        <source>doEIRSearch() protected, updating;
/*

Date		Who		Reason
21 January 2015	cnwer1	Initial creation PAR 35553 CCMS 1409
12 November 2018 jlgmd1 TFS 41068 - JMT - CardSchema monitoring for Web services

*/

vars
	iter : Iterator;
	eirNumber : CM_EIRNumber;
	ti	: CM_TrackedItem;
	breakOut		: Boolean;
	passport		: CM_Passport;
begin
	passport := app.myPassport;
	iter:=self.myTerminal.allEIRNumbers.createIterator;
	
	self.myTerminal.allEIRNumbers.startKeyGeq(self.eirNumber,iter);	
	while iter.next(eirNumber) do
		// Let JSA know we're still doing something
		app.sendHeartbeatIfRequired();
		
		if eirNumber.eirNumber &lt;&gt; self.eirNumber then
			break;
		endif;
		if eirNumber.myTrackedItem = null then
			continue;
		endif;
			
		ti:= eirNumber.myTrackedItem;
		if ti = null then
			continue;
		endif;
		
		self.addObjectToSet(ti);		
		if breakOut then
			break;
		endif;
		
	endwhile;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doNoSiteSearch" id="551b2dc6-9130-4f91-a815-916ef94e32fe">
        <updating/>
        <source>doNoSiteSearch() protected, updating;
// ---------------------------------------------------------------------------
// Created:     04 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
// 12 Nov 2018	jlgmd1	TFS 41068 - JMT - CardSchema monitoring for Web services
//  11/1/19 	jlger1		TFS 42829  -discreteLock added
vars
	tiSet			: CM_TISet;
	ti				: CM_TrackedItem;
	breakOut		: Boolean;
	passport		: CM_Passport;
	invalidObj		: Boolean;
begin
	
	passport := app.myPassport;
	
	create tiSet transient;
	if site = null then
		self.myTerminal.lookupAllTIsOfIdCargoType(self.id, self.cargoType, tiSet, self.searchArchivedVoyages, self.searchReversed, null);
	elseif site = SEL_QUERYSITE_ONSHIP then
	//  self.myTerminal.lookupAllOnShipTrackedItems(self.id, self.cargoType, true, false, tiSet, null);
	//	self.myTerminal.lookupAllOnShipTrackedItems(self.id, self.cargoType, true, true, tiSet, null);	//09 June 2011	NDL	Par 27684
		self.myTerminal.lookupAllOnShipTrackedItems(self.id, self.cargoType, true, self.searchArchivedVoyages, self.searchReversed, tiSet, null);	//02 Nov 2011	NDL	Par 28421
	endif;
	
	on Exception do app.handleDeletedObject(exception, ti, invalidObj);	// 25 June 2012	NDL	Par 29883
	foreach ti in tiSet discreteLock do
		// Let JSA know we're still doing something
		app.sendHeartbeatIfRequired();
		
		if self.includesObject(ti, breakOut, passport) then
			self.addObjectToSet(ti);
		endif;
		if breakOut then
			break;
		endif;
	endforeach;
epilog
	delete tiSet;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOnShipAltIdSearch" id="ce952a6b-c60f-4cae-86a0-3c13e7dc9b5f">
        <updating/>
        <source>doOnShipAltIdSearch() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Aug 2023	jlier1	Initial creation 59748
07 Mar 2024	navdap1	TFS 56853 CUX - MTN-EDBIC - 190 - Cargo Details Query
*/

vars
	startObject : CM_TrackedItem;
	iter : Iterator;
	ti : CM_TrackedItem;
	breakOut : Boolean;
	passport : CM_Passport;
	invalidObj : Boolean;
	exactMatch 	: Boolean;
	critLine 	: CM_SelectorCriteriaLine;
begin
	// TFS 56853 There is a chance we could get here without a voyage if an EDBIC query was sent with no site/state
	if self.myVoyage = null then
		self.doOnShipNoVoyageAltIdSearch();
		return;
	endif;
	// TFS 56853 end
	
	if self.myCriteriaLineHolder &lt;&gt; null then
		critLine := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::id.name);	
		if critLine &lt;&gt; null and critLine.myQueryOperator &lt;&gt; null then
			if critLine.myQueryOperator.isKindOf(CM_QStringEquals) then
				exactMatch:=true;
			endif;
		endif;
	endif;
	
	passport := app.myPassport;

	startObject := self.myVoyage.allOnshipTIsByAlternativeId.getAtKeyGeq(self.altId);
	if startObject &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, ti, invalidObj);
		iter := self.myVoyage.allOnshipTIsByAlternativeId.createIterator;
		iter.startAtObject(startObject);
		while iter.next( ti ) do
			// Let JSA know we're still doing something
			app.sendHeartbeatIfRequired();
			
			if ti.alternativeId &lt;&gt; self.altId then
				if exactMatch then
					break;
				endif;
				if not ti.alternativeId.startsWith( self.altId ) then
					break;
				endif;
			endif;
			if self.includesObject(ti, breakOut, passport) then
				self.addObjectToSet(ti);
			endif;
			if breakOut then
				break;
			endif;
		endwhile;
	endif;
	
epilog

	delete iter;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOnShipNoVoyageAltIdSearch" id="f9adaa36-02ab-4462-9b4a-3ca7e1d1b3de">
        <updating/>
        <source>doOnShipNoVoyageAltIdSearch() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/03/2024	navdap1		TFS 56853 CUX - MTN-EDBIC - 190 - Cargo Details Query
//
vars
	startObject : CM_TrackedItem;
	terminal : CM_Terminal;
	voyageIter, iter : Iterator;
	voyage : CM_Voyage;
	ti : CM_TrackedItem;
	breakOut : Boolean;
	passport : CM_Passport;
	invalidObj : Boolean;
	exactMatch : Boolean;
	critLine : CM_SelectorCriteriaLine;
	
begin
	if self.myCriteriaLineHolder &lt;&gt; null then
		critLine := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::id.name);
		if critLine = null then
			critLine := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::alternativeId.name);
		endif;
		if critLine &lt;&gt; null and critLine.myQueryOperator &lt;&gt; null then
			if critLine.myQueryOperator.isKindOf(CM_QStringEquals) then
				exactMatch := true;
			endif;
		endif;
	endif;
	
	passport := app.myPassport;
	terminal := passport.myTerminal;
	
	voyageIter := terminal.allVoyagesByCode.createIterator;
	while voyageIter.next(voyage) do
		
		startObject := voyage.allOnshipTIsByAlternativeId.getAtKeyGeq(self.altId);
		if startObject &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, ti, invalidObj);
			iter := voyage.allOnshipTIsByAlternativeId.createIterator;
			iter.startAtObject(startObject);
			while iter.next( ti ) do
				// Let JSA know we're still doing something
				app.sendHeartbeatIfRequired();
				
				if ti.alternativeId &lt;&gt; self.altId then
					if exactMatch then
						break;
					endif;
					if not ti.alternativeId.startsWith( self.altId ) then
						break;
					endif;
				endif;
				
				if self.includesObject(ti, breakOut, passport) then
					self.addObjectToSet(ti);
				endif;
				if breakOut then
					break;
				endif;
				
			endwhile;
			delete iter;
		endif;
		
	endwhile;
	
epilog
	delete iter;
	delete voyageIter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOnSiteAltIdSearch" id="6c7a1e86-649a-445f-b9f3-6c9392e0e57b">
        <updating/>
        <source>doOnSiteAltIdSearch()  updating;
/*

Purpose:			

Parameters:			Only want cargo onsite, where the alternativeId of the TI starts with 
					or exactly matches the value passed in...

Return Value:		

Date		Who		Reason
03 May 2013	cnwndl1	Initial creation	Par 31506
12 Nov 2018 jlgmd1	TFS 41068 - JMT - CardSchema monitoring for Web services
05 May 2022	jlier1	TFS 53249 - removed proteced - and check for criteria line where operator is = in that case should check that it is = not starts with
*/

vars
	startObject : CM_TrackedItem;
	iter : Iterator;
	ti : CM_TrackedItem;
	breakOut : Boolean;
	passport : CM_Passport;
	invalidObj : Boolean;
	cargoTypeObj : CM_CargoType;
	exactMatch 	: Boolean;
	critLine 	: CM_SelectorCriteriaLine;
begin
	
	if self.myCriteriaLineHolder &lt;&gt; null then
		critLine := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::id.name);	
		if critLine &lt;&gt; null and critLine.myQueryOperator &lt;&gt; null then
			if critLine.myQueryOperator.isKindOf(CM_QStringEquals) then
				exactMatch:=true;
			endif;
		endif;
	endif;
	
	passport := app.myPassport;
	
	//11 Jun 2015	NDL	Par 36338
	cargoTypeObj := app.myRoot.allCargoTypesById.getAtKey( self.cargoType );
	if cargoTypeObj = null or cargoTypeObj.isCargoGroup then
		startObject := self.myTerminal.allCargoGroupsByAlternativeID.getAtKeyGeq(self.altId);
		if startObject &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, ti, invalidObj);
			iter := self.myTerminal.allCargoGroupsByAlternativeID.createIterator;
			iter.startAtObject(startObject);
			while iter.next( ti ) do
				// Let JSA know we're still doing something
				app.sendHeartbeatIfRequired();
				
				if ti.alternativeId &lt;&gt; self.altId then
					if exactMatch then
						break;
					endif;
					if not ti.alternativeId.startsWith( self.altId ) then
						break;
					endif;
				endif;
				if self.includesObject(ti, breakOut, passport) then
					self.addObjectToSet(ti);
				endif;
				if breakOut then
					break;
				endif;
			endwhile;
			delete iter;
		endif;
	endif;
	
	startObject := self.myTerminal.allOnsiteTIsByAlternativeId.getAtKeyGeq(self.altId);
	if startObject &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, ti, invalidObj);
		iter := self.myTerminal.allOnsiteTIsByAlternativeId.createIterator;
		iter.startAtObject(startObject);
		while iter.next( ti ) do
			// Let JSA know we're still doing something
			app.sendHeartbeatIfRequired();
			
			if ti.alternativeId &lt;&gt; self.altId then
				if exactMatch then
					break;
				endif;
				if not ti.alternativeId.startsWith( self.altId ) then
					break;
				endif;
			endif;
			if self.includesObject(ti, breakOut, passport) then
				self.addObjectToSet(ti);
			endif;
			if breakOut then
				break;
			endif;
		endwhile;
	endif;
	
epilog

	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="b6122934-df31-4a3e-ab0f-bbf6dd9cbaa2">
        <updating/>
        <source>doQuery(_qDef: CM_QueryDefinition) updating;
// ---------------------------------------------------------------------------
// Created:     14 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
// 25/10/2017	jlgdap1	TFS 7523 SNO Selector query not allowing prenotified in "is one of"
// 24/05/2019	cnwma1	Bug 44837: SNO - Web Portal - Search cargo on ship by booking id
// 20/01/2020	jlgmd1	TFS 48287 SNO - Search by booking number not returning cargo items if voyage is different from booking
// 9 May 2022 	NAVVT20	ChangeRequest 53370: MTN - Make cargo enquiry over archived voyages optional in the UI
// 16 Jun 2025	navhl20 Bug MTN-35065: Selector Query - Days Passed
// 24 Jun 2025	navhl20 Defect MTN-35231: Selector Query - Cargo Transaction Days Passed less than 0 is not returning any data
vars
	results					: ObjectSet;
	crit					: CM_SelectorCriteriaLine;
	siteArray, 
	stateArray, 
	tempStateArray 			: IntegerArray;
	dictSelectArray			: IntegerArray;	//15 Jun 2015	NDL	Par 36347	
	voySet,
	importVoySet,
	exportVoySet,
	termSet,
	termAreaSet				: ObjectSet;
	theSite					: Integer;
	obj2,
	obj						: Object;
	voyage					: CM_Voyage;
	vesselSet				: CM_VesselSet;
	tmpVoyageCode			: String;
	now						: TimeStamp;
	cmCargoTpeObj 			: CM_CargoType;
	theState				: Integer;
	locId					: String;
	bolNum					: String;	
	foundHeight				: Integer;
begin

	self.reset();
	now := app.actualTimeServer();
	create siteArray transient;
	create stateArray transient;
	create tempStateArray transient;
	create dictSelectArray transient;
	create exportVoySet transient;  	//cnwrd1 par 25910 5.10.2010
	create importVoySet transient;		//cnwrd1 par 25910 5.10.2010
	
	//epr TFS 47132 16/12/19 
	crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::cargoType.name);

	if crit &lt;&gt; null and crit.myQueryOperator.isKindOf(CM_QIntegerLookupEqual) then
		self.cargoType := crit.myQueryOperator.getSearchValue().Integer;
		if self.cargoType &gt; 0 then
			cmCargoTpeObj := app.myRoot.allCargoTypesById.getAtKey( self.cargoType );
		endif;
	endif;
	
	//epr TFS 47132 16/12/19 
	crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::site.name);		
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsIntegerArr(siteArray);
		//15 Jun 2015	NDL	Par 36347
		if crit.myQueryOperator.isKindOf(CM_QIntegerLookupNotEqual) then
			theSite := siteArray.first; // there can only be one that its not equal to.
			if theSite &lt;&gt; TI_SITE_ONSITE then
				dictSelectArray.add( SEL_QUERYSITE_ONSITE );
			endif;
			if theSite &lt;&gt; TI_SITE_OFFSITE then
				dictSelectArray.add( SEL_QUERYSITE_OFFSITE );
			endif;
			if theSite &lt;&gt; TI_SITE_ONSHIP then
				dictSelectArray.add( SEL_QUERYSITE_ONSHIP );
			endif;
			if theSite &lt;&gt; TI_SITE_TBA then
				dictSelectArray.add( SEL_QUERYSITE_TBA );
			endif;
			if theSite &lt;&gt; TI_SITE_PLACEHOLDER then	//13 Mar 2020	NDL	TFS 47004
				dictSelectArray.add( SEL_QUERYSITE_PLACEHOLDER );
			endif;
			//if theSite &lt;&gt; SEL_QUERYSITE_NOTIFIED then	// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
			//if theSite &lt;&gt; TI_SITE_UNDEFINED then						// TFS 7523
			if theSite &lt;&gt; SEL_QUERYSITE_NOTIFIED then					// TFS 7523
				dictSelectArray.add( SEL_QUERYSITE_NOTIFIED );
			endif;
		else
			siteArray.copy( dictSelectArray );
		endif;
	endif;

	//epr par 32018 7/1/13
	crit :=self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::state.name);
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsIntegerArr( tempStateArray );
		if crit.myQueryOperator.isKindOf(CM_QIntegerLookupNotEqual) then
			theState := tempStateArray.first; // there can only be one that its not equal to.
			if theState &lt;&gt; TI_STATE_DELETED then
				stateArray.add( TI_STATE_DELETED );
			endif;
			if theState &lt;&gt; TI_STATE_EDI then
				stateArray.add( TI_STATE_EDI );
			endif;
			if theState &lt;&gt; TI_STATE_NORMAL then
				stateArray.add( TI_STATE_NORMAL );
			endif;
			if theState &lt;&gt; TI_STATE_OFFSITE then
				stateArray.add( TI_STATE_OFFSITE );
			endif;
			if theState &lt;&gt; TI_STATE_OFFLOADED then
				stateArray.add( TI_STATE_OFFLOADED );
			endif;
			if theState &lt;&gt; TI_STATE_ONSHIP then
				stateArray.add( TI_STATE_ONSHIP );
			endif;
			if theState &lt;&gt; TI_STATE_NOTIFIED then
				stateArray.add( TI_STATE_NOTIFIED );
			endif;
			if theState &lt;&gt; TI_STATE_UNDEFINED then
				stateArray.add( TI_STATE_UNDEFINED );
			endif;
		else
			tempStateArray.copy( stateArray );
		endif;
	endif;
	
	if not stateArray.isEmpty then
		self.setIsDeletedOnly( stateArray );	//21 Jan 2014	NDL	Par 33347
	else
		self.setIsDeletedOnly( null );			//21 Jan 2014	NDL	Par 33347
	endif;
	
	//epr TFS 47132 16/12/19
	create termSet transient;	
	self.myCriteriaLineHolder.getTerminals(termSet, app.myPassport);
	
	if termSet.size = 1 then
		self.myTerminal := termSet.first.CM_Terminal;
	endif;
	
	self.isPreNoteOnly := ( stateArray.size = 1 ) and ( stateArray.includes(TI_STATE_NOTIFIED) );	//20 Aug 2014	NDL	Par 34781
	
	// some states = site in selector site not state is used to determine which dict to search in 
	if stateArray.includes(TI_STATE_NOTIFIED) and  not dictSelectArray.includes(SEL_QUERYSITE_NOTIFIED)  then // AKB
		dictSelectArray.add(SEL_QUERYSITE_NOTIFIED);
	endif;
	if stateArray.includes(TI_STATE_TBA) and  not dictSelectArray.includes(SEL_QUERYSITE_TBA)  then
		dictSelectArray.add(SEL_QUERYSITE_TBA);
	endif;
	if stateArray.includes(TI_SITE_PLACEHOLDER) and  not dictSelectArray.includes(SEL_QUERYSITE_PLACEHOLDER)  then	//13 Mar 2020	NDL	TFS 47004
		dictSelectArray.add(SEL_QUERYSITE_PLACEHOLDER);
	endif;
	if stateArray.includes(TI_STATE_ONSHIP)  and not dictSelectArray.includes(SEL_QUERYSITE_ONSHIP) then
		dictSelectArray.add(SEL_QUERYSITE_ONSHIP);
	endif;
	if stateArray.includes(TI_STATE_NORMAL) and not dictSelectArray.includes(SEL_QUERYSITE_ONSITE) then
		dictSelectArray.add(SEL_QUERYSITE_ONSITE);		
	endif;
	if  stateArray.includes( TI_STATE_OFFSITE) and not dictSelectArray.includes(SEL_QUERYSITE_OFFSITE) then
		dictSelectArray.add(SEL_QUERYSITE_OFFSITE);
	endif;	
	
	//epr TFS 47132 19/12/19 noticed this state search does not
	if stateArray.size = 1 and (stateArray.includes(TI_STATE_TRANSFER_FROM) or stateArray.includes(TI_STATE_TRANSFER_TO)) then
		//do special search
		self.doTransferStateSearch(stateArray.first);
		return;
	endif;
	
	if dictSelectArray.size = 0 then
	//28 Aug 2014	NDL	Par 34762
	// if (app.activeForm &lt;&gt; null and app.activeForm.class.name = "CM_ContainerEnqForm") or self.containerEnqSearch then
	// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
		if  self.containerEnqSearch then
			dictSelectArray.add(0);	// just search the world including archived and deleted....	(Will use 'doNoSiteSearch')
		else
			// DVB changed 17/05/06
			dictSelectArray.add(SEL_QUERYSITE_ONSITE);
			dictSelectArray.add(SEL_QUERYSITE_ONSHIP);
			dictSelectArray.add(SEL_QUERYSITE_TBA);
			dictSelectArray.add(SEL_QUERYSITE_OFFSITE);
			dictSelectArray.add(SEL_QUERYSITE_NOTIFIED);	//14 Oct 2019	NDL	TFS 46959
			
			//jlier1 TFS 53423 26/5/22
			if cmCargoTpeObj &lt;&gt; null and cmCargoTpeObj.isLog then
				dictSelectArray.add(SEL_QUERYSITE_DELETED);
			endif;
		endif;
		
	endif;
	
	//15 Jun 2015	Par 36338
	if cmCargoTpeObj &lt;&gt; null and cmCargoTpeObj.productType = ProductType_CargoGroup then
		dictSelectArray.clear();
		dictSelectArray.add(SEL_QUERYSITE_CARGOGROUP);
	endif;
	
	
	
	if self.isDeletedOnly and termSet.size = 1 then
		self.myTerminal := termSet.first.CM_Terminal;
		self.doSearch();
		return;
	endif;

	create voySet transient;
	//epr TFS 47132 16/12/19
	crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::voyageCode.name);  
	if crit &lt;&gt; null then
	
		//28 Oct 2014	NDL	Par 35127 - ** Anywhere **, but for a specific voyage....
		if dictSelectArray.size = 1 and dictSelectArray.first = 0 and app.activeForm &lt;&gt; null and app.activeForm.class.name = "CM_ContainerEnqForm" then
			dictSelectArray.clear();
			dictSelectArray.add(SEL_QUERYSITE_ONSITE);
			dictSelectArray.add(SEL_QUERYSITE_ONSHIP);
			dictSelectArray.add(SEL_QUERYSITE_TBA);
			dictSelectArray.add(SEL_QUERYSITE_OFFSITE);
			dictSelectArray.add(SEL_QUERYSITE_NOTIFIED);		// 10/03/2015 cnwar2 #35836
		endif;
		
		//16 Apr 2012	NDL Par 29397
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_IsOneOf then
			//epr TFS 42829 11/1/19
			foreach tmpVoyageCode in crit.myQueryOperator.CM_QStringIsOneOf.allSelectionValues discreteLock do
				foreach obj in termSet do
					voyage := obj.CM_Terminal.lookupVoyage (tmpVoyageCode, null, true);
					if voyage &lt;&gt; null and not voySet.includes(voyage) then
						voySet.add(voyage);
					endif;
				endforeach;
			endforeach;
			
		elseif crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then
			tmpVoyageCode := crit.myQueryOperator.getSearchValue().String;
			foreach obj in termSet discreteLock do
				voyage := obj.CM_Terminal.lookupVoyage (tmpVoyageCode, null, true);
				if voyage &lt;&gt; null then
					voySet.add(voyage);
					break;
				endif;
			endforeach;
		endif;
	else
		//16/07/2010 cnwdz2 24667
		//epr TFS 47132 16/12/19
		crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::importVoyageCode.name);
		if crit &lt;&gt; null then
			if crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then
				tmpVoyageCode := crit.myQueryOperator.getSearchValue().String;
				foreach obj in termSet discreteLock do
					voyage := obj.CM_Terminal.lookupVoyage (tmpVoyageCode, null, true);
					if voyage &lt;&gt; null then
						importVoySet.add(voyage);
						break;
					endif;
				endforeach;
			endif;
		endif;
		//16/07/2010 cnwdz2 24667
	
		crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::exportVoyageCode.name);
		if crit &lt;&gt; null then
			if crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then
				tmpVoyageCode := crit.myQueryOperator.getSearchValue().String;
				foreach obj in termSet discreteLock  do
					voyage := obj.CM_Terminal.lookupVoyage (tmpVoyageCode, null, true);
					if voyage &lt;&gt; null then
						exportVoySet.add(voyage);
						break;
					endif;
				endforeach;
			endif;
		endif;
		
		// 20/01/2020 jlgmd1 TFS 48287 - Removed as this prevents finding cargo when the voyage on the booking is different from the tracked items
		//24.05.2019 cnwma1 Bug #44837
		/*crit :=self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::bookingReference.name);
		if crit &lt;&gt; null then
			if crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then
				bookingRefCode := crit.myQueryOperator.getSearchValue().String;
				bookingRef     := self.myTerminal.allBookingRefsByRef[bookingRefCode];
				if bookingRef &lt;&gt; null then
					if bookingRef.myVoyage &lt;&gt; null then
						voySet.add(bookingRef.myVoyage);
					endif;
				endif;
			endif;
		endif;*/
	endif;
	
	//cnwmc5 - 1 Sep 2015 - CCMS 1142
	if self.myTerminal &lt;&gt; null and voySet.size = 0 then
		crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::billOfLading.name);
		if crit = null then
			crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::receivalBOLNum.name);
		endif;
		if crit &lt;&gt; null then
			bolNum := crit.myQueryOperator.getSearchValueStr(crit.myQueryProperty);
			self.myTerminal.getBOLInsFromNumber(self.allBOLs, BOLType_Log, bolNum, true, null);
			self.myTerminal.getBOLOutsFromNumber(self.allBOLs, BOLType_Log, bolNum, true, null);
			if not self.allBOLs.isEmpty then	//24 May 2016	NDL TFS 2014
				self.doSearch();
				return;
			endif;
		endif;
	endif;
	
	create vesselSet transient;
	crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::vesselName.name);
	if crit &lt;&gt; null then
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_IsOneOf then
			crit.myQueryOperator.getSearchValueAsObjectSet(vesselSet);
		endif;
	endif;
	
	create termAreaSet transient;	
	crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::myTerminalArea.name);
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(termAreaSet);
	endif;
	
	//cnwmc5 - 1 Sep 2015 - CCMS 1142
	if self.myTerminal &lt;&gt; null and termAreaSet.size = 1 then
		self.myTerminalArea := termAreaSet.first.CM_TerminalAreaMaster;
		
		crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::locationId.name);
		if crit &lt;&gt; null then
			locId := crit.myQueryOperator.getSearchValueStr(crit.myQueryProperty);
			if locId &lt;&gt; null then
				self.myTerminal.findLocationFromString(self.myTerminalArea.id &amp; " " &amp; locId, true, self.myLocationsController, foundHeight);
				if self.myLocationsController &lt;&gt; null then		//24 May 2016	NDL TFS 2014
					self.doSearch();
					return;
				endif;
			endif;
		endif;
	endif;
	
	crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::id.name);
	if crit &lt;&gt; null and 
	   ( crit.myQueryOperator.isKindOf(CM_QStringEquals)
	   or crit.myQueryOperator.isKindOf(CM_QStringStartsWith)
	   or crit.myQueryOperator.isKindOf(CM_QStringEndsWith)			//15 May 2013	NDL	Par 31506
	   or crit.myQueryOperator.isKindOf(CM_QStringStartsOrEndsWith) //15 May 2013	NDL	Par 31506
	   ) then
	//	self.id := crit.myQueryOperator.getSearchValue().String;
		self.id := crit.myQueryOperator.getSearchValue().String[1:30];	//26 Feb 2020 TFS 48700
	endif;
	
	//03 May 2013	NDL	Par 31506
	crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::alternativeId.name);
	if (crit &lt;&gt; null) and
	   ((crit.myQueryOperator.isKindOf(CM_QStringEquals) or
	   (crit.myQueryOperator.isKindOf(CM_QStringStartsWith)))) then
		self.altId := crit.myQueryOperator.getSearchValue().String;
	endif;
	
	
	crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::releasedDT.name);
	if crit &lt;&gt; null then
		if CM_QDateEquals.hasInstance(crit.myQueryOperator) then
			self.releaseDTStart := crit.myQueryOperator.getSearchValue().TimeStamp;
			self.releaseDTEnd := crit.myQueryOperator.getSearchValue().TimeStamp;
			self.releaseDTEnd.setTime('23:59:59:999'.Time);
		elseif CM_QDateGreaterThan.hasInstance(crit.myQueryOperator) then
			self.releaseDTStart := crit.myQueryOperator.getSearchValue().TimeStamp;
			self.releaseDTEnd := now;
		elseif CM_QDateLessThan.hasInstance(crit.myQueryOperator) then
			self.releaseDTEnd := crit.myQueryOperator.getSearchValue().TimeStamp;
			self.releaseDTEnd.setTime('23:59:59:999'.Time);
			self.releaseDTStart := null;
		elseif CM_QDateRange.hasInstance(crit.myQueryOperator) then
			self.releaseDTStart := crit.myQueryOperator.CM_QDateRange.getSearchValueFromDate().TimeStamp;
			self.releaseDTEnd := crit.myQueryOperator.CM_QDateRange.getSearchValueToDate().TimeStamp;
			self.releaseDTEnd.setTime('23:59:59:999'.Time);
		elseif crit.myQueryOperator.isKindOf(CM_QDateDayLessThan) then								//16.06.2025 navhl20 #35065
			self.releaseDTStart := now.addDays(-crit.myQueryOperator.getSearchValue().Integer);		//03.07.2025 navhl20 #35231
			self.releaseDTStart.setTime('00:00'.Time);												//24.06.2025 navhl20 #35231
			self.releaseDTEnd := now;																//24.06.2025 navhl20 #35231
		elseif crit.myQueryOperator.isKindOf(CM_QDateDayGreaterThan) then							//16.06.2025 navhl20 #35065
			self.releaseDTEnd := now.addDays(-crit.myQueryOperator.getSearchValue().Integer);
			self.releaseDTEnd.setTime('23:59:59:999'.Time);											//24.06.2025 navhl20 #35231
			self.releaseDTStart := null;															//24.06.2025 navhl20 #35231
		elseif crit.myQueryOperator.isKindOf(CM_QDateDayRange) then									//16.06.2025 navhl20 #35065												
			self.releaseDTStart := now.addDays(-1 * crit.myQueryOperator.CM_QDateDayRange.getSearchToValue().Integer.max(crit.myQueryOperator.CM_QDateDayRange.getSearchFromValue().Integer));
			self.releaseDTStart.setTime('00:00'.Time);												//24.06.2025 navhl20 #35231
			self.releaseDTEnd := now.addDays(-1 * crit.myQueryOperator.CM_QDateDayRange.getSearchToValue().Integer.min(crit.myQueryOperator.CM_QDateDayRange.getSearchFromValue().Integer));
			self.releaseDTEnd.setTime('23:59:59:999'.Time);											//24.06.2025 navhl20 #35231
		endif;
	endif;
	
	//epr CCMS 1409 21/1/15 par 35553
	if self.myTerminal &lt;&gt; null and myTerminal.getConfig(UseReceiveReleaseEIR).Boolean then
		crit :=  self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::eirNumber.name);
		if (crit &lt;&gt; null) and
		   (crit.myQueryOperator.isKindOf(CM_QStringEquals)) then
		   self.eirNumber:=crit.myQueryOperator.getSearchValue().String;   
		   if self.eirNumber &lt;&gt; null then
				self.doEIRSearch();
				return;
			endif;		
		endif;
	endif;
	//02 Nov 2011	NDL	Par 28421
	crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::isVoyageArchived.name);
	if crit &lt;&gt; null and crit.myQueryOperator.isKindOf(CM_QIntegerIsOneOf) then
		self.searchArchivedVoyages :=  crit.myQueryOperator.getSearchValue().IntegerArray.includes( MsgBox_Return_Yes );
		
	//09 Apr 2021 TFS 51061/51043 - special condition Bish thinks we should handle.
	else
	//if voySet.isEmpty and exportVoySet.isEmpty and importVoySet.isEmpty and dictSelectArray.size = 1 and dictSelectArray.first = SEL_QUERYSITE_ONSHIP then		//11.05.2022 navvt20 53370
		//If no voyage is selected and we are only looking on-ship for cargo from the Cargo Enquiry, then include archived voyages.					//11.05.2022 navvt20 53370
		if not app.isBackGroundApp then		//navra1 - 10th Jan 2022 - TFS 56106 
			if app.activeForm &lt;&gt; null then		//11.05.2022 navvt20 53370
				//self.searchArchivedVoyages :=  true;		//11.05.2022 navvt20 53370
				self.searchArchivedVoyages :=   app.activeForm.getArchivedVoyages();		//11.05.2022 navvt20 53370
			endif;
		endif;								//navra1 - 10th Jan 2022 - TFS 56106 
	endif;
	
	foreach theSite in dictSelectArray discreteLock do
		self.site := theSite;
		//cnwmc5 - 19 Sep 2014 - PAR 34888
		if self.numItemsFoundLimit &gt;= 1 and self.numItemsFound &gt;= self.numItemsFoundLimit then
			break;
		endif;
		if (not termSet.isEmpty) and termAreaSet.isEmpty then
			foreach obj in termSet discreteLock do
				if (not voySet.isEmpty) then
					foreach obj2 in voySet discreteLock do
						self.myVoyage:= obj2.CM_Voyage;
						self.myTerminal := obj.CM_Terminal;
						self.doSearch();
					endforeach;
				elseif (not exportVoySet.isEmpty) then //16/07/2010 cnwdz2 24667
					foreach obj2 in exportVoySet discreteLock do
						self.myExportVoy := obj2.CM_Voyage;
						self.myImportVoy := null;
						self.myTerminal := obj.CM_Terminal;
						self.doSearch();
					endforeach;
				elseif (not importVoySet.isEmpty) then //16/07/2010 cnwdz2 24667
					foreach obj2 in importVoySet discreteLock do
						self.myImportVoy := obj2.CM_Voyage;
						self.myExportVoy := null;
						self.myTerminal := obj.CM_Terminal;
						self.doSearch();
					endforeach;
				else
					self.myTerminal := obj.CM_Terminal;					
					self.doSearch();
				endif;
			endforeach;
			
		elseif (not termAreaSet.isEmpty) then
			foreach obj in termAreaSet discreteLock do
				self.myTerminalArea := obj.CM_TerminalAreaMaster;
				self.myTerminal 	:= obj.CM_TerminalAreaMaster.myTerminal;
				self.doSearch();
			endforeach;
		endif;
	endforeach;

epilog
	endLoad;
	self.myContext := null;	//24 July 2014	NDL	Par 34625
	delete results;
	delete siteArray;
	delete termSet;
	delete termAreaSet;
	delete voySet;
	delete importVoySet;
	delete exportVoySet;
	delete vesselSet;
	delete stateArray;
	delete dictSelectArray;
	delete tempStateArray;
end;</source>
        <Parameter name="_qDef" type="CM_QueryDefinition"/>
    </JadeMethod>
    <JadeMethod name="doQueuedPlannedSearch" id="f690ad92-92a3-487b-9867-f071d65e8b35">
        <updating/>
        <source>doQueuedPlannedSearch():Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Feb 2020	jlgndl1	Initial creation	TFS 48724 - selector search using mode from YRD_LocationEnquiryFrm
30 Jun 2020	jlgdap1	TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
*/

vars

	ti : CM_TrackedItem;
	breakOut : Boolean;
	passport : CM_Passport;
	fm : CM_FutureMove;
	iter : Iterator;
	lc : CM_LocationsController;
	ta : CM_TerminalArea;
	crit : CM_SelectorCriteriaLine;
	taId : String;
	lcId : String;
	foundHeight : Integer;
	lcIter : Iterator;				// TFS 49453
	lcArray : ObjectArray;			// TFS 49453
	obj : Object;					// TFS 49453

begin

	if self.displayMode &lt;&gt; DISPLAY_MODE_PLAN and self.displayMode &lt;&gt; DISPLAY_MODE_QUEUE then
		return false;
	endif;
	
	crit := self.myCriteriaLineHolder.findCriteriaByName( CM_TrackedItem::getPlannedLocationDisplay.name );
	if crit &lt;&gt; null then
		lcId := crit.myQueryOperator.getSearchValue.String;
		if lcId &lt;&gt; null then
			self.myTerminal.findLocationFromString( lcId, true, lc, foundHeight);
		endif;
	endif;
	if lc = null then
		crit := self.myCriteriaLineHolder.findCriteriaByName( CM_TrackedItem::getQueuedLocationDisplay.name );
		if crit &lt;&gt; null then
			lcId := crit.myQueryOperator.getSearchValue.String;
			if lcId &lt;&gt; null then
				self.myTerminal.findLocationFromString( lcId, true, lc, foundHeight);
			endif;
		endif;
	endif;
	
	crit := self.myCriteriaLineHolder.findCriteriaByName( CM_TrackedItem::plannedTermAreaId.name );
	if crit &lt;&gt; null then
		taId := crit.myQueryOperator.getSearchValue.String;
		if taId &lt;&gt; null then
			ta := self.myTerminal.allTerminalAreaMastersById[ taId ].CM_TerminalArea;
		endif;
	endif;
	if ta = null then
		crit := self.myCriteriaLineHolder.findCriteriaByName( CM_TrackedItem::getQueuedTermAreaId.name );
		if crit &lt;&gt; null then
			taId := crit.myQueryOperator.getSearchValue.String;
			if taId &lt;&gt; null then
				ta := self.myTerminal.allTerminalAreaMastersById[ taId ].CM_TerminalArea;
			endif;
		endif;
	endif;
	
	if lc = null and ta = null  then
		return false;
	endif;

	passport := app.myPassport;

	
	if lc &lt;&gt; null then
		if self.displayMode = DISPLAY_MODE_PLAN then
			iter := lc.allPlannedFutureMoves.createIterator;
		elseif self.displayMode = DISPLAY_MODE_QUEUE then
			iter := lc.allQueuedFutureMoves.createIterator;
		endif;
		
		while iter.next( fm ) do
			ti := fm.getTrackedItem();
			if ti &lt;&gt; null then
				app.sendHeartbeatIfRequired();
				if self.allObjects.includes( ti ) then // can be planned to the same place more than once
					continue;
				endif;
				if self.includesObject(ti, breakOut, passport) then
					self.addObjectToSet(ti);
				endif;
				if breakOut	or self.breakOutOfSearch then
					break;
				endif;
			endif;
		endwhile;	
			
			
	elseif ta &lt;&gt; null then
		//foreach lc in ta.allLocationsControllers discreteLock do		// TFS 49453
		create lcArray transient;										// TFS 49453
		ta.getAllLocationsControllers(lcArray);							// TFS 49453
		foreach obj in lcArray do										// TFS 49453
			lc := obj.CM_LocationsController;							// TFS 49453
			if self.displayMode = DISPLAY_MODE_PLAN then
				iter := lc.allPlannedFutureMoves.createIterator;
			elseif self.displayMode = DISPLAY_MODE_QUEUE then
				iter := lc.allQueuedFutureMoves.createIterator;
			endif;
			while iter.next( fm ) do
				ti := fm.getTrackedItem();
				if ti &lt;&gt; null then
					app.sendHeartbeatIfRequired();
					if self.allObjects.includes( ti ) then // can be planned to the same place more than once
						continue;
					endif;
					if self.includesObject(ti, breakOut, passport) then
						self.addObjectToSet(ti);
					endif;
					if breakOut	or self.breakOutOfSearch then
						break;
					endif;
				endif;
			endwhile;
			delete iter;
		endforeach;
		
		
	endif;
	
	
	return true;

epilog

	delete iter; 
	delete lcArray;				// TFS 49453
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doReleaseDateSearch" id="b3936a61-1970-407b-b0e5-aba64fd49634">
        <updating/>
        <source>doReleaseDateSearch()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Jun 2025	navhl20 Defect MTN-35231: Selector Query - Cargo Transaction Days Passed less than 0 is not returning any data
22 Jul 2025	navhl20 Story MTN-35507: MTN - Improving performance of selector query for tracked item mode
*/

vars
	iteratorObj		: Iterator;
	ti				: CM_TrackedItem;
	breakOut		: Boolean;
	passport		: CM_Passport;
	tiSet			: CM_TISet;
	term			: CM_Terminal;
begin
	passport 	:= app.myPassport;
	term := self.myTerminal;
	
	if self.site = SEL_QUERYSITE_OFFSITE then
		if self.releaseDTStart.isValid then
			iteratorObj	:=	term.allOffsiteTIsByCargoTypeId.createIterator();
			term.allOffsiteTIsByCargoTypeId.startKeyGeq(self.cargoType, self.id, self.releaseDTStart, iteratorObj);
		else
			iteratorObj	:=	term.allOffsiteTIsByCargoTypeId.createIterator();
			term.allOffsiteTIsByCargoTypeId.startKeyLeq(self.cargoType, self.id, self.releaseDTEnd, iteratorObj);
		endif;
	elseif self.site = SEL_QUERYSITE_ONSHIP then
		if self.myVoyage &lt;&gt; null then
			iteratorObj	:=	self.myVoyage.allOnshipTIsByCargoTypeId.createIterator();
		else
			create tiSet transient;
			term.lookupAllOnShipTrackedItems(self.id, self.cargoType, true, self.searchArchivedVoyages, self.searchReversed, tiSet, null);
			iteratorObj := tiSet.createIterator();
		endif;
	elseif self.site = SEL_QUERYSITE_ONSITE then
		iteratorObj	:=	term.allOnsiteTIsByCargoTypeId.createIterator();
		term.allOnsiteTIsByCargoTypeId.startKeyLeq(self.cargoType, self.id, iteratorObj);
	else
		create tiSet transient;
		term.lookupAllTIsOfIdCargoType(self.id, self.cargoType, tiSet, self.searchArchivedVoyages, self.searchReversed, null);
		iteratorObj := tiSet.createIterator();
	endif;
	
	while iteratorObj.next(ti) do
		if not ti.releasedDT.isValid then
			continue;
		endif;
		
		if self.site = SEL_QUERYSITE_OFFSITE then
			if (self.releaseDTEnd.isValid and ti.releasedDT &gt; self.releaseDTEnd) then
				continue;
			endif;
		else
			if (self.releaseDTStart.isValid and ti.releasedDT &lt; self.releaseDTStart) then
				continue;
			endif;
			if (self.releaseDTEnd.isValid and ti.releasedDT &gt; self.releaseDTEnd) then
				continue;
			endif;
		endif;
		
		if self.includesObject(ti, breakOut, passport) then
			self.addObjectToSet(ti);
		endif;
			
		if breakOut or self.breakOutOfSearch then
			break;
		endif;
	endwhile;
epilog
	delete iteratorObj;
	if tiSet &lt;&gt; null then
		delete tiSet;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSearch" id="9a6a92ca-06ba-4ce0-92a3-2c61f56c2060">
        <updating/>
        <source>doSearch() updating, protected;
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/11/2018	jlgmd1		TFS 41068 - JMT - CardSchema monitoring for Web services
//  11/1/19 	jlger1		TFS 42829  - use getCurrentKeys for performance 
// 15/09/2023	navkc1		CR 60429 Task 60448: UI - Cargo Review UI Changes - VBS Slot Selector Query
// 05/02/2023	navkc1 		Bug 62766: FR | 53715 - Customs - Road exit - Cargo review Link to clear customs
// ---------------------------------------------------------------------------
vars

	idLength		: Integer;
	dict			: Dictionary;
	ti				: CM_TrackedItem;
	iter			: Iterator;
	haveId			: Boolean;
	tmpId,
	idKey			: String;
	cargoTypeKey	: Integer;
	dictHasDate		: Boolean;
	dateKey			: TimeStamp;
	obj				: Object;	
	breakOut		: Boolean;
	ls				: Boolean;
	passport		: CM_Passport;
	currentCargoType	: Integer;
	voyDict         : CM_TIByIdCargoTypeDict;
	noVoyageSelected : Boolean;
	
	tempDict1         : CM_TIByIdCargoTypeDictRev;
	tempDict2         : CM_TIByCargoTypeIdDictRev;
	
	//cnwmc5 - 1 Sep 2015 - CCMS 1142
	bol				: CM_BOL;
	crit					: CM_SelectorCriteriaLine;
	tiSet	 : CM_TISet;
	bookingRef 	: String;
	brXref			: CM_TerminalTIsByBR;
	wleSorter : CM_VoyageWLEDynaDict;
	wle : CM_WorkListEntry;
begin
	currentCargoType := self.cargoType;
	
	passport := app.myPassport;

	haveId 		 := (self.id &lt;&gt; null);
	//please note - endLoad state is handled in processDict which is called from getObjectsForDict - 
	//drops every 500 so should minimise locking issues
	app.cmsBeginLoad(ls);
	
	//15/09/2023	navkc1	CR 60429 Task 60448
	crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::getVBSExternalRef.name);
	if crit &lt;&gt; null then
		self.getVBSExtRefTI();
		return;
	endif;
	
	//05/02/2023	navkc1 Bug 62766 - If we have defined a VVR, get the TI collection from Terminal::allVehicleVisitsByNumDT, rather than going throgh all onsite TIs (time consuming);
	crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::getVehicleVisitNumber.name);
	if crit &lt;&gt; null then
		self.doSearchTiByVVR();
		return;
	endif;
	
	crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::releasedDT.name);
	if crit &lt;&gt; null then
		self.doReleaseDateSearch();
		return;
	endif;
	
	if self.site = SEL_QUERYSITE_ONSITE and altId &lt;&gt; null then
		self.doOnSiteAltIdSearch();
		return;
	endif;
	
	//jlier1 TFS 59748 17/8/23
	if self.site = SEL_QUERYSITE_ONSHIP and altId &lt;&gt; null then
		self.doOnShipAltIdSearch();
		return;
	endif;
	
	//28 Feb 2020	NDL	TFS 48724
	if self.doQueuedPlannedSearch then
		return;
	endif;
	
	if (self.site &lt;&gt; SEL_QUERYSITE_ONSHIP) and
	   self.myOperator &lt;&gt; null or 
	   self.myTerminalArea &lt;&gt; null or
	   self.myLocationsController &lt;&gt; null then
		self.getObjectsForDict(passport);
		return;
	endif;
	
	//cnwmc5 - 1 Sep 2015 - CCMS 1142
	if not self.allBOLs.isEmpty then
		foreach bol in self.allBOLs  discreteLock do
			foreach ti in bol.allTrackedItems discreteLock do
				// Let JSA know we're still doing something
				app.sendHeartbeatIfRequired();
				
				if self.includesObject(ti, breakOut, passport) then
					self.addObjectToSet(ti);
				endif;
				
				if breakOut	or self.breakOutOfSearch then
					break;
				endif;
			endforeach;
		endforeach;
		
		return;
	endif;
	
	//epr TFS 47132 13/12/19 was only done on Cargo Enquiry now do for any selector query to improve performance
	crit :=self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::bookingReference.name);
	if crit &lt;&gt; null then
		bookingRef:=crit.myQueryOperator.getSearchValueStr(crit.myQueryProperty);
	endif;
	if bookingRef  &lt;&gt; null then
		brXref := self.myTerminal.getBookingRefXref();
		if brXref &lt;&gt; null and brXref.xrefComplete then
			create tiSet transient;
			brXref.getTIsForBookingRef(bookingRef, true, tiSet, null);
			foreach ti in tiSet discreteLock do
				// Let JSA know we're still doing something
				app.sendHeartbeatIfRequired();
				
				if self.includesObject(ti, breakOut, passport) then
					self.addObjectToSet(ti);
				endif;
				
				if breakOut	or self.breakOutOfSearch then
					break;
				endif;
			endforeach;
			return;
		endif;
	endif;
	
	//jlier TFS 52028 18/11/21
	if self.myVoyageJob &lt;&gt; null then
		app.writeLog("Searching voyage job " &amp; self.myVoyageJob.id, LogDEBUG);
		create wleSorter transient;
		wleSorter.init(self.myVoyageJob.myVoyage,self.myVoyageJob );
		self.myVoyageJob .workListEntries.copy(wleSorter);
		
		foreach obj in wleSorter discreteLock  do
			ti:= obj.CM_WorkListEntry.myTrackedItem;
			if ti = null then
				continue;
			endif;
			// Let JSA know we're still doing something
			app.sendHeartbeatIfRequired();
			
			if self.includesObject(ti, breakOut, passport) then
				self.addObjectToSet(ti);
			endif;
			
			if breakOut or self.breakOutOfSearch then	// Par 17107	cnwvu1	June 2008
				break;
			endif;
		endforeach;
		return;
	endif;
	
	
//	if not self.isDeletedOnly then
	if not self.isDeletedOnly and not self.isPreNoteOnly then	//20 Aug 2014	NDL	Par 34781
		noVoyageSelected := ( self.myVoyage = null and self.myExportVoy = null and self.myImportVoy = null );	// 06 Sep 2012	NDL	Par 30330
		if ((self.site = null) and (self.myVoyage = null)) or 
			((self.site = SEL_QUERYSITE_ONSHIP and noVoyageSelected)) then	// 06 Sep 2012	NDL	Par 30330
			self.doNoSiteSearch();
			return;
		endif;
	endif; 

	
	endLoad;
	
	
//	if isDeletedOnly then	//21 Jan 2014	NDL	Par 33347
	if isDeletedOnly or self.site = SEL_QUERYSITE_DELETED then	//23 July 2014	NDL	Par 34625
		//dict := self.myTerminal.allDeletedTIsByCargoTypeId;
		dict := self.myTerminal.getDictForTISelector(SEL_QUERYSITE_DELETED, null, haveId, false);	//23 July 2014	NDL	Par 34625
		
	elseif self.myVoyage = null then
		create voyDict transient;
		if	self.myExportVoy &lt;&gt; null then
			if self.site = null then
				voyDict := self.myExportVoy.allExportTIs;
			else
				foreach ti in self.myExportVoy.allExportTIs discreteLock do
					if ti.site &lt;&gt; self.site then
						continue;
					endif;
					voyDict.add(ti);
				endforeach;
			endif;
			dict := voyDict;
		elseif self.myImportVoy &lt;&gt; null then
			if self.site = null then
				voyDict := self.myImportVoy.allImportTIs;
			else
				foreach ti in self.myImportVoy.allImportTIs discreteLock do
					if ti.site &lt;&gt; self.site then
						continue;
					endif;
					voyDict.add(ti);
				endforeach;
			endif;
			dict := voyDict;
		else
			dict := self.myTerminal.getDictForTISelector(self.site, self.myVoyage, haveId, false); //20/07/2010 cnwdz2 25088
		endif;
	else
		dict := self.myTerminal.getDictForTISelector(self.site, self.myVoyage, haveId, false);
	endif;

	if dict = null then
		return;
	endif;
	
	if haveId then
		// We have an id or part id so look for this
		tmpId	 := self.id;
		idLength := tmpId.length;
		iter := dict.createIterator;
		dictHasDate := false;
		if dict.isKindOf(CM_TIByIdCargoTypeDeletDict) or
		   dict.isKindOf(CM_TIByIdCargoTypeRelseDict) then
		   	dictHasDate := true;
			dict.startKeyGeq(tmpId, self.cargoType, null, iter);
			//epr par 36151 7/5/15
		elseif dict.isKindOf(CM_TIByCargoTypeIdRelseDict) then
			dict.startKeyGeq(self.cargoType,tmpId, null, iter);
		else
			dict.startKeyGeq(tmpId, self.cargoType, iter);
		endif;

		while iter.next(ti) do
			// Let JSA know we're still doing something
			app.sendHeartbeatIfRequired();
			
			idKey:= ti.id;
				
			if idKey[1 : idLength] &lt;&gt; tmpId then
				break;
			endif;
			
			if self.includesObject(ti, breakOut, passport) then
				self.addObjectToSet(ti);
			endif;
			
			if breakOut or self.breakOutOfSearch then	// Par 17107	cnwvu1	June 2008
				break;
			endif;
		endwhile;
		
		delete iter;

		
		//epr TFS 1856 20/4/16
		if cargoType &lt;&gt; TI_CargoType_Container then
			crit := self.myCriteriaLineHolder.allCriteriaByPropertyName['id', "CM_TrackedItem"];
		else
			crit := self.myCriteriaLineHolder.allCriteriaByPropertyName['id', "CM_Container"];
		endif;
		if crit &lt;&gt; null and 
		   ( crit.myQueryOperator.isKindOf(CM_QStringEquals)
		   or crit.myQueryOperator.isKindOf(CM_QStringStartsWith)) then
		   
		   //its a search by equals or starts with its pointless searching reversed dicts
		   return;
		endif;
		
		// now check the reversed dicts if there is one
		if isDeletedOnly or self.site = SEL_QUERYSITE_DELETED then	//23 July 2014	NDL	Par 34625
			dict := self.myTerminal.getDictForTISelector(SEL_QUERYSITE_DELETED, null, haveId, true);	//23 July 2014	NDL	Par 34625
		else
			//epr par 33310 16/1/14
			dict := self.myTerminal.getDictForTISelector(site, self.myVoyage, haveId, true);
		endif;
		
		if dict &lt;&gt; null then
			//08 May 2014	NDL	- found during general testing
			//No reversed dicts for voyage - create a temp one
			if dict.isKindOf(CM_TIByIdCargoTypeDict) then
				create tempDict1 transient;
				dict.copy(tempDict1);
				dict := tempDict1;
			elseif dict.isKindOf(CM_TIByCargoTypeIdDict) then
				create tempDict2 transient;
				dict.copy(tempDict2);
				dict := tempDict2;
			endif;
			
			tmpId := tmpId.reverse;
			iter := dict.createIterator;
			
			if dict.isKindOf(CM_TIByIdCargoTypeDeletDictRev) or
			   dict.isKindOf(CM_TIByIdCargoTypeRelseDictRev) then
			   	dictHasDate := true;
				dict.startKeyGeq(tmpId, self.cargoType, null, iter);
			else
				dictHasDate := false;
				dict.startKeyGeq(tmpId, self.cargoType,iter);
			endif;
			
			while iter.next(ti) do
				// Let JSA know we're still doing something
				app.sendHeartbeatIfRequired();
				
				if dictHasDate then
					iter.getCurrentKeys(idKey, cargoTypeKey, dateKey);
				else
					iter.getCurrentKeys(idKey, cargoTypeKey);
				endif;

				if idKey[1 : idLength] &lt;&gt; tmpId then
					break;
				endif;
				
				if (currentCargoType &lt;&gt; null and currentCargoType &lt;&gt; cargoTypeKey) then
					//break;
					continue;	//06 Nov 2013	NDL	Par 32910 - Don't break we might only be checking the first part so cargo type may change back...
				endif;
			
				if self.includesObject(ti, breakOut, passport) then
					self.addObjectToSet(ti);
				endif;
				
				if breakOut	or self.breakOutOfSearch then	// Par 17107	cnwvu1	June 2008
					break;
				endif;
			endwhile;
			
			delete iter;
		endif;
	else
		iter := dict.createIterator;
		if dict.isKindOf(CM_TIByCargoTypeIdDeletDict) or
		   dict.isKindOf(CM_TIByCargoTypeIdRelseDict) then
			dict.startKeyGeq(self.cargoType, null, null, iter);
			
			while iter.next(ti) do
				// Let JSA know we're still doing something
				app.sendHeartbeatIfRequired();
				
				iter.getCurrentKeys(cargoTypeKey, idKey, dateKey);
				
				if (currentCargoType &lt;&gt; null and currentCargoType &lt;&gt; cargoTypeKey) then
					break;
				endif;
				
				if self.includesObject(ti, breakOut, passport) then
					self.addObjectToSet(ti);
				endif;
				
				if breakOut or self.breakOutOfSearch then	// Par 17107	cnwvu1	June 2008
					break;
				endif;
			endwhile;
		else
			//16/07/2010 cnwdz2 24667
			if dict.isKindOf(CM_TIDictByIdCargoType) then
				dict.startKeyGeq(null, self.cargoType,iter);
			else
				dict.startKeyGeq(self.cargoType, null, iter);
			endif;
			
			while iter.next(ti) do
				// Let JSA know we're still doing something
				app.sendHeartbeatIfRequired();
			
				//16/07/2010 cnwdz2 24667
				if dict.isKindOf(CM_TIDictByIdCargoType) then
					iter.getCurrentKeys(idKey, cargoTypeKey);
				else
					iter.getCurrentKeys(cargoTypeKey, idKey);
					if (currentCargoType &lt;&gt; null and currentCargoType &lt;&gt; cargoTypeKey) then
						break;
					endif;
				endif;	
			
				if self.includesObject(ti, breakOut, passport) then
					self.addObjectToSet(ti);
				endif;
				
				if breakOut or self.breakOutOfSearch then	// Par 17107	cnwvu1	June 2008
					break;
				endif;
			endwhile;
		endif;
		delete iter;
	endif;

epilog
	endLoad;
	//16/07/2010 cnwdz2 24667

	delete voyDict;
	delete tempDict1;
	delete tempDict2;
	delete tiSet;
	delete iter;
	delete wleSorter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSearchTiByVVR" id="7ced8fc8-7177-4c65-ad82-239fed5f0328">
        <updating/>
        <source>doSearchTiByVVR() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/02/2023	navkc1 Bug 62766: FR | 53715 - Customs - Road exit - Cargo review Link to clear customs

*/

vars
	mergeIter	: SetMergeIterator;
	vvr			: CM_VehicleVisitRecord;
	crit		: CM_SelectorCriteriaLine;
	ti, tiob 			: CM_TrackedItem;
	hasTI,
	breakout	: Boolean;
	passport	: CM_Passport;
	qryOperator	: CM_QueryOperator;
	tiset : CM_TISet;
begin
	create mergeIter transient;
	
	passport := app.myPassport;
	crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::getVehicleVisitNumber.name);
	
	if crit &lt;&gt; null then
		qryOperator := crit.myQueryOperator;
	endif;
	
	if qryOperator = null then
		return;
	endif;
	
	// If we are looking for a particular VVR
	if qryOperator.isQStringEquals() then
		vvr := self.myTerminal.getVehicleVisitRecordByTran(qryOperator.getSearchValue().String);
		if vvr &lt;&gt; null then
			mergeIter.addCollection(vvr.allReceivedTrackedItems);
			mergeIter.addCollection(vvr.allReleasedTrackedItems);
			// Pre check do we have TI to process in the iter?
			hasTI := vvr.allReceivedTrackedItems.isNotEmpty() or vvr.allReleasedTrackedItems.isNotEmpty();
		endif;
		
	// Otherwise, loop through the collection
	else
		foreach vvr in self.myTerminal.allVehicleVisitsByNumDT discreteLock do
			if not qryOperator.doMatch(vvr.visitNumber) then
				continue;
			endif;
			
			mergeIter.addCollection(vvr.allReleasedTrackedItems);
			mergeIter.addCollection(vvr.allReceivedTrackedItems);
			
			// Pre check do we have TI to process in the iter?
			if not hasTI then
				hasTI := vvr.allReceivedTrackedItems.isNotEmpty() or vvr.allReleasedTrackedItems.isNotEmpty();
			endif;
			
		endforeach;
	endif;
	
	// If no TI then return;
	if not hasTI then
		return;
	endif;


	while mergeIter.next(ti) do
		if ti.site &lt;&gt; self.site then
			continue;
		endif;
		
		// ### TFS BUG 62837 11MAR2024 NAVAB1
		if ti.isChassis() then
			create tiset transient;
			ti.getAllOnboardTIs(tiset);
			foreach tiob in tiset discreteLock do
				if self.includesObject(tiob, breakout, passport) then
					self.addObjectToSet(tiob);
				endif;
			endforeach;
		endif;
		
		if self.includesObject(ti, breakout, passport) then
			self.addObjectToSet(ti);
		endif;
		
		if breakout then
			break;
		endif;
	endwhile;
	
epilog
	delete mergeIter;
	delete tiset; // ### TFS BUG 62837 11MAR2024 NAVAB1
end;</source>
    </JadeMethod>
    <JadeMethod name="doTransferStateSearch" id="a3f07077-509e-4110-b1eb-0865b1973b5e">
        <updating/>
        <source>doTransferStateSearch(_state : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2019	jlger1	Initial creation TFS 47132

*/

vars
	coll : Collection;
	iter : Iterator;
	obj : Object;
	invalidObj : Boolean;
	breakOut : Boolean;
	passport : CM_Passport;
	crit					: CM_SelectorCriteriaLine;
begin
	
	
	if _state = TI_STATE_TRANSFER_FROM then
		coll:= self.myTerminal.allInTransitTIsToByFromTypeId;
	elseif _state = TI_STATE_TRANSFER_TO  then
		coll:= self.myTerminal.allInTransitTIsFromByToTypeId;
	else
		return;
	endif;

	iter:=coll.createIterator();
	
	crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::state.name);
	if crit &lt;&gt; null and crit.isTransient then
		crit.setMyCriteriaLineHolder(null);
	endif;
	
	 on Exception do app.handleDeletedObject(exception, obj, invalidObj);	// 25 June 2012	NDL	Par 29883
	while iter.next(obj) do
		// Let JSA know we're still doing something
		app.sendHeartbeatIfRequired();
		
		if self.includesObject(obj.CM_Object, breakOut, app.myPassport) then
			self.addObjectToSet(obj.CM_Object);
		endif;
		if breakOut then
			break;
		endif;
	endwhile;
	if crit &lt;&gt; null and crit.isTransient then
		crit.setMyCriteriaLineHolder( self.myCriteriaLineHolder);
	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="_state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTxnSearch" id="2f81bb03-9052-4294-9406-d5c567bcce5f">
        <source>doTxnSearch() protected;
// ---------------------------------------------------------------------------
// Created:     17 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	txnSet		: ObjectSet;
begin
	create txnSet transient;
	self.myTerminal.getTITxnsForTypeAdvanced(TRANS_TYPE_REL_ROAD,
											self.releaseDTStart,
											self.releaseDTEnd,
											'includesObjectTxn',
											self,
											txnSet);
	
	self.myTerminal.getTITxnsForTypeAdvanced(TRANS_TYPE_REL_ROAD_INTER_TERM,
											self.releaseDTStart,
											self.releaseDTEnd,
											'includesObjectTxn',
											self,
											txnSet);

	self.myTerminal.getTITxnsForTypeAdvanced(TRANS_TYPE_REL_SHIP,
											self.releaseDTStart,
											self.releaseDTEnd,
											'includesObjectTxn',
											self,
											txnSet);
											
	self.myTerminal.getTITxnsForTypeAdvanced(TRANS_TYPE_REL_RAIL,
											self.releaseDTStart,
											self.releaseDTEnd,
											'includesObjectTxn',
											self,
											txnSet);
	
	self.myTerminal.getTITxnsForTypeAdvanced(TRANS_TYPE_REL_RAIL_INTER_TERM,
											self.releaseDTStart,
											self.releaseDTEnd,
											'includesObjectTxn',
											self,
											txnSet);
epilog
	delete txnSet;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getObjectsForDict" id="26df51bf-47a6-49f2-9b54-2121bb92dd12">
        <updating/>
        <source>getObjectsForDict(_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/11/2018	jlgmd1		TFS 41068 - JMT - CardSchema monitoring for Web services
//  11/1/19 	jlger1		TFS 42829  - use getCurrentKeys for performance 
// ---------------------------------------------------------------------------
vars
	breakOut,
	haveId			: Boolean;
	keyId,
	tmpId 			: String;
	keyType,
	idLength 		: Integer;
	iter 			: Iterator;
	ti 				: CM_TrackedItem;
	dict 			: CM_TIByIdCargoTypeDict;
	dictByCargoType	: CM_TIByCargoTypeIdDict;
begin

	haveId := (self.id &lt;&gt; null);
	if self.myOperator &lt;&gt; null or 
	   self.myTerminalArea &lt;&gt; null or 
	   self.myLocationsController &lt;&gt; null then
		create dict transient;
		self.processDict(dict);
	else
		return;
	endif;

	if dict &lt;&gt; null then
		if haveId then
			tmpId	 := self.id;
			idLength := tmpId.length;
			iter := dict.createIterator;
			dict.startKeyGeq(tmpId, self.cargoType, iter);
			while iter.next(ti) do
				iter.getCurrentKeys(keyId, keyType);
				if keyId[1 : idLength] &lt;&gt; tmpId then
					break;
				endif;
			//	if keyType = self.cargoType then
				if self.cargoType = 0 or keyType = self.cargoType then	//27 May 2013	NDL	Found while testing Break bulk changes.
					if self.includesObject(ti, breakOut, _passport) then
						self.addObjectToSet(ti);
					endif;
					if breakOut then
						break;
					endif;
				endif;
			endwhile;
			delete iter;
		else
			
			// DVB added. Pickup cargo type first.
			create dictByCargoType transient;
			dict.copy(dictByCargoType);
			iter := dictByCargoType.createIterator;
			dictByCargoType.startKeyGeq(self.cargoType, null, iter);
			while iter.next(ti) do
				iter.getCurrentKeys(keyType, keyId);
				if self.cargoType &lt;&gt; null then

					if keyType &lt;&gt; self.cargoType then
						break;
					endif;
				endif;
				
				if self.includesObject(ti, breakOut, _passport) then
					self.addObjectToSet(ti);
				endif;

				if breakOut then
					break;
				endif;
			endwhile;

			delete iter;
		endif;
	endif;
	
	// Let JSA know we're still doing something
	app.sendHeartbeatIfRequired();

epilog
	delete iter;
	delete dict;
	delete dictByCargoType;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getVBSExtRefTI" id="e125b4cb-e902-49ef-8ab1-aabcdf99185c">
        <updating/>
        <source>getVBSExtRefTI() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/09/2023	navkc1	CR 60429 Task 60448: UI - Cargo Review UI Changes - VBS Slot Selector Query
26 Aug 2024	navcs2	Bug 62476: MTN - CM_VehicleBookingTimeSlot allTiIds collection not updating
*/

vars
	terminal 			: CM_Terminal;
	vbs					: CM_VehicleBookingTimeSlot;
	vehBookingTerm 		: CM_VehicleBookingTerminal;
	ti,
	vbsItemTrackedItem	: CM_TrackedItem;
	vbsItem				: CM_VehicleBookingTimeSlotItem;
	breakout			: Boolean;
	tiset				: CM_TISet;
	tiId				: String;
	crit				: CM_SelectorCriteriaLine;
	cargoType			: Integer;
	vbsProcess 			: CM_VBSProcess;
	isAdvanced			: Boolean;
begin
	terminal 	:= self.myTerminal;
	
	if terminal = null then
		return;
	endif;
	
	if not terminal.isUsingVbsSlotValProcess then
		return;
	endif;
	
	vehBookingTerm := terminal.myVehicleBookingTerminal;
	
	if vehBookingTerm = null then
		return;
	endif;
	
	create tiset transient;
	
	crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::getVBSExternalRef.name);
	
	cargoType := self.cargoType;
	
	// 26 Aug 2024 navcs2	Bug 62476 Start
	foreach vbs in vehBookingTerm.allBookingsByTS discreteLock do
		foreach vbsItem in vbs.allVehicleBookingItems discreteLock do
			if vbsItem.myTrackedItem &lt;&gt; null then
				vbsItemTrackedItem := vbsItem.myTrackedItem;
			else
				continue;
			endif;
			
			if self.site = vbsItemTrackedItem.site then
				tiset.addNoDuplicates(vbsItemTrackedItem, false);
			elseif self.site = SEL_QUERYSITE_NOTIFIED and vbsItemTrackedItem.isNotified then
				tiset.addNoDuplicates(vbsItemTrackedItem, false);
			endif;
			foreach ti in tiset do
				if not crit.myQueryOperator.doMatch(ti.getVBSExternalRef()) then
					continue;
				endif;
				if self.includesObject(ti, breakout, app.myPassport) then
					self.addObjectToSet(ti);
				endif;
					
				if breakout then
					break;
				endif;
			endforeach;
		endforeach;
	endforeach;
	
epilog
	delete tiset;
end;</source>
    </JadeMethod>
    <JadeMethod name="includesObject" id="80d7933a-cb3c-438f-9169-ebb345c3301a">
        <updating/>
        <source>includesObject(_obj: CM_Object; _breakOut: Boolean output; _passport: CM_Passport input): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2022	jlier1	Initial creation 53022 - validate if for machine cargo query
16 Dec 2025	navah1	MTN-36672: POL | Vehicle Apps Driver Move Advanced Search Not Working
*/

vars
	continueExceptions : Boolean;
	allOverstowTIs : CM_TIArray;
	sideAccessDirection : Integer;
	overstowTI : CM_TrackedItem;
	isMatch : Boolean; //16.12.2025 navah1 #MTN-36672
begin
	if app.isWebApp and app.myPassport.myMachine &lt;&gt; null then
		//validate if should include
		on CM_Exception do app.validationExHandler(exception,app.myPassport);
		continueExceptions:=app.continueCMExceptions;
		
		if _obj.isKindOf(CM_TrackedItem) then
			if _obj.CM_TrackedItem.isChild then
				self.numItemsSearched := self.numItemsSearched + 1;
				return false;
			endif;
			app.setContinueCMExceptions(true);
			 app.myPassport.myMachine.validateForMove(null,_obj.CM_TrackedItem,false);
			app.setContinueCMExceptions(continueExceptions);
			 if app.myPassport.hasErrors then
					app.myPassport.clearErrorsWarnings();
					self.numItemsSearched := self.numItemsSearched + 1;
					
					return false;
			endif;
			
			isMatch := inheritMethod(_obj, _breakOut, _passport); //16.12.2025 navah1 #MTN-36672
			
			//jlier1 TFS 56538 20/2/22
			//if _obj.CM_TrackedItem.isOverStowedRTQueue(null) then           //16.12.2025 navah1 #MTN-36672
			if isMatch and _obj.CM_TrackedItem.isOverStowedRTQueue(null) then //16.12.2025 navah1 #MTN-36672
				create allOverstowTIs transient;																				
				_obj.CM_TrackedItem.getAllOverstowedTIs(allOverstowTIs,false,sideAccessDirection,null);											
				foreach overstowTI in allOverstowTIs discreteLock do	
						if not  self.allObjects.includes(overstowTI) then
							self.numItemsSearched := self.numItemsSearched + 1;
							self.addObjectToSet(overstowTI);
						endif;
				endforeach;
			endif;
			
			return isMatch; //16.12.2025 navah1 #MTN-36672
		endif;
	endif;

	return inheritMethod(_obj, _breakOut, _passport);

epilog
	delete allOverstowTIs;
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesObjectTxn" id="b79dfdbe-d451-4211-b0f0-471511de7c75">
        <updating/>
        <source>includesObjectTxn(_txn : CM_TITransaction; 
				_passport : CM_Passport input; 
				_breakOut : Boolean output) updating;
// ---------------------------------------------------------------------------
// Created:     17 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	ti			: CM_TrackedItem;
begin
	ti := _txn.myTrackedItem;
	if self.includesObject(ti, _breakOut, _passport) then
		self.addObjectToSet(ti);
	endif;

end;</source>
        <Parameter name="_txn" type="CM_TITransaction"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="processDict" id="bb5c6926-e591-4716-85bf-09ef739a58b6">
        <source>processDict(_dict : CM_TIByIdCargoTypeDict input) protected;
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 12/11/2018	jlgmd1		TFS 41068 - JMT - CardSchema monitoring for Web services
//  11/1/19 	jlger1		TFS 42829  - discreteLock because we are in load state
// ---------------------------------------------------------------------------
vars
	lc			: CM_LocationsController;
	ti			: CM_TrackedItem;
	lcSet 		: CM_LCSet;
	opTerm		: CM_OperatorTerminal;
	
begin
	
	if self.myOperator = null and 
	   self.myLocationsController = null and 
	   self.myTerminalArea = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 
							  'Error occurred while filtering tracked items. Operator and  Location are both null.', null, null);
		return;
	endif;	

	//Filter by yard location (site/state ignored)
	if self.myLocationsController &lt;&gt; null then
		self.myLocationsController.allTrackedItemsById.copy(_dict);
		endLoad;
		beginLoad;
		//Filter by yard location and operator
		if self.myOperator &lt;&gt; null then
			foreach ti in _dict discreteLock do
				if ti.myOperator &lt;&gt; self.myOperator then
					_dict.remove(ti);
				endif;
				//Also check the voyage if need be
				if self.myVoyage &lt;&gt; null then
					if ti.myVoyage &lt;&gt; self.myVoyage then
						_dict.remove(ti);
					endif;
				endif;
			endforeach;
		//Filter by yard location and voyage
		elseif self.myVoyage &lt;&gt; null then
			foreach ti in _dict discreteLock do
				if ti.myVoyage &lt;&gt; self.myVoyage then
					_dict.remove(ti);
				endif;
			endforeach;
		endif;
	//Filter by Terminal Area
	elseif self.myTerminalArea &lt;&gt; null then
		if self.myTerminalArea.isRail then	//27 May 2013	NDL	Not populating with correct data, found during Bulk break testing
			create lcSet transient;
			self.myTerminalArea.CM_Rail.getCurrentLocationsControllers( lcSet );
		else
			lcSet := self.myTerminalArea.getLCSet().CM_LCSet;
		endif;
		if lcSet &lt;&gt; null then
			foreach lc in lcSet  discreteLock do
				if self.myOperator &lt;&gt; null then
					//Filter by Terminal Area and Operator
					foreach ti in lc.allTrackedItemsById discreteLock do
						if ti.myOperator = self.myOperator then
							if self.myVoyage &lt;&gt; null then
								//Filter by Terminal Area -&gt; Operator and Voyage.
								if ti.myVoyage = self.myVoyage then									
									if not _dict.includes(ti) then
										_dict.add(ti);
									endif;
								endif;
							else
								if not _dict.includes(ti) then
									_dict.add(ti);
								endif;
							endif;
						endif;	
					endforeach;
				//Filter by Terminal Area and Voyage
				elseif self.myVoyage &lt;&gt; null then
					foreach ti in lc.allTrackedItemsById  discreteLock do
						if ti.myVoyage = self.myVoyage then
							if not _dict.includes(ti) then
								_dict.add(ti);
							endif;
						endif;
					endforeach;
				//Filter by Terminal Area
				else
					foreach ti in lc.allTrackedItemsById  discreteLock do
						if not _dict.includes(ti) then
							_dict.add(ti);
						endif;
					endforeach;
				endif;
			endforeach;
		endif;
	//Filter by Operator and site
	elseif self.myOperator &lt;&gt; null then
	
		opTerm := self.myOperator.allOperatorTerminals[self.myTerminal];
		if opTerm &lt;&gt; null then
			if self.site = SEL_QUERYSITE_ONSITE then
				opTerm.allOnsiteTIsByCargoTypeId.copy(_dict);
			elseif self.site = SEL_QUERYSITE_OFFSITE then
				opTerm.allOffsiteTIsByCargoTypeId.copy(_dict);
			else 
				opTerm.allDeletedTIsByCargoTypeId.copy(_dict);
			endif;
			//Filter by Voyage
			if self.myVoyage &lt;&gt; null then
				foreach ti in _dict discreteLock do
					if ti.myVoyage &lt;&gt; self.myVoyage then
						_dict.remove(ti);
					endif;
				endforeach;
			endif;
		endif;
		
	endif;
	
	// Let JSA know we're still doing something
	app.sendHeartbeatIfRequired();
epilog
	endLoad;				// 11/04/2011 cnwmh5 #27347
	if lcSet &lt;&gt; null and lcSet.isTransient() then
		delete lcSet;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_dict" type="CM_TIByIdCargoTypeDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="reset" id="9e22fa81-f455-44ac-87ea-0b1c4b1557bc">
        <updating/>
        <source>reset() updating;
// ---------------------------------------------------------------------------
// Created:     14 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
vars

begin
	inheritMethod();

	self.cargoType				:= 0;
	self.id						:= null;
	self.altId					:= null;	//15 May 2013	NDL	Par 31506
	self.myLocationsController	:= null;
	self.myOperator				:= null;
	self.myTerminal				:= null;
	self.myTerminalArea			:= null;
	self.myVoyage				:= null;
	self.releaseDTStart	:= null;
	self.releaseDTEnd	:= null;
	if not self.containerEnqSearch then	// this may have been set in the Container Enquiry which is not using criteria for archived voyages
		self.searchArchivedVoyages := false;	//02 Nov 2011	NDL	Par 28421
	endif;
	self.site					:= 0;
	
	//09 Oct 2014	NDL	Par 35042
	self.myImportVoy := null;
	self.myExportVoy := null;
	
	//cnwmc5 - 1 Sep 2015 - CCMS 1142
	self.allBOLs.clear();

end;</source>
    </JadeMethod>
    <JadeMethod name="setIsDeletedOnly" id="b4022c6c-3c8c-42d3-8783-26406a245e3f">
        <updating/>
        <source>setIsDeletedOnly( _states : IntegerArray ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2014	cnwndl1	Initial creation	Par 33347

*/

vars

begin

	self.isDeletedOnly := false;
	
	if _states &lt;&gt; null then
		if _states.size = 1 then
			if _states[1] = TI_STATE_DELETED then
				self.isDeletedOnly := true;
			endif;
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_states" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="setMyFilterClass" id="e9c1110b-3fed-42e0-97c7-816d5e30db23">
        <updating/>
        <source>setMyFilterClass() updating;
// ---------------------------------------------------------------------------
// Created:     14 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.myFilterClass := CM_TrackedItem; 


end;</source>
    </JadeMethod>
</Class>
