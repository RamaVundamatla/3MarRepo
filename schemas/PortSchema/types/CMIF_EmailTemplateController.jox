        <type name="CM_EmailEntityByTypeNameDict"/>
    </ImplicitInverseRef>
    <PrimAttribute name="freeTxtBccAddesses" id="b4652c59-5d04-4d82-85c5-d57a9dff0284">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="freeTxtCcAddesses" id="8a26224e-b34d-413d-bcd0-c7941577918a">
