<Class name="CM_LocationCheck" id="7ee5bb39-c480-4f8a-838b-3c82fdc9eac5">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <PrimAttribute name="actualLocation" id="06b9a4a3-a89e-415e-918f-7a197c5e20e8">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="expectedLocation" id="76421cae-aac2-4f16-b4bf-fe729da435ae">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getCheckString" id="36629a3e-f237-4868-93b7-71a29dbf441a">
        <source>getCheckString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	lDetail : String;

begin

	if self.expectedLocation &lt;&gt; null then
		if self.actualLocation &lt;&gt; null then
			if self.expectedLocation = self.actualLocation then
				lDetail := app.getErrorString(Verified);
			else
				lDetail := app.getErrorString(Extra);
			endif;
		else
			lDetail := app.getErrorString(Missing);
		endif;
	endif;
	
	return lDetail;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="ddbbf00d-8264-42a5-8e7d-965813ed4d9c">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	lDetail : String;

begin

	if _attrName = ETRow_Details  then
	
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			lDetail := self.typeString &amp; ": ";
			if self.expectedLocation &lt;&gt; null then
				if self.actualLocation &lt;&gt; null then
					lDetail := lDetail &amp; app.getErrorString2(Expected_scanned,self.expectedLocation,self.actualLocation);
				else
					lDetail := lDetail &amp; app.getErrorString2(Expected_not_scanned,self.expectedLocation,self.expectedLocation);
				endif;
				lDetail := lDetail &amp; " (" &amp; self.getCheckString &amp; ")";
			endif;
			
			return lDetail;
			
		endif;

	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="714bb0a9-f6e5-4644-bc3d-8d96f9003267">
        <source>getEnquiryRow(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	lDetail : String;

begin

	lDetail := inheritMethod();
	return lDetail;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="5c0f08ed-5014-491d-b062-a268e4472eaa">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_LocationCheckController; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

begin

	self.actualLocation := _tiTransCntrl.actualLocation;
	self.expectedLocation := _tiTransCntrl.expectedLocation;
	
	inheritMethod(_tiTransCntrl, _passport);

epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_LocationCheckController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
