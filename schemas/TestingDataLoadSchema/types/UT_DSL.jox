    <JadeMethod name="transactionMapLoad" id="5ca3c7b8-1fe7-41c5-a132-aa85fbfa395d">
        <source>transactionMapLoad(_text : String; _userDefinedName : String);
// May 2010		cnwjre1

vars
	loadFile : File;
	fileName : String;
	la 		 : CM_InvoiceTranMapFileLoadAgent;
	bank	 : CM_Bank;
begin

	fileName := "TM_LOAD " &amp; _userDefinedName &amp; ".csv";
	fileName.replaceChar(' ', '_');
	create loadFile transient;
	loadFile.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
	loadFile.openOutput(fileName);
	loadFile.writeString(_text);
	loadFile.close;
	
	app.writeLog(method.qualifiedName() &amp; Tab &amp; "isFileOpen 1: " &amp; loadFile.isOpen().String, LogINFO);

	bank := app.myPassport.myTerminal.getDefaultCompanyBank();	// 35872

	create la;
	la.myTerminal := app.myPassport.myTerminal;
	app.writeLog(method.qualifiedName() &amp; Tab &amp; "isFileOpen 2: " &amp; loadFile.isOpen().String, LogINFO);
	la.doLoadCSVFile(bank, fileName, true);	// files on client

epilog
	delete loadFile;
	delete la;
end;</source>
        <Parameter name="_text" type="String"/>
        <Parameter name="_userDefinedName" type="String"/>
    </JadeMethod>
    <JadeMethod name="transientMethodToRun" id="897242e0-3297-4c1d-85e3-b56ffa822925">
        <updating/>
        <source>transientMethodToRun() updating;


vars
	
	machine				: CM_Machine;
	terminal					: CM_Terminal;

	isPasswordCompulsary		: Boolean;
	useSerialConnection		: Boolean;
	useLocalTCP				: Boolean;


begin
		self.opts.purge();
	self.opts.addAssoc("Terminal", "TT1");

	terminal := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(app.myRoot.allTerminals["TT1"]);

	self.addRTDevice("HAND HELD", "700", "Hand Held 1", "", machine, false.Boolean, false.Boolean, false.Boolean);

	self.opts.purge();
	self.opts.addAssoc("Terminal", "TT1");

	terminal := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(app.myRoot.allTerminals["TT1"]);

	self.addRTDevice("HAND HELD", "701", "Hand Held 2", "", machine, false.Boolean, false.Boolean, false.Boolean);

	self.opts.purge();
	self.opts.addAssoc("Terminal", "TT1");

	terminal := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(app.myRoot.allTerminals["TT1"]);

	self.addRTDevice("HAND HELD", "702", "Hand Held 3", "", machine, false.Boolean, false.Boolean, false.Boolean);

	self.opts.purge();
	self.opts.addAssoc("Terminal", "TT1");

	terminal := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(app.myRoot.allTerminals["TT1"]);

	self.addRTDevice("HAND HELD", "703", "Hand Held 4", "", machine, false.Boolean, false.Boolean, false.Boolean);

	self.opts.purge();
	self.opts.addAssoc("Terminal", "TT1");

	terminal := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(app.myRoot.allTerminals["TT1"]);

	self.addRTDevice("HAND HELD", "705", "Hand Held 5", "", machine, false.Boolean, false.Boolean, false.Boolean);


epilog
		app.myPassport.setMyTerminal(terminal);

end;</source>
    </JadeMethod>
    <JadeMethod name="uCreateEDIFileTypeUser" id="74d7abdb-5c21-43fa-ab23-a5b7614cb3ef">
        <source>uCreateEDIFileTypeUser(_pxyFileTypeName: CM_EDIFileTypeUser): CM_EDIFileTypeUser;
/*

Purpose:			

Parameters:			Migrated up from UT_DSL

Return Value:		

Date		Who		Reason
16 February 2016	cnwndl1	Initial creation

*/

vars
	realFileTypeUser 	: CM_EDIFileTypeUser;
begin
	realFileTypeUser	:= app.myRoot.allEDIFileTypes[ EDIFileType_UserDefined, _pxyFileTypeName.name ].CM_EDIFileTypeUser;
	if realFileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser( realFileTypeUser, app.myPassport );
		self.assertIsDeleted( realFileTypeUser );
		self.assertTrue(app.myPassport.trxCompletedOK());
	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(realFileTypeUser, _pxyFileTypeName, app.myPassport);
	realFileTypeUser	:= app.myRoot.allEDIFileTypes.getAtKey( EDIFileType_UserDefined, _pxyFileTypeName.name ).CM_EDIFileTypeUser;
	self.assertNotNullMsg(realFileTypeUser, 'User Type ' &amp; _pxyFileTypeName.name &amp; ' is missing');
	
	return realFileTypeUser;
epilog
end;</source>
        <Parameter name="_pxyFileTypeName" type="CM_EDIFileTypeUser"/>
        <ReturnType type="CM_EDIFileTypeUser"/>
    </JadeMethod>
    <JadeMethod name="unmarkSlotsAsLoadJob" id="da2a3005-a8bd-4f0d-87f5-e3b4d8f1c025">
        <source>unmarkSlotsAsLoadJob(_allSlots : CM_SlotControllerArray);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2008	cnwer1	Initial creation

*/

vars
	allObjectEditions : CM_ObjectByOidEditionDict;
