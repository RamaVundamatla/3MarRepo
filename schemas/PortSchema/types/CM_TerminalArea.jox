    <JadeMethod name="actAsReleasePoint" id="6a8bbf3d-a719-47c6-b892-d0d8abc8fd20">
        <methodInvocation>mapping</methodInvocation>
        <source>actAsReleasePoint(_set: Boolean; _value: Integer io) mapping;

//25/02/2010 cnwcs5 remove VTA references
vars

begin
	
	if _set then
		return;
	endif;
	
	if self.actAsReleasePoint &lt;&gt; 0 then
		_value := self.actAsReleasePoint;
		return;
	endif;		
	if self.isKindOf(CM_CraneTransferArea) then
		_value := 1;
		return;
	endif;
	if self.type = TA_TYPE_RAIL_TRANS then //or self.type = TA_TYPE_ROAD_TRANS then 25/02/2010 cnwcs5 remove VTA references
		_value := 1;
		return;
	endif;
	//NFS 3833; Transfer Areas are always release points
	if self.type = TA_TYPE_RECTRANS or self.type = TA_TYPE_RELTRANS then
		_value := 1;
		return;
	endif;
	_value := 0;
end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
