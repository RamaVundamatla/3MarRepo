<Class name="Node">
    <JadeMethod name="getTotalAndAvailableMemory" id="2eabeab1-8768-4215-8059-624286bde2d2">
        <source>getTotalAndAvailableMemory(total, avail : Integer output);

vars
	b : Binary;
	
begin
	b[1 : 256] := 0.Binary;

	// Get the memory status for the local machine. If we're running thin
	// client, this call will get the memory status for the app server.
	call winGlobalMemoryStatus(b);
	
	total := b[9 : 4].Integer;
	avail := b[13 : 4].Integer;
end;</source>
        <Parameter name="total" type="Integer" usage="output"/>
        <Parameter name="avail" type="Integer" usage="output"/>
    </JadeMethod>
</Class>
