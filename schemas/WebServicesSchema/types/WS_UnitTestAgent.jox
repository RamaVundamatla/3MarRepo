    <JadeMethod name="wsGetJobDetails" id="c34baa9b-579b-4262-9b27-71b477644604">
        <source>wsGetJobDetails(_job, _queryParamString : String; _response: String io):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Oct 2024 navhl20 Bug 32981 EUP - Todo Tasks Job complete for Partial Receive and Release Work orders

*/

vars
	ref 				: String;
	webService 			: MTNInternalAPIService;
	response			: WS_Response; 
	terminalCode  		: String;
	token 				: String;
	loginJson 			: String;
	dict 				: WS_QueryStringParamDict;
	jsonHelper 			: JMTJadeJson;
begin
	// Web service call
	create webService transient;
	
	terminalCode := self.UT_TERMINAL_CODE;
	
	if app.myRoot.allTerminals[terminalCode] = null then
		return "UT Terminal not found!";
	endif;	
	
	loginJson := '{
   "userId": "' &amp; self.USERCODE &amp; '",
   "password": "' &amp; self.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; terminalCode &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	
	self.wsRESTLogin(loginJson, token);
	
	webService.qsData.parseNameValuePair(_queryParamString);
	
	if token &lt;&gt; null then				
		webService.unitTestData.addAssoc("HTTP_AUTHORIZATION", token);
	endif;
	
	response := webService.getJobDetails(_job);
	create jsonHelper transient;
	_response := jsonHelper.generateJson(response.WS_Response, JadeJson.Format_Json_Microsoft);	
	
	if response = null then
		return "test 1, trackeditem not Loaded successfully";
	endif;
	if response.hasErrors then
		return "test 2, " &amp; response.getErrorsAsStringForTesting;
	endif;
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsGetJobDetails.name;
epilog
	webService.unitTestData.removeAssoc("HTTP_AUTHORIZATION");
	response.WS_RestIntJobsResponse.allJobs.first.allRequests.purge();
	response.WS_RestIntJobsResponse.allJobs.purge();
	delete response;
	app.myProxyManager.allProxies.purge();
	if webService.objectsToBeDeleted.isNotEmpty then
		webService.objectsToBeDeleted.purge;
	endif;
	dict := webService.qsData;
	dict.purge();
	delete webService;
	delete jsonHelper;
end;</source>
        <Parameter name="_job" type="String"/>
        <Parameter name="_queryParamString" type="String"/>
        <Parameter name="_response" type="String" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsGetLogRows" id="ad148135-5b56-46bf-8630-7ab75fb16df4">
        <source>wsGetLogRows(_terminal : CM_Terminal): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/03/2016	cnwdap1		Initial creation PAR #37675 Check for transient leaks in the getLogRows service
//
vars
	ref : String;
	queryRequestLogRows : WS_LogRowsQueryRequest;
	queryResponseLogRows : WS_LogRowsResponse;
	queryRequestFindLog : WS_LogQueryRequest;
	queryResponseFindLog : WS_LogResponse;
	queryReqService : JMTUserInterfaceService;
	totalFound : Integer;
	id : String;
	log : CM_TrackedItem;
	logOid : String;
	iter : Iterator;

begin
	if app.name &lt;&gt; "JMTUnitTest" and app.name &lt;&gt; "JMTUnitTestRunner" then
		return "Pre-test check: App.name = '" &amp; app.name &amp; "' test will fail...";
	endif;

	// Query all log rows for terminal
	create queryRequestLogRows transient;
	queryRequestLogRows.setPropertyValue(WS_LogRowsQueryRequest::filterTerminal.name, _terminal.code);
	queryRequestLogRows.setPropertyValue(WS_LogRowsQueryRequest::filterOperator.name, Any_String);
	queryRequestLogRows.setPropertyValue(WS_LogRowsQueryRequest::filterStatus.name, CMIF_LogRowQuery.Status_Open_Only);
	queryRequestLogRows.maxReturnedItems := 0;
	queryRequestLogRows.startFrom := 0;
	
	create queryReqService transient;
	queryResponseLogRows := queryReqService.getLogRows(queryRequestLogRows);
	if queryResponseLogRows = null then
		return _terminal.code &amp; " test 1, queryResponse not returned.";
	endif;
	if queryResponseLogRows.hasErrors then
		return _terminal.code &amp; " test 2, " &amp; queryResponseLogRows.getErrorsAsStringForTesting;
	endif;
	if queryResponseLogRows.allLogRows.isEmpty then
		return _terminal.code &amp; " test 3, queryResponse no log rows found, probably wrong.";
	endif;
	delete queryResponseLogRows;
	
	// Query all log rows for an operator 
	queryRequestLogRows.setPropertyValue(WS_LogRowsQueryRequest::filterOperator.name, "ULOG");
	queryResponseLogRows := queryReqService.getLogRows(queryRequestLogRows);
	if queryResponseLogRows = null then
		return _terminal.code &amp; " test 4, queryResponse not returned.";
	endif;
	if queryResponseLogRows.hasErrors then
		return _terminal.code &amp; " test 5, " &amp; queryResponseLogRows.getErrorsAsStringForTesting;
	endif;
	if queryResponseLogRows.allLogRows.isEmpty then
		return _terminal.code &amp; " test 6, queryResponse no log rows found, probably wrong.";
	endif;
	delete queryResponseLogRows;
	
	// Query all log rows for a log species
	queryRequestLogRows.setPropertyValue(WS_LogRowsQueryRequest::filterOperator.name, Any_String);
	queryRequestLogRows.setPropertyValue(WS_LogRowsQueryRequest::filterLogSpecies.name, "OAK");
	queryResponseLogRows := queryReqService.getLogRows(queryRequestLogRows);
	if queryResponseLogRows = null then
		return _terminal.code &amp; " test 7, queryResponse not returned.";
	endif;
	if queryResponseLogRows.hasErrors then
		return _terminal.code &amp; " test 8, " &amp; queryResponseLogRows.getErrorsAsStringForTesting;
	endif;
	if queryResponseLogRows.allLogRows.isEmpty then
		return _terminal.code &amp; " test 9, queryResponse no log rows found, probably wrong.";
	endif;
	delete queryResponseLogRows;
	
	// Query all log rows for a log length
	queryRequestLogRows.setPropertyValue(WS_LogRowsQueryRequest::filterLogSpecies.name, null);
	queryRequestLogRows.setPropertyValue(WS_LogRowsQueryRequest::filterLogLength.name, "8.0");
	queryResponseLogRows := queryReqService.getLogRows(queryRequestLogRows);
	if queryResponseLogRows = null then
		return _terminal.code &amp; " test 10, queryResponse not returned.";
	endif;
	if queryResponseLogRows.hasErrors then
		return _terminal.code &amp; " test 11, " &amp; queryResponseLogRows.getErrorsAsStringForTesting;
	endif;
	if queryResponseLogRows.allLogRows.isEmpty then
		return _terminal.code &amp; " test 12, queryResponse no log rows found, probably wrong.";
	endif;
	delete queryResponseLogRows;
	
	// Query all log rows for "docket checked"
	queryRequestLogRows.setPropertyValue(WS_LogRowsQueryRequest::filterLogLength.name, null);
	queryRequestLogRows.setPropertyValue(WS_LogRowsQueryRequest::filterIsDocketChecked.name, "true");
	queryResponseLogRows := queryReqService.getLogRows(queryRequestLogRows);
	if queryResponseLogRows = null then
		return _terminal.code &amp; " test 13, queryResponse not returned.";
	endif;
	if queryResponseLogRows.hasErrors then
		return _terminal.code &amp; " test 14, " &amp; queryResponseLogRows.getErrorsAsStringForTesting;
	endif;
	if queryResponseLogRows.allLogRows.isEmpty then
		return _terminal.code &amp; " test 15, queryResponse no log rows found, probably wrong.";
	endif;
	delete queryResponseLogRows;
	
	// now try a findLogs query
	// find a log in the terminal
	iter := _terminal.allOnsiteTIsByCargoTypeId.createIterator;
	_terminal.allOnsiteTIsByCargoTypeId.startKeyGeq(TI_CargoType_Log, null, iter);
	while iter.next(log) do
		if log.isKindOf(CM_Log) then
			logOid := log.getOidString;
		endif;
		break;
	endwhile;
	if logOid = null then
		return _terminal.code &amp; " test 16, no logs found - this is probably wrong";
	endif;
	create queryRequestFindLog transient;
	queryRequestFindLog.setPropertyValue(WS_LogQueryRequest::filterOID.name, logOid);
	queryResponseFindLog := queryReqService.findLogs(queryRequestFindLog);
	if queryResponseFindLog = null then
		return _terminal.code &amp; " test 17, queryResponse not returned.";
	endif;
	if queryResponseFindLog.hasErrors then
		return _terminal.code &amp; " test 18, " &amp; queryResponseFindLog.getErrorsAsStringForTesting;
	endif;
	if queryResponseFindLog.allLogs.isEmpty then
		return _terminal.code &amp; " test 19, queryResponse no log found, probably wrong.";
	endif;
	delete queryResponseFindLog;
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsGetLogRows.name; 

epilog
	delete queryRequestLogRows;
	delete queryResponseLogRows;
	delete queryRequestFindLog;
	delete queryResponseFindLog;
	delete queryReqService;
	delete iter;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsGetUnpackedCargo" id="85725cbd-b088-4542-9874-f3dfe4d2f320">
        <source>wsGetUnpackedCargo( _container : CM_TrackedItem;
					_xtraTestString : String;
					_expectedError : Integer;
					_unpackedCargoArray : HugeStringArray io
					) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 August 2020	jlgndl1	Initial creation	TFS 47356

*/

vars

	ref : String;
	webService : JMTUserInterfaceService;
	request : WS_UnpackedCargoRequest;
	response : WS_UnpackedCargoResponse; 
	
	invalidObject : Boolean;
	wsUnpackedCargo : WS_UnpackedCargo;

begin

	on Exception do app.handleDeletedObject( exception, response, invalidObject );
	_unpackedCargoArray.clear();


	// Web service call
	create request transient;
	
	request.setPropertyValue( WS_UnpackedCargoRequest::containerOid.name, _container.getOidString );

	create webService transient;
	response := webService.getUnpackedCargo(request);
	if response = null then
		return _xtraTestString &amp; ", updateResponse not returned.";
	endif;
	if response.hasErrors then
		if _expectedError &gt; 0  and response.allErrors.includesError(_expectedError) then
			return null;
		endif;
		return _xtraTestString &amp; ", " &amp; response.getErrorsAsStringForTesting;
	endif;
	
	if _expectedError &gt; 0 then
		return _xtraTestString &amp; ", Expected error " &amp; _expectedError.String &amp; " but none generated.";
	endif;
	
	foreach wsUnpackedCargo in response.allUnpackedCargo do
		_unpackedCargoArray.add( wsUnpackedCargo.returnAsXMLString );
	endforeach;
	
	return null;
	
	// Not used,just here to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsGetUnpackedCargo.name; 

epilog

	delete response;
	delete webService;
	delete request;
	
end;</source>
        <Parameter name="_container" type="CM_TrackedItem"/>
        <Parameter name="_xtraTestString" type="String"/>
        <Parameter name="_expectedError" type="Integer"/>
        <Parameter name="_unpackedCargoArray" type="HugeStringArray" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsLanderComplete" id="575ec3ae-79f7-489b-b68d-b5c023dbf3b9">
        <source>wsLanderComplete(_mode : Integer; _voyage: CM_Voyage; _job: CM_Job; _ti: CM_TrackedItem; _targetLoc : CM_LocationsController): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes

*/

vars
	ref 			: String;
	webService 		: JMTUserInterfaceService;
	request			: WS_LanderCompleteRequest;
	response		: WS_Response; 
begin
	// Web service call
	create request transient;
	if _mode = JOB_TYPE_LOAD then
		request.setPropertyValue('doLoad', true);
	else
		request.setPropertyValue('doDischargeToMachine', true);
	endif;
	request.setPropertyValue('cargoOid', _ti.getOidAsString());
	request.setPropertyValue('voyageOid',_voyage.getOidAsString());
	request.setPropertyValue('doDischargeToMachine',true);
	request.setPropertyValue('jobOid',_job.getOidAsString());
	request.setPropertyValue('targetLocation',_targetLoc.getOidAsString());
	request.setPropertyValue('quantity',_ti.totalQuantity);
	
	create webService transient;
	response := webService.doLanderComplete(request);
	if response = null then
		return "test 1, trackeditem not discharged successfully";
	endif;
	if response.hasErrors then
		return "test 2, " &amp; response.getErrorsAsStringForTesting;
	endif;
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsLanderComplete.name;
epilog
	delete request;
	delete response;
	delete webService;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_targetLoc" type="CM_LocationsController"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsLogLocationMaint" id="2a1122db-0941-410e-b8b6-6fed83caf051">
        <source>wsLogLocationMaint() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2014	cnwdb2	Initial creation
13 Nov 	2017 	jlger1	TFS 7541 - unit test should not delete any transient ws object only requests and responses
									otherwise we are hiding the real transient leaks

*/

constants

	CODE_GROUP = "UT_Log" ; 
	
vars
	ref : String;
	request					: WS_LogSpecsUpdateRequest;
	
	codeGroup  				: WS_CodeGroupLogSpecs ; 
	logSpecies  			: WS_LogSpecies ; 
	logType  				: WS_LogType ; 
	logLength  				: WS_LogLength ; 
	logTreatment 			: WS_LogTreatment ; 
	logGrade      : WS_LogGrade ; 
	
	
	
	
	responseDelete 			: WS_Response;
	webService 				: JMTUserInterfaceService;
	response 				: WS_LogSpecsResponse;
	
	sourceLocation,	sourceLocation1			: WS_SourceLocation;
	sourceSubLocation			: WS_SourceSubLocation;
	sourceSubSubLocation		: WS_SourceSubSubLocation;	
	
	realCodeGroup  : CM_CodeGroupLogSpecs ; 
	
begin
	
	if app.name &lt;&gt; "JMTUnitTest" and app.name &lt;&gt; "JMTUnitTestRunner" then
		return "Pre-test check: App.name = '" &amp; app.name &amp; "' test will fail...";
	endif;
	
	create logSpecies transient ; 
	create codeGroup transient ; 
	create webService transient;
	create logType transient ; 
	create logLength transient ; 
	create logTreatment transient ; 
	create logGrade transient ; 

	codeGroup.setPropertyValue('name','UT_Log') ; 
	
	codeGroup.allLogSpecies.add(logSpecies) ; 
	codeGroup.allLogTypes.add(logType) ; 
	codeGroup.allLogLengths.add(logLength) ; 
	codeGroup.allLogTreatments.add(logTreatment) ; 
	
	// setup log lengths
	logLength.setPropertyValue("code","2.0") ; 
	logLength.setPropertyValue("description"," 2 meters") ; 
	
	//setup log treatments
	logTreatment.setPropertyValue('code','UTN') ; 
	logTreatment.setPropertyValue('description','untreated') ; 
	
	//setup log types
	logType.setPropertyValue('code','BOFFUT') ; 
	logType.setPropertyValue('description','Bark off UT') ; 
	
	//setup species
	logSpecies.setPropertyValue("code","OAK") ; 
	logSpecies.setPropertyValue("description","Oak UT") ; 
	logSpecies.allLogGrades.add(logGrade) ; 
	
	
	logGrade.setPropertyValue('code','GH') ; 
	logGrade.setPropertyValue('description','Grade High UT') ; 
/*	
	logGrade2.setPropertyValue('code','GL') ; 
	logGrade2.setPropertyValue('description','Grade Low UT') ; 
*/	
	create request transient;
	request.setPropertyValue('myCodeGroupLogSpecs', codeGroup);
	
	response := webService.createLogSpec(request);
		
	if response = null then
		return "test 1, updateResponse not returned.";
	endif;
	if response.hasErrors then
		return "test 2, " &amp; response.getErrorsAsStringForTesting;
	endif;
	
	if response.myCodeGroupLogSpecs = null then
		return "test 3, " &amp; "Failed to create log species" ; 
	endif ; 
	
	if response.myCodeGroupLogSpecs.allLogSpecies = null then
		write "l" ; 
	
	endif ; 
	// go through the log species tree and check all has been created
	foreach logSpecies in response.myCodeGroupLogSpecs.allLogSpecies do
		if logSpecies.code = null then
			return "log species does not exist" ; 
		endif ; 
		foreach logGrade in logSpecies.allLogGrades do
			if logGrade.code = null then
				return "log grade has not been created"  ; 
			endif ; 
		endforeach ; 
	endforeach ; 
	
	// go throught the log treatments and make sure they exist
	foreach logTreatment in response.myCodeGroupLogSpecs.allLogTreatments do
		if logTreatment.code = null then
			return "log grade has not been created"  ; 
		endif ; 
	endforeach ; 
	
	// go through log length and make sure they exist 
	foreach logLength in response.myCodeGroupLogSpecs.allLogLengths do
		if logLength.code = null then 
			return "log length has not been created"  ; 
		endif ; 
	endforeach ; 
	
	// through each log type and make sure they exist 
	foreach logType in response.myCodeGroupLogSpecs.allLogTypes do
		if logType.code = null then
			return "log type has not been created"  ;
		endif ; 
	endforeach  ;
	
	delete request;
	delete response;
	
	
	// TEST 2 delete the logs	

	//now we will clear out the transients and get the real object that has been created before updating

	realCodeGroup := app.myRoot.allCodeGroups[CodeGroup_LogSpecs, CODE_GROUP].CM_CodeGroupLogSpecs;

	create codeGroup transient;
	codeGroup.setProxyFromObject(realCodeGroup);
	
	create request transient;
	request.setPropertyValue('myCodeGroupLogSpecs', codeGroup);
	
	
	foreach logSpecies in codeGroup.allLogSpecies do 
	//	logSpecies.setPropertyValue("code","OAKDif") ; 
		logSpecies.setPropertyValue("description","OakDifDesc") ; 
		foreach logGrade in logSpecies.allLogGrades do
			
		//	logGrade.setPropertyValue('code','GH2') ; 
			logGrade.setPropertyValue('description','Grade High Dif') ; 
		endforeach  ; 
	endforeach ;
	
	response := webService.updateLogSpec(request);
	
	if response = null then
		return "test 1, updateResponse not returned.";
	endif;
	if response.hasErrors then
		return "test 2, " &amp; response.getErrorsAsStringForTesting;
	endif;
	
	if response.myCodeGroupLogSpecs = null then
		return "test 3, " &amp; "Failed to update log species" ; 
	endif ; 
	
	//check they have actually changed
	//check there actually has been a change
	foreach logSpecies in codeGroup.allLogSpecies do 
		if logSpecies.description = "Oak UT" then
			write "The original Log Species failed to change Log Species description " &amp; "(" &amp; " Oak UT "&amp; ")" ; 
		endif  ; 
		foreach logGrade in logSpecies.allLogGrades do
			if logGrade.description = "Grade High UT" then
				return "The original  Log Grade description failed to change Log Grade description " &amp; "(" &amp; "Grade High UT" &amp; ")" ; 
			endif ; 
		endforeach ; 
	endforeach ;  

	//tidy up from update
	//delete codeGroup;
	delete request;
	delete response;

	// TEST 3 delete the logs	
	create codeGroup transient;
	codeGroup.setProxyFromObject(realCodeGroup);
	
	//update the values
	create request transient;
	request.setPropertyValue('myCodeGroupLogSpecs', codeGroup);
	
	// make the delete call
	responseDelete := webService.deleteLogSpecs(request) ; 
	// check the response again
	if responseDelete = null then
		return "test 1, response not returned.";
	endif;
	if responseDelete.hasErrors then
		return "test 2, " &amp; responseDelete.getErrorsAsStringForTesting;
	endif;
	
	realCodeGroup := app.myRoot.allCodeGroups[CodeGroup_LogSpecs,CODE_GROUP].CM_CodeGroupLogSpecs ; 
	if realCodeGroup &lt;&gt; null then
		return "test 3, code group not deleted" ; 
	endif; 	
	
	
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsLogLocationMaint.name; 

epilog
	delete webService;

	delete request;
	delete response ; 
	delete responseDelete ; 
	
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsLogRowMaint" id="f414d664-ca55-449c-91e6-e49ee0015ddb">
        <source>wsLogRowMaint(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 January 2015	cnwmc5	Initial creation
13 Nov 	2017 	jlger1	TFS 7541 - unit test should not delete any transient ws object only requests and responses
									otherwise we are hiding the real transient leaks
*/
constants


vars
	ref : String;
	queryRequest 		: WS_LogRowUpdateRequest;
	queryResponse		: WS_Response;
	logRowResponse 		: WS_LogRowResponse;
	
	logController		: WS_LogController;
	locationRestriction	: WS_LocationRestriction;
	logSpecies			: WS_LogSpecies;
	logGrade			: WS_LogGrade;
	logLength			: WS_LogLength;
	logTreatment		: WS_LogTreatment;
	logType				: WS_LogType;
	operator			: WS_Operator;
	
	logArea				: CM_LogArea;
	logRow				: CM_LogController;
	
	queryReqService 	: JMTUserInterfaceService;
	
begin
	
	if app.name &lt;&gt; "JMTUnitTest" and app.name &lt;&gt; "JMTUnitTestRunner" then
		return "Pre-test check: App.name = '" &amp; app.name &amp; "' test will fail...";
	endif;
	
	create queryReqService transient;
	create queryRequest transient;
	create logController transient;
	create locationRestriction transient;
	create logSpecies transient;
	create logGrade transient;
	create logLength transient;
	create logTreatment transient;
	create logType transient;
	create operator transient;
	
	operator.setPropertyValue('code', 'DOUG');
	logType.setPropertyValue('code', 'AA');
	logTreatment.setPropertyValue('code', 'NONE');
	logLength.setPropertyValue('code', '2M');
	logGrade.setPropertyValue('code', 'HIGH');
	logSpecies.setPropertyValue ('code', 'DUGFIR');
	
	locationRestriction.allOperators.add(operator);
	locationRestriction.allLogTypes.add(logType);
	locationRestriction.allLogTreatments.add(logTreatment);
	locationRestriction.allLogLengths.add(logLength);
	locationRestriction.allLogGrades.add(logGrade);
	locationRestriction.allLogSpecies.add(logSpecies);
	locationRestriction.setPropertyValue('id', 'UT_WEB');
	locationRestriction.setPropertyValue('mixedRow', false);
	locationRestriction.setPropertyValue('transportMode', 3);
	
	logController.setPropertyValue('myLocationRestriction', locationRestriction);
	

	
	
	logController.setPropertyValue('id', 'UT_WEB');
	logController.setPropertyValue('checkScaled', true);
	logController.setPropertyValue('isFumigated', true);
	logController.setPropertyValue('terminalAreaId', 'UTLOG');
	logController.setPropertyValue('rowIsMixed', false);
	logController.setPropertyValue('remarks', 'Some UT remarks.');
	logController.setPropertyValue('status', 0);
	
	queryRequest.setPropertyValue('myLogController', logController);
	
	//Create tests
	logRowResponse := queryReqService.createLogRow(queryRequest);
	if logRowResponse = null then
		return "test 1, queryResponse not returned.";
	endif;
	if logRowResponse.hasErrors then
		return "test 2, " &amp; logRowResponse.getErrorsAsStringForTesting;
	endif;
	logArea := self.myTerminal.allTerminalAreas['UTLOG'].CM_LogArea;
	if logArea &lt;&gt; null then
		logRow := logArea.findLogRow('UT_WEB');
	endif;
	if logRow = null then
		return "test 3, the log row was NOT created.";
	endif;
	delete logRowResponse;
	delete queryRequest;
	//delete logController;
	
	//Update tests
	create queryRequest transient;
	create logController transient;
	
	logController.setProxyFromObject(logRow);
	logController.setPropertyValue('rowWidth', 10.Real);
	logController.setPropertyValue('remarks', 'Some UT remarks UPDATED.');
	
	queryRequest.setPropertyValue('myLogController', logController);
	
	logRowResponse := queryReqService.updateLogRow(queryRequest);
	if logRowResponse = null then
		return "test 4, queryResponse not returned.";
	endif;
	if logRowResponse.hasErrors then
		return "test 5, " &amp; logRowResponse.getErrorsAsStringForTesting;
	endif;
	if logRow &lt;&gt; null and logRow.getRowWidth() &lt;&gt; 10.Real and logRow.remarks &lt;&gt; 'Some UT remarks UPDATED.' then
		return "test 6, log row was NOT updated successfully.";
	endif;
	delete logRowResponse;
	
	//Delete test
	queryResponse := queryReqService.deleteLogRow(queryRequest);
	if queryResponse = null then
		return "test 7, queryResponse not returned.";
	endif;
	if queryResponse.hasErrors then
		return "test 8, " &amp; queryResponse.getErrorsAsStringForTesting;
	endif;
	logArea := self.myTerminal.allTerminalAreas['UTLOG'].CM_LogArea;
	if logArea &lt;&gt; null then
		logRow := logArea.findLogRow('UT_WEB');
	endif;
	if logRow &lt;&gt; null then
		return "test 9, the log row was NOT deleted.";
	endif;
	delete queryResponse;
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsLogRowMaint.name; 

epilog
	

	delete logRowResponse;
	delete queryResponse;
	delete queryRequest;
	delete queryReqService;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsMoveTI" id="d61d17c8-92f2-41bb-aa0d-e62881208ed2">
        <source>wsMoveTI(_ti: CM_TrackedItem; _location: CM_LocationsController): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2016	cnwmp6	Initial creation

*/

vars
	ref : String;
	queryRequest : WS_MoveRequest;
	queryReqService : JMTUserInterfaceService;
	queryResponse : WS_Response;

begin
	if app.name &lt;&gt; "JMTUnitTest" and app.name &lt;&gt; "JMTUnitTestRunner" then
		return "Pre-test check: App.name = '" &amp; app.name &amp; "' test will fail...";
	endif;

	create queryRequest transient;
	queryRequest.setPropertyValue("cargoOid", _ti.getOidString());
	queryRequest.setPropertyValue("targetLocation", _location);
	
	create queryReqService transient;
	queryResponse := queryReqService.doMoveCargo(queryRequest);
	if queryResponse = null then
		return "test 1, queryResponse not returned.";
	endif;
	if queryResponse.hasErrors then
		return "test 2, " &amp; queryResponse.getErrorsAsStringForTesting;
	endif;
	delete queryResponse;	
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsMoveTI.name; 

epilog
	delete queryResponse;
	delete queryRequest;
	delete queryReqService;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsPelindo1PKK" id="da39c3fa-5574-4068-8dac-6e0777ade76c">
        <source>wsPelindo1PKK(	_xtraTestString : String;
				_expectedError : Integer
				) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars
	ref : String;
	invalidObject : Boolean;
	
	webService : JMTExternalInterfaceService;
	request : WS_EntryPKKRequest;
	response : WS_EntryPKKResponse; 
	
	xmlString : String;
	xmlDoc : JadeXMLDocument;
	headerElement : JadeXMLElement;
	subNode : JadeXMLNode;
	subElement : JadeXMLElement;
	
	
	xmlStrLine : String;
	propName : String;
	propValue : String;
	prop : Property;
	
	term : CM_Terminal;
	portCode : String;
	operatorCode : String;
	vesselName : String;

begin

	on Exception do app.handleDeletedObject( exception, response, invalidObject );
	
	term := app.myPassport.myTerminal;
	if term.getDefaultPort() &lt;&gt; null then
		portCode := term.getDefaultPort.code;
	endif;
	operatorCode := "UTOP";
	vesselName := "UTPELINDO1";
	
	// manually setup the request object
	
	xmlString := '&lt;?xml version="1.0" encoding="UTF-8"?&gt;
&lt;SOAP-ENV:Envelope xmlns:SOAP-ENV="http://schemas.xmlsoap.org/soap/envelope/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ns1="http://src/"&gt;
    &lt;SOAP-ENV:Body&gt;
        &lt;entryPKK&gt;
            &lt;req&gt;
	           &lt;user&gt;cnwndl1&lt;/user&gt;
                &lt;password&gt;password&lt;/password&gt;
                &lt;nomorPKK&gt;PKK.DN.IDMAK.1604.000002&lt;/nomorPKK&gt;
                &lt;perusahaanNama&gt;' &amp; operatorCode &amp; '&lt;/perusahaanNama&gt;
                &lt;tandaPendaftaranKapal&gt;2002_Ka_No._2996/L&lt;/tandaPendaftaranKapal&gt;
                &lt;kapalNama&gt;' &amp; vesselName &amp; '&lt;/kapalNama&gt;
                &lt;nahkoda&gt;YOHANES YAMLEAN&lt;/nahkoda&gt;
                &lt;drt&gt;16000&lt;/drt&gt;
                &lt;grt&gt;1007&lt;/grt&gt;
                &lt;loa&gt;57.18&lt;/loa&gt;
                &lt;jenisTrayek&gt;02&lt;/jenisTrayek&gt;
                &lt;bendera&gt;ID&lt;/bendera&gt;
                &lt;callSign&gt;YGWI&lt;/callSign&gt;
                &lt;imoNumber&gt;&lt;/imoNumber&gt;
                &lt;tanggalEta&gt;2016-04-15 13:05:00&lt;/tanggalEta&gt;
                &lt;tanggalEtd&gt;2016-04-18 09:10:00&lt;/tanggalEtd&gt;
                &lt;kodeAsalPelabuhan&gt;IDENE&lt;/kodeAsalPelabuhan&gt;
                &lt;asalPelabuhan&gt;ENDE, FLORES &lt;/asalPelabuhan&gt;
                &lt;kodeTujuanPelabuhan&gt;IDLWE&lt;/kodeTujuanPelabuhan&gt;
                &lt;tujuanPelabuhan&gt;LEWOLEBA &lt;/tujuanPelabuhan&gt;
                &lt;dermagaNama&gt;HASANUDDIN - MULTIPURPOSE I&lt;/dermagaNama&gt;
                &lt;penumpangNaikTurunBongkar&gt;&lt;/penumpangNaikTurunBongkar&gt;
                &lt;penumpangNaikTurunMuat&gt;&lt;/penumpangNaikTurunMuat&gt;
                &lt;jenisBarang&gt;Bag Cargo&lt;/jenisBarang&gt;
                &lt;containerBongkarIsi40 xsi:nil="true" /&gt;
                &lt;containerBongkarIsi20 xsi:nil="true" /&gt;
                &lt;containerBongkarIsi40Empty xsi:nil="true" /&gt;
                &lt;containerBongkarIsi20Empty xsi:nil="true" /&gt;
                &lt;containerMuatIsi40 xsi:nil="true" /&gt;
                &lt;containerMuatIsi20 xsi:nil="true" /&gt;
                &lt;containerMuatIsi40Empty xsi:nil="true" /&gt;
                &lt;containerMuatIsi20Empty xsi:nil="true" /&gt;
                &lt;cargoBarangCampurBongkar&gt;&lt;/cargoBarangCampurBongkar&gt;
                &lt;cargoBarangCampurMuat&gt;&lt;/cargoBarangCampurMuat&gt;
                &lt;cargoBarangKarungBongkar&gt;&lt;/cargoBarangKarungBongkar&gt;
                &lt;cargoBarangKarungMuat&gt;1600 Ton&lt;/cargoBarangKarungMuat&gt;
                &lt;cargoBarangCurahBongkar&gt;&lt;/cargoBarangCurahBongkar&gt;
                &lt;cargoBarangCurahMuat&gt;&lt;/cargoBarangCurahMuat&gt;
                &lt;cargoBarangCairBongkar&gt;&lt;/cargoBarangCairBongkar&gt;
                &lt;cargoBarangCairMuat&gt;&lt;/cargoBarangCairMuat&gt;
                &lt;cargoBarangBerbahayaBongkar&gt;&lt;/cargoBarangBerbahayaBongkar&gt;
                &lt;cargoBarangBerbahayaMuat&gt;&lt;/cargoBarangBerbahayaMuat&gt;
                &lt;jenisBarangLain&gt;&lt;/jenisBarangLain&gt;
                &lt;jenisBarangLainBongkar&gt;&lt;/jenisBarangLainBongkar&gt;
                &lt;jenisBarangLainMuat&gt;&lt;/jenisBarangLainMuat&gt;
                &lt;jumlahBongkar&gt;0&lt;/jumlahBongkar&gt;
                &lt;jumlahMuat&gt;1600&lt;/jumlahMuat&gt;
                &lt;hewanNaikTurunBongkar&gt;&lt;/hewanNaikTurunBongkar&gt;
                &lt;hewanNaikTurunMuat&gt;&lt;/hewanNaikTurunMuat&gt;
                &lt;portCode&gt;' &amp; portCode &amp; '&lt;/portCode&gt;
                &lt;sts&gt;2&lt;/sts&gt;
                &lt;npwp&gt;01.673.218.2-801.002&lt;/npwp&gt;
                &lt;kodeMuatPelabuhan&gt;IDGRE&lt;/kodeMuatPelabuhan&gt;
                &lt;muatPelabuhan&gt;GRESIK&lt;/muatPelabuhan&gt;
                &lt;kodeTujuanAkhirPelabuhan&gt;IDMAK&lt;/kodeTujuanAkhirPelabuhan&gt;
                &lt;tujuanAkhirPelabuhan&gt;MAKASSAR&lt;/tujuanAkhirPelabuhan&gt;
                &lt;jenisKapal&gt;1.7.1&lt;/jenisKapal&gt;
                &lt;tahunPembuatan&gt;2002&lt;/tahunPembuatan&gt;
                &lt;lebarKapal&gt;12&lt;/lebarKapal&gt;
                &lt;drMax&gt;4.8&lt;/drMax&gt;
                &lt;drDepan&gt;2.1&lt;/drDepan&gt;
                &lt;drBelakang&gt;3.2&lt;/drBelakang&gt;
                &lt;drTengah xsi:nil="true" /&gt;
                &lt;noinmarsat&gt;&lt;/noinmarsat&gt;
                &lt;nomorTrayek&gt;AL.302/59/10/157/16&lt;/nomorTrayek&gt;
                &lt;statusBM&gt;Y&lt;/statusBM&gt;
				&lt;statusWindow&gt;Y&lt;/statusWindow&gt;
            &lt;/req&gt;
        &lt;/entryPKK&gt;
    &lt;/SOAP-ENV:Body&gt;
&lt;/SOAP-ENV:Envelope&gt;';

	create request transient;

	create xmlDoc transient;
	xmlDoc.parseString( xmlString );
	headerElement := xmlDoc.findElementByTagName("req");

	
	//populate the request
	foreach subNode in headerElement.childNodes do
		propName := subNode.JadeXMLElement.tagName;
		propValue := subNode.JadeXMLElement.text;
		prop := request.class.getPropertyInHTree(propName);
		if prop = null or propValue.trimBlanks = null then
			continue;
		endif;
		request.setPropertyValue(propName,propValue);
	endforeach; 

	//Start test
	
	create webService transient;
	webService.setPropertyValue( "incomingMessage", xmlString );
	
	response := webService.entryPKK(request);
	
	if response = null then
		return _xtraTestString &amp; ", updateResponse not returned.";
	endif;
	
	if response.statusMessage = 'Success' then
		return null;
	endif;
	
	return response.statusMessage;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsPelindo1PKK.name; 

epilog

	delete xmlDoc;
	
	delete response;
	delete webService;
	delete request;
	

end;</source>
        <Parameter name="_xtraTestString" type="String"/>
        <Parameter name="_expectedError" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsPelindo1Perpan" id="06941891-73d9-4a04-8efa-9efb221bb99d">
        <source>wsPelindo1Perpan(	_xtraTestString : String;
					_expectedError : Integer;
					_contextObj : Object
					) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 November 2018	jlgndl1	Initial creation	TFS 41906

*/

vars
	ref : String;
	invalidObject : Boolean;
	
	webService : JMTExternalInterfaceService;
	request : WS_EntryPMTRequest;
	response : WS_EntryPMTResponse; 
	
	xmlString : String;
	xmlDoc : JadeXMLDocument;
	headerElement : JadeXMLElement;
	subNode : JadeXMLNode;
	subElement : JadeXMLElement;
	
	
	xmlStrLine : String;
	propName : String;
	propValue : String;
	prop : Property;
	
	term : CM_Terminal;
	portCode : String;
	operatorCode : String;
	vesselName : String;
	
	vessel : CM_Vessel;
	voyage : CM_Voyage;

begin

	on Exception do app.handleDeletedObject( exception, response, invalidObject );
	
	term := app.myRoot.allTerminals["JBL"];
	if term.getDefaultPort() &lt;&gt; null then
		portCode := term.getDefaultPort.code;
	endif;
	operatorCode := "UTOP";
	vesselName := "UTPELINDO1";
	
	vessel := app.myRoot.allVesselsByName.getAtKey( vesselName );
	if vessel = null then
		return "Vesssel '" &amp; vesselName &amp; "' not found during setup";
	endif;
	voyage := vessel.allVoyagesByTermCodeArrival.getAtKeyGeq( term, null, null );
	if voyage = null then
		return "Voyage in Unit Test for '" &amp; vesselName &amp; "' not found during setup";
	endif;
	
		xmlString := '&lt;?xml version="1.0" encoding="UTF-8"?&gt;
&lt;SOAP-ENV:Envelope xmlns:SOAP-ENV="http://schemas.xmlsoap.org/soap/envelope/" xmlns:ns1="urn:JadeWebServices/JMTExternalInterfaceService/"&gt;
  &lt;SOAP-ENV:Body&gt;
    &lt;ns1:entryPerpanjanganMasaTambat&gt;
      &lt;ns1:req&gt;
        &lt;ns1:portCode&gt;' &amp; portCode &amp; '&lt;/ns1:portCode&gt;
        &lt;ns1:alasan/&gt;
        &lt;ns1:catatan/&gt;
        &lt;ns1:kodeDermaga&gt;PPj.d.1602.00001&lt;/ns1:kodeDermaga&gt;
        &lt;ns1:nomorMasaTambat&gt;TMT.IDDUM.1118.000009&lt;/ns1:nomorMasaTambat&gt;
        &lt;ns1:nomorPkk&gt;' &amp; voyage.voyageCodeExternal &amp; '&lt;/ns1:nomorPkk&gt;
        &lt;ns1:nomorRpkRo&gt;IDDUM-RPKRO-14791.656&lt;/ns1:nomorRpkRo&gt;
        &lt;ns1:tanggalMulai&gt;2018-11-13 10:00:00&lt;/ns1:tanggalMulai&gt;
        &lt;ns1:tanggalPermohonan&gt;2018-11-11 10:00:00&lt;/ns1:tanggalPermohonan&gt;
        &lt;ns1:tanggalSelesai&gt;2018-11-14 10:00:00&lt;/ns1:tanggalSelesai&gt;
      &lt;/ns1:req&gt;
    &lt;/ns1:entryPerpanjanganMasaTambat&gt;
  &lt;/SOAP-ENV:Body&gt;
&lt;/SOAP-ENV:Envelope&gt;';

	create request transient;
	request.user := "superuser";
	request.password := "yeahR1ght!";

	create xmlDoc transient;
	xmlDoc.parseString( xmlString );
	headerElement := xmlDoc.findElementByTagName("ns1:req");
	
	//populate the request
	foreach subNode in headerElement.childNodes do
		propName := subNode.JadeXMLElement.tagName[5:end];
		propValue := subNode.JadeXMLElement.text;
		prop := request.class.getPropertyInHTree(propName);
		if prop = null or propValue.trimBlanks = null then
			continue;
		endif;
		request.setPropertyValue(propName,propValue);
	endforeach; 

	//Start test	
	create webService transient;
	webService.setPropertyValue( "incomingMessage", xmlString );
	
	response := webService.entryPerpanjanganMasaTambat(request);
	
	if _contextObj &lt;&gt; null then
		write "post response create ";
		_contextObj.sendMsgWithParams( "writeTransientsNow", IntegerArray );
		write " ";
	endif;
	
	if response = null then
		return _xtraTestString &amp; ", updateResponse not returned.";
	endif;
	
	if response.statusMessage = 'Success' then
		return null;
	endif;
	
	return response.statusMessage;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsPelindo1Perpan.name; 


epilog

	delete xmlDoc;
	
	delete response;
	delete webService;
	delete request;
	
//	if _contextObj &lt;&gt; null then
//		write "post deletes ";
//		_contextObj.sendMsgWithParams( "writeTransientsNow", IntegerArray );
//	endif;
	
end;</source>
        <Parameter name="_xtraTestString" type="String"/>
        <Parameter name="_expectedError" type="Integer"/>
        <Parameter name="_contextObj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsPelindo1RKBM" id="f871eaaa-1d8c-4027-94cb-c11dbf4806c7">
        <source>wsPelindo1RKBM(_xtraTestString: String; _expectedError: Integer): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 26/04/2018	jlgdap1		Initial creation TFS 38135 PEL1 Inaportnet Integration (Web Service Provider)
//
vars
	ref : String;
	webService : JMTExternalInterfaceService;
	request : WS_EntryRKBMRequest;
	response : WS_EntryRKBMResponse;
	rkbmDetail : WS_DetailRKBM;
	
	invalidObject : Boolean;
	xmlString : String;
	xmlDoc : JadeXMLDocument;
	headerElement : JadeXMLElement;
	subNode, childNode : JadeXMLNode;
	subElement : JadeXMLElement;
	
	propName : String;
	propValue : String;
	prop : Property;
	
	term : CM_Terminal;
	portCode : String;
	
	voyage : CM_Voyage;
	voyageStatus : CM_VoyageStatus;

begin
	on Exception do app.handleDeletedObject( exception, response, invalidObject );
	
	term := app.myRoot.allTerminals["JBL"];
	if term.getDefaultPort() &lt;&gt; null then
		portCode := term.getDefaultPort.code;
	endif;
	
	xmlString := '&lt;?xml version="1.0" encoding="UTF-8"?&gt;
&lt;soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" xmlns:src="http://src/"&gt;
   &lt;soapenv:Body&gt;
      &lt;entryRKBM&gt;
         &lt;RequestEntryRKBM&gt;
	         &lt;user&gt;jlgdap1&lt;/user&gt;
            &lt;password&gt;dddddd&lt;/password&gt;
            &lt;nomorPKK&gt;PKK.DN.IDMAK.1604.000002&lt;/nomorPKK&gt;
            &lt;portCode&gt;' &amp; portCode &amp; '&lt;/portCode&gt;
            &lt;DetailRKBM&gt;
               &lt;namaBarang&gt;TEKSTIL&lt;/namaBarang&gt;
               &lt;bahaya&gt;N&lt;/bahaya&gt;
               &lt;ganggu&gt;N&lt;/ganggu&gt;
               &lt;kegiatan&gt;BONGKAR&lt;/kegiatan&gt;
               &lt;unit&gt;14&lt;/unit&gt;
               &lt;ton&gt;50&lt;/ton&gt;
               &lt;m3&gt;50&lt;/m3&gt;
               &lt;penyaluran&gt;G&lt;/penyaluran&gt;
               &lt;kade&gt;UT_WorkPoint&lt;/kade&gt;
               &lt;pbm&gt;PT. Perushaan bongkar Muat&lt;/pbm&gt;
               &lt;npwpPbm&gt;70.358.594.3-412.001&lt;/npwpPbm&gt;
               &lt;consignee&gt;RAL&lt;/consignee&gt;
               &lt;shipper&gt;PT. Perusahaan Pelayaran&lt;/shipper&gt;
               &lt;npwpShipper&gt;70.358.594.3-412.000&lt;/npwpShipper&gt;
               &lt;blNo&gt;1234567&lt;/blNo&gt;
               &lt;gang&gt;1&lt;/gang&gt;
               &lt;palka&gt;2&lt;/palka&gt;
               &lt;noRkbmBongkar&gt;SL001.B.0001&lt;/noRkbmBongkar&gt;
               &lt;rencanaBongkar &gt;2016-04-15 13:05:00&lt;/rencanaBongkar &gt;
               &lt;noRkbmMuat&gt;SL001.M.001&lt;/noRkbmMuat&gt;
               &lt;rencanaMuat &gt;2016-04-15 20:05:00&lt;/rencanaMuat &gt;
            &lt;/DetailRKBM&gt;
         &lt;/RequestEntryRKBM&gt;
      &lt;/entryRKBM&gt;
   &lt;/soapenv:Body&gt;
&lt;/soapenv:Envelope&gt;';

	create request transient;

	create xmlDoc transient;
	xmlDoc.parseString(xmlString);
	headerElement := xmlDoc.findElementByTagName("RequestEntryRKBM");
	
	// populate the request
	foreach subNode in headerElement.childNodes do
		if subNode.childNodes.isEmpty then
			propName := subNode.JadeXMLElement.tagName;
			propValue := subNode.JadeXMLElement.text;
			prop := request.class.getPropertyInHTree(propName);
			if prop = null or propValue.trimBlanks = null then
				continue;
			endif;
			request.setPropertyValue(propName,propValue);
		else
			// we have a RKBM detail
			create rkbmDetail transient;
			foreach childNode in subNode.childNodes do
				propName := childNode.JadeXMLElement.tagName;
				propValue := childNode.JadeXMLElement.text;
				prop := rkbmDetail.class.getPropertyInHTree(propName);
				if prop = null or propValue.trimBlanks = null then
					continue;
				endif;
				rkbmDetail.setPropertyValue(propName,propValue);
			endforeach;
			request.allDetailRKBM.add(rkbmDetail);
		endif;
	endforeach;
	
	// find the voyage
	voyage := term.allVoyagesByExternalCode["PKK.DN.IDMAK.1604.000002"];
	if voyage = null then
		return _xtraTestString &amp; ", voyage PKK.DN.IDMAK.1604.000002 not found.";
	endif;
	// set it to the correct status Cargo Request Pending
	voyageStatus := app.myRoot.allVoyageStatuses[Voyage_Status_ICargoReqPending];
	if voyageStatus = null then
		return _xtraTestString &amp; ", voyage status Voyage_Status_ICargoReqPending not found.";
	endif;
	beginTransaction;
	voyage.setPropertyValue(CM_Voyage::status.name, voyageStatus.id);
	commitTransaction;
	
	//Start test
	create webService transient;
	webService.setPropertyValue( "incomingMessage", xmlString );
	
	response := webService.entryRKBM(request);
	
	if response = null then
		return _xtraTestString &amp; ", updateResponse not returned.";
	endif;
	
	if response.statusMessage = 'Success' then
		return null;
	endif;
	
	return response.statusMessage;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsPelindo1RKBM.name; 
	
epilog
	delete xmlDoc;
	delete response;
	delete webService;
	delete request;
end;</source>
