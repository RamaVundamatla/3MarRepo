Date		Who		Reason
05 August 2014	cnwer1	Initial creation PAR

*/

vars

begin
	if _table = self.tblDirector then
		if self.isEnquiryMode then
			return CM_RTVehicleConfig.CARGO_FEILDS;
		else
			return CM_RTVehicleConfig.DIRECTOR_FEILDS;
		endif;
	endif;
	

	
	return CM_RTVehicleConfig.QENTRY_FIELDS;

epilog

end;</source>
