    <JadeMethod name="addTotalSumObjects" id="2e922d77-f4f3-4d03-a8dc-98d3eb249ad6">
        <source>addTotalSumObjects(prevRowType : Integer);
// ---------------------------------------------------------------------------
// Created:     19 March 2008 by cnwaer1
//
// Purpose:     Class is used to add a line displaying allTotalSums objects for the Container Summary Sheet 
//				at the end of allOperators and allFreightForwarders 
// ---------------------------------------------------------------------------
constants
	LineSep = 3;
vars
	col,
	currentRow 		: Integer;
	tmpSheet 		: JadeTableSheet;
	queryHeader 	: CMIF_CommercialQueryHeader;
	iter			: Iterator;
	tmpTSum 		: CMIF_CommercialQuerySmryTotal;
begin
	tmpSheet := self.tblData.accessSheet(2);
	queryHeader := self.myQueryHdr;
	
	if prevRowType = self.myQueryHdr.SumRow_Operator then
		// display Operator totals
		currentRow := tmpSheet.addItem('');
		tmpSheet.accessRow(currentRow).backColor:= Gray;
		tmpSheet.accessCell(currentRow, 1).text := "Total";
		// adding the total summs objects
		iter := self.myQueryHdr.allTotalSums.createIterator;
		while iter.next(tmpTSum) do
			if tmpTSum.cargoType &lt;&gt; TI_CargoType_Container or tmpTSum.rowType &lt;&gt; prevRowType then
				continue;
			endif;
			if tmpTSum.imexStatus = 1 then // IMPORT
				if tmpTSum.contentsStatus = 1 then // FULL CONTAINER
					col := ColumnNumbContainerSummaryGrp1 + tmpTSum.cntrType;
				elseif tmpTSum.contentsStatus = 3 then // EMPTY CONTINER
					col := ColumnNumbContainerSummaryGrp2 + tmpTSum.cntrType;
				endif;	
			elseif tmpTSum.imexStatus = 2 then // EXPORT
				if tmpTSum.contentsStatus = 1 then // FULL CONTAINER
					col := ColumnNumbContainerSummaryGrp3 + tmpTSum.cntrType;
				elseif tmpTSum.contentsStatus = 3 then // EMPTY CONTINER
					col := ColumnNumbContainerSummaryGrp4 + tmpTSum.cntrType;
				endif;	
			endif;
			tmpSheet.accessCell(currentRow, col).text := tmpTSum.num.Integer.asStringJMT;
			tmpSheet.accessCell(currentRow, col).itemObject := tmpTSum;
		endwhile;
	elseif prevRowType = self.myQueryHdr.SumRow_FF then
		// display FF totals
		currentRow := tmpSheet.addItem('');
		tmpSheet.accessRow(currentRow).backColor:= Gray;
		tmpSheet.accessCell(currentRow, 1).text := "Total";
		// adding the total summs objects
		iter := self.myQueryHdr.allTotalSums.createIterator;
		while iter.next(tmpTSum) do
			if tmpTSum.cargoType &lt;&gt; TI_CargoType_Container or tmpTSum.rowType &lt;&gt; prevRowType then
				continue;
			endif;
			if tmpTSum.imexStatus = 1 then // IMPORT
				if tmpTSum.contentsStatus = 1 then // FULL CONTAINER
					col := ColumnNumbContainerSummaryGrp1 + tmpTSum.cntrType;
				elseif tmpTSum.contentsStatus = 3 then // EMPTY CONTINER
					col := ColumnNumbContainerSummaryGrp2 + tmpTSum.cntrType;
				endif;	
			elseif tmpTSum.imexStatus = 2 then // EXPORT
				if tmpTSum.contentsStatus = 1 then // FULL CONTAINER
					col := ColumnNumbContainerSummaryGrp3 + tmpTSum.cntrType;
				elseif tmpTSum.contentsStatus = 3 then // EMPTY CONTINER
					col := ColumnNumbContainerSummaryGrp4 + tmpTSum.cntrType;
				endif;	
			endif;
			tmpSheet.accessCell(currentRow, col).text := tmpTSum.num.Integer.asStringJMT;
			tmpSheet.accessCell(currentRow, col).itemObject := tmpTSum;
		endwhile;
	endif;

	
epilog
	delete iter;		// PAR #26678
	
end;</source>
        <Parameter name="prevRowType" type="Integer"/>
    </JadeMethod>
