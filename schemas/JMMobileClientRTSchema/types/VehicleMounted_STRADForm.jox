    <JadeMethod name="updateButtonCaptions" id="6ae1de8d-6987-4461-a5a7-40cd0aebb0b2">
        <source>updateButtonCaptions();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2009	cnwer1	Initial creation

*/

vars

begin
	if not 	app.myVehicleMountedSTRADGuiAgent.isWorking then
		self.btnAccept.caption:="Accept";
		self.btnReject.caption:="Reject";
		self.btnReject.enabled:=false;
	else
		if 	app.myVehicleMountedSTRADGuiAgent.isTaskPickup then
			self.btnAccept.caption:="Pickup";
			self.btnReject.caption:="Reject";
			self.btnReject.enabled:=true;	
		elseif app.myVehicleMountedSTRADGuiAgent.isTaskSetdown then
			self.btnAccept.caption:="Setdown";
			self.btnReject.enabled:=false;	
		endif;
	
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateTableElapsedTimes" id="991bee5c-1073-4f63-a8b5-ef94646b1727">
        <updating/>
        <source>updateTableElapsedTimes() protected, updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
28 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	row : Integer;
	time : String;
	timeCell : JadeTableCell;
begin
	foreach row in self.tblJobs.fixedRows + 1  to self.tblJobs.rows do
		timeCell:=self.tblJobs.accessCell(row,self.colNoTime+1);
		if timeCell &lt;&gt; null then
			time:=timeCell.text;
			timeCell.text:=(time.Integer + 1).String;
			if time.Integer &gt; self.configElapsedTime then
				timeCell.fontBold:=true;
				timeCell.foreColor:=Red;
			endif;
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="userNotify" id="d19f352a-3c93-4da6-b7a8-a8fe00b15575">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
19 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	app.mousePointer	:=	Busy;
	if eventType = Event_Delete_Queue_Entry  or  eventType = Event_Add_Queue_Entry    then
		self.loadTaskTable();
	elseif eventType = EVENT_MACH_BROADCAST_MSG then
		app.msgBox(userInfo.String,"Message from RT Control",MsgBox_OK_Only);
	elseif eventType = EVENT_MACHQUEUE_ALTERED then
		self.doControlChangedQueue(userInfo.String);
	elseif eventType = EVENT_RESET_MEDIATOR then
		self.doControlResetSession(userInfo.String);
	else
		return;
	endif;
	
epilog
	app.mousePointer	:=	Idle;



end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
