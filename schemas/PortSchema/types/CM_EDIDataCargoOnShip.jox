    <JadeMethod name="createTIUpdateController" id="e384e5c6-ae58-42b1-8b29-ce916c4ebccf">
        <source>createTIUpdateController() : CMIF_TIUpdateController;
/*
Purpose:	PAR 34535		
Date		Who		Reason
09 July 2014	cnwab1	Initial creation
*/

vars
	updateController		:CMIF_TIUpdateController;

begin
	updateController := app.createTIUpdateControl(TI_UPDMODE_BAYPLAN, null, null);
	
	return updateController;
epilog

end;</source>
        <ReturnType type="CMIF_TIUpdateController"/>
    </JadeMethod>
    <JadeMethod name="doesReceiptTransportModeExist" id="7fcd0f76-e08e-4cec-b2cc-7b25d31d9a8d">
        <source>doesReceiptTransportModeExist(_receiptTransportMode: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
6 April 2023	navra1	Initial creation for 57263

*/

vars

begin
	//since the receipt transport mode would be TI_TRANSMODE_SHIP_STR for a cargo on ship edi file
	if _receiptTransportMode.toUpper().compareEql(TI_TRANSMODE_SHIP_STR.toUpper(), true, false, null) then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_receiptTransportMode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getEDIDataType" id="4077b5f6-9ddc-4035-9192-452146b32067">
        <source>getEDIDataType(): Integer;
/*
----------   ----------  --------------------------------------------------
Created:	08 jan 2010 cnwrs1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	return EDIDataType_CargoOnShip;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getEDIDataTypeChildren" id="aa8d9e69-c9fc-491c-8521-549a1265c909">
        <source>getEDIDataTypeChildren(_ediDataType: Integer; _childrenDataTypes: IntegerArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2016	cnwndl1	Initial creation	TFS 2843 / 2604
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
*/

vars

begin
	if _ediDataType = EDIDataType_JMTInternal then
		_childrenDataTypes.add(EDIDataType_CargoOnShip);
	elseif _ediDataType = EDIDataType_CargoOnShip then
		_childrenDataTypes.add(EDIDataType_TIHazDets);
		_childrenDataTypes.add(EDIDataType_TISeal);
	endif;

epilog

end;</source>
        <Parameter name="_ediDataType" type="Integer"/>
        <Parameter name="_childrenDataTypes" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getEDITIType" id="08a715a8-e6d3-431b-b755-52cae6a6235a">
        <source>getEDITIType(_ediDataType : Integer): Class;
/*
----------   ----------  --------------------------------------------------
Created:	08 jan 2010 cnwrs1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
*/
vars

begin
	if _ediDataType =  EDIDataType_TIHazDets then	//17 Nov 2016	NDL	TFS 2843 / 2604
		return CM_EDIHazDetailsTI;
	elseif _ediDataType =  EDIDataType_TISeal then
		return CM_EDISealTI;
	else
		return CM_EDICargoOnShipTI;
	endif;
end;</source>
        <Parameter name="_ediDataType" type="Integer"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getEDITITypes" id="30d24b1f-c12d-4073-b745-5d5fe930df79">
