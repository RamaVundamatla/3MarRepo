    <JadeMethod name="hasJobActivityType" id="21b36fe7-7966-4468-9ae6-3bcc7062cd07">
        <source>hasJobActivityType(_type: Integer): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jun 2024 navnk30 Bug 64601: FR | 54883 - Start and End Times for Operations in Mobile App
09 Oct 2024 navhl20 Bug 12389 FR | 54883 - Start and End Times for Operations in Mobile App - Retrospective Ops
*/

vars
	woDtl	: CM_WorkOrderDtl;
	woTxn	: CM_WOTransaction;
begin
	woDtl :=  self.getMyWorkOrderDtl();
	if woDtl = null then
		return false;
	endif;
	
	foreach woTxn in woDtl.allWODtlTransactions discreteLock do
		if woTxn.type = _type and woTxn.getJobId() = self.jobId then		//09.10.2024 navhl20 #12389
			return true;
		endif;
	endforeach;
	
	return false;
	
	
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initializeForActivity" id="10d65cd9-1a1b-42a2-b71a-d27d3a166a0c">
        <updating/>
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable: CMIF_OpsViewTables) updating;
/*
Purpose:			

Date		Who		Reason
04 May 2022	navab1	TFS 53569
*/

vars
	train : CM_Train;
	xpsCraneShift	    	: CMIF_XpsCraneshift;

begin
	inheritMethod(_ewsOpsView, _opsViewTable);
	

	if _opsViewTable.isKindOf(CMIF_XpsCraneshift) then
		xpsCraneShift := _opsViewTable.CMIF_XpsCraneshift;
		
		train := self.getMyTrain();	
		if train &lt;&gt; null then
			if self.isRelease then // ### TFS 54010 28JUN2022 NAVAB1
				xpsCraneShift.visit := train.code &amp; CMIF_OpsViewTables.Prefix_Outbound; // ### TFS 54010 28JUN2022 NAVAB1
			else // ### TFS 54010 28JUN2022 NAVAB1
				xpsCraneShift.visit := train.code &amp; CMIF_OpsViewTables.Prefix_Inbound; // ### TFS 54010 28JUN2022 NAVAB1
			endif; // ### TFS 54010 28JUN2022 NAVAB1
			 // ### TFS 54010 28JUN2022 NAVAB1 xpsCraneShift.visit := train.code;
		endif;
	endif;
	
	

epilog

end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
    <JadeMethod name="isJobMatchingMode" id="c7987679-c4fd-48f5-95ea-f2b15492b1a3">
