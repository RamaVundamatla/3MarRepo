    <JadeMethod name="zBuildDockContextMenu" id="1d175c3d-2f29-4a50-91c4-251a83744d40">
        <updating/>
        <source>zBuildDockContextMenu(_control: Control input; _conwin: Window input; _mouse: Boolean; _x: Integer; _y: Integer):Boolean updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	26 April 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	x1,
	y1			: Real;

	clickedIdx			: Integer;
	obj					: CM_Object;				
begin
	self.mnuDockFrame.visible := false;
	self.mnuShowFrame.visible := false;
	self.mnuHideFrame.visible := false;
	self.mnuFloatFrame.visible := false;
	self.mnuSep1.visible:=false;
	if _control.isKindOf(JadeDockBar) and _control.JadeDockBar.floatingStyle &lt;&gt; JadeDockBar.FloatingStyle_None then
		self.mnuSep1.visible:=true;
		
		self.buildShowFrameMenu();
		self.buildHideFrameMenu();
		self.buildDockFrameMenu();
		self.buildFloatFrameMenu();
	endif;
	x1	:=	_x;
	y1	:=	_y;
	
	if (not _mouse) then  // if keyboard, use current listIndex value
	    x1	:=	1;
	    y1	:=	1;
	endif;

	_conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	self.popupMenu(self.mnuDockOptions, x1.Integer, y1.Integer);
	
	return true;
end;


</source>
        <access>protected</access>
        <Parameter name="_control" type="Control" usage="input"/>
        <Parameter name="_conwin" type="Window" usage="input"/>
        <Parameter name="_mouse" type="Boolean"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zBuildTreeContextMenu" id="0be97809-0808-464d-ac9b-7e4fc05e74cb">
        <updating/>
        <source>zBuildTreeContextMenu(_lst : CMUI_ListBox input; _conwin: Window input; _mouse: Boolean; _x: Integer; _y: Integer):Boolean updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	26 April 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	x1,
	y1			: Real;

	clickedIdx			: Integer;
	obj					: CM_Object;				
begin
	clickedIdx := _lst.getListIndex(_x, _y);
	if clickedIdx &gt; 0 and clickedIdx &lt;= _lst.listCount then
		obj := _lst.itemObject[clickedIdx].CM_Object;
	endif;
	
	if obj = null //no object clicked over, so go up to the next conext menu (docking menu probably)
	or self.mode = self.Mode_View  // PAR 16213 added to show the menu always in view mode.
	and not (CM_BulkRelease.hasInstance(obj) and obj.CM_BulkRelease.type = BR_TYPE_RAIL) then // 07/05/2008 cnwar2 #16478
		return true;																		  // (except for rail release - needs to display 'assign outward rail' context menu)
	endif;
	if self.mode &lt;&gt; self.Mode_View then
		self.mnuEditItem.visible := false;
		self.mnuLstTreeSep3.visible := false;
	endif;
	
	self.mnuAddChildItems.visible := false;
	self.mnuAddPeerItems.visible := false;
	
	x1	:=	_x;
	y1	:=	_y;
	if (not _mouse) then  // if keyboard, use current listIndex value
	    x1	:=	1;
	    y1	:=	1;
	endif;
	
	self.buildLstTreeMenu(obj, _conwin, _mouse, _x, _y);

	_conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	self.popupMenu(self.mnuLstTree, x1.Integer, y1.Integer);
	
	return false;
end;


</source>
        <access>protected</access>
        <Parameter name="_lst" type="CMUI_ListBox" usage="input"/>
        <Parameter name="_conwin" type="Window" usage="input"/>
        <Parameter name="_mouse" type="Boolean"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zCloneFrameMenuItem" id="6c344db8-50c5-4aec-b54e-e50474f26bcb">
        <final/>
        <source>zCloneFrameMenuItem(_dockFrame : JadeDockBase; _mnuSubMaster : MenuItem input; _menuIdx : Integer) : MenuItem protected, final;
/*
----------   ----------  --------------------------------------------------
Created:	26 April 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	cloneMenu			: MenuItem;
begin
	
	cloneMenu := _mnuSubMaster.getMenuItem(_menuIdx);
	if cloneMenu = null then
		cloneMenu := _mnuSubMaster.loadMenu(_menuIdx);
	endif;
	
	cloneMenu.caption :=_dockFrame.caption;
	cloneMenu.userObject := _dockFrame;
	cloneMenu.visible:= false;
	return cloneMenu;
	
end;


</source>
        <access>protected</access>
        <Parameter name="_dockFrame" type="JadeDockBase"/>
