    <JadeMethod name="addToolbarControls" id="b3f44462-8a16-414c-8bf1-1f8d03aaa878">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	queryToolbar,
	mainFrm	,toolbar		: CMUI_Toolbar;
begin
	inheritMethod();

	mainFrm := self.frmToolbar;
	queryToolbar := self.frmQueryToolbar;
	
	mainFrm.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

	if self.usesQueryFrame then
		queryToolbar.showCaptions := false;
		self.addToolbarControlsQuery();
		queryToolbar.positionToolbarControls();
		queryToolbar.visible := true;
	endif;
	
	toolbar := self.frmToolBarPopup;
	
	toolbar.addButton(self.btnPopupClose, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPopupPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPopupEnq, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.positionToolbarControls();
	toolbar.visible := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
