    <JadeMethod name="removeButtonAt" id="d17cf960-8ac4-4faa-ade8-022705cce177">
        <updating/>
        <source>removeButtonAt(_idx : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     24 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	controlArray		: CMUI_ToolbarControlArray;
	existingControl		: CMUI_ToolbarControl;

begin
	controlArray := self.allLeftControls;
	if _idx &lt; 1 or _idx &gt; controlArray.size then
		return;
	endif;
	
	existingControl := controlArray[_idx];

	controlArray.removeAt(_idx);
	delete existingControl;
	
	if self.isPositionsCalculated then
		self.cnEcResizeContents();
	endif;

end;</source>
        <Parameter name="_idx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="removeButtonByName" id="192e368a-873f-41a8-8253-816f8d425805">
        <source>removeButtonByName(_btnName : String);
/* ---------------------------------------------------------------------------
Created:     01 October 2009 by cnwrs2

Purpose:     Remove a button from the toolbar
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	tmpControl,
	delControl	: CMUI_ToolbarControl;
	found		: Boolean;
	
begin

	foreach tmpControl in self.allLeftControls do
		if tmpControl.isKindOf(CMUI_ToolbarButton) and
		   tmpControl.CMUI_ToolbarButton.userObjectName  = _btnName then
			found := true;
			break;
		endif;
	endforeach;
	
	if (not found) then
		foreach tmpControl in self.allRightControls do
			if tmpControl.isKindOf(CMUI_ToolbarButton) and
			   tmpControl.CMUI_ToolbarButton.userObjectName  = _btnName then
				found := true;
				break;
			endif;
		endforeach;
	endif;
	
	if found then
		delete tmpControl;
	endif;

epilog

end;</source>
        <Parameter name="_btnName" type="String"/>
    </JadeMethod>
    <JadeMethod name="repositionAfterResize" id="6a64f9bc-6722-42d6-a505-518ece6837d8">
        <updating/>
        <source>repositionAfterResize() updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();

	if self.showCaptions then
		self.height := HeightWithCaptions;// + (self.ControlGap * 2);
	else
		self.height := HeightWithoutCaptions;// + (self.ControlGap * 2);	
	endif;

	self.cnEcResizeContents();

end;</source>
    </JadeMethod>
    <JadeMethod name="resetButtonStateForParent" id="fa246ec3-f83d-4451-b1cf-ffaae1ad7575">
        <source>resetButtonStateForParent(_btn : CMUI_ToolbarButton; _parent : Window);
// ---------------------------------------------------------------------------
// Created:     11 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	cntrl	: CMUI_ToolbarControl;
	tmpBtn	: CMUI_ToolbarButton;
begin

	foreach cntrl in self.allLeftControls where cntrl.isKindOf(CMUI_ToolbarButton) do
		tmpBtn := cntrl.CMUI_ToolbarButton;
		if tmpBtn &lt;&gt; _btn then
			cntrl.CMUI_ToolbarButton.resetButtonsInGroup(false, _parent);
		endif;
	endforeach;

end;</source>
        <Parameter name="_btn" type="CMUI_ToolbarButton"/>
        <Parameter name="_parent" type="Window"/>
    </JadeMethod>
    <JadeMethod name="setHorizontalOffsetLeft" id="02072231-bba5-4ff1-851d-09a2724f801f">
        <updating/>
        <source>setHorizontalOffsetLeft(_value : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2009	cnwer1	Initial creation

*/

vars

begin
	self.horizontalOffsetLeft:=_value;

epilog

end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setToolbarControlsEnabled" id="359e2c00-1d8a-4380-a437-39dec2cb1158">
        <source>setToolbarControlsEnabled(_enabled : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2009	cnwer1	Initial creation

*/

vars

	tbControl : CMUI_ToolbarControl;
begin

	foreach tbControl in self.allRightControls do
		tbControl.enabled:=_enabled;
	endforeach;
	
	foreach tbControl in self.allLeftControls do
		tbControl.enabled:=_enabled;
	endforeach;
	
	foreach tbControl in self.allMoreToShowControls do
		tbControl.enabled:=_enabled;
	endforeach;

epilog

end;</source>
        <Parameter name="_enabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showCaptions" id="dd2ebee2-f348-441e-a28a-71d99cb7c63a">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>showCaptions(set: Boolean; _value: Boolean io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     30 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	control					: CMUI_ToolbarControl;
begin
	
	if set then
		self.showCaptions := _value;
		foreach control in self.allLeftControls do
			control.setShowCaptions(_value);
		endforeach;
		foreach control in self.allRightControls do
			control.setShowCaptions(_value);
		endforeach;
		if self.isPositionsCalculated then
			self.positionToolbarControls();	
		endif;
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="showMoreToShowButton" id="3ffc4dba-6375-4b1c-80e6-ca4c058c1298">
        <source>showMoreToShowButton(_rightMargin : Real) protected;
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if self.myMoreToShowButton = null then
		return;
	endif;
	
	self.myMoreToShowButton.left := _rightMargin - self.ControlGap - self.MoreToShowWidth;
	self.myMoreToShowButton.visible := true;

end;</source>
        <access>protected</access>
        <Parameter name="_rightMargin" type="Real"/>
    </JadeMethod>
    <JadeMethod name="showMoreToShowContextMenu" id="bb7c3bf1-2ce5-46d0-895d-a5fe5468e6e8">
        <updating/>
        <source>showMoreToShowContextMenu() updating;
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 27/08/2012	cnwcs5	par 30274 - handle checked/unchecked when user button is 2-state
// 29/10/2012	cnwcs5	par 29653 - handle pictureDown for 2-state button
vars
	menuItem	: MenuItem;
	baseForm	: CM_BaseForm;
	numControls,
	idx			: Integer;
	control		: CMUI_ToolbarControl;
	toolbarBtn	: CMUI_ToolbarButton;
	realBtn		: CMUI_ButtonForToolbar;
	x1, y1		: Real;
	menuUserToolbar		: CM_MenuUserToolbar;	
	tb 			: Object;
	allFormTBs : ObjectSet;
	maxClonedShowAllMenus : Integer;
begin  
	if self.myMoreToShowButton = null then
		return;
	endif;
	
	if (not self.form.isKindOf(CM_BaseForm)) then
		return;
	endif;

	baseForm := self.form.CM_BaseForm;
	numControls := self.allMoreToShowControls.size;
	
	create allFormTBs transient;
	baseForm.getAllToolbarFrames(allFormTBs);
	if not allFormTBs.includes(self) then
		allFormTBs.add(self);
	endif;
	
	//epr par 30950 some forms like RORO planning have 2 rows of toolbars need to check all this for the clones menus
	foreach tb in allFormTBs do
		maxClonedShowAllMenus:=maxClonedShowAllMenus.max(tb.CMUI_Toolbar.lastMoreToShowMax);
	endforeach;
	
	// now delete all the menuItems created - do this rather than reuse
	// as they may be recreated out of order for the next show

	foreach idx in 1 to  maxClonedShowAllMenus do
		menuItem := baseForm.mnuToolbarMoreClone.getMenuItem(idx);
		
		delete menuItem;
	endforeach;
	
	foreach control in self.allMoreToShowControls reversed do

		if (not control.isKindOf(CMUI_ToolbarButton)) then
			continue;
		endif;
		
		idx 		:= idx + 1;
		toolbarBtn 	:= control.CMUI_ToolbarButton;
		
		if toolbarBtn.referenceType = CMUI_ToolbarButton.ReferenceType_MenuUserToolbar then 
			menuUserToolbar := toolbarBtn.getMenuUserToolbar();
			menuItem := baseForm.mnuToolbarMoreClone.loadMenu(idx);
		
			menuItem.caption	:= menuUserToolbar.heading;
			menuItem.enabled  	:= control.enabled;
			
			if menuItem.enabled then
				menuItem.picture := menuUserToolbar.pictureButton;
			endif;
			
			menuItem.visible := true;
			menuItem.userObject	:= menuUserToolbar;
		else 
			realBtn 			:= toolbarBtn.getButtonForToolbar();
			menuItem 			:= baseForm.mnuToolbarMoreClone.loadMenu(idx);
			menuItem.caption 	:= realBtn.caption;
			menuItem.enabled  	:= control.enabled;
			
			if menuItem.enabled then
				// par 29653 - handle pictureDown for 2-state button
				if realBtn.style = Button.Style_Normal then //or not realBtn.value then
					// normal button or 2-state button not clicked
					if realBtn.picture = null then
						menuItem.picture := realBtn.myToolbarButton.getMyPicture.createPicture(false,false,24);
					else
						menuItem.picture := realBtn.picture;
					endif;
				else
					// 2-state button which is clicked 
					if realBtn.pictureDown = null then
						// if no pictureDown then use picture property
						if realBtn.picture = null then
							menuItem.picture := realBtn.myToolbarButton.getMyPicture.createPicture(false,false,24);
						else
							menuItem.picture := realBtn.picture;
						endif;
					else
						menuItem.picture := realBtn.pictureDown;
					endif;
				endif;
				// the checked property indicates the state of a 2-state button - par 30274 Aug 2012
				//epr par 30950 28/1/15
				if realBtn.style = Button.Style_2State or realBtn.style =  Button.Style_Auto2State then	
					if realBtn.value then
						menuItem.checked := true;
					endif;
				endif;
			else
				if realBtn.pictureDisabled = null then
					if realBtn.pictureDown = null then
						menuItem.picture := realBtn.myToolbarButton.getMyPicture.createPicture(false,false,24);
					else
						menuItem.picture := realBtn.pictureDown;
					endif;
				else
					menuItem.picture := realBtn.pictureDisabled;
				endif;
			endif;
			menuItem.visible 	:= true;
			menuItem.userObject	:= realBtn;
		endif;
	endforeach;

	self.lastMoreToShowMax := idx;

	x1 := 4;
	if self.showCaptions then
		y1 := (self.HeightWithCaptions - 4).Integer;
	else
		y1 := (self.HeightWithoutCaptions - 4).Integer;
	endif;

	self.myMoreToShowButton.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form

	baseForm.popupMenu(baseForm.mnuToolbarMoreToShow, x1.Integer, y1.Integer);
epilog
	delete allFormTBs;
end;</source>
    </JadeMethod>
    <JadeMethod name="showSeperator" id="bf589578-3798-45ce-9bfa-96119b2085df">
        <source>showSeperator(_idx : Integer);
// ---------------------------------------------------------------------------
// Created:     24 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpSeperator	: CMUI_ToolbarSeperator;
	
begin
	tmpSeperator := self.getSeperatorFromIndex(_idx);
	if tmpSeperator = null then
		return;
	endif;
	tmpSeperator.visible := true;
end;</source>
        <Parameter name="_idx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateControls" id="8bbfc1d3-a8ff-444b-b2e6-5e9828f61378">
        <source>updateControls();
// ---------------------------------------------------------------------------
// Created:     28 July 2003		cnwth2	
//
// Purpose:     Call this to make the toolbar frame go through and update all of its buttons
//				to have the same settings as their menuItems	 
// ----------   ----------  --------------------------------------------------
vars
	control		: CMUI_ToolbarControl;
begin

	foreach control in self.allLeftControls do
		control.updateSelf(self.showCaptions);
	endforeach;
	foreach control in self.allRightControls do
		control.updateSelf(self.showCaptions);
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="updateSelfForPermissions" id="1262d620-4e60-43e0-bc8f-9509e2c92455">
        <source>updateSelfForPermissions(_user : CM_User; _terminal : CM_Terminal);
// ---------------------------------------------------------------------------
// Created:     28 July 2003		cnwth2	
//
// Purpose:     Set enabled of all menuUserToolbarButtons based on user's permissions		 
// ----------   ----------  --------------------------------------------------
vars
	control			: CMUI_ToolbarControl;
	
begin

	if _user = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'User passed was null');
		return;
	endif;
	
	if _terminal = null then
		// DVB Need to know terminal or else things go haywire.
		// Rather have icons that raise exception than ones
		// that you can't click even though the user has access.
		// This should only happen if the navigator was closed and
		// the second to last window to open was a system item and the toobar
		// is being updated after the customise toolbar window just closed.
		return;
	endif;
	
	foreach control in self.allLeftControls do
		control.setForPermission(_user, _terminal);
	endforeach;
	foreach control in self.allRightControls do
		control.setForPermission(_user, _terminal);
	endforeach;

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="5d3edbf1-b1eb-4f28-838a-010908be478a">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// ---------------------------------------------------------------------------
// Created:     25 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod(cntrl, persistCntrl);
	self.visible := false; //don;t display while setting self up
	self.borderStyle := Frame.BorderStyle_None; //BorderStyle_Single;
	self.boundaryWidth := 0;
	self.bevelInner := self.Bevel_None;
	self.bevelOuter := self.Bevel_None;
	self.bevelInnerWidth := 0;
	self.boundaryBrush := self.BoundaryBrush_Solid;
	self.caption := null;
	self.enabled := true;
	self.autoRedraw := true;
	
	//cnwmc5 - PAR #31051
	if not self.isInPainter() and app.myPassport.myUser &lt;&gt; null then
		if not app.isUsingSkin() then
			self.bevelInner := self.Bevel_Raised;
			self.bevelInnerWidth := 1;
		endif;
	endif;
		
	self.transparent := false;
	
	self.top := 0;
	self.left := 0;
	self.stretchWidth := true;

	self.createMasterButton();
	self.createMasterSeperator();
	self.createMoreToShowButton();

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
