    <JadeMethod name="displayReport" id="d5d23e09-db73-4126-89f0-4545853c387e">
        <source>displayReport(_area : CM_String; _selected : Boolean) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2025	navpw1	Initial creation

*/

vars

begin
	if _area = null then
		return null;
	endif;

	if _selected then
		return TableCheckBox_Selected &amp; Tab &amp; _area.string;
	else
		return TableCheckBox_NotSelected &amp; Tab &amp; _area.string;
	endif;
	
epilog

end;</source>
        <Parameter name="_area" type="CM_String"/>
        <Parameter name="_selected" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doFindUser" id="dedfff50-bf53-4afe-8125-e99bac29864a">
        <updating/>
        <source>doFindUser() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
10 October 2012	cnwmc5	Initial creation
16 April 2025	navpw1	JIRA: MTN-34402: Added Control Id as the list reports is a duplicated control

*/

vars
	userEmail	: UM_UserEmailAddress;
	rowNum		: Integer;
	controlId	: Integer;
	
begin	
	if self.txtFind.text = null then
		app.msgBox("Please enter a username to search for!", "Error!", MsgBox_OK_Cancel);
	else
		self.allReportControls.purge;
		self.tblUserData.rows := 1;
		controlId := 13000;
		foreach userEmail in self.myRoot.allUserEmailAddresses do
			//if userEmail.user.cnContains(self.txtFind.text) or userEmail.altUser.cnContains(self.txtFind.text) then
			if app.returnCorrectUserName(userEmail.user, false).cnContains(self.txtFind.text) or userEmail.altUser.cnContains(self.txtFind.text) then
				rowNum := self.tblUserData.addItem(null);
				self.setupNewRow(rowNum, controlId);
				
				self.tblUserData.accessCell(rowNum, 1).text := userEmail.isAdmin.Integer.String &amp; Tab &amp; 
				//userEmail.user &amp; Tab &amp; 
				app.returnCorrectUserName(userEmail.user, false) &amp; Tab &amp; 
				self.getMethodCount(app.returnCorrectUserName(userEmail.user, true)) &amp; Tab &amp; 
				userEmail.getsSummary.Integer.String &amp; Tab &amp;  
				userEmail.getsUserSummary.Integer.String &amp; Tab &amp;  
				userEmail.getsUserIgnore.Integer.String &amp; Tab &amp;  
				userEmail.isTester.Integer.String &amp; Tab &amp; 
				userEmail.allReports.asCSV(false) &amp; Tab &amp; 
				userEmail.altUser &amp; Tab &amp;  
				userEmail.isDisabled.Integer.String;			
			endif;
		endforeach;
		
		if self.tblUserData.rows = 1 then
			app.msgBox("No results were found!", "Error!", MsgBox_OK_Cancel);
			self.txtFind.text := null;
			self.populateTable();
		endif;
		
		self.toggleRowsReadOnly(true);
		self.getAltUsers();
		self.checkForAltUserErrors();
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="d4d3826e-66c5-4cb5-94d6-2695f1552e62">
        <updating/>
        <source>doSave() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
10 October 2012	cnwmc5	Initial creation
17 April 2025	navpw1	JIRA: MTN-34402 - Refactored code and added constant DeleteUsers_Column so that the column will be the correct one.

*/

vars
	tbl 				: CM_Table;
	userEmail			: UM_UserEmailAddress;
	rowNum 				: Integer;
	userName,
	altUser,
	origUserName		: String;
	isAdmin,
	summary,
	userSummary,
	userIgnore,
 	isDisabled,
	isTester,
	isMarkedDeleted		: Boolean;
	toDelete			: StringArray;
	allReports			: StringArray;
	
begin
	tbl := self.tblUserData;
	
	tbl.setFocus();
	
	create toDelete transient;
	
	beginTransaction;
		if self.isNew then
			create userEmail persistent;
			rowNum := tbl.rows;
			
			self.getTableData(rowNum, userName, altUser, isAdmin, summary, userSummary, userIgnore, isDisabled, isTester, isMarkedDeleted, allReports);
			userEmail.setNewUserDetails(userName, altUser, isAdmin, summary, userSummary, userIgnore, isDisabled, isTester, allReports);
			delete allReports;
			
		else
			foreach rowNum in 2 to tbl.rows do
				userName := app.returnCorrectUserName(tbl.accessCell(rowNum, self.User_Column).text, true);
				origUserName := tbl.accessCell(rowNum, self.OrigUserCode_Column).text;
				userEmail := self.myRoot.allUserEmailAddresses[origUserName];
				
				if tbl.accessCell(rowNum, self.DeleteUsers_Column).text.Integer.Boolean then
					toDelete.add(tbl.accessCell(rowNum, self.User_Column).text);
				else
					if userEmail = null then
						create userEmail persistent;
					endif;
					
					self.getTableData(rowNum, userName, altUser, isAdmin, summary, userSummary, userIgnore, isDisabled, isTester, isMarkedDeleted, allReports);
					userEmail.setNewUserDetails(origUserName, altUser, isAdmin, summary, userSummary, userIgnore, isDisabled, isTester, allReports);
					delete allReports;
				endif;
			endforeach;
		endif;
	commitTransaction;
	
	// delete the following uses
	if toDelete.size &gt; 0 then	
		if app.msgBox("Are you sure wish to delete the following?" &amp; CrLf &amp; toDelete.concatenate(", "), "Warning!", MsgBox_Yes_No + MsgBox_Information_Icon) = MsgBox_Return_Yes then
			beginTransaction;
			foreach userName in toDelete do
				userName := app.returnCorrectUserName(userName, true);
				userEmail:= self.myRoot.allUserEmailAddresses[userName];
				if userEmail &lt;&gt; null then
					delete userEmail;
				endif;
			endforeach;
			commitTransaction;
		endif;
	endif;
	
	self.populateTable();
	
epilog
	delete toDelete;

end;</source>
    </JadeMethod>
    <JadeMethod name="enableDisableAll" id="15245bce-c00e-4adb-b8d9-c332a21ceae2">
        <updating/>
        <source>enableDisableAll(_isEnabled : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 October 2012	cnwmc5	Initial creation
17 April 2025	navpw1	JIRA: MTN-34402 - Refactored code

*/

vars
	tbl 	: CM_Table;
	cell 	: JadeTableCell;
	
	row 	: Integer;
	cellText: String;
	
begin
	tbl := self.tblUserData;
	row := 2;
	
	if not _isEnabled then
		cellText := _isEnabled.String;
	endif;
	
	while row &lt;= tbl.rows do
		cell := tbl.accessCell(row, self.DisableUsers_Column);
		tbl.setCellText(row, self.DisableUsers_Column, cellText);
		row := row + 1;
	endwhile;
	
end;</source>
        <Parameter name="_isEnabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAltUsers" id="55a88c22-30b2-402e-841c-62cb56cec6fb">
        <updating/>
        <source>getAltUsers() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 October 2012	cnwmc5	Initial creation

*/

vars
	user		: UM_UserEmailAddress;
	
begin
	self.cmbAltUsers.clear();
	
	self.cmbAltUsers.addItem(null);

	foreach user in self.myRoot.allUserEmailAddresses where user.altUser = null do
		//self.cmbAltUsers.addItem(user.user);
		self.cmbAltUsers.addItem(app.returnCorrectUserName(user.user, false));
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAvailableReports" id="eb9af11c-2d4c-4c4a-b7ae-e4e0df011fd7">
        <source>getAvailableReports() protected;
/*

Purpose:			Gets all the available reports

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
15 April 2025	navpw1	Initial creation JIRA: MTN-34402

*/

vars
	availableReports	: ObjectArray;
	reports				: StringArray;
	report				: String;
	stringObj			: CM_String;
	
begin
	create reports transient;
	
	reports.add(UT_UnitTest.Team_Andrew);
	reports.add(UT_UnitTest.Team_Phil);
	reports.add(UT_UnitTest.Team_Mason);
	reports.add(UT_UnitTest.Team_Mohamed);
	reports.add(UT_UnitTest.Team_Ram);
	reports.add(UT_UnitTest.Team_None);
	
	availableReports := self.allAvailableReports;
	
	availableReports.clear;
	
	foreach report in reports do
		create stringObj transient;
		stringObj.string := report;
		availableReports.add(stringObj);
		
	endforeach;
	
epilog
	delete reports;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getMethodCount" id="1d69ff5c-e5e6-4f67-895b-c75b9d9433aa">
        <source>getMethodCount(_user : String) : String;

/*

Purpose:		Return the method count as a string

Date			Who		Reason
16/04/2014		cnwmh5	Initial creation

*/

vars

	indexOf 					: Integer;
	methodCount					: String;
	
begin

	indexOf := self.allMethodOwners.indexOf(_user);
	if indexOf &gt; 0 then
		methodCount := self.allOwnerMethodsCount[indexOf].String;
	endif;

	return methodCount;
	
epilog

end;</source>
        <Parameter name="_user" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTableData" id="d816dee9-8f7e-44e0-a382-1422eabf50c8">
        <updating/>
        <source>getTableData(	_rowNum			: Integer;
				_userName, 
				_altUser		: String output; 
				_isAdmin, 
				_summary, 
				_userSummary, 
				_userIgnore, 
				_isDisabled, 
				_isTester,
				_isMarkedDelete	: Boolean output;
				_allReports		: StringArray output) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 October 2012	cnwmc5	Initial creation
17 April 2025	navpw1	JIRA: MTN-34402 - Added isMarkedDeleted parameter to allow us to tell if the row is deleted instead of accessing row in outside method

*/

vars
	tbl : CM_Table;
	allReports : String;
	
begin
	tbl := self.tblUserData;

	_isAdmin		:= tbl.accessCell(_rowNum, self.IsAdmin_Column).text.Integer.Boolean;
	_userName 		:= tbl.accessCell(_rowNum, self.User_Column).text;
	
	_summary		:= tbl.accessCell(_rowNum, self.Summary_Column).text.Integer.Boolean;
	_userSummary	:= tbl.accessCell(_rowNum, self.UserSummary_Column).text.Integer.Boolean;
	_userIgnore		:= tbl.accessCell(_rowNum, self.UserIgnore_Column).text.Integer.Boolean;
	_isTester		:= tbl.accessCell(_rowNum, self.Tester_Column).text.Integer.Boolean;
	UM_UserEmailAddress@getAllReportsFromString(tbl.accessCell(_rowNum, self.ReportsList_Column).text, _allReports);
	_altUser		:= tbl.accessCell(_rowNum, self.AltUser_Column).text;
	_isDisabled		:= tbl.accessCell(_rowNum, self.DisableUsers_Column).text.Integer.Boolean;
	_isMarkedDelete	:= tbl.accessCell(_rowNum, self.DeleteUsers_Column).text.Integer.Boolean;
	
epilog

end;</source>
        <Parameter name="_rowNum" type="Integer"/>
        <Parameter name="_userName" type="String" usage="output"/>
        <Parameter name="_altUser" type="String" usage="output"/>
        <Parameter name="_isAdmin" type="Boolean" usage="output"/>
        <Parameter name="_summary" type="Boolean" usage="output"/>
        <Parameter name="_userSummary" type="Boolean" usage="output"/>
        <Parameter name="_userIgnore" type="Boolean" usage="output"/>
        <Parameter name="_isDisabled" type="Boolean" usage="output"/>
        <Parameter name="_isTester" type="Boolean" usage="output"/>
        <Parameter name="_isMarkedDelete" type="Boolean" usage="output"/>
        <Parameter name="_allReports" type="StringArray" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getUserMethodsCount" id="8d968f0a-d8ff-410e-9105-75b977f3062d">
        <updating/>
        <source>getUserMethodsCount() updating;

/*

Purpose:		

Date			Who		Reason
16 April 2014	cnwmh5	Initial creation
16/03/2014		cnwmh5	Transient Leaks
*/

vars

	klass						: Class;
	meth						: Method;
	
	classes						: ClassColl;
	methodsDict					: MethodNDict;
	tokens						: StringArray512;
	
	found						: Boolean;
	linePos						: Integer;
	line						: String;
	token						: String;
	cnwPos						: Integer;
	userName					: String;
	indexOf						: Integer;

begin

	// get UT_DSL class
	klass := currentSchema.getClass("UT_DSL");
	if klass = null then
		return;
	endif;
	
	// create classes
	create classes transient;
	classes.add(klass);
	klass.allLocalSubclasses(classes);
	
	create tokens transient;
	foreach klass in classes do
	
		methodsDict := klass.cnGetMethods();
		
		foreach meth in methodsDict where meth.isRunnableUnitTestMethod() do
		
			found := false;
			linePos := 1;
			meth.getSource.cnEcGetNextLine(linePos);
			while linePos &gt; 0 do
				line :=  meth.getSource.cnEcGetNextLine(linePos);
				if (line[1:9] = 'constants' and line.trimBlanks().length = 9) or 		
						(line[1:4] = "vars" and line.trimBlanks().length = 4) then
					break;
				endif;
				line.replaceChar(Tab, ' ');
				tokens.clear;
				if not line.toUpper().cnContains("CNW") and not line.toUpper().cnContains("JLG") then
					continue;
				endif;
				line.getTokensForDelimiter(" ", tokens);
				foreach token in tokens do
					if self.populateMethodOwnerArrays("CNW", tokens) or self.populateMethodOwnerArrays("JLG", tokens) then
						linePos := -1;
						break;
					endif;
					/*
					if token.toUpper().cnContains("CNW") then
						cnwPos := token.toUpper.pos("CNW", 1);
						if cnwPos = 0 then
							continue;
						endif;
						userName := token[cnwPos:end];
						if not self.allMethodOwners.includes(userName.toUpper) then
							self.allMethodOwners.add(userName.toUpper);
							self.allOwnerMethodsCount.add(1);
							linePos := -1;
							//write meth.getSchemaType().name &amp; "::" &amp; meth.name &amp; Tab &amp; userName;
							break;
						else
							indexOf := self.allMethodOwners.indexOf(userName.toUpper);
							if indexOf &lt;&gt; 0 then
								self.allOwnerMethodsCount[indexOf] := self.allOwnerMethodsCount[indexOf] + 1;
							endif;
						endif;
						if token.toUpper().cnContains("CNW") then
							linePos := -1;
							break;
						endif;
					endif;
					*/
				endforeach;
			endwhile;
			
		endforeach;
		
	endforeach;

epilog
	delete tokens;
end;</source>
    </JadeMethod>
    <JadeMethod name="initTable" id="667f14ea-e689-4da7-a07f-1cf5c1e212bc">
        <source>initTable() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
16 April 2025	navpw1	Initial creation JIRA: MTN-34402

*/

vars
	tbl : UT_Table;
	
begin
	tbl := self.tblUserData;
	
	tbl.clear();
	tbl.rows := 1;
	tbl.columns := 12;
	
	tbl.accessCell(1, 1).text := "Admin" &amp; Tab &amp; 
		" User" &amp; Tab &amp; 
		" Meth Count" &amp; Tab &amp; 
		"Summary" &amp; Tab &amp;  
		"User Summary" &amp; Tab &amp;  
		"User Ignore" &amp; Tab &amp; 
		"Tester" &amp; Tab &amp;
		" Reports" &amp; Tab &amp;
		" Alt User" &amp; Tab &amp;  
		"Disable" &amp; Tab &amp;
		"Delete" &amp; Tab &amp;
		"Orig User";
	
	tbl.accessColumn(self.IsAdmin_Column).alignment := Table.Alignment_Center;
	tbl.accessColumn(self.User_Column).alignment := Table.Alignment_Left;
	tbl.accessColumn(self.MethodCount_Column).alignment := Table.Alignment_Center;
	tbl.accessColumn(self.Summary_Column).alignment := Table.Alignment_Center;
	tbl.accessColumn(self.UserSummary_Column).alignment := Table.Alignment_Center;
	tbl.accessColumn(self.UserIgnore_Column).alignment := Table.Alignment_Center;
	tbl.accessColumn(self.Tester_Column).alignment := Table.Alignment_Center;
	tbl.accessColumn(self.ReportsList_Column).alignment := Table.Alignment_Left;
	tbl.accessColumn(self.ReportsList_Column).width := 150;
	tbl.accessColumn(self.AltUser_Column).alignment := Table.Alignment_Left;
	tbl.accessColumn(self.DisableUsers_Column).alignment := Table.Alignment_Center;
	tbl.accessColumn(self.DeleteUsers_Column).alignment := Table.Alignment_Center;
	tbl.accessColumn(self.OrigUserCode_Column).visible := false; //This is a hidden column
	
	tbl.accessRow(1).alignment := Table.Alignment_Center;
	tbl.sortColumn[1] := 2;
	tbl.sortAsc[1] := true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="lstReports_displayRow" id="b415ccad-65bc-4645-a0f9-6156f6fc09dd">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstReports_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2025	navpw1	Initial creation

*/

vars
	selected : Boolean;
begin
	selected := table.UT_ListTable.allSelectedObjects.includes(obj);
	return self.displayReport(obj.CM_String, selected);
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="lstReports_gotFocus" id="766a64a1-333f-4a61-b8b6-611eb1a7f38d">
        <controlMethod name="Table::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstReports_gotFocus(_table: UT_ListTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
16 April 2025	navpw1	Initial creation JIRA: MTN-34402

*/

vars
	userDataTable	: UT_Table;
	jadeRow		: JadeTableRow;
	jadeCell	: JadeTableCell;
	cellText	: String;
	reportArr	: StringArray;
	report		: String;
	
begin	
	userDataTable := self.tblUserData;
	
	_table.clearSelected();
	
	jadeRow := userDataTable.accessRow(userDataTable.row);
	jadeCell := userDataTable.accessCell(userDataTable.row, userDataTable.column);
	
	cellText := jadeCell.text;
	
	if cellText &lt;&gt; null then
		create reportArr transient;
		cellText.getTokensForDelimiter(",", reportArr);
		foreach report in reportArr do
			_table.setSelectedString(report.trimBlankCharacters);
		endforeach;
		
	endif;
	
	jadeRow.height := 110;
	
epilog
	delete reportArr;
	
end;</source>
        <Parameter name="_table" type="UT_ListTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstReports_lostFocus" id="dba3abd4-074a-45db-9b1c-5dea5122f9ad">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstReports_lostFocus(table: UT_ListTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
16 April 2025	navpw1	Initial creation JIRA: MTN-34402

*/

vars
	tbl 	: UT_Table;
	str		: String;
begin
	tbl := self.tblUserData;
	
	str := table.getSelectedFromDisplay();
	if str &lt;&gt; null then
		tbl.setValue(tbl.accessedRow.row, str, self.ReportsList_Column);
		
		table.setSelected(null);
	else
		tbl.setValue(tbl.accessedRow.row, null, self.ReportsList_Column);
		
		table.setSelected(null);
	endif;
	
	tbl.optimiseValueRowHeights(tbl.column);
	tbl.scrollBars := Table.ScrollBars_Vertical;
	
end;</source>
        <Parameter name="table" type="UT_ListTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="populateMethodOwnerArrays" id="3d1d146a-c243-47ea-b128-615ef6527c9f">
        <updating/>
        <source>populateMethodOwnerArrays(_lookFor : String; _tokens : StringArray512 input) : Boolean updating;

/*

Purpose:		Popuplate the method owner array with who created the test

Date			Who		Reason
04/07/2017		cnwmh5	Initial creation

*/

vars

	token					: String;
	lookForPos				: Integer;
	linePos					: Integer;
	userName				: String;
	indexOf					: Integer;
	loopBrokenOutOf			: Boolean;

begin

	loopBrokenOutOf := false;
	//write '_lookFor: ' &amp; _lookFor;

	foreach token in _tokens do
		if token.toUpper().cnContains(_lookFor) then
			lookForPos := token.toUpper.pos(_lookFor, 1);
			if lookForPos = 0 then
				continue;
			endif;
			userName := app.returnCorrectUserName(token[lookForPos:end], true);
			if not self.allMethodOwners.includes(userName.toUpper) then
				self.allMethodOwners.add(userName.toUpper);
				self.allOwnerMethodsCount.add(1);
				linePos := -1;
				loopBrokenOutOf := true;
				break;
			else
				indexOf := self.allMethodOwners.indexOf(userName.toUpper);
				if indexOf &lt;&gt; 0 then
					self.allOwnerMethodsCount[indexOf] := self.allOwnerMethodsCount[indexOf] + 1;
				endif;
			endif;
			if token.toUpper().cnContains(_lookFor) then
				linePos := -1;
				loopBrokenOutOf := true;
				break;
			endif;
		endif;
	endforeach;
	
	return loopBrokenOutOf;

epilog

end;</source>
        <Parameter name="_lookFor" type="String"/>
        <Parameter name="_tokens" type="StringArray512" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateTable" id="bbb26157-a2ed-4c1c-98ce-598bd47c104c">
        <updating/>
        <source>populateTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
09 October 2012	cnwmc5	Initial creation
16 April 2025	navpw1	JIRA: MTN-34402: Added Control Id as the list reports is a duplicated control

*/

vars
	userEmail 	: UM_UserEmailAddress;
	
	rowNum		: Integer;
	string		: CM_String;
	controlId	: Integer;
	
begin
	self.allReportControls.purge;
	self.tblUserData.rows := 1;
	controlId := 13000;
	
	foreach userEmail in self.myRoot.allUserEmailAddresses do
		rowNum := self.tblUserData.addItem(null);
		self.setupNewRow(rowNum, controlId);
		
		self.tblUserData.accessCell(rowNum, 1).text := userEmail.isAdmin.Integer.String &amp; Tab &amp; 
		//userEmail.user &amp; Tab &amp; 
		//self.getMethodCount(userEmail.user) &amp; Tab &amp; 
		app.returnCorrectUserName(userEmail.user, false) &amp; Tab &amp; 
		self.getMethodCount(app.returnCorrectUserName(userEmail.user, true)) &amp; Tab &amp; 
		userEmail.getsSummary.Integer.String &amp; Tab &amp;  
		userEmail.getsUserSummary.Integer.String &amp; Tab &amp;  
		userEmail.getsUserIgnore.Integer.String &amp; Tab &amp;  
		userEmail.isTester.Integer.String &amp; Tab &amp; 
		userEmail.allReports.asCSV(false) &amp; Tab &amp; 
		userEmail.altUser &amp; Tab &amp;  
		userEmail.isDisabled.Integer.String &amp; Tab &amp;
		"" &amp; Tab &amp;
		userEmail.user.String;
	endforeach;
	
	self.controlIdxMax := controlId;
	
	toggleRowsReadOnly(true);
	
	self.getAltUsers();
	
	self.checkForAltUserErrors();
	
	self.tblUserData.doResort();
end;</source>
    </JadeMethod>
    <JadeMethod name="readEmailAddressFromText" id="0682d2be-f525-49fa-8ee8-d631fdb2ec68">
        <source>readEmailAddressFromText();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 October 2012	cnwmc5	Initial creation

*/

vars

	xmlDoc					: JadeXMLDocument;
	element					: JadeXMLElement;
	attribute				: JadeXMLAttribute;
	
	emailAddress			: String;
	
begin

	emailAddress := "@jadeworld.com";

	on JadeXMLException do app.handleXMLExceptions(exception);

	create xmlDoc transient;
	xmlDoc.parseString(UM_UserEmailAddress.getPropertyValue("text").String);
	
	element := xmlDoc.getElementByTagName("EmailAddress");
	if element &lt;&gt; null then
		attribute := element.getAttributeByName("address");
	endif;
	
	if attribute &lt;&gt; null then
		emailAddress := attribute.value;
	endif;
	
	self.txtEAddress.text := emailAddress;	

epilog

	delete xmlDoc;

end;</source>
    </JadeMethod>
    <JadeMethod name="resize" id="32472fdd-1927-4e54-a532-a8003fd01d4b">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
02 November 2012	cnwmh5	Initial creation

*/

vars

begin

	tblUserData.width := self.width - (tblUserData.left * 2) - 15 ;
	
	// horizontal change
	btnDisableAll.left := self.width - btnDisableAll.width - (self.width - tblUserData.left - tblUserData.width);
	btnEnableAll.left := btnDisableAll.left;
	
	btnCancel.left := self.width - btnCancel.width - (self.width - tblUserData.left - tblUserData.width);
	btnSave.left := btnCancel.left - btnSave.width - 5;
	btnSave.top := btnCancel.top;
	btnEdit.left := btnSave.left - btnEdit.width - 5;
	btnEdit.top := btnCancel.top;
	btnNew.left := btnEdit.left - btnNew.width - 5;
	btnNew.top := btnCancel.top;

	// vertical change
	if grpAddress.height &gt; grpLegend.height then
		grpAddress.top := self.height - grpAddress.height - 43;
		grpLegend.top := grpAddress.top;
	else
		grpLegend.top := self.height - grpLegend.height - 43;
		grpAddress.top := grpLegend.top;
	endif;
	
	btnEnableAll.top := self.height - btnEnableAll.height - 43;
	btnDisableAll.top := btnEnableAll.top - 5 - btnDisableAll.height;
	
	tblUserData.height := grpAddress.top - 10 - tblUserData.top;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="saveAddressToText" id="a4e4be68-a8e3-448f-b103-90306087e763">
        <updating/>
        <source>saveAddressToText() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 October 2012	cnwmc5	Initial creation

*/

vars

	xmlDoc				: JadeXMLDocument;
	element				: JadeXMLElement;
	attribute			: JadeXMLAttribute;
	form				: Form;

	text				: String;
	
begin
	
	on JadeXMLException do app.handleXMLExceptions(exception);
	
	create xmlDoc transient;
	xmlDoc.outputDeclaration := true;
	
	element := xmlDoc.addElement("EmailAddress");
	
	if element &lt;&gt; null then
		attribute := element.addAttribute("address", self.txtEAddress.text);
	endif;
	
	beginTransaction;
		UM_UserEmailAddress.setPropertyValue("text", xmlDoc.writeToString());
	commitTransaction;
	
epilog

	delete xmlDoc;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="bc2beeda-80d1-4d96-a086-911b55deed03">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 October 2012	cnwmc5	Initial creation
16 April 2025	navpw1	JIRA: MTN-34402: Added report generation and population of the list reports control

*/

vars
	stringObj : CM_String;
	
begin
	self.myRoot := UM_Root.firstInstance();
	
	if self.myRoot = null then
		return;
	endif;
	
	self.getAvailableReports();
	
	self.lstReports.clearTable;
	
	//Used this over displayCollection in case we need to do scrolling. displayCollection unselects items out of view while scrolling
	foreach stringObj in self.allAvailableReports do
		self.lstReports.addItemObject(stringObj.string, stringObj);
	endforeach;
	
	create self.allMethodOwners transient;
	create self.allOwnerMethodsCount transient;
	self.getUserMethodsCount();								// 16/04/2014 cnwmh5	
	
	//cnwmc5 - 25 July 2013
	//self.caption := "Email Management Form - " &amp; app.myRoot.getConfig(SystemTitle).String;
	self.caption := "Email Management Form - " &amp; app.myCnKarmaCntrl.environmentId.toUpper;
	
	self.initTable();
	
	self.lblErrorColor1.backColor := LightBlue;
	self.lblErrorColor2.backColor := LightRed;
	
	self.populateTable();
	
	self.centreWindow();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupNewRow" id="a96b7321-4c24-4069-939e-5854cc4c7475">
        <source>setupNewRow(_row : Integer; _controlId : Integer io);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
09 October 2012	cnwmc5	Initial creation
16 April 2025	navpw1	JIRA: MTN-34402: Added generation of reports row to have a list table control

*/

vars
	cell				: JadeTableCell;
	lstReportsControl	: UT_ListTable;
	
begin
	cell := self.tblUserData.accessCell(_row, self.IsAdmin_Column);
	cell.inputType := Table.InputType_CheckBox;
	
	cell := self.tblUserData.accessCell(_row, self.User_Column);
	cell.inputType := Table.InputType_TextBox;
	self.txtUser.case := 2;
	cell.cellControl := self.txtUser;
	self.txtUser.enabled := true;
	self.txtUser.visible := true;
	
	cell := self.tblUserData.accessCell(_row, self.MethodCount_Column);
	cell.inputType := Table.InputType_Default;
	cell.enabled := false;
	
	cell := self.tblUserData.accessCell(_row, self.Summary_Column);
	cell.inputType := Table.InputType_CheckBox;
	cell.enabled := false;
	
	cell := self.tblUserData.accessCell(_row, self.UserSummary_Column);
	cell.inputType := Table.InputType_CheckBox;
	cell.enabled := false;
	
	cell := self.tblUserData.accessCell(_row, self.UserIgnore_Column);
	cell.inputType := Table.InputType_CheckBox;
	cell.enabled := false;
	
	cell := self.tblUserData.accessCell(_row, self.Tester_Column);
	cell.inputType := Table.InputType_CheckBox;
	///cell.enabled := false;
	
	cell := self.tblUserData.accessCell(_row, self.ReportsList_Column);
	cell.inputType := Table.InputType_Default;
	_controlId += 1;
	lstReportsControl := self.lstReports.loadControl(_controlId).UT_ListTable;
	lstReportsControl.visible := true;
	lstReportsControl.enabled := true;
	lstReportsControl.name := "lstReports";
	lstReportsControl.setEventMapping("lostFocus", "lstReports_lostFocus");
	lstReportsControl.setEventMapping("gotFocus", "lstReports_gotFocus");
	lstReportsControl.setAvailableOptions(self.allAvailableReports);
	self.allReportControls.add(lstReportsControl);
	self.tblUserData.setControl(_row, self.ReportsList_Column, lstReportsControl);
	
	cell := self.tblUserData.accessCell(_row, self.AltUser_Column);
	cell.inputType := Table.InputType_Default;
	cell.cellControl := self.cmbAltUsers;
	self.cmbAltUsers.enabled := true;
	self.cmbAltUsers.visible := true;
	
	cell := self.tblUserData.accessCell(_row, self.DisableUsers_Column);
	cell.inputType := Table.InputType_CheckBox;
	
	cell := self.tblUserData.accessCell(_row, self.DeleteUsers_Column);
	cell.inputType := Table.InputType_CheckBox;
	
end;</source>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_controlId" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="show" id="c9332709-37c0-4927-a49d-6c4c42448651">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>show() updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 October 2012	cnwmc5	Initial creation

*/

vars

begin
	inheritMethod();
	self.setupForm();
	
	self.readEmailAddressFromText();
	
epilog

end;</source>
    </JadeMethod>
