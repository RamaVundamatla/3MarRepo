    <JadeMethod name="runForegroundReport" id="ac854451-07b7-407c-bd11-124411d86a5e">
        <updating/>
        <source>runForegroundReport(_qryReport 		: CM_QryReport;
					_filterObject 	: CMQF_FilterReports;
					_extraDetail 	: CM_ExtraDetail;
					_profileName	: String;
					_formatOption : Integer;
					_fileName,
					_printerName	: String;
					_printPreview 	: Boolean;
					_noDataEmail 	: Boolean io) updating;							
// ---------------------------------------------------------------------------
// Created:     26 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	numItems		: Integer;
	cmifMonitor		: CMIF_Monitor;
	clientStartTime	: TimeStamp;		// 33875 this is deliberately the client or local date/time, not the server date/time
	startTime,
	logStart,
	logEnd			: TimeStamp;
	endNoteSent		: Boolean;
	replacementFileTS : TimeStamp;
	
begin
	if _qryReport = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Cannot initialize - CM_QryReport instance passed in is null');
		return;
	endif;

	if _formatOption &lt;&gt; JadeReportWriterReport.PRINTER and _fileName.trimBlanks = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Output file name is null');
		return;
	endif;
	
	if app.myPassport &lt;&gt; null then
		app.myPassport.myActivityCapture.startCaptureReport(_qryReport.reportName);
	endif;
	
	self.myQryReport 		:= _qryReport;
	self.myFilterObject		:= _filterObject;
	self.myExtraDetail		:= _extraDetail;
	self.profileName 		:= _profileName;
	self.outputtingToFile	:= (_formatOption &lt;&gt; JadeReportWriterReport.PRINTER);
	self.fileName			:= _fileName;
	self.printerName		:= _printerName;
	self.printPreview		:= _printPreview;

	startTime := app.actualTimeServer;
	app.lockKeeperNotifyStartActivity(startTime, method, null, self.myQryReport.getNameForLockKeeper(0), app.myPassport);
	
	logStart := app.actualTimeServer();
	app.writeLog('Commencing filtering of the data at ' &amp; logStart.shortCurrentLocaleFormat(), LogINFO);
	
	numItems := self.doFilter(); //epr 15/5/18 tfs 38530 
	
	logEnd := app.actualTimeServer();
	app.writeLog('Finished filtering of data. Time taken in seconds to filter is ' &amp; logStart.getDifferenceInSeconds(logEnd).String &amp; ' seconds.', LogINFO); // Add a log entry to make it easier to work out filter vs report painting. PAR25700 cnwsh3
	
	if numItems = 0 and not app.myRoot.getConfig(RunReportWhenNoData).Boolean then
		if not app.isWebApp then
			global.beep;
			app.msgBox(app.getErrorString(No_Print_Output), "No output", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			_noDataEmail := true;				// 10/08/2010 cnwmh5 #25358
			return;
		endif;
		// Par 12335
		//return;
	endif; 
	
	//17 Sep 2013	NDL	Par 32466 - numItems represents how much data will be sent to the report writer.
	if self.fileName &lt;&gt; null and not app.myRoot.getConfig(RunReportWhenNoData).Boolean and not app.isWebApp then
		// if the file is pre-existing get its last modified date.
		app.removeFile(self.fileName, false);
	endif;

	endNoteSent := app.lockKeeperNotifyEndActivity(startTime, true, app.myPassport);

	cmifMonitor := app.myPassport.myCMIFMonitor;
	if cmifMonitor &lt;&gt; null then
		if cmifMonitor.partsInJob &lt; numItems then
			cmifMonitor.partsInJob := numItems;
		endif;
		cmifMonitor.partsDone := numItems;
		cmifMonitor.updateProgress(CMUI_ReportRunner.REPORT_COMPLETE_MESSAGE, cmifMonitor.partsInJob, cmifMonitor.partsDone);
		if cmifMonitor.monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Cancel then
			return;
		endif;
	endif;

	if (not self.myQryReport.isFormBasedReport) then
		self.runJRWReportForeground(_formatOption, clientStartTime );
	else
		self.runStaticReportForeground();
	endif;
	
	//17 Sep 2013	NDL	Par 32466
	if self.fileName &lt;&gt; null then
		//app.getFileLastModified( self.fileName, replacementFileTS );
		app.getFileLastModifiedWithWait(self.fileName, replacementFileTS, 500, 10); //11/07/2024	navkc1 CR 64837 Task 64852
		// 33875 file was created on client using client PC time so compare using the client current time (was previously startTime from server)
		if not replacementFileTS.Date.isValid or replacementFileTS &lt; clientStartTime then
			// No file, or file too old, indicate that they should NOT send it.
			if app.isWebApp then
				_noDataEmail := true;
				app.raiseCMException(No_Print_Output,null, null);
				return;
			else
				app.msgBox(app.getErrorString(No_Print_Output), "No output", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			endif;
			_noDataEmail := true;
		endif;
	endif;

epilog
	if (not endNoteSent) then
		app.lockKeeperNotifyEndActivity(startTime, true, app.myPassport);
	endif;
	if app.myPassport &lt;&gt; null then
		app.myPassport.myActivityCapture.stopCaptureReport();
	endif;
	
end;</source>
        <Parameter name="_qryReport" type="CM_QryReport"/>
        <Parameter name="_filterObject" type="CMQF_FilterReports"/>
        <Parameter name="_extraDetail" type="CM_ExtraDetail"/>
        <Parameter name="_profileName" type="String"/>
        <Parameter name="_formatOption" type="Integer"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_printerName" type="String"/>
        <Parameter name="_printPreview" type="Boolean"/>
        <Parameter name="_noDataEmail" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="runJRWReportForeground" id="bd8a2a67-2f20-424b-acaa-ff4c139c2a52">
        <source>runJRWReportForeground(_formatOption : Integer; _clientStartTime : TimeStamp ) protected;
// ---------------------------------------------------------------------------
// Created:     26 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
/*
Date		Who		Reason
17 Sep 2008	cnwkpd1	PAR #17924 - 15022 exception from web when running multi part JRW reports
17 Mar 2010	consw1	PAR #22886 - Leaking report transients
17 Nov 2015	cnwkpd1	PAR #37177 - No data report issues for Web Service
13 Dec 2017	jlgkpd1	TFS #8294 - Initiate compact of transient file after running a report
22 Feb 2018 jlgmd1	TFS #37204 - MSL - Wrong behavior during Report launch
06 Nov 2018 jlgrh7 	TFS #41338 CIG - Problems generating reports
29 May 2019 cnwma1	Bug 44935: PKT - Creating JMT Reports Printing Issue
*/

vars
	jadeReport 			: JadeReportWriterReport;
	tmpJadeReport,
	pxyJadeReport		: JadeReport;
	tmpPrintData,
	pxyPrintData		: JadePrintData;
	profileArray		: StringArray;
	profName,
	logStr,
	repName,
	repNameLetter		: String;
	isSecondTime		: Boolean;
	extPos,
	idx,
	partNum,
	pageNum				: Integer;
	pPreviewCalled 		: Boolean;
	cmifMonitor			: CMIF_Monitor;
	secondFileName		: String;
	appendableFileName	: String;
	fileExtention		: String;
	startTime			: TimeStamp;
	reportArray			: StringArray;
	iter				: Iterator;

	endNoteSent			: Boolean;
	// page options
	documentType: Integer;
	file : File;
	filedSep,										//+TFS41338 starts To get Delimiter File Options
	fieldDelim : Character;
	isExtGroupHead,
	isExtGroupFooter,
	isExtReportHead,
	isExtReportFooter,
	isCombinedGropDetails,
	isFormatDates,
	isFormatNumerics : Boolean;
	duplex           : Integer;
	
begin
	
	create pxyJadeReport transient;
	create reportArray transient;
	create file transient;
	file.mode := File.Mode_Output;

	//epr 24/1/2008 par 15661 everytime app.printer.getDefaultDocumentType is called this is opening the printer which is a big performance overhead
	// this is done in JadeReport::getPageOptions so no need to do it here
	// e.g. was being done 3 times in this method and a report with no output went from taking 9 secs to 4 secs
	documentType := app.printer.documentType; 
	duplex       := app.printer.duplex;						//29.05.2019 cnwma1 #44935
	profileArray := self.myQryReport.jrwReportProfileName;
	cmifMonitor  := app.myPassport.myCMIFMonitor;
	//09/03/2010 cnwdz2 par22817
	//extPos := self.fileName.pos(".", 1);
	extPos := self.fileName.reversePos(".");
	if extPos &gt; 0 then
		//fileExtention := self.fileName[extPos:4];
		fileExtention := self.fileName[extPos:end];	//09/03/2010 cnwdz2 par22817
		appendableFileName := self.fileName[1:extPos-1];
	else
		appendableFileName := self.fileName;
	endif;

	//app.writeLog(method.qualifiedName &amp; " appendableFileName=" &amp; appendableFileName &amp;
	//			" fileExtention=" &amp; fileExtention, 0);
				
	app.myQAFilter.getReportsToRun(self.myQryReport, self.myFilterObject, reportArray);
	
	//	foreach repName in self.myQryReport.jrwReportName do
	foreach repName in reportArray do
		// PAR #17924 - Reinstate previous patch for 16162/15953
		//PAR16162/15953 A report with multiple designs over the web was causing a 15022 error.  
		//Need to abort the process before running the next report to reset the document type as we are
		//calling the setReport in our code further down. 30/4/2008
		app.printer.abort();

		idx := idx + 1;
	
		//jadeReport := self.myJadeReportWriterManager.getReport(repName);
		jadeReport := null;
		
		// 7/6/2006 Lorcan If the printer is set up for letter try to get the report for letter (i.e repName followed by _L)
		if documentType = Print_Letter then
			repNameLetter := repName &amp; "_L";
			jadeReport := self.myJadeReportWriterManager.getReport(repNameLetter);
		endif;

		if jadeReport = null then
			jadeReport := self.myJadeReportWriterManager.getReport(repName);
		endif;

		if jadeReport = null then
			app.writeLog(logStr &amp; 'JRW Report (' &amp; repName &amp; ') not found', LogINFO);
			app.raiseCMException2(ERR_INVALID_VALUE, "the report name: " &amp; repName, "Contact Developer", null,null);
			return;
		endif;

		//if profile is specified then use it
		if self.profileName &lt;&gt; null then
			profName := self.profileName.trimBlanks;
		else
			if profileArray &lt;&gt; null and profileArray.size &gt;= idx then
				profName := profileArray[idx];
			endif;
		endif;		
		
		if profName &lt;&gt; null then
			jadeReport.setProfile(profName);
		endif;

		if self.outputtingToFile then
			
			//TFS 37204 - moved to above the tryOpen check to get the new filename first
			if isSecondTime then
			//	secondFileName := 'JMT_' &amp; self.csvFileName &amp; self.getInstanceIdForObject(process).String;
				secondFileName := appendableFileName &amp; "_" &amp; idx.String &amp; fileExtention;
				jadeReport.setOutputFileTitle(secondFileName);
				file.fileName := secondFileName;
			else
				jadeReport.setOutputFileTitle(self.fileName);
				file.fileName := self.fileName;
				
			endif;
			
			//epr TFS 4261 1/5/17
			//epr TFS 4773 15/6/17
			if not app.isWebApp then			
				if (not file.tryOpen) then
					app.raiseCMException1(FileUnavailable, file.fileName, null, null);	
					return;
				endif;
			endif;		
		else
			//cnwth2 - Jade 6 has no 'setPrinterOptions' method - replaced by the following
			//still need a way of setting the printer???
			jadeReport.setPreviewOptions(false, false, false, false, null);

		endif;
		
		jadeReport.setOutputDestination(_formatOption);
		
		// Set print preview to false to force to object rather than printer output.
		app.printer.printPreview := false;
		app.printer.setReport(pxyJadeReport);	//need to do this for each report
		partNum := partNum + 1;

		app.writeLog(logStr &amp; 'running report - start, part ' &amp; partNum.String &amp; ' ' &amp; jadeReport.name, LogINFO);
	
		//these are for multi reports - doesn't barf if report does not have these params.
		jadeReport.setParameter('startPage', pageNum);
		jadeReport.setParameter('partNumber', partNum);
		self.setParameters(jadeReport);

		startTime := app.actualTimeServer;
		app.lockKeeperNotifyStartActivity(startTime, method, null, self.myQryReport.getNameForLockKeeper(idx), app.myPassport);

		// Very necessary
		if app.isWebApp then
			app.printer.suppressDialog := true;
		endif;
				
		jadeReport.getDelimitedFileOptions(	filedSep,							//+TFS41338
																					fieldDelim,
																					isExtGroupHead,
																					isExtGroupFooter,
																					isExtReportHead,
																					isExtReportFooter,
																					isCombinedGropDetails,
																					isFormatDates,
																					isFormatNumerics);
		jadeReport.setDelimitedFileOptions(	filedSep,							//+TFS41338
																					fieldDelim,
																					isExtGroupHead,
																					isExtGroupFooter,
																					isExtReportHead,
																					isExtReportFooter,
																					false,
																					isFormatDates,
																					isFormatNumerics);
		
		
		
	///	',',',',false,true,false,false,false,false,false);
		
		
		jadeReport.run;
		
		process.initiateTransientCompact();		// TFS 8294
	
		if not isSecondTime then
			tmpJadeReport := pxyJadeReport.cloneSelf(true);
			tmpJadeReport.description := self.myQryReport.heading;
			
			isSecondTime := true;
		else
			if self.outputtingToFile then
				if file &lt;&gt; null and file.isOpen then
					file.close; //18 Dec 2017	NDL	TFS 8267 - Previously it didn't care.... now it does.
				endif;
				if file.isAvailable then	//TFS 37204 - Only combine files if the new file exists (ie, the report returned data)
					self.appendToOriginalFile(self.fileName, secondFileName);
				endif;
			endif;	
		endif;
		
		//04 Sep 2015	NDL	Par 36205	
		if app.isWebApp then
			// Check that a report generating a file through the web service has actually 
			// created a file.  If there is no data, then ensure a 'No output report' is
			// generated instead
			self.createNoOutputReportIfRequired( 	jadeReport,	//jadeReport : JadeReportWriterReport io;
												_formatOption,	//_formatOption : Integer;
												pxyJadeReport,	//pxyJadeReport : JadeReport input;
												tmpJadeReport,	//tmpJadeReport : JadeReport io;
												_clientStartTime	// : TimeStamp
												);
		endif; 
		
		foreach pxyPrintData in pxyJadeReport.printArray do
			tmpPrintData := pxyPrintData.cloneSelf(true);
			tmpJadeReport.printArray.add(tmpPrintData);
		endforeach;
	
		pageNum := tmpJadeReport.printArray.size();
		pxyJadeReport.printArray.purge;	//pages have been cloned on to tmpJadeReport
		
		delete jadeReport;

		abortTransaction;				// to clear any locks held by the report writer
		endNoteSent := app.lockKeeperNotifyEndActivity(startTime, true, app.myPassport);
	endforeach;
	
	app.writeLog(logStr &amp; 'running report - complete', LogINFO);

	if self.outputtingToFile then
		return;
	endif;
	
	if self.printPreview then
		pPreviewCalled := true;	//Set this so THIS next method will do the cleanup
		app.printPreview(tmpJadeReport, true);
	else
		self.printReport(tmpJadeReport);
	endif;
	
epilog
	if not endNoteSent then
		abortTransaction;		// Problem in report writer left locks
		app.lockKeeperNotifyEndActivity(startTime, true, app.myPassport);
	endif;
	delete iter;
	delete jadeReport;
	delete pxyJadeReport;
	delete reportArray;
	if not pPreviewCalled then
		delete tmpJadeReport;
	endif;
	delete file;
	app.printer.documentType := documentType;
	app.printer.duplex       := duplex;        //29.05.2019 cnwma1 #44935
	app.writeLog(logStr &amp; 'completed', LogINFO);

end;</source>
        <access>protected</access>
        <Parameter name="_formatOption" type="Integer"/>
        <Parameter name="_clientStartTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="runStaticReportForeground" id="e7b2be98-1bcd-4ea9-8954-b9b08268019c">
        <source>runStaticReportForeground() protected;
// ---------------------------------------------------------------------------
// Created:     26 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	theSchema			: Schema;
	reportClass 		: Class;
	csv					: Binary;
	form				: CMUI_ReportBaseForm;
	pxyJadeReport		: JadeReport;
	isPreviewCalled		: Boolean;
	startTime			: TimeStamp;
	endNoteRequired		: Boolean;

begin
	// Do a static report.
	// Clear out any screwed up output and reset printer.
	app.printer.abort();

	theSchema := rootSchema.getSchema(self.myQryReport.schemaName);

	if theSchema &lt;&gt; null then
		reportClass := theSchema.getClass(self.myQryReport.formClassName);

		if reportClass &lt;&gt; null then
			if not self.outputtingToFile then
				create pxyJadeReport transient;
				app.printer.printPreview := false;
				app.printer.setReport(pxyJadeReport);
			endif;
			
			startTime := app.actualTimeServer;
			endNoteRequired := true;
			app.lockKeeperNotifyStartActivity(startTime, method, null, self.myQryReport.getNameForLockKeeper(0), app.myPassport);

			create form as reportClass transient;

			// Very necessary
			if app.isWebApp or self.outputtingToFile then
				app.printer.suppressDialog := true;
			endif;
			
			csv := form.run(false, self.outputtingToFile, self.myExtraDetail);
			
			app.lockKeeperNotifyEndActivity(startTime, true, app.myPassport);
			endNoteRequired := false;
			
			if self.outputtingToFile then
				if csv &lt;&gt; null and not csv.writeSlobToFile(self.fileName) then
					app.msgBox("Error opening CSV file. Please enter valid file path", "Report", MsgBox_Information_Icon	);
					return;	
				endif;
			else
				if self.printPreview then
					isPreviewCalled := true;	//Set this so THIS next method will do the cleanup
				
					app.printPreview(pxyJadeReport, true);
				else
					self.printReport(pxyJadeReport);
					//app.printer.printPreview := false;
//					app.printerFixPAR34782(pxyJadeReport);
//					app.printer.printReport(pxyJadeReport);
				endif;
			endif;
		endif;
	endif;

epilog
	abortTransaction;
	if endNoteRequired then
		// must have had an exception earlier, so ensure cnTransaaction instrumentation is correct
		app.lockKeeperNotifyEndActivity(startTime, true, app.myPassport);
	endif;

	if not isPreviewCalled then
		delete pxyJadeReport;
	endif;
	delete form;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setFilterProfile" id="7082cd31-e99e-4bda-86bc-9868b26417fc">
