    <JadeMethod name="lstCustomers_mouseDown" id="c176cc5f-8e20-4d58-8b23-57b42b1dac37">
        <controlMethod name="ListBox::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstCustomers_mouseDown(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		20 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	actualXPos	: Real;
	actualYPos	: Real;
	
begin
	if button = Window.MouseButton_Right then
		actualXPos	:=	x;
		actualYPos	:=	y;
		
		self.getRelativePosition(listbox, actualXPos, actualYPos);
		popupMenu(mnuCustomer, actualXPos.Integer, actualYPos.Integer);
	endif;
end;</source>
