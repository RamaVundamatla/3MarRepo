    <JadeMethod name="setControlsForMovement" id="1d402aca-ebea-426c-9cb5-71db8b517aa7">
        <updating/>
        <source>setControlsForMovement() updating, protected;
/* ---------------------------------------------------------------------------
Created:	17 February 2009	by cnwvu1

Purpose:	Par 17906. When starting from Graphical View, there is a particular movement
			with its offset times for blue box in the Windows Entrance. 
			When changinf vessel, region or Entering/Leaving, the movement is unknown.
			So, disabling controls when starting from Graphical View.
			Controls remain enabled, when starting from JMT Navigator.
			
 			Also, when the "Show Relative Times On Tidal Model" (Harbour Admin)
			is set to flase - we are hiding blue box in the screen called from JMT Navigator.
  
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	diffHeight	: Real;

begin

	if self.myWorkingMovement &lt;&gt; null then
		self.cmbVesselHMS.enabled := false;
		self.cmbRegion.enabled := false;
		self.optArrival.enabled := false;
		self.optDeparture.enabled := false;
	endif;
	
	if not self.showRelativeTimesOnTidalModel then	// blue box is hidden on the screen, see setupTable
		// changing the form's height and lifting lables
		diffHeight	:= self.tblEntranceWindow.height;
		self.height	:= self.height - diffHeight;

		self.lblEntranceWin.top := self.tblEntranceWindow.top + (self.tblEntranceWindow.height - self.lblEntranceWin.height) div 2;
		self.lblTime4.top := self.tblEntranceWindow.top + self.tblEntranceWindow.height + 2;
	
		self.lblTZWarning.top		:= self.lblTZWarning.top - diffHeight;
		self.lblLegendRegion.top	:= self.lblLegendRegion.top - diffHeight;
		self.lblLegendBerth.top		:= self.lblLegendBerth.top - diffHeight;
		self.legendRegion.top		:= self.legendRegion.top - diffHeight;
		self.legendBerth.top		:= self.legendBerth.top - diffHeight;
		self.frmTimeDepthFlow.top	:= self.frmTimeDepthFlow.top - diffHeight;
		self.lblZoneTime.top		:= self.lblZoneTime.top - diffHeight;

	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setOffsetTimeAndLocation" id="a1b28711-cc5a-4c0c-bf98-0b208ac23222">
        <updating/>
        <source>setOffsetTimeAndLocation() updating, protected;

vars
	steamingTimeToWharf:		Integer;
  	offsetChkPtRelToBaseTime:	Integer;
  	arrv_PilotOBRelToBaseTime:	Integer;
  	arrv_LinesRelToBaseTime:	Integer;
  	dept_PilotOffRelToBaseTime:	Integer;
  	dept_LinesRelToBaseTime:	Integer;
  	berthFrom, berthTo : HMS_Berth;
	movePrevious:	CMIF_HMS_WorkingMovement;
	harbour : HMS_Harbour;
begin
	//epr par 16635 changed harbour to be off the terminal
	offsetChkPtRelToBaseTime := self.baseTimeToChkpt;
	self.reportTimeCaption := null;
	harbour := self.myTerminal.myHarbour;
	if harbour = null then
		app.raiseCMException1(HMSNoHarbourForTerminal, self.myTerminal.name, null, null);
		return;
	endif;	
/* TidalTimeTypeArrival(TTTA) is the blue window on the model. Base time is the time of the movement
eg Arrival
	Pilot				Chkpt			Wharf
	1130				1145			1200
    (TTTA)								(BaseTime)

or Departure
	Pilot				Chkpt			Wharf
	1230				1215			1200
 										(BaseTime)
                                        (TTTA)
*/

    // Test to see if this is a general enquiry or an enquiry for a specific movement
    if self.myWorkingMovement = null then
   		// General Enquiry
     	steamingTimeToWharf := harbour.stdSteamingTimeMins;
   		// Determine whether vessel is entering or leaving
		if optArrival.value = true then
			// Entering harbour
			arrv_PilotOBRelToBaseTime := harbour.defaultOrderTimesArrive[4];
			arrv_LinesRelToBaseTime := harbour.defaultOrderTimesArrive[1];
			if harbour.tidalTimeTypeArrival = TidalTimeType_AtWharf then
				// Blue window is arrival at wharf
				self.reportTimeCaption := $TidalTimeRelTo_BerthArrival;
				if harbour.baseTimeArrive = AtSea then
					self.chkptToTTTATime := steamingTimeToWharf;
					self.baseTimeToChkpt := arrv_LinesRelToBaseTime - steamingTimeToWharf;	// eg +30 - +15
				elseif harbour.baseTimeArrive = AtWharf then
				    self.chkptToTTTATime := steamingTimeToWharf;
				    self.baseTimeToChkpt := (-1*steamingTimeToWharf);
				endif;
			elseif harbour.tidalTimeTypeArrival = TidalTimeType_AtSea then
				// Blue window is PILOT ON BOARD time
				self.reportTimeCaption := $TidalTimeRelTo_PilotOBoard;
				if harbour.baseTimeArrive = AtSea then
					self.chkptToTTTATime := steamingTimeToWharf-arrv_LinesRelToBaseTime;
					self.baseTimeToChkpt := arrv_LinesRelToBaseTime - steamingTimeToWharf;
				elseif harbour.baseTimeArrive = AtWharf then
					//TTNA is pilot on board, Base time is at wharf
				    self.baseTimeToChkpt := (-1* steamingTimeToWharf);		//Arrival is -ve
				    self.chkptToTTTATime := arrv_PilotOBRelToBaseTime + steamingTimeToWharf;
				endif;
			endif;
		else
			// Leaving harbour
			dept_PilotOffRelToBaseTime := harbour.defaultOrderTimesDepart[5];
			dept_LinesRelToBaseTime := harbour.defaultOrderTimesDepart[1];

			if harbour.tidalTimeTypeDeparture = TidalTimeType_AtWharf then
				// Blue window is pilot on board (at wharf)
				self.reportTimeCaption := $TidalTimeRelTo_BerthDeparture;
				if harbour.baseTimeDepart = AtSea then
					self.chkptToTTTATime := (-1*steamingTimeToWharf);		//eg -15 mins
            		self.baseTimeToChkpt := dept_LinesRelToBaseTime + steamingTimeToWharf;

				elseif harbour.baseTimeDepart = AtWharf then
					self.chkptToTTTATime := (-1*steamingTimeToWharf);		//eg -15 mins
				    self.baseTimeToChkpt := steamingTimeToWharf;		//eg +15 mins
				endif;
			elseif harbour.tidalTimeTypeDeparture = TidalTimeType_AtSea then
				// Blue window is pilot off (ie at sea)
				self.reportTimeCaption := $TidalTimeRelTo_PilotOffVessel;
				if harbour.baseTimeDepart = AtSea then
					self.chkptToTTTATime :=  dept_LinesRelToBaseTime - (-1*steamingTimeToWharf);
					self.baseTimeToChkpt := dept_LinesRelToBaseTime + steamingTimeToWharf;
				elseif harbour.baseTimeDepart = AtWharf then
				    self.chkptToTTTATime := dept_PilotOffRelToBaseTime-steamingTimeToWharf;
				    self.baseTimeToChkpt := steamingTimeToWharf;		//eg +15 mins
				endif;
			endif;
		endif;
   	else
   		// Enquiry for a Specific Movement
   		movePrevious := self.myWorkingMovement.getMovementPrevious();	//AJA 27/11/00 : Added this section of code
   		if movePrevious &lt;&gt; null then
   			berthFrom := movePrevious.myBerth;
   		endif;
   		berthTo := self.myWorkingMovement.myBerth;
   		// Determine movement type
		// ---------------------------------------------------------------------------------------
		// ARRIVAL
		//AJA 27/11/00: Or a shift from a non piloted berth (eg outside the harbour)
		// ---------------------------------------------------------------------------------------
		if self.myWorkingMovement.moveType = HMSMovementTypeArrival 
		or (self.myWorkingMovement.moveType = HMSMovementTypeShift 
		and berthFrom.noMarineServices = true) then
			
			arrv_PilotOBRelToBaseTime := harbour.defaultOrderTimesArrive[4];
			arrv_LinesRelToBaseTime := harbour.defaultOrderTimesArrive[1];

			if harbour.tidalTimeTypeArrival = TidalTimeType_AtWharf then
				// Blue window is TIME AT WHARF
				if harbour.baseTimeArrive = AtSea then
					self.chkptToTTTATime := arrv_LinesRelToBaseTime-offsetChkPtRelToBaseTime;
				elseif harbour.baseTimeArrive = AtWharf then
				    self.chkptToTTTATime := (-1*offsetChkPtRelToBaseTime);
				endif;
			elseif harbour.tidalTimeTypeArrival = TidalTimeType_AtSea then
				// Blue window is TIME OF PILOT ON BOARD (ie At sea for an arrival)
				self.reportTimeCaption := $TidalTimeRelTo_PilotOBoard;
				if harbour.baseTimeArrive = AtSea then
					self.chkptToTTTATime := (-1*offsetChkPtRelToBaseTime);
				elseif harbour.baseTimeArrive = AtWharf then
				    // Set offset time from movement time (ie pilot on board time ..to.. at berth)
				    self.chkptToTTTATime := arrv_PilotOBRelToBaseTime-offsetChkPtRelToBaseTime;
				    self.baseTimeToChkpt := (offsetChkPtRelToBaseTime);
				endif;
			endif;
		
		elseif self.myWorkingMovement.moveType = HMSMovementTypeDeparture 
		or (myWorkingMovement.moveType = HMSMovementTypeShift 
		and berthTo.noMarineServices = true) then
			// ---------------------------------------------------------------------------------------
			// DEPARTURE
			//AJA 27/11/00: Or a shift to a non piloted berth (eg outside the harbour)
			// ---------------------------------------------------------------------------------------	
			dept_PilotOffRelToBaseTime := harbour.defaultOrderTimesDepart[5];
			dept_LinesRelToBaseTime := harbour.defaultOrderTimesDepart[1];
			
			if harbour.tidalTimeTypeDeparture = TidalTimeType_AtWharf then
				// Report times relative to TIME AT WHARF
				if harbour.baseTimeDepart = AtSea then
					// Movement time is pilot off vessel time (ie at sea)
					// Set offset time from movement time (pilot off vessel time ..to.. time at wharf departure)
					self.chkptToTTTATime := dept_LinesRelToBaseTime-offsetChkPtRelToBaseTime;
					// eg. -45mins - (-35mins) = -10mins
				elseif harbour.baseTimeDepart = AtWharf then
				    // Movement time is time at berth
				    self.chkptToTTTATime := (-1*offsetChkPtRelToBaseTime);
				    // eg. - (+10mins) = -10mins
				endif;
			elseif harbour.tidalTimeTypeDeparture = TidalTimeType_AtSea then
				self.reportTimeCaption := $TidalTimeRelTo_PilotOffVessel;
				// Report times relative to TIME OF PILOT OFF VESSEL (ie At sea for a departing movement)
				if harbour.baseTimeDepart = AtSea then
					// Movement time is pilot off vessel time
					// Set offset time from movement time 
					self.chkptToTTTATime := offsetChkPtRelToBaseTime;
					// eg -35mins
				elseif harbour.baseTimeDepart = AtWharf then
				    // Movement time is time at berth 
				    // Set offset time from movement time (ie at berth time ..to.. pilot off vessel)
				    self.chkptToTTTATime := dept_PilotOffRelToBaseTime-offsetChkPtRelToBaseTime;
				    // eg +45mins - +10mins = +35mins  
				endif;
			endif;
		elseif self.myWorkingMovement.moveType = HMSMovementTypeShift then
		// ---------------------------------------------------------------------------------------
		// SHIFT (From berth to berth within the harbour AJA 27/11/00)
		// ---------------------------------------------------------------------------------------
			// Always report times relative to pilot on board time - which is the movement time, which is 
			// also the 'berth departing from' time.
			self.chkptToTTTATime := (-1*offsetChkPtRelToBaseTime);
			// eg. -10mins

		endif;
	endif;
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c0be9fb5-c40c-4f1e-a4a5-f12ef8b0cafd">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------------------
//Created: 21 July 2003 By: cnwgd1
//--------------------------------------------------------------
begin
	inheritMethod();
	
// cnwdad1 11/07/2008 - PAR #17493.
	if self.myTerminal.myHarbour = null then
		app.raiseCMException1(HMSNoHarbourForTerminal, self.myTerminal.name, null, null);
		self.unloadForm();
		return;
	endif;
	
	self.addRegisteredKey(J_key_RightArrow);
	self.addRegisteredKey(J_key_LeftArrow);
	
	self.height := 620;	//height can be changed in setControlsForMovement()
	self.width := 625;
	self.toolbarStyle	:=	self.ToolbarStyle_ShowNoHide;
	self.showToolbar	:=	true;
	self.initialLoad	:=	true;
	self.initForm();
	self.initialLoad	:=	false;

	self.setControlsForMovement();	//Par17096 Feb 2009
	
	self.setNavigatorHeading(self.caption);
end;</source>
    </JadeMethod>
    <JadeMethod name="setupTable" id="ea1dbb10-1e3f-4e17-a408-04bd7b04b5a7">
        <source>setupTable(_tbl : Table io);

constants
	Stripe : Integer = 15724527; // very light gray
	Columns : Integer = 24;
	Rows : Integer = 12;
vars
	int		: Integer;
	colW	: Integer;
	rowH	: Integer;
	tmpRows	: Integer;

begin
	_tbl.columns := Columns;
	
	tmpRows	:= Rows;
	if _tbl = self.tblEntranceWindow and not self.showRelativeTimesOnTidalModel then
		//Par 17906. Feb 2009. When starting Tidal Model from the JMT Navigator, there is no movement - only tidal and black box  required.
		// When starting from Graphical View by selecting a voyage, there is a particular movement and relative time can be counted.		
		tmpRows := tmpRows div 2;
		self.tblEntranceWindow.height := self.tblEntranceWindow.height div 2;
	endif;
	_tbl.rows	:= tmpRows;
	
	colW := (_tbl.width / Columns).Integer; 
	_tbl.backColor := White;
	_tbl.gridColor := DarkGray;
	_tbl.accessMode := Table.AccessMode_Column;
	int := 1;
	while int &lt;= Columns do
		_tbl.columnWidth[int] := colW;		
		if int mod 2 = 0 then
			_tbl.column := int;
			_tbl.backColor := Stripe;
		endif;				
		int := int + 1;
	endwhile;

	_tbl.accessMode := Table.AccessMode_Row;
	int := 1;
	while int &lt;= tmpRows do
		_tbl.rowHeight[int] := (_tbl.height / tmpRows).Integer;
		int := int + 1;
	endwhile;		

	_tbl.accessMode 	:= Table.AccessMode_Sheet;
	_tbl.readOnly   	:= true;
	_tbl.autoRedraw 	:= true;
	_tbl.drawStyle  	:= DrawStyle_Solid;//DrawStyle_Dot;
	_tbl.drawWidth	:= 3;		
end;</source>
        <Parameter name="_tbl" type="Table" usage="io"/>
    </JadeMethod>
    <JadeMethod name="showRelativeTimes" id="80271109-3c5d-40fc-9ce9-ca6dc8c431a7">
        <source>showRelativeTimes() : Boolean protected;
/* ---------------------------------------------------------------------------
Created:	17 February 2009	by cnwvu1

Purpose:	
------------------------------------------------------------------------------*/
vars

begin

	//Par 17906. Feb 2009. When starting Tidal Model from the JMT Navigator, there is no movement - only tidal and black box  required.
	// When starting from Graphical View by selecting a voyage, there is known movement and offser time can be counted.
	if self.myWorkingMovement &lt;&gt; null then
		return true;
	endif;

	if self.myTerminal.myHarbour = null then
		return false;
	endif;
	
	if self.myTerminal.myHarbour.showRelativeTimesOnTidal then
		return true;
	endif;

	return false;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
