        <source>utlCreateOutwardRailTIs(pTI : CM_TrackedItem);
//--------------------------------------------------------------
//Created: November 2001 By: cnwgd1
//--------------------------------------------------------------
//Wrapper for creating EDI TIs for Tranzrail outward rail.
//Called during clearing of rail rake. After release txn is created and before jobs are deleted.
//And before rake is cleared.

vars
	ediTI : CM_EDIOutwardRailTI;
begin

	self.initialiseActivity();
	if pTI = null then
		app.raiseCMException1(ERR_NO_OBJECT, 'Tracked Item', null, null);
		return;
	endif;

	create ediTI persistent;

	ediTI.setForCreate(pTI);	
	
end;</source>
