    <JadeMethod name="getTblTextXML" id="d1cb66af-c037-4c1f-a03f-f974489c9fd9">
        <source>getTblTextXML():String;
/*
	Created on 19 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	str : String;
begin
	if self.xmlStrTblText &lt;&gt; null then
		str := self.xmlStrTblText;
	else
		str := self.tblBRItems.getXmlStrForDisplay();
	endif;
	return str;
end;</source>
        <ReturnType type="String"/>
