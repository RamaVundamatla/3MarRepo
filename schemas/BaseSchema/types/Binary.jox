<PrimType name="Binary">
    <JadeMethod name="cnEcClearBit" id="341e6228-d5e9-4f6c-a18f-9ce264afec8d">
        <updating/>
        <source>cnEcClearBit(pIndex:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		10 October 2002 by cnwdad1
//
// Purpose:		Turns off a bit in the receiver, such as for a bit-mask.
//
// Parameters:	pIndex - The index of the bit to be turned off.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 03/04/2003	cnwdad1		Added a check for whether the pIndex exceeded the maximum
//							possible bit index.
// --------------------------------------------------------------------------------
vars
	maximumIndex	: Integer;
	byteIndex		: Integer;
	byteValue		: Integer;
	bitPointer		: Integer;
	
begin
	maximumIndex	:=	(self.length() * 8);
	
	if pIndex &gt; maximumIndex then
		return;
	endif;
	
	byteIndex	:=	((pIndex - 1) div 8) + 1;
	byteValue	:=	self[byteIndex];
	bitPointer	:=	(pIndex mod 8);
	
	if bitPointer = 1 then			// Right-most bit.
		byteValue	:=	byteValue.bitXor(1);
	elseif bitPointer = 2 then
		byteValue	:=	byteValue.bitXor(2);
	elseif bitPointer = 3 then
		byteValue	:=	byteValue.bitXor(4);
	elseif bitPointer = 4 then
		byteValue	:=	byteValue.bitXor(8);
	elseif bitPointer = 5 then
		byteValue	:=	byteValue.bitXor(16);
	elseif bitPointer = 6 then
		byteValue	:=	byteValue.bitXor(32);
	elseif bitPointer = 7 then
		byteValue	:=	byteValue.bitXor(64);
	elseif bitPointer = 0 then		// Left-most bit.
		byteValue	:=	byteValue.bitXor(128);
	endif;
	
	self[byteIndex]	:=	byteValue;
end;</source>
        <Parameter name="pIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcCopyToTempFile" id="0b9f4907-ff01-4cc8-bb9f-8036a7b9795b">
        <source>cnEcCopyToTempFile(pFileName:String; pFileTS:TimeStamp):Boolean;
// --------------------------------------------------------------------------------
// Created:		10 June 2006 by cnwdad1
//
// Purpose:		Copies the receiver to a temporary file, using the Windows 'temp'
//				directory.  If no such directory can be located, the 'logs' directory
//				will be used.
//
// Parameters:	pFileName - The name of the temporary file (excluding the path name).
//				pFileTS - The timestamp of the temporary file (optional).
//
// Returns:		True if the receiver was successfully copied to a temporary file.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 19/01/2007	cnwdad1		Changed so that if a full file name is passed in, then
//							strip out the path name, leaving just the file name.
// --------------------------------------------------------------------------------
// adm 200509 Par 19207  change abstract exception class
vars
	fileObj		: File;
	fileName	: String;
	namePos		: Integer;
	tempDirName	: String;
	fullName	: String;
	
begin
	create fileObj transient;
	fileObj.kind	:=	File.Kind_Binary;
	
	if pFileName = null then
		CnEcBaseSchemaException.raise_(CNEC_X_12007, "No target file name was specified.");
	else
		fileName	:=	pFileName;
		
		if fileName.pos("\", 1) &gt; 0 then
			namePos		:=	fileName.reversePos("\");
			fileName	:=	fileName[namePos + 1:end];
		elseif fileName.pos("/", 1) &gt; 0 then
			namePos		:=	fileName.reversePos("/");
			fileName	:=	fileName[namePos + 1:end];
		endif;
		
		tempDirName	:=	app.getTempDir();
		fullName	:=	tempDirName &amp; global.cnEcGetFileSeparator() &amp; fileName;
		fileObj.allowCreate		:=	true;
		fileObj.allowReplace	:=	true;
		fileObj.mode			:=	File.Mode_Output;
		fileObj.fileName		:=	fullName;
		fileObj.open();
	endif;
	
	fileObj.writeBinary(self);
	fileObj.lastModifiedTime	:=	pFileTS;
	
	return true;
epilog
	delete fileObj;		// This will close the file.
end;</source>
        <Parameter name="pFileName" type="String"/>
        <Parameter name="pFileTS" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcDefaultSuffix" id="7fc08df4-a41a-4895-b19e-f20ac0fc0b8f">
        <source>cnEcDefaultSuffix():String;
// --------------------------------------------------------------------------------
// Created:		06 September 2005 by cnwdad1
//
// Purpose:		Assuming that the receiver is an image, this method returns the
//				default file name suffix for the receiver, based upon the format
//				of the image.
//
// Parameters:	None
//
// Returns:		The file name suffix, or null if format is not recognized.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fileSuffix	: String;
	
begin
	if self.pictureType = Window.PictureType_Bitmap then
		fileSuffix	:=	"bmp";
	elseif self.pictureType = Window.PictureType_Cursor then
		fileSuffix	:=	"cur";
	elseif self.pictureType = Window.PictureType_Gif then
		fileSuffix	:=	"gif";
	elseif self.pictureType = Window.PictureType_Icon then
		fileSuffix	:=	"ico";
	elseif self.pictureType = Window.PictureType_Jpeg then
		fileSuffix	:=	"jpg";
	elseif self.pictureType = Window.PictureType_MetaFile then
		fileSuffix	:=	"mcf";
	elseif self.pictureType = Window.PictureType_Png then
		fileSuffix	:=	"png";
	elseif self.pictureType = Window.PictureType_Tiff then
		fileSuffix	:=	"tif";
	else
		fileSuffix	:=	null;
	endif;
	
	return fileSuffix;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsBit" id="bb10a797-344d-4fdb-b5d8-61013e7335e5">
        <source>cnEcIsBit(pIndex:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		10 October 2002 by cnwdad1
//
// Purpose:		Returns a flag to indicate whether a bit in the receiver is on.
//
// Parameters:	pIndex - The index of the bit to check.
//
// Returns:		True if the bit is set, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 03/04/2003	cnwdad1		Added a check for whether the pIndex exceeded the maximum
//							possible bit index.
// --------------------------------------------------------------------------------
vars
	maximumIndex	: Integer;
	byteIndex		: Integer;
	byteValue		: Integer;
	bitPointer		: Integer;
	
begin
	maximumIndex	:=	(self.length() * 8);
	
	if pIndex &gt; maximumIndex then
		return false;
	endif;
	
	byteIndex	:=	((pIndex - 1) div 8) + 1;
	byteValue	:=	self[byteIndex];
	bitPointer	:=	(pIndex mod 8);
	
	if bitPointer = 1 then			// Right-most bit.
		return byteValue.bitAnd(1) &lt;&gt; 0;
	elseif bitPointer = 2 then
		return byteValue.bitAnd(2) &lt;&gt; 0;
	elseif bitPointer = 3 then
		return byteValue.bitAnd(4) &lt;&gt; 0;
	elseif bitPointer = 4 then
		return byteValue.bitAnd(8) &lt;&gt; 0;
	elseif bitPointer = 5 then
		return byteValue.bitAnd(16) &lt;&gt; 0;
	elseif bitPointer = 6 then
		return byteValue.bitAnd(32) &lt;&gt; 0;
	elseif bitPointer = 7 then
		return byteValue.bitAnd(64) &lt;&gt; 0;
	elseif bitPointer = 0 then		// Left-most bit.
		return byteValue.bitAnd(128) &lt;&gt; 0;
	endif;
	
	return false;
end;</source>
        <Parameter name="pIndex" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsValidPicture" id="ccb49fc0-6c8b-4130-a0a4-d12a963eefc8">
        <source>cnEcIsValidPicture():Boolean;
// --------------------------------------------------------------------------------
// Created:		07 October 1999 by cnwdad1
//
// Purpose:		Checks whether the format of this binary is a valid picture.
//
// Parameters:	None
// Returns:		True if the binary is a valid picture format, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
//
//	***************************************************************
//	* Note that JADE supports PNG files from Release 5.0.14 only. *
//	***************************************************************
//
//constants
//	PictureType_None		: Integer = 0;		// Not a valid picture
//	PictureType_Bitmap		: Integer = 1;		// Bitmap
//	PictureType_NotUsed		: Integer = 2;		// Not used
//	PictureType_Icon		: Integer = 3;		// Icon
//	PictureType_Metafile	: Integer = 4;		// Metafile
//	PictureType_Cursor		: Integer = 5;		// Cursor
//	PictureType_TIF			: Integer = 6;		// Tag Image File Format (.tif file)
//	PictureType_JPEG		: Integer = 7;		// Joint Photographic Experts Group (JPEG)
//	PictureType_PNG			: Integer = 8;		// Portable Network Graphics (PNG)
//	PictureType_Gif			: Integer = 9;		// Graphic Interchange Format (GIF)
//
begin
	if self.pictureType = Window.PictureType_Bitmap
	or self.pictureType = Window.PictureType_Cursor
	or self.pictureType = Window.PictureType_Gif
	or self.pictureType = Window.PictureType_Icon
	or self.pictureType = Window.PictureType_Jpeg
	or self.pictureType = Window.PictureType_MetaFile
	or self.pictureType = Window.PictureType_Png
	or self.pictureType = Window.PictureType_Tiff
	then
		return true;
	else
		return false;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcPrintMe" id="7cc46088-f8cc-43c1-b860-2bfe0b55c544">
        <source>cnEcPrintMe(pFileName:String; pFileTS:TimeStamp; pFormHandle:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		10 June 2006 by cnwdad1
//
// Purpose:		Copies the receiver to a temporary file, then sends it to the default
//				printer.
//
// Parameters:	pFileName - The name of the temporary file (excluding the path name).
//				pFileTS - The timestamp of the temporary file (optional).
//				pFormHandle - The Windows handle of the current form.
//
// Returns:		True if the receiver was successfully printed, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 22/11/2021	navmd1		TFS 52434 Add Unicode support
// --------------------------------------------------------------------------------
constants
	NO_FILE_ASSOC	: Integer = 31;
	OPEN_ERROR		: Integer = 32; // Any result &lt;= this indicates an error
	
vars
	result		: Integer;
	dirName		: String;
	message		: String;
	
begin
	if self.cnEcCopyToTempFile(pFileName, pFileTS) then
		dirName	:=	app.getTempDir();
		
		if app.isUnicode() then
			result := call cnEcShellExecuteW(pFormHandle, "print", pFileName, null, dirName, 1);
		else
			result := call cnEcShellExecuteA(pFormHandle, "print", pFileName, null, dirName, 1);
		endif;
		app.mousePointer := Idle;
		
		if result = NO_FILE_ASSOC then
			message	:=	"Could not open file " &amp; pFileName &amp;
						" (in folder " &amp; dirName &amp;
						").  This is most likely because there is no " &amp;
						"program associated with files of this extension.";
			
			app.msgBox(	message,
						"File Open Failed",
						MsgBox_OK_Only + MsgBox_Stop_Icon);
			return false;
						
		elseif result &lt;= OPEN_ERROR then
			message	:=	"Could not print file " &amp; pFileName &amp;
						" (in folder " &amp; dirName &amp; ").";
			
			app.msgBox(	message,
						"File Open Failed",
						MsgBox_OK_Only + MsgBox_Stop_Icon);
			return false;
		endif;
	else
		return false;
	endif;
	
	return true;
end;</source>
        <Parameter name="pFileName" type="String"/>
        <Parameter name="pFileTS" type="TimeStamp"/>
        <Parameter name="pFormHandle" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcReadFromFile" id="48eedf0e-7446-4e33-ba46-a65b1bc6180d">
        <updating/>
        <source>cnEcReadFromFile(pFileName:String io):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		05 September 2005 by cnwdad1
//
// Purpose:		Reads the contents of a disk file as a BLOB into the receiver.  If
//				a file name is not specified, then the user will be prompted to
//				select the file to read.
//
// Parameters:	pFileName - The name of the file to read.  If this is null, then
//					the user will be prompted to browse/select the file, and the
//					name will be returned in this parameter.
//
// Returns:		True if the file was successfully read, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 19/01/2007	cnwdad1		Made the file name parameter IO and now returns the name
//							of the file that the user browsed/selected.
// --------------------------------------------------------------------------------
vars
	fileObj		: File;
	
begin
	create fileObj transient;
	fileObj.kind	:=	File.Kind_Binary;
	
	if pFileName = null then
		if fileObj.cnEcSetOpenName(true, false, null) then
			pFileName	:=	fileObj.fileName;
		else
			return false;
		endif;
	else
		fileObj.openInput(pFileName);
	endif;
	
	self	:=	fileObj.readBinary(fileObj.fileLength());
	
	return true;
epilog
	delete fileObj;		// This will close the file.
end;</source>
        <Parameter name="pFileName" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetBit" id="7db22615-80a8-416e-92f0-095b8efb3740">
        <updating/>
        <source>cnEcSetBit(pIndex:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		10 October 2002 by cnwdad1
//
// Purpose:		Turns on a bit in the receiver, such as for a bit-mask.
//
// Parameters:	pIndex - The index of the bit to be set.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	byteIndex		: Integer;
	byteValue		: Integer;
	bitPointer		: Integer;
	
begin
	byteIndex	:=	((pIndex - 1) div 8) + 1;
	byteValue	:=	self[byteIndex];
	bitPointer	:=	(pIndex mod 8);
	
	if bitPointer = 1 then			// Right-most bit.
		byteValue	:=	byteValue.bitOr(1);
	elseif bitPointer = 2 then
		byteValue	:=	byteValue.bitOr(2);
	elseif bitPointer = 3 then
		byteValue	:=	byteValue.bitOr(4);
	elseif bitPointer = 4 then
		byteValue	:=	byteValue.bitOr(8);
	elseif bitPointer = 5 then
		byteValue	:=	byteValue.bitOr(16);
	elseif bitPointer = 6 then
		byteValue	:=	byteValue.bitOr(32);
	elseif bitPointer = 7 then
		byteValue	:=	byteValue.bitOr(64);
	elseif bitPointer = 0 then		// Left-most bit.
		byteValue	:=	byteValue.bitOr(128);
	endif;
	
	self[byteIndex]	:=	byteValue;
end;</source>
        <Parameter name="pIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcUnpackCString" id="1c769b23-199a-4ecf-8774-cd1834bfb821">
        <source>cnEcUnpackCString(pStartPos:Integer):Binary;
// --------------------------------------------------------------------------------
// Created:		04 September 2000 by cnwdad1
//
// Purpose:		Finds a C String and trims off the null terminated bit.  This is
//				a reimplementation of the JADE "unpackCString" method which does
//				not allow for unicode's two-byte characters.
//
// Parameters:	pStartPos (Integer) - The position from which to start scanning.
//
// Returns:		The C String.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	posIndex	: Integer;
	dataLength	: Integer;
	
begin
	posIndex	:=	pStartPos;
	dataLength	:=	self.length;

	if app.isUnicode() then
		while self[posIndex:1] &lt;&gt; null do
			posIndex := posIndex + 1;

			if posIndex = dataLength then
				break;
			endif;
		endwhile;
	else
		while self[posIndex:1] &lt;&gt; false.Binary do
			posIndex := posIndex + 1;

			if posIndex = dataLength then
				break;
			endif;
		endwhile;
	endif;

	if posIndex &gt; pStartPos then
		return self[pStartPos:(posIndex - pStartPos)];
	endif;

	return null;	
end;</source>
        <Parameter name="pStartPos" type="Integer"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="cnEcViewMe" id="6dbfd68c-bc6f-4a63-a1bf-27d7418cfb78">
        <source>cnEcViewMe(pFileName:String; pFileTS:TimeStamp; pFormHandle:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		10 June 2006 by cnwdad1
//
// Purpose:		Copies the receiver to a temporary file, then opens it, relying on
//				the Windows program file association mechanism.
//
// Parameters:	pFileName - The name of the temporary file (excluding the path name).
//				pFileTS - The timestamp of the temporary file (optional).
//				pFormHandle - The Windows handle of the current form.
//
// Returns:		True if the receiver was successfully opened, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 22/11/2021	navmd1		TFS 52434 Add Unicode support
// --------------------------------------------------------------------------------
constants
	// Based on https://docs.microsoft.com/en-us/openspecs/windows_protocols/ms-erref/18d8fbe8-a967-4f1c-ae50-99ca8e491d2d (Win32 Error Codes)
	// I don't think these error codes line up any more. navmd1 22/11/2021
	NO_FILE_ASSOC	: Integer = 31;
	OPEN_ERROR		: Integer = 32; // Any result &lt;= this indicates an error
	
vars
	result		: Integer;
	dirName		: String;
	message		: String;
	
begin
	if self.cnEcCopyToTempFile(pFileName, pFileTS) then
		dirName	:=	app.getTempDir();
		
		if app.isUnicode() then
			result := call cnEcShellExecuteW(pFormHandle, "open", pFileName, null, dirName, 1);
		else
			result := call cnEcShellExecuteA(pFormHandle, "open", pFileName, null, dirName, 1);
		endif;
		app.mousePointer := Idle;
		
		if result = NO_FILE_ASSOC then
			message	:=	"Could not open file " &amp; pFileName &amp;
						" (in folder " &amp; dirName &amp;
						").  This is most likely because there is no " &amp;
						"program associated with files of this extension.";
			
			app.msgBox(	message,
						"File Open Failed",
						MsgBox_OK_Only + MsgBox_Stop_Icon);
			return false;
						
		elseif result &lt;= OPEN_ERROR then
			message	:=	"Could not open file " &amp; pFileName &amp;
						" (in folder " &amp; dirName &amp; ").";
			
			app.msgBox(	message,
						"File Open Failed (" &amp; result.String &amp; ")",
						MsgBox_OK_Only + MsgBox_Stop_Icon);
			return false;
		endif;
	else
		return false;
	endif;
	
	return true;
end;</source>
        <Parameter name="pFileName" type="String"/>
        <Parameter name="pFileTS" type="TimeStamp"/>
        <Parameter name="pFormHandle" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcWriteToFile" id="89b84519-8bea-4b87-86a0-c9cbd3eb34dd">
        <updating/>
        <source>cnEcWriteToFile(pFileName:String):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		05 September 2005 by cnwdad1
//
// Purpose:		Writes the receiver (as a BLOB) to a disk file. If a file name is
//				not specified, then the user will be prompted to select a target
//				file (to overwrite) or to enter a name.
//
// Parameters:	pFileName - The name of the file to write to (or null).
//
// Returns:		True if the file was successfully written, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fileObj		: File;
	
begin
	create fileObj transient;
	fileObj.kind	:=	File.Kind_Binary;
	
	if pFileName = null then
		if not fileObj.cnEcSetSaveName(pFileName, true, true, null) then
			return false;
		endif;
	else
		fileObj.openOutput(pFileName);
	endif;
	
	fileObj.writeBinary(self);
	return true;
epilog
	delete fileObj;		// This will close the file.
end;</source>
        <Parameter name="pFileName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</PrimType>
