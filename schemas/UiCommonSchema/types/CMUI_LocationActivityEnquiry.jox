    <JadeMethod name="initTblLocActivity" id="db4d613b-c396-4349-b768-f4f22014432c">
        <updating/>
        <source>initTblLocActivity()updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2021	navndl1	Initial creation	TFS 

*/

vars
	entTableDef		: EntTableDef;
begin
	if self.tableInitialised then
		return;
	endif;

	self.tblLocActivity.alignment := Table.Alignment_Left_Top;
	self.tblLocActivity.autoSize := Table.AutoSize_Both;

	entTableDef := app.myController.getEntTableDef(ETDef_LocationActivityEnquiry);
	if entTableDef &lt;&gt; null then
		if self.xmlStrTblLocActivity.trimBlanks &lt;&gt; null then
			self.tblLocActivity.setTblDataEntRowsFromXML(entTableDef, self.xmlStrTblLocActivity);
		else
			self.tblLocActivity.setTblDataEntRowsFromDef(entTableDef);
		endif;
	endif;
	self.tblLocActivity.readOnly := false;	
	self.tblLocActivity.fixedColumns := 0;
	self.tblLocActivity.show3D := Table.Show3D_Not3D;
	self.tblLocActivity.selectMode := Table.SelectMode_Row;
	self.tblLocActivity.accessMode := Table.AccessMode_Row;
	self.tblLocActivity.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.tblLocActivity.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblLocActivity.defaultRowHeight := 17;
	self.tblLocActivity.allSelectedObjects.clear;
	
	self.tableInitialised := true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="mnuAudits_click" id="6ad543fe-b7a1-469f-84d1-072c944a8c2c">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuAudits_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

	locAct : CMEVT_LocationActivity;
	allAuditObjects : CM_AuditObjectDictByTimestamp;
	stateData : Any;
	form : CM_AuditViewForm;

begin

	locAct := menuItem.userObject.CMEVT_LocationActivity;
	if locAct = null then
		return;
	endif;
	
	//when new audits is in production this needs to use the new audit stuff.
	process.isNDLAudits;
	stateData := locAct.getExtraData("allAuditObjects");
	if stateData &lt;&gt; null then
		allAuditObjects := stateData.CM_AuditObjectDictByTimestamp;
	else
		return;
	endif;
	
	if not allAuditObjects.isEmpty then
		form := app.loadForm(CM_AuditViewForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CM_AuditViewForm;
	endif;
	form.show;
	form.displaySelectorResults( allAuditObjects, 0);
	
epilog

end;</source>
