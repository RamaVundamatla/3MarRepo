    <JadeMethod name="canUserAccessSelf" id="f4ed3678-7aff-4528-895a-3c56c4bac80e">
        <source>canUserAccessSelf() : Boolean;
// ---------------------------------------------------------------------------
// Created:     03 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

	failedDAC  :CM_DataAccessController;
	
begin

	if self.myLocationsController &lt;&gt; null then
		return self.myLocationsController.canUserAccessSelf(null, failedDAC, app.myPassport);
	endif;
	
	return true;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="column" id="441452aa-a69e-4fe7-9ecb-b5899e5bfcb2">
        <methodInvocation>mapping</methodInvocation>
        <source>column(set: Boolean; _value: Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:     31 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.myGridColumn = null then	// 24769 can be null from update issues
		_value := 0;
	else
		_value := self.myGridColumn.column;
	endif;
end;</source>
