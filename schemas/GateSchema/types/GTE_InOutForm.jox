    <JadeMethod name="addFromBulkRelease" id="7219b4c4-eeb3-42f9-a508-416332f11ddb">
        <source>addFromBulkRelease(br : CM_BulkRelease) protected;
// ---------------------------------------------------------------------------
// Created:     10 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/02/2010	cnwas3 par 18106
// ---------------------------------------------------------------------------
vars
	carrier : Any;	//par 18106
begin
	self.createMenuActionSheet(NavObj_GTE_Out, br);

	carrier := self.tblCommon.getValueByName(ETRow_CarrierCode);	//par 18106
	
	if br.carrierId &lt;&gt; null and carrier = null then	//par 18106
		self.cmbCarrier.setObject(app.myRoot.allCarriers[br.carrierId]);
		self.cmbCarrier.lostFocus(cmbCarrier);
		self.tblCommon.setValueByName(ETRow_CarrierCode, self.cmbCarrier.text);
	endif;
	self.tblBulkRelease.selectObject(br, true);
	self.showBulkReleaseDtl();

end;</source>
        <access>protected</access>
        <Parameter name="br" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="addFromInterTerminalTI" id="c4c9b677-bacf-46c6-b06b-ecf2539f4a73">
        <source>addFromInterTerminalTI(pTI : CM_TrackedItem) protected;
//----------------------------------------------------------------
//	Created:	26 July 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
