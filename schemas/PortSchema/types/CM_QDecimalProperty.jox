    <JadeMethod name="cloneReferences" id="a7c9eb6a-5a5f-4883-8865-7cc3ea9b83db">
        <source>cloneReferences(_realProperty: SelfType input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 08/05/2013	cnwdap1		Initial creation PAR #31155 CMS SFW 1321 Imperial Measurements
//
vars

begin
	inheritMethod(_realProperty);
	_realProperty.myMeasurementType := self.myMeasurementType;
epilog

end;</source>
        <Parameter name="_realProperty" type="SelfType" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="4ba7b3bb-52a6-4d94-b657-c7dfcba1fd09">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     05 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	oper	: CM_QueryOperator;
	
begin
	if self.isTransient then 
		return;
	endif;
	
	create oper as CM_QDecimalEquals persistent;
	self.allAllowedOperators.add(oper);

	create oper as CM_QDecimalGreaterThan persistent;
	self.allAllowedOperators.add(oper);
	
	// cnwrd1 par 18838 3.2.09
	create oper as CM_QDecimalGreaterEquals persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QDecimalLessThan persistent;
	self.allAllowedOperators.add(oper);
	
	// cnwrd1 par 18838 3.2.09
	create oper as CM_QDecimalLessThanEquals persistent;
	self.allAllowedOperators.add(oper);
	
end;</source>
    </JadeMethod>
