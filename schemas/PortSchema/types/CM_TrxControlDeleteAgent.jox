/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

