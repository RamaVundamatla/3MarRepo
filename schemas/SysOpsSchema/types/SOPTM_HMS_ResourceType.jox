    <JadeMethod name="doSave" id="a5e13c78-6a2d-4cd0-b8c3-2629a84dece5">
        <updating/>
        <source>doSave(): Boolean updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
//15 Sep 2022 navsj20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards

//--------------------------------------------------------------
vars
	pxyResourceType	:	HMS_ResourceType;
	theForm			:	SOP_TableMaintForm;
		
begin
//	return inheritMethod();
	theForm := self.myForm.SOP_TableMaintForm;
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as HMS_ResourceType transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy is null for update');
			return false;
		endif;
	endif;
	
	pxyResourceType := theForm.myProxyObject.HMS_ResourceType;
	//theForm.tblInput1.setObjectFromTable(pxyResourceType, null, false);
	theForm.tblInput1.setObjectFromTable(pxyResourceType, "setObjectFromTableSpecial", false);	//15 Sep 2022	navsj20	TFS 54739
	pxyResourceType.setProxy(app.myRoot);

	//Are we adding or updating
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateHMSObject( pxyResourceType, theForm.myCurrentObject, app.myPassport );
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateHMSObject(pxyResourceType, app.myPassport );
	else
		app.raiseUnexpectedProgramError( class.name,
										 method.name, 
										 '  Invalid mode (' &amp; theForm.mode.String &amp; ')' );
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
