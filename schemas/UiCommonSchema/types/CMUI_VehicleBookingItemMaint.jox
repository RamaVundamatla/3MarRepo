        <updating/>
        <source>cmbReleaseReq_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 July 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
03 May 2023 	navhl20	ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]
24 July 2024	navpw1	TFS: 61525 (61527) - Hiding Max Weight when release request is changed
04 Dec	2024	navcs2	MTN-14819 EUP | Release By Weight - VBS Weight Limit Dev - Thin Client - Extra Changes
*/

vars

begin
	self.txtQuantity.text := "";
	self.tblMaxWeight.visible := false;
	self.lblMaxWeight.visible := false;
	self.populateDetailsCombo();
