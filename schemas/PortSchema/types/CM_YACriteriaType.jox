    <JadeMethod name="getAllCriteriaValues" id="6be09d26-2d07-4c3b-bb29-8deedf3ca847">
        <source>getAllCriteriaValues(_terminalObj:CM_Terminal; _allCriteriaValues:ObjectSet input; _filter : Integer; _allDependentObjs : CM_ObjectArray);
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Purpose:		Populate the collection parameter with instances of the corresponding
//				class.  The class will vary depending upon the Criteria Type.  Some
//				types have no corresponding class, but instead uses a primitive value
//				(i.e. boolean).
//
//				Only reimplement this method if non-primitive values are expected for
//				the receiving Criteria Type.
//
// Parameters:	_terminalObj - A reference to the Terminal from which to fetch the values.
//				_allCriteriaValues - A reference to the collection to populate.
//				_filter - An optional filter.
//
// Returns:		The populated collection parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//17 September 2013	cnwmc5	PAR 31255 - allowing dependent objects the criteria is based on.
// --------------------------------------------------------------------------------
begin
	app.raiseUnexpectedProgramError(class.name, method.name, "This method is inappropriate for this Criteria Type (primitive values only expected)");
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getAllCriteriaValuesByPattern" id="893aefdd-dc6f-4ffa-99a9-b5b591736faf">
        <source>getAllCriteriaValuesByPattern(_pattern: String; pAllCriteriaValues:ObjectSet input);
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Purpose:		Populate the collection parameter with instances of the corresponding
//				class that match the pattern string.  The class will vary depending 
//				upon the Criteria Type.  Some types have no corresponding class, but
//				instead uses a primitive value	(i.e. boolean).
//
//				Only reimplement this method if non-primitive values are expected for
//				the receiving Criteria Type.
//
// Parameters:	_pattern - the pattern to use - this is assumed to be a valid pattern string
//				pAllCriteriaValues - A reference to the collection to populate.
//
// Returns:		The populated collection parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.raiseUnexpectedProgramError(class.name, method.name, "This method is inappropriate for this Criteria Type (primitive values only expected)");
end;</source>
        <Parameter name="_pattern" type="String"/>
        <Parameter name="pAllCriteriaValues" type="ObjectSet" usage="input"/>
    </JadeMethod>
