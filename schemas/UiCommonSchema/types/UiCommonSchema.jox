    <JadeMethod name="showTrxErrorDialog" id="c7c58ccf-592b-47df-8d77-b2324cb677f2">
        <source>showTrxErrorDialog(_heading : String) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Sep 2019	jlger1	Initial creation 46815

*/

vars
	theReturn : Integer;
begin
	if self.myPassport.trxCompletedOK then
		return false;
	endif;
	
	theReturn := app.showErrorWarningDialog(_heading, self.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
	if self.myPassport.noErrors and
	   theReturn = IDOK then
		// there must have just been warnings that the user has acknoledged so ..
		self.myPassport.warningsAcknowledged	:= true;
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_heading" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
