    <JadeMethod name="getTrackedItemForRow" id="fa4297fb-f8cf-4695-b3d0-72b83a684228">
        <source>getTrackedItemForRow(blnNew : Boolean output): CM_TrackedItem protected;
// ---------------------------------------------------------------------------
// Created:     06 May 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
// 05/08/2010	cnwdap1		PAR #25291 Objects in tbl_Items are CM_SOHLocation objects, NOT CMIF_TIGenCargo
// 12/08/2010	cnwdap1		PAR #25407 Objects in tbl_Items can be CM_SOHLocation OR CMIF_TIGenCargo
vars
	cmifObj		: CMIF_TIGenCargo;
	tiObj		: CM_TrackedItem;
	obj			: Object;				// PAR #25407
	sohLoc		: CM_SOHLocation;		// PAR #25291
	
begin
	//sohLoc := self.tbl_Items.cnEcGetRowObject().CM_SOHLocation;	// PAR # 25407
	obj := self.tbl_Items.cnEcGetRowObject();						// PAR # 25407
	//if sohLoc &lt;&gt; null then										// PAR # 25407
	if obj &lt;&gt; null and CM_SOHLocation.hasInstance(obj) then			// PAR # 25407
		sohLoc := obj.CM_SOHLocation;								// PAR # 25407
		if sohLoc.allTrackedItems.isEmpty then
			blnNew := true;
		else
			tiObj := sohLoc.allTrackedItems.first;
		endif;
	
	elseif obj &lt;&gt; null and CMIF_TIGenCargo.hasInstance(obj) then	// PAR # 25407
		cmifObj := obj.CMIF_TIGenCargo;								// PAR # 25407
		tiObj := cmifObj.getTrackedItem;							// PAR # 25407
		if tiObj = null then										// PAR # 25407
			blnNew := true;											// PAR # 25407
		endif;														// PAR # 25407
	endif;
	return tiObj;
	/* PAR #25291 what it was
	cmifObj	:=	tbl_Items.cnEcGetRowObject().CMIF_TIGenCargo;
	
	if cmifObj &lt;&gt; null then
		tiObj	:=	cmifObj.getTrackedItem;
		if tiObj = null then
			blnNew := true;
		endif;
	endif;
	
	return tiObj;*/
end;</source>
        <access>protected</access>
        <Parameter name="blnNew" type="Boolean" usage="output"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="handleF8Key" id="d74bc7da-1928-41f7-8554-0b516fa28ee7">
        <updating/>
        <source>handleF8Key() updating;

vars
	loc			: CM_LocationsController;
	selectedRow	: Integer;
	result		: Integer;
	trackedItem : CM_TrackedItem;
	blnNew	: Boolean;
begin
	if not app.myCurrentUserCan(self.myMobileDataAgent.myTerminal, PmMobMaintainAllocations) then
		app.msgBox(app.getErrorString1(NoPermission, 'maintain allocations.'), '', MsgBox_OK_Only);
		return;
	endif;

	loc	:= self.getLocationForRow();
	
	if loc = null then
		return;
	endif;
	
	result := app.msgBox(app.getErrorString1(Close_Location, loc.getFullId()), '', MsgBox_Yes_No);
	
	if result = MsgBox_Return_Yes then
		if self.closeLocation(loc) then
			loc := null;
			selectedRow := tbl_Items.row;
			// Replan the ti now this location is closed
			trackedItem := self.getTrackedItemForRow(blnNew);   //PAR 17517
			if trackedItem &lt;&gt; null then
				self.updateTILocation(trackedItem);
				tbl_Items.row := selectedRow;
				loc	:= self.getLocationForRow();
			endif;
			
			// If the replan failed open the allocation form
			if loc = null then
				self.handleF6Key();
			endif;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadTable" id="721841f3-1bed-49ea-874c-39b80a8106f3">
        <updating/>
        <source>loadTable(tbl : CM_MobTable io)updating;
/*
	Created on 14 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	cmif 		: CMIF_Object; 
	cmif_TI 	: CMIF_TIGenCargo;
begin
	tbl.rows := 1;
	self.myMobileDataAgent.recalculateLoadCounts;
	foreach cmif in self.myMobileDataAgent.allCMIFs do
		cmif_TI := cmif.CMIF_TIGenCargo;
		addTIToTable(tbl, cmif_TI);
	endforeach;
	self.myMobileDataAgent.recalculateLoadCounts;
	self.updateBtnCaption();//20/05/2009 cnwdz2 ccms1801
end;</source>
        <Parameter name="tbl" type="CM_MobTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processForCloseForm" id="b152948e-5097-440f-abd6-f1e7c6fade62">
        <updating/>
        <source>processForCloseForm():Boolean updating;
/*
	Created on 05 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	if not self.forceClose and self.myMobileDataAgent.allCMIFs.size() &gt; 0 then
		app.msgBox(app.getErrorString(EXIT_TO_MAIN_MENU),"", MsgBox_OK_Only);
		return false;
	endif;
	
	return inheritMethod;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
