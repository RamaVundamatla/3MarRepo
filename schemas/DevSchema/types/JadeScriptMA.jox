    <JadeMethod name="micoBenchmarking" id="50f0395b-439b-4714-b877-9c08dc939488">
        <source>micoBenchmarking();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2024		navma1	Initial creation

*/

vars
    oldWay : Boolean;
    dts,dte : Decimal[19];
    s,t,u,v : String;
    i,j,reps : Integer;
	prof	 : JadeProfiler;
	starTM   : Decimal[19,0];
	invoiceProcess	 : CM_InvoiceProcess;
	root : CM_Root;
begin
	app.myRoot.startJadeProfiler(prof,method.getNiceName,20,false,'MA',starTM);
    write CrLf &amp; "Starting...";
    reps   := 10000;  // adjust this to get a run length of 1 to 10 seconds
    oldWay := true;
    dts    := app.relativeMachineTime;
	
	write 'Start Time :' &amp; app.actualTimeAppServer.String;
   root := app.myRoot;
   
   foreach i in 1 to reps do
        if oldWay then
           invoiceProcess := CM_InvoiceProcessDefault.firstInstance;
		  // write invoiceProcess.description;
        else
            invoiceProcess := root.allInvoiceProcesses[InvoiceProcessDefault];
			//write invoiceProcess.description;
        endif;
    endforeach;
	
	write 'End Time : ' &amp; app.actualTimeAppServer.String;
    dte := app.relativeMachineTime;
    write "&lt;" &amp; s &amp; "&gt;" &amp; "&lt;" &amp; t &amp; "&gt;";  // to verify the functional results
    write ((dte-dts)/reps).roundedTo(6).String &amp; " ms/rep";
epilog
    write "Finished";
	app.myRoot.stopJadeProfiler(prof,starTM);
end;</source>
    </JadeMethod>
    <JadeMethod name="nXL1210221" id="948f5ddf-857b-4c1f-9896-6fff6c2d63a6">
