    <JadeMethod name="doEditRealDeckItem" id="475694f8-d12b-4cbe-8cfd-b6004d8eace3">
        <source>doEditRealDeckItem();
/*
Date		    Who			Reason
18 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	deckItem : CM_DeckItem;
begin
	if self.myCurrentProxyItemLayout &lt;&gt; null then
		deckItem := self.myCurrentProxyItemLayout.myDeckItem;
		if deckItem &lt;&gt; null then
			self.myAssistant.SHP_Assistant.showRORODeckItemForm(self.myCurrentDeck,deckItem, SHP_ParentChildForm.Mode_Edit);	
		endif;	
	endif;
	
	return;
		
	
epilog

end;</source>
