    <JadeMethod name="listboxAddEntry" id="5ae1d527-ac07-4cf5-b021-c55efd46e4e0">
        <source>listboxAddEntry(pObject:CM_YAEntity; pListboxObj:ListBox input; pItemLevel:Integer; pType:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		10 May 2006 by cnwdad1
//
// Purpose:		Adds an entry to the specified listbox control.
//
// Parameters:	pObject - A reference to an instance of a YA Entity subclass.
//				pListboxObj - A reference to the listbox control to add the entry to.
//				pItemLevel - The hierarchy level to add the entry at.
//				pType - The location type (refer to the "Location_..." class constants.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 08 Jan 2026  navma1 		MTN-36897 PEN - Transient File Growth in PEN Production Environment 
// --------------------------------------------------------------------------------
vars
	listPointer			: Integer;
	callerName			: String;
	callStackObj		: ProcessStackArray;
	methodCallObj		: MethodCallDesc;
	
begin
	if pType &lt;&gt; self.LOCATION_BLOCK and pType &lt;&gt; self.LOCATION_GROUP then
		create callStackObj transient;
		self.cnEcGetPreviousMethods(callStackObj);
		callStackObj.removeAt(1);
		methodCallObj	:=	callStackObj[1];
		
		app.raiseUnexpectedProgramError(class.name, method.name, "An attempt was made to add an invalid location type to the YA list - caller: " &amp; methodCallObj.display());
		// Thro and exception for invalid location type.
		return;
	endif;
	
	listPointer	:=	pListboxObj.addItem(pObject.getYAListDisplay(self.myOptSortIn.value));
	pListboxObj.itemObject[listPointer]	:=	pObject;
	pListboxObj.itemLevel[listPointer]	:=	pItemLevel;
	pListboxObj.itemData[listPointer]	:=	pType;
epilog
	if callStackObj &lt;&gt; null then
		callStackObj.purge();
		delete callStackObj;			//08.01.2026 navma1 #MTN-36897
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pObject" type="CM_YAEntity"/>
        <Parameter name="pListboxObj" type="ListBox" usage="input"/>
        <Parameter name="pItemLevel" type="Integer"/>
        <Parameter name="pType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="populateFillOptionCombos" id="87a22cdf-23bb-4662-8028-d561bf57a094">
        <source>populateFillOptionCombos(pComboboxObj:ComboBox input) protected;
// --------------------------------------------------------------------------------
// Created:		10 March 2005 by cnwdad1
//
// Purpose:		Populates the specified ComboBox control will YA Fill Options.
//
// Parameters:	pComboboxObj - A reference to the control to populate.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listPointer		: Integer;
	
begin
	listPointer	:=	pComboboxObj.addItem(YAFillOption_InOrderStr);
	pComboboxObj.itemData[listPointer]	:=	YAFillOption_InOrder;
	
	listPointer	:=	pComboboxObj.addItem(YAFillOption_AlternatingStr);
	pComboboxObj.itemData[listPointer]	:=	YAFillOption_Alternating;
	
	listPointer	:=	pComboboxObj.addItem(YAFillOption_FIFOStr);
	pComboboxObj.itemData[listPointer]	:=	YAFillOption_FIFO;
end;</source>
        <access>protected</access>
        <Parameter name="pComboboxObj" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="populateLocationsListbox" id="0adfe801-20b8-4dd5-ba67-4d5d3a73d3e1">
        <updating/>
        <source>populateLocationsListbox(pIsIn:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		15 March 2005 by cnwdad1
//
// Purpose:		Sets up the listbox of selected Yard Allocation (Groups of) Blocks.
//
// Parameters:	pIsIn - True if the incomming blocks are to be shown, otherwise
//					the outgoing blocks will be shown.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	blockGroupObj	: CM_YABlockGroup;
	blockObj		: CM_YABlock;
	listboxObj		: CMUI_YAListBox;
	listPointer		: Integer;
	
begin
	self.setIsSortIn(pIsIn);
	
	listboxObj	:=	self.myLstLocations;
	listPointer	:=	listboxObj.topIndex;
	listboxObj.clear();
	
	if pIsIn then
		foreach blockGroupObj in self.allBlockGroupsIn do
			self.listboxAddEntry(blockGroupObj, listboxObj, 1, self.LOCATION_GROUP);
			
			foreach blockObj in blockGroupObj.allYABlocksIn do
				self.listboxAddEntry(blockObj, listboxObj, 2, self.LOCATION_BLOCK);
			endforeach;
		endforeach;
	else
		foreach blockGroupObj in self.allBlockGroupsOut do
			self.listboxAddEntry(blockGroupObj, listboxObj, 1, self.LOCATION_GROUP);
			
			foreach blockObj in blockGroupObj.allYABlocksOut do
				self.listboxAddEntry(blockObj, listboxObj, 2, self.LOCATION_BLOCK);
			endforeach;
		endforeach;
	endif;
	
	listboxObj.doOpenNodes();
	
	if self.isFirstLocationLoad then
		if listPointer &gt; 1 then
			listboxObj.topIndex	:=	listPointer;
		endif;
	endif;
end;</source>
        <Parameter name="pIsIn" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateNoLocationFlagCombobox" id="5c58c324-39a3-4052-b875-be7c8521fcd4">
        <source>populateNoLocationFlagCombobox() protected;
// --------------------------------------------------------------------------------
// Created:		11 March 2005 by cnwdad1
//
// Purpose:		Populates the specified ComBox control will YA Fill Options.
//
// Parameters:	pComboboxObj - A reference to the control to populate.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	comboboxObj		: ComboBox;
	listPointer		: Integer;
	
begin
	comboboxObj	:=	self.myCmbNoLocation;
	
	listPointer	:=	comboboxObj.addItem(YANoLocation_ContinueStr);
	comboboxObj.itemData[listPointer]	:=	YANoLocation_Continue;
	
	listPointer	:=	comboboxObj.addItem(YANoLocation_StopStr);
	comboboxObj.itemData[listPointer]	:=	YANoLocation_Stop;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateOverlapFlagCombobox" id="76aa3c7d-1200-4669-a49a-6870a0d4cae2">
        <source>populateOverlapFlagCombobox() protected;
// --------------------------------------------------------------------------------
// Created:		11 March 2005 by cnwdad1
//
// Purpose:		Populates the specified ComBox control will YA Fill Options.
//
// Parameters:	pComboboxObj - A reference to the control to populate.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	comboboxObj		: ComboBox;
	listPointer		: Integer;
	
begin
	comboboxObj	:=	self.myCmbAllowOthers;
	
	listPointer	:=	comboboxObj.addItem(YAOverlap_AlwaysStr);
	comboboxObj.itemData[listPointer]	:=	YAOverlap_Always;
	
	listPointer	:=	comboboxObj.addItem(YAOverlap_NeverStr);
	comboboxObj.itemData[listPointer]	:=	YAOverlap_Never;
	
	listPointer	:=	comboboxObj.addItem(YAOverlap_SometimesStr);
	comboboxObj.itemData[listPointer]	:=	YAOverlap_Sometimes;
	
	listPointer	:=	comboboxObj.addItem(YAOverlap_LastResortStr);
	comboboxObj.itemData[listPointer]	:=	YAOverlap_LastResort;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateOverstowRulesCombobox" id="503c49d9-be47-46aa-a2cf-f10fba5a8e08">
        <source>populateOverstowRulesCombobox(_terminal : CM_Terminal) protected;
// --------------------------------------------------------------------------------
// Created:		11 March 2005 by cnwdvb1
//
// Purpose:		Populates the specified ComBox control will YA Fill Options.
//
// Parameters:	pComboboxObj - A reference to the control to populate.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	comboboxObj		: ComboBox;
	listPointer		: Integer;
	rule			: CM_YAOverstowRule;
	
begin
	comboboxObj	:=	self.myCmbOverstowRule;
	listPointer	:=	comboboxObj.addItem('None');
	comboboxObj.itemObject[listPointer]	:=	null;
	
	foreach rule in _terminal.allYAOverstowRules discreteLock do
		listPointer	:=	comboboxObj.addItem(rule.code);
		comboboxObj.itemObject[listPointer]	:=	rule;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
