    <JadeMethod name="change" id="c0ab4de7-bdfa-485a-b1b7-06ecce49475b">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>change(textbox: TextBox input) updating, clientExecution;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/05/2013	cnwdap1		Initial creation PAR #31574 Allowable Time Off Power entry
//
vars

begin
	inheritMethod(textbox);
	self.myFieldFrame.hasChanged(self.myFieldFrame);
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lostFocus" id="360a3b2b-5f74-478d-af8c-cd2794c77dea">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>lostFocus(textbox: TextBox input) updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 July 2009	cnwdap1	Initial creation

*/

vars

begin
	inheritMethod(textbox);
	self.myFieldFrame.hasLostFocus(self.myFieldFrame);
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="parentName" id="72d078d4-29ee-48a9-9138-1cd3fb633ede">
        <source>parentName() : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 September 2009	cnwdap1	Initial creation
*/
vars

begin
	return self.myFieldFrame.name;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="228c323a-f24b-4d56-b706-3dc731223cbd">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2013	cnwmc5	Initial creation	PAR 31051

*/

vars

begin
	inheritMethod(cntrl, persistCntrl);
	
	if not self.isInPainter then
		if app.isUsingSkin() then
			self.height := self.height - 1;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
