    <JadeMethod name="overlapsMe" id="341df82b-d3f9-48bc-b776-401d83d71632">
        <source>overlapsMe(	_opHrs : CM_WorkPointOperatingHours ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

begin
	if _opHrs.craneWorkPointId &lt;&gt; self.craneWorkPointId then
		//different crane or workpoint
		return false;
	endif;

	if _opHrs.labourStart &gt;= self.labourStart and ( not self.labourEnd.Date.isValid or _opHrs.labourStart &lt;= self.labourEnd ) then
		//other one starts between my dates or starts after me and I have no end date yet.
		return true;
	elseif _opHrs.labourStart &lt; self.labourStart and ( not _opHrs.labourEnd.Date.isValid or _opHrs.labourEnd &gt;= self.labourStart ) then
		//other one starts before me and has no end date or starts before me and his end date is not before my start date.
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_opHrs" type="CM_WorkPointOperatingHours"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
