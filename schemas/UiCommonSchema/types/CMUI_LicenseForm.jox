    <JadeMethod name="doCkbTerminalClick" id="174dcaeb-61ab-439b-b30f-c32959e976e2">
        <updating/>
        <source>doCkbTerminalClick()updating, protected;
//--------------------------------------------------
// Created:	13 September 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.ckbTerminal.value then
		self.populateCmbForTerminalLicense();
	else
		self.populateCmbForSystemLicense();
	endif;
end;</source>
