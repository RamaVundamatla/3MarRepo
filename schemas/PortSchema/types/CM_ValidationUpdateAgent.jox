    <JadeMethod name="valSetControllerStatusWithYA" id="3524d7c7-b138-48b3-85fc-89dd3528f5f3">
        <updating/>
        <source>valSetControllerStatusWithYA(	_status:Integer;
								_controllerObj:CM_LocationsController;
								_allAllocationsObj:CM_YardAllocationSet;
								_passport:CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2008 by cnwdad1:2
//
// Purpose:		Refer to transaction method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.raiseExceptionIfNull(_controllerObj, "Locations Controller");
	self.raiseExceptionIfNull(_allAllocationsObj, "Yard Allocations to remove");
	
	if _status &lt;&gt; LC_Status_Closed
	and _status &lt;&gt; LC_Status_Open
	then
		app.raiseCMException1(Location_Status_Invalid, _status.String, null, null);
	endif;
end;</source>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_controllerObj" type="CM_LocationsController"/>
        <Parameter name="_allAllocationsObj" type="CM_YardAllocationSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
