<Class name="CMQF_ExportsLoaded" id="72d60c64-0e47-4eb0-92ca-af0ab404629e">
    <superclass name="CMQF_Export"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>ExportsLoadedToVessel</text>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="d9c1425a-30ae-42db-b25c-eecde4a394a5">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
//----------------------------------------------------------------
//	Created:	20 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	ti				: CM_TrackedItem;
	breakOut		: Boolean;
begin
	//need a voyage

	if self.getMyVoyage &lt;&gt; null then
	
		foreach ti in self.getMyVoyage.allOnshipTIsByIdCargoType discreteLock do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
					self.doStats(ti);
				endif;
			endif;
			
//			if breakOut then
//				return;
//			endif;
		endforeach;
	endif;
		
	
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
