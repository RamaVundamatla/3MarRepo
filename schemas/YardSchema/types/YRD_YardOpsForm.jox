    <JadeMethod name="addToolbarControls" id="68ae7261-687f-4d48-83ef-7bf21d91536f">
        <updating/>
        <source>addToolbarControls() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Jul2009	cnwrd1	Initial creation
13 Sep 2022 navma1	ChangeRequest 54645: MTN - Work Order Refactor (Additional Changes and remove IsSpecial)
27 Mar 2023 navdp20  ChangeRequest 57304:[57305] EUP - [Framework] - Add selection counter and Text Filtering on Yard Operation screen
*/

vars

	toolbar	,
	queryToolbar	: CMUI_Toolbar;
	leftAlignment   : Integer;
begin
	
	toolbar 		:= self.frmToolbar;
	leftAlignment	:= CMUI_Toolbar.Control_Alignment_Left;
	
	toolbar.addButton(self.btnPrint, 		leftAlignment);
	toolbar.addSeperator(leftAlignment);
	
	toolbar.addButton(self.btnShowSearcher, leftAlignment);
	toolbar.addButton(self.btnNewTV, 		leftAlignment);
	toolbar.addButton(self.btnEdit,			leftAlignment);
	toolbar.addButton(self.btnDeleteTV, 	leftAlignment);
	toolbar.addSeperator(leftAlignment);

	toolbar.addFrame(self.frmViewBy, 		leftAlignment);
	toolbar.addSeperator(leftAlignment);	
	
	toolbar.addButton(self.btnMoveIt,		 leftAlignment);
	toolbar.addSeperator(leftAlignment);

	toolbar.addButton(self.btnShowWorkOrder, leftAlignment);
	
	/* //23/04/2024	navkc1 CR63736 Task 63770 - Use new filter control
	toolbar.addSeperator(leftAlignment);										     //27.3.2023 navdp20 #57304[57305]
	toolbar.addFrame(self.frmFilterBox,    CMUI_Toolbar.Control_Alignment_Left);	 //27.3.2023 navdp20 #57304[57305]			
	toolbar.addButton(self.btnClearFilter, leftAlignment);                           //27.3.2023 navdp20 #57304[57305]          
	toolbar.addSeperator(leftAlignment);                                             //27.3.2023 navdp20 #57304[57305]
	*/ //23/04/2024	navkc1 CR63736 Task 63770 end
	
	//05/06/2024	navkc1 CR 63736 Task 63770
	toolbar.addSeperator(leftAlignment);
	toolbar.addFrame(self.frmTableFilter, leftAlignment);
	self.frmTableFilter.visible := true;
	toolbar.addSeperator(leftAlignment);
	
	//toolbar.addButton(self.btnShowSchedule,  leftAlignment);		//13.09.2022 navma1 #54645
	//toolbar.addButton(self.btnShowWorkMgr,   leftAlignment);		//13.09.2022 navma1 #54645
	toolbar.addButton(self.btnCancelBase, 	 leftAlignment);
					
	
	toolbar.positionToolbarControls();
	toolbar.visible 		  := true;	
	queryToolbar    		  := self.frmQueryToolbar;
	queryToolbar.showCaptions := false;
	
	
	self.addToolbarControlsQuery();
	queryToolbar.positionToolbarControls();
	queryToolbar.visible	 := true;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addToolbarControlsQuery" id="e5ad5212-56e3-492f-8a91-374e1ff3bb04">
        <updating/>
        <source>addToolbarControlsQuery() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2009	cnwrd1	Initial creation

*/

vars

	queryToolbar			: CMUI_Toolbar;
begin
	queryToolbar := self.frmQueryToolbar;
	queryToolbar.addButton(self.btnQuery, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnHideSearcher, CMUI_Toolbar.Control_Alignment_Left);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnDeleteTV_click" id="d60d262f-2ac1-48f7-a82c-3c46619623d8">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDeleteTV_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2009	cnwrd1	Initial creation

*/

vars
	msgStr : String;
	jobIDStr : String;
	separator : String;
	obj : Object;
begin

	foreach obj in self.tblJobs.allSelectedObjects do
		jobIDStr := jobIDStr &amp; separator &amp; obj.CM_Job.id;
		separator := ', ';
	endforeach;	

	msgStr := app.getErrorString2(ConfirmDelete, '', app.getErrorString(Jobs) &amp; ' - ' &amp; jobIDStr );
	if app.msgBox(msgStr, app.getErrorString(ConfirmDeletion), MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_Yes then
		self.doDeleteJob();
	endif;
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
