epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnTwo" id="051d2962-9486-4170-ae29-6abe3a8a7e74">
        <updating/>
        <source>handleBtnTwo() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	row : Integer;
	dataString : String;
	
begin

	//user pressed Checks
	if self.myTrackedItem = null then
		// need to create the item first.
		if saveChanges( true ) then
			self.myMobileGenericAgent.setTruck( self.myMobileGenericAgent.myTruck );
			return;	//03 jun 2010	NDL	Par 23903
		else
			return;
		endif;
	endif;
	
	self.myMobileGenericAgent.setMyNextTiToAction(self.myTrackedItem);
	self.myMobileGenericAgent.setDisplayIdOnCheckForm(true);
	
	
	row := tblCargo.getRow(ETRow_Location);
	if row &gt; 0 then
		dataString := tblCargo.getCellText(row,2).trimBlanks.toUpper;
		self.myMobileGenericAgent.setLocationPreChecks(dataString);
	endif;
	
	//28 Aug 2013	NDL	Par 32337
	self.myMobileGenericAgent.setStringField1(null);
	row := tblCargo.getRow(ETRow_NumItems);
	if row &gt; 0 then
		dataString := tblCargo.getCellText(row,2).trimBlanks.toUpper;
		self.myMobileGenericAgent.setStringField1(dataString);
	endif;
	
	self.myMobileGenericAgent.setDecimalField1(self.getConvertedWeight);
	
	self.gotoForm( MOB_HHGateCheckCargo, false );

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="hideAttributeRows" id="6dd46606-1884-4f17-8020-0db8d7808561">
        <updating/>
        <source>hideAttributeRows(_cargoType : CM_CargoType; _product : CM_Product) updating;

/*

Date		Who		Reason
22 April 2010	cnwas3	par 23825
27 April 2010   cnwas3 par 23956 - enhanced this to deal with subcargo types as well

If width,length,height,quantity are not viewable for the current (sub)cargo type,then do not show their rows, otherwise, show them with their display name as set up in the cargo type attibutes table in system admin
*/

vars
	
	attributes : StringArray;
	prodAttr : CM_ProductAttr;
	attrRow : Integer;
	product : CM_Product;
	sysCargoBOLType : Boolean;	
	prefix, heading, rowname : String;	
	entTableRow	: EntTableRow;
	convertedRowStr : String;
	
begin
	
	if _cargoType &lt;&gt; null then
		attributes := _cargoType.allAttributesOnProduct;
	elseif _product &lt;&gt; null and
		   _product.myCargoType &lt;&gt; null then
		attributes := _product.myCargoType.allAttributesOnProduct;
	endif;
	
		
	if _product &lt;&gt; null then
		product := _product;
	elseif _cargoType.mySystemProductType &lt;&gt; null then
		product := _cargoType.mySystemProductType;
	endif;	
	
	if _cargoType &lt;&gt; null then
		sysCargoBOLType := _cargoType.isSystemCargoBOLType;
	else
		sysCargoBOLType := false;//we have a subCargoType, therefore it's not a system cargo bol type
	endif;
	
	
	if not attributes.includes(ETRow_MyLength) or sysCargoBOLType then		
		self.tblCargo.hideRowByName(ETRow_Length,false);			
	elseif product &lt;&gt; null then			
		prodAttr := product.getProdAttrFromName(ETRow_MyLength);
		if prodAttr.isViewable then
			attrRow := self.tblCargo.getMeasureConvertedRowIndex(Type_Length,ETRow_Length);
			if attrRow &lt;= self.tblCargo.fixedRows or attrRow &gt; self.tblCargo.rows or not self.tblCargo.accessRow(attrRow).visible then
				self.tblCargo.showRowByName(ETRow_Length,false);
				attrRow := self.tblCargo.getRow(ETRow_Length);
			endif;
			self.updateMeasurementTypeRow( 	self.tblCargo, ETRow_Length, attrRow, self.tblCargo.ColumnHeading, 2, prodAttr );
		else
			self.tblCargo.hideRowByName(ETRow_Length,false);				
		endif;				
	endif;
	
	
	if not attributes.includes(ETRow_MyWidth) or sysCargoBOLType then
		self.tblCargo.hideRowByName(ETRow_Width,false);
	elseif product &lt;&gt; null then		
		prodAttr := product.getProdAttrFromName(ETRow_MyWidth);
		if prodAttr.isViewable then
			attrRow := self.tblCargo.getMeasureConvertedRowIndex(Type_Width,ETRow_Width);
			if attrRow &lt;= self.tblCargo.fixedRows or attrRow &gt; self.tblCargo.rows or not self.tblCargo.accessRow(attrRow).visible then
				self.tblCargo.showRowByName(ETRow_Width,false);
				attrRow := self.tblCargo.getRow(ETRow_Width);
			endif;
			self.updateMeasurementTypeRow( 	self.tblCargo, ETRow_Width, attrRow, self.tblCargo.ColumnHeading, 2, prodAttr );
		else
			self.tblCargo.hideRowByName(ETRow_Width,false);
		endif;			
	endif;
	
	
	if not attributes.includes(ETRow_MyHeight) or sysCargoBOLType then
		self.tblCargo.hideRowByName(ETRow_Height,false);			
	elseif product &lt;&gt; null then
		prodAttr := product.getProdAttrFromName(ETRow_MyHeight);
		if prodAttr.isViewable then
			attrRow := self.tblCargo.getMeasureConvertedRowIndex(Type_Height,ETRow_Height);
			if attrRow &lt;= self.tblCargo.fixedRows or attrRow &gt; self.tblCargo.rows or not self.tblCargo.accessRow(attrRow).visible then
				self.tblCargo.showRowByName(ETRow_Height,false);
				attrRow := self.tblCargo.getRow(ETRow_Height);
			endif;
			self.updateMeasurementTypeRow( 	self.tblCargo, ETRow_Height, attrRow, self.tblCargo.ColumnHeading, 2, prodAttr );
		else
			self.tblCargo.hideRowByName(ETRow_Height,false);	
		endif;		
	endif;
	
	
	if not attributes.includes(ETRow_MyQuantity) or sysCargoBOLType then
		self.tblCargo.hideRowByName(ETRow_Quantity,false);
	elseif product &lt;&gt; null then
		prodAttr := product.getProdAttrFromName(ETRow_MyQuantity);
		if prodAttr.isViewable then
			self.tblCargo.showRowByName(ETRow_Quantity,false);
			attrRow := self.tblCargo.getRow(ETRow_Quantity);
			self.tblCargo.setCellText(attrRow, self.tblCargo.ColumnHeading, prodAttr.displayName);
		else
			self.tblCargo.hideRowByName(ETRow_Quantity,false);
		endif;		
	endif;
	
	if not attributes.includes(ETRow_MyType) or sysCargoBOLType then
		self.tblCargo.hideRowByName(ETRow_DimType,false);
	elseif product &lt;&gt; null then
		prodAttr := product.getProdAttrFromName(ETRow_MyType);
		if prodAttr.isViewable then
			self.tblCargo.showRowByName(ETRow_DimType,false);
			attrRow := self.tblCargo.getRow(ETRow_DimType);
			self.tblCargo.setCellText(attrRow, self.tblCargo.ColumnHeading, prodAttr.displayName);
		else
			self.tblCargo.hideRowByName(ETRow_DimType,false);
		endif;		
	endif;
	
	if product &lt;&gt; null then			
		prodAttr := product.getProdAttrFromName(ETRow_TotalWeight);
		
		attrRow := self.tblCargo.getMeasureConvertedRowIndex(Type_Weight,ETRow_TotalWeight);
		if attrRow &lt;= self.tblCargo.fixedRows or attrRow &gt; self.tblCargo.rows or not self.tblCargo.accessRow(attrRow).visible then
			self.tblCargo.showRowByName(ETRow_TotalWeight,false);
			attrRow := self.tblCargo.getRow(ETRow_TotalWeight);
		endif;
		self.updateMeasurementTypeRow( 	self.tblCargo, ETRow_TotalWeight, attrRow, self.tblCargo.ColumnHeading, 2, prodAttr );
					
	endif;


end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_product" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="initTblCargo" id="9ec081d5-ad9c-463e-a7bd-797861352636">
        <updating/>
        <source>initTblCargo( entTableString : String ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	vHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	vHeight := self.btnOne.top - self.resizedMargin  - self.resizedMargin;

	self.tblCargo.visible := true;
	self.tblCargo.move(	self.resizedMargin,
						self.resizedMargin,
						self.clientWidth - self.resizedMargin - self.resizedMargin,
						vHeight );
						
	self.tblCargo.fixedRows := 0;
	self.tblCargo.fixedColumns := 0;
	self.tblCargo.rows := 0;
	self.tblCargo.columns := 2;
	self.tblCargo.parentAspect:=Table.ParentAspect_StretchBoth;
	
	self.setEntTable( entTableString );
	
	self.doResizeControls(true);
	
epilog

end;</source>
        <Parameter name="entTableString" type="String"/>
    </JadeMethod>
