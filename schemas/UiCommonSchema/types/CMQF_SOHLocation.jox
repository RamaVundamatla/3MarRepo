<Class name="CMQF_SOHLocation">
    <JadeMethod name="setFromAgent" id="e3bc460b-d9cc-4eaf-b17d-9499eecaa6ea">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;
// ---------------------------------------------------------------------------
// Created:     12 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	cargoType		: CM_CargoBOLType;
begin
	if _agent.isRowIncluded(ETRow_VoyageActual) then
		self.setMyVoyageGlobal( _agent.getSelectedActualVoyage() );
	endif;
	
	//18/05/2009 cnwdz2 par19257 changed ETRow_Voyage to ETRow_VoyageAllocated
	if _agent.isRowIncluded(ETRow_VoyageAllocated) then
		self.setMyVoyageGlobalAllocated( _agent.getSelectedAllocatedVoyage() );
	endif;	
	
	cargoType := _agent.getSelectedCargoType();
	if cargoType &lt;&gt; null then
		self.cargoType := cargoType.id;
	endif;
	
	inheritMethod(_agent);


end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
