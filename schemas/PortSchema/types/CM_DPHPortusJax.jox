    <JadeMethod name="getSiteId" id="a3e56a00-dec7-47f1-bbc7-096f6bbb3b95">
        <source>getSiteId(_bank: CM_Bank) : String;
/*
Purpose:			
Date		Who		Reason
21 May 2013	cnwab1	Initial creation
21 Jul2017	cnwma1	TFS #5392  DPH - External File for Business Unit 025
04 Sep2017	cnwma1	TFs #6806  DPH - External File for Business Unit 025 Rework 
*/

vars

begin
	if _bank.code = "DFBU" then  //21.07.2017 cnwma1 TFS #5392
		return "JAX";
	else
		//return "TOTE";  // 04/09/2017 cnwma1 TFS #6806
		return "025";    // 04/09/2017 cnwma1 TFS #6806
	endif;
epilog

end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
        <ReturnType type="String"/>
    </JadeMethod>
