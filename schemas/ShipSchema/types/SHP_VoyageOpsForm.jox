    <JadeMethod name="doMnuSummariseSelectedClick" id="665621ea-d65d-4ab3-8514-9e24d26c8a0a">
        <source>doMnuSummariseSelectedClick();

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
16 February 2009	cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	coll				: ObjectSet;
	
begin
	app.mousePointer	:= Busy;
	create coll transient;
	
	// Get a collection of all the objects SELECTED to pass to the Summary Definition form.
	if self.myCurrentContextTbl &lt;&gt; null then
		self.myCurrentContextTbl.allSelectedObjects.copy( coll );
	endif;
	self.myAssistant.showXTABSummaryDefinitionForm( coll, false, false, false, true );
	
epilog
	delete coll;
	app.mousePointer	:= Idle;
	
end;</source>
