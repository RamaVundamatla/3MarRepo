    <JadeMethod name="action" id="c3163608-a515-4ea6-b7a5-ea783c3a9557">
        <updating/>
        <source>action(): Boolean updating;
/*

Purpose:			Perform the required Web Service call(s) based on the attributes of the
					receiver

Parameters:			None

Return Value:		True if the request is successfully processed

Date		Who		Reason
11 Jun 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
25 Jun 2018	jlgkpd1	TFS 39323 - Handle timeout retry processing
25/06/2018  cnwma1	ChangeRequest 38635: PEL1 - SAP Cancellations
29/06/2018  cnwma1	ChangeRequest 39405: PEL1 - SAP Release Hold
02/07/2018  cnwma1	ChangeRequest 38633: PEL1 - SAP Send Invoice and Associated Data Interfaces
12/07/2018	jlgrs1	ChangeRequest 38630: PEL1 - SAP Credit Check Interfaces
23/11/2018  cnwma1	Bug 42175: PEL1 - Auto Posting Invoices after WSDL 1.2 Sucesss
*/

vars
	errCode 		: Integer;
	errTxt 			: String;
	msg 			: String;
	timeoutOccurred : Boolean;
	agent			: CM_SAPWSConsumerAgent;
	wsDefinition	: CM_ExternalWebServiceDef;
	returnVal		: Boolean;
	user 			: CM_User;
begin
	app.writeLog( method.qualifiedName,LogINFO);
	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	
	returnVal := true;
	self.setUser();
	if self.myUser = null then
		user := app.myBGPObject.BGP_ExternalWSController.myUser;
		app.myPassport.setMyUser(user);
	endif;
	msg := 'Call SAP Web Service';
	app.writeLog(self.getUserCode&amp;' '&amp;app.name &amp; ' ' &amp; msg ,LogINFO);
	
	wsDefinition := app.myBGPObject.BGP_ExternalWSController.myExternalWSDef;
	create agent transient;
	agent.setupFromWebServiceDefinition(wsDefinition);
	app.myPassport.setMyTerminal(self.myTerminal);     //23/11/2018  cnwma1	Bug 42175
	
	//19.06.2018 cnwma1 ChangeRequest #38637
	if self.isSAPAutoEstReq then                //001 - WSDL 1.1: Auto-Collection - Credit Limit + Hold Amount 
		timeoutOccurred := not self.processSAPAutoEstReq(agent);
	elseif self.isSAPPreBillCheckLimitReq then  //002 - WSDL 1.4: Pre-Billing - Credit Limit + Billing Payment Process
		timeoutOccurred := not self.processSAPPreBillCheckLimitReq(agent);
	elseif self.isSAPPostBillEstReq then        //003 - WSDL 1.6: Post-Billing - Credit Limit
		timeoutOccurred := not self.processSAPPostBillEstReq(agent);
	elseif self.isSAPReleaseHoldDebit then 		//004 - WSDL 1.2: Auto-Collection - Release Hold/Debit
		timeoutOccurred := not self.processSAPReleaseHoldDebit(agent); 
	elseif self.isSAPAutoInvReq then 	   		//005 - WSDL 1.3: Auto-Collection - Revenue Journal + Incoming Cash Journal
		timeoutOccurred := not self.processSAPAutoInvoiceReq(agent);
	elseif self.isSAPPreBillInvoiceReq then 	//006 - WSDL 1.5: Pre-Billing - Revenue Journal + Incoming Cash Journal
		timeoutOccurred := not self.processSAPPreBillInvoiceReq(agent);
	elseif self.isSAPPostBillInvReq then 		//007 - WSDL 1.7: Post-Billing - Billing Payment Process
		timeoutOccurred := not self.processSAPPostBillInvReq(agent);
	elseif self.isSAPGetExchangeRate then       //008 - WSDL 1.8: Foreign Exchange Rate - Get Exchange Rate
		timeoutOccurred := not self.processSAPGetExchangeRate(agent);
	elseif self.isSAPCancelEstimate then        //009 - WSDL 1.10: Auto-Collection - Estimation Cancellation
		timeoutOccurred := not self.processSAPCancelEstimate(agent);
    elseif self.isSAPCancelPaymentCode then     //010 - WSDL 1.11: Pre-Billing - Cancellation
		timeoutOccurred := not self.processSAPCancelPaymentCode(agent);
	elseif self.isSAPPreBillProdDataReq then  //011 - WSDL 1.12: Pre-Billing - Revenue Journal + Incoming Cash Journal
		timeoutOccurred := not self.processSAPPreBillProdDataReq(agent);
	elseif self.isSAPDataKinerja then     
		timeoutOccurred := not self.processSAPDataKinerja(agent);
	elseif self.isSAPDataTPP then     
		timeoutOccurred := not self.processSAPDataTPP();
	endif;
	
	// Handle timeout
	if timeoutOccurred then
		if self.doWebServiceTimeoutProcessing(wsDefinition) then
			returnVal := false;
		endif;
	endif;
		
epilog
	delete agent;
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	endif;
	inheritMethod();
	return returnVal;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createFileBarang" id="fef8a969-46dd-45b1-b87d-9e8a5c054921">
        <source>createFileBarang(file : File io;tppArr : CMIF_TPPArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jan 2019	cnwma1	ChangeRequest 42036: PEL1 - SAP TPP Report

*/

vars
	tpp : CMIF_TPP;
	line: String;
begin
	file.writeLine(
		"TERMINAL" 					  &amp; "," &amp;
		"YEAR"          			  &amp; "," &amp;
		"MONTH"         			  &amp; "," &amp;
		"WHARF CODE"    			  &amp; "," &amp;
		"WHARF NAME"    			  &amp; "," &amp;
		"BERTH CODE"    			  &amp; "," &amp;
	    "BERTH NAME"    			  &amp; "," &amp;
	    "IMEX"   					  &amp; "," &amp;
	    "BUSINESS UNIT" 			  &amp; "," &amp;
	    "TRANSFER TYPE" 			  &amp; "," &amp;
	    "KODE COMMODITY HEWAN/MOBIL"  &amp; "," &amp;
		"NAMA COMMODITY HEWAN/MOBIL"  &amp; "," &amp;
	    "ISO TYPE"  	 			  &amp; "," &amp;
	    "CONTENT STATUS"			  &amp; "," &amp;
	    "CARGO TYPE"    			  &amp; "," &amp;
	    "COMMODITY"    				  &amp; "," &amp;
		"QUANTITY REALISASI" 		  &amp; "," &amp;
	    "UOM"   	                  &amp; "," &amp;
		"VOYAGE CODE"
		);
	foreach tpp in tppArr where tpp.isBarangGLCode() do
	
		line :=
			tpp.termCode          &amp; "," &amp;
			tpp.year              &amp; "," &amp;
			tpp.month             &amp; "," &amp;
			tpp.wharfCode         &amp; "," &amp;
			tpp.wharfName         &amp; "," &amp;
			tpp.berthCode    	  &amp; "," &amp;
			tpp.berthName    	  &amp; "," &amp;
			tpp.imex         	  &amp; "," &amp;
			tpp.businessUnit 	  &amp; "," &amp;
			tpp.transferType 	  &amp; "," &amp;
			tpp.codeHewanMobil    &amp; "," &amp;
			tpp.nameHewanMobil    &amp; "," &amp;
			tpp.isoType           &amp; "," &amp;
			tpp.contentStatus     &amp; "," &amp;
			tpp.cargoType         &amp; "," &amp;
			tpp.commodity    	  &amp; "," &amp;
			tpp.quantity		  &amp; "," &amp;
			tpp.uOM               &amp; "," &amp;
			tpp.voyageCode;

		file.writeLine(line);
	
	endforeach;
epilog

end;</source>
        <Parameter name="file" type="File" usage="io"/>
        <Parameter name="tppArr" type="CMIF_TPPArray"/>
    </JadeMethod>
    <JadeMethod name="createFileKapal" id="19d9fe21-1615-400e-88bf-2e20a5810cfb">
        <source>createFileKapal(file : File io;tppArr : CMIF_TPPArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jan 2019	cnwma1	ChangeRequest 42036: PEL1 - SAP TPP Report

*/

vars
	tpp : CMIF_TPP;
begin
	file.writeLine(
		"Terminal Code" &amp; "," &amp;
		"YEAR"          &amp; "," &amp;
		"MONTH"         &amp; "," &amp;
		"WHARF CODE"    &amp; "," &amp;
		"WHARF NAME"    &amp; "," &amp;
		"BERTH CODE"    &amp; "," &amp;
	    "BERTH NAME"    &amp; "," &amp;
	    "VOYAGE CODE"   &amp; "," &amp;
	    "VESSEL NAME"   &amp; "," &amp;
	    "BUSINESS UNIT" &amp; "," &amp;
	    "RUTE PELAYARAN"&amp; "," &amp;
	    "COUNTRY ID"    &amp; "," &amp;
	    "VESSEL TYPE"   &amp; "," &amp;
	    "QUANTITY"      &amp; "," &amp;
	    "UNIT_GRT"      &amp; "," &amp;
	    "COUNTER"       &amp; "," &amp;
	    "FLAG"   	    &amp; "," &amp;
		"EXTERNAL INVOICE NBR"
		
		);
	foreach tpp in tppArr do
	
		file.writeLine( 
			tpp.termCode     &amp; "," &amp;
			tpp.year         &amp; "," &amp;
			tpp.month        &amp; "," &amp;
			tpp.wharfCode    &amp; "," &amp;
			tpp.wharfName    &amp; "," &amp;
			tpp.berthCode    &amp; "," &amp;
			tpp.berthName    &amp; "," &amp;
			tpp.voyageCode   &amp; "," &amp;
			tpp.vesselName   &amp; "," &amp;
			tpp.businessUnit &amp; "," &amp;
			tpp.routeType    &amp; "," &amp;
			tpp.countryID    &amp; "," &amp;
			tpp.vesselType   &amp; "," &amp;
			tpp.quantity     &amp; "," &amp;
			tpp.uNIT_GRT     &amp; "," &amp;
			tpp.counter      &amp; "," &amp;
			tpp.flag         &amp; "," &amp;
			tpp.externalInvoiceNbr
		);
	
	endforeach;
epilog

end;</source>
        <Parameter name="file" type="File" usage="io"/>
        <Parameter name="tppArr" type="CMIF_TPPArray"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="5677bd97-d7ba-45a9-8d61-faee9cb7b44c">
        <source>getDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/06/2018   cnwma1		ChangeRequest 38635: PEL1 - SAP Cancellations
29/06/2018   cnwma1		ChangeRequest 39405: PEL1 - SAP Release Hold
04 Sep 2018  cnwma1		ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data
31 Dec 2018  cnwma1		ChangeRequest 42036: PEL1 - SAP TPP Report
23 Jan 2019	 cnwma1 	ChangeRequest 42942: PEL1 - Container Services - SAP Process
*/

vars
 woID,
 customerNo,
 invoiceID,
 estimationID,
 voyCode,
 paymentCode	: String;
 invalid 		: Boolean;
 
begin
	on Exception do app.handleDeletedObject(exception,self.myWorkOrder, invalid);
	
	if invalid then
		return inheritMethod;
	endif;
	
	if self.myInvoice &lt;&gt; null then
		invoiceID := self.myInvoice.exportCurrencyCode.String;
		customerNo := self.myInvoice.getDebtor.name;
		paymentCode := self.myInvoice.paymentCode;
		if self.myInvoice.myVoyage &lt;&gt; null then
			voyCode := self.myInvoice.myVoyage.code;
		endif;
	endif;
	

	if self.myCashReceipt &lt;&gt; null then
		if self.myCashReceipt.getDebtor &lt;&gt; null then
			customerNo 	 := self.myCashReceipt.getDebtor.name;
		endif;
		estimationID := self.myCashReceipt.externalInvoiceNumber ; 
		if self.myCashReceipt.myCashInvoice &lt;&gt; null then           //23.01.2019 cnwma1 TFS #42942
			invoiceID := self.myCashReceipt.myCashInvoice.exportCurrencyCode.String;
			customerNo := self.myCashReceipt.myCashInvoice.getDebtor.name;
		endif;
	endif;

	
	if  self.isSAPAutoEstReq then			   //001 
		return inheritMethod &amp; Tab &amp; 'Term ['&amp;self.myTerminal.code &amp;']' &amp;' Perform Credit Check for Auto-Collection Customer : '&amp; customerNo &amp;' ,Estimation No : '&amp; estimationID;
	
	elseif self.isSAPPreBillCheckLimitReq then //002
		return inheritMethod &amp; Tab &amp; 'Term ['&amp;self.myTerminal.code &amp;']' &amp;' Perform Credit Check for Pre-Billing Customer ,Pre-Invoice No : '&amp; invoiceID;
	
	elseif self.isSAPPostBillEstReq	then       //003
		return inheritMethod &amp; Tab &amp; 'Term ['&amp;self.myTerminal.code &amp;']' &amp;' Perform Credit Check for Post-Billing Customer :    '&amp; customerNo &amp;' ,Estimation No : '&amp; estimationID;
	
	elseif self.isSAPReleaseHoldDebit then     //004
		return inheritMethod &amp; Tab &amp;'Term ['&amp;self.myTerminal.code &amp;']' &amp;' Send Release Hold and Debit for Auto-Collection Customer : '&amp; customerNo &amp; ' ,Invoice No :' &amp; invoiceID ;
	
	elseif self.isSAPAutoInvReq then           //005
		return inheritMethod &amp; Tab &amp;'Term ['&amp;self.myTerminal.code &amp;']' &amp;' Send Invoice / Data for Auto-Collection Customer :' &amp; customerNo &amp; ',Invoice No :' &amp; invoiceID;
	
	elseif self.isSAPPreBillInvoiceReq  then   //006
		return inheritMethod &amp; Tab &amp;'Term ['&amp;self.myTerminal.code &amp;']' &amp;' Send Invoice/Data for Pre-Billing Customer : '&amp; customerNo &amp; ',Invoice No :'&amp;  invoiceID ;
	
	elseif self.isSAPPostBillInvReq then       //007
		return inheritMethod &amp; Tab &amp;'Term ['&amp;self.myTerminal.code &amp;']' &amp;' Send Invoice/Data for Post-Billing Customer : '&amp; customerNo &amp; ',Invoice No :'&amp;  invoiceID ;
	elseif self.isSAPGetExchangeRate then      //008
		return inheritMethod &amp; Tab &amp;' Request Exchange Rate';
	elseif  self.isSAPCancelEstimate then      //009
		if self.myWorkOrder &lt;&gt; null and self.myWorkOrder.isKindOf(CM_WorkOrderVoyage) then
			woID := self.myWorkOrder.CM_WorkOrderVoyage.id;			
		endif;
		return inheritMethod &amp; Tab &amp; 'Term ['&amp;self.myTerminal.code &amp;']' &amp;' SAP Cancel Estimate for Work Order : '&amp; woID &amp;' Estimation ID : '&amp; estimationID;
	elseif  self.isSAPCancelPaymentCode then	//010	
		return inheritMethod &amp; Tab &amp;'Term ['&amp;self.myTerminal.code &amp;']' &amp;' SAP Cancel Payment Code : '&amp; paymentCode &amp;' Prepend Invoice ID : '&amp; invoiceID;
	elseif	self.isSAPDataKinerja then			//011 
		if invoiceID &lt;&gt; null then
			return inheritMethod &amp; Tab  &amp;'Term ['&amp;self.myTerminal.code &amp;']' &amp; ' SAP Send Performance Kinerja Data , '&amp; voyCode;
		else
			return inheritMethod &amp; Tab  &amp;'Term ['&amp;self.myTerminal.code &amp;']' &amp; ' SAP Send Performance Kinerja Data , Daily ';
		endif;
	elseif  self.isSAPPreBillProdDataReq then  //002
		return inheritMethod &amp; Tab &amp;'Term ['&amp;self.myTerminal.code &amp;']' &amp;' Send Pre-Billing - Revenue Journal and Incoming Cash Journal : '&amp; customerNo &amp; ',Invoice No :'&amp;  invoiceID ;
	elseif self.isSAPDataTPP then     
		return inheritMethod &amp; Tab  &amp;'Term ['&amp;self.myTerminal.code &amp;']' &amp; ' SAP Send Performance TPP Data';
	else
		return inheritMethod;
	endif;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initRequestFromTask" id="b53a9d31-b8d6-409e-8710-913fd8523d91">
        <updating/>
        <source>initRequestFromTask(_task: CM_AutoTask) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Jun 2018 cnwma1	ChangeRequest 38637: PEL1 - SAP Request Exchange Rate
31 Aug 2018	jlgma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data
27 Oct 2018 jlger1  TFS 41625  have tasks for each terminal
31 Dec 2018	cnwma1	ChangeRequest 42036: PEL1 - SAP TPP Report
*/

vars

begin
	if _task.isKindOf(CM_AutoTaskGetExchangeRate) then
		self.setIsGetExchangeRate(true);
		self.fromCurrency     := _task.CM_AutoTaskGetExchangeRate.fromCurrency;
		self.toCurrency       := _task.CM_AutoTaskGetExchangeRate.toCurrency;
		self.daysLookback     := _task.CM_AutoTaskGetExchangeRate.daysLookback;
	elseif _task.isKindOf(CM_AutoTaskSapPerformance) then    //31.08.2018 cnwma1 TFS #38638
		self.isSAPDataKinerja := true;
		self.myTerminal       :=_task.myTerminal;
	elseif _task.isKindOf(CM_AutoTaskSapTPP) then           //31.12.2018 cnwma1 TFS #42036
		self.isSAPDataTPP     := true;
		self.myTerminal       := _task.myTerminal;
		self.directoryPath    := _task.CM_AutoTaskSapTPP.directoryPath;
	endif;
	
	inheritMethod(_task);

epilog

end;</source>
        <Parameter name="_task" type="CM_AutoTask"/>
    </JadeMethod>
