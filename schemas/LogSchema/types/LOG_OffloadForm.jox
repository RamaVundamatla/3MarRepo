		self.tblSelectData.setTerminologyRelevant(app.myRoot.allBOLTypes[BOLType_Log], self.myTerminal);
		self.cmbLocation.listObject := null;
		self.tblActionData.setValueByName(ETRow_Location, null);
		selection := DOCKET;
		self.tblSelection.showHideRowsByViewName("viewDocket", CM_EntryTable.ShowHideRows, false); 
		self.tblSelection.optimiseHeadingColumn();
		self.tblSelection.adjustHeight(1000);
		resetDistances();
		self.resize();
		self.tblActionData.visible := true;
		self.tblSelectData.visible	:= true;
		self.txtDetail.visible		:= false;
		self.loadSelectionData();
		self.setNavigatorHeading('By Docket');
