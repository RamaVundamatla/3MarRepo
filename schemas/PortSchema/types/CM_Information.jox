    <JadeMethod name="getDisplayStringForAttribute" id="5d445e39-f8c8-4e05-883c-7cb5105a946e">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			return self.description &amp; ' double-click to view details...';
			
		endif;
							
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="ae82928b-81c2-470a-bc62-87abf2f0df66">
        <source>getEnquiryRow(): String;
// -------------------------------------------
// Created 21 September 2005 by cnwdvb1
// -------------------------------------------
vars

	str	: String;

begin

	str := inheritMethod();
	
	return str &amp; self.description &amp; ' double-click to view details...';


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRowFullInfo" id="230b2ddf-20ff-48d0-a6af-7e6852e16917">
        <source>getEnquiryRowFullInfo(_dataContainer: CM_DataContainer io);
/*

Purpose:			Populate the passed in Data Container from the receiver

Parameters:			Data container to update

Date		Who		Reason
28 Dec 2006	cnwmo1	Initial creation
28 Feb 2012	cnwkpd1	PAR #29165 - CCMS SFW 1272 - Reduce physical database size

*/

vars
	block 			: CM_DataContainerBlock;
	str				: String;
	theTI			: CM_TrackedItem;
	information 	: CM_Information;
	idx				: Integer;
	lColour			: Integer;
	infoLines		: StringArray512;
	
begin
	theTI := self.myTrackedItem;
	if theTI = null then
		return;
	endif;
	
	create _dataContainer transient;
	block := _dataContainer.addNewBlock;	
		
	/*beginTransaction;	
	if app.myYAAgent &lt;&gt; null then
		theTI.createInfomationTransaction('Yard allocation logging', app.myYAAgent.getLoggingArray(true), app.myPassport);
	endif;	
	commitTransaction;*/

	// PAR #29165 - Change to use method to handle possible XML storage option
	create infoLines transient;
	self.getInformationLines(infoLines);
	
	foreach str in infoLines do
		idx:= idx +1;
		block.addNewItem(idx.String &amp; ' ', DC_Label, 1, null);
		block.addNewItem(str, DC_Data, 1, null);
	endforeach;
	
epilog
	delete infoLines;

end;
</source>
        <Parameter name="_dataContainer" type="CM_DataContainer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getInformationLines" id="de3c53ca-bbef-4390-b65d-6fd362de418c">
        <source>getInformationLines(_infoLines : StringArray512 input);
/*

Purpose:			Get the information lines for the receiver into the passed in array, converting
					from the stored XML if required

Parameters:			Array to populate with information lines

Return Value:		Array cleared and populated as required

Date		Who		Reason
28 Feb 2012	cnwkpd1	PAR #29165 - CCMS SFW 1272 - Reduce physical database size

*/

vars
	headerTag,
	firstLine,
	xmlInfoString	: String;
	headerTagLen	: Integer;
	
begin
	_infoLines.clear();
	
	// New objects have xmlInfo populated, so check this first
	if self.xmlInfo &lt;&gt; null then
		_infoLines.setFromXmlString(self.xmlInfo, self.InfoHeaderTag, self.InfoDetailTag);
		return;
	endif;
	
	// Otherwise, info will be stored in the array, and could be XML or raw
	if self.allInformationLines.isEmpty() then
		return;
	endif;
	
	headerTag := "&lt;" &amp; self.InfoHeaderTag &amp; "&gt;";
	headerTagLen := headerTag.length();
	
	firstLine := self.allInformationLines.first();
	if firstLine.length &gt; headerTagLen and firstLine[1:headerTagLen] = headerTag then
		// Data has been stored as XML, so need to get it out and parse into parameter array
		xmlInfoString := self.allInformationLines.asLongString();
		_infoLines.setFromXmlString(xmlInfoString, self.InfoHeaderTag, self.InfoDetailTag);
	else
		// Data is stored raw in the array, so just copy it out
		self.allInformationLines.copy(_infoLines);
	endif;
		
epilog

end;</source>
        <Parameter name="_infoLines" type="StringArray512" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMyCamProtocolName" id="9499d31e-57d0-4c23-813c-20a4a99e2724">
        <source>getMyCamProtocolName() : String;
//
// ccms 1644 cnwrs1 Aug 2008 
//
/*

Date		Who		Reason
28 Feb 2012	cnwkpd1	PAR #29165 - CCMS SFW 1272 - Reduce physical database size
16/03/201	cnwnh5	Transient Leaks	
*/

vars
	pos 			: Integer;
	line1			: String;
	infoLines		: StringArray512;
	
begin
	// PAR #29165 - Change to use method to handle possible XML storage option
	create infoLines transient;
	
	self.getInformationLines(infoLines);
	
	if not infoLines.isEmpty then
		line1 := infoLines.first();
		if line1[1:9] = "Protocol:" then
			pos := 10;
			return line1.cnEcNextDelimitedField('seq', pos).trimBlanks();
		endif;	
	else
		return null;
	endif;
epilog
		delete infoLines;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyOtherTransaction" id="9e4f668b-d5e0-4732-a35b-377224bf1ff3">
        <source>getMyOtherTransaction() : CM_TITransaction;
//
// CCMS 1644 cnwrs1 Aug 2008
//
// 07/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
vars
	isInvalid : Boolean;
	int : Integer;
	otherTransaction 	: CM_TITransaction;
begin
	otherTransaction := self.myOtherTransaction;
	if otherTransaction = null then
		return null;
	endif;
	on Exception do app.handleDeletedObject(exception, otherTransaction, isInvalid);
	int := otherTransaction.type;
	if not isInvalid then
		return otherTransaction;
	else
		return null;
	endif;
end;
</source>
        <ReturnType type="CM_TITransaction"/>
    </JadeMethod>
