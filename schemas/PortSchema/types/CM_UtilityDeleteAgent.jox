    <JadeMethod name="utlDeleteVoyageStage" id="520add5a-bc66-46e5-a4c5-3efb8de827d0">
        <updating/>
        <source>utlDeleteVoyageStage(_realStage :CM_VoyageStage input; _passport : CM_Passport input) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 18JUL2024
ADO - CR 64612 TASK 64659
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars
	theTerminal : CM_Terminal;
	voyage      : CM_Voyage;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	// note that validation agent locks object
	app.myValDA.valVoyageStage(_realStage);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	if _passport.noErrors then
		// This should be :
		//_obj.erase(NORMAL_ERASE);
		// but is as below so test exceptions can be generated.
		theTerminal := _passport.myTerminal;
		voyage      := _realStage.getMyVoyageObject();
		app.myEventManager.createSingleObjInfoNoteEvt(voyage,theTerminal.getTerminalEvent(Event_VoyageStageDelete),_realStage);	

		_realStage.erase(NORMAL_ERASE);
	endif;

end;</source>
        <Parameter name="_realStage" type="CM_VoyageStage" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteWOJobGrouping" id="195f3534-4ce3-4c95-8e84-fc8c87edd1cf">
        <source>utlDeleteWOJobGrouping(_woJobGrouping : CM_WorkOrderJobGroupMethod io; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Sep 2023 navhl20 ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes

*/

vars

begin
	if not self.exclusiveLockObjectToDelete(_woJobGrouping) then
	    return;
	endif;
	_woJobGrouping.validateDelete(_passport);
	
	if not _passport.noErrors then
		return;
	endif;
	
	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_woJobGrouping);
	endif;
	
	_woJobGrouping.erase(NORMAL_ERASE);
epilog

end;</source>
        <Parameter name="_woJobGrouping" type="CM_WorkOrderJobGroupMethod" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteWPOperatingHours" id="ed826c42-6841-43c6-931a-7fe7ada3503b">
        <source>utlDeleteWPOperatingHours(_wpOpHrs : CM_WorkPointOperatingHours io; _passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 Apr 2012	cnwndl1	Initial creation	Par 29369
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars
	voyage : CM_Voyage;
	term : CM_Terminal;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valWPOperatingHours( _wpOpHrs, _passport );
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;


	app.setContinueCMExceptions(false);

	if _passport.hasErrors then					//31.03.2025 navma1 #MTN-34387
		return;
	endif;
	
	voyage := _wpOpHrs.myVoyage;
	if voyage &lt;&gt; null then
		term := voyage.getMyTerminal;
		if term &lt;&gt; null then
			app.myEventManager.createSingleObjInfoNoteEvt(voyage, term.getTerminalEvent(Voyage_Update_Event), voyage);
		endif;
	endif;

	_wpOpHrs.erase(NORMAL_ERASE);
epilog
	
end;</source>
        <Parameter name="_wpOpHrs" type="CM_WorkPointOperatingHours" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteWagon" id="81904f4d-deff-4a7b-a8b5-082ad3c9e27d">
        <source>utlDeleteWagon(	pWagon:CM_Wagon input;
				_isValidate : Boolean;
				_isTrainConsist : Boolean;
				_isInitialise : Boolean;
				_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 28/07/2010	cnwdad1		PAR #25120, added parameter for calling "initialiseActivity".
// ---------------------------------------------------------------------------
begin
	if _isInitialise then
		self.initialiseActivity();
	endif;
	
	app.setContinueCMExceptions(true);
	app.myValDA.valWagon(pWagon, (_isValidate and _isTrainConsist));
	
	if (not self.checkValidationWithPassport(_passport)) or _isValidate then // Show any Errors and Warnings in a list
		return;
	endif;

	app.setContinueCMExceptions(false);

	if _passport.noErrors() then
		self.myDeleteAuditAgent.audDeleteGeneric(pWagon);
	endif;

	if _passport.noErrors() then
		pWagon.erase(NORMAL_ERASE);
	endif;
end;</source>
