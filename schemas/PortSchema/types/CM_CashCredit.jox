    <JadeMethod name="getAuditText" id="e2ef6e07-3a80-4658-8245-9a510799c955">
        <source>getAuditText(): String;
/*

Purpose: To include the myCashPayment of both Derived from and Applied to Credit Details in audit trail.

Parameters:			

Return Value:		

Date		Who		TFS#	Reason
==========================================================
18 Jul 2019	jlgdi1	45301	Initial creation
==========================================================
*/

vars
	txt	: String;
	tmpStr : String;
	appliedCRDet : CM_CashCreditDetail;
	derivedCRDet : CM_CashCreditDetail;
	cashPayment : CM_CashPayment;
	cashPayments : CM_CashPaymentSet;
	
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	
	create cashPayments transient;
	
	foreach appliedCRDet in self.allAppliedToCreditDetails do
		if appliedCRDet.myCashPayment &lt;&gt; null then
			cashPayment := appliedCRDet.myCashPayment;
			if not cashPayments.includes(cashPayment) then
				if tmpStr = null then
					tmpStr := appliedCRDet.getDescription();
				else
					tmpStr := tmpStr &amp; ', ' &amp; appliedCRDet.getDescription();
				endif;
			endif;
		endif;
	endforeach;
	
	if tmpStr &lt;&gt; null then 
		txt := txt &amp; 'myCashPayment on Applied to Credit Details' &amp; AuditStringSeparator 
			   &amp; tmpStr.length.String &amp; AuditStringSeparator 
			   &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := "";
	cashPayments.clear();
	foreach derivedCRDet in self.allDerivedFromCreditDetails do
		if derivedCRDet.myCashPayment &lt;&gt; null then
			cashPayment := derivedCRDet.myCashPayment;
			if not cashPayments.includes(cashPayment) then
				if tmpStr = null then
					tmpStr := derivedCRDet.getDescription();
				else
					tmpStr := tmpStr &amp; ', ' &amp; derivedCRDet.getDescription();
				endif;
			endif;
		endif;
	endforeach;
	
	if tmpStr &lt;&gt; null then 
		txt := txt &amp; 'myCashPayment on Derived from Credit Details' &amp; AuditStringSeparator 
			   &amp; tmpStr.length.String &amp; AuditStringSeparator 
			   &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	return txt;
	
epilog
	delete cashPayments;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCreditAvailable" id="43d36144-428b-4c08-8330-78ae2a2ef1e2">
        <source>getCreditAvailable() : Decimal;

vars
	
	creditDetail	: CM_CashCreditDetail;
	value			: Decimal[23, 6];	//10 May 2018	NDL	TFS 38523
begin

	value := self.cashValue;

	foreach creditDetail in self.allAppliedToCreditDetails do
		value := value - creditDetail.cashValue;
	endforeach;

	if value &lt; 0 then
		value := 0;
	endif;
	
	return value;
end;
</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getDebtor" id="9ea2ccdc-9a09-4ca1-86f8-feac22564c1f">
        <source>getDebtor() : CM_Debtor;
// TFS 985

vars
	debtorTerminal	: CM_DebtorTerminal;
	debtor			: CM_Debtor;
begin
	debtorTerminal := self.getDebtorTerminal();
	if debtorTerminal &lt;&gt; null then
		debtor := debtorTerminal.myDebtor;
	endif;
	
	return debtor;
epilog

end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
