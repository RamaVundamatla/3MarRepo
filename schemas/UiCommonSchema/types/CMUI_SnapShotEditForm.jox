    <JadeMethod name="doBuildCargoSubTypeCombo" id="d962bfce-716d-4697-918f-5009dd8d3049">
        <source>doBuildCargoSubTypeCombo(_cargoType : CM_CargoType);
/*

Purpose:			TFS 40336

Parameters:			

Return Value:		

Date		Who		Reason
12 September 2018	jlgab1	Initial creation

*/

vars
	cargosub : CM_Product;
begin
	self.cmbCargoSubType.clear();
	
	if _cargoType = null then
		return;
	endif;
	
	foreach cargosub in _cargoType.allProducts	discreteLock do
		self.cmbCargoSubType.addItemObject(cargosub.description,cargosub);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="doSaveSnapShot" id="e0695127-6623-4965-afb0-3dbb22f0d31d">
        <updating/>
        <source>doSaveSnapShot() updating;
//----------------------------------------------------------------
//	Created:	15 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpCargoType, tmpImexStatus,
	tmpContentsStatus, tmpTransitStatus	: Integer;
	tmpID, tmpCommodity, tmpLoadPort,
	tmpDischPort, tmpOperator, tmpType	: String;
	tmpHide, tmpTranship,
	tmpOD, tmpIs40						: Boolean;
//	ssSet		: CM_SnapShotSet;
	changeStr	: String;
	chgReason	: CM_MessageUser;
	theReturn	: Integer;
	billOfLading : String;
	cargoGroupId : String;
	cargoSubtypeCode : String;
	cargoSubtypeDescription : String;
	cargoTypeCode : String;
	cargoTypeDescription : String;
	colour : String;
	customsAgentCode  : String;
	description : String;
	destinationPortCode : String;
	destinationPortDescription : String;
	dischargePortDescription : String;
	hazard  : String;
	isotypeDescription : String;
	loadPortDescription : String;
	markNumber : String;
	mark : String;
	orderNumber : String;
	remarks : String;
	totalQuantity : Integer;
	totalWeight : Decimal [16,4];
	totalVolume : Decimal [16,4];
	temp : Decimal [16,4];
	voyageCode : String;
	isotype : String;
	conee, conor : String;
	
begin

	if self.myProxyObject = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "the proxy object is null - cannot update");
		return;
	endif;

	if self.allEditSnapShots.size &lt; 2 then
		tmpID			:= self.txtToID.text;
	else
		tmpID := null;
	endif;
	
	if self.cmbToCargoType.myObject&lt;&gt; null then
		tmpCargoType		:= self.cmbToCargoType.myObject.CM_CargoType.id;
	endif;
	if self.cmbToImEx.myObject&lt;&gt; null then
		tmpImexStatus		:= self.cmbToImEx.myObject.CM_IMEXStatus.code;
	endif;
	if self.cmbToContents.listObject&lt;&gt; null then
		tmpContentsStatus	:= self.cmbToContents.listObject.CM_ContentsStatus.code;
	endif;
	if self.cmbToTransit.listObject &lt;&gt; null then
		tmpTransitStatus	:= self.cmbToTransit.listObject.CM_TransitStatus.code;
	endif;
	if self.cmbToCommodity.myObject&lt;&gt; null then
		tmpCommodity		:= self.cmbToCommodity.myObject.CM_Commodity.code;
	endif;
	if self.cmbToLoadPort.myObject &lt;&gt; null then
		tmpLoadPort			:= self.cmbToLoadPort.myObject.CM_Port.code;
	endif;
	if self.cmbToDischPort.myObject &lt;&gt; null then
		tmpDischPort		:= self.cmbToDischPort.myObject.CM_Port.code;
	endif;
	if self.cmbToOperator.myObject &lt;&gt; null then
		tmpOperator			:= self.cmbToOperator.myObject.CM_Operator.code;
	endif;
	tmpType				:= self.cmbToType.text;
	tmpHide				:= self.chkToHide.value;
	tmpTranship			:= self.chkToTranship.value;
	tmpOD				:= self.chkToOD.value;
	tmpIs40				:= self.cmbToSize.text = CMIF_CandHRpt.Size_40;
	changeStr			:= self.txtChangeReason.text;
	
	// TFS 40336
	if changeStr = "" then
		if self.isFromItemSelector() then
		changeStr := "Selector Query";
		endif;
	endif;
	
	// TFS 40336
	billOfLading := self.txtBOL.text;
	cargoGroupId := self.txtCargoGroupId.text;
	if self.cmbCargoSubType.listObject&lt;&gt; null then
		cargoSubtypeCode := self.cmbCargoSubType.listObject.CM_Product.code;
	endif;
	cargoSubtypeDescription := self.txtCargoSubDesc.text;
	if self.cmbToCargoType.myObject&lt;&gt; null then
		cargoTypeCode := self.cmbToCargoType.myObject.CM_CargoType.abbreviation;
	endif;
	cargoTypeDescription := self.txtCargoTypeDesc.text;
	colour := self.txtColour.text;
	if self.cmbCustomsAgent.listObject &lt;&gt; null then
		customsAgentCode  := self.cmbCustomsAgent.listObject.CM_CustomsAgent.code;
	endif;
	description := self.txtDescription.text;
	if self.cmbDestPort.listObject &lt;&gt; null then	
		destinationPortCode := self.cmbDestPort.listObject.CM_Port.code;
	endif;
	if self.cmbISOType.listObject &lt;&gt; null then
		isotype := self.cmbISOType.listObject.CM_ISOType.code;
	endif;
	destinationPortDescription := self.txtDestPortDesc.text;
	dischargePortDescription := self.txtDischPortDesc.text;
	hazard  := self.txtHAZCodes.text; // self.cmbHazList.getSelectedString();
	isotypeDescription := self.txtISOTypeDesc.text;
	loadPortDescription := self.txtLoadPortDesc.text;
	markNumber := self.txtMarkNumber.text;
	mark := self.txtMark.text;
	orderNumber := self.txtOrderNumber.text;
	remarks := self.txtRemarks.text;
	totalQuantity := self.txtTotalQuantity.text.Integer;
	totalWeight := self.txtTotalWeight.text.Decimal;
	totalVolume := self.txtTotalVolume.text.Decimal;
	temp := self.txtTemp.text.Decimal;
	voyageCode := self.txtVoyageCode.text;

	if self.cmbConsignee.listObject &lt;&gt; null then
		conee := self.cmbConsignee.listObject.CM_ConsigneeConsignor.code;
	endif;
	if self.cmbConsignor.listObject &lt;&gt; null then
		conor := self.cmbConsignor.listObject.CM_ConsigneeConsignor.code;
	endif;
	
	
	
	
	self.myProxyObject.setProxy(tmpHide, tmpIs40, tmpTranship, tmpOD,
								tmpID, tmpCommodity, tmpLoadPort, tmpDischPort, tmpOperator, tmpType,
								tmpCargoType, tmpImexStatus, tmpContentsStatus, tmpTransitStatus,
								// TFS 40336
								isotype,
								billOfLading,
								cargoGroupId,
								cargoSubtypeCode,
								cargoSubtypeDescription,
								cargoTypeCode,
								cargoTypeDescription,
								colour,
								customsAgentCode ,
								description,
								destinationPortCode,
								destinationPortDescription,
								dischargePortDescription,
								hazard ,
								isotypeDescription,
								loadPortDescription,
								markNumber,
								mark,
								orderNumber,
								remarks,
								totalQuantity,
								totalWeight,
								totalVolume,
								voyageCode,
								temp,
								conee,
								conor
								);
	
	
	create chgReason transient;
	chgReason.setForCreate("Update", changeStr, null, false, null, app.myPassport.myUser.code); 
			
	while true do
		app.myTrxUA.trxUpdateSnapShot(self.myProxyObject, self.allEditSnapShots, chgReason, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			theReturn := app.showErrorWarningDialog("Update Snap Shot", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
	self.unloadForm();
epilog

	delete chgReason;
end;</source>
    </JadeMethod>
    <JadeMethod name="isFromItemSelector" id="394ef536-c65d-4e06-84c6-9cdb391adbcc">
        <source>isFromItemSelector() : Boolean;
/*

Purpose:			TFS 40336

Parameters:			

Return Value:		

Date		Who		Reason
13 September 2018	jlgab1	Initial creation

*/

vars

begin
	return self.summaryCode = "ITEMSELECTOR";
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isNonContainer" id="a0e2832e-7897-417c-9750-291d17151667">
        <source>isNonContainer():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 October 2018	jlgndl1	Initial creation	TFS 41204

*/

vars

	obj : CM_Object;
	ti : CM_TrackedItem;

begin

	if self.myProxyObject &lt;&gt; null then
		obj := self.myProxyObject.snapShotOf;
		if obj &lt;&gt; null and obj.isKindOf( CM_TrackedItem ) then
			ti := obj.CM_TrackedItem;
			if ti &lt;&gt; null and not ti.isContainer then
				return true;
			endif;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromFromSnapShot" id="4ae828d2-f493-463e-9914-b34754ef6248">
        <updating/>
        <source>setFromFromSnapShot() updating;
//----------------------------------------------------------------
//	Created:	12 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	snapShot			: CM_TISnapShot;
	tmpPxy				: CM_UserTISnapShot;
	root				: CM_Root;
begin

	snapShot := self.allEditSnapShots.first.CM_TISnapShot;

	root := app.myRoot;
	
	if snapShot.myUserTISnapShot = null then
		create tmpPxy transient;
		tmpPxy.setFromTISnapShot(snapShot);
	else
		tmpPxy := app.createUpdateProxy(snapShot.myUserTISnapShot).CM_UserTISnapShot;
	endif;

	self.myProxyObject := tmpPxy;
	
	self.chkToHide.value			:= tmpPxy.ignore;
	
	if self.allEditSnapShots.size &gt; 1 then
		self.txtToID.text := "All Selected";
		self.txtToID.enabled := false;	
	else
		self.txtToID.enabled := true;
		self.txtToID.text := tmpPxy.id;	
	endif;
	self.chkToTranship.value		:= tmpPxy.isTransship;
	self.chkToOD.value				:= tmpPxy.isOverDimensions;
	
	
	// TFS 40336
	self.txtCargoSubDesc.text := tmpPxy.cargoSubtypeDescription;
	self.txtCargoTypeDesc.text := tmpPxy.cargoTypeDescription;
	self.txtCargoGroupId.text := tmpPxy.cargoGroupId;
	self.txtISOTypeDesc.text := tmpPxy.isotypeDescription;
	self.txtBOL.text := tmpPxy.billOfLading;
	self.txtColour.text := tmpPxy.colour;
	self.txtMarkNumber.text := tmpPxy.markNumber;
	self.txtMark.text := tmpPxy.mark;
	self.txtOrderNumber.text := tmpPxy.orderNumber;
	self.txtVoyageCode.text := tmpPxy.voyageCode;
	self.txtDescription.text := tmpPxy.description;
	self.txtRemarks.text := tmpPxy.remarks;
	self.txtLoadPortDesc.text := tmpPxy.loadPortDescription;
	self.txtDischPortDesc.text := tmpPxy.dischargePortDescription;
	self.txtDestPortDesc.text := tmpPxy.destinationPortDescription;
	self.txtTotalQuantity.text := tmpPxy.totalQuantity.String;
	self.txtTotalWeight.text := tmpPxy.totalWeight.String;
	self.txtTotalVolume.text := tmpPxy.totalVolume.String;
	self.txtHAZCodes.text := tmpPxy.hazard.String;
	self.txtTemp.text := tmpPxy.temperature.String;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupCombos" id="0e8680e6-3679-4630-9ca3-9f066f8d733f">
        <updating/>
        <source>setupCombos() updating;
//----------------------------------------------------------------
//	Created:	12 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	root	: CM_Root;
	ct : CM_CargoType;
	sct : CM_Product;
begin
	root := app.myRoot;
	
	self.cmbToCargoType.myTerminal := self.myTerminal;
	ct := root.allCargoTypesById[self.myProxyObject.cargoType]; // TFS 40336
	self.cmbToCargoType.setObject(ct);
	self.cmbToCommodity.setObject(root.allCommodities[self.myProxyObject.commodity]);
	self.myAssistant.comboBoxContentsStatus(self.cmbToContents, root.allContentsStatuses[self.myProxyObject.contentsStatus]);
	
	self.cmbToDischPort.myAssistant := self.myAssistant;
	self.cmbToDischPort.setObject(root.allPorts[self.myProxyObject.dischargePort]);
	self.cmbToImEx.setObject(root.allImexStatuses[self.myProxyObject.imExStatus]);
	
	self.cmbToLoadPort.myAssistant := self.myAssistant;
	self.cmbToLoadPort.setObject(root.allPorts[self.myProxyObject.loadPort]);
	self.cmbToOperator.setObject(root.allOperators[self.myProxyObject.operatorCode]);
	
	self.cmbToSize.clear;
	self.cmbToSize.addItem(CMIF_CandHRpt.Size_20);
	self.cmbToSize.addItem(CMIF_CandHRpt.Size_40);
	if self.isNonContainer() then	//11 Oct 2018	NDL	TFS 41204
		self.cmbToSize.listIndex := self.cmbToSize.addItem(" ");	
	elseif self.myProxyObject.is40 then
		self.cmbToSize.text := CMIF_CandHRpt.Size_40;
	else
		self.cmbToSize.text := CMIF_CandHRpt.Size_20;
	endif;
	
	self.myAssistant.comboBoxTransitStatus(self.cmbToTransit, self.myProxyObject.transitStatus);
	
	self.cmbToType.clear;
	self.cmbToType.addItem(CMIF_CandHRpt.ISO_General);
	self.cmbToType.addItem(CMIF_CandHRpt.ISO_Reefer);
	if self.isNonContainer() then	//11 Oct 2018	NDL	TFS 41204
		self.cmbToType.listIndex := self.cmbToType.addItem(" ");	
	elseif self.myProxyObject.isReefer then
		self.cmbToType.text := CMIF_CandHRpt.ISO_Reefer;
	else
		self.cmbToType.text := CMIF_CandHRpt.ISO_General;
	endif;
	
	
	// TFS 40336
	if ct &lt;&gt; null then
		self.cmbToCargoType_click(self.cmbToCargoType);
		sct := ct.allProducts[null,self.myProxyObject.cargoSubtypeCode];
		self.cmbCargoSubType.listObject := sct;
	endif;
	
	self.cmbISOType.setObject(root.allISOTypes[self.myProxyObject.isoType]);
	self.cmbCustomsAgent.setObject(root.allCustomsAgents[self.myProxyObject.customsAgentCode]);
	self.cmbDestPort.myAssistant := self.myAssistant;
	self.cmbDestPort.setObject(root.allPorts[self.myProxyObject.destinationPortCode]);
	self.cmbConsignee.setObject(root.allConsigneeConsignors[self.myProxyObject.consignee]);
	self.cmbConsignor.setObject(root.allConsigneeConsignors[self.myProxyObject.consignor]);
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="9f79461f-3d3c-49eb-b322-ed39dea0836d">
        <updating/>
        <source>setupForm() updating;
//----------------------------------------------------------------
//	Created:	12 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod();

	self.setFromFromSnapShot();

	self.setupCombos();
	
	self.width :=1300; // TFS 40336
	
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnSaveChange.enabled := false;
	
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d2f13248-2a16-4338-b02d-25770a2ae93d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 19 September 2018 08:41:48.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008152, locale);
	btnCancelChange.translateCaption(Xlat_0000908, locale);
	btnHazDetails.translateCaption(Xlat_0022967, locale);
	btnSaveChange.translateCaption(Xlat_0000923, locale);
	chkToHide.translateCaption(Xlat_0000921, locale);
	chkToOD.translateCaption(Xlat_0000922, locale);
	chkToTranship.translateCaption(Xlat_0000924, locale);
	lblBol.translateCaption(Xlat_0022968, locale);
	lblCargoGroupId.translateCaption(Xlat_0022969, locale);
	lblCargoSub.translateCaption(Xlat_0022970, locale);
	lblCargoSubDescr.translateCaption(Xlat_0022971, locale);
	lblCargoTypeDescr.translateCaption(Xlat_0022972, locale);
	lblColour.translateCaption(Xlat_0022973, locale);
	lblConsignee.translateCaption(Xlat_0023006, locale);
	lblConsignor.translateCaption(Xlat_0023007, locale);
	lblCustomsAgent.translateCaption(Xlat_0022974, locale);
	lblDescription.translateCaption(Xlat_0022975, locale);
	lblDestPort.translateCaption(Xlat_0022976, locale);
	lblDestPortDesc.translateCaption(Xlat_0022977, locale);
	lblDischPortDesc.translateCaption(Xlat_0022978, locale);
	lblHazCodes.translateCaption(Xlat_0022979, locale);
	lblISOType.translateCaption(Xlat_0022980, locale);
	lblISOTypeDesc.translateCaption(Xlat_0022981, locale);
	lblLoadPortDesc.translateCaption(Xlat_0022982, locale);
	lblMark.translateCaption(Xlat_0022983, locale);
	lblMarkNumber.translateCaption(Xlat_0022984, locale);
	lblOrderNumber.translateCaption(Xlat_0022985, locale);
	lblRemarks.translateCaption(Xlat_0022986, locale);
	lblTemperature.translateCaption(Xlat_0022994, locale);
	lblTotalQuantity.translateCaption(Xlat_0022987, locale);
	lblTotalVolume.translateCaption(Xlat_0022988, locale);
	lblTotalWeight.translateCaption(Xlat_0022989, locale);
	lblVoyageCode.translateCaption(Xlat_0022990, locale);
	zlblValue01.translateCaption(Xlat_0000917, locale);
	zlblValue02.translateCaption(Xlat_0000918, locale);
	zlblValue03.translateCaption(Xlat_0000914, locale);
	zlblValue04.translateCaption(Xlat_0000919, locale);
	zlblValue05.translateCaption(Xlat_0000910, locale);
	zlblValue06.translateCaption(Xlat_0000911, locale);
	zlblValue07.translateCaption(Xlat_0000912, locale);
	zlblValue08.translateCaption(Xlat_0000909, locale);
	zlblValue09.translateCaption(Xlat_0000916, locale);
	zlblValue10.translateCaption(Xlat_0000913, locale);
	zlblValue11.translateCaption(Xlat_0000920, locale);
	zlblValue12.translateCaption(Xlat_0000915, locale);
end;</source>
    </JadeMethod>
