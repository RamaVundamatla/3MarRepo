    <JadeMethod name="doSave" id="d3694e64-84dd-4957-a90b-807364bf0094">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars
	proxyVehicleModel	: CM_VehicleModel;
	theForm 			: SOP_TableMaintForm;
	
	lModel				: String;
	
begin
	theForm := self.myForm; 
	
	lModel := theForm.tblInput1.getValueByName(ETRow_Model).String;

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_VehicleModel transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyVehicleModel := theForm.myProxyObject.CM_VehicleModel;
	proxyVehicleModel.setProxy(lModel);

	if theForm.mode = theForm.Mode_Add then
		 app.myTrxCA.trxCreateVehicleModel(proxyVehicleModel, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateVehicleModel(proxyVehicleModel, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
