        <source>doSearch()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	#cnwdz2	 par21593

*/

vars

begin
	self.doFilterMessages();
	
	self.frmSearch.visible := (self.tblData.rows = self.tblData.fixedRows);
	self.statusLine.caption := (self.tblData.rows-self.tblData.fixedRows).String &amp; ' rows found.';		
epilog
	
end;</source>
