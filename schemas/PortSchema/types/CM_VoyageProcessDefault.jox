    <JadeMethod name="setReportNames" id="bf7a93b5-20d3-4275-a5e9-27af40ce905e">
        <updating/>
        <source>setReportNames(	_ediPrenoteFormat: String;
				_reportInvoiceEstimate: String;
				_reportInvoicePreinvoice: String;
				_reportInvoiceTaxinvoice: String;
				_workOrderReceivalReport : String;
				_workOrderReleaseReport : String
				) updating;
/*

Purpose:			

Parameters:			Default one does not use/have reports....

Return Value:		

Date		Who		Reason
10 May 2018	jlgndl1	Initial creation	TFS 38517

*/

vars

begin

	self.ediPrenoteFormat := null;
	self.reportInvoiceEstimate := _reportInvoiceEstimate;	 //jlier1 TFS 51963 -default can have the estimate
	self.reportInvoicePreinvoice := null;
	self.reportInvoiceTaxinvoice := null;
	self.workOrderReceivalReport := null;	//11 Jun 2018	NDL	TFS 38795
	self.workOrderReleaseReport := null;	//11 Jun 2018	NDL	TFS 38795

epilog

end;</source>
        <Parameter name="_ediPrenoteFormat" type="String"/>
        <Parameter name="_reportInvoiceEstimate" type="String"/>
        <Parameter name="_reportInvoicePreinvoice" type="String"/>
        <Parameter name="_reportInvoiceTaxinvoice" type="String"/>
        <Parameter name="_workOrderReceivalReport" type="String"/>
        <Parameter name="_workOrderReleaseReport" type="String"/>
    </JadeMethod>
