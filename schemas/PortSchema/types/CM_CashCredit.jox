    <JadeMethod name="matches" id="ff8fa5a7-a842-4813-804e-0a032c3f4677">
        <source>matches(_voyageCode : String; _bol : String; _customsEntryNumber : String; _externalId : String; _cargoId : String) : Boolean;

/*

Purpose:			Used in cash transaction enquiry when filtering by bol, customs entry number etc
					Also used in cash reporting for filtering.

Parameters:			

Return Value:		


Date		Who		Reason
Feb 2016	cnwjre1	Initial creation for TFS 985

*/

vars
	ti	: CM_TrackedItem;
	creditDetail	: CM_CashCreditDetail;
begin
	// all null parameters means no matching required so it passes
	if _voyageCode = null and
	   _bol = null and
	   _customsEntryNumber = null and
	   _externalId = null and
	   _cargoId = null then
		return true;
	endif;

	if _voyageCode &lt;&gt; null then
		if _bol = null then
			if _voyageCode = self.myDerivedFromCashReceipt.cashId1 then
				return true;
			else
				if _voyageCode = self.myDerivedFromCashReceipt.cashId1 and
				   _bol = self.myDerivedFromCashReceipt.cashId2 then
					return true;
				endif;
			endif;
		endif;
	endif;
	if _bol &lt;&gt; null then
		if _bol = self.myDerivedFromCashReceipt.cashId2 then
			return true;
		endif;
	endif;
	if _customsEntryNumber &lt;&gt; null then
		if _customsEntryNumber = self.myDerivedFromCashReceipt.cashId3 then
			return true;
		endif;
	endif;
	if _externalId &lt;&gt; null then
		if _externalId = self.myDerivedFromCashReceipt.getExternalInvoiceNumber or
		   _externalId = self.externalId then
			return true;
		endif;
	endif;

	if _cargoId &lt;&gt; null then
		foreach creditDetail in self.allDerivedFromCreditDetails do
			if creditDetail.myTrackedItem &lt;&gt; null and
			   creditDetail.myTrackedItem.id = _cargoId then
				return true;
			endif;
		endforeach;
		foreach creditDetail in self.allAppliedToCreditDetails do
			if creditDetail.myTrackedItem &lt;&gt; null and
			   creditDetail.myTrackedItem.id = _cargoId then
				return true;
			endif;
		endforeach;
	endif;

	return false;
epilog

end;
</source>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_bol" type="String"/>
        <Parameter name="_customsEntryNumber" type="String"/>
        <Parameter name="_externalId" type="String"/>
        <Parameter name="_cargoId" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="2c99581d-325e-4fb9-b65c-72ef0926e0b3">
        <source>pxyCreateUpdateProxy() : SelfType;
// 14 January 2016	cnwjre1	TFS 985 37141 cash credits
vars
	proxyCashCredit	: CM_CashCredit;
begin
	proxyCashCredit := inheritMethod();
	proxyCashCredit.comments := self.comments;
	proxyCashCredit.externalId := self.externalId;

	return proxyCashCredit;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="pxySetBank" id="312c1804-d806-4dd9-b22b-3a3bb0bf9748">
        <updating/>
        <source>pxySetBank(_proxyDetails : ObjectArray)  updating;

/*

Purpose:		// TFS 38732	

Parameters:			

Return Value:		


Date		Who		Reason
16 May 2018	jlgab1	Initial creation

*/

vars
	pxyDetail : CM_CashCreditDetail;
	bank : CM_Bank;
	terminal : CM_Terminal;
	obj : Object;
begin
	foreach obj in _proxyDetails do
		pxyDetail := obj.CM_CashCreditDetail;

		bank := pxyDetail.pxyGetBank();
		
		if bank &lt;&gt; null then
			break;
		endif;
	endforeach;
	
	// Use default BU
	if bank = null then
		terminal := self.getDebtorTerminal().myTerminal;
		bank := terminal.getDefaultCompanyBank();
	endif;
	
	if bank &lt;&gt; null then
		self.myBank := bank;
	endif;
	

epilog

end;</source>
        <Parameter name="_proxyDetails" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="463877cb-31f3-4da1-92ec-7d0c3621c775">
        <updating/>
        <source>setForCreate(_proxyCashCredit : CM_CashCredit) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 Jan 2016	cnwjre1	TFS 985 37141 cash credits
16 Nov 2016		    2985:PAR38341 QNS - Changes to existing Oracle R12 Interface for Hamad port multi terminal go-live (JMT changes)
*/

vars
	externalNumber  : String;
	finIO			: CM_ExtFinanceIO;
	terminal 		: CM_Terminal;
begin
	_proxyCashCredit.raiseExceptionIfNotTransient(method);

	self.setForUpdate(_proxyCashCredit);
	self.sequenceNum	  := _proxyCashCredit.myDebtorTerminal.getNextCreditSeqNum();
	self.myBank 		  := _proxyCashCredit.myBank;
	self.myDebtorTerminal := _proxyCashCredit.myDebtorTerminal;
	
	terminal := _proxyCashCredit.getDebtorTerminal().myTerminal; 															
	finIO    := terminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	
	if finIO &lt;&gt; null then										//TFS38181 PKT - Report Fields Not Working
		externalNumber  := finIO.getExternalCreditNumber(self);
		self.externalId := externalNumber;
	endif;
	
	

end;
</source>
        <Parameter name="_proxyCashCredit" type="CM_CashCredit"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="4e5abb3b-03f0-4465-9f9b-fd4c9385ec2b">
        <updating/>
        <source>setForUpdate(_proxyCashCredit : CM_CashCredit) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 Jan 2016	cnwjre1	TFS 985 37141 cash credits
*/
begin
	inheritMethod(_proxyCashCredit);

	self.comments   				:= _proxyCashCredit.comments;
	self.externalId 				:= _proxyCashCredit.externalId;
	self.myDerivedFromCashReceipt 	:= _proxyCashCredit.myDerivedFromCashReceipt;
	self.myUser 					:= _proxyCashCredit.myUser;
	
end;
</source>
        <Parameter name="_proxyCashCredit" type="CM_CashCredit"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="b1229195-c4de-4309-b6fc-bff68797ae4b">
        <updating/>
        <source>setProxy(_cashValue 	: Decimal; 
		_dateTime 		: TimeStamp; 
		_comments 		: String; 
		_bank 			: CM_Bank;
		_debtorTerminal : CM_DebtorTerminal; 
		_cashReceipt 	: CM_CashReceipt;
		_user 			: CM_User) updating;
/*

Purpose:			.

Parameters:			

Return Value:		


Date		Who		Reason
14 January 2016		cnwjre1	TFS 985 37141 cash credits


*/


vars

begin
	self.cashValue 		  		  := _cashValue;
	self.dateTime  		  		  := _dateTime;
	self.comments  		  		  := _comments;
	self.myBank   		  		  := _bank;
	self.myDebtorTerminal 		  := _debtorTerminal;
	self.myDerivedFromCashReceipt := _cashReceipt;
	self.myUser 				  := _user;
end;
</source>
        <Parameter name="_cashValue" type="Decimal"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_comments" type="String"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_debtorTerminal" type="CM_DebtorTerminal"/>
        <Parameter name="_cashReceipt" type="CM_CashReceipt"/>
        <Parameter name="_user" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="89082f54-e21e-49cb-8895-9ad42eac5aff">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 Jan 2016	cnwjre1	TFS 985 37141 cash credits
17 Oct 2019 cnwma1 ChangeRequest 46984: JMT - Refactor Cash Credit UI and Tax
*/
begin
	if not self.dateTime.Date.isValid then
		app.raiseCMException(Input_required_field_dateTime, null, null);
	endif;
	
	if self.myDebtorTerminal = null then
		app.raiseCMException(Input_required_field_debtor, null, null);
	endif;
	
	if self.myBank = null then
		app.raiseCMException(Input_required_field_BusUnit, null, null);
	endif;

	if self.myUser = null then
		app.raiseCMException(Input_required_field_userCode, null, null);
	endif;

end;</source>
    </JadeMethod>
</Class>
