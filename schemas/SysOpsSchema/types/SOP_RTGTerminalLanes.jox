    <JadeMethod name="loadRTGAreas" id="3265adab-d45d-4426-a6c9-bef8a0606ab3">
        <updating/>
        <source>loadRTGAreas() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2008	cnwer1	Initial creation

*/

vars
	rtgArea : CM_RTGArea;
	iter : Iterator;
	termArea : CM_TerminalArea;
	newIdx : Integer;
begin
	
	iter:=self.myTerminal.allTerminalAreasByTypeId.createIterator;
	self.myTerminal.allTerminalAreasByTypeId.startKeyGeq(TA_TYPE_RTG,null,iter);
	while iter.next(termArea) do
		if termArea.type &lt;&gt; TA_TYPE_RTG then
			continue;
		endif;
		app.writeStatement( termArea.id);
		newIdx :=self.lstRTGAreas.addItem(termArea.id);
		self.lstRTGAreas.itemObject[newIdx]:=termArea;
	endwhile;
	
	self.frmRTGTemplate.left:= - 300;
	//self.drawRTGArea(rtgArea,self.frmRTGTemplate);
epilog

end;</source>
    </JadeMethod>
