    <JadeMethod name="addToolbarControls" id="d6364335-dbca-4c1a-a444-5220aedb142e">
        <source>addToolbarControls() protected;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	toolbar		: CMUI_Toolbar;
begin

	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnSelectTAs, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmTrainDir, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnPrintPrint, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnToggleView, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	

//	toolbar.addButton(self.btnMoveIt, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnTrainMaint, CMUI_Toolbar.Control_Alignment_Left);
	if not app.myPassport.myUser.canDo(self.myTerminal, PmAdmRailopsMaint) then
		self.btnTrainMaint.enabled := false;
	endif;
	
	self.frmTrainCmb.borderStyle := Frame.BorderStyle_None;
	toolbar.addFrame(self.frmTrainCmb, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnConfirmTrain, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	

	//toolbar.addButton(self.btnSelectAll, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;	
	self.btnEdit.visible := false;
	//self.btnMoveIt.visible := false;
	
	toolbar := self.frmRakeToolbar;
	toolbar.showCaptions := self.frmToolbar.showCaptions;
//	toolbar.isPositionsCalculated := false;
//	toolbar.allLeftControls.purge();
//	toolbar.allRightControls.purge();

	toolbar.addButton(self.btnNewWindow, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
// TFS 2198	toolbar.addButton(self.btnNewWagon, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEditWagon, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCCWagon, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnViewJob, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnViewVoyage, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnViewCommodity, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnViewConsignee, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnViewDischarge, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnViewDest,CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewISOGroup, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnViewOperator, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnViewStatus, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnViewTempRange, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);		
	toolbar.addButton(self.btnMoveTopLeft, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnMoveTopRight, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnMoveBotLeft, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnMoveBotRight, CMUI_Toolbar.Control_Alignment_Left);			
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);		
	toolbar.addButton(self.btnFlipH, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.positionToolbarControls();
	toolbar.zOrder(1);	
	toolbar.visible := true;
