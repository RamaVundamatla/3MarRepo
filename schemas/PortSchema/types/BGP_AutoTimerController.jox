    <JadeMethod name="setAttributesForCreate" id="6cf3c0bf-71a1-421d-9cda-4e17635194e7">
        <updating/>
        <source>setAttributesForCreate() updating, protected;

// cnwdvb1 12 December 2002 

vars

begin
	
	inheritMethod();
	self.name			:= 'Auto Schedule Runner';
	self.timerInterval	:= 5;
	self.isEditable		:= true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCurrentAutoTask" id="736004da-161e-477f-934d-93f7681f89f3">
        <updating/>
        <source>setCurrentAutoTask(_task : CM_AutoTask) updating;

// cnwdvb1 05 February 2003 

vars

begin

	self.myCurrentAutoTask := _task;

end;</source>
