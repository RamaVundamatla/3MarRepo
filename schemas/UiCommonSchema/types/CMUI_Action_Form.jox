    <JadeMethod name="initTables" id="7acc1a20-5621-4355-91a1-0cafc6ba47ca">
        <updating/>
        <source>initTables() updating;
// ---------------------------------------------------------------------------
// Created:     01 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	entTableControl	: EntTableDef;

begin

	self.tblActionData.userInputEnabled := false;
	// Setup selection table.
	self.txtDetails.height := self.splitContainer.height - self.txtDetails.top;
	entTableControl := self.getTblSelectionDef();
	self.tblSelection.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');
	self.tblSelection.resetSize();
	self.tblSelection.optimiseHeadingColumn();
	self.tblSelectData.selectMode := Table.SelectMode_WholeRows;
	
	// Setup action table.
	entTableControl := self.getTblActionDataDef();
	self.tblActionData.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');
	self.tblActionData.optimiseHeadingColumn();
	self.setActionTableView();
	//cnwth2 - was being called a total of four times on form load!!
//	self.doOptTicketClick();
	self.optSingleItem.value := true;
	
	// Do resizing stuff.		
	self.tblSelection.optimiseRowHeight := true;
	self.tblSelection.cnEcResizeContents();
	
	self.tblActionData.optimiseRowHeight := true;
	self.tblActionData.cnEcResizeContents();
	
	self.centreWindow;
	self.resize();
end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="dac797f6-295d-4a07-ac45-7213f51ffb24">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

vars
	theActiveControl	: Control;
	
begin

	if keyCode = J_key_Tab then
		theActiveControl := app.activeControl;
		if theActiveControl.parent.isKindOf(CM_EntryTable) then
			theActiveControl := theActiveControl.parent.Control;
		endif;

		if self.tblSelectData.tabStop then
			tblSelection.handleFormTab(keyCode, shift, optLocation, tblSelectData);
			tblActionData.handleFormTab(keyCode, shift, tblSelectData, btnNext);
		else
			tblSelection.handleFormTab(keyCode, shift, optLocation, tblActionData);
			tblActionData.handleFormTab(keyCode, shift, tblSelection, btnNext);
		endif;

		if theActiveControl.isKindOf(CM_EntryTable) and theActiveControl.visible then
			theActiveControl.CM_EntryTable.handleTableTab(shift);
		endif;
		return;
	endif;
	
	inheritMethod(keyCode, shift);
	
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="f336d40c-7130-4522-b73e-9aa1516057de">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	taType	: CM_TerminalAreaType;
begin
	
	self.populateCombos();
	self.initTables();
	self.loadTATypes();
	taType := cmbTAType.listObject.CM_TerminalAreaType;
	self.loadLocations(taType);
	
	self.doOptTicketClick();
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnSave.enabled := false;
		self.btnNext.enabled := false;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadLocations" id="1d529319-2f83-474d-83e4-849f1e0a9a28">
        <source>loadLocations(_taType : CM_TerminalAreaType);
// ---------------------------------------------------------------------------
// Created:     01 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	tmpLCSearch		: CMIF_SearchTypes;
	lc				: CM_LocationsController;
begin
	self.cmbLocation.clear();
	self.allLocations.clear();
	if _taType &lt;&gt; null then
		create tmpLCSearch transient;
		self.myTerminal.availableLocationsForType(tmpLCSearch, self.allLocations, _taType.type);
		if not self.allLocations.isEmpty then
			self.cmbLocation.listCollection(self.allLocations, false, 0);
			lc := self.allLocations.first;
			self.cmbLocation.listObject := lc;
			self.tblSelection.setValueByName(ETRow_Location, lc.getID);
		endif;
	endif;
	
epilog
	delete tmpLCSearch;
		
end;</source>
        <Parameter name="_taType" type="CM_TerminalAreaType"/>
    </JadeMethod>
    <JadeMethod name="loadTATypes" id="adab4c6e-641e-42b3-a144-8d9865eff246">
        <source>loadTATypes();
// ---------------------------------------------------------------------------
// Created:     01 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
10 Jun 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars
	taDict		: CM_TATypeByTypeDict;
	taType		: CM_TerminalAreaType;
begin
	taDict := app.myRoot.allTerminalAreaTypes;
	if not taDict.isEmpty then
		self.cmbTAType.listCollection(taDict, true, 0);
		
		taType := taDict[TA_TYPE_IRREGULAR_BLOCK_AREA];			// was TA_TYPE_GENERAL_CARGO_AREA
		self.cmbTAType.listObject := taType;
		self.tblActionData.setValueByName(ETRow_TaTypeTo, taType.description);
		self.tblSelection.setValueByName(ETRow_TaType, taType.description);
	
	endif;

end;</source>
    </JadeMethod>
