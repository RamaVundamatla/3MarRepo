    <JadeMethod name="runTest" id="43911676-a1de-4e7a-8359-bf5fee9656c9">
        <updating/>
        <source>runTest():Integer updating;

vars
	sa:StringArray;
	meth:String;
	myRFIDTag:CM_RFIDTag;
begin
	create rfidConn transient;
	rfidConn.port:=6005;  // gate lane 2 is port 6002
	rfidConn.name:=app.computerNameAppServer;
	//rfidConn.usePresentationClient:=true;
	rfidConn.openAsynch(self, "openNotify");/**/
	app.logMessage("openAsynch called");

	create sa transient;
	//sa.add('tp002_CN_lstTest_click');
	//sa.add('tp004_CN_lstTest_dblClick');
	//sa.add('tp006_GIOF_picture_click');

	foreach meth in sa do
		if meth[6:2] &lt;&gt; "v_" then
			app.doWindowEvents(longPause);
		endif;
		retCode:=self.sendMsg(meth).Integer;
		if app.atcgReplayFailure then
			app.atcgReplayFailure:=false;
			break;
		elseif retCode = 0 then
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" succeeded");
		else
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" failed with error code "&amp;retCode.String);
			break;
		endif;
	endforeach;
	app.atcgDetectMissedMsgBoxes;

	myRFIDTag:=app.myPassport.myTerminal.allRFIDTagsByCode["TAG14"];
	rfidConn.writeBinaryAsynch((CM_RFIDAccess7CERead.Msg_Begin_Delimiter &amp; myRFIDTag.serialNumber).Binary, self, 'writeBinaryNotify');
	app.doWindowEvents(longPause);
	rfidConn.closeAsynch(self, "closeNotify");
	app.doWindowEvents(longPause);
	
	app.logMessage("Finished");
	return 0;
epilog
	delete sa;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
