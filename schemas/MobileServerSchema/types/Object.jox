<Class name="Object">
    <JadeMethod name="jmtRaiseException" id="ed9dd483-944b-4d27-bb20-b64bab67034f">
        <source>jmtRaiseException(pError : String) protected;
// --------------------------------------------------------------------------------
// Created:		12 October 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	FATAL_ERROR		: Integer = 999999;
	
vars
	exceptionObj	: CM_Exception;
	
begin
	create exceptionObj transient;
	
	exceptionObj.errorCode			:=	FATAL_ERROR;
	exceptionObj.continuable		:=	false;
	exceptionObj.resumable			:=	true;
	exceptionObj.extendedErrorText	:=	pError;
	
	raise exceptionObj;
end;</source>
        <access>protected</access>
        <Parameter name="pError" type="String"/>
    </JadeMethod>
</Class>
