    <JadeMethod name="doSetupTable" id="ea58fecc-3eac-484d-bddf-ac836c93aa82">
        <source>doSetupTable() protected;

vars
	table				: Table;
	columnWidthArray	: IntegerArray;

begin
	table			:=	tblParameters;
	table.rows		:=	1;
	table.columns	:=	5;

	create columnWidthArray transient;
	columnWidthArray.add(10);
	columnWidthArray.add(20);
	columnWidthArray.add(40);
	columnWidthArray.add(20);
	columnWidthArray.add(10);
	table.cnEcSetColumnWidths(columnWidthArray);

	table.setCellText(1, 1, "Sequence");
	table.setCellText(1, 2, "Name");
	table.setCellText(1, 3, "Display Value");
	table.setCellText(1, 4, "Type");
	table.setCellText(1, 5, "List");
epilog
	delete columnWidthArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="optLandscape_click" id="4e3bcaaa-3823-4ee9-a584-f051fd23ce53">
        <controlMethod name="OptionButton::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>optLandscape_click(optionbutton: OptionButton input) updating;

begin
	if (optionbutton.value) then
		picLandscape.visible	:=	true;
		picPortrait.visible		:=	false;
	endif;
end;</source>
