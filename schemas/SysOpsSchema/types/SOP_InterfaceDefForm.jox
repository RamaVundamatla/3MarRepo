    <JadeMethod name="btnResetInterfac_click" id="ca61b794-7052-4504-8e5a-2c39b445a905">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnResetInterfac_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 January 2010	#cnwdz2	par21593

*/

vars
	userResponse	: Integer;
begin
	app.mousePointer	:=	Busy;
	userResponse := app.msgBox(	app.getErrorString(ResetITSInterface),
									self.caption &amp; " Reset Interface !",
									MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_First );
	
	if not (userResponse = MsgBox_Return_Yes) then 
		return;
	endif;
	
	self.doResetInterface();
epilog
	app.mousePointer := Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
