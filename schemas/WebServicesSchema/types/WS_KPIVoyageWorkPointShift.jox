<Class name="WS_KPIVoyageWorkPointShift" id="734ef498-d345-4b05-96c2-3bef7844e6b5">
    <superclass name="WS_KPIVoyage"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <PrimAttribute name="shiftCode" id="b290580f-4a7e-43ad-b505-46fa7dbd8176">
        <length>101</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="shiftDescription" id="cacb7bb8-50dd-45ab-ba1d-8f82bc7beac4">
        <length>101</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="shiftEndTS" id="57bc314c-b767-498b-9c3a-550fa1c888f6">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="shiftStartTS" id="39715d84-ad13-4be3-8591-adfaa572140f">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="wpCode" id="74e5c79f-9689-4b91-98b4-c3442a8f5028">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="2c333109-4277-4a73-be53-1a2e19ca3c25">
        <updating/>
        <source>setProxyFromObject(_voyageKPI: CM_KPIVoyageEntity; _includeDetails : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2025	navcs2	MTN-36746 MTN | KPI REST APIs - Voyage [1]

*/

vars
	kpi : CM_KPIVoyageWorkPointShift;
begin
	inheritMethod(_voyageKPI, _includeDetails);
	
	if not _voyageKPI.isKPIVoyageWorkPointShift then
		return;
	endif;
	
	kpi := _voyageKPI.CM_KPIVoyageWorkPointShift;
	
	self.shiftCode 				:= kpi.shiftCode;
	self.shiftDescription 		:= kpi.shiftDescription;
	self.shiftEndTS 			:= kpi.shiftEndTS.asStringForWebInterface;
	self.shiftStartTS 			:= kpi.shiftStartTS.asStringForWebInterface;
	if kpi.myWorkPoint &lt;&gt; null then
		self.wpCode 				:= kpi.myWorkPoint.code;
	endif;
	
epilog

end;</source>
        <Parameter name="_voyageKPI" type="CM_KPIVoyageEntity"/>
        <Parameter name="_includeDetails" type="Boolean"/>
    </JadeMethod>
</Class>
