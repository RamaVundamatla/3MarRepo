    <JadeMethod name="doesCargoForExptDateExist" id="524eb117-d2c0-44cf-8598-916e92ddfc5d">
        <source>doesCargoForExptDateExist(_eta: Date): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 February 2025	navsaa30	Initial creation
25 Feb 2025 navsaa30 EUP | FR 54871 - EDI Message Administration Advanced Filters not working
*/
vars

begin
	
	if self.myGateDocument &lt;&gt; null and self.myGateDocument.allEDITrackedItems &lt;&gt; null then
		return self.myGateDocument.doesCargoForExptDateExist(_eta);
	elseif self.myTrainConsist &lt;&gt; null and self.myTrainConsist.allEDITrackedItems &lt;&gt; null then
		return self.myTrainConsist.doesCargoForExptDateExist(_eta);
	endif;
	return false;
epilog

end;</source>
        <Parameter name="_eta" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doesCargoGroupExist" id="0fae67eb-bc70-4584-b362-3238e563614d">
        <source>doesCargoGroupExist(_cargoGroupId: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 December 2024	navsaa30	Initial creation
7/12/2024 navsaa30 EUP | FR 54871 - EDI Message Administration Advanced Filters not working

*/

vars
	ediTi	: CM_EDITrackedItem;
	ediData : CM_EDIData;

begin
	if self.myCargoOnSite &lt;&gt; null then
		ediData := self.myCargoOnSite;
	elseif self.myGateDocument &lt;&gt; null then
		ediData := self.myGateDocument;
	elseif self.myShipManifest &lt;&gt; null then
		ediData := self.myShipManifest;
	elseif self.myTrainConsist &lt;&gt; null then
		ediData := self.myTrainConsist;
	endif;	
	
	if ediData &lt;&gt; null then
		foreach ediTi in ediData.allEDITrackedItems do
			if ediTi.getCargoGroupId().compareEql(_cargoGroupId, true, false, null) then
				return true;
			endif;
		endforeach;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_cargoGroupId" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doesCargoOperatorExist" id="00655d0c-7c0f-4640-9349-7c5a1e47550c">
        <source>doesCargoOperatorExist(_cargoOperator: String): Boolean;
/*****************************************************
Author		: navlw1 (Laura Wells)
Date		: 06 May 2024
TFS#		: 63312
Function	:

*** Changes ***
Date			Name		TFS#		Description
31 July 2024	navhn30		Bug 65413: EUP | FR 54871 - EDI Administration Usability Operator Search Filter Returns 1090 Error
20 Aug 2024		navhn30		Bug 65720: EUP | FR 54871 - EDI Administration Usability Operator Search Filter Returns 1090 Error (Relogged)
****************************************************/

vars
	ediTi		: CM_EDITrackedItem;
	ediTiType	: CM_EDITIById;
	operatorCode: String;
begin
	if self.myCargoOnSite &lt;&gt; null and self.myCargoOnSite.allEDITrackedItems &lt;&gt; null then
		ediTiType := self.myCargoOnSite.allEDITrackedItems; 
	elseif self.myGateDocument &lt;&gt; null and self.myGateDocument.allEDITrackedItems &lt;&gt; null then
		ediTiType := self.myGateDocument.allEDITrackedItems;
	elseif self.myShipManifest &lt;&gt; null and self.myShipManifest.allEDITrackedItems &lt;&gt; null then
		ediTiType := self.myShipManifest.allEDITrackedItems;
	elseif self.myTrainConsist &lt;&gt; null and self.myTrainConsist.allEDITrackedItems &lt;&gt; null then
		ediTiType := self.myTrainConsist.allEDITrackedItems;
	endif;
	if ediTiType &lt;&gt; null then		//20.08.24		navhn30		TFS #65720
		foreach ediTi in ediTiType do
			operatorCode := ediTi.getOperatorCode();			//31.07.24  	navhn30 	TFS #65413
			if operatorCode &lt;&gt; null and operatorCode.toUpper().compareEql(_cargoOperator.toUpper(), true, false, null) then
				return true;
			endif;
		endforeach;
	endif;
	if self.sender.toUpper().compareEql(_cargoOperator.toUpper(), true, false, null) or self.operatorCode.toUpper().compareEql(_cargoOperator.toUpper(), true, false, null) then
		return true;
	endif;
	return false;
epilog

end;</source>
        <Parameter name="_cargoOperator" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doesEDIActionExist" id="c8c6cae0-daad-4ff7-8509-af29ecd2afde">
        <source>doesEDIActionExist(_action: String): Boolean;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 03 October 2023
TFS#		: 60232
Function	:

*** Changes ***
Date			Name		TFS#		Description
16/1/25 navsaa30 EUP | FR 54871 - EDI Message Administration Advanced Filters not working
****************************************************/
begin
	return self.getAction().toUpper() = _action;	//navsaa30 16/1/25 #33489
end;</source>
        <Parameter name="_action" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doesReceiptTransportModeExist" id="22566e01-8ec8-48fd-93d0-aba5e374038b">
        <source>doesReceiptTransportModeExist(_receiptTransportMode: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 January 2025	navsaa30	Initial creation
17 Jan 2025 navsaa30 EUP | FR 54871 - EDI Message Administration Advanced Filters not working
*/

vars

begin

	if _receiptTransportMode = TI_TRANSMODE_ROAD_STR.toUpper() and self.myShipManifest = null and self.myTrainConsist = null then
		return true;
	elseif self.myTrainConsist &lt;&gt; null and _receiptTransportMode = TI_TRANSMODE_RAIL_STR.toUpper() then
		return true;
	elseif self.myShipManifest &lt;&gt; null and _receiptTransportMode = TI_TRANSMODE_SHIP_STR.toUpper() then			//navsaa30 07/2/25 #33489
		return true;
	endif;
	return false;
end;</source>
        <Parameter name="_receiptTransportMode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doesVehicleNumberExist" id="739d804b-3af5-47fe-9c74-fdfb5a99933d">
        <source>doesVehicleNumberExist(_vehicleNumber: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 February 2025	navsaa30	Initial creation
11/2/25 navsaa30 EUP | FR 54871 - EDI Message Administration Advanced Filters not working
*/

vars
	ediFile			: CM_EDIFile;
	fileType		: CM_EDIFileType;
	message			: String;
begin

	if self.myEDIFile &lt;&gt; null then 
		ediFile := self.myEDIFile; 
	endif;
	
	if ediFile = null then
		return false;
	endif;

	fileType := ediFile.myEDIFileType;

	message := ediFile.getOriginalFileDataString();
	
	if message = null and fileType = null then
		message := ediFile.getRawDataString();
	endif;
	
	if message &lt;&gt; null then									
		return message.toUpper.cnContains(_vehicleNumber.toUpper);
	endif;
	return false;
epilog

end;</source>
        <Parameter name="_vehicleNumber" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doesVesselNameExist" id="4e0ee4cc-3ad2-4b5b-989e-f53c1ba08f8a">
        <source>doesVesselNameExist(_vesselName: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2024	naviv1	Initial creation - TFS 63310 - EUP | FR 54871 Search EDI Message on Vessel Behaviour Not Clear
10 Feb 2025 navsaa30 EUP | FR 54871 - EDI Message Administration Advanced Filters not working
*/

vars
	ediFile			: CM_EDIFile;
	fileType		: CM_EDIFileType;
	message			: String;
	vessel			: CM_Vessel;
begin

	if self.myEDIFile &lt;&gt; null then 
		ediFile := self.myEDIFile; 
	endif;
	
	if ediFile = null then
		return false;
	endif;

	fileType := ediFile.myEDIFileType;

	message := ediFile.getOriginalFileDataString();
	
	if message = null and fileType = null then
		message := ediFile.getRawDataString();
	endif;
	
	if message &lt;&gt; null then										//navsaa30 10/2/25 #33489
		if message.toUpper.cnContains(_vesselName.toUpper) then
			return true;
		endif;
		vessel := app.myRoot.allVesselsByName[_vesselName];
		if vessel &lt;&gt; null then
			return message.toUpper.cnContains(vessel.code.toUpper);
		endif;
	endif;													//navsaa30 10/2/25 #33489
	return false;
epilog
end;</source>
        <Parameter name="_vesselName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="erase" id="2bbbdf53-3d5f-4f05-9186-1dabe56d9323">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2023	navra1	Initial creation

*/

vars

begin

	if self.myTrainConsist &lt;&gt; null then
		self.myTrainConsist.erase(_eraseLevel);
	elseif self.myGateDocument &lt;&gt; null then
		self.myGateDocument.erase(_eraseLevel);
	elseif self.myShipManifest &lt;&gt; null then
		self.myShipManifest.erase(_eraseLevel);
	elseif self.myCargoOnSite &lt;&gt; null then		//11.Oct.2023 navsp1 TFS 58058
		self.myCargoOnSite.erase(_eraseLevel);
	endif;
	
	inheritMethod(_eraseLevel);

epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAction" id="8e074fd6-e5a5-4e3d-aac5-567457b10251">
        <source>getAction(): String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 29 September 2023
TFS#		: 60232
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	return self.statusString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllEDITrackedItems" id="831a5bd0-0a80-4c12-8b10-93a8adb585b4">
        <source>getAllEDITrackedItems(_objSet: CM_ObjectArray io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2023	navsp1	Initial creation TFS ChangeRequest 58054: EUP - Manifest Send EDI Endpoint
23 Feb 2024		navsaa30 ChangeRequest 62289: EUP | FR 53824 - Transport Manifest - Hide Keymark Line (Cargo Group Detail) in Uploaded Manifest EDI Data
*/

vars
	ediTI 	: CM_EDITrackedItem;
	cargoType : CM_CargoType;
begin
	
	if self.myCargoOnSite &lt;&gt; null then
		foreach ediTI in self.myCargoOnSite.allEDITrackedItems do
			_objSet.add(ediTI);
		endforeach;
	endif;
	
	if self.myShipManifest &lt;&gt; null then
		foreach ediTI in self.myShipManifest.allEDITrackedItems do //where ediTI.isEDICargoOnShipTI do			// 23.02.2024 navsaa30 #62289
			//cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(ediTI.cargoTypeDescr);		// TFS 62699 for now
			//if not cargoType.isCargoGroup then
				_objSet.add(ediTI);
			//endif;
		endforeach;
	endif;
	
	if self.myTrainConsist &lt;&gt; null then
		foreach ediTI in self.myTrainConsist.allEDITrackedItems do
			_objSet.add(ediTI);
		endforeach;
	endif;
	
	if self.myGateDocument &lt;&gt; null then
		foreach ediTI in self.myGateDocument.allEDITrackedItems do
			_objSet.add(ediTI);
		endforeach;
	endif;
	
epilog

end;</source>
        <Parameter name="_objSet" type="CM_ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getDataTypeFromDefName" id="8769f3c7-a753-4c65-be65-424ec3fd2a2a">
        <source>getDataTypeFromDefName(_name: String): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
18 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
*/
vars
	aCargoOnSite : CM_EDIDataCargoOnSite;
	aGateDocument: CM_EDIDataGateDoc;
	aShipManifest : CM_EDIDataShipManifest;
	aTrainConsist : CM_EDIDataTrainConsist;
	dataType : Integer;
begin
	create aCargoOnSite transient;
	create aGateDocument transient;
	create aShipManifest transient;
	create aTrainConsist transient;
	dataType := aCargoOnSite.getDataTypeFromDefName(_name);
	if dataType = EDIDataType_CargoOnSite and
	   _name = ETDef_EDITICargo then
		dataType := EDIDataType_CargoOnShip;	// user defined Trans Manifest only supports 1 type of cargo by site as its runtime decision to determine if its on site or on ship
	endif;
	if dataType = EDIDataType_CargoOnSite and
	   _name &lt;&gt; ETDef_EDITICargo then
		dataType := null;
	endif;
	if dataType = null then
		dataType := aGateDocument.getDataTypeFromDefName(_name);
	endif;
	if dataType = null then
		dataType := aShipManifest.getDataTypeFromDefName(_name);
	endif;
	if dataType = null then
		dataType := aTrainConsist.getDataTypeFromDefName(_name);
	endif;
	if dataType = null and
	   _name =ETDef_EDIDataTransportManifest then		//11 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
		dataType := EDIDataType_TransportManifest;
	endif;
	return dataType;
epilog
	if aCargoOnSite &lt;&gt; null then
		delete aCargoOnSite;
	endif;
	if aGateDocument &lt;&gt; null then
		delete aGateDocument;
	endif;
	if aShipManifest &lt;&gt; null then
		delete aShipManifest;
	endif;
	if aTrainConsist &lt;&gt; null then
		delete aTrainConsist;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStrForDefName" id="b77fed6a-c407-44c2-9c21-9a468c56c4f9">
        <source>getDisplayStrForDefName(_name: String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Oct 2023	jlirs1	TFS 59171 Transport Manifest User Defined Format
13 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
*/

vars
	aCargoOnSite : CM_EDIDataCargoOnSite;
	aGateDocument: CM_EDIDataGateDoc;
	aShipManifest : CM_EDIDataShipManifest;
	aTrainConsist : CM_EDIDataTrainConsist;
	fieldName : String;
begin
	if _name = ETDef_EDIDataTransportManifest then
		return app.getErrorString(TransportManifest);
	endif;
	create aCargoOnSite transient;
	create aGateDocument transient;
	create aShipManifest transient;
	create aTrainConsist transient;
	fieldName := aCargoOnSite.getDisplayStrForDefName(_name);
	if fieldName = null then
		fieldName := aGateDocument.getDisplayStrForDefName(_name);
	endif;
	if fieldName = null then
		fieldName := aShipManifest.getDisplayStrForDefName(_name);
	endif;
	if fieldName = null then
		fieldName := aTrainConsist.getDisplayStrForDefName(_name);
	endif;
	return fieldName;
epilog
	if aCargoOnSite &lt;&gt; null then
		delete aCargoOnSite;
	endif;
	if aGateDocument &lt;&gt; null then
		delete aGateDocument;
	endif;
	if aShipManifest &lt;&gt; null then
		delete aShipManifest;
	endif;
	if aTrainConsist &lt;&gt; null then
		delete aTrainConsist;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="27f4daf8-3542-4dca-a38a-a8933ccbc589">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Jun 2023	navsp1	Initial creation TFS ChangeRequest 58054: EUP - Manifest Send EDI Endpoint
08 Aug 2023	navdap1	TFS 59719 EUP - EDI Sender Field - Financial ID
12 Sep 2023	navdap1	TFS 60453 EUP | FR 53824 - EDI Operations Date Range Filter Sometimes Omits Valid or Includes Invalid EDI Data Items
11 Oct 2023	navlw1	Bug 60652: MTN - Minor Issue when Loading Transport Manifest File
12 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
01 November 2024	MTN-33047 EUP - NTO-1000 - EUP - Additional Data Fields in EDI Operations	
*/

vars
	strValue 		: String;
	invalid : Boolean;
	debtor : CM_Debtor;			// TFS 59719
begin
	
	if _attrName = ETRow_ManifestType then
		strValue := self.type;
		if self.myCargoOnSite &lt;&gt; null then
			strValue := strValue &amp; " (Unknown)";
		elseif self.myGateDocument &lt;&gt; null then
			strValue := strValue &amp; " (Road)";
		elseif self.myShipManifest &lt;&gt; null then
			strValue := strValue &amp; " (Ship)";
		elseif self.myTrainConsist &lt;&gt; null then
			strValue := strValue &amp; " (Rail)";
		endif;
		return strValue;
		
	elseif _attrName = ETRow_HeaderDate then //not in BRD
		return self.headerDate.String;
	
	elseif _attrName = ETRow_Guid then
		return self.guid;
		
	elseif _attrName = ETRow_ManifestNumber then
		return self.manifestNumber;
		
	elseif _attrName = ETRow_TransRefCust then
		return self.transportReferenceCustomer;
	elseif _attrName = ETRow_TransRefInternal then
		return self.transportReferenceInternal;
	elseif _attrName = ETRow_EstArrivalDate then
		return self.estimatedDateTimeOfArrival.asStringJMT;
	elseif _attrName = ETRow_EstDepartureDate then
		return self.estimatedDateTimeOfDeparture.asStringJMT;
	elseif _attrName = ETRow_Receiver then
		return self.receiver;
		
	elseif _attrName = ETRow_Sender then
		if self.sender &lt;&gt; null then // #60652
			// TFS 59719 start
			debtor := app.myRoot.myRootCompany.allDebtorsByCode[self.sender];
			if debtor &lt;&gt; null then
				return self.sender &amp; " - " &amp; debtor.name;
			endif;
			// TFS 59719 end
		endif;
		return self.sender;
		
	elseif _attrName = ETRow_TransportStatus then
		return self.statusString;
	elseif _attrName = ETRow_HasItems then			// 01 November 2024	navcs2	MTN-33047
		if self.hasItems then						// 01 November 2024	navcs2	MTN-33047
			return app.getErrorString(Yes);			// 01 November 2024	navcs2	MTN-33047
		else										// 01 November 2024	navcs2	MTN-33047
			return app.getErrorString(No);			// 01 November 2024	navcs2	MTN-33047	
		endif;										// 01 November 2024	navcs2	MTN-33047	
	elseif _attrName = ETRow_Status 
	or _attrName = ETRow_CreatedTime	// TFS 60453
	// ### TFS BUG 65389 01AUG2024 NAVAB1
	or _attrName = ETRow_NumErrors
	or _attrName = ETRow_NumWarnings
	or _attrName = ETRow_Date
	or _attrName = ETRow_FirstOperatorCode then
		return inheritMethod(_attrName, _short);
	endif;
	
	on Exception do app.handleDeletedObject(exception, self.myCargoOnSite, invalid);
	if self.myCargoOnSite &lt;&gt; null then
		strValue := self.myCargoOnSite.getDisplayStringForAttribute(_attrName, _short);
		if invalid then
			return null;
		endif;
		if  strValue &lt;&gt; null then
			return strValue;
		endif;
	endif;
	on Exception do null;
	
	on Exception do app.handleDeletedObject(exception, self.myGateDocument, invalid);
	if self.myGateDocument &lt;&gt; null then
		strValue	:= self.myGateDocument.getDisplayStringForAttribute(_attrName, _short);
		if invalid then
			return null;
		endif;
		if strValue &lt;&gt; null then
			return strValue;
		endif;
	endif;
	on Exception do null;
	
	on Exception do app.handleDeletedObject(exception, self.myShipManifest, invalid);
	if self.myShipManifest &lt;&gt; null then
		strValue := self.myShipManifest.getDisplayStringForAttribute(_attrName, _short);
		if invalid then
			return null;
		endif;
		if strValue &lt;&gt; null then	
			return strValue;
		endif;
	endif;
	on Exception do null;
	
	on Exception do app.handleDeletedObject(exception, self.myTrainConsist, invalid);
	if self.myTrainConsist &lt;&gt; null then
		strValue	:= self.myTrainConsist.getDisplayStringForAttribute(_attrName, _short);
		if invalid then
			return null;
		endif;
		if strValue &lt;&gt; null then
			return strValue;
		endif;
	endif;
	on Exception do null;
	
	return inheritMethod(_attrName, _short);
	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEDIAction" id="7e8151ba-1b43-4ccc-8e0c-bd6889476c45">
        <source>getEDIAction(): String;
/*

