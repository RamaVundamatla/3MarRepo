    <JadeMethod name="initForm" id="6f5c465b-3df2-47ab-9391-2d09a0a0e801">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:     31 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	user			: CM_User;
begin
	inheritMethod();
	
	user := app.getMyUser();
	if user.canDo(self.myTerminal, self.permissionMaint) then
		self.allowMasterNew := true;
		self.allowMasterDelete := true;
		self.allowDetailAdd := true;
		self.allowDetailUpdate := true;
		self.allowDetailRemove := true;
		self.allowMasterEdit := true;
	endif;
	
	self.showTblDetailCount := true;
	self.isSelectorCapable := true;
	self.doRefresh();
end;</source>
    </JadeMethod>
    <JadeMethod name="maintainIDCombos" id="742e78a4-48b4-4447-9f1c-aa856af35829">
        <source>maintainIDCombos(_tmpCmbItem : CMUI_ComboBox input) protected;

// Created by cnwdvb1 on 07 May 2007

vars

	obj 		: Object;
	detailLine	: CMIF_BOLOutLine;
	rows,
	column,
	count		: Integer;
	tmpCmbItem	: CMUI_ComboBox;
	tmpCell		: JadeTableCell;
	ti			: CM_TrackedItem;
	cmif		:CMIF_TIsForProduct;
			
begin

	// This is really ugly but necessary.
	count	:= self.tblDataDetail.fixedRows;
	rows	:= self.tblDataDetail.rows;
	column := self.tblDataDetail.getColumnByRowName(ETRow_Id);
	
	self.allSelectedItems.clear();
	self.allTmpItems.purge();
	
	// Find out what items are currently selected.
	foreach obj in self.allDetailObjects do
		detailLine := obj.CMIF_BOLOutLine;
		if detailLine.myTrackedItem &lt;&gt; null then
			self.allSelectedItems.add(detailLine.myTrackedItem);
		endif;
	endforeach;
	
	// Iterate threw cmifs and find item combo foreach row.
	foreach obj in self.allDetailObjects where count &lt; rows do
		count := count + 1;
		detailLine := obj.CMIF_BOLOutLine;
		tmpCell := self.tblDataDetail.accessCell(count, column);
		tmpCmbItem := tmpCell.cellControl.CMUI_ComboBox;
		// If the current item combo has been passed in and it is already populated then move on.
		if _tmpCmbItem &lt;&gt; null and _tmpCmbItem = tmpCmbItem and _tmpCmbItem.listIndex &lt;&gt; -1 then
			continue;
		endif;
		
		// Reset.
		tmpCmbItem.clear();
		if detailLine.myProduct &lt;&gt; null then
			// Get tis for this product once per reset.
			cmif := self.allTmpItems.getAtKey(detailLine.myProduct).CMIF_TIsForProduct;
			if cmif = null then
				create cmif transient;
				self.myAssistant.tisByProduct(detailLine.myProduct, cmif.allTis);
			endif;
			// Add tis to this combo if they aren't included in other combos and they aren't our selected item.
			foreach ti in cmif.allTis do
				if self.allSelectedItems.includes(ti) and ti &lt;&gt; detailLine.myTrackedItem then
					continue;
				else
					tmpCmbItem.itemObject[tmpCmbItem.addItem(ti.id)] := ti;
				endif;
				
			endforeach;
			
			// Try and find the current object;
			tmpCmbItem.listIndex := tmpCmbItem.findObject(detailLine.myTrackedItem);
		endif;
	endforeach;
	
	
end;</source>
        <access>protected</access>
        <Parameter name="_tmpCmbItem" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
