        <source>utlCreateFault(_pxyFault : CM_Fault; _newFault : CM_Fault output; _terminal : CM_Terminal; _passport : CM_Passport input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
17 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valFault(_pxyFault);

	
	self.raiseExceptionIfNull(_terminal, 'Terminal');
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	app.setContinueCMExceptions(false);

	create _newFault persistent;

	_newFault.setForCreate(_pxyFault,_terminal);
	
	
	_newFault.causeEvent(_terminal.getTerminalEvent(Event_Fault_Add),false,_newFault);
	

epilog

end;</source>
