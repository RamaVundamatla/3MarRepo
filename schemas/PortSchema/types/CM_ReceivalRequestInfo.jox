    <JadeMethod name="getTotQtyLeft" id="0325317e-18a4-44ec-bbe6-8378be33ef91">
        <source>getTotQtyLeft(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2014	cnwndl1	Initial creation	Par 33596

*/

vars

	job : CM_Job;
	wle : CM_WorkListEntry;
	qty : Integer;
	ti : CM_TrackedItem;
	qtyLeft : Integer;

begin

	
	if self.quantity = 0 then
		return 0;
	endif;

	if self.myReceivalRequest &lt;&gt; null then
		job := self.myReceivalRequest.myJob;
		if job &lt;&gt; null then
			foreach wle in job.workListEntries do
				ti := wle.myTrackedItem;
				if ti &lt;&gt; null then
					qty := qty + wle.quantity.max(1);
				endif;
			endforeach;
			if qty &gt; 0 then
				qtyLeft := self.quantity - qty;	
				if qtyLeft &lt; 1 then
					// in case its negative
					qtyLeft := 0;
				endif;
				return qtyLeft;
			endif;
		endif;
	endif;
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalQuantityUnloaded" id="1bccb9af-5700-4bd4-8184-f231ed828d35">
        <source>getTotalQuantityUnloaded():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2014	cnwndl1	Initial creation	Par 33596

*/

vars

	job : CM_Job;
	wle : CM_WorkListEntry;
	ti : CM_TrackedItem;
	qty : Integer;

begin

	if self.myReceivalRequest &lt;&gt; null then
		job := self.myReceivalRequest.myJob;
		if job &lt;&gt; null then
			foreach wle in job.workListEntries do
				ti := wle.myTrackedItem;
				if ti &lt;&gt; null and self.allTrackedItems.includes(ti) then
					qty := qty + wle.quantity.max(1);
				endif;
			endforeach;
		endif;
	endif;
	
	return qty;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="c7001f63-3fd1-46c8-a899-761a374b8a7f">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
23 February 2010	cnwjk3	Initial creation
20/04/2011			cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
							trying to create the proxy
*/

vars
	_pxyReceivalInfo : SelfType;
	completedOK		: Boolean;
begin
	_pxyReceivalInfo := inheritMethod();
	_pxyReceivalInfo.setGTEReceivalInfo(self.myGTEReceivalInfo);
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return _pxyReceivalInfo;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete _pxyReceivalInfo;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
