    <JadeMethod name="addBulkArea" id="aa67a4a9-e0e5-4a94-b821-758b74a67a70">
        <source>addBulkArea(_id : String) : CM_BulkArea;

/*

Purpose:	Create a Bulk Area		

Date		Who		Reason
17/10/2017	jlgmh5	Initial creation

*/

vars

	pxyBulkArea				: CM_BulkArea;
	realBulkArea			: CM_TerminalAreaMaster;
	
	comment					: String;

begin

	self.deleteTerminalArea(_id);
	
	comment := self.opts.str("comment");
	
	create pxyBulkArea transient;
	pxyBulkArea.setProxy(_id, comment, 30, self.getTerminal(), 0.00, 0.00, 0, 0, false, false, null, 
		null, null);
		
	app.myTrxCA.trxCreateTerminalArea(pxyBulkArea, realBulkArea, app.myPassport);
	self.assertNoTrxErrors();

	return realBulkArea.CM_BulkArea;
	
epilog

	delete pxyBulkArea;

end;</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_BulkArea"/>
    </JadeMethod>
    <JadeMethod name="addBulkCalendarDates" id="ca951df5-094b-42b5-90fd-cab762afd1cc">
        <source>addBulkCalendarDates(_calendar : CM_Calendar; _startDate : Date; _count : Integer; _label : String);
// CCMS 1295 free storage days - create a recurring weekly date
vars
	loopCount	: Integer;
	transCalendarDate : CM_CalendarDate;
	loopDate : Date;
	nullTime : Time;
	allTransCalendarDates 	: CM_CalendarDatesByDateTimedict;

	calendarDate : CM_CalendarDate;
	calendarDateProxy : CM_CalendarDate;
	calendarYear : CM_CalendarYear;
	calendarYearProxy : CM_CalendarYear;
	iter : Iterator;
	invalidObject : Boolean;
	year : Integer;

begin
	if _calendar = null or 
	   _count &lt; 1 or
	   not _startDate.isValid() then
		return;
	endif;

	nullTime := "00:00:00".Time;
	create allTransCalendarDates transient;
	loopDate := _startDate;
	
	while loopCount &lt;= _count do
	
		loopCount := loopCount + 1;

		create transCalendarDate transient;
		
		transCalendarDate.setProxy(	loopDate,	//_date : Date;
									_label,	//_description : String;
									null,	//_myCalendar : CM_Calendar;
									null,	//_myCalendarYear : CM_CalendarYear
									1	//_dataSource : Integer
									);
		transCalendarDate.setStartEndTime(	nullTime,	//_startTime : Time;
											nullTime	//_endTime : Time
											);
		allTransCalendarDates.add(transCalendarDate);
		
		loopDate := loopDate + 7;
	endwhile;
	
	// read and update from the date proxies
	iter := allTransCalendarDates.createIterator;
	
	on Exception do app.handleDeletedObject(exception, calendarDateProxy, invalidObject);
	
	while iter.next( calendarDateProxy ) do
	
		year := calendarDateProxy.date.year;
		if invalidObject then
			invalidObject := false;
			continue;
		endif;
		
		calendarYear := _calendar.allCalendarYears.getAtKey(year);
		if calendarYear = null then
		
			// have to create a new calendar year first...
			create calendarYearProxy transient;
			calendarYearProxy.setProxy( year, _calendar);
		
			app.myTrxCA.trxCreateCalendarYear(calendarYearProxy, calendarYear, app.myPassport, false);
			delete calendarYearProxy;
			
		endif;
		
		// set up the calendar and calendar year on the calendar date transient.
		calendarDateProxy.setProxy(	calendarDateProxy.date,	//_date : Date;
									calendarDateProxy.description,	//_description : String;
									_calendar,	//_myCalendar : CM_Calendar;
									calendarYear,	//_myCalendarYear : CM_CalendarYear;
									calendarDateProxy.dataSource	//_dataSource : Integer
									);
									
		
		app.myTrxCA.trxCreateCalendarDate(calendarDateProxy, calendarDate, app.myPassport);
		delete calendarDateProxy;
	endwhile;
	

epilog
	delete calendarYearProxy;
	delete calendarDateProxy;
	delete iter;
	if allTransCalendarDates &lt;&gt; null then
		allTransCalendarDates.purge();
	endif;
	delete allTransCalendarDates;
end;
</source>
        <Parameter name="_calendar" type="CM_Calendar"/>
        <Parameter name="_startDate" type="Date"/>
        <Parameter name="_count" type="Integer"/>
        <Parameter name="_label" type="String"/>
    </JadeMethod>
    <JadeMethod name="addCalculationType" id="368d7598-7147-4840-b9a7-612b8ad8aa28">
        <source>addCalculationType(_calcType : Integer; _code : String; _description : String; _quantityHookSource : String; _rateHookSource : String; _remarksHookSource: String; _block, _free, _min, _max : Decimal; _isCargo, _isVoyage, _isEvent : Boolean; _blockUnit : Integer) : CM_CalculationType;
// Oct 2010 cnwjre1
//02/10/2025	navkc1 JIRA 36149 AAT | RotaBox ISO Type and New Attributes - Calculation Type
vars
	pxyCalculationType,
	calculationType	: CM_CalculationType;
	
	ranges			: IntegerArray;

begin

	create pxyCalculationType transient;
	
	if self.opts.includesKey("Ranges") then							// 11/05/2016 cnwmh5
		ranges := self.opts.intArray("Ranges").IntegerArray;
	endif;
	
	pxyCalculationType.setProxy(null, //_booleans
							_calcType,
							_code,
							_description,
							_free, _max,_min, _block, 
							ranges,									// 11/05/2016 cnwmh5 null,
							false,null,null,null,null,_blockUnit, // PAR 35940
							_quantityHookSource, _rateHookSource, _remarksHookSource, null, _isCargo, _isVoyage, _isEvent, 
							false, // TFS 39198
							null, null, null, 0, false, false, 0);	// the 'true' is cargo
	
	app.myTrxCA.trxCreateCalculationType(pxyCalculationType, calculationType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return calculationType;
epilog
	delete pxyCalculationType;
end;</source>
        <Parameter name="_calcType" type="Integer"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_quantityHookSource" type="String"/>
        <Parameter name="_rateHookSource" type="String"/>
        <Parameter name="_remarksHookSource" type="String"/>
        <Parameter name="_block" type="Decimal"/>
        <Parameter name="_free" type="Decimal"/>
        <Parameter name="_min" type="Decimal"/>
        <Parameter name="_max" type="Decimal"/>
        <Parameter name="_isCargo" type="Boolean"/>
        <Parameter name="_isVoyage" type="Boolean"/>
        <Parameter name="_isEvent" type="Boolean"/>
        <Parameter name="_blockUnit" type="Integer"/>
        <ReturnType type="CM_CalculationType"/>
    </JadeMethod>
    <JadeMethod name="addCalculationTypeFull" id="5a1cc44a-c98a-4b22-b1df-9a8ee159f23b">
        <source>addCalculationTypeFull(_calcType : Integer; _code : String; _description : String; _quantityHookSource : String; _rateHookSource : String; _remarksHookSource: String;
						_block, _free, _min, _max : Decimal; _isCargo, _isVoyage, _isEvent : Boolean; _calcTypeUnit : Integer; _mesType : CM_MeasurementType) : CM_CalculationType;
// Jan 2015 cnwjre1
//02/10/2025	navkc1 JIRA 36149 AAT | RotaBox ISO Type and New Attributes - Calculation Type
vars
	pxyCalculationType,
	calculationType	: CM_CalculationType;

begin

	create pxyCalculationType transient;
	
	pxyCalculationType.setProxy(null, //_booleans
							_calcType,
							_code,
							_description,
							_free, _max,_min, _block, null,false,null,null,null,null,_calcTypeUnit,
							_quantityHookSource, _rateHookSource, _remarksHookSource, null, _isCargo, _isVoyage,
							_isEvent, 
							false, // TFS 39198
							null, null, _mesType, 0, false, false, 0);
	
	app.myTrxCA.trxCreateCalculationType(pxyCalculationType, calculationType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return calculationType;
epilog
	delete pxyCalculationType;
end;</source>
        <Parameter name="_calcType" type="Integer"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_quantityHookSource" type="String"/>
        <Parameter name="_rateHookSource" type="String"/>
        <Parameter name="_remarksHookSource" type="String"/>
        <Parameter name="_block" type="Decimal"/>
        <Parameter name="_free" type="Decimal"/>
        <Parameter name="_min" type="Decimal"/>
        <Parameter name="_max" type="Decimal"/>
        <Parameter name="_isCargo" type="Boolean"/>
        <Parameter name="_isVoyage" type="Boolean"/>
        <Parameter name="_isEvent" type="Boolean"/>
