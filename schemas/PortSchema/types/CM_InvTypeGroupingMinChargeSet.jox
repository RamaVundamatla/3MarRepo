<CollClass name="CM_InvTypeGroupingMinChargeSet" id="39738026-4acf-4089-9b94-a9643eb54372">
    <loadFactor>66</loadFactor>
    <memberType name="CM_InvTypeGroupingMinCharge"/>
    <superclass name="ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <JadeMethod name="includesGrpForLineType" id="e253c856-b797-4792-91e6-dfd18d3935a5">
        <source>includesGrpForLineType( _invLineType : CM_InvoiceLineDesc; _desc : String output ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 March 2019	jlgndl1	Initial creation	TFS 43687

*/

vars

	item : CM_InvTypeGroupingMinCharge;
	iter : Iterator;

begin

	if _invLineType = null then
		return false;
	endif;

	iter := self.createIterator;	
	while iter.next( item ) do
		if item.allLineTypesForMinimumCharge.includes( _invLineType ) then
			_desc := item.description;
			return true;
		endif;
	endwhile;
	
	return false;

epilog

	delete iter;

end;</source>
        <Parameter name="_invLineType" type="CM_InvoiceLineDesc"/>
        <Parameter name="_desc" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
