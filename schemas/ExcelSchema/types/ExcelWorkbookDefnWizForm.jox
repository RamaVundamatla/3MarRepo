    <JadeMethod name="btnBack_click" id="80f0e8ea-2b4e-4ecc-91c3-58911ff3fec5">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBack_click(btn: Button input) updating;

/*****************************************************
	Written by	:	cnwgrp1		05 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	on Exception do app.defaultExceptionHandler(exception);
	
	normalUnload := true;
	
	myDA.doWizardStepProcessingBack;
	
	if myDA.backProcessingCancelled then
		myDA.setBackProcessingCancelled(false);
		return;
	endif;
	
	myDA.setIntCurrentWizardStep(myDA.intCurrentWizardStep - 1);
	myDA.wizardControl;
	unloadForm;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnCancel_click" id="1f77c358-223a-4dda-99a0-1e76629cf086">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;

/*****************************************************
	Written by	:	cnwgrp1		04 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	error	: Boolean;

begin
	on UserInterfaceException do handleUserInterfaceException(exception, error);
	
	myDA.checkExcel;
	
	if error then
		return;
	endif;
	
	on UserInterfaceException do null;
	on Exception do app.defaultExceptionHandler(exception);
	
	normalUnload := true;
	
	myDA.doCancelled;
	unloadForm;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnNext_click" id="6331c244-e7d3-4b23-ac98-941117543cd4">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNext_click(btn: Button input) updating;

/*****************************************************
	Written by	:	cnwgrp1		04 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	on Exception do app.defaultExceptionHandler(exception);
	app.statusBusy(true);
	setProcessingParameters;	// pass the parameters to the DA
	
	if blnError then		// something went wrong in the setProcessingParameters
		blnError := false;
		return;
	endif;
	
	myDA.doWizardStepProcessing;
	
	if myDA.processingErrorFound then	// something went wrong with the current step
		return;
	endif;
	normalUnload := true;
	myDA.setIntCurrentWizardStep(myDA.intCurrentWizardStep + 1);
	myDA.wizardControl;
	unloadForm;

epilog
	app.statusBusy(false);

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="handleUserInterfaceException" id="9e4739a8-b459-4aa1-8f05-b7b7f0e5e126">
        <updating/>
        <source>handleUserInterfaceException(	ex		: Exception;
								error	: Boolean io) : Integer updating;

/*****************************************************
	Written by	:	cnwpra1		16 July 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	if ex.errorCode = 14108 then				// User Interface exception
		if ex.extendedErrorText.pos('0x80010001', 1) &lt;&gt; 0 then	// the Window error =  0x80010001 - Call was rejected by callee.
			app.msgBox('It appears the active cell in Excel has not yet been finished.' &amp; CrLf &amp; CrLf &amp;
							'Go to the workbook and use Enter or Arrow out of the current cell and try again', 'Excel not able to continue', MsgBox_OK_Only);
			error := true;
			return Ex_Resume_Next;
		endif;
	endif;
		
	return Ex_Pass_Back;
	
epilog

end;</source>
        <Parameter name="ex" type="Exception"/>
        <Parameter name="error" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataFromDA" id="784a4e9e-bb22-4f08-8e5c-bd5cdcb27adf">
        <updating/>
        <source>loadDataFromDA() updating;

