    <JadeMethod name="deleteMyMoveCriteria" id="310d8c12-b295-4a37-aae2-ee63c3e93a1a">
        <updating/>
        <source>deleteMyMoveCriteria(): Boolean updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 04 August 2023
TFS#		: 59582
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	theReturn : Integer;
begin
	if self.myCurrentMoveCrit = null then // nothing to delete continue closing the form
		return true;
	endif;
	while true do
		app.myTrxDA.trxDeleteCamsMoveTAType(self.myCurrentMoveCrit.CM_CamsMoveTATypeCritieria, self.myCamprotocol, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			return true;
		else
			theReturn := app.showErrorWarningDialog(self.class.name,  app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;		
		endif;
		break;
	endwhile;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doAdd" id="3fc7eba9-0aa8-45a3-bfb9-b3ce7b0651a1">
