    <JadeMethod name="enableCashOnlyTerminal" id="95b9a954-4dd2-47d9-8ab7-d24edc82047b">
        <source>enableCashOnlyTerminal( _term : CM_Terminal; _enable : Boolean );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	self.assertTrueMsg(app.isCashOnlyEnabled, "System not licensed for Cash only Debtors...");

	self.assertTrueMsg(_term &lt;&gt; null, "No terminal declared to set Cash only for...");
	
	if  _enable &lt;&gt; _term.isCashOnlyEnabled then
		self.opts.addAssoc("Terminal", _term.code);
		///self.setTerminalConfig(CashProcessingEnabled, _enable);
		self.opts.removeAssoc(CashProcessingEnabled);
	endif;
	
	self.assertTrueMsg(_enable = _term.isCashOnlyEnabled, "Set/Reset config for 'CashProcessingEnabled' failed");

epilog

end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findTIsWithIDInTerminalQuick" id="ee475d51-0a4f-4457-9168-6f6166de3fd8">
        <source>findTIsWithIDInTerminalQuick(_tiId : String; _tiSet : CM_TISet io);

/*

Purpose:		Rather than use getTrackedItem and getTrackedItemByCargoType which
				use the lookupAllTIsOfIdCargoType methods this is a cutdown faster 
				version of this without all the cmifMonitor stuff.

Date			Who		Reason
24/11/2014		cnwmh5	Initial creation

*/

vars

	terminal				: CM_Terminal;
	voyage					: CM_Voyage;
	ti						: CM_TrackedItem;

	iter					: Iterator;
	
	ts						: TimeStamp;

begin

	if _tiSet = null then
		return;
	endif;

	terminal := self.getTerminal();
	
	self.sendMsg("deleteMyMergeIter");
	
	// create mergeIter the 1st time in
	if self.myMergeIter = null then
		self.sendMsg("createMyMergeIter");
		
		self.myMergeIter.addCollection(terminal.allNotifiedTIsByIdCargoType);
		self.myMergeIter.addCollection(terminal.allOnsiteTIsByIdCargoType);
		
		foreach voyage in terminal.allVoyagesArchived do
			self.myMergeIter.addCollection(voyage.allOnshipTIsByIdCargoType);
		endforeach;
		
		foreach voyage in terminal.allVoyagesByCode do
			//if not voyage.allOnshipTIsByIdCargoType.isEmpty() then
				self.myMergeIter.addCollection(voyage.allOnshipTIsByIdCargoType);
			//endif;
		endforeach;
	endif;
	
	self.myMergeIter.startKeyGeq(_tiId, 0);
	while self.myMergeIter.next(ti) and ti.id = _tiId do
		_tiSet.add(ti);	
	endwhile;
	
	ts := null;
	iter := terminal.allOffsiteTIsByIdCargoType.createIterator;
	terminal.allOffsiteTIsByIdCargoType.startKeyGeq(_tiId, null, ts, iter);
	while iter.next(ti) and ti.id = _tiId do
		_tiSet.add(ti);
	endwhile;
	
epilog

	delete iter;

end;</source>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_tiSet" type="CM_TISet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="gateInBreakBulk" id="921eff51-3880-412e-aa32-2f06c77b70ac">
        <source>gateInBreakBulk(_gteEntity : Class; _rego, _driverCode, _driverName, _state, _carrier, _yic, _dischPort, _voyage, _operator, _cargoType, _subType, _gate : String;
	_imexStatus, _qty : Integer; _totalweight : Decimal) : CMGTE_Entity;

// 30/01/2018		jlgmh5		Initial Creation
//								See UiCommonSchema::CMUI_ReceiveCargoForm
//								doSaveFlexiGateForm; doSaaaaveFlexiGateController
//								for details on what is saved

vars

	controller 					: CMIF_FlexiGateController;
	pxyGTEEntity				: CMGTE_Entity;
	realGTE						: CMGTE_Entity;
	cargoType					: CM_CargoType;
	subType						: CM_Product;
	pxyVVR						: CM_VehicleVisitRecord; 
	realVVR 					: CM_VehicleVisitRecord;
	lane						: CM_GateAreaLaneController;
	gateArea					: CM_GateArea;
	gate						: CM_Gate;
	carrier						: CM_Carrier;
	
	allProformaLines 			: ObjectSet;
	
	ownerTrailerID				: String;
	now							: TimeStamp;

begin


/*

