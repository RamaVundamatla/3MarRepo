/*
Purpose:			
Date		Who		Reason
19 March 2015	cnwab1	Initial creation
*/

vars

	form : INV_SnapShotSummMap;

begin

	create form;
	form.setMyTerminal(self.myTerminal);	
	form.myCurrentTranMapSS := self.myCurrentTranMapSS;
	form.mySnapShotBroker := self.mySnapShotBroker;
	form.myOutputFormat := self.mySnapShotBroker.mySnapShotDefinition;
	form.mode := INV_SnapShotSummMap.Mode_Update;

	form.show();
	
	self.unloadForm;

epilog

end;</source>
