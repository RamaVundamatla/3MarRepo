<Class name="File">
    <JadeMethod name="jssCopy" id="cc893224-c443-4d4a-928b-1148b8517445">
        <updating/>
        <source>jssCopy(pTarget:String):Boolean updating;
// -----------------------------------------------------------------------------
// Created:		17 January 2002 by cnwdad1
//
// Purpose:		Copies the receiver's disk file to the specified file name.
//
// Parameters:	pTarget - The name of the file to copy the receiver to.
//
// Returns:		True if the copy was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	isSuccessful	: Boolean;
	copyResult		: Integer;
	
begin
	isSuccessful	:=	false;
	
	if app.isUnicode() then
		copyResult	:=	call jssCopyFileW(self.fileName, pTarget, true);
	else
		copyResult	:=	call jssCopyFileA(self.fileName, pTarget, true);
	endif;
	
	if copyResult = 0 then
		isSuccessful	:=	false;
	else
		isSuccessful	:=	true;
	endif;
epilog
	return isSuccessful;
end;</source>
        <Parameter name="pTarget" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssGetAttributes" id="3ab76d0c-099e-48f4-b3c8-f94be74c4dae">
        <source>jssGetAttributes():String;
// --------------------------------------------------------------------------------
// Created:		14 May 1999 - getAttributes
// By:			cnwdad1
//
// Purpose:		Returns a string of the files File System attributes.
//
// Parameters:	None
//
// Returns:		String - A string of one-character attributes.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	attributes	: String;

begin
	if self.archive then		
		attributes	:=	attributes &amp; 'A';
	endif;

	if self.hidden then
		attributes	:=	attributes &amp; 'H';
	endif;

	if self.readOnly then
		attributes	:=	attributes &amp; 'R';
	endif;

	if self.systemFile then
		attributes	:=	attributes &amp; 'S';
	endif;
epilog
	return attributes;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssIsFile" id="d2c8b1e2-59ad-4c63-a1d5-cc4ea47fa451">
        <source>jssIsFile(): Boolean;
// -----------------------------------------------------------------------------
// Created:		22 January 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssIsNotEndOfFile" id="ba9d66cf-7fba-4db9-bf03-428a505012a1">
        <source>jssIsNotEndOfFile():Boolean;
// --------------------------------------------------------------------------------
// Created:		12 April 2001 by cnwdad1
//
// Purpose:		This method returns a boolean flag to indicate whether the end of
//				the receiver (file) has been reached.  This method is the opposite
//				of the native "endOfFile" method.
//
// Parameters:	None
//
// Returns:		True if the end of the file has NOT been reached, or false if the
//				end of the file HAS been reached.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (not self.endOfFile());
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssMove" id="a2791fea-f151-4532-971f-4d43d1f6a880">
        <updating/>
        <source>jssMove(pTarget: String): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		17 January 2002 by cnwdad1
//
// Purpose:		Moves the receiver's disk file to the specified file name.
//
// Parameters:	pTarget - The name of the file to move the receiver to.
//
// Returns:		True if the move was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	isSuccessful	: Boolean;
	moveResult		: Integer;
	
begin
	isSuccessful	:=	false;
	
	if app.isUnicode() then
		moveResult	:=	call jssMoveFileW(self.fileName, pTarget);
	else
		moveResult	:=	call jssMoveFileA(self.fileName, pTarget);
	endif;
	
	if moveResult = 0 then
		isSuccessful	:=	false;
	else
		isSuccessful	:=	true;
	endif;
epilog
	return isSuccessful;
end;</source>
        <Parameter name="pTarget" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssReadCsv" id="05c7693f-d9c8-41fc-a1a7-5e3aed5eb078">
        <source>jssReadCsv(pRecordArray:ObjectArray io; pIsHuge:Boolean);
// --------------------------------------------------------------------------------
// Created:		12 May 1999 by cnwdad1
//
// Purpose:		Reads a comma-delimited file (quote-enclosed) into an array of arrays.
//
// Parameters:	pRecordArray (ObjectArray) - Accepts an ObjectArray.  The returned
//				array will contain a StringArray for each record (the StringArray
//				will contain one subscript for each field).
//
//				pIsHuge (Boolean) - Indicates whether to return records as a StringArray
//				or as a HugeStringArray.
//
// Returns:		See 'pRecordArray' Input-Output paramter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	COMMA			: String = ',';
	DOUBLE_QUOTE	: String = '"';

vars
	fieldNo		: Integer;
	fieldPos	: Integer;
	fieldLen	: Integer;
	record		: String;
	recordLen	: Integer;
	fieldArray	: Array;

begin
	pRecordArray.clear();		// Initialize the array of records.

	while (not self.endOfFile()) do
		record		:=	self.readLine();		// Get the (next) file record.
		recordLen	:=	record.length();	// Get the length of the record.
		fieldPos	:=	1;					// Initialize the field position.
		fieldNo		:=	1;					// Initialize the field number.

		// Create a new array of record fields.

		if pIsHuge then
			create fieldArray as HugeStringArray transient;
		else
			create fieldArray as StringArray transient;
		endif;

		// Now scan the record...

		while fieldPos &lt; recordLen do
			fieldLen	:=	record.pos(COMMA, fieldPos);		// Locate the next subsequent comma (field delimiter).
			fieldLen	:=	fieldLen - fieldPos;				// Get the length of this field.

			if record.pos(COMMA, fieldPos) = 0 and fieldPos &lt; recordLen then
				// This must be the last field in the record.
				fieldLen	:=	recordLen - fieldPos + 1;
			endif;

			fieldArray[fieldNo]	:=	record[fieldPos:fieldLen];		// Add this field to the array of fields.

			// If the comma is inside double-quotes, scan ahead in the record for the next double-quote.

			while fieldArray[fieldNo].String[1] = DOUBLE_QUOTE
			and fieldArray[fieldNo].String[fieldArray[fieldNo].String.length()] &lt;&gt; DOUBLE_QUOTE
			do
				fieldPos			:=	fieldPos + fieldLen + 1;
				fieldLen			:=	record.pos(COMMA, fieldPos);
				fieldLen			:=	fieldLen - fieldPos;
				fieldArray[fieldNo]	:=	fieldArray[fieldNo].String &amp; COMMA &amp; record[fieldPos:fieldLen];
			endwhile;

			// String any double-quotes that surround the field value.

			if fieldArray[fieldNo].String[1] = DOUBLE_QUOTE
			and fieldArray[fieldNo].String[fieldArray[fieldNo].String.length()] = DOUBLE_QUOTE
			then
				fieldArray[fieldNo]	:=	fieldArray[fieldNo].String[2:(fieldArray[fieldNo].String.length() - 2)];
			endif;

			// Increment positions to the next field position.

			fieldPos	:=	fieldPos + fieldLen + 1;
			fieldNo		:=	fieldNo + 1;
		endwhile;

		pRecordArray.add(fieldArray);
	endwhile;
end;</source>
        <Parameter name="pRecordArray" type="ObjectArray" usage="io"/>
        <Parameter name="pIsHuge" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssRemove" id="1eecf2f5-1d44-446f-867b-8dfe89a676d4">
        <updating/>
        <source>jssRemove(): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		17 January 2002 by cnwdad1
//
// Purpose:		Deletes the receiver's file from disk.  The file is physically
//				deleted, and so cannot be restored from the Windows' Recycle Bin.
//
// Parameters:	None.
//
// Returns:		True if the delete was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	isSuccessful	: Boolean;
	
begin
	isSuccessful	:=	false;
	self.purge();
	isSuccessful	:=	true;
epilog
	return isSuccessful;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssSetOpenName" id="b59f8dcf-bb90-4c3a-b517-3b4395904495">
        <updating/>
        <source>jssSetOpenName(pMustExist:Boolean; pCreatePrompt:Boolean; pFileFilter:String):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		17 August 2001 by cnwdad1
//
// Purpose:		This method will prompt the user to select (or enter) a file name,
//				and will then use that name to set the receiver's file name.
//
// Parameters:	pMustExist - If true, then the file being opened must already exist.
//				pCreatePrompt - If true, the user will be prompted to create the
//					file if it doesn't already exist.
//				pFileFilter - The file-type filter string.
//
// Returns:		True if the file name was successfully set, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	isSuccessful	: Boolean;
	theFileName		: CMDFileOpen;
	
begin
	isSuccessful	:=	false;
	create theFileName;
	
	if pFileFilter &lt;&gt; null then
		theFileName.filter	:=	pFileFilter;
	endif;
	
	theFileName.fileMustExist	:=	pMustExist;
	theFileName.createPrompt	:=	pCreatePrompt;
	
	if theFileName.open() = 0 then
		self.fileName	:=	theFileName.fileName;
		self.kind 		:=	File.Kind_Unknown_Text;	// 3/3/16 cnwmp6 PAR 36286 unicode version
		isSuccessful	:=	true;
	endif;
epilog
	delete theFileName;
	
	return isSuccessful;
end;</source>
        <Parameter name="pMustExist" type="Boolean"/>
        <Parameter name="pCreatePrompt" type="Boolean"/>
        <Parameter name="pFileFilter" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssSetSaveName" id="9ed28385-4d50-42cc-97d3-079b4cc3fb05">
        <updating/>
        <source>jssSetSaveName(pDefaultName:String; pCreatePrompt:Boolean; pOverwritePrompt:Boolean):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		17 August 2001 by cnwdad1
//
// Purpose:		This method will prompt the user to select (or enter) a file name,
//				and will then use that name to set the receiver's file name.
//
// Parameters:	pDefaultName - The default file name.
//				pCreatePrompt - If true, the user will be prompted to create the
//					file if it doesn't already exist.
//				pOverwritePrompt - If true, the user will be prompted to overwrite
//					the file if it already exists.
//
// Returns:		True if the file name was successfully set, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	isSuccessful	: Boolean;
	theFileName		: CMDFileSave;
	
begin
	isSuccessful	:=	false;
	create theFileName;
	
	theFileName.fileName		:=	pDefaultName;
	theFileName.fileMustExist	:=	false;
	theFileName.createPrompt	:=	pCreatePrompt;
	theFileName.overwritePrompt	:=	pOverwritePrompt;
	theFileName.pathMustExist	:=	true;
	
	if theFileName.open() = 0 then
		self.fileName	:=	theFileName.fileName;
		isSuccessful	:=	true;
	endif;
epilog
	delete theFileName;
	
	return isSuccessful;
end;</source>
        <Parameter name="pDefaultName" type="String"/>
        <Parameter name="pCreatePrompt" type="Boolean"/>
        <Parameter name="pOverwritePrompt" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
