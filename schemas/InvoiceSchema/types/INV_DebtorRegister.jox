    <JadeMethod name="objLoadList" id="aa8d26ea-846d-465d-b4ba-3521dc6b2e39">
        <source>objLoadList(_debtorNode : CM_DebtorNode;  _level: Integer; _filterText : String) : Boolean;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		Loads the list of debtors that match filter text
//
// Date		Who		Reason
// 19 July 2022		navpw1	Bug: 53979 EUP - Text Filter in Debtor register
// ---------------------------------------------------------------------------

vars
	//theDebtor 			: CM_Debtor; // ### TFS 53979 26July2022 NAVPW1
	theDebtorGroup 			: CM_DebtorGroup;
	theDebtorNode 			: CM_DebtorNode;
	theListBox 				: CMUI_ListBox;
	index 				 	: Integer;
	shouldShow 			 	: Boolean;
	foundMatchingSubItem 	: Boolean;
	
begin
	theListBox := self.lstData;
	
	// ### TFS 53979 26July2022 NAVPW1
	// ### ROOT DEBTOR GROUP
	if _debtorNode.isKindOf(CM_RootDebtorGroup) then
		theDebtorGroup := _debtorNode.CM_DebtorGroup;
		theListBox.addItem(theDebtorGroup.getListName());
		theListBox.itemObject[theListBox.newIndex] := theDebtorGroup;
		theListBox.itemLevel[theListBox.newIndex] := _level;
		theListBox.itemPicture[theListBox.newIndex] := theListBox.form.INV_DebtorRegister.picDebtorGroup.picture;
		
		if (not _debtorNode.allChildDebtorNodes.isEmpty) then
			foreach theDebtorNode in _debtorNode.allChildDebtorNodes do
				if not theDebtorNode.isKindOf(CM_VoidDebtor) then
					shouldShow := self.objLoadList(theDebtorNode, _level +1, _filterText);
					if shouldShow then
						foundMatchingSubItem := true;
					endif;
				endif;
			endforeach;
			
			return foundMatchingSubItem;
			
		endif;
		
	//### DEBTOR or DEBTOR GROUPS
	elseif _debtorNode.isKindOf(CM_Debtor) or _debtorNode.isKindOf(CM_DebtorGroup) or _debtorNode.isKindOf(CM_VoidDebtor) then
		theListBox.addItem(_debtorNode.getListName());
		index := theListBox.newIndex;
		theListBox.itemObject[index] := _debtorNode;
		theListBox.itemLevel[index] := _level;
		
		if _debtorNode.isKindOf(CM_Debtor) then
			theListBox.itemPicture[index] := theListBox.form.INV_DebtorRegister.picDebtor.picture;
		elseif _debtorNode.isKindOf(CM_DebtorGroup) then
			theListBox.itemPicture[index] := theListBox.form.INV_DebtorRegister.picDebtorGroup.picture;
		endif;
		
		if (not _debtorNode.allChildDebtorNodes.isEmpty) then
			foreach theDebtorNode in _debtorNode.allChildDebtorNodes do
				if not theDebtorNode.isKindOf(CM_VoidDebtor) then
					shouldShow := self.objLoadList(theDebtorNode, _level +1, _filterText);
					if shouldShow then
						foundMatchingSubItem := true;
					endif;
				endif;
			endforeach;
			
			if not foundMatchingSubItem and _debtorNode.name.toUpper.pos(_filterText, 1) &lt; 1 and _filterText &lt;&gt; "" then
				theListBox.removeItem(index);
			endif;
			
			return foundMatchingSubItem;
			
		endif;
		
		if _debtorNode.name.toUpper.pos(_filterText, 1) &lt; 1 and _filterText &lt;&gt; "" then
			theListBox.removeItem(index);
			return false;
		endif;
		
		return true;
		
	endif;
	// ### TFS 53979 26July2022 NAVPW1

	/*
	//### DEBTOR
	if _debtorNode.isKindOf(CM_Debtor) or _debtorNode.isKindOf(CM_VoidDebtor) then
		theDebtor := _debtorNode.CM_Debtor;
		
		theListBox.addItem(theDebtor.getListName());
		theListBox.itemObject[theListBox.newIndex] := theDebtor;
		theListBox.itemPicture[theListBox.newIndex] := theListBox.form.INV_DebtorRegister.picDebtor.picture;
		theListBox.itemLevel[theListBox.newIndex] := _level;
	// ### DEBTOR GROUPS
	elseif _debtorNode.isKindOf(CM_DebtorGroup) or _debtorNode.isKindOf(CM_RootDebtorGroup) then
		theDebtorGroup := _debtorNode.CM_DebtorGroup;
		theListBox.addItem(theDebtorGroup.getListName());
		theListBox.itemObject[theListBox.newIndex] := theDebtorGroup;
		theListBox.itemLevel[theListBox.newIndex] := _level;
		theListBox.itemPicture[theListBox.newIndex] := theListBox.form.INV_DebtorRegister.picDebtorGroup.picture;
		*/
		/* CCMS-1604
		foreach theDebtorNode in theDebtorGroup.allChildDebtorNodes do
			if not theDebtorNode.isKindOf(CM_VoidDebtor) then
				self.objLoadList(theDebtorNode, _level+1);
			endif;
		endforeach;
		*/
	/*endif;
	
	// CCMS-1604
	if (not _debtorNode.allChildDebtorNodes.isEmpty) then
		foreach theDebtorNode in _debtorNode.allChildDebtorNodes do
			if not theDebtorNode.isKindOf(CM_VoidDebtor) then
				self.objLoadList(theDebtorNode, _level+1);
			endif;
		endforeach;
	endif;*/ // ### TFS 53979 26July2022 NAVPW1 - Commented out old code was easier to rewrite it

end;</source>
        <Parameter name="_debtorNode" type="CM_DebtorNode"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_filterText" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="objLoadListAt" id="20f2f278-c9a2-4fe9-b4c1-1e1e91c7d65d">
        <source>objLoadListAt(_debtorNode : CM_DebtorNode;  _level: Integer; _at : Integer);
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theDebtor : CM_Debtor;
	theDebtorGroup : CM_DebtorGroup;
	theDebtorNode : CM_DebtorNode;
	theListBox : CMUI_ListBox;
begin

	theListBox := self.lstData;
	
	//### DEBTOR
	if _debtorNode.isKindOf(CM_Debtor) or _debtorNode.isKindOf(CM_VoidDebtor) then
		theDebtor := _debtorNode.CM_Debtor;
		if _at &gt; 0 then
			theListBox.addItemAt(theDebtor.getListName(),_at);
		else
			theListBox.addItem(theDebtor.getListName());
		endif;
		theListBox.itemObject[theListBox.newIndex] := theDebtor;
		theListBox.itemPicture[theListBox.newIndex] := self.picDebtor.picture;
		theListBox.itemLevel[theListBox.newIndex] := _level;		
		
	// ### DEBTOR GROUPS
	elseif _debtorNode.isKindOf(CM_DebtorGroup) or _debtorNode.isKindOf(CM_RootDebtorGroup) then
		theDebtorGroup := _debtorNode.CM_DebtorGroup;
		if _at &gt; 0 then
			theListBox.addItemAt(theDebtorGroup.getListName(),_at);
		else
			theListBox.addItem(theDebtorGroup.getListName());
		endif;
		theListBox.itemObject[theListBox.newIndex] := theDebtorGroup;
		theListBox.itemLevel[theListBox.newIndex] := _level;
		theListBox.itemPicture[theListBox.newIndex] := self.picDebtorGroup.picture;
	
		/*
		CCMS-1604
		foreach theDebtorNode in theDebtorGroup.groupMembers do
			if not theDebtorNode.isKindOf(CM_VoidDebtor) then
				self.objLoadList(theDebtorNode, _level+1);
			endif;
		endforeach;
		*/
		
	endif;
	
	// CCMS-1604
	if (not _debtorNode.allChildDebtorNodes.isEmpty) then
		foreach theDebtorNode in _debtorNode.allChildDebtorNodes do
			if not theDebtorNode.isKindOf(CM_VoidDebtor) then
				self.objLoadList(theDebtorNode, _level+1, null);
			endif;
		endforeach;
	endif;
	
end;</source>
        <Parameter name="_debtorNode" type="CM_DebtorNode"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_at" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="objSetEnableObjects" id="0ac1dfe1-61c3-4022-b14d-9ee68630935f">
        <source>objSetEnableObjects(_debtorNode : CM_DebtorNode;  _viewOnly : Boolean);
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theDebtor		: CM_Debtor;
	theDebtorGroup : CM_DebtorGroup;
	canMaintain		: Boolean;
begin

	canMaintain := app.myPassport.myUser.canDo(null, self.permissionMaint);

	//### DEBTOR
	if _debtorNode.isKindOf(CM_Debtor) or _debtorNode.isKindOf(CM_VoidDebtor) then
		theDebtor := _debtorNode.CM_Debtor;
		
		self.mnuDebtorNew.enabled := canMaintain;
		self.mnuNewGroup.enabled := canMaintain;
		self.btnNew.enabled := canMaintain;
		self.btnNewGroup.enabled := canMaintain;
		self.btnImport.enabled := canMaintain;  //MES 1010 jmn
	
		self.mnuDebtorDelete.enabled := false;
		self.btnDelete.enabled := false;
	
		self.mnuDebtorInvoiceItems.enabled := false;
		self.btnInvoiceItems.enabled := false;
		self.btnInvoices.enabled := false;
		self.mnuDebtorInvoices.enabled := false;
	
		if self.myCurrentDebtorNode.isSuspended then
			self.mnuDebtorSuspend.enabled := canMaintain;
			self.mnuDebtorSuspend.caption := app.getErrorString(CM_Reinstate);
		else
			// can only suspend if no operators or consignors
			if theDebtor.operators.size = 0 and theDebtor.consignors.size = 0 then
				self.mnuDebtorSuspend.enabled := canMaintain;
			else
				self.mnuDebtorSuspend.enabled := false;
			endif;
			self.mnuDebtorSuspend.caption := app.getErrorString(CM_Suspend);
		endif;
	
		if theDebtor.allInvoices.size &gt; 0 then
			self.btnInvoices.enabled := canMaintain;
			self.mnuDebtorInvoices.enabled := canMaintain;
			if theDebtor.invoiceLines.size &gt; 0 then
				self.mnuDebtorInvoiceItems.enabled := canMaintain;
				self.btnInvoiceItems.enabled := canMaintain;
			endif;
		endif;
	
		if theDebtor.allInvoices.size = 0 and 
		   theDebtor.allChildDebtorNodes.size = 0 and	// CCMS-1604
		   theDebtor.lineGroups.size = 0 then
			self.mnuDebtorDelete.enabled := canMaintain;
			self.btnDelete.enabled := canMaintain;
		else
			self.mnuDebtorDelete.enabled := false;
			self.btnDelete.enabled := false;
		endif;
	
		self.mnuDebtorProperties.enabled := canMaintain;
		self.btnProperties.enabled := canMaintain;

	// ### DEBTOR GROUPS
	elseif _debtorNode.isKindOf(CM_DebtorGroup) or _debtorNode.isKindOf(CM_RootDebtorGroup) then
		theDebtorGroup := _debtorNode.CM_DebtorGroup;
		
		self.mnuDebtorNew.enabled := canMaintain;
		self.mnuNewGroup.enabled := canMaintain;
		self.btnNew.enabled := canMaintain;
		self.btnNewGroup.enabled := canMaintain;
		self.btnImport.enabled := canMaintain;  //JMT 1010 jmn
	
		if self.myCurrentDebtorNode.isSuspended then
			self.mnuDebtorSuspend.enabled := canMaintain;
			self.mnuDebtorSuspend.caption := app.getErrorString(CM_Reinstate);
		else
			self.mnuDebtorSuspend.enabled := false;
			self.mnuDebtorSuspend.caption := app.getErrorString(CM_Suspend);
		endif;
	
		self.btnInvoiceItems.enabled := false;
		self.mnuDebtorInvoiceItems.enabled := false;
	
		self.mnuDebtorProperties.enabled := canMaintain;
		self.btnProperties.enabled := canMaintain;			//HJG 
	
		if theDebtorGroup.allChildDebtorNodes.size = 0 and theDebtorGroup.lineGroups.size = 0 then
			self.mnuDebtorDelete.enabled := canMaintain;
			self.btnDelete.enabled := canMaintain;
		else
			self.mnuDebtorDelete.enabled := false;
			self.btnDelete.enabled := false;
		endif;
	
		self.btnInvoices.enabled := false;
		self.mnuDebtorInvoices.enabled := false;

		// ### ROOT GROUP
		if _debtorNode.isKindOf(CM_RootDebtorGroup) then
			if self.myCurrentDebtorNode.isSuspended then
				self.mnuDebtorSuspend.enabled := canMaintain;
				self.mnuDebtorSuspend.caption := app.getErrorString(CM_Reinstate);
			else
				self.mnuDebtorSuspend.enabled := false;
				self.mnuDebtorSuspend.caption := app.getErrorString(CM_Suspend);
			endif;
		
			self.mnuDebtorDelete.enabled := false;
			self.btnDelete.enabled := false;
		
			self.mnuDebtorProperties.enabled := false;
			self.btnProperties.enabled := false;
		
		endif;
	endif;
end;</source>
        <Parameter name="_debtorNode" type="CM_DebtorNode"/>
        <Parameter name="_viewOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="objShowProperties" id="919a221b-26a2-4d82-b31c-40b9d25c5126">
        <source>objShowProperties(_debtorNode : CM_DebtorNode;  _viewOnly : Boolean);
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 08 May 2025 navrv30	MTN 34672: MTN | Multigroup Selection Filter Phase 3
// ---------------------------------------------------------------------------

vars
	theDebtor : CM_Debtor;
	theDebtorGroup : CM_DebtorGroup;
	theTable : CM_EntryTable;
//	ops : ObjectSet;
	row : Integer;
begin
	theTable := self.tblProperties;

	// ### DEBTOR NODE
	row := theTable.setValueByName(ETRow_Name40, _debtorNode.name);
	theTable.setValueByName(ETRow_Remarks, _debtorNode.remarks);
	theTable.setValueByName(ETRow_IsZeroRated, _debtorNode.isZeroRatedTax);
	theTable.setValueByName(ETRow_BadCredit, _debtorNode.badDebtor);
	
	
	// cnwjk3 PAR 18434 - Date - 06/11/2008
	theTable.setValueByName(ETRow_IsPurchaseOrderMandatory, _debtorNode.isPurchaseOrderMandatory);
	
	self.tblProperties.userInputEnabled := not _viewOnly;	
	self.doBuildComboParents();
	//### DEBTOR
	if _debtorNode.isKindOf(CM_Debtor) or _debtorNode.isKindOf(CM_VoidDebtor) then
		theDebtor := _debtorNode.CM_Debtor;
		
		theTable.setValueByName(ETRow_Name40, theDebtor.name);
		theTable.setValueByName(ETRow_Remarks, theDebtor.remarks);
		theTable.setValueByName(ETRow_Address, theDebtor.getBillingAddressString());
		theTable.setValueByName(ETRow_IsZeroRated, theDebtor.isZeroRatedTax);
		theTable.setValueByName(ETRow_IsSuspended, theDebtor.isSuspended); // 10974 this was missing
		theTable.setValueByName(ETRow_PostingNumber, theDebtor.decfinName);
		theTable.setValueByName(ETRow_PurchaseOrderNumber, theDebtor.purchaseOrderCode);
		
		self.tblProperties.readOnly := _viewOnly;
		
		
		self.loadOperators(theDebtor);
		self.loadCustomsAgents(theDebtor);
		self.loadDebtorTypes(theDebtor); //CP ccms 1047 2 amy 2008 cnwgb1
		self.loadCarriers(theDebtor); //+ cnwmd1, CCMS 1067, Par 19913		
		
		self.doBuildComboParents();
		self.doCmbTermsTradeBuild();
		if self.cmbTermsTrade.findObject(theDebtor.myTermsOfTrade) &gt; 0 then
			self.cmbTermsTrade.listObject := theDebtor.myTermsOfTrade;
		else
			self.cmbTermsTrade.listObject := null;
		endif;
		theTable.setValueByName(ETRow_Terms, self.cmbTermsTrade.text);
		self.loadTransactionTypes();

	endif;
epilog
//	delete ops;
end;</source>
        <Parameter name="_debtorNode" type="CM_DebtorNode"/>
        <Parameter name="_viewOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="abc79fab-4889-4dbe-b711-72931b87fd14">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 June 2009	cnwmd1	Initial creation

*/

vars

begin
	inheritMethod(_colorControl);
	self.myCarriersSheet.backColor := self.backColor;
	self.myCarriersMultiSelectBox.backColor := self.backColor;
epilog

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="8f71cf21-9f6c-4075-9de2-0c9eab280ac2">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 08 May 2025 navrv30	MTN 34672: MTN | Multigroup Selection Filter Phase 3
// ---------------------------------------------------------------------------

vars
	u : CM_User;
	ut : CM_UserTerminal;
	t : CM_Terminal;
begin
	self.setNavigatorHeading(self.caption);
	
	self.lstData.defaultLineHeight := 30; // ### TFS 50421 27OCT2021 NAVAB1
	self.lstData.fontSize := 10; // ### TFS 50421 27OCT2021 NAVAB1


	inheritMethod();

	// 18/07/2014 moved after inheritMethod so the form caption doesn't include the terminal code, which is confusing - debtors are system not terminal
	if self.myTerminal = null then // BIG HACK. Fix in 732
	
		// ### TFS 50421 17SEP2021 NAVAB1 changed to be first user terminal, otherwise you get a 'cannot access' if the first terminal is not in the users list of terminals.
		u := app.getMyUser();
		if u &lt;&gt; null then
			ut := u.allUserTerminals.first;
			if ut &lt;&gt; null then
				t := ut.myTerminal;
			endif;
		endif;
		
		if t = null then
			t := CM_Terminal.firstInstance;
		endif;

		self.myTerminal := t;
		
		 // ### TFS 50421 17SEP2021 NAVAB1self.myTerminal := CM_Terminal.firstInstance;
		self.myAssistant.setMyTerminal(self.myTerminal);
	endif;

	if (not app.myCurrentUserCan(self.myTerminal, PmAdmDebtorregisterMaint)) then		// this is a Terminal permission, should be a System one.
		self.viewOnly := true;
	endif;

	self.splMain.setLeftToRightRatio(75);
	self.splMain.cnEcResizeContents();
	self.initPropertyTable(ETDef_InvMaintDebtorReg);	
	
	self.shtPropTwo.visible := true;
	self.shtPropTwo.enabled := true;
	self.shtPropTwo.caption := "Consignors";

	self.shtPropThree.visible := true;
	self.shtPropThree.caption := "Operators";
	
	self.shtPropFour.visible := true;
	self.shtPropFour.caption := "Customs Agents";	
	
	self.shtProp5.visible := true;
	self.shtProp5.caption := "Transactions";
	self.lstPropFour.parent := self.shtProp5;
	self.lstPropFour.visible := true;

	// Centreport CCMS 1047 Par 16666 cnwgb1 2 May 2008
	
	self.shtPropSix.visible := true;
	self.shtPropSix.caption := "Debtor Types";	
	
	//+ cnwmd1, CCMS 1067, Par 19913 - Add Debtors sheet ... still in development
	self.initMSG(self.myCarriersMultiSelectBox,"Carriers Available","Carriers Selected","displayMSGCarriers");
	self.myCarriersMultiSelectBox.setAvailable(app.myRoot.allCarriers, true);
	self.myCarriersSheet.caption := "Carriers";
	self.myCarriersSheet.visible := true;
	

	self.beginNotification(app.myRoot, EVENT_DEBTORNODE_CREATE, Response_Continuous, null);
	self.beginNotification(app.myRoot, EVENT_DEBTORNODE_DELETE, Response_Continuous, null);
	self.beginNotification(app.myRoot, EVENT_DEBTORNODE_UPDATE, Response_Continuous, null);

	self.loadDebtorRegister(null);
end;</source>
    </JadeMethod>
    <JadeMethod name="showPropertyFrame" id="9e56c3bd-5434-4245-8a15-c5f0bcc46d98">
        <updating/>
        <source>showPropertyFrame(_entTableView: String; _mode: Integer; _actualHeight: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 08 May 2025 navrv30	MTN 34672: MTN | Multigroup Selection Filter Phase 3
// ---------------------------------------------------------------------------

vars
	zeroRow : Integer;
begin
	inheritMethod(_entTableView, _mode, _actualHeight);
	
	self.frmToolbar.enabled := false;
	
	if self.updateMode = self.UpdateMode_New then		
		self.myCarriersMultiSelectBox.setSelected(null); //+ cnwmd1, CCMS 1067, Par 19913
		loadCustomsAgents(null); // + dh 20/11/2007 par 14447
		loadDebtorTypes(null); // CP ccms 1047 2 May 2008 cnwgb1
		self.myCarriersMultiSelectBox.setAvailable(app.myRoot.allCarriers, true); //+ cnwmd1, CCMS 1067, Par 19913
	endif;
	
	self.tblProperties.accessRow(self.tblProperties.getRowByName(ETRow_Address)).height := 50;
	self.tblProperties.accessRow(self.tblProperties.getRowByName(ETRow_Remarks)).height := 50;
	
	zeroRow := self.tblProperties.getRowByName(ETRow_IsZeroRated);
	
	if self.modePropertyNew = self.MODEPROPERTY_DEBTOR
	or self.modePropertyUpdate = self.MODEPROPERTY_DEBTOR  then
		self.tblProperties.showRowByName(ETRow_PurchaseOrderNumber,false);
		self.tblProperties.showRowByName(ETRow_IsZeroRated,false);
		if self.myCurrentDebtorParent &lt;&gt; null then
//			self.cmbGroups.listObject := self.myCurrentDebtorGroup;
		endif;
		self.shtPropTwo.visible := true;
		self.shtPropThree.visible := true;
		self.shtPropFour.visible := true;
		self.shtPropSix.visible := true; // CP CCMS 1047 5 May 2008 cnwgb
		self.myCarriersSheet.visible := true; //+ cnwmd1, CCMS 1067, Par 19913
//		self.lstPropFour.accessRow(idx).itemObject.Class

	elseif self.modePropertyNew = self.MODEPROPERTY_GROUP 
	or self.modePropertyUpdate = self.MODEPROPERTY_GROUP  then
		self.tblProperties.hideRowByName(ETRow_PurchaseOrderNumber,false);
		self.tblProperties.hideRowByName(ETRow_IsZeroRated,false);
		self.shtPropTwo.visible := false;
		self.shtPropThree.visible := false;
		self.myCarriersSheet.visible := false;	//- cnwmd1, CCMS 1067, Par 19913
		self.shtPropFour.visible := false;
		self.shtPropSix.visible := false; // CP CCMS 1047 5 May 2008 cnwgb
	endif;

	self.frmProperties.height := 350;
	
	// cnwjk3 PAR 18434 - Date - 07/11/2008
	self.fldProperties.move(1,self.frmPropToolbar.clientHeight + 4,self.frmProperties.clientWidth - 2,
								self.frmProperties.height - self.frmPropToolbar.clientHeight - 10);
	self.tblProperties.height := self.fldProperties.height - 10;

	
	self.tblProperties.scrollBars := self.tblProperties.ScrollBar_Vertical;

	
	self.myCarriersMultiSelectBox.height := self.tblProperties.height - 20; //+ cnwmd1, CCMS 1067, Par 19913

	self.lstData.enabled := false;
end;</source>
        <Parameter name="_entTableView" type="String"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_actualHeight" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showSearchFrame" id="5b181ba4-a684-4545-bb73-460298630ef1">
        <updating/>
        <source>showSearchFrame() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theFrame : CMUI_MoveableFrame;

begin
	// 35872 search frame shows business unit, hide it here, not relevent in this screen
	self.lblBank.visible := false;
	self.cmbBank.visible := false;
	self.lblSearch.caption := "Debtor Code";
	self.lblSearch.top := self.lblBank.top;
	self.txtSearch.top := self.cmbBank.top;
	self.frmSearch.height := 82;
	self.txtBank.visible := false; // ### TFS 50421 17SEP2021 NAVAB1

	
//	inheritMethod();
	
	//17 Jul 2018	NDL	TFS 39254
	theFrame := self.frmSearch;
	theFrame.zOrder(1);
	theFrame.centreWindow();
	theFrame.visible := true;
	self.txtSearch.setFocus();
	self.lstData.enabled := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="ce9b3797-024d-4dfd-8980-8e1ab41b8ef5">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			Filters the table once the user finishes typing

Parameters:			eventTag	Integer	The event tag triggered

Return Value:		NONE

Date				Who		Reason
20 September 2021	navpw1	Initial creation TFS: 51912

*/

begin
	// ### TFS 51912 20Sep2021 NAVPW1
	if eventTag = self.Timer_TableData_Filter then 
		self.doFilterTree();
		return;
	endif;
	
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="6e704512-c12e-494b-8e8e-324cdf7c50c3">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 22 August 2019 09:46:40.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006147, locale);
	btnCashBals.translateBubbleHelp(Xlat_0018037, locale);
	btnCashBals.translateCaption(Xlat_0018038, locale);
	btnCashTrans.translateBubbleHelp(Xlat_0018039, locale);
	btnCashTrans.translateCaption(Xlat_0018040, locale);
	btnDelete.translateBubbleHelp(Xlat_0002077, locale);
	btnDelete.translateCaption(Xlat_0002082, locale);
	btnImport.translateCaption(Xlat_0011527, locale);
	btnInvoiceItems.translateBubbleHelp(Xlat_0002073, locale);
	btnInvoiceItems.translateCaption(Xlat_0002074, locale);
	btnInvoices.translateBubbleHelp(Xlat_0002078, locale);
	btnInvoices.translateCaption(Xlat_0002083, locale);
	btnNew.translateBubbleHelp(Xlat_0002079, locale);
	btnNew.translateCaption(Xlat_0002084, locale);
	btnNewGroup.translateBubbleHelp(Xlat_0002080, locale);
	btnNewGroup.translateCaption(Xlat_0002085, locale);
	btnPrint.translateBubbleHelp(Xlat_0002081, locale);
	btnPrint.translateCaption(Xlat_0002086, locale);
	btnProperties.translateBubbleHelp(Xlat_0002075, locale);
	btnProperties.translateCaption(Xlat_0002076, locale);
	chkPartial.translateCaption(Xlat_0022677, locale);
	mnuAudits.translateCaption(Xlat_0023690, locale);
	mnuDebtor.translateCaption(Xlat_0006148, locale);
	mnuDebtorDelete.translateCaption(Xlat_0006149, locale);
	mnuDebtorInvoiceItems.translateCaption(Xlat_0006150, locale);
	mnuDebtorInvoices.translateCaption(Xlat_0006151, locale);
	mnuDebtorNew.translateCaption(Xlat_0006152, locale);
	mnuDebtorProperties.translateCaption(Xlat_0006153, locale);
	mnuDebtorSuspend.translateCaption(Xlat_0006154, locale);
	mnuInspect.translateCaption(Xlat_0006155, locale);
	mnuNewDebtor.translateCaption(Xlat_0006156, locale);
	mnuNewGroup.translateCaption(Xlat_0006157, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="2306b208-737a-4ef8-82c0-9812e068de2f">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.viewOnly := false;
	delete self.myCarriersMultiSelectBox;
	delete self.myCarriersSheet;
	inheritMethod();
end;</source>
