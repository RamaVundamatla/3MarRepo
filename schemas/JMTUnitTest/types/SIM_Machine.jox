    <JadeMethod name="getTaskDisplay" id="3f2bb748-b15d-4b1b-beca-0c87d06186e7">
        <source>getTaskDisplay() : String;

vars
	msg: String;
begin
	if self.myTask &lt;&gt; null then
		msg := msg &amp; self.myTask.getDisplay();
	endif;
	if self.movingUntil &lt;&gt; null then
		msg := msg &amp; " Moving Until: " &amp; self.movingUntil.asStringForWebInterface;
	endif;
	return msg;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
