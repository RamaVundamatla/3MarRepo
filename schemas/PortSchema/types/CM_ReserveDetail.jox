    <JadeMethod name="getLocationLC" id="fe908e89-319f-47bc-9ca4-e840aa852c62">
        <source>getLocationLC() : CM_LocationsController;
// Get the primary location of the onsite tracked items PAR 18617
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
vars
	ti: CM_TrackedItem;
	lc: CM_LocationsController;
	allTis: CM_TISet;
begin
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	self.getAllTrackedItems(allTis, false); 
	//if self.allTrackedItems.size &gt; 0 then
	if allTis.size() &gt; 0 then //23/06/2023	navkc1	CR 58406 Task 58408
		//foreach ti in self.allTrackedItems where ti.isOnSite do
		foreach ti in allTis where ti.isOnSite do //23/06/2023	navkc1	CR 58406 Task 58408
			if lc = null then
				lc := ti.getPrimaryLocation(REAL_MODE);
			elseif ti.getPrimaryLocation(REAL_MODE) &lt;&gt; lc then
				return null;
			endif;
		endforeach;
		return lc;
	endif;
	
	return null;
epilog
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;
</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
