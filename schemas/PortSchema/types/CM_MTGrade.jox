    <JadeMethod name="getDisplayStringForAttribute" id="d632ebf6-d9f9-49eb-8af1-d861920db650">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	01 December 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _attrName = ETRow_Code then
		// Grade Undefined code is null
		return self.code.String;
	elseif _attrName = ETRow_NotAvailableForEntry then
		return self.isNotAvailableForEntry.display;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTranslationForOperator" id="9898bcc3-296d-4b36-b486-117b4cc80d81">
        <source>getTranslationForOperator(	_mtGrade		: CM_MTGrade;
							_operator 		: CM_Operator;
						 	_operatorGroup	: CM_OperatorGroup;
						 	_code			: CM_MTGradeCode output;
						 	_canDisplay 	: Boolean output) : String;
// -------------------------------------------
// Created 26 October 2004 by cnwdvb1
// -------------------------------------------

vars

	codeGroup			: CM_CodeGroup;
	code				: CM_MTGradeCode;
	group				: CM_OperatorGroup;
	invalidOperator		: Boolean;
	
begin

	_canDisplay := true;
	group := _operatorGroup;
	// Operator will overide operator group.
	if _operator &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, _operator, invalidOperator);		// Par 16733 AER 30/07/2008
		codeGroup := _operator.allCodeGroups[CodeGroup_AvailabilityGrade];
		if codeGroup &lt;&gt; null then
			code := self.allCodeTranslations[codeGroup].CM_MTGradeCode;
			if code &lt;&gt; null then
				_code := code;
				// Found code so return appropriate details.
				return code.code &amp; Tab &amp; code.description;
			endif;
			// We return null if we have found a translation group but no code and we aren't forcing the display.
			if _mtGrade &lt;&gt; self then
				_canDisplay := false;
				return null;
			endif;
		else
			group := _operator.getOperatorGroupIfOnlyOne();
			if group = null then
				// No code groups found at all so ok to return grade details.
				return self.code.String &amp; Tab &amp; self.description;
			endif;
		endif;
	endif;
		
	// This group can either the group from the operator because the operator
	// had one group and no translation of its own or a group passed in to the method
	// where there wasn't an operator.
	if group &lt;&gt; null then
		codeGroup := group.allCodeGroups[CodeGroup_AvailabilityGrade];
		if codeGroup &lt;&gt; null then
			code := self.allCodeTranslations[codeGroup].CM_MTGradeCode;
			if code &lt;&gt; null then
				_code := code;
				// Found code so return appropriate details.
				return code.code &amp; Tab &amp; code.description;
			else
				// We return null if we have found a translation group but no code and we aren't forcing the display.
				if _mtGrade &lt;&gt; self then
					_canDisplay := false;
					return null;
				endif;	
			endif;
		endif;
	endif;
	
	// Nothing found so return grade details.
	return self.code.String &amp; Tab &amp; self.description;

end;</source>
        <Parameter name="_mtGrade" type="CM_MTGrade"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_operatorGroup" type="CM_OperatorGroup"/>
        <Parameter name="_code" type="CM_MTGradeCode" usage="output"/>
        <Parameter name="_canDisplay" type="Boolean" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTranslationForOperatorOld" id="61507bfc-7dfa-4a37-9f59-fa0c0d6d52d7">
        <source>getTranslationForOperatorOld(_operator : CM_Operator; _operatorGroup : CM_OperatorGroup; _code : CM_MTGradeCode output) : String;
// -------------------------------------------
// Created 26 October 2004 by cnwdvb1
// -------------------------------------------
vars

	codeGroup	: CM_CodeGroup;
	code		: CM_MTGradeCode;
	group		: CM_OperatorGroup;

begin

	group := _operatorGroup;
	// Operator will overide operator group.
	if _operator &lt;&gt; null then
		codeGroup := _operator.allCodeGroups[CodeGroup_AvailabilityGrade];
		if codeGroup &lt;&gt; null then
			code := self.allCodeTranslations[codeGroup].CM_MTGradeCode;
			if code &lt;&gt; null then
				_code := code;
				// Found code so return appropriate details.
				return code.code &amp; Tab &amp; code.description;
			endif;
		else
			group := _operator.getOperatorGroupIfOnlyOne();
			if group = null then
				// Nothing found so return grade details.
				return self.code.String &amp; Tab &amp; self.description;
			endif;
		endif;
	endif;
		
	// This group can either the group from the operator because the operator
	// had one group and no translation of its own or a group passed in to the method
	// where there wasn't an operator.
	if group &lt;&gt; null then
		codeGroup := group.allCodeGroups[CodeGroup_AvailabilityGrade];
		if codeGroup &lt;&gt; null then
			code := self.allCodeTranslations[codeGroup].CM_MTGradeCode;
			if code &lt;&gt; null then
				_code := code;
				// Found code so return appropriate details.
				return code.code &amp; Tab &amp; code.description;
			endif;
		endif;
	endif;
	
	// Nothing found so return grade details.
	return self.code.String &amp; Tab &amp; self.description;


end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_operatorGroup" type="CM_OperatorGroup"/>
        <Parameter name="_code" type="CM_MTGradeCode" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
