    <JadeMethod name="addObjectsToTable" id="1b8c9640-bcee-474b-af0a-15d0ea325a2d">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// -------------------------------------------
// Created 21 September 2005 by cnwdvb1
// -------------------------------------------
vars

	rule		: CM_YAOverstowRule;
	terminal	: CM_Terminal;
	breakOut	: Boolean;

begin

	inheritMethod(_numItems);
	
	terminal := self.myTerminal;
	
	foreach rule in terminal.allYAOverstowRules discreteLock do
		self.addObjectToTable(rule, _numItems, breakOut);
	endforeach;
	


end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="buildCMIFOverstowAttribute" id="2b4f7290-edf9-42cf-a7ec-7e376d446111">
        <updating/>
        <source>buildCMIFOverstowAttribute(_type	: Integer) protected, updating;
// -------------------------------------------
// Created 21 September 2005 by cnwdvb1
// -------------------------------------------
vars

	cmifAttribute	: CMIF_YAOverstowAttributeType;

begin

	// We need a transient object for the list collection.
	create cmifAttribute transient;
	cmifAttribute.set(self.myTransientOverstowObj, _type);
	self.allAttributeTypes.add(cmifAttribute);
	
	if _type = TI_Test_Voyage then
		// Keep track of voyage attribute so we can decide
		// whether we need to show the voyage extra fields.
		self.myCMIFVoyageAttribute := cmifAttribute;
	endif;


end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
