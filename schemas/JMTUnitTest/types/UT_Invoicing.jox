    <JadeMethod name="checkRateEntryDetailsCSV" id="108b510d-c666-4ea3-bff8-342b0554d245">
        <source>checkRateEntryDetailsCSV(_allSelectedServices : ObjectArray input; _debtorNode : CM_DebtorNode input; _readInFileDetails : HugeStringArray input);

/*

Purpose:		Check that the extracted details are the same as the details loaded in	

Date			Who		Reason
17/10/2012 		cnwmh5	Initial creation

*/

vars

	rateEntry					: CM_RateEntry;
	obj							: Object;
	service						: CM_Service;
	
	rateEntryDetails			: HugeStringArray;
	notFoundArray				: HugeStringArray;	

	ts							: TimeStamp;
	str 						: String;
	currentRow					: Integer;
	
begin
	
	create rateEntryDetails transient;
	create notFoundArray transient;

	// do an extract of the details but don't write to the file
	foreach obj in _allSelectedServices do
		service := obj.CM_Service;
		rateEntry := _debtorNode.getServiceTimeRate(service, ts);
		//write service.String &amp; Tab &amp; service.name &amp; Tab &amp; ts.String &amp; Tab &amp; rateEntry.String;
		if rateEntry &lt;&gt; null then
			rateEntry.extractAsCSV(_debtorNode, service, rateEntryDetails);
		endif;
	endforeach;

	// check the file deatils that were loaded (_allFileRows) is the same as what has been extracted
	currentRow := 1;
	foreach str in _readInFileDetails do
		if not rateEntryDetails.includes(str) then
			notFoundArray.add(str.String);
		endif;
		currentRow := currentRow + 1;
	endforeach;
	
	// check to see if we have an error
//	if notFoundArray.size &gt; 0 then
//		app.writeLog("The following lines do not have a match in the file loaded:", LogINFO);
//	endif;
//	foreach str in notFoundArray do
//		app.writeLog(str, LogINFO);
//	endforeach;
	self.assertEqual(notFoundArray.size, 0);	
	
epilog

	delete rateEntryDetails;
	delete notFoundArray;
	
end;</source>
        <Parameter name="_allSelectedServices" type="ObjectArray" usage="input"/>
        <Parameter name="_debtorNode" type="CM_DebtorNode" usage="input"/>
        <Parameter name="_readInFileDetails" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="checkRateEntryDetailsTS" id="651331b4-52fb-4439-ab16-1ba21dfd2927">
        <source>checkRateEntryDetailsTS(_allSelectedServices : ObjectArray input; _debtorNode : CM_DebtorNode input; _readInFileDetails : HugeStringArray input; _ts : TimeStamp);

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Dec 2025 navhl20 Bug MTN-35943: POL - Importing Rates from CSV takes too long

*/

vars
	rateEntry					: CM_RateEntry;
	obj							: Object;
	service						: CM_Service;
	rateEntryDetails			: HugeStringArray;
	notFoundArray				: HugeStringArray;
	str 						: String;
	currentRow					: Integer;
begin
	
	create rateEntryDetails transient;
	create notFoundArray transient;

	// do an extract of the details but don't write to the file
	foreach obj in _allSelectedServices do
		service := obj.CM_Service;
		rateEntry := _debtorNode.getServiceTimeRate(service, _ts);
		//write service.String &amp; Tab &amp; service.name &amp; Tab &amp; ts.String &amp; Tab &amp; rateEntry.String;
		if rateEntry &lt;&gt; null then
			rateEntry.extractAsCSV(_debtorNode, service, rateEntryDetails);
		endif;
	endforeach;

	// check the file deatils that were loaded (_allFileRows) is the same as what has been extracted
	currentRow := 1;
	foreach str in _readInFileDetails do
		if not rateEntryDetails.includes(str) then
			notFoundArray.add(str.String);
		endif;
		currentRow := currentRow + 1;
	endforeach;
	
	self.assertEqual(notFoundArray.size, 0);	
epilog
	delete rateEntryDetails;
	delete notFoundArray;
end;</source>
        <Parameter name="_allSelectedServices" type="ObjectArray" usage="input"/>
        <Parameter name="_debtorNode" type="CM_DebtorNode" usage="input"/>
        <Parameter name="_readInFileDetails" type="HugeStringArray" usage="input"/>
        <Parameter name="_ts" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="compareCargoAllocTransMaps" id="8a656b89-ea2f-4524-a0f6-9f6cb60babf7">
        <source>compareCargoAllocTransMaps( _tran1, _tran2 : CM_TranMapCargoAllocation) protected;
/*

Purpose:			Compares Transaction Maps tran2 against tran1

Parameters:			

Return Value:		

Date				Who		Reason
15 November 2017	jlgmd1	Initial creation
22 March 2018		jlgmd1	Made error messages a little clearer

*/

vars
	cargoAlloc1, cargoAlloc2 : CM_InvoiceCargoAllocation;
	yardAlloc1, yardAlloc2 : CM_YardAllocation;
	iter1 : Iterator;
	yac1, yac2 : CM_YACriteria;
	notMatch : Boolean;
	qm1, qm2 : CM_QuantityMap;
	qr1, qr2 : CM_QuantityRangeMap;
	tmilm1, tmilm2 : CM_TranMapInvoiceLineMapping;
begin
	// Do some basic sanity checks
	self.assertEqualMsg(_tran1.allInvoiceAllocByTranType.size, _tran2.allInvoiceAllocByTranType.size, "allInvoiceAllocByTranType sizes do not match.");
	self.assertEqualMsg(_tran1.allInvoiceCargoAllocByPriority.size, _tran2.allInvoiceCargoAllocByPriority.size, "allInvoiceCargoAllocByPriority sizes do not match.");
	self.assertEqualMsg(_tran1.allInvoiceCargoAllocations.size, _tran2.allInvoiceCargoAllocations.size, "allInvoiceCargoAllocations sizes do not match.");
	
	//Go through all allocs from tran1 and compare them against tran2
	iter1 := _tran2.allInvoiceCargoAllocations.createIterator();
	foreach yardAlloc1 in _tran1.allInvoiceCargoAllocations do
		cargoAlloc1 := yardAlloc1.CM_InvoiceCargoAllocation;
		// Find our corrosponding alloc in tran2
		cargoAlloc2 := null;
		_tran2.allInvoiceCargoAllocations.startKeyGeq(cargoAlloc1.code, iter1);
		while iter1.next(yardAlloc2) do
			if yardAlloc2.code &lt;&gt; yardAlloc1.code then
				// No matching alloc
				break;
			endif;
			
			if yardAlloc2.description = yardAlloc1.description then
				// As close as we can get to a match
				cargoAlloc2 := yardAlloc2.CM_InvoiceCargoAllocation;
				break;
			endif;
			
			// repeat...
		endwhile;
		self.assertNotNullMsg( cargoAlloc2, cargoAlloc1.description &amp; " not found in AllocMap 2.");
		
		// Check criteria match
		foreach yac1 in cargoAlloc1.allCriteria do
			yac2 := cargoAlloc2.allCriteria[yac1.priorityValue];
			self.assertNotNullMsg(yac2, cargoAlloc2.description &amp; " Criteria does not exist in AllocMap 2.");
			self.assertEqual(yac1.code, yac2.code);
			self.assertEqual(yac1.myYACriteriaType, yac2.myYACriteriaType);
			self.assertEqual(yac1.myYAData.getDataDisplay(yac1.myYACriteriaType), yac2.myYAData.getDataDisplay(yac2.myYACriteriaType));
		endforeach;
		
		// Check Quantity Map
		qm1 := cargoAlloc1.myQuantityMap;
		if qm1 &lt;&gt; null then
			qm2 := cargoAlloc2.myQuantityMap;
			self.assertNotNullMsg(qm2, "Quality Map [" &amp; cargoAlloc2.description &amp; "] does not match AllocMap 1.");
			self.assertEqualMsg(qm1.myCalculationType, qm2.myCalculationType, "Quantity Map Calculation Type [" &amp; cargoAlloc2.description &amp; "] does not match AllocMap 1.");
				
			// Check Range Maps
			foreach qr1 in qm1.allQuantityRanges do
				qr2 := qm2.allQuantityRanges[qr1.rangeStart];
				self.assertNotNullMsg(qr2, cargoAlloc2.description &amp; " Quantity Range Map " &amp; qr1.getName &amp; " is missing from AllocMap 2.");
				
				// Check line mappings
				foreach tmilm1 in qr1.allTMInvoiceLineMappings do
					tmilm2 := qr2.allTMInvoiceLineMappings[tmilm1.mapValue];
					self.assertNotNullMsg(tmilm2, cargoAlloc2.description &amp; " Invoice Line Mapping [mapValue " &amp; tmilm1.mapValue.String &amp; "] on " &amp; qr1.getName &amp; " is missing from AllocMap 2.");
				endforeach;
					
			endforeach;
			
		endif;
	endforeach;
epilog
	delete iter1;
end;</source>
        <access>protected</access>
        <Parameter name="_tran1" type="CM_TranMapCargoAllocation"/>
        <Parameter name="_tran2" type="CM_TranMapCargoAllocation"/>
    </JadeMethod>
    <JadeMethod name="contractINCOCreate" id="601d5ff9-47dc-420d-9326-ab9f8d80b5cd">
        <source>contractINCOCreate(_realInvoiceINCO:CM_InvoiceINCOTerm output; _code : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 MAY 2023 navtnr20	TFS CR 57985 Task 57986: EUP - INCO Terms Unit Tests

*/
vars
	pxyInvoiceINCOTerm : CM_InvoiceINCOTerm;
	bank : CM_Bank;
begin
	//Create Invoice ship term
	bank := self.myBank;
    create pxyInvoiceINCOTerm transient;
