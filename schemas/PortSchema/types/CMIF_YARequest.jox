    <JadeMethod name="isISOGroup_Match" id="701122f4-a022-4046-a072-11a267a1edb2">
        <source>isISOGroup_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// 09/03/2010 cnwjre1a 23023	if self.isoGroup is non-null, use this otherwise use the group of the isoType
// -------------------------------------------
vars
	obj			: Object;
	isoType		: CM_ISOType;
begin
	if self.isoGroup = null then
		isoType := self.getISOTypeFromRequest();
		// Can't tell
		if isoType = null or isoType.myISOTypeGroup = null then
			return false;
		endif;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	if self.isoGroup = null then
		return _yaData.includes(isoType.myISOTypeGroup);
	else
		foreach obj in _yaData.allObjects do
			if obj.isKindOf(CM_ISOTypeGroup) and
			   obj.CM_ISOTypeGroup.code = self.isoGroup then
				return true;
			endif;
		endforeach;
	endif;
	
	return false;
end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isISO_Compare" id="5e24261a-eaea-4c28-ad6d-fed7885465f1">
        <source>isISO_Compare(isoType: Object;iso: String): Boolean;
begin
	return isoType.CM_ISOType.code.trimBlanks() = iso;
end;</source>
