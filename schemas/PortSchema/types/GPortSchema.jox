    <JadeMethod name="lcStatusStringToEnum" id="1e4f40e1-f56b-4d1e-aa9c-8de301fa4238">
        <source>lcStatusStringToEnum(_value : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     10 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _value = LC_StatusStr_Closed then
