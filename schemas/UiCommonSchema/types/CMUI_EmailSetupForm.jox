        <source>btnClose_click(btn: Button input) updating;
// -------------------------------------------
// Created 08 October 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	self.openCloseSelector(false);
	self.doubleClickedRow := 1;
	self.doSaveAddresses();
	self.doubleClickedRow := 2;
	self.doSaveAddresses();
	self.doubleClickedRow := 3;
	self.doSaveAddresses();
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
