    <JadeMethod name="setControlsForAddEdit" id="74b50781-7b5e-4efc-9c1a-6e21a4d38b46">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		  Reason
10 October 2022	navsks20  ChangeRequest 53424: MTN - MOB - Input Remarks - Jade

*/

vars
	theForm : SOP_TableMaintForm;
	tbl		: CM_EntryTable;
begin
	
	theForm := self.myForm;
	tbl		:= theForm.tblInput1;
	
	tbl.userInputEnabled := true;

	if theForm.mode = theForm.Mode_Add then 
		tbl.clearValues;
		tbl.enableRowByName(ETRow_Context);
		tbl.enableRowByName(ETRow_Text);
		tbl.enableRowByName(ETRow_SortOrder);
		tbl.enableRowByName(ETRow_NotAvailableForEntry);
		tbl.setFocus;
		tbl.moveFirst();
		tbl.gotFocus(tbl);		
		
		theForm.mulSelect1.setSelected(null);
	else
		self.showThumbnail(theForm.myCurrentObject.CM_DefinedText);
		tbl.enableRowByName(ETRow_Context);
		tbl.enableRowByName(ETRow_Text);
		tbl.enableRowByName(ETRow_SortOrder);
		tbl.enableRowByName(ETRow_NotAvailableForEntry);
	endif;
	
    tbl.cnEcResizeContents;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="6d0ddede-06c3-4f29-a200-20adc214bb73">
        <updating/>
        <source>setCtrlsForView() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 October 2022	navsks20  ChangeRequest 53424: MTN - MOB - Input Remarks - Jade

*/

vars
	theForm : SOP_TableMaintForm;
begin
	inheritMethod();
	
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.tblInput2.userInputEnabled := false;
	theForm.loadCmbContext(null);
epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="4b2b517b-91e3-457d-97bf-d53f3de76cda">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		  Reason
10 October 2022	navsks20  ChangeRequest 53424: MTN - MOB - Input Remarks - Jade

*/

vars
	theForm	: SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_DefinedText);
	
	theForm.shtTblInput1.caption := app.getErrorString(Details);
	theForm.initTblInput(theForm.tblInput1, ETDef_DefinedText);
	theForm.shtTblInput1.visible := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="0701b59e-c270-4f80-9bb4-57751b49aeb9">
        <updating/>
        <source>showThumbnail(pObj: CM_DefinedText) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		  Reason
10 October 2022	navsks20  ChangeRequest 53424: MTN - MOB - Input Remarks - Jade

*/

vars
	theForm : SOP_TableMaintForm;
	tbl		: CM_EntryTable;
begin
	
	theForm := self.myForm;
	tbl     := theForm.tblInput1;
	
	tbl.clearValues();
	theForm.loadCmbContext(pObj.context);
	tbl.setValueByName(ETRow_Context, app.getDefTextIntToStr(pObj.context));
	tbl.setValueByName(ETRow_Text, pObj.text);
	tbl.setValueByName(ETRow_SortOrder, pObj.sortOrder);
	tbl.setValueByName(ETRow_IsNotAvailableForEntry, pObj.isNotAvailableForEntry);
epilog

end;</source>
        <Parameter name="pObj" type="CM_DefinedText"/>
    </JadeMethod>
</Class>
