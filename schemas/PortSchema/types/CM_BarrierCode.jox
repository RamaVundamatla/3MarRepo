    <JadeMethod name="generateBarrierCode" id="67fcdca8-ef3c-4d9c-baf0-a20d77af79ec">
        <source>generateBarrierCode(_terminal : CM_Terminal) :String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2023	jlier1	Initial creation 57936

*/

constants
	
	MinimumBarrierNum	= 1;
	MaximumBarrierNum	= 99999;
	MaxTries		: Integer = 100;
vars
	stringSeed		: String;
	seed,
	range,
	pinInt,cnt 	: Integer;
	pinStr : String;
	barrierNumLength : Integer;
begin
	if _terminal = null then
		return null;
	endif;
	barrierNumLength:=CM_BarrierCode::code.getLengthForString;
	stringSeed := app.relativeMachineMicros().String.padZeros(20);
	seed := stringSeed[12:9].Integer;
	
	range := MaximumBarrierNum - MinimumBarrierNum;
	
	// Need to reserveLock this up front to prevent upgrade deadlocks
	reserveLock(_terminal.allBarrierCodes);

	while true do
		// Now letting JADE generate next seed each time around the loop, so we have a better
		// chance of getting a truly random number
		pinInt := app.random31(seed, range) + MinimumBarrierNum;
		pinStr := pinInt.String[1:barrierNumLength].padLeadingZeros(barrierNumLength);
		if (not _terminal.allPinNos.includesKey(pinStr)) then
			return pinStr;
		endif;
		
		cnt := cnt + 1;
		if cnt &gt; MaxTries then
			app.raiseCMException(CANNOT_GENERATE_BARRIER,  null, null);
		//	return false;
			break;
		endif;
		
	endwhile;
	
	return null;
epilog
	if _terminal &lt;&gt; null then
		unlock(_terminal.allBarrierCodes);
	endif;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setBarrierDT" id="a551cad4-70a3-49cd-9d77-320710768a12">
        <updating/>
        <source>setBarrierDT(_barrierDT : TimeStamp) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2023	jlier1	Initial creation 57936

*/

vars

begin
	self.barrierDT:=_barrierDT;
epilog

end;</source>
        <Parameter name="_barrierDT" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="94ab427c-62cb-4d9f-b4bb-e0826c93584f">
        <updating/>
        <source>setForCreate(_term : CM_Terminal; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2023	jlier1	Initial creation 57936

*/

vars

begin
	self.code:=self.generateBarrierCode(_term);
	if _passport.hasErrors then
		return;
	endif;
	if self.code = null then
		app.raiseCMException(CANNOT_GENERATE_BARRIER, null, null);
		return;
	endif;
	
	self.setMyTerminal(_term);
epilog

end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyTerminal" id="d54a1381-8b1c-4f1b-bdf9-0bdac0a6c479">
