    <JadeMethod name="delete" id="169bf7e4-13b7-4fb1-8278-cbe202b7725d">
        <updating/>
        <source>delete() updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 08/10/2002	cnwdad1		Hot Fix #249 for JADE 5.2.08 now deletes child controls
//							automatically - where developers have implemented
//							destructors on  controls to explicitly delete child
//							controls, an error 4 exception is raised.
// --------------------------------------------------------------------------------
begin
	if (not self.isInPainter()) then
//		delete self.myLabel;		// cnwdad1 08/10/2002.
		delete self.myDriver;
//		delete self.myPicture;		// cnwdad1 08/10/2002.
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="64221d9c-239f-4cd9-9f62-21e26821d8f5">
        <source>doRefresh();
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myDriver.refresh();
end;</source>
    </JadeMethod>
    <JadeMethod name="initializeDriver" id="991f616e-dd2e-4bdd-af62-2c6fd2a62ff7">
        <source>initializeDriver() protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		Initializes the reference to the processor object for the receiver.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.myDriver.initializeMe(self.myPicture, self.graphLineColor, self.minimumY);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initializeMe" id="a9347c05-1601-47df-a670-f4955c7a0608">
        <updating/>
        <source>initializeMe(pMinY : Real) updating;
// -----------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		Initializes the graph with a base value.
//
// Parameters:	pMinY - The minimum value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.minimumY	:=	pMinY;
	self.initializeDriver();
end;</source>
        <Parameter name="pMinY" type="Real"/>
    </JadeMethod>
    <JadeMethod name="move" id="5bf17591-64d4-4ce9-9875-4881201499c3">
        <source>move(x: Real; y: Real; width: Real; height: Real);
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(x, y, width, height);
	
	self.resizeMe();
end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="width" type="Real"/>
        <Parameter name="height" type="Real"/>
    </JadeMethod>
    <JadeMethod name="paint" id="fd8bfa89-0023-45c9-a4a6-3ea6221e6b1b">
        <updating/>
        <source>paint(cntrl: BaseControl input) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (not self.isInPainter()) then
		self.doRefresh();
	endif;
	
	inheritMethod(cntrl);
end;</source>
        <Parameter name="cntrl" type="BaseControl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="resizeMe" id="771a2d41-3411-44a6-b3b4-d09e59f458fa">
        <source>resizeMe();
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		Resizes the graph control's contents (i.e. the title label and
//				the graph picture controls).
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if self.graphTitle = null then
		self.myPicture.move(0, 0, self.width, self.height);
	else
		self.myLabel.move(0, 0, self.width, self.graphTitleHeight);
		self.myPicture.move(0, (self.graphTitleHeight + 1), self.width, (self.height - (self.graphTitleHeight + 1)));
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setGraphTitle" id="989ebb26-a331-4331-b6a6-6f1db0943e46">
        <updating/>
        <source>setGraphTitle(pTitle:String) updating;
// -----------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		Updates the title of the graph's title.  If the title is greater
//				than the maximum length of the title property, then the remainder
//				will be discarded.
//
// Parameters:	pTitle - The title of the graph.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	maximumLength	: Integer;
	
begin
	maximumLength	:=	self.class().jssGetStringPropertyLength("graphTitle");
	
	if pTitle.length &gt; maximumLength then
		self.graphTitle	:=	pTitle[1:maximumLength];
	else
		self.graphTitle	:=	pTitle;
	endif;
	
	self.myLabel.caption	:=	self.graphTitle;
end;</source>
        <Parameter name="pTitle" type="String"/>
    </JadeMethod>
    <JadeMethod name="setLineColor" id="8f4259c7-b3c1-4f7a-a90d-f33a33bcd806">
        <updating/>
        <source>setLineColor(pColor:Integer) updating;
// -----------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		Sets the color to be used to draw the graph line.
//
// Parameters:	pColor - The desired color of the line.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.graphLineColor	:=	pColor;
	self.initializeDriver();
end;</source>
        <Parameter name="pColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="401fe508-d4bb-441d-b85f-6d8f68719777">
        <source>updateMe(pNewValue : Real);
// -----------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		Updates the graph with a new current value.
//
// Parameters:	pNewValue - The new current value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.myDriver.updateMe(pNewValue);
end;</source>
        <Parameter name="pNewValue" type="Real"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="9d22d4cc-cfee-4502-995a-6fd5babf05ec">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (not self.isInPainter()) then
		if self.graphTitleHeight = 0 then
			self.graphTitleHeight	:=	21;
		endif;
		
		create self.myLabel transient;
		create self.myPicture transient;
		create self.myDriver transient;
		
		if self.graphTitle = null then
			self.myLabel.visible		:=	false;
		else
			self.myLabel.visible		:=	true;
			self.myLabel.caption		:=	self.graphTitle;
			self.myLabel.height			:=	self.graphTitleHeight;
			self.myLabel.fontBold		:=	self.graphTitleIsBold;
			self.myLabel.alignment		:=	Label.Alignment_Center_Middle;
			self.myLabel.borderStyle	:=	Window.BorderStyle_None;
			self.myLabel.show3D			:=	Control.Show3D_Not3D;
		endif;
		
		self.myLabel.parent			:=	self;
		self.myPicture.borderStyle	:=	Window.BorderStyle_None;
		self.myPicture.parent		:=	self;
		
		self.form.addControl(self.myLabel);
		self.form.addControl(self.myPicture);
		
		self.resizeMe();
		self.minimumY	:=	5;
		self.initializeDriver();
	endif;
	
	inheritMethod(cntrl, persistCntrl);
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
