			minX := point.x;
		endif;
	endforeach;
	
	// Calculate other points...
	point.set((minX + ((maxX - minX)/2)).Integer, bestPlace[1].y + height);
	bestPlace.add(point);
	
	//Build opposites... only needed for check if inside polygon.
