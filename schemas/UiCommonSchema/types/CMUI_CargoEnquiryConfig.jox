    <JadeMethod name="doTblDrop" id="2494bde5-ce9a-4725-8c8a-8f00c2fea57c">
        <updating/>
        <source>doTblDrop(table: Table input; win: Window input; x: Real; y: Real) updating, protected;

// 14/10/2011	cnwmh5	#28424 - UnComment the swapAttributes line

vars

begin
	if table.dragRow &gt; table.fixedRows then
		if table.row &lt;&gt; table.dragRow then
			self.setChanged();
		endif;
		self.myUserConfigTab.swapAttribute(table.row-1, table.dragRow-1);
		table.moveRow(table.row, table.dragRow);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doTblTabsSelect" id="1170539e-b84f-41e9-bc8a-ff4664348f60">
        <updating/>
        <source>doTblTabsSelect() updating, protected;
//12/05/2016	cnwma1 TFS #1975 SPT- Issue with configuring Cargo Enquiry Screen Tabs
vars
	column,
	row,
	row2,
	value	: Integer;
	table	: CM_DataTable;
	configTab : CM_UserConfigTab;
begin
	table := self.tblTabs;
	row := table.row;
	if row &lt;= table.fixedRows  or 
	   row &gt; table.rows then
		return;
	endif;

	self.myUserConfigTab := table.accessRow(row).itemObject.CM_UserConfigTab;
	self.btnAddTab.enabled := (table.rows &lt; MaxTabs);
	self.btnDeleteTab.enabled := (self.myUserConfigTab.allAttributes.size = 0);
	self.btnRenameTab.enabled := true;
	column := table.column;
	if column = 2 then
		value := table.accessCell(row, 2).text.Integer;
		if value &lt;&gt; self.myUserConfigTab.tabType then
			self.myUserConfigTab.setTabType(value);
			self.setChanged();
		endif;
		// if setting the Reefer option, clear it from all other rows
		if value &lt;&gt; 0 then
			foreach row2 in table.fixedRows+1 to table.rows do
				if row2 &lt;&gt; row then
					table.accessCell(row2, 2).text := '0';
					configTab := table.accessRow(row2).itemObject.CM_UserConfigTab; //12/05/2016 cnwma1 TFS #1975
					configTab.setTabType(0);										//12/05/2016 cnwma1 TFS #1975
				endif;
			endforeach;
		endif;
	endif;
	
	self.enableTabsArrows();
	
	self.populateTableAttributes();
end;

</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUseDefault" id="63365d8b-a04b-4d53-b7bc-4927b63345c8">
        <updating/>
        <source>doUseDefault(_value : Boolean) updating, protected;
// if set true, recreate the proxy from the cargo type XML for ent table defs and show this
// if set false, set isChanged and reset the proxy isDefault
vars

begin
	if self.myCargoType = null then
		return;
	endif;
	
	if _value then
		delete self.myProxyUserCargoType;
		self.showTabsForCargoType(true);
	else
		self.myProxyUserCargoType.isDefault := false;
	endif;
	self.isFormChanged := true;
	self.btnSave.enabled := true;
end;
</source>
        <access>protected</access>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
