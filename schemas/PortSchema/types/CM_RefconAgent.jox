    <JadeMethod name="sendTelegram" id="b106996a-d501-4854-bc01-71ecf92631ba">
        <updating/>
        <source>sendTelegram(_telegram : Binary) updating;

vars

begin
	if self.myTcpMsg &lt;&gt; null and	//cnwrs1 par 25391 17 Aug 2010
	   self.isConnected then
		if _telegram[9:1] &gt; #06.Binary[1:1] or _telegram.length &lt; 9 then
			self.closeConnect;
			self.logMonitor("Invalid message will close and open Connection.");
			self.openConnect;
			return;
		endif;
	endif;
	inheritMethod(_telegram);
end;
</source>
        <Parameter name="_telegram" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="sizeTypeString" id="da9e177b-382a-45a4-8c99-c152d3d9a4c8">
        <source>sizeTypeString(_container : CM_Container) :String protected;

vars
	tLength,tHeight			: Integer;
	tType					: String[2];
	message					: String;
	
begin
	// PAR 16415 CCMS 1029
	if _container.is45 then
		tLength := 45;
	elseif _container.is40 then
		tLength := 40;
	elseif _container.is30 then
		tLength := 30;
	elseif _container.is53 then
		tLength := 53;
	else
		tLength := 20;
	endif;
	
	if _container.sizeAttributes.bitAnd(ISO_HEIGHT_4) &lt;&gt; 0 then
		tHeight := 40;
	elseif _container.sizeAttributes.bitAnd(ISO_HEIGHT_43) &lt;&gt; 0 then
		tHeight := 43;
	elseif _container.sizeAttributes.bitAnd(ISO_HEIGHT_8) &lt;&gt; 0 then
		tHeight := 80;
	elseif _container.sizeAttributes.bitAnd(ISO_HEIGHT_86) &lt;&gt; 0 then
		tHeight := 86;
	elseif _container.sizeAttributes.bitAnd(ISO_HEIGHT_96) &lt;&gt; 0 then
		tHeight := 96;
	endif;
	if tLength = 40 and tHeight = 0 then
		tHeight := 86;
	endif;
	tType := "RF";
	message := tLength.String.padZeros(2)&amp;tHeight.String.padZeros(2)&amp;tType;
	return message[1:6];
end;</source>
        <access>protected</access>
        <Parameter name="_container" type="CM_Container"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="sysNotification" id="57e21e3f-acdb-460c-bd2e-27a0c3e61310">
        <updating/>
        <source>sysNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating;
// cnwdvb1 28 April 2003 
// 14/12/2009	cnwdap1		CCMS MES 1007 Any tracked item can now be a reefer
// 02/08/2013	cnwdap1		PAR #32074 Don't process notifications for transactions that aren't at the terminal the agent is running for
vars
	transaction		: CM_TITransaction;
	//container		: CM_Container;		// CCMS 1007
	container		: CM_TrackedItem;	// CCMS 1007
	message			: Binary;
begin
	if not theObject.isKindOf(CM_TITransaction) then
		return;
	endif;
	
	transaction := theObject.CM_TITransaction;
	
	//if transaction.myTrackedItem = null or not transaction.myTrackedItem.isKindOf(CM_Container) then	// CCMS 1007
	if transaction.myTrackedItem = null then															// CCMS 1007
		return;
	endif;
	
	//container := transaction.myTrackedItem.CM_Container;	// CCMS 1007
	container := transaction.myTrackedItem;					// CCMS 1007
	
	if not container.isRefConMonitored then					// CCMS 1007
		return;
	endif;
	
	if not app.getMyTerminalDO_NOT_USE.allOnsiteTIsByIdCargoType.includes(container) then	// PAR #32074
		return;																				// PAR #32074
	endif;																					// PAR #32074
	
	if transaction.isKindOf(CM_DisconnectPower) then
	
		message := self.createReeferDataTelegram(container, Reefer_Delete);
		self.sendTelegram(message);
	
	elseif transaction.isKindOf(CM_ConnectPower) then
	
		message := self.createReeferDataTelegram(container, Reefer_Data);
		self.sendTelegram(message);
		
		//try to get the first temp asap
		message := self.createReeferDataTelegram(container, Reefer_Monitor_Request);
		process.sleep(2);
		self.sendTelegram(message);
	
	elseif transaction.isKindOf(CM_Edit) then
	
		if container.isConnected then	//this is an update - only do if connected
			message := self.createReeferDataTelegram(container, Reefer_Data);
			self.sendTelegram(message);
		endif;
	
	else
		//return;
	endif;
	
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tempString" id="d910cc22-a8f8-4e1b-a7b6-04f1e52728bc">
        <source>tempString(_temp:Real):String protected;

vars
	message			: String;
	tString			: String;
	tReal			: Real;
	tInteger		: Integer;
	
begin
	//message := (_temp.userNumberFormat($CM_Temperature)&amp;"C").String.padLeftBlanks(9);
	// AER par 14632
	message := (_temp.asStringJMTWithPrecision(PRECISION_TEMPERATURE, false)&amp;"C").String.padLeftBlanks(9);
	return message[1:9];
end;</source>
        <access>protected</access>
        <Parameter name="_temp" type="Real"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="timeOfAct" id="ee47bce2-1fba-4a72-bea3-be1a745c0a9b">
        <source>timeOfAct(_time:TimeStamp):String protected;
// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//							Send in UTC
// ---------------------------------------------------------------------------

vars
	utcTime : TimeStamp;
	message: String;
begin
	utcTime := _time.localToUTCTime();
	message := utcTime.date.formatAsYYYYMMDD()&amp;utcTime.time.format("HHmmss");
	//message := _time.date.formatAsYYYYMMDD()&amp;_time.time.format("HHmmss");
	return message;
end;</source>
        <access>protected</access>
        <Parameter name="_time" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="75b37e14-0871-466b-bf77-9b3b070d2148">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//----------------------------------------------------------------
//	Created:	30 June 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*

Date		Who		Reason
08 Oct 2008	cnwkpd1	PAR #18009 - Prevent transient leaks

*/

vars
	str		: String;
	event	: Integer;
	sa		: StringArray;
	message	: Binary;
begin
	
	if theObject &lt;&gt; app.getMyTerminalDO_NOT_USE then
		
		return;
	endif;
		
	event := app.getMyTerminalDO_NOT_USE.getEventFromTerminalEvent(eventType);
	if event = EVENT_REFCON_REQUEST then
		
		//create sa transient;
		sa := userInfo.String.getTokens();
		self.requestIDs.clear;
		sa.copy(self.requestIDs);
		foreach str in sa do
			message := self.createReeferRequest(str);
			process.sleep(2);
			
			self.sendTelegram(message);
		endforeach;
		
	endif;


epilog
	delete sa;		// PAR #18009
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="ventString" id="daef9964-d8d5-441e-b8f6-f91a84c07fd4">
        <source>ventString(_vent:Real):String protected;

vars
	message: String;
begin
	if _vent = 0 then
		message := "         ";
	else
	//	message := (_vent.userNumberFormat($CM_Temperature)&amp;"M").String.padLeftBlanks(9);
	// AER Par 14632
		message := (_vent.asStringJMTWithPrecision(PRECISION_TEMPERATURE, false)&amp;"M").String.padLeftBlanks(9);
	endif;
	return message[1:9];
end;</source>
        <access>protected</access>
        <Parameter name="_vent" type="Real"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="xHandler" id="a61f1c2d-f6a9-45f7-b141-23f9c61ec463">
        <updating/>
        <source>xHandler(_exObj : Exception) : Integer updating;

// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11 Jul 2019	jlgrs1	TFS45051 JMT terminate on a SDS secondary exception ie a takeover has happened.
// ---------------------------------------------------------------------------

vars
	errStr	: String;
	msg : String;
begin
	if _exObj.errorCode = 1228 or 
	   _exObj.errorCode = 1295 or 
	   _exObj.errorCode = 3015 or 
	   _exObj.errorCode = 3037 then
		abortTransaction;
		abortTransientTransaction;
		msg := class.name&amp;'::'&amp;method.name&amp;' SDS Exception, cant continue,'&amp;_exObj.errorCode.String&amp;' '&amp;_exObj.extendedErrorText&amp;' processApp= '&amp;process.persistentApp.name&amp;' '&amp;process.userInfo&amp;' ('&amp;process.node.String&amp;", "&amp;process.String&amp;')';
		app.writeLog(msg, LogFATAL);	//25 Nov 2019	NDL	TFS 47053
		
		terminate;
	endif;

	//Our exceptions
	if _exObj.isKindOf(CM_Exception) then
	   	abortTransaction;
		errStr := 'Error (' &amp; _exObj.errorCode.String &amp; '). ' &amp; _exObj.extendedErrorText;
		self.logMonitor(errStr);
		return Ex_Resume_Next;
	endif;
	
	//all other exceptions
	abortTransaction;
	self.logMonitor('Refcon error (' &amp; _exObj.errorCode.String); 
	app.doDumpStack(_exObj); //rs 7 October 2002
	self.buffRemain := null;
	return Ex_Abort_Action;

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
