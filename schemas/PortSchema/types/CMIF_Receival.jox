    <JadeMethod name="setMyProxyTrackedItem" id="5003af74-e3db-426f-8ca9-483a79eca3cd">
        <updating/>
        <source>setMyProxyTrackedItem(pTI : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:     16 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pTI &lt;&gt; null then
//		pTI.raiseExceptionIfNotProxy(method);
		pTI.raiseExceptionIfNotTransient(method);
	endif;

	self.myProxyTrackedItem := pTI;
	
end;</source>
