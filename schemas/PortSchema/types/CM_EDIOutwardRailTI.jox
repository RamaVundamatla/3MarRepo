    <JadeMethod name="setForCreate" id="81f5b40c-a548-47ed-9a96-d9012e60e06b">
        <updating/>
        <source>setForCreate(pTI : CM_TrackedItem) updating;
//--------------------------------------------------------------
//Created: December 2001 By: cnwgd1
//--------------------------------------------------------------
// This method takes TI's from CMS and converts data to EDI TIs
// The release data should have been set on the TI before this is called
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
vars
	request			: CM_DeliveryRequest;
	dest			: CM_ConsigneeConsignor;
	obj				: Object;
	job				: CM_RailJob;
	jobTI			: CM_TrackedItem;
	fpCode			: String;
	op				: CM_Operator;
begin

	if pTI = null then
		app.raiseCMException1(ERR_NO_OBJECT, 'Tracked Item', null, null);
		return;
	endif;

	if pTI.isEmpty then
		self.fullOrMT := "E";
	else
		self.fullOrMT := "F";
	endif;
	self.imex	:= self.getTranslationForIMEX(pTI);
	self.bookingReleaseNo	:= pTI.deliveryRelease;
	self.setId(pTI.id);
	self.isoType 			:= pTI.isoTypeDesc[1:30]; // PAR 17162 AKB2008JUN //this solves the par 16874 (string too long error) cnwdz2 
	if pTI.jobRailRelease &lt;&gt; null then
		self.remarks 		:= pTI.remarks &amp; ' ' &amp; pTI.jobRailRelease.remarks;
	else
		self.remarks 		:= pTI.remarks;
	endif;
	self.weight 			:= pTI.totalWeight;
	self.wagon 				:= pTI.wagon;
	self.operator 			:= pTI.operatorCode;
	self.operatorDesc 		:= pTI.operatorDescription;
	self.loadDT	 			:= pTI.moveDT;
	dest					:= app.myRoot.allConsigneeConsignors[pTI.consignee];
	if dest &lt;&gt; null then
		self.destination	:= dest.description;
	endif;

	//Use the con. voyage code if there is one
//	self.voyage 	:= pTI.consignorVoyageCode;	// cnwrl1 09/06/2010 PAR 24299 - what it was
	// make sure the manual collection on CM_EDIConfig gets maintained
	self.setVoyageCode( pTI.consignorVoyageCode );
	//No Con. voyage code then try the voyage code
//	if self.voyage = null then			// cnwrl1 09/06/2010 PAR 24299 - what it was
	if self.getVoyageCode() = null then
//		self.voyage := pTI.voyageCode;	// cnwrl1 09/06/2010 PAR 24299 - what it was
		self.setVoyageCode( pTI.voyageCode );
	endif;
	
	if pTI.releaseRequest &lt;&gt; null then
		self.freightPayerCode	:= pTI.releaseRequest.freightPayerCode;
	endif;

	self.setStatus(CM_EDIFile.EDI_STATUS_LOADED);	

end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setVoyageCode" id="db40b3d0-0fd7-4e6f-b279-16c6f13c15b0">
        <updating/>
        <source>setVoyageCode( _value : String ) updating;
/*
Date			Who		Reason
09 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
11 April 2013	cnwcs5	Make use of local variables
*/
vars
	config			:CM_EDIConfig;
	coll			:CM_EDITIsByVoyageCodeDict;
	code, codeUpper	:String;
begin
	// need to make sure the manual collection on CM_EDIConfig gets maintained correctly, this collection
	// keeps track of all EDITrackedITems that have some connection to a voyageCode of some kind.
	config := self.myEDIConfig;
	
	if config &lt;&gt; null then
		coll := config.allEDITrackedItemsByVoyageCode;
	endif;
	
	code := self.voyage;
	
	// remove the previous non-null value from this collection
	if code &lt;&gt; null and coll &lt;&gt; null then
		codeUpper := code.toUpper;
		
		if coll.includesKey( codeUpper, self ) then
			coll.removeKeyEntry( codeUpper, self, self );
		endif;
	endif;

	// now change it and add this new value to the manual collection (if not null).
	code		:= _value[ 1 : self.voyage.maxLength ];
	self.voyage	:= code;
	
	if code &lt;&gt; null and coll &lt;&gt; null then
		codeUpper := code.toUpper;
		
		if not coll.includesKey( codeUpper, self ) then
			coll.putAtKey( codeUpper, self, self );
		endif;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
