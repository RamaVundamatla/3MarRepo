    <JadeMethod name="doCoparn_mtrel_dates" id="aeda1fb8-ac8d-4e5f-93cf-f575c46b12fc">
        <source>doCoparn_mtrel_dates(_sender, _mode, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _releaseNo:String; 
						_reqTS, _estReqTS :TimeStamp; _mt :Character; _operator :CM_Operator; _ediPartyRules :CM_EDIPartyCoparnRules; _hasRequestDTMRule :Boolean)protected;
/*
Date		        Who		Reason
01 December 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
23/04/2012	        cnwcs5	CCMS POL 2172 / par 29480 - coparn release updates
9 January 2013      cnwgb1  CCMS POL 2216/ par 30902 Heavy Rated Releases      
// 31 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
*/
constants
	MTGRADE			= 'DAIRY';
	ISOTYPE 		= '22G1';
	QUANTITY		= 10;
vars
	text	:String;
	ediFile	:CM_EDIFile;
	ediData	:CM_EDIData;
	ediTI	:CM_EDIRequestHeaderTI;
	release	:CM_BulkRelease;
	ediItemTI : CM_EDIRequestDetailTI;
	ediRelReq : CM_EDIReleaseRequestTI;
	item	:CM_ReserveSelection;
	isoType	:CM_ISOType;
	tempStr :String;
	tokens 	:StringArray;
	type	:String;
	reqDate	: TimeStamp;
	ediItem : CM_EDITrackedItem;
begin
	// ---------------------------------------
	// delete the release if it already exists
	// ---------------------------------------
	if _mode = '9' then
		self.deleteReleaseRequest (_releaseNo);
		type := 'A';
	elseif _mode = '5' then
		type := 'U';
		
		release := self.getReleaseRequest (_releaseNo);
		self.assertNotNull (release);
		
		// update the request date so we know if it gets updated or not
		reqDate.setDate ('01/01/2012'.Date);
		reqDate.setTime ('12:00'.Time);
		beginTransaction;
		release.setRequestDate (reqDate);
		commitTransaction;
	endif;
	// ---------------------------------------
	// get edi file to load (add)
	// ---------------------------------------
	text := self.zCoparn_mtrel_dates (_sender, _mode, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _releaseNo, MTGRADE, ISOTYPE, QUANTITY.String, _reqTS, _estReqTS, _mt);
	// ---------------------------------------
	// load edi file to create EDI tracked items
	// ---------------------------------------
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN"&amp;method.name);
	
	self.assertNotNull(ediFile);
	// ---------------------------------------
	// find the release request ediData
	// ---------------------------------------
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');
	// ---------------------------------------
	// find the edi tracked item
	// ---------------------------------------
//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	if _reqTS &lt;&gt; null and _hasRequestDTMRule then
		// we can only check request date if it was in the file
		reqDate := _reqTS;
	else
		reqDate := null;	// not checked
	endif;
	if ediData.isKindOf(CM_EDIDataGateDoc) then
		foreach ediItem in ediData.allEDITrackedItems do
			if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
				ediTI := ediItem.CM_EDIRequestHeaderTI;
				break;
			endif;
		endforeach;
		self.assertNotNullMsg(ediTI, 'EDI tracked items not created');
		ediItemTI := self.getMatchingEDIItemTI(ediTI);
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		self.doCheckEDITiRequestMulti(ediTI, ediItemTI, type, _releaseNo, _voyageCode, _vesselName,  _operator.code,_consignorCode, _consigneeCode, ISOTYPE, null,  null, null, QUANTITY, _ediPartyRules, reqDate, _estReqTS, false, false, false, true, false, true);
	endif;
	if ediData.isKindOf(CM_EDIDataReleaseRequest) then
		foreach ediItem in ediData.allEDITrackedItems do
			if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
				ediRelReq := ediItem.CM_EDIReleaseRequestTI;
				break;
			endif;
		endforeach;
		self.assertNotNullMsg(ediRelReq, 'EDI tracked items not created');
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		self.doCheckEDITIReleaseRequest(ediRelReq, type, _releaseNo, _voyageCode, _vesselName,  _operator.code,_consignorCode, _consigneeCode, ISOTYPE, null,  null, null, QUANTITY, _ediPartyRules, reqDate, _estReqTS, false, false, false, true, false, true);
	endif;
	// ---------------------------------------
	// check values on EDI TI
	// ---------------------------------------
	
//	self.doCheckEDITiRequestMulti (ediTI, ediItemTI, type, _releaseNo, _voyageCode, _vesselName,  _operator.code,_consignorCode, _consigneeCode, ISOTYPE, null,  null, null, QUANTITY, _ediPartyRules, reqDate, _estReqTS, false, false, false, true, false, true);	
	
	if type = 'U' then
		reqDate := release.dateRequested;
	endif;
	
	// ---------------------------------------
	// do verify (all edi data)  
	// ---------------------------------------
	self.ediVerify(ediFile);
	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);
	// ---------------------------------------
	// load to DB
	// ---------------------------------------
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	// ---------------------------------------
	// find the release
	// ---------------------------------------
	release := self.getReleaseRequest (_releaseNo);
	
	self.assertNotNull (release);
	// ---------------------------------------
	// do standard checks
	// ---------------------------------------
	self.doCheckPartyRules_AddRelease (release, _ediPartyRules, false, false, false);
	
	self.assertTrueMsg (release.releaseByType, 'Release by type is not set');
	self.assertEqualMsg (release.code, _releaseNo, 'Release number is incorrect');
	self.assertEqualMsg (release.myVoyage.code, _voyageCode, 'Voyage code is incorrect');
	self.assertEqualMsg (release.myOperator, _operator, 'Operator is incorrect');
	// check ediFile collection has been updated
	self.assertTrueMsg (release.allEDIFiles.includes (ediFile), 'Update the edi files collection !!!');
	// ===============
	// check dates 
	// ===============
	self.assertNotNullMsg (release.dateRequested, _sender &amp; '/' &amp; _releaseNo &amp; '(' &amp; type &amp; ')  request date should never be null');

	if _hasRequestDTMRule and _reqTS &lt;&gt; null then
		// there was DTM+133 in file and the sender has a DTM for for request date
		// request date should always be updated
		self.assertEqualMsg (release.dateRequested, _reqTS, _sender &amp; '/' &amp; _releaseNo &amp; '(' &amp; type &amp; ')  expected request date to match DTM+133 in file');
	else		
		if type = 'A' and _reqTS &lt;&gt; null then
			// there was DTM+133 in file but sender does not have rule - date will be quite close to NOW but we can't be sure what it is
			self.assertNotEqualMsg (release.dateRequested, _reqTS, _sender &amp; ' expected request date NOT to match DTM+133 in file');
		endif;
		
		if type = 'U' then
			self.assertEqualMsg (release.dateRequested, reqDate, _sender &amp; '/' &amp; _releaseNo &amp; ' expected request date to NOT change');
		endif;
	endif;
epilog
	delete tokens;
end;</source>
        <access>protected</access>
