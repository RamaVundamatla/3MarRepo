    <JadeMethod name="cnwdad1_Test_File_Attributes" id="420bd52b-eb8e-4bc2-a5ea-12ecc3d7d996">
        <source>cnwdad1_Test_File_Attributes();
// -----------------------------------------------------------------------------
// Created:		18 January 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	theFolder	: FileFolder;
	theFile		: File;
	attributes	: String;
	startTime	: Integer;
	
begin
	startTime	:=	app.clock();
	
	create theFolder transient;
	create theFile transient;
	
	theFolder.fileName	:=	"c:\temp";
	
	if theFolder.isAvailable() then
		if theFolder.isValidPathName(theFolder.fileName) then
			attributes			:=	theFolder.jssGetAttributes();
			write "Attributes of " &amp; theFolder.fileName &amp; ": " &amp; attributes;
		else
			write theFolder.fileName &amp; " is not a valid path name.";
		endif;
	else
		write theFolder.fileName &amp; " is not available.";
	endif;
	
	theFile.fileName	:=	"c:\temp\jade.log";
	
	if theFile.isAvailable() then
		attributes			:=	theFile.jssGetAttributes();
		write "Attributes of " &amp; theFile.fileName &amp; ": " &amp; attributes;
	else
		write theFile.fileName &amp; " is not available.";
	endif;
epilog
	delete theFolder;
	delete theFile;
	
	write "File attributes completed in " &amp; startTime.jssClockDifference().String &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_FreeDiskAndMemory" id="f10694c6-2c8e-42a5-b217-19b6b05b5e80">
