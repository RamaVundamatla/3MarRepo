    <JadeMethod name="setupForm" id="ceaba4d8-d2e2-406c-addd-0776f797e323">
        <updating/>
        <source>setupForm() updating;
// -------------------------------------------
// Created 10 May 2004 by cnwdvb1
//03 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
// -------------------------------------------
vars

begin
	inheritMethod();
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.cmbFileFormat.addItem("CSV");
	self.cmbFileFormat.addItem("HTML");
	self.cmbFileFormat.listIndex := 2;

	self.frmMain.width := self.clientWidth;
	self.frmMain.height := self.clientHeight - self.frmToolbar.height - 4;
	self.frmMain.backColor := self.backColor;
	self.initTable();
	self.initReport();

end;</source>
    </JadeMethod>
