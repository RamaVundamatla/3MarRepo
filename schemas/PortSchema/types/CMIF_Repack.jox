<Class name="CMIF_Repack" id="46058f8a-ac57-4b24-a2ac-2a24b7490f65">
    <superclass name="CMIF_Receival"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="allChildren" id="9c88fab6-2df8-42df-b966-6220c12152c2">
        <memberTypeInverse/>
        <type name="CM_TISet"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myOperator" id="87ab6057-e7a2-41c7-a43e-e8ea4e86669c">
        <embedded/>
        <type name="CM_Operator"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myProxyEmptyContainer" id="a05eca8e-bc21-444c-968a-3a115b66a054">
        <embedded/>
        <type name="CM_Container"/>
        <text>Container that is current empty that is to be repacked</text>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myProxyFullContainer" id="bf8d0fb6-de93-47e4-aea0-bc21a0b8a392">
        <embedded/>
        <type name="CM_Container"/>
        <text>The container that is current full but about to be emptied.</text>
    </ImplicitInverseRef>
