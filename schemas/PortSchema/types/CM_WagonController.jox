    <JadeMethod name="getLocationsForSpan" id="2443d278-e6cb-49a8-85ce-3618692e614b">
        <source>getLocationsForSpan(_vertSpan, _horzSpan, depthSpan : Integer; _lcDict : CM_LCSet input);
/*
----------   ----------  --------------------------------------------------
Created:	22 November 2006 By cnwth2

Purpose:	vertical span = N/A (this would be rail lines apart if required, but unlikely)
			horizontal span = number of wagons apart
			depth span = N/A (and extremely unlikely to ever be needed) 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
23 July 2015	NDL	Par 36568	- remove use of LC collection with 'myTerminalArea' as key, replace with LC Set
*/
vars
	wagonController		: CM_WagonController;
	wagonPos,
	myWagonsPosition,
	minWagonIdx,
	maxWagonIdx			: Integer;
	railLine			: CM_RailLine;
	wagon				: CM_Wagon;
	doLog				: Boolean;
begin
	
	railLine := self.myWagon.myRailLine;
	if railLine = null then
		return;//not confirmed
	endif;
	
	myWagonsPosition := railLine.allWagons.indexOf(self.myWagon);
	minWagonIdx := (myWagonsPosition - _horzSpan).max(1);
	maxWagonIdx := (myWagonsPosition + _horzSpan).min(railLine.myRailArea.numberOfWagonPositions);
	
	doLog := app.myPassport.myActivityCapture.captureDiagnositcs;
	if doLog then
		app.myPassport.myActivityCapture.logDiagnostic('GetLocationForSpan - from ' &amp; self.getFullId &amp; CrLf &amp;
													'minWagonIdx=' &amp; minWagonIdx.String &amp; ', maxWagonIdx=' &amp; maxWagonIdx.String); 
	endif;
	foreach wagonPos in minWagonIdx to maxWagonIdx do
		wagon := railLine.getWagonAtPosition(wagonPos);
		if wagon = null then
			continue;
		endif;
		
		foreach wagonController in wagon.allLocationsControllersArray do
			if (not _lcDict.includes(wagonController)) then
				if doLog then
					app.myPassport.myActivityCapture.logDiagnostic('Adding wagonController for span :' &amp; wagonController.getFullId());
				endif;
				_lcDict.add(wagonController);
			endif;
		endforeach;
	endforeach;
	
end;




</source>
        <Parameter name="_vertSpan" type="Integer"/>
        <Parameter name="_horzSpan" type="Integer"/>
        <Parameter name="depthSpan" type="Integer"/>
        <Parameter name="_lcDict" type="CM_LCSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="4d3d119a-30ce-447c-9d05-478140b763e7">
        <source>getMyTerminal() : CM_Terminal;
/*
Purpose:			

Date		Who		Reason
10FEB2022	NAVAB1	TFS 51855
01NOV2023	navmd1	TFS 61063 - Unit Test - Fix 1090 when myWagon is null
*/

vars
	terminal : CM_Terminal;
begin
	if self.myWagon &lt;&gt; null then
		terminal := self.myWagon.myTrainOutwards.myTerminal;
		if terminal = null then
			terminal := self.myWagon.myTrainInwards.myTerminal;
		endif;
	endif;
	
	if terminal = null then
		terminal := inheritMethod();
	endif;
	
	return terminal;

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
