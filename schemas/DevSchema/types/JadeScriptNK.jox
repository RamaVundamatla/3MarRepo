    <JadeMethod name="printMthdContent" id="b6a09fc5-6392-4b1f-888c-4c0607083596">
        <source>printMthdContent();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2025	navnk30	Initial creation

*/

vars
	cls			: Class;
	mthd		: Method;
	srcLine		: String;
	startIndex	: Integer;
begin
	cls := self.class;
	foreach mthd in cls.cnGetMethods do
		startIndex := 1;
		srcLine := mthd.getSource().scanUntil(";", startIndex);
		write mthd.name &amp; " : " &amp; srcLine &amp; CrLf;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="refresh_Xlat_0002137" id="c5527a77-81a5-4534-8d01-32653c7ef623">
        <source>refresh_Xlat_0002137();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2024	navnk30	Initial creation

*/


vars
	transAgent : CM_TranslationAgent;
	tmpArray : StringArray;
begin
	app.initialize();
	
	write app.getErrorString(CM_INCO_Terms);
	write app.getErrorString(CM_Storage_Operator);
	return;

	create transAgent transient;
	create tmpArray transient;

	tmpArray.add('Xlat_0002137 ');
	transAgent.trxLoadSpecificTranslations(tmpArray);
	
	return;
epilog
	delete tmpArray;
	delete transAgent;
end;</source>
    </JadeMethod>
