		vbts := self.myJRWVBDetailsObj.myVehicleBookingTimeSlot;
		if vbts &lt;&gt; null then
			return vbts.bookingTSstart.date;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
