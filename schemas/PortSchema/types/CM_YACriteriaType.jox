    <JadeMethod name="patternTokensAreObjects" id="13ba4a28-2928-4816-bbce-5d67a2548f5a">
        <source>patternTokensAreObjects( nameDict: ObjectLongNameDict; tokens: StringArray input ):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 February 2016	cnwndl1	Initial creation	Par 37510

*/

vars

	token : String;
	obj : Object;

begin

	if nameDict = null or nameDict.isEmpty then	// no objects.
		return false;
	endif;

	foreach token in tokens do
		if token.containsOneOf("*!") then
			obj := nameDict[token.toUpper()];
			if obj = null then
				return false;
			endif;
		endif;
	endforeach;
	
	return true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="nameDict" type="ObjectLongNameDict"/>
        <Parameter name="tokens" type="StringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeMyDataObject" id="1ed14bca-6dcf-4e40-a65b-88884ea97171">
        <source>removeMyDataObject(_object: Object);
// -------------------------------------------
// Created 28 September 2005 by cnwrs1
// -------------------------------------------
vars

	criteria : CM_YACriteriaPriority;

begin

	if self.isTransportModeType or self.isPrimitiveValue then
		return;
	endif;
	
	foreach criteria in self.allYACriteria discreteLock do
		if criteria.myYAData &lt;&gt; null and 
		   criteria.myYAData.CM_YADataObjects.includes(_object) then // par 16733 AER 30/07/2008
			criteria.myYAData.CM_YADataObjects.allObjects.remove(_object);
		endif;
	endforeach;

	foreach criteria in self.allYAPriorities discreteLock do
		if criteria.myYAData &lt;&gt; null and 
		   criteria.myYAData.CM_YADataObjects.matches(_object) then // par 16733 AER 30/07/2008
			criteria.myYAData.CM_YADataObjects.allObjects.remove(_object);
		endif;
	endforeach;

end;</source>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="resolveIntendedRelModePattern" id="21d89be6-d1de-4783-ae1b-2e0b10401af2">
        <source>resolveIntendedRelModePattern(_pattern: String; _valueArray: IntegerArray input);
// 24/02/2011	cnwmh5	#26912
// If the pattern has no wildcards, then resolve the transport modes into objects and add to _objectSet
vars
	name: String;
	mode: Integer;
	tokens: StringArray;
	pattern: CMIF_YAPattern;
begin
	// If this there are wildcard patterns then just return.
	// This will need to be resolved during autoplanning
	create pattern transient;
	pattern.setPattern(_pattern, CMIF_YAPattern.YAPattern_Wildcard);
	if pattern.hasWildcard then
		return;
	endif;
	
	create tokens transient;
	pattern.getTokens(pattern.pattern, tokens);
	foreach name in tokens do
		mode := app.intendedReleaseModeString2Enum(name);
		if mode = null then
			//app.raiseCMException2(ErrYACriteriaNotFound, name, self.getTypeName, null, null);
			app.raiseCMException2(ErrYACriteriaNotFound, name, self.description, null, null);	//09 Oct 2013	NDL	Par 32456
		else
			if not _valueArray.includes(mode) then
				_valueArray.add(mode);
			endif;
		endif;
	endforeach;
epilog
	delete tokens;
	delete pattern;
end;</source>
        <Parameter name="_pattern" type="String"/>
        <Parameter name="_valueArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="resolvePattern" id="739a9583-7648-4dcd-ab91-f6c516641fee">
        <source>resolvePattern(_pattern: String; _objectSet: ObjectSet input; _raiseException: Boolean); // cnwrd1 par 19072 18.3.09 backed out 1.4.09 due to par 19341
//29 May 2009	cnwjo3
// If the pattern has no wildcards, then resolve the names into objects and add to _objectSet
//exactly like 'resolvePattern' but don't throw UE if no pattern can be found
// 15/01/2025	navlw1	JIRA-12608: MTN - Invoice Cargo Allocations Review (Mapping and Extract/Load)
vars
	nameDict: ObjectLongNameDict;
	name: String;
	obj: Object;
	tokens: StringArray;
	pattern: CMIF_YAPattern;
begin
	// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1, default values have null pattern
	if _pattern = null then
		return;
	endif;

	// If this there are wildcard patterns then just return.
	// This will need to be resolved during autoplanning
	create pattern transient;
	pattern.setPattern(_pattern, CMIF_YAPattern.YAPattern_Wildcard);
	
	//10 Feb 2016	NDL	Par 37510 - moved up
	create nameDict transient;
	self.getObjects(nameDict);
	
	if nameDict.size = 0 then
		return;
	endif;
	
	
	create tokens transient;
	pattern.getTokens(pattern.pattern, tokens);
	
	if self.isPattern(pattern) then
		if not self.patternTokensAreObjects(nameDict, tokens) then	//10 Feb 2016	NDL	Par 37510
			//patterns are strings with '*' or '!' charcters. We don't want to call it a pattern if we have the null voyage or the null operator..
			return;
		endif;
	endif;
	
	//create nameDict transient;
	//self.getObjects(nameDict);	
	//if nameDict.size = 0 then
	//	return;
	//endif;	
		
//	create tokens transient;
//	pattern.getTokens(pattern.pattern, tokens);

	foreach name in tokens do
		// start navlw1 #JIRA-12608
		if self.saveCodeInUpper then
			obj := nameDict[name.toUpper()];
		else
			obj := nameDict[name];
		endif;
		// end navlw1 #JIRA-12608
		if obj &lt;&gt; null then
			if not _objectSet.includes(obj) then
				_objectSet.add(obj);
			endif;
		else
			if _raiseException then
				//app.raiseCMException2(ErrYACriteriaNotFound, name, self.getTypeName, null, null);
				app.raiseCMException2(ErrYACriteriaNotFound, name, self.description, null, null);	//09 Oct 2013	NDL	Par 32456
			endif;
		endif;
	endforeach;
epilog
	delete nameDict;
	delete tokens;
	delete pattern;
end;</source>
        <Parameter name="_pattern" type="String"/>
        <Parameter name="_objectSet" type="ObjectSet" usage="input"/>
        <Parameter name="_raiseException" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resolveTransitStatusPattern" id="11c41b96-4f47-438d-8441-75eec53fb239">
        <source>resolveTransitStatusPattern(_pattern: String; _valueArray: IntegerArray input);
/*

Purpose:			

