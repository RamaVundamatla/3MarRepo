<Class name="CM_YATypeOperatorVoyage" id="0b7c47bc-8526-4d70-a8f1-25b50edb0baf">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getAllCriteriaValues" id="d7c0394f-e42c-48e4-a645-e384c1956e5c">
        <source>getAllCriteriaValues(_terminalObj:CM_Terminal; _allCriteriaValues: ObjectSet input; _filter : Integer; _allDependentObjs : CM_ObjectArray);
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//17 September 2013	cnwmc5	PAR 31255 - allowing dependent objects the criteria is based on.
// --------------------------------------------------------------------------------
vars
	voyageGlobalObj	: CM_VoyageGlobal;
	voyOperator		: CM_VoyageOperator;
	temp : CM_YATypeOperatorItem;
	
begin
	foreach voyageGlobalObj in app.myRoot.allVoyagesGlobal do
		voyageGlobalObj.allVoyageOpsByTermOp.copy(_allCriteriaValues);
	endforeach;
	
	//17 Sep 2021	NDL	TFS 52012
	if _allCriteriaValues &lt;&gt; null and _allCriteriaValues.isEmpty then
		create temp transient;
		temp.getAllCriteriaValues( _terminalObj, _allCriteriaValues, _filter, _allDependentObjs );
	endif;
	
epilog
	delete temp;
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaValuesForVoyage" id="f1144980-49a6-4e0d-bea6-9a7e7980b0c8">
        <source>getCriteriaValuesForVoyage(_voyage: CM_Voyage; _criteriaValues: ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 September 2021	navndl1	Initial creation	TFS 52012

*/

vars

begin

	_criteriaValues.clear;
	_voyage.allOperators.copy( _criteriaValues );

epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_criteriaValues" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="6c34d8ba-f5bf-442a-897f-aaea052908af">
        <source>getDataDisplay(pDataObj : CM_YAData) : String;
//01 August 2008	cnwdw1
begin
	return pDataObj.CM_YADataObjects.getDataDisplay(self);
end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="8e349a5d-4a72-46dc-8af8-a351768318a4">
        <source>getDisplay(dataObj : Object) : String;
//01 August 2008	cnwdw1
begin

	if dataObj.isKindOf(CM_VoyageOperator) then
		return dataObj.CM_VoyageOperator.myOperator.code;
	elseif dataObj.isKindOf(CM_Operator) then  	//jlger1 TFS 52549 3/2/22
		return dataObj.CM_Operator.code;
	endif;
end;</source>
        <Parameter name="dataObj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getObjects" id="c9dab6c5-4b08-415c-beda-b5c3963cda4d">
        <source>getObjects(objects: ObjectLongNameDict input);
//03 August 2008	cnwdw1	
// Return a dict of objects for this criteria type
vars
	voyageGlobalObj	: CM_VoyageGlobal;
	voyOperator		: CM_VoyageOperator;
	temp : CM_YATypeOperatorItem;
begin
	foreach voyageGlobalObj in app.myRoot.allVoyagesGlobal discreteLock do
		foreach voyOperator in voyageGlobalObj.allVoyageOpsByTermOp  discreteLock do
			objects[voyOperator.getYAIdentifier] := voyOperator;
		endforeach;
	endforeach;
	
	//jlger1 TFS 52549 3/2/22
	create temp transient;
	temp.getObjects( objects);
	
epilog

	delete temp;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTypeName" id="2084e424-bc47-4bc4-902c-dd9cbc3fe0ec">
        <source>getTypeName(): String;
// --------------------------------------------------------------------------------
// Created:		16 March 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return "Operator (Voyage)";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isCMIFDataMatch" id="3eda9d2d-0231-4742-b88a-62c0d91a8ce0">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
vars
	obj : Object;
begin
	//jlger1 TFS 52549 3/2/22
	obj:= _yaData.allObjects.first();
	if obj &lt;&gt; null and obj.isKindOf(CM_Operator) then
		//return _cmifAutoPlan.isOperator_Match(_yaData);
		return _cmifAutoPlan.isOperatorVoyage_Match(_yaData); // ### TFS 53303 26APR2022 NAVPW1
	endif;

	return _cmifAutoPlan.isVoyageOperator_Match(_yaData);


end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStorageDetailMatch" id="f5db740f-ea40-403a-a18d-88c207afd9c2">
        <source>isStorageDetailMatch(_criteria: CM_YACriteria; _ti: CM_TrackedItem; _tiTrx: CM_TITransaction): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2023	navmk20	Task 57998: JADE - Storage Config - YA Criteria Storage Matching
06 Sep 2023 navma1	Bug 60374: CUX - Error on Road Gate
*/

vars
	voyageOper		: CM_Operator;
	yaData			: CM_YAData;
	ti				: CM_TrackedItem;  
	voyage			: CM_Voyage;
begin

	if _tiTrx &lt;&gt; null then											//6.09.2023 navma1 #60374
		ti := _tiTrx.myTrackedItem;
	else 
		ti := _ti;  					
	endif; 
	
	if ti &lt;&gt; null then												//6.09.2023 navma1 #60374
		voyage := ti.myVoyage;
		if voyage &lt;&gt; null then
			voyageOper := voyage.myOperator;
		endif;
	endif;
	
	yaData := _criteria.myYAData;  
	
	// specific value - handle wild cards as well
	if yaData.CM_YADataObjects.matchesStorage(voyageOper) then		//6.09.2023 navma1 #60374
		return true;
	endif;
	
	if yaData.isKindOf(CM_YADataPattern) and
	   yaData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;

epilog

end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
