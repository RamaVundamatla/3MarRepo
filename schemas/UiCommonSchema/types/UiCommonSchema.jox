    <JadeMethod name="getViewModeString" id="4040b6c6-b40c-41d3-bec8-b9325813d6ff">
        <source>getViewModeString(_mode : Integer) : String;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20 May 2008	cnwkpd1		PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens
//							Add Cargo Type, Booking references, Release Request
// 15 Jun 2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// 08 Nov 2012	cnwcs5		par 30519 - translations
//19 may 2022 navtnr20	53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// ---------------------------------------------------------------------------

vars
	theString : String;
begin
	if _mode = VIEW_OPERATOR then
		theString := app.getErrorString (Mode_Operator);
	elseif _mode = VIEW_HAZ then
		theString := app.getErrorString (Mode_Hazard);
	elseif _mode = VIEW_HEIGHT then
		theString := app.getErrorString (Mode_Height);
	elseif _mode = VIEW_IMEX then
		theString := app.getErrorString (Mode_Imex);
	elseif _mode = VIEW_DWELL then
		theString := app.getErrorString (Mode_Dwell);
	elseif _mode = VIEW_DWELL_DAYS then	// 20 Jul 2011	NDL	Par 27890
		theString := app.getErrorString (Mode_Dwell_days);
	elseif _mode = VIEW_DWELL_DAYS then	// 29 Jul 2011	NDL	Par 27890
		theString := app.getErrorString(Mode_MTGrade);
	elseif _mode = VIEW_PRODUCT then
		theString := app.getErrorString(Mode_Product);
	elseif _mode = VIEW_VOYAGE then
		theString := app.getErrorString(Mode_Voyage);
	elseif _mode = VIEW_TEMPERATURE then
		theString := app.getErrorString(Mode_Temperature);
	elseif _mode = VIEW_COMMODITY then
		theString := app.getErrorString(Mode_Commodity);
	elseif _mode = VIEW_WEIGHT then
		theString := app.getErrorString(Mode_Weight);
	elseif _mode = VIEW_CONSIGNEE then
		theString := app.getErrorString(Mode_Consignee);
	elseif _mode = VIEW_DISPORT then
		theString := app.getErrorString(Mode_Discharge_Port);
	elseif _mode = VIEW_LOADPORT then
		theString := app.getErrorString(Mode_Load_Port);
	elseif _mode = VIEW_DESTPORT then
		theString := app.getErrorString(Mode_Destination_Port);
	elseif _mode = VIEW_STATUS then
		theString := app.getErrorString(Status);
	elseif _mode = VIEW_ISOGROUP then
		theString := app.getErrorString (Mode_Group);
	elseif _mode = VIEW_JOB then
		theString := app.getErrorString (Mode_Job);		
	elseif _mode = VIEW_YARD_ALLOC then
		theString := app.getErrorString (Mode_YA);
	elseif _mode = VIEW_CARGO_TYPE then
		theString := app.getErrorString (Mode_Cargo_Type);
	elseif _mode = VIEW_BOOKREF_EXPORT then
		theString := app.getErrorString (Mode_Export_Booking);
	elseif _mode = VIEW_BOOKREF_STOCK then
		theString := app.getErrorString (Mode_Stock_Booking);
	elseif _mode = VIEW_RELEASE_REQUEST then
		theString := app.getErrorString (Mode_Release_Request);
	elseif _mode = VIEW_LOG_GRADE then // 03/04/2009 cnwdz2 PAR 18231
		theString := app.getErrorString (Mode_Log_Grade);
	elseif _mode = VIEW_TRAIN then
		theString := app.getErrorString (Mode_Train);
	elseif _mode = VIEW_CARRIERIN then		// 12/6/17 MAP TFS4209
		theString := (app.getErrorString(Receive) &amp; " " &amp; app.getErrorString(Carrier)).trimBlanks();
	elseif _mode = VIEW_CARRIEROUT then		// 12/6/17 MAP TFS4209
		theString := app.getErrorString(Release_carrier);
	elseif _mode = VIEW_SHIPPINGLINE then	//19-may-2022 navtnr20  53204
		theString := app.getErrorString(ShippingLine);
	endif;
	
	return theString;

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWebSiteConfigFromCmdLine" id="9145aede-01cc-4e2f-b9d7-376b35bfe026">
        <updating/>
        <source>getWebSiteConfigFromCmdLine(_cmdLine: String): CM_WebSiteConfig updating;

/*

Purpose:			Get the Web Config from the command line

Parameters:			Command line used to run this Web Application

Return Value:		Web Site Config found on command line


Date		Who		Reason
22 Jan 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	configName		: String;
	pos				: Integer;
	root			: CM_Root;
	config			: CM_WebSiteConfig;

begin
	root := app.myRoot;

    pos := 1;
    pos := _cmdLine.pos("Web_Config=", pos);
    if pos &lt;&gt; 0 then
		configName := _cmdLine[pos + "Web_Config=".length : end];
        if root &lt;&gt; null and configName &lt;&gt; null then
        	config := root.allWebSiteConfigs[configName];
        	if config &lt;&gt; null then
        		return config;
        	else
        		self.writeLog('ERROR &gt;&gt; Config not found (' &amp; configName &amp; ')', LogINFO);
           	endif;
        elseif root = null then
       		self.writeLog('ERROR &gt;&gt; root is null', LogINFO);
       	elseif configName = null then
       		self.writeLog('ERROR &gt;&gt; configName is null (' &amp; _cmdLine &amp; ')', LogINFO);
        endif;
    else
		self.writeLog('ERROR &gt;&gt; Web_Config= not found on command line (' &amp; _cmdLine &amp; ')', LogINFO);
    endif;

    return null;


end;</source>
        <Parameter name="_cmdLine" type="String"/>
        <ReturnType type="CM_WebSiteConfig"/>
    </JadeMethod>
    <JadeMethod name="handleFormLoss" id="6eb01007-043f-4589-976d-f069d7793e87">
        <source>handleFormLoss( _exception : Exception ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2019	jlgndl1	Initial creation	TFS 48010 - Handle a user closing a window in the background that we rely on.
															I.e. myParentForm ( or others ) that the current form might try to access directly.
*/

constants

	InvalidObject : Integer = 4;
	
vars

	returnValue : Integer;
	obj : Object;
	msg : String;

begin

	returnValue := Ex_Pass_Back;
	
	if _exception.errorCode = InvalidObject then
		obj := _exception.errorObject;
		if obj &lt;&gt; null then
			if obj.isKindOf( CM_BaseForm ) then
				abortTransientTransaction;
				abortTransaction;
				msg := app.getErrorString( Windo_tryin_updat_data_been_cl );
				app.msgBox( msg, app.getErrorString( Error ), MsgBox_OK_Only + MsgBox_Stop_Icon );
				returnValue := Ex_Abort_Action;
			endif;
		endif;
	endif;
	
	
	return returnValue;

epilog

end;</source>
        <Parameter name="_exception" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleHelpFormatChange" id="9e5877f7-d9bb-42f4-8e85-59f4478ea218">
        <source>handleHelpFormatChange();
/*

Purpose:			If the current User changes the Help format, then we need to change
					the menu visibility on all the open forms, and reset the base help keyword

Parameters:			None

Return Value:		None

Date		Who		Reason
27 May 2014	cnwkpd1	PAR #34210 - CCMS SFW 1350 - Online Documentation

*/

vars
	f				: Form;
	i				: Integer;
	
begin
	foreach i in 1 to app.formsCount() do
		f := app.forms(i);
		if f.isKindOf(CM_BaseForm) then
			f.CM_BaseForm.handleHelpMenuSetup();
		endif;
	endforeach;

	app.setupHelpFile();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="handleLocaleException" id="6860a8b4-671c-4bbc-bb6a-47bde72e375d">
        <source>handleLocaleException( _exc : Exception; _raiseWarning : Boolean ) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 November 2018	jlgrh7	Initial creation TFS41429
Purpose:  if the user nodes does not have  consistent set of locale settings (client's node and application server local settings are different) then there will be unhandled exceptions (date format and numeric format)
*/

constants

	InvalidIiteral 		: Integer = 14202;			//Invalid literal in a JadeEditMask control
	InvalidNumeric 	: Integer = 14074;			//Text of numeric TextBox or JadeEditMask not valid numeric
	
vars
	retVal					: Integer;
begin
	retVal := Ex_Pass_Back;
	if _exc.errorCode = InvalidIiteral or _exc.errorCode =InvalidNumeric then
		app.raiseCMException(InconsistenLocaleSetting, null, null);
		retVal:= Ex_Resume_Next; 
	endif;
	return retVal;
epilog

end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_raiseWarning" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initAsyncWorker" id="46060681-6845-4c67-80bb-b9042183499f">
        <updating/>
        <source>initAsyncWorker(user:CM_User) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2024   annamth     CR 61540: MTN - [POC - Phase 1] - Enhancing Query Performance through Multi-Process

*/

vars

begin
	self.myCmuiRoot := app.getSingleton(CMUI_Root).CMUI_Root;
	self.initialize();
	self.myPassport.setMyUser(user);
	app.asyncInitialize();
	self.beginNotification(process,EVENT_AYSNCHAPP_END,Response_Continuous,0);
epilog

end;</source>
        <Parameter name="user" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="initBGPStartManagersServer" id="7baa1960-dc7c-4ef2-8c9c-a97a3bc35ca2">
        <source>initBGPStartManagersServer();

// cnwdvb1 01 November 2002 

vars

	manager : BGP_Manager;

begin

	app.initialize();
	// 33632 make SDS-aware and exit
	if app.isSDSSecondaryDB() then
		app.writeLog(app.name &amp; ' started in SDS secondary mode, terminating', LogINFO);
		terminate;
	endif;

	foreach manager in BGP_Manager.instances do
		if manager.isRunOnServer then
			if not manager.isRunning then
				app.writeLog('INFO &gt;&gt; Starting manager - ' &amp; manager.name , LogINFO);
				app.myTrxUA.trxUpdateBGPManagerProcess(manager, null, null, app.myPassport);
				app.startManagerServer(manager);
			else
				app.writeLog('INFO &gt;&gt; Manager - ' &amp; manager.name &amp; ' is already running' , LogINFO);
			endif;
		endif;
	endforeach;
	app.exitLogFile();
	app.finalize();
	terminate;

end;</source>
    </JadeMethod>
    <JadeMethod name="initBGP_ControllerApp" id="5d994d90-9191-4755-af5b-70a49d1cfb46">
        <updating/>
        <source>initBGP_ControllerApp(_controller : BGP_Controller input) updating;

// cnwdvb1 29 October 2002 

vars

begin

	if _controller = null then
		app.writeCnLog(CnCntrl.CnLogErrors, class.name &amp; '::' &amp; method.name &amp; ' _controller = null &gt;&gt; terminating');	//25 Nov 2019	NDL	TFS 47053 - pre initialise needs card schema logging
		terminate;
	endif;
	// 33632 make SDS-aware and exit
	if app.isSDSSecondaryDB() then
		if app.myCnCntrl = null then
			self.setupAppVersion();
			self.cnActivateKarmaControl(Cn_Fat_Client, null, null);
		endif;
		app.writeCnLog(CnCntrl.CnLogErrors, app.name &amp; ' started in SDS secondary mode, terminating');	//25 Nov 2019	NDL	TFS 47053 - pre initialise needs card schema logging
		terminate;
	endif;
	self.myBGPObject := _controller;
	
	_controller.initApp();
	self.changeLogLevel( LogWARN );	//22 Nov 2019	NDL	TFS 47053
	
//	app.myCnCntrl.setCheckTransientsOnShutDown(true);

end;</source>
        <Parameter name="_controller" type="BGP_Controller" usage="input"/>
    </JadeMethod>
