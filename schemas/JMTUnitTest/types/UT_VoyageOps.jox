    <JadeMethod name="createCCJOBForSLTL" id="fa65478d-8166-4540-bfb6-7a674c1bf238">
        <updating/>
        <source>createCCJOBForSLTL(_locations20 : StringArray; _locations40 : StringArray; _locnSeq : StringArray; _sequence : StringArray; _startId : Integer; _voyage : CM_Voyage input) updating;
/*
Purpose:			
Date		Who		Reason
23 December 2015	NAVAB1	Initial creation
*/

vars
	cargoId : String;
	startId : Integer;
	
	locn : String;
	isoTypeGroup 		: CM_ISOTypeGroup;
	isoTypeGroupDesc	: String;
	isoType				: CM_ISOType;
	isotypecoll			: CM_ISOTypeByCodeDict;
	isoTypeGroupSub		: CM_ISOTypeGroupByCodeDict;

	slots, jobSlots : CM_SlotControllerArray;
	aSlot : CM_SlotController;
	voyageJob : CM_VoyageJob;
	ct : CM_CargoType;
	product: CM_Product;
	realAlloc : CM_VoyageAllocation;
	seqGroupSingleLifts, shipSLiftIfDiffHeights : Boolean;
	container : CM_Container;
	aPort : CM_Port;
	idx : Integer;
	seqStr : String;
begin
	aPort := app.myRoot.allPorts[_voyage.myTerminal.getConfig(PortDestCode).String];

	startId := _startId;
	
		create slots transient;
	create jobSlots transient;

	
	// ### 20 FOOT CARGO
	self.opts.purge();
	self.opts.addAssoc(UTTI_TotalWeight, 18000);
	jobSlots.clear();
	slots.clear;
	
	
	foreach locn in _locations20 discreteLock do
		cargoId := "UTTL" &amp; startId.String;
		aSlot := self.getJobLOLOControllerByID("UTBISH_SL1", locn[1:2], locn); slots.add(aSlot);
		container := self.addContainerAtLocnDisch(cargoId, "U20G", "GENL", TI_IMEX_STATUS_IMPORT, aSlot, aPort, _voyage);
		startId := startId+ 1;
	endforeach;
 
	// ### 20 FOOT COLOUR CODING
	self.opts.purge();
	self.opts.addAssoc(UTTI_IMEX, TI_IMEX_STATUS_IMPORT);
	realAlloc := self.addVoyageAllocation(_voyage, "NZPOE", "U20G", "GENL", TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(false, realAlloc, slots, null);
	slots.copy(jobSlots);
	
	
	// ### 40 FOOT CARGO
	slots.clear;
	self.opts.purge();
	self.opts.addAssoc(UTTI_TotalWeight, 18000);
	
	foreach locn in _locations40 discreteLock do
		cargoId := "UTTL" &amp; startId.String;
		aSlot := self.getJobLOLOControllerByID("UTBISH_SL1", locn[1:2], locn); slots.add(aSlot);
		container := self.addContainerAtLocnDisch(cargoId, "U40G", "GENL", TI_IMEX_STATUS_IMPORT, aSlot, aPort, _voyage);
		startId := startId+ 1;
	endforeach;
 
	// ### 40 FOOT COLOUR CODING
	self.opts.purge();
	self.opts.addAssoc(UTTI_IMEX, TI_IMEX_STATUS_IMPORT);
	realAlloc := self.addVoyageAllocation(_voyage, "NZPOE", "U40G", "GENL", TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(false, realAlloc, slots, null);
	slots.copy(jobSlots);
	
	
	voyageJob:=self.addVoyageJob(_voyage,"CRN2",jobSlots, true);	//CM_VoyageJob::setRequestSeqNumbers  172
	assertTrue(voyageJob &lt;&gt; null);
	assertTrueMsg(voyageJob.isTwinLift, "Job " &amp; voyageJob.jobNum &amp; " Should be TWIN  LIFT");
	
	
	
	foreach locn in _locnSeq discreteLock do
		idx := idx + 1;
		seqStr := _sequence[idx];
		aSlot := self.getJobLOLOControllerByID("UTBISH_SL1", locn[1:2], locn); 
		
		self.assertTrueMsg(aSlot.mySlotRequestDischarge.numSeqPortTwin = seqStr.Integer,"Pre Job " &amp; voyageJob.jobNum &amp; "(D) - " &amp; aSlot.getFullId &amp; " should be seq num " &amp; seqStr &amp; ", is " &amp; aSlot.mySlotRequestDischarge.numSeqPortTwin.String);
	endforeach;
epilog
	delete slots;
	delete jobSlots;

end;</source>
        <Parameter name="_locations20" type="StringArray"/>
        <Parameter name="_locations40" type="StringArray"/>
        <Parameter name="_locnSeq" type="StringArray"/>
        <Parameter name="_sequence" type="StringArray"/>
        <Parameter name="_startId" type="Integer"/>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createCargoOnSite" id="d4c37089-bbfe-4319-a427-cfaa98c90fc1">
        <updating/>
        <source>createCargoOnSite() updating;
// ---------------------------------------------------------------------------
// Created:     31 May 2010 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	bs: CM_StraddleStack;

	cargo : CM_TrackedItem;
	strs : StringArray;
	idx : Integer;	
	aPort : CM_Port;
	voy : CM_Voyage;
	op : CM_Operator;
	ct : CM_CargoType;
	product: CM_Product;
	startLC : CM_GridController;
begin
	ct	:= self.getTerminal.getFirstNonSystemCargoType().CM_CargoType;
	product := ct.allProducts.first;

	voy := self.getVoyage("UTBISH9");

	aPort := app.myRoot.allPorts["NZAKL"];
	op := app.myRoot.allOperators["MSC"];
	create strs transient;
	

	deleteTerminalArea("UTBISHW");
	bs := self.addStraddleStack("UTBISHW", 5,5,3);

	
	
	startLC := bs.allGridControllersByRowColumn.first();
	// ### 20 GENERALS
	cargo := self.addContainerAtLocnDisch("GENL2077441", "U20G", "GENL", TI_IMEX_STATUS_EXPORT, startLC, aPort, voy);
	startLC := bs.getNextAvailableLocation(startLC);
	cargo := self.addContainerAtLocnDisch("GENL2077442", "U20G", "GENL", TI_IMEX_STATUS_EXPORT, startLC, aPort, voy);
	startLC := bs.getNextAvailableLocation(startLC);
	cargo := self.addContainerAtLocnDisch("GENL2077443", "U20G", "GENL", TI_IMEX_STATUS_EXPORT, startLC, aPort, voy);
	startLC := bs.getNextAvailableLocation(startLC);
	cargo := self.addContainerAtLocnDisch("GENL2077444", "U20G", "GENL", TI_IMEX_STATUS_EXPORT, startLC, aPort, voy);
	startLC := bs.getNextAvailableLocation(startLC);
	cargo := self.addContainerAtLocnDisch("GENL2077445", "U20G", "GENL", TI_IMEX_STATUS_EXPORT, startLC, aPort, voy);
	startLC := bs.getNextAvailableLocation(startLC);
	cargo := self.addContainerAtLocnDisch("GENL2077446", "U20G", "GENL", TI_IMEX_STATUS_EXPORT, startLC, aPort, voy);


epilog
	delete strs;
end;</source>
    </JadeMethod>
    <JadeMethod name="createCargoOnship" id="a1fefa09-b7f1-4b12-b483-f7510c0ae704">
        <source>createCargoOnship(_voyage : CM_Voyage);
/*
Purpose:			
Date				Who			Reason
AUGUST 2013	NAVAB1		Initial creation
*/

vars
	theSlot : CM_LocationsController;
	cargo : CM_TrackedItem;
	strs : StringArray;
	idx : Integer;
	aPort : CM_Port;
	voyageDeck : CM_DeckVoyage;
	lcs : CM_LCArray;
begin

	aPort := app.myRoot.allPorts[_voyage.myTerminal.getConfig(PortDestCode).String];
	create strs transient;
	
	// ### FORWARD 20 GENERALS
	strs.clear;
	strs.add("010688");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.opts.addAssoc(UTTI_TotalWeight, 18000);
	cargo := self.addContainerAtLocnDisch("GENL3344551", "U20G", "GENL", TI_IMEX_STATUS_REMAINONBOARD, theSlot, aPort, _voyage);
	self.assertTrueMsg((cargo.getImExStatus() =TI_IMEX_STATUS_REMAINONBOARD), "ImEx on ROB is wrong" );

	strs.clear;
	strs.add("010488");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.opts.addAssoc(UTTI_TotalWeight, 10000);
	cargo := self.addContainerAtLocnDisch("GENL3344552", "U20G", "GENL", TI_IMEX_STATUS_REMAINONBOARD, theSlot, aPort, _voyage);

	strs.clear;
	strs.add("010686");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.opts.addAssoc(UTTI_TotalWeight, 18000);
	cargo := self.addContainerAtLocnDisch("GENL3344553", "U20G", "GENL", TI_IMEX_STATUS_REMAINONBOARD, theSlot, aPort, _voyage);
	
	strs.clear;
	strs.add("010486");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.opts.addAssoc(UTTI_TotalWeight, 10000);
	cargo := self.addContainerAtLocnDisch("GENL3344554", "U20G", "GENL", TI_IMEX_STATUS_REMAINONBOARD, theSlot, aPort, _voyage);
	
	
	// ### AFT 20 GENERALS
	strs.clear;
	strs.add("030688");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.opts.addAssoc(UTTI_TotalWeight, 10000);
	cargo := self.addContainerAtLocnDisch("GENL3344556", "U20G", "GENL", TI_IMEX_STATUS_REMAINONBOARD, theSlot, aPort, _voyage);
	self.assertTrueMsg((cargo.getImExStatus() =TI_IMEX_STATUS_REMAINONBOARD), "ImEx on ROB is wrong" );

	strs.clear;
	strs.add("030488");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.opts.addAssoc(UTTI_TotalWeight, 10000);
	cargo := self.addContainerAtLocnDisch("GENL3344557", "U20G", "GENL", TI_IMEX_STATUS_REMAINONBOARD, theSlot, aPort, _voyage);

	strs.clear;
	strs.add("030686");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.opts.addAssoc(UTTI_TotalWeight, 10000);
	cargo := self.addContainerAtLocnDisch("GENL3344558", "U20G", "GENL", TI_IMEX_STATUS_REMAINONBOARD, theSlot, aPort, _voyage);
	
	
	strs.clear;
	strs.add("030486");
	_voyage.findLocation(strs, false, theSlot, idx);
	self.opts.addAssoc(UTTI_TotalWeight, 10000);
	cargo := self.addContainerAtLocnDisch("GENL3344559", "U20G", "GENL", TI_IMEX_STATUS_REMAINONBOARD, theSlot, aPort, _voyage);
	
	
epilog
	delete lcs;
	delete strs;
end;</source>
