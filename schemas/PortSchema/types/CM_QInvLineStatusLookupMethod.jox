    <JadeMethod name="getKeyLengthForXTABDictionary" id="3c6ef217-e9cd-45b8-bda5-fb245c41473f">
        <source>getKeyLengthForXTABDictionary(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2014	cnwndl1	Initial creation

*/

vars
	length	:Integer;
begin
	// just incase the global constant values change !!!
	length := app.getErrorString(Normal).length;
	length := length.max (app.getErrorString(Void).length);
	
	return length;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
