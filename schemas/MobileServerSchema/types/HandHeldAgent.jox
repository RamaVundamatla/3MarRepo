    <JadeMethod name="getRTDeviceForSelf" id="c559bbdf-8f8b-4c98-aabd-49ed82088136">
        <source>getRTDeviceForSelf(_computerName : String) : CM_RadioTelemetryDevice;
/*
----------   ----------  --------------------------------------------------
Created:	02 April 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  -------------------------------------------------
22 Aug 2012	cnwer1		PAR 30126 - added discreteLock 
*/
vars
	terminal		: CM_Terminal;
	radioTelemetry	: CM_RadioTelemetry;
	device,
	theDevice: CM_RadioTelemetryDevice;
	altDeviceName, deviceName   : String;
	index 			: Integer;
	checkAlt        : Boolean;
begin
	foreach terminal in app.myRoot.allTerminals discreteLock do
		radioTelemetry := terminal.radioTelemetry;
		if radioTelemetry = null then		
			continue;
		endif;
		
		foreach device in radioTelemetry.allRTDevices discreteLock do
			//if device.computerName.toUpper = app.computerName.toUpper then
			theDevice:= self.isRTDeviceValid(device,_computerName,checkAlt);
			if theDevice &lt;&gt; null then
				return theDevice;
			endif;
			
			if checkAlt then
				deviceName:=device.computerName.toUpper;
				//checkAlt:=false;
				if deviceName &lt;&gt; null then
					index:=1;
					deviceName.scanUntil(":",index);
					if index &gt;  1 then
						altDeviceName:=deviceName[1:index-1];
					else
						altDeviceName:=deviceName;
					endif;
				endif;
			endif;
				
			if checkAlt and altDeviceName = _computerName.toUpper then
				return device;
			endif;
				
		endforeach;
	endforeach;
	return null;
end;








</source>
        <Parameter name="_computerName" type="String"/>
        <ReturnType type="CM_RadioTelemetryDevice"/>
    </JadeMethod>
    <JadeMethod name="getTerminalConfig" id="39e756a3-da7d-4a0d-aafc-068fa8656a67">
        <source>getTerminalConfig(config : String) : Any;
/*

Purpose:			


Return Value:		


Date		Who		Reason
28 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
