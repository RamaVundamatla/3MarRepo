    <JadeMethod name="btnGetValues_click" id="edc1aefd-34e7-47f3-9731-fad339d5018a">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnGetValues_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     18 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpStr	: String;

begin

	tmpStr := self.getValues(cmbForms.listObject.Form, cmbControls.listObject.Control, chkInclChildren.value);
	
	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; CrLf &amp; tmpStr &amp; CrLf &amp; '---- end ----');
	
	self.setAllTestControls(tmpStr);
	
	self.allTestData.inspect;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
