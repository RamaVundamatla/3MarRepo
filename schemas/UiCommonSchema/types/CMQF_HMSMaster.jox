<Class name="CMQF_HMSMaster">
    <JadeMethod name="setFromAgent" id="0bb7e88a-fae8-46e6-8268-1c428938ebec">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
