    <JadeMethod name="validateForCreate" id="1a794852-2eb5-445d-8551-c72b430e56ec">
        <source>validateForCreate( _realFormat : CM_OutputFormat_XTAB );
// ---------------------------------------------------------------------------
// Created:     11 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/01/2009	cnwrl1		Validate name is not already being used (CCMS SFW 1047 - Totals Only Lists)
// 16/12/2009	cnwcs5		ccms 1023 - validation for local xtabs.  renamed local variable
// ---------------------------------------------------------------------------
vars
	tempStr	: String;
	element	: CM_XTABElement;
	xtab	: CM_OutputFormat_XTAB;	// cnwcs5 renamed
	
begin
	if self.getQueryDefinition = null then
	//	app.raiseCMException1 (REQUIRED_FIELD, 'mode', null, self);
		app.raiseCMException (Input_required_field_mode, null, self);

	endif;
	
	if self.name.trimBlanks = null then
	//	app.raiseCMException1 (REQUIRED_FIELD, 'name', null, self);
		app.raiseCMException (Input_required_field_name, null, self); // cnwdb2	PAR 35364
	else
		// Make sure the name does not contain the default name part of "&lt;New Summary Defn&gt;"
		tempStr		:= app.getString( XTAB_New_Summary_Definition, null ).trimBlanks;
		
		if self.name.trimBlanks.pos( tempStr, 1 ) &lt;&gt; null then
			app.raiseCMException1( SummaryDefn_InvalidName, tempStr, null, self );
		endif;
		
		// Validate name is not already being used (CCMS SFW 1047 - Totals Only Lists)
		if self.myOutputFormat_SS &lt;&gt; null then																	// cnwcs5 16/12/2009
			xtab := self.myOutputFormat_SS.allOutputFormats_XTAB[ self.name.trimBlanks ].CM_OutputFormat_XTAB;	// cnwcs5 16/12/2009
		else																									// cnwcs5 16/12/2009
			xtab := app.myRoot.allOutputFormats_XTAB[ self.name.trimBlanks ].CM_OutputFormat_XTAB;
		endif;																									// cnwcs5 16/12/2009
		
		if xtab &lt;&gt; null then
			// one exists with this name, make sure not attempting to updating same object.
			if _realFormat = null or _realFormat &lt;&gt; xtab then	
				app.raiseCMException2(	Already_exists_valid,
										self.name.trimBlanks.display,
										app.getErrorString( XTAB_SummaryDefinition ),
										null,
										self );
			endif;
		endif;
	endif;
	
	if (self.isSnapshotMode and self.myOutputFormat_SS = null ) then													// cnwcs5 16/12/2009
		// expect GUI to take care of this
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Snapshot format required for type/mode');		// cnwcs5 16/12/2009
	elseif (not self.isSnapshotMode and self.myOutputFormat_SS &lt;&gt; null) then											// cnwcs5 16/12/2009
		// expect GUI to take care of this
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Snapshot format not valid for type/mode');		// cnwcs5 16/12/2009
	endif;																												// cnwcs5 16/12/2009
	
	foreach element in self.allTabs do
		element.validateForCreate;
	endforeach;
	
	foreach element in self.allRows do
		element.validateForCreate;
	endforeach;
	
	foreach element in self.allColumns do
		element.validateForCreate;
	endforeach;
	
	foreach element in self.allFields do
		element.validateForCreate;
	endforeach;
	
	if self.allFields.isEmpty then			// must have selected at least one CELL entry.
		app.raiseCMException( XTAB_OneFieldRequired, null, self );
	endif;
	
	if self.allTabs.size &gt; 1 then			// currently only allowed one TAB field.
		app.raiseCMException( XTAB_OnlyOneTab, null, self );
	endif;
	
epilog
	
end;</source>
        <Parameter name="_realFormat" type="CM_OutputFormat_XTAB"/>
    </JadeMethod>
