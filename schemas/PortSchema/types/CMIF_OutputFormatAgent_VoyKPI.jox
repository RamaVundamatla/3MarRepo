        <source>getAllVoyageCargoTypes(_voyage :CM_Voyage; _coll :CM_CargoTypeSet input) protected;
/*

Date		Who		Reason
18 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	kpi	:CM_KPIVoyageEntity;
begin
	kpi := _voyage.getKPI;
	
	if kpi &lt;&gt; null then
		kpi.getAllCargoTypes (_coll);
	endif;
epilog

end;</source>
