    <JadeMethod name="validateMe" id="9730930c-6703-4fcc-a80d-a935b8eda039">
        <source>validateMe() protected;
/*
 ------------------------------------------------------------------------
Created:			11 October 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if self.ordinalHold = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Ordinal Hold', null, null);
		app.raiseCMException(Input_required_field_ordnlHold, null, null); // cnwdb2	PAR 35364
	endif;

end;</source>
