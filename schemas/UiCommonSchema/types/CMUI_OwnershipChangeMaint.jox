    <JadeMethod name="doSelectAll" id="fc65c499-35d7-42dd-9547-07c7894ce22e">
        <source>doSelectAll();
/*
Purpose:			

Date		Who		Reason
27 May 2024	navab1	CR 64164 TASK 64180
//20.07.2024 navrv30 Bug 64858: MTN - Ownership Change Maint - Select All issues
*/

vars
	col, row : Integer;
	include : Boolean;
begin

	if self.tblData.rows = self.tblData.fixedRows then
		return;
	endif;
	
	
	include := self.chkSelectAll.value;
	col := self.tblData.getColumnByRowName(ETRow_Include);

	if col  &gt; 0 then
	
		foreach row in self.tblData.fixedRows + 1 to self.tblData.rows do
				self.tblData.accessRow(row);
				self.tblData.accessCell(row,col);
				self.tblData.accessedCell.text := include.cnReturnTickDisplayValue();			
		endforeach;
	endif;
	
	self.createPxyDetailForUpdate();
	self.displayStatus(); 

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSetSelectAll" id="ea801880-5c9c-428a-8d9f-c876e38e05c9">
        <source>doSetSelectAll();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//20.07.2024 navrv30 Bug 64858: MTN - Ownership Change Maint - Select All issues

*/

vars
	col, row : Integer;	
	uncheck : Boolean;
begin

	if self.tblData.rows = self.tblData.fixedRows then
		return;
	endif;
	
	self.chkSelectAll.value := false;
	col := self.tblData.getColumnByRowName(ETRow_Include);
	
	if col  &gt; 0 then	
		foreach row in self.tblData.fixedRows + 1 to self.tblData.rows do
			if self.tblData.accessCell(row, 1).text = "0" then
				uncheck := true;
				break;
			endif;
		endforeach;
		if not uncheck then
			self.chkSelectAll.value := true;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblCOODetailContMenu" id="39cb74f6-b36e-4324-8815-1b06cf932a8b">
        <updating/>
        <source>doTblCOODetailContMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2023 navtnr20	TFS CR 58233	Task 58235: UI - Change of Ownership Maint
*/

vars
	canEdit		: Boolean;
	x1,
	y1			: Real;
begin
	x1 := x;
	y1 := y;
	if (not mouse) then
	    x1 := 1;
	    y1 := 1;
	endif;
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	self.mnuColumnOrganiser.visible := true;
	self.mnuColumnOrganiser.userObject := self.tblData;
	self.mnuInspectObject.visible := app.isAllowedToInspect();  // ### TFS 60004 24AUG2023 NAVAB1
	self.popupMenu(self.mnuContextMenu, x1.Integer, y1.Integer);
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enableForCargoReview" id="49810d54-ed98-40e4-a643-6a5e4ab9a484">
        <updating/>
        <source>enableForCargoReview() : Boolean updating;
/*
Purpose:			

Date		Who		Reason
13 May 2024	navab1	BUG 64115
*/

vars
	cooDate: Date;
begin
	if self.mode &lt;&gt; self.Cargo_Review_Mode then
		return false;
	endif;
	
	if self.txtRefNumber.text = "" then
		return false;
	endif;
	
	cooDate := self.mskCOOFromStart.getDate();
	if not cooDate.isValid() then
		return false;
	endif;
	
	if self.cmbNewOperator.listIndex &lt; 1 then
		return false;
	endif;
	
	self.btnUpdate.enabled := true;
	
	self.createPxyOwnershipChange();
	
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getFreeStoExpForOldOperator" id="9305fbdd-0936-4698-bdc3-30a419f292f8">
        <source>getFreeStoExpForOldOperator();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/05/2024	navkc1 Bug 64186: MTN - COO Maint Changes
02 Jul 2024	navnk30	Bug 64896: COO - Incorrect Free Storage Expiry on COO maintenance screen

*/

vars
	myTrackedItem		: CM_TrackedItem;
	localStorageExpTS,
	storageExpTS		: TimeStamp;
	prevStorageExpDtl	: CM_StorageExpiryDetail;
begin
	if self.myOwnershipChange &lt;&gt; null then
		myTrackedItem := self.myOwnershipChange.getMyTrackedItem();
	else
		if self.tblData.rows &gt; self.tblData.fixedRows then
			myTrackedItem := self.tblData.accessRow(2).itemObject.CM_OwnershipChangeDetail.myTrackedItem;
		endif;
	endif;
	
	if myTrackedItem &lt;&gt; null then
		if myTrackedItem.isCargoGroupItem then
			myTrackedItem := myTrackedItem.CM_CargoGroup.allAssignedTrackedItems.first;
		endif;
		
		if self.updateMode then			//02.07.2024 navnk30 #64896
			prevStorageExpDtl := myTrackedItem.getPrevStorageExpDtl();
			if prevStorageExpDtl &lt;&gt; null then
				storageExpTS := prevStorageExpDtl.freeStorageExpiry;
			endif;
		else
			storageExpTS := myTrackedItem.getFreeStorageExpiry();
		endif;
		localStorageExpTS := self.systemToLocalTime(storageExpTS);
		
		self.displayCurOprStoExp.caption	:= localStorageExpTS.date().asStringJMT();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getFreeStoExpForOriOperator" id="ef99eec3-a71a-40cb-b882-2691d1afe0cd">
        <source>getFreeStoExpForOriOperator();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/05/2024	navkc1 Bug 64186: MTN - COO Maint Changes

*/

vars
	myTrackedItem		: CM_TrackedItem;
	localStorageExpTS,
	storageExpTS		: TimeStamp;
	storageExpDetails	: CM_StorageExpiryDetail;
	oriOperatorCaption,
	oriOperatorCode		: String;
	oriOperator			: CM_Operator;
	idx					: Integer;
begin
	
	
	
	if self.myOwnershipChange &lt;&gt; null then
		myTrackedItem := self.myOwnershipChange.getMyTrackedItem();
	else
		if self.tblData.rows &gt; self.tblData.fixedRows then
			myTrackedItem := self.tblData.accessRow(2).itemObject.CM_OwnershipChangeDetail.myTrackedItem;
		endif;
	endif;
	
	if myTrackedItem &lt;&gt; null then
		
		if myTrackedItem.isCargoGroupItem then
			myTrackedItem := myTrackedItem.CM_CargoGroup.allAssignedTrackedItems.first;
		endif;
		
		// Get operator Code and description for group box caption
		oriOperatorCode := myTrackedItem.getCOOOperatorOrigCode();
		if oriOperatorCode &lt;&gt; null then
			idx := 1;
			oriOperatorCode := oriOperatorCode.scanUntil(",", idx);
			oriOperator := app.myRoot.allOperators[oriOperatorCode];
		else
			oriOperator := myTrackedItem.myOperator;
		endif;
		
		if oriOperator &lt;&gt; null then
			oriOperatorCaption := oriOperator.code &amp; " - " &amp; oriOperator.description;
			if oriOperatorCaption.length() &gt; 50 then
				oriOperatorCaption := oriOperatorCaption[1:50] &amp; "...";
			endif;
			self.grpOriOperator.caption := app.getErrorString(Original_operator) &amp; ": " &amp; oriOperatorCaption;
		endif;
		
		storageExpDetails := myTrackedItem.allStorageExpiryDetails.first();
		
		if storageExpDetails &lt;&gt; null then
			storageExpTS := storageExpDetails.freeStorageExpiry;
			localStorageExpTS := self.systemToLocalTime(storageExpTS);
			self.displayOriOprStoExp.caption := localStorageExpTS.date().asStringJMT();
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getFreeStorageForNewOperator" id="2c7ca02a-a03e-4e7f-b13b-4531dbf9c8aa">
        <source>getFreeStorageForNewOperator();
/*
Purpose:			

Date		Who		Reason
20 July 2023	navab1	 CR 58239 TASK 58241 
02 Jul 2024	navnk30	Bug 64896: COO - Incorrect Free Storage Expiry on COO maintenance screen
*/

vars
	myTrackedItem, pxyTi : CM_TrackedItem;
	storageDetail : CM_StorageDetail;
	expiryDT : Date;
	effectiveTS : TimeStamp;
	addFreeDays : Integer;
	prevStorageExp	: CM_StorageExpiryDetail;
begin
	if self.myOwnershipChange &lt;&gt; null then
		myTrackedItem := self.myOwnershipChange.getMyTrackedItem();
	else
		if self.tblData.rows &gt; self.tblData.fixedRows then
			myTrackedItem := self.tblData.accessRow(2).itemObject.CM_OwnershipChangeDetail.myTrackedItem;
		endif;
	endif;
	
	if myTrackedItem &lt;&gt; null then
		if myTrackedItem.isCargoGroupItem then
			myTrackedItem := myTrackedItem.CM_CargoGroup.allAssignedTrackedItems.first;
		endif;
		
		prevStorageExp := myTrackedItem.allStorageExpiryDetails.last();
		
		pxyTi := app.createUpdateProxy(myTrackedItem).CM_TrackedItem;
		if app.myProxyManager &lt;&gt; null then
			app.myProxyManager.deleteProxyLink(pxyTi);
		endif;

		// ### TFS BUG 59644 03AUG2023 NAVAB1
		effectiveTS.setDate(self.mskCOOFromStart.text.asDateJMT());
		effectiveTS.setTime(self.mskCOOFromStartTime.text.asTimeJMT());
		//expiryDT := effectiveTS.date;							//02.07.2024 navnk30 #64896
		expiryDT := self.systemToLocalTime(effectiveTS).date;	//02.07.2024 navnk30 #64896
		
		pxyTi.setMyOperator(self.cmbNewOperator.listObject.CM_Operator);
		
		storageDetail:= pxyTi.getMatchingFreeStorageDetail(null);
		if storageDetail &lt;&gt; null then
			self.displayCOOFreeDays.caption := storageDetail.cooFreeStorageDays.String;
			// ### TFS CR 58263 TASK 58264 02FEB2024 NAVAB1
			if storageDetail.cooFreeStorageDays &gt; 0 then
				expiryDT := expiryDT.addDays(storageDetail.cooFreeStorageDays);
			endif;
			addFreeDays := self.txtAddFreeDaysNew.text.Integer;
			if addFreeDays &gt; 0 then
				expiryDT := expiryDT.addDays(addFreeDays);
			endif;
		// ### TFS BUG 64099 10MAY2024 NAVAB1
		else
			self.displayCOOFreeDays.caption := app.getErrorString(Storage_configurat_found); //20/05/2024	navkc1 Bug 64186
			addFreeDays := self.txtAddFreeDaysNew.text.Integer;
			if addFreeDays &gt; 0 then
				expiryDT := expiryDT.addDays(addFreeDays);
			endif;

		endif;
		
		if prevStorageExp &lt;&gt; null and prevStorageExp.freeStorageExpiry.date() &gt; expiryDT then
			//expiryDT := prevStorageExp.freeStorageExpiry.date();							//02.07.2024 navnk30 #64896
			expiryDT := self.systemToLocalTime(prevStorageExp.freeStorageExpiry).date();	//02.07.2024 navnk30 #64896
		endif;
		
		//self.displayFreeStorageExpiry.caption	:= expiryDT.String;
		if self.updateMode then				//02.07.2024 navnk30 #64896
			self.displayFreeStorageExpiry.caption	:= self.myOwnershipChange.storageExpiryOperatorNew.date.asStringJMT();
		else
			self.displayFreeStorageExpiry.caption	:= expiryDT.asStringJMT(); //20/05/2024	navkc1 Bug 64186
		endif;
	endif;

epilog
	delete pxyTi;
end;</source>
    </JadeMethod>
    <JadeMethod name="getFreeStorageForOldOperator" id="0ac952e2-3707-4ef5-b639-9c4e611153c2">
        <source>getFreeStorageForOldOperator();
/*
Purpose:			

Date		Who		Reason
20 July 2023	navab1	 CR 58239 TASK 58241 
*/

vars
	myTrackedItem 	: CM_TrackedItem;
	storageDetail 	: CM_StorageDetail;
	pxyTI			: CM_TrackedItem; //27/05/2024	navkc1 Bug 64185
	
begin
	if self.myOwnershipChange &lt;&gt; null then
		myTrackedItem := self.myOwnershipChange.getMyTrackedItem();
	else
		if self.tblData.rows &gt; self.tblData.fixedRows then
			myTrackedItem := self.tblData.accessRow(2).itemObject.CM_OwnershipChangeDetail.myTrackedItem;
		endif;
	endif;
	
	if myTrackedItem &lt;&gt; null then
		if myTrackedItem.isCargoGroupItem then
			myTrackedItem := myTrackedItem.CM_CargoGroup.allAssignedTrackedItems.first;
		endif;
		
		//27/05/2024	navkc1 Bug 64185 - If COO is already approved, we want to display the correct storage of the previous operator
		if self.myOwnershipChange &lt;&gt; null 
		and self.myOwnershipChange.isApproved() then // ### TFS CR 64164 TASK 64733 20JUNE024 NAVAB1
			pxyTI := app.createUpdateProxy(myTrackedItem).CM_TrackedItem;
			if app.myProxyManager &lt;&gt; null then
				app.myProxyManager.deleteProxyLink(pxyTI);
			endif;
			
			pxyTI.setMyOperator(self.cmbCurrentOperator.listObject.CM_Operator);
			storageDetail := pxyTI.getMatchingFreeStorageDetail(null);
		else
			storageDetail:= myTrackedItem.getMatchingFreeStorageDetail(null);
		endif;
		
		if storageDetail &lt;&gt; null then
			self.displayFreedaysOld.caption	:= storageDetail.freeStorageDays.String;
		endif;
	endif;

epilog
	delete pxyTI;
end;</source>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="8cf943a3-7cd2-4889-bddf-9c64fefd9df6">
