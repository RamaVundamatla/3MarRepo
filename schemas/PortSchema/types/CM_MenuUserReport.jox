    <JadeMethod name="pxyCreateUpdateProxy" id="41974168-bc23-4dc7-bb72-7410de3e4a43">
        <source>pxyCreateUpdateProxy(): SelfType;
// -------------------------------------------
// Created 13 December 2004 by cnwdvb1
// -------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars

	pxyMenu		: CM_MenuUserReport;
	completedOK		: Boolean;
	
begin

	pxyMenu := inheritMethod();
	
	pxyMenu.myMenuRoot	:= self.myMenuRoot;
	pxyMenu.myParent	:= self.myParent;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyMenu;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyMenu;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="sendEvent" id="5b58e271-2248-4b93-a079-ab8dbe8d4139">
        <source>sendEvent(_event : Integer; _immediate : Boolean);

vars

	user : CM_User;

begin
	if (self.myMenuRoot = null) or (not self.myMenuRoot.isKindOf(CM_MenuRootUserBackgroundReps)) then
		return;
	endif;
	
	user := self.myMenuRoot.CM_MenuRootUserBackgroundReps.myUser;
	
	if user &lt;&gt; null then
		user.causeEvent(_event, _immediate, self);	
	endif;

end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_immediate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreateTemplate" id="9bf86f31-fba9-418c-a7fc-faba777a73b8">
        <updating/>
        <source>setForCreateTemplate(_pxyMenuUserReport	: CM_MenuUserReport) updating;
// ---------------------------------------------------------------------------
// Created:     18 October 2002 by cnwth2
//
// Purpose:     Has a two separate set for creates - method signature could not inherit
//				whilst being inclusive of all neccessary data
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	realEmail : CM_EmailTemplate;

begin
//	self.name 				:= _pxyMenuUserReport.name;
	
	self.myMenuRoot			:= _pxyMenuUserReport.myMenuRoot;
	
	self.myParent			:= _pxyMenuUserReport.myParent;
	self.myMenuItem 		:= _pxyMenuUserReport.myMenuItem;

	
	self.heading			:= _pxyMenuUserReport.name;
	
end;</source>
        <Parameter name="_pxyMenuUserReport" type="CM_MenuUserReport"/>
    </JadeMethod>
    <JadeMethod name="setForProxy" id="f0121dbe-3d36-4b60-9689-21d65c2dd165">
        <updating/>
        <source>setForProxy(_reportTemplate : CM_ReportTemplate; _root : CM_MenuRoot; _parent : CM_MenuEntity) updating;
// -------------------------------------------
// Created 10 December 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	// Just some basic stuff. Everything for reports is basically a mapping
	// method on the report template. This ensures system is backward compatible.
		
	if _root = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Template Root' , null, null);
		app.raiseCMException(Input_required_field_tempRoot , null, null); // cnwdb2	PAR 35364


		return;
	endif;
	
	self.myMenuRoot			:= _root;
	
	self.myParent			:= _parent;
	self.myMenuItem 		:= _reportTemplate.myQryReport;
	self.myReportTemplate	:= _reportTemplate;

end;</source>
        <Parameter name="_reportTemplate" type="CM_ReportTemplate"/>
        <Parameter name="_root" type="CM_MenuRoot"/>
        <Parameter name="_parent" type="CM_MenuEntity"/>
    </JadeMethod>
