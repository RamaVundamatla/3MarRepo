    <JadeMethod name="doDetailEdit" id="746c4f8f-f5b7-46a1-ac1a-8227a13f70f8">
        <updating/>
        <source>doDetailEdit()updating;
// ---------------------------------------------------------------------------
// Created:     08 August 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	tbl				: CM_DataTable;
	theRow 			: Integer;
	obj				: Object;
begin
	
	tbl	:= self.tblDataDetail;
	theRow  := tbl.row;
	
	if tbl.rows &lt;= tbl.fixedRows then 
		if self.myCurrentDetailObject = null then
			app.msgBox('There is no currently selected ' &amp; self.getDataEntityDescription(false) &amp; ' to update', app.getErrorString(Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	endif;	

	self.zDoEdit();
		
end;</source>
    </JadeMethod>
