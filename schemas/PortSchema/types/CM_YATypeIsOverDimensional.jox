    <JadeMethod name="isCMIFDataMatch" id="736b810c-52fb-4bfa-a894-40342f3ddf12">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataBoolean): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	
	return _cmifAutoPlan.isOverDimensional_Match(_yaData);


end;</source>
