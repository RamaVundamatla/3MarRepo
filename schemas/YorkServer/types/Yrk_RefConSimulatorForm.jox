    <JadeMethod name="reeferMonitorTelegram" id="6154268a-a9d2-4af6-9def-57004925e088">
        <source>reeferMonitorTelegram(_ti:Yrk_Container):Binary;
// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	message,header,data: Binary;
	length: Integer;
	bin: Binary;
begin
	header := self.messageHeader(Reefer_Monitor);
	data := self.messageData(Reefer_Monitor,_ti);
	length := header.length + data.length;
	bin := length.Binary;
	header[1:1] := bin[2:1];
	header[2:1] := bin[1:1];
	message := header&amp;data;
	return message;
end;</source>
        <Parameter name="_ti" type="Yrk_Container"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="reeferMonitorTelegramNoTI" id="6be68c0a-6c7f-465a-a8ee-9304b10a2e78">
        <source>reeferMonitorTelegramNoTI(_id : String; _tempSupply : Real) : Binary;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09 September 2015	cnwdap1		Initial creation PAR #
//
vars
	message,header,data: Binary;
	ti : Yrk_Container;
	length: Integer;
	bin: Binary;
begin
	header := self.messageHeader(Reefer_Monitor);
	
	beginTransaction;
	create ti;
	ti.setForUpdate("N", " ", "DOU", "Y", "RF", " ", " ", " ", "REEF0909152", " ", 86, 20, 0, 0, 0, 0, -21, -18, -22, 0, _tempSupply, -1, self.config, "TSBS1");
	commitTransaction;
	data := self.messageData(Reefer_Monitor, ti);
	
	length := header.length + data.length;
	bin := length.Binary;
	header[1:1] := bin[2:1];
	header[2:1] := bin[1:1];
	message := header&amp;data;
	return message;
epilog
	beginTransaction;
	delete ti;
	commitTransaction;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_tempSupply" type="Real"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="sendAll" id="a94fdfb4-b178-4d89-8e52-7901decee37e">
        <updating/>
        <source>sendAll() updating;
// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	ti			: Yrk_Container;
	message		: Binary;
	count		: Integer;
begin
//	write  class.name&amp;"::"&amp;method.name&amp;" Server ";
	self.staMain.caption := "Sent Reefer Monitor message.";
	self.logReport("Sent Reefer Monitor message.");
	exclusiveLock(self.config);
	foreach ti in Yrk_Container.instances do
		count := count + 1;
		message := self.reeferMonitorTelegram(ti);
		self.sendTelegram(message);
		self.logMonitor('Sending message for ' &amp; ti.id &amp; ' Count - ' &amp; count.String);
		self.sentImAlive := false;
		app.doWindowEvents(0);
		process.sleep(300);
	endforeach;
epilog
	unlock(self.config);
end;</source>
    </JadeMethod>
    <JadeMethod name="sendOnlyOne" id="3f5590e9-adfe-4131-a4f1-6717fc92ea48">
        <updating/>
        <source>sendOnlyOne(ti : Yrk_Container) updating;
// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
