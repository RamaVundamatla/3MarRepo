    <JadeMethod name="dataDumpCheckCCT" id="b0e02cd9-2b75-46f0-9197-176cabfc5bbd">
        <source>dataDumpCheckCCT();
//dataDumpFindChageTrackerRecord();

vars
	schema : Schema;
	class : Class;
	obj : Object;
	iter : Iterator;
	value : String;
	outputStr : String;
	count : Integer;
	ddh : CM_DataDumpExtractHistory;
	dt : TimeStamp;
begin
	schema := rootSchema.getSchema("JSSChangeTrackingSchema");
	class := schema.getClass("JSSCTChangeTrackingObject");
	obj := class.lastInstance;
	ddh := "3932.2334979".asOid.CM_DataDumpExtractHistory;
	iter := class.instances.createIterator;
	while iter.back( obj ) do
//		count := count + 1;
//		if count &gt; 20 then
//			break;
//		endif;
//		outputStr := obj.String;
		dt := obj.getPropertyValue("changeTimestamp").TimeStamp;
		if dt &gt; ddh.extractedFromDateTime and dt &lt; ddh.extractedUpToDateTime then
			value := obj.getPropertyValue("className").String;
			if value = "CM_Container" then
				count := count + 1;
			value := obj.getPropertyValue("changeObjectID").String;
				outputStr := outputStr&amp;" "&amp;value.String;
			endif;
//		obj.inspect;
//			break;
		endif;
//		outputStr := outputStr &amp; " " &amp; value;
//		write outputStr;
	endwhile;
	app.msgBox(outputStr, "From "&amp;ddh.extractedFromDateTime.String&amp;" to "&amp;ddh.extractedUpToDateTime.String&amp;" "&amp;count.String, 0);
epilog
	delete iter;
end;
</source>
    </JadeMethod>
    <JadeMethod name="dataDumpCheckDSSFeatures" id="3259ff1d-eaf1-4729-b3f0-a3619a1c044a">
        <source>dataDumpCheckDSSFeatures();
//
//23 Apr 2015	cnwrs1	Par 36113 Adding DSS Class to data extract can cause extract to fail.
//
constants
	DoUpdate = false;
vars
	definition : CM_DataDumpExtractDef;
	ddExClass : CM_DataDumpExtractClass;
	ddCMFeature : CM_DataDumpFeature;
	objArray : ObjectArray;
	object : Object;
begin
	app.initialize;
	create objArray	transient;
	foreach definition in CM_DataDumpExtractDef.instances do
		if definition.extractFormat = definition.FmtExternalDatabase then
		foreach ddExClass in definition.allDataDumpExtractClasses do
			foreach ddCMFeature in ddExClass.allDataDumpFeatures do
				if not ddCMFeature.isDSS then
					write class.name&amp;'::'&amp;method.name&amp;' '&amp;definition.description.trimBlanks&amp;' '&amp;ddExClass.className&amp;' '&amp;ddCMFeature.featureName;
					objArray.add(ddCMFeature);
				endif;
			endforeach;
			if DoUpdate then
				foreach object in objArray do
					beginTransaction;
					ddExClass.allDataDumpFeatures.remove(object.CM_DataDumpFeature);
					commitTransaction;
				endforeach;
			endif;
			objArray.clear;
		endforeach;
		endif;
	endforeach;
epilog
	delete objArray;
end;
</source>
    </JadeMethod>
    <JadeMethod name="dataDumpCheckSQLNativeFeatures" id="d4467c1c-22ca-4303-b6c6-225d3fd764e4">
        <source>dataDumpCheckSQLNativeFeatures();

constants
	DDxDefDescription = "RS SQL NATIVE";
//	DoUpdate = false;
vars
	definition : CM_DataDumpExtractDef;
	ddExClass : CM_DataDumpExtractClass;
	extClass : CM_DataDumpClass;
	feature : CM_DataDumpFeature;
	ddCMFeature : CM_DataDumpFeature;
//	objArray : ObjectArray;
	object : Object;
	found : Boolean;
begin
	app.initialize;
//	create objArray	transient;
	definition := app.myRoot.allDataDumpExtractDefs[DDxDefDescription];
//	foreach definition in CM_DataDumpExtractDef.instances do
//		if definition.extractFormat &lt;&gt; CM_DataDumpExtractDef.FmtSQLNative then
//			continue;
//		endif;
	if definition.extractFormat = definition.FmtSQLNative then
		foreach extClass in app.myRoot.allDataDumpClasses do
			found := false;
			foreach ddExClass in definition.allDataDumpExtractClasses do
				if ddExClass.className = extClass.className then
					found := true;
					if extClass.allDataDumpFeatures.size &gt; 126 then 
						if ddExClass.allDataDumpFeatures.size = 126 then
							write "Class already has 126 features "&amp;extClass.className;
							continue;
						endif;
						if ddExClass.allDataDumpFeatures.size &lt; 126 then
							write "Class already has only "&amp;ddExClass.allDataDumpFeatures.size.String&amp;" features "&amp;extClass.className;
						endif;
					endif;
					if ddExClass.allDataDumpFeatures.size &lt;&gt; ddExClass.allDataDumpSQLColumns.size then
						write "Number of SQL Columns does not match number of features, re edit the class. "&amp;extClass.className&amp;' '&amp;definition.description;
					endif;
					foreach feature in extClass.allDataDumpFeatures do
						if feature.featureName = "oidBin" then
							continue;
						endif;
						if not ddExClass.allDataDumpFeatures.includes(feature) then
							
							write "Feature not included "&amp;extClass.className&amp;' '&amp;feature.featureName;
						endif;
					endforeach;
				endif;
			endforeach;
			if not found then
				write "Class not included "&amp;extClass.className;
			endif;
		endforeach;
	endif;
//	endforeach;
epilog

	
end;

</source>
    </JadeMethod>
    <JadeMethod name="dataDumpCreateEDBFeatures" id="fabd5d14-12a1-4a6d-b8f5-197c720089d3">
        <source>dataDumpCreateEDBFeatures();
// ---------------------------------------------------------------------------
// Created:     May 2008 cnwrs1
//
// Purpose:		Creates SQL file from current EDB classes.
//
// ---------------------------------------------------------------------------
vars
	class : Class;
	property : Property;
	subs : ClassColl;
	propColl : PropertyColl;
	ddFeature : DEV_DataDumpFeature;
	ddClass, addClass : DEV_DataDumpClass;
	name : String;
	typeString : String;
	length : Integer;
	
	_def: CM_DataDumpExtractDef;
	ddExClass : CM_DataDumpExtractClass;
	aClass : Class;
	ddCMFeature : CM_DataDumpFeature;
	feature: Feature;
//	property : Property;
	featureAlias : String;
	object : CM_Object;
	type, newType : Type;
	newLength : Integer;
	ddExDict : CM_DataDumpExtractClassDict;
begin
app.initialize;
	on Exception do null;
	_def := '5650.1'.asOid.CM_DataDumpExtractDef;
	beginTransaction;
	foreach ddClass in DEV_DataDumpClass.instances do
		delete ddClass;
	endforeach;
commitTransaction;
beginTransaction;
	foreach ddFeature in DEV_DataDumpFeature.instances do
		delete ddFeature;
	endforeach;
	commitTransaction;
	beginTransaction;
	create subs transient;
	ExternalObject.allSubclassesInSubschemas(subs);
	foreach class in subs do
		name := class.name[5:class.name.length].toLower();
		create ddClass;
		ddClass.name := name;
		propColl := class.allProperties();
		foreach property in propColl do
			if property.name[1:1] = '_' then
				continue;
			endif;
			if property.type = String then
				typeString := 'varchar';
				length := property.getLength()+1;
			elseif property.type = Binary then
				typeString := 'objectid';
			elseif property.type = TimeStamp then
				typeString := 'datetime';
			else
				typeString := property.type.name.toLower();
			endif;
			create ddFeature;
			ddFeature.name := property.name[5:property.name.length].toLower();
			ddFeature.owner := DEV_DataDumpFeature.Owner_SQL;
			ddFeature.type := typeString;
			ddFeature.length := length;
app.writeStatement( ddClass.name&amp;'::'&amp;ddFeature.name&amp;' SQL '&amp;ddClass.String&amp;' '&amp;ddFeature.String);
			if ddFeature.myDevClass &lt;&gt; ddClass then
				ddFeature.myDevClass := ddClass;
			endif;
		endforeach;
	endforeach;

	create ddExDict transient;
	foreach ddExClass in _def.allDataDumpExtractClasses do
		ddExDict.add(ddExClass);
	endforeach;
			
	foreach ddExClass in ddExDict do
		aClass := ddExClass.myDataDumpClass.myClass;
		name := ddExClass.myDataDumpClass.classAlias.toLower();
app.writeStatement( name); 
		ddClass := null;
		foreach addClass in DEV_DataDumpClass.instances do
			if addClass.name = name then
				ddClass := addClass;
				break;
			endif;
		endforeach;
		if ddClass = null then
			create ddClass;
			ddClass.name := name;
		endif;
		foreach ddCMFeature in ddExClass.allDataDumpFeatures do
			type := null;
			length := 0;
			featureAlias := ddCMFeature.getExternalDatabaseFeatureName(aClass, newType, newLength).toLower();
app.writeStatement( name&amp;';;'&amp;featureAlias); 
			if featureAlias = "edition" or 
			   featureAlias = "oid" then
			   	continue;
			endif;
			if newType = null then
				feature := ddExClass.myDataDumpClass.getFeatureForClass(aClass, ddCMFeature.featureName);
				if feature = null then
					feature := ddExClass.myDataDumpClass.getFeatureForClass(aClass, featureAlias);
				endif;
				if feature = null then
					feature := ddExClass.myDataDumpClass.getFeatureForSubClass(aClass, ddCMFeature.featureName);
				endif;
				if feature = null then
					feature := ddExClass.myDataDumpClass.getFeatureForSubClass(aClass, featureAlias);
				endif;
				if feature &lt;&gt; null then
					if feature.isKindOf(Method) and featureAlias &lt;&gt; 'edition' then
						type := feature.Method.getFeatureType();
						if type = String then
							length := 101;
						endif;
					else
						type := feature.type;
						if type = String then
							if feature.Attribute.getLength() &gt; 0 then
								length := feature.Attribute.getLength()-1;
							else
								length := 601;
							endif;
						endif;
					endif;
				else		
					app.writeStatement( ddExClass.myDataDumpClass.classAlias&amp;'::'&amp;ddCMFeature.featureName&amp;' or '&amp;featureAlias&amp;' no feature.');
				endif;				
			else	
				type := newType;
				length := newLength-1;
			endif;
			if type = null and featureAlias &lt;&gt; "edition" then
				app.writeStatement( ddExClass.myDataDumpClass.classAlias&amp;'::'&amp;ddCMFeature.featureName&amp;' or '&amp;featureAlias&amp;' type is null');
			endif;
			if featureAlias = "edition"  then
				typeString := 'integer';
			elseif featureAlias = DataDumpOid then
				typeString := "objectid NOT NULL";
			elseif type.isKindOf(Class) or
				   type = Class then
				typeString := "objectid";
			elseif type.name = 'TimeStamp' then
				typeString := "datetime";
			elseif type.name = 'Date' then
				typeString := "date";
			elseif type.name = 'Time' then
				typeString := 'time';
			elseif type.name = 'String' then
				typeString := "varchar("&amp;length.String&amp;")";
			elseif type.name = 'Integer' then
				typeString := "integer";
			elseif type.name = 'Boolean' then
				typeString := "boolean";
			elseif type.name = 'Real' then
				typeString := "real";
			elseif type.name = 'Decimal' then
				typeString := "decimal("&amp;feature.PrimAttribute.precision.Integer.String&amp;','&amp;feature.PrimAttribute.scaleFactor.Integer.String&amp;")";
			else
				app.writeStatement( ddExClass.myDataDumpClass.classAlias&amp;'::'&amp;featureAlias&amp;' cant handle type '&amp;type.name);
				typeString := "varchar("&amp;99.String&amp;")";
			endif;
	app.writeStatement( ddClass.name&amp;'::'&amp;featureAlias&amp;' JMT '&amp;ddClass.String&amp;' '&amp;ddFeature.String);
			if ddClass.allDevFeatures[featureAlias, DEV_DataDumpFeature.Owner_JMT] = null then
				create ddFeature;
				ddFeature.name := featureAlias;
				ddFeature.owner := DEV_DataDumpFeature.Owner_JMT;
				ddFeature.type := typeString;
				ddFeature.length := length;
if featureAlias = 'startMeterage' then
	app.writeStatement( 'stop');
endif;
				if ddFeature.myDevClass &lt;&gt; ddClass then
					ddFeature.myDevClass := ddClass;
				endif;
			endif;
		endforeach;
	endforeach;
	commitTransaction;
	app.writeStatement( "Finish.");
epilog
	delete ddExDict;
	delete subs;
end;
</source>
    </JadeMethod>
    <JadeMethod name="dataDumpCreateNewDatabaseSQL" id="a220b778-ba0c-4949-9f63-cd2545bcc81f">
        <source>dataDumpCreateNewDatabaseSQL();
// ---------------------------------------------------------------------------
// Created:     Mar 2006 cnwrs1
//
// Purpose:		Creates SQL file from current Feature list.
//
// ---------------------------------------------------------------------------
constants
	DDxDefDescription = "RS SQL NATIVE";
vars
	agent : CM_DataDumpMaintenanceAgent;
	def : CM_DataDumpExtractDef;
	fileFolder : FileFolder;
	file : File;
	dirName : String;
begin
	app.initialize;
	dirName := 'f:\software\SQL\JMT'&amp;app.myRoot.getVersionString&amp;'\';
	create fileFolder transient;
	fileFolder.fileName := dirName;
	if not fileFolder.isAvailable then
		fileFolder.make();
	endif;
	if not fileFolder.isAvailable then
		app.writeStatement( "cannot create folder requested");
		return;
	endif;
	delete fileFolder;
	create file transient;
	
	def := app.myRoot.allDataDumpExtractDefs[DDxDefDescription];
//	foreach def in app.myRoot.allDataDumpExtractDefs do
		file.fileName := dirName&amp;def.description&amp;app.myRoot.getVersionString&amp;'.sql';
		file.mode := File.Mode_Output;
		file.open;
		create agent transient;
		file.writeLine('-- JMT'&amp;CM_Version.VERSION);
		file.writeLine('');
		file.writeLine('-- add user types from def');
		file.writeLine("--CREATE TYPE objectid FROM binary(6) NOT NULL;");
		file.writeLine("--CREATE TYPE boolean FROM bit NOT NULL;");
		file.writeLine("--CREATE TYPE date FROM datetime NOT NULL;");
		file.writeLine("--CREATE TYPE time FROM datetime NOT NULL;");
		file.writeLine('');
		file.writeLine('-- begin tables');
		agent.createNewDatabaseSQL(file, def);
		
		if app.myPassport.hasErrors then
			app.writeStatement(app.myPassport.getErrorsAsString);
		endif;
		file.close;
//	endforeach;
epilog
	delete file;
	delete agent;
end;</source>
    </JadeMethod>
    <JadeMethod name="dataDumpCreateNewDbSQLFromEDB" id="f9a291f5-3ce7-432e-bef7-76a60458b57e">
        <source>dataDumpCreateNewDbSQLFromEDB();

// ---------------------------------------------------------------------------
// Created:     May 2008 cnwrs1
//
// Purpose:		Creates SQL file from current EDB classes.
//
// ---------------------------------------------------------------------------
vars
	agent : CM_DataDumpMaintenanceAgent;
	fileFolder : FileFolder;
	file : File;
	dirName : String;
begin
	app.initialize;
	dirName := 'f:\software\SQL\JMT'&amp;app.myRoot.getVersionString&amp;'\';
	create fileFolder transient;
	fileFolder.fileName := dirName;
	if not fileFolder.isAvailable then
		fileFolder.make();
	endif;
	if not fileFolder.isAvailable then
		app.writeStatement( "cannot create folder requested");
		return;
	endif;
	delete fileFolder;
	create file transient;
	
	file.fileName := dirName&amp;'EDB_Class'&amp;app.myRoot.getVersionString&amp;'.sql';
	file.mode := File.Mode_Output;
	file.open;
	create agent transient;
	file.writeLine('-- JMT'&amp;CM_Version.VERSION);
	file.writeLine('');
	file.writeLine('-- add user types from EDB_');
	file.writeLine("--CREATE TYPE objectid FROM binary(6) NOT NULL;");
	file.writeLine("--CREATE TYPE boolean FROM bit NOT NULL;");
	file.writeLine("--CREATE TYPE date FROM datetime NOT NULL;");
	file.writeLine("--CREATE TYPE time FROM datetime NOT NULL;");
	file.writeLine('');
	file.writeLine('-- begin tables');
	agent.createNewDbSQLFromEDB(file);
	
	if app.myPassport.hasErrors then
		app.writeStatement(app.myPassport.getErrorsAsString);
	endif;
	file.close;
epilog
	delete file;
	delete agent;
end;</source>
    </JadeMethod>
