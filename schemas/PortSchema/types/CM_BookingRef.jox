    <JadeMethod name="getShippingMarksCSV" id="71aeef4e-60fc-4b88-bc43-a696a4ec2a0a">
        <source>getShippingMarksCSV() : String;
/*
Purpose:		TFS 2930	
Date		Who		Reason
12 December 2016	cnwab1	Initial creation
*/

vars
	mark, marks : String;
begin
	foreach mark in self.shippingMarks discreteLock do
		if marks = null then
			marks := marks;
		else
			marks := marks &amp; "," &amp; mark;
		endif;
	endforeach;
	
	return marks;
epilog

end;</source>
