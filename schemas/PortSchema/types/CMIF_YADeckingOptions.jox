    <JadeMethod name="hasMultipleInRules" id="21c77f4a-87c6-4f8e-98b1-c1a145828407">
        <methodInvocation>mapping</methodInvocation>
        <source>hasMultipleInRules(set: Boolean; _value: Boolean io) mapping;
//----------------------------------------------------------------
//	Created:	13 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if set then
		// set code here
		return;
	else
		// get code here
		if self.myProxyDeckingOptions &lt;&gt; null then
		_value := (self.myProxyDeckingOptions.allDeckingRulesIn.size &gt; 1);
		else
			_value := false;
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="hasMultipleOutRules" id="cc954fe8-e9cd-46af-85e7-b97520cfece9">
        <methodInvocation>mapping</methodInvocation>
        <source>hasMultipleOutRules(set: Boolean; _value: Boolean io) mapping;
//----------------------------------------------------------------
//	Created:	13 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if set then
		// set code here
		return;
	else
		// get code here
		if self.myProxyDeckingOptions &lt;&gt; null then
			_value := (self.myProxyDeckingOptions.allDeckingRulesOut.size &gt; 1);
		else
			_value := false;
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isCustomIn" id="349ee6fe-2fce-4ca9-9065-6bd043b1282a">
        <methodInvocation>mapping</methodInvocation>
        <source>isCustomIn(set: Boolean; _value: Boolean io) mapping;
//----------------------------------------------------------------
//	Created:	13 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if set then
		// set code here
		return;
	else
		// get code here
		if self.myProxyDeckingOptions &lt;&gt; null
		and self.myProxyDeckingOptions.allDeckingRulesIn.size = 1 then
			_value := (self.myProxyDeckingOptions.allDeckingRulesIn.first.deckingRuleType = DeckingRule_Custom);	
		else
			//if size = 0 or &gt; 1 then cannot be
			_value := false;
		endif;
		
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isCustomOut" id="7dc9b7b6-af40-4695-9f8a-3240d6c0127b">
