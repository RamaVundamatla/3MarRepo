<Class name="WS_BookingQueryRequest" id="9b56bd1a-7e38-42b6-b84c-d9dbbfbbd827">
    <superclass name="WS_QueryRequest"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="filterBooking" id="2ee5e3e9-22e9-4194-bdc7-de4ef3840040">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="filterExternalVoyageCode" id="23a58581-b15d-42fa-8373-ea5fa3a1574a">
        <length>41</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="filterForWorkOrders" id="b7f09c51-9e78-4917-8f99-8bbafc1293a9">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="filterOperator" id="21790717-ce9b-47f9-8008-0b5eef52d337">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="filterStatus" id="47d93f57-4091-4b75-a24a-42c389f0d966">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="filterStockBooking" id="1ffb0e96-664b-4ba7-b9b5-907be051d931">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="filterVessel" id="4bb89169-4d5b-4c18-8d7b-398d05a7a13e">
        <length>26</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="filterVoyage" id="625cfc68-b63d-4082-860c-00825e212e15">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="isStockBooking" id="718ab265-e1cc-4ac4-8de7-e227fbdd9e73">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="voyageArrivalFromDate" id="0294e103-818f-46a3-ab8a-9e4ba38f8c90">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="voyageArrivalToDate" id="4bc5834e-9470-43ae-80a1-863f37111ad2">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="doesBookingMatch" id="f7ef8bda-a870-4b2b-9d60-057d933bb0c6">
        <source>doesBookingMatch(_bookingRef : CM_BookingRef;
				_filterVoyage : CM_Voyage) : Boolean;
/*

Date		Who		Reason
26 Sep 2016	cnwer1	Initial creation TFS 2526
09 May 2018 cnwma1	ChangeRequest 38518: PEL1 - WP Cargo Receivals
15 Jan 2020	jlgdap1	TFS 47457 Web Portal Bookings
18 Oct 2021	navma1	Bug 52181: SAL - Bookings - Web Portal
*/

vars
	theFilterStatus : Integer;
	terminal	    : CM_Terminal;
	vessel 	        : CM_Vessel;
	failedDAC  		: CM_DataAccessController;
	iter 			: Iterator;
	ti			   	: CM_TrackedItem;
	foundCargoForWO : Boolean;
	arrivalDT		: TimeStamp;				// TFS 47457
begin
	
	if _bookingRef = null then
		return false;
	endif;
	
	if self.filterOperator.trimBlanks() &lt;&gt; null and _bookingRef.operatorCode &lt;&gt; filterOperator.trimBlanks() then
		return false;
	endif;
	
	if self.filterBooking.trimBlanks() &lt;&gt; null and not _bookingRef.bookingReference.startsWith(filterBooking.trimBlanks) then	// TFS 47457
		return false;
	endif;
	
	theFilterStatus:=app.bookingRefStatusStringToEnum(self.filterStatus.trimBlanks());
	
	if self.filterForWorkOrders then
		//epr 2526 26/9/16
		if _bookingRef.status &lt;&gt; BOOKING_REF_ACTIVE and _bookingRef.status &lt;&gt; BOOKING_REF_PENDING then
			return false;
		endif;
		
		iter:=  _bookingRef.allTIs.createIterator;
		while iter.next(ti) do
			if not ti.isPreNote then
				continue;
			endif;
			if ti.getWorkOrderDetailOfType( WO_TASK_RECEIVE) = null then
				foundCargoForWO:=true;
				break;
			endif;					
		endwhile;
		if not foundCargoForWO then
			return false;
		endif;
	else
	
		if theFilterStatus &lt;&gt; -1 and _bookingRef.status &lt;&gt; theFilterStatus then
			return false;
		endif;
	endif;
		
	if _filterVoyage &lt;&gt; null and _bookingRef.myVoyage &lt;&gt; _filterVoyage then
		return false;
	endif;
	
	// cnwma1 TFS # 38519 09/05/2018
	if self.filterVessel &lt;&gt; null then
		if _bookingRef.myVoyage = null then
			return false;
		endif;
		vessel := app.myRoot.allVessels[self.filterVessel.toUpper.trimBlanks];
		
		if vessel &lt;&gt; null then
			if  (not vessel.canUserAccessSelf(null, failedDAC,  app.myPassport))then
				return false;
			endif;
			if _bookingRef.myVoyage.getMyVessel &lt;&gt; vessel then
				return false;
			endif;
		else
			return false;
		endif;
	endif;
	
	// cnwma1 TFS # 38519 09/05/2018
	if self.filterExternalVoyageCode &lt;&gt; null  then
		if _bookingRef.myVoyage = null  then
			return false;
		else
			if (not _bookingRef.myVoyage.canUserAccessSelf(null, failedDAC,  app.myPassport)) then
				return false;
			endif;
					
			if _bookingRef.myVoyage.voyageCodeExternal.toUpper &lt;&gt; self.filterExternalVoyageCode.toUpper  then
				return false;
			endif;
		endif;
	endif;

	if self.filterStockBooking then
		if _bookingRef.isStockBookingRef &lt;&gt; self.isStockBooking then
			return false;
		endif;
	endif;
	
	// TFS 47457 voyage arrival date checking
	if _bookingRef.myVoyage &lt;&gt; null  and  not _bookingRef.myVoyage.isNullVoyage then  //18.10.21 navma1 #52181
		arrivalDT := _bookingRef.myVoyage.getArrivalDT;
		if arrivalDT = null or not arrivalDT.isValid then
			return false;
		endif;
		if self.voyageArrivalFromDate &lt;&gt; null and arrivalDT &lt;&gt; null and arrivalDT.date &lt; self.voyageArrivalFromDate.asDate then
			return false;
		endif;
		if self.voyageArrivalToDate &lt;&gt; null and arrivalDT &lt;&gt; null and arrivalDT.date &gt; self.voyageArrivalToDate.asDate then
			return false;
		endif;
	endif;
	// TFS 47457 end
	
	return true;
epilog
	delete iter;
end;</source>
        <Parameter name="_bookingRef" type="CM_BookingRef"/>
        <Parameter name="_filterVoyage" type="CM_Voyage"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
