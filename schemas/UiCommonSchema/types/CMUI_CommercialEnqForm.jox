    <JadeMethod name="columnsVisibilityForISOType" id="997bce99-5ef4-4222-ad55-19b78ce5e46c">
        <source>columnsVisibilityForISOType( ) protected;
// ----------------------------------------------------------------
// Created:     16 May 2008 by cnwvu1
//
// Purpose:     Hides columns for ISO Type of 30, 45 and 53 footers 
//				by checking the flags in the Terminal Configuration
// ----------------------------------------------------------------

vars
	isOwn	: Boolean;
	tmpSheet: JadeTableSheet;
	
begin
	
	//-------------------------------------------------------------
	//					Container Activity
	//-------------------------------------------------------------
	tmpSheet := self.tblData.accessSheet(1);

	tmpSheet.accessColumn(5).visible := false;
	if app.is30IncludedForReportsAsColumn( isOwn ) then
		if isOwn then
			tmpSheet.accessColumn(5).visible := true;
		endif;
	endif;

	tmpSheet.accessColumn(6).visible := false;
	if app.is45IncludedForReportsAsColumn( isOwn ) then
		if isOwn then
			tmpSheet.accessColumn(6).visible := true;
		endif;
	endif;
	
	tmpSheet.accessColumn(7).visible := false;
	if app.is53IncludedForReportsAsColumn( isOwn ) then
		if isOwn then
			tmpSheet.accessColumn(7).visible := true;
		endif;
	endif;

	if app.isOtherColumnIncludedForReport() then
		tmpSheet.accessColumn(8).visible := true;	
	else
		tmpSheet.accessColumn(8).visible := false;	
	endif;

	
	//-------------------------------------------------------------
	//					Container Summary
	//-------------------------------------------------------------
	tmpSheet := self.tblData.accessSheet(2);


	tmpSheet.accessColumn(4).visible	:= false;	
	tmpSheet.accessColumn(11).visible	:= false;	
	tmpSheet.accessColumn(18).visible	:= false;	
	tmpSheet.accessColumn(25).visible	:= false;	
	if app.is30IncludedForReportsAsColumn( isOwn ) then
		if isOwn then
			tmpSheet.accessColumn(4).visible	:= true;	
			tmpSheet.accessColumn(11).visible	:= true;	
			tmpSheet.accessColumn(18).visible	:= true;	
			tmpSheet.accessColumn(25).visible	:= true;	
		endif;
	endif;

	tmpSheet.accessColumn(5).visible	:= false;	
	tmpSheet.accessColumn(12).visible	:= false;	
	tmpSheet.accessColumn(19).visible	:= false;	
	tmpSheet.accessColumn(26).visible	:= false;	
	if app.is45IncludedForReportsAsColumn( isOwn ) then
		if isOwn then
			tmpSheet.accessColumn(5).visible	:= true;	
			tmpSheet.accessColumn(12).visible	:= true;	
			tmpSheet.accessColumn(19).visible	:= true;	
			tmpSheet.accessColumn(26).visible	:= true;	
		endif;
	endif;
	
	tmpSheet.accessColumn(6).visible	:= false;	
	tmpSheet.accessColumn(13).visible	:= false;	
	tmpSheet.accessColumn(20).visible	:= false;	
	tmpSheet.accessColumn(27).visible	:= false;	
	if app.is53IncludedForReportsAsColumn( isOwn ) then
		if isOwn then
			tmpSheet.accessColumn(6).visible	:= true;	
			tmpSheet.accessColumn(13).visible	:= true;	
			tmpSheet.accessColumn(20).visible	:= true;	
			tmpSheet.accessColumn(27).visible	:= true;	
		endif;
	else
	endif;

	if app.isOtherColumnIncludedForReport() then
		tmpSheet.accessColumn(7).visible	:= true;	
		tmpSheet.accessColumn(14).visible	:= true;	
		tmpSheet.accessColumn(21).visible	:= true;	
		tmpSheet.accessColumn(28).visible	:= true;	
	else
		tmpSheet.accessColumn(7).visible	:= false;	
		tmpSheet.accessColumn(14).visible	:= false;	
		tmpSheet.accessColumn(21).visible	:= false;	
		tmpSheet.accessColumn(28).visible	:= false;	
	endif;
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
