    <JadeMethod name="tCoparnSNO5705PrenoteDelete" id="e6366bc2-141c-456d-b2eb-bfdb7cbbd936">
        <source>tCoparnSNO5705PrenoteDelete();
//
//10 April 2018	jlgrs1	Initial creation
//
constants
	HSDExample : String = "HSDExample";
	KKKExample : String = "KKKExample";
	GBExample : String = "GBExample";
	USER_DEF_NAME	: String = "SNO_COPARN";
	VesselCode : String = "SNOVESSEL";
	Voyage_Code : String = "7905N";
	EDIPartyName : String = "SNO_COPARN7905";
//	BookingNo : String = "48563500";
	Prenote1 : String = "SNOW1111111";
	Prenote2 : String = "SNOW1111121";
	Prenote3 : String = "SNOW1111131";
	Prenote4 : String = "SNOW1111141";
	VehicleId : String = "UTTRUCK1";
vars
	terminal : CM_Terminal;
	oper : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediParty : CM_EDIParty;
	proxyEDIParty : CM_EDIParty;
	pxyRules : CM_EDIPartyRules;
	pxyItem	: CM_EDIEDIFactRule;
	ediFile : CM_EDIFile;
	subTerminal : CM_SubTerminal;
	ediItem : CM_EDITrackedItem;
	coparnInput : String;
	errorMsg : String;
//	booking : CM_BookingRef;
//	bookingItems : Integer;
	prenote : CM_TrackedItem;
	vvr : CM_VehicleVisitRecord;
	singleGate : CM_Gate;
	int : Integer;
begin
	self.setTerminalConfig(EdiBookingAllowPartial, true);
	self.setTerminalConfig(EdiReleaseAllowPartial, true);
	terminal := self.getTerminal;
	oper := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	prenote := self.getTrackedItem(Prenote1);
	self.deleteTrackedItem(prenote, true);
	prenote := self.getTrackedItem(Prenote1);
	self.assertIsDeleted(prenote);
	prenote := self.getTrackedItem(Prenote2);
	self.deleteTrackedItem(prenote, true);
	prenote := self.getTrackedItem(Prenote2);
	self.assertIsDeleted(prenote);
	prenote := self.getTrackedItem(Prenote3);
	self.deleteTrackedItem(prenote, true);
	prenote := self.getTrackedItem(Prenote3);
	self.assertIsDeleted(prenote);
	prenote := self.getTrackedItem(Prenote4);
	self.deleteTrackedItem(prenote, true);
	prenote := self.getTrackedItem(Prenote4);
	self.assertIsDeleted(prenote);
	self.deleteVessel(VesselCode);
	vessel := self.getVessel(VesselCode);
	self.assertIsDeleted(vessel);
	self.deleteVoyage(Voyage_Code);
	voyage := self.getVoyage(Voyage_Code);
	self.assertIsDeleted(voyage);
	self.createVoyageVessel(Voyage_Code, VesselCode, voyage, vessel);
	self.assertNotNullMsg(vessel, "Add vessel failed!");
	self.assertNotNullMsg(voyage, "Add voyage failed!");
	self.addVoyageToEDIProcessing(voyage);
	self.setTerminalConfig(EdiUseOldCoparn, false);
	// Create the party rules.
	self.deleteEDIParty(EDIPartyName);
	ediParty := self.createEDIParty(EDIPartyName, EDIPartyName, "TOFU", oper);
	if terminal.isSubTerminalsOn then
		subTerminal := terminal.getDefaultSubTerminal(CM_SubTerminal.Type_BulkRelease, BR_TYPE_ROAD, 0, null, false);
	endif;

	beginLoad;
	proxyEDIParty := ediParty.pxyCreateUpdateProxy;
	endLoad;
	create pxyRules as CM_EDIPartyCoparnRules transient;	
	pxyRules.setMyEDIParty(proxyEDIParty);
	pxyRules.setMyEDIConfig(terminal.myEdiConfig);
	pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::defaultReleaseType.name, BR_TYPE_UNKNOWN);
	pxyRules.CM_EDIPartyCoparnRules.setCoparnEDIDataStyle(false);
	if terminal.isSubTerminalsOn then
		pxyRules.setPropertyValue(CM_EDIPartyCoparnRules::myDefaultSubTerminal.name, subTerminal);
	endif;

	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_BGM_1_1, '11', CM_EDIEDIFactRule.Function_BGM_1_1_Booking);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_BGM_1_1, '12', CM_EDIEDIFactRule.Function_BGM_1_1_Release);
	create pxyItem transient;
	pxyItem.setMyEDIPartyRules(pxyRules);
	pxyItem.setProxy(CM_EDIEDIFactRule.Item_BGM_1_1, '27', CM_EDIEDIFactRule.Function_BGM_1_1_Prenote);

	app.myTrxUA.trxUpdateEDIParty(proxyEDIParty, app.myPassport);
	
	delete pxyItem;
	delete proxyEDIParty;

	coparnInput := self.zCoparnFile5705(5);
	ediFile	:=	self.ediLoadFileName(coparnInput, EDIFileType_Unknown, "COPARN", USER_DEF_NAME&amp;"1"&amp;method.name);
	self.assertNotNull(ediFile);
//	filesToDelete.add(ediFile);
	
	self.ediVerify(ediFile);
	errorMsg :=	"Verify failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertIsOneOf(	ediFile.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	errorMsg :=	"Load failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);

	// set up the vehicle
	self.deleteVehicle(VehicleId);
	// gate in the container with no carrier
	prenote := self.getTrackedItem(Prenote1);
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	self.opts.addAssoc("AutoComplete", true);
	vvr := self.gateInPrenote(VehicleId, "", "", prenote, singleGate);
	self.assertNotNull(vvr);
	assertTrue(getTrackedItem(Prenote1).isOnSite);

	// set up the vehicle
	self.deleteVehicle(VehicleId);
	// gate in the container with no carrier
	prenote := self.getTrackedItem(Prenote2);
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	self.opts.addAssoc("AutoComplete", true);
	vvr := self.gateInPrenote(VehicleId, "", "", prenote, singleGate);
	self.assertNotNull(vvr);
	assertTrue(getTrackedItem(Prenote2).isOnSite);

	// set up the vehicle
	self.deleteVehicle(VehicleId);
	// gate in the container with no carrier
	prenote := self.getTrackedItem(Prenote3);
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	self.opts.addAssoc("AutoComplete", true);
	vvr := self.gateInPrenote(VehicleId, "", "", prenote, singleGate);
	self.assertNotNull(vvr);
	assertTrue(getTrackedItem(Prenote3).isOnSite);

	// set up the vehicle
	self.deleteVehicle(VehicleId);
	// gate in the container with no carrier
	prenote := self.getTrackedItem(Prenote4);
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	self.opts.addAssoc("AutoComplete", true);
	vvr := self.gateInPrenote(VehicleId, "", "", prenote, singleGate);
	self.assertNotNull(vvr);
	assertTrue(getTrackedItem(Prenote4).isOnSite);

	self.assertEqual(ediFile.ediData.allEDITrackedItems.size, 4);
	if ediFile.ediData.isKindOf(CM_EDIDataBooking) then
		return;
	endif;
	prenote := self.getTerminal.searchForOnsiteTI(Prenote1, int, 1);
	self.assertNotNull(prenote);
	prenote := self.getTerminal.searchForOnsiteTI(Prenote2, int, 1);
	self.assertNotNull(prenote);
	prenote := self.getTerminal.searchForOnsiteTI(Prenote3, int, 1);
	self.assertNotNull(prenote);
	prenote := self.getTerminal.searchForOnsiteTI(Prenote4, int, 1);
	self.assertNotNull(prenote);
	
	coparnInput := self.zCoparnFile5705(6);
	ediFile	:=	self.ediLoadFileName(coparnInput, EDIFileType_Unknown, "COPARN", USER_DEF_NAME&amp;"1"&amp;method.name);
	self.assertNotNull(ediFile);
//	filesToDelete.add(ediFile);
	
	self.ediVerify(ediFile);
	errorMsg :=	"Verify failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertIsOneOf(	ediFile.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS,
						CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X);
	
	self.ediDBLoad(ediFile);
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) then
		errorMsg :=	"Load failed with - " &amp; app.myPassport.getErrorsAsString();
		self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL_X, errorMsg);
		self.assertEqual(ediFile.ediData.allEDITrackedItems.size, 4);
	
		prenote := self.getTerminal.searchForNotifiedTI(Prenote1, int);
		self.assertNull(prenote);
		prenote := self.getTerminal.searchForNotifiedTI(Prenote2, int);
		self.assertNull(prenote);
		prenote := self.getTerminal.searchForNotifiedTI(Prenote3, int);
		self.assertNull(prenote);
		prenote := self.getTerminal.searchForNotifiedTI(Prenote4, int);
		self.assertNull(prenote);
	else
		errorMsg :=	"Load failed with - " &amp; app.myPassport.getErrorsAsString();
		self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, errorMsg);
	
		self.assertEqual(ediFile.ediData.allEDITrackedItems.size, 4);
	
//		prenote := self.getTerminal().allNotifiedTIsByIdCargoType[Prenote1, 1]; //cnwrs1 par 21329 19 Jan 2010
		prenote := self.getTerminal.searchForNotifiedTI(Prenote1, int);
		self.assertNull(prenote);
		prenote := self.getTerminal.searchForNotifiedTI(Prenote2, int);
		self.assertNull(prenote);
		prenote := self.getTerminal.searchForNotifiedTI(Prenote3, int);
		self.assertNull(prenote);
		prenote := self.getTerminal.searchForNotifiedTI(Prenote4, int);
		self.assertNull(prenote);
	endif;
epilog

end;</source>
