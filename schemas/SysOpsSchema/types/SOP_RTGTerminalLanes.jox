        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 July 2008	cnwer1	Initial creation

*/

vars
	i,j : Integer;
	stepSize : Integer;
	lineSize : Integer;
	rtgArea : CM_RTGArea;
	
begin
	gridSize:=5;
	zoom:=2;
	
	inheritMethod();


	self.setupScrollableMain();
