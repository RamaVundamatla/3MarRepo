<Class name="CM_WOReceiveCargoRequest" id="3b2eeef7-c3f7-4074-bb70-904e013d9429">
    <superclass name="CM_WORequest"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="createWLE" id="ae020630-164d-455c-a6be-a16c69eb792e">
        <source>createWLE() : CM_WorkListEntry;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
10 July 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema

*/

vars

	wle	: CM_WOReceiveCargoWLE;

begin

	create wle;
	wle.setForCreate(self.myJob, self);
	wle.causeEvent(wle.job.getMyTerminal.getTerminalEvent(WLE_Create_Event), false, wle);	

	return wle;
epilog

end;</source>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="createWLEs" id="db4a3fa8-b4f0-418a-91f8-7ea096df0603">
        <updating/>
        <source>createWLEs() updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Jul 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
04 Oct 2023 navhl20 ChangeRequest 60033: EUP | Ship Operations in DD - [54176.010] - [Receive] Ship Job List 
*/

vars

	i,
	numReq,
	numTIs		:	Integer;
	aWLE		:	CM_WorkListEntry;
	theTI		: 	CM_TrackedItem;
	iter		: 	Iterator;
begin
	//------------
	//Create the appropriate WLEs
	// 1 for each ti on the job and extra up to totalRequested
	//------------
	
	numTIs := self.myJob.CM_WOReceiveCargoJob.allTrackedItems.size;
	
	numReq := self.totalRequested;
	i := 1;		
	
	if numReq &lt; numTIs then
		numReq := numTIs;
	endif;
	
	iter := self.myJob.CM_WOReceiveCargoJob.allTrackedItems.createIterator;

	// step through all real ti's on the job 
	//then continue untill we have all we need
	
	while iter.next(theTI) do
	// create WLE , create pack  on ti link that to the wle			
		aWLE := self.createWLE();
		aWLE.setMyTrackedItem( theTI); // set the tracked item
		aWLE.setQuantity(theTI.totalQuantity);		//04.10.2023 navhl20 #60033
		aWLE.setWeight(theTI.totalWeight);			//04.10.2023 navhl20 #60033
		i := i+1;	
	endwhile;
		
	while true do
		if i &gt; numReq then
			//If total requested = 0 then we always create 1
			break;
		endif;

		//create 'empty' WLE's will fill them later
		aWLE := self.createWLE();
		i := i+1;		
	endwhile;

epilog
	delete iter;
end;</source>
    </JadeMethod>
