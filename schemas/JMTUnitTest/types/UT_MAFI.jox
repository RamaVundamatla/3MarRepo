    <JadeMethod name="tMAFIChangeVoyage" id="56284b15-bf2e-419c-8203-969bd0434f2d">
        <source>tMAFIChangeVoyage();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Nov 2025 navhl20 Bug MTN-33391: CUX - Change voyage to ***** for MAFIs with onboard break bulk not possible

*/

constants
	Ref				= "33391";
	Id				= "UT1" &amp; Ref;
	CargoId			= "UTC1" &amp; Ref;
	Cargo_Type 		= "UTMAFI2";
	TrailerType 	= "UTMAFI2";
	TrailerTypeDesc = "UTMAFI - MAFI Trailer Type";
	VoyageID 		= "UT1" &amp; Ref&amp; "_VOY";
	VesselID 		= Ref &amp; "_VSL1";
vars
	ct 				: CM_CargoType;
	tt				: CM_TILCType;
	trailer,
	pxyTrailer		: CM_TILC;
	bs1				: CM_BlockStack;
	cargo			: CM_TrackedItem;
	voyage,
	newVoyage		: CM_Voyage;
	vessel			: CM_Vessel;
	location		: CM_LocationsController;
	cargoType		: CM_CargoType;
	product			: CM_Product;
	terminal 		: CM_Terminal;
begin
	terminal := self.getTerminal;	
	
	self.opts.purge;
	self.opts.addAssoc("TrackAs",ProductType_Trailer);
	ct:=self.addCargoType(Cargo_Type, false);
	
	self.assertNotNull(ct);
	self.assertEqual(ct.productType,ProductType_Trailer);
	self.assertEqual(ct.myClassToCreate, CM_TILC);
	
	tt := self.addTrailerType(TrailerType,TrailerTypeDesc,ct,500,1,50,30000,13000,null,TRAILER_CATEGORY_MAFI,500);
	self.assertNotNull(tt);
	
	bs1:=self.addBlockStack("BSCHAS",999,null);
	vessel := self.addVesselWithHolds(VesselID, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VoyageID, vessel.name, vessel.myOperator.code, null, 0);
	
	trailer:=self.addTrailerAtLocation(Id,ct,tt,self.getOperator("PON"),bs1.myLocationsController).CM_TILC;
	beginTransaction;
		trailer.setMyVoyage(voyage,app.myPassport);
	commitTransaction;
	self.assertNotNull(trailer);
	self.assertEqual(trailer.myPrimaryActualLocation,bs1.myLocationsController);
	
	location := trailer.getNextFreeLC;
	cargoType := terminal.allCargoBOLTypes.getCargoTypeByAbbreviation("STEEL COIL").CM_CargoType;
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.getProductFromCode("TIEWIRE10G");
	self.assertNotNullMsg(product, "product");
	
	self.opts.purge();
	self.opts.addAssoc("Product", product);
	cargo := self.addCargoBreakBulkAtLocation(CargoId, cargoType, 500, location, null, TI_IMEX_STATUS_IMPORT, voyage, self.getOperator("PON"));
	self.assertNotNull(cargo);
	self.assertEqual(cargo.myPrimaryActualLocation,location);
	
	foreach location in voyage.allVoyageLocations do
		if location.isKindOf(CM_GeneralCargoController) then
			break;
		endif;
	endforeach;
	
	self.moveQueued(trailer,location);
	self.moveQueued(cargo,location);
	newVoyage := self.getTerminal.allVoyagesByCode[NULL_VOYAGE_CODE,null];
	beginTransaction;
	pxyTrailer := trailer.pxyCreateUpdateProxy();
	commitTransaction;
	
	pxyTrailer.setMyVoyage(newVoyage,app.myPassport);
	
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxUpdateTrackedItem(pxyTrailer, null, TI_UPDMODE_NORMAL, null, app.myPassport);
	self.assertNotEqual(trailer.myVoyage,voyage);
	self.assertNotEqual(cargo.myVoyage,voyage);
epilog
	delete pxyTrailer;
	self.deleteTrailerType(tt);
	self.deleteTrackedItem(trailer,false);
	self.deleteTrackedItem(cargo,false);
	self.deleteCargoType(Cargo_Type);
	self.deleteVessel(VesselID);
	self.deleteVoyage(VoyageID);
end;</source>
    </JadeMethod>
    <JadeMethod name="tMAFIGateExport" id="296d4b86-75fc-41f6-9b49-6f70a6992b24">
        <source>tMAFIGateExport();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason 
27 October 2022	jlier1	Initial creation 54675

*/
constants
	AreaName = "UTMAFHA";
	AreaNameB = "UTMAFHB";
	VoyageName ="UTVMAFI";
	YAName  = "UTYAMAFI";
	MAFI1 = "MAFI31102201";
	MAFI2 = "MAFI31102202";
	MAFI3 = "MAFI31102203";
	MAFI4 = "MAFI31102204";
	MAFI5 = "MAFI31102205";
	Cargo_Type = "UTMAFI";
	TrailerType ="UTMAFI";
	Container1 = "CON31102201";
	TruckIn ="UTTRUMAFI";
vars
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	locations : CM_LCArray;
	mafiHeapA,
	mafiHeapB : CM_BlockStack;
	mafi1,
	mafi2,
	mafi3,
	mafi4,
	mafi5,
	pxyTI : CM_TILC;
	cargoType : CM_CargoType;
	trailerType : CM_TILCType;
	operator : CM_Operator;
	terminal : CM_Terminal;
	cont1 : CM_TrackedItem;
	vvrIn : CM_VehicleVisitRecord;
	gate  : CM_Gate;
	planLocation : CM_LocationsController;
	queueEntry : CM_RTQueueEntry;
	machine : CM_Machine;
	tas : StringArray;
	trx : CM_TITransaction;
begin
	self.tMAFIHeap;
	
	mafiHeapA:=self.getTerminalArea(AreaName).CM_BlockStack;
	self.assertNotNull(mafiHeapA);
	self.opts.purge;
	self.opts.addAssoc("TA_Type",TA_TYPE_MAFI);
	mafiHeapB:=self.addBlockStack(AreaNameB,null,null);
	self.assertNotNull(mafiHeapB);
	
	vessel := self.addVesselWithHolds(	VoyageName, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VoyageName, vessel.name, vessel.myOperator.code, "APL", 0);
		disableAllYA(true);
	create locations transient;
	locations.add(mafiHeapA.myLocationsController);
	locations.add(mafiHeapB.myLocationsController);
	self.addYA(YAName, YACriteriaType_ImexStatus, "EXP",YACriteriaType_Voyage,VoyageName,null,null,locations,null);
	
	//create machine rules 
	//gate to mafi heap - Forklift - MAFI
	self.addMachineRuleType(app.myRoot.allTerminalAreaTypes.getAtKey(TA_TYPE_GATE_ROAD),app.myRoot.allTerminalAreaTypes.getAtKey(TA_TYPE_MAFI),RTMoveMethod_41,FullMoveQueuing);
	// mafi heap to WP Interchange - Tractor
	self.addMachineRuleType(app.myRoot.allTerminalAreaTypes.getAtKey(TA_TYPE_MAFI),app.myRoot.allTerminalAreaTypes.getAtKey(TA_TYPE_WORKPOINT_INTERCHANGE),RTMoveMethod_39,FullMoveQueuing);
	
	//create 2 storgage MAFI in MAFIAREAA
	cargoType:= app.myRoot.getCargoTypeFromAbbrevOrDescr(Cargo_Type).CM_CargoType;
	self.assertNotNull(cargoType);
	trailerType:= cargoType.allTILCTypes[TrailerType];
	self.assertNotNull(trailerType);
	operator:=app.myRoot.allOperators["MSC"];
	self.assertNotNull(operator);
	
	self.deleteCargo(MAFI1,cargoType);	
	self.opts.purge;
	self.opts.addAssoc("ContentsStatus",TI_CONTENTS_STATUS_EMPTY);
	
	mafi1:=self.addTrailerAtLocation(MAFI1,cargoType,  trailerType,operator,mafiHeapA.myLocationsController);
	self.assertNotNull(mafi1);
	self.assertTrue(mafi1.getContentsStatus = TI_CONTENTS_STATUS_EMPTY);
	
	self.deleteCargo(MAFI2,cargoType);	
	self.opts.purge;
	self.opts.addAssoc("ContentsStatus",TI_CONTENTS_STATUS_EMPTY);
	
	mafi2:=self.addTrailerAtLocation(MAFI2,cargoType,  trailerType,operator,mafiHeapA.myLocationsController);
	self.assertNotNull(mafi2);
	self.assertTrue(mafi2.getContentsStatus = TI_CONTENTS_STATUS_EMPTY);
	
	//3 export mafi in MAFI B for voyage 
	self.deleteCargo(MAFI3,cargoType);	
	mafi3:=self.addTrailerAtLocation(MAFI3,cargoType,  trailerType,app.myRoot.allOperators["MSK"],mafiHeapB.myLocationsController);
	self.assertNotNull(mafi3);
	beginTransaction;
	mafi3.setImExStatus(TI_IMEX_STATUS_EXPORT);
	commitTransaction;
	
	self.deleteCargo(MAFI4,cargoType);	
	mafi4:=self.addTrailerAtLocation(MAFI4,cargoType,  trailerType,operator,mafiHeapB.myLocationsController);
	self.assertNotNull(mafi4);
	beginTransaction;
	mafi4.setImExStatus(TI_IMEX_STATUS_EXPORT);
	commitTransaction;
	
	
	self.deleteCargo(MAFI5,cargoType);	
	mafi5:=self.addTrailerAtLocation(MAFI5,cargoType,  trailerType,operator,mafiHeapB.myLocationsController);
	self.assertNotNull(mafi5);
	beginTransaction;
	mafi5.setImExStatus(TI_IMEX_STATUS_EXPORT);
	commitTransaction;
	//set ignore TEU capacity to false
	
	terminal:=self.getTerminal();
	beginTransaction;
	terminal.setConfig(IgnoreTrailerTypeTEUCap,false);
	commitTransaction;
	
	
	//create 2 prenote containers export 40' for the voyage
	//create a pre note to gate in
	self.opts.purge;
	
	self.opts.addAssoc( "CargoType", TI_CargoType_Container );
	self.opts.addAssoc( "ISOType", "4200" );
	self.opts.addAssoc( "Commodity", "MT" );
	self.opts.addAssoc( "OperatorCode", vessel.myOperator.code );
	self.opts.addAssoc("ExportVoyage",voyage);
	cont1 := self.addPrenoted( Container1 ).CM_Container;
	self.assertNotNull(cont1);
	
	//road gate in prenote
	self.deleteVehicle( TruckIn );
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	self.assertTrueMsg(gate &lt;&gt; null, "No gate not found during setup.");
	vvrIn:=self.gateInPrenote(TruckIn,null,null,cont1,gate);
	
	self.assertNotNull(vvrIn);
	//should fail to auto plan to mafi heap
	self.assertNotNull(cont1.myPrimaryQueuedLocation);
	self.unqueueTI(cont1);
	
	
	//set ignore TEU capacity to true
	beginTransaction;
	terminal.setConfig(IgnoreTrailerTypeTEUCap,true);
		terminal.setConfig(AutoPlanToEmptyMAFIs,true);
	commitTransaction;
	//queue cargo on truck - operators, voyage and discharge port need to be the same
	// the cargo operator is different to the trailer so should fail
	planLocation := app.autoPlanTiYA(self.getTerminal, null, cont1);
	self.assertNull(planLocation); //operators 
	
	//change cargo operator
	beginTransaction;
		cont1.setMyOperator(mafi3.myOperator);
	commitTransaction;
	planLocation := app.autoPlanTiYA(self.getTerminal, null, cont1);
	self.assertNotNull(planLocation); 
	self.assertEqual(planLocation,mafi3.CM_TILC.allLCs.first);
	self.moveQueued(cont1,planLocation);
	
	queueEntry:=cont1.getQueueEntry();
	
	self.assertNotNull(queueEntry);
	self.assertEqual(queueEntry.myRTMoveMethodRule.myRTMoveMethod.type, RTMoveMethod_41);
	self.assertEqual(queueEntry.allTasks.first.machineTypeGroup, MACHINETYPEGRP_LIFTER);
	self.assertEqual(queueEntry.allTasks.last.machineTypeGroup, MACHINETYPEGRP_MAFI);
	self.assertEqual(queueEntry.allTasks.last.targetLocationId, "(MAFI in) " &amp; AreaNameB ); //setdown container on a MAFI in mafi heap B
	
	//lets pick it up with a fork lift that has access to MAFIHEAP1
	
	create tas transient;
	tas.add(AreaName);
	tas.add(AreaNameB);
	machine:=self.addForkLift("UTF1", 91, tas, cont1.queueId);
	self.assertNotNull(machine);
	
	app.myTrxUA.trxMachinePickupTask( machine, null, null, app.myPassport);
	self.assertNoTrxErrors;
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxMachineSetdownTask(machine, queueEntry.allTasks.last, null, MAFI4, null, false, false,null, false,app.myPassport);
	self.assertNoTrxErrors;
	//content status of the MAFI should now be full
	self.assertTrue(mafi4.contentsStatus = TI_CONTENTS_STATUS_FCL);
	trx:=mafi4.getLastTransOfType(TRANS_TYPE_TRAILER_CARGO_LOAD);
	self.assertNotNull(trx);
	self.assertTrue(trx.contentsStatus  = TI_CONTENTS_STATUS_FCL);
	
	self.moveCargo(cont1,null,mafiHeapB.allLocationsControllers.first,app.myPassport);
	self.assertNoTrxErrors;
	trx:=mafi4.getLastTransOfType(TRANS_TYPE_TRAILER_CARGO_DIS);
	self.assertNotNull(trx);
	self.assertTrue(trx.contentsStatus  = TI_CONTENTS_STATUS_EMPTY);
	
	
epilog
	if terminal &lt;&gt; null then
		beginTransaction;
		terminal.setConfig(IgnoreTrailerTypeTEUCap,false);
		terminal.setConfig(AutoPlanToEmptyMAFIs,false);
		commitTransaction;
	endif;
	
	delete locations;
	delete tas;
	disableAllYA(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="tMAFIHeap" id="7d0215a5-508f-468e-b6a4-28e528816a2a">
        <source>tMAFIHeap();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 October 2022	jlier1	Initial creation 54675
10 Mar 2023		jlika1	TFS 56923 - Add width to Trailer
*/
constants	
	AreaName = "UTMAFHA";
	Cargo_Type = "UTMAFI";
	TrailerType ="UTMAFI";
	TrailerTypeDesc ="UTMAFI - MAFI Trailer Type";
vars
	pxyBlockStack : CM_BlockStack;
	realTA 			: CM_TerminalAreaMaster;
	pDO				: CM_YADeckingOptionsTA;
	ct  : CM_CargoType;
	tt : CM_TILCType;
begin

	self.deleteTerminalArea(AreaName);
	
	create pxyBlockStack transient;
	pxyBlockStack.setProxy(AreaName, 
					"",
					TA_TYPE_MAFI, 
					999,
					5,
					5,
					false,
					"", 
					999,
					true, 
					null,
					self.getTerminal,
					false,
					false,
					false,
					false,
					false,
					null,
					null,
					false
					);
	create pDO transient;
	pDO.setProxy(false, true, pxyBlockStack);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);

		
	app.myTrxCA.trxCreateTerminalArea(pxyBlockStack, realTA, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
		
	self.assertEqual(realTA.type, TA_TYPE_MAFI);
	self.assertEqual(realTA.typeString,app.myRoot.allTerminalAreaTypes[TA_TYPE_MAFI].description);
	
	self.opts.purge;
	self.opts.addAssoc("TrackAs",ProductType_Trailer);
	ct:=self.addCargoType(Cargo_Type, false);
	
	tt:=self.addTrailerType(TrailerType,TrailerTypeDesc,ct,1,600,600,30000,6000,300,TRAILER_CATEGORY_MAFI,null);
	
	self.addYAToBlockStack("UT_YAMAFI", YACriteriaType_TrailerType, tt, realTA.CM_BlockStack);
	
	self.assertEqual(realTA.CM_TerminalArea.allYABlocks.size,1);
	self.assertTrue(realTA.CM_TerminalArea.allYABlocks.first.isKindOf(CM_YABlockMAFI));
epilog
	delete pxyBlockStack;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tMAFITrailerType" id="ae344b52-f996-4a5a-b1fe-dcbf48a877a4">
        <source>tMAFITrailerType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 October 2022	jlier1	Initial creation 54675
10/03/2023	jlika1	Add width to Trailer Type
*/

constants

	Cargo_Type = "UTMAFI";
	TrailerType ="UTMAFI";
	TrailerTypeDesc ="UTMAFI - MAFI Trailer Type";
	
vars
	ct : CM_CargoType;
	tt,pxyTrailerType	: CM_TILCType;
begin
	
	self.opts.purge;
	self.opts.addAssoc("TrackAs",ProductType_Trailer);
	ct:=self.addCargoType(Cargo_Type, false);
	
	self.assertNotNull(ct);
	self.assertEqual(ct.productType,ProductType_Trailer);
	self.assertEqual(ct.myClassToCreate, CM_TILC);
	
	tt := app.myRoot.allTILCTypes[null, TrailerType];
	self.deleteTrailerType(tt);
	tt:=null;
	create pxyTrailerType transient;
	pxyTrailerType.setProxy(TrailerType,										// code : String;
							TrailerTypeDesc,										// description : String;
							ct,										// cargoType : CM_CargoType;
							60,											// length : Integer;
							3,									// numControllers : Integer
							600,											// maxHeight : Integer;
							30000, 										// maxWeight : Integer;
							5000, 										
							null,												// colour : Integer
							false,
							300,
							TRAILER_CATEGORY_MAFI,							
							500,
							null,												// par 30852 Dec 2012
							false												//15/10/2025	navkc1 JIRA 36057
							);
							
	app.myTrxCA.trxCreateTILCType(pxyTrailerType, tt, app.myPassport);
	delete pxyTrailerType;
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertNotNull(tt);
	self.assertEqual(tt.numControllers,3);
	self.assertEqual(tt.category,TRAILER_CATEGORY_MAFI);
	self.assertEqual(tt.tareWeight,5000.Decimal);
	self.assertEqual(tt.height,300.Decimal);
	self.assertEqual(tt.width.asStringJMT,"500.0000");
	beginLoad;
	pxyTrailerType:=tt.pxyCreateUpdateProxy;
	endLoad;
	
	pxyTrailerType.setProxy(pxyTrailerType.code,
							pxyTrailerType.description,
							pxyTrailerType.myCargoType,
							pxyTrailerType.length,
							pxyTrailerType.numControllers,
							pxyTrailerType.maxHeight,
							pxyTrailerType.maxWeight,
							6000.000,
							pxyTrailerType.colour,
							false,
							350,
							TRAILER_CATEGORY_TRAILER,
							null,
							null,
							false			//15/10/2025	navkc1 JIRA 36057
							);
	app.myTrxUA.trxUpdateTILCType(pxyTrailerType,app.myPassport);
	
	self.assertNotNull(tt);
	self.assertEqual(tt.category,TRAILER_CATEGORY_TRAILER);
	self.assertEqual(tt.tareWeight,6000.Decimal);
	self.assertEqual(tt.height,350.Decimal);
epilog
	delete pxyTrailerType;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTrailerTransactions" id="350c52fe-d411-4bb4-98c9-b3e3399a8b20">
        <source>tTrailerTransactions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason 
27 Feb 2025	navsp1	Initial creation JIRA-19358

*/
constants

	VesselCode 		: String = 'VES19358';
	VoyageCode 		: String = 'VOY19358';
	
	MAFI_ID_A		: String = "MAFI8";
	TILC_ID_A		: String = "TILC8";
	CONT_ID_A		: String = "TI000019358";
	BBLK_ID_A		: String = "BB000019358";
	
	BBULKCargoType 	: String = "BBCT"; 
	MAFICargoType 	: String = "MFCT";
	TrailerType 	: String = "TRLT1";
	TrailerType2 	: String = "TRLT2";
	MAFIAreaName 	: String = "MFA1";
	TrailerTypeDesc : String = "TRLT1 - MAFI Trailer Type";
	TrailerTypeDesc2: String = "TRLT2 - Non MAFI Trailer Type";
vars

	operator 		: CM_Operator;
	shipLineStr 	: String;
	nullVoyage		: CM_Voyage;
	voyage 			: CM_Voyage;
	vessel			: CM_Vessel;
	bbCargoType 	: CM_CargoType;
	mafiCargoType	: CM_CargoType;
	contCargoType 	: CM_CargoType;
	trailerType		: CM_TILCType;
	trailerType2	: CM_TILCType;	
	mafiHeap		: CM_BlockStack;	
	bblkTI			: CM_BreakBulkGeneric;
	contTI			: CM_Container;
	mafiTI			: CM_TILC;
	trailerTI		: CM_TILC;	
	trx 			: CM_TITransaction;	
begin
	//==========================
	// Generic Stuff
	//==========================
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	shipLineStr := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	nullVoyage := self.getVoyage(NULL_VOYAGE_CODE);
	
	//==========================
	// Clean-up
	//==========================
	self.deleteCargo(BBLK_ID_A, BBULKCargoType);
	self.deleteCargo(CONT_ID_A, TI_CargoType_Container);
	self.deleteCargo(MAFI_ID_A, MAFICargoType);
	self.deleteVoyage(VoyageCode);
	self.deleteVessel(VesselCode);
	self.deleteCargoType(BBULKCargoType);
	self.deleteCargoType(MAFICargoType);
	self.deleteTerminalArea(MAFIAreaName);
	
	self.setTerminalConfig(DefaultVoyageProcess, VoyageProcessDefault);
	
	//==========================
	// Set up Voyages
	//==========================
	vessel := self.addVesselLOLOholdsRORO(VesselCode, operator);
	voyage := self.addVoyageWithConRORO(VoyageCode, VesselCode, operator.code, shipLineStr, null, 0, false, true);
	self.assertTrueMsg(voyage &lt;&gt; null, "'Voyage' not created during setup");
	
	
	//==========================
	// Set up Cargotypes
	//==========================
	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	bbCargoType := self.addCargoType(BBULKCargoType, false);
	self.assertTrueMsg(bbCargoType &lt;&gt; null, "BBLK cargo type failed to be created");
	
	self.opts.purge;
	self.opts.addAssoc("TrackAs", ProductType_Trailer);
	mafiCargoType := self.addCargoType(MAFICargoType, false);
	self.assertTrueMsg(mafiCargoType &lt;&gt; null, "MAFI cargo type failed to be created");
	trailerType := self.addTrailerType(TrailerType, TrailerTypeDesc, mafiCargoType, 1, 600, 600, 30000, 6000, 300, TRAILER_CATEGORY_MAFI, null);
	trailerType2 := self.addTrailerType(TrailerType2, TrailerTypeDesc2, mafiCargoType, 1, 600, 600, 30000, 6000, 300, TRAILER_CATEGORY_TRAILER, null);
	
	contCargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	self.assertTrueMsg(contCargoType &lt;&gt; null, "Container Cargo Type not found during setup.");
	
	//==========================
	// Set up Terminal Area
	//==========================
	self.opts.purge;
	self.opts.addAssoc("TA_Type", TA_TYPE_MAFI);
	mafiHeap := self.addBlockStack(MAFIAreaName, null, null);
	self.assertNotNullMsg(mafiHeap, "Mafi Heap");
	
	//==========================
	// Set up Cargo
	//==========================
	bblkTI := self.addCargoBreakBulkAtLocation(BBLK_ID_A, bbCargoType, 80, mafiHeap.myLocationsController, null, TI_IMEX_STATUS_IMPORT, nullVoyage, operator).CM_BreakBulkGeneric;
	self.assertTrueMsg(bblkTI &lt;&gt; null, "'" &amp; BBLK_ID_A &amp; "' cargo not created during setup");
	
	contTI := self.addContainerAtLocation(CONT_ID_A, operator, "2200", "MT", TI_IMEX_STATUS_EXPORT, mafiHeap.myLocationsController);
	self.assertTrueMsg(contTI &lt;&gt; null, CONT_ID_A &amp; " container not created");

	mafiTI := self.addTrailerAtLocation(MAFI_ID_A, mafiCargoType, trailerType, operator, mafiHeap.myLocationsController);
	self.assertTrueMsg(mafiTI &lt;&gt; null, MAFI_ID_A &amp; " mafi not created");
	
	trailerTI := self.addTrailerAtLocation(TILC_ID_A, mafiCargoType, trailerType2, operator, mafiHeap.myLocationsController);
	self.assertTrueMsg(trailerTI &lt;&gt; null, TILC_ID_A &amp; " trailer not created");

	
	//************Check Trailer transactions
	//Load cargo on to the trailer
	self.move(bblkTI, trailerTI.allLCs.first);
	
	//Check Transaction
	trx:=trailerTI.getLastTransOfType(TRANS_TYPE_TRAILER_CARGO_LOAD);
	self.assertNotNullMsg(trx, "Trailer Load Transaction should not be null");
	
	trx:=bblkTI.getLastTransOfType(TRANS_TYPE_TRAILER_LOAD);
	self.assertNotNullMsg(trx, "TI Load Transaction should not be null");
	
	//Unload cargo from trailer
	self.move(bblkTI, mafiHeap.myLocationsController);
	
	//Check Transaction
	trx:=trailerTI.getLastTransOfType(TRANS_TYPE_TRAILER_CARGO_DIS);
	self.assertNotNullMsg(trx, "Trailer Discharge Transaction should not be null");
	
	trx:=bblkTI.getLastTransOfType(TRANS_TYPE_TRAILER_DIS);
	self.assertNotNullMsg(trx, "TI Discharge Transaction should not be null");
	
	//************Check MAFI transaction
	//Load cargo on to the MAFI
	self.move(contTI, mafiTI.allLCs.first);
	
	//Check Transaction
	trx:=mafiTI.getLastTransOfType(TRANS_TYPE_TRAILER_CARGO_LOAD);
	self.assertNotNullMsg(trx, "Trailer Load Transaction should not be null");
	
	trx:=contTI.getLastTransOfType(TRANS_TYPE_TRAILER_LOAD);
	self.assertNotNullMsg(trx, "TI Load Transaction should not be null");
	
	//Unload cargo from MAFI
	self.move(contTI, mafiHeap.myLocationsController);
	
	//Check Transaction
	trx:=mafiTI.getLastTransOfType(TRANS_TYPE_TRAILER_CARGO_DIS);
	self.assertNotNullMsg(trx, "Trailer Discharge Transaction should not be null");
	
	trx:=contTI.getLastTransOfType(TRANS_TYPE_TRAILER_DIS);
	self.assertNotNullMsg(trx, "TI Discharge Transaction should not be null");
	
epilog
	
end;</source>
    </JadeMethod>
</Class>
