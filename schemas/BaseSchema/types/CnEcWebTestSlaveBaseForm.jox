    <ImplicitInverseRef name="aMyWebTestController" id="0445aa2f-c93a-4a79-af3b-e29faf550801">
        <embedded/>
        <type name="CnEcWebTestController"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <JadeMethod name="doFormLoad" id="c4328179-a230-4913-aab8-2c7530b66c34">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		06 July 2000 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	create self.aMyWebTestController transient;
	inheritMethod();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRegisterNotifications" id="dc5c4afd-cf29-4008-92f9-74815ff5c2df">
        <source>doRegisterNotifications() protected;

// --------------------------------------------------------------------------------
// Created:		16 June 2000 by cnwdad1
//
// Purpose:		Refer to the superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	beginNotification(global, CNEC_WEBTEST_SLAVE_CLOSE, Response_Continuous, 0);
	beginNotification(global, CNEC_WEBTEST_TEST_START, Response_Continuous, 0);
	beginNotification(global, CNEC_WEBTEST_TEST_STOP, Response_Continuous, 0);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRunWebTest" id="0055dce3-e05d-49ad-8d75-b387d656ae1e">
        <source>doRunWebTest(pWebTestName:String) protected;
// --------------------------------------------------------------------------------
// Created:		13 June 2000 by cnwdad1
//
// Purpose:		Initiates the requested Web Test.
//
// Parameters:	pWebTestName - The name of the Web Test to initiate.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	testController	: CnEcWebTestController;
	webTest			: CnEcWebTest;
	webTestArray	: CnEcWebTestArray;

begin
	if pWebTestName &lt;&gt; null then
		webTest			:=	app.myBaseRoot.allWebTests[pWebTestName];	// Find the Web Test object.

		if webTest &lt;&gt; null then
			testController	:=	self.aMyWebTestController;
			create webTestArray transient;
			webTestArray.add(webTest);
			testController.addWebTests(webTestArray);

			if testController.doRunTest() then
				self.doDisplayMessage(pWebTestName &amp; " succeeded.");
			else
				self.doDisplayMessage(pWebTestName &amp; " failed!");
			endif;
		endif;
	endif;
epilog
	delete webTestArray;
end;</source>
        <access>protected</access>
        <Parameter name="pWebTestName" type="String"/>
    </JadeMethod>
    <JadeMethod name="isValidClient" id="6d7d1360-d809-4ce0-a814-8dea94e46672">
        <source>isValidClient(): Boolean;
// --------------------------------------------------------------------------------
// Created:		18 June 2000 by cnwdad1
//
// Purpose:		Refer to the superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCaption" id="60fbb68b-f61f-486a-92de-e88194ebc994">
        <updating/>
        <source>setCaption() updating;
// --------------------------------------------------------------------------------
// Created:		11 July 2000 by cnwdad1
//
// Purpose:		Refer to the superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.caption	:=	self.caption &amp; ": " &amp; process.userCode;
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="7287f207-a27d-407b-bdd6-d09e11f79c5d">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// --------------------------------------------------------------------------------
// Created:		06 July 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	delete self.aMyWebTestController;
	inheritMethod;
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="c52ae4e1-5028-434f-83d6-b48556d61df4">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// --------------------------------------------------------------------------------
// Created:		16 June 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	webTestName		: String;

begin
	app.mousePointer	:=	Busy;

	if eventType = CNEC_WEBTEST_TEST_START then
		webTestName		:=	userInfo.String;
		self.doRunWebTest(webTestName);

	elseif eventType = CNEC_WEBTEST_TEST_STOP then
		self.aMyWebTestController.setIsStopRequested(true);

	elseif eventType = CNEC_WEBTEST_SLAVE_CLOSE then
		self.doDisplayMessage("I've been requested to close down, bye...");
		terminate;

	else
		inheritMethod(eventType, theObject, eventTag, userInfo);
	endif;

epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
