    <JadeMethod name="validateFortyAttributes" id="853dd05b-18e2-4c12-b9d1-ec259be4e613">
        <source>validateFortyAttributes();
// ---------------------------------------------------------------------------
// Created:     15 July 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpBay	: CM_Bay;
begin

	tmpBay := self.myBay;

	if tmpBay &lt;&gt; null then
		if self.fortyFront and
		   tmpBay.isLastInHold() then
			app.raiseCMException2(Slot_canno_marke_forty_foot_sl, tmpBay.id, self.id, null, null);
		endif;
	
		if self.fortyBack and
		   tmpBay.isFirstInHold() then
			app.raiseCMException2(Forwa_slot_this_canno_marke_fo, tmpBay.id, self.id, null, null);
		endif;
	endif;

end;</source>
    </JadeMethod>
