    <JadeMethod name="tblMachines_dragDrop" id="aff360fc-463b-43c7-aa33-de70209f01c7">
        <controlMethod name="Table::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMachines_dragDrop(table: Table input; win: Window input; x: Real; y: Real) updating;
// -------------------------------------------
// Created 04 February 2004 by cnwdvb1
// -------------------------------------------
vars
	machine : CM_Machine;
	theRow,
	theCol 	: Integer;
	lObj 	: Object;
begin
	
	if win = self.tblQEntries then
		self.allSelectedRTQEntries.clear();
		foreach lObj in self.tblQEntries.allSelectedObjects do
			if lObj.isKindOf(CM_RTQueueTask) then
				self.allSelectedRTQEntries.add(lObj.CM_RTQueueTask.myEntry);
			endif;
		endforeach;
	endif;
	
	if table.getCellFromPosition(x, y, theRow, theCol) then
		machine:=table.accessRow(theRow).itemObject.CM_Machine;
		if machine &lt;&gt; null then
			self.doAllocateMachineToTask(machine);
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
