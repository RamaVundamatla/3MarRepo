    <JadeMethod name="updateTI" id="001f3beb-76a1-4cee-a5be-baf0503f375f">
        <updating/>
        <source>updateTI(_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     24 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// June 2008	CNWRS2		PAR 16898 - add FF to transaction
// 26/09/2008	concms1		par 16130 - new parameter for clearPIN method
// 20 Nov 2017	cnwkpd1		TFS 7466 - Make update of chilled dict more consistent
// 25 May 2024  navma1		ChangeRequest 63027: MTN - Improve Performance of Cargo Bulk Edit - Second Enhancement
// ---------------------------------------------------------------------------
vars
	ti					   : CM_TrackedItem;
	yardActivityReeferJobs : CM_YardActivityArray;	//29 Jul 2020	NDL	TFS 49581
	yardActivity 		   : CM_YardActivity;		//29 Jul 2020	NDL	TFS 49581
	wsRequest 			   : BGP_AllocWSRequest;	//06 Aug 2020	NDL	TFS 49869
begin

	inheritMethod(_passport);
	
	ti := self.myTrackedItem;

	if ti = null then
		return;
	endif;

	if not ti.isRehandle and not ti.isSOB then
		self.createTransaction(_passport);
	endif;

	ti.setReleasedDTfromTrxs();	//07 Dec 2017	NDL	TFS 8116
	

	ti.removePIN(true, false); // cnwrd1 par 22624 3.5.2010
	
	ti.updateChilledDict();		//PAR 2984: Chilled reefer alarm
	
	//29 Jul 2020	NDL	TFS 49581
	if ti.hasAnyReeferJob then
		create yardActivityReeferJobs transient;
		foreach yardActivity in ti.allYardActivities do
			if yardActivity.isReeferJob then
				yardActivityReeferJobs.add( yardActivity );
			endif;
		endforeach;
		foreach yardActivity in yardActivityReeferJobs do
			app.myUtilityDA.utlDeleteYardActivity( yardActivity, _passport );
		endforeach;
	endif;
	
	// CCMS DPH 2278 storage billing, remove any future actors
	app.myRoot.deleteFutureActor(ti, CM_FutureStorageProcess);

	ti.onReleaseFutureStorageRevert(self.dateTime.Date,true); // ### JIRA 33350 22NOV2024 NAVAB1
	
	//12 Jul 2017	NDL	TFS 5314
	if ti.hasSealTypes then
		ti.createSealCheckTranForAllSeals( SEAL_CHECK_RECORDED, self );
	endif;
	
	//04 Aug 2020	NDL	TFS 49869
	ti.createAllotracBGPRequest( self, wsRequest );

epilog
	delete yardActivityReeferJobs;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
