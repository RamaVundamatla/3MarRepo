    <JadeMethod name="setupContextMenuItems" id="5dad5f7d-9137-4979-bc44-291b0d943fb6">
        <updating/>
        <source>setupContextMenuItems( table: Table input ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 February 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	obj : Object;
	primeAllocation :CM_YardAllocation;
	ti : CM_TrackedItem;
	rowIndex : Integer;
//	planLocStr : String;

begin

	self.mnuAddYA.visible := false;
	self.mnuColOrg.userObject := table;
	self.mnuColOrg.visible := true;
	self.mnuEditYA.visible := false;
	self.mnuInspect.visible := false;
	self.mnuRemoveItems.visible := false;
	self.mnuSendToEnquiry.visible := false;
	self.mnuSendToMove.visible := false;
	self.mnuSendToReport.visible := false;
	self.mnuSep1.visible := false;
	self.mnuShowAPLog.visible := false;
	self.mnuSummarise.visible := false;
	self.mnuPlanItems.visible := false;		// Unconditionally not available at present, may use in the future.
	self.mnuRemovePlanned.visible := false;
	
	obj := table.accessRow(table.row).itemObject;
	self.mnuInspect.userObject := obj;

	if table = tblSelected then
		if not table.CM_DataTable.allSelectedObjects.isEmpty then
			self.mnuRemoveItems.visible := true;
			self.mnuSep1.visible := true;
		elseif obj &lt;&gt; null then
			self.mnuInspect.visible := app.isAllowedToInspect();
		endif;
		if self.isLocalTerminal then
			foreach rowIndex in self.tblSelected.fixedRows to self.tblSelected.rows do
				ti := self.tblSelected.accessRow(rowIndex).itemObject.CM_TrackedItem;
				if ti &lt;&gt; null and ti.myPrimaryPlannedLocation &lt;&gt; null then
					self.mnuRemovePlanned.visible := true;
					break;
				endif;
			endforeach;
		endif;
	
	elseif table = tblWouldPlan then
		
		if table.CM_DataTable.allSelectedObjects.size &gt; 1 then
//			planLocStr := "'" &amp; table.CM_DataTable.getColHeadingByRowName( ETRow_PlanLocation ) &amp; "'";
//			self.mnuPlanItems.userObject := table;
//			self.mnuPlanItems.visible := self.isLocalTerminal;
//			self.mnuPlanItems.caption := app.getErrorString1(Plan_items, planLocStr);
			self.mnuSendToEnquiry.userObject := table;
			self.mnuSendToEnquiry.visible := true;
			self.mnuSendToMove.userObject := table;
			self.mnuSendToMove.visible := true;
			self.mnuSendToReport.userObject := table;
			self.mnuSendToReport.visible := true;
			self.mnuSummarise.userObject := table;
			self.mnuSummarise.visible := true;
			self.mnuSep1.visible := true;
		elseif obj &lt;&gt; null then
//			planLocStr := "'" &amp; obj.CM_TestAutoPlanPlanned.myPlannedLocation.getFullId &amp; "'";
			primeAllocation := obj.CM_TestAutoPlanResult.myPrimeYardAllocation;
			if primeAllocation &lt;&gt; null then
				self.mnuEditYA.userObject := primeAllocation;
				self.mnuEditYA.caption := app.getErrorString(Edit) &amp; " '" &amp; primeAllocation.code &amp; "'...";
				self.mnuEditYA.visible := self.isLocalTerminal;
			endif;
//			self.mnuPlanItems.userObject := table;
//			self.mnuPlanItems.visible := self.isLocalTerminal;
//			self.mnuPlanItems.caption := app.getErrorString1( Plan_item, planLocStr);
			self.mnuSendToEnquiry.userObject := table;
			self.mnuSendToEnquiry.visible := true;
			self.mnuSendToMove.userObject := table;
			self.mnuSendToMove.visible := true;
			self.mnuSendToReport.userObject := table;
			self.mnuSendToReport.visible := true;
			self.mnuSummarise.userObject := table;
			self.mnuSummarise.visible := true;
			self.mnuAddYA.userObject := obj.CM_TestAutoPlanResult;
			self.mnuAddYA.visible := self.isLocalTerminal;
			self.mnuShowAPLog.userObject := obj;
			self.mnuShowAPLog.visible := true;
			self.mnuSep1.visible := true;
			self.mnuInspect.visible := app.isAllowedToInspect();
		endif;
	
	elseif table = self.tblFailed then
		if table.CM_DataTable.allSelectedObjects.size &gt; 1 then
			self.mnuSendToEnquiry.userObject := table;
			self.mnuSendToEnquiry.visible := true;
			self.mnuSendToMove.userObject := table;
			self.mnuSendToMove.visible := true;
			self.mnuSendToReport.userObject := table;
			self.mnuSendToReport.visible := true;
			self.mnuSummarise.userObject := table;
			self.mnuSummarise.visible := true;
			self.mnuSep1.visible := true;
		elseif obj &lt;&gt; null then
			primeAllocation := obj.CM_TestAutoPlanResult.myPrimeYardAllocation;
			if primeAllocation &lt;&gt; null then
				self.mnuEditYA.userObject := primeAllocation;
				self.mnuEditYA.caption := app.getErrorString(Edit) &amp; " '" &amp; primeAllocation.code &amp; "'...";
				self.mnuEditYA.visible := self.isLocalTerminal;
			endif;
			self.mnuSendToEnquiry.userObject := table;
			self.mnuSendToEnquiry.visible := true;
			self.mnuSendToMove.userObject := table;
			self.mnuSendToMove.visible := true;
			self.mnuSendToReport.userObject := table;
			self.mnuSendToReport.visible := true;
			self.mnuSummarise.userObject := table;
			self.mnuSummarise.visible := true;
			self.mnuAddYA.userObject := obj.CM_TestAutoPlanResult;
			self.mnuAddYA.visible := self.isLocalTerminal;
			self.mnuShowAPLog.userObject := obj;
			self.mnuShowAPLog.visible := true;
			self.mnuSep1.visible := true;
			self.mnuInspect.visible := app.isAllowedToInspect();
		endif;
	
	endif;
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="453dcc35-cac3-4374-951d-94618918a7e9">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 January 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	term : CM_Terminal;

begin
	
	self.isSelectorCapable := true;

	inheritMethod();
	
	frmMain.left := 0;
	frmMain.top := 0;
	frmMain.width := self.clientWidth;
	frmMain.height := self.clientHeight;
	
	self.minimumWidth := 500;
	self.minimumHeight := 300;
	
	self.doResize();
	
	self.populateCombo();	
	self.initTables();
	self.moveModeForm := PLANNING_MODE;
	
	self.tblWouldPlan.btnClearFilters.setEventMapping(CMUI_Button::click.name, CMUI_TestAutoPlanFormTest2::btnClear_click.name);
	self.tblWouldPlan.btnShowHide.setEventMapping(CMUI_Button::click.name, CMUI_TestAutoPlanFormTest2::btnClear_click.name);
	
epilog

end;</source>
    </JadeMethod>
