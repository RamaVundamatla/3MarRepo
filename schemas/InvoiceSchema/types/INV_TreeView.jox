    <JadeMethod name="clearFilter" id="44e03396-ae7c-492b-b11a-4400f91321e7">
        <updating/>
        <source>clearFilter() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2021	navpw1	Initial creation TFS: 51912

*/

vars

begin

	if (self.txtFilterBox.text &lt;&gt; "") then
		self.txtFilterBox.text := "";
		self.btnClearFilter.enabled := false;
	endif;
	
	if(self.txtFilterBox.text = "") then
		self.btnClearFilter.enabled := false;
	endif;		

epilog

end;</source>
    </JadeMethod>
