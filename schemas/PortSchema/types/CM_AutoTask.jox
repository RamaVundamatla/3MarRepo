    <JadeMethod name="getAuditText" id="2b5935a3-cbd3-4cfe-8832-3f051b6acafe">
        <source>getAuditText(): String;
 // par 20581 cnwrs1 sept 2009
vars
	autoSchedule : CM_AutoSchedule;
	txt : String;
begin
	txt := inheritMethod();
	if self.myTerminal &lt;&gt; null then
		txt := txt &amp; self.myTerminal.getAuditText();
	endif;
	if self.myUser &lt;&gt; null then
		txt := txt &amp; self.myUser.getAuditText();
	endif;
	foreach autoSchedule in self.allAutoSchedules do
		txt := txt &amp; autoSchedule.getAuditText();
	endforeach;
	return txt;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
