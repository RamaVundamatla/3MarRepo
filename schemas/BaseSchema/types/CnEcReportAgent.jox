    <JadeMethod name="valReportDefinitionCreate" id="ddff1da6-aa81-4bb8-8be3-6947c479da66">
        <updating/>
        <source>valReportDefinitionCreate(	pReportName:String;
							pReportCategoryObj:CnEcReportCategory;
							pReportDescription:String;
							pFormName:String;
							pPrinterName:String;
							pCopies:Integer;
							pIsLocalAllowed:Boolean;
							pPaperSize:Integer;
							pOrientation:Integer;
							pMarginTop:Integer;
							pMarginBottom:Integer;
							pMarginLeft:Integer;
							pMarginRight:Integer;
							pParameterArray:CnEcReportParameterArray):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Validation for creating a Report Definition.
//
// Parameters:	The object's properties.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	reportDefinitionObj	: CnEcReportDefinition;
	errorMessage		: String;

begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers.
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	if app.myBaseRoot = null then
		return self.agentSetError("The BaseRoot object is missing or not set.");
	endif;

	if pReportName.trimBlanks = null then
		return self.agentSetError("The name of the Report cannot be null.");
	endif;

	if pReportCategoryObj = null then
		return self.agentSetError("Please choose a Report Category.");
	endif;

	if pReportDescription.trimBlanks = null then
		return self.agentSetError("The Report description cannot be empty.");
	endif;

	if pCopies = 0 then
		return self.agentSetError("There must be at least one Copies of the Report.");
	endif;

	if pFormName.trimBlanks = null then
		return self.agentSetError("Please choose a Form name for the Report.");
	endif;

	if pPrinterName.trimBlanks = null then
		return self.agentSetError("Please choose a Printer for the Report.");
	endif;

	if pPaperSize = 0 then
		return self.agentSetError("Please choose a Paper Size for the Report.");
	endif;

	if pParameterArray &lt;&gt; null then
		errorMessage	:=	self.valReportParameterDuplicates(pParameterArray);
	endif;
	
	if errorMessage &lt;&gt; null then
		return self.agentSetError(errorMessage);
	endif;

	// If the owner object is invalid, we want our exception handlers to return a message saying so.
	self.agentRegisterObjectAndError(app.myBaseRoot, "The BaseRoot object is missing or not set.");

	reportDefinitionObj	:=	app.myBaseRoot.allReportDefinitions[pReportName.trimBlanks];
	// If the above operation gets an exception, our handler will resume to here.
	if self.lastError &lt;&gt; null then
		return self.lastError;
	endif;

	if reportDefinitionObj &lt;&gt; null then
		return self.agentSetError("A Report Definition already exists with this name (" &amp; pReportName.trimBlanks &amp; ").");
	endif;

	return null;
end;</source>
