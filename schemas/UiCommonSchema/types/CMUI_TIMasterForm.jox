	elseif self.isTILC() then
		self.filterCargoType	:= null;
		self.filterOperator		:=null;
		
	elseif self.isGenerator() then
		self.filterGeneratorType:= null;
	
	else
		//Container
		self.filterOperator		:=null;
		self.filterISOType		:=null;
		self.filterUpper		:=null;
		self.filterLower		:=null;
	endif;
	
end;
</source>
