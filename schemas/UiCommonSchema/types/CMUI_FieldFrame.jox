    <JadeMethod name="setWidths" id="a1f00045-70cf-4dbc-a81e-4f1044a50c7a">
        <updating/>
        <source>setWidths(_controlWidth, _labelWidth : Integer) updating;

vars

begin
	self.labelWidth 	:= _labelWidth;
	self.myLabel.width	:= _labelWidth;
	self.width 			:= _controlWidth + _labelWidth + self.HORIZONTAL_SPACING;
end;</source>
        <Parameter name="_controlWidth" type="Integer"/>
        <Parameter name="_labelWidth" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="f6fad715-cdbf-4d9f-a8c1-83f7be9c3a9b">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		15 February 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin

	inheritMethod(cntrl, persistCntrl);

	self.boundaryWidth		:=	0;
	self.bevelInner			:=	Frame.Bevel_None;
	self.bevelInnerWidth	:=	0;
	self.bevelOuter			:=	Frame.Bevel_None;
	self.bevelOuterWidth	:=	0;
	
	if self.isInPainter() then
		self.borderStyle	:=	Control.BorderStyle_Single;
		self.transparent	:=	false;
	else
		self.borderStyle	:=	Control.BorderStyle_None;
		self.transparent	:=	true;
		self.buildSelf();
		self.visible		:=	false;
	endif;
	
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
