    <JadeMethod name="extractCalculationTypes" id="b9dc3a83-e361-46c5-b5d6-404d97f47b4e">
        <source>extractCalculationTypes(_file : File input) : Integer;

/*

Purpose:		Extract all user-defined calculation types

Parameters:			

Return Value:		


Date		Who		Reason
Aug 2016	cnwjre1	Continuation of prior work for DOHA copy from test to UAT

*/

vars
	count	: Integer;
	msg		: String;
	int		: Integer;
	bool	: Boolean;
	root	: CM_Root;
	calcType	: CM_CalculationType;
	qr		: CM_QuantityRange;
begin
	root := CM_Root.firstInstance;

	msg := '&lt;calculationTypes&gt;';
	_file.writeLine(msg);
	foreach calcType in root.allCalculationTypesByCode do
		// just user-defined types
		if calcType.isStandardEvent 
		or calcType.isStandardCargo
		or calcType.isStandardInventory // ### TFS 51219 28MAY2021 NAVAB1
		or calcType.isStandardWorkOrder then // TFS 39198
			continue;
		endif;
		count := count + 1;
		msg := '&lt;calcType&gt;';
		_file.writeLine(msg);
		msg := self.formatAsXML("amountMax", calcType.amountMax.String);
		_file.writeLine(msg);
		msg := self.formatAsXML("amountMin", calcType.amountMin.String);
		_file.writeLine(msg);
		msg := self.formatAsXML("type", calcType.calculationType.String);
		_file.writeLine(msg);
		msg := self.formatAsXML("code", calcType.code);
		_file.writeLine(msg);
		msg := self.formatAsXML("description", calcType.description);
		_file.writeLine(msg);
		msg := self.formatAsXML("hoursBlock", calcType.hoursBlock.String);
		_file.writeLine(msg);
		msg := self.formatAsXML("hoursFree", calcType.hoursFree.String);
		_file.writeLine(msg);
		msg := self.formatAsXML("hoursMax", calcType.hoursMax.String);
		_file.writeLine(msg);
		msg := self.formatAsXML("hoursMin", calcType.hoursMin.String);
		_file.writeLine(msg);
		msg := self.formatAsXML("isCargoCalcType", calcType.isCargoCalcType.String);
		_file.writeLine(msg);
		msg := self.formatAsXML("IsInventoryType", calcType.isInventoryType.String); // ### TFS 51219 28MAY2021 NAVAB1
		_file.writeLine(msg); // ### TFS 51219 28MAY2021 NAVAB1
		msg := self.formatAsXML("IsWorkOrderType", calcType.isWorkOrderType.String); // TFS 39198
		_file.writeLine(msg); // TFS 39198
		msg := self.formatAsXML("isBolCalcType", calcType.isBolCalcType.String); //31 Oct 2019	NDL	TFS 47100
		_file.writeLine(msg); //31 Oct 2019	NDL	TFS 47100
		msg := self.formatAsXML("isEventCalcType", calcType.isEventCalcType.String);
		_file.writeLine(msg);
		msg := self.formatAsXML("isNotAvailableForEntry", calcType.isNotAvailableForEntry.String);
		_file.writeLine(msg);
		msg := self.formatAsXML("isVoyageCalcType", calcType.isVoyageCalcType.String);
		_file.writeLine(msg);
		msg := self.formatAsXML("unit", calcType.theCalcTypeUnit.String);
		_file.writeLine(msg);
		msg := self.formatAsXML("timeFrom", calcType.timeFrom.String);
		_file.writeLine(msg);
		msg := self.formatAsXML("timeTo", calcType.timeTo.String);
		_file.writeLine(msg);
		msg := self.formatAsXML("rateType", calcType.rateType.String);	//22 Mar 2019	NDL	TFS 43687
		_file.writeLine(msg);
		foreach qr in calcType.allQuantityRanges do
			_file.writeLine("&lt;quantityRange&gt;");
			msg := self.formatAsXML("rangeStart", qr.rangeStart.String);
			_file.writeLine(msg);
			msg := self.formatAsXML("rangeEnd", qr.rangeEnd.String);
			_file.writeLine(msg);
			msg := self.formatAsXML("daysIncrement", qr.daysIncrement.String);
			_file.writeLine(msg);
			msg := self.formatAsXML("rangeType", qr.rangeType.String);
			_file.writeLine(msg);
			_file.writeLine("&lt;/quantityRange&gt;");
		endforeach;
		if not calcType.booleanList.isEmpty then
			_file.writeLine("&lt;booleanList&gt;");
			foreach bool in calcType.booleanList do
				msg := self.formatAsXML("value", bool.String);
				_file.writeLine(msg);
			endforeach;
			_file.writeLine("&lt;/booleanList&gt;");
		endif;
		if not calcType.integerRange1.isEmpty then
			_file.writeLine("&lt;integerRange1&gt;");
			foreach int in calcType.integerRange1 do
				msg := self.formatAsXML("value", int.String);
				_file.writeLine(msg);
			endforeach;
			_file.writeLine("&lt;/integerRange1&gt;");
		endif;
		if calcType.myCalendarType1 &lt;&gt; null then
			msg := self.formatAsXML("calendar1", calcType.myCalendarType1.code);
			_file.writeLine(msg);
		endif;
		if calcType.myCalendarType2 &lt;&gt; null then
			msg := self.formatAsXML("calendar2", calcType.myCalendarType2.code);
			_file.writeLine(msg);
		endif;
		if calcType.myMeasurementType &lt;&gt; null then
			msg := self.formatAsXML("measurementType", calcType.myMeasurementType.shortName);
			_file.writeLine(msg);
		endif;
		if calcType.myHookCodeQuantity &lt;&gt; null then
			_file.writeLine("&lt;quantityHook&gt;");
			msg := calcType.myHookCodeQuantity.getCurrentJadeCode().xmlReplaceReservedChars(true);
			_file.writeLine(msg);
			_file.writeLine("&lt;/quantityHook&gt;");
		endif;
		if calcType.myHookCodeRate &lt;&gt; null then
			_file.writeLine("&lt;rateHook&gt;");
			msg := calcType.myHookCodeRate.getCurrentJadeCode().xmlReplaceReservedChars(true);
			_file.writeLine(msg);
			_file.writeLine("&lt;/rateHook&gt;");
		endif;
		if calcType.myHookCodeRemarks &lt;&gt; null then		// 22/2/18 MAP TFS37124
			_file.writeLine("&lt;remarksHook&gt;");
			msg := calcType.myHookCodeRemarks.getCurrentJadeCode().xmlReplaceReservedChars(true);
			_file.writeLine(msg);
			_file.writeLine("&lt;/remarksHook&gt;");
		endif;
		msg := '&lt;/calcType&gt;';
		_file.writeLine(msg);
	endforeach;
	msg := '&lt;/calculationTypes&gt;';
	_file.writeLine(msg);
	return count;

end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="extractCustomsAgents" id="69f4a386-51a1-49d1-a77d-a43fd0a0fc1d">
        <source>extractCustomsAgents(_file : File input);

/*

Purpose:		Extract all customs agents along with debtors

Parameters:			

Return Value:		


Date		Who		Reason
23 April 2012	cnwjre1	Initial creation for DOHA copy from test to UAT

*/

vars
	msg		: String;
	root	: CM_Root;
	debtor	: CM_Debtor;
	agent	: CM_CustomsAgent;
begin
	root := CM_Root.firstInstance;

	msg := '&lt;agents&gt;';
	_file.writeLine(msg);
	foreach agent in root.allCustomsAgents do
		msg := '&lt;customsAgent&gt;';
		_file.writeLine(msg);
		msg := self.formatAsXML("code", agent.code);
		_file.writeLine(msg);
		msg := self.formatAsXML("name", agent.name);
		_file.writeLine(msg);
		msg := self.formatAsXML("isNotAvailableForEntry", agent.isNotAvailableForEntry.String);
		_file.writeLine(msg);
		debtor := agent.myDebtor;
		if debtor &lt;&gt; null then
			msg := self.formatAsXML("debtor", debtor.name);
			_file.writeLine(msg);
		endif;
		msg := '&lt;/customsAgent&gt;';
		_file.writeLine(msg);
	endforeach;
	msg := '&lt;/agents&gt;';
	_file.writeLine(msg);

end;</source>
        <Parameter name="_file" type="File" usage="input"/>
    </JadeMethod>
    <JadeMethod name="extractDebtorNode" id="64c27160-e59a-4ca0-9d7c-04f1bf6584ab">
        <source>extractDebtorNode(_file : File input; _debtorNode : CM_DebtorNode) protected;
/*
Purpose:	extract the given debtor node plus all children		

Parameters:			

Return Value:		

Date		Who		Reason
19/04/2012	cnwjre1	Initial creation for DOHA copy from test to UAT
14/03/2018	jlgdap1	TFS 36473 LNX Expand extract to include lots more fields
17/08/2018	jlgsl4	TFS 40294 PEL1 new fields for extract
*/

vars
	msg		: String;
	debtor	: CM_Debtor;
	child	: CM_DebtorNode;
	agent	: CM_CustomsAgent;
	operator	: CM_Operator;
	trade 	: String;						// TFS 36473
	type	: CM_DebtorType;				// TFS 36473
	carrier : CM_Carrier;					// TFS 36473
	consignor : CM_ConsigneeConsignor;		// TFS 36473
	contact : CM_EmailEntity;				// TFS 36473
begin
	msg := '&lt;debtor class="' &amp; _debtorNode.class.name &amp; '"&gt;';
	_file.writeLine(msg);
	msg := self.formatAsXML("name", _debtorNode.name);
	_file.writeLine(msg);
	msg := self.formatAsXML("remarks", _debtorNode.remarks);
	_file.writeLine(msg);
	msg := self.formatAsXML("isPurchaseOrderMandatory", _debtorNode.isPurchaseOrderMandatory.String);
	_file.writeLine(msg);
	msg := self.formatAsXML("isSuspended", _debtorNode.isSuspended.String);
	_file.writeLine(msg);
	msg := self.formatAsXML("isZeroRatedTax", _debtorNode.isZeroRatedTax.String);
	_file.writeLine(msg);
	msg := self.formatAsXML("hasBadCredit", _debtorNode.hasBadCredit.String);	// TFS 36473
	_file.writeLine(msg);														// TFS 36473
	if _debtorNode.isKindOf(CM_Debtor) then
		debtor := _debtorNode.CM_Debtor;
		msg := self.formatAsXML("account", debtor.decfinName);
		_file.writeLine(msg);
		msg := self.formatAsXML("address", debtor.getBillingAddressString());
		_file.writeLine(msg);
		msg := self.formatAsXML("purchaseOrderCode", debtor.purchaseOrderCode);
		_file.writeLine(msg);
		msg := self.formatAsXML("externalReference", debtor.externalReference);		// 31193
		_file.writeLine(msg);
		msg := self.formatAsXML("longName", debtor.longName);
		_file.writeLine(msg);
		msg := self.formatAsXML("code", debtor.code); // TFS 40294
		_file.writeLine(msg); // TFS 40294		
		msg := self.formatAsXML("additionalInformation1", debtor.additionalInformation1); // TFS 40294
		_file.writeLine(msg); // TFS 40294
		msg := self.formatAsXML("additionalInformation2", debtor.additionalInformation2); // TFS 40294
		_file.writeLine(msg); // TFS 40294
		extractPaymentTypes(debtor, _file); // TFS 40294
		if debtor.myTermsOfTrade &lt;&gt; null then									// TFS 36473
			trade := debtor.myTermsOfTrade.code;								// TFS 36473
		endif;																	// TFS 36473
		msg := self.formatAsXML("termsOfTrade", trade);							// TFS 36473
		_file.writeLine(msg);													// TFS 36473
		foreach agent in debtor.allCustomsAgents do
			msg := self.formatAsXML("customsAgent", agent.code);
			_file.writeLine(msg);
		endforeach;
		foreach operator in debtor.operators do
			msg := self.formatAsXML("operator", operator.code);
			_file.writeLine(msg);
		endforeach;
		foreach type in debtor.allDebtorTypes do					// TFS 36473
			msg := self.formatAsXML("debtorType", type.code);		// TFS 36473
			_file.writeLine(msg);									// TFS 36473
		endforeach;													// TFS 36473
		foreach carrier in debtor.allCarriers do					// TFS 36473
			msg := self.formatAsXML("carrier", carrier.code);		// TFS 36473
			_file.writeLine(msg);									// TFS 36473
		endforeach;													// TFS 36473
		foreach consignor in debtor.consignors do					// TFS 36473
			msg := self.formatAsXML("consignor", consignor.code);	// TFS 36473
			_file.writeLine(msg);									// TFS 36473
		endforeach;													// TFS 36473
		foreach contact in debtor.allContacts do					// TFS 36473
			msg := self.formatAsXML("contact", contact.name);		// TFS 36473
			_file.writeLine(msg);									// TFS 36473
		endforeach;													// TFS 36473
	endif;

	if not _debtorNode.allChildDebtorNodes.isEmpty() then
		msg := '&lt;children&gt;';
		_file.writeLine(msg);
		foreach child in _debtorNode.allChildDebtorNodes do
			self.extractDebtorNode(_file, child);
		endforeach;
		msg := '&lt;/children&gt;';
		_file.writeLine(msg);
	endif;

	msg := '&lt;/debtor&gt;';
	_file.writeLine(msg);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_debtorNode" type="CM_DebtorNode"/>
    </JadeMethod>
    <JadeMethod name="extractDebtors" id="2c5089f5-b9a0-4cab-952c-46981fa446d6">
        <source>extractDebtors(_file : File input) : Integer;

/*

Purpose:		Extract all debtors keeping the debtor group/children relationships	

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2012	cnwjre1	Initial creation for DOHA copy from test to UAT

*/

vars
	count	: Integer;
	company : CM_Bank;
	rdg		: CM_RootDebtorGroup;

begin

	company := app.myRoot.myRootCompany;
	rdg := company.getRootDebtorGroup();

	self.extractDebtorNode(_file, rdg);
	rdg.getTotalCount(count);
	return count;
end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="extractGLCodes" id="85a6ef1b-4d08-4084-917d-3ae39c9d2a54">
        <source>extractGLCodes(_file : File input);

/*

Purpose:		Extract all GL Codes

Parameters:			

Return Value:		


Date		Who		Reason
20NOV12 AKB		Oracle extract testing, copy GL codes form Production to TEST

*/

vars
	msg		: String;
	root	: CM_Root;
	debtor	: CM_Debtor;
	glcode	: CM_GLCode;
	term : CM_Terminal;
	bu : CM_Bank;
begin
	root := CM_Root.firstInstance;
	msg := '&lt;glcodes&gt;';	_file.writeLine(msg);

	foreach term in root.allTerminals discreteLock do
		msg := '&lt;term&gt;';	_file.writeLine(msg);
		msg := self.formatAsXML("code", term.code); _file.writeLine(msg);
		
		foreach bu in term.companies where bu.isBusinessUnit and (not bu.isSuspended) do
			msg := '&lt;bu&gt;';	_file.writeLine(msg);
			msg := self.formatAsXML("code", bu.code); _file.writeLine(msg);
		
			foreach glcode in bu.glCodes do
				msg := '&lt;glcode&gt;';_file.writeLine(msg);
				msg := self.formatAsXML("code", glcode.code);_file.writeLine(msg);
				msg := self.formatAsXML("remarks", glcode.remarks); _file.writeLine(msg);
				msg := self.formatAsXML("externalRef", glcode.externalRef); _file.writeLine(msg);			//	28 May 2018	NDL	TFS 38896 
				msg := self.formatAsXML("services", glcode.services.size.String); _file.writeLine(msg);
				msg := self.formatAsXML("charges", glcode.charges.size.String); _file.writeLine(msg);
				msg := '&lt;/glcode&gt;';	_file.writeLine(msg);
			endforeach;
	
			msg := '&lt;/bu&gt;';	_file.writeLine(msg);

		endforeach;
		msg := '&lt;/term&gt;';	_file.writeLine(msg);

	endforeach;
	msg := '&lt;/glcodes&gt;';	_file.writeLine(msg);

end;</source>
        <Parameter name="_file" type="File" usage="input"/>
    </JadeMethod>
    <JadeMethod name="extractGLCodesForBank" id="1e56092c-516c-4711-92d4-1956104f0b58">
        <source>extractGLCodesForBank(_file : File input; _bank : CM_Bank input) : Integer;

/*

Purpose:		Extract GL Codes for the given business unit

Parameters:			

Return Value:		


Date		Who			Reason
May 2015 	cnwjre1		ADP copy from UAT to production

*/

vars
	count	: Integer;
	msg		: String;
	glcode	: CM_GLCode;

begin

	msg := '&lt;glcodes&gt;';
	_file.writeLine(msg);

	foreach glcode in _bank.glCodes do
		count := count + 1;
		msg := '&lt;glcode&gt;';
		_file.writeLine(msg);
		msg := self.formatAsXML("code", glcode.code);
		_file.writeLine(msg);
		msg := self.formatAsXML("remarks", glcode.remarks);
		_file.writeLine(msg);
		msg := self.formatAsXML("externalRef", glcode.externalRef);	//	28 May 2018	NDL	TFS 38896 
		_file.writeLine(msg);	//	28 May 2018	NDL	TFS 38896 
		msg := self.formatAsXML("isNotAvailableForEntry", glcode.isNotAvailableForEntry.String);
		_file.writeLine(msg);
		msg := '&lt;/glcode&gt;';
		_file.writeLine(msg);
	endforeach;
	msg := '&lt;/glcodes&gt;';
	_file.writeLine(msg);
	
	return count;

end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_bank" type="CM_Bank" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="extractInvAllocTranMap" id="0596a1ac-4e7e-4951-bbce-768d0c68ce95">
        <source>extractInvAllocTranMap(_file : File input; _bank : CM_Bank input ;_allocationMapName: String input;_linesCount : Integer output):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Jun 2017	cnwma1 	TFS #4498 JMT - Cargo Allocation Fix Up Export Script
15 Nov 2017 jlgmd1	TFS #7659 STWO - FW: Transaction Map: PROBLEM
15/01/2025	navlw1	JIRA-12608: MTN - Invoice Cargo Allocations Review (Mapping and Extract/Load)

*/

vars
	count	: Integer;
	msg		: String;
	map : CM_TranMapCargoAllocation;
	inventtranmap : CM_TranMapInventoryAllocation;
	ya : CM_YardAllocation;
	yaCriteria : CM_YACriteria;
	invAlloc  : CM_InvoiceAllocation; // ### TFS 51219 28MAY2021 NAVAB1
	qtyMap : CM_QuantityMap;
	qtyRangeMap : CM_QuantityRangeMap;
	invLineMap	: CM_TranMapInvoiceLineMapping;
	allocCount  : Integer;
	obj : Object;
	strData: String;
	yacArray : CM_YACriteriaTypeArray;
	yacType : CM_YACriteriaType;
	isCargoAlloc : Boolean; // ### TFS 51219 28MAY2021 NAVAB1
	tranmaptag, tranmaptagend : String; // ### TFS 51219 28MAY2021 NAVAB1
	tranmapname, tranmapdesc : String; // ### TFS 51219 28MAY2021 NAVAB1
	allocdict : CM_YardAllocationsByCodeDict; // ### TFS 51219 28MAY2021 NAVAB1
begin
	map := _bank.allCargoAllocTranMaps[_allocationMapName];
	foreach map in _bank.allCargoAllocTranMaps do
		if map.name.toUpper =_allocationMapName.toUpper then
			break;
		else 
		
			map := null;
		endif;
	endforeach;
	if map &lt;&gt; null then
		isCargoAlloc := true; // ### TFS 51219 28MAY2021 NAVAB1
		count := 1;
		tranmaptag := '&lt;invoiceAllocationMap&gt;'; // ### TFS 51219 28MAY2021 NAVAB1
		tranmaptagend := '&lt;/invoiceAllocationMap&gt;'; // ### TFS 51219 28MAY2021 NAVAB1
		tranmapname := map.name.toUpper.String; // ### TFS 51219 28MAY2021 NAVAB1
		tranmapdesc := map.description.String; // ### TFS 51219 28MAY2021 NAVAB1
		allocdict :=  map.allInvoiceCargoAllocations; // ### TFS 51219 28MAY2021 NAVAB1
	else
		foreach inventtranmap in _bank.allInventoryAllocTranMaps do // ### TFS 51219 28MAY2021 NAVAB1
			if inventtranmap.name.toUpper =_allocationMapName.toUpper then // ### TFS 51219 28MAY2021 NAVAB1
				break;
			else 
				inventtranmap := null;
			endif;
		endforeach;
		if inventtranmap &lt;&gt; null then
			isCargoAlloc := false; // ### TFS 51219 28MAY2021 NAVAB1
			count := 1;
			tranmaptag := '&lt;inventoryAllocationMap&gt;'; // ### TFS 51219 28MAY2021 NAVAB1
			tranmaptagend := '&lt;/inventoryAllocationMap&gt;'; // ### TFS 51219 28MAY2021 NAVAB1
			tranmapname := inventtranmap.name.toUpper.String; // ### TFS 51219 28MAY2021 NAVAB1
			tranmapdesc := inventtranmap.description.String; // ### TFS 51219 28MAY2021 NAVAB1
			allocdict :=  inventtranmap.allInvoiceInventoryAllocations; // ### TFS 51219 28MAY2021 NAVAB1
		else

			count := 0;
			return count;
		endif;
	endif;
	msg := tranmaptag;   // ### TFS 51219 28MAY2021 NAVAB1								//Header
	_file.writeLine(msg);
	msg := self.formatAsXML("name",tranmapname );  	 	//name // ### TFS 51219 28MAY2021 NAVAB1
	_file.writeLine(msg);
	msg := self.formatAsXML("description", tranmapdesc ); //description
	_file.writeLine(msg);
		
	msg := '&lt;allOpCriteria&gt;';									// myInvoiceAllocationConfig.allOpCriteria		// TFS 7659 starts
	_file.writeLine(msg);
	create yacArray transient;
	if isCargoAlloc then // ### TFS 51219 28MAY2021 NAVAB1
		map.myInvoiceAllocationConfig.allOpCriteria.copy(yacArray);
	else
		inventtranmap.myInvoiceAllocationConfig.allOpCriteria.copy(yacArray); // ### TFS 51219 28MAY2021 NAVAB1
	endif;
	// Get all Criteria Types, except for 'Transaction Type' because its hard coded to always be there
	foreach yacType in yacArray where yacType.type &lt;&gt; YACriteriaType_TransactionType do
		msg := '&lt;CM_YACriteriaType&gt;';
		_file.writeLine(msg);
			
		msg := self.formatAsXML("type", yacType.type.String);
		_file.writeLine(msg);
			
		msg := self.formatAsXML("description", yacType.description.String);
		_file.writeLine(msg);
				
		msg := '&lt;/CM_YACriteriaType&gt;';
		_file.writeLine(msg);
	endforeach;
	msg := '&lt;/allOpCriteria&gt;';
	_file.writeLine(msg);
	delete yacArray;																							// TFS 7659 ends
		
	if not allocdict.isEmpty then // ### TFS 51219 28MAY2021 NAVAB1
		msg := '&lt;allInvoiceCargoAllocation&gt;';					//allInvoiceAllocation
		_file.writeLine(msg);
		foreach ya in allocdict where ya.isKindOf(CM_InvoiceAllocation) do // ### TFS 51219 28MAY2021 NAVAB1
			allocCount := allocCount +1;
			invAlloc := ya.CM_InvoiceAllocation; // ### TFS 51219 28MAY2021 NAVAB1
			msg := '&lt;CM_InvoiceCargoAllocation&gt;';
			_file.writeLine(msg);
			msg := self.formatAsXML("allowMultiRangeSplit", invAlloc.allowMultiRangeSplit.String);
			_file.writeLine(msg);
			
			msg := self.formatAsXML("allowOthersOption ", invAlloc.allowOthersOption.String);
			_file.writeLine(msg);
			
			msg := self.formatAsXML("code", invAlloc.code.String);
			_file.writeLine(msg);
			
			//msg := self.formatAsXML("color", invAlloc.color.String);			// TFS 7659
			msg := self.formatAsXML("priority", invAlloc.priorityValue.String);			// TFS 7659
			_file.writeLine(msg);
		
			msg := self.formatAsXML("description", invAlloc.description.String);
			_file.writeLine(msg);
							
			msg := self.formatAsXML("expiryDate", invAlloc.expiryDate.String);
			_file.writeLine(msg);
			
			msg := self.formatAsXML("expiryType", invAlloc.expiryType.String);
			_file.writeLine(msg);
			
			msg := self.formatAsXML("default", invAlloc.default.String);
			_file.writeLine(msg);
			
			if not ya.allCriteria.isEmpty then
				msg := '&lt;allCriteria&gt;';
				_file.writeLine(msg);
				foreach yaCriteria in ya.allCriteria do 
					msg := '&lt;CM_YACriteria&gt;';
					_file.writeLine(msg);
					msg := self.formatAsXML("myYACriteriaType", yaCriteria.myYACriteriaType.type.String);
					_file.writeLine(msg);
					if yaCriteria.myYAData &lt;&gt; null then
						if yaCriteria.myYAData.isKindOf(CM_YADataBoolean) then
							msg := self.formatAsXML("myYAData", yaCriteria.myYAData.CM_YADataBoolean.getDataValue().asStringJMT);
						elseif yaCriteria.myYACriteriaType.isKindOf(CM_YATypeProduct) then
							strData :=null;
							foreach obj in yaCriteria.myYAData.CM_YADataObjects.allObjects do
									strData := obj.CM_Product.getYAIdentifier &amp;"," &amp; strData; 
							endforeach;
							strData:=strData.truncatedAt(strData.length-1);
							msg := self.formatAsXML("myYAData", strData.toUpper);
						
						elseif yaCriteria.myYACriteriaType.isKindOf(CM_YATypeContentsStatus) then
							strData :=null;
							foreach obj in yaCriteria.myYAData.CM_YADataObjects.allObjects do
									strData := obj.CM_ContentsStatus.getYAIdentifier &amp; "," &amp; strData; 
							endforeach;
							strData:=strData.truncatedAt(strData.length-1);
							msg := self.formatAsXML("myYAData", strData.toUpper);
							
						elseif yaCriteria.myYACriteriaType.isKindOf(CM_YATypeSrcTermAreaType) then
							strData :=null;
							foreach obj in yaCriteria.myYAData.CM_YADataObjects.allObjects do
									strData := obj.CM_TerminalAreaType.getYAIdentifier &amp; "," &amp; strData; 
							endforeach;
							strData:=strData.truncatedAt(strData.length-1);
							msg := self.formatAsXML("myYAData", strData.toUpper);
						
						elseif yaCriteria.myYACriteriaType.isKindOf(CM_YATypeSrcTermArea) then
							strData :=null;
							foreach obj in yaCriteria.myYAData.CM_YADataObjects.allObjects do
									strData := obj.CM_TerminalArea.getYAIdentifier &amp; "," &amp; strData; 
							endforeach;
							strData:=strData.truncatedAt(strData.length-1);
							msg := self.formatAsXML("myYAData", strData.toUpper);
						
						elseif yaCriteria.myYACriteriaType.isKindOf(CM_YATypeStops) then
							strData :=null;
							foreach obj in yaCriteria.myYAData.CM_YADataObjects.allObjects do
									strData := obj.CM_StopsTable.getYAIdentifier &amp; "," &amp; strData; 
							endforeach;
							strData:=strData.truncatedAt(strData.length-1);
							msg := self.formatAsXML("myYAData", strData.toUpper);
					
						elseif yaCriteria.myYACriteriaType.isKindOf(CM_YATypeToDoTasks) then
							strData :=null;
							foreach obj in yaCriteria.myYAData.CM_YADataObjects.allObjects do
									strData := obj.CM_ToDoTaskDesc.getYAIdentifier &amp; "," &amp; strData; 
							endforeach;
							strData:=strData.truncatedAt(strData.length-1);
							msg := self.formatAsXML("myYAData", strData.toUpper);	
						else
							// Start navlw1 #JIRA-12608
							if yaCriteria.myYACriteriaType.saveCodeInUpper then
								msg := self.formatAsXML("myYAData", yaCriteria.myYAData.getDataDisplay(yaCriteria.myYACriteriaType).toUpper);
							else
								msg := self.formatAsXML("myYAData", yaCriteria.myYAData.getDataDisplay(yaCriteria.myYACriteriaType));
							endif;
							// End navlw1 #JIRA-12608
						endif;
						_file.writeLine(msg);
					endif;
					if yaCriteria.myYAData &lt;&gt; null then
						msg := self.formatAsXML("priorityValue", yaCriteria.priorityValue.String);
						_file.writeLine(msg);
					endif;
					if yaCriteria.myYAData &lt;&gt; null then
						msg := self.formatAsXML("code", yaCriteria.code);
						_file.writeLine(msg);
					endif;
					
					msg := '&lt;/CM_YACriteria&gt;';
					_file.writeLine(msg);
				endforeach;
				msg := '&lt;/allCriteria&gt;';
				_file.writeLine(msg);
			endif;
			
			if invAlloc.myServiceBroker &lt;&gt; null then
				if invAlloc.myServiceBroker.myChildQuantityMap &lt;&gt; null then
					qtyMap := invAlloc.myServiceBroker.myChildQuantityMap;
					msg := '&lt;CM_QuantityMap&gt;';
					_file.writeLine(msg);
						msg := self.formatAsXML("chargeZero", qtyMap.chargeZero.String);
						_file.writeLine(msg);
						msg := self.formatAsXML("mappingType", qtyMap.mappingType.String);
						_file.writeLine(msg);
						if qtyMap.myCalculationType &lt;&gt; null then
							msg := self.formatAsXML("myCalculationType", qtyMap.myCalculationType.code.String);
						else
							msg := self.formatAsXML("myCalculationType", null);
						endif;
						_file.writeLine(msg);
						if not qtyMap.allQuantityRanges.isEmpty then
							msg := '&lt;allQuantityRanges&gt;';
							_file.writeLine(msg);
							foreach qtyRangeMap in qtyMap.allQuantityRanges do
							msg := '&lt;CM_QuantityRangeMap&gt;';
							_file.writeLine(msg);
							msg := self.formatAsXML("rangeStart",qtyRangeMap.rangeStart.String);
							_file.writeLine(msg);
							
							msg := self.formatAsXML("rangeEnd",qtyRangeMap.rangeEnd.String);
							_file.writeLine(msg);
							
							msg := self.formatAsXML("rangeType",qtyRangeMap.rangeType.String);
							_file.writeLine(msg);
							
							if not qtyRangeMap.allTMInvoiceLineMappings.isEmpty then
								msg := '&lt;allTMInvoiceLineMappings&gt;';
								_file.writeLine(msg);
								foreach invLineMap in  qtyRangeMap.allTMInvoiceLineMappings do
									msg := '&lt;CM_TranMapInvoiceLineMapping&gt;';
									_file.writeLine(msg);
										msg := self.formatAsXML("mapValue",invLineMap.mapValue.String);
										_file.writeLine(msg);
										if invLineMap.myTMInvoiceLineDesc &lt;&gt; null then
											msg := self.formatAsXML("myTMInvoiceLineDesc",invLineMap.myTMInvoiceLineDesc.narration.String);
											_file.writeLine(msg);
										endif;
										
										if invLineMap.myTMInvoiceLineGroupType &lt;&gt; null then
										
											msg := '&lt;CM_TranMapInvoiceLineGroupType&gt;';
											_file.writeLine(msg);
												msg := self.formatAsXML("type",invLineMap.myTMInvoiceLineGroupType.type.String);
												_file.writeLine(msg);
												
												msg := self.formatAsXML("name",invLineMap.myTMInvoiceLineGroupType.name.String);
												_file.writeLine(msg);
											msg := '&lt;/CM_TranMapInvoiceLineGroupType&gt;';
											_file.writeLine(msg);

										endif;
									msg := '&lt;/CM_TranMapInvoiceLineMapping&gt;';
								   _file.writeLine(msg);
									
								endforeach;
								
								msg := '&lt;/allTMInvoiceLineMappings&gt;';
								_file.writeLine(msg);
							endif;
							msg := '&lt;/CM_QuantityRangeMap&gt;';
							_file.writeLine(msg);
							
							endforeach;
							
							msg := '&lt;/allQuantityRanges&gt;';
							_file.writeLine(msg);
						endif;
					
					msg := '&lt;/CM_QuantityMap&gt;';
					_file.writeLine(msg);
				endif;
			
			endif;
			msg := '&lt;/CM_InvoiceCargoAllocation&gt;';
			_file.writeLine(msg);
		endforeach;
		msg := '&lt;/allInvoiceCargoAllocation&gt;';
		_file.writeLine(msg);
	endif;
	msg := tranmaptagend; 
	_file.writeLine(msg);
	_linesCount := allocCount;
	return count;
epilog
	if yacArray &lt;&gt; null then
		delete yacArray;		// TFS 7659
	endif;
end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_bank" type="CM_Bank" usage="input"/>
        <Parameter name="_allocationMapName" type="String" usage="input"/>
        <Parameter name="_linesCount" type="Integer" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="extractInvoiceContracts" id="b58dfdca-388a-4a09-afe4-6a0e92b31ab1">
        <source>extractInvoiceContracts(_file : File input; _bank : CM_Bank input;_contracts : CM_InvoiceContractSet) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 January 2023	navmv20	TFS 55650 Task 55701: Jade - Contracts XML Extract TRX

*/

vars
	agent : CMIF_InvoiceContract;
begin
	create agent transient;
	return agent.extractInvoiceContractsXML(_file,_bank,_contracts);

epilog
	delete agent;
end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_bank" type="CM_Bank" usage="input"/>
