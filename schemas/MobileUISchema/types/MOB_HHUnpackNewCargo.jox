    <JadeMethod name="setInitialCursorPosition" id="080152e7-96d1-4926-ad49-82dc8398a6c1">
        <source>setInitialCursorPosition() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 September 2011	cnwndl1	Initial creation

*/

vars

	row : Integer;
	locRow : Integer;
	cargoType : CM_CargoType;
	tableCell : JadeTableCell;
	bookingNumber : String;
	config : Integer;
	
begin

	inheritMethod();

	row := tblCargo.getRow(ETRow_CargoId);
		
	cargoType := self.cmbType.listObject.CM_CargoType;
	if cargoType = null and tblCargo.getRow(ETRow_CargoType) &gt; 0 then
		// need to capture the cargo type first.
		row := tblCargo.getRow(ETRow_CargoType);	
	endif;
			
	self.tblCargo.row := row;
	
	tableCell := self.tblCargo.accessCell(row,2);
	
	if tableCell.cellControl &lt;&gt; null and tableCell.cellControl.isKindOf(TextBox) then
		tableCell.cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
	endif;
	
	self.tblCargo.setFocus();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d89654d7-d22f-42b2-a5dd-827a6bbf04f0">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016641, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
