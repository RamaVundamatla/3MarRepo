    <JadeMethod name="createCargoTransaction" id="81691762-7883-4ed6-8e24-991824038e21">
        <source>createCargoTransaction();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 December 2018	jlgab1	Initial creation

*/

vars
	voyage : CM_Voyage;
	job : CM_Job;
	holdJob : CM_VoyageHoldJob;
	vwle : CM_VoyageWLE;
	wle : CM_WorkListEntry;
	txnParams : CMIF_WorkOrderTransController;
	ti : CM_TrackedItem;
	wodcargo : CM_WodCargoRequest;
begin
	if app.isInProformaMode then
		return;
	endif;

	voyage := self.getMyVoyageObject();
	
	if voyage = null then
		return;
	endif;
	
	create txnParams transient;

	txnParams.type := TRANS_TYPE_WORKORDER_EXTRATI;
	
	foreach job in voyage.allVoyageJobs do
		if job.isKindOf(CM_VoyageHoldJob) then
			if job.status &lt;&gt; JOB_COMPLETE then

				foreach wle in job.workListEntries discreteLock do
					if wle.status &lt;&gt; WLE_UNACTIONED then
						continue;
					endif;
					ti := wle.myTrackedItem;
					
					if ti &lt;&gt; null then
						wodcargo := ti.getWOCargoRequestForPermit(); // TFS 42221 19DEC18
						txnParams.myWorkOrderDetail := wodcargo;
						txnParams.myTrackedItem := ti;
						
						ti.createTransaction(txnParams, app.myPassport);
					endif;
					
				endforeach;
			endif;
		endif;
	endforeach;
	
epilog
	delete txnParams;
end;</source>
    </JadeMethod>
