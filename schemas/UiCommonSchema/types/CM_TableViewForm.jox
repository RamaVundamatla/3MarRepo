    <JadeMethod name="searcherDockUndock" id="c8c5d45a-f365-4a1a-a392-a2c40e47cf19">
        <updating/>
        <source>searcherDockUndock(_dock : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     28 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.isSearcherFloating := (not _dock);

	if _dock then
		sptDataFilter.setLeftControl(self.frmSearch);
		sptDataFilter.showLeftControl(50, true);

		self.searcherShowHideControls(true);
		tblSearch.resetSize();
		self.zResetDataFilterRatio();

	else
		sptDataFilter.setLeftControl(null);
		self.frmSearch.parent := self;
	
		tblSearch.parent 		:= frmSearch;
		frmSearchToolbar.parent := frmSearch;

		self.searcherShowHideControls(false);
		tblSearch.adjustHeight(self.clientHeight);
		frmSearch.height := tblSearch.height + tblSearch.top + 15;

		frmSearch.width := FrmSearchStdWidth;
		frmSearch.cnEcResizeContents();
		frmSearch.height := tblSearch.height + tblSearch.top + 15;
		frmSearch.centreWindow();

		// do this at end as it causes height of tblFilter to be set to 0
		sptDataFilter.hideLeftControl(true);
	endif;

	frmSearch.zOrder(1);
	


end;</source>
        <Parameter name="_dock" type="Boolean"/>
    </JadeMethod>
