<Class name="CM_YardJob" id="e4c44ced-1279-44c5-ad6c-4f639b8fd620">
    <superclass name="CM_Job"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <access>protected</access>
    <PrimAttribute name="remarks" id="807b7608-882e-47fe-80dc-bfe09b2e7683">
        <virtual/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="addJobRequest" id="458b51cb-5631-4689-9957-e2d50fa99967">
        <updating/>
        <source>addJobRequest(	_ti : CM_TrackedItem input; 
				_isReceipt : Boolean;
				_quantity : Integer;
				_weight : Decimal;
				_passport : CM_Passport input) updating;
//This is the JADE version of the addJobRequest method.
/*

Purpose:			Creates a new Job Request

Parameters:			_ti			CM_TrackedItem	The tracked item to use for the new request
					_isReceipt	Boolean			Whether or not this is a receipt
					_quantity	Integer			The quantity for the request
					_weight		Decimal			The weight for the request
					_passport	CM_Passport		The passport to use and capture errors etc.

Return Value:		NONE

Date			Who		Reason
22 August 2024	navpw1	TFS: 65623 (65624) - Added support for Any Id Any Amount Jobs whereby a new TiRequest has to be created for the tracked item we are assigning to the release

*/
vars
	proxyYRequest	: CM_TIRequest;
	newYRequest		: CM_Request;
	deliveryRequest	: CM_Request;
	
begin

	if _ti = null then
		app.raiseCMException1(ERR_NO_OBJECT, "No TI Reference", null, null);
		return;
	endif;	

	//epr par 34466 7/7/14 removed find to add request if complete
	if self.status = JOB_COMPLETE then
	//	app.raiseCMException1(ERR_JOB_COMPLETE,self.jobId, null, null);
	endif;
	
	//Is a  TI Request, receipt or release
	create proxyYRequest  transient;
	proxyYRequest.setTrackedItem(_ti);
	
	
	proxyYRequest.setJob(self);
	proxyYRequest.isReceipt := _isReceipt;
	//epr par 34466 7/7/14
	proxyYRequest.setWeightRequested(_weight);
	proxyYRequest.setQuantity(_quantity);
	
	// ### TFS 65623 (65624) 21Aug2024 NAVPW1
	//To fix Any Id Any Amount not being assigned to release request
	deliveryRequest := self.allRequests.first;
	if deliveryRequest &lt;&gt; null and deliveryRequest.isDeliveryRequest and 
		(deliveryRequest.isAnyId or self.allRequests.first.isAnyAmount) 
	then
		proxyYRequest.setMyOriginatingBulkRelease(deliveryRequest.myOriginatingBulkRelease);
		proxyYRequest.setReserveDetail(deliveryRequest.myReserveDetail);
		
	endif;
	// ### TFS 65623 (65624) 21Aug2024 NAVPW1
	
	app.myUtilityCA.utlCreateRequest(proxyYRequest, newYRequest, _passport);
	
	//This updates the collections as well
	self.addTI(_ti, newYRequest);	

	self.updateStatus();
epilog
	delete proxyYRequest;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_isReceipt" type="Boolean"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addRequest" id="c00b80d2-25de-43bd-b1b5-6e7eb4fbf118">
        <updating/>
        <source>addRequest(pProxyRequest : CM_Request input; _passport : CM_Passport input) : CM_Request updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	request	: CM_Request;
	theTI	: CM_TrackedItem;
begin

	pProxyRequest.raiseExceptionIfNotTransient(method);
	
	create request as pProxyRequest.class persistent;
	
	pProxyRequest.setJob(self);

	request.setJob(self);
	request.setForCreate(pProxyRequest);

	if request.isKindOf(CM_BOLYardRequest) then
		self.jobType := request.CM_BOLYardRequest.myBOL.bolType;
	endif;	
	
	return request;
end;</source>
        <Parameter name="pProxyRequest" type="CM_Request" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="amendRequest" id="d9aa292f-cc59-4719-abb2-766657f83677">
        <source>amendRequest(_request:CM_YardRequest);

vars
	ti:CM_TrackedItem;
begin
	if _request = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_NO_OBJECT, null, null);
		return;	
	endif;
	if _request.isKindOf(CM_TIRequest) and _request.CM_TIRequest.trackedItem = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_INVALID_JOB, null, null);
		return;	
	elseif _request.isKindOf(CM_DeliveryRequest) and _request.CM_DeliveryRequest.isoType = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_INVALID_JOB, null, null);
		return;	
	endif;

end;</source>
        <Parameter name="_request" type="CM_YardRequest"/>
    </JadeMethod>
    <JadeMethod name="checkReceiptsNotQueued" id="72f2a5be-1666-4af5-86e6-c38da576c10a">
        <source>checkReceiptsNotQueued(_wleToIgnore : CM_WorkListEntry): Boolean;
//--------------------------------------------------
// Created:	09 December 2003 By: cnwgd1
//--------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	notQueued : Boolean;
	wle	:	CM_WorkListEntry;
begin
	foreach wle in self.workListEntries do
		if wle = _wleToIgnore then
			continue;
		endif;
		if wle.status = WLE_COMPLETED then
			continue;
		endif;
		//epr par 34612 8/8/14
		if wle.isROB then
			continue;
		endif;
		if wle.isReceipt then
			notQueued := (wle.queue = null);
			if notQueued then
				break;
			endif;
		endif;
	endforeach;
	return notQueued;

end;</source>
        <Parameter name="_wleToIgnore" type="CM_WorkListEntry"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cleanup" id="cd1d904a-a86a-49b7-aa97-8cbed77af087">
        <updating/>
        <source>cleanup(numCleaned :	Integer io) updating;
//Remove ourselves from the Queue if we are complete
vars
begin

	if self.status &lt;&gt; JOB_COMPLETE then
		return;
	endif;
	if self.allEntries.isEmpty then
		return;
	endif;
	if not tryLock(self, Exclusive_Lock, Transaction_Duration,	LockTimeout_Server_Defined	) then 
		return;
	endif;
	while self.allEntries.isEmpty = false do
		self.allEntries.last.deleteEntry(false, null);
	endwhile;
	numCleaned := numCleaned +1;	
end;</source>
        <Parameter name="numCleaned" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="createWLEs" id="883b4e4b-c132-48fb-93b3-17be747ad814">
        <updating/>
        <source>createWLEs()updating;
// 30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
vars
	tmpRequest 	: CM_Request;
	firstTime : Boolean;
begin

//WLEs are now created when the request is created
return;
	exclusiveLock(self);

	firstTime := true;

	foreach tmpRequest in self.allRequests do
		if tmpRequest.isKindOf(CM_BOLYardRequest) then
			if firstTime then
				self.jobType := tmpRequest.CM_BOLYardRequest.myBOL.bolType;
				firstTime := false;
			endif;
		endif;
		sharedLock(tmpRequest);
		tmpRequest.createWLEs();
	endforeach;
	
	self.updateStatus();	
	self.updateObjectEdition(self);	// par 30292

end;</source>
    </JadeMethod>
