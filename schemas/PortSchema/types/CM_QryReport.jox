    <JadeMethod name="doFilter" id="13dad80d-35ec-49b7-8c8d-c2fa589f89fd">
        <updating/>
        <source>doFilter(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
// -----------------------------------------------------------------------------
// Created:		28 June 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	numItems : Integer;
begin
	if _filter &lt;&gt; null then
		numItems := app.myQAFilter.sendMsgWithParams(self.qryMethodName, _filter, _passport).Integer;
	endif;
	
	return numItems;
	
epilog
	endLoad;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="erase" id="7a341cf0-31b1-4dac-bc58-2d5a4558b86f">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     21 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	menuEntity			: CM_MenuEntity;
	menuUserReport		: CM_MenuUserReport;
	bgpRequest			: BGP_ReportRequest;
begin
	foreach menuEntity in self.allMenuUserItems do
		if (not CM_MenuUserReport.hasInstance(menuEntity)) then
			continue;
		endif;
		
		//PAR22361 - cnwsh3 - 18/02/2010 - Remove references to CM_MenuUserReport.myReportRequest 
		//mapped method.  Now using getBGPReportRequest method
		menuUserReport := menuEntity.CM_MenuUserReport;
		bgpRequest := menuUserReport.getBGPReportRequest();
		
		//if global.isValidObject(menuUserReport.myReportRequest) then
		if global.isValidObject(bgpRequest) then
			//if (not self.tryLock(menuUserReport.myReportRequest, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined)) then
			if (not self.tryLock(bgpRequest, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined)) then
				app.raiseCMException1(BGP_STILL_PROCESSING, menuUserReport.heading, null, null);
				return;
			endif;
		
			//delete menuUserReport.myReportRequest;
			delete bgpRequest;
		endif;
	endforeach;
	
	delete self.myFilterObject;
	inheritMethod(_eraseLevel);


end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="ddaa559a-f8fe-433c-b93b-2a4bf49f952e">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2021	jlgndl1	Initial creation	TFS 50152

*/

vars

	txt,
	tmpStr,str	: String;
	param : CM_QueryReportParam;

begin
	
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
	tmpStr := null;
	str    := null;
	if not self.allQueryReportParams.isEmpty then
		foreach param in self.allQueryReportParams do
			if tmpStr &lt;&gt; null then
				tmpStr := tmpStr &amp; ", ";
			endif;
			tmpStr := tmpStr &amp; param.displayName &amp; "=" &amp; param.getParamValue.String;
		endforeach;
	endif;
	
	txt := txt &amp; app.getErrorString(Parameters) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	
	
	
	
	return txt;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDescriptionFromType" id="48a93240-f289-4d57-a558-4a68bfc52d20">
        <source>getDescriptionFromType(_type : Integer) : String;
// ---------------------------------------------------------------------------
// Created:     14 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 01/11/2010	cnwcs5		par 23714/ccms 1132 - new type (machine history)
// 02/08/2017	jlgdap1		TFS 5558 SNO Empty Release Reports
// 01/05/2019	jlgdap1		TFS 44298 PEL1 Host-to-Host (H2H) Monitoring
// 03/08/2022	navkc1		Bug 54342: PRP - VVR Report
// 16 March 2023 navhl20 	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
// 24/04/2023	navkc1		CR 55654 Task 55670: Jade - Contract reporting
// 16 Aug 2023 	navhl20 	ChangeRequest 58568: EUP - Delivery Dispatch – Reporting
vars
	qryReport			: CM_QryReport;
begin
	if _type = null then
		return null;
	endif;
	
	qryReport := self;
	
	if _type = qryReport.ReportType_SystemDefined then
		return qryReport.ReportTypeDescr_SystemDefined;
		
	elseif _type = qryReport.ReportType_Selector then
		return qryReport.ReportTypeDescr_Selector;
	
	elseif _type = qryReport.ReportType_External then
		return qryReport.ReportTypeDescr_External;
		
	elseif _type = qryReport.ReportType_BookingRef then	//Par 17601. July 2008
		return qryReport.ReportTypeDescr_BookingRef;
		
	elseif _type = qryReport.ReportType_CargoChgs then	//28 Feb 2012	NDL	Par 28119
		return qryReport.ReportTypeDescr_CargoChgs;
	
	elseif _type = qryReport.ReportType_CargoReport then
		return qryReport.ReportTypeDescr_CargoReport;

	elseif _type = qryReport.ReportType_BR_Discrepancy then	//07 Sep 2009	NDL CCMS 1609 Par 20521
		return qryReport.ReportTypeDescr_BR_Discrepancy;
	
	elseif _type = qryReport.ReportType_Train then	//Par 19913
		return qryReport.ReportTypeDescr_Train;

	elseif _type = qryReport.ReportType_DateSorter then  //CCMS 1869 cnwjo3
		return qryReport.ReportTypeDescr_DateSorter;

	elseif _type = qryReport.ReportType_LogCheckScaling then
		return qryReport.ReportTypeDescr_LogCheckScale;
	
	elseif _type = qryReport.ReportType_LogDocket then
		return qryReport.ReportTypeDescr_LogDocket;
	
	elseif _type = qryReport.ReportType_LogLocation then
		return qryReport.ReportTypeDescr_LogLocation;
	
	elseif _type = qryReport.ReportType_LogProductLocation then
		return qryReport.ReportTypeDescr_LogProductLoc;
		
	elseif _type = qryReport.ReportType_TrackedItem then
		return qryReport.ReportTypeDescr_TrackedItem;
		
	elseif _type = qryReport.ReportType_LogTransaction then
		return qryReport.ReportTypeDescr_LogTransaction;
		
	elseif _type = qryReport.ReportType_LogSummary then //20 January 2010	#cnwdz2	 CCMS 1108 par22177 
		return qryReport.ReportTypeDescr_LogSummary;
		
	elseif _type = qryReport.ReportType_LogVoyageRowSummary then
		return qryReport.ReportTypeDescr_LogVoyRowSum;
	
	elseif _type = qryReport.ReportType_External then
		return qryReport.ReportTypeDescr_External;
	
	elseif _type = qryReport.ReportType_VehicleDetails then
		return qryReport.ReportTypeDescr_VehicleDetails;
	
	elseif _type = qryReport.ReportType_TransactionReport then
		return qryReport.ReportTypeDescr_TransReport;
		
	elseif _type = qryReport.ReportType_TrxResource then	// 18 Jan 2010 NDL CCMS MES 1006
		return qryReport.ReportTypeDescr_TrxResource;
	
	elseif _type = qryReport.ReportType_TrxSealChecks then	// 30 Sep 2010 NDL Par 25608
		return qryReport.ReportTypeDescr_TrxSealChecks;
	
	elseif _type = qryReport.ReportType_Invoice then 		// 13/4/2010 SFW CCMS 1115 PAR23680 - cnwsh3. Invoice JRW Interface
		return qryReport.ReportTypeDescr_Invoice;
	
	elseif _type = qryReport.ReportType_InvoiceRate then	// cnwrd1 par 23583 11.8.2010
		return qryReport.ReportTypeDescr_InvoiceRate;
		
	elseif _type = qryReport.ReportType_HMSVoyage then
		return qryReport.ReportTypeDescr_HMSVoyage;
		
	elseif _type = qryReport.ReportType_HMSMasters then		//01 May 2012	NDL	Par 29496
		return qryReport.ReportTypeDescr_HMSMasters;
		
	elseif _type = qryReport.ReportType_HMSMovements then
		return qryReport.ReportTypeDescr_HMSMovements;
		
	elseif _type = qryReport.ReportType_HMSGlobalVoyage then
		return qryReport.ReportTypeDescr_HMSGlobalVoy;
		
	elseif _type = qryReport.ReportType_Events then
		return qryReport.ReportTypeDescr_Events;

	elseif _type = qryReport.ReportType_MachineHistory then	// 01/11/2010 cnwcs5 par 23714/ccms 1132
		return qryReport.ReportTypeDescr_MachineHistory;	// 01/11/2010 cnwcs5 par 23714/ccms 1132
		
	elseif _type = qryReport.ReportType_CraneKPI then		// Dec 2010 CCMS 1134
		return qryReport.ReportTypeDescr_CraneKPI;
		
	elseif _type = qryReport.ReportType_Vessels then		//01 May 2012	NDL	Par 29496
		return qryReport.ReportTypeDescr_Vessels;
		
	elseif _type = qryReport.ReportType_CashTrx then		//14 Aug 2012	NDL	Par 29496
		return qryReport.ReportTypeDescr_CashTrx;
		
	elseif _type = qryReport.ReportType_OrgAccess then		// 12 Feb 2013	cnwjre1	CCMS HAT 2205
		return qryReport.ReportTypeDescr_OrgAccess;

	elseif _type = qryReport.ReportType_VehicleBooking then		// 16 Apr 2013	NDl	Par 31393
		return qryReport.ReportTypeDescr_VehicleBooking;

	elseif _type = qryReport.ReportType_InvoiceLine then			// 22/05/2014 cnwjre1	CCMS 2348 Financial Reporting
		return qryReport.ReportTypeDescr_InvoiceLine;

	elseif _type = qryReport.ReportType_CashReceipt then		// 22/05/2014 cnwjre1	CCMS 2348 Financial Reporting
		return qryReport.ReportTypeDescr_CashReceipt;
	
	elseif _type = CM_QryReportUser.ReportType_InvoiceProforma then ////epr par 36778 18/8/15 CCMS 2368
		return CM_QryReportUser.ReportTypeDescr_InvoiceProform;

	elseif _type = qryReport.ReportType_CashCredit then		// 3/02/2016 cnwjre1	TFS 985 cash credits
		return qryReport.ReportTypeDescr_CashCredit;
	
	elseif _type = qryReport.ReportType_BOLTransaction then		// 2/05/2016 cnwjre1	TFS 1904 
		return qryReport.ReportTypeDescr_BOLTransaction;
	
	elseif _type = qryReport.ReportType_BulkReleases then			// TFS 5558
		return qryReport.ReportTypeDescr_BulkReleases;				// TFS 5558
		
	elseif _type = qryReport.ReportType_Audit then			// TFS37718
		return qryReport.ReportTypeDescr_Audit;				// TFS37718
		
	elseif _type = qryReport.ReportType_SAPActivity then		// TFS 44298
		return qryReport.ReportTypeDescr_SAPActivity;			// TFS 44298

	elseif _type = qryReport.ReportType_SpecialVoySumm then		//14 Aug 2019	NDL	TFS 46131
		return qryReport.ReportTypeDescr_SpecialVoySumm;			

	elseif _type = qryReport.ReportType_EventTransaction then		//06 Jan 2020	NDL	TFS 47780
		return qryReport.ReportTypeDescr_EvtTrans;	
		
	elseif _type = qryReport.ReportType_WOTransaction then		//16.3.2023 navhl20	#54350[54269]
		return qryReport.ReportTypeDescr_WOTrans;	
		
	elseif _type = qryReport.ReportType_LocActivity then	//01 Jun 2021 NDL	TFS 51245
		return qryReport.ReportTypeDescr_LocActivity;
	
	elseif _type = qryReport.ReportType_LocInventory then	//01 Jun 2021 NDL	TFS 51245
		return qryReport.ReportTypeDescr_LocInventory;
	
	elseif _type = qryReport.ReportType_GateReceipt then	// 03/08/2022	navkc1	#54342
		return qryReport.ReportTypeDescr_GateReceipt;		// 03/08/2022	navkc1	#54342
	
	// 20/04/2023	navkc1	CR 55654 Task 55670
	elseif _type = qryReport.ReportType_InvoiceContract then
		return qryReport.ReportTypeDescr_InvoiceContrct;
		
	elseif _type = qryReport.ReportType_WorkOrder then	//16.8.2023 navhl20 #58568
		return qryReport.ReportTypeDescr_WorkOrder;
	
	endif;	
	
	app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled report type');

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="788286c4-b20a-4bc4-b025-3fbd06052f12">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

vars

begin
	

	if _attrName = ETRow_ReportName then
		return self.reportName;
	elseif _attrName = ETRow_ReportDescription then
		return self.reportDescription;
	elseif _attrName = ETRow_JrwReport then
		return self.jrwReportName[1];
	elseif _attrName = ETRow_ReportView then
		return self.jrwViewName;
	elseif _attrName = ETRow_ReportType then
		return self.getDescriptionFromType(self.reportType);
	else
		return null;
	endif;
	
//	report.reportName &amp; Tab &amp; report.reportDescription &amp; Tab &amp; report.jrwReportName[1] &amp; Tab &amp; report.jrwViewName;	
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getETDef" id="8a2eb812-5a7b-4488-a578-bab7c55dc2fb">
        <source>getETDef() : EntTableDef;
// ---------------------------------------------------------------------------
// Created:     04 October 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpDefName	: String;
	tmpDefRoot	: EntTableDataRoot;
begin
	tmpDefName := self.getETDefName();
	if tmpDefName = null then
		return null;
	endif;
	
	tmpDefRoot := app.myRoot.myEntTableDataRoot;
	if tmpDefRoot = null then
		return null;
	endif;
	return tmpDefRoot.allEntTableDefs[tmpDefName];
end;</source>
        <ReturnType type="EntTableDef"/>
    </JadeMethod>
