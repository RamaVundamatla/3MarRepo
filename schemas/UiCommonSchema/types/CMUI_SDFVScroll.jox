    <JadeMethod name="change" id="65c8ce66-19f3-4739-881f-1e409d4a34ce">
        <updating/>
        <source>change(scroll: ScrollBar input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(scroll);
	self.mySDF.setFocus();
end;</source>
        <Parameter name="scroll" type="ScrollBar" usage="input"/>
    </JadeMethod>
