/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2019	jlgndl1	Initial creation	TFS 45963

*/

vars

begin

	return TI_TRANSMODE_NULL_STR;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validateCMIF_TIUpdateCntrlr" id="1bd51ddb-dccb-41ec-883c-17752900e100">
        <source>validateCMIF_TIUpdateCntrlr(_tiUpdateCntrlr: CMIF_TIUpdateController; _passport : CM_Passport input): Boolean;
//--------------------------------------------------------------
//Created: 02 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if (not inheritMethod(_tiUpdateCntrlr, _passport)) then
		return false;
	endif;

epilog
	return _passport.noErrors();
end;</source>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
