    <JadeMethod name="getAllReportsFromString" id="d4ae10f8-84f8-4ddb-ade1-9b5bf8c2775e">
        <options>4</options>
        <source>getAllReportsFromString(_reportsStr : String; _allReports : StringArray output) typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2025	navpw1	Initial creation

*/

vars
	reportsStr		: String;
	reportStr		: String;
	idx,
	numberOfReports	: Integer;
	
begin
	reportsStr := _reportsStr;
	
	create _allReports transient;
	reportsStr.getTokensForDelimiter(Comma, _allReports);
	numberOfReports := _allReports.size;
	
	foreach idx in 1 to numberOfReports do
		_allReports[idx] := _allReports[idx].trimBlankCharacters();
	endforeach;
	
epilog

end;</source>
        <Parameter name="_reportsStr" type="String"/>
        <Parameter name="_allReports" type="StringArray" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setNewUserDetails" id="fe72ba17-ea54-4e9d-bee8-e59c4a0d33b5">
        <updating/>
        <source>setNewUserDetails(	_user, 
					_altUser : String; 
					_isAdmin, 
					_getsSummary, 
					_getsUserSummary, 
					_getsUserIgnore,
					_isDisalbed,
					_isTester : Boolean;
					_allReports : StringArray) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
10 October 2012	cnwmc5	Initial creation
11 April 2025	navpw1	MTN-34402: Added new field allReports this will store all the user reports as strings that the user wants

*/

vars
	currentUser 					: String;
begin
	currentUser := _user;
	//self.user 			:= app.returnCorrectUserName(currentUser, true);
	self.user				:= currentUser;
	self.altUser			:= _altUser;
	self.isAdmin			:= _isAdmin;
	self.getsSummary 		:= _getsSummary;
	self.getsUserSummary 	:= _getsUserSummary;
	self.getsUserIgnore 	:= _getsUserIgnore;
	self.isDisabled			:= _isDisalbed;
	self.isTester			:= _isTester;
	self.myRoot				:= UM_Root.firstInstance();
	
	if _allReports = null then
		return;
	endif;
	
	if _allReports.isEmpty then
		self.allReports.clear();				//If empty then clear
	endif;
	
	self.allReports.clear;						//Clear out all reports
	
	_allReports.copyNoDups(self.allReports);	//Re-add selected ones
	
end;</source>
        <Parameter name="_user" type="String"/>
        <Parameter name="_altUser" type="String"/>
        <Parameter name="_isAdmin" type="Boolean"/>
        <Parameter name="_getsSummary" type="Boolean"/>
        <Parameter name="_getsUserSummary" type="Boolean"/>
        <Parameter name="_getsUserIgnore" type="Boolean"/>
        <Parameter name="_isDisalbed" type="Boolean"/>
        <Parameter name="_isTester" type="Boolean"/>
        <Parameter name="_allReports" type="StringArray"/>
    </JadeMethod>
</Class>
