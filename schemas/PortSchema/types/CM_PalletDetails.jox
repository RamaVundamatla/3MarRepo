<Class name="CM_PalletDetails" id="7ad26d1c-89c9-4e01-b672-232afa1b7506">
    <superclass name="CM_Object"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="pallet"/>
    <PrimAttribute name="heatTreated" id="ef4b7c0e-5bb1-4bc1-959b-aa10079bc496">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myPalletType" id="a063ab19-4a50-4158-8bd6-beed91cf7410">
        <embedded/>
        <type name="CM_PalletType"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="storeOnPallets" id="19ad34b0-c63f-443d-a385-3ba232ba6de4">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getHandlingTypeDisplay" id="924ffe1e-889c-4ffa-ab1a-761f6341333f">
        <source>getHandlingTypeDisplay():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2017	cnwndl1	Initial creation	TFS 3414

*/

vars

	palletType : CM_PalletType;
	str : String;

begin

	palletType := self.getPalletTypeObj();
	if palletType = null then
		return null;
		
	else
		str := palletType.getHandlingTypeDisplay( false );
		if self.heatTreated then
			str := str &amp; ", " &amp; app.getErrorString(Heat_treated);
		endif;
		if self.storeOnPallets then
			str := str &amp; ", " &amp; app.getErrorString(Store_pallets);
		endif;
		return str;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPalletType" id="5929e718-4db4-412a-b32f-361ada55826f">
        <source>getPalletType():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 April 2017	cnwndl1	Initial creation	TFS 3141

*/

vars

	palletType : CM_PalletType;

begin

	palletType := self.getPalletTypeObj;
	if palletType = null then
		return null;
		
	else
		return palletType.getHandlingTypeDisplay( false );
		
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPalletTypeObj" id="49e46a6f-5492-4f7e-b8b3-4c6c13f8dfe9">
        <source>getPalletTypeObj() : CM_PalletType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 April 2017	cnwndl1	Initial creation

*/

vars

	palletType : CM_PalletType;
	edition : Integer;
	invalid : Boolean;

begin

	if self.myPalletType = null then
		return null;
	endif;

	on Exception do app.handleDeletedObject( exception, self.myPalletType, invalid );
	edition := self.myPalletType.edition;
	
	if invalid then
		return null;
	else
		return self.myPalletType;
	endif;

epilog

end;</source>
        <ReturnType type="CM_PalletType"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="2b11f5e9-b131-4380-9623-30a1b8f3fcae">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 April 2017	cnwndl1	Initial creation	TFS 3414

*/

vars

	pxy : CM_PalletDetails;

begin
	pxy := inheritMethod();
	pxy.myPalletType := self.getPalletTypeObj;
	
	return pxy;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setBaseDetails" id="2ef2b879-c699-4488-a454-f9a3fffe91fe">
        <updating/>
        <source>setBaseDetails(	_heatTreated : Boolean;
				_storeOnPallets : Boolean;
				_myPalletType :	CM_PalletType
				) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 April 2017	cnwndl1	Initial creation	TFS 3424

*/

vars

begin

	self.heatTreated := _heatTreated;
	self.storeOnPallets := _storeOnPallets;
	self.myPalletType := _myPalletType;

epilog

end;</source>
        <Parameter name="_heatTreated" type="Boolean"/>
        <Parameter name="_storeOnPallets" type="Boolean"/>
        <Parameter name="_myPalletType" type="CM_PalletType"/>
    </JadeMethod>
</Class>
