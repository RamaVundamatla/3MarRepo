    <JadeMethod name="load" id="ff203efd-caff-40ac-b706-6af38e72dbca">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		22 July 2001 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	app.mousePointer	:=	Busy;
	centreWindow();
	self.doFormLoad();
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="showError" id="dd211eb9-0bb9-4419-b33a-7b89b1bd08df">
        <updating/>
        <source>showError():Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		22 July 2001 by cnwdad2
//
// Purpose:		Standard method to display an error message.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;
	
begin
	errorMessage	:=	self.aError;
	
	if errorMessage = null then
		return true;
	else
		self.aError	:=	null;
		app.msgBox(errorMessage, "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
		return false;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
