    <JadeMethod name="btnConfig_click" id="7520d62d-4b2c-4b34-aabd-6d96a2b6609d">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnConfig_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 January 2019	jlgndl1	Initial creation

*/

vars

	form : INV_SnapShotSummMap;

begin

	create form;
	form.setMyTerminal(self.myTerminal);	
	form.myCurrentTranMapSS := self.myCurrentTranMapSS;
	form.mySnapShotBroker := self.mySnapShotBroker;
	form.myOutputFormat := self.mySnapShotBroker.mySnapShotDefinition;
	form.mode := INV_SnapShotSummMap.Mode_Update;

	form.show();
	
	self.unloadForm;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
