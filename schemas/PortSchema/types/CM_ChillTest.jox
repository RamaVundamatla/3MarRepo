    <JadeMethod name="validateCMIF_TITransCntrl" id="60ad3ed0-1d5f-4511-b645-53bb0bcca8d8">
        <source>validateCMIF_TITransCntrl(_tiTransCntrl: CMIF_TITransactionController): Boolean;
//--------------------------------------------------------------
//Created: 11 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	rtnCode	: Boolean;

begin
	if (not inheritMethod(_tiTransCntrl)) then
		return false;
	endif;
	
	if (not _tiTransCntrl.myTrackedItem.isIntegral) then
		app.raiseCMException3(ERR_INVALID_ISOTYPE,
							 "Not an Integral Container",
							 'Tracked Item',
							 _tiTransCntrl.myTrackedItem.id,
							 'isoType', null);
		return false;
	endif;

	rtnCode := true;
epilog
	return rtnCode;
end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="b9e00b8d-7fad-47d0-9ea4-6b901ee759b3">
        <source>validateForCreate(): Boolean;
// ---------------------------------------------------------------------------
// Created:     21 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ok	: Boolean;

begin

	ok := inheritMethod();
	if (not ok) then
		return false;
	endif;
	
	if (not self.myTrackedItem.isIntegral) then
		app.raiseCMException3(ERR_INVALID_ISOTYPE, "Not an Integral Container", 'Tracked Item', self.myTrackedItem.id, 'isoType', null);
		return false;
	endif;

	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
