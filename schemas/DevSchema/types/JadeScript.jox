    <JadeMethod name="dataDumpUpdateGen" id="a1f22f44-285b-4ba7-bd9f-785c9883452f">
        <source>dataDumpUpdateGen();

vars
	aClass : Class;
	file : File;
	str : String;
	property : Property;
	classColl : ClassColl;
begin
	app.initialize();
	app.myPassport.warningsAcknowledged	:= true;
	on Exception do null global;
	app.setPassBackExceptions(false, false);
	create file transient;
	file.fileName := "d:\cnwdmast\dssFeatures.txt";
	file.mode := File.Mode_Output;
	create classColl transient;
	CM_Object.allSubclasses(classColl);
	foreach aClass in classColl do
//		if aClass.getSuperclass() &lt;&gt; HMS_Object then
//			continue;
//		endif;
		if aClass &lt;&gt; CM_ToDoTask and aClass &lt;&gt; CM_ToDoTaskDesc and
		   aClass &lt;&gt; CM_Stops and aClass &lt;&gt; CM_StopsTable then
			continue;
		endif;
		file.writeLine(Tab&amp;Tab&amp;'elseif _class = '&amp;aClass.name&amp;' then');
//		file.writeLine(Tab&amp;Tab&amp;"_classes.add("&amp;aClass.name&amp;");");
//		file.writeLine(Tab&amp;Tab&amp;"_sqlTables.add(EDB_"&amp;aClass.getNiceName()&amp;".name[5:end];");
		foreach property in aClass.allProperties do
			if property.isKindOf(Attribute) and 
			   property.name &lt;&gt; CM_Object::createdTime.name and
			   property.name &lt;&gt; CM_Object::oidAsBin.name and
			   property.name &lt;&gt; CM_Object::oidAsHex.name then
				file.writeLine(Tab&amp;Tab&amp;Tab&amp;'_features.add('&amp;aClass.name&amp;'::'&amp;property.name&amp;'.name);');
			endif;
			if property.isKindOf(Reference) and
			   not property.type.isKindOf(CollClass) and 
			   property.name &lt;&gt; HMS_Harbour::myRoot.name and
			   property.name[1:1] &lt;&gt; '_' then
				file.writeLine(Tab&amp;Tab&amp;Tab&amp;'_features.add('&amp;aClass.name&amp;'::'&amp;property.name&amp;'.name);');
			endif;
		endforeach;
	endforeach;
	app.writeStatement( "fin.");
epilog
	file.close;
	delete file;
	delete classColl;
end;</source>
    </JadeMethod>
    <JadeMethod name="dataDumpUpdateInvoiceLineSnap" id="0c6af0de-521a-4232-b6bd-2901eb82c8ab">
        <source>dataDumpUpdateInvoiceLineSnap();

vars
	obj : CM_InvoiceLine;
	ti : CM_TrackedItem;
	tr : CM_TITransaction;
	iv : CM_InvoiceLine;
begin
	ti := "2367.8423265".asOid.CM_TrackedItem;
		beginTransaction;
		ti.updateObjectEdition(ti);
		commitTransaction;
	foreach tr in ti.allTransactions do
		beginTransaction;
		tr.updateObjectEdition(tr);
		foreach iv in tr.allInvoiceLines do
			iv.updateObjectEdition(iv);
		endforeach;
		if tr.mySnapShot &lt;&gt; null then
			tr.mySnapShot.updateObjectEdition(tr.mySnapShot);
		endif;
		commitTransaction;
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="dataDumpUpdateTITransactions" id="ae19add3-4427-4611-812a-49c31eb4116c">
        <source>dataDumpUpdateTITransactions();

vars
	tr : CM_TITransaction;
	ti : CM_TrackedItem;
	terminal : CM_Terminal;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	startDate, endDate : Date;
	number : Integer;
	iter : Iterator;
	form : CMS_Modal;
	txtStartDate, txtEndDate : JadeEditMask;
	label1, label2, label3 : Label;
	trChb, tiChb : CheckBox;
	result : Integer;
begin
	app.initialize;
	terminal := app.myRoot.allTerminals["T01"];
	create form transient;
	form.caption:= "Set Transactions to start and end from.";
	create label1 transient;
	label1.caption := "Start date:=";
	label1.parent := form;
	label1.transparent := true;
	form.addControl(label1);
	label1.move(5, 1, 200, label1.height);
	create txtStartDate transient;
	txtStartDate.parent := form;
	txtStartDate.mask := "dd/MM/yyyy";
	txtStartDate.visible := true;
	txtStartDate.tabIndex := 0;
	form.addControl(txtStartDate);
	txtStartDate.move(label1.width+20, 1, txtStartDate.width, txtStartDate.height);
	create label2 transient;
	label2.caption := "End date:=";
	label2.parent := form;
	label2.transparent := true;
	form.addControl(label2);
	label2.move(5, label1.height + 10, 200, label2.height);
	create txtEndDate transient;
	txtEndDate.parent := form;
	txtEndDate.mask := "dd/MM/yyyy";
	txtEndDate.visible := true;
	txtEndDate.tabIndex := 1;
	form.addControl(txtEndDate);
	txtEndDate.move(label1.width+20, label1.height + 10, txtEndDate.width, txtEndDate.height);
	create label3 transient;
	label3.caption := "First up go from say 01/08/2006 to 31/08/2006, second time run from 01/-7/2006 to 31/07/2006 etc";
	label3.wordWrap := true;
	label3.parent := form;
	label3.transparent := true;
	form.addControl(label3);
	label3.move(10, label2.top + 50, 200, 50);
	create trChb transient;
	trChb.caption := "Update matching Transactions.";
//	trChb.wordWrap := true;
	trChb.parent := form;
	trChb.transparent := true;
	form.addControl(trChb);
	trChb.move(10, label3.top + 50, 200, 50);
	create tiChb transient;
	tiChb.caption := "Update matching Tracked Items.";
//	trChb.wordWrap := true;
	tiChb.parent := form;
	tiChb.transparent := true;
	form.addControl(tiChb);
	tiChb.move(10, trChb.top + 50, 200, 50);
	txtStartDate.setFocus();
	form.btnCancel.visible := true;
	result := form.showModal();
	if result = IDCANCEL then
		return;
	endif;
	startDate := txtStartDate.text.Date;
	endDate := txtEndDate.text.Date;
	if (not startDate.isValid()) or (not endDate.isValid()) or (startDate &gt; endDate) then
		app.msgBox("Start Date ="&amp;startDate.String&amp;' End Date ='&amp;endDate.String , "Error Invalid Date", 0);
		return;
	endif;
	if not trChb.value and not tiChb.value then 
		app.msgBox(" Must select either Transaction or Tracked Item or both.", "Error Invalid Update Type", 0);
		return;
	endif;
	startDateTime.setDate(startDate);
	startDateTime.setTime("0.0.0.0".Time);
	endDateTime.setDate(endDate);
	endDateTime.setTime("23.59.59.999".Time);
	iter := terminal.allTITransactions.createIterator;
	terminal.allTITransactions.startKeyGeq(startDateTime, 0, iter);
	while iter.next(tr) do
		if tr.dateTime &gt; endDateTime then
			break;
		endif;
			beginTransaction;
		if trChb.value then
			number := number + 1;
			tr.updateObjectEdition(tr);	// par 30292
		endif;
		if tiChb.value then
			ti := tr.myTrackedItem;
			number := number + 1;
			ti.updateObjectEdition(ti);	// par 30292
		endif;
			commitTransaction;
	endwhile;
	if tr = null then
		app.msgBox((number).String&amp;' hexOid=null' , " Warning end position", 0);
	else	
		app.msgBox((number).String&amp;' hexOid='&amp;tr.oidAsHex , " Warning end position", 0);
	endif;
epilog
	delete trChb;
	delete tiChb;
	delete txtStartDate;
	delete txtEndDate;
	delete label1;
	delete label2;
	delete label3;
	delete form;
end;
</source>
    </JadeMethod>
    <JadeMethod name="dataDumpUpdateTIs" id="670a0f3a-5580-422b-bd8e-b7f0b3e337ba">
        <source>dataDumpUpdateTIs();

vars
	ti : CM_TrackedItem;
	obj : Object;
	startCount, count, endCount : Integer;
	number : Integer;
	objArray : ObjectArray;
	form : CMS_Modal;
	txtStartCount, txtCount : TextBox;
	label1, label2, label3 : Label;
	newLoadPortCode : String;
	newDischargePortCode : String;
	newDestinationCode : String;
	oldLoadPortCode : String;
	oldDischargePortCode : String;
	oldDestinationCode : String;
	file : File;
	msg : String;
begin
	app.initialize;
	create file transient;
	file.kind := File.Kind_Unknown_Text; // 2/3/16  cnwns1 PAR 36286 unicode version
	file.fileName := "c:\temp\tiupdatefile.txt";
	file.mode := File.Mode_IO;
	file.open;
	create form transient;
	form.caption:= "Set number of TrackedItems to process and start from.";
	create label1 transient;
	label1.caption := "Start number:=";
	label1.parent := form;
	label1.transparent := true;
	form.addControl(label1);
	label1.move(5, 1, 200, label1.height);
	create txtStartCount transient;
	txtStartCount.parent := form;
	txtStartCount.alignment := TextBox.Alignment_Right;
	txtStartCount.visible := true;
	txtStartCount.tabIndex := 0;
	form.addControl(txtStartCount);
	txtStartCount.move(label1.width+20, 1, txtStartCount.width, txtStartCount.height);
	create label2 transient;
	label2.caption := "Number to process:=";
	label2.parent := form;
	label2.transparent := true;
	form.addControl(label2);
	label2.move(5, label1.height + 10, 200, label2.height);
	create txtCount transient;
	txtCount.parent := form;
	txtCount.alignment := TextBox.Alignment_Right;
	txtCount.visible := true;
	txtCount.tabIndex := 1;
	form.addControl(txtCount);
	txtCount.move(label1.width+20, label1.height + 10, txtCount.width, txtCount.height);
	create label3 transient;
	label3.caption := "First up go from say 1 for 100, second time run from 101 for 100 third time 201 for 100 etc";
	label3.wordWrap := true;
	label3.parent := form;
	label3.transparent := true;
	form.addControl(label3);
	label3.move(10, label2.top + 50, 200, 50);
	txtStartCount.setFocus();
	form.showModal();
	if form.modalResult &lt;&gt; IDOK then
		return;
	endif;
	startCount := txtStartCount.text.Integer;
	file.writeLine("Start position="&amp;(startCount).String);
	count := txtCount.text.Integer;

	create objArray transient;
	CM_TrackedItem.allInstances(objArray, 0, true);
	foreach obj in objArray do
		number := number + 1;
		if number &lt; startCount then
			continue;
		endif;
		if number &gt;= startCount + count then
			break;
		endif;
		ti := obj.CM_TrackedItem;

		msg := null; 
/*		newLoadPortCode := self.dataDumpUpdatePort(ti.operatorCode, ti.loadPort, true, false, false);*/
//		newDischargePortCode := self.dataDumpUpdatePort(ti.operatorCode, ti.dischargePort,false, true, false);
/*		newDestinationCode := self.dataDumpUpdatePort(ti.operatorCode,ti.destinationPort, false, false, true);

		oldLoadPortCode := ti.loadPort;
*/
		oldDischargePortCode := ti.dischargePort;
/*		oldDestinationCode := ti.destinationPort;
*/
		if /*(newLoadPortCode &lt;&gt; null and newLoadPortCode &lt;&gt; oldLoadPortCode)  or */
		   (newDischargePortCode &lt;&gt; null and newDischargePortCode &lt;&gt; oldDischargePortCode) /*or 
		   (newDestinationCode &lt;&gt; null and newDestinationCode &lt;&gt; oldDestinationCode)*/ then
			beginTransaction;
/*			if newLoadPortCode &lt;&gt; null then
				ti.setPropertyValue(CM_TITransaction::loadPort.name, newLoadPortCode);
				msg := msg&amp;' LoadPort '&amp;oldLoadPortCode&amp;' to '&amp;newLoadPortCode;
			endif;
*/			if newDischargePortCode &lt;&gt; null then
				ti.setPropertyValue(CM_TITransaction::dischargePort.name, newDischargePortCode);
				msg := msg&amp;' Discharge '&amp;oldDischargePortCode&amp;' to '&amp;newDischargePortCode;
			endif;
/*			if newDestinationCode &lt;&gt; null then
				ti.setPropertyValue(CM_TITransaction::destinationPort.name, newDestinationCode);
				msg := msg&amp;' Dest '&amp;newDestinationCode&amp;' to '&amp;oldDestinationCode;
			endif;
*/
			commitTransaction;
		endif;
		if msg &lt;&gt; null then
			file.writeLine('change '&amp;ti.id&amp;msg);
		endif;

		endCount := endCount + 1;
	endforeach;
	app.msgBox((endCount+startCount).String&amp;' hexOid='&amp;ti.oidAsHex ,"Warning end position",0);
	file.writeLine("End position="&amp;(endCount+startCount).String&amp;' hexOid='&amp;ti.oidAsHex);
epilog
	file.close;
	delete file;
	delete txtStartCount;
	delete txtCount;
	delete label1;
	delete label2;
	delete label3;
	delete form;
	delete objArray;	
end;</source>
    </JadeMethod>
    <JadeMethod name="dataDumpUpdateTIsOld" id="60688139-e284-4ea3-8693-9755dc1bc28b">
        <source>dataDumpUpdateTIsOld();

vars
	ti : CM_TrackedItem;
	obj : Object;
	startCount, count, endCount : Integer;
	number : Integer;
	objArray : ObjectArray;
	form : CMS_Modal;
	txtStartCount, txtCount : TextBox;
	label1, label2, label3 : Label;
begin
	app.initialize;
	create form transient;
	form.caption:= "Set number of TrackedItems to process and start from.";
	create label1 transient;
	label1.caption := "Start number:=";
	label1.parent := form;
	label1.transparent := true;
	form.addControl(label1);
	label1.move(5, 1, 200, label1.height);
	create txtStartCount transient;
	txtStartCount.parent := form;
	txtStartCount.alignment := TextBox.Alignment_Right;
	txtStartCount.visible := true;
	txtStartCount.tabIndex := 0;
	form.addControl(txtStartCount);
	txtStartCount.move(label1.width+20, 1, txtStartCount.width, txtStartCount.height);
	create label2 transient;
	label2.caption := "Number to process:=";
	label2.parent := form;
	label2.transparent := true;
	form.addControl(label2);
	label2.move(5, label1.height + 10, 200, label2.height);
	create txtCount transient;
	txtCount.parent := form;
	txtCount.alignment := TextBox.Alignment_Right;
	txtCount.visible := true;
	txtCount.tabIndex := 1;
	form.addControl(txtCount);
	txtCount.move(label1.width+20, label1.height + 10, txtCount.width, txtCount.height);
	create label3 transient;
	label3.caption := "First up go from say 1 for 100, second time run from 101 for 100 third time 201 for 100 etc";
	label3.wordWrap := true;
	label3.parent := form;
	label3.transparent := true;
	form.addControl(label3);
	label3.move(10, label2.top + 50, 200, 50);
	txtStartCount.setFocus();
	form.showModal();
	startCount := txtStartCount.text.Integer;
	count := txtCount.text.Integer;
	write startCount;
	create objArray transient;
	CM_TrackedItem.allInstances(objArray, 0, true);
	foreach obj in objArray do
		number := number + 1;
		if number &lt; startCount then
			continue;
		endif;
		if number &gt;= startCount + count then
			break;
		endif;
		ti := obj.CM_TrackedItem;
		beginTransaction;
		ti.updateObjectEdition(ti);	// par 30292
		commitTransaction;
		app.writeStatement( (endCount+startCount).String&amp;' hexOid='&amp;ti.oidAsHex);
		endCount := endCount + 1;
	endforeach;
	app.msgBox((endCount+startCount).String&amp;' hexOid='&amp;ti.oidAsHex ,"Warning end position",0);
epilog
	delete txtStartCount;
	delete form;
	delete objArray;	
end;</source>
    </JadeMethod>
    <JadeMethod name="dataDumpXDBExHandler" id="25152cb9-d77e-4b36-8401-da050a2cc218">
        <source>dataDumpXDBExHandler(exObj: Exception; agent: CM_ExternalDatabaseAgent input) : Integer;
// ---------------------------------------------------------------------------
// Created:		12 August 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	abortTransaction;
	app.writeStatement( "EDB exception - abandoned changes" &amp; CrLf &amp;
			"Error Code: " &amp; exObj.errorCode.String &amp; CrLf &amp;
			"Extended Error Text: " &amp; exObj.extendedErrorText);
	agent.abortTrans("EDB");
	
	return Ex_Abort_Action;
end;</source>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="agent" type="CM_ExternalDatabaseAgent" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="dataDumpXDBTestBulkUpdate" id="012fdb3f-58e9-49f5-8a76-1d8cd315a0a6">
        <source>dataDumpXDBTestBulkUpdate();
// ---------------------------------------------------------------------------
// Created:     20 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
constants
	DDxDefDescription = "Joe's Test SQL Native";
vars
	agent : CM_ExternalDatabaseAgent;
	obj : Object;
	cnt : Integer;
	def : CM_DataDumpExtractDef;
	classToUpdate : Class;
	dictSize : Integer;
	transExtractDef : CM_DataDumpTransExtractDef;
	oba : ObjectArray;
	created, updated : Boolean;
	sqlStatement: String;
	file: File;
	longSqlStatement: CM_LongString;
	sqlStatements: CM_LongStringArray;
	loadMode: Boolean;
begin
	app.initialize;
	
	classToUpdate := CM_Country;

	create sqlStatements transient;
	create agent transient;
	on Exception do self.dataDumpXDBExHandler(exception, agent);

	// Initialise the agent with the transExtractDef for this extractDef
	def := app.myRoot.allDataDumpExtractDefs[DDxDefDescription];
	if def = null then
		app.writeStatement( "Definition not found");
		return;
	endif;
	create transExtractDef transient;
	transExtractDef.setForCreate(def, false);
	
	agent.initialise(EDB_PortDss, transExtractDef, null, false);
	
	dictSize := agent.getExternalDictSize(classToUpdate);
	if dictSize &gt; agent.MaxPerExternalTransaction then
		app.writeStatement( "Too many items to bulk update: " &amp; dictSize.String);
		return;
	endif;

	agent.beginTrans;

	create oba transient;
	classToUpdate.allInstances(oba, agent.MaxPerExternalTransaction, true);

	agent.purgeExternalDict(classToUpdate);
	
	foreach obj in oba do
		agent.updateExternalObj(obj, created, updated, sqlStatement, loadMode);
		if sqlStatement &lt;&gt; null then
			create longSqlStatement transient;
			longSqlStatement.string := sqlStatement;
			sqlStatements.add(longSqlStatement);	
		endif;
	endforeach;
	
	agent.commitTrans("EDB");
	
	agent.inspectExternalDict(classToUpdate);
	if sqlStatements.size &gt; 0 then
		create file transient;
		file.fileName := classToUpdate.name.trimBlanks&amp;".sql";
		file.mode := File.Mode_Output;
		file.open;
		file.writeLine("USE database");
		foreach longSqlStatement in sqlStatements do
			file.writeLine(longSqlStatement.string);
		endforeach;
		file.close;
	endif;

epilog
	if agent &lt;&gt; null then
		agent.finalise;
	endif;
	delete agent;
	delete transExtractDef;
	delete oba;
end;</source>
    </JadeMethod>
    <JadeMethod name="dataDumpXDBTestCount" id="c24799b0-db7f-41bf-a0c6-f9ea265764d3">
        <source>dataDumpXDBTestCount();
// ---------------------------------------------------------------------------
// Created:     20 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
constants
