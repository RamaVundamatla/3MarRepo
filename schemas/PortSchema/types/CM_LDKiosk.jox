    <JadeMethod name="pxyCreateUpdateProxy" id="e03b9a25-d050-4853-a021-38479a76469c">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     28 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxy	:SelfType;
	completedOK		: Boolean;
begin
	proxy :=  inheritMethod();

	proxy.myKiosk	:= self.myKiosk;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="3c3ea60b-8467-4dbf-b866-35ac505d5951">
        <updating/>
        <source>setForUpdate(_proxy: CM_LDKiosk) updating;
// ---------------------------------------------------------------------------
// Created:     28 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_proxy);
	
	self.myKiosk	:= _proxy.myKiosk;

epilog

end;</source>
        <Parameter name="_proxy" type="CM_LDKiosk"/>
    </JadeMethod>
    <JadeMethod name="setKiosk" id="619d411d-cb89-43cf-8418-9f8e518b2c51">
        <updating/>
        <source>setKiosk(_kiosk : CM_Kiosk) updating;

/*
Date			Who		Reason
07 July 2009	cnwar2	Initial creation

*/
vars

begin
	self.raiseExceptionIfNotTransient (method);
	
	if self.myKiosk &lt;&gt; _kiosk then
		self.myKiosk := _kiosk;
	endif;
end;</source>
        <Parameter name="_kiosk" type="CM_Kiosk"/>
    </JadeMethod>
    <JadeMethod name="validate" id="5ba82ff4-7379-4333-aec6-5b71e7fdfd5f">
        <source>validate(_passport: CM_Passport input) protected;

/*
Date		Who		Reason
07 Jul 2009	cnwar2	Initial creation
05 Dec 2019	jlgsl4	TFS 47719 - JMT - Can't edit Gate Definition when kiosk is associated
17 Jan 2024 navma1	Bug 61953: FR | 57937 - [TKT: 61898] - Kiosk - US.010 'b' - Kiosk can't be associated to multiple gates
*/
vars
	newGateArea,
	oldGateArea		: CM_GateArea;
	aKiosk 			: CM_Kiosk;
	aLaneDevice, 
	realLaneDevice  : CM_LaneDevice; // TFS 47719
begin
	
	inheritMethod(_passport);

	
	
	aKiosk := self.myKiosk;
	
	if aKiosk = null then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Kiosk required');
	endif;
	realLaneDevice := self.pxyGetRealObject(); // TFS 47719
	//need to get MY gate area.
	newGateArea := self.myLaneController.getMyGridArea().CM_GateArea;
		
	if newGateArea.isTransient then										//17.01.2024 navma1 #61953
		newGateArea := newGateArea.pxyGetRealObject();
	endif;
	// now need to check all the other gate areas for a different one.
	foreach aLaneDevice in aKiosk.allLaneDevices do
		if  realLaneDevice = aLaneDevice then // TFS 47719
			continue;
		endif;
		
		oldGateArea := aLaneDevice.myLaneController.getMyGridArea().CM_GateArea;
		
		if oldGateArea &lt;&gt; newGateArea then
			app.raiseCMException2(Kiosk_already_has_area, aKiosk.description, oldGateArea.id, null, null);
		endif;
		
	endforeach;
	

	
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
