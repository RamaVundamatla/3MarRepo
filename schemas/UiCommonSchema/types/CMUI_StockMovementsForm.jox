    </JadeMethod>
    <JadeMethod name="validateByLocation" id="9bb997de-607c-43b6-a5ef-ce1544de41a7">
        <updating/>
        <source>validateByLocation(_errorsOnly : Boolean; _validationType : Integer) updating;
//--------------------------------------------------------------
//Created: September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpSheet	: JadeTableSheet;
	sohLocns	: CM_SOHLocationsByProduct;
	lcSet		: CM_LCSet;
	termAreas	: CM_TAByIdDict;
	termArea	: CM_TerminalArea;
	sohLocn		: CM_SOHLocation;
	locnCntrl	: CM_LocationsController;
	errorsFound, 
	loadStateSet 	: Boolean;
	idx, numTIsLC, numTIsSOH 	: Integer;
	volLocn, volSOHLocn 		: Decimal[16,4];	
	weightSOHLocn, qtySOHLocn,
	weightLocn, qtyLocn 		: Real;
	tmpPartsInJob, 
	tmpPartsDone,
	locnStartRow	: Integer;
	cmifMonitor : CMIF_Monitor;
begin

	app.mousePointer := Busy;

	tmpSheet := tblData.accessSheet(TblDataSheet_ValidateTotals);
	tmpSheet.columns 	:= 5;
	tmpSheet.rows 		:= 1;
	tmpSheet.fixedRows 	:= 1;
	tmpSheet.accessCell(1,1).text := 'Totals For' &amp; Tab &amp; 'No. Items' &amp; Tab &amp;'Total Qty' &amp; Tab &amp; 'Total Volume' &amp; Tab &amp; 'Total Weight (kgs)';
	tmpSheet.accessColumn(2).alignment := Table.Alignment_Left_Middle;
	tmpSheet.accessColumn(3).alignment := Table.Alignment_Right_Middle;
	tmpSheet.accessColumn(4).alignment := Table.Alignment_Right_Middle;
	tmpSheet.accessColumn(5).alignment := Table.Alignment_Right_Middle;	
			
	app.cmsBeginLoad(loadStateSet);
	create lcSet transient;

	if _validationType = ValidType_Location and self.filtLocationType = LocationType_LC then
		if self.myFiltLC = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Location', null, null);
			app.raiseCMException(Input_required_field_locn, null, null); // cnwdb2	PAR 35364
			return;
		endif;
		lcSet.add(self.myFiltLC);

	elseif _validationType = ValidType_TerminalArea then
		if self.myFiltTA = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal Area', null, null);		
			app.raiseCMException(Input_required_field_termArea, null, null);				 // cnwdb2	PAR 35364
			return;
		endif;	
		sharedLock(self.myFiltTA);
		self.myFiltTA.allLocationsControllers.copy(lcSet);
		// PAR 18081
		self.myFiltTA.allLCsArchived.copy(lcSet);

	elseif _validationType = ValidType_Voyage then
		if self.myFiltVoyage = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Voyage', null, null);	
			app.raiseCMException(Input_required_field_voyage, null, null); // cnwdb2	PAR 35364
			return;
		endif;		
		sharedLock(self.myFiltVoyage);
		self.myFiltVoyage.allVoyageLocations.copy(lcSet);		

	else
		if self.myFiltTerminal = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', null, null);	
			app.raiseCMException(Input_required_field_terminal, null, null); // cnwdb2	PAR 35364
			return;
		endif;		
		termAreas := self.myFiltTerminal.allTerminalAreas;
		foreach termArea in termAreas where termArea.isStockControlled do
			sharedLock(termArea);
			termArea.allLocationsControllers.copy(lcSet);
			// PAR 18081
			termArea.allLCsArchived.copy(lcSet);
		endforeach;
	endif;

	create cmifMonitor transient;
   	cmifMonitor.myParent := self;
   	self.modalDialogReturnValue := self.ModalDialogReturn_Null;
	self.modalDialogShow(null, 'Cancel', null, null, 'Checking Stock', cmifMonitor.message);		
	tmpPartsInJob := lcSet.size;
	self.pbProgressBar.partsInJob := tmpPartsInJob;
	self.pbProgressBar.visible := true;
	cmifMonitor.updateProgress(null, tmpPartsInJob, tmpPartsDone);
	
	foreach locnCntrl in lcSet do
		sharedLock(locnCntrl);

		tmpPartsDone := tmpPartsDone + 1;
		if (not cmifMonitor.updateProgress('Validating ' &amp; locnCntrl.getID, tmpPartsInJob, tmpPartsDone)) then
			break;
		endif;			

		if locnCntrl.allProductLocations.isEmpty then
			continue;
		endif;		
		volLocn := locnCntrl.getTotalVolumeActual();
		weightLocn := locnCntrl.getTotalWeightActual();	
//		qtyLocn := locnCntrl.numTIs;	want total quantity of whats in TI's not number of TI's HG 10/01/05
		qtyLocn := locnCntrl.getQuantityActual();
		numTIsLC := locnCntrl.numTIs;
		
		idx := tmpSheet.addItem(locnCntrl.getID() &amp; Tab &amp;
								numTIsLC.String &amp; Tab &amp;
								qtyLocn.String &amp; Tab &amp;
								volLocn.jasVolumeString &amp; Tab &amp;
								weightLocn.String);		
		
		locnStartRow := idx;
		
		tmpSheet.accessRow(idx).backColor := self.colorRow1;
		tmpSheet.accessRow(idx).itemObject := locnCntrl;
		volSOHLocn 		:= 0;
		weightSOHLocn 	:= 0;
		qtySOHLocn 		:= 0;
		numTIsSOH 		:= 0;
		
		sohLocns := locnCntrl.allProductLocations;
		foreach sohLocn in sohLocns do
			idx := tmpSheet.addItem(sohLocn.myProduct.code &amp; Tab &amp;
									sohLocn.numTIs.String &amp; Tab &amp;
							 		sohLocn.currentQuantity.String &amp; Tab &amp; 
							 		sohLocn.currentVolume.jasVolumeString &amp; Tab &amp; 
							 		sohLocn.currentWeightKgs.String);
			tmpSheet.accessRow(idx).backColor := self.colorRow1;
			tmpSheet.accessRow(idx).itemObject := sohLocn;
									 		
			volSOHLocn 		:= volSOHLocn + sohLocn.currentVolume;
			weightSOHLocn 	:= weightSOHLocn + sohLocn.currentWeightKgs;
			qtySOHLocn 		:= qtySOHLocn + sohLocn.currentQuantity;
			numTIsSOH 		:= numTIsSOH + sohLocn.numTIs;
		endforeach;

		if (numTIsLC &lt;&gt; numTIsSOH) or
		   (qtyLocn &lt;&gt; qtySOHLocn) or
		   (volLocn &lt;&gt; volSOHLocn) or
		   (weightLocn &lt;&gt; weightSOHLocn) then
			errorsFound := true;
		else
			errorsFound := false;	
		endif;		
		if _errorsOnly and (not errorsFound) then
			tmpSheet.rows := locnStartRow - 1;
			continue;
		endif;
		
		if errorsFound then
			idx := tmpSheet.addItem('Difference ' &amp; Tab &amp;
								(numTIsLC - numTIsSOH).String &amp; Tab &amp;
								(qtyLocn - qtySOHLocn).String &amp; Tab &amp;
								(volLocn - volSOHLocn).jasVolumeString &amp; Tab &amp;
								(weightLocn - weightSOHLocn).String);		   								

			tmpSheet.accessRow(idx).backColor := Red;
			tmpSheet.accessRow(idx).foreColor := White;	
		endif;		

	endforeach;

epilog
	app.cmsEndLoad(loadStateSet);
	self.frmModalDialog.visible := false;
	delete lcSet;
	delete cmifMonitor;	
	app.myPassport.setMyCMIFMonitor(null);	
	app.mousePointer := MousePointer_Default;

	app.mousePointer := Idle;
end;</source>
        <Parameter name="_errorsOnly" type="Boolean"/>
        <Parameter name="_validationType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zAddTblDataColumn" id="a5952e8e-4610-4af3-86c1-6553c3b69dcc">
        <updating/>
        <source>zAddTblDataColumn(_heading, _property : String; _inputType : Integer) updating, protected;
