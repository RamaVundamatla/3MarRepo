    <JadeMethod name="setupForm" id="ee26f8a4-2aa6-49f0-bec6-b9b1f4abb53e">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2013	cnwndl1	Initial creation

*/

vars

begin
	inheritMethod();
	
	if self.myVoyage = null then
		self.setCaption(app.getErrorString1(GCVoyage_locn_def,null));
	else
		self.setCaption(app.getErrorString1(GCVoyage_locn_def,self.myVoyage.code));
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="3f91cfc3-3d6e-457d-8d30-30703f805429">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 26 July 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019173, locale);
end;</source>
    </JadeMethod>
</GUIClass>
