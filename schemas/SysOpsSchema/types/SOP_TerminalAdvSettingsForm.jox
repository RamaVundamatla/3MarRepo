<GUIClass name="SOP_TerminalAdvSettingsForm" id="358fb325-0150-437c-97a2-1488a08152de">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="grpCrossRef" id="2e41f924-b5ad-4d5f-9d2a-a1a9eb12fd54">
        <embedded/>
        <type name="CMUI_GroupBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblInstructions" id="54df49df-fc5c-45d2-8527-d6d9608c461d">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="optDelete" id="00378599-dc52-4062-bd84-49d47ba8fd1b">
        <embedded/>
        <type name="CMUI_OptionButton"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="optRebuild" id="3a25fb10-3824-4f70-92fe-a2f77e013e41">
        <embedded/>
        <type name="CMUI_OptionButton"/>
    </ImplicitInverseRef>
    <JadeMethod name="doOK" id="b47a2dc4-3efb-4280-ad79-a79013db8186">
        <updating/>
        <source>doOK() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 Sep 2009	cnwkpd1	PAR #20398 - Add Booking Reference cross reference functionality

*/

vars
	doRebuild		: Boolean;
	confirm			: String;
	passport		: CM_Passport;
	cmifMonitor		: CMIF_Monitor;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	doRebuild := self.optRebuild.value;
	
	// First get confirmation from User
	if doRebuild then
		confirm := self.optRebuild.caption;
	else
		confirm := self.optDelete.caption;
	endif;
	
	if app.msgBox(confirm &amp; "?", app.getErrorString(SHP_Confirm), MsgBox_Yes_No_Cancel) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	
	// If OK to proceed, then set up CMIF_Monitor
	app.mousePointer := self.MousePointer_HourGlass;				
	passport := app.myPassport;
	
	cmifMonitor := passport.myCMIFMonitor;
	if cmifMonitor &lt;&gt; null then
		delete cmifMonitor;
	endif;
	create cmifMonitor transient;
	cmifMonitor.myParent := self;
	passport.setMyCMIFMonitor(cmifMonitor);

	self.modalDialogReturnValue := self.ModalDialogReturn_Null;	
	self.modalDialogShow(null, app.getErrorString(Cancel), null, null, confirm, app.getErrorString(PleaseWait) &amp; "...");
	self.pbProgressBar.visible := true;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		// And call appropriate trx
		if doRebuild then
			app.myTrxUA.trxRebuildTerminalBRXref(self.myTerminal, passport);
		else
			app.myTrxDA.trxDeleteTerminalBRXref(self.myTerminal, passport);
		endif;
	
		if app.myPassport.trxCompletedOK then
			inheritMethod();
			break;
		else
			theResult := app.showErrorWarningDialog(app.getString(Terminal) &amp; " " &amp; app.getString(Advanced_Settings), passport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

epilog
	self.frmModalDialog.visible := false;
	app.mousePointer := self.MousePointer_Default;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1333fb4f-c592-4956-a16a-ecebf4aed1b1">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 Sep 2009	cnwkpd1	PAR #20398 - Add Booking Reference cross reference functionality

*/

vars

begin
	inheritMethod();
	
	if self.myTerminal.getBookingRefXref() = null then
		self.optDelete.enabled := false;
	endif;
	
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(null, PmCmpTerminalMaint) then
		self.btnOk.enabled:= false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="03426b8a-eabe-41ac-bdce-4a0b3cf33e87">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0011716, locale);
	lblInstructions.translateCaption(Xlat_0011717, locale);
	optDelete.translateCaption(Xlat_0011718, locale);
	optRebuild.translateCaption(Xlat_0011719, locale);
end;</source>
    </JadeMethod>
</GUIClass>
