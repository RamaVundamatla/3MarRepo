    <JadeMethod name="tblExtra_queryRowColChg" id="22b72fff-6c8a-4436-966a-816d05e26181">
        <controlMethod name="CM_EntryTable::queryRowColChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblExtra_queryRowColChg(table: Table input; newSheet: Integer; newRow: Integer; newCol: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     15 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	entRowTrans	: EntTableRowTransient;
	rowName		: String;

begin

/*	

	entRowTrans := table.accessRow(newRow).itemObject.EntTableRowTransient;
	if entRowTrans = null then
		return true;
	endif;

	rowName := entRowTrans.name;

	// only enable the change event for those rows that
	// require the change event to be fired (reduces network traffic).

	if rowName = ETRow_HasCOU or
	   rowName = ETRow_StatusString or
	   rowName = ETRow_IsOverDimensions or
	   rowName = ETRow_HasAttachments or
	   rowName = ETRow_TransportMode or
	   rowName = ETRow_JasScaled then
		table.enableEvent('change', true);
	else
		table.enableEvent('change', false);
	endif;
*/	
	return true;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblExtra_resizeColumn" id="5d549126-ee27-4df0-8507-0c8fed43d1e4">
        <controlMethod name="CM_EntryTable::resizeColumn"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblExtra_resizeColumn(table: Table input; column: Integer input; previousWidth: Integer input) updating;
// ---------------------------------------------------------------------------
// Created:     08 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	mainTbl	: CM_EntryTable;
	sheet	: GTE_Sheet;
	
begin

	sheet := self.topSheet;
	
	if sheet = null then
		return;
	endif;
	
	mainTbl := sheet.myTblMain;
	
	if mainTbl &lt;&gt; null then
		mainTbl.accessColumn(column).width := table.accessColumn(column).width;
		mainTbl.setValueColumnWidth();
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="column" type="Integer" usage="input"/>
        <Parameter name="previousWidth" type="Integer" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblExtra_rowColumnChg" id="1f4d1957-d70d-4fdf-8fd0-f14262b7aec6">
        <controlMethod name="CM_EntryTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblExtra_rowColumnChg(table: CM_EntryTable input) updating;
// ---------------------------------------------------------------------------
// Created:     12 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	entRowTrans	: EntTableRowTransient;
	theRow		: Integer;

begin
	theRow := table.row;
	entRowTrans := table.accessRow(theRow).itemObject.EntTableRowTransient;
	if entRowTrans = null then
		return;
	endif;


	// only enable queryRowColChg event for those
	// rows that have a "lostFocusMethod"
	if entRowTrans.lostFocusMethodName &lt;&gt; null then
		table.enableEvent('queryRowColChg', true);
	else
		table.enableEvent('queryRowColChg', false);
	endif;

	//epr par 20792 12/10/09 removed code that was disabling enabling the change event for certain rows

	if table.isOnTopOrBottomRow() then
		self.addRegisteredKey(J_key_Tab);
		//self.enableEvent('keyDown', true);
	else
		self.removeRegisteredKey(J_key_Tab);
		//self.enableEvent('keyDown', false);
	endif;
end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
