    <JadeMethod name="delete" id="b14243f0-acc8-420c-89f8-17cd0cb0f1a1">
        <updating/>
        <source>delete() updating;

vars

begin

	if self.myLocationRestriction &lt;&gt; null then
		self.myLocationRestriction.erase(NORMAL_ERASE);
	endif;

end;</source>
