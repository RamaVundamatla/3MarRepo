vars

begin

	self.shtOne.visible := _state;
	self.shtTwo.visible := _state;
	self.shtThree.visible := _state;
	self.shtFour.visible := _state;
	self.shtFive.visible := _state;
	self.shtSix.visible := _state;
	self.shtSeven.visible := _state;
	self.shtEight.visible := _state;

end;</source>
