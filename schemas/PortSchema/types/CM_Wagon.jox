    <JadeMethod name="getLocationId" id="5339d1c3-b215-490e-89e1-034a83bbffa3">
        <source>getLocationId() : String;
//--------------------------------------------------
// Created:	05 September 2003 By: cnwgd1
//--------------------------------------------------
vars

begin

	if self.myRailLine &lt;&gt; null then
		return self.myRailLine.getFullId() &amp; self.getWagonPosition();
	endif;
	
	if self.isDeparted() then
		return app.getErrorString(Departed);
	endif;
	
	return null;
end;</source>
