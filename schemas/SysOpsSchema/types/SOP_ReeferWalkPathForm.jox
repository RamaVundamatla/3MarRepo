epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="unselectAllRowsDeleteProxies" id="b498f0b3-9f37-479a-8512-13a9e906d2d8">
        <updating/>
        <source>unselectAllRowsDeleteProxies() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2020	jlgndl1	Initial creation

*/

vars

	rowIndex : Integer;
	size : Integer;

begin

	self.mySelectedReeferBlock := null;
	
	if self.myProxyReeferBlock &lt;&gt; null then
		delete self.myProxyReeferBlock;
		self.myProxyReeferBlock := null;
	endif;

	size := self.tblReeferWalkBlocks.rows;
	foreach rowIndex in 1 to size do
		if self.tblReeferWalkBlocks.accessRow(rowIndex).selected then
			self.tblReeferWalkBlocks.accessRow(rowIndex).selected := false;
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="e3b844fe-94fc-452f-8d70-af06bc0e140f">
        <source>validateForUpdate( _name : String output; _objArray : ObjectArray input; _terminalArea : CM_TerminalArea output ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2020	jlgndl1	Initial creation	TFS 49579

*/

vars

	msg : String;

begin

	_name := self.txtWalkBlockName.text;
	_terminalArea := self.cmbGridTermArea.listObject.CM_TerminalArea;
	
	if _terminalArea = null then
		msg := app.getErrorString( Terminal_area_selected );
		return false;
	endif;
	
	if _name = null then
		msg := app.getErrorString( Name_required_field );
		return false;
	endif;
	
	self.mulWalkPositions.getSelected( _objArray );
	if _objArray.isEmpty then
		msg := app.getErrorString( CMUI_Nothing_Selected );
		return false;
	endif;
	
	return true;

epilog

	if msg &lt;&gt; null then
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
	endif;

end;</source>
        <Parameter name="_name" type="String" usage="output"/>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
