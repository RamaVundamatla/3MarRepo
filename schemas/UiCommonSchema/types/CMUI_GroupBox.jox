    <JadeMethod name="repositionAfterResize" id="7ddf4838-3539-474e-b28e-07e6b49f0a97">
        <updating/>
        <source>repositionAfterResize() updating;

// -----------------------------------------------------------------------------
// Created:		26 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
 	newLeft, newTop, newWidth, newHeight,
   	parentWidth,
   	parentHeight	: Real;

begin

	newLeft 	:= self.left;
	newTop 		:= self.top;
	newWidth 	:= self.width;
	newHeight	:= self.height;
	
	if self.parent.isKindOf(Form) then
		parentWidth  := self.parent.Form.clientWidth;
		parentHeight := self.parent.Form.clientHeight;
	elseif self.parent.isKindOf(Control) then
		parentWidth  := self.parent.Control.clientWidth;
		parentHeight := self.parent.Control.clientHeight;
	else
		parentWidth  := self.parent.width;
		parentHeight := self.parent.height;
	endif;

	if lockRight then
		newLeft := (parentWidth - newWidth - self.distanceFromRight).max(0);
	endif;
	if lockBottom then
		newTop := (parentHeight - newHeight - self.distanceFromBottom).max(0);
	endif;
	if stretchWidth then
		newWidth := (parentWidth - newLeft - distanceFromRight).max(0);
	endif;
	if stretchHeight then
		newHeight := (parentHeight - newTop - distanceFromBottom).max(0);
	endif;

	if newLeft &lt;&gt; self.left or newTop &lt;&gt; self.top or newWidth &lt;&gt; self.width or newHeight &lt;&gt; self.height then
		self.move(newLeft, newTop, newWidth, newHeight);
		self.cnEcResizeContents();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="stretchHeight" id="53c3d7a6-a372-41d9-80a1-4be9ecd62c1b">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>stretchHeight(set: Boolean; _value: Boolean io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     16 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set and _value then
		if lockBottom then
			lockBottom := false;
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="stretchWidth" id="7db7f8f9-5a76-409a-abff-100a523259d9">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>stretchWidth(set: Boolean; _value: Boolean io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     16 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

    if set and _value then
    	if lockRight then
    		lockRight := false;
    	endif;
   	endif;
   	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
