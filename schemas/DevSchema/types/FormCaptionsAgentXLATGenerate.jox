    <JadeMethod name="create" id="4f2d32d9-c2be-426b-a0e9-112ac965657f">
        <updating/>
        <source>create() updating;

/*

Purpose:		

Date			Who		Reason
05/11/2015		cnwmh5	Initial creation

*/

vars

begin
	self.category := root.allXLAT_Categories[XLAT_FormCaptions];
	
	create self.errorDetailsDict transient;
	self.errorDetailsDict.setMembership(StringArray512);
	self.errorDetailsDict.addExternalKey(String, 25, true, false);					// User Name
	self.errorDetailsDict.endKeys(true);
	
	create self.myReleaseExtractAgent transient;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createObjsForNewConstants" id="e5431580-c3fc-42c1-b7d5-91dcfacd7f91">
        <source>createObjsForNewConstants(_folderServer : FileFolder io) : Boolean;

/*

Purpose:		Find out the newly load constants and create their objects

Date			Who		Reason
05/11/2015		cnwmh5	Initial creation

*/

vars

	transAgent						: CM_TranslationAgent;
	lsSchema						: LSschema;
	lsConstant						: LSconstant;
	lsClass							: LSclass;
	formCaption						: XLAT_FormCaption;
	file							: File;
	
	sa 								: StringArray;
	
	allFiles						: FileNodeArray;
	
	xlatDict						: DynaDictionary;
	
	line							: String;
	pos								: Integer;

begin

	create allFiles transient;
	_folderServer.mask := "PortSchema-FormCaptions-*.scm";
	allFiles := _folderServer.files();
	
	if "PortSchema-FormCaptions-*.scm".cnContains("PortSchema-FormCaptions-*.scm") and allFiles.size &lt;&gt; 1 then
		return true;
	endif;
	
	create transAgent transient;
	create sa transient;
	
	create file transient;
	file.usePresentationFileSystem := _folderServer.usePresentationFileSystem;
	file.kind := File.Kind_Unknown_Text;	// 3/3/16 cnwmp6 PAR 36286 unicode version
	//file.fileName := allFiles.first.FileNode.fileName;
	file.openInput(allFiles.first.FileNode.fileName);
	
	while not file.endOfFile do
	
		line := file.readLine();
		if not line.cnContains("Integer = ") then
			continue;
		endif;
		
		pos := 1;
		line := line.scanUntil(":", pos);
		line := line.removeTabCrLfs().trimBlanks();
		sa.add(line);
	
	endwhile;
	
	if sa.isEmpty then							// 06/04/2016 cnwmh5
		return true;
	endif;

	transAgent.trxLoadSpecificTranslations(sa);

	XLAT_FormCaption.edition;
	create xlatDict transient;
	xlatDict.setMembership(XLAT_FormCaption);
	xlatDict.addMemberKey("vSchemaName", true, false);
	xlatDict.addMemberKey("vFormClass", true, false);
	xlatDict.addMemberKey("vControlName", true, false);
	xlatDict.addMemberKey("vControlProperty", true, false);
	xlatDict.endKeys(true);
	XLAT_FormCaption.instances.copy(xlatDict);	

	foreach lsSchema in self.allSchemas do
	
		foreach lsConstant in lsSchema.allConstants do				// 13/10/2016 cnwmh5
			
			formCaption := xlatDict.getAtKey(lsSchema.name, lsConstant.formName, lsConstant.controlName, lsConstant.controlProperty).XLAT_FormCaption;
			
			lsClass := lsSchema.allClasses[lsConstant.formName];				// 14/06/2016 cnwmh5
			if formCaption &lt;&gt; null then
				lsConstant.name := formCaption.vConstantName;
				lsConstant.number := formCaption.number;						// 17/03/2016 cnwmh5
				// add to list for object creation
				// class needs to have translateForm method genereated
				///lsClass := lsSchema.allClasses[lsConstant.formName];
				if sa.includes(lsConstant.name) then							// 21/06/2016 cnwmh5
					lsClass.generateTranslateFormMethod := true;
				endif;
			
			endif;
		
		endforeach;
	
		/*
		foreach lsConstant in lsSchema.allConstants do
		
			//constant := schema.getConstant(lsConstant.name);
			//if constant &lt;&gt; null then
			formCaption := xlatDict.getAtKey(lsSchema.name, lsConstant.formName, lsConstant.controlName, lsConstant.controlProperty).XLAT_FormCaption;
			////write method.qualifiedName() &amp; Tab &amp; formCaption.String &amp; Tab &amp; lsSchema.name &amp; Tab &amp; lsConstant.formName &amp; Tab &amp; 
			///	lsConstant.controlName &amp; Tab &amp; lsConstant.controlProperty;
			lsClass := lsSchema.allClasses[lsConstant.formName];				// 14/06/2016 cnwmh5
			if formCaption &lt;&gt; null then
				lsConstant.name := formCaption.vConstantName;
				lsConstant.number := formCaption.number;							// 17/03/2016 cnwmh5
				// add to list for object creation
				// class needs to have translateForm method genereated
				///lsClass := lsSchema.allClasses[lsConstant.formName];
				lsClass.generateTranslateFormMethod := true;
				//lsSchema.allConstants.remove(lsConstant);
			else											// 14/06/2016 cnwmh5
				lsClass.allConstants.remove(lsConstant);
			endif;
		
		endforeach;
		*/
	
	endforeach;

	return false;
	
epilog

	delete transAgent;
	delete sa;
	delete xlatDict;
	delete file;

end;</source>
        <Parameter name="_folderServer" type="FileFolder" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="0b143cb3-3409-4812-9722-1a2a02dae302">
        <updating/>
        <source>delete() updating;

/*

Purpose:		

Date			Who		Reason
05/11/2015		cnwmh5	Initial creation

*/

vars

begin

	errorDetailsDict.purge();
	delete errorDetailsDict;
	delete myReleaseExtractAgent;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="generateErrorDetails" id="25a3e313-98bb-4510-bfc8-c6a8122d9ff1">
        <source>generateErrorDetails();

/*

Purpose:		Generate error details for those that don't come back with a global constant
				This will stop a new translateForm method from being generated

Date			Who		Reason
05/11/2015		cnwmh5	Initial creation

*/

vars

	obj							: Object;
	guiClass					: GUIClass;
	property					: Property;
	lsSchema					: LSschema;
	lsConstant					: LSconstant;
	
	strArray					: StringArray512;
	
	modifiedBy					: String;
	modifiedTS					: TimeStamp;

begin

	foreach lsSchema in self.allSchemas do
		
		// Check to see if there are any constants that haven't been updated
		if lsSchema.allConstants.size = 0 then
			continue;
		endif;

		// read through the lsConstants 
		foreach lsConstant in lsSchema.allConstants do
		
			if lsConstant.number &gt; 0 then
				continue;
			endif;
		
			modifiedBy := null;
			modifiedTS := null;
		
			// get the form so can work out who to send the error email to
			foreach obj in self.allForms do
				if obj.GUIClass.name &lt;&gt; lsConstant.formName then
					continue;
				endif;
				guiClass := obj.GUIClass;
				break;
			endforeach;
			
			
			// get the property (control name)
			foreach property in guiClass.getProperties() do
				if property.name = lsConstant.controlName then	
					modifiedBy := property.getModifiedBy();
					modifiedTS := property.getModifiedTimestamp();
					break;
				endif;
			endforeach;
			
			if property = null then
				if guiClass.name = lsConstant.controlName then
					modifiedBy := guiClass.getModifiedBy();
					modifiedTS := guiClass.getModifiedTimestamp();
				endif;
			endif;			
			
			//self.errorArray.add(modifiedBy &amp; "," &amp; lsConstant.controlName &amp; "." &amp; lsConstant.controlProperty &amp; " on form (" &amp;
			//	lsConstant.formName &amp; ") was added by " &amp; modifiedBy &amp; " on " &amp; modifiedTS.date.format("dd/MM/yyyy") &amp; 
			//	" at " &amp; modifiedTS.time.formatAsHHmmSS() &amp; " but there is on constant available in CNWDMAST." &amp; 
			//	"," &amp; ""); 
			
			create strArray transient;
			strArray.add(lsConstant.controlName &amp; "." &amp; lsConstant.controlProperty &amp; " on form (" &amp;
				lsConstant.formName &amp; ") was added by " &amp; modifiedBy &amp; " on " &amp; modifiedTS.date.format("dd/MM/yyyy") &amp; 
				" at " &amp; modifiedTS.time.formatAsHHmmSS() &amp; " but there is no constant available in CNWDMAST.");
			app.writeLog(lsConstant.controlName &amp; "." &amp; lsConstant.controlProperty &amp; " on form (" &amp;
				lsConstant.formName &amp; ") was added by " &amp; modifiedBy &amp; " on " &amp; modifiedTS.date.format("dd/MM/yyyy") &amp; 
				" at " &amp; modifiedTS.time.formatAsHHmmSS() &amp; " but there is no constant available in CNWDMAST.", LogINFO);
			self.errorDetailsDict.putAtKey(modifiedBy, strArray);
				
		endforeach;

	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="generateNewTranslateFormMethod" id="32c07d16-ebc4-4d1c-9b52-34949b0ff4a5">
        <source>generateNewTranslateFormMethod(_folderServer : FileFolder io) : Boolean;

/*

Purpose:		Generate the new translateForm method

Date			Who		Reason
05/11/2015		cnwmh5	Initial creation

*/

vars

	lsSchema					: LSschema;
	lsClass						: LSclass;
	file						: File;
	dummyFileFolder				: FileFolder;
	
	ts							: TimeStamp;
	translateFormCreated		: Boolean;
	dontContinue				: Boolean;

begin

	ts := app.cnGetServerTime();

	foreach lsSchema in self.allSchemas do
	
		if lsSchema.name = "PortSchema" then 
			continue;
		endif;
		
		// doesn't have any new constants so dont care
		if lsSchema.allConstants.size = 0 then
			continue;
		endif;
		
		delete file;
		create file transient;
		file.usePresentationFileSystem := _folderServer.usePresentationFileSystem;
		file.openOutput(_folderServer.fileName &amp; "\" &amp; lsSchema.name &amp; '-FormCaptions-partial.scm');
		
		file.writeLine(lsSchema.zScmHeader);
		file.writeLine("typeDefinitions");
		
		translateFormCreated := false;
		
		foreach lsClass in lsSchema.allClasses do
			if not lsClass.generateTranslateFormMethod then
				continue;
			endif;

			translateFormCreated := true;
			
			file.writeLine(lsClass.name &amp; " partialDefinition");
			file.writeLine(Tab &amp; "(");
			file.writeLine(Tab &amp; "jadeMethodDefinitions");
			file.writeLine(Tab &amp; Tab &amp;  CM_BaseForm::translateForm.makeHeader &amp; " updating;");	// cnwkpd1 05/06/2008
			file.writeLine(Tab &amp; Tab &amp; 'setModifiedTimeStamp "cnwmh5" "16.0.02" ' &amp; currentSchema.patchVersion.String  &amp; ' ' &amp;
				ts.date.year.String &amp; ":" &amp; ts.date.month.padLeadingWith("0", 2) &amp; ":" &amp; ts.date.day.padLeadingWith("0", 2) &amp; ":" &amp; 
				ts.time.hour.padLeadingWith("0", 2) &amp; ":" &amp; ts.time.minute.padLeadingWith("0", 2) &amp; ":" &amp; 
				ts.time.second.padLeadingWith("0", 2) &amp; "." &amp; ts.time.milliSecond.String &amp; ";");
			file.writeLine(Tab &amp; ")");
		endforeach;
		
		file.writeLine("typeSources");
		foreach lsClass in lsSchema.allClasses do
			if lsClass.generateTranslateFormMethod then
				file.writeLine(lsClass.zScmTypeSource);
			endif;
		endforeach;
		file.close();
		
		// if we haven't created a translateForm method then delete the file
		if not translateFormCreated then
			file.purge();
			continue;
		endif;
		
		// load the new translateForm method
		dontContinue := self.loadSchemaFile(_folderServer, dummyFileFolder, lsSchema.name &amp; '-FormCaptions-partial.scm', false);
		if dontContinue then
			//return dontContinue;
			continue;
		endif;
	
	endforeach;
	
	return dontContinue;
	
epilog

	delete file;

end;</source>
        <Parameter name="_folderServer" type="FileFolder" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getLSschema" id="c231b5f5-eb16-4618-bac6-7a7232e7b3bc">
        <source>getLSschema(_schemaName : String) : LSschema;

/*

Purpose:		Add / Create the schema if it doesn't exist

Date			Who		Reason
04/11/2015		cnwmh5	Initial creation

*/

vars

	lsSchema					: LSschema;

begin

	lsSchema := self.allSchemas[_schemaName];
	if lsSchema = null then
		self.createLSchema(_schemaName);
		lsSchema := self.allSchemas[_schemaName];
	endif;
	
	return lsSchema;

epilog

end;</source>
        <Parameter name="_schemaName" type="String"/>
        <ReturnType type="LSschema"/>
    </JadeMethod>
    <JadeMethod name="handleFormTranslationTransfer" id="9c8e9af9-4dbe-4bef-ba25-60d7f1fa6438">
        <updating/>
        <source>handleFormTranslationTransfer(_lsClass : LSclass io; _constantName, _controlName, _controlProperty, _text, _commentedOutTextStartOfLine, _commentedOutTextEndOfLine : String; 
		_isCommentedOut, _updateSchema, _useExisting: Boolean) updating;

/*

Purpose:		Create / Update the lsConstant with the appropriate details

Date			Who		Reason
04/11/2015		cnwmh5	Initial creation
//12/03/2019	jlgns1	TFS 36423 XLAT_FormCaptions need to be sorted out
*/

vars

	xmlDoc					: JadeXMLDocument;
	xmlElement				: JadeXMLElement;
	textElement				: JadeXMLElement;
	xmlAttribute			: JadeXMLAttribute;
	
	constantObj				: Constant;
	lsConstant				: LSconstant;
	
	controlName				: String;
	constantName 			: String;
	constantNumber			: Integer;
	updateSchema			: Boolean;
	formClass				: String;
	text					: String;

begin

	text := _text;
//	if text &lt;&gt; null then
//		process.isNICK;
//	endif;
	constantObj := self.tryGetConstant(_lsClass,_controlName,_controlProperty);	//TFS 36423
	
	
	
	
	rootSchema.getSchema(PortSchemaName).getConstant(_constantName);			//TFS 36423
	controlName := _controlName;
	
	constantName := _constantName;
	if constantObj &lt;&gt; null then
		if not _useExisting then
			//If we are on Wmast and we already have a matching constant we want to scrap it and get a new one from Dmast 
			beginTransaction;
			write "Marking for removal: " &amp; constantObj.name &amp; Tab &amp; constantObj.text;
		
			constantObj.cnEcSetText(constantObj.text.replace("&lt;/ErrorMsg&gt;",CrLf &amp; CrLf &amp; "&lt;DELETE_ME/&gt;" &amp; CrLf &amp; CrLf &amp; "&lt;/ErrorMsg&gt;")
													.replace('ControlProperty="','ControlProperty="NOT_'));
			commitTransaction;
		else
		constantName := constantObj.name;
		// no xml then error as should have xml
		if constantObj.text = null then
			app.writeStatement("*** Error - No XML Text (" &amp; constantObj.name &amp; " - " &amp; constantObj.getSource() &amp; ")");
			return;
		endif;
		
		delete xmlDoc;
		create xmlDoc transient;
		xmlDoc.parseString(constantObj.text);
		xmlElement := xmlDoc.getElementByTagName(XMLTag_Header);
		
		// Get the text
		textElement := xmlElement.findElement(XMLTag_Msg, null);
		if textElement &lt;&gt; null then
			text := textElement.text;
		endif;
		
		// Get the controlName
		xmlAttribute := xmlElement.getAttributeByName(XML_Tag_ControlName);
		if xmlAttribute &lt;&gt; null then
			controlName := xmlAttribute.value;
		endif;
		
		// get the form class
		xmlAttribute := xmlElement.getAttributeByName(XML_Tag_FormClass);
		if xmlAttribute &lt;&gt; null then
			formClass := xmlAttribute.value;
		endif;
		if _controlName = "self" then
			controlName := _lsClass.name;
			formClass := controlName;
		elseif _controlName &lt;&gt; controlName then
			controlName := _controlName;
		endif;
		constantNumber := constantObj.getSource().Integer;
		endif;
	else
		
		if _controlName = "self" then
			controlName := _lsClass.name;
			if text = null then
				text := controlName;
			else
			
			endif;
		endif;
	endif;
	
	//if controlName = "lblTipsLegend1" then
	//	write 'debug';
	//endif;
	//write Tab &amp; method.qualifiedName() &amp; Tab &amp; Tab &amp; _lsClass.mySchema.name &amp; Tab &amp; _lsClass.name &amp; Tab &amp; controlName &amp; Tab &amp; _controlProperty;
	lsConstant := _lsClass.allConstants[_lsClass.mySchema.name, _lsClass.name, controlName, _controlProperty];		
	if lsConstant = null then
		if _controlName = "self" or text &lt;&gt; null or _isCommentedOut then
			create lsConstant transient;
			lsConstant.schemaName := _lsClass.mySchema.name;
			lsConstant.formName := _lsClass.name;
			lsConstant.controlName := controlName;
			lsConstant.controlProperty := _controlProperty;
			if  _useExisting and constantNumber &lt;&gt; 0 then
				lsConstant.number := constantNumber;
				lsConstant.name := constantName;
			else
				lsConstant.name :=  self.makeConstantName( lsConstant,0);
			endif;
			lsConstant.commentedOutTextStartOfLine := _commentedOutTextStartOfLine;
			lsConstant.isCommentedOut := _isCommentedOut;
			
			lsConstant.text := text;
			lsConstant.commentedOutTextEndOfLine := _commentedOutTextEndOfLine;
			if _isCommentedOut then							// 24/09/2015 cwnmh5
				lsConstant.dontGenerate := true;
			endif;
			_lsClass.allConstants.add(lsConstant);
			updateSchema := true;							// 17/02/2016 cnwmh5
			if _updateSchema or updateSchema then
				_lsClass.mySchema.allConstants.add(lsConstant);
			endif;
			_lsClass.generateTranslateFormMethod := true;
			///if _addToDisplayDict then
			///	self.dictLSconstantsToDisplay.putAtKey(self.myLSclass.name, controlName, _controlProperty, lsConstant);
			////endif;
		endif;
	else
		if lsConstant.isCommentedOut and not _isCommentedOut then
			lsConstant.isCommentedOut := _isCommentedOut;
			lsConstant.name := _constantName;
			lsConstant.commentedOutTextEndOfLine := null;
			lsConstant.commentedOutTextStartOfLine := null;
			lsConstant.text := text;
		elseif lsConstant.isCommentedOut and _isCommentedOut then
			lsConstant.name := _constantName;
			lsConstant.commentedOutTextEndOfLine := _commentedOutTextEndOfLine;
			lsConstant.commentedOutTextStartOfLine := _commentedOutTextStartOfLine;
			lsConstant.text := text;
		elseif not lsConstant.isCommentedOut and not _isCommentedOut then
			if lsConstant.name &lt;&gt; _constantName then
				lsConstant.name := _constantName;
				lsConstant.commentedOutTextEndOfLine := _commentedOutTextEndOfLine;
				lsConstant.commentedOutTextStartOfLine := _commentedOutTextStartOfLine;
				lsConstant.text := text;
			endif;
		endif;
	endif;
	
epilog

	delete xmlDoc;
	
end;</source>
        <Parameter name="_lsClass" type="LSclass" usage="io"/>
        <Parameter name="_constantName" type="String"/>
        <Parameter name="_controlName" type="String"/>
        <Parameter name="_controlProperty" type="String"/>
        <Parameter name="_text" type="String"/>
        <Parameter name="_commentedOutTextStartOfLine" type="String"/>
        <Parameter name="_commentedOutTextEndOfLine" type="String"/>
        <Parameter name="_isCommentedOut" type="Boolean"/>
        <Parameter name="_updateSchema" type="Boolean"/>
        <Parameter name="_useExisting" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initAllForms" id="6dbfd650-1c34-4f52-ac8f-b7a9e701c087">
        <source>initAllForms();

/*

Purpose:		

Date			Who		Reason
04/11/2015		cnwmh5	Initial creation

*/

vars

	schema				: Schema;
	class				: Class;
	form				: Form;

	schemaArray					: SchemaColl;
	classesArray				: ClassColl;
	allowableSchemasArray		: StringArray;

begin
	
	self.allForms.clear;
	
	create allowableSchemasArray transient;									// 12/04/2013 cnwmh5
	allowableSchemasArray.add(UiCommonSchemaName);
	allowableSchemasArray.add(MobileUISchemaName);
	allowableSchemasArray.add(PortSchemaName);
	allowableSchemasArray.add(GateSchemaName);
	allowableSchemasArray.add(GeneralCargoSchemaName);
	allowableSchemasArray.add(HmsSchemaName);
	allowableSchemasArray.add(InvoiceSchemaName);
	allowableSchemasArray.add(LogSchemaName);
	allowableSchemasArray.add(ShipSchemaName);
	allowableSchemasArray.add(SysOpsSchemaName);
	allowableSchemasArray.add(YardSchemaName);

	create schemaArray transient;
	schemaArray.add(rootSchema.getSchema(UiCommonSchemaName));
	schemaArray.add(rootSchema.getSchema(MobileUISchemaName));
	
	create classesArray transient;
	
	foreach schema in schemaArray do
		if schema.name &lt;&gt; MobileUISchemaName then
			schema.getClass(CM_BaseForm.name).allSubclasses(classesArray);
			schema.getClass(CM_BaseForm.name).allSubclassesInSubschemas(classesArray);
		else
			schema.getClass('MOB_BaseForm').allSubclasses(classesArray);
			schema.getClass('MOB_BaseForm').allSubclassesInSubschemas(classesArray);
		endif;
	endforeach;
	
	foreach class in classesArray do
		if not allowableSchemasArray.includes(class.schema.name) then						
			continue;
		endif;	
		foreach form in Form.instances do
			if form.name = class.name then
				self.allForms.add(class);
				break;
			endif;
		endforeach;
	endforeach;

epilog

	delete schemaArray;
	delete classesArray;
	delete allowableSchemasArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="loadSchemaFile" id="3a3886fa-1592-4bf5-8a84-d943e2043c6d">
        <source>loadSchemaFile(_folderServer, _folderNonServer : FileFolder io; _mask : String; _doCopy : Boolean) : Boolean;

/*

Purpose:		Load the required schema file

Date			Who		Reason
05/11/2015		cnwmh5	Initial creation

*/

vars

	fileNode						: FileNode;
	
	allFiles						: FileNodeArray;

	dontContinue					: Boolean;

begin

	create allFiles transient;

	if _doCopy then
		allFiles.clear();
		_folderNonServer.mask := _mask;
		allFiles := _folderNonServer.files();
		if allFiles.size = 0 then
			return false;
		endif;
		self.myReleaseExtractAgent.copyFile(allFiles.first.FileNode.fileName, _folderNonServer.usePresentationFileSystem, 
			_folderServer.fileName &amp; allFiles.first.FileNode.fileName[allFiles.first.FileNode.fileName.reversePos("\"):end], 
			_folderServer.usePresentationFileSystem);
	endif;

	allFiles.clear();
	_folderServer.mask := _mask;
	allFiles := _folderServer.files();
	
	if allFiles.size = 0 then
		return false;
	endif;
	
	foreach fileNode in allFiles do
		
		app.writeLog("Loading schema file: " &amp; fileNode.fileName, LogINFO);
		dontContinue := self.myReleaseExtractAgent.runLoadCommand('schemaFile="' &amp; fileNode.fileName &amp; '"');
		if not dontContinue then
			return not dontContinue;
		endif;
	
	endforeach;
	
	return not dontContinue;
	
epilog

end;</source>
        <Parameter name="_folderServer" type="FileFolder" usage="io"/>
        <Parameter name="_folderNonServer" type="FileFolder" usage="io"/>
        <Parameter name="_mask" type="String"/>
        <Parameter name="_doCopy" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="makeConstantNameOld" id="2fb7d19c-4c6b-4301-b497-0183f0e2c736">
        <source>makeConstantNameOld(formClass : String; controlName : String; controlProperty : String) : String protected;

// make a unique constant name up to max 30 chars based on form (class) and control name
// &lt;class-part&gt;_&lt;control-name-part&gt;
// &lt;class-part&gt; minimum length ClassPartMin, &lt;control-name-part&gt; gets priority, up to remainder
//12/03/2019	jlgns1	TFS 36423 XLAT_FormCaptions need to be sorted out
constants
	ClassPartMin = 9;
	MaxLength	 = 30;
	MaxTries = 30;
	AscSpace = ' '.Character.Integer;
	Suffices = '0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwx';
	
vars
	classPart	: String;
	prefix		: String;
	overflow	: Integer;
	remainder	: Integer;
	classPartLen: Integer;
	randomChar	: String[1];
	constantName: String;
	triesCount	: Integer;
	logMsg		: String;

begin
	if controlProperty = 'caption' then
		prefix := 'C';
	elseif  controlProperty = 'bubbleHelp' then
		prefix := 'B';
	else
		beginTransaction;beginTransaction; // error
	endif;

	overflow := (formClass.length + controlName.length - MaxLength);

	if overflow &gt; 0 then
		classPartLen := (MaxLength - controlName.length).max(ClassPartMin);
	else
		classPartLen := MaxLength - controlName.length;
	endif;

	classPart := formClass[1:classPartLen] &amp; '_' &amp; prefix;
	remainder := MaxLength - classPart.length;

	constantName := classPart &amp; controlName[1:remainder];


	// make sure the constant name is unique (simple algorithm swaps last character)
	while rootSchema.getSchema(PortSchemaName).getConstant(constantName) &lt;&gt; null or self.allConstantsByName[constantName] &lt;&gt; null do				// 08/3/2016 cnwmh5
		////write class.name &amp; '::' &amp; method.name &amp; Tab &amp; constantName;

		randomChar := Suffices[app.random(Suffices.length-1)+1].String;
		if constantName.length &lt; MaxLength then
			// append another character
			constantName := constantName &amp; randomChar;
		else
			constantName := constantName[1:constantName.length-1] &amp; randomChar;
//			constantName := classPart[1:classPart.length-2] &amp; randomChar &amp; '_' &amp; controlName[1:remainder];
		endif;

		logMsg	:=	"*** INFO *** Control constant name conflict, resolved for " &amp; formClass &amp; '::' &amp; controlName &amp; ' -&gt; ' &amp; constantName;
		self.log(logMsg, false);
		////app.createAlert(logMsg, true);	// #27657

		// get out of jail card
		triesCount := triesCount + 1;
		if triesCount &gt; MaxTries then
			logMsg	:=	"*** ERRROR *** Control constant name conflict, could not be resolved for " &amp; formClass &amp; '::' &amp; controlName &amp; ' -&gt; ' &amp; constantName;
			self.log(logMsg, true);
			app.createAlert(logMsg, true);
//			process.debug;
			break;
		endif;
	endwhile;

	return constantName;			
end;</source>
        <access>protected</access>
        <Parameter name="formClass" type="String"/>
        <Parameter name="controlName" type="String"/>
        <Parameter name="controlProperty" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputFileConstantsToGet" id="1fd1586e-eaac-4044-b4a8-f835967781b9">
        <source>outputFileConstantsToGet(_fileFolder : FileFolder);

/*

Purpose:		Output the file for the constants that we need to get

Date			Who		Reason
04/11/2015		cnwmh5	Initial creation

*/

vars

	file							: File;
	lsSchema						: LSschema;
	lsConstant						: LSconstant;
	fileFolder						: FileFolder;
	
	today							: TimeStamp;
	fileError						: String;

begin

	create file transient;
	file.fileName := _fileFolder.fileName &amp; "\ConstantsToGet.csv";
	if file.isAvailable() then
		file.purge();
	endif;
	
	app.writeLog("Creating constants to get file: " &amp; file.fileName, LogINFO);
	
	foreach lsSchema in self.allSchemas where lsSchema.allConstants.size &gt; 0 do
		foreach lsConstant in lsSchema.allConstants do
			if lsConstant.number &gt; 0 then
				continue;
			endif;
			file.writeLine(lsConstant.name &amp; "," &amp; lsConstant.schemaName &amp; "," &amp; lsConstant.formName &amp; "," &amp; lsConstant.controlName &amp; "," &amp; 
				lsConstant.controlProperty);
			app.writeLog(lsConstant.name &amp; "," &amp; lsConstant.schemaName &amp; "," &amp; lsConstant.formName &amp; "," &amp; lsConstant.controlName &amp; "," &amp; 
				lsConstant.controlProperty, LogINFO);
		endforeach;
	endforeach;
	
epilog

	delete file;

end;</source>
        <Parameter name="_fileFolder" type="FileFolder"/>
    </JadeMethod>
    <JadeMethod name="populatelSchemasClassesConsts" id="77536f8c-8f6a-491e-b1e5-d2aedc9144f8">
        <updating/>
        <source>populatelSchemasClassesConsts() updating;

/*

Purpose:		Fill the schema and class collections

Date			Who		Reason
04/11/2015		cnwmh5	Initial creation

*/

vars

	obj									: Object;
	guiClass							: GUIClass;
	lsSchema							: LSschema;
	lsClass								: LSclass;

begin


	foreach obj in self.allForms do
	
		guiClass := obj.GUIClass;
		
		lsSchema := self.allSchemas[guiClass.schema.name];
		if lsSchema = null then
			self.createLSchema(guiClass.schema.name);
			lsSchema := self.allSchemas[guiClass.schema.name];
		endif;
		
		lsClass := lsSchema.getLSclass(guiClass.name);	
		
		//if lsClass.name &lt;&gt; "CM_ContainerEnqForm" then
		//	continue;
		//endif;
		
		self.processFormMethodDetails(lsSchema, lsClass);
					
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="processFormMethodDetails" id="268f3005-d344-44f3-89fb-0e16413e3f69">
        <updating/>
        <source>processFormMethodDetails(_lsSchema: LSschema io; _lsClass: LSclass io) updating;

/*

Purpose:	Get / Create the constants required to build the translateForm method

			The following rules cause an error / warning to occur.  I've included those that are checked but don't cause an error / warning to occur.
		
			No Warning / Error
			------------------
			* Constant doesn't exist and line is commented out
			
			Warning
			-------
			* Constant has no XML in its text (Needs to be addressed)
			* Form caption is still default
			* Constant exists with different text (Needs to be addressed)
			
			Error
			-----
			* Unable to find Xlat_FormCaption constant (Needs to be addressed)
			* Constant isn't a Xlat_FormCaption constant (Needs to be addressed)

Date			Who		Reason
16/01/2012		cnwmh5	Initial creation
12/04/2013		cnwmh5	Fix issue where bubbleHelp isn't getting found for at least ComboBox, Picture, TextBox, Table controls.
						These are the ones that were found so fix will do all controls.
//12/03/2019	jlgns1	TFS 36423 XLAT_FormCaptions need to be sorted out
*/

constants
	TranslateCaption		: String = "translateCaption";
	TranslateCaption2		: String = ".caption";
	TranslateBubbleHelp		: String = "translateBubbleHelp";
	TranslateBubbleHelp2	: String = ".bubbleHelp";
	AlphaCharacters			: String = "abcdefghijklmnopqrstuvwxyz";
vars

	meth					: Method;
	lsConstant				: LSconstant;
	form					: Form;
	cntrl					: Control;
	tmpMenu					: MenuItem;
	prop					: Property;
	
	methSource				: String;
	attribute				: String;
	constant				: String;
	sourceLine				: String;
	str						: String;
	controlName				: String;
	constantProperty		: String;
	commentedOutStartOfLine	: String;
	commentedOutEndOfLine	: String;
	
	posCrLf					: Integer;
	length					: Integer;
	pos1					: Integer;
	pos2					: Integer;
	isCommentedOut			: Boolean;
	numControls				: Integer;
	index					: Integer;
	numMenus				: Integer;
	multiCommentOut			: Boolean;
	nullLsConstant 			: LSconstant;	//TFS 36423
	conObj : Constant;
	conNum : Integer;
begin
	
	posCrLf := 0;
	
	meth := _lsClass.myClass.getMethod("translateForm");
	if meth &lt;&gt; null then
		methSource := meth.getSource();
		length := methSource.length;
		posCrLf := 1;
	endif;
	
	// Read the source and see what is currently already defined
	// read through the file getting current constants
	
	while posCrLf &gt; 0 do
	
		sourceLine := methSource.cnEcGetNextLine(posCrLf);
		if posCrLf = 0 then
			break;
		endif;
		
		////write method.qualifiedName() &amp; Tab &amp; Tab &amp; sourceLine;
		
		pos1 := 1;
		attribute := null;
		constant := null;
		isCommentedOut := multiCommentOut;
		commentedOutStartOfLine := null;
		commentedOutEndOfLine := null;
		
		// ok have translate need to get the details
		sourceLine.cnReplaceString(Tab, " ");
		sourceLine.cnReplaceString("( ", "(");
		sourceLine.cnReplaceString(" )", ")");
		
		// check to see if the following exist on the line and cause error message
		if sourceLine.cnContains(TranslateCaption2) or sourceLine.cnContains(TranslateBubbleHelp2) then
			pos1 := 1;
			str := sourceLine.scanUntil(AlphaCharacters, pos1);
			str.cnReplaceString(Tab, "");
			continue;
		endif;

		// if line doesn't have .translate then don't want to know about it
		pos1 := 1;
		pos1 := sourceLine.pos(".translate", pos1);
		if pos1 = 0 then
			continue;
		endif;
		
		// get the starting point of the text
		pos2 := sourceLine.reversePosIndex(" ", pos1);
		attribute := sourceLine[pos2+1:pos1-pos2-1];
		if pos2 &gt; 0 then
			commentedOutStartOfLine := sourceLine[1:pos2].trimBlanks();
			if commentedOutStartOfLine &lt;&gt; null and commentedOutStartOfLine.cnContains("//") then
				isCommentedOut := true;
			endif;
		endif;
		
		// get the attribute
		if attribute[1:2] = "//" then	
			pos2 := 1;
			commentedOutStartOfLine :=  sourceLine.scanUntil(AlphaCharacters, pos2);
			if commentedOutStartOfLine &lt;&gt; null and commentedOutStartOfLine.cnContains("//") then
				isCommentedOut := true;
			endif;
			attribute := sourceLine[pos2:pos1-pos2];
		endif;
		if attribute = "self" then
			if sourceLine[pos1:10] &lt;&gt; ".translate" then
				pos1 := pos1 + 1;
				attribute := sourceLine.scanUntil(".", pos1);
			endif;
		endif;
		sourceLine := sourceLine[pos1+1:end];
		
		// get what we are translation
		pos1 := 1;
		constantProperty := sourceLine.scanUntil("(", pos1);
		constantProperty := constantProperty[10:end].trimBlanks();
		constantProperty[1:1] := constantProperty[1:1].toLower();
		sourceLine := sourceLine[pos1+1:end];
		
		// get the constant
		pos1 := 1;
		constant := sourceLine.scanUntil(",", pos1);
		
		// if commented out see if there is a comment on the end of the line
		sourceLine.scanUntil(";", pos1);
		if pos1+1 &lt; sourceLine.length then
			commentedOutEndOfLine := sourceLine[pos1+1:end];
			commentedOutEndOfLine.cnReplaceString(Tab, "");
			commentedOutEndOfLine.cnReplaceString(Cr, "");
			commentedOutEndOfLine.cnReplaceString(Lf, "");
		endif;
		conObj := rootSchema.getSchema(PortSchemaName).getConstant(constant);
		
		if conObj &lt;&gt; null then
			conNum := conObj.getSource.Integer;
		endif;
		
		if not _lsClass.allConstants.includesKey(_lsSchema.name,_lsClass.name, attribute,constantProperty) then
			_lsClass.addConstant(constant, attribute, constantProperty,null, commentedOutStartOfLine,commentedOutEndOfLine,isCommentedOut,true,conNum);
		endif;
	//	if constant &lt;&gt; null then
	//	self.handleFormTranslationTransfer(_lsClass, constant, attribute, constantProperty, null, commentedOutStartOfLine, commentedOutEndOfLine, isCommentedOut, false, true);
		
	endwhile;

	// read through the form and see what is left to define
	foreach form in Form.instances do
		if form.name = _lsClass.name then
			break;
		endif;
	endforeach;
	
	lsConstant := _lsClass.allConstants[_lsSchema.name, form.name, form.name, 'caption'];			
	if lsConstant = null then
	
		self.handleFormTranslationTransfer(_lsClass, null, form.name, 'caption', 						//TFS 36423
			form.getPropertyValue('caption').String, null, null, false, true, false);													//TFS 36423
	
		//self.handleFormTranslationTransfer(_lsClass, self.makeConstantNameOld(form.name, form.name, "caption"), "self", 'caption', 	//TFS 36423
		//	form.getPropertyValue('caption').String, null, null, false, true, true);													//TFS 36423
	else 
		lsConstant.text := form.getPropertyValue('caption').String;
		lsConstant.matchedToFormConstant := true;
	endif;
	
	// read through the controls seeing who's there an who isn't
	numControls := form.controlCount;
	foreach index in 1 to numControls do
		cntrl := form.controls(index);
		
		controlName := cntrl.getPropertyValue('name').String;
		
		// check to see if the property has a caption
		prop := cntrl.class.getPropertyInHTree("caption");
		if prop &lt;&gt; null then
			lsConstant := _lsClass.allConstants[_lsSchema.name, form.name, controlName, 'caption'];			
			if lsConstant = null then
			
				self.handleFormTranslationTransfer(_lsClass, null, 	//TFS 36423
					cntrl.getPropertyValue('name').String, 'caption', cntrl.getPropertyValue('caption').String, null, null, false, true, false);		//TFS 36423
				if lsConstant &lt;&gt; null then	
					_lsClass.generateTranslateFormMethod := true;	
				endif;
		//	self.handleFormTranslationTransfer(_lsClass, self.makeConstantNameOld(form.name, controlName, 'caption'), 								//TFS 36423
		//			cntrl.getPropertyValue('name').String, 'caption', cntrl.getPropertyValue('caption').String, null, null, false, true, true);		//TFS 36423		
			else
				lsConstant.text := cntrl.getPropertyValue('caption').String;
				lsConstant.matchedToFormConstant := true;
			endif;
		endif;
		
		// get bubbleHelp
		prop := cntrl.class.getPropertyInHTree("bubbleHelp");
		write cntrl.name &amp; Tab &amp; cntrl.class.name &amp; Tab &amp; prop.name &amp; prop.String;
		if prop &lt;&gt; null then
			lsConstant := _lsClass.allConstants[_lsSchema.name, form.name, controlName, 'bubbleHelp'];
			if lsConstant = null then
				self.handleFormTranslationTransfer(_lsClass, null, 		//TFS 36423
					cntrl.getPropertyValue('name').String, 'bubbleHelp', cntrl.getPropertyValue('bubbleHelp').String, null, null, false, true,false);
			//	self.handleFormTranslationTransfer(_lsClass, self.makeConstantNameOld(form.name, controlName, 'bubbleHelp'), 
			//		cntrl.getPropertyValue('name').String, 'bubbleHelp', cntrl.getPropertyValue('bubbleHelp').String, null, null, false, true, true);	//TFS 36423
				if lsConstant &lt;&gt; null then	
					_lsClass.generateTranslateFormMethod := true;	
				endif;
			else
				lsConstant.text := cntrl.getPropertyValue('bubbleHelp').String;
				lsConstant.matchedToFormConstant := true;
			endif;
		endif;
		
	endforeach;
	
	// read through the menu to see who isn't there
	numMenus := form.menuItemCount;
	foreach index in 1 to numMenus do
		tmpMenu := form.menuItems(index);
		
		if tmpMenu.isSeparatorJMT() then
			continue;
		endif;
		
		if tmpMenu.name = null then
			continue;
		endif;
		
		controlName := tmpMenu.getPropertyValue('name').String;
		
		lsConstant := _lsClass.allConstants[_lsSchema.name, form.name, tmpMenu.name, 'caption'];
		if lsConstant = null then
			self.handleFormTranslationTransfer(_lsClass, null, tmpMenu.getPropertyValue('name').String, 'caption', 	//TFS 36423
				tmpMenu.getPropertyValue('caption').String, null, null, false, true, false);
		//	self.handleFormTranslationTransfer(_lsClass, self.makeConstantNameOld(form.name, tmpMenu.name, 'caption'), tmpMenu.getPropertyValue('name').String, 'caption', 			//TFS 36423
		//		tmpMenu.getPropertyValue('caption').String, null, null, false, true, true);
			if lsConstant &lt;&gt; null then	
				_lsClass.generateTranslateFormMethod := true;	
			endif;
		else
			lsConstant.text := tmpMenu.getPropertyValue('caption').String;
			lsConstant.matchedToFormConstant := true;
		endif;
	endforeach;
	

epilog
	
end;

</source>
        <Parameter name="_lsSchema" type="LSschema" usage="io"/>
        <Parameter name="_lsClass" type="LSclass" usage="io"/>
    </JadeMethod>
    <JadeMethod name="returnErrorDetails" id="9cb6195a-fe75-4271-9f22-06cf4bc42bf9">
        <source>returnErrorDetails(_userSummaryDict : CM_AssociationDict io);

/*

Purpose:		

Date			Who		Reason
09/11/2015		cnwmh5	Initial creation
30/04/2025		navpw1	JIRA: MTN-34767 - Added if statement to check errorDetailsAdmin is not null before adding it to the dictionary
*/

vars

	strArray					: StringArray512;
	
	iter						: Iterator;
	
	userName					: String;
	currentUserName				: String;
	errorDetails				: String;
	errorDetailsAdmin			: String;

begin

	iter := self.errorDetailsDict.createIterator;
	while iter.next(strArray) do
	
		self.errorDetailsDict.getIteratorKeys(userName, iter);
		
		if currentUserName = null then
			currentUserName := userName;
		endif;
		
		if currentUserName &lt;&gt; userName then
			errorDetails := CrLf &amp; "The following translateForm methods were not regenerated due to XLAT Constant(s) missing in DMAST.  " &amp; 
				"Please run DevSchem::GenTranslateFormMethod application in CNWDMAST to create required constant(s):" &amp; CrLf &amp; CrLf &amp; errorDetails;
			_userSummaryDict.addAssociation(currentUserName, errorDetails);
			currentUserName := userName;
			errorDetails := null;
		endif;
	
		errorDetails := errorDetails &amp; strArray[1] &amp; CrLf;
		errorDetailsAdmin := errorDetailsAdmin &amp; strArray[1] &amp; CrLf;
	
	endwhile;
	
	
	if errorDetails &lt;&gt; null then
		errorDetails := CrLf &amp; "The following translateForm methods were not regenerated due to XLAT Constant(s) missing in DMAST.  " &amp; 
			"Please run DevSchem::GenTranslateFormMethod application in CNWDMAST to create required constant(s):" &amp; CrLf &amp; CrLf &amp; errorDetails;
		_userSummaryDict.addAssociation(currentUserName, errorDetails);	
	endif;
	
	if errorDetailsAdmin &lt;&gt; null then
		// admin setup
		errorDetailsAdmin := CrLf &amp; "The following translateForm methods were not regenerated due to XLAT Constant(s) missing in DMAST.  " &amp; 
			"Please run DevSchem::GenTranslateFormMethod application in CNWDMAST to create required constant(s):" &amp; CrLf &amp; CrLf &amp; errorDetailsAdmin;
		_userSummaryDict.addAssociation("CNWMH5", errorDetailsAdmin);
	endif;

epilog

end;</source>
        <Parameter name="_userSummaryDict" type="CM_AssociationDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="tryGetConstant" id="ac8c2cdc-2ccb-44fe-b7b6-4861b69b7a4a">
        <updating/>
        <source>tryGetConstant(_lsClass : LSclass;_controlName,_controlProperty : String): Constant updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2017	cnwns1	Initial creation

*/

vars
	const : Constant;
	xmlDoc : JadeXMLDocument;
	xmlElement : JadeXMLElement;
	xmlAttribute : JadeXMLAttribute;
	formSchema : String;
	formClass : String;
	controlName : String;
	controlProperty : String;
begin
	if self.allConstantsByUse = null then
		create self.allConstantsByUse transient;
		
		self.allConstantsByUse.setMembership(Constant);
		self.allConstantsByUse.addExternalKey(String, 35, false, true);					// Schema
		self.allConstantsByUse.addExternalKey(String, 35, false, true);					// form name
		self.allConstantsByUse.addExternalKey(String, 35, false, true);					// control
		self.allConstantsByUse.addExternalKey(String, 35, false, true);					// type   e.g. caption or bubbleHelp
		self.allConstantsByUse.endKeys(false);
		
		foreach const in rootSchema.getSchema(PortSchemaName).getConstantCategory(XLAT_FormCaptions).cnEcGetConstants() do
			delete xmlDoc;
			create xmlDoc transient;
			xmlDoc.parseString(const.text);
			xmlElement := xmlDoc.getElementByTagName(XMLTag_Header);
		
			// get the form Schema
			xmlAttribute := xmlElement.getAttributeByName(XML_Tag_SchemaName);
			if xmlAttribute &lt;&gt; null then
				formSchema := xmlAttribute.value;
			endif;
		
						// get the form class
			xmlAttribute := xmlElement.getAttributeByName(XML_Tag_FormClass);
			if xmlAttribute &lt;&gt; null then
				formClass := xmlAttribute.value;
			endif;
	
			xmlAttribute := xmlElement.getAttributeByName(XML_Tag_ControlName);
			if xmlAttribute &lt;&gt; null then
				controlName := xmlAttribute.value;
			endif;
			
			// Get the controlName
			xmlAttribute := xmlElement.getAttributeByName(XML_Tag_ControlProperty);
			if xmlAttribute &lt;&gt; null then
				controlProperty := xmlAttribute.value;
			endif;
			
			if not allConstantsByUse.includesKey(formSchema,formClass,controlName,controlProperty) then
				allConstantsByUse.putAtKey(formSchema,formClass,controlName,controlProperty,const);
			endif;
		endforeach;
	endif;
	
	if _controlName = "self" then
		return allConstantsByUse.getAtKey(_lsClass.mySchema.name,_lsClass.name,_lsClass.name,_controlProperty).Constant;
	else
		return allConstantsByUse.getAtKey(_lsClass.mySchema.name,_lsClass.name,_controlName,_controlProperty).Constant;
	endif;

epilog
	delete xmlDoc;
end;</source>
        <Parameter name="_lsClass" type="LSclass"/>
        <Parameter name="_controlName" type="String"/>
        <Parameter name="_controlProperty" type="String"/>
        <ReturnType type="Constant"/>
    </JadeMethod>
</Class>
