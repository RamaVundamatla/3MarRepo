    <JadeMethod name="validateMe" id="e91e1eaa-4481-4da3-87c8-f4873c3bae7a">
        <source>validateMe();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin
	if self.type &lt;&gt; self.TypeCargo then // TFS 37453
		if self.allEventTypes.isEmpty and self.allHMSResources.isEmpty then
			app.raiseCMException(Pleas_selec_some_resou_event_t, null, null);
		endif;
		if self.type = self.TypeVessel and self.myVessel = null then
			app.raiseCMException(SHP_Enter_A_Vessel_Code, null, null);
		endif;
	else
		if self.allTransactionTypes.isEmpty then
			app.raiseCMException(Selecte_transat_list_empty, null, null);
		endif;
		if self.allCriteria.isEmpty then
			app.raiseCMException(No_Criteria_values_selected, null, null);
		endif;
	endif;
	

epilog

end;</source>
    </JadeMethod>
</Class>
