    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="8218f12b-45e3-4e8a-b8b7-9281c7dceb3f">
        <updating/>
        <source>create() updating;
//-----------------------------------------------------------------------
//	Created:	12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields
//-----------------------------------------------------------------------
vars

begin
	self.description := self.Operator_GreaterThanEqual;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMatch" id="5af505ca-f22c-4dca-9ea3-272fedaabf16">
        <source>doMatch(_value: Any): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/

vars
	intValue : Integer;
begin
	if _value = null or _value.IntegerArray.isEmpty() then
		return false;
	endif;
	
	foreach intValue in _value.IntegerArray do
		if  intValue &gt;= self.searchValue then
			return true;
		endif;	
	endforeach;
	
	return false;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
