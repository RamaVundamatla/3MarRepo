    <JadeMethod name="createInvoiceLineWeb" id="8cd8555d-0cb2-4263-84d9-cacfd73d437b">
        <updating/>
        <source>createInvoiceLineWeb(debtor : CM_Debtor; _invoice: CM_Invoice; _quantity: Real; _remarks: String) : CM_InvoiceLine updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 August 2023	navcs2	Bug 59959: EUP | TAS Invoicing - Invoice API doesn't match whats defined in API spec

*/


vars
	invLine:   CM_InvoiceLine;
	now:       TimeStamp;
	seqNum : Integer;
	invType : CM_InvoiceDesc;
begin
	
	create invLine persistent;
	
	seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_INVOICELINE); 

	now := app.serverTimestampAtTrxStart;	
	invLine.setForCreate(seqNum, false, _remarks,self, _invoice, debtor, bank, _quantity, now);
	invLine.createCharges();
	
	invLine.doHookCodeForRemarks();	
		
	app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(invLine);		

	return invLine;

epilog
	
end;</source>
        <Parameter name="debtor" type="CM_Debtor"/>
