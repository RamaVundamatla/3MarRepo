    <JadeMethod name="createSQLNativeObject" id="f02a5b12-bc67-400a-9fae-0de37582cf3c">
        <updating/>
        <source>createSQLNativeObject(_transClass : CM_DataDumpTransSpecClass; _object : Object; _created : Boolean output; _updated : Boolean output) : Boolean updating;
/*

Purpose:			Called when Inserting (creating) a row into the SQL Database
					Iterates through the transient method dictionary for the appropriate method.
					Uses the Super Class transient method. If this fails we are in trouble.
					
					
Parameters:			

Return Value:		

Date			Who		Reason
04 May 2010		conkc1	Initial creation

PAR 24641
28/04/2017		cnwdap1	TFS 4129 Data Extract Failing - no method found
*/
vars
	result           : Boolean;
	created          : Boolean;
	updated          : Boolean;
	found            : Boolean;
	sqlResult        : Integer;
	classNumber      : Integer;
	object           : Object;
	transientMethod  : CM_DataDumpTransientMethod;
	xdbAgent         : CM_ExternalDatabaseAgent;
	tableName        : String;
begin
	//write method.qualifiedName &amp; " Class: " &amp; _object.class.name &amp; Tab &amp; _object.asStringJMT &amp; Tab &amp; "Created at: " &amp; _object.creationTime.asStringJMT();
	xdbAgent     := self;
	object       := _object;
	// TFS 4129 CMEVT_WagonTransaction is a subclass of CM_EventTransaction. If a data extract is set up for CM_EventTransaction				// TFS 4129
	// the getParentClassNumber method below will return the class number for CMEVT_WagonTransaction when we are processing						// TFS 4129
	// a CMEVT_WagonTransaction transaction. This will then fail to find a method in app.myDataDumpExtractionAgent.allDataDumpTransientMethod	// TFS 4129
	// collection because they are keyed on the class number for the superclass (CM_EventTransaction). So wee need to hack 						// TFS 4129
	// a bit for CMEVT_WagonTransaction																											// TFS 4129
	if _transClass.myExtractClass.className = CM_EventTransaction.name and _object.isKindOf(CMEVT_WagonTransaction) then						// TFS 4129
		classNumber := CM_EventTransaction.number;																								// TFS 4129
	else																																		// TFS 4129
		classNumber  := getParentClassNumber(object);
	endif;																																		// TFS 4129
	
	app.myDataDumpExtractionAgent.allDataDumpTransientMethod.startKeyGeq(classNumber, CM_DataDumpExtractionAgent.SQL_Insert, "", app.myDataDumpExtractionAgent.myTransientMethodIterator);

	//
	//  Iterate around all Insert methods for this object
	//  Each time a Jade Class is mapped to a SQL Table we need to update all Tables
	//
	while app.myDataDumpExtractionAgent.myTransientMethodIterator.next(transientMethod) do		
		if transientMethod.classNumber &lt;&gt; classNumber or transientMethod.action &lt;&gt; CM_DataDumpExtractionAgent.SQL_Insert then
			break;
		endif;
		found := true;

		sqlResult := process.executeTransientIOMethod(transientMethod.myJadeMethod, object, object, self.myExternalDatabase, self.myExtractionAgent).Integer;
		
		if sqlResult &lt;&gt; 0 then
			tableName := transientMethod.sqlTableName;
			//
			//  3258 - Row with this oid already exists so we will update it
			//
			if sqlResult = 3258 then
				transientMethod  := app.myDataDumpExtractionAgent.allDataDumpTransientMethod[classNumber, CM_DataDumpExtractionAgent.SQL_Update, tableName];
				if transientMethod = null then
					self.myExtractionAgent.createSQLNativeAlert(method.qualifiedName &amp; " : " &amp; _object.String &amp; " : " &amp; app.getErrorString1(TransientMethodUpdateNotFound, tableName));
					app.raiseCMException1(TransientMethodUpdateNotFound, tableName, null, null);
					return false;
				endif;

				sqlResult := process.executeTransientIOMethod(transientMethod.myJadeMethod, object, object, self.myExternalDatabase, self.myExtractionAgent).Integer;
		
				if sqlResult &lt;&gt; 0 then
					self.myExtractionAgent.createSQLNativeAlert(method.qualifiedName &amp; " : " &amp; _object.String &amp; " : " &amp; app.getErrorString2(RetryUpdateFailed, tableName, sqlResult.String));
					app.raiseCMException2(RetryUpdateFailed, tableName, sqlResult.String, null, null);
					return false;
				endif;

				_updated := true;
				self.transNumUpdates := self.transNumUpdates + 1;
			else
				//
				// SQL Error other than a Duplicate - Alert
				//				
				//self.myExtractionAgent.createSQLNativeAlert(method.qualifiedName &amp; " : " &amp; _object.String &amp; " : " &amp; app.getErrorString2(InsertToSQLTableFailed, tableName, sqlResult.String));
				//app.raiseCMException2(InsertToSQLTableFailed, tableName, sqlResult.String, null, null);
				self.myExtractionAgent.createSQLNativeAlert(method.qualifiedName &amp; " : " &amp; _object.String &amp; " : " &amp; app.getErrorString3(InsertToSQLTableFailed, tableName, sqlResult.String, self.myExtractionAgent.sqlCallInfo)); //cnwrd1 par 32871
				app.raiseCMException3(InsertToSQLTableFailed, tableName, sqlResult.String,self.myExtractionAgent.sqlCallInfo, null, null);	//cnwrd1 par 32871
				return false;			
			endif;
		else
			//
			//  All OK
			//
			_created := true;
			self.transNumCreates := self.transNumCreates + 1;
		endif;
	endwhile;
	
	if found = false then
		// failed to find Transient method
		self.myExtractionAgent.createSQLNativeAlert(method.qualifiedName &amp; " : " &amp; _object.String &amp; " : " &amp; app.getErrorString(JadeSourceNotFound));
		app.raiseCMException(JadeSourceNotFound, null, null);
		return false;
	endif;

	return true; 
epilog	

end;</source>
        <Parameter name="_transClass" type="CM_DataDumpTransSpecClass"/>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_created" type="Boolean" usage="output"/>
        <Parameter name="_updated" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createSQLStatement" id="fe782c97-8af0-4620-bc9f-c3d4265a421b">
        <source>createSQLStatement(_extObj: ExternalObject; _newObject: Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     06 July 2003 by cnwrs1
//
// Purpose:		This method create a T-SQL statement from the properties and values
//				already put into the external object for jade to sql update
//				The main use is to help debug the system after a failure, if the system fails
//				and these sql statements work thru winsql the problem is in Jade.
//				_newObject true will generate INSERT or if false UPDATE SET statements.
// ---------------------------------------------------------------------------

vars
	property: Property;
	popColl: PropertyNDict;
	msg1,msg2,propertyName,sqlStatement: String;
	object: Object;
begin
	popColl := _extObj.class.getProperties;
	foreach property in popColl do
		propertyName := property.getName;
		if msg1 = null then
			msg1 := propertyName[5:propertyName.length];
		else
			msg1 := msg1&amp;', '&amp;propertyName[5:propertyName.length];
		endif;
		if property.isKindOf(Attribute) then
			if property.type = String then
				if _newObject then
					if msg2 = null then
						if _extObj.getPropertyValue(propertyName).String = null then
							msg2 := "' '";
						else
							msg2 := "'"&amp;_extObj.getPropertyValue(propertyName).String.dataDumpFormat.replaceString("'", "''")&amp;"'";
						endif;
					else
						if _extObj.getPropertyValue(propertyName).String = null then
							msg2 := msg2&amp;','&amp;"' '";
						else
							msg2 := msg2&amp;','&amp;"'"&amp;_extObj.getPropertyValue(propertyName).String.dataDumpFormat.replaceString("'", "''")&amp;"'";
						endif;
					endif;
				else
					if _extObj.getPropertyValue(propertyName).String = null then
						msg1 := msg1&amp;'='&amp;"' '";
					else
						msg1 := msg1&amp;'='&amp;"'"&amp;_extObj.getPropertyValue(propertyName).String.dataDumpFormat.replaceString("'", "''")&amp;"'";
					endif;
				endif;
			elseif property.type = Binary then
				if _newObject then
					if msg2 = null then
						msg2 := '0x'&amp;_extObj.getPropertyValue(propertyName).Binary.asHex;
					else
						msg2 := msg2&amp;','&amp;'0x'&amp;_extObj.getPropertyValue(propertyName).Binary.asHex;
					endif;
				else
					msg1 := msg1&amp;'='&amp;'0x'&amp;_extObj.getPropertyValue(propertyName).Binary.asHex;
					if property.getName = "edb_Oid" then
						msg2 := '0x'&amp;_extObj.getPropertyValue(propertyName).Binary.asHex; 
					endif;
				endif;
			elseif property.type = TimeStamp then
				if _newObject then
					if msg2 = null then
						if _extObj.getPropertyValue(propertyName).TimeStamp.dataDumpFormat = DataDumpDefaultNullValue then
							msg2 := "NULL";
						else
							msg2 := "CAST('"&amp;_extObj.getPropertyValue(propertyName).TimeStamp.dataDumpFormat&amp;"' as datetime)";
						endif;
					else
						if _extObj.getPropertyValue(propertyName).TimeStamp.dataDumpFormat = DataDumpDefaultNullValue then
							msg2 := msg2&amp;','&amp;"NULL";
						else
							msg2 := msg2&amp;','&amp;"CAST('"&amp;_extObj.getPropertyValue(propertyName).TimeStamp.dataDumpFormat&amp;"' as datetime)";
						endif;
					endif;
				else
					if _extObj.getPropertyValue(propertyName).TimeStamp.dataDumpFormat = DataDumpDefaultNullValue then
						msg1 := msg1&amp;"=NULL";
					else
						msg1 := msg1&amp;'='&amp;"CAST('"&amp;_extObj.getPropertyValue(propertyName).TimeStamp.dataDumpFormat&amp;"' as datetime)";
					endif;
				endif;
			elseif property.type = Boolean then
				if _newObject then
					if msg2 = null then
						msg2 := _extObj.getPropertyValue(propertyName).Boolean.dataDumpFormat;
					else
						msg2 := msg2&amp;','&amp;_extObj.getPropertyValue(propertyName).Boolean.dataDumpFormat;
					endif;
				else
					msg1 := msg1&amp;'='&amp;_extObj.getPropertyValue(propertyName).Boolean.dataDumpFormat;
				endif;
			else
				if _newObject then
					if msg2 = null then
						msg2 := _extObj.getPropertyValue(propertyName).String;
					else
						msg2 := msg2&amp;','&amp;_extObj.getPropertyValue(propertyName).String;
					endif;
				else
					msg1 := msg1&amp;'='&amp;_extObj.getPropertyValue(propertyName).String;
				endif;
			endif;
		endif;
	endforeach;	
	if _newObject then
		sqlStatement := "INSERT INTO "&amp;_extObj.class.name[5:_extObj.class.name.length]&amp;" ("&amp;msg1&amp;") VALUES ("&amp;msg2&amp;")";
	else
		sqlStatement := "UPDATE "&amp;_extObj.class.name[5:_extObj.class.name.length]&amp;" SET "&amp;msg1&amp;" WHERE oid="&amp;msg2;
	endif;
	return sqlStatement;
end;</source>
        <Parameter name="_extObj" type="ExternalObject"/>
        <Parameter name="_newObject" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="createSQLStatementFile" id="f1688727-cf19-406b-805a-e685f94c89f7">
        <updating/>
        <source>createSQLStatementFile(_fileName: String) updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 November 2003 by cnwrs1
// ---------------------------------------------------------------------------

vars
	iniFileName	: String;
	now: TimeStamp;
begin
	if self.mySQLStatementFile = null then
		iniFileName := app.getProfileStringAppServer(app.getIniFileNameAppServer(), 'JadeLog', 'LogDirectory', null);
		create self.mySQLStatementFile transient;
		self.mySQLStatementFile.fileName := iniFileName.trimBlanks&amp;"\"&amp;_fileName&amp;self.sqlStatementFileNumber.stringWithLeadingZeros(3)&amp;now.date.formatAsYYMMDD()&amp;now.time.format("hhmmss")&amp;".sql";
		self.mySQLStatementFile.mode := File.Mode_Output;
		self.mySQLStatementFile.open;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_fileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteExternalObj" id="4f67f821-db3e-494e-999b-6f07426e83a8">
        <updating/>
        <source>deleteExternalObj(_oidStr: String) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     26 June 2003 by cnwsb1

// Purpose:		Deletes the ExternalObject for the given JADE oidStr.
//
// Performance:	The call to setClassForOidStr() is slow.
//				It is intended that this method be called many times with the
//				same class of object, rather than hopping around different
//				classes of object randomly.
// ---------------------------------------------------------------------------
vars
	extObj : ExternalObject;
	result : Boolean;
begin
	if not self.setClassForOidStr(_oidStr) then
		self.log("Failed to delete object "&amp;_oidStr);
		result := false;
		return result;
	endif;
	
	extObj := self.myExternalDict[_oidStr.oidStringToDataDumpBin];
	
	if extObj &lt;&gt; null then
		if self.DebugTracingToObjectLevel then
			self.log("Updating " &amp; _oidStr.oidStringId);
		endif;

		extObj.deleteSelf;
		
		self.transNumDeletes := self.transNumDeletes + 1;

		// This should be unnecessary (ie. comment out and run the
		// JadeScript::dataDumpExtractTestVolume test) when PAR 30980
		// is addressed by loading JADE 5.2.8 Q3-2003.
		self.refreshExternalDict;

		self.intermediateCommitWhenRequired(false);
	endif;
	result := true;
epilog	
	return result;
end;</source>
        <Parameter name="_oidStr" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deleteSQLNativeObject" id="e6ef1d9a-2246-4aba-a5db-a40e4f524a8e">
        <updating/>
        <source>deleteSQLNativeObject(_transClass : CM_DataDumpTransSpecClass; _objectString : String) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     04 May 2010 
//
// Purpose:		Deletes object from SQL Database, or flag Object as deleted, or just ignore delete.
//
// PAR 24641
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 28/04/2017	cnwdap1		TFS 4129 Data Extract Failing - no method found
// ---------------------------------------------------------------------------
vars
	result           : Boolean;
	sqlResult        : Integer;
	found            : Boolean;
	classNumber      : Integer;
	transientMethod  : CM_DataDumpTransientMethod;
	xdbAgent         : CM_ExternalDatabaseAgent;
	object           : Object;
	tableName        : String;
begin
	object           := _objectString.asOid;
	// TFS 4129 CMEVT_WagonTransaction is a subclass of CM_EventTransaction. If a data extract is set up for CM_EventTransaction				// TFS 4129
	// the getParentClassNumber method below will return the class number for CMEVT_WagonTransaction when we are processing						// TFS 4129
	// a CMEVT_WagonTransaction transaction. This will then fail to find a method in app.myDataDumpExtractionAgent.allDataDumpTransientMethod	// TFS 4129
	// collection because they are keyed on the class number for the superclass (CM_EventTransaction). So wee need to hack 						// TFS 4129
	// a bit for CMEVT_WagonTransaction																											// TFS 4129
	if _transClass.myExtractClass.className = CM_EventTransaction.name and object.isKindOf(CMEVT_WagonTransaction) then							// TFS 4129
		classNumber := CM_EventTransaction.number;																								// TFS 4129
	else																																		// TFS 4129
		classNumber      := getParentClassNumber(object);
	endif;																																		// TFS 4129
	
	app.myDataDumpExtractionAgent.allDataDumpTransientMethod.startKeyGeq(classNumber, CM_DataDumpExtractionAgent.SQL_UpdateDelete, "", app.myDataDumpExtractionAgent.myTransientMethodIterator);
	while app.myDataDumpExtractionAgent.myTransientMethodIterator.next(transientMethod) do
		if transientMethod.classNumber &lt;&gt; classNumber or transientMethod.action &lt;&gt; CM_DataDumpExtractionAgent.SQL_UpdateDelete then
			break;
		endif;
		found := true;
		//
		// Ignoring deletes - so just continue the loop
		//
		if transientMethod.ignoreDeletes = true then
			continue;
		endif;
	
		xdbAgent  := self;
		sqlResult := process.executeTransientIOMethod(transientMethod.myJadeMethod,  xdbAgent, object, self.myExternalDatabase, self.myExtractionAgent).Integer;
		
		//25/11/2010 cnwdz2 26370
		//continue if could not find the object to be updated
		if sqlResult = 3259 then
			continue;
		endif;
		
		if sqlResult &lt;&gt; 0 then
			tableName := transientMethod.sqlTableName;
			self.myExtractionAgent.createSQLNativeAlert(method.qualifiedName &amp; " : " &amp; _objectString &amp; " : " &amp; app.getErrorString2(DeleteFromSQLTableFailed, tableName, sqlResult.String));
			app.raiseCMException2(DeleteFromSQLTableFailed, tableName, sqlResult.String, null, null);
			return false;
		endif;

		self.transNumDeletes := self.transNumDeletes + 1;

	endwhile;

	if found = false then
		self.myExtractionAgent.createSQLNativeAlert(method.qualifiedName &amp; " : " &amp; _objectString &amp; " : " &amp; app.getErrorString(JadeSourceNotFound));
		app.raiseCMException(JadeSourceNotFound, null, null);
		return false;
	endif;

	result := true;

epilog	

end;</source>
        <Parameter name="_transClass" type="CM_DataDumpTransSpecClass"/>
        <Parameter name="_objectString" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doItForRS" id="ef4b3ee1-6775-4b71-89ce-4f0805fa65f4">
        <source>doItForRS();

vars
	binObj : Binary[6];
	obj : Object;
	extObj : ExternalObject;
begin
	obj := "2399.910050".asOid;
	binObj := global.dataDumpFormatBin(obj);
	extObj := self.myExternalDict[binObj];
epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="finalise" id="a9994625-cc1c-40fa-832b-096eb656d404">
        <updating/>
        <source>finalise() updating;
// ---------------------------------------------------------------------------
// Created:     24 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
//03 Feb 2016	cnwrs1	Par37170 - SQL Native not recovering from SQL shutdown
vars
	gotNotInTransStateException : Boolean;
	
begin
	// In case we are in external trans state - end it.
	on Exception do self.localAbortTransExHandler(exception, gotNotInTransStateException);
	self.myExternalDatabase.abortExternalTransaction();
epilog
	self.closeDb();
	
	self.log("EDB agent finished");
	self.deleteLog();
end;</source>
    </JadeMethod>
    <JadeMethod name="getColumnOrdinalPosition" id="43048d36-b9bc-4a69-a8f6-86952eedcb11">
        <updating/>
        <source>getColumnOrdinalPosition(_sqlTableName : String; _sqlColumn : String) : Integer updating;
/*
Purpose:			Calls SQL Stored Procedure (jmt_getColumnOrdinalPosition) to return Column Pos

Parameters:			SQL Table name and column name

Return Value:		Column position

Date			Who		Reason
01 June 2010	conkc1	Initial creation

PAR 24641
*/
vars

begin
	return self.myExternalDatabase.jmt_callStoredProcGeneric("jmt_getColumnOrdinalPosition", 8888, _sqlTableName, _sqlColumn);
epilog

end;</source>
        <Parameter name="_sqlTableName" type="String"/>
        <Parameter name="_sqlColumn" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getExternalDictSize" id="a3949c6b-1715-4d2f-836c-6fb413327eb2">
        <updating/>
        <source>getExternalDictSize(_class : Class) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     02 July 2003 by cnwsb1
//
// Purpose:		Returns count of rows in ExternalDictionary for the
//				given JADE class.  Useful for testing.
// ---------------------------------------------------------------------------
begin
	if _class &lt;&gt; self.myClass then
		// Class has changed
		if not self.setClass(_class) then
			return null;
		endif;
	endif;
	
	return self.myExternalDict.size;
end;</source>
        <Parameter name="_class" type="Class"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getExternalObj" id="cdfe2d13-e774-4370-a418-a3f03e95fc93">
        <updating/>
        <source>getExternalObj(_obj: Object) : ExternalObject updating;
// ---------------------------------------------------------------------------
// Created:     24 June 2003 by cnwsb1
//
// Purpose:		Retrieves the ExternalObject for the given JADE object.
//
// Performance:	The call to setClassForObj() is slow.
//				It is intended that this method be called many times with the
//				same class of object, rather than hopping around different
//				classes of object randomly.
// ---------------------------------------------------------------------------
vars
	extObj : ExternalObject;

begin
	if not self.setClassForObj(_obj) then
		return null;
	endif;

	extObj := self.myExternalDict[global.dataDumpFormatBin(_obj)];
	
	return extObj;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="ExternalObject"/>
    </JadeMethod>
    <JadeMethod name="getJMTControlValues" id="09ec2c5c-f432-4909-9488-41bc343d4c6f">
        <updating/>
        <source>getJMTControlValues(_uniqueIdentifier : Integer64 output) : Integer64 updating;
//
//  gets the SQL JMT Control table uniqueIdentifier 
//
// PAR 24641
constants

vars

begin
	
	return self.myExternalDatabase.jmt_callStoredProcGeneric("jmtControl_getUnique", 8881);

epilog

end;</source>
        <Parameter name="_uniqueIdentifier" type="Integer64" usage="output"/>
        <ReturnType type="Integer64"/>
    </JadeMethod>
    <JadeMethod name="getNumChanges" id="68ae12fb-3555-470e-9a45-db1bd45dcaf7">
        <source>getNumChanges() : Integer protected;
// ---------------------------------------------------------------------------
// Created:     26 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	return self.transNumCreates + self.transNumUpdates + self.transNumDeletes;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getParentClassNumber" id="381a51f1-7e70-4687-892a-21a4d47c77df">
        <updating/>
        <source>getParentClassNumber(_object : Object) : Integer updating;
//
// Called when we fail to find a Transient Method for an object.
// Transient methods are generated for all class that have properties exposed
// so those that do not expose properties but are a subclass of one that does we use
// the super class transient method.  Could change code only to generate superclass transient
//
// Whenever adding a new Class add code here
//
// PAR 24641
//13 Jan 2016	cnwrs1	Par 37432 TFS 1268 SQL Native Changes for DPH
//16 Mar 2016	cnwrs1	TFS 1656 SQL Native Event Type and Event Transaction
//09/06/2016	cnwdap1	POL TFS #1963 SQL Native Extract of CM_BulkRelease
// 19 Dec 2016	cnwrs1	TFS add CM_GLCode to SQL Native
//19/01/2017 	cnwrh7		TFS	2929  Additional Fields Required in SQL Native for Release Requests
// 14/3/2017 	cnwer1	tfs 3418 tidied up with classes that were references but not in extract
//29/08/2022	navkc1	ChangeRequest 54568: EUP - Inv Config - Reports and Extracts
//12 Sep 2022	navpw1	TFS: 54568 - EUP - Inv Config - Reports and Extracts
//06 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
//23 Nov 2022 navmv20  ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance
//16 Feb 2023 navvt20  TFS CR 55655 Task 55687: Jade - Data Extract
//25 May 2023	navpw1	TFS: 53902 - Added Data Extract for Vehicle Booking Time Slot
//01 June 2023	navlw1	Bug 58327: MTN - CM_VehicleBookingTimeSlotItem is missing on the data extract
//30 Jan 2023   navhl20 ChangeRequest 55111: GPHA -- Adding Workpoint to Tracked Item and Transaction Views
//02 Feb 2024  navnk30 ChangeRequest 62313: ATD - Add feature Marine Service timing
//16-Jun-2025	naviv1	MTN-35059 : HAT - Error 86291 SQL Extract
// 03 Sep 2025 	navbs1	Story 35845: PNL - Cargo forecast string does not contain 'Quantity' field - Dev
vars

	number    : Integer;
	
begin
	//
	//  These are in Alphabetical Order except for the first 3 (CM_TITransaction, CM_Log and CM_TrackedItem)
	//  This is for performance reasons - it is much quicker to find the Classes at the top of the code
	//  If there are other frequently used Classes - move them up.
	//
	if _object.isKindOf(CM_TITransaction) then				number := CM_TITransaction.number;
	elseif _object.isKindOf(CM_Log) then					number := CM_Log.number;	//15 Jan 2014	NDL	Par 33264
	elseif _object.isKindOf(CM_TrackedItem) then			number := CM_TrackedItem.number;
	
	elseif _object.isKindOf(CMGTE_Entity) then				number := CMGTE_Entity.number; //MTN-35059
	elseif _object.isKindOf(CM_AuditObject) then 					number := CM_AuditObject.number; // PAR 33412
	elseif _object.isKindOf(CM_Bank) then 					number := CM_Bank.number;
	elseif _object.isKindOf(CM_BookingRefItem) then 					number := CM_BookingRefItem.number; // TFS 2930
	elseif _object.isKindOf(CM_BookingRef) then 					number := CM_BookingRef.number; // TFS 2930
	elseif _object.isKindOf(CM_BOL) then					number := CM_BOL.number;	//15 Jan 2014	NDL	Par 33264
	elseif _object.isKindOf(CM_BOLExtension) then			number := CM_BOLExtension.number;	//15 Jan 2014	NDL	Par 33264
	elseif _object.isKindOf(CM_BulkRelease) then			number := CM_BulkRelease.number;		// TFS #1963
	elseif _object.isKindOf (CM_GLCode) then 					number := CM_GLCode.number;
	elseif _object.isKindOf(CM_ReserveSelection) then	number := CM_ReserveSelection.number;		// +TFS 2929
	elseif _object.isKindOf (CM_ReserveTI) then number := CM_ReserveTI.number;										//+TFS 2929
	elseif _object.isKindOf(CM_CargoType) then				number := CM_CargoType.number;
	elseif _object.isKindOf(CM_Carrier) then				number := CM_Carrier.number;
	elseif _object.isKindOf(CM_Charge) then					number := CM_Charge.number;
	elseif _object.isKindOf(CM_CodeGroupLogSpecs) then		number := CM_CodeGroupLogSpecs.number;	//15 Jan 2014	NDL	Par 33264
	elseif _object.isKindOf(CM_CodeGroup) then		number := CM_CodeGroup.number;	// TFS 2942
	elseif _object.isKindOf(CM_Commodity) then				number := CM_Commodity.number;
	elseif _object.isKindOf(CM_CommodityGroup) then			number := CM_CommodityGroup.number;
	elseif _object.isKindOf(CM_ConsigneeConsignor) then		number := CM_ConsigneeConsignor.number;
	elseif _object.isKindOf(CM_ConsigneeConsignorGroup) then number := CM_ConsigneeConsignorGroup.number;
	elseif _object.isKindOf(CM_ContentsStatus) then			number := CM_ContentsStatus.number;
	elseif _object.isKindOf(CM_Country) then				number := CM_Country.number;
	elseif _object.isKindOf(CM_DamageInstance) then			number := CM_DamageInstance.number;  // PAR 24435
	elseif _object.isKindOf(CM_Delay) then 					number := CM_Delay.number;     //28/09/2011 cnwdz2 CCMS 1254 PAR 28270
	elseif _object.isKindOf(CM_DelayType) then 				number := CM_DelayType.number; //28/09/2011 cnwdz2 CCMS 1254 PAR 28270
	elseif _object.isKindOf(CM_Debtor) then					number := CM_Debtor.number;
	elseif _object.isKindOf(CM_DebtorGroup) then			number := CM_DebtorGroup.number;
	elseif _object.isKindOf(CM_DocketError) then			number := CM_DocketError.number;	//15 Jan 2014	NDL	Par 33264
	elseif _object.isKindOf(CM_EmailAddress2) then			number := CM_EmailAddress2.number;	// epr 13/3/17 tfs 3418 
	elseif _object.isKindOf(CM_EventType) then				number := CM_EventType.number;
	
	// cnwmc5 - 31 May 2016 - TFS 2052 - moved (CMEVT_WagonTransaction) above parent (CM_EventTransaction)... this was causing it to crash...
	elseif _object.isKindOf(CMEVT_WagonTransaction) then	number := CMEVT_WagonTransaction.number; // 18/5/15 cnwrd1 36230
	elseif _object.isKindOf(CM_EventTransaction) then		number := CM_EventTransaction.number;
	
	elseif _object.isKindOf(CM_GLCode) then					number := CM_GLCode.number;
