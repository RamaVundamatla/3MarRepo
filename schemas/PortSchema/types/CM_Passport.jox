    <JadeMethod name="noErrors" id="fab640c7-58f6-43fd-9e31-195b4e3d66e8">
        <source>noErrors() : Boolean;
// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	return self.allErrors.isEmpty;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="noErrorsIgnored" id="d6a4fa8e-78df-476c-975d-eba4553579b8">
        <source>noErrorsIgnored() : Boolean;
// ---------------------------------------------------------------------------
// Created:     Sept 2008 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	error : CM_Error;
begin
	if self.errorsToIgnore.isEmpty then
		return self.allErrors.isEmpty;
	endif;
	
	foreach error in self.allErrors do
		if not self.errorsToIgnore.includes(error.errorCode) then
			return false;
		endif;
	endforeach;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="noTrxReplayAllowed" id="677993f4-f973-426a-9c2b-3eab3511a28e">
        <updating/>
        <source>noTrxReplayAllowed():Boolean updating;
/*

Purpose:		Used in the loop that retries a trx when deadlocks encountered 
				and silent retry is in use... So we know when to give up.

Parameters:			

Return Value:		

Date		Who		Reason
15 January 2013	cnwndl1	Initial creation	Par 30920

*/
vars

begin

	if self.hadDeadlock = false then
		// didn't have a Deadlock
		return true;
	endif;
	if self.silentDeadlockRetryCount &gt; self.silentDeadlockLimit then
		// had too many Deadlock retries alreadys;
		return true;
	endif;
	
	//have a wee sleep, to give the other guy a chance to bail/complete first
	process.sleep(self.silentDeadlockSleepTime);
	
	//reset the boolean
	self.hadDeadlock := false;
	
	return false;

end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="noWarnings" id="d10b391f-d023-436f-9de4-58365b07c7e5">
