    <JadeMethod name="setupInYard" id="bbe7a802-2ac2-4e59-a3d5-0e510868528a">
        <updating/>
        <source>setupInYard() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2010	cnwndl1	Initial creation	CCMS MES 1005
22 May 2013	NDL	- CCMS 2274 Break Bulk
17 Dec 2019	jlgdi1	47879	Code optimization. Avoid calling the method 'vehicleVisitRecord.getMoveTotalForTIDisplay' twice.
*/

constants
	TAB_INDEX_START = 1000;
	
vars
	menuButton : MOB_Button;
	buttonOffset : Integer;
	buttonNumber : Integer;
	buttonWidth : Real;
	tiArray: CM_TIArray;
	ti : CM_TrackedItem;
	size : Integer;
	vehicleVisitRecord : CM_VehicleVisitRecord;
	buttonHeight : Integer;
	//12 Apr 2017	NDL	TFS 4015
	docActions : CM_DocumentActions;
	bookingItem : CM_BookingRefItem;
	taskAndStopStr : String;
	unloadedItemDesc : String;
	
begin
	tiArray := self.myMobileGenericAgent.allUnloadedTis;
	size := tiArray.size;

	buttonHeight := self.getScrollingButtonHeight();
	self.btnInYardTemp.height := buttonHeight;
	buttonWidth := getButtonWidthSetScrollBar( size, self.frmCargoInYard, self.btnInYardTemp.height, self.scrCargoInYard );
	
	vehicleVisitRecord := self.myMobileGenericAgent.myTruck.getCurrentVisit();	//06 Mar 2014	NDL	Par 33596

	foreach ti in tiArray do
		if ti.myPrimaryActualLocation = null then	//13 May 2015	NDL	Par 36189
			continue;
		endif;
		
		//31 Aug 2018	NDL	TFS 39769
		if (ti.isBulkByQuantity or ti.isBulkByWeight or ti.isBulkByVolume) and vehicleVisitRecord &lt;&gt; null then			
			unloadedItemDesc := vehicleVisitRecord.getMoveTotalForTIDisplay(ti);
			if unloadedItemDesc = null then
				//what ever was unloaded for this one has alreday been completely reloaded.
				continue;
			endif;
		endif;
		
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnInYardTemp.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		
		menuButton.userObject := ti;
		//06 Mar 2014	NDL	Par 33596
		if (ti.isBulkByQuantity or ti.isBulkByWeight or ti.isBulkByVolume) and vehicleVisitRecord &lt;&gt; null then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; unloadedItemDesc &amp; ")"
										 &amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId;
		else
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId;
		endif;
		
		//12 Apr 2017	NDL	TFS 4015
		docActions := null;
		bookingItem := ti.myBookingRefItem;
		if bookingItem &lt;&gt; null then
			docActions := bookingItem.myBookingRefItemActions;
		endif;
		if docActions &lt;&gt; null then
			taskAndStopStr := docActions.getTaskAndStopStrForTi(ti, true);
			if taskAndStopStr &lt;&gt; null then
				menuButton.caption := menuButton.caption &amp; " " &amp; taskAndStopStr;
				self.docActsToDisplay.addExclusive(docActions);
			endif;
		endif;
		
		self.addHazDetailsToButton( menuButton, ti, " " ); //30 May 2017	NDL	TFS 4587
		
		self.allNotableObjects.add(ti);
	
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
	endforeach;
	
	self.btnInYardTemp.visible := false;
	self.frmCargoInYard.caption := null;
	self.inYardButtonCount := buttonNumber;
	
	if tiArray.isEmpty then
		lblNoCargoYard.visible := true;
	else
		lblNoCargoYard.visible := false;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupOnTruck" id="e60587ac-4221-4e24-be52-d5d5b0080b73">
        <updating/>
        <source>setupOnTruck() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/01/2010	cnwndl1	Initial creation	CCMS MES 1005
22/05/2013	NDL	- CCMS 2274 Break Bulk
29/09/2016	cnwdap1	TFS 2653 Document Actions for Bookings
*/

constants

	TAB_INDEX_START = 1000;
	
vars

	menuButton : MOB_Button;
	buttonOffset : Integer;
	buttonNumber : Integer;
	buttonWidth : Real;
	wleArray: CM_WLEArray;
	wle : CM_WorkListEntry;
	ti : CM_TrackedItem;
	size : Integer;
	objArray : ObjectArray;
	obj : Object;
	obj2 : Object;
	
	receivalRequest : CM_ReceivalRequest;
	receivalRequestInfo : CM_ReceivalRequestInfo;
	cargoTypeString : String;
	count : Integer;
	count2 : Integer;
	loadedTiArray : CM_TIArray;
	quantityString : String;
	
	multiTIArrayObj : Object;
	hasAssocCargoOnTruck : Boolean;
	
	desc1 : String;
	desc2 : String;
	qty : Integer;
	
	checksSubCargo : CM_TrackedItem;
	rrTotQuantity : Integer;
	
	allowMoreCargoButton : Boolean;
	vehicleVisitRecord : CM_VehicleVisitRecord;
	buttonHeight : Integer;
	
	docActions : CM_DocumentActions;			// TFS 2653
	bookingItem : CM_BookingRefItem;			// TFS 2653
	taskAndStopStr : String;					// TFS 2653
	
begin
//	self.docActsToDisplay.clear;				// TFS 2653

//	allowMoreCargoButton := false;	//05 Mar 2014	NDL	Par 33596
//	allowMoreCargoButton := app.myRoot.getConfig(AllowUnloadMoreCargo).Boolean;	//06 Mar 2014	NDL	Par 33554
	allowMoreCargoButton := self.myTerminal.getConfig(AllowUnloadMoreCargo).Boolean;	//04 Dec 2015	NDL	Par 36866
	vehicleVisitRecord := self.myMobileGenericAgent.myTruck.getCurrentVisit();	//07 Mar 2014	NDL	Par 33554

	wleArray := self.myMobileGenericAgent.allLoadedWles;
	create objArray transient;
	create loadedTiArray transient;
	foreach  wle in wleArray do
		ti := wle.myTrackedItem;
		if ti &lt;&gt; null then
		//	objArray.add(ti);
			if not wle.isReceipt then
				if not loadedTiArray.includes(ti) then
					loadedTiArray.add(ti);
				endif;
			else
				objArray.addExclusive(ti);
			endif;
		else
			if wle.myRequest &lt;&gt; null and wle.myRequest.isKindOf(CM_ReceivalRequest) then
				receivalRequest := wle.myRequest.CM_ReceivalRequest;
				if receivalRequest &lt;&gt; null and not receivalRequest.allReceivalInfo.isEmpty then
					foreach receivalRequestInfo in receivalRequest.allReceivalInfo do
						//10 Oct 2011	NDL	Par 28285
						hasAssocCargoOnTruck := false;
						rrTotQuantity := 0;	//04 Mar 2014	NDL	Par 33596
						foreach ti in receivalRequestInfo.allTrackedItems do
							if ti.myPrimaryActualLocation = self.myMobileGenericAgent.myTruck.locationsController then
								hasAssocCargoOnTruck := true;
								break;
							else	//04 Mar 2014	NDL	Par 33596
								if ti.hasBeenMerged and vehicleVisitRecord &lt;&gt; null then	//07 Mar 2014	NDL	Par 33554
									rrTotQuantity := rrTotQuantity +  vehicleVisitRecord.getMoveTotalForTIID(ti.id).Integer;
									break;
								else
									rrTotQuantity := rrTotQuantity + ti.totalQuantity;	//04 Mar 2014	NDL	Par 33596
								endif;
							endif;
						endforeach;
						if hasAssocCargoOnTruck then
					//		continue;  //01 Dec 2015	NDL - Yeah we do want to show it again......
							// cos we don't want to show the receival info object while there is cargo to unload that
							// is associated with it
						endif;
						//04 Mar 2014	NDL	Par 33596
						if rrTotQuantity &gt;= receivalRequestInfo.quantity and receivalRequestInfo.quantity &lt;&gt; 0 then
							//already processed all that we should from this one.
							continue;
						endif;
						objArray.add(receivalRequestInfo);
					endforeach;
					continue;
				endif;
				objArray.add(wle);
			endif;
		endif;
	endforeach;
	
	//24 May 2013	NDL	CCMS 2274 - Break Bulk
	foreach ti in self.myMobileGenericAgent.allTruckTis do
		//might be some that have been some that were split off and loaded back on.
		if not loadedTiArray.includes(ti) and not objArray.includes(ti) then
			loadedTiArray.add(ti);
		endif;
	endforeach;

	size := loadedTiArray.size + objArray.size; // to allow for the extra button below.
	if allowMoreCargoButton then
		size := size + 1; // to allow for the extra button below.
	endif;
	
	//28 Sep 2011	NDL	Par 28285
	// build any collections of TIs able to be bulk unloaded
	if not self.myMobileGenericAgent.isInterTerminal then
		if not objArray.isEmpty then
			self.populateMultiObjArray( objArray );
			size := size + multiObjArray.size;
		endif;
	endif;
	
	buttonHeight := self.getScrollingButtonHeight();
	self.btnOnTruckTemp.height := buttonHeight;
	buttonWidth := getButtonWidthSetScrollBar( size, self.frmCargoOnTruck, self.btnOnTruckTemp.height, self.scrCargoOnTruck );
	
	//28 Sep 2011	NDL	Par 28285	
	if not multiObjArray.isEmpty then
	
		// build buttons for bulk unloads first
		foreach multiTIArrayObj in multiObjArray do		
			buttonNumber := buttonNumber + 1;
			menuButton := self.btnOnTruckTemp.loadControl( buttonNumber ).MOB_Button;
			menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
			
			menuButton.userObject := multiTIArrayObj;
			menuButton.caption := self.getMultiObjectCaption(multiTIArrayObj.CM_TIArray);
			
			buttonOffset := buttonOffset + buttonHeight-2;
			menuButton.tabIndex := TAB_INDEX_START + buttonNumber;			
		endforeach; 
		
		// add the indivudal button as well (so they are in a logical order)
		foreach multiTIArrayObj in multiObjArray do
		
			foreach ti in multiTIArrayObj.CM_TIArray do
				// remove it from the general array, so its only processed once
				objArray.remove( ti );
				
				buttonNumber := buttonNumber + 1;
				menuButton := self.btnOnTruckTemp.loadControl( buttonNumber ).MOB_Button;
				menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
				
				menuButton.userObject := ti;
				desc2 := null;	//28 Aug 2013	NDL	Par 32337
				ti.getShortDescriptions( desc1, desc2 );	//28 Aug 2013	NDL	Par 32337
				if ti.canSplitTotalQuantity and ti.isBulkByQuantity then
					//menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.totalQuantity.String &amp; ")";
					menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.totalQuantity.String &amp; ")" &amp; CrLf &amp; desc2; //28 Aug 2013	NDL	Par 32337
	
				//elseif ti.isBulkByWeight or ti.isBulkByVolume then
			//		menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.CM_Bulk.getBulkTrackByDisplayForWeight(true) &amp; ")" &amp; CrLf &amp; desc2;  
				else
					//menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id ;
					menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; CrLf &amp; desc2; //28 Aug 2013	NDL	Par 32337
				endif;
				
				// TFS 2653 NDL 29/09/2016 start
				docActions := null;
				bookingItem := ti.myBookingRefItem;
				if bookingItem &lt;&gt; null then
					docActions := bookingItem.myBookingRefItemActions;
				endif;
				if docActions &lt;&gt; null then
					taskAndStopStr := docActions.getTaskAndStopStrForTi(ti, true);
					if taskAndStopStr &lt;&gt; null then
						menuButton.caption := menuButton.caption &amp; " " &amp; taskAndStopStr;
						self.docActsToDisplay.addExclusive(docActions);
					endif;
				endif;
				// TFS 2653 NDL 29/09/2016 end
				
				self.allNotableObjects.add(ti);
				
				buttonOffset := buttonOffset + buttonHeight-2;
				menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
		
			endforeach;

		endforeach; 
	endif;

	foreach obj in objArray do
	
		ti := null;
		wle := null;
		receivalRequestInfo := null;
		
		if CM_TrackedItem.hasInstance( obj ) then
			ti := obj.CM_TrackedItem;
		elseif CM_WorkListEntry.hasInstance( obj ) then
			wle := obj.CM_WorkListEntry;
		elseif CM_ReceivalRequestInfo.hasInstance( obj ) then
			receivalRequestInfo := obj.CM_ReceivalRequestInfo;
		else
			continue;
		endif;
		
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnOnTruckTemp.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		
		if ti &lt;&gt; null then
			menuButton.userObject := ti;
			desc2 := null;	//28 Aug 2013	NDL	Par 32337
			ti.getShortDescriptions( desc1, desc2 );	//28 Aug 2013	NDL	Par 32337
			if ti.canSplitTotalQuantity and ti.isBulkByQuantity then
				//menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.totalQuantity.String &amp; ")";
				menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.totalQuantity.String &amp; ")" &amp; CrLf &amp; desc2; //28 Aug 2013	NDL	Par 32337
			else
				//menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id ;
				menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; CrLf &amp; desc2; //28 Aug 2013	NDL	Par 32337
			endif;
			// TFS 2653 cnwdap1 29/09/2016 start
			docActions := null;
			bookingItem := ti.myBookingRefItem;

			if bookingItem &lt;&gt; null then
				docActions := bookingItem.myBookingRefItemActions;
			endif;
			if docActions &lt;&gt; null then
				taskAndStopStr := docActions.getTaskAndStopStrForTi(ti, true);
				if taskAndStopStr &lt;&gt; null then
					menuButton.caption := menuButton.caption &amp; " " &amp; taskAndStopStr;
					self.docActsToDisplay.addExclusive(docActions);
				endif;
			endif;
			// TFS 2653 cnwdap1 29/09/2016 end
			
			//26 Sep 2013	NDL	Par 32557
			if not self.myMobileGenericAgent.isWaitingOnRequiredChecks( CARGO_CHECK_CONTEXT_TRUKUNLOAD, ti, checksSubCargo ) =  null then
				menuButton.foreColor := Green;
			elseif checksSubCargo &lt;&gt; null then
				menuButton.foreColor := Red;
			else
				menuButton.foreColor := Black;
			endif;
			self.allNotableObjects.add(ti);

		elseif receivalRequestInfo &lt;&gt; null then
			menuButton.userObject := receivalRequestInfo;
			if receivalRequestInfo.myCargoType = null then
				cargoTypeString := app.getErrorString(Undeclared_cargo_type);
			else
				cargoTypeString := receivalRequestInfo.myCargoType.description;
			endif;
			self.allNotableObjects.add(receivalRequestInfo);
			count := receivalRequestInfo.allTrackedItems.size;
			if count &gt; 0 then
				foreach obj2 in objArray do
					if obj2.isKindOf( CM_TrackedItem ) and receivalRequestInfo.allTrackedItems.includes( obj2.CM_TrackedItem ) then
						// ti has been created for this receival, but is on the truck!!
						// remove it from the count.
						count := count - 1;
					endif;
				endforeach;
				//30 Sep 2011	NDL	Par 28285
				foreach multiTIArrayObj in multiObjArray do
					foreach ti in multiTIArrayObj.CM_TIArray do
						if receivalRequestInfo.allTrackedItems.includes( ti) then
							// ti is onto the truck!!
							// remove it from the count.
							count := count - 1;
						endif;
					endforeach;
				endforeach;
			endif;
			//16 Nov 2010	NDL	Par 26055
			if receivalRequestInfo.quantity = 0 then
				quantityString := "?? x ";
			else
				quantityString := receivalRequestInfo.quantity.String &amp; " x ";
			endif;
			if count &lt; 1 then
				menuButton.caption := quantityString &amp; cargoTypeString;
			else			
				//06 Mar 2014	NDL	33554
				count2 := receivalRequestInfo.getTotalQuantityUnloaded();
				menuButton.caption := quantityString &amp; cargoTypeString  &amp; " (x" &amp; count2.String &amp; " " &amp; app.getErrorString(Unloaded) &amp; ")";
			endif;
		
		endif;
		
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
		
	endforeach;
	
	if allowMoreCargoButton then
		// add an extra button for adding unknown items....
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnOnTruckTemp.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		menuButton.userObject := null;
		menuButton.caption := app.getErrorString(More_cargo);
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
	endif;
	
	foreach ti in loadedTiArray do
	
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnOnTruckTemp.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );

		menuButton.userObject := ti;
		if ti.canSplitTotalQuantity and ti.isBulkByQuantity then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.totalQuantity.String &amp; ")" 
									&amp; CrLf &amp;  " (" &amp; app.getErrorString(Loaded) &amp; ")";
		else
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; " (" &amp; app.getErrorString(Loaded) &amp; ")";
		endif;
		
		//12 Apr 2017	NDL	TFS 4015
		docActions := null;
		bookingItem := ti.myBookingRefItem;
		if bookingItem &lt;&gt; null then
			docActions := bookingItem.myBookingRefItemActions;
		endif;
		if docActions &lt;&gt; null then
			taskAndStopStr := docActions.getTaskAndStopStrForTi(ti, true);
			if taskAndStopStr &lt;&gt; null then
				menuButton.caption := menuButton.caption &amp; " " &amp; taskAndStopStr;
				self.docActsToDisplay.addExclusive(docActions);
			endif;
		endif;
		
		self.addHazDetailsToButton( menuButton, ti, null ); //30 May 2017	NDL	TFS 4587
		
		menuButton.enabled := false;
		self.allNotableObjects.add(ti);
		
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
	
	endforeach;
	
	self.onTruckButtonCount := buttonNumber;
	
	self.btnOnTruckTemp.visible := false;
	self.frmCargoOnTruck.caption := null;
	
	lblNoCargoTruck.visible := false;

	
epilog

	delete objArray;
	delete loadedTiArray;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tisAreSimilar" id="9df1eb27-615b-4102-ac1e-d2c573fddb08">
        <source>tisAreSimilar( _ti1 : CM_TrackedItem; _ti2 : CM_TrackedItem ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 September 2011	cnwndl1	Initial creation	Par 28285

*/

vars

	id1NumStr : String;
	id2NumStr : String;
	id1AlphaStr : String;
	id2AlphaStr : String;
	pos : Integer;
	char : Character;
	cmifAutoPlan	: CMIF_YAAutoPlan;
	cargoCheck : CM_CargoCheck;
	cargoCheckItem : CM_CargoCheckItem;

begin

	//must be the same cargo type
	if _ti1.cargoType &lt;&gt; _ti2.cargoType then
		return false;
	endif;
	
	// must be the same cargo SUB type
	if _ti1.myProduct &lt;&gt; _ti2.myProduct then
		return false;
	endif;
	
	// The alpha portion of the ids must match,
	// and teh numeric portion differ by one.
	
	foreach pos in 1 to _ti1.id.length do
		char := _ti1.id[pos];
		if char.isNumeric then
			id1NumStr := id1NumStr &amp; char;
		else
			id1AlphaStr := id1AlphaStr &amp; char;
		endif;
	endforeach;
	
	foreach pos in 1 to _ti2.id.length do
		char := _ti2.id[pos];
		if char.isNumeric then
			id2NumStr := id2NumStr &amp; char;
		else
			id2AlphaStr := id2AlphaStr &amp; char;
		endif;
	endforeach;
	
	if id1AlphaStr &lt;&gt; id2AlphaStr then
		return false;
	endif;
	
	if id1NumStr.length &gt; 8 then
		id1NumStr := id1NumStr[(id1NumStr.length - 8):end];
	endif;
	if id2NumStr.length &gt; 8 then		// 36306 09/2015 was just the id1NumStr.length test
		id2NumStr := id2NumStr[(id2NumStr.length - 8):end];
	endif;
	
	if ( id1NumStr.Integer + 1 ) &lt;&gt; id2NumStr.Integer then
		return false;
	endif;
	
	//cargoType must NOT be configured for any Compulsory checks during the truck unload operation
	cargoCheck := app.myPassport.myTerminal.allCargoChecks[CARGO_CHECK_CONTEXT_TRUKUNLOAD];
	if cargoCheck &lt;&gt; null then
		create cmifAutoPlan as CMIF_YAAutoPlanNormal transient;
		cmifAutoPlan.attachTI(_ti1);
		foreach cargoCheckItem in cargoCheck.allCargoCheckItems do
			if not cargoCheckItem.required then	//10 Oct 2011	NDL - Qual change, Par 28285
				continue;
			endif;
			if not cargoCheckItem.doesTIMatchMe(cmifAutoPlan) then
				continue;
			else
				// some sort of check required here
				return false;
			endif;
		endforeach;
	endif;
	
	return true;
	
epilog

	delete cmifAutoPlan;

end;</source>
        <Parameter name="_ti1" type="CM_TrackedItem"/>
        <Parameter name="_ti2" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="dce857d6-82af-4e0b-9dd3-1016b8d8fc84">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 27 October 2016 09:09:50.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014434, locale);
	btnDocActions.translateCaption(Xlat_0021438, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
