    <JadeMethod name="drawGraphic" id="d26a7eac-43c7-4d4b-a69b-d1b2fea5a448">
        <source>drawGraphic();
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	theWidth, theHeight, pntX1, pntX2, pntY1, pntY2, idx, tmpX,tmpY : Integer;
	point1, point2, tmpPoint : Point;
	theXs , theYs : IntegerArray;
	theRow, theCol, theSegments, numRows, numColumns  : Integer;
	thePoints, newPoints : PointArray;
	theSegmentor : CMIF_RectangleSegments;
	thePolygons : ObjectArray;
begin
	numRows := 20;
	numColumns := 20;
	

	self.frmDraw.autoRedraw := true;
	self.frmDraw.clearGraphics();
/*
	self.frmDraw.drawRectangle(10,10,50,40,Black);
	self.frmDraw.drawLine(10,10,50,40,Black);

	self.frmDraw.drawRectangle(10,10,70,55,Black);
	self.frmDraw.drawLine(10,10,70,55,Black);
*/	
	
	create theSegmentor transient;
	create thePoints transient;
	create newPoints transient;
	
	tmpPoint.set(88,180);
	newPoints.add(tmpPoint);
	tmpPoint.set(134,175);
	newPoints.add(tmpPoint);
	tmpPoint.set(144,257);
	newPoints.add(tmpPoint);
	tmpPoint.set(98,261);
	newPoints.add(tmpPoint);
	tmpPoint.set(88,180);
	newPoints.add(tmpPoint);

	theSegmentor.setupSegmentor(numRows,numColumns,newPoints);
	
	
	theSegmentor.generatePolygons();
	thePolygons := theSegmentor.allPolygons;
//process.debug;	
	foreach idx in 1 to thePolygons.size do
		thePoints := thePolygons[idx].PointArray;
		
		foreach theSegments in 1 to thePoints.size do
			if theSegments = 1 then
				point1 := thePoints[theSegments];
			else
				point2 := thePoints[theSegments];
				self.frmDraw.drawLine(point1.x,point1.y,point2.x,point2.y,Black);
				point1 := point2;
			endif;
			
			
		endforeach;
	endforeach;
	
epilog
	delete theSegmentor;
	delete thePoints;
	delete newPoints;


end;</source>
    </JadeMethod>
    <JadeMethod name="drawGraphicRJS" id="4313880f-b823-4c08-a363-76d94852a800">
        <source>drawGraphicRJS();
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	theRow, theCol, theSegments, 
	numRows, numCols  : Integer;
	idx, idx2,
	xpos, ypos	: Integer;

begin	
	numRows := 20;
	numCols := 20;


	self.frmDraw.autoRedraw := true;
	self.frmDraw.clearGraphics();
	
	foreach idx in 1 to numRows do
		ypos := 20 + (idx - 1) * 12;
		self.frmDraw.drawLine(20, ypos, (12 * numCols) + 24, ypos,Black);
	endforeach;
	foreach idx in 1 to numCols do
		xpos := 20 + (idx - 1) * 12;
		self.frmDraw.drawLine(xpos, 20, xpos, (12 * numRows) + 24,Black);
	endforeach;

	foreach idx in 1 to numRows - 1 do
		ypos := 20 + (idx-1) * 12;
		foreach idx2 in 1 to numCols - 1 do
			self.frmDraw.drawFillColor := Blue + (10 * idx * idx2);
			xpos := 20 + (idx2 - 1) * 12;
			self.frmDraw.drawFloodFill(xpos+1, ypos+1, 0, Black);
		endforeach;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="drawSmallText" id="140f3d77-62c7-4509-8316-1e87746d3641">
        <source>drawSmallText();
/*
Purpose:			
Date		Who		Reason
12 March 2013	cnwab1	Initial creation
*/

vars
	cnt, idx : Integer;
	x1, y1, ysave : Real;
begin
	x1 := 50;
	y1 := 50;

	self.frmDraw.caption := "";
	self.frmDraw.autoRedraw := true;
	self.frmDraw.clearGraphics();
	self.frmDraw.backColor := White;
	self.frmDraw.drawFillStyle := Frame.DrawFillStyle_Transparent;
	self.frmDraw.drawFontName := "Simplified Arabic"; //"Latha";
	self.frmDraw.drawFontSize := 7;

	self.frmDraw.drawTextAt("FONT: " &amp; self.frmDraw.drawFontName ,50,10, Black);
	self.frmDraw.drawTextAt("SIZE: " &amp; self.frmDraw.drawFontSize.String ,50,20, Black);
	
	foreach cnt in 1 to 5 do
		self.frmDraw.drawRectangle(x1 - 5, y1 + 1, x1+150,y1+40,Black);
		ysave := y1;
		foreach idx in 1 to 4 do
		self.frmDraw.drawTextAt("LMCU1234567 BCN 23.4",x1,y1, Black);
		y1 := y1 + 7;
		
		endforeach;
/*		
		y1 := ysave;
		foreach idx in 1 to 4 do
		self.frmDraw.drawTextAt("LMCU1234567 BCN 23.4",x1 + 170,y1, Black);
		y1 := y1 + 6;
		endforeach;
		*/
		
		y1 := y1 + 15;
	endforeach;
//	app.printer.print(self.frmDraw);
//	app.printer.close();

epilog

end;</source>
    </JadeMethod>
