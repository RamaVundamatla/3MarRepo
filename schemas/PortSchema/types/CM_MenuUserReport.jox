    <JadeMethod name="writeCSVBlobToFile" id="b05977fb-ba84-4bfc-bd8e-b1fb5346d768">
        <source>writeCSVBlobToFile(_fileName : String) : Boolean;

vars

	file		: File;
	fileDtl		: CM_FileDataStorageDetail;
	tmpBin		: Binary;

begin

	if self.myReportTemplate &lt;&gt; null then
		return self.myReportTemplate.writeCSVBlobToFile(_fileName);
	endif;
	
	create file transient;
	file.mode		:=	File.Mode_Output;
	file.shareMode	:=	File.Share_Exclusive;
	file.kind		:=	File.Kind_Binary;
	file.fileName	:= _fileName;
	
	if not file.tryOpen then
		return false;
	endif;
	
	// Will concat all files on this object as csv can know come
	// from multiple runs e.g detail + summary reports.
	foreach fileDtl in self.allMenuCSVFileData do
		if fileDtl.csvBlob = null then
			continue;
		endif;
// cnwdad1 25/02/2009 - PAR #18366.
//		tmpBin := fileDtl.csvBlob.uncompress;
		tmpBin := fileDtl.csvBlob.uncompressToBinary();
		file.writeBinary(tmpBin);
	endforeach;
	return true;
epilog
	if file &lt;&gt; null then
		file.close;
	endif;
	delete file;
	

end;</source>
        <Parameter name="_fileName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
