    <JadeMethod name="getTidalClassRateEntry" id="d41c32c8-353c-455c-bfbc-b87da16821e3">
        <source>getTidalClassRateEntry(_tidalClasses : ObjectArray input) : CM_RateEntry;
// CCMS SFW 1327 Tidal Class, calculation type, method to use in rate hook code
//  Returns the first (if any) rate entry from charges which uses a tidal rate calculation type.
//  The _tidalClasses array is populated with the tidal classes, sorted by description, to match the CM_RateEntry allCostPerUnits values.
vars
	rateEntry	: CM_RateEntry;
	calcType	: CM_CalculationType;
	charge		: CM_Charge;
begin
	calcType := self.invoiceLineDesc.getCalcType();
	if calcType = null then
		return null;
	endif;
	if calcType.calculationType &lt;&gt; INV_CALC_TYPE_TIDAL_CLASS then
		return null;
	endif;

	foreach charge in self.charges do
		rateEntry := charge.getRateEntry();
		if rateEntry &lt;&gt; null then
			break;
		endif;
	endforeach;
	if rateEntry &lt;&gt; null then
		app.sortTidalClasses(_tidalClasses);
	endif;

	return rateEntry;
end;
</source>
        <Parameter name="_tidalClasses" type="ObjectArray" usage="input"/>
        <ReturnType type="CM_RateEntry"/>
    </JadeMethod>
