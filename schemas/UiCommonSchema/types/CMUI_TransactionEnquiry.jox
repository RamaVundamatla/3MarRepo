    <JadeMethod name="addTransactionToTblTrans" id="d54e84dc-f4ea-45cf-b844-e39bd502b9e4">
        <source>addTransactionToTblTrans( _sortIndex : Integer; _trn : CM_Transaction ) : Integer protected;
// ---------------------------------------------------------------------------
// Created:     04 March 2008 by cnwvu1
// ---------------------------------------------------------------------------

vars
	idx			: Integer;
	enqRow		: String;
	detailsCol 	: Integer;
	auditString,
	detailsString : String;
	sortKeyCol 	: Integer;
	rowKeyCol	: Integer;
begin

	//08 Jun 2010	NDL	Par 23498 - Now uses entTable def to populate base data.
	enqRow := _trn.getAttributeStringForDefArray(tblTrans.allTblDataEntRows);
	idx := tblTrans.addItem(enqRow);
	if _sortIndex &lt;&gt; null then
		// TFS 47428 jlgzm1 12/11/2019
		sortKeyCol := self.tblTrans.getColumnByRowName(ETRow_SortKey);
		rowKeyCol := self.tblTrans.getColumnByRowName(ETRow_RowKey);
		tblTrans.setCellText(idx, sortKeyCol, _sortIndex.String );	// but set hidden sort keys manually (Section of table)	
		tblTrans.setCellText(idx, rowKeyCol, idx.String.padLeadingZeros(3) );	// original sort key withn section (because Date time can be duplicates)
	endif;
	tblTrans.accessRow(idx).itemObject := _trn;
	
	//epr TFS 2996 8/12/16
	if _trn.isKindOf(CM_TITransaction) and _trn.CM_TITransaction.superseded  then
		detailsCol:=self.tblTrans.getColumnByRowName(ETRow_Details);
		if detailsCol &gt; 0 then
			detailsString:= self.tblTrans.getCellText(idx,detailsCol).trimBlanks();
			auditString := _trn.getExtraData(TrnsExtraDataAuditInfo).asString;
			if auditString &lt;&gt; null then
				if detailsString &lt;&gt; null then
					detailsString:= detailsString &amp; CrLf &amp;  auditString;
				else
					detailsString:= auditString;
				endif;
				tblTrans.setCellText(idx,detailsCol,detailsString);
			endif;
		endif;
	endif;
	
	return idx;
 
end;
</source>
        <access>protected</access>
        <Parameter name="_sortIndex" type="Integer"/>
        <Parameter name="_trn" type="CM_Transaction"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="allowsTableFilters" id="37bfdd34-0720-4b84-beae-98b1aa7d9c9a">
        <source>allowsTableFilters(_table: Table): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2014	cnwndl1	Initial creation

*/

vars

begin
	if _table = self.tblTransactions then
		return true;
	endif;
	return false;

epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="applyColumnFilter" id="5c6ef9c8-ba07-46a7-84ba-b0472d1002f6">
        <updating/>
        <source>applyColumnFilter(_table: CM_DataTable io): Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2014	cnwndl1	Initial creation

*/

vars
	visibleCount : Integer;
begin
	if _table &lt;&gt; null then
		if _table.allowsColumnFilters then
			visibleCount := _table.applyColumnFilter( self.allColumnFilters );
			self.showSearchCriteria();
		endif;
	endif;
	
	return visibleCount;

epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="bolTransactionSearch" id="f8a16b43-3771-49ed-8f3e-c93999f9cb3b">
        <updating/>
        <source>bolTransactionSearch() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars
	user : CM_User;
	
	qDef : CM_QueryDefinition;
	myEnqController : CM_EnqControllerBOLTrans;
	criteriaHolder : CM_QueryCriteriaLineHolder;
	
	fromTimeStamp : TimeStamp;
	toTimeStamp : TimeStamp;
	dateArray : DateArray;
	
	iter : Iterator;
	bolTrx : CM_Transaction;
	atLimit: Boolean;
	now : TimeStamp;

begin
	user := app.getMyUser();
	
	// Get the correct definition
	qDef := app.myRoot.allQueryDefinitionObjects[ CM_QueryDefinition.Transaction_Query_Type, CM_QueryDefinition.BOLTransaction_Query_Mode ];
	
	// Create the query controller
	create myEnqController;
	create myEnqController.allObjects as  CM_TransactionSet transient;
	create criteriaHolder transient;
	myEnqController.myTerminal := self.myTerminal;
	myEnqController.myCriteriaLineHolder := criteriaHolder;
	
	
	//populate the query criteria
	
	//start with the terminal
	self.doCreateCriteriaLine(qDef, criteriaHolder, CM_BOLTransaction::myTerminal.name, CM_QueryOperator.Operator_Equal, self.myTerminal);
	
	fromTimeStamp.setDate(self.filterDateFrom);
	fromTimeStamp.setTime(self.filterTimeFrom);
	toTimeStamp.setDate(self.filterDateTo);
	toTimeStamp.setTime(self.filterTimeTo);
	now := app.actualTimeServer();
	
	if fromTimeStamp.Date.isValid and toTimeStamp.Date.isValid then
		create dateArray transient;
		dateArray.add(fromTimeStamp.Date);
		myEnqController.startDateTime.setTime(fromTimeStamp.Time);
		dateArray.add(toTimeStamp.Date);
		myEnqController.endDateTime.setTime(toTimeStamp.Time);
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_BOLTransaction::dateTime.name, CM_QueryOperator.Operator_Between, dateArray);
	elseif fromTimeStamp.Date.isValid then
	//	self.doCreateCriteriaLine(qDef, criteriaHolder, CM_BOLTransaction::dateTime.name, CM_QueryOperator.Operator_GreaterThan, fromTimeStamp.Date);
	//	myEnqController.startDateTime.setTime(fromTimeStamp.Time);
		//NDL 08 Nov 2019 - Use a range, cos can't include a from or to time in a Greater Than DATE
		create dateArray transient;
		dateArray.add(fromTimeStamp.Date);
		myEnqController.startDateTime.setTime(fromTimeStamp.Time);
		dateArray.add(now.Date);
		myEnqController.endDateTime.setTime('23:59:59:999'.Time);
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_BOLTransaction::dateTime.name, CM_QueryOperator.Operator_Between, dateArray);
	elseif toTimeStamp.Date.isValid then
	//	self.doCreateCriteriaLine(qDef, criteriaHolder, CM_BOLTransaction::dateTime.name, CM_QueryOperator.Operator_LessThan, toTimeStamp.Date);
	//	myEnqController.endDateTime.setTime(toTimeStamp.Time);
		//NDL 08 Nov 2019 - Use a range, cos can't include a from time in a Less Than DATE
		create dateArray transient;
		dateArray.add("01 Jan 2019".Date);	//No BOL transactions existed before this
		myEnqController.startDateTime.setTime('00:00:00:001'.Time);
		dateArray.add(toTimeStamp.Date);
		myEnqController.endDateTime.setTime(toTimeStamp.Time);
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_BOLTransaction::dateTime.name, CM_QueryOperator.Operator_Between, dateArray);
	endif;
	
	if self.filterTransactionType &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_BOLTransaction::getTransactionType.name, CM_QueryOperator.Operator_Equal, self.filterTransactionType );
	endif;
	
	if self.filterVoyage &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_BOLTransaction::getMyVoyage.name, CM_QueryOperator.Operator_Equal, self.filterVoyage );
	endif;
	
	if self.filterUser &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_BOLTransaction::getUserId.name, CM_QueryOperator.Operator_Equal, self.filterUser );	//09 Dec 2019	NDL	TFS 46875
	endif;

	
	if self.filterDebtor &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_BOLTransaction::getDebtorForSelector.name, CM_QueryOperator.Operator_Equal, self.filterDebtor );
	endif;
	
	if self.filterInvoiceNumber &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_BOLTransaction::getInvoiceNumber.name, CM_QueryOperator.Operator_Equal, self.filterInvoiceNumber );
	endif;
	
	if self.filterCharged &lt;&gt; null then
		if self.filterCharged = Not_Charged then
			self.doCreateCriteriaLine(qDef, criteriaHolder, CM_BOLTransaction::isCharged.name, CM_QueryOperator.Operator_Equal, false );
		elseif self.filterCharged = Is_Charged then
			self.doCreateCriteriaLine(qDef, criteriaHolder, CM_BOLTransaction::isCharged.name, CM_QueryOperator.Operator_Equal, true );
		endif;
	endif;
	
	//run the query
	myEnqController.myContext := self;
	myEnqController.doQuery( qDef );
	
	//populate the table
	iter := myEnqController.allObjects.CM_TransactionSet.createIterator;	
	while iter.next( bolTrx ) do
	
		if self.filterBusinessUnit &lt;&gt; null then
			if bolTrx.CM_BOLTransaction.getMyBank &lt;&gt; self.filterBusinessUnit then
				continue;
			endif;
		endif;
		
		atLimit := self.addObjectToCollection( bolTrx, user );	
		if atLimit then
			break;
		endif;
	endwhile;

epilog

	if myEnqController &lt;&gt; null then
		if myEnqController.myCriteriaLineHolder &lt;&gt; null then
			delete myEnqController.myCriteriaLineHolder;
		endif;
	endif;
	delete myEnqController;
	delete dateArray;

end;</source>
    </JadeMethod>
