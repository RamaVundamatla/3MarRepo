    <JadeMethod name="translateForm" id="e37703ae-54dd-4d71-8505-be35eeedfaff">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 September 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019809, locale);
	btnAccept.translateCaption(Xlat_0019810, locale);
	btnCanDir.translateCaption(Xlat_0019811, locale);
	btnDamage.translateCaption(Xlat_0019812, locale);
	btnGrading.translateCaption(Xlat_0019813, locale);
	btnLogoff.translateCaption(Xlat_0019814, locale);
	btnMoreTasks.translateCaption(Xlat_0019815, locale);
	btnPickup.translateCaption(Xlat_0019816, locale);
	btnPickupAll.translateCaption(Xlat_0019817, locale);
	btnPickupDir.translateCaption(Xlat_0019818, locale);
	btnReject.translateCaption(Xlat_0019819, locale);
	btnSetdown.translateCaption(Xlat_0019820, locale);
	btnSetdownAll.translateCaption(Xlat_0019821, locale);
	btnStops.translateCaption(Xlat_0019822, locale);
	btnToDo.translateCaption(Xlat_0019823, locale);
	btnWorking.translateCaption(Xlat_0019824, locale);
	lbDirAmount.translateCaption(Xlat_0019825, locale);
	lblAmount.translateCaption(Xlat_0019826, locale);
	lblSource.translateCaption(Xlat_0019827, locale);
	lblTarget.translateCaption(Xlat_0019828, locale);
	lblTaskCargo.translateCaption(Xlat_0019829, locale);
	lblTaskSource.translateCaption(Xlat_0019830, locale);
	lblTaskTarget.translateCaption(Xlat_0019831, locale);
	shtChecks.translateCaption(Xlat_0019832, locale);
	shtTask.translateCaption(Xlat_0019833, locale);
end;</source>
