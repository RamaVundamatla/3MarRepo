    <JadeMethod name="doCargoDisplay" id="52a0c60d-d293-4f5b-a5e4-9c7869476f3a">
        <updating/>
        <source>doCargoDisplay() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/07/2009	cnwndl1	Initial creation
10/03/2010	cnwdap1	PAR #22797 Clear myCurrentTI reference if no TI selected in the combo
*/
vars
	ti : CM_TrackedItem;
	operator : CM_Operator;
	destPort : String;
	isoType : String;
	displayString : String;
begin
	if cmbCargoID.listCount &gt; 0 and cmbCargoID.listIndex &gt; 0 then
		ti := cmbCargoID.itemObject[cmbCargoID.listIndex].CM_TrackedItem;
	else
		self.doAutoFindCargo( cmbCargoID );
		if cmbCargoID.listCount &gt; 0 and cmbCargoID.listIndex &gt; 0 then
			ti := cmbCargoID.itemObject[cmbCargoID.listIndex].CM_TrackedItem;
		endif;
	endif;
	if ti = null then
		lblCargoDetail.caption := null;
		self.myCurrentTI := null;		// PAR #22797
	else
		self.myCurrentTI := ti;
		operator := ti.myOperator;
		if operator &lt;&gt; null then
			displayString := operator.code &amp; "  ";
		endif;
		destPort := ti.destinationPort;
		displayString := displayString &amp; destPort &amp; "  ";
		if ti.isContainer then
			isoType := ti.CM_Container.isoType;
		endif;
		displayString := displayString &amp; isoType;
		lblCargoDetail.caption := displayString;
		//self.cmbCargoType.listObject := ti.myCargoType;
		self.cmbCargoType.listIndex := self.cmbCargoType.findObject( ti.myCargoType );	//10 Sep 2015	NDL	Par 36390
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
