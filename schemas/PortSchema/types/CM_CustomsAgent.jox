    <JadeMethod name="setForCreate" id="604a7df4-f8bb-4ed6-b24e-17716af84843">
        <updating/>
        <source>setForCreate(_pxyCA:CM_CustomsAgent) updating;
// ---------------------------------------------------------------------------
// Created:		February 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin

	_pxyCA.raiseExceptionIfNotTransient(method);
	
	setForUpdate(_pxyCA);
	self.myRoot := app.myRoot;

end;</source>
        <Parameter name="_pxyCA" type="CM_CustomsAgent"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="99528f8c-83ba-4336-b5fd-d9c7b028b970">
        <updating/>
        <source>setForUpdate(_proxy :CM_CustomsAgent) updating;
// ---------------------------------------------------------------------------
// Created:		February 2006 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------// 15/04/2013	cnwcs5		CCMS POL 2097 / par 31259
// 15/04/2013	cnwcs5		CCMS POL 2097 / par 31259
vars

begin
	// par 31259 - make sure xlations updated with new code
	if self.code &lt;&gt; _proxy.code then
		self.updateXlations_Code (_proxy.code.String, self.code.String, self.allXlations);
	endif;

	
	self.code 					:= _proxy.code;
	self.name 					:= _proxy.name.trimBlanks;
	self.isNotAvailableForEntry	:= _proxy.isNotAvailableForEntry;
	self.myDebtor 				:= _proxy.myDebtor;
end;</source>
        <Parameter name="_proxy" type="CM_CustomsAgent"/>
    </JadeMethod>
