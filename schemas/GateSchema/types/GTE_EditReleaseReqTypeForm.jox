<GUIClass name="GTE_EditReleaseReqTypeForm" id="d099de57-a644-4b2a-8fb4-698b33397852">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>cnwcs5 28/11/2011 - CCMS POL 2122 - PAR 28696 - Coparn Empty Releases
</text>
    <ImplicitInverseRef name="allReleaseRequests" id="e9b36d8b-56ff-42a7-9612-eff7cd86a0a8">
        <memberTypeInverse/>
        <type name="CM_BulkReleaseSet"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="cmbType" id="51ba41c4-7a2d-4620-a7bb-cd9d2f665e12">
        <embedded/>
        <type name="CMUI_ComboBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblInstructions" id="903bc8d8-93cc-4e40-b851-7af310ee9005">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblType" id="8aca5c25-64e6-4062-b4cd-b81b29539f0b">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <JadeMethod name="doOK" id="ce46e4e8-47e5-40c1-920c-0fecfff25617">
        <updating/>
        <source>doOK() updating;
/*
Date		Who		Reason
28 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	type		: Integer;
	result		: Integer;
begin
	if self.cmbType.listIndex = CNEC_NULL_INDEX then
		// Please select a Status for this operation
		app.msgBox(	app.getString( NothingSelected, self.lblType.caption ),
					app.getString( Nothing_Selected ),
					MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_First );
		self.cmbType.setFocus;
		return;
	else
		type	:=	self.cmbType.itemData[ self.cmbType.listIndex ];
	endif;
	
	while true do : transaction_loop
		app.myTrxUA.trxSetReleaseRequestsType( type, self.allReleaseRequests, app.myPassport );
		
		if app.myPassport.trxCompletedOK() then
			// Clear errors/warnings from form and err/warnings window.
			self.clearErrorWarnings();
			break transaction_loop;
		else
			result	:=	app.showErrorWarningDialog(	self.caption, app.myPassport,
													ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings );
			
			if app.myPassport.noErrors() and result = IDOK then
				// There must have just been warnings that the user has acknowledged so...
				app.myPassport.warningsAcknowledged	:=	true;
				continue transaction_loop;
			endif;
			
			self.setAllErrorWarnings( app.myPassport );	// Copies errors to this form and shows in err/warnings window.
		endif;
		break transaction_loop;
	endwhile transaction_loop;
	
	if result = IDOK then				// otherwise unloads the form!
		inheritMethod();
	endif;
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="setAllReleaseRequests" id="9c1c0082-1bb5-494d-9fea-73e8bce0f6de">
        <updating/>
        <source>setAllReleaseRequests(_value : CM_BulkReleaseSet ) updating;
/*
Date		Who		Reason
28 Nov 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	coll	:CM_BulkReleaseSet;
begin
	coll	:= self.allReleaseRequests;
	
	coll.clear;
	_value.copy( coll );
epilog

end;</source>
        <Parameter name="_value" type="CM_BulkReleaseSet"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="63fef4a1-ec70-426d-b5c9-3f50cf54c283">
        <updating/>
        <source>setupForm() updating;
/*
Date		Who		Reason
28 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	terminal	:CM_Terminal;
begin
	if self.allReleaseRequests.isEmpty() then
		// Please select a Release request for this operation
		app.msgBox(	app.getString( NothingSelected, app.getString( Release_request ) ),
					app.getString( Nothing_Selected ),
					MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_First );
		self.unloadForm();
		return;
	endif;

	inheritMethod();
	
	// load the combo with the valid types
	terminal := self.myTerminal;
	
	self.myAssistant.comboBoxReleaseType (self.cmbType, 
											app.myCurrentUserCan(terminal, PmGteMTReleaseViewRd), 
											app.myCurrentUserCan(terminal, PmGteMTReleaseViewRail),
											app.myCurrentUserCan(terminal, PmGteMTReleaseViewGen),
											app.myCurrentUserCan(terminal, PmGteMTReleaseViewShip),
											app.myCurrentUserCan(terminal, PmGteMTReleaseViewUnknown),
											false);
	self.cmbType.setFocus();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="a304520b-fa04-4c34-b074-58a42d525bb3">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018148, locale);
	lblInstructions.translateCaption(Xlat_0018149, locale);
	lblType.translateCaption(Xlat_0018150, locale);
end;</source>
    </JadeMethod>
</GUIClass>
