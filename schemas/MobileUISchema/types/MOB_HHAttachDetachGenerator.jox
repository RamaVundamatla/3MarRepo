    <JadeMethod name="setupControls" id="4f055980-01ba-4f3c-9c2a-db9a92fa6792">
        <updating/>
        <source>setupControls()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers

*/

vars
	date		: TimeStamp;
begin
	date 	:= self.systemToLocalTime(app.actualTimeServer());
	
	self.doResizeControls(true);
	
	self.txtDate.setDate(date.date());
	self.txtTime.setTime(date.time());
	
	self.populateTrackedItem();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="bd208e67-ebd2-454e-9573-ed8e55b838d0">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers

*/

vars
	ti : CM_TrackedItem;
	isAttach : Boolean;
	lblAction : String;
begin
	
	
	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;
	
	ti := app.myMobileCargoFindAgent.myTrackedItemToProcess;
	if ti &lt;&gt; null then
		//returning from a specific search
		self.setMyTrackedItem(  app.myMobileCargoFindAgent.myTrackedItemToProcess );
	else
		// populated on one of the other maint forms
		self.setMyTrackedItem( self.getSessionAgent().mySelectedTI );
	endif;
	
	if isAttach then
		lblAction := app.getErrorString(Attach);
	else
		lblAction := app.getErrorString(Detach);
	endif;
	
	inheritMethod();
	self.setupCmdButtons( 3, lblAction, app.getErrorString(Cancel),BACK_BUTTON ,null,null);
	self.showHideControls(true,false);
	
	self.setupControls();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showHideControls" id="2a2f167e-8651-4ce5-885f-4a2b9a0f6faa">
        <source>showHideControls(_intialSetup ,_isAttach: Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers

*/

vars

begin
	if _intialSetup then
		self.btnOne.enabled := false;
		self.lblDate.visible := false;
		self.txtDate.visible := false;
		self.lblTime.visible := false;
		self.txtTime.visible := false;
		self.lblLocation.visible := false;
		self.txtLocation.visible := false;
		self.lblNoCharge.visible := false;
		self.chkNoCharge.visible := false;
	
	endif;
	
	if _isAttach then
	   if not _intialSetup then
			self.btnOne.enabled := true;
			self.lblDate.visible := true;
			self.txtDate.visible := true;
			self.lblTime.visible := true;
			self.txtTime.visible := true;
			self.lblLocation.visible := true;
			self.txtLocation.visible := true;
			self.lblNoCharge.visible := true;
			self.chkNoCharge.visible := true;
			self.txtGenerator.enabled := true;
			//Disable location
			self.txtLocation.enabled := false;
		endif;
	else
		 if not _intialSetup then
			self.btnOne.enabled := true;
			self.lblDate.visible := true;
			self.txtDate.visible := true;
			self.lblTime.visible := true;
			self.txtTime.visible := true;
			self.lblLocation.visible := true;
			self.txtLocation.visible := true;
			self.lblNoCharge.visible := true;
			self.chkNoCharge.visible := true;
			
			self.txtGenerator.enabled := false;
			//Enable location
			self.txtLocation.enabled :=true;
		endif;
	endif;
	

epilog

end;</source>
        <Parameter name="_intialSetup" type="Boolean"/>
        <Parameter name="_isAttach" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="c4ff74c6-ae51-4ea0-a19b-6e274d117f9b">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 22 March 2018 11:31:01.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022211, locale);
	lblCargoId.translateCaption(Xlat_0022212, locale);
	lblDate.translateCaption(Xlat_0022213, locale);
	lblGeneratorId.translateCaption(Xlat_0022214, locale);
	lblLocation.translateCaption(Xlat_0022215, locale);
	lblNoCharge.translateCaption(Xlat_0022216, locale);
	lblTime.translateCaption(Xlat_0022217, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_gotFocus" id="c59b7f7c-6b4a-45aa-a532-d1d1ce91428c">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers

*/

vars

begin
	self.txtCargoId.selStart := 0;
	self.txtCargoId.selLength := self.lblCargoId.caption.length;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_keyPress" id="a2840222-ff75-4415-bb96-ab4eb2db93ef">
        <controlMethod name="TextBox::keyPress"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_keyPress(textbox: TextBox input; keyCharCode: Integer io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
*/

vars

begin
	if keyCharCode = J_key_Enter then
		app.convertScannedCargoId( self.myTerminal, textbox, false, null );
		self.doClickPartCargoIdSearch();
	endif;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="keyCharCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_lostFocus" id="a2dda8db-77da-42ff-9abd-0aa4eaa3024b">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers

*/

vars

begin
	app.convertScannedCargoId( self.myTerminal, textbox, false, null );

	if self.txtCargoId.text = self.lblCargoId.caption.toUpper then
		self.setMyTrackedItem( null );
		//do nothing
	elseif self.txtCargoId.text.trimBlanks = null then
		self.setMyTrackedItem( null );
		self.txtCargoId.text := self.lblCargoId.caption.toUpper;
	else
		if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.id &lt;&gt; self.txtCargoId.text then
			self.selectCargoItem( false );
		endif;
	endif;
	
	self.txtCargoId.selStart := 0;
	self.txtCargoId.selLength := 0;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
