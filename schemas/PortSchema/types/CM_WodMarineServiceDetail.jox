    <JadeMethod name="pxyCreateUpdateProxy" id="6fba7d8c-6d34-44fe-b159-71ceca4f3a85">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2018	jlger1	Initial creation

*/

vars
	pxySelf : CM_WodMarineServiceDetail;
	completedOK  : Boolean;
begin
	pxySelf:= inheritMethod();
	pxySelf.myHMSResource:=self.myHMSResource;
	pxySelf.myHMSResourceType := self.myHMSResourceType;	//26 Nov 2018	NDL	TFS 41980
	pxySelf.myDebtor := self.myDebtor;		//26 Nov 2018	NDL	TFS 41980
	
	completedOK :=true;
	return pxySelf;
epilog
	if not completedOK then
		delete pxySelf;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="6a09ea71-f5df-432d-a9bd-b78c0045fa73">
