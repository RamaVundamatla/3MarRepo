<Class name="CMIF_RestrictionsForMenu" id="6679311b-cc56-4774-9d8a-e1d1776c9f7a">
    <superclass name="CMIF_Object"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>This class is used to interrogate restriction &amp; total containers
for a terminal area, to load to dynamic menus.</text>
    <PrimAttribute name="hasRestriction" id="e17d3168-edb4-4553-b613-bfdb435be8e2">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="isoType" id="9f733d67-ebc4-47f6-94bd-e0e9e944570b">
        <length>5</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="operatorCode" id="cffc7b13-dd9f-4919-b827-71382efc041d">
        <length>5</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="terminalArea" id="3fbe7a6e-cce2-49bd-b360-49804613db92">
        <length>14</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="totalInArea" id="e1681c8b-3037-486d-a7df-b3cac102fabe">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="washed" id="d52f0bce-b65c-4d0a-aa83-a10deff1c3a7">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
</Class>
