    <JadeMethod name="getTotalActionedForAnyAmount" id="129fa457-ac71-441f-aa45-307238d2a6f0">
        <source>getTotalActionedForAnyAmount(_weight : Decimal output) : Integer;
/*

Purpose:				AnyAmount requests don't have a totalRequested value so need to get the total
						from the wles that are being actioned

Parameters:			

Return Value:		

Date					Who		Reason
14 November 2022		jlizm1	Initial creation TFS 54118 Assigning Releases to Wagons

*/

vars

	wle : CM_WorkListEntry;
	qty : Integer;
	
begin

	if not self.isAnyAmount then
		return qty;
	endif;
	
	foreach wle in self.allWorkListEntries do 
		if wle.myTrackedItem &lt;&gt; null and wle.myTrackedItem.isRRP then
			continue;
		endif;
		
		qty := qty + wle.getQuantity;
		if wle.weight = 0 and wle.myTrackedItem &lt;&gt; null then
			_weight := wle.myTrackedItem.totalWeight;
		else
			_weight := _weight + wle.weight;
		endif;
	endforeach;
	
	return qty;
	
epilog

end;</source>
        <Parameter name="_weight" type="Decimal" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalRequested" id="f78684c2-6200-451c-ba4e-e8fde5cc64a2">
        <source>getTotalRequested(): Integer;

vars
	numReleased 	: Integer;
	reserveDetail	: CM_ReserveDetail;
begin
	
	// This is the number of WLEs to be created for the request
	if self.totalRequested &gt; 0 then
		numReleased := 0;
		//PAR16052 Check for a reserve detail first.
		
		reserveDetail := self.myReserveDetail;
		
		if reserveDetail &lt;&gt; null then
			// PAR 19710 Rail BR now pass through what is left, cos the user can amend this
			if reserveDetail.isRailType() or reserveDetail.isRoadType() then 	//SFW1035
				return self.totalRequested;
			endif;
			
			numReleased := reserveDetail.allTrackedItemsReleased.size;
		endif;
		
		return self.totalRequested - numReleased;// PAR 16929 put back
	endif;
	
	return 1;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getVbsti" id="5d46af92-08fa-4289-9b86-dfcb465635ba">
        <source>getVbsti() : CM_VehicleBookingTimeSlotItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 October 2024	navpw1	Initial creation JIRA: MTN-14770

*/

vars
	gateEntity : CMGTE_Entity;
	
begin
	gateEntity := self.myGateEntity;
	if gateEntity = null then
		return null;
	endif;
	
	return gateEntity.myVbsti;
	
end;</source>
        <ReturnType type="CM_VehicleBookingTimeSlotItem"/>
