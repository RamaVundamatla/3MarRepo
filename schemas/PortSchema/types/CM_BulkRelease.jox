    <JadeMethod name="getTotalStaged" id="1746c783-5b8e-4fe8-a9eb-af4ea12e2d6b">
        <source>getTotalStaged( _tiSet : CM_TISet input; _firstStagingLC : CM_LocationsController output ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 October 2015	cnwndl1	Initial creation	Par 37033

*/

vars

	reserveDetail: CM_ReserveDetail;
	iter : Iterator;
	count : Integer;
	firstStagingLC : CM_LocationsController;
	
begin

	iter := self.allReserveDetails.createIterator;
	while iter.next(reserveDetail) do
		count := count + reserveDetail.getTotalStaged( _tiSet, firstStagingLC, null );
		if _firstStagingLC = null then
			_firstStagingLC := firstStagingLC;
		endif;
	endwhile;
	
	return count;

epilog

	delete iter;

end;</source>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
        <Parameter name="_firstStagingLC" type="CM_LocationsController" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalStorageEmpties" id="935a2abc-527c-4350-8c9d-b3e8b99291a6">
        <source>getTotalStorageEmpties(): Integer;
//----------------------------------------------------------------
//	Created:	17 March 2005	by Jason Chapman  (cnwjc2)
//
//	total storage empties waiting to be released
//
//----------------------------------------------------------------
vars
	res		: CM_ReserveDetail;
	ti		: CM_TrackedItem;
	count	: Integer;
begin
//	if self.getDeliveryRequest(false) &lt;&gt; null then
//		return (self.totalRequested - self.releasedItemStrings.size);
//	endif;

	// PAR 12374
	if self.releaseByType then
		// check that there are still some items remaining to
		// be delivered.
		//return self.getTotalOutstanding();
		return self.getMTTotalOutstanding();	//13 Apr 2012	NDL	Par 28931
	endif;

	count := 0;
	//need to count if any of the attached items are storage empty and are not released as yet
	foreach ti in self.allTrackedItemsAssigned do
		if (ti.isStorage and ti.isEmpty)
		and ti.isContainer and ti.getISOTypeObject &lt;&gt; null and ti.getISOTypeObject.isContainer	///13 Apr 2012	NDL	Par 28931
		and (not self.allTrackedItemsReleased.includes(ti)) then
			count := count + 1;
		endif;
	endforeach;
	
	return count;	
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalVolumeRequested" id="b53cad00-0609-4a69-bd99-d213272f3992">
        <source>getTotalVolumeRequested() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2014	cnwmc5	Initial creation	PAR 33988

*/

vars
	reserveDetail			: CM_ReserveDetail;
	total					: Decimal[12,2];
	measureType				: CM_MeasurementType;
begin
	measureType := app.getDefaultMeasurementForType(Type_Volume);
	
	foreach reserveDetail in self.allReserveDetails do
		if reserveDetail.isKindOf(CM_ReserveSelection) then
			total := total + reserveDetail.CM_ReserveSelection.volumeSelection;
		endif;
	endforeach;

	return app.convertMeasurementForDisplay(measureType.shortName, total);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
