<Class name="TranslatableString">
    <JadeMethod name="analyseAllRefs" id="49d611c6-1dba-4716-a3ed-683b4f34ede9">
        <source>analyseAllRefs(appSchemas : SchemaColl; directScriptRefs, indirectScriptRefs, directMethodRefs, indirectMethodRefs : FeatureSet input);

// Analyse and return script and method references (localisation)

vars
	scriptRefs	: FeatureUsageSet;
	scriptUsage	: FeatureUsage;
	feature		: Feature;
begin
	// script references
	
	create scriptRefs transient;
	getScriptRefs(scriptRefs);
	foreach scriptUsage in scriptRefs do
		feature := scriptUsage.getPropertyValue('feature').Feature;
		
		// assume script refs are other translatable strings
		feature.TranslatableString.analyseMethodRefs(appSchemas, directScriptRefs, indirectScriptRefs);
	endforeach;


	// method references
	analyseMethodRefs(appSchemas, directMethodRefs, indirectMethodRefs);

end;</source>
        <Parameter name="appSchemas" type="SchemaColl"/>
        <Parameter name="directScriptRefs" type="FeatureSet" usage="input"/>
        <Parameter name="indirectScriptRefs" type="FeatureSet" usage="input"/>
        <Parameter name="directMethodRefs" type="FeatureSet" usage="input"/>
        <Parameter name="indirectMethodRefs" type="FeatureSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="analyseMethodRefs" id="121767f6-e1aa-48d0-b501-240b09e6ef90">
        <source>analyseMethodRefs(appSchemas : SchemaColl; directRefs, indirectRefs : FeatureSet input);

// Analyse and return method references (localisation)

vars
	visited 	: FeatureSet;
	meths 		: MethodSet;
	mySchema 	: Schema;
	ref			: Feature;
begin
	create visited transient;
	mySchema := getMySchema;

	// only interested in direct method references if in application schema
	if appSchemas.includes(mySchema) then	
		create meths transient;
		getMethodRefs(meths);
		// add each method (once) to the reference list
		foreach ref in meths where directRefs.includes(ref) = false do
			directRefs.add(ref);
		endforeach;
	else
		getRefs(mySchema, appSchemas, indirectRefs, visited);
	endif;
	
epilog
	delete meths;
end;</source>
        <Parameter name="appSchemas" type="SchemaColl"/>
        <Parameter name="directRefs" type="FeatureSet" usage="input"/>
        <Parameter name="indirectRefs" type="FeatureSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getLocaleName" id="98f54228-d2fe-45de-84c5-c2ad2a383c64">
        <source>getLocaleName():String;

vars

begin
	return locale.name;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMySchema" id="7c38a1a6-45d6-4d09-95c7-098ff0afdc2a">
        <source>getMySchema():Schema;

vars

begin
	return locale.getPropertyValue('schema').Schema;
end;</source>
        <ReturnType type="Schema"/>
    </JadeMethod>
</Class>
