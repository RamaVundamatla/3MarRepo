    <JadeMethod name="doOK" id="dd5c60b3-ff8c-462b-bfc4-f3144046e90a">
        <updating/>
        <source>doOK() updating;

/*
Date			Who		Reason
07 July 2009	cnwar2	Initial creation

*/
vars
	pxyKiosk : CM_Kiosk;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	pxyKiosk := self.myProxyObject.CM_Kiosk;
	
	pxyKiosk.setProxy(	txtCode.text,
						txtDescription.text,
						txtMachineName.text,
						self.myTerminal,
						pxyKiosk.myPrimaryLocale,
						pxyKiosk.allLocales,
						pxyKiosk.noPassengersEnabled,
						pxyKiosk.maxAllowedPassengers,
						pxyKiosk.securityEmailAddresses,
						pxyKiosk.allowEditTransitDetails,
						pxyKiosk.trailerTypeEnabled); //jlier1 TFs 58511 3/8/23
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		if self.mode = self.Mode_Add then
			app.myTrxCA.trxCreateKiosk(pxyKiosk, self.updateObject, app.myPassport);
		else
			app.myTrxUA.trxUpdateKiosk(pxyKiosk, app.myPassport);
		endif;
	
		if app.myPassport.trxCompletedOK then
			inheritMethod();	// unload form
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Gate_configuration), app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c7fdd93f-3f36-4a86-b7b7-aa72eecf35d2">
        <updating/>
        <source>setupForm() updating;

/*
Date			Who		Reason
07 July 2009	cnwar2	Initial creation

*/
vars
	kiosk : CM_Kiosk;
	
begin
	inheritMethod();
	
	if mode = self.Mode_Update then
		self.myProxyObject 	:= app.createUpdateProxy(self.updateObject);
		kiosk				:= self.myProxyObject.CM_Kiosk;
		
		self.txtCode.text			:= kiosk.code;
		self.txtDescription.text	:= kiosk.description;
		self.txtMachineName.text	:= kiosk.machineName;
		
	else
		create self.myProxyObject as CM_Kiosk transient;
		
		self.txtCode.text			:= "";
		self.txtDescription.text	:= "";
		self.txtMachineName.text	:= "";
		self.btnOk.caption			:= app.getErrorString(AddUpper);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="a826c06e-c20a-4c11-a170-48674dd6505c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0011657, locale);
	lblCode.translateCaption(Xlat_0011658, locale);
	lblDescription.translateCaption(Xlat_0011659, locale);
	lblMachineName.translateCaption(Xlat_0011660, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unloadForm" id="89399019-3a53-4b48-93a0-a5680e55ce0b">
        <updating/>
        <source>unloadForm(): Boolean updating;

/*
Date			Who		Reason
10 July 2009	cnwar2	Initial creation

*/
vars

begin
	delete self.myProxyObject;
	return inheritMethod();

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
