    <JadeMethod name="cmbIncludeFormatPopulate" id="c4f4602b-c728-4a72-84ba-5f3454a37689">
        <source>cmbIncludeFormatPopulate() protected;

vars
	formatObj			: CnEcXmlFormat;
	xmlFormatCollObj	: CnEcXmlFormatDict;
	
begin
	cmbIncludeFormat.clear();
	create xmlFormatCollObj transient;
	app.myBaseRoot.getAllFormatsForSchema(xmlFormatCollObj, app.myCnEcXmlSchema.name);
	
	foreach formatObj in xmlFormatCollObj do
    	cmbIncludeFormat.itemObject[cmbIncludeFormat.addItem(formatObj.formatName)] := formatObj;
    endforeach;
epilog 
	delete xmlFormatCollObj;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cmbOutputFormatsPopulate" id="12a00218-d17c-4636-9291-7eb80f7fbc22">
        <source>cmbOutputFormatsPopulate() protected;

vars
	formatObj			: CnEcXmlFormat;
	xmlFormatCollObj	: CnEcXmlFormatDict;
	
begin
	cmbOutputFormats.clear();
	create xmlFormatCollObj transient;
	app.myBaseRoot.getAllFormatsForSchema(xmlFormatCollObj, app.myCnEcXmlSchema.name);

	foreach formatObj in xmlFormatCollObj do	
    	cmbOutputFormats.addItem(formatObj.formatName);
    	
    	if formatObj.getGodBit() &gt; 0 then
    		cmbOutputFormats.itemEnabled[cmbOutputFormats.newIndex] := false;
    	endif;
    endforeach;
    
    lstFormatClasses.clear();
    btnAddLiteral.enabled	:= false;
    btnSample.enabled		:= false;
    btnAddMethod.enabled	:= false;
    lstFormatAttribs.clear();
    self.clearPropertyPanel();	
epilog 
	delete xmlFormatCollObj;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cmbOutputFormats_click" id="7d7bd99a-da03-48e6-9648-23b4f8325b9a">
        <controlMethod name="ComboBox::click"/>
