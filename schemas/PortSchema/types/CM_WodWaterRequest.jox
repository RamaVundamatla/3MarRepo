    <JadeMethod name="isTaxExempt" id="3930d286-e718-4d4e-81ca-3ce3618aa9cd">
        <source>isTaxExempt(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2019	jlger1	Initial creation refactored part of TFS 44550

*/

vars
	voyage : CM_Voyage;
begin
	
	voyage := self.getMyVoyageObject;
	if voyage = null then
		return false;
	endif;
	
	if voyage.myVoyageProcess.isMTNWOProcess  then //jlier1 TFS 51963 1/10/21
		return true;
	endif;
	
	return false;

epilog

end;</source>
