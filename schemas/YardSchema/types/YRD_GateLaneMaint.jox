    <JadeMethod name="delete" id="54a7e86d-1238-403b-82cd-331336eb571c">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
/*

Purpose:	Delete Proxies for all ways  of leaving the form		
			Added for PAR 18175 
Parameters:			

Return Value:		


Date		Who		Reason
13 October 2008	cnwer1	Initial creation

*/

vars

