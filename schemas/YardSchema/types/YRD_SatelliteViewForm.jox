    <JadeMethod name="doProgressUpdate" id="a0b3f6a9-2ca5-4a44-98be-dde720708198">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CMUI_Progress::updateProgress"/>
        </interfaceImplements>
        <updating/>
        <source>doProgressUpdate(_message : String; _partsInJob : Integer; _partsDone : Integer) updating;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2010	cnwer1	Initial creation
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	intervalSinceLastUpdate, 
	interval : TimeStampInterval;
	now 	: TimeStamp;
begin
	self.lblModalMessage.caption:=_message;
	
	now:=app.actualTimeServer;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	intervalSinceLastUpdate:= now -self.lastProgressUpdateDT;
	if intervalSinceLastUpdate.getMilliseconds &lt; 2000 then
		return;
	endif;
	self.lastProgressUpdateDT:=now;
	interval:=self.lastProgressUpdateDT - self.progressStartDT;

	self.lblModalInfo.caption:="Elapsed Time : " &amp; interval.display;
	
	
	self.frmModalDialog.refreshNow;
epilog

end;</source>
