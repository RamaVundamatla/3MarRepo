    <JadeMethod name="currencyRoundedUp" id="c797c419-5d80-4baf-b06d-1363717dd7fc">
        <source>currencyRoundedUp():Decimal;
// ---------------------------------------------------------------------------
// Created:     07 November 2002		cnwth2	
//
// Purpose:     Returns a monetary value that is always rounded up as long as the tenth of a cent is 
//				not zero.
//				ie. 3.410 stays at 3.410, but 3.411 becomes 3.420 
//			 
// ----------   ----------  --------------------------------------------------
vars
	dollarAmount		: Integer;
	tenthCent			: Integer;
	roundedAmount		: Decimal[12, 2];
	modResult			: Integer;
begin
	
	dollarAmount	:=	self.Integer;
	tenthCent		:= 	((self - dollarAmount) * 1000).Integer;
	modResult := tenthCent mod 10;
	
	if modResult &lt;&gt; 0 then
		tenthCent := (tenthCent + (10 - modResult)).Integer;
	else
		return self;
	endif;
	
	roundedAmount := dollarAmount + tenthCent / 1000;
	return roundedAmount;
	
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
