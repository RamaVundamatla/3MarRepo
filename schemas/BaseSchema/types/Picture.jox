<GUIClass name="Picture">
    <JadeMethod name="cnEcBrowseForPicture" id="224af60a-2917-4f09-93f9-796d8e016122">
        <updating/>
        <source>cnEcBrowseForPicture():Boolean updating;
// --------------------------------------------------------------------------------
// Created:		09 October 2004 by cnwdad1
//
// Purpose:		Browses for an image file, and loads it into the receiver.
//
// Parameters:	None
//
// Returns:		True if an image is loaded, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fileObj		: CnEcFile;
	imageBlob	: Binary;
	
begin
	create fileObj transient;
	fileObj.kind	:=	File.Kind_Binary;
	
	if fileObj.cnEcSetOpenName(true, false, null) then
		imageBlob	:=	fileObj.readBinary(fileObj.fileLength());
		
		if imageBlob &lt;&gt; null then
			self.picture	:=	imageBlob;
			
			return true;
		endif;
	endif;
	
	return false;
epilog
	delete fileObj;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcSet" id="789d3a78-afb8-4e95-a789-61053777e949">
        <updating/>
        <source>cnEcSet(pValue:Binary) updating;
// --------------------------------------------------------------------------------
// Created:		13 August 2002 by cnwdad1
//
// Purpose:		Updates the receiver's picture binary with the specified value.
//
// Parameters:	pValue - The string value to set the text to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.picture &lt;&gt; pValue then
		self.picture	:=	pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Binary"/>
    </JadeMethod>
</GUIClass>
