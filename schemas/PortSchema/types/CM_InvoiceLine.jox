    <JadeMethod name="getUncreditedAmount" id="46a1b731-7b8f-4332-99aa-c3e11cd3b404">
        <source>getUncreditedAmount() : Decimal;
// 37141 return the total less any cash credits, used to determine how much more credit can be applied
vars
//	amount		: Decimal[16, 6];
	payment		: CM_CashPayment;
	amount		: Decimal[23, 6];	//11 May 2018	NDL	TFS 38528
begin
	foreach payment in self.allCashPayments do
		amount := amount + payment.getUncreditedAmount();
	endforeach;
	
	return amount;
end;
</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getUnitNarrFromInvoiceLocale" id="da706db9-19c5-425f-acef-6562c3475535">
        <source>getUnitNarrFromInvoiceLocale() : String;
/*

Purpose:			Gets the unit narration for the invoice's locale

Parameters:			NONE

Return Value:		String	Representing the unit narration translated into the invoice's locale

Date		Who		Reason
05 September 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

vars
	locale 					: CM_Locale;
	lcid					: String;
	invoiceLineType 		: CM_InvoiceLineDesc;
	invoiceLineNarration 	: CM_InvoiceLineNarration;
	coll					: CM_InvoiceLineNarrationSet;
	
begin
	if self.invoiceLineDesc = null then
		return null;
		
	endif;
	
	if self.invoice = null then
		return null;
		
	endif;
	
	locale 			:= self.invoice.myLocale;
	invoiceLineType := self.invoiceLineDesc;
	
	if locale = null then
		return invoiceLineType.unitNarration;
	endif;
	
	lcid := locale.localeId;
	
	coll := invoiceLineType.allInvoiceLineNarrations;
	
	foreach invoiceLineNarration in coll where invoiceLineNarration.myLocale.localeId = lcid do
		return invoiceLineNarration.unitNarration; //Return the narration if we have one
	endforeach;
	
	return invoiceLineType.unitNarration; //If we do not a find narration for the locale return the invoice line type narration.

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUnpaidAmount" id="3d81cda1-44aa-4aef-b9c6-44247d9c623b">
        <source>getUnpaidAmount() : Decimal;
// 34917 return the unpaid balance
// 06/09/2016 cnwma1 TFS# 2539:PAR38133 ADP -Cash Value Increase by Fills
vars
//	result,
//	cashTotal	: Decimal[16, 6];
	payment		: CM_CashPayment;
	result, cashTotal	: Decimal[23, 6];	//11 May 2018	NDL	TFS 38528
	qty, rate, cashtot :  Decimal[23, 6];
	
begin
	foreach payment in self.allCashPayments do
		// skip voided payments
		if payment.voided then
			continue;
		endif;
		cashTotal := cashTotal + payment.cashValue;
	endforeach;
	
	// ### JIRA 34855 12APR2025 NAVAB1
	qty := self.quantity;
	rate :=  self.totalRate; // ### JIRA 35502 18JUL2025 NAVAB1 use static value not self.getRate;
	cashtot := cashTotal;
	
	// ### JIRA 35502 18JUL2025 NAVAB1 result := (self.quantity * self.getRate).Decimal.asDecimal(23, $CM_ChargeQuantity.decimalPlaces)- cashTotal; //06/09/2016 cnwma1 TFS#2539 // ### JIRA 34855 12APR2025 NAVAB1  changed from 12 to 23
	result := self.totalAmount - cashTotal; //06/09/2016 cnwma1 TFS#2539 // ### JIRA 34855 12APR2025 NAVAB1  changed from 12 to 23

	return result;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getUnpaidInvLineForProforma" id="5b3b41b0-df57-4467-b860-d5c8c7a79286">
        <source>getUnpaidInvLineForProforma() : CM_InvoiceLine;
/*

Purpose:		// TFS 37963	

Parameters:			

Return Value:		

Date		Who		Reason
09 April 2018	jlgab1	Initial creation

*/

vars
	unpaidLine : CM_InvoiceLine;
    charge : CM_Charge;
	remarks : String;
//	unpaid : Decimal[16,6];
	unpaidQ : Real;
	service : CM_Service;
	unpaid : Decimal[23,6];	//11 May 2018	NDL	TFS 38528
begin
	unpaid := self.getUnpaidAmount();
	unpaidQ := self.getUnpaidQuantity();
	
	
	remarks := "Owing - " &amp; self.invoiceLineDesc.narration;
	remarks := remarks &amp; " (x" &amp; unpaidQ.roundedTo(4).String &amp; ")";
	remarks := remarks &amp; " " &amp; unpaid.asCurrencyJMT();

	create unpaidLine transient;
	unpaidLine.setForCreate(	Max_Integer,	//_sequenceNum : Integer;
								true,	//_manual : Boolean;
								remarks,	//_remarks : String;
								self.invoiceLineDesc,	//_invoiceLineDesc : CM_InvoiceLineDesc;
								null,	//_invoice : CM_Invoice;
								null,	//_debtor : CM_Debtor;
								self.bank,	//_bank : CM_Bank;
								1,	//_quantity : Real;
								self.chargeTime	//_chargeTime : TimeStamp
								);
	
	unpaidLine.setTrackedItem( self.trackedItem );
	
	service := self.charges.first.service;
	
	create charge transient;
	charge.setForCreate(	null,
							unpaidLine, 
							Max_Integer,
							service);
	charge.total := unpaid;


	return unpaidLine;
epilog

end;</source>
        <ReturnType type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="getUnpaidQuantity" id="b251b6ad-5120-4989-a4eb-e04ce90646c4">
        <source>getUnpaidQuantity() : Real;
/*

Purpose:			// TFS 37963

Parameters:			

Return Value:		

Date		Who		Reason
10 April 2018	jlgab1	Initial creation

*/

vars
	payment		: CM_CashPayment;
	totalCashQuantity, unpaid : Real;
begin
		foreach payment in self.allCashPayments do
			if payment.myProformaDetail &lt;&gt; null then
				totalCashQuantity := totalCashQuantity + payment.myProformaDetail.quantity;
			endif;
		endforeach;

		unpaid := (self.quantity - totalCashQuantity);
		if unpaid &lt; 0 then
			unpaid := 0;
		endif;
		return unpaid;
epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
